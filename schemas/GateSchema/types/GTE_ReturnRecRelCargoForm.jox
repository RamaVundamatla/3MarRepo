    <JadeMethod name="doSave" id="31c93a8d-cc62-419c-b2c7-7f141d9a2879">
        <updating/>
        <source>doSave() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 August 2009	cnwml2	Initial creation

*/

vars

begin

	if self.isReceival then	
		self.doTurnaroundAsRelease();
	else
		self.doUnassignTI();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTurnaroundAsRelease" id="a005067e-391a-4de9-9894-b4aee2367fc5">
        <updating/>
        <source>doTurnaroundAsRelease() updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 27 June 2007
//
//----------------------------------------------------------------------

vars
	proxyWLE	: CM_WorkListEntry;
	result		: Integer;
begin
	
	//Be sure the current one is a RECEIPT
	if self.myCurrentWLE = null then
		return;
	endif;
	
	self.myCurrentWLE.fetchLatest();
	
	mousePointer := MousePointer_HourGlass;

	proxyWLE := app.createUpdateProxy(self.myCurrentWLE).CM_WorkListEntry;
	
	while true do
		app.myTrxUA.trxUpdateWLEConvertToRelease(proxyWLE, null, app.myPassport); // cnwrd1 par 22624 3.5.2010
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Turn Around as Release',
												 app.myPassport, 
												 ErrWarnMode_AddUpdate + 
												 ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			// copies errors to this form and shows in err/warnings window			
			self.setAllErrorWarnings(app.myPassport);	
		endif;
		break;
	endwhile;	

	self.unloadForm;
	
epilog
	delete proxyWLE;
	mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doUnassignTI" id="65f69f58-7086-4bfd-80f0-7fd22a306340">
        <updating/>
        <source>doUnassignTI() updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 27 June 2007
//
//----------------------------------------------------------------------

vars
	wleSet : CM_WLESet;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	app.mousePointer := MousePointer_HourGlass;	
	if self.myCurrentWLE = null then
		return;
	endif;
	
	if self.myCurrentWLE.status &lt;&gt; WLE_UNACTIONED then
		return;
	endif;	
	
	create wleSet transient;
	wleSet.add(self.myCurrentWLE);
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateWLEsUnassignTI(wleSet, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.unload;
			break;
		else
			theResult := app.showErrorWarningDialog('Unassign Cargo', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog 
	app.mousePointer := MousePointer_Default;	
	delete wleSet;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setCaption" id="014beaf0-5a66-4650-91f8-342e3ec071e7">
        <updating/>
        <source>setCaption(_caption: String) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 August 2009	cnwml2	Initial creation

*/

vars
	caption : String;
begin
	if self.isReceival then
		caption := "Return Received Cargo";
	else
		caption := "Return Released Cargo";
	endif;
	
	inheritMethod(caption);

epilog

end;</source>
        <Parameter name="_caption" type="String"/>
    </JadeMethod>
