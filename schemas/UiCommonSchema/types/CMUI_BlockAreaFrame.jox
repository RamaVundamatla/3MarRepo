    <JadeMethod name="windowCreated" id="81e050c6-8919-471d-bb83-bb0d8ac23125">
        <controlMethod name="Control::windowCreated"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: CMUI_BlockAreaFrame input; persistCntrl: Control) updating, clientExecution;
//Create the controls needed by this frame
// The drawing controller is not done until init is called.
begin
	inheritMethod(cntrl, persistCntrl);

	if (self.isInPainter) then
		return;
	endif;

	// These MUST be called in the following order
	cntrl.createScrollableFrame();
	cntrl.createScrollingFrame();
	cntrl.createDrawingFrame();

	self.myScrollableFrame.setScrollingFrame(myScrollingFrame);
	self.myScrollableFrame.setHLabelDetails(50, false);
	self.myScrollableFrame.setVLabelDetails(50, false);
	
	self.myDrawingFrame.setScrollableFrame(self.myScrollableFrame);
	self.changeBackColor(self.backColor);
	
	self.bevelInner := Frame.Bevel_None;
	self.bevelOuter := Frame.Bevel_None;
	self.borderStyle := Frame.BorderStyle_None;
	self.boundaryWidth := 0;


end;</source>
        <Parameter name="cntrl" type="CMUI_BlockAreaFrame" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
