    <JadeMethod name="pxyCreateUpdateProxy" id="5e5380f3-aacb-40a9-a5b0-1db1835912f6">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 February 2019	jlgndl1	Initial creation	TFS 43240

*/

vars

	pxyVoyageProcessReport : CM_VoyageProcessReport;
	completedOK : Boolean;

begin

	pxyVoyageProcessReport := inheritMethod();
	
	pxyVoyageProcessReport.myVoyageProcess := self.myVoyageProcess;
	completedOK := true;
	return pxyVoyageProcessReport;

epilog

	if not completedOK then
		delete pxyVoyageProcessReport;
	endif;
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
