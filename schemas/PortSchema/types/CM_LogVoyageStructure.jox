    <JadeMethod name="canUserAccessSelf" id="54ba9e74-b0f6-4358-a209-086720d75e25">
        <source>canUserAccessSelf(_user : CM_User; _failedDAC  :CM_DataAccessController output; _passport: CM_Passport): Boolean;
//--------------------------------------------------
// Created:	19 July 2004 By: cnwgd1
//--------------------------------------------------
vars
	tmpUT : CM_UserTerminal;
	term : CM_Terminal;
begin

	if (not inheritMethod(_user, _failedDAC, _passport)) then
		return false;
	endif;
	
	term := self.myVoyage.myTerminal;
	
	if term = null then
		return false;
	endif;
	
	tmpUT := _passport.myUser.getUserTerminal(term);
	if tmpUT = null then
		return false;
	endif;
		
	return true;
end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_failedDAC" type="CM_DataAccessController" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="872176d0-3e35-49c1-9dff-25e34d6484ad">
        <updating/>
        <source>create() updating;
//----------------------------------------------------------------
//	Created:	13 April 2004	by Jason Chapman  (cnwjc2)
//
// 27 Mar 2013		PJS		PAR # 31232
//----------------------------------------------------------------
vars

begin

	//self.type := LogStructure;   // 31232
	
	if not self.isTransient then	
		//create dicts involved in large updates 
		self.allBOLExtLogOutNotLoaded.instantiate();
		self.allEDIDataBOLOutLog.instantiate();
		self.allLoadedLogLocations.instantiate();
		self.allLocationsByHatchPlaceLot.instantiate();
		self.allLocationsByLotHatchPlace.instantiate();
		self.allLogBOLsInError.instantiate();
		self.allLogLots.instantiate();
		self.allLogNoNumbers.instantiate();
		self.allLogRowDownloads.instantiate();
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="erase" id="3a843dd6-23a0-4f23-bdec-05706625176d">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
// -------------------------------------------
// Created 08 October 2004 by cnwdvb1
// -------------------------------------------
vars

	lc	: CM_LocationsController;

begin

	// DVB There are some invalid locations controllers at NP.
	// Deleting rows here gets around Jade update error during 
	// automatic delete by Jade
	foreach lc in self.allLocationsByHatchPlaceLot do
		lc.erase(_eraseLevel);
	endforeach;	
	inheritMethod(_eraseLevel);


end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findLocation" id="af36740b-9670-404b-af16-75808dfeba12">
        <source>findLocation(_strs: StringArray; _noException: Boolean; _foundLC: CM_LocationsController io; _foundHeight: Integer io);

/*

Purpose:	find a location from a locationID string , fix for par 30436		

Parameters:			

Return Value:		


Date		Who		Reason
09 October 2012	cnwrd1	Initial creation

*/

vars
	tStr : String;
	loc : CM_LocationsController;
	strArray : CnStringArray;
	lotNo : String;
	hatch, 
	place : Integer;
begin

	tStr := _strs[1].trimBlanks;
	if tStr = null then
		return;
	endif;	
	
	strArray := tStr.cnGetTokens('/');
	
	if strArray.size = 3 then
	
		lotNo := strArray[1];
		
		if strArray[2].isInteger then
			hatch := strArray[2].Integer;
		else
			return;
		endif;
		
		place := app.vesselPlaceStrToEnum(strArray[3]);

	elseif strArray.size = 4 then
		lotNo := strArray[2];

		if strArray[3].isInteger then
			hatch := strArray[3].Integer;
		else
			return;
		endif;
		
		place := app.vesselPlaceStrToEnum(strArray[4]);
	else
		return;
	endif;
	
	_foundLC := self.getLogVoyController(lotNo, hatch, place);

epilog

end;</source>
        <Parameter name="_strs" type="StringArray"/>
        <Parameter name="_noException" type="Boolean"/>
        <Parameter name="_foundLC" type="CM_LocationsController" usage="io"/>
        <Parameter name="_foundHeight" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllAssignedSOHLocations" id="99b083eb-e888-410f-a8f6-3ca48fca7417">
        <source>getAllAssignedSOHLocations(_sohLocnSet : CM_SOHLocationSet input;
						   _logLot : CM_LogLot; _operator : CM_Operator);
//--------------------------------------------------------------
//Created: 12 September 2002 By: cnwgd1
//--------------------------------------------------------------
// 23/12/2009	cnwmh5		PAR22069 - 
//--------------------------------------------------------------
vars
	sohLocn : CM_SOHLocation;
	cntrlr : CM_RowController;
begin
	if _sohLocnSet = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null set passed to method. Contact Developer.');
		return;
	endif;
	self.myVoyage.getAllAllocatedSOHLocations(_logLot, _operator, _sohLocnSet);

	foreach cntrlr in self.allLoadedLogLocations do
		foreach sohLocn in cntrlr.allProductLocations do
			if _operator &lt;&gt; null and _operator &lt;&gt; sohLocn.myOperator then
				continue;
			endif;
			// 23/12/2009 cnwmh5 #22069 - Start
			if _logLot &lt;&gt; null and not sohLocn.isLogLotNumberValidForLocation(_logLot.lotNo, self.myVoyage) then  	
				continue;												
			endif;					
			// 23/12/2009 cnwmh5 #22069 - End
			if (not _sohLocnSet.includes(sohLocn)) then
				_sohLocnSet.add(sohLocn);
			endif;
		endforeach;
	endforeach;
	
	
end;</source>
        <Parameter name="_sohLocnSet" type="CM_SOHLocationSet" usage="input"/>
        <Parameter name="_logLot" type="CM_LogLot"/>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="getAllCMIF_LogNNReconDtls" id="99cac40e-e71c-4b69-8b8c-ed5d18fd5474">
        <source>getAllCMIF_LogNNReconDtls(_logLot : CM_LogLot; _operator : CM_Operator;
					 _cmifNNReconDtlSet : CMIF_LogNNReconDtlByProdDict input);
//--------------------------------------------------------------
//Created: 29 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	log			: CM_Log;
	nnLog 		: CM_LogNoNumber;
	sohLocn 	: CM_SOHLocation;
	sohLocnSet	: CM_SOHLocationSet;
	iFaceItem 	: CMIF_LogNNReconDtl;
	tmpResidualLogs : CM_LogByFellDateDict;
	residuePieces : Integer;
	nnVolume, 
	residualVolume: Real;
	lastProduct	: CM_Product;
	ls			: Boolean;
	
begin

	app.cmsBeginLoad(ls);
	foreach nnLog in self.allLogNoNumbers do
		sharedLock(nnLog);
		if (not nnLog.isOnShip) then
			//We only won't onship No Number Logs
			continue;
		endif;
		if nnLog.isRetainedOnVoyage then
			continue;
		endif;
		if _logLot &lt;&gt; null and 
		   _logLot &lt;&gt; nnLog.myReleaseBOL.myExtension.CM_BOLExtLogOut.myLogLot then
		   	continue;
		endif;
		if _operator &lt;&gt; null and
		   _operator &lt;&gt; nnLog.myOperator then
		   	continue;
		endif;

		iFaceItem := _cmifNNReconDtlSet.getAtKey(nnLog.myProduct.CM_ProductLog);
		
		if iFaceItem = null then
			create iFaceItem transient;
			iFaceItem.myOperator := nnLog.myOperator;
			//no protection here because if it's not a log product then we're in deep sh..
			iFaceItem.myProductLog := nnLog.myProduct.CM_ProductLog;
			iFaceItem.myLogVoyageStructure := self;
			
			_cmifNNReconDtlSet.add(iFaceItem);
		endif;
		
		iFaceItem.allNoNumberLogs.add(nnLog);
		iFaceItem.noNumberVolume := iFaceItem.noNumberVolume + nnLog.getMyTotalVolume;

	endforeach;

epilog
	app.cmsEndLoad(ls);
end;</source>
        <Parameter name="_logLot" type="CM_LogLot"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_cmifNNReconDtlSet" type="CMIF_LogNNReconDtlByProdDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllLoadedSOHForLotHatchPl" id="0f807a55-a445-4cd3-9b2d-70d9923cff11">
        <source>getAllLoadedSOHForLotHatchPl(_sohSet : CM_SOHLocationSet input; _logLot : CM_LogLot;
							 _hatch, _place : Integer);
//--------------------------------------------------------------
//Created: Match 2003 By: cnwgd1
//--------------------------------------------------------------
/*

Date		Who		Reason
23 Dec 2010	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	cntrlr : CM_LogVoyageController;
	iter : Iterator;
	sohLocn : CM_SOHLocation;
begin
	if _sohSet = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null Collection passed to method. Contact Developer.');
		return;
	endif;
	
	iter := self.allLocationsByLotHatchPlace.createIterator;

	if _logLot &lt;&gt; null then
		self.allLocationsByLotHatchPlace.startKeyLeq(_logLot.lotNo, _hatch, _place, iter);
	endif;

	while iter.next(cntrlr) do
		if _logLot &lt;&gt; null and cntrlr.myLogLot &lt;&gt; _logLot then
			continue;
		endif;
		if _hatch &lt;&gt; null and cntrlr.hatch &lt;&gt; _hatch then
			continue;
		endif;
		if _place &lt;&gt; null and cntrlr.place &lt;&gt; _place then
			continue;
		endif;				
		foreach sohLocn in cntrlr.allProductLocations do
			if sohLocn.numTIs &gt; 0 then
				_sohSet.add(sohLocn);
			endif;
		endforeach;
	endwhile;

epilog
	delete iter;		// PAR #26678
	
end;</source>
        <Parameter name="_sohSet" type="CM_SOHLocationSet" usage="input"/>
        <Parameter name="_logLot" type="CM_LogLot"/>
        <Parameter name="_hatch" type="Integer"/>
        <Parameter name="_place" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllLoadedSOHLocnsForLot" id="2cfca9ec-2c40-42fa-b4de-2a986de77883">
        <source>getAllLoadedSOHLocnsForLot(_sohSet : CM_SOHLocationSet input; _logLot : CM_LogLot);
//--------------------------------------------------------------
//Created: 11 September 2002 By: cnwgd1
//--------------------------------------------------------------
/*

Date		Who		Reason
23 Dec 2010	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	cntrlr : CM_LogVoyageController;
	iter : Iterator;
	sohLocn : CM_SOHLocation;
begin
	if _sohSet = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null Collection passed to method. Contact Developer.');
		return;
	endif;
	
	iter := self.allLocationsByLotHatchPlace.createIterator;

	if _logLot &lt;&gt; null then
		self.allLocationsByLotHatchPlace.startKeyGtr(_logLot.lotNo, null, null, iter);
	endif;
	
	while iter.next(cntrlr) do
		if _logLot &lt;&gt; null and cntrlr.myLogLot &lt;&gt; _logLot then
			break;
		endif;
		foreach sohLocn in cntrlr.allProductLocations do
			if sohLocn.numTIs &gt; 0 then
				_sohSet.add(sohLocn);
			endif;
		endforeach;
	endwhile;

epilog
	delete iter;		// PAR #26678
end;</source>
        <Parameter name="_sohSet" type="CM_SOHLocationSet" usage="input"/>
        <Parameter name="_logLot" type="CM_LogLot"/>
    </JadeMethod>
    <JadeMethod name="getAllOperators" id="6afd97b4-5fa3-42e4-8cef-599d57fe72ba">
        <source>getAllOperators(_allOperators : CM_OperatorSet input);

vars

	iter	: Iterator;
	logLot	: CM_LogLot;

begin

	iter := self.allLogLots.createIterator;
	while iter.next(logLot) do
		logLot.getAllOperators(_allOperators);
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_allOperators" type="CM_OperatorSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="13eca2ad-e9e8-40fc-b75d-db838622d0c8">
        <source>getDisplayDetails(_short: Boolean): String;
//--------------------------------------------------
// Created:	12 July 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	return self.myVoyage.myTerminal.code &amp; ' ' &amp; inheritMethod(_short);

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoLogVoyOps" id="9f97408a-e6ee-445f-937c-a992d6449d63">
        <source>getExtraInfoLogVoyOps(_array: HugeStringArray input;  _terminalForTerminology : CM_Terminal);
//--------------------------------------------------------------
//Created: 07 August 2002 By: cnwgd1
//
//	par 10009 - _terminalForTerminology added to method signature. needed
//	for teminology. is taken from form so terminology will be consistent 
//	depending on what terminal the form was started from - HJG 10/05/05
//
//--------------------------------------------------------------
vars
	lot : CM_LogLot;
	str	: String;
	firstTime	: Boolean;

begin
	
	// PAR 17358 - HugeStringArray - max length = 2047
	str := "Lots" &amp; Tab;
	firstTime := true;

	foreach lot in self.allLogLots do
		if firstTime then
			firstTime := false;
			str := str &amp; lot.lotNo;
		else
			str := str &amp; '; ' &amp; lot.lotNo;
		endif;
	endforeach;
	
	if str.length &gt; 2047 then
		str := str[1:2047];	// PAR 17358
	endif;
	
	_array.add(str);

end;</source>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
        <Parameter name="_terminalForTerminology" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getLogVoyController" id="7ae196f6-ff9d-4a2e-aded-c8d7882ede91">
        <source>getLogVoyController(_lotNo : String; _hatch, _place : Integer) : CM_LogVoyageController;
//--------------------------------------------------------------
//Created: 22 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	voyCntrl : CM_LogVoyageController;
begin

	voyCntrl := self.allLocationsByLotHatchPlace.getAtKey(_lotNo, _hatch, _place);
	return voyCntrl;
end;</source>
        <Parameter name="_lotNo" type="String"/>
        <Parameter name="_hatch" type="Integer"/>
        <Parameter name="_place" type="Integer"/>
        <ReturnType type="CM_LogVoyageController"/>
    </JadeMethod>
    <JadeMethod name="hasFileBeenLoaded" id="585fef15-93f0-4eb4-a47e-899b1a7d7616">
        <source>hasFileBeenLoaded(_fileName : String) : Boolean;
// ---------------------------------------------------------------------------
// Created:     28 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	ediData		: CM_EDIData;
	ediBolOut	: CM_EDIDataBOLOutLog;
	ls,cast		: Boolean;
	tmpFileName : String;
	length      : Integer;
begin
	//Par 16852 //par 17735 cnwdz2 15/08/08 shorten file base name to the last 30 characters if it is longer than 30 characters.
	tmpFileName	:= app.shortenStringLength(_fileName.fileBaseName(),30);

	app.cmsBeginLoad(ls);

	foreach ediData in self.allEDIDataBOLOutLog do
		if (not CM_EDIDataBOLOutLog.hasInstance(ediData)) then
			continue;
		endif;
		
		//par 17735 cnwdz2 15/08/08	
		if ediData.CM_EDIDataBOLOutLog.fileShortName = tmpFileName then
			return true;
		endif;
	endforeach;

	return false;

epilog
	app.cmsEndLoad(ls);

end;</source>
        <Parameter name="_fileName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isLocationLoadedAssigned" id="bd66aac5-0553-459c-81dc-86d0ff6c0d00">
        <source>isLocationLoadedAssigned(_logCntrl : CM_LogController): Boolean;
//--------------------------------------------------------------
//Created: 10 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	lcSet : CM_LCSet;
	
begin
	if _logCntrl = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null CM_LogController passed to method. Contact Developer.');
		return false;
	endif;
	
	// comented by PAR 21916 Dec 2009
	/*if self.allLoadedLogLocations.includes(_logCntrl) then
		return true;
	endif;*/
	
	create lcSet transient;
	
	self.myVoyage.getAllAllocatedRows(lcSet);
	
	if lcSet.includes(_logCntrl) then
		return true;
	endif;
	
	// comented by PAR 21916 Dec 2009
	/*if _assignIfNot then
		//If we get to here then the location is being loaded for the first time
		//Add it to our loaded collection but return false so warning message can be produced
		self.allLoadedLogLocations.add(_logCntrl);			
	endif;*/

	return false;

epilog
	if lcSet &lt;&gt; null then
		delete lcSet;
	endif;
end;</source>
        <Parameter name="_logCntrl" type="CM_LogController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setAllLogRowDownloads" id="1e083be8-fe79-4e0d-a9f9-005adc519f21">
        <source>setAllLogRowDownloads();

vars
	tmpVoyage	: CM_Voyage;
	stkOrd		: CM_StockOrderHeader;
	alloc		: CM_StockOrderAllocation;
	locnCntrl	: CM_LocationsController;
	logCntrl	: CM_LogController;
	dwnLoad		: CM_LogVoyageRowDownload;
	tmpDict		: CM_LogVoyageRowDownldByLCDict;
	tmpOrderDict: CM_StockOrderByOperOrderNoDict;
begin

	exclusiveLock(self);
	
	tmpVoyage := self.myVoyage;
	tmpOrderDict := tmpVoyage.allOrdersByOperatorOrderNo;
	create tmpDict transient;

	foreach stkOrd in tmpOrderDict do
		foreach alloc in stkOrd.allStockOrderAllocations do
			locnCntrl := alloc.myLocationsController;
			if locnCntrl.isKindOf(CM_LogController) then
				logCntrl := locnCntrl.CM_LogController;
				dwnLoad := self.allLogRowDownloads[logCntrl];
				if dwnLoad = null then
					create dwnLoad persistent;
					dwnLoad.setForCreate(logCntrl, self);
				endif;
				if (not tmpDict.includes(dwnLoad)) then
					tmpDict.add(dwnLoad);
				endif;
			endif;
		endforeach;
	endforeach;
	
	//Delete any dwnLoads that are not longer relevant.
	foreach dwnLoad in self.allLogRowDownloads do
		if (not tmpDict.includes(dwnLoad)) then
			dwnLoad.erase(NORMAL_ERASE);
		endif;
	endforeach;
	
epilog
	delete tmpDict;
end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="9cfe2730-b2ff-46d3-8b84-188a9e1688f0">
        <updating/>
        <source>setForCreate(_proxyVoyage: CM_LogVoyageStructure; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 20 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
begin
	
	inheritMethod(_proxyVoyage, _passport);
	
	self.numHatches := _proxyVoyage.numHatches;
	
end;</source>
        <Parameter name="_proxyVoyage" type="CM_LogVoyageStructure"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="44a39942-423f-4a55-8505-91b4b23f10d2">
        <updating/>
        <source>setForUpdate(_proxyVoyage: CM_LogVoyageStructure; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 20 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	origStatus	: Integer;
	ediData 	: CM_EDIData;
	failedDAC  :CM_DataAccessController;
begin
	if (not self.canUserAccessSelf(null, failedDAC, _passport)) then
		//Do not raise exception as there is nothing the user can do
		return;
	endif;
	origStatus := self.myVoyage.status;

	inheritMethod(_proxyVoyage, _passport);

	if not self.isTransient then	//20 Jan 2014	NDL	Par 33264
		//14 Jan 2014	NDL	Par 33264
		if  self.numHatches &lt;&gt; _proxyVoyage.numHatches and self.myVoyage &lt;&gt; null then
			self.updateObjectEdition(self.myVoyage);
		endif;
	endif;
	self.numHatches := _proxyVoyage.numHatches;

	if _passport.noErrors 
	and origStatus &lt;&gt; self.myVoyage.status
	and self.myVoyage.status = Voyage_Status_LoadComplete then
		// need to validate stock on the voyage
		app.myUtilityUA.utlFixupStockOnHandVoyage(self.myVoyage, null, _passport, null);
	endif;
	
	
end;</source>
        <Parameter name="_proxyVoyage" type="CM_LogVoyageStructure"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyLogVoyage" id="e84c5d39-55da-45b4-b543-22e9765b030e">
        <updating/>
        <source>setProxyLogVoyage(_terminal : CM_Terminal; _numHatches : Integer)updating;
//--------------------------------------------------------------
//Created: 09 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.numHatches := _numHatches;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_numHatches" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="e442cac5-6e98-448c-992e-af335cd1a468">
        <source>validateMe(_passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 10 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	realVoyageStruc	: CM_LogVoyageStructure;
	lot			: CM_LogLot;
begin
	inheritMethod(_passport);
	if self.myVoyage.myVoyageGlobalArrival = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Global Voyage', ETRow_VoyageCode, null);
		app.raiseCMException(Input_required_field_globVoy, ETRow_VoyageCode, null); // cnwdb2	PAR 35364


	endif;

	if self.numHatches = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Log Voyage Hatches', ETRow_NumHatches, null);
		app.raiseCMException(Input_required_field_logVoyHat, ETRow_NumHatches, null); // cnwdb2	PAR 35364
	endif;	
				
	if self.numHatches &gt; 9 then
		app.raiseCMException1(HatchesExceedMax, 'nine', ETRow_NumHatches, null);
	endif;	

	realVoyageStruc := self.pxyGetRealObject();
	
	if realVoyageStruc &lt;&gt; null then
		foreach lot in realVoyageStruc.allLogLots discreteLock do
		//Par12749 Checks are now necessary as lot number has been increased from 10 char length to 20 char length.
			if lot.lotNo.length + self.myVoyage.code.length &gt; 22 then
				app.raiseCMException2(ERR_STRING_TO_LONG, 'combined length of the Voyage Code and Lot No ' &amp; lot.lotNo, '22', null, null);
			endif;
		endforeach;
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
