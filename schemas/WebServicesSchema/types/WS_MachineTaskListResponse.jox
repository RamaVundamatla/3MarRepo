<Class name="WS_MachineTaskListResponse" id="73029e31-e1ab-4aed-8a37-ec1b8e47ef36">
    <superclass name="WS_Response"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <ImplicitInverseRef name="allAvailableTasks" id="6549fed1-2884-479e-a579-4ebc46b47cff">
        <memberTypeInverse/>
        <type name="WS_QueueTaskArray"/>
    </ImplicitInverseRef>
    <JadeMethod name="delete" id="24ae0d49-35bd-4b39-8011-2dbd85f4ef4d">
        <updating/>
        <source>delete() updating;
/*

Date		Who		Reason
23 May 2017	cnwer1	Initial creation TFS

*/

vars

begin
	self.allAvailableTasks.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAllAvailableTasks" id="6e16612f-33a8-4ec2-be4e-6ec2dbf96acf">
        <source>getAllAvailableTasks();
/*

Date		Who		Reason
23 May 2017	cnwer1	Initial creation TFS
20 May 2019	jlgzm1	TFS 44769 Error 4, improve exception handling
*/

vars
	allTasks 	: CM_RTQueueTaskArray; 
	task 		: CM_RTQueueTask;
	wsQueueTask : WS_QueueTask;
	invalidTask : Boolean;
	invalidSession : Boolean;		//04 Nov 2020	NDL	TFS 49917
	qCount, maxQ : Integer;			//06 Nov 2020 	RMAR TFS 50313
	config : CM_RTVehicleConfig; 	
	machine : CM_Machine;
begin
	
	machine := currentSession.myCurrentMachine;
	
	if machine = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject(exception, task, invalidTask); //tfs44769
	on Exception do app.handleDeletedObject(exception, currentSession, invalidSession);	//04 Nov 2020	NDL	TFS 49917 - Logs off during the loop where we are getting the tasks.
	
	create allTasks transient;
	
	machine.getAllAvailableQueuesTasks(allTasks);
			
	qCount := 0;
	config:= machine.myTerminal.getRTVehicleConfigForObject(machine);
	maxQ := config.maxNumberQueueEntries;
	
	foreach task in allTasks discreteLock do
		//tfs44769
		task.edition();
		if invalidTask then
			invalidTask := false;
			continue;
		endif;
		
		create wsQueueTask transient;
		wsQueueTask.setProxyFromObject(task);
		
		if invalidSession then	//04 Nov 2020	NDL	TFS 49917
			break;
		endif;
		
		self.allAvailableTasks.add(wsQueueTask);
		
		// 06 Nov 2020 RMAR TFS 50313
		qCount := qCount+1;
		if maxQ &lt;&gt; null and maxQ &gt; 0 and qCount &gt;= maxQ then
			break;
		endif;

	endforeach;
	
	if invalidSession then	//04 Nov 2020	NDL	TFS 49917
		return;
	endif;
	
	//epr TFS 4836 23/6/17 set the machines current list of tasks
	app.myTrxUA.trxMachineSetTaskStates(machine,allTasks,app.myPassport);
	
epilog
	delete allTasks;
end;</source>
    </JadeMethod>
</Class>
