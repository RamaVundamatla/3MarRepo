    <JadeMethod name="getTotalMilliseconds" id="953b05c0-8ec8-477b-8b6b-703f88778df5">
        <source>getTotalMilliseconds() : Integer;
/*
----------   ----------  --------------------------------------------------
Created:	09 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	return (self.hour * 3600000) + (self.minute * 60000) + (self.second * 1000) + self.milliSecond;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getValidSQLTime" id="56af7f7c-a9dc-4fd6-b2a8-3221894cf1dc">
        <source>getValidSQLTime() : Time;
/*
Purpose:			Check that Time is valid before using
					it in SQL Bulk data extract

Parameters:			

Return Value:		a valid time or a null time

Date			Who		Reason
01 June 2010	conkc1	Initial creation
*/
vars

begin
	if self.isValid = false then
		return null;
	else
		return self;
	endif;
epilog

end;</source>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="getValidSQLTime2005" id="9b1305c4-064f-4d10-9b74-22e818a7775f">
        <source>getValidSQLTime2005() : TimeStamp;
//
//  Converts time to Timestamp for SQL 2005 and below releases
//  PAR 24641
vars
	ts   : TimeStamp;
	time : Time;
begin

	ts.setDate("1900/01/01".Date);
	time := self.getValidSQLTime;
	ts.setTime(time);
	return ts;

end;
</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="roundToNearestMinute" id="01ac2d80-0f86-4436-ac7f-8cb232ca3ff2">
        <updating/>
        <source>roundToNearestMinute():Time updating;

vars

begin
	// This method rounds the time to the nearest minute
	if self.second&gt;30 then
		if self.minute&lt;&gt;59 then
			return (self.hour.String &amp; ":" &amp; (self.Time.minute+"00:01:00".Time.minute).String &amp; ":00").Time;
		else
			return ((self.hour+"01:00:00".Time.hour).String &amp; ":" &amp; ("00:00:00".Time.minute).String &amp; ":00").Time;
		endif;
	else
		return (self.hour.String &amp; ":" &amp; self.Time.minute.String &amp; ":00").Time;
	endif;	
end;</source>
        <ReturnType type="Time"/>
    </JadeMethod>
