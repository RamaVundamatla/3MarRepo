    <JadeMethod name="populateMe" id="a968512f-fdf9-407b-9e6c-b458f8c0d859">
        <updating/>
        <source>populateMe( _parent : CM_JRWVehicleBookingDetailsObj; _reserve : CM_ReserveSelection ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 August 2014	cnwndl1	Initial creation

*/

vars

begin

	self.myReserveSelection := _reserve;
	self.myRequest := _reserve.getRequest();
	
	inheritMethod( _parent, null );

epilog

end;</source>
