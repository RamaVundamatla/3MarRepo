    <JadeMethod name="colourTableRows" id="fd1e1b3d-0f8c-4ce5-a1ff-30b75479958d">
        <source>colourTableRows( _table : CM_DataTable input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2014	cnwndl1	Initial creation	Par 32501

*/

vars

	rowIndex : Integer;
	backColour : Integer;

begin

	if _table = null then
		return;
	endif;
	
	_table.alignFilterHeaderColumns();
	
	foreach rowIndex in 1 to _table.rows do
		if rowIndex &lt;= _table.fixedRows then
			continue;
		endif;
		if rowIndex mod 2 = 0 then
			backColour := self.getRowColour(1,_table);
		else
			backColour := self.getRowColour(2,_table);
		endif;
		_table.accessRow(rowIndex).backColor := backColour;
	endforeach;

epilog

end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
