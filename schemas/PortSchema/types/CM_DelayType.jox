epilog

end;</source>
        <Parameter name="_event" type="CM_EventType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="905d281a-6d15-47f3-b03c-0f8c09a44f11">
        <updating/>
        <source>setProxy(_root: CM_Root; _allDelayTypeGroups : CM_DelayTypeGroupSet; _machineAvailability : CM_MachineAvailability;
			_description : String; _isNotAvailableForEntry, _requiresMachine, _requiresVoyage , _requiresWorkpoint: Boolean; 
			_isOperational : Boolean;  _canScheduleInAdvance : Boolean; _delayTypeOrder : Integer) updating;
/*
----------   ----------  --------------------------------------------------
Created:	31 January 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
02/04/2011 	cnwcs5		CCMS 1132 - add is not available for entry
06/09/2011	cnwcs5		CCMS MES 1033 - add requires workpoint
*/
vars

begin
	self.raiseExceptionIfNotTransient(method);
	
	self.description 			:= _description;
	self.myMachineAvailability 	:= _machineAvailability; // check on this one!!!!
	self.isNotAvailableForEntry	:= _isNotAvailableForEntry;
	self.isOperational 			:= _isOperational;
	self.requiresMachine 		:= _requiresMachine;
	self.requiresVoyage 		:= _requiresVoyage;
	self.requiresWorkpoint		:= _requiresWorkpoint;
	self.delayTypeOrder 		:= _delayTypeOrder;
	self.canScheduleInAdvance 	:= _canScheduleInAdvance;
	self.myRoot 				:= _root;
	
	self.allDelayTypeGroups.clear();
	
	_allDelayTypeGroups.copy(self.allDelayTypeGroups);
end;
</source>
        <Parameter name="_root" type="CM_Root"/>
        <Parameter name="_allDelayTypeGroups" type="CM_DelayTypeGroupSet"/>
        <Parameter name="_machineAvailability" type="CM_MachineAvailability"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_isNotAvailableForEntry" type="Boolean"/>
        <Parameter name="_requiresMachine" type="Boolean"/>
        <Parameter name="_requiresVoyage" type="Boolean"/>
        <Parameter name="_requiresWorkpoint" type="Boolean"/>
        <Parameter name="_isOperational" type="Boolean"/>
        <Parameter name="_canScheduleInAdvance" type="Boolean"/>
        <Parameter name="_delayTypeOrder" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="c0f11223-e052-411a-a2cb-a76e00ec71e4">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 July 2020	jlgndl1	Initial creation	TFS 49670

*/

vars

begin

	if _property = CM_DelayType::allDelays then
		return false;
	endif;
	
	return inheritMethod(_rootClass, _property);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="7e359d18-edd0-48c2-bc69-afd90656777b">
        <source>validateForCreate();
/*
----------   ----------  --------------------------------------------------
Created:	31 January 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
//13/06/2022 navds20 TFS 53760 DuplicateItem not Translatable
----------   ----------  --------------------------------------------------
*/
vars
	tmpDelayType	: CM_DelayType;
begin

	// ************ do i need to check for duplicates? ******************
	tmpDelayType := self.myRoot.allDelayTypes.getAtKey(self.description);
	if tmpDelayType &lt;&gt; null then
		//app.raiseCMException2(DuplicateItem, 'Delay Type', self.description, ETRow_Description, null); //13.06.2022 navds20 53760
		// Delay Type already exists for %1  : Delay_type_already_exists
		app.raiseCMException1(Delay_type_already_exists, self.description, ETRow_Description, null); //13.06.2022 navds20 53760
	endif;
	
	self.validateMe();

end;
</source>
    </JadeMethod>
