    <JadeMethod name="tblDimensions_keyDown" id="28978631-011c-42da-9d18-f65af76f28fb">
        <controlMethod name="CM_BaseTable::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDimensions_keyDown(table: Table input; keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	tmpRow : Integer;
begin
	if keyCode = J_key_Tab then
		tmpRow := table.row;
		if tmpRow = table.rows and 
		   shift = 0 then
			table.tabKey := 0;

			// so that if we move to the tblDimensions we are on the right row
			//table.row := self.tblKeyDistances.fixedRows + 1;

			self.tabNext();
			table.selected := false;
		elseif tmpRow = table.fixedRows + 1 and 
		   shift = 1 then
			table.tabKey := 0;
			self.tabPrior();
			table.selected := false;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblExtRamps_contextMenu" id="2aee5abb-88e2-42f5-afd4-1adcafb9ab79">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblExtRamps_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

	xLeft 	: Real;
	yTop	: Real;
	ramp : CM_DeckItem;
begin

	xLeft := x;
	yTop := y;

	self.mnuRampInspect.visible := app.isAllowedToInspect();
	
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form

	self.mnuRampAudits.visible:=false;
	if table.row &gt; 1 and table.accessRow(table.row) &lt;&gt; null then
		ramp:=table.accessRow(table.row).itemObject.CM_DeckItem;
		self.mnuRampAudits.visible:= ramp.hasAudits; //14 Jan 2021	NDL	TFS 50152
	endif;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuRampAdd.visible := false;
		self.mnuRampDelete.visible := false;
	endif;
	
	self.popupMenu(self.mnuRampContext, xLeft.Integer, yTop.Integer);

	return false;

epilog

end;</source>
