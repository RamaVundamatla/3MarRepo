    <JadeMethod name="validateMoveOverstow" id="e28b4d77-5081-4c38-a1f9-d03aebc8356f">
        <source>validateMoveOverstow(control: CMIF_MoveController input; _moveTI: CM_TrackedItem; _otherLoc: CM_LocationsController input): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2014	cnwndl1	Initial creation	Par 35346
//22 Nov 2016 cnwrs1	Par 37738 TFS 2949 incorrect UPSP rail location being displayed
*/

vars
	maxNumInStack : Integer;
	count : Integer;
	nextWc : CM_WagonController;
	firstTiLocation : CM_LocationsController;
	firstTi : CM_TrackedItem;
	nextTi : CM_TrackedItem;
	firstItemActualLength : Real;
	firstItemLengthInUnits : Integer;
	moveItemActualLength : Real;
	moveItemLengthInUnits : Integer;
	foundA20: Boolean;
	index : Integer;
	stackHeight : Real;
	actualTIs,
	nextActualTIs  : CM_TIArray;
	planqueTIs : CM_TIArray;
begin
	maxNumInStack := self.myWagon.myWagonClass.maxNumInStack;
	
	if maxNumInStack =1 then
		return false;
	else
		//epr par 37324 22/1/16
		create actualTIs transient;
		self.getActualTIsForValidateMove(control, actualTIs);
		create planqueTIs transient;
		self.getPlanQueTIsForValidateMove(control, planqueTIs);
		create nextActualTIs transient;
		
		if _otherLoc = null then
			// checking primary location
			nextWc := self;
			count := self.myWagon.getLengthInUnitsForWagon(_moveTI).Integer - 1;
			stackHeight := self.getStackHeight();
			while count &gt;= 1 do
				count := count - 1;
				nextWc := nextWc.myNextController;
				nextActualTIs.clear;
				if nextWc &lt;&gt; null then
					nextWc.getActualTIsForValidateMove(control,nextActualTIs);
				endif;
				
				if nextWc = null then 
					// not enough controllers...  
					app.raiseCMException2(No_room_start_position, _moveTI.id, self.getFullId, null, _moveTI);
					return false;
				elseif nextWc.CM_WellcarWagonController.myWellcarWellVisit &lt;&gt; self.myWellcarWellVisit then 
					// not enough controllers...  
					// would be astride the articulation point 
					app.raiseCMException(Not_load_cargo_acros_mulit_wel, null, _moveTI);
					return false;
				elseif nextActualTIs.size &lt;&gt; actualTIs.size then
					//stacked to different heights
					if nextActualTIs.includes(_moveTI) and not actualTIs.includes(_moveTI) then
						if nextActualTIs.size &lt;&gt;actualTIs.size + 1 then
							//just moving along the same well
							app.raiseCMException(Not_place_cargo_where_overs_st, null, _moveTI);
							return false;
						endif;
					else
						app.raiseCMException(Not_place_cargo_where_overs_st, null, _moveTI);
						return false;
					endif;					
				elseif stackHeight &lt;&gt; nextWc.getStackHeight then
					//stacked to different heights
					app.raiseCMException(Not_place_cargo_where_overs_st, null, _moveTI);
					return false;
				endif;
				
			endwhile;
		endif;
			
		if actualTIs.isEmpty and
		   planqueTIs.isEmpty then
			return true;
		else
			firstTi := actualTIs.first;
			if firstTi = null then
				firstTi := planqueTIs.first;
				if firstTi.myPrimaryQueuedLocation &lt;&gt; null then
					firstTiLocation := firstTi.myPrimaryQueuedLocation;
				elseif firstTi.myPrimaryPlannedLocation &lt;&gt; null then
					firstTiLocation := firstTi.myPrimaryPlannedLocation;
				endif;
			else
				firstTiLocation := firstTi.myPrimaryActualLocation;
			endif;
			if firstTi &lt;&gt; null then
				firstItemLengthInUnits := self.myWagon.getLengthInUnitsForWagon( firstTi ).Integer;
				firstItemActualLength := self.myWagon.getActualLengthFor( firstTi );
			endif;
			
			if firstTi = _moveTI then
				return true;
			endif;
		
			moveItemActualLength := self.myWagon.getActualLengthFor( _moveTI );
			moveItemLengthInUnits := self.myWagon.getLengthInUnitsForWagon( _moveTI ).Integer;
			if firstTi &lt;&gt; null and moveItemActualLength &lt; firstItemActualLength then
			
				// not allwed to stack small on large
				app.raiseCMException2(Not_stack_smallOnLarge, moveItemActualLength.String, firstItemActualLength.String, null, _moveTI);
				return false;
				
			elseif _otherLoc = null then
				//primary pos should be a twenty foot position for well wagons...
				index := self.myWellcarWellVisit.allLocationsControllersArray.indexOf(self);
				if not index.isOdd then
					app.raiseCMException(Inval_start_posit_this_cargo_n, null, _moveTI);
					return false;
				endif;
				
				if firstTi &lt;&gt; null and not firstTi.isRRP then
					if firstTiLocation &lt;&gt; self then
						// trying to stagger stack the containers  
						app.raiseCMException(Not_stagger_stack_cargo, null, _moveTI);
						return false;
					endif;
				endif;
				
				if firstItemLengthInUnits = 2 and	// bottom one is a 20
				   moveItemLengthInUnits &lt;&gt; 2 then	// top one is bigger
					// another way of trying to stagger stack the containers  i.e. a 40(or larger) over a 20 then a 40..
					// But 40 over 2 x 20s is allowed.
					nextWc := self;
					while true do
						nextWc := nextWc.myNextController.CM_WellcarWagonController;
						if nextWc = null or nextWc.CM_WellcarWagonController.myWellcarWellVisit &lt;&gt; self.myWellcarWellVisit then
							break;
						endif;
						nextActualTIs.clear;
						if nextWc &lt;&gt; null then
							nextWc.getActualTIsForValidateMove(control, nextActualTIs);
							nextWc.getPlanQueTIsForValidateMove(control, nextActualTIs);
						endif;
						nextTi := nextActualTIs.first;
						if nextTi &lt;&gt; firstTi then
							if nextTi &lt;&gt; null and self.myWagon.getLengthInUnitsForWagon( nextTi ) = 2 then
								foundA20 := true;
								break;
							else
								app.raiseCMException(Not_stagger_stack_cargo, null, _moveTI);
								return false;  // second item is not a 20
							endif;
						endif;
					endwhile;
					if not foundA20 then
						// stacking over a gap
						app.raiseCMException1(Not_stack_overgap, _moveTI.id, null, _moveTI);
						return false;
					endif;
				endif;
			endif;
		endif;
		return true;
	endif;
	
	return inheritMethod( control,_moveTI, _otherLoc);
	
epilog
	delete actualTIs;
	delete planqueTIs;
	delete nextActualTIs;
end;</source>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_moveTI" type="CM_TrackedItem"/>
        <Parameter name="_otherLoc" type="CM_LocationsController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateMoveTo" id="2c7b77a2-9099-43f3-8d43-f97e455ef9f6">
        <source>validateMoveTo(control: CMIF_MoveController input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 December 2014	cnwndl1	Initial creation	Par 35346

*/

vars

	index : Integer;
	moveTI : CM_TrackedItem;
	nextWc : CM_WagonController;
	count : Integer;
	wellId : String;
	actualTIs,
	nextActualTIs  : CM_TIArray;
begin

	if control.myToPrimaryLocation = self then
		index := self.myWellcarWellVisit.allLocationsControllersArray.indexOf(self);
		moveTI := control.myTrackedItem;
		if not index.isOdd then
			//must start on a 20 foot location not a 10 foot one.
			app.raiseCMException(Inval_start_posit_this_cargo_n, null, moveTI);
		endif;
		
		//epr par 37324 22/1/16
		create actualTIs transient;
		self.getActualTIsForValidateMove(control,actualTIs);
		
		create nextActualTIs transient;
		
		
		nextWc := self;
		wellId := self.getWellId;
		count := self.myWagon.getLengthInUnitsForWagon(moveTI).Integer - 1;
		while count &gt;= 1 do
			count := count - 1;
			nextWc := nextWc.myNextController;
			nextActualTIs.clear;
			if nextWc &lt;&gt; null then
				nextWc.getActualTIsForValidateMove(control,nextActualTIs);
			endif;
			if nextWc = null then
				//no room  
				app.raiseCMException2(No_room_start_position, moveTI.id, self.getFullId, null, moveTI);
				return;
			elseif nextActualTIs.size &lt;&gt; actualTIs.size then
				//stacked to different heights 
				if nextActualTIs.includes(moveTI) and not actualTIs.includes(moveTI) then
					//just moving along the same well
					if nextActualTIs.size &lt;&gt; actualTIs.size + 1 then
						app.raiseCMException(Not_place_cargo_where_overs_st, null, moveTI);
						return;
					endif;
				else
					app.raiseCMException(Not_place_cargo_where_overs_st, null, moveTI);
					return;
				endif;

			elseif nextWc.getWellId &lt;&gt; wellId then
				// would be astride the articulation point 
				app.raiseCMException(Not_load_cargo_acros_mulit_wel, null, moveTI);
				return;
			endif;
		endwhile;
		
	endif;
			
	inheritMethod(control);

epilog
		delete actualTIs;
	delete nextActualTIs;
end;</source>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
</Class>
