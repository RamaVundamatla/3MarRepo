    <JadeMethod name="setComboValues" id="87933034-3d35-421e-8f6c-fff8ebfad918">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields


*/

vars

begin

	_combo.clear;
	_combo.addItem(INV_VOL_BASED_PERIOD_STR);
	_combo.addItem(INV_VOL_BASED_VOYAGE_STR);
	
	if CM_QIntArrayLookupEqual.hasInstance(_queryOperator) then
		_combo.text := app.accumTypeIntToStr(_queryOperator.CM_QIntArrayLookupEqual.searchValue);
	elseif CM_QIntArrayLookupNotEqual.hasInstance(_queryOperator) then
		_combo.text := app.accumTypeIntToStr(_queryOperator.CM_QIntArrayLookupNotEqual.searchValue);
	endif;
	
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="3d6e7b5c-2c69-415b-81e3-90f1b7d4f960">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields

*/

vars
	intArray	: IntegerArray;
	idx,int	: Integer;
	cmString		: CM_String;
begin

	_tbl.purgeTableObjects();
	_tbl.clear;
	_tbl.rows := _tbl.fixedRows;
	
	create intArray transient;
	
	intArray.add(INV_VOL_BASED_PERIOD);
	intArray.add(INV_VOL_BASED_VOYAGE);
	
	foreach int in intArray do
		create cmString transient;
		cmString.string := self.translateToDisplayValue( int );
		
		if _operator &lt;&gt; null then
			idx := _tbl.addItem(1.String &amp; Tab &amp; cmString.string);
		else
			idx := _tbl.addItem(0.String &amp; Tab &amp; cmString.string);	
		endif;
		_tbl.accessRow(idx).itemObject := cmString;
		_tbl.row := idx;
		_tbl.change(_tbl);	
	endforeach;

epilog
	delete intArray;
end;

</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="a5ea21b8-11ef-4413-8678-40f785fedb9e">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields


*/

vars
	str		: String;
	numRows,
	idx		: Integer;
	ia		: IntegerArray;

begin

	create ia transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			str := _tbl.accessCell(idx, 2).text;
			ia.add(self.translateToSearchValue(str).Integer);
		endif;
	endforeach;
	
	_op.setSearchValue(ia);

epilog
	delete ia;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="dce8c114-c56d-410e-8e32-5548faf61199">
        <source>translateStringToSearchValue(_value: Any; _criteriaLine: CM_SelectorCriteriaLine): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields


*/

vars
	accumType	: Integer;
	
begin
	if _value.String.isInteger then
		return _value;
	endif;
	
	accumType := app.accumTypeStrToInt(_value.String);
	
	return accumType;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="82c01c23-470e-4c52-94b6-63750ba8c318">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields

*/

vars
	returnVal,
	categoryStr : String;
	intCategory : Integer;
	
begin
	if _value.String.isInteger then
		return app.accumTypeIntToStr(_value.Integer);
	elseif _value.isKindOf(IntegerArray) then
		foreach intCategory in _value.IntegerArray do
			categoryStr := app.accumTypeIntToStr(intCategory);
			if categoryStr &lt;&gt; null then
				if returnVal = null then
					returnVal := categoryStr;
				else
					returnVal := returnVal &amp; ", " &amp; categoryStr;
				endif;
			endif;
		endforeach;
	endif;
	
	return returnVal;
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="aa5568b5-6eef-4558-9d3f-7159f32b014e">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields

*/

vars
	
begin
	if _value.isKindOf(IntegerArray) then
		return _value;
	elseif _value.isKindOf(Integer) then	
		return _value.String;
	endif;
	
	return translateStringToSearchValue( _value.String, null).Integer;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
