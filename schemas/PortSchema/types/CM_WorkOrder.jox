    <JadeMethod name="allCashReceiptsAre" id="d6f611d7-152b-4651-9064-b0ceec52be50">
        <source>allCashReceiptsAre( _paymentStatus : Integer ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 February 2019	jlgndl1	Initial creation	TFS 43058

*/

vars

	cashRec : CM_CashReceipt;

begin

	foreach cashRec in self.allCashReceipts do	
		if cashRec.paymentStatus = _paymentStatus then
			continue;
		endif;
		return false;
	endforeach;
	
	return true;

epilog

end;</source>
        <Parameter name="_paymentStatus" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="allowAttachDocsToPrintKiosk" id="b86e93a3-42a0-4671-8fa3-a6da4bd59d5a">
        <source>allowAttachDocsToPrintKiosk(): Boolean;
/*

Purpose:			
	54546.030 Print Documents at Kiosk
Acceptance Criteria:
a. User is able to mark any of the attached Documents on a Receive or Release Cargo Work Order as to be printed at the Kiosk – either for the Gate In or for the Gate Out of the Truck.
b. By Default the option is turned off, but the user is able to update it at any point but only if the Work Order is not Completed yet    .
Parameters:			

Return Value:		

Date		Who		Reason
22 Feb 2023	navhl20	ChangeRequest 56625:[56517] EUP - Print Documents at Kiosk
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
*/

vars
	woDtl : CM_WorkOrderDtl;
begin
	
	foreach woDtl in self.allWoDtls discreteLock do 
		if woDtl.isKindOf(CM_WodReceive) or woDtl.isKindOf(CM_WodRelease) then
			return true;
		endif;
	endforeach;
	
	return false;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
