    <JadeMethod name="setSearchValue" id="3ffee6db-e25f-4ace-a450-949b9e83f156">
        <updating/>
        <source>setSearchValue(_value: IntegerArray) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
08 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if _value &lt;&gt; null and _value.size &gt; 1 then
		self.fromNumDays 	:= _value[1];
		self.toNumDays		:= _value[2];
	endif;


epilog

end;</source>
        <Parameter name="_value" type="IntegerArray"/>
    </JadeMethod>
