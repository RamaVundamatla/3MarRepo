    </JadeMethod>
    <JadeMethod name="setForCreateSubClasses" id="d6adba87-580e-4a76-a078-f48b206c0f42">
        <updating/>
        <source>setForCreateSubClasses(_ti: CM_Container; _passport : CM_Passport input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     01 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 04/12/2009	cnwdap1		CCMS MES 1007 move reefer properties to CM_TrackedItem
// ---------------------------------------------------------------------------
vars
	realCOU : CM_ClipOnUnit;
	realGenerator : CM_Generator;
	strs	:	CM_Strings;
	txn : CM_TITransaction;
	txnParams : CMIF_ConnectParams;
	aCOU: CM_ClipOnUnit;
begin

	inheritMethod(_ti, _passport);

	self.changeISOType(_ti.isoType, null, _passport);
	self.availabilityGrade := _ti.availabilityGrade;
	self.dairyBoardAvailable := _ti.dairyBoardAvailable;
	self.dairyBoardChargeable := _ti.dairyBoardChargeable;
	self.dairyInspectDT := _ti.dairyInspectDT;
	self.hideLined := _ti.hideLined;
	self.hideLinedDT := _ti.hideLinedDT;
	self.isoType := _ti.isoType;
	self.setPreTripDT(_ti.getPreTripDT);
	self.probedDT := _ti.probedDT;
	self.repackedDT := _ti.repackedDT;
	self.sweptDT := _ti.sweptDT;
	self.unpackedDT := _ti.unpackedDT;
	self.washDT := _ti.washDT;
	self.isOverDimensions := _ti.isOverDimensions;					//+cnwml2 PAR25277
	self.overHeight		:= _ti.overHeight;		// adm 220909 Par 20434 add oversize fields
	self.overLengthFront := _ti.overLengthFront;
	self.overLengthRear	:= _ti.overLengthRear;
	self.overWidthLeft	:= _ti.overWidthLeft;
	self.overWidthRight := _ti.overWidthRight;

	// CCMS 1029 from here
	self.offsiteCleaned := _ti.offsiteCleaned;
	if self.offsiteCleaned then
		create txnParams transient;
		txnParams.type := TRANS_TYPE_EDIT;
		txnParams.myTrackedItem := self;
		txn := self.createTransaction(txnParams, _passport);	
	
		strs := txn.CM_Edit.fieldsValues;
		strs.add(CM_Container::offsiteCleaned.name &amp; " =&gt; "&amp; self.offsiteCleaned.String);
	endif;

	self.offsitePreTrip := _ti.offsitePreTrip;
	if self.offsitePreTrip then
		if txnParams = null then
			create txnParams transient;
		endif;
		txnParams.type := TRANS_TYPE_EDIT;
		txnParams.myTrackedItem := self;
		txn := self.createTransaction(txnParams, _passport);	
	
		strs := txn.CM_Edit.fieldsValues;
		strs.add("PreTripped Offsite");
	endif;
	// CCMS 1029 to here
epilog
	if txnParams &lt;&gt; null then
		delete txnParams;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_Container"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForRailHandHeld" id="e3c878c9-6a99-419b-8137-528cbeb2911a">
        <updating/>
        <source>setForRailHandHeld(_pxyTI: CM_Container)  updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
07 June 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	userStr : String;
	isoType,
	vSealNumCust,
	vSealNum,
	vSealNumShipper: String;
	txnParams : CMIF_TITransactionController;
	trans : CM_Edit;
begin
	inheritMethod(_pxyTI);
	
	create txnParams transient;
	txnParams.userId := userStr;
	txnParams.dateTime := app.serverTimestampAtTrxStart;
	txnParams.noCharge := false; //TFS 3844 changed to false
	txnParams.type := TRANS_TYPE_EDIT;
	if (not self.checkSameISOType(_pxyTI)) then
		// Par 8032 Need to be able to change ISO type from hand held.
		isoType := self.CM_Container.isoType;	
		self.changeISOType(_pxyTI.CM_Container.isoType, null,  app.myPassport); 			
//				realTI.setISOType(ti.CM_Container.isoType);
		
		//------------------
		//Create the edited transaction
		//------------------
		if trans = null then
			trans := self.createTransaction(txnParams, app.myPassport).CM_Edit;
		endif;
		trans.fieldsValues.add(CM_Container::isoType.name&amp;' '&amp;isoType&amp;' =&gt; '&amp; self.isoType);
	endif;
	
	if self.getSealNumCustoms &lt;&gt; _pxyTI.getSealNumCustoms then
		vSealNumCust:=self.getSealNumCustoms;
		//self.sealNumCustoms:=_pxyTI.getSealNumCustoms;
		self.setCustomsSealNums(_pxyTI);
		if trans = null then
			trans := self.createTransaction(txnParams, app.myPassport).CM_Edit;
		endif;
		//trans.fieldsValues.add(CM_Container::sealNumCustoms.name&amp;' '&amp;vSealNumCust&amp;' =&gt; '&amp; self.getSealNumCustoms);
		trans.fieldsValues.add( SealNumCustoms &amp;' '&amp;vSealNumCust&amp;' =&gt; '&amp; self.getSealNumCustoms);	//17 Sep 2010	NDL	Par 25608
	endif;
	
	//15 Sep 2010	NDL	Par 25608 - change from direct ref to using method 'getSealNum'
	if self.getSealNum &lt;&gt; _pxyTI.getSealNum then
		vSealNum:=self.getSealNum;
		//self.sealNum:=_pxyTI.getSealNum;
		self.setSealNumOperators(_pxyTI.getSealNum);
		if trans = null then
			trans := self.createTransaction(txnParams, app.myPassport).CM_Edit;
		endif;
		//trans.fieldsValues.add(CM_Container::sealNum.name&amp;' '&amp;vSealNum&amp;' =&gt; '&amp; self.getSealNum);
		trans.fieldsValues.add( SealNum &amp;' '&amp;vSealNum&amp;' =&gt; '&amp; self.getSealNum);	//17 Sep 2010	NDL	Par 25608
	endif;
	
	//15 Sep 2010	NDL	Par 25608 - change from direct ref to using method 'getSealNumShipper'
	if self.getSealNumShipper &lt;&gt; _pxyTI.getSealNumShipper then
		vSealNumShipper:=self.getSealNumShipper;
		//self.sealNumShippers:=_pxyTI.getSealNumShipper;
		self.setSealNumShippers( _pxyTI.getSealNumShipper );
		if trans = null then
			trans := self.createTransaction(txnParams, app.myPassport).CM_Edit;
		endif;
		//trans.fieldsValues.add(CM_Container::sealNumShippers.name&amp;' '&amp;vSealNumShipper&amp;' =&gt; '&amp; self.getSealNumShipper);
		trans.fieldsValues.add( SealNumShippers &amp;' '&amp;vSealNumShipper&amp;' =&gt; '&amp; self.getSealNumShipper);	//17 Sep 2010	NDL	Par 25608
	endif;
	//if realTI.
	


epilog
	delete txnParams;
end;</source>
        <Parameter name="_pxyTI" type="CM_Container"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateActual" id="50542a75-232a-4b11-8819-d24cfbc519ef">
        <updating/>
        <source>setForUpdateActual(_pxyTI: CM_Container; _tiUpdateCntrlr : CMIF_TIUpdateController input; _passport : CM_Passport input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     01 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07/12/2009	cnwdap1		CCMS MES 1007 Moved reefer properties up to CM_TrackedItem level
// 15/04/2014	cnwdap1		PAR #33822 Don't udpate allowableTimeOffPower here, it's done at the superclass level!
//22 Feb 2016	cnwrs1	Par 37568 TFS 1177 CCMS 2158 - EDI User defined  field expansion
// 04/11/2019	jlgdap1	TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
// ---------------------------------------------------------------------------
vars
	strs				: CM_Strings;
//	sealTxnController	: CMIF_SealTransController;
	txnObj 				: CM_TITransaction;
	txnParams			: CMIF_TITransactionController;
	createStorage		: Boolean;
	
begin
	self.availabilityGrade		:= _pxyTI.availabilityGrade;
	//self.setAllowableTimeOffPower(_pxyTI.getAllowableTimeOffPower);			// PAR #33822

	self.dairyBoardAvailable 	:= _pxyTI.dairyBoardAvailable;
	self.dairyBoardChargeable 	:= _pxyTI.dairyBoardChargeable;
	self.dairyInspectDT 		:= _pxyTI.dairyInspectDT;
	self.hideLined 			:= _pxyTI.hideLined;
	self.hideLinedDT 		:= _pxyTI.hideLinedDT;

	//change the isoType before connecting cou as cou validated based on isoType
	if self.isoType &lt;&gt; _pxyTI.isoType then
		self.weightTare := _pxyTI.weightTare;   // Needed for check in changeISOType - Par  32931
		self.changeISOType(_pxyTI.isoType, _tiUpdateCntrlr, app.myPassport);
		self.isoType 	:= _pxyTI.isoType;
	endif;
	self.probedDT 		:= _pxyTI.probedDT;
	self.repackedDT 	:= _pxyTI.repackedDT;
	self.sweptDT 		:= _pxyTI.sweptDT;
	self.unpackedDT 	:= _pxyTI.unpackedDT;
	self.washDT 		:= _pxyTI.washDT;
	// CCMS 1029 from here
	if self.offsiteCleaned &lt;&gt; _pxyTI.offsiteCleaned then
		create txnParams transient;
		txnParams.type := TRANS_TYPE_EDIT;
		txnParams.myTrackedItem := self;
		txnObj := self.createTransaction(txnParams, _passport);
		
		strs := txnObj.CM_Edit.fieldsValues;
		strs.add(CM_Container::offsiteCleaned.name &amp; " =&gt; " &amp; self.offsiteCleaned.String);
	endif;
	
	self.offsiteCleaned := _pxyTI.offsiteCleaned;

	if self.offsitePreTrip &lt;&gt; _pxyTI.offsitePreTrip then
		if txnParams = null then
			create txnParams transient;
		endif;
		txnParams.type := TRANS_TYPE_EDIT;
		txnParams.myTrackedItem := self;
		txnObj := self.createTransaction(txnParams, _passport);
		
		strs := txnObj.CM_Edit.fieldsValues;
		strs.add(CM_Container::offsiteCleaned.name &amp; " =&gt; " &amp; self.offsitePreTrip.String);
	endif;
	
	self.offsitePreTrip := _pxyTI.offsitePreTrip;


	self.overHeight		:= _pxyTI.overHeight;	// adm 240909 Par 20434
	self.overLengthFront := _pxyTI.overLengthFront;
	self.overLengthRear	:= _pxyTI.overLengthRear;
	self.overWidthLeft	:= _pxyTI.overWidthLeft;
	self.overWidthRight	:= _pxyTI.overWidthRight;
	
	// if we have any over dimensions measurements, but the over dimensions flag has been unset, reset it
	if self.overHeight &lt;&gt; null or self.overLengthFront &lt;&gt; null or self.overLengthRear &lt;&gt; null or self.overWidthRight &lt;&gt; null or self.overWidthLeft &lt;&gt; null then
		self.isOverDimensions := true;
	endif;

	inheritMethod(_pxyTI, _tiUpdateCntrlr, _passport);
	
	//07 Sep 2015	NDL	Par 36272-
	self.length := 0;
	self.width := 0;
	self.height := 0;
	
	self.setDoorsDirn(_pxyTI.doorsDirn);			// TFS 46405
	
epilog
//	delete sealTxnController;
	delete txnParams;
end;</source>
        <access>protected</access>
        <Parameter name="_pxyTI" type="CM_Container"/>
        <Parameter name="_tiUpdateCntrlr" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromDeliveryRequest" id="0d1f0ae3-aff8-46c3-b153-43a6c2c5985b">
        <updating/>
        <source>setFromDeliveryRequest(pDelvReq : CM_DeliveryRequest; _theTerminal : CM_Terminal) updating;
// ---------------------------------------------------------------------------
// Created:     28 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	term	: CM_Terminal;
	theVoyage : CM_Voyage;
begin

	self.raiseExceptionIfNotTransient(method);

	term	:= _theTerminal;

	self.myTerminal := _theTerminal;
	self.setCommodity(term.getDefaultEmptyCommodity());
	self.contentsStatus	:= TI_CONTENTS_STATUS_EMPTY;
	self.imexStatus 	:= TI_IMEX_STATUS_STORAGE;
	self.isoType 		:= pDelvReq.isoType;
	self.setOperatorCode(pDelvReq.operatorCode, null);
	self.consignee		:= pDelvReq.consignee;
	
	if pDelvReq.voyageCode &lt;&gt; null then
		theVoyage := term.lookupVoyage(pDelvReq.voyageCode, null, false);
		if theVoyage = null then
			app.raiseCMException2(ERR_VOYAGE_CODE, pDelvReq.voyageCode, app.getErrorString(Voyage), ETRow_Voyage, null);
			return;
		endif;
		self.setMyVoyage(theVoyage, null);
		self.voyageCode := theVoyage.code;
	//	self.voyageCode := pDelvReq.voyageCode;
	endif;
		
	if pDelvReq.clean then	//Set washedDT to now, that way it will be a clean self
		self.washDT := app.serverTimestampAtTrxStart;
	endif;
	
	//cnwrd1 par 26633 17.12.2010
	//CM_YardDeliveryRequest.mtGrade depreciated now use allAvailabilityGrades - assuming this mthod is not in use.
	/*
	if pDelvReq.isKindOf(CM_YardDeliveryRequest) then
		self.availabilityGrade := pDelvReq.CM_YardDeliveryRequest.mtGrade;
	endif;
	*/

end;</source>
        <Parameter name="pDelvReq" type="CM_DeliveryRequest"/>
        <Parameter name="_theTerminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setGeneratorForUpdate" id="b1131c59-4ba6-4f71-9918-0fb232d5cc3c">
        <updating/>
        <source>setGeneratorForUpdate(pProxyGenerator : CM_Generator; originalState : Integer;
		_tiUpdateCntrlr : CMIF_TIUpdateController input; _passport : CM_Passport input) updating, protected;
// ---------------------------------------------------------------------------
// Created:      18 July 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	prxyGenerator : CM_Generator;
	origGenerator : CM_Generator;
	realGenerator : CM_Generator;
	aGenerator : CM_Generator;
	expectedEdition	: Integer;
	
begin
	
	inheritMethod(pProxyGenerator, originalState, _tiUpdateCntrlr, _passport);
	
/*	if self.getGenerator = null and pProxyGenerator = null then
		// no work to do
		return;
	endif;

	if self.isTransient and
	   self.getGenerator = null and
	   pProxyGenerator &lt;&gt; null then // AKB2002JAN added
		// i have not got a generator so attach this proxy one and get out, probably part of a container update
		prxyGenerator := pProxyGenerator;
		self.attachGenerator(prxyGenerator, _passport);
		return;
	endif;

	if self.getGenerator &lt;&gt; null then
		origGenerator := self.getGenerator;
		if originalState = TI_STATE_NOTIFIED then
			//Prenoted Items: Just update the prenote generator with the proxy data
			realGenerator := origGenerator;
			expectedEdition := realGenerator.edition;
		endif;
	endif;

	//We did have a generator attached and now we don't
	if pProxyGenerator = null then
		// We must detach the original generator and erase it (if not onsite)
		if origGenerator &lt;&gt; null then
			exclusiveLock(origGenerator);
			self.detachGenerator(_passport);		
			if originalState = TI_STATE_NOTIFIED then
				origGenerator.erase(NORMAL_ERASE);
			else
				// RJS TODO - just move origGenerator to default location
			endif;
		endif;
		return;
	endif;

	if pProxyGenerator.cargoType &lt;&gt; TI_CargoType_Generator then
		app.raiseCMException(ERR_TI_NOT_GENERATOR, "", null);
		return;
	endif;

	if realGenerator = null then
		if pProxyGenerator.isTransient then
			//See if the generator is part of a proxy / persistent pair
			pProxyGenerator.pxyGetRealObjectAndEdition(realGenerator, expectedEdition);
			if realGenerator = null then
				//Try a lookup
				realGenerator := self.myTerminal.lookupTrackedItem(pProxyGenerator.id, pProxyGenerator.cargoType, originalState, null, false).CM_Generator;
			endif;
		else
			app.raiseCMException1(NotAProxyObject,"Generator " &amp; pProxyGenerator.id, "", null);
		endif;
	endif;

	if realGenerator = null then
		//Must create a new generator, based on the proxy
		if originalState = TI_STATE_NOTIFIED then
			aGenerator := pProxyGenerator;
			aGenerator.setPropertyValue("isValid", true);
			realGenerator := self.myTerminal.createTrackedItem(pProxyGenerator, _passport).CM_Generator;
			self.attachGenerator(realGenerator, _passport);
		else
			app.raiseCMException1(ProxyMgrCannotLocateReal, CM_TrackedItem.name, null, null);
			return;
		endif;

	else
		if realGenerator &lt;&gt; null then // AKB2002JAN added
			exclusiveLock(realGenerator);
			if realGenerator = origGenerator then
				//Check that it hasn't been updated meantime
				//if app.noErrors and realCOU.edition &lt;&gt; expectedEdition then
				//	app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Tracked Item COU', null, null);
				//	return;
				//endif;
			endif;

/*	
			if realCOU.myReefer &lt;&gt; null then // AKB2002JAN added
				if realCOU.myReefer &lt;&gt; self then
					// COU is already attached to another container
					app.raiseCMException2(ERR_DUPLICATE_CHILD, 'COU ' &amp; realCOU.id, 'Container ' &amp; realCOU.CM_ClipOnUnit.myReefer.id, null, null);
					return;
				endif;
			endif;

			if realGenerator &lt;&gt; origGenerator then
				// the original COU has been replaced with another COU
				//Detach the old COU and attach the new COU
				//OR there was no original COU to begin with
				if origGenerator &lt;&gt; null then
					exclusiveLock(origGenerator);
					self.detachGenerator(_passport);		//Works even if origGenerator is null			
				endif;
				// RJS TODO - need to move orig to default location
				self.attachGenerator(realGenerator, _passport);
			endif;
		endif;
		aGenerator := pProxyGenerator;
		aGenerator.setPropertyValue("isValid", true);
		realGenerator.setFromPxy(pProxyGenerator, _tiUpdateCntrlr, _passport);
	endif;
	*/
end;</source>
        <access>protected</access>
        <Parameter name="pProxyGenerator" type="CM_Generator"/>
        <Parameter name="originalState" type="Integer"/>
        <Parameter name="_tiUpdateCntrlr" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setHideLinedDetails" id="b58a726a-9c88-4d84-9c77-f3d903d37095">
        <updating/>
        <source>setHideLinedDetails() updating;
// ---------------------------------------------------------------------------
// Created:     21 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	trans	: CM_TITransaction;

begin

	//trans := self.getLastTransOfType(TRANS_TYPE_HIDE);
	trans := getLastTransOfClass(CM_HideLined);	//22 Mar 2016	NDL	TFS 1694
	
	if trans = null then
		self.hideLined	 := false;
		self.hideLinedDT := null;
	else
		self.hideLined	 := true;
		self.hideLinedDT := trans.dateTime;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setISOType" id="ef5a59b8-c483-4e0e-b6d7-3bf932ebc4ff">
        <updating/>
        <source>setISOType(_value: String) updating;
vars

begin

	if self.isoType &lt;&gt; _value then
		self.isoType := _value;
	endif;
	
end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setMeasurementValue" id="df3c306d-2c11-418a-a0bc-e26b1a537ee3">
        <updating/>
        <source>setMeasurementValue(_entRowName: String; _value: Decimal) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/02/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars

begin
	if _entRowName = ETRow_OverLengthBack     then
		self.setPropertyValue(CM_Container::overLengthRear.name, _value);
		self.setPropertyValue(CM_Container::length.name, self.overLengthRear + self.overLengthFront);
	elseif _entRowName = ETRow_OverLengthFront then
		self.setPropertyValue(CM_Container::overLengthFront.name, _value);
		self.setPropertyValue(CM_Container::length.name, self.overLengthRear + self.overLengthFront);
	elseif _entRowName = ETRow_OverWidthLeft then
		self.setPropertyValue(CM_Container::overWidthLeft.name, _value);
		self.setPropertyValue(CM_Container::width.name, self.overWidthLeft + self.overWidthRight);
	elseif _entRowName = ETRow_OverWidthRight then
		self.setPropertyValue(CM_Container::overWidthRight.name, _value);
		self.setPropertyValue(CM_Container::width.name, self.overWidthLeft + self.overWidthRight);
	elseif _entRowName = ETRow_OverHeight then
		self.setPropertyValue(CM_Container::overHeight.name, _value);
		self.setPropertyValue(CM_Container::height.name, self.overHeight);
	else
		inheritMethod(_entRowName, _value);
	endif;

epilog

end;</source>
        <Parameter name="_entRowName" type="String"/>
        <Parameter name="_value" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setMyTiMaster" id="d434c12d-d8b1-4b95-82bf-3bbd00965ab8">
        <updating/>
        <source>setMyTiMaster() updating;
/* ---------------------------------------------------------------------------
Created:     10 September 2009 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	tiMaster	: CM_TIMaster;
	
begin
	tiMaster := app.myRoot.findTIMasterContainerByID(self.id);
	
	if self.myTiMaster &lt;&gt; tiMaster then	//06 Jul 2017	NDL TFS 5238
		self.myTiMaster := tiMaster;	
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyVGMDetails" id="93518a72-5404-4a9f-8c2f-74a6d87ad18f">
        <updating/>
        <source>setMyVGMDetails(	_certifiedName, _authorisedName : String;
					_authSig, _commsType, _docDetails, _ediTrans, _email, _mail, _phone, _fax, _telephone : String;
					_docDT, _deterDT : TimeStamp;
					_tiUpdateCntrlr : CMIF_TIUpdateController input	) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/06/2017	cnwdap1		Initial creation TFS 4492 SNO VERMAS Changes
//	21/02/2018	jlgns1		Bug 37011: PNL - VGM weigh transactions - doubles
vars
	tmpTransType : Integer;			//Bug 37011
begin
	tmpTransType := TRANS_TYPE_NULL;//Bug 37011
	
	if not app.getMyUser.canDo(self.myTerminal, PmCargoVGMMaint) then //epr TFS 2011
		return;
	endif;
	if _certifiedName = null and _authorisedName = null and _authSig = null 
	and _commsType = null and _docDetails = null and _ediTrans = null and _email = null 
	and _mail = null and _phone = null and _fax = null and _telephone = null 
	and _docDT = null and _deterDT = null then
		if self.myVGMDetails &lt;&gt; null then
			delete self.myVGMDetails;
		endif;
		return;
	endif;
	
	if self.myVGMDetails &lt;&gt; null 										//Bug 37011
	and _certifiedName 	= self.myVGMDetails.weightCertifiedReference	//Bug 37011
	and _authorisedName = self.myVGMDetails.weightCertifiedName 		//Bug 37011
	and _authSig 		= self.myVGMDetails.vgmAuthSignature 			//Bug 37011
	and _commsType 		= self.myVGMDetails.vgmCommsType				//Bug 37011
	and _docDetails 	= self.myVGMDetails.vgmDocumentDetails			//Bug 37011
	and _ediTrans 		= self.myVGMDetails.vgmEDITransmission			//Bug 37011
	and _email 			= self.myVGMDetails.vgmElectronicMail			//Bug 37011
	and _mail 			= self.myVGMDetails.vgmMail						//Bug 37011
	and _phone 			= self.myVGMDetails.vgmPhone					//Bug 37011
	and _fax 			= self.myVGMDetails.vgmTelefax					//Bug 37011
	and _telephone 		= self.myVGMDetails.vgmTelephone				//Bug 37011
	and _docDT 			= self.myVGMDetails.vgmDocsIssuedDT				//Bug 37011
	and _deterDT 		= self.myVGMDetails.vgmDeterminationDT then		//Bug 37011
		return;															//Bug 37011
	endif;																//Bug 37011
	
	if (not self.isTransient) and _tiUpdateCntrlr &lt;&gt; null then
		self.beginUpdate(_tiUpdateCntrlr, app.myPassport);
	endif;
	
	if self.myVGMDetails = null 
	and (_certifiedName &lt;&gt; null or _authorisedName &lt;&gt; null or _authSig &lt;&gt; null or
	_commsType &lt;&gt; null or _docDetails &lt;&gt; null or _ediTrans &lt;&gt; null or _email &lt;&gt; null or
	_mail &lt;&gt; null or _phone &lt;&gt; null or _fax &lt;&gt; null or _telephone &lt;&gt; null or
	_docDT &lt;&gt; null or _deterDT &lt;&gt; null) then
		if self.isTransient then
			create self.myVGMDetails transient;
		else
			create self.myVGMDetails persistent;
		endif;
	endif;
	self.myVGMDetails.setForUpdate(	_certifiedName, _authorisedName,
									_authSig, _commsType, _docDetails, _ediTrans, _email, _mail, _phone, _fax, _telephone,
									_docDT, _deterDT	);
									
	if not self.isTransient then
		self.checkVGMDetails(app.myPassport);
	endif;
	
	if (not self.isTransient) and _tiUpdateCntrlr &lt;&gt; null then
		if _tiUpdateCntrlr.transactionType &lt;&gt; TRANS_TYPE_EDIT then	//Bug 37011	
			tmpTransType :=_tiUpdateCntrlr.transactionType;			//Bug 37011
			_tiUpdateCntrlr.transactionType := TRANS_TYPE_EDIT;		//Bug 37011
		endif;														//Bug 37011
		
		self.endUpdate(_tiUpdateCntrlr, app.myPassport);
		
		if tmpTransType &lt;&gt; TRANS_TYPE_NULL then						//Bug 37011
			_tiUpdateCntrlr.transactionType := tmpTransType;		//Bug 37011
		endif;														//Bug 37011
	endif;
epilog

end;</source>
        <Parameter name="_certifiedName" type="String"/>
        <Parameter name="_authorisedName" type="String"/>
        <Parameter name="_authSig" type="String"/>
        <Parameter name="_commsType" type="String"/>
        <Parameter name="_docDetails" type="String"/>
        <Parameter name="_ediTrans" type="String"/>
        <Parameter name="_email" type="String"/>
        <Parameter name="_mail" type="String"/>
        <Parameter name="_phone" type="String"/>
        <Parameter name="_fax" type="String"/>
        <Parameter name="_telephone" type="String"/>
        <Parameter name="_docDT" type="TimeStamp"/>
        <Parameter name="_deterDT" type="TimeStamp"/>
        <Parameter name="_tiUpdateCntrlr" type="CMIF_TIUpdateController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyVGMDetailsVermas" id="cad17ee3-9656-49c7-bfa4-6f657d08e0e6">
        <updating/>
        <source>setMyVGMDetailsVermas(	_certifiedName, _authorisedName : String;
					_authSig, _commsType, _docDetails, _ediTrans, _email, _mail, _phone, _fax, _telephone : String;
					_docDT, _deterDT : TimeStamp;
					_tiUpdateCntrlr : CMIF_TIUpdateController input	) updating;
/*

Purpose:		Very similar to setMyVGMDetails but Vermas specific

Parameters:

Return Value:

Date		Who		Reason
09 Sep 2019	jlgsl4	TFS 46404 - SNO - update from non-null Vermas details only
08 Jan 2020	jlgdi1	48192	Added myVGMDetails null check prior to updating to avoid 1090 error
							Conditions in creating a new instance of CM_VGMDetails are still in-tact
*/

vars
	tmpTransType : Integer;			//Bug 37011
	tmpCertifiedName, tmpAuthorisedName : String; // TFS 46404
begin
	tmpTransType := TRANS_TYPE_NULL;//Bug 37011
	
	if not app.getMyUser.canDo(self.myTerminal, PmCargoVGMMaint) then //epr TFS 2011
		return;
	endif; 
	if self.myVGMDetails &lt;&gt; null then									//Bug 37011
		tmpCertifiedName := self.myVGMDetails.weightCertifiedReference; // TFS 46404
		tmpAuthorisedName := self.myVGMDetails.weightCertifiedName; // TFS 46404
		if 		_certifiedName 	= tmpCertifiedName //self.myVGMDetails.weightCertifiedReference	//Bug 37011 // TFS 46404
			and _authorisedName = tmpAuthorisedName //self.myVGMDetails.weightCertifiedName 		//Bug 37011 // TFS 46404
			and _authSig 		= self.myVGMDetails.vgmAuthSignature 			//Bug 37011
			and _commsType 		= self.myVGMDetails.vgmCommsType				//Bug 37011
			and _docDetails 	= self.myVGMDetails.vgmDocumentDetails			//Bug 37011
			and _ediTrans 		= self.myVGMDetails.vgmEDITransmission			//Bug 37011
			and _email 			= self.myVGMDetails.vgmElectronicMail			//Bug 37011
			and _mail 			= self.myVGMDetails.vgmMail						//Bug 37011
			and _phone 			= self.myVGMDetails.vgmPhone					//Bug 37011
			and _fax 			= self.myVGMDetails.vgmTelefax					//Bug 37011
			and _telephone 		= self.myVGMDetails.vgmTelephone				//Bug 37011
			and _docDT 			= self.myVGMDetails.vgmDocsIssuedDT				//Bug 37011
			and _deterDT 		= self.myVGMDetails.vgmDeterminationDT then		//Bug 37011
				return;															//Bug 37011
		endif;
	endif;//Bug 37011
	
	if (not self.isTransient) and _tiUpdateCntrlr &lt;&gt; null then
		self.beginUpdate(_tiUpdateCntrlr, app.myPassport);
	endif;
	
	if self.myVGMDetails = null 
	and (_certifiedName &lt;&gt; null or _authorisedName &lt;&gt; null or _authSig &lt;&gt; null or
	_commsType &lt;&gt; null or _docDetails &lt;&gt; null or _ediTrans &lt;&gt; null or _email &lt;&gt; null or
	_mail &lt;&gt; null or _phone &lt;&gt; null or _fax &lt;&gt; null or _telephone &lt;&gt; null or
	_docDT &lt;&gt; null or _deterDT &lt;&gt; null) then
		if self.isTransient then
			create self.myVGMDetails transient;
		else
			create self.myVGMDetails persistent;
		endif;
	endif;
	
	if self.myVGMDetails = null then 
		return;
	endif;
	
	if _certifiedName &lt;&gt; null then // --&gt; TFS 46404 - only replace Certified and Authorised names
		tmpCertifiedName := _certifiedName;
	endif;
	if _authorisedName &lt;&gt; null then
		tmpAuthorisedName := _authorisedName;
	endif; // &lt;-- TFS 46404 - with non-null Vermas details
	self.myVGMDetails.setForUpdate(	tmpCertifiedName, tmpAuthorisedName, //_certifiedName, _authorisedName, // TFS 46404
									_authSig, _commsType, _docDetails, _ediTrans, _email, _mail, _phone, _fax, _telephone,
									_docDT, _deterDT	);
									
	if not self.isTransient then
		self.checkVGMDetails(app.myPassport);
	endif;
	
	if (not self.isTransient) and _tiUpdateCntrlr &lt;&gt; null then
		if _tiUpdateCntrlr.transactionType &lt;&gt; TRANS_TYPE_EDIT then	//Bug 37011	
			tmpTransType :=_tiUpdateCntrlr.transactionType;			//Bug 37011
			_tiUpdateCntrlr.transactionType := TRANS_TYPE_EDIT;		//Bug 37011
		endif;														//Bug 37011
		
		self.endUpdate(_tiUpdateCntrlr, app.myPassport);
		
		if tmpTransType &lt;&gt; TRANS_TYPE_NULL then						//Bug 37011
			_tiUpdateCntrlr.transactionType := tmpTransType;		//Bug 37011
		endif;														//Bug 37011
	endif;
epilog

end;</source>
        <Parameter name="_certifiedName" type="String"/>
        <Parameter name="_authorisedName" type="String"/>
        <Parameter name="_authSig" type="String"/>
        <Parameter name="_commsType" type="String"/>
        <Parameter name="_docDetails" type="String"/>
        <Parameter name="_ediTrans" type="String"/>
        <Parameter name="_email" type="String"/>
        <Parameter name="_mail" type="String"/>
        <Parameter name="_phone" type="String"/>
        <Parameter name="_fax" type="String"/>
        <Parameter name="_telephone" type="String"/>
        <Parameter name="_docDT" type="TimeStamp"/>
        <Parameter name="_deterDT" type="TimeStamp"/>
        <Parameter name="_tiUpdateCntrlr" type="CMIF_TIUpdateController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setOffsiteCleaned" id="50fcd704-dfb4-408b-bfa0-f08848af4d16">
        <updating/>
        <source>setOffsiteCleaned(_value : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		April 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.offsiteCleaned = _value then
		// no change, don't overwrite DT - PAR 6650
		return;
	endif;
	
	self.offsiteCleaned := _value;

	if self.offsiteCleaned then
		self.washDT := app.serverTimestampAtTrxStart;
	else
		self.washDT := null;
	endif;

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setOffsitePreTrip" id="35a4fdd5-5154-4a8d-be3e-f6a51db36b9a">
        <updating/>
        <source>setOffsitePreTrip(_value : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		March 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	now : TimeStamp;
begin
	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	if self.offsitePreTrip = _value then
		// no change, don't overwrite DT - PAR 6650
		return;
	endif;

	self.offsitePreTrip := _value;
	
	if _value then
		self.setPreTripDT(now);
	else
		self.setPreTripDT(null);
	endif;

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setOverDimensions" id="e7480611-eba2-452f-ba74-94af4652ddff">
        <updating/>
        <source>setOverDimensions(	_overHeight : Decimal;
					_overLengthFront : Decimal;
					_overLengthRear : Decimal;
					_overWidthLeft : Decimal;
					_overWidthRight : Decimal;
					_tiUpdateCntrlr : CMIF_TIUpdateController input;
					_passport : CM_Passport input
					) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 January 2010	cnwndl1	Initial creation	CCMS 1006

*/

vars

begin

	if (not self.isTransient) then
		self.beginUpdate(_tiUpdateCntrlr, _passport);
	endif;
	
	self.overHeight := _overHeight;
	self.overLengthFront := _overLengthFront;
	self.overLengthRear := _overLengthRear;
	self.overWidthLeft := _overWidthLeft;
	self.overWidthRight := _overWidthRight;
		
	if (not self.isTransient) then
		self.endUpdate(_tiUpdateCntrlr, _passport);
	endif;
	
epilog

end;</source>
        <Parameter name="_overHeight" type="Decimal"/>
        <Parameter name="_overLengthFront" type="Decimal"/>
        <Parameter name="_overLengthRear" type="Decimal"/>
        <Parameter name="_overWidthLeft" type="Decimal"/>
        <Parameter name="_overWidthRight" type="Decimal"/>
        <Parameter name="_tiUpdateCntrlr" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setOverDimensionsOnly" id="12e9e254-5766-45e9-86d1-735abaa28dfe">
        <updating/>
        <source>setOverDimensionsOnly(_overHeight : Decimal;
					_overLengthFront : Decimal;
					_overLengthRear : Decimal;
					_overWidthLeft : Decimal;
					_overWidthRight : Decimal) updating;
//
// 07 Nov 2014	cnwrs1	Par 35153 - dont do the beginupdate/endupdate when doing Baplie merge
//
vars

begin
	self.overHeight := _overHeight;
	self.overLengthFront := _overLengthFront;
	self.overLengthRear := _overLengthRear;
	self.overWidthLeft := _overWidthLeft;
	self.overWidthRight := _overWidthRight;
end;
</source>
        <Parameter name="_overHeight" type="Decimal"/>
        <Parameter name="_overLengthFront" type="Decimal"/>
        <Parameter name="_overLengthRear" type="Decimal"/>
        <Parameter name="_overWidthLeft" type="Decimal"/>
        <Parameter name="_overWidthRight" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setOverHeight" id="71c72fe0-0eb9-4d5d-9d2e-7f45ecf32844">
        <updating/>
        <source>setOverHeight(_value : Decimal;_tiUpdateCntrlr : CMIF_TIUpdateController input; _passport : CM_Passport input) updating;
//17 December 2009	cnwml2


vars

begin
	if (not self.isTransient) then
		self.beginUpdate(_tiUpdateCntrlr, _passport);
	endif;
	
	self.overHeight := _value;
		
	if (not self.isTransient) then
		self.endUpdate(_tiUpdateCntrlr, _passport);
	endif;	

epilog

end;</source>
        <Parameter name="_value" type="Decimal"/>
        <Parameter name="_tiUpdateCntrlr" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
