    <JadeMethod name="doAutoPlan" id="c42f946c-007a-4fda-adbe-4e1caf14978b">
        <updating/>
        <source>doAutoPlan() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 March 2013	cnwndl1	Initial creation	Par 31278

*/

vars
	result : Integer;
	errMsg : String;
	job : CM_Job;
	wle : CM_WorkListEntry;
	
begin
	
	if self.myTrackedItem = null then
		return;
	endif;
	
	if self.msgBox( app.getErrorString1( Autoplan_Continue, self.myTrackedItem.id ) , app.getErrorString(Warning), MsgBox_Yes_No, false ) = MsgBox_Return_No then
		return;
	endif;
	
	if self.myMobileGenericAgent.checksState = self.myMobileGenericAgent.RailReceipt then
		self.getRailJobWLE( job, wle, false );
	endif;
	result := self.myMobileGenericAgent.rePlanTi( self.myTrackedItem, job, 0 );
	
	if self.myTrackedItem.myPrimaryQueuedLocation &lt;&gt; null then
		errMsg := app.getErrorString2( Tracked_item_queued, self.myTrackedItem.id, self.myTrackedItem.myPrimaryQueuedLocation.getFullId);
	else
		errMsg := app.getErrorString1( Not_queued_anywhere, self.myTrackedItem.id);
	endif;
	
	if self.myTrackedItem.myPrimaryQueuedLocation &lt;&gt; null then
		self.setTxtLocationDetails( self.myTrackedItem.myPrimaryQueuedLocation.getFullId, self.myTrackedItem.myPrimaryQueuedLocation );	
	elseif self.myTrackedItem.myPrimaryPlannedLocation &lt;&gt; null then
		self.setTxtLocationDetails( self.myTrackedItem.myPrimaryPlannedLocation.getFullId, self.myTrackedItem.myPrimaryPlannedLocation );	
	else
		self.resetLocationDisplay();
	endif;
	
	self.msgBox( errMsg, app.getErrorString(Warning), MsgBox_OK_Only, false );
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCheckDirectDelsLoadedToOps" id="412ded41-35b2-4968-ba30-82a2b5acf92e">
        <source>doCheckDirectDelsLoadedToOps( wle : CM_WorkListEntry; otherDDWle : CM_WorkListEntry output ) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2013	cnwndl1	Initial creation	Par 31278

*/

vars

	errMess : String;

begin

	if wle = null then
		errMess := app.getErrorString(Direct_deliver_require_wles);
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
		return false;
	endif;
	otherDDWle := self.myTrackedItem.getDirectDeliveryTargetWle( wle );
	if otherDDWle = null then
		errMess := app.getErrorString(Direct_deliver_require_wles);
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
		return false;
	endif;
	if wle.job = null then
		errMess := app.getErrorString1(Not_found_worklis_entry, wle.id );
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
		return false;
	endif;
	if wle.isKindOf(CM_VoyageWLE) and not wle.CM_VoyageWLE.isLoadedToOperations() then	//09 Jan 2014	NDL	Par 33277
		errMess := app.getErrorString1(Voyag_been_loade_voyag_opera_c, wle.job.jobId );
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
		return false;
	endif;
	if otherDDWle.isKindOf(CM_VoyageWLE)then
		if otherDDWle.job = null then
			errMess := app.getErrorString1(Not_found_worklis_entry, otherDDWle.id );
			self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
			return false;
		endif;
		if not otherDDWle.CM_VoyageWLE.isLoadedToOperations() then
			errMess := app.getErrorString1(Voyag_been_loade_voyag_opera_c, otherDDWle.job.jobId );
			self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
			return false;
		endif;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="wle" type="CM_WorkListEntry"/>
        <Parameter name="otherDDWle" type="CM_WorkListEntry" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
