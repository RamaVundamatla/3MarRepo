    <JadeMethod name="getPageHTML" id="ab808225-946a-4d05-b5cc-8479167b50df">
        <source>getPageHTML(pSchemaObj : Schema; pPageName : String):String protected;
// --------------------------------------------------------------------------------
// Created:		21 June 2005 by cnwdad1
//
// Purpose:		Returns the HTML for the specified web page.
//
// Parameters:	pSschemaObj - A reference to the Web Page schema.
//				pPageName - The name of the web page.
//
// Returns:		The HTML source of the specified web page.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	classObj		: Class;
	htmlClassObj	: JadeHTMLClass;
	htmlDocObj		: JadeHTMLDocument;
	
begin
	classObj	:=	pSchemaObj.getClass(pPageName);
	
	if classObj = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Class (' &amp; pPageName &amp; ') not found');
		return null;
	endif;
	
	create htmlClassObj as classObj transient;
	htmlDocObj	:=	htmlClassObj.getPropertyValue(JadeHTMLClass::htmlDocument.name).JadeHTMLDocument;
	
	if htmlDocObj &lt;&gt; null then
		return htmlDocObj.getPropertyValue(JadeHTMLDocument::htmlString.name).String;
	endif;
epilog
	delete htmlClassObj;
end;</source>
        <access>protected</access>
        <Parameter name="pSchemaObj" type="Schema"/>
        <Parameter name="pPageName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWebSiteSchema" id="1ad655f8-c4b3-4132-b86c-d966b699ac00">
        <source>getWebSiteSchema(_giveError : Boolean) : Schema;
// ---------------------------------------------------------------------------
// Created:     12 June 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpSchema	: Schema;
begin
	tmpSchema := currentSchema.getSchema(self.schemaName);
	if tmpSchema = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Schema (' &amp; self.schemaName &amp; ') not found');
	endif;
	
	return tmpSchema;
end;</source>
        <Parameter name="_giveError" type="Boolean"/>
        <ReturnType type="Schema"/>
    </JadeMethod>
    <JadeMethod name="loadHTMLForPage" id="3b5660ad-648e-461b-b739-68cfd1e19dc1">
        <source>loadHTMLForPage(_files : FileNodeArray; _pageName : String; _pageType : Integer) protected;
// ---------------------------------------------------------------------------
// Created:     12 June 2005 by cnwrs2
//
// Purpose:     Creates/Updates the WebPageHTML from the html in a file
//				Assumes that the fileName is the same as the pageName
// ---------------------------------------------------------------------------
vars
	tmpFileNode	: FileNode;
	tmpFile		: File;
	tmpFileName	: String;
	tmpHTML		: String;
	tmpWebPageHTML	: CM_WebPageHTML;
begin

	foreach tmpFileNode in _files do
		if (not tmpFileNode.isKindOf(File)) then
			continue;
		endif;
		tmpFile := tmpFileNode.File;
		tmpFile.kind := File.Kind_Unknown_Text;	// 26/2/16 cnwmp6 PAR 36286 unicode version
		tmpFileName := tmpFile.cnEcFileStem.toUpper();
		if tmpFileName = _pageName then
		
			tmpFile.open();
			tmpHTML := tmpFile.readString(tmpFile.fileLength);

			tmpWebPageHTML := self.allWebPageHTML[_pageType];
			if tmpWebPageHTML = null then
				create tmpWebPageHTML persistent;
				tmpWebPageHTML.setForCreate(tmpHTML, _pageType, self);
			else
				tmpWebPageHTML.setForUpdate(tmpHTML);
			endif;
			break;
		endif;
	endforeach;

epilog
	if tmpFile &lt;&gt; null and
	   tmpFile.isOpen() then
		tmpFile.close();
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_files" type="FileNodeArray"/>
        <Parameter name="_pageName" type="String"/>
        <Parameter name="_pageType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadHTMLFromFiles" id="6fc6341c-163d-4cc1-8e0e-af9cfb51b5b3">
        <source>loadHTMLFromFiles();
// ---------------------------------------------------------------------------
// Created:     12 June 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpSchema	: Schema;
begin
	tmpSchema := self.getWebSiteSchema(true);

	self.setWebPageHTMLForPage(tmpSchema, self.changePasswordPage, Page_ChangePassword);
	self.setWebPageHTMLForPage(tmpSchema, self.currentReportsPage, Page_CurrentReports);
	self.setWebPageHTMLForPage(tmpSchema, self.criteriaPage, Page_ReportCriteria);
	self.setWebPageHTMLForPage(tmpSchema, self.eventNotifyMaintPage, Page_EventNotifyMaint);
	self.setWebPageHTMLForPage(tmpSchema, self.eventNotifyViewPage, Page_EventNotifyView);
	self.setWebPageHTMLForPage(tmpSchema, self.footerPage, Page_Footer);
	self.setWebPageHTMLForPage(tmpSchema, self.headerInPage, Page_HeaderLoggedIn);
	self.setWebPageHTMLForPage(tmpSchema, self.headerOutPage, Page_HeaderLoggedOut);
	self.setWebPageHTMLForPage(tmpSchema, self.infoPage, Page_Info);
	self.setWebPageHTMLForPage(tmpSchema, self.listPage, Page_ReportsList);
	self.setWebPageHTMLForPage(tmpSchema, self.eventReqStopMaintPage, Page_StopMaint);
	self.setWebPageHTMLForPage(tmpSchema, self.eventReqStopViewPage, Page_StopView);
	self.setWebPageHTMLForPage(tmpSchema, self.outputPage, Page_ReportOutput);

end;</source>
    </JadeMethod>
    <JadeMethod name="responseTimeoutSecs" id="f9e23c9e-b28c-4825-9305-ab733c9a2e7a">
        <methodInvocation>mapping</methodInvocation>
        <source>responseTimeoutSecs(_set : Boolean; _value : Integer io) mapping;
/*

Purpose:			Default to 60 seconds

Parameters:			

Return Value:		

Date			Who		Reason
08 April 2021	navmd1	Initial creation TFS 42010 MTN - Early Termination of web services

*/

vars

begin
	if not _set then
		if _value = 0 then
			_value := 60;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="saveWebPagesToDisk" id="3391705b-0b23-4d35-992e-cee42df671da">
        <source>saveWebPagesToDisk(pDestinationPath:String);
// --------------------------------------------------------------------------------
// Created:		21 June 2005 by cnwdad1
//
// Purpose:		Saves (writes) the receiver's web pages to disk files.
//
// Parameters:	pDestinationPath - The directory path to write the files to.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 21 Oct 2009	cnwkpd1		Added missing Login Page
// --------------------------------------------------------------------------------
vars
	schemaObj		: Schema;
	htmlSource		: String;
	pathSeparator	: String;
	fileName		: String;
	
begin
	schemaObj	:=	self.getWebSiteSchema(true);
	
	if schemaObj = null then
		return;
	endif;
	
	pathSeparator	:=	global.cnEcGetFileSeparator();
	
	htmlSource	:=	self.getPageHTML(schemaObj, self.loginPage);
	fileName	:=	pDestinationPath &amp; pathSeparator &amp; self.loginPage &amp; ".html";
	htmlSource.writeToFile(fileName);
	
	htmlSource	:=	self.getPageHTML(schemaObj, self.changePasswordPage);
	fileName	:=	pDestinationPath &amp; pathSeparator &amp; self.changePasswordPage &amp; ".html";
	htmlSource.writeToFile(fileName);

	htmlSource	:=	self.getPageHTML(schemaObj, self.changePasswordPage);
	fileName	:=	pDestinationPath &amp; pathSeparator &amp; self.changePasswordPage &amp; ".html";
	htmlSource.writeToFile(fileName);
	
	htmlSource	:=	self.getPageHTML(schemaObj, self.currentReportsPage);
	fileName	:=	pDestinationPath &amp; pathSeparator &amp; self.currentReportsPage &amp; ".html";
	htmlSource.writeToFile(fileName);
	
	htmlSource	:=	self.getPageHTML(schemaObj, self.criteriaPage);
	fileName	:=	pDestinationPath &amp; pathSeparator &amp; self.criteriaPage &amp; ".html";
	htmlSource.writeToFile(fileName);
	
	htmlSource	:=	self.getPageHTML(schemaObj, self.eventNotifyMaintPage);
	fileName	:=	pDestinationPath &amp; pathSeparator &amp; self.eventNotifyMaintPage &amp; ".html";
	htmlSource.writeToFile(fileName);
	
	htmlSource	:=	self.getPageHTML(schemaObj, self.eventNotifyViewPage);
	fileName	:=	pDestinationPath &amp; pathSeparator &amp; self.eventNotifyViewPage &amp; ".html";
	htmlSource.writeToFile(fileName);
	
	htmlSource	:=	self.getPageHTML(schemaObj, self.footerPage);
	fileName	:=	pDestinationPath &amp; pathSeparator &amp; self.footerPage &amp; ".html";
	htmlSource.writeToFile(fileName);
	
	htmlSource	:=	self.getPageHTML(schemaObj, self.headerInPage);
	fileName	:=	pDestinationPath &amp; pathSeparator &amp; self.headerInPage &amp; ".html";
	htmlSource.writeToFile(fileName);
	
	htmlSource	:=	self.getPageHTML(schemaObj, self.headerOutPage);
	fileName	:=	pDestinationPath &amp; pathSeparator &amp; self.headerOutPage &amp; ".html";
	htmlSource.writeToFile(fileName);
	
	htmlSource	:=	self.getPageHTML(schemaObj, self.infoPage);
	fileName	:=	pDestinationPath &amp; pathSeparator &amp; self.infoPage &amp; ".html";
	htmlSource.writeToFile(fileName);
	
	htmlSource	:=	self.getPageHTML(schemaObj, self.listPage);
	fileName	:=	pDestinationPath &amp; pathSeparator &amp; self.listPage &amp; ".html";
	htmlSource.writeToFile(fileName);
	
	htmlSource	:=	self.getPageHTML(schemaObj, self.eventReqStopMaintPage);
	fileName	:=	pDestinationPath &amp; pathSeparator &amp; self.eventReqStopMaintPage &amp; ".html";
	htmlSource.writeToFile(fileName);
	
	htmlSource	:=	self.getPageHTML(schemaObj, self.eventReqStopViewPage);
	fileName	:=	pDestinationPath &amp; pathSeparator &amp; self.eventReqStopViewPage &amp; ".html";
	htmlSource.writeToFile(fileName);
	
	htmlSource	:=	self.getPageHTML(schemaObj, self.prenoteMaintPage);
	fileName	:=	pDestinationPath &amp; pathSeparator &amp; self.prenoteMaintPage &amp; ".html";
	htmlSource.writeToFile(fileName);
	
	htmlSource	:=	self.getPageHTML(schemaObj, self.prenoteViewPage);
	fileName	:=	pDestinationPath &amp; pathSeparator &amp; self.prenoteViewPage &amp; ".html";
	htmlSource.writeToFile(fileName);
	
	htmlSource	:=	self.getPageHTML(schemaObj, self.outputPage);
	fileName	:=	pDestinationPath &amp; pathSeparator &amp; self.outputPage &amp; ".html";
	htmlSource.writeToFile(fileName);
end;</source>
        <Parameter name="pDestinationPath" type="String"/>
    </JadeMethod>
