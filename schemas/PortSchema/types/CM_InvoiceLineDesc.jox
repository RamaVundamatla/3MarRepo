    <JadeMethod name="isChargeByDaysType" id="e5bde8bc-6d08-42dc-8272-1520adbc83ef">
        <source>isChargeByDaysType() : Boolean;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//	Nov 2010	cnwjre1		par 26107 CCMS 2020 Invoice storage by first/last cargo item on/off voyage
//							add INV_CALC_TYPE_DAYSINCE_SHIP tests
// ---------------------------------------------------------------------------

vars
	chgByUnits : Integer;
begin
	chgByUnits := self.getChargeByUnits;	// 24024 CCMS 1151 Aug 2010 cnwjre1 user hook code for invoice quantity and rate
	
	if  chgByUnits = INV_CALC_TYPE_DAYS_SINCE_RECVL 
	or  chgByUnits = INV_CALC_TYPE_DAYSINCE_SUBTERM 	//28 Jun 2018	NDL	TFS 39338
	or  chgByUnits = INV_CALC_TYPE_DAYSINCE_REC_TEU 
	or	chgByUnits = INV_CALC_TYPE_DAYSINCE_REC_RT 	//08 May 2018	NDL	TFS 38525
	or	chgByUnits = INV_CALC_TYPE_DAYSINCE_SHIP_ST
	or	chgByUnits = INV_CALC_TYPE_DAYSINCE_SHIP_EN
	or	chgByUnits = INV_CALC_TYPE_DAYSINCE_VOY_IN
	or	chgByUnits = INV_CALC_TYPE_DAYSINCE_VOY_OUT
	or  chgByUnits = INV_CALC_TYPE_DAYS_ONSITE_AT 
	or  chgByUnits = INV_CALC_TYPE_DAYS_CONNECTED
	or  chgByUnits = INV_CALC_TYPE_DAYS_WEIGHT
	or  chgByUnits = INV_CALC_TYPE_DAYS_VOLUME
	then
		return true;
	endif;

	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
