    <JadeMethod name="pxyCreateUpdateProxy" id="9275b906-6e80-45cd-bdb6-3a38ff6c1be3">
        <source>pxyCreateUpdateProxy(): SelfType;

// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	tempCommodity : CM_Commodity;
	completedOK		: Boolean;
begin

	tempCommodity := inheritMethod();
	tempCommodity.myCommodityGroup := self.myCommodityGroup;
	tempCommodity.mySpecialStow:=self.mySpecialStow;
	
	//PAR 19704, CCMS 1080 May 2009 cnwvu1
	tempCommodity.allCargoTypes.clear();	 
	self.allCargoTypes.copy(tempCommodity.allCargoTypes);

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return tempCommodity;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete tempCommodity;
	endif;
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="8f822286-eb7f-4d89-a714-d11385a7e3d2">
        <updating/>
        <source>setForCreate(pProxyCommodity:CM_Commodity) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	setForUpdate(pProxyCommodity);
	self.myRoot := app.myRoot;

end;</source>
        <Parameter name="pProxyCommodity" type="CM_Commodity"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="24281786-f6b3-4b64-8eff-eceb1a7d0c0f">
        <updating/>
        <source>setForUpdate(_proxy :CM_Commodity) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 15/04/2013	cnwcs5		CCMS POL 2097 / par 31259
// 25/03/2015	cnwdap1		PAR #35895 CCMS PNL 2461 Added isUsedForPacking attribute
// ---------------------------------------------------------------------------
vars

	needsRefresh : Boolean;

begin
	// par 31259 - make sure xlations updated with new code
	if self.code &lt;&gt; _proxy.code then
		self.updateXlations_Code (_proxy.code, self.code, self.allXlations);
	endif;

	self.code 					:= _proxy.code.trimBlanks;
	if self.description &lt;&gt; _proxy.description then	//03 Apr 2019	NDL	TFS 44194
		self.description 		:= _proxy.description.trimBlanks;
		needsRefresh 			:= true;	//03 Apr 2019	NDL	TFS 44194
	endif;
	self.shortDescription 		:= _proxy.shortDescription.trimBlanks;
	self.bayplanPrintAs 		:= _proxy.bayplanPrintAs;
	self.colour 				:= _proxy.colour;
	self.hasTemp 				:= _proxy.hasTemp;
	self.maxTemp 				:= _proxy.maxTemp;
	self.minTemp 				:= _proxy.minTemp;
	self.myCommodityGroup 		:= _proxy.myCommodityGroup;
	self.requiresPower 			:= _proxy.requiresPower;
	self.requiresMAFFields 		:= _proxy.requiresMAFFields;
	self.isNotAvailableForEntry := _proxy.isNotAvailableForEntry;
	self.isEmpty 				:= _proxy.isEmpty;
	self.mySpecialStow			:= _proxy.mySpecialStow; //epr 17/9/08 CCMS 1037
	self.isUsedForPacking		:= _proxy.isUsedForPacking;						// PAR #35895
	self.requiresWeighing		:= _proxy.requiresWeighing;	//05 Jul 2019	NDL	TFS 44965

	self.allCargoTypes.clear();	//PAR 19704, CCMS 1080 May 2009 cnwvu1
	_proxy.allCargoTypes.copy(self.allCargoTypes);
	
	//03 Apr 2019	NDL	TFS 44194
	if needsRefresh then
		if app.myAlternateDict &lt;&gt; null then
			app.myAlternateDict.setCommodityDictNeedsRefresh();
		endif;
	endif;
	
end;</source>
        <Parameter name="_proxy" type="CM_Commodity"/>
    </JadeMethod>
    <JadeMethod name="setMyCommodityGroup" id="b6ca7e86-d78a-41e5-ad78-1a9139bf6a9d">
        <updating/>
        <source>setMyCommodityGroup(pCommodityGroup : CM_CommodityGroup )updating;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 27 August 2003
//
//-----------------------------------------------------------------------

vars

begin
	if self.myCommodityGroup &lt;&gt; pCommodityGroup then
		self.myCommodityGroup := pCommodityGroup;
	endif;
end;</source>
        <Parameter name="pCommodityGroup" type="CM_CommodityGroup"/>
    </JadeMethod>
    <JadeMethod name="setMyRoot" id="4f3a2e5e-2a13-4704-be7c-fcfd2e0e28ff">
        <updating/>
        <source>setMyRoot() updating;
// ---------------------------------------------------------------------------
// Created:     04 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myRoot := app.myRoot;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setProxy" id="e2cdaa99-7ddc-43d9-8c16-78db6e75112f">
        <updating/>
        <source>setProxy(	_code,
			_description,
			_shortDesc,
			_bayplanPrintAs			: String; 
			_hasTemp,_requiresPower,
			_requiresPackDetails,
			_isNotAvailableForEntry, _isEmpty 	: Boolean;               
			_colour					: Integer;
			_maxTemp,
			_minTemp				: Real;
			_commodityGroup			: CM_CommodityGroup;
			_specialStow 			: CM_SpecialStow;
			_isUsedForPacking		: Boolean;							// PAR #35895
			_allCargoTypes			: Collection;
			_requiresWeighing : Boolean	//05 Jul 2019	NDL	TFS 44965
			) updating;
//
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------
// 25/03/2015	cnwdap1		PAR #35895 CCMS PNL 2461 Added isUsedForPacking boolean
//
vars

begin

	self.raiseExceptionIfNotTransient(method);
	self.code := _code[1:4];
 	self.description := _description[1:30];
	self.shortDescription := _shortDesc[1:30];
	self.bayplanPrintAs := _bayplanPrintAs[1:5];
	self.colour := _colour;
	self.hasTemp := _hasTemp;
	self.maxTemp := _maxTemp;
	self.minTemp := _minTemp;
	self.myCommodityGroup := _commodityGroup;
	self.requiresPower := _requiresPower;
	self.requiresMAFFields := _requiresPackDetails;
	self.isNotAvailableForEntry := _isNotAvailableForEntry;
	self.myRoot := app.myRoot;
	self.isEmpty :=_isEmpty;
	self.isUsedForPacking := _isUsedForPacking;							// PAR #35895
	self.mySpecialStow:=_specialStow;
	self.requiresWeighing := _requiresWeighing;	//05 Jul 2019	NDL	TFS 44965
	
	//PAR 19704, CCMS 1080 May 2009 cnwvu1
	self.allCargoTypes.clear();	
	_allCargoTypes.copy(self.allCargoTypes);
	
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_shortDesc" type="String"/>
        <Parameter name="_bayplanPrintAs" type="String"/>
        <Parameter name="_hasTemp" type="Boolean"/>
        <Parameter name="_requiresPower" type="Boolean"/>
        <Parameter name="_requiresPackDetails" type="Boolean"/>
        <Parameter name="_isNotAvailableForEntry" type="Boolean"/>
        <Parameter name="_isEmpty" type="Boolean"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_maxTemp" type="Real"/>
        <Parameter name="_minTemp" type="Real"/>
        <Parameter name="_commodityGroup" type="CM_CommodityGroup"/>
        <Parameter name="_specialStow" type="CM_SpecialStow"/>
        <Parameter name="_isUsedForPacking" type="Boolean"/>
        <Parameter name="_allCargoTypes" type="Collection"/>
        <Parameter name="_requiresWeighing" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="4228130a-74f1-4dc8-a02d-dd92a5343260">
        <source>showThumbnail(pTable : Table);
// ---------------------------------------------------------------------------
// Created:     27 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpStr		: String;
	firstOne	: Boolean;

begin

	pTable.addItem('Code' &amp; Tab &amp; self.code.trimRight);
	pTable.addItem('Description' &amp; Tab &amp; self.description.trimRight);
	pTable.addItem('Short Descrption' &amp; Tab &amp; self.shortDescription.trimRight);
	pTable.addItem('');
	
	if self.myCommodityGroup &lt;&gt; null then
		tmpStr := self.myCommodityGroup.code.trimRight;
	else
		tmpStr := '&lt;not set&gt;';
	endif;
	pTable.addItem('Group' &amp; Tab &amp; tmpStr);
	if self.myCommodityGroup &lt;&gt; null then
		pTable.addItem(Tab &amp; self.myCommodityGroup.description.trimRight);
	endif;
	
	pTable.addItem('');
	
	if self.hasTemp then
		pTable.addItem('Min Temp' &amp; Tab &amp; self.minTemp.String);
		pTable.addItem('Max Temp' &amp; Tab &amp; self.maxTemp.String);
	else
		pTable.addItem('Temp' &amp; Tab &amp; 'Not Required');
	endif;

	pTable.addItem('Requires Power' &amp; Tab &amp; app.getYesNo(self.requiresPower));
	
end;</source>
        <Parameter name="pTable" type="Table"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="fafbc07a-f580-4aa9-b1c4-318c4d046144">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if app.myRoot.allCommodities[code] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;

	self.validateMe;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="076bb3d5-24bf-4aba-b920-79973d94112e">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//11/04/2019 	JLGNS1	Bug 44243: PEL1 add inverses to prevent deleting consigniees if used in a WODCargoRequest
// ---------------------------------------------------------------------------
vars
	theCommodity : CM_Commodity;
	anObject : Object;
	aTerm : CM_Terminal;
	theID : String;
	whereUsed : String;
	map : CM_TranMapInvoiceLineMapping;
begin
	// ### TFS CR 65336 TASK 65337 08AUG2024 NAVAB1
	map :=  self.allTMInvoiceLineMappings.first;
	if map &lt;&gt; null then
		app.raiseCMWarning2(Commo_used_invoi_mappi_sure_wa, self.code,map.getTranMapBreadCrumb(),null,null, self);
	endif;

	foreach aTerm in app.myRoot.allTerminals do
		theID := aTerm.getConfig(DefCommodity).String;
		if theID = self.code then
			app.raiseCMException3(ERR_USED_IN_CONFIG,"Commodity", self.code,"Terminal " &amp; aTerm.code,null, null);
		endif;
	endforeach;

	if (not self.allHMSVoyageDataDischarge.isEmpty) or (not self.allHMSVoyageDataLoad.isEmpty) then
		app.raiseCMException2(ObjectStillHasEntries, self.code, "ports", null, null);
	endif;
	
	if self.allWodCargoRequests.isNotEmpty then																									//Bug 44243
		app.raiseCMException2(ObjectStillHasEntries, self.code, self.allWodCargoRequests.size.String, app.getErrorString(Work_order), null);	//Bug 44243
	endif;																																		//Bug 44243
	
	//09 Nov 2020	NDL	TFS 50279
	if self.isUsedinConfig( whereUsed ) then
		app.raiseCMException2(ERR_CANNOT_DELETE, self.code, whereUsed, null, self);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="612f5846-4f77-4d11-898e-77e430ba5afc">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	whereUsed : String;
begin
	self.validateMe;
	
	//09 Nov 2020	NDL	TFS 50279
	if self.isNotAvailableForEntry then
		if self.isUsedinConfig( whereUsed ) then
			app.raiseCMException1(Not_make_not_availa_while, whereUsed, null, self);
		endif;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="8d841698-659f-4c1c-8ba5-553540d7717a">
        <source>validateMe() protected;

vars

	cargoType	: CM_CargoType;
	
begin

	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Commodity Code', null, null);
		app.raiseCMException(Input_required_field_commCode, null, null); // cnwdb2	PAR 35364
	endif;
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Commodity Description', null, null);
		app.raiseCMException(Input_required_field_commDesc, null, null); // cnwdb2	PAR 35364
	endif;
	
	// cargo type can be not commodity required. CCMS SFW 1080, PAR 19704. Nov 2009.
	foreach cargoType in self.allCargoTypes do
		if not cargoType.isCommodityRequired then
			app.raiseCMException1(ERR_CommodWithCargoTypeNonComm, cargoType.description, null, self);
		endif;
	endforeach;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateTemperature" id="14ef9f73-f32d-46fe-b2af-ff01317813cd">
        <source>validateTemperature(	_temperature : Real;
						_displayFahreiheit : Boolean;
						_packTempDetails : CM_PackTempReading;
						_allowableTimeOffPower : Decimal;
						_idString	: String;
						_giveErrorTemp : Boolean;
						_ignoreIfNullTemp : Boolean;
						_validateHasTemp : Boolean;
						_validatePackTemp : Boolean;
						_giveErrorpackTemp : Boolean;
						_ti : CM_TrackedItem);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 November 2008	cnwer1	Initial creation

*/

vars
	lower,
	upper,
	temp,
	packTempC : Real;
	packTime : Time;
	packDate : Date;
	tempConv		: CM_TemperatureConversion;
	currentTempStr,
	minTempStr,
	maxTempStr 			: String;
begin

	//does the commodity require temperature validated
	if  self.hasTemp then
		if not _validateHasTemp then
			return;
		endif;
		// check if we should ignore if it is a null temperature
		if  _temperature = NULL_TEMPERATURE then
			if _ignoreIfNullTemp then
				return;
			else
			//	app.raiseCMException1(REQUIRED_FIELD,app.getErrorString(CM_TemperatureExtra), app.getErrorString(CM_TemperatureExtra), null);
				app.raiseCMException1(Input_required_field_Required,app.getErrorString(CM_TemperatureExtra), app.getErrorString(CM_TemperatureExtra), null); // cnwdb2	PAR 35364


				return;
			endif;
		endif;
		
		//all temperature are stored in celcius check 
		if _displayFahreiheit then
			lower := app.temperatureConversion(true, self.minTemp);
			upper := app.temperatureConversion(true, self.maxTemp);
			temp := app.temperatureConversion(true, _temperature);
			tempConv := app.temperatureConversionLookup(false, temp);
			if tempConv = null then
				app.raiseCMException2(ERR_KEY_NOT_FOUND, temp.asStringJMT, "Fahrenheit Temperatures",'temperature', null);
			endif;
		else
			lower :=  self.minTemp;
			upper := self.maxTemp;
			temp := _temperature;
		endif;
		
		if not _temperature.isValidTemp then
			app.raiseCMException1(ERR_INVALID_TEMP, _temperature.asStringJMT, app.getErrorString(CM_TemperatureExtra),null);  
		else
			if (temp &lt; lower) or 
			   (temp &gt; upper) then
			   
				currentTempStr:=app.temperatureDisplayString(temp);
				minTempStr:=app.temperatureDisplayString(lower);
				maxTempStr:=app.temperatureDisplayString(upper);
			   
			   if _displayFahreiheit then
					currentTempStr:=currentTempStr &amp; Degrees_F;
					minTempStr:=minTempStr &amp; Degrees_F;
					maxTempStr:=maxTempStr &amp; Degrees_F;
			   else
					currentTempStr:=currentTempStr &amp; Degrees_C;
					minTempStr:=minTempStr &amp; Degrees_C;
					maxTempStr:=maxTempStr &amp; Degrees_C;
			   endif;
			   
			   if _giveErrorTemp then
					app.raiseCMException4(VB_TEMP_VALIDATION, currentTempStr,_idString, minTempStr,maxTempStr , app.temperatureDisplayString(temp), null);
								
			   else
					app.raiseCMWarning4(VB_TEMP_VALIDATION, currentTempStr,_idString, minTempStr,maxTempStr , app.temperatureDisplayString(temp), null,null);
								
			   endif;
			endif;
			
			if self.requiresMAFFields and
			   _validatePackTemp then
			   
   			   if _ti.getImExStatus = TI_IMEX_STATUS_EXPORT then		//+cnwml2 PAR25924
					if _packTempDetails = null then
						packTempC := NULL_TEMPERATURE;			// was null which = 0 which is valid temp
						packTime := null;
						packDate := null;
					else
						packTempC := _packTempDetails.tempC;
						packTime := _packTempDetails.dateTime.time;
						packDate := _packTempDetails.dateTime.date;
					endif;
					if packTempC = NULL_TEMPERATURE then				//+cnwml2 PAR24459
				//	07 Jun 2011	NDL	CCMS 2091
				//		if _giveErrorpackTemp then
				//			app.raiseCMException2(ERR_COMMODITY_REQ_PACKINFO, self.code, 'Pack Temperature', ETRow_PackTempC, null);
				//		else
							app.raiseCMWarning2(ERR_COMMODITY_REQ_PACKINFO, self.code, 'Pack Temperature', ETRow_PackTempC, null, self);
				//		endif;
					endif;
					
					if not packDate.isValid then
						if _giveErrorpackTemp then
							app.raiseCMException2(ERR_COMMODITY_REQ_PACKINFO, self.code, 'Pack Date', ETRow_PackDate, null);
						else
							app.raiseCMWarning2(ERR_COMMODITY_REQ_PACKINFO, self.code, 'Pack Date', ETRow_PackDate, null, self);
						endif;
					endif;
					
					if not packTime.isValid then		
						if _giveErrorpackTemp then
							app.raiseCMException2(ERR_COMMODITY_REQ_PACKINFO, self.code, 'Pack Time', ETRow_PackTime, null);
						else
							app.raiseCMWarning2(ERR_COMMODITY_REQ_PACKINFO, self.code, 'Pack Time', ETRow_PackTime, null, self);
						endif;
					endif;
					
					//if not _allowableTimeOffPower &gt; 0 then
					if not _allowableTimeOffPower &gt; NULL_ALLOWABLE_TIME_OFF_POWER then	// 12 Jul 2011	NDL	Par 27824
						if _giveErrorpackTemp then
							app.raiseCMException2(ERR_COMMODITY_REQ_PACKINFO, self.code, 'Allowable Time Off Power', ETRow_AllowableTimeOffPower, null);
						else
							app.raiseCMWarning2(ERR_COMMODITY_REQ_PACKINFO, self.code, 'Allowable Time Off Power', ETRow_AllowableTimeOffPower, null, self);
						endif;
					endif;
				endif;
			endif;
		endif;
	else
		if _temperature &lt;&gt; NULL_TEMPERATURE then
			app.raiseCMException2(ERR_Commodity_does_not_require, _idString, app.getErrorString(CM_TemperatureExtra), app.temperatureDisplayString(_temperature), null);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_temperature" type="Real"/>
        <Parameter name="_displayFahreiheit" type="Boolean"/>
        <Parameter name="_packTempDetails" type="CM_PackTempReading"/>
        <Parameter name="_allowableTimeOffPower" type="Decimal"/>
        <Parameter name="_idString" type="String"/>
        <Parameter name="_giveErrorTemp" type="Boolean"/>
        <Parameter name="_ignoreIfNullTemp" type="Boolean"/>
        <Parameter name="_validateHasTemp" type="Boolean"/>
        <Parameter name="_validatePackTemp" type="Boolean"/>
        <Parameter name="_giveErrorpackTemp" type="Boolean"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
