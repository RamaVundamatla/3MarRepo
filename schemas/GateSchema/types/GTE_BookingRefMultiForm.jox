    <JadeMethod name="doCancel" id="9bc3cd18-f134-4412-90e8-6788b5cc1cff">
        <updating/>
        <source>doCancel(): Boolean updating;
/*
	Created on 18 February 2008
	
	by Debby Hutchison
	
	Purpose:

Date		Who		Reason
10 Jul 2008	cnwkpd1	PAR #17486 - Rework of tidy up of transients and interface

*/

vars
	invalidProcess	: Boolean;
	result: Boolean;
begin

	on Exception do app.handleDeletedObject(exception, self.myInterfaceBookingRef.myProxyBookingRef, invalidProcess);	//par 16917 - when press the Cancel button just after the Next button - there is invalid reference. cnwvu1	June 2008
	
	if inheritMethod then

		if self.myCurrentBRItemInterface &lt;&gt; null and app.isValidObject(self.myCurrentBRItemInterface) then				//+cnwml2 PAR25189
			delete myCurrentBRItemInterface;
		endif;
		
		// 13/06/2008 cnwar2 #16888 - deleting the interface booking ref will also delete the proxy, so remove from collection
//		if self.myInterfaceBookingRef &lt;&gt; null then
//			if self.allProxyObjects.includes(self.myInterfaceBookingRef.myProxyBookingRef) then
//				self.allProxyObjects.remove(self.myInterfaceBookingRef.myProxyBookingRef);
//			endif;
//			delete self.myInterfaceBookingRef;
//		endif;

		self.doDeleteInterfaceBookingRef();		// PAR #17486
		
		doCancelBookRefItem(true);
		self.isItemsHaveChanged := false;
		return true;
	endif;
	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCancelBookRefItem" id="fbd39ce6-4abf-4ba2-8bf4-a6656c43079b">
        <updating/>
        <source>doCancelBookRefItem(_blnClose : Boolean):Boolean updating;
/*
	Created on 15 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	self.tblExtra.clearValues;
	if self.itemEditMode = Mode_Add then
		if self.myCurrentBRItemInterface &lt;&gt; null then
			delete self.myCurrentBRItemInterface;
		endif;
	else
		self.myCurrentBRItemInterface := null;
	endif;
	if _blnClose then
		self.itemEditMode := Mode_View;
		self.bookRefItemDockbarHide();
	endif;
	return true;
end;</source>
        <Parameter name="_blnClose" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="afb50cf1-b825-4929-a6cf-86aa638a737a">
        <updating/>
        <source>doDelete(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     02 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	obj : Object;
	booking: CM_BookingRef;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	if self.myCurrentObject.isKindOf(CM_BookingRef) then
		booking := self.myCurrentObject.CM_BookingRef;
	else
		booking := self.myCurrentObject.CM_BookingRefItem.myBookingReference;
	endif;
	if self.allowMultiSelectDelete = false then
	
		//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxDA.trxDeleteBookingRef(booking, null, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog('Booking Reference Deletion', app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
		
	else
		foreach obj in self.tblData.allSelectedObjects do
			self.myCurrentObject := obj.CM_Object;
			
			//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
			while true do
			
				app.myTrxDA.trxDeleteBookingRef(self.myCurrentObject.CM_BookingRef , null, app.myPassport);
			
				if app.myPassport.trxCompletedOK then
					break;
				else
					theResult := app.showErrorWarningDialog('Booking Reference Deletion', app.myPassport, ErrWarnMode_Update);
					if app.myPassport.noErrors and theResult = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
				endif;
				
				break;
				
			endwhile;
	
		endforeach;
		
	endif;

epilog

	return app.myPassport.trxCompletedOK;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDeleteBookRefItem" id="4adfccc0-1350-4ef0-965f-1fd70a9165ad">
        <updating/>
        <source>doDeleteBookRefItem() updating;
/*
	Created on 18 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	msgStr : String;
	cmifBRItem : CMIF_BookingRefItem;
begin
	if tblBRItems.allSelectedObjects.size = 0 then
		return;
	endif;
	if dck_BRefItem.visible then
		return;
	endif;
	cmifBRItem := getSelectedBRItem.CMIF_BookingRefItem; // should only be one selected
	if cmifBRItem.myRealBookingRefItem &lt;&gt; null and cmifBRItem.myRealBookingRefItem.allTIs.size &gt; 0 then
		app.msgBox(app.getErrorString(CannotDeleteBRItem), 'Delete error', MsgBox_OK_Only);	
		return;
	endif;
	if cmifBRItem = null 
	or app.msgBox(app.getErrorString2(ConfirmDelete, app.getErrorString(The_Selected_Items), ""), "", MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then		
		return;
	endif;
	if cmifBRItem.myRealBookingRefItem &lt;&gt; null then
		self.isItemsHaveChanged := true;
	endif;
	delete cmifBRItem;
	self.loadBookRefItems(null, true, false);
//	self.setMultiChkEnablement();	//05 Nov 2012	NDL	Par 29859
end;</source>
    </JadeMethod>
    <JadeMethod name="doDeleteInterfaceBookingRef" id="7dc59868-789d-46eb-8937-c1674ee8d4e6">
        <updating/>
        <source>doDeleteInterfaceBookingRef() updating, protected;

/*

Purpose:			Delete myInterfaceBookingRef, and tidy up any other references
					to its associated objects

Parameters:			None

Return Value:		None


Date		Who		Reason
10 Jul 2008	cnwkpd1	PAR #17486 - Rework of tidy up of transients and interface

*/

vars
	proxyBookingRef		: CM_BookingRef;
	
begin
	if self.myInterfaceBookingRef &lt;&gt; null then
		proxyBookingRef := self.myInterfaceBookingRef.myProxyBookingRef;
		if proxyBookingRef &lt;&gt; null then
			if self.allProxyObjects.includes(proxyBookingRef) then
				self.allProxyObjects.remove(proxyBookingRef);
			endif;
		endif;
		delete self.myInterfaceBookingRef;		// This will delete the proxy Booking Ref
	endif;
		

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doEditBookRefItem" id="679b9d75-2489-4758-834b-954c1de552aa">
        <updating/>
        <source>doEditBookRefItem(_obj : Object) updating;
/*
	Created on 18 February 2008
	
	by Debby Hutchison
	
