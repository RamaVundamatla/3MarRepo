    <ImplicitInverseRef name="tbCargo" id="3df7bb8d-2282-4e2b-ae4d-1d213d70f246">
        <embedded/>
        <type name="CM_TextTable"/>
    </ImplicitInverseRef>
    <JadeMethod name="checkPin" id="d5f22d19-45b8-4610-9f7c-1c6f758113e3">
        <source>checkPin( _ti : CM_TrackedItem ; _pin : String): Boolean;
/*
Date		Who		Reason
10 December 2010	cnwrd1	Initial creation
*/
vars

begin
	if _pin = null or _ti.getOperatorImportReleasePIN &lt;&gt; _pin then 
		return false;
	endif;
		
	return true;	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_pin" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCancel" id="6e20ab68-6f4b-41e7-a7d7-8bb0f172d04a">
        <updating/>
        <source>doCancel() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 December 2010	cnwrd1	Initial creation

*/

vars
	numRows,
	idx		: Integer;
	aString : CM_String;
	pinNum 	: String;
begin


	numRows := self.tbCargo.rows - self.tbCargo.fixedRows ;
	
	foreach idx in self.tbCargo.fixedRows+1 to numRows+1 do
		pinNum := self.tbCargo.accessCell(idx, 2 ).text;
		aString := self.tbCargo.accessRow(idx).itemObject.CM_String;		
		aString.string := pinNum;	
	endforeach;


	inheritMethod();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCellEditCheck" id="5c5ddec6-6dd9-434f-bf9f-468124fd14b6">
        <source>doCellEditCheck( _table : Table);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 December 2010	cnwrd1	Initial creation

*/


vars
	theTI : CM_TrackedItem;
	thePin : String;
	result : Boolean;
	table : Table;
begin
	//write table.accessCell(table.row, table.column).text;
	table := _table;
	
	theTI := table.accessRow(table.row).itemObject.CM_String.myObject.CM_TrackedItem;
	thePin := table.accessCell(table.row, table.column).text;
	
	result := self.checkPin( theTI, thePin);
	
	if result then
		table.accessCell(table.row, table.column + 1).text := self.pass;
	else
		table.accessCell(table.row, table.column + 1).text := self.fail;
	endif;
	
epilog

end;</source>
        <Parameter name="_table" type="Table"/>
    </JadeMethod>
