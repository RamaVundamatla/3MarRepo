    <JadeMethod name="getDisplayStringForAttribute" id="b1254d95-764e-4610-a95f-a02c600eed2f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 March 2014	cnwndl1	Initial creation

*/

vars

	type : String;					
	str	: String;					
	value : Decimal [23,10];

begin

	if _attrName.isMeasurementType then											
		// _attrName will be formatted as WTRow_&lt;real ent row name&gt;_&lt;weight unit&gt;	
		_attrName.getRowNameMeasureType(str, type);									
		return self.getMeasurementStringForAttrib(str, type, _short);				

	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementStringForAttrib" id="2568b5a1-cb10-4859-bfa0-45b160e948df">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 March 2014	cnwndl1	Initial creation

*/

vars

begin

	if _attrName = ETRow_CubicMetres then
		return app.convertMeasurementForDisplay(_measureType, self.cubicMetres);
		
	elseif _attrName = ETRow_ExtHeight then
		return app.convertMeasurementForDisplay(_measureType, self.extHeight);
		
	elseif _attrName = ETRow_ExtLength then
		return app.convertMeasurementForDisplay(_measureType, self.extLength);
		
	elseif _attrName = ETRow_ExtWidth then
		return app.convertMeasurementForDisplay(_measureType, self.extWidth);
		
	elseif _attrName = ETRow_IntHeight then
		return app.convertMeasurementForDisplay(_measureType, self.intHeight);
		
	elseif _attrName = ETRow_IntLength then
		return app.convertMeasurementForDisplay(_measureType, self.intLength);
		
	elseif _attrName = ETRow_IntWidth then
		return app.convertMeasurementForDisplay(_measureType, self.intWidth);
		
	elseif _attrName = ETRow_MaxKilos then
		return app.convertMeasurementForDisplay(_measureType, self.maxKilos);
		
	elseif _attrName = ETRow_TareKilos then
		return app.convertMeasurementForDisplay(_measureType, self.tareKilos);
		
	else
		return inheritMethod(_attrName, _measureType, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNext" id="0a959af8-3681-4272-a71f-010fd89c236b">
        <source>getNext() : CM_ContRange protected;
/*
 ------------------------------------------------------------------------
Created:			12 September 2002 by cnwdwq1
Purpose:			Returns the next contRange in the dict ascending
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	iter : Iterator;
	cr : CM_ContRange;
	aRange : CM_ContRange;
begin
	if self.pxyIsProxy then
		aRange := self.pxyGetRealObject();
	else
		aRange := self;
	endif;
	
	iter := self.myRoot.allContainerRanges.createIterator;
//	iter.startAtObject(self);
//	iter.startAtObject(aRange);
	self.myRoot.allContainerRanges.startKeyGeq(aRange.lower, iter); //rs dec 2005 par11118
	iter.next(cr);
	//iter.next seems to return aRange here - so do another iter.next
	if cr = aRange then
		iter.next(cr);
	endif;
	
	return cr;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <ReturnType type="CM_ContRange"/>
    </JadeMethod>
    <JadeMethod name="getPrevious" id="ec0e685b-a570-4dfb-9039-0b51182cd296">
        <source>getPrevious() : CM_ContRange protected;
/*
 ------------------------------------------------------------------------
Created:			12 September 2002 by cnwdwq1
Purpose:			Returns the previous object in the dict in key order.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	iter : Iterator;
	cr : CM_ContRange;
	aRange : CM_ContRange;
begin
	if self.pxyIsProxy then
		aRange := self.pxyGetRealObject();
	else
		aRange := self;
	endif;

	iter := self.myRoot.allContainerRanges.createIterator;
//	iter.startAtObject(self);
//	iter.startAtObject(aRange);
	self.myRoot.allContainerRanges.startKeyLeq(aRange.lower, iter); //rs dec 2005 par11118
	iter.back(cr);
	//iter.back seems to return aRange here - so do another iter.back
	if cr = aRange then
		iter.back(cr);
	endif;
	return cr;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <ReturnType type="CM_ContRange"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="f71617b4-7874-4daa-ae98-cfa6d4380074">
        <updating/>
        <source>setForCreate(pProxyContRange:CM_ContRange) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	pProxyContRange.raiseExceptionIfNotTransient(method);
	
	setForUpdate(pProxyContRange);
	self.myRoot := app.myRoot;
	//We have to do this here when ROOT has been set, as we are looking forwards and backwards
	//to see if there is an overlap. DQ.
	self.testForOverlappingRange(self); //rs dec 2005 par11118

end;</source>
        <Parameter name="pProxyContRange" type="CM_ContRange"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="6928e595-6ae6-428b-a21d-282c746d76fc">
        <updating/>
        <source>setForUpdate(pProxyContRange:CM_ContRange) updating;
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.lower := pProxyContRange.lower;
	self.upper := pProxyContRange.upper;
	self.cubicMetres := pProxyContRange.cubicMetres;
	self.isoType := pProxyContRange.isoType;
	self.extHeight := pProxyContRange.extHeight;
	self.extLength := pProxyContRange.extLength;
	self.extWidth := pProxyContRange.extWidth;
	self.intHeight := pProxyContRange.intHeight;
	self.intLength := pProxyContRange.intLength;
	self.intWidth := pProxyContRange.intWidth;
    self.maxKilos := pProxyContRange.maxKilos;
    self.tareKilos := pProxyContRange.tareKilos;
    self.heavyLift :=pProxyContRange.heavyLift;
    self.coolingType := pProxyContRange.coolingType;
    self.voltageType := pProxyContRange.voltageType;
    //self.hasCoolingWaterConnection := pProxyContRange.hasCoolingWaterConnection;
    self.heavyLift :=pProxyContRange.heavyLift;

end;</source>
        <Parameter name="pProxyContRange" type="CM_ContRange"/>
    </JadeMethod>
    <JadeMethod name="setMyRoot" id="cd495bf6-96a6-4abd-b909-c240fcfdc957">
        <updating/>
        <source>setMyRoot() updating;
// ---------------------------------------------------------------------------
// Created:     04 July 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myRoot := app.myRoot;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setProxy" id="9d6ff304-4909-4f60-a0d0-eb1afc2a22ad">
        <updating/>
        <source>setProxy(pLower, pUpper ,pIsoType : String;
         pCubicmeters : Decimal; 
         pExtHeight,pExtLength,pExtWidth : Decimal;
         pIntHeight,pIntLength,pIntWidth : Decimal;
         pMaxKilos, pTareKilos :Decimal;
		 _coolingType, _voltageType : Integer;
         pHeavyLift : Boolean) updating;

vars

begin

	self.raiseExceptionIfNotTransient(method);

	self.lower := pLower[1:11];
	self.upper := pUpper[1:11];
	self.isoType := pIsoType[1:4];
	self.cubicMetres := pCubicmeters;
	self.extHeight := pExtHeight; 
	self.extLength := pExtLength; 
	self.extWidth := pExtWidth;
	self.intHeight := pIntHeight;
	self.intLength := pIntLength;
	self.intWidth  := pIntWidth;
	self.maxKilos := pMaxKilos;
	self.tareKilos := pTareKilos;
    self.coolingType := _coolingType;
    self.voltageType := _voltageType;	
	//self.hasCoolingWaterConnection := pHasWater;
	self.heavyLift := pHeavyLift;
	self.myRoot := app.myRoot;
	
end;</source>
        <Parameter name="pLower" type="String"/>
        <Parameter name="pUpper" type="String"/>
        <Parameter name="pIsoType" type="String"/>
        <Parameter name="pCubicmeters" type="Decimal"/>
        <Parameter name="pExtHeight" type="Decimal"/>
        <Parameter name="pExtLength" type="Decimal"/>
        <Parameter name="pExtWidth" type="Decimal"/>
        <Parameter name="pIntHeight" type="Decimal"/>
        <Parameter name="pIntLength" type="Decimal"/>
        <Parameter name="pIntWidth" type="Decimal"/>
        <Parameter name="pMaxKilos" type="Decimal"/>
        <Parameter name="pTareKilos" type="Decimal"/>
        <Parameter name="_coolingType" type="Integer"/>
        <Parameter name="_voltageType" type="Integer"/>
        <Parameter name="pHeavyLift" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testForOverlappingRange" id="017199b4-0db3-4210-8fcf-9438c2a8c4a4">
        <source>testForOverlappingRange(_existingContRange: CM_ContRange) protected;
/*
 ------------------------------------------------------------------------
Created:			12 September 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	tempContRange	: CM_ContRange;
	duplContRange	: CM_ContRange;
begin

	//basic overlap test
	duplContRange := app.myRoot.allContainerRanges[self.lower];
	if duplContRange &lt;&gt; null
	and duplContRange &lt;&gt; _existingContRange then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.lower, null, null);
	endif;

	//------------------------------
	// Check for overlapping ranges
	//------------------------------
	tempContRange := self.getNext();

	if tempContRange &lt;&gt; null then
		//test whether the next's lower is within the new container range.
//		if (tempContRange.lower &gt; self.lower) and (tempContRange.lower &lt; self.upper) then
		if tempContRange.lower &lt;= self.upper then
			app.setContinueCMExceptions(false);
			app.raiseCMException2(ERR_OVERLAP_NEXTCR, tempContRange.lower, tempContRange.upper, null, null);
			return;		
		endif;
	endif;

	tempContRange := self.getPrevious();
	if tempContRange &lt;&gt; null then
		//test whether the previous's upper is within the new container range.
//		if (tempContRange.upper &gt; self.lower) and (tempContRange.upper &lt; self.upper) then
		if tempContRange.upper &gt;= self.lower then
			app.setContinueCMExceptions(false);
			app.raiseCMException2(ERR_OVERLAP_NEXTCR, tempContRange.lower, tempContRange.upper, null, null);
			return;		
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_existingContRange" type="CM_ContRange"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="6cc75122-8560-48b1-961d-07e37b0b0866">
        <source>validateForCreate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin

	self.testForOverlappingRange(self); //rs dec 2005 par11118
	self.validateMe;
end;</source>
    </JadeMethod>
