    <JadeMethod name="rel812_par31248" id="1957fa02-d8b3-446a-80c6-87a0690adbd1">
        <source>rel812_par31248();

/*

Purpose:			Copy back to 812 and setup there the new row ETRow-OrganisationUsers for CCMS HAT 2205 to keep default users
					and convert any existing reports which used ETRow_Users to the new equivalent ETRow-OrganisationUsers.
Parameters:			

Return Value:		


Date			Who		Reason
6 March 2013	cnjre1	Initial creation

*/

vars
	indx	: Integer;
	str		: String;
	cmqf		: CMQF_OrganisationAccess;
	reportUser	: CM_QryReportUser;
	entTblAgent : EntTableAgent;
	tmpArray : StringArray;
	
begin
	app.initialize();
	
	create entTblAgent transient;
	entTblAgent.myEntTableDataRoot := app.myRoot.myEntTableDataRoot;
	
	create tmpArray transient;
	tmpArray.add("ETRow_OrganisationUsers");
	tmpArray.add("ETDef_OrganisationAccess");
	entTblAgent.trxUpdateFromConstant(tmpArray);
	
	beginTransaction;
	foreach cmqf in CMQF_OrganisationAccess.instances do
		if cmqf.myQryReport.isKindOf(CM_QryReportUser) then
			reportUser := cmqf.myQryReport.CM_QryReportUser;
			indx := 0;
			foreach str in reportUser.allVisibleRows do
				indx := indx + 1;
				if str = "user" then
					reportUser.allVisibleRows[indx] := "organisationUsers";
					break;
				endif;
			endforeach;
			indx := 0;
			foreach str in reportUser.viewRows do
				indx := indx + 1;
				if str = "user" then
					reportUser.viewRows[indx] := "organisationUsers";
					break;
				endif;
			endforeach;
		endif;
	endforeach;
	commitTransaction;
	
	return;
	
	write ETRow_OrganisationUsers;
	write ETDef_OrganisationAccess;
epilog
	delete tmpArray;
	delete entTblAgent;
end;</source>
    </JadeMethod>
