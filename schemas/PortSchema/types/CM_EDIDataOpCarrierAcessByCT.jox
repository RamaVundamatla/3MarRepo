    <JadeMethod name="assignValueSpecial" id="aa9e0a5e-0d7b-4052-bdeb-7d8cfd77e01b">
        <updating/>
        <source>assignValueSpecial(_propName: String; _processedValue: String; _xlationOperator: CM_Operator): Boolean updating;
//
// 16 Aug 2018	jlgrs1	TFS 39619 PEN - Approved Carriers For Operator 
//
vars
	ediTI : CM_EDITrackedItem;
	cargoType : CM_CargoType;
	int : Integer;
begin
	if _propName = ETRow_CargoTypes then
		cargoType := self.getCargoType(_processedValue);
		int := cargoType.id;
		foreach ediTI in self.allEDITrackedItems do
			ediTI.setCargoType(int);
		endforeach;
	else
		return inheritMethod(_propName, _processedValue, _xlationOperator);
	endif;
epilog

end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
