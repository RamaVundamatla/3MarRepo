begin

	_value := null;
	if set then
		// set code here
		app.raiseSetVirtualError(class.name, method.name);
		return;		
	else
		// get code here
		self.myTerminal.findLocationFromString(self.targetLocn, false, tmpFoundLC, tmpFoundHeight);
		if tmpFoundLC &lt;&gt; null then
			//some locations do not have terminal areas e.g. voyage locations
			if tmpFoundLC.myTerminalArea &lt;&gt; null then
				_value := tmpFoundLC.myTerminalArea.typeString;
			endif;
		endif;		
	endif;
	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="targetTerminalAreaType" id="8e85807a-8969-4cf7-a93f-6c7c303f8071">
        <methodInvocation>mapping</methodInvocation>
        <source>targetTerminalAreaType(set: Boolean; _value: Integer io) mapping;
//--------------------------------------------------
// Created:	07 September 2004 By: cnwgd1
//--------------------------------------------------
vars
	tmpFoundLC : CM_LocationsController;
	tmpFoundHeight : Integer;
begin

	//CCMS 1277 - they want the Terminal area type integer as per DQ
	_value := TA_TYPE_NULL;
	if set then
		// set code here
		app.raiseSetVirtualError(class.name, method.name);
		return;		
	else
		// get code here
		self.myTerminal.findLocationFromString(self.targetLocn, false, tmpFoundLC, tmpFoundHeight);
		if tmpFoundLC &lt;&gt; null then
			//some locations do not have terminal areas e.g. voyage locations
