    <JadeMethod name="addObjectLabel" id="07e07385-615a-4cdc-b66d-55fa574dcfa8">
        <source>addObjectLabel(_theX, _theY : Integer;_theObject : CM_Object);
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
//	theTA		: CM_TerminalArea;
	anObject	: CM_Object;
	removeObj	: CM_Object;
//	idx			: CM_Object;
	theX		: Integer;
	theY		: Integer;
	iter01		: Iterator;
	
begin
	if _theObject = null then
		return;
	endif;
	
	iter01 := self.allPointLabels.createIterator();
	
	while iter01.next(anObject) do
		if global.isValidObject(anObject) then
			if anObject = _theObject then
				return;
			endif;
		else
			removeObj := anObject;
			theX := iter01.getCurrentKey(1).Integer;
			theY := iter01.getCurrentKey(2).Integer;
		endif;
	endwhile;

	if removeObj &lt;&gt; null then
		self.allPointLabels.removeKeyEntry(theX, theY, removeObj);
	endif;

	// Here we are putting in any labels, plus X &amp; Y so that at the end of drawing we can put the sub block stack labels on the grid
	self.allPointLabels.putAtKey(_theX,_theY, _theObject);
	
epilog
	delete iter01;
end;</source>
        <Parameter name="_theX" type="Integer"/>
        <Parameter name="_theY" type="Integer"/>
        <Parameter name="_theObject" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="addPointToSelected" id="aeb991b3-8eba-4be6-91a8-28084023aa83">
        <source>addPointToSelected(_thePoint : CMUI_GridPoint);
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		PAR 7372
//
// ---------------------------------------------------------------------------

vars

begin
	if _thePoint = null then
		return;
	endif;
	
	if not self.allSelectedPoints.includes(_thePoint) then
		self.allSelectedPoints.add(_thePoint);
	endif;

end;</source>
        <Parameter name="_thePoint" type="CMUI_GridPoint"/>
    </JadeMethod>
    <JadeMethod name="addRemoveTIToFromSelected" id="04074fd3-4ab5-49fa-b8e0-3c3ce59d7680">
        <source>addRemoveTIToFromSelected(_theTI : CM_TrackedItem);
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if not self.allSelectedTrackedItems.includes(_theTI) then
		self.allSelectedTrackedItems.add(_theTI);
	else
		self.allSelectedTrackedItems.remove(_theTI);
	endif;

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addTIToSelected" id="c792bea2-98bb-4efe-9b63-fec55fa0e994">
        <source>addTIToSelected(_theTI : CM_TrackedItem);
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
