    <JadeMethod name="validateCriteriaLineRemoval" id="5f635277-716b-4adf-b166-e55b95230d19">
        <source>validateCriteriaLineRemoval(_crit : CM_SelectorCriteriaLine) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog

*/

vars

begin
	if _crit = null then
		app.msgBox(app.getErrorString2(CMUI_MustSelect, app.getErrorString(CMUI_Selector_CriteriaLine), app.getErrorString(Delete)), app.getErrorString(CMUI_Nothing_Selected), MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;

	if (self.myTerminal &lt;&gt; null) and 
	   (_crit.myQueryProperty.propertyName = CM_Invoice::myTerminal.name ) then	
		app.msgBox(app.getErrorString1(CMUI_Selector_No_Retreive, app.getErrorString(Terminal)), app.getErrorString(NotAllowed), MsgBox_Exclamation_Mark_Icon);
		return false;

	endif;


	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_crit" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateCriteriaLineUpdate" id="b88f6e68-34fd-4b7f-b5fc-3ccd89caad83">
        <source>validateCriteriaLineUpdate(_propertyName : String) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2022 navtnr20	TFS CR 55301 Task 55553: UI - New Selector Dialog

*/

vars
	criteriaHolder		: CM_QueryCriteriaLineHolder;
begin
	criteriaHolder := self.myCriteriaLineHolder;
	
	if _propertyName = 'InvoceLine' then
		if criteriaHolder.allCriteriaByPropertyName['InvoceLine', 'CM_Invoice'] &lt;&gt; null then
			app.msgBox('You must first remove the Invoice Code criteria line', app.getErrorString(NotAllowed), MsgBox_Exclamation_Mark_Icon);
			return false;
		endif;
	endif;


	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_propertyName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
