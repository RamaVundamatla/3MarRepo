    <JadeMethod name="doClonedMenuClickSpecial" id="33154916-93f2-44f2-93e5-018f2141a711">
        <updating/>
        <source>doClonedMenuClickSpecial(menuItem: MenuItem input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 October 2015	cnwndl1	Initial creation	Par 37011

*/

vars

	obj	: Object;
	ti : CM_TrackedItem;
	realTiSet : CM_TISet;
	taskFormName : String;
	taskFormNameLength : Integer;
	passedAction : Integer;

begin
	
	taskFormName := CMUI_TasksForm.name;
	taskFormNameLength := taskFormName.length;
	if menuItem.helpKeyword.length &gt; taskFormNameLength and menuItem.helpKeyword[1:taskFormNameLength] = taskFormName then
		passedAction := menuItem.helpKeyword[taskFormNameLength + 2:1].Integer;
		create realTiSet transient;
		ti  := self.myCurrentTI;
		if ti = null then
			return;
		endif;
		realTiSet.add( ti );
		self.myAssistant.showTasksForm (ti, realTiSet, true, passedAction );
		return;
	endif;

	inheritMethod(menuItem);

epilog

	delete realTiSet;

end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMenuRequestTaskClick" id="7461b577-fd5d-4e9f-892e-fcbfdbfbd961">
        <source>doMenuRequestTaskClick();
// ---------------------------------------------------------------------------
// Created:     08 September 2008 by concms1
// Purpose:     PAR 17884/CCMS 1742 - ToDoo tasks interim solution
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ti				: CM_TrackedItem;
	tiSet			: CM_TISet;
	obj				: Object;
	form			: CM_BaseForm;
begin

	ti := self.myCurrentTI.CM_TrackedItem;
	
	// get all selected cargo items 
	create tiSet transient;
	
	tiSet.add(ti);
	
	form := app.loadForm (CMUI_JobRequestForm, CMUI_Assistant, false, false, false, self.myTerminal, null).CM_BaseForm;
	
	form.displaySelectorResults (tiSet, null);
	
	form.show;
epilog
	delete tiSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuSetStopsClick" id="3313f561-b2b9-415b-bcaa-578019d0bacd">
        <updating/>
        <source>doMnuSetStopsClick( _menuItem : MenuItem input ) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	23 May 2006 By cnwth2

Purpose:	PAR 11791 - Bulk update of tasks and stops - overhaulled

Changed On	Changed By	Reason
27/01/2010	cnwrl1		PAR 21889 - CCMS 1002 = Stops and Italian Customs - T1015 = Expiry Date for Stops Clearance
15/06/2010	cnwcs5		par 24342 - new form for stops maintenance
----------   ----------  --------------------------------------------------
*/
vars
	lTI			: CM_TrackedItem;
begin
	lTI := self.myCurrentTI;
	
	self.myAssistant.showStopsForm_TI (lTI, self.tblData.allSelectedObjects, app.getMyUser.canUpdateStops( self.myTerminal) );	//cnwrd1 par 29440 27.4.2012	

	return; 
/*	
	if lTI = null then
		app.msgBox(	app.getString( CannotUpdateStopNothingSelectd ),
					app.getString( Please_Select_Cargo_Items ),
					MsgBox_Stop_Icon + MsgBox_OK_Only );
		return;
	endif;
	
	stopsTable := _menuItem.userObject.CM_StopsTable;
	
	// cnwrl1 27/01/2010 PAR 21889 - start of coding
	// NOTE: This reproduces the release 7.7.3 behaviour - ie it only handles the last TrackedItem clicked on.
	create tiSet transient;
	while true do : update_TrackedItems
		self.myAssistant.contextMenuTIsStop( stopsTable, lTI, tiSet );
		
		if app.myPassport.noErrors then
			self.clearErrorWarnings();
			return;
		endif;
		result	:= app.showErrorWarningDialog(	app.getString( EWD_Cannot_Continue, app.getString( HeadingSaved ) ),
												app.myPassport,
												ErrWarnMode_Add + ErrWarnMode_CanAckWarnings );
		if app.myPassport.noErrors and result = IDOK then
			app.myPassport.warningsAcknowledged	:= true;
			continue update_TrackedItems;
		endif;
		self.setAllErrorWarnings( app.myPassport );	// copies errors to this form and shows in err/warnings window
		return;
	endwhile update_TrackedItems;*/
	// cnwrl1 27/01/2010 PAR 21889 - end of coding
	
	/* cnwrl1 27/01/2010 PAR 21889 - what it was
	// get all selected cargo items to add or remove stop from all.
	create tiSet transient;
	tiSet.add(ti);
			
	create stopArr transient;
	stopArr.add(tmpStopTable.id);

	if (not ti.hasStopOfType(tmpStopTable)) then //must be adding
		// create stop for selected cargo items...
		while true do
			app.myTrxCA.trxCreateStopsForTIs(tiSet, stopArr, app.myPassport);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				if self.ackTodoStop then
					app.msgBox('Stop ' &amp; tmpStopTable.heading &amp; ' added to ' &amp; ti.id &amp; '.', 'Info', MsgBox_OK_Only + MsgBox_Information_Icon);
				endif;
				break;
			else
				result := app.showErrorWarningDialog('Add Stops ', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknowledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			endif;
			
			break;
		endwhile;
	
	else
		// remove stop for selected cargo items...
		if tmpStopTable.requiresInfo then
			// check stop requires extra info. before it can be cleared...
			create inputBox;
			inputBox.setAssistantAndTerminalRefs(self.myAssistant, self.myTerminal);
//			inputBox.init(app.getErrorString(LBLCustoms_entry_number), app.getErrorString(LBLEnterCustomsEntryNum),"", 11, TextBox.DataType_AlphaNumeric, false);	// cnwrl1 05/06/2009 PAR 19574 - what it was
			inputBox.init(	app.getErrorString(LBLCustoms_entry_number), app.getErrorString(LBLEnterCustomsEntryNum),
							"", 11, TextBox.DataType_AlphaNumeric, TextBox.Case_None, false );

			inputBox.showModal;
			if inputBox.modalResult &lt;&gt; IDOK then
				self.clearErrorWarnings();
				return;
			endif;
			tmpCENumber := inputBox.txtInput.text.trimBlanks;
		endif;
		
		while true do
			app.myTrxDA.trxDeleteStopForTIsBulk(tiSet, tmpStopTable, tmpCENumber, app.myPassport);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				if self.ackTodoStop then
					app.msgBox('Stop ' &amp; tmpStopTable.heading &amp; ' removed from ' &amp; ti.id &amp; '.', 'Info', MsgBox_OK_Only + MsgBox_Information_Icon);
				endif;
				break;
			else
				result := app.showErrorWarningDialog('Remove Stops ', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					// there must have just been warnings that the user has acknowledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			endif;
			
			break;
		endwhile;
	endif;
	
	_menuItem.checked := not _menuItem.checked;

epilog
	delete tiSet;
	delete stopArr;
	mousePointer := MousePointer_Default;
end;
	cnwrl1 27/01/2010 PAR 21889 - end of what it was */
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuTasksAddClick" id="7ced900e-d2ef-4339-a48a-7f50a356746e">
        <updating/>
        <source>doMnuTasksAddClick(menuItem: MenuItem input) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	23 May 2006 By cnwth2

Purpose:	PAR 11791 - Bulk update of tasks and stops - overhaulled

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	tmpTI 			: CM_TrackedItem;
	taskDesc 		: CM_ToDoTaskDesc;
	tiSet			: CM_TISet;
	result			: Integer;
begin
	
	if menuItem = null then
		return;
	else
		taskDesc := menuItem.userObject.CM_ToDoTaskDesc;
	endif;

	tmpTI := self.myCurrentTI;
	if tmpTI = null then
		return;
	endif;
	
	create tiSet transient;
	tiSet.add(tmpTI);
	
	while true do
		app.myTrxUA.trxUpdateTIToDoTaskAddBulk(taskDesc, tiSet, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			if self.ackTodoStop then
				app.msgBox('Task ' &amp; taskDesc.description &amp; ' added to ' &amp; tmpTI.id &amp; '.', 'Info', MsgBox_OK_Only + MsgBox_Information_Icon);
			endif;
			break;
		else
			result := app.showErrorWarningDialog('Add Todo Task', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		break;
	endwhile;

epilog
	delete tiSet;
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuTasksCompleteClick" id="33465b92-a907-4d9b-b174-b9acb6e9867e">
        <updating/>
        <source>doMnuTasksCompleteClick(menuItem: MenuItem input) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	23 May 2006 By cnwth2

Purpose:	PAR 11791 - Bulk update of tasks and stops - overhaulled

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

	tmpTI			: CM_TrackedItem;
	taskDesc 		: CM_ToDoTaskDesc;
	realTiSet		: CM_TISet;
	pxyTiSet		: CM_TISet;
	result			: Integer;
	tiTask 			: CM_ToDoTask;
	resourceUsageProxys : CM_ResourceTypeUsageSet;
	
begin

	if menuItem = null then
		return;
	endif;
	
	if menuItem.userObject = null then
		return;
	endif;
	taskDesc := menuItem.userObject.CM_ToDoTaskDesc;
	
	tmpTI := self.myCurrentTI;
	if tmpTI = null then
		return;
	endif;
	
	create realTiSet transient;
	realTiSet.add(tmpTI);
	
	create pxyTiSet transient;
	//+cnwml2 MSL CCMS 1017

	//31 Dec 2009 NDL CCMS MES 1006	- Common code migrated up to assistant
	if not self.myAssistant.doTaskProxySetForComplete( taskDesc.code, pxyTiSet, tmpTI, realTiSet, resourceUsageProxys) = IDOK then
		return;
	endif;
		
	while true do
		app.myTrxUA.trxUpdateTIToDoTaskCmpltBulk(taskDesc, pxyTiSet, resourceUsageProxys, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			if self.ackTodoStop then
				app.msgBox('Task ' &amp; taskDesc.description &amp; ' completed for ' &amp; tmpTI.id &amp; '.', 'Info', MsgBox_OK_Only + MsgBox_Information_Icon);
			endif;
			break;
		else
			result := app.showErrorWarningDialog('Complete Todo Task', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		break;
	endwhile;

epilog

	if pxyTiSet &lt;&gt; null and not pxyTiSet.isEmpty then
		pxyTiSet.purge;
	endif;
	delete pxyTiSet;
	delete realTiSet;

end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuTasksRemoveClick" id="9dfc1dfd-acb6-40d0-b2c5-7fb7b3e09f4c">
        <updating/>
        <source>doMnuTasksRemoveClick(menuItem: MenuItem input) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	23 May 2006 By cnwth2

Purpose:	PAR 11791 - Bulk update of tasks and stops - overhaulled

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	tmpTI 			: CM_TrackedItem;
	taskDesc 		: CM_ToDoTaskDesc;
	tiSet			: CM_TISet;
	result			: Integer;
begin
	if menuItem = null then
		return;
	endif;
	
	if menuItem.userObject = null then
		return;
	endif;
	
	taskDesc := menuItem.userObject.CM_ToDoTaskDesc;
	
	tmpTI := self.myCurrentTI;
	if tmpTI = null then
		return;
	endif;
	
	create tiSet transient;
	tiSet.add(tmpTI);

	//result := app.msgBox(app.getErrorString(TaskRemoveConfirm), app.getErrorString(Remove_Task), MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
	result := app.msgBox('Are you sure you want to remove task ' &amp;
			taskDesc.description &amp; ' from ' &amp; tmpTI.id &amp; '?', 
			app.getErrorString(Remove_Task), MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
	
	if result = MsgBox_Return_No then
		return;
	endif;

	while true do
		app.myTrxUA.trxUpdateTIToDoTaskRemBulk(taskDesc, tiSet, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			if self.ackTodoStop then
				app.msgBox('Task ' &amp; taskDesc.description &amp; ' removed from ' &amp; tmpTI.id &amp; '.', 'Info', MsgBox_OK_Only + MsgBox_Information_Icon);
			endif;
			break;
		else
			result := app.showErrorWarningDialog('Remove Todo Task', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		break;
	endwhile;

epilog
	delete tiSet;
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doPrint" id="015d6601-1b96-4201-8b40-75622491e008">
        <updating/>
        <source>doPrint() updating;
// ---------------------------------------------------------------------------
// Created:     May 2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 14 May 2008	cnwkpd1		PAR #16748 - Correct handling of deleted/null TI
// ---------------------------------------------------------------------------

vars
	tiReport	: CM_TIEnquiryOutput;
	progress	: CMS_Progress;
	now			: TimeStamp;
	ti 			: CM_TrackedItem;
	tmpReport	: JadeReport;
	tp			: CM_GenericTablePrint;
	bol			: CM_BOL;
	printTableObj	: CM_GenericTablePrint;
	invalidTI	: Boolean;

begin
	//if not self.myCurrentObject.isKindOf(CM_TrackedItem) then
	//	return;
	//endif;
	
	// PAR #16748
	if self.myCurrentTI = null then
		app.msgBox('No current item selected', 'Nothing to print', MsgBox_Exclamation_Mark_Icon);
		return;	
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	now := self.systemToLocalTime(app.actualTimeServer());	// 13/6/16 cnwmp6 TFS 488 - Multi timezone support
	create tmpReport transient;
	app.printer.close;
	app.printer.setMargins(Print_Portrait,5,5,10,10);
	app.printer.topOfPage := 1;
	app.printer.bottomOfPage := 1;
	app.printer.setReport(tmpReport);	//Capture for print preview.

	create tiReport transient;
	tiReport.initReport();	
	app.printer.setHeader(tiReport.frHeader);
	app.printer.setFooter(null);
	tiReport.lblPrintedBy.caption := app.getMyUserCode &amp; " - " &amp; now.String;
	
	ti := self.myCurrentTI;
	
	on Exception do app.handleDeletedObject(exception, ti, invalidTI);	// PAR #16748
	
	tmpReport.description := "Cargo Enquiry " &amp; ti.id;
	// setup header information
	tiReport.lblCargoTypeLbl.visible := true;
	tiReport.lblTIID.visible := true;
	tiReport.picLogo.picture := app.getPicLogoPort; // The bitmap called rptlogo.bmp in reports/formats
	tiReport.lblCargoType.caption := ti.isoTypeDesc.trimBlanks; //ti.isoTypeDesc;
	tiReport.lblTIID.caption := ti.id;
	
	create printTableObj transient;
	create progress transient;
	printTableObj.printTable(self.tblThumb, true, progress);

	app.printer.close();
	app.printPreview(tmpReport, true);
	
	
epilog
	app.printer.close();
	
	delete progress;
	delete printTableObj;
	delete tiReport;
	
	delete progress;
	delete tp;
	delete tiReport;
	app.mousePointer := MP_DEFAULT;

end;</source>
    </JadeMethod>
    <JadeMethod name="doPrintList" id="104976a8-69f0-4e6e-b94b-087b91010bd4">
        <source>doPrintList();
// ---------------------------------------------------------------------------
// Created:     23 February 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.tblData.rows &lt;= self.tblData.fixedRows then
		app.msgBox('No items are currently listed', 'Nothing to print', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	self.tblData.printTable('Cargo Listing');
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSearch" id="f3a1646a-8feb-4775-bbf0-e5e9a4a43a1d">
        <updating/>
        <source>doSearch() updating, protected;
// ---------------------------------------------------------------------------
// Created:     29 August 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 12.Jun.2025  navsp1  JIRA-35052  Total items displayed was not shown in Cargo List View form
vars
	tmpCargoType	: CM_CargoType;
begin
	self.myCurrentTI := null; //PAR 16931 cnwgb1
	tmpCargoType := self.cmbCargoType.listObject.CM_CargoType;
	if tmpCargoType = null then
		self.myQuickViewController.cargoType := null;
	else
		self.myQuickViewController.cargoType := tmpCargoType.id;
	endif;
	
	self.myQuickViewController.id := self.txtCargoID.text;
	self.myQuickViewController.searchArchived := self.chkArchivedVoy.value;

	
	if self.myQuickViewController.doSearch() then
		if self.myQuickViewController.allTIs.size &gt; 0 then
			self.staMain.caption := self.myQuickViewController.allTIs.size.String &amp; ' rows found';
			self.showResults();
		else
			self.tblThumb.rows := 0;
			self.tblData.rows := self.tblData.fixedRows;
			self.staMain.caption := 'No results found';
		endif;
        self.staMain.zOrder(1);                 //JIRA-35052
	else
		// an error occured which should have already been reported.
		self.staMain.caption := null;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="dbadaf47-e51d-4ea8-8c0f-d3bae02bfe23">
