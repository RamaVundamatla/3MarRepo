        <Parameter name="_proxyCraneMoveRates" type="CM_CraneMoveRates"/>
        <Parameter name="_craneMoveRates" type="CM_CraneMoveRates" usage="output"/>
        <Parameter name="_crane" type="CM_Crane"/>
