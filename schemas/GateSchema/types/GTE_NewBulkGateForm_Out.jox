    <JadeMethod name="resetWeight" id="de48bf87-eb74-4a58-8542-c3a60c6bcf03">
        <source>resetWeight(table : Table input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Nov 2016	cnwns1	Initial creation
27 Oct 2025 navhl20 Bug MTN-36207: MTN - Generic API for Bulk Gate IN/OUT
*/

vars

begin
    if  table.row &gt; table.fixedRows then
		self.txtWeightOUT.setValue(0);
		self.lblCargoWeight.caption := null;
		if self.myAssistant &lt;&gt; null then						//27.10.2025 navhl20 #36207
			self.myAssistant.clearCurrentGateScanRecord();
		endif;
	endif;
end;
</source>
