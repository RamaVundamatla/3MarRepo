<Class name="CM_QBooleanStopsProperty">
    <JadeMethod name="canBeViewed" id="4f68220b-00b8-4045-b4d9-5490a2a22583">
        <source>canBeViewed(_passport: CM_Passport): Boolean;
//----------------------------------------------------------------
//	Created:	02 December 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	stopTable		: CM_StopsTable;
	user		: CM_User;
	term		: CM_Terminal;
begin
	//stops have view/update security - check that the user can view these stops
	//this may be a bit extravagant  - can always remove later
	
	if _passport = null then 
		return true; 
	endif;
	user := _passport.myUser;
	term := _passport.myTerminal;
	stopTable := app.myRoot.allStopsTable[self.stopId];
	
	if stopTable = null
	//or term = null		// 20/02/2009 cnwar2 #17949
	or user = null then 
		return true; 
	endif;
	
	/*if user.canViewStop(term, stopTable) then 
		return true;
	endif;*/
	foreach term in app.myRoot.allTerminals do			// 20/02/2009 cnwar2 #17949
		if user.canViewStop(term, stopTable) then 		// This method is used by selector which is not terminal specific
			return true;								// Changed to allow view if user has permission for ANY terminal
		endif;	
	endforeach;
	
	return false;
	
	
	
end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
