<Class name="CM_EDILoadListTIMSK" id="f66bb011-d35d-4273-bbb2-c628cadac449">
    <superclass name="CM_EDILoadListTI"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <JadeMethod name="setDefault" id="4ec2593f-f161-49c8-8c9d-b460a4093fd6">
        <updating/>
        <source>setDefault(_infoTI: StringArray) updating;
//----------------------------------------------------------------
//	Created:	03 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
//08 Apr 2013	cnwcs5	CCMS POL 2097/par 31259 - commodity xlations
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	infoTI		: StringArray;
	loadPortCode,
	commodity	: String;
	xlationOperator : CM_Operator;
	foundMatch : Boolean;
begin
	loadPortCode 		:= self.getMyTerminal.getConfig(PortDestCode).String;
	infoTI 				:= _infoTI;
	self.operatorCode 	:= "MSK";					
	self.locationId		:= "null";
	xlationOperator := app.myRoot.allOperators["MSK"];
	
	self.setLoadPort(loadPortCode);						//loadport	
	
	//blank,1
	self.setID(infoTI[2]);								//cargo ID
	
	self.bookingRef	:= infoTI[3];						//bookingRef
	
	self.setISOType(xlationOperator.getXlationSystemCode(infoTI[4], XLATION_TYPE_ISOTYPE_BYOP, foundMatch)[1:4]);
	self.setDischargePort(infoTI[5][1:5]);				//discharge
	self.setDestinationPort(infoTI[6][1:5]);			//Dest				
	// par 31259 - set temp b4 commodity as it is needed for xlation
	commodity 	:= infoTI[7];
	self.weight	:= infoTI[8].String[9].Integer;			//weight
	
	self.setTemp(infoTI[9]);							//temp
	self.setCommodity(commodity, app.myRoot.allOperators[self.operatorCode]);
	
	if infoTI[10] &lt;&gt; null then
		self.setHumidity( infoTI[10].asDecimalJMT );					//humid //par18451 nov 2008 cnwrs1
	endif;
	
	if infoTI[11] &lt;&gt; null then
		self.setVents(infoTI[11]);							//vents
	endif;
	
	if infoTI[12] &lt;&gt; null then
		self.setCarbonDioxide( infoTI[12].asDecimalJMT );			//CO2
	endif;
	
	if infoTI[13] &lt;&gt; null then
		self.setOxygen( infoTI[13].asDecimalJMT );							//O2
	endif;
	
	self.setCooledType(infoTI[14]);						//W/C,14
	self.setFullEmpty(infoTI[15]);						//empty
	self.setHazardous(infoTI[16]);						//haz?
	self.setOutOfGauge(infoTI[17]);						//OD?
	//Gate-In, 18
	//Count, 19
end;</source>
        <Parameter name="_infoTI" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="setDestinationPort" id="a912a7d1-4152-41b1-8f5a-6e1cd6e844b0">
        <updating/>
        <source>setDestinationPort(_code: String) updating;
//----------------------------------------------------------------
//	Created:	12 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// Dont translate it - want to use it in a report
vars

begin
	if _code &lt;&gt; null then
		self.destinationPort := _code;
	endif;

epilog

end;</source>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="20b0ab7e-e6cc-404f-901b-b1ab153229d0">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
//----------------------------------------------------------------
//	Created:	23 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod(_proxyEDITI);

	if self.temperature = NULL_TEMPERATURE then
		self.temperature := app.temperatureConversion(true, NULL_TEMPERATURE).rounded;
	endif;

epilog

end;</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setTemp" id="ddf32e50-7462-4a3c-bbeb-7e70c9d8fc24">
        <updating/>
        <source>setTemp(_temp: String) updating;
//----------------------------------------------------------------
//	Created:	10 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	//the temp is fahreinhiet SAVE AS FAHREINHIET
	
	if _temp.isReal then
		self.temperature := _temp.Real;
	else
		self.temperature := app.temperatureConversion(true, NULL_TEMPERATURE).rounded;
	endif;

end;</source>
        <Parameter name="_temp" type="String"/>
    </JadeMethod>
</Class>
