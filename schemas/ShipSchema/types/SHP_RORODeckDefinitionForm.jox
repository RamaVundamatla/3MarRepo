    <JadeMethod name="doFrameDrawContextMenuEvent" id="bf82c18e-e322-4661-b70e-27e33ea381af">
        <updating/>
        <source>doFrameDrawContextMenuEvent(cntrl: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     January 2010 ANDREW BISHOP
//
// CALLED BY CMUI_POINTDRAWINGFRAME, no references
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpSect 	: CM_VesselSection;
	posM 		: Decimal[12,2];
	deckItem 	: CM_DeckItem;

begin
	if self.mode = self.Mode_View then
		return false;
	endif;

	// ### SECTION
	tmpSect := self.getSectionFromPixelX(x, posM);
	if tmpSect &lt;&gt; null then
		self.mnuDrawSectionDelete.enabled := true;
		self.mnuDrawSectionDelete.caption := app.getErrorString(Delete_section) &amp; " " &amp; tmpSect.code &amp; app.getErrorString(At) &amp; tmpSect.position.String;
		self.mnuDrawSectionDelete.userObject := tmpSect;
		self.mnuDrawSectionNew.caption := app.getErrorString(Add_section);
		self.mnuDrawSectionNew.enabled := false;
		self.mnuDrawSectionNew.helpKeyword := null;
	else
		self.mnuDrawSectionDelete.userObject := null;
		self.mnuDrawSectionDelete.caption := app.getErrorString(Delete_section);
		self.mnuDrawSectionDelete.enabled := false;
		self.mnuDrawSectionNew.caption := app.getErrorString(Add_section) &amp; app.getErrorString(At)  &amp; posM.String &amp; " " &amp; app.getErrorString(Metres);
		self.mnuDrawSectionNew.helpKeyword := posM.String;
		self.mnuDrawSectionNew.enabled := true;
	endif;
	
	if self.frmScrollable.myDrawingFrame &lt;&gt; null then
		self.mnuGrphPointAfter.enabled := self.frmScrollable.myDrawingFrame.CMUI_PointDrawingFrame.doIsPointDetected();
		self.mnuGrphPointBefore.enabled := self.mnuGrphPointAfter.enabled;
		self.mnuGrphPointRemove.enabled := self.mnuGrphPointAfter.enabled;
	endif;
	if self.myCurrentProxyItemLayout &lt;&gt; null then
		deckItem := self.myCurrentProxyItemLayout.myDeckItem;
		if deckItem &lt;&gt; null then			
			if deckItem.isKindOf(CM_ROROLocnDefn) then
				self.mnuEditRealDeckItem.enabled := false;
				if deckItem.CM_ROROLocnDefn.allROROSlotDefnByOrdinal.isEmpty() then
					self.mnuSlotAvailability.enabled := false;
				else
					self.mnuSlotAvailability.enabled := true;
				endif;
			else
				self.mnuEditRealDeckItem.enabled := true;
				self.mnuSlotAvailability.enabled := false;
			endif;
		else
			self.mnuEditRealDeckItem.enabled := false;
		endif;	
	endif;	
	
	// ### MENU
	self.origMouseY := y;
	self.origMouseX := x;
	return self.showContextMenu(self.mnuGrphMain, cntrl, conwin, mouse, x, y);

end;</source>
        <Parameter name="cntrl" type="Frame" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
