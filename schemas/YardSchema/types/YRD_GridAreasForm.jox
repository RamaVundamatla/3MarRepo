    <JadeMethod name="doMnuLcnCLICK" id="3dbd338a-8275-4871-af2d-99143cc6804c">
        <updating/>
        <source>doMnuLcnCLICK(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	menuParams : CMIF_MenuParams;
begin
	if  menuItem.userObject &lt;&gt; null then
		menuParams := menuItem.userObject.CMIF_MenuParams;
		self.showRestrictionsForm(menuParams.object2.CM_TerminalArea,menuParams.integer1,menuParams.object1.CM_Object);
	endif;
epilog
