    <JadeMethod name="xGCDCStatusBarStep3" id="3ed4dca1-d681-4b2c-a7ec-fa88736d451c">
        <source>xGCDCStatusBarStep3();

/*

Purpose:		Plan discharge job and check that the status bar is correct	

Date			Who		Reason
14/05/2013		cnwmh5	Initial creation

*/

vars

	voyageJob						: CM_VoyageJob;
	
begin

	app.writeLog("STEP 3", LogINFO);
	app.writeLog("Create discharge job.  Please wait...", LogINFO);
	
	self.roroLCs.clear();
	self.getJobROROControllerByID(self.myVoyage.code, self.myDeck.code, null, "D4210190", self.roroLCs, false, 1); 
	self.getJobROROControllerByID(self.myVoyage.code, self.myDeck.code, null, "D4210192", self.roroLCs, false, 1); 
	voyageJob := self.addVoyageROROJob(self.myVoyage, self.myDeck, "UT_MHQ", self.roroLCs, true);
	assertTrue(voyageJob &lt;&gt; null);

	self.roroLCs.clear();
	self.getJobROROControllerByID(self.myVoyage.code, self.myDeck.code, null, "D4270690", self.roroLCs, false, 1); 
	self.getJobROROControllerByID(self.myVoyage.code, self.myDeck.code, null, "D4270692", self.roroLCs, false, 1); 
	voyageJob := self.addVoyageROROJob(self.myVoyage, self.myDeck, "UT_MHQ", self.roroLCs, true);
	assertTrue(voyageJob &lt;&gt; null);
	
	self.roroLCs.clear();
	self.getJobROROControllerByID(self.myVoyage.code, self.myDeck.code, null, "D4211184", self.roroLCs, false, 1); 
	voyageJob := self.addVoyageROROJob(self.myVoyage, self.myDeck, "UT_MHQ", self.roroLCs, true);
	assertTrue(voyageJob &lt;&gt; null);
	
	self.roroLCs.clear();
