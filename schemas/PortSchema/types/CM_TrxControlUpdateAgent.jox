    <JadeMethod name="trxUpdateTIRemarks" id="27b4c906-e86f-4bd1-b365-9491ff97c993">
        <updating/>
        <source>trxUpdateTIRemarks(_theProxyTI : CM_TrackedItem input; 
				  _theRemarks  : String;
				  _passport    : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22 Oct 2024 navma1	MTN-33173 MTN - Error 1081 occurs when attempting to create or update cargo items. The system fails when trying to create associated damage instances
// ---------------------------------------------------------------------------
vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportSilentExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 10, _passport);

	_passport.useTITransactionDeferUpdate	:= true;		//22.10.2024 navma1 #MTN-33173
	_passport.useTIDictDeferUpdate			:= true;		//22.10.2024 navma1 #MTN-33173
	
	beginTransaction;
	
	app.myUtilityUA.utlUpdateTIRemarks(_theProxyTI, _theRemarks, _passport);
	
	if _passport.noErrors then								//22.10.2024 navma1 #MTN-33173
		_passport.doDeferredUpdates();
	endif;
	
epilog	
	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_theProxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_theRemarks" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
