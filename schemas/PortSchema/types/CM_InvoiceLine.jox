    <JadeMethod name="setWebValues" id="3d12a772-7842-4748-8514-4a1825509525">
        <updating/>
        <source>setWebValues(_externalRef1: String; _externalRef2: String; _externalRef3: String; _externalRef4 : String; _remarks: String; _uomCode: String; _date: TimeStamp) updating;
/*

Purpose:

	A method to set the additional details required for a TAS invoice line

Parameters:			

	_extRef2LineNumber
	_amount				
	_extRef4FileNumber
	_extRef5YourRef
	_quantity
	_taxCode
	_uom
	_extRef6Narration

Return Value:

	None

Date		Who		Reason
06/06/2023	navcs2	ChangeRequest 56901: [58447]: TAS Invoicing Invoice Endpoint - JADE changes
//20/01/2026	navkc1 JIRA MTN 36571 - ROS - 2 - External Reference updates in API
*/

vars

begin
	self.externalRef1 		:= _externalRef1;
	self.externalRef2 		:= _externalRef2;
	self.externalRef3 		:= _externalRef3;
	self.externalRef4 		:= _externalRef4; 	//20/01/2026	navkc1 JIRA MTN 36571
	self.remarks 			:= _remarks;		//20/01/2026	navkc1 JIRA MTN 36571
	self.setUOMCode(_uomCode);
	self.chargeTime			:= _date;
epilog

end;</source>
        <Parameter name="_externalRef1" type="String"/>
        <Parameter name="_externalRef2" type="String"/>
        <Parameter name="_externalRef3" type="String"/>
        <Parameter name="_externalRef4" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_uomCode" type="String"/>
        <Parameter name="_date" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="0c93e4ac-6b57-460e-9d58-380baebd1662">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2018	jlgmp6	Initial creation	TFS37718

*/

vars
	propName	: String;

begin

	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if propName = CM_InvoiceLine::myInvoiceLineOriginal.name or
		propName = CM_InvoiceLine::myInvoiceLineAdditional.name then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;


end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="status" id="4e4b0835-9340-4965-8917-1b615d3e162f">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>status(set: Boolean; value: Integer io) mapping, updating;

begin


	if set then
		if value = self.status then
			app.setContinueCMExceptions(false);
			app.raiseCMException2(ERR_STATUS_CHANGE, "line " &amp; self.sequenceNum.String, "Is already status of " &amp; self.getStatusDescription(self.status),null, null);
			return;
		endif;
		if invoice &lt;&gt; null then
			if invoice.isPosted 
			and not invoice.isTASInvoice() then // ### TFS CR 58085 TASK 61346 11JAN2024 NAVAB1 - if creating a credit note from a TAS invoice void the TAS lines.
				app.setContinueCMExceptions(false);
				app.raiseCMException2(ERR_STATUS_CHANGE, invoice.sequenceNum.String,null,null, null);
				return;
			endif;
		endif;
		status := value;
	else
		value := status;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="trackedItemTEU" id="e123e39f-e6f3-44c1-a19a-4794fb561a75">
