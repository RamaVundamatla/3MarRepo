    <JadeMethod name="utlUpdateInvLineExtTS05" id="9256e609-af9a-49d9-932c-77596db60c26">
        <updating/>
        <source>utlUpdateInvLineExtTS05(_invoice: CM_Invoice input; _ts: TimeStamp; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2019	jlgmp6	Initial creation	TFS42036

*/

vars
	invLine: CM_InvoiceLine;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);

	foreach invLine in _invoice.invoiceLines where not invLine.externalTS05.isValid() do
		exclusiveLock(invLine);
		self.myUpdateAuditAgent.audUpdateGeneric(invLine, true);
		if _passport.noErrors then
			invLine.setExternalTS05(_ts);
		endif;
		if _passport.noErrors then
			self.myUpdateAuditAgent.audUpdateGeneric(invLine, false);
		endif;
		if _passport.noErrors then
			_invoice.causeEvent(_invoice.myTerminal.getTerminalEvent(Event_InvoiceLineUpdate), false, invLine);	
		endif;
	endforeach;

epilog

end;</source>
