    <JadeMethod name="auditId" id="05031b7d-f73c-44b6-9eb7-cc9ff47242cf">
        <source>auditId(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

begin
	return self.getTranMapBreadCrumb;

epilog

end;</source>
