    <JadeMethod name="txtArgFind_keyUp" id="56bc771e-7c20-4c11-a699-3938aa761f0f">
        <controlMethod name="TextBox::keyUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtArgFind_keyUp(textbox: TextBox input; keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2019	jlger1	Initial creation

*/

vars
column		: Integer;
	findText	: String;
	idx			: Integer;
	startRow	: Integer;
	
begin
	findText := textbox.text.trimBlanks.toUpper();
	
	if findText = null then
		if self.tblArgument.rows &gt; self.tblArgument.fixedRows then
			self.tblArgument.row := self.tblArgument.fixedRows + 1;
			self.tblArgument.topRow := self.tblArgument.fixedRows + 1;
		endif;
		return;
	endif;

	column := 2;
	
	startRow := self.tblArgument.fixedRows + 1;

	if self.tblArgument.row &gt; self.tblArgument.fixedRows and findText &gt;= self.tblArgument.accessCell( self.tblArgument.row, column ).text.toUpper() then
		startRow := self.tblArgument.row;
	endif;

	foreach idx	in startRow to self.tblArgument.rows do
		if findText &lt;= self.tblArgument.accessCell( idx, column ).text.toUpper() then
			self.tblArgument.row := idx;
			self.tblArgument.topRow := idx;
			break;
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
