    <JadeMethod name="doCoparn_mtrel_addthendelete" id="8a0bfce2-0de2-48a7-a49f-eb449ae7b191">
        <source>doCoparn_mtrel_addthendelete(_sender, _voyageCode, _vesselName, _consignorCode, _consigneeCode, _releaseNo:String; _mt :Character; _operator :CM_Operator;  _ediPartyRules :CM_EDIPartyCoparnRules)protected;
/*
Date		        Who		Reason
01 December 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
9 January 2013      cnwgb1  CCMS POL 2216/ par 30902 Heavy Rated Releases      
// 31 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
*/
