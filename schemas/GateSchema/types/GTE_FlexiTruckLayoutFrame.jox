    <JadeMethod name="swapContainers" id="b068994c-404b-45f5-98a9-df949108cedf">
        <source>swapContainers(pFrom, pTo : Integer) protected;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	fromContainer,
	toContainer		: GTE_FlexiContainerFrame;
	fromMenuAction,
	toMenuAction		: CMUI_MenuAction;
	navForm			: CMUI_Navigator;
	updateContainers,
	receivalContainers,
	releaseContainers : CMGTE_EntityArray;
	vvr				: CM_VehicleVisitRecord;
	isReceival 		: Boolean;
begin

	if pTo &gt; 0 and pTo &lt;= self.allFlexiContainerFrames.size and
	   pFrom &gt; 0 and pFrom &lt;= self.allFlexiContainerFrames.size then
		// Swap the containers.  This is done in this convulated fashion as a straight swap got
		// the inverses screwed and left one container with its inverse not set.

		fromContainer 	:= self.allFlexiContainerFrames[pFrom];
		toContainer 	:= self.allFlexiContainerFrames[pTo];		
		
		
		// code to swap pictures

		// clear the inverses
		self.allFlexiContainerFrames[pFrom] 	:= null;
		self.allFlexiContainerFrames[pTo] 	:= null;
		
		// add into the new positions    cnwas3
		self.allFlexiContainerFrames[pFrom] 	:= toContainer;
		self.allFlexiContainerFrames[pTo] 	:= fromContainer;
	endif;
	
	//epr changes for CCMS 1386 ROB gate cargo
	create updateContainers transient;
	foreach fromContainer in self.allFlexiContainerFrames do
		if fromContainer.myContainer &lt;&gt; null then
			if fromContainer.myContainer.isKindOf(CMGTE_Receival) then
				isReceival:=true;
			endif;
			updateContainers.add(fromContainer.myContainer);
			if vvr = null then
				vvr:=fromContainer.myContainer.myVehicleVisitRecord;
			endif;
		endif;
	endforeach;
	
	if not updateContainers.isEmpty and vvr &lt;&gt; null then
		if isReceival then
			receivalContainers:=updateContainers;
		else
			releaseContainers:=updateContainers;
		endif;
		app.myTrxUA.trxUpdateRoadJobQueueOrder(vvr,receivalContainers,releaseContainers,app.myPassport);
		
	endif;

epilog
	delete updateContainers;
end;</source>
        <access>protected</access>
        <Parameter name="pFrom" type="Integer"/>
        <Parameter name="pTo" type="Integer"/>
    </JadeMethod>
