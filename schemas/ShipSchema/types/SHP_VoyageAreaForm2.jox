    <JadeMethod name="doResize" id="08d1521b-bdf8-446b-b35c-0b2d2ec2cf9e">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	tmpTop	: Real;
	
begin

	inheritMethod();
	
	// BOTTOM TOOLBAR
	self.setToolbarCombosWidth();

	tmpTop := self.frmToolbarSelect.height + VerticalSpacing;
	self.lblVoyage.top	:= tmpTop;
	self.cmbVoyage.top 	:= tmpTop;
	self.msgHolds.top 	:= tmpTop + self.cmbVoyage.height;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="cef86398-5f6d-4698-b971-82c0fd77cfb5">
        <updating/>
        <source>doSave() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
// 22/10/2024	navcs2		MTN-28961 EUP | Transaction Instrumentation - Voyage Planning
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
vars
	
begin
	app.mousePointer := MousePointer_HourGlass;

	if self.workingMode = WorkMode_Job then
		self.doSaveJob(true, false);
	elseif self.workingMode = self.WorkMode_CustomSeq then
		self.doSaveSequence();
	elseif self.workingMode = self.WorkMode_None and 
	       self.displayMode = ShpDisplayMode_ColCodeLoad then
		self.doSaveColorCodeLoad(false);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled working mode (' &amp; self.workingMode.String &amp; ')');
		return;
	endif;
	
epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveBulkTiNonTrans" id="ab9e22a1-1e4a-4ba5-99e1-06a0629a3a9a">
        <updating/>
        <source>doSaveBulkTiNonTrans(_pxyTISet : CM_TISet input ) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 December 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------

vars
	
	updateController		: CMIF_TIUpdateController;
	tbl						: CM_EntryTable;
	idx,
	result,
	numDefs					: Integer;
	cbType					: CM_CargoBOLType;
	pxyTI					: CM_TrackedItem;
	propDict				: PropertyNDict;
	rowObj					: Object;
	theClass				: Class;
	prop					: Property;
	
begin
	while true do
	 	app.myTrxUA.trxUpdateTrackedItems(_pxyTISet,											
											TI_UPDMODE_NORMAL, 
											null, 
											app.myPassport);
											

		if app.myPassport.trxCompletedOK then
			return true;
		else
			result := app.showErrorWarningDialog('Tracked Item Update', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;

end;</source>
        <access>protected</access>
        <Parameter name="_pxyTISet" type="CM_TISet" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveCC" id="c5cdb3c0-5f9e-4cb4-b3ba-e43932db4728">
        <updating/>
        <source>doSaveCC(_voyAllocation : CM_VoyageAllocation) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 December 2009	cnwas3	Initial creation

*/

vars

begin

	if self.displayMode = ShpDisplayMode_ColCodeLoad then
		self.updateSlotRequestAttributes(_voyAllocation);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid displayMode (' &amp; self.displayMode.String &amp; ')');
	endif;

end;</source>
        <Parameter name="_voyAllocation" type="CM_VoyageAllocation"/>
    </JadeMethod>
    <JadeMethod name="doSaveColorCodeLoad" id="50272cfd-d8cf-4a1c-adf9-05c4bc1c4f9a">
        <updating/>
        <source>doSaveColorCodeLoad(_overrideMoveType : Boolean) updating, protected;
// ---------------------------------------------------------------------------
// Created:     31 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpLoadCC	: CMIF_LoadColorCode;
	tmpDrawController	: SHP_BayDrawingController;
	theSlots		: CM_SlotControllerArray;
	tmpObject	: Object;
	theReturn	: Integer;
	warning : String;
begin

	if self.displayMode &lt;&gt; ShpDisplayMode_ColCodeLoad then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid display mode (' &amp; self.displayMode.String &amp; ')');
		return;
	endif;

	if (self.workingMode &lt;&gt; self.WorkMode_None) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid working mode (' &amp; self.workingMode.String &amp; ')');
		return;
	endif;

	app.mousePointer := Window.MousePointer_HourGlass;

	tmpDrawController := self.myBayDrawingController;
	
	if tmpDrawController.allSelectedObjects.isEmpty then
		app.msgBox('Please select some slots to update', 'Error', MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	create tmpLoadCC transient;
	self.setLoadColorCodeAttributes(tmpLoadCC, null);
	tmpLoadCC.overrideMoveType := _overrideMoveType;
	
	create theSlots transient;
	foreach tmpObject in tmpDrawController.allSelectedObjects do
		if CM_SlotController.hasInstance(tmpObject) then
			theSlots.add(tmpObject.CM_SlotController);			
		endif;
	endforeach;

	self.myBayDrawingController.updateEditionForSelectedObjs(self.myBayDrawingController.allObjectEditions);  //cnwrd1 par 31052 29.1.13
	
	while true do
		if theSlots.isEmpty() then
			break;
		endif;
		app.myTrxUA.trxUpdateSlotRequestLoadCC(theSlots, tmpLoadCC, tmpDrawController.allObjectEditions, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.hasChanged := false;
			tmpDrawController.updateEditionForSelectedObjs(theSlots);
			global.beep;
			break;
		else			
			theReturn := app.showErrorWarningDialog($Load_Colour_Code, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
epilog
	delete tmpLoadCC;
	delete theSlots;

end;</source>
        <access>protected</access>
        <Parameter name="_overrideMoveType" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveJob" id="7f6c0843-b9cf-42a9-9d58-1b933f8ea0aa">
        <updating/>
        <source>doSaveJob(_fromToolBar, _fromFrmHatchLidJob : Boolean) updating, protected;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/10/2024	navcs2		MTN-28961 EUP | Transaction Instrumentation - Voyage Planning
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
// ---------------------------------------------------------------------------
vars
	theJobId, 
	theCraneID 			: String;
	theJobParams 		: CMIF_VoyageJobParams;
	isCreate, 
	ls 					: Boolean;
	aSlotController 	: CM_SlotController;
	theJobTypeNumber, 
	theReturn			: Integer;
	theRealVJob,
	theProxyVJob 		: CM_VoyageJob;
	tmpHatchLid 		: CM_HatchLid;
	theLidBay 			: CM_Bay;
	isHatchLidJob, 
	isSOB 				: Boolean;
	aSlotReq			: CM_SlotRequest;
	tmpDrawController	: SHP_BayDrawingController;
	tmpObj				: Object;
	reseq,	
	isDischarge 		: Boolean;
begin
	if (self.workingMode &lt;&gt; WorkMode_Job) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid working mode (' &amp; self.workingMode.String &amp; ')');
		return;
	endif;

	app.mousePointer := Window.MousePointer_HourGlass;

	tmpDrawController := self.myBayDrawingController;

	theJobId := self.cmbJob.text.trimBlanks.toUpper;
	isCreate := false;
	if self.cmbCrane.listObject &lt;&gt; null then
		theCraneID := self.cmbCrane.listObject.CM_Crane.id.trimBlanks;
	endif;

	if (not _fromToolBar) then // called from context menu
		isCreate := true;
	else
		theRealVJob := self.cmbJob.listObject.CM_VoyageJob;
		if theRealVJob = null  then
			isCreate := true;
		endif;
	endif;
	
	create theJobParams transient;
	theJobParams.useNewMethod := true;
	
	
	reseq := true; // PAR 35031
	if (not isCreate) then
		theProxyVJob := app.createUpdateProxy(theRealVJob).CM_VoyageJob;
		reseq := not theRealVJob.isCustomSequenced(); // PAR 35031
	endif;
	
	if theProxyVJob &lt;&gt; null then // PAR 34649
		isDischarge := theProxyVJob.isDischarge;  // updating
	else
		isDischarge := (self.displayMode = ShpDisplayMode_ColCodeDisch); // PAR 34649
	endif;
	

 // PAR 34649	theJobParams.isDischarge		:=	(self.displayMode = ShpDisplayMode_ColCodeDisch);
	theJobParams.isDischarge		:=	isDischarge; // PAR 34649
	theJobParams.jobNumLinkedLoad	:=	self.txtJobLinkLoad.text.trimBlanks.toUpper;
	theJobParams.craneID			:=	theCraneID;
	theJobParams.myVoyage			:=	self.myCurrentVoyage;
	theJobParams.myProxyJob			:=	theProxyVJob;
	theJobParams.resquence			:=		reseq;  // PAR 35031  true;		//set true whenever there's the posibility of slots added/removed from a job
	theJobParams.isSeqForJob		:=	false;
	theJobParams.allowOutOfOrderLoading	:= self.chkOutOfSequence.value; //cnwrd1 par 30626 ccms 2209 23.10.12

	if (not _fromToolBar) then // called from context menu or from frmHatchLidJob
		theJobParams.myBay := self.mnuGridNewJob.userObject.CM_Bay;
	endif;

	if _fromFrmHatchLidJob then
		// the following are on the frame frmHatchLidJob
		theJobParams.id := self.txtJobHatchNum.text;
		theJobParams.myJobType := self.cmbHatchLidType.listObject.CM_JobType;
		theJobParams.remarks := self.cmbHatchLidRemrk.text.trimBlanks;
	else
		theJobParams.id := self.cmbJob.text.trimBlanks.toUpper;
	endif;
	
	tmpDrawController.allObjectEditions.copy(theJobParams.allObjectEditions);

	foreach tmpObj in tmpDrawController.allSelectedObjects do
		if CM_SlotController.hasInstance(tmpObj) then
			theJobParams.allSlotControllers.add(tmpObj.CM_SlotController);
		elseif CM_HatchLid.hasInstance(tmpObj) then
			theJobParams.addHatchLid(tmpObj.CM_HatchLid);
		endif;
	endforeach;

	while true do
		if isCreate then
			app.myTrxCA.trxCreateVoyageJob(theJobParams, theRealVJob, app.myPassport);
		else
			app.myTrxUA.trxUpdateVoyageJob(theJobParams, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			self.btnTwinLiftCrane.value := theRealVJob.isTwinLift;
			self.btnTwinLiftCrane.click(self.btnTwinLiftCrane);
			self.hasChanged := false;
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Job Save", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;

	self.doCmbJobBuild();
	
	if not theJobParams.allTIs.isEmpty then
		self.myAssistant.showShipNowSingleLiftForm(theJobParams, self.myMasterMenuAction);
	endif;
epilog
	if theJobParams &lt;&gt; null then
		delete theJobParams.myProxyJob;
	endif;
	delete theJobParams;

	self.cmbHatchLidRemrk.listObject := null;
	self.cmbHatchLidType.listObject := null;
	self.txtJobLinkLoad.text := null;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <access>protected</access>
        <Parameter name="_fromToolBar" type="Boolean"/>
        <Parameter name="_fromFrmHatchLidJob" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveSequence" id="30994443-0b10-434a-895a-6f9f1649fb8d">
        <updating/>
        <source>doSaveSequence() updating, protected;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	tmpDrawController	: SHP_BayDrawingController;
	theReturn			: Integer;
begin
	if self.workingMode &lt;&gt; self.WorkMode_CustomSeq then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid working mode (' &amp; self.workingMode.String &amp; ')');
		return;
	endif;

	if self.myCurrentJob = null then
		app.msgBox("You have not selected a slot which is associated with a job. Cannot sequence.", 'Sequence Error', MsgBox_Stop_Icon + MsgBox_OK_Only);
		return;
	endif;

	tmpDrawController := self.myBayDrawingController;
	
	if self.allCustomSeqObjsByReq.isEmpty then
		//app.raiseUnexpectedProgramError(class.name, method.name, 'self.allCustomSeqObjsBySeqNum is empty');
		app.msgBox(app.getErrorString(Save_before_custom_seq), app.getErrorString(Error), MsgBox_Stop_Icon + MsgBox_OK_Only);	//28 Mar 2012	NDL	Par 29112
		return;
	endif;

	while true do
		app.myTrxUA.trxUpdateSlotRequestSeqNum2(self.allCustomSeqObjsByReq, self.btnTwinLiftCrane.value, tmpDrawController.isStarboardBerthed, self.myCurrentJob, app.myPassport);
									
		if app.myPassport.trxCompletedOK then
			self.hasChanged := false;
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog($Sequence, app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;

	self.currentSeqNumber := 0;
	self.txtSeqNum.text := ""; // PAR 36321
	self.myCurrentJob := null;
	self.customSeqObjPurge();

	global.beep;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSaveSingleTiNonTrans" id="f2c3f5b5-2b94-47c2-bc32-febe693c30ed">
        <updating/>
        <source>doSaveSingleTiNonTrans(_pxyTI : CM_TrackedItem input) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     18 December 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------

vars
	pxyTI					: CM_TrackedItem;
	result					: Integer;
	
begin
	
	while true do
		app.myTrxUA.trxUpdateTrackedItem(_pxyTI,
											null,
											TI_UPDMODE_NORMAL, 
											null, 
											app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			return true;
		else
			result := app.showErrorWarningDialog('Tracked Item Update', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;

end;</source>
        <access>protected</access>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doScrollToCorners" id="c02f62ce-6bb5-49c0-9995-4ad4ef01f73b">
        <updating/>
        <source>doScrollToCorners(pCorner : Integer) updating, protected;
begin
	inheritMethod(pCorner);
end;</source>
