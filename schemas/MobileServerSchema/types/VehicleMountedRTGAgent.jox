    <JadeMethod name="createDoorTurnaroundJob" id="cf9544a9-3a55-4163-bcff-aaddded589f0">
        <source>createDoorTurnaroundJob(_rtQueueEntry : CM_RTQueueEntry input;
						_errorMsgs : DTO_HandHeldGateErrorDict input);
/*

Purpose:			


Return Value:		


Date				Who		Reason
13 November 2006	cnwer1	Initial creation - PAR#xxxx
25/06/2010			cnwcs5	par 24292 - door turnaround area can now be an interchange area as ell as a block stack
// 10/12/2014  cnwdb2	PAR 35364

*/
vars
	doorDirArea : CM_TerminalArea;	// par 24292
	ti 			: CM_TrackedItem;
	task 		: CM_RTQueueTask;
	currentLoc 	: CM_LocationsController;
	wle 		: CM_WorkListEntry;
begin
	self.initialiseForNewRequest(_errorMsgs);  //cnwjo3 par 24636

	if _rtQueueEntry = null then
	//	self.addError(UNEXPECTED_PROGRAM_ERROR,app.getErrorString1(REQUIRED_FIELD,"RT Queue Entry"),_errorMsgs);
		self.addError(UNEXPECTED_PROGRAM_ERROR,app.getErrorString(Input_required_field_rtQueEnt),_errorMsgs); // cnwdb2	PAR 35364
		return;
	endif;
	
	task := _rtQueueEntry.allTasks.first;
	
	if task = null then
	//	self.addError(UNEXPECTED_PROGRAM_ERROR,app.getErrorString1(REQUIRED_FIELD,"RT Queue Task"),_errorMsgs);
		self.addError(UNEXPECTED_PROGRAM_ERROR,app.getErrorString(Input_required_field_RTQue),_errorMsgs); // cnwdb2	PAR 35364

		return;
	endif;
	
	wle:=task.myEntry.myWorkListEntry;
	ti := task.ti;
	doorDirArea:=self.myTerminal.getConfig(DefTurnaroundArea).CM_BlockStack;
	if doorDirArea = null then
	//	self.addError(REQUIRED_FIELD,app.getErrorString1(REQUIRED_FIELD,"Terminal Config - Turnaround Area"),_errorMsgs);
		self.addError(Input_required_field_termCnfTr ,app.getErrorString(Input_required_field_termCnfTr),_errorMsgs); // cnwdb2	PAR 35364

		return;
	endif;
	if ti = null then
	//	self.addError(REQUIRED_FIELD,app.getErrorString1(REQUIRED_FIELD,"Task - Container"),_errorMsgs);
		self.addError(Input_required_fieldTskCont,app.getErrorString(Input_required_fieldTskCont),_errorMsgs);
		return;
	endif;
	if wle = null then
	//	self.addError(REQUIRED_FIELD,app.getErrorString1(REQUIRED_FIELD,"Task - Work List Entry"),_errorMsgs);
		self.addError(Input_required_fieldTskWrkEnt,app.getErrorString(Input_required_fieldTskWrkEnt),_errorMsgs);// cnwdb2	PAR 35364


		return;
	endif;
	// the ti should be on an IMV if it isn't return an error
	currentLoc :=ti.getPrimaryLocation(REAL_MODE);
	if currentLoc = null or not currentLoc.isKindOf(CM_MachineController) then
		self.addError(Err_IMV_Door_turnaround,app.getErrorString1(Err_IMV_Door_turnaround,ti.id),_errorMsgs);
		return;
	endif;
	
	if self.createErrorsFromPassport(_errorMsgs) then
		return;
	endif;
epilog
	
end;</source>
        <Parameter name="_rtQueueEntry" type="CM_RTQueueEntry" usage="input"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
