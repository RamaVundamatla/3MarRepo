<Class name="CM_FieldAttribute" id="30f24f6a-2203-44af-8ce2-4a429ff36444">
    <superclass name="CM_Field"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <ExplicitInverseRef name="myEDIXMLField" id="33af0f81-7a6e-46ae-89da-d4e0a415298c">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_EDIItemFieldXML"/>
        <access>readonly</access>
        <Inverse name="CM_EDIItemFieldXML::allAttributes"/>
    </ExplicitInverseRef>
    <JadeMethod name="setForCreate" id="bed0268e-feee-4dd2-8ac3-2dfe8bc28321">
        <updating/>
        <source>setForCreate(_name, _value: String; _ediItemField: CM_EDIItemFieldXML) updating;
//----------------------------------------------------------------
//	Created:	04 August 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.name := _name;
	self.value := _value;
	
	self.myEDIXMLField := _ediItemField;

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_value" type="String"/>
        <Parameter name="_ediItemField" type="CM_EDIItemFieldXML"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromXMLAttribute" id="0afe9814-8a5b-4439-8fe0-68997bf8e6ff">
        <updating/>
        <source>setProxyFromXMLAttribute(_xmlAttr: JadeXMLAttribute; _ediItemField: CM_EDIItemFieldXML) updating;
//----------------------------------------------------------------
//	Created:	03 August 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if _xmlAttr = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'set from object called with null object');
	endif;
	
	self.name := _xmlAttr.name;
	self.value := _xmlAttr.value;
	self.myEDIXMLField := _ediItemField;
	
end;</source>
        <Parameter name="_xmlAttr" type="JadeXMLAttribute"/>
        <Parameter name="_ediItemField" type="CM_EDIItemFieldXML"/>
    </JadeMethod>
</Class>
