    <JadeMethod name="initTable" id="00ac6434-b722-4d0a-b926-58e2ce35c0ca">
        <updating/>
        <source>initTable() updating;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	heading		: String;
	tableObj	: Table;

begin
	tableObj				:=	tblAlerts;
	tableObj.fixedRows		:=	1;
	tableObj.fixedColumns	:=	0;
	
	self.objectType	:=	self.isForWhatType();
	
	if  self.objectType = self.SystemAlert then
		tableObj.rows			:=	1;
		tableObj.columns		:=	1;
		tableObj.setCellText(1, 1, 'Detail');
		heading					:=	"System Alerts Details";
		
	elseif self.objectType = self.ActivityHistory then
		tableObj.rows			:=	1;
		tableObj.columns		:=	2;
		tableObj.setCellText(1, 1, 'Heading' &amp; Tab &amp; 'Detail');
		heading					:=	'Activity History Details';
		
	elseif self.objectType = self.InformationTransaction then
		tableObj.rows			:=	1;
		tableObj.columns		:=	1;
		tableObj.setCellText(1, 1, 'Detail');
		heading					:=	'Information';
		
	elseif self.objectType = self.GlobalVoyageMoveLog then
		tableObj.rows			:=	1;
		tableObj.columns		:=	1;
		tableObj.setCellText(1, 1, "Movement");
		heading					:=	"Voyage Movement Logs";
		
	elseif self.objectType = self.PassportExtraInfo then
		tableObj.rows			:=	1;
		tableObj.columns		:=	1;
		tableObj.setCellText(1, 1, 'Details');
		heading					:=	self.caption;

	elseif self.objectType = self.EmailRequest then		// PAR 17925
		tableObj.rows			:=	1;
		tableObj.columns		:=	2;
		tableObj.setCellText(1, 1, 'Heading' &amp; Tab &amp; 'Detail');
		heading					:=	'Email Details';
	else													//+ dh par 15214 12/11/2007
		heading 				:= "Logging Details";  	//+ "
		//cnwjo3 par 22493.  Smooth scrolling allows whole row to be viewed correctly
		self.tblAlerts.accessSheet(1).scrollMode := Table.ScrollMode_HorzPixel_VertCell;
	endif;
	
	self.caption			:=	heading;
	tableObj.wordWrap		:=	true;
	tableObj.selectMode		:=	Table.SelectMode_CurrentRow;
	tableObj.partialTextIndication	:=	true;
	tableObj.accessRow(1).backColor	:=	self.colorHeadingColumn;
	tableObj.scrollBars		:=	Table.ScrollBars_Both;
end;</source>
    </JadeMethod>
    <JadeMethod name="isForWhatType" id="d8483066-6232-4b58-95fa-29946da4d079">
        <source>isForWhatType() : Integer protected;
// -------------------------------------------
// Created 29 March 2004 by cnwdvb1
// -------------------------------------------
begin
	if self.myObject.isKindOf(CM_ActivityHistory) then
		return self.ActivityHistory;
	elseif self.myObject.isKindOf(CM_SystemAlert) then
		return self.SystemAlert;
	elseif self.myObject.isKindOf(CM_InfoEDISent) then		// cnwdad1 23/08/2010 - CCMS 1903 (PAR 24065).
		return self.InformationTransaction;						// cnwdad1 23/08/2010 - CCMS 1903 (PAR 24065).
	elseif self.myObject.isKindOf(CM_Information) then
		return self.InformationTransaction;
	elseif self.myObject.isKindOf(CMIF_VoyageGlobal) then
		return self.GlobalVoyageMoveLog;
	elseif self.myObject.isKindOf(CM_Passport) then
		return self.PassportExtraInfo;
	elseif self.myObject.isKindOf(BGP_EmailSendRequest) then	// PAR 17925
		return self.EmailRequest;
	else
		return 0;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="load" id="442574f7-bab8-476a-9f60-5e078d757d0e">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		22 October 2008 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	inheritMethod;
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="ea6d4f32-ed2e-4ddc-a77e-e5f8e7e43d60">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:      29 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
begin
	if self.objectType = self.SystemAlert then
		self.displayAlerts();		
	elseif self.objectType = self.ActivityHistory then
		self.displayActivity();
	elseif self.objectType = self.InformationTransaction then
		self.displayInformation();
	elseif self.objectType = self.GlobalVoyageMoveLog then
		self.displayMovementLogs();
	elseif self.objectType = self.PassportExtraInfo then
		self.displayPassportExtraInfo();
	elseif self.objectType = self.EmailRequest then	// PAR 17925
		self.displayEmailRequest();
	endif;
	
//	self.tblAlerts.adjustHeight(1000);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="e2bf2723-c59f-4e79-a4b4-00afbe501aea">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
begin
	inheritMethod();
	
	self.toolbarStyle	:=	self.ToolbarStyle_ShowNoHide;
	self.showToolbar	:=	true;
	self.displayLimit	:=	100;
	self.initTable();
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="ba3ba7bf-7291-4d19-b7b5-51d69e1ff1e0">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014619, locale);
	btnExtract.translateBubbleHelp(Xlat_0008186, locale);
	btnExtract.translateCaption(Xlat_0010044, locale);
	btnFind.translateBubbleHelp(Xlat_0008187, locale);
	btnFind.translateCaption(Xlat_0008188, locale);
	btnPrint.translateBubbleHelp(Xlat_0000971, locale);
	btnPrint.translateCaption(Xlat_0000972, locale);
	clrOne.translateCaption(Xlat_0000973, locale);
	clrTwo.translateCaption(Xlat_0000974, locale);
	frmReport.translateCaption(Xlat_0000969, locale);
	lblReport.translateCaption(Xlat_0000970, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="7015bfd6-2279-4fb1-8adf-93e73ba8eca7">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
//
// PAR 18070 cnwrs1 Oct 2008
// get the unload to detete the transinet created by SOP_BackgoroundForm::showDetails
//
vars

begin
	inheritMethod();	// Par 18143

	//cnwdz2 par 18225 18432
	if self.objectType = self.EmailRequest	// PAR 18070 cnwrs1 Oct 2008 
	and self.myObject &lt;&gt; null
	and self.myObject.isTransient
	then
		delete self.myObject;
	endif;
end;
</source>
    </JadeMethod>
</GUIClass>
