    <JadeMethod name="getLengthInMetres" id="399b2439-f862-441a-a964-972cadd9c295">
        <source>getLengthInMetres(): Real;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 January 2010	cnwjk3	ccms 1018

*/

constants
	Factor : Real = 0.3048;
vars

begin
	if self.is45() then 
		return 45 * Factor;
	elseif self.is40 then
		return 40 * Factor;
	elseif self.is30() then 
		return 30 * Factor;
	elseif self.is53() then 
		return 53 * Factor;
	else
		return 20 * Factor;
	endif;
epilog

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getLengthInUnits" id="3421559a-712b-493a-936d-34766785964e">
        <source>getLengthInUnits(): Real;
/*
 ------------------------------------------------------------------------
Created:			24 July 2001 by cnwdwq1
Purpose:			Get the length of the receiver in units
Returns:			Length in units

Date		Who		Reason
27 Jan 2011	cnwkpd1	PAR #26792 - Performance improvements for Bay View form

*/

vars

begin
	// PAR #26792 - new code, reordered into most common first
	if self.is40 then
		return 4;
	elseif self.is20 then
		// Drop through to default
	elseif self.is45() then // PAR 16415 CCMS 1029
		return 4;
	elseif self.is53() then // PAR 16415 CCMS 1029
		return 4;
	endif;
	
	return 2;

end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
