    <JadeMethod name="setupForm" id="dadb765d-6237-40c4-a842-fc55c88bcc9e">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 January 2010	cnwas3	Initial creation

*/

vars

begin
	self.showToolbar := true;
	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;
	inheritMethod();
	self.mnuFile.visible := false;
	self.mnuHelp.visible := false;
	self.mnuOptions.visible := false;
	self.mnuWindows.visible := false;
	self.mnuTerminal.visible := false;
	self.mnuView1.visible := false;
	
	self.minimumWidth := 625;
	
	self.beginNotification(self.myParentForm, self.myTerminal.getTerminalEvent(ShowHide_VoyageAllocationsCC), Response_Continuous, null);

	self.setCaption(app.getErrorString2(Colour_coding_palette, self.myVoyage.code, app.getErrorString(Load)));
	
	self.btnSaveCC.bubbleHelp := app.getErrorString(Save_colour_coding_select_stow);
	self.btnSaveBase.bubbleHelp := app.getErrorString(Save_colour_coding_select_stow);
	
	self.tblCCAllocation.initialSetup( self.myVoyage );
		// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, PmVoyagePlanningMaint) then
		self.btnDeleteVA.enabled:= false;
		self.btnDeleteVALL.enabled:= false;
		self.btnEraseAlloc.enabled:= false;
		self.tblCCAllocation.userInputEnabled := false;
		self.btnSaveCC.enabled:= false;
		self.btnSaveProj.enabled:= false;
		self.btnSaveBase.enabled:= false;
		self.btnSummBooking.enabled:= false;
		self.btnSummCargo.enabled:= false;
		
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblCCAllocation_click" id="9de3b423-0cdb-457d-9079-983fd4959dd8">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCCAllocation_click(table: Table input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 January 2012	cnwndl1	Initial creation

*/

vars

	invalid : Boolean;

begin

	self.myCurrentVoyageAllocation := null;
	table.clearAllSelected();
	
	self.tblCCAllocation.setSelectedIndicator();
	if table.row &gt; table.fixedRows then
		self.myCurrentVoyageAllocation := table.accessRow(table.row).itemObject.CM_VoyageAllocation;
		if self.myCurrentVoyageAllocation &lt;&gt; null then
			on Exception do app.handleDeletedObject( exception, self.myCurrentVoyageAllocation, invalid );	//23 Dec 2013	NDL	Par 31011
			table.bubbleHelp := self.myCurrentVoyageAllocation.getBaysCoveredString();
			self.setCCScreenAttributes();
		else
			table.bubbleHelp := null;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
