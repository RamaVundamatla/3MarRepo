<Class name="JadeXMLElement">
    <JadeMethod name="addToHugeStringArray" id="2425939f-97b0-48ca-a0f5-f9fd8f91fecb">
        <source>addToHugeStringArray( _hugeStrArray : HugeStringArray input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 April 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

	startString : String;
	endString : String;
	childNode : JadeXMLNode;
	attr : JadeXMLAttribute;

begin

	if _hugeStrArray = null then
		return;
	endif;
	
	startString := "&lt;" &amp; self.tagName;
	
	
	foreach attr in self.attributes do
		startString := startString &amp; " " &amp; attr.name &amp; "=" &amp; attr.value;
	endforeach;
	
	startString := startString &amp; "&gt;";
	endString := "&lt;/" &amp; self.tagName &amp; "&gt;";
	
	if self.text.trimBlanks = null and self.childNodes.isEmpty then
		_hugeStrArray.addTruncated( startString &amp; endString );
	elseif self.childNodes.isEmpty then
		_hugeStrArray.addTruncated( startString &amp; self.text.trimBlanks &amp; endString );
	else
		_hugeStrArray.addTruncated( startString &amp; self.text.trimBlanks );
		foreach childNode in self.childNodes do
			if not childNode.isKindOf(JadeXMLElement) then
				continue;
			endif;
			childNode.JadeXMLElement.addToHugeStringArray( _hugeStrArray );
		endforeach;
		_hugeStrArray.addTruncated( endString );
	endif;

epilog

end;</source>
        <Parameter name="_hugeStrArray" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="findElement" id="c77f42a7-04be-42f1-a594-52dd4a0caf4a">
        <source>findElement(_tagName: String; _stopTagName: String): JadeXMLElement;
//----------------------------------------------------------------
//	Created:	25 November 2004	by Jason Chapman  (cnwjc2)
//
//	Find element with tagName = _tagName
//	Stop walking the tree when you get to _stopTagName
//----------------------------------------------------------------
vars
	xmlElement	: JadeXMLElement;
	xmlNode		: JadeXMLNode;
begin
	
	if self.tagName = _stopTagName then
		return null;
	endif;
	
	foreach xmlNode in self.childNodes do
		
		if xmlNode.JadeXMLElement.tagName = _tagName then
			//we have found it
			xmlElement := xmlNode.JadeXMLElement;
			break;
		else
			xmlElement := xmlNode.JadeXMLElement.findElement(_tagName, _stopTagName);
			if xmlElement &lt;&gt; null then
				//we have found it
				break;
			endif;
		endif;
	
	endforeach;
	
	return xmlElement;

end;</source>
        <Parameter name="_tagName" type="String"/>
        <Parameter name="_stopTagName" type="String"/>
        <ReturnType type="JadeXMLElement"/>
    </JadeMethod>
    <JadeMethod name="findElementForEDIField" id="9bd08acf-334b-40b2-bed5-d9fca45f9598">
        <source>findElementForEDIField(_ediField: CM_EDIItemFieldXML): JadeXMLElement;
//----------------------------------------------------------------
//	Created:	04 August 2005	by Jason Chapman  (cnwjc2)
//
//	Find the element at position 1 by walking the path
//
//
//----------------------------------------------------------------
vars
	tagName			: String;
	prevElement,
	foundElement	: JadeXMLElement;
//	xmlElement		: JadeXMLElement;
	xmlElements		: JadeXMLElementArray;
	theTagName,
	attrName,
	attrValue		: String;
	xmlAttr			: JadeXMLAttribute;
	attributes		: CM_FieldByNameDict;
	fieldAttr		: CM_Field;
	allOK			: Boolean;
	isValid			: Boolean;
begin

	prevElement := self;
	create xmlElements transient;
	create attributes transient;
	
	foreach tagName in _ediField.allTagsInPath reversed do
		attributes.purge;	//cnwrs1 14 Jan 2011 fix Kiwi rail AdvNot leaks
		xmlElements.clear;
		_ediField.readTag(tagName, theTagName, attributes);
		if prevElement.tagName = theTagName then
			//found self? - self must appear somewhere in the list
			isValid := true;
			continue;
		endif;
		


		//foundElement := prevElement.getElementByTagName(tagName);
		prevElement.getAllElementsByTagName(theTagName, xmlElements);
		foundElement := null;
		
		foreach foundElement in xmlElements do	:	elementloop
			allOK := true;
			foreach fieldAttr in attributes do	:	attrloop
				xmlAttr := foundElement.getAttributeByName(fieldAttr.name);
				if xmlAttr = null
				or xmlAttr.value &lt;&gt; fieldAttr.value then
					allOK := false;
					break attrloop;
				endif;
			endforeach;
			if allOK then
				//all attributes checked out
				break elementloop;
			endif;
		endforeach;	
					
		if foundElement = null then
			//this is the last valid element
			foundElement := prevElement;
			continue;
		else
			if not isValid then
				foundElement := null;
				break;
			endif;
		endif;
//write "&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt;&gt; " &amp; foundElement.tagName &amp; " " &amp; foundElement.textData;
		prevElement := foundElement;
	endforeach;

	return foundElement;
epilog
	delete xmlElements;
	attributes.purge();	//cnwrs1 14 Jan 2011 fix Kiwi rail AdvNot leaks
	delete attributes;	
end;</source>
        <Parameter name="_ediField" type="CM_EDIItemFieldXML"/>
        <ReturnType type="JadeXMLElement"/>
    </JadeMethod>
    <JadeMethod name="getChildDataElements" id="2b04e8db-f715-47c6-b640-7d7ab8f00e36">
        <source>getChildDataElements(_dataElements: JadeXMLElementArray input);
//----------------------------------------------------------------
//	Created:	07 October 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	xmlElem	: JadeXMLNode;
begin

	if self.childNodes.isEmpty 
	and self.textData &lt;&gt; null then
		_dataElements.add(self);
	else
		if (not self.attributes.isEmpty) then
			_dataElements.add(self);
		endif;
		foreach xmlElem in self.childNodes do
			if JadeXMLElement.hasInstance(xmlElem) then
				xmlElem.JadeXMLElement.getChildDataElements(_dataElements);
			endif;
		endforeach;
	endif;	

end;</source>
        <Parameter name="_dataElements" type="JadeXMLElementArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTagValueOfName" id="6761e6f7-016a-475b-92fb-1804182bf54f">
        <source>getTagValueOfName(_tagName : String) : String;
// ---------------------------------------------------------------------------
// Created:     11 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	xmlElem	: JadeXMLElement;
begin

	if _tagName = null then
		return null;
	endif;

	xmlElem := self.getElementByTagName(_tagName);
	if xmlElem = null then
		return null;
	endif;
	
	return xmlElem.textData.xmlReplaceReservedChars(false);

end;</source>
        <Parameter name="_tagName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="returnAsObject" id="14ca6447-4422-4dc9-963f-0a9af58c5301">
        <source>returnAsObject(_transient : Boolean;
			   _createdObjects : ObjectSet input) : Object;

/*

Purpose:			


Return Value:		


Date		Who		Reason
12 December 2007	cnwkpd1	CCMS TWLENH 1018 - RF Gun Web Service

*/

vars
	className		: String;
	cls				: Class;
	obj				: Object;
	
begin
	className := self.localName;
	cls := currentSchema.getClass(className);
	if cls = null then
		return null;
	endif;
	
	if _transient then
		create obj as cls transient;
	else
		create obj as cls persistent;
	endif;
	
	if not obj.canCreateFromXML then
		delete obj;
		return null;
	endif;
	
	obj.populateFromXMLElement(self, _createdObjects);
	
	return obj;
	
	
epilog

end;</source>
        <Parameter name="_transient" type="Boolean"/>
        <Parameter name="_createdObjects" type="ObjectSet" usage="input"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="setTextOrDefault" id="50245484-40e6-4695-9519-828f99b24106">
        <updating/>
        <source>setTextOrDefault(_value, _defaultValue : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Oct 2025	navnk30	JIRA 36241: Yara New Discoveries | Modify empty XML elements by inserting placeholder values

*/

vars

begin
	if _value &lt;&gt; null then
		self.setText(_value);
	else
		self.setText(_defaultValue);
	endif;
epilog

end;</source>
        <Parameter name="_value" type="String"/>
        <Parameter name="_defaultValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTextOrUnknown" id="3eebfe4f-dae6-478b-8fab-8d00418ac587">
        <updating/>
        <source>setTextOrUnknown(_value : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Oct 2025	navnk30	JIRA 36241: Yara New Discoveries | Modify empty XML elements by inserting placeholder values

*/

vars

begin
	if _value &lt;&gt; null then
		self.setText(_value);
	else
		self.setText(self.tagName &amp; " Unknown");
	endif;
epilog

end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
</Class>
