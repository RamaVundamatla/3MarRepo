end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="optDischarge_click" id="87d6e2ad-0711-403d-9319-4b4a90352d37">
        <controlMethod name="OptionButton::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>optDischarge_click(optionbutton: OptionButton input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 July 2010	cnwer1	Initial creation

*/

vars

begin	
	if optionbutton.value then
		self.grpDischTo.visible:=self.myMobileGenericAgent.myTerminal.getConfig(DischargeHHLanderOption).Integer = DiscHHLander_Both and self.toGroundAllowed;
		self.optGround.visible:=self.myMobileGenericAgent.myTerminal.getConfig(DischargeHHLanderOption).Integer = DiscHHLander_Both and self.toGroundAllowed;
		self.optMach.visible:=self.myMobileGenericAgent.myTerminal.getConfig(DischargeHHLanderOption).Integer = DiscHHLander_Both;
		self.chkSearchParam.visible := false;	//08 Feb 2017	NDL	TFS 3191/2876
	endif;
epilog

end;</source>
        <Parameter name="optionbutton" type="OptionButton" usage="input"/>
    </JadeMethod>
