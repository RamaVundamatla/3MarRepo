    <JadeMethod name="getFullId" id="d459460a-3095-43c9-a7d5-8ad8c9c46b9d">
        <source>getFullId() : String;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	tmpStr : String;
begin
	
	if self.myVoyage &lt;&gt; null then
		tmpStr := self.myVoyage.code.trimRight;
	endif;
	return tmpStr &amp; " " &amp; self.ident;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
