    <JadeMethod name="validateForDelete" id="3892c055-b953-4190-96ca-2961f53145a6">
        <source>validateForDelete();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2008	cnwer1	Initial creation
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars
	reserveObj :CM_ReserveDetail;
begin
	
	if not self.allTIs.isEmpty() then
		app.raiseCMException1 (WARN_GENERIC, 'You can not delete Equipment items with containers received'  ,  null, self);
	else
		reserveObj	:=	self.myReserveDetail;	
		//if reserveObj &lt;&gt; null and not reserveObj.allTrackedItems.isEmpty() then
		if reserveObj &lt;&gt; null and reserveObj.hasTi() then //23/06/2023	navkc1	CR 58406 Task 58408
			app.raiseCMException1 (WARN_GENERIC, 'You can not delete release requests with containers already released'  ,  null, self);
		endif;
	endif;
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="26278439-c9fb-4dde-b4bf-924205962c2d">
        <updating/>
        <source>validateForUpdate(_passport : CM_Passport input; _terminal : CM_Terminal) updating;
/*
	Created on 17 January 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	
begin
	self.raiseExceptionIfNotTransient(method);
	self.validate(_passport, _terminal);
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="validateNotOverSubScribed" id="a2ea2f92-78d1-43ec-bdc0-71d4e14e8a31">
        <source>validateNotOverSubScribed( _ti : CM_TrackedItem );
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
22 January 2013	cnwndl1	Initial creation
08/04/2014 		cwnmh5	#33829 - Change to use terminal oversubscribe config setting
*/

vars
	isError : Boolean;
	realTi  : CM_TrackedItem;
begin
	
	if not _ti.isTransient then
		realTi := _ti;
	else
		realTi := _ti.pxyGetRealObject;
	endif;
	
	if realTi &lt;&gt; null and self.allTIs.includes( realTi ) then
		// the real one is already associated with me.
		return;
	endif;
	
	//epr par 34935 26/9/14
	if self.isBulkMulti then
		if (self.getReceivedWeight() + _ti.totalWeight) &lt;= self.getWeight() then
			return;
		endif;
	else
		if self.getRecievedCount() + _ti.totalQuantity.max(1) &lt;= self.getQuantity then
			return;
		endif;
	endif;

	isError := not self.myBookingReference.myTerminal.getConfig(BookingOversubscribe).Boolean;				// 08/04/2014 cnwmh5 #33829	
	
	if isError then
		app.raiseCMException2(Book_item_already_has, self.getAmountDisplay(), self.getReceivedDisplay(), null, self);
	else
		app.raiseCMWarning2(Book_item_already_has, self.getAmountDisplay(),self.getReceivedDisplay(), null, self, self);
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="validateTIHazards" id="6eb8185c-c92d-4b97-be14-dc132a89410f">
        <source>validateTIHazards(_terminal : CM_Terminal) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2013	cnwer1	Initial creation HAT 2189

*/

vars
	terminal : CM_Terminal;
	haz : CM_Hazard;
begin
	foreach haz in self.allTIHazards discreteLock do	
		haz.validateTIHazard(_terminal);
	endforeach;
epilog

end;</source>
