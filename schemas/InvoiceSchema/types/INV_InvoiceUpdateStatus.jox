    <JadeMethod name="calculateDueDate" id="6456dfc8-1e6b-40c0-9d23-6712d895affd">
        <source>calculateDueDate(_changedCtrl	: Control) : Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/01/2023	navkc1 ChangeRequest 59145 Task 61332: UI - Invoice Post

*/

vars
	today,
	endDate,
	invoiceDate,
	dueDate					: Date;
	term					: CM_InvoiceTermsOfTrade;
	dueRule,
	dueDays					: Integer;
	table					: CM_EntryTable;
	firstInvoice			: CM_Invoice;
	bank					: CM_Bank;
	nowTS					: TimeStamp;
begin
	
	term := self.cmbTermsTrade.listObject.CM_InvoiceTermsOfTrade;
	table := self.tblInvProperties;
	
	// If date is changed from INvoice Date
	if _changedCtrl = self.mskInvoiceDate then
		dueDate := table.getValueByName(ETRow_InvoiceDate).Date;
	// if changed from , use the end date
	elseif _changedCtrl = self.mskEndDate then
		// Due date default to End Date
		dueDate := table.getValueByName(ETRow_EndDate).Date;
	endif;
	
	if term &lt;&gt; null then
		dueRule := term.dueRule;
		dueDays := term.dueDays;
		
		// If no rule selected, use end of period by default
		if dueRule = null or dueRule = CM_InvoiceTermsOfTrade.EndOfPeriodPlusDueDays then
			firstInvoice := self.allInvoices.first();
			endDate := app.myRoot.myRootCompany.getPeriodEndDateInitialise(firstInvoice.debtor, firstInvoice.invoiceType, nowTS, true).date();
			dueDate := endDate.addDays(dueDays);
		elseif dueRule = CM_InvoiceTermsOfTrade.PostedDatePlusDueDays then
			dueDate := today.addDays(dueDays);
		elseif dueRule = CM_InvoiceTermsOfTrade.EndDatePlusDueDays then
			endDate := table.getValueByName(ETRow_EndDate).Date;
			dueDate := endDate.addDays(dueDays);
		elseif dueRule = CM_InvoiceTermsOfTrade.InvoiceDatePlusDueDays then
			invoiceDate := table.getValueByName(ETRow_InvoiceDate).Date;
			dueDate := invoiceDate.addDays(dueDays);
		endif;
	endif;
	
	// Set the Due date on the UI
	self.mskDueDate.setDate(dueDate);
	table.setValueByName(ETRow_DueDate, dueDate);
	
	return dueDate;
epilog

end;</source>
        <Parameter name="_changedCtrl" type="Control"/>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="cmbTermsTrade_lostFocus" id="d3dddcfa-580d-4346-8834-54679ad822bf">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTermsTrade_lostFocus(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/01/2023	navkc1 ChangeRequest 59145 Task 61332: UI - Invoice Post

*/

vars

begin
	inheritMethod(combobox);
	self.calculateDueDate(self.cmbTermsTrade);
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="23636c5d-132e-4fe2-b7d0-f17062a67400">
        <updating/>
        <source>doSave() updating;
/*

Purpose:			

Parameters:			

Return Value:

Date		Who		Reason
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
15/01/2023	navkc1 ChangeRequest 59145 Task 61332: UI - Invoice Post
12/02/2024	navra1	CR 61910/Task 62303 - EUP | API Create default package to run on invoice updating status to POSTED
20/02/2024  navra1	CR 61803/Tasks - 61804/61805 - EUP |  API - Save a printout of the invoice and its attachments in the directory specified
*/

vars
	doExport,
	runPackage,
	showWarning			: Boolean;
	finIOClass			: CM_ExtFinanceIO;
	createdTransient	: Boolean;
	extraMessage		: String;
	theStatus			: CMIF_InvoiceStatus;
	pxyInvoice,
	realInvoice			: CM_Invoice;
	idx			: Integer;
	invoices			: CM_InvoiceBySeqNumDict;
	statuses			: CMIF_Array;
	oa					: ObjectArray;
	debtorInvType		: CM_DebtorInvType;
	package				: CM_PackageInvoice;
	task				: CM_AutoTask;
	schedule			: CM_AutoSchedule;
	invLine				: CM_InvoiceLine;
	isASPAInterface,
	isPelindo1Interface	: Boolean;
	isPOBFinanceOneInterface : Boolean;
	allFailedInvoices : CM_InvoiceBySeqNumDict;
	multiNarration,
	financeOneMessage : String;
	rootCompany			: CM_Bank;
	ts,
	fromDT				: TimeStamp;
	shouldDefaultPackageRun	: Boolean;
	
begin
	app.mousePointer  := MP_HOURGLASS;
	
	if self.newStatus = CM_Invoice.INVOICE_POSTED then
		if not self.myCurrentBank.userCanSet(self.newStatus) then 
			app.msgBox(app.getErrorString1(VB_SECMOVE,app.getErrorString(INV_Invoice_Status_Post)) ,
											app.getErrorString(INV_Invoice_Security),
											MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
			return;
		endif;
	endif;
	
	realInvoice := self.myCurrentInvoice;
	rootCompany := app.myRoot.myRootCompany;
	
	create invoices transient;
	create statuses transient;
	create oa transient;
	
	finIOClass := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	if finIOClass = null 
		or not global.isValidObject(finIOClass) then
			create finIOClass as CM_DefaultFinanceIO transient;
			createdTransient := true;
	endif;
	
	if finIOClass &lt;&gt; null then
		if finIOClass.isKindOf( CM_ASPAInterface ) then
			isASPAInterface := true;
		elseif finIOClass.isKindOf( CM_Pelindo1Interface ) then
			isPelindo1Interface := true;
		elseif finIOClass.isKindOf(CM_POBFinanceOneInterface) then
			isPOBFinanceOneInterface:=true;
		endif;
	endif;
	
	// Exclude reversed invoices
	foreach realInvoice in self.allInvoices do
		if realInvoice.isReversed() or realInvoice.isReverseCredit() then
			continue;
		endif;
		
		invoices.add(realInvoice);
		
		if realInvoice.debtor.isRDT() then
			extraMessage := "NOTE: Invoice is for default debtor.";
		endif;
	endforeach;
	
	idx := invoices.size();
	
	if idx &gt; 1 then
		realInvoice := invoices.first.CM_Invoice;
		if app.msgBox("Do you want to change the status of all " &amp; idx.String &amp; " invoices to " &amp; realInvoice.getStatusDescription(self.newStatus) &amp; "?  " &amp; extraMessage,
							app.getErrorString1(INV_ChangeStatus, realInvoice.getStatusDescription(self.newStatus)),
							MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon) = MsgBox_Return_No  then
			return;
		endif;
	else
		if app.msgBox(app.getErrorString(WARN_CHANGE_STATE)&amp; " Do you want to continue?  " &amp; extraMessage, app.getErrorString1(INV_ChangeStatus,
				realInvoice.getStatusDescription(self.newStatus)),
				MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No  then
			return;
		endif;
	endif;
	
	multiNarration := self.txtNarr.text;
	
	create allFailedInvoices transient;
	
	if isPOBFinanceOneInterface and self.newStatus = CM_Invoice.INVOICE_POSTED then
		foreach realInvoice in invoices discreteLock do
			finIOClass.export(realInvoice);
			if realInvoice.externalIntefaceStatus &lt;&gt; CM_EWSActivityFinanceOne.Status_Success then
				allFailedInvoices.add(realInvoice);
				invoices.remove(realInvoice);
			endif;
		endforeach;
		financeOneMessage:=app.getErrorString2(Success_failure_inv_fin_one,invoices.size.String,allFailedInvoices.size.String);
		
		if invoices.size = 0 then
			app.msgBox(app.getErrorString(No_success_fin_one),app.getErrorString(Finance_one),MsgBox_OK_Only);
			return;
		endif;
	endif;
	
	foreach realInvoice in invoices do
		pxyInvoice := app.createUpdateProxy(realInvoice).CM_Invoice;
		oa.add(pxyInvoice);
		
		create theStatus transient;
		theStatus.myInvoice := pxyInvoice;
		
		if realInvoice.myInvoiceProcess.isKindOf(CM_InvoiceProcessInvoiceAPI) then							//navra1 - CR 61910/Task 62303 - 16th Feb 2024
			theStatus.runPackages := self.tblInvProperties.getValueByName(ETRow_RunPackage).Boolean;		//navra1 - CR 61910/Task 62303 - 16th Feb 2024
		endif;																								//navra1 - CR 61910/Task 62303 - 16th Feb 2024
		
		//navra1 - CR 61910/Task 62303 - 12th Feb 2024 - start
		/*if self.newStatus = CM_Invoice.INVOICE_POSTED and realInvoice.status = CM_Invoice.INVOICE_PENDING then
			if realInvoice.myInvoiceProcess.isKindOf(CM_InvoiceProcessInvoiceAPI) then
				theStatus.newStatus := CM_Invoice.INVOICE_POSTED_PENDING;
			else
				theStatus.newStatus := self.newStatus;
			endif;
		endif;*/
		//navra1 - CR 61910/Task 62303 - 12th Feb 2024 - end
		
		//navra1 - BUG 62651 - 1st Mar 2024 - start
		if realInvoice.myInvoiceProcess.isKindOf(CM_InvoiceProcessInvoiceAPI) then
			if self.newStatus = CM_Invoice.INVOICE_POSTED then
				if realInvoice.status = CM_Invoice.INVOICE_PENDING or realInvoice.status = CM_Invoice.INVOICE_POSTED_ERROR then 
					theStatus.newStatus := CM_Invoice.INVOICE_POSTED_PENDING;
				elseif realInvoice.status = CM_Invoice.INVOICE_POSTED_PENDING then //jlier1 MTN-34357 20/3/25
					if realInvoice.isNSWFinancialSystem then
						theStatus.newStatus:= CM_Invoice.INVOICE_POSTED_PENDING;
						//should check if there are already a bgp request then give error and return
						if realInvoice.hasInvoiceAPIRequest then
							 app.msgBox(app.getErrorString(Not_chang_invoi_poste_when_the), app.getErrorString1(INV_ChangeStatus,
								realInvoice.getStatusDescription(self.newStatus)),
								MsgBox_OK_Only + MsgBox_Question_Mark_Icon);
							return;
						endif;
					endif;
				else	//this can happen when a user with invoice admin permission changes invoice from INVOICE_POSTED_PENDING to INVOICE_POSTED
					theStatus.newStatus := self.newStatus;
				endif;
			else
				theStatus.newStatus := self.newStatus;
			endif;
		else
			theStatus.newStatus := self.newStatus;		
		endif;
		//navra1 - BUG 62651 - 1st Mar 2024 - end
		
		if self.newStatus = CM_Invoice.INVOICE_POSTED then
			showWarning := true;
			
			foreach invLine in realInvoice.invoiceLines where invLine.status &lt;&gt; CM_InvoiceLine.STATUS_VOIDED do
				showWarning := false;
				break;
			endforeach;
		endif;
		
		if showWarning then
			if app.msgBox(app.getErrorString(WARN_POST_VOID_LINES)&amp; " Do you want to continue?", app.getErrorString1(INV_ChangeStatus,
							realInvoice.getStatusDescription(self.newStatus)),
							MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No  then
				return;
			endif;
		endif;
		
		theStatus.myTermsOfTrade 	  	:= self.cmbTermsTrade.listObject.CM_InvoiceTermsOfTrade;
		theStatus.purchaseOrderNumber 	:= self.tblInvProperties.getValueByName(ETRow_PurchaseOrderNumber).String;
		theStatus.debtorReference 	  	:= self.tblInvProperties.getValueByName(ETRow_DebtorReference).String;
		
		if multiNarration = null then
			theStatus.narration := realInvoice.narration;
		else
			theStatus.narration := multiNarration;
		endif;		
		
		if self.isCreditNote then
			theStatus.toDT.setDate(self.mskCNEndDate.getDate());
		else
			theStatus.toDT.setDate(self.tblInvProperties.getValueAsDate(ETRow_EndDate));
		endif;
		theStatus.toDT.setTime('23:59:59.999'.Time);
		
		if isASPAInterface then
			theStatus.isZeroRatedTax      := true;
			theStatus.doExport            := true;
		else
			theStatus.isZeroRatedTax 	  := self.tblInvProperties.getValueByName(ETRow_IsZeroRated).Boolean;
			
			if self.tblInvProperties.isRowVisible(ETRow_Export) then
				theStatus.doExport := self.tblInvProperties.getValueByName(ETRow_Export).Boolean;
			else
				theStatus.doExport := false;	
			endif;
		endif;
		
		doExport := theStatus.doExport;
		theStatus.myCurrencyType := self.cmbCurrencyType.listObject.CM_CurrencyType;
		theStatus.myLocale := self.cmbLocale.listObject.CM_Locale;
		
		// If changing to Pending, we can update Debtor, so we update addresses also
		if self.newStatus = CM_Invoice.INVOICE_PENDING then
			theStatus.myDebtor := self.cmbDebtorInvProp.listObject.CM_Debtor;
			theStatus.myAlternativeAddress := self.cmbDebtorAltAddrProp.listObject.CM_Address;
			theStatus.myBillingAddress := self.cmbDebtorAddressProp.listObject.CM_Address;
		else
			if self.isMulti then
				theStatus.myAlternativeAddress := realInvoice.myAlternativeAddress;
				theStatus.myBillingAddress := realInvoice.myBillingAddress;
			else
				theStatus.myAlternativeAddress := self.cmbDebtorAltAddrProp.listObject.CM_Address;
				theStatus.myBillingAddress := self.cmbDebtorAddressProp.listObject.CM_Address;
			endif;
		endif;
		
		if realInvoice.isCreditNote() then
			theStatus.invoiceType := self.cmbInvTypeInv.listObject.CM_InvoiceDesc;
			fromDT.setDate(self.mskCNStartDate.getDate());
			fromDT.setTime(self.mskCNStartTime.getTime());
			theStatus.fromDT := app.localToSystemTime(fromDT);
		else
			theStatus.invoiceType := realInvoice.invoiceType;
			theStatus.fromDT := realInvoice.fromDT;
		endif;
		
		// Invoice Date
		ts.setDate(self.mskInvoiceDate.getDate());
		theStatus.invoiceDate := self.localToSystemTime(ts);
		
		// Due Date
		ts.setDate(self.mskDueDate.getDate());
		theStatus.dueDate := self.localToSystemTime(ts);
		
		statuses.add(theStatus);
	endforeach;
	
	runPackage := self.tblInvProperties.getValueByName(ETRow_RunPackage).Boolean;
	
	// ### JIRA 19932 21OCT2024 NAVAB1
	if not self.doSaveDLRT(statuses) then
		return;
	endif;
	/*// ### JIRA 19932 21OCT2024 NAVAB1
	while true do
		app.myTrxUA.trxUpdateInvoiceStatuses(statuses, app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(CM_Update_Invoice), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
	*/
	// Stop here if we are not posting
	if not self.newStatus = CM_Invoice.INVOICE_POSTED then
		if financeOneMessage &lt;&gt; null then
			app.msgBox(financeOneMessage,app.getErrorString(Finance_one),MsgBox_OK_Only);
		endif;
		self.unloadForm();
		return;
	endif;
	
	// ** NOTE**
	// Do not go beyond this line if not posting
	
	if doExport then
		foreach realInvoice in invoices where (realInvoice.isPosted() or realInvoice.status = CM_Invoice.INVOICE_POSTED_PENDING) do
			finIOClass.export(realInvoice);
		endforeach;
	endif;
	
	//navra1 - 20 Feb 2024 - TFS 61803/Tasks - 61804/61805 - start
	foreach realInvoice in invoices do
		if realInvoice.myInvoiceProcess.isKindOf(CM_InvoiceProcessInvoiceAPI) and realInvoice.status = CM_Invoice.INVOICE_POSTED_PENDING then
			app.myTrxCA.trxCopyInvoiceAndAttachments(realInvoice, finIOClass.exportPath.normaliseDirectory().substituteDirectory(), app.myPassport);
			if app.myPassport.trxCompletedOK then
				global.beep;
				break;
			else
				app.writeLog("Copy of the attachments/PDF report failed!" &amp; app.myPassport.getErrorsAsString(), LogERROR);
				break;
			endif;
		endif;
	endforeach;
	//navra1 - 20 Feb 2024 - TFS 61803/Tasks - 61804/61805 - end
	
	if runPackage then
		foreach realInvoice in invoices do			
			if realInvoice.status &lt;&gt; CM_Invoice.INVOICE_POSTED_PENDING then												//navra1 - CR 61910/Task 62303 - 16th Feb 2024
				shouldDefaultPackageRun := true;		//for each invoice assume defaultpackage should run 			//navra1 - CR 61910/Task 62303 - 13th Feb 2024
				debtorInvType := realInvoice.debtor.allDebtorInvTypes[realInvoice.invoiceType];
				if debtorInvType &lt;&gt; null then				
					foreach package in debtorInvType.allPackageInvoices do					
						foreach task in package.allTasks do
							//navra1 - CR 61910/Task 62303 - 13th Feb 2024
							//if there was a package configured and it had a schedule 
							//to run, we dont want to run the default package
							shouldDefaultPackageRun := false;
							schedule := task.allAutoSchedules.first;
							app.runEventScheduleInvoice(schedule, realInvoice, null);
						endforeach;
					endforeach;				
				endif;
				if shouldDefaultPackageRun then																			//navra1 - CR 61910/Task 62303 - 13th Feb 2024
					package := realInvoice.bank.myDefaultPackage;														//navra1 - CR 61910/Task 62303 - 13th Feb 2024
					foreach task in package.allTasks do																	//navra1 - CR 61910/Task 62303 - 13th Feb 2024
						schedule := task.allAutoSchedules.first;														//navra1 - CR 61910/Task 62303 - 13th Feb 2024
						app.runEventScheduleInvoice(schedule, realInvoice, null);										//navra1 - CR 61910/Task 62303 - 13th Feb 2024
					endforeach;																							//navra1 - CR 61910/Task 62303 - 13th Feb 2024
				endif;																									//navra1 - CR 61910/Task 62303 - 13th Feb 2024
			endif;																										//navra1 - CR 61910/Task 62303 - 16th Feb 2024
		endforeach;
	endif;
	
	if financeOneMessage &lt;&gt; null then
		app.msgBox(financeOneMessage,app.getErrorString(Finance_one),MsgBox_OK_Only);
	endif;
	
	self.unloadForm();
	
epilog
	delete invoices;
	if oa &lt;&gt; null then
		oa.purge;
		delete oa;
	endif;
	if statuses &lt;&gt; null then
		statuses.purge;
		delete statuses;
	endif;
	if createdTransient then
		delete finIOClass;
	endif;
	delete allFailedInvoices;
	app.mousePointer := MP_DEFAULT;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSaveDLRT" id="16798c22-d03c-4e94-9546-238de2eb4afc">
        <updating/>
        <source>doSaveDLRT(_statuses	: CMIF_Array) : Boolean updating;
/*
Purpose:	

Date		Who		Reason
21 October 2024	navab1	JIRA 19932
7/3/25 navsaa30 14818 MTN | Silent Deadlock Retry Technical Debt
03/11/2025 jlier1 	MTN-34531 - Deadlock retry for everyone
*/

vars
	theReturn : Integer;
	localCaption : String;
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	localCaption := self.caption;
	//set up the silent deadlock handler to attempt to retry
	app.myPassport.setupForDeadlockReplay(220, 3000);
	app.myPassport.silentDeadlockLimit := 10;	
	
	while true do
		//call the code that was originally in this method
		while true do
			app.myTrxUA.trxUpdateInvoiceStatuses(_statuses, app.myPassport);
			
			if app.myPassport.hadDeadlock then //jlier1 4/11/25 break to deadlock loop
				break;
			endif;
			
			if app.myPassport.trxCompletedOK then
				global.beep;
				break;
			else
				theReturn := app.showErrorWarningDialog(app.getErrorString(CM_Update_Invoice), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				return false;
			endif;
			break;
		endwhile;
		
		//if we did NOT have a dead lock, just bail out.
		if app.myPassport.noTrxReplayAllowed() then	
			if app.myPassport.hadDeadlock then //had a deadlock and reached the limit show the deadlock error
				app.showErrorWarningDialog(app.getErrorString(CM_Update_Invoice), app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			endif;
			break;
		endif;
		
		self.updateCaptionDeadlockRetry(localCaption);
				
	endwhile;

	return true;
epilog

	//set the silent deadlock handler back to the default values i.e. OFF
	app.myPassport.resetSilentDeadlockHandler;	//7/3/25 navsaa30 #14818
	self.caption := localCaption;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_statuses" type="CMIF_Array"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initEntTables" id="3d2597ae-4d34-4e37-801a-34627fc5cbe1">
        <updating/>
        <source>initEntTables() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items

*/

vars
	theTable		: CM_EntryTable;
begin

	inheritMethod(); // 10/11/2023	navkc1 Bug 61004
	
	theTable := self.tblInvProperties;
	if self.newStatus = CM_Invoice.INVOICE_POSTED then
		//self.initEntTable(theTable, ETDef_InvListInvProperties, ETView_InvListInvPropPost);
		theTable.showHideRowsByViewName(ETView_InvListInvPropPost, CM_EntryTable.ShowHideRows, true);
	elseif self.newStatus = CM_Invoice.INVOICE_PENDING then
		//self.initEntTable(theTable, ETDef_InvListInvProperties, ETView_InvListInvPropUpdate);
		theTable.showHideRowsByViewName(ETView_InvListInvPropUpdate, CM_EntryTable.ShowHideRows, true);
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initForStatus" id="11f6f1f6-a3ce-4472-bb33-114dae67a3a4">
        <updating/>
        <source>initForStatus() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
//13/02/2024	navra1	CR 61910/Task 62303 - EUP | API Create default package to run on invoice updating status to POSTED

*/

vars
	theTable		: CM_EntryTable;
	packageNames	: String;
begin
	
	theTable := self.tblInvProperties;
	
	if self.isMulti then
		theTable.hideRowByName(ETRow_SequenceNum, false);
		if self.newStatus = CM_Invoice.INVOICE_POSTED then
			theTable.hideRowByName(ETRow_DebtorAddress, false);
			theTable.hideRowByName(ETRow_AlternativeAddress, false);
		endif;
	endif;

	theTable.setValueByName(ETRow_Export, true);
	
	packageNames:=self.myCurrentInvoice.getDisplayStringForAttribute(ETRow_Packages,false);	
	if self.newStatus = CM_Invoice.INVOICE_POSTED and packageNames &lt;&gt; null then
		theTable.setValueByName(ETRow_Packages, packageNames);
		theTable.showRowByName(ETRow_RunPackage, false);
		theTable.setValueByName(ETRow_RunPackage, true);								//navra1 - CR 61910/Task 62303 - 13th Feb 2024
		theTable.showRowByName(ETRow_Packages, false);
	else
		theTable.hideRowByName(ETRow_RunPackage, false);
		theTable.hideRowByName(ETRow_Packages, false);
	endif;
	
	if self.isCreditNote then
		theTable.hideRowByName(ETRow_EndDate, false);
	else
		theTable.hideRowByName(ETRow_InvoiceTypeCode, false);
		theTable.hideRowByName(ETRow_CreditNoteStartDate, false);
		theTable.hideRowByName(ETRow_CreditNoteStartTime, false);
		theTable.hideRowByName(ETRow_CreditNoteEndDate, false);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="invTypeClick" id="ef6f6a15-d3eb-4405-aa16-13e31dd6a72f">
        <updating/>
        <source>invTypeClick(combobox: ComboBox input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10/11/2023	navkc1 Bug 61004: LNX - New Invoice Creation screen is multi tabbed
13/02/2024	navra1	CR 61910/Task 62303 - EUP | API Create default package to run on invoice updating status to POSTED

*/

vars
	theTable 		: CM_EntryTable;
	theInvoice		: CM_Invoice;
	packageNames	: String;
begin
	theTable := self.tblInvProperties;
	theInvoice := self.myCurrentInvoice;
	
	inheritMethod(combobox);
	
	theTable.hideRowByName(ETRow_RunPackage, false);
	theTable.hideRowByName(ETRow_Packages, false);
	
	theTable.setValueByName(ETRow_EndDate, theInvoice.toDT.date());
	theTable.disableRowByName(ETRow_EndDate);
	
	packageNames:=theInvoice.getDisplayStringForAttribute(ETRow_Packages,false);
	if packageNames &lt;&gt; null then
		theTable.showRowByName(ETRow_RunPackage, false);
		theTable.setValueByName(ETRow_RunPackage, true);								//navra1 - CR 61910/Task 62303 - 13th Feb 2024
		theTable.showRowByName(ETRow_Packages, false);
		theTable.setValueByName(ETRow_Packages, packageNames);
	endif;	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="isPosted" id="304013ad-9ef4-4980-aa0d-91879c0a3160">
