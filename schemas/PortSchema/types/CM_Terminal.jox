    <JadeMethod name="setForCreate" id="419e0e3a-bfe6-42de-88fa-e86d0e3f0907">
        <updating/>
        <source>setForCreate(_proxyTerminal : CM_Terminal input; _keyValue : Any) updating;
// -----------------------------------------------------------------------------
// Created:		19 February 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
// 17 May 2010	cnwkpd1	PAR #23525 - System performance enhancements
// 26/10/2022 	Navcs2		Bug 55222: MTN - allDebtorsTerminal collection not updating for debtor when new Terminal Created
// -----------------------------------------------------------------------------
vars
	company,
	businessUnit	: CM_Bank;
	ioClass 		: CM_DefaultFinanceIO;
	theRoot 		: CM_Root;
	agent			: CM_ObjectVolatilityConverter;
	
begin
	_proxyTerminal.raiseExceptionIfNotTransient(method);
	
	theRoot := app.myRoot;
	
	self.setPermValue(_keyValue);
	self.setForUpdate(_proxyTerminal);
	
	self.myRoot := theRoot;

	create company persistent;
	company.initialise("Default Company", "DCOM", theRoot.myRootCompany, self);
	
	create businessUnit persistent;
	businessUnit.initialise("Default Business Unit", "DFBU", company, self);
	//self.setConfig(DefCompany, businessUnit);
	self.setDefaultCompanyBank(businessUnit);	//17 Apr 2012	NDL	Par 29393
	
	if theRoot.myRootCompany.ioClasses.isEmpty then
		create ioClass persistent;	
		ioClass.initialise(theRoot.myRootCompany, "Default Financial Class");
	endif;
	
	// PAR #23525 - If system is using stable objects, then need to change the volatility of
	// the newly created object's collections
	if theRoot.useStableObjects then
		create agent transient;
		agent.newVolatility := Volatility_Stable;
		agent.multipleTransactions := false;
		
		self.doObjectVolatilityConversion(agent, 1);
	endif;
	
	self.createDebtorTerminals(); // 26/10/2022 Navcs2 Bug 55222

epilog
	delete agent;
	
end;</source>
        <Parameter name="_proxyTerminal" type="CM_Terminal" usage="input"/>
        <Parameter name="_keyValue" type="Any"/>
    </JadeMethod>
