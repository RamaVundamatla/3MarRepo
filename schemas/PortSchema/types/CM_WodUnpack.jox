    <JadeMethod name="pxyCreateUpdateProxy" id="0d11e49c-b80c-4c33-8345-a7e5a79287f6">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
12 Aug 2009		cnwmd1	Initial creation
20/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when	trying to create the proxy
*/

vars
	pxy : SelfType;
	completedOK		: Boolean;
begin
	pxy := inheritMethod();
	
	pxy.myUnpackToLocation := self.myUnpackToLocation;

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="f3de02e4-5de7-4652-a94b-6bea59289e30">
        <updating/>
        <source>setForUpdate(_pxyWoDDtl: CM_WorkOrderDtl) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2009	cnwrd1	Initial creation

*/

vars

begin
	inheritMethod(_pxyWoDDtl);
	

	self.myUnpackToLocation := _pxyWoDDtl.CM_WodUnpack.myUnpackToLocation;
epilog

