    <JadeMethod name="jreApplyLockForTesting" id="c472bf1a-dfe5-4166-b92d-ffcdf25b67a7">
        <source>jreApplyLockForTesting();
// in conjunction XMLSchema JadeScript testXMLLocking
vars
	logTest	: UT_LogTests;
	terminal : CM_Terminal;
	
	
begin
	app.initialize;
	
	create logTest transient;
	logTest.sendMsg("setActiveProfile");
	logTest.uBOLDelete();
	terminal := app.myRoot.allTerminals["UT"];

	self.exclusiveLock(terminal.allBOLTermsByTypeNum);
	app.msgBox("Terminal collection locked", "Wait", 0);
	self.unlock(terminal.allBOLTermsByTypeNum);
epilog
	delete logTest;
end;
</source>
    </JadeMethod>
    <JadeMethod name="lockTestingFonterraXML" id="5e561053-1569-44fb-8fd7-cb27efd22b70">
        <source>lockTestingFonterraXML();
//
//22 Feb 2013	cnwrs1	Par 31150 EDI Pack not restarting after lock error
//
