    <JadeMethod name="setMeasurementValue" id="8a8a7599-c6a6-434d-b127-bb3e3f8f201b">
        <updating/>
        <source>setMeasurementValue(_entRowName: String; _value: Decimal) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 16 May 2022
TFS#		: 53316
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	if _entRowName = ETRow_Diameter then
		//self.diameter :=_value;
		self.setDiameter(_value); 		// ### TFS 54021 29June2022 NAVPW1
	elseif _entRowName = ETRow_RollingLength then
		//self.rollingLength :=_value;
