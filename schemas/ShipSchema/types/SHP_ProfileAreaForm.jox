    <JadeMethod name="getXMLSettingsForSave" id="837c9f3a-c0c0-48bb-b098-bc77498fe398">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:		06 October 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theXML			: String;
	
begin
	theXML := inheritMethod();

	// NOTE if these menus have a caption saying SHOW it means that the item is hidden
	theXML := theXML &amp; 
			global.formatAsXML("WEBZOOM",self.webPicScaleFactor.String);
	theXML := theXML &amp; 
			global.formatAsXML("WEBTOP",self.frmWebCam.top.String);
	theXML := theXML &amp; 
			global.formatAsXML("WEBLEF",self.frmWebCam.left.String);
	
	return theXML;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="0711cdc1-4acc-4501-a682-cb83b3d66167">
        <updating/>
        <source>getXMLSettingsForSetup() updating;
// ---------------------------------------------------------------------------
// Created:		06 October 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	zoomScale		: Real;
	theXML			: String;
	theXMLValue		: String;
	hideL			: Boolean;
	hideT			: Boolean;
	hideM			: Boolean;
	userWindow		: CM_UserWindow;
	
begin
	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then  // first time in new rewritten form, get old forms XML settings
		userWindow := app.getUserWindow("YRD_GridAreaForm", false);
		
		if userWindow = null then
			return;
		endif;
	endif;
	theXML := userWindow.xmlInfo;

	// #### ZOOM SCALE
 	zoomScale := theXML.cnEcGetTagValueOfName("WEBZOOM").Real;
 
 	if zoomScale = 0 then
	 	zoomScale := 0.5;
	endif;
	self.webPicScaleFactor := zoomScale;
	
	// cnwrl1 13/03/2009 - PAR 18245 - start of coding
	 // #### HIDE LEGEND
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_HL);
 	hideL := false;
 	if theXMLValue &lt;&gt; null then
 		hideL := theXMLValue.Integer.Boolean;
 	endif;
	self.xmlLegend	:= hideL;
	
 	// #### HIDE MACRO
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_HM);
 	hideM := false;
 	if theXMLValue &lt;&gt; null then
 		hideM := theXMLValue.Integer.Boolean;
 	endif;
	self.xmlMacro	:= hideM;
	
 	// #### HIDE TOOLBAR
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_HT);
 	hideT  := false;
 	if theXMLValue &lt;&gt; null then
 		hideT := theXMLValue.Integer.Boolean;
 	endif;
	self.xmlToolbar	:= hideT;
	// cnwrl1 13/03/2009 - PAR 18245 - end of coding
	
	// ### FRAME POSITION
	zoomScale := theXML.cnEcGetTagValueOfName("WEBTOP").Real;
 	if zoomScale = 0 then
	 	zoomScale := 100;
	endif;
	self.xmlWebTop := zoomScale.Integer;
	zoomScale := theXML.cnEcGetTagValueOfName("WEBLEF").Real;
 	if zoomScale = 0 then
	 	zoomScale := 100;
	endif;
	self.xmlWebLeft := zoomScale.Integer;

	// ### SHIFT HOURS
	zoomScale := theXML.cnEcGetTagValueOfName("WEBTOP").Real;
 	if zoomScale = 0 then
	 	zoomScale := 100;
	endif;
	self.xmlWebTop := zoomScale.Integer;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="gridXMLCreate" id="587639dc-f530-469f-8148-7448039689f7">
        <executionLocation>client</executionLocation>
        <source>gridXMLCreate(_theXMLString : String) clientExecution;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theXMLTag, theGridAreaXML : String;
	pos : Integer;
	aColour : Integer;
	theProfileGridArea : SHP_ProfileArea;
begin
	pos := 1;
	while (pos &gt; 0) do
		theGridAreaXML := _theXMLString.cnEcGetNextTagValueOfName("GA",pos); // GRID AREA
		if theGridAreaXML = null then
			break;
		endif;
		
		theXMLTag :=  theGridAreaXML.cnEcGetTagValueOfName("cc");
		if theXMLTag &lt;&gt; null then
			aColour := theXMLTag.Integer;
		endif;

		create theProfileGridArea transient;
		theProfileGridArea.setMyCurrentVoyage(self.myCurrentVoyage);
	
		// there is only one at a time here so the col and row are one
		theProfileGridArea.setForCreateXML(theGridAreaXML, 0);

		self.sdf01.addGridAreaAndFrame(theProfileGridArea, self.frmGridArea);

		self.allGridAreas.add(theProfileGridArea);
		theProfileGridArea.myGridAreaFrame :=  self.frmGridArea;
		self.frmGridArea.backColor := 16777173; // Sky Blue
		if not self.frmGridArea.myGridArea.allGridRows.isEmpty() then
			self.frmGridArea.height :=  self.frmGridArea.myGridArea.allGridRows.last.y2 + 60;
		else
			self.frmGridArea.height :=  200;
		endif;
	endwhile;
	self.frmGridArea.width := 2000;
	self.frmGridArea.height := 550;

	// PAR 28701 - no bays but does have decks
	if self.allGridAreas.size = 1 
	and theProfileGridArea &lt;&gt; null
	and theProfileGridArea.allGridColumns.size = 0
	and theProfileGridArea.allGridRows.size = 0
	and self.myCurrentVoyage.hasStructureOfType(CellularStructureRORO) then
		theProfileGridArea.setForCreateDefault();
	endif;
end;</source>
        <Parameter name="_theXMLString" type="String"/>
    </JadeMethod>
    <JadeMethod name="initBayTable" id="a5c4c087-6f2a-42b9-8f5a-b7a6f14759dc">
        <source>initBayTable();
// ---------------------------------------------------------------------------
// Created:		24 September 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	entTableView	: EntTableView;
	entTableDef		: EntTableDef;
	theTable		: CM_DataTable;
begin
	theTable := self.tblBays;
	
	theTable.userInputEnabled := false;
	theTable.selectMode := CM_EntryTable.SelectMode_FixedRow;
	theTable.selectionType := CM_EntryTable.SelectionType_Row;
	theTable.rows := theTable.fixedRows;
	theTable.cnEcResizeContents();
	
	entTableDef := app.myController.getEntTableDef(ETDef_KPIBayDataTable);
	theTable.setTblDataEntRowsFromDef(entTableDef);
	
	theTable.readOnly := false;	
	theTable.fixedColumns := 0;
	theTable.show3D := Table.Show3D_Not3D;
	theTable.sortColumn[1] := 0;


end;</source>
    </JadeMethod>
    <JadeMethod name="initDelaysTable" id="81f5a28b-8ca2-4704-97ca-cc92e2f13439">
        <source>initDelaysTable();
// ---------------------------------------------------------------------------
// Created:		03 April 2007 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
// 08/11/2012	cnwcs5	par 30519 - translations
vars
	table 	: CM_DataTable;
	heading : String;
begin
	table := self.tblDelays;
	
	table.columns 	:= 9;
	table.rows 		:= 0;
	
	heading := app.getErrorString (CM_Crane_GC) &amp; Tab &amp; 
				app.getErrorString (Start_time) &amp; Tab &amp; 
				app.getErrorString (End_time) &amp; Tab &amp; 
				app.getErrorString (Shift_Name) &amp; Tab &amp; 
				app.getErrorString (Duration) &amp; Tab &amp; 
				app.getErrorString (CM_Description) &amp; Tab &amp; 
				app.getErrorString (Remarks_GC) &amp; Tab &amp; 
				app.getErrorString (Delay_start) &amp; Tab &amp; 
				app.getErrorString (Delay_end);
	
	table.addItem(heading);
	
	table.fixedRows := 1;
	table.gridLines := true;
	table.gridColor := self.ColourLightGrey01;
end;</source>
    </JadeMethod>
    <JadeMethod name="initMovesTable" id="b9318e75-b5ac-4b72-b94d-4f658781325b">
        <source>initMovesTable();
// ---------------------------------------------------------------------------
// Created:		03 April 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	table : CM_DataTable;
	colStr : String;
	numCols, idx : Integer;
begin
	table := self.tblStats;
	
	table.columns := 24;
	table.rows := 0;

	colStr := 	"" &amp; Tab &amp; Tab &amp; 
					"Shift" &amp;Tab &amp; 
					"" &amp; Tab &amp;
					"" &amp; Tab &amp;
					"" &amp; Tab &amp; // GAP 1
					"Moves" &amp; Tab &amp; 
					Tab &amp;
					Tab &amp; 
					"" &amp; Tab &amp; // GAP 2
					"Hours" &amp; Tab &amp; 
					"" &amp; Tab &amp; 
					"" &amp; Tab &amp;
					"" &amp; Tab &amp;
					"" &amp; Tab &amp; // GAP 3
					"Container" &amp; Tab &amp; 
					"" &amp; Tab &amp; 
					"" &amp; Tab &amp; 
					"" &amp; Tab &amp; 
					"" &amp; Tab &amp; // GAP 4
					"Lifts" &amp; Tab &amp; 
					"" &amp; Tab &amp; 
					"" &amp; Tab &amp; 
					"" &amp; Tab &amp; 
					"";
	table.addItem(colStr);

	colStr := 	"Voyage" &amp; Tab &amp; 
					"Crane" &amp; Tab &amp; 
					"Start" &amp; Tab &amp; 
					"End" &amp; Tab &amp; 
					"Name" &amp; Tab &amp; 
					"" &amp; Tab &amp; // GAP 1
					"Containers" &amp; Tab &amp; 
					"TEUs" &amp; Tab &amp; 
					"Lids" &amp; Tab &amp; 
					"" &amp; Tab &amp; // GAP 2
					"Gross" &amp;  Tab &amp;
					"Down " &amp; Tab &amp;
					"Delay " &amp; Tab &amp;
					"Net " &amp; Tab &amp; 
					"" &amp; Tab &amp; // GAP 3
					"Gross Rate" &amp; Tab &amp; 
					"+/-" &amp; Tab &amp;
					"Net Rate" &amp; Tab &amp; 
					"+/-" &amp; Tab &amp;
					"" &amp; Tab &amp; // GAP 4
					"Min P/Hr" &amp; Tab &amp; 
					"+/-" &amp; Tab &amp;
					"Max P/Hr" &amp; Tab &amp; 
					"+/-";
			
	table.addItem(colStr);
	table.accessCell(1,21).mergeCells := Table.MergeCells_Merge;
	table.accessedCell.alignment := Table.Alignment_Center;
	table.accessCell(1,16).mergeCells := Table.MergeCells_Merge;
	table.accessedCell.alignment := Table.Alignment_Center;
	table.accessCell(1,11).mergeCells := Table.MergeCells_Merge;
	table.accessedCell.alignment := Table.Alignment_Center;
	table.accessCell(1,7).mergeCells := Table.MergeCells_Merge;
	table.accessedCell.alignment := Table.Alignment_Center;
	table.accessCell(1,3).mergeCells := Table.MergeCells_Merge;
	table.accessedCell.alignment := Table.Alignment_Center;
	
	table.fixedRows := 2;
	table.gridLines := true;
	table.gridColor := self.ColourLightGrey01;
	numCols := table.columns;
	foreach idx in 5 to numCols do
		table.accessColumn(idx).alignment := Table.Alignment_Right_Top;
	endforeach;

	table.accessColumn(6).width := 2;
	table.accessedColumn.backColor := Grey;
	table.accessColumn(10).width := 2;
	table.accessedColumn.backColor := Grey;
	table.accessColumn(15).width := 2;
	table.accessedColumn.backColor := Grey;
	table.accessColumn(20).width := 2;
	table.accessedColumn.backColor := Grey; //DarkGray;
	table.selectMode := Table.SelectMode_CurrentRow;
	
	self.showAverageColumns(false);
end;</source>
    </JadeMethod>
