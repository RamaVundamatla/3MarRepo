    <JadeMethod name="createData_ContainerKPI" id="a7eda1c5-8a84-43e2-9268-a49b4cce8536">
        <source>createData_ContainerKPI(_coll :CM_KPIVoyageMoveDtlContDict; _obj :CM_Object) protected;
/*
Date		Who		Reason
15 Aug 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
03/09/2012	cnwcs5	par 30290
*/
constants
	NotIncluded	 	= 0;
	IncludeOther 	= 2;
vars
	dd				:DynaDictionary;
	array			:ObjectArray;
	kpi				:CM_KPIVoyageMoveDtl;
	length, index	:Integer;
	coll			:CM_KPIVoyageMoveDtlDict;
	moveType, int	:Integer;	// par 30290
begin	
	dd 		:= self.allData_Containers;

	foreach kpi in _coll do
		length := kpi.CM_KPIVoyageMoveDtl_Container.containerLength;
		
		if length = 30 then					// par 30290 Sep 2012
			int := self.is30Included;  		// par 30290 Sep 2012
			
			if int = NotIncluded then		// par 30290 Sep 2012
				continue;					// par 30290 Sep 2012
			endif;							// par 30290 Sep 2012
			
			if int = IncludeOther then		// par 30290 Sep 2012
				length := Max_Integer;		// par 30290 Sep 2012
			endif;							// par 30290 Sep 2012
		elseif length = 45 then				// par 30290 Sep 2012
			int := self.is45Included;  		// par 30290 Sep 2012
			
			if int = NotIncluded then		// par 30290 Sep 2012
				continue;					// par 30290 Sep 2012
			endif;							// par 30290 Sep 2012
			
			if int = IncludeOther then		// par 30290 Sep 2012
				length := Max_Integer;		// par 30290 Sep 2012
			endif;							// par 30290 Sep 2012
		elseif length = 53 then				// par 30290 Sep 2012
			int := self.is53Included;  		// par 30290 Sep 2012
			
			if int = NotIncluded then		// par 30290 Sep 2012
				continue;					// par 30290 Sep 2012
			endif;							// par 30290 Sep 2012
			
			if int = IncludeOther then		// par 30290 Sep 2012
				length := Max_Integer;		// par 30290 Sep 2012
			endif;							// par 30290 Sep 2012
		endif;								// par 30290 Sep 2012		
		
		if self.mode = self.Mode_DecksTable then
			array	:= dd.getAtKey (length, _obj.CM_KPIVoyageDeckWorkPoint.myWorkPoint.description, _obj.CM_KPIVoyageDeckWorkPoint.myDeckVoyage.code, _obj).ObjectArray;
		elseif self.mode = self.Mode_RRMovesTable then
			array	:= dd.getAtKey (length, _obj.CM_KPIVoyageWorkPointShift.shiftStartTS, _obj.CM_KPIVoyageWorkPointShift.myWorkPoint.code, _obj).ObjectArray;
		endif;
		
		if array = null then
			create array transient;
			array[self.getMaxIndex]	:= null;
			
			if self.mode = self.Mode_DecksTable then
				dd.putAtKey (length, _obj.CM_KPIVoyageDeckWorkPoint.myWorkPoint.description, _obj.CM_KPIVoyageDeckWorkPoint.myDeckVoyage.code, _obj, array);
			elseif self.mode = self.Mode_RRMovesTable then
				dd.putAtKey (length, _obj.CM_KPIVoyageWorkPointShift.shiftStartTS, _obj.CM_KPIVoyageWorkPointShift.myWorkPoint.code, _obj, array);
			endif;
		endif;
	
		moveType := kpi.voyageMoveType;
		
		if moveType = VoyageMoveType_Discharge then
			if kpi.isTranship then
				index := self.Index_DischargeTS;
			else
				index := self.Index_Discharge;
			endif;
		elseif moveType = VoyageMoveType_Load then
			if kpi.isTranship then
				index := self.Index_LoadTS;
			else
				index := self.Index_Load;
			endif;
		elseif moveType = VoyageMoveType_DLR then
			index := self.Index_DLR;
		elseif moveType = VoyageMoveType_SOB then
			index := self.Index_SOB;
		else
			app.raiseUnexpectedProgramError (self.class.name, method.name, 'Invalid move type');
		endif;
		
		coll := array [index].CM_KPIVoyageMoveDtlDict;
		
		if coll = null then
			create coll transient;
			array [index] := coll;
			
			self.allObjectsToGarbageCollect.add (coll);
		endif;
		
		coll.add (kpi);
	endforeach;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_coll" type="CM_KPIVoyageMoveDtlContDict"/>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="createData_DecksTable" id="e3a42fd5-197b-46a7-be4e-5cd7c26ca371">
        <source>createData_DecksTable(_voyage :CM_Voyage) protected;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
08 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	cargoTypes		:CM_CargoTypeSet;
	cargoType		:CM_CargoType;
	kpi				:CM_KPI;
	kpiDeck			:CM_KPIVoyageDeckWorkPoint;
	keyLength, keyMoveType	:Integer;
	keyWPDesc, keyDeckDesc	:String;
	dd_headings		:DynaDictionary;
	array			:DecimalArray;
begin
	create cargoTypes transient;
	
	self.getAllVoyageCargoTypes (_voyage, cargoTypes);
	
	self.allCargoTypes.clear;
	cargoTypes.copy (self.allCargoTypes);
		
	dd_headings 	:= self.allColumnHeadings;
	
	foreach kpi in _voyage.allVoyageKPIEntities do
		if not kpi.isKindOf (CM_KPIVoyageDeckWorkPoint) then
			continue;
		endif;
		
		kpiDeck := kpi.CM_KPIVoyageDeckWorkPoint;
		
		keyWPDesc 	:= kpiDeck.myWorkPoint.code;
		keyDeckDesc := kpiDeck.myDeckVoyage.code;
		
		dd_headings.putAtKey (keyWPDesc, keyDeckDesc, kpiDeck);
		
		// now accumulate container values
		self.createData_ContainerKPI (kpi.CM_KPIVoyageEntity.allKPIVoyageMoveDtls_Container, kpi);
				
		// now accumulate the general cargo values
		self.createData_GCKPI (kpi.CM_KPIVoyageEntity.allKPIVoyageMoveDtls_GC, kpi);	
	endforeach;
epilog
	delete cargoTypes;
end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="createData_GCKPI" id="6513c5a6-bf02-45f9-b1c0-5e4faaa0007b">
        <source>createData_GCKPI (_coll :CM_KPIVoyageMoveDtlGCDict; _obj :CM_Object) protected;
/*
Date		Who		Reason
15 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	dd			:DynaDictionary;
	array		:ObjectArray;
	kpi			:CM_KPIVoyageMoveDtl;
	index		:Integer;
	cargoType	:CM_CargoType;
	coll		:CM_KPIVoyageMoveDtlDict;
	moveType	:Integer;
begin	
	dd 		:= self.allData_GeneralCargo;

	foreach kpi in _coll do
		cargoType := kpi.CM_KPIVoyageMoveDtl_GC.myCargoType;
		
		if self.mode = self.Mode_DecksTable then
			array	:= dd.getAtKey (cargoType, _obj.CM_KPIVoyageDeckWorkPoint.myWorkPoint.description, _obj.CM_KPIVoyageDeckWorkPoint.myDeckVoyage.code, _obj).ObjectArray;
		elseif self.mode = self.Mode_RRMovesTable then
			array	:= dd.getAtKey (cargoType, _obj.CM_KPIVoyageWorkPointShift.shiftStartTS, _obj.CM_KPIVoyageWorkPointShift.myWorkPoint.code, _obj).ObjectArray;
		endif;
	
		if array = null then
			create array transient;
			array[self.getMaxIndex]	:= null;
			
			if self.mode = self.Mode_DecksTable then
				dd.putAtKey (cargoType, _obj.CM_KPIVoyageDeckWorkPoint.myWorkPoint.description, _obj.CM_KPIVoyageDeckWorkPoint.myDeckVoyage.code, _obj, array);
			elseif self.mode = self.Mode_RRMovesTable then
				dd.putAtKey (cargoType, _obj.CM_KPIVoyageWorkPointShift.shiftStartTS, _obj.CM_KPIVoyageWorkPointShift.myWorkPoint.code, _obj, array);
			endif;
		endif;
	
		moveType := kpi.voyageMoveType;
		
		if moveType = VoyageMoveType_Discharge then
			if kpi.isTranship then
				index := self.Index_DischargeTS;
			else
				index := self.Index_Discharge;
			endif;
		elseif moveType = VoyageMoveType_Load then
			if kpi.isTranship then
				index := self.Index_LoadTS;
			else
				index := self.Index_Load;
			endif;
		elseif moveType = VoyageMoveType_DLR then
			index := self.Index_DLR;
		elseif moveType = VoyageMoveType_SOB then
			index := self.Index_SOB;
		else
			app.raiseUnexpectedProgramError (self.class.name, method.name, 'Invalid move type');
		endif;
		
		coll := array [index].CM_KPIVoyageMoveDtlDict;
		
		if coll = null then
			create coll transient;
			array [index] := coll;
			
			self.allObjectsToGarbageCollect.add (coll);
		endif;
		
		coll.add (kpi);
	endforeach;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_coll" type="CM_KPIVoyageMoveDtlGCDict"/>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="createData_ROROMovesTable" id="7308f9f0-d01e-469b-b1ae-ad67b72e29ec">
        <source>createData_ROROMovesTable(_voyage :CM_Voyage) protected;
/*
Date		Who		Reason
08 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	cargoTypes		:CM_CargoTypeSet;
	cargoType		:CM_CargoType;
	kpi				:CM_KPI;
	kpiShift		:CM_KPIVoyageWorkPointShift;
	dd_headings		:DynaDictionary;
	array			:DecimalArray;
begin
	create cargoTypes transient;
	
	self.getAllVoyageCargoTypes (_voyage, cargoTypes);
		
	dd_headings 	:= self.allColumnHeadings;
	self.allCargoTypes.clear;
	
	cargoTypes.copy (self.allCargoTypes);
	
	foreach kpi in _voyage.allVoyageKPIEntities do
		if not kpi.isKindOf (CM_KPIVoyageWorkPointShift) then
			continue;
		endif;
		
		kpiShift := kpi.CM_KPIVoyageWorkPointShift;
		
		dd_headings.putAtKey (kpiShift.shiftStartTS, kpiShift.myWorkPoint.description, kpiShift);
		
		// now accumulate container values
		self.createData_ContainerKPI (kpi.CM_KPIVoyageEntity.allKPIVoyageMoveDtls_Container, kpi);
				
		// now accumulate the general cargo values
		self.createData_GCKPI (kpi.CM_KPIVoyageEntity.allKPIVoyageMoveDtls_GC, kpi);	
	endforeach;
epilog
	delete cargoTypes;
end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="displayData_Hours" id="64a348cd-c7c5-4718-82bf-137a7681d5ad">
        <source>displayData_Hours(_table :Table input; _row :Integer) protected;
/*
Return Value:		

Date		Who		Reason
15 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	coll	:DynaDictionary;
	obj		:Object;
	kpi		:CM_KPIVoyageEntity;
	col		:Integer;
begin
	coll := self.allColumnHeadings;
	
	foreach obj in coll do
		kpi := obj.CM_KPIVoyageEntity;
		col	:= self.findColumnForObject (_table, self.RRMoves_RowWP, kpi);
		
		if col = null then
			app.raiseUnexpectedProgramError (self.class.name, method.name, 'Unable to find KPI in table');
		endif;
		
		_table.accessCell (_row, col + self.Offset_GrossHours).text	:= kpi.hoursGross.asStringJMT;
		_table.accessCell (_row, col + self.Offset_Down).text		:= kpi.hoursDown.asStringJMT;	//04 Apr 2012	NDL	Par 29369
		_table.accessCell (_row, col + self.Offset_Delay).text		:= kpi.hoursDelay.asStringJMT;
		//_table.accessCell (_row, col + self.Offset_NetHours).text	:= kpi.hoursNet.asStringJMT;
		_table.accessCell (_row, col + self.Offset_NetHours).text	:= kpi.getHoursNetLessDownTime.asStringJMT;	//04 Apr 2012	NDL	Par 29369
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="displayDecksTable" id="fdc42be9-6e60-46d5-a461-b8d47992a4d1">
        <updating/>
        <source>displayDecksTable(_voyage :CM_Voyage; _table :Table input)updating;
/*
Date		Who		Reason
09 Aug 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
09 Sep 2012	cnwcs5	par 30290 -
*/
vars
	table	:Table;
	terminal	:CM_Terminal;	// par 30290
begin
	table := self.myTable;
	
	if table &lt;&gt; null and table &lt;&gt; _table then
		// can't change table
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Cannot change KPI table');
	endif;
	
	self.myTable 	:= _table;
	self.myVoyage	:= _voyage;
	terminal		:= _voyage.getMyTerminal;								// par 30290 Sept 2012
	
	self.mode := Mode_DecksTable;

	self.is30Included	:= terminal.getConfig (Is30IncludedForReports).Integer;	// par 30290 Sept 2012
	self.is45Included	:= terminal.getConfig (Is45IncludedForReports).Integer;	// par 30290 Sept 2012
	self.is53Included	:= terminal.getConfig (Is53IncludedForReports).Integer;	// par 30290 Sept 2012

	self.clearTable;
	self.init_DecksTable (_table);
	self.setup_DecksTable ();
	self.createData_DecksTable (_voyage);
	self.displayHeadings_DecksTable (_table);
	self.displayData_Containers (_table, self.Decks_RowDeck, true, true, true);
	self.displayData_GC (_table, self.Decks_RowDeck, true, false, true, true, true, true, true, null);
epilog
	// membership of these collections is transient collection - they need to be deleted
	self.allData_Containers.purge;
	self.allData_GeneralCargo.purge;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="displayHeadings_DecksTable" id="2962a0f9-2e62-4013-a165-ff29e8e57416">
        <source>displayHeadings_DecksTable(_table :Table input)protected;
/*	
Purpose:	Display all required column headings

Date		Who		Reason
08 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
15/11/2011		cnwcs5	Leaking iterator
*/
constants

vars
	strTotal, strLoad, strTS, strDischarge, strImport, strExport, 
	strSOB, strDLR	:String;
	coll			:Collection;
	iter			:Iterator;
	obj				:Object;
	kpi				:CM_KPIVoyageDeckWorkPoint;
	key1, key2,
	strWP, strDeck	:String;
	col, offset_SubTotal	:Integer;
begin
	offset_SubTotal	:= self.getOffsetSubTotal;
	strTotal		:= app.getErrorString(Total);
	strLoad			:= app.getErrorString (VoyJob_Load);
	strDischarge	:= app.getErrorString (VoyJob_Discharge);
	strSOB			:= app.getErrorString (VoyJob_SOB);
	strDLR			:= app.getErrorString(VoyJob_DLR );
	strTS			:= app.getErrorString (VoyJob_Tranship);
	strImport		:= app.getErrorString (Import);
	strExport		:= app.getErrorString (Export);
	
	// add columns for cargo types
	_table.columns 		:= 1;
	_table.rows			:= 4;
	_table.fixedRows	:= 4;
	
	_table.accessCell (self.Decks_RowWP, 1).text	:= app.getErrorString(Work_point) &amp; ' &gt;';	_table.accessRow (self.Decks_RowWP).fontBold := true;
	_table.accessCell (self.Decks_RowDeck, 1).text	:= app.getErrorString(Deck) &amp; ' &gt;';			_table.accessRow (self.Decks_RowDeck).fontBold := true;
	_table.accessRow (self.Decks_RowImex1).fontBold := true;
	_table.accessCell (self.Decks_RowImex2, 1).text	:= app.getErrorString(IMEX) &amp; ' &gt;';			_table.accessRow (self.Decks_RowImex2).fontBold := true;
	
	coll := self.allColumnHeadings;
	iter := coll.createIterator;
	
	while iter.next (kpi) do
		col := _table.columns;
		
		iter.getCurrentKeys (key1, key2);
		
		if key1 &lt;&gt; strWP or key2 &lt;&gt; strDeck then
			if key1 &lt;&gt; strWP then
				self.addSplitterColumn (_table, self.Decks_RowWP);
			
				col := col + 1;
			else
				self.addSplitterColumn (_table, self.Decks_RowDeck);
			
				col := col + 1;
			endif;
			
			// new workpoint or deck - add new columns for it
			_table.columns := col + offset_SubTotal + 1;
			// col is the start for our headings
			col	:= col + 1;
			
			if key1 &lt;&gt; strWP then
				// add workpoint heading
				_table.accessCell (self.Decks_RowWP, col).text 	:= kpi.myWorkPoint.description;
				_table.accessedCell.itemObject 		:= kpi.myWorkPoint;
				_table.accessedCell.mergeCells		:= Table.MergeCells_Merge;
				_table.accessedCell.gridRight		:= false;	// because there will be a splitter
				_table.accessColumn (col).itemObject := kpi.myWorkPoint;
				
			endif;

			// add headings for deck
			_table.accessCell (self.Decks_RowDeck, col).text	:= key2; 
			_table.accessedCell.itemObject 		:= kpi;
			_table.accessedCell.mergeCells		:= Table.MergeCells_Merge;
			_table.accessedCell.gridRight		:= false;	// because there will be a splitter
			
			// add level 1 discharge/load headings
			_table.accessCell (self.Decks_RowImex1, col + self.Offset_Discharge).text		:= 	strDischarge;
			_table.accessedCell.mergeCells	:= Table.MergeCells_Merge;
			_table.accessedCell.alignment	:= Table.Alignment_Center;
			
			_table.accessCell (self.Decks_RowImex1, col + self.Offset_Load).text		:= 	strLoad;
			_table.accessedCell.mergeCells	:= Table.MergeCells_Merge;
			_table.accessedCell.alignment	:= Table.Alignment_Center;
			
			_table.accessCell (self.Decks_RowImex1, col + self.Offset_DLR).mergeCells	:= Table.MergeCells_NotAvailable;
			_table.accessCell (self.Decks_RowImex1, col + self.Offset_SOB).mergeCells	:= Table.MergeCells_NotAvailable;
			
			// add headings for discharge/load/TS/total
			_table.accessCell (self.Decks_RowImex2, col + self.Offset_Discharge).text		:= strImport;
			_table.accessColumn (col + self.Offset_Discharge).alignment	:= Table.Alignment_Center;
			
			_table.accessCell (self.Decks_RowImex2, col + self.Offset_DischargeTS).text		:= 	strTS;
			_table.accessColumn (col + self.Offset_DischargeTS).alignment	:= Table.Alignment_Center;

			_table.accessCell (self.Decks_RowImex2, col + self.Offset_Load).text		:= strExport;
			_table.accessColumn (col + self.Offset_Load).alignment	:= Table.Alignment_Center;
			
			_table.accessCell (self.Decks_RowImex2, col + self.Offset_LoadTS).text		:= 	strTS;
			_table.accessColumn (col + self.Offset_LoadTS).alignment	:= Table.Alignment_Center;

			_table.accessCell (self.Decks_RowImex2, col + self.Offset_DLR).text		:= 	strDLR;
			_table.accessColumn (col + self.Offset_DLR).alignment	:= Table.Alignment_Center;
			
			_table.accessCell (self.Decks_RowImex2, col + self.Offset_SOB).text		:= 	strSOB;
			_table.accessColumn (col + self.Offset_SOB).alignment	:= Table.Alignment_Center;
			
			// GRAND TOTAL
			_table.accessCell (self.Decks_RowImex2, col + offset_SubTotal).text		:= 	strTotal;
			_table.accessedCell.mergeCells		:= Table.MergeCells_NotAvailable;
			_table.accessColumn (col + offset_SubTotal).alignment	:= Table.Alignment_Center;
			
		endif;
		
		strWP 	:= key1;
		strDeck	:= key2;
	endwhile;
	// now add column for Grand Total
	self.addSplitterColumn (_table, self.Decks_RowWP);

	col 			:= _table.columns;
	col				:= col + 1;
	_table.columns	:= col;
	
	_table.accessCell (self.Decks_RowWP, col).text			:= strTotal.toUpper;	
	_table.accessedCell.mergeCells							:= Table.MergeCells_NotAvailable;
	_table.accessCell (self.Decks_RowDeck, col).mergeCells	:= Table.MergeCells_NotAvailable;
	_table.accessCell (self.Decks_RowImex1, col).mergeCells	:= Table.MergeCells_NotAvailable;
	_table.accessCell (self.Decks_RowImex2, col).mergeCells	:= Table.MergeCells_NotAvailable;
	
	_table.accessColumn (col).alignment	:= Table.Alignment_Center;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="displayHeadings_ROROMovesTable" id="316eef85-8bea-48e7-a0ae-cbf6218ac6b3">
        <source>displayHeadings_ROROMovesTable(_table :Table input)protected;
/*	
Purpose:	Display all required column headings

Date		Who		Reason
08 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
15/11/2011		cnwcs5	Leaking iterator
*/
constants
	
vars
	strTotal, strLoad, strDischarge, strSOB, strDLR, strDown,
	strTS, strExport, strImport, strDelay, strGross, strNet			:String;

	coll			:Collection;
	iter			:Iterator;
	obj				:Object;
	kpi				:CM_KPIVoyageWorkPointShift;
	key1, ts		:TimeStamp;
	key2, strWP		:String;
	col, offset_SubTotal	:Integer;
begin
	offset_SubTotal	:= self.getOffsetSubTotal;
	strTotal		:= app.getErrorString(Total);
	strLoad			:= app.getErrorString (VoyJob_Load);
	strDischarge	:= app.getErrorString (VoyJob_Discharge);
	strSOB			:= app.getErrorString (VoyJob_SOB);
	strDLR			:= app.getErrorString(VoyJob_DLR );
	strTS			:= app.getErrorString (VoyJob_Tranship);
	strDelay		:= app.getErrorString(Delay);
	strDown			:= app.getErrorString(Down);
	strGross		:= app.getErrorString (Gross);
	strNet			:= app.getErrorString (Net);
	strExport		:= app.getErrorString (Export);
	strImport		:= app.getErrorString (Import);
	
	// add columns for cargo types
	_table.columns 		:= 1;
	_table.rows			:= self.RRMoves_RowImex2;
	_table.fixedRows	:= self.RRMoves_RowImex2;
	
	_table.accessCell (self.RRMoves_RowShift, 1).text		:= app.getErrorString(MOVE_SHIFT) &amp; ' &gt;';
	_table.accessCell (self.RRMoves_RowWP, 1).text			:= app.getErrorString(Work_point) &amp; ' &gt;';
	_table.accessCell (self.RRMoves_RowHoursHdg, 1).text	:= app.getErrorString(Hours) &amp; ' &gt;';
	
	_table.accessRow (self.RRMoves_RowShift).fontBold		:= true;
	_table.accessRow (self.RRMoves_RowWP).fontBold			:= true;
	_table.accessRow (self.RRMoves_RowHoursHdg).fontBold	:= true;
	_table.accessRow (self.RRMoves_RowImex1).fontBold		:= true;
	_table.accessRow (self.RRMoves_RowImex2).fontBold		:= true;
	
	coll := self.allColumnHeadings;
	iter := coll.createIterator;
	
	while iter.next (kpi) do
		col := _table.columns;
		
		iter.getCurrentKeys (key1, key2);
		
		if key1 &lt;&gt; ts or key2 &lt;&gt; strWP then
			if key1 &lt;&gt; ts then
				self.addSplitterColumn (_table, self.RRMoves_RowShift);
			
				col := col + 1;
			else
				self.addSplitterColumn (_table, self.RRMoves_RowWP);
			
				col := col + 1;
			endif;
			// new shift or work point - add new columns for it
			_table.columns := col + offset_SubTotal + 1;
			
			// col is the start for our headings
			col	:= col + 1;
			
			if key1 &lt;&gt; ts then
				// add shift heading
				_table.accessCell (self.RRMoves_RowShift, col).text 	:= key1.asStringJMT;
				_table.accessedCell.itemObject 		:= kpi.myWorkPoint;
				_table.accessedCell.mergeCells		:= Table.MergeCells_Merge;
				_table.accessedCell.gridRight		:= false;	// because there will be a splitter
				
				_table.accessColumn (col+1).itemObject := kpi.myWorkPoint;
			endif;
			// add headings for workpoint
			_table.accessCell (self.RRMoves_RowWP, col).text	:= key2; 
			_table.accessedCell.itemObject 		:= kpi;
			_table.accessedCell.mergeCells		:= Table.MergeCells_Merge;
			_table.accessedCell.gridRight		:= false;	// because there will be a splitter
			
			// add headings for gross/delay/net hours
			_table.accessCell (self.RRMoves_RowHoursHdg, col + self.Offset_GrossHours).text	:= strGross;
			_table.accessedCell.mergeCells									:= Table.MergeCells_Merge;
			_table.accessColumn (col + self.Offset_GrossHours).alignment	:= Table.Alignment_Center;
			_table.accessCell (self.RRMoves_RowHours, col + self.Offset_GrossHours).mergeCells	:= Table.MergeCells_Merge;
			
				//04 Apr 2012	NDL	Par 29369
			_table.accessCell (self.RRMoves_RowHoursHdg, col + self.Offset_Down).text		:= strDown;
			_table.accessedCell.mergeCells							:= Table.MergeCells_Merge;
			_table.accessColumn (col + self.Offset_Down).alignment	:= Table.Alignment_Center;
			_table.accessCell (self.RRMoves_RowHours, col + self.Offset_Down).mergeCells	:= Table.MergeCells_Merge;
			
			_table.accessCell (self.RRMoves_RowHoursHdg, col + self.Offset_Delay).text		:= strDelay;
			_table.accessedCell.mergeCells							:= Table.MergeCells_Merge;
			_table.accessColumn (col + self.Offset_Delay).alignment	:= Table.Alignment_Center;
			_table.accessCell (self.RRMoves_RowHours, col + self.Offset_Delay).mergeCells	:= Table.MergeCells_Merge;
			
			_table.accessCell (self.RRMoves_RowHoursHdg, col + self.Offset_NetHours).text	:= strNet;
			_table.accessedCell.mergeCells								:= Table.MergeCells_Merge;
			_table.accessedCell.gridRight								:= false;	// because there will be a splitter
			_table.accessColumn (col + self.Offset_NetHours).alignment	:= Table.Alignment_Center;
			_table.accessCell (self.RRMoves_RowHours, col + self.Offset_NetHours).mergeCells	:= Table.MergeCells_Merge;
			_table.accessedCell.gridRight								:= false;	// because there will be a splitter
			
			// add level 1 discharge/load headings
			_table.accessCell (self.RRMoves_RowImex1, col + self.Offset_Discharge).text		:= 	strDischarge;
			_table.accessedCell.mergeCells	:= Table.MergeCells_Merge;
			_table.accessedCell.alignment	:= Table.Alignment_Center;
			
			_table.accessCell (self.RRMoves_RowImex1, col + self.Offset_Load).text		:= 	strLoad;
			_table.accessedCell.mergeCells	:= Table.MergeCells_Merge;
			_table.accessedCell.alignment	:= Table.Alignment_Center;
			
			_table.accessCell (self.RRMoves_RowImex1, col + self.Offset_DLR).mergeCells	:= Table.MergeCells_NotAvailable;

			// add headings for discharge/load/TS/total
			_table.accessCell (self.RRMoves_RowImex2, col + self.Offset_Discharge).text := 	strImport;
			_table.accessColumn (col+ self.Offset_Discharge).alignment	:= Table.Alignment_Center;
			
			_table.accessCell (self.RRMoves_RowImex2, col + self.Offset_DischargeTS).text		:= 	strTS;
			_table.accessColumn (col + self.Offset_DischargeTS).alignment	:= Table.Alignment_Center;

			_table.accessCell (self.RRMoves_RowImex2, col + self.Offset_Load).text	:= 	strExport;
			_table.accessColumn (col + self.Offset_Load).alignment	:= Table.Alignment_Center;

			_table.accessCell (self.RRMoves_RowImex2, col + self.Offset_LoadTS).text		:= 	strTS;
			_table.accessColumn (col + self.Offset_LoadTS).alignment	:= Table.Alignment_Center;
			
			_table.accessCell (self.RRMoves_RowImex2, col + self.Offset_DLR).text	:= 	strDLR;
			_table.accessColumn (col + self.Offset_DLR).alignment	:= Table.Alignment_Center;
			
			_table.accessCell (self.RRMoves_RowImex2, col + self.Offset_SOB).text	:= 	strSOB;
			_table.accessColumn (col + self.Offset_SOB).alignment	:= Table.Alignment_Center;
						
			_table.accessCell (self.RRMoves_RowImex2, col + offset_SubTotal).text		:= 	app.getErrorString(Total);
			_table.accessColumn (col + offset_SubTotal).alignment	:= Table.Alignment_Center;
		endif;
		
		ts	 	:= key1;
		strWP	:= key2;
	endwhile;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="displayROROMovesTable" id="d4a26cb2-9b83-46c8-8fcf-952d349f62aa">
        <updating/>
        <source>displayROROMovesTable(_voyage :CM_Voyage; _table :Table input)updating;
/*
Date		Who		Reason
09 Aug 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
03 Swp 2012	cnwcs5	par 30290
*/
vars
	table		:Table;
	terminal	:CM_Terminal;	// par 30290
begin
	table := self.myTable;
	
	if table &lt;&gt; null and table &lt;&gt; _table then
		// can't change table
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Cannot change KPI table');
	endif;
	
	self.myTable 	:= _table;
	self.myVoyage	:= _voyage;
	terminal		:= _voyage.getMyTerminal;									// par 30290 Sept 2012
	
	self.mode := self.Mode_RRMovesTable;
	
	self.is30Included	:= terminal.getConfig (Is30IncludedForReports).Integer;	// par 30290 Sept 2012
	self.is45Included	:= terminal.getConfig (Is45IncludedForReports).Integer;	// par 30290 Sept 2012
	self.is53Included	:= terminal.getConfig (Is53IncludedForReports).Integer;	// par 30290 Sept 2012

	self.clearTable;
	self.init_ROROMovesTable (_table);
	self.setup_ROROMovesTable ();
	self.createData_ROROMovesTable (_voyage);
	self.displayHeadings_ROROMovesTable (_table);
	self.displayData_Hours (_table, 4);
	self.displayData_Containers(_table, self.RRMoves_RowWP, true, true, false);
	self.displayData_GC(_table, self.RRMoves_RowWP, true, false, true, true, true, true, false, null);
epilog
	// membership of these collections is transient collection - they need to be deleted
	self.allData_Containers.purge;
	self.allData_GeneralCargo.purge;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
