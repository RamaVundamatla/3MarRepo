    <JadeMethod name="myTerminal" id="95a1eab7-86ad-4237-bd93-0f1942292cb1">
        <methodInvocation>mapping</methodInvocation>
        <source>myTerminal(set: Boolean; _value: CM_Terminal io) mapping;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if set then
		return;
	endif;
	
	if self.myRequest &lt;&gt; null then
		_value := self.myRequest.myTerminal;
	else
		_value := null;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_Terminal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="916c200e-1004-424a-abc7-966dceb5f049">
        <updating/>
        <source>setForCreate(_status : Integer; _toDoTaskDesc : CM_ToDoTaskDesc; _toDoRemarks : String; _userCode : String; _request : CM_ToDoRequest) updating;
// ---------------------------------------------------------------------------
// Created:     07 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.setForCreateToDoTask(_status, _toDoTaskDesc, _toDoRemarks, _userCode);
	self.myRequest := _request;

end;</source>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_toDoRemarks" type="String"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_request" type="CM_ToDoRequest"/>
    </JadeMethod>
</Class>
