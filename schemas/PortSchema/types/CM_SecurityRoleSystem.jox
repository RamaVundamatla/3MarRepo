<Class name="CM_SecurityRoleSystem" id="dbf2a782-17ad-45ae-b83b-3c888a21ea2b">
    <superclass name="CM_SecurityRole"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <ExplicitInverseRef name="allUsersForSystemRole" id="4070a0fd-6573-43fc-a8e0-fd0303e419d1">
        <transientToPersistentAllowed/>
        <type name="CM_UserSet"/>
        <access>readonly</access>
        <Inverse name="CM_User::mySystemSecurityRole"/>
    </ExplicitInverseRef>
    <JadeMethod name="getAllUsers" id="a25cfb09-2543-435a-b562-dc08e15e5d25">
        <source>getAllUsers(_userSet: CM_UserSet input);
//--------------------------------------------------
// Created:	21 August 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_userSet);
	self.allUsersForSystemRole.copy(_userSet);
end;</source>
        <Parameter name="_userSet" type="CM_UserSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getRoleTypeString" id="477155f1-61b9-45dc-b0ee-88158e296f41">
        <source>getRoleTypeString(): String;
// ---------------------------------------------------------------------------
// Created:     21 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return 'System';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isSystemSecurityRole" id="1ff46442-3352-487a-83ae-66f8f73097fc">
        <methodInvocation>mapping</methodInvocation>
        <source>isSystemSecurityRole(set: Boolean; _value: Boolean io) mapping;
// ---------------------------------------------------------------------------
// Created:     19 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		_value := true;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="resetRootRole" id="b27edc23-bd46-4794-a72d-f1687e3937f0">
        <updating/>
        <source>resetRootRole(_permAgent: CM_PermissionAgent; _cmifMonitor: CMIF_Monitor input) updating;
// ---------------------------------------------------------------------------
// Created:     19 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	user	: CM_User;

begin
	inheritMethod(_permAgent, _cmifMonitor);

	foreach user in self.allUsersForSystemRole do
		user.checkSysMenuAgainstPermissions(false);
	endforeach;

end;</source>
        <Parameter name="_permAgent" type="CM_PermissionAgent"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="291da679-7a9b-4563-8d96-6aecfaa49382">
        <updating/>
        <source>setForUpdate(_pxyRole: CM_SecurityRole) updating;
// ---------------------------------------------------------------------------
// Created:     19 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	user	: CM_User;

begin
	inheritMethod(_pxyRole);

	foreach user in self.allUsersForSystemRole do
		user.checkSysMenuAgainstPermissions(false);
	endforeach;
	
end;</source>
        <Parameter name="_pxyRole" type="CM_SecurityRole"/>
    </JadeMethod>
    <JadeMethod name="updateFromParent" id="66534b85-e884-422b-8314-4ab89016a137">
        <updating/>
        <source>updateFromParent(_cmifMonitor: CMIF_Monitor input) updating;
// ---------------------------------------------------------------------------
// Created:     19 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	user	: CM_User;
begin
	inheritMethod(_cmifMonitor);
	
	foreach user in self.allUsersForSystemRole do
		user.checkSysMenuAgainstPermissions(false);
	endforeach;

end;</source>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="8945d4ca-6f3e-4e39-9547-6e96013dfa78">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     27 June 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();

	if (not self.allUsersForSystemRole.isEmpty) then
		app.raiseCMException2(ObjectStillHasEntries, 'Role ' &amp; self.name, 'users', null, null);
	endif;

end;</source>
    </JadeMethod>
</Class>
