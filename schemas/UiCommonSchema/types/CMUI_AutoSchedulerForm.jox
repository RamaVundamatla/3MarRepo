    <JadeMethod name="tblTaskCreation_cellInputReady" id="8fd5f585-f382-484c-9352-984c455436bd">
        <controlMethod name="Table::cellInputReady"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblTaskCreation_cellInputReady(_table: CM_EntryTable input; _inputControl: Control input; _left, _top, _width, _height: Real io) updating;

// 0608/2012	cnwcs5	par 30136 - EDI BGP split
// 28/03/2017	cnwdap1	TFS #1832 TSW BGP name
vars
	
begin

	if _inputControl = self.listTemplates or
		_inputControl = self.listRemotes or
		_inputControl = self.lstTblEventTypes or
		_inputControl = self.lstDataTypes then

		self.myAssistant.listTableCellInputReady(_table, _height, self.saveRowHeight);
		
		_table.adjustHeight(1000);
	elseif _inputControl = self.cmbTSWName then											// TFS #1832
		self.cmbTSWName.findStringExact(1, _table.accessCell(_table.row, 2).text);		// TFS #1832
	endif;

end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
        <Parameter name="_inputControl" type="Control" usage="input"/>
        <Parameter name="_left" type="Real" usage="io"/>
        <Parameter name="_top" type="Real" usage="io"/>
        <Parameter name="_width" type="Real" usage="io"/>
        <Parameter name="_height" type="Real" usage="io"/>
    </JadeMethod>
