<Class name="CM_EDIDataCargoFieldUpdate" id="c991fd12-9599-4319-bf04-7731948a6db3">
    <superclass name="CM_EDIData"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <text>
Unit tests with a prefix of

tCargoFieldUpdate or
iCargoFieldUpdate

can be used to test this.</text>
    <DbClassMap file="edi"/>
    <JadeMethod name="doLoadDB" id="e6e741aa-51fb-4e79-83c5-70dade8f5ec4">
        <source>doLoadDB(_isValidateOnly:Boolean; _passport : CM_Passport input):Integer;
// --------------------------------------------------------------------------------
// Created:		15 December 2009 by cnwdad1
//
// Purpose:		Process the EDI records to load the data into the database proper.
//				This should only be called from trxCargoFieldUpdate
//
// Returns:		The number of errors.
/* Changes

Date		Name	TFS#		Description
============================================================================
20 Feb 2012	cnwcs5	par 28756 	use utlUpdateBulkRelease instead of utlUpdateBulkReleaseNew
28 Jun 2012	cnwcs5	par 29847 	pass null in _realBooking parameter for utlUpdateBulkRelease
13 May 2016	cnwns1	TFS 488  	Multi Timezone Support
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
19 Oct 2020 jlgmd1	TFS 49971	STWR - Rework CargoFieldUpdate messages to better handle assigning cargo to Release Requests
20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
25 Jul 2023	navdap1	TFS 58923	EUP CallOff EDI Data Type / Data Load
12 Jun 2025 navma1  MTN-34090  MTN | Dead lock (1081) on CM_TIByIdCargoTypeRelseDictRev
============================================================================*/
vars
	partsDone			: Integer;
	partsInJob			: Integer;
	progressStr			: String;
	progressTS			: TimeStamp;
	cargoTIObj			: CM_EDICargoFieldUpdateTI;
	ediTI				: CM_EDITrackedItem;
	allCargoTIs			: CM_EDICargoByIdBOLDict;
	allBRCargoTIs		: CM_EDICargoByIdBOLDict;
	allCargoTIsToUpdate	: CM_EDICargoByIdBOLDict;
	lastCargoId			: String;
	lastBolNumber		: String;
	lastVoyageCode		: String;
	lastCargoType		: Integer;
	hasErrors			: Boolean;
	errorCount			: Integer;
	realBRSet, 
	pxyBRSet 			: CM_BulkReleaseSet;
	pxyBR				: CM_BulkRelease;
	logStr				: String;
	terminal			: CM_Terminal;
	realTI				: CM_TrackedItem;
begin
	// Arm our base exception handlers
	on Exception do self.validationExceptionHandler(exception, _passport);
	app.setContinueCMExceptions(true);	// Get as many error messages in 1 go as possible.

	if _isValidateOnly then
		logStr := 'Cargo Field Validation for';
	else
		logStr := 'Cargo Field Update for';
	endif;
	
	partsInJob		:=	self.allEDITrackedItems.size();
	partsDone		:=	null;
	
	progressStr	:=	app.getString(Loading_EDI_Data_Total, partsInJob.display);
	progressTS	:=	app.actualTimeServer();		// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	// Start at 0%
	self.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, _passport);
	
	create allCargoTIs transient;
	create allBRCargoTIs transient;
	create allCargoTIsToUpdate transient;
	create realBRSet transient;
	create pxyBRSet transient;
	
	//self.allEDITrackedItems.copy(allCargoTIs);		// TFS 49971 jlgmd1
	
	// Saparate out just the Release Request updates
	foreach ediTI in self.allEDITrackedItems do
		if ediTI.CM_EDICargoFieldUpdateTI.fieldName = CM_EDICargoFieldUpdateTI.F_BulkRelease then
			allBRCargoTIs.add(ediTI.CM_EDICargoFieldUpdateTI);
		else
			// Reorder the rest into something a little more sensible
			allCargoTIs.add(ediTI.CM_EDICargoFieldUpdateTI);
		endif;
	endforeach;
	
	lastCargoId		:=	null;
	lastBolNumber	:=	null;
	hasErrors		:=	false;
	errorCount		:=	0;
	
	// When processing the EDI Cargo, we want to process all updates with the same
	// Cargo ID or BOL Number in the same transaction, so that only one "Edit Transaction"
	// is recorded against the Tracked Item.  Note that for a BOL, multiple Tracked Items
	// may be updated in the same transaction.
	
	foreach cargoTIObj in allCargoTIs do
		partsDone			:=	partsDone + 1;
		self.updateProgress(progressTS, progressStr, partsInJob, partsDone, false, _passport);
		
		if allCargoTIsToUpdate.isEmpty() or	// First time thru.
			(cargoTIObj.getVoyageCode() = lastVoyageCode and cargoTIObj.bolNumber = lastBolNumber and 
		    cargoTIObj.cargoType = lastCargoType and cargoTIObj.id = lastCargoId)
		then
			allCargoTIsToUpdate.add(cargoTIObj);
			
			lastVoyageCode	:= cargoTIObj.getVoyageCode();
			lastBolNumber	:= cargoTIObj.bolNumber;
			lastCargoType	:= cargoTIObj.cargoType;
			lastCargoId		:= cargoTIObj.id;
			continue;
		endif;
		
		// cnwrl1 30/07/2010 PAR 23526 - start of coding
		// Because CM_UtilityAgent::initialiseActivity always sets this to false need to reset it here!
		app.setContinueCMExceptions( _isValidateOnly );
		// cnwrl1 30/07/2010 PAR 23526 - end of coding
		
		self.doUpdateTIs(allCargoTIsToUpdate, _isValidateOnly, realBRSet, pxyBRSet, _passport);

		allCargoTIsToUpdate.clear();
		
		if _passport.hasErrors() then
			hasErrors	:=	true;
			errorCount	:=	errorCount + _passport.allErrorWarnings.size();
		endif;
		
		allCargoTIsToUpdate.add(cargoTIObj);

		lastVoyageCode	:= cargoTIObj.getVoyageCode();
		lastBolNumber	:= cargoTIObj.bolNumber;
		lastCargoType	:= cargoTIObj.cargoType;
		lastCargoId		:= cargoTIObj.id;
		
	endforeach;
	
	if allCargoTIsToUpdate.cnEcIsNotEmpty() then
		self.doUpdateTIs(allCargoTIsToUpdate, _isValidateOnly, realBRSet, pxyBRSet, _passport);
		
		if _passport.hasErrors() then
			hasErrors	:=	true;
			errorCount	:=	errorCount + _passport.allErrorWarnings.size();
		endif;
	endif;
	
	// Group Release Request updates together.
	if allBRCargoTIs.cnEcIsNotEmpty() then
	
		if not _isValidateOnly then
			// Grab a lock on our collections if we're actually doing some updating, to single thread updates at this point
			terminal := self.getMyTerminal();
			self.exclusiveLock(terminal.allBulkReleasesByCodeDate);    //004 - CM_BulkReleaseByCodeDict
			self.exclusiveLock(terminal.allBulkReleasesByDelRelNo);    //021 - CM_BulkReleaseByDelRelNoDict
			self.exclusiveLock(terminal.allBulkReleaseByTypeByStByCd); //159 - CM_BulkReleaseByTypeStCodeDict
		endif;
		
		foreach cargoTIObj in allBRCargoTIs do
			partsDone			:=	partsDone + 1;
			
			// Update monitoring progress
			self.updateProgress(progressTS, progressStr, partsInJob, partsDone, false, _passport);
		
			// Make sure we are only dealing with that we think we are
			if not cargoTIObj.fieldName = CM_EDICargoFieldUpdateTI.F_BulkRelease then
				continue;	// skip
			endif;
			
			// As the associating of a container with a bulk release has to be
			// done with the persistent we handle differently here			
			realTI	:= self.findMyTrackedItem(cargoTIObj.id, cargoTIObj.cargoType, true, true, true);
			if realTI = null then
				app.raiseCMException3(CargoItemNotFound, cargoTIObj.cargoTypeDescr, cargoTIObj.id , '', null, cargoTIObj);
				continue;
			endif;
			
			self.handleBulkReleaseChange(realTI, cargoTIObj, realBRSet, pxyBRSet);	// &lt;-- this may update realTI's edition.
			
		endforeach;
	
		if _passport.hasErrors() then
			hasErrors	:=	true;
			errorCount	:=	errorCount + _passport.allErrorWarnings.size();
		endif;
	
		if not _isValidateOnly and not pxyBRSet.isEmpty then
			foreach pxyBR in pxyBRSet do
				app.writeLog(logStr &amp; ' bulk release ' &amp; pxyBR.code, LogINFO);
				//app.myUtilityUA.utlUpdateBulkRelease(pxyBR, null, false, null, _passport); //cnwrd1 par 25594 ccms 2032 13.12.2010
				app.myUtilityUA.utlUpdateBulkRelease(pxyBR, null, false, null, null, _passport);	// TFS 58923
			endforeach;
		endif;
	
	endif;
	
	// Show we have finished this part of the process.
	self.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, _passport);
	
epilog
	delete allCargoTIs;
	delete allBRCargoTIs;
	delete allCargoTIsToUpdate;
	delete realBRSet;
	
	if pxyBRSet &lt;&gt; null then
		pxyBRSet.purge;
		delete pxyBRSet;
	endif;

	return errorCount;
end;</source>
        <Parameter name="_isValidateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doUpdateTIs" id="9ce6416e-24cf-4a11-afb3-3b51d2d9aedc">
        <source>doUpdateTIs(_allCargoTIsObj:CM_EDICargoByIdBOLDict; _isValidateOnly:Boolean;
			_realBRSet, _pxyBRSet : CM_BulkReleaseSet input; _passport : CM_Passport input) protected;
/* ---------------------------------------------------------------------------
Created:     07 March 2010 by cnwrs2

Purpose:     
        
Change Date	Who		Reason
------------------------------------------------------------------------------
26/07/2010	cnwdad1	PAR #24955 - Updating Bulk Release fields on a TI was causing
					CM_TrackedItem::setForUpdate to fail because the object edition
					was being incremented.
14 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
07 Jan 2020 cnwma1  Bug 48197: SNO - Re: Data Base Lock - URGENT - 835582
19 Oct 2020 jlgmd1	TFS 49971 STWR - Rework CargoFieldUpdate messages to better handle assigning cargo to Release Requests
07 Feb 2023	jlizm1	TFS 56416 PNL Update Reefer PTI date/time from edi
14/01/2025	navcs2	MTN-35581 MTN | EDI cargo fields update - Remove unnecessary audit
------------------------------------------------------------------------------*/
// 
vars
	weightBefore,
	weightChange		: Decimal[14, 4];
	quantityBefore,
	quantityChange		: Integer;
	volumeChange		: Decimal[16, 4];		// not yet implemented, not needed yet
	cargoTIObj			: CM_EDICargoFieldUpdateTI;
	parentTI,
	pxyParent,
	realTI,
	pxyTI				: CM_TrackedItem;
	bolObj				: CM_BOL;
	terminalObj			: CM_Terminal;
	voyageObj			: CM_Voyage;
	
	loadState			: Boolean;
	isBOLUpdate			: Boolean;
	theVoyageCode,
	theBOLNum,
	theCargoID			: String;
	theCargoType		: Integer;
	
	tiSet,
	pxySet				: CM_TISet;
	
	realBR				: CM_BulkRelease;
	logStr				: String;
	invalidVoyage		: Boolean;
	
	consumed : CM_Consumed;	//04 May 2017	NDL	TFS 4274
	cargoGroupId : String;	//04 May 2017	NDL	TFS 4274
	fileType 			: CM_EDIFileType; 	// TFS 56416
	dtString			: String;			// TFS 56416
	simpleFieldsArray	: StringArray;						// 14/01/2025	navcs2	MTN-35581
	allSimpleFields		: Boolean;							// 14/01/2025	navcs2	MTN-35581 
	controller			: CMIF_BulkEditController;			// 14/01/2025	navcs2	MTN-35581 
	updateAgent			: CMIF_TIBulkUpdateAgent;			// 14/01/2025	navcs2	MTN-35581 
	changedFieldsDict	: CMIF_EditObjectByAttrNameDict;	// 14/01/2025	navcs2	MTN-35581 
	editObject	 		: CMIF_EditObject;					// 14/01/2025	navcs2	MTN-35581 
	allProxies			: CM_ObjectSet;						// 14/01/2025	navcs2	MTN-35581 
begin
	on Exception do app.handleDeletedObject(exception, voyageObj, invalidVoyage);  //PAR24233 - cnwsh3 skip invalid voyages.
	
	if _isValidateOnly then
		logStr := 'Cargo Field Validation for';
	else
		logStr := 'Cargo Field Update for';
	endif;

	// The transaction will process one or more EDI cargo items with the same Cargo ID.
	// or BOL number, so if any one is in error, then none of them should be updated.
	
	terminalObj := self.getMyTerminal();
	
	// PAR 22957 - Firstly validate that all are the same
	if _allCargoTIsObj.isEmpty then
		// nothing to do
		return;
	endif;

	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;

	cargoTIObj := _allCargoTIsObj.first;
	isBOLUpdate := cargoTIObj.isBOLUpdate;
	fileType := self.getEDIFileType();	// TFS 56416
	
	if isBOLUpdate then
		theVoyageCode	:= cargoTIObj.getVoyageCode();
		theBOLNum		:= cargoTIObj.bolNumber;
	else
		theCargoType	:= cargoTIObj.cargoType;
		theCargoID		:= cargoTIObj.id;
	endif;
	
	foreach cargoTIObj in _allCargoTIsObj do
		if isBOLUpdate &lt;&gt; cargoTIObj.isBOLUpdate then
			app.raiseUnexpectedProgramError(class.name, method.name, '_allCargoTIsObj inconsistent - mixed update types');
			return;
		endif;
		if isBOLUpdate then
			if theVoyageCode &lt;&gt; cargoTIObj.getVoyageCode() or
		       theBOLNum &lt;&gt; cargoTIObj.bolNumber then
				app.raiseUnexpectedProgramError(class.name, method.name, '_allCargoTIsObj inconsistent - mixed voyage code or BOL numbers');
				return;
			endif;
		else
			if theCargoType &lt;&gt; cargoTIObj.cargoType or
		       theCargoID &lt;&gt; cargoTIObj.id then
				app.raiseUnexpectedProgramError(class.name, method.name, '_allCargoTIsObj inconsistent - mixed cargo type or cargo ID');
				return;
			endif;
		endif;
	endforeach;

	create tiSet transient;
	create pxySet transient;
	
	if isBOLUpdate then
		//get the BOL and copy the TI's off the BOL into tiSet
		voyageObj	:=	terminalObj.lookupVoyage(theVoyageCode, null, false);
		
		if voyageObj = null then
			app.raiseCMException1(Voyage_not_found, theVoyageCode, null, cargoTIObj);
			return;
		endif;
		
		if (not terminalObj.myEdiConfig.allVoyagesToProcess.includes(voyageObj)) then
			app.raiseCMException1(Voyage_not_marked_for_EDI, theVoyageCode, null, cargoTIObj);
		endif;

		bolObj		:=	voyageObj.doesBOLAlreadyExist(theBOLNum);
		
		if bolObj = null then
			app.raiseCMException2(BOL_not_found_voyage, theBOLNum, theVoyageCode, null, cargoTIObj);
			return;
		endif;
		
		bolObj.allTrackedItems.copy(tiSet);
		
		app.writeLog(logStr &amp; ' ' &amp; theVoyageCode &amp; '/' &amp; theBOLNum &amp; '  ' &amp; tiSet.size.String &amp; ' tis', LogINFO);
	else
		//07.01.2019 cnwma1 #48197 &gt;&gt; Moved up before Doing locking
		realTI	:= self.findMyTrackedItem(theCargoID, theCargoType, true, true, true);
		if realTI = null then
			app.raiseCMException3(CargoItemNotFound, cargoTIObj.cargoTypeDescr, theCargoID, '', null, cargoTIObj);
			return;
		endif;
//05 Mar 2020 NDL	TFS 48776 Seemed to be causing excessive locking when EDI already handles lock generically now. Stops HH apps getting a fair go.	
		// 14 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
/*		if _passport.useTITransactionDeferUpdate then
			if not self.tryLock(terminalObj.allTITransactions, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
				self.exclusiveLock(terminalObj.allTITransactions);
			endif;
			if not self.tryLock(terminalObj.allTITransactionsByTypeDate, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
				self.exclusiveLock(terminalObj.allTITransactionsByTypeDate);
			endif;
			if not self.tryLock(terminalObj.allTITransactionsByCamsTS, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
				self.exclusiveLock(terminalObj.allTITransactionsByCamsTS);
			endif;
		endif;

		if _passport.useTIDictDeferUpdate then
			if realTI.state = TI_STATE_NOTIFIED then
				if not self.tryLock(terminalObj.allNotifiedTIsByIdCargoType, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
					self.exclusiveLock(terminalObj.allNotifiedTIsByIdCargoType);
				endif;
			elseif realTI.state = TI_STATE_NORMAL then
				if not self.tryLock(terminalObj.allOnsiteTIsByIdCargoType, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
					self.exclusiveLock(terminalObj.allOnsiteTIsByIdCargoType);
				endif;
			endif;
		endif; */

		tiSet.add(realTI);
		app.writeLog(logStr &amp; ' ' &amp; cargoTIObj.cargoTypeDescr &amp; '/' &amp; theCargoID, LogINFO);
	endif;
	
	// TFS 49971 jlgmd1 Moved logic to doLoadDB instead
	// Only process Bulk Release fields:
	/*foreach realTI in tiSet do
		realBR := null;
		
		foreach cargoTIObj in _allCargoTIsObj do
			if cargoTIObj.fieldName = CM_EDICargoFieldUpdateTI.F_BulkRelease then
				// As the associating of a container with a bulk release has to be
				// done with the persistent we handle differently here
				self.handleBulkReleaseChange(realTI, cargoTIObj, _realBRSet, _pxyBRSet);	// &lt;-- this may update realTI's edition.
			endif;
		endforeach;
	endforeach;*/
	
	/*
	// 14/01/2025	navcs2	MTN-35581 
	Start
	*/
	create simpleFieldsArray transient;
	simpleFieldsArray.add(CM_EDICargoFieldUpdateTI.F_Consignee);	
	simpleFieldsArray.add(CM_EDICargoFieldUpdateTI.F_AvailabilityGrade);
	simpleFieldsArray.add(CM_EDICargoFieldUpdateTI.F_CargoQuantityChange);
	simpleFieldsArray.add(CM_EDICargoFieldUpdateTI.F_CargoWeightChange);
	simpleFieldsArray.add(CM_EDICargoFieldUpdateTI.F_Consignor);
	simpleFieldsArray.add(CM_EDICargoFieldUpdateTI.F_FreightForwarder);
	simpleFieldsArray.add(CM_EDICargoFieldUpdateTI.F_Imex);	
	simpleFieldsArray.add(CM_EDICargoFieldUpdateTI.F_IsExternallyMonitored);
	simpleFieldsArray.add(CM_EDICargoFieldUpdateTI.F_IsWeightCertified);
	simpleFieldsArray.add(CM_EDICargoFieldUpdateTI.F_OffsiteCleaned);
	simpleFieldsArray.add(CM_EDICargoFieldUpdateTI.F_OffsitePTI);
	simpleFieldsArray.add(CM_EDICargoFieldUpdateTI.F_PreTripDT);
	simpleFieldsArray.add(CM_EDICargoFieldUpdateTI.F_Remarks);	
	simpleFieldsArray.add(CM_EDICargoFieldUpdateTI.F_WeightCertifiedName);
	simpleFieldsArray.add(CM_EDICargoFieldUpdateTI.F_WeightCertifiedReference);
	// Continue with other fields on CM_EDICargoFieldUpdateTI in Constants
	
	/*
	// 14/01/2025	navcs2	MTN-35581 
	End
	*/
	
	// Now process the remaining fields on the proxy TI(s):
	foreach realTI in tiSet do
		// cnwrl1 30/07/2010 PAR 23526 - start of coding
		// Because CM_UtilityAgent::initialiseActivity always sets this to false need to reset it here!
		app.setContinueCMExceptions( _isValidateOnly );
		// cnwrl1 30/07/2010 PAR 23526 - end of coding
		
		pxyTI	:=	realTI.pxyCreateUpdateProxy();
		//if proxy failed to be created then skip
		if pxyTI = null then
			continue;
		endif;
		
		pxySet.add(pxyTI);
		realBR	:=	null;
		parentTI := null;
		cargoGroupId := realTI.getMyCargoGroupId();	//04 May 2017	NDL	TFS 4274
		
		create changedFieldsDict transient;					// 14/01/2025	navcs2	MTN-35581 MTN
		
		foreach cargoTIObj in _allCargoTIsObj do
			
			allSimpleFields := true;											// 14/01/2025	navcs2	MTN-35581 
			
			if not simpleFieldsArray.includes(cargoTIObj.fieldName) then		// 14/01/2025	navcs2	MTN-35581 
				allSimpleFields := false;										// 14/01/2025	navcs2	MTN-35581 
			else																// 14/01/2025	navcs2	MTN-35581 
				
				create editObject transient;									// 14/01/2025	navcs2	MTN-35581 
				editObject.myBulkEditController := controller;					// 14/01/2025	navcs2	MTN-35581 
				editObject.attrName := cargoTIObj.fieldName;					// 14/01/2025	navcs2	MTN-35581 
				
				changedFieldsDict.add(editObject);								// 14/01/2025	navcs2	MTN-35581 
			endif;																// 14/01/2025	navcs2	MTN-35581 
			
			if cargoTIObj.fieldName = CM_EDICargoFieldUpdateTI.F_BulkRelease then
				continue;
				
			elseif cargoTIObj.fieldName = CM_EDICargoFieldUpdateTI.F_PreTripDT then	// TFS 56416
				dtString := cargoTIObj.fieldValue.ediTimeStampFormat(fileType, null, null).asStringJMT();
				pxyTI.setPxyFromFieldValue(cargoTIObj.fieldName, dtString, cargoTIObj, _passport);
				
			else
				// 36912 TFS 456 tank discharge cargo weight change to child is to recalculate parent tank container weight as well
				if cargoTIObj.fieldName = CM_EDICargoFieldUpdateTI.F_CargoWeightChange then
					if pxyTI.isChild then
						parentTI := pxyTI.myParent;
					endif;
					weightBefore := pxyTI.weightCargo;
				endif;
				if cargoTIObj.fieldName = CM_EDICargoFieldUpdateTI.F_CargoQuantityChange then
					quantityBefore := pxyTI.totalQuantity;
				endif;
				pxyTI.setPxyFromFieldValue(cargoTIObj.fieldName, cargoTIObj.fieldValue, cargoTIObj, _passport);
				if cargoTIObj.fieldName = CM_EDICargoFieldUpdateTI.F_CargoWeightChange then
					weightChange := pxyTI.weightCargo - weightBefore;
				endif;
				if cargoTIObj.fieldName = CM_EDICargoFieldUpdateTI.F_CargoQuantityChange then
					quantityChange := pxyTI.totalQuantity - quantityBefore;
				endif;
			endif;
		endforeach;
		
		if _passport.noErrors() or _isValidateOnly then
			// pass in the cargoTIObj that will be the last one used for this TI.  Might not be the actual error line
			// but will be close
			
			if allSimpleFields then																	// 14/01/2025	navcs2	MTN-35581 
				create updateAgent transient;														// 14/01/2025	navcs2	MTN-35581 
				create allProxies transient;														// 14/01/2025	navcs2	MTN-35581 
				allProxies.add(pxyTI);																// 14/01/2025	navcs2	MTN-35581 
				updateAgent.setupAgentForSimpleUpdate(changedFieldsDict, pxyTI, allProxies);		// 14/01/2025	navcs2	MTN-35581 
				app.myUtilityUA.utlUpdateTIsForBulkEditSimple(updateAgent, _passport);				// 14/01/2025	navcs2	MTN-35581 
			else
			app.myUtilityUA.utlUpdateTrackedItem(pxyTI, null, TI_UPDMODE_NORMAL, null, null, cargoTIObj, _passport);
			endif;
			if not _isValidateOnly then
				if parentTI &lt;&gt; null then		// 36912 update parent cargo and total weight as well, with Edit transactions
					
						// remove the child proxy as the parent create proxy will create another one
						pxySet.remove(pxyTI);
						delete pxyTI;
						app.cmsBeginLoad(loadState);
						pxyParent := parentTI.pxyCreateUpdateProxy();
						app.cmsEndLoad(loadState);
						pxyParent.setWeightCargo(( pxyParent.weightCargo + weightChange).max(0));	//05/01/2026	navtr3	MTN-36173
						pxyParent.updateTotalWeightFromChildren();					
						app.myUtilityUA.utlUpdateTrackedItem(pxyParent, null, TI_UPDMODE_NORMAL, null, null, cargoTIObj, _passport);
						pxySet.add(pxyParent);
				endif;
				// write any CM_Consumed here
				if quantityChange &lt;&gt; 0 or
				   weightChange &lt;&gt; 0 or
				   volumeChange &lt;&gt; 0 then
				   //realTI.createConsumedTransaction(quantityChange, volumeChange, weightChange, _passport);
				   //04 May 2017	NDL	TFS 4274
				   consumed := realTI.createConsumedTransaction(quantityChange, volumeChange, weightChange, _passport);
				   if consumed &lt;&gt; null and cargoGroupId &lt;&gt; null then
						consumed.setCargoGroupId( cargoGroupId);
				   endif;		
				endif;
				
			endif;
		endif;
	endforeach;
// End of changes for PAR #24955.
epilog
	if pxySet &lt;&gt; null then
		pxySet.purge;
		delete pxySet;
	endif;
	delete tiSet;
	
	delete updateAgent;					// 14/01/2025	navcs2	MTN-35581 	
	delete simpleFieldsArray;			// 14/01/2025	navcs2	MTN-35581 
	delete controller;					// 14/01/2025	navcs2	MTN-35581 
	delete allProxies;					// 14/01/2025	navcs2	MTN-35581 

end;</source>
        <access>protected</access>
