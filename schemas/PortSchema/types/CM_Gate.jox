end;</source>
        <ReturnType type="CM_GateArea"/>
    </JadeMethod>
    <JadeMethod name="getFirstPGateLane_IN" id="69f5a97b-b268-4b6a-8881-3adb915a87e0">
        <source>getFirstPGateLane_IN(): CM_YardController;
/*

Purpose:			Returns the first P-Gate Lane

Parameters:			

Return Value:		

Date			Who		Reason
