    <JadeMethod name="setExtraAddressesFromVoyage" id="63fcdac2-073a-4104-be42-4c0f07b8816a">
        <source>setExtraAddressesFromVoyage( email : CM_VoyStatusDefaultEmail io; _voyage : CM_Voyage );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 April 2018	jlgndl1	Initial creation	TFS 38198

*/

vars

	oper : CM_Operator;
	operSet : CM_OperatorSet;
	ti : CM_TrackedItem;
	emailAdd : CM_EmailAddress2;
	emailAddresses : CM_EmailAddressByAddressDict;
	
	toAddresses : String;
	workString : String;
	
	wo : CM_WorkOrder;
	woDtl : CM_WorkOrderDtl;
	wodOpSet : CM_OperatorSet;

begin

	create operSet transient;
	create wodOpSet transient;
	
	if _voyage &lt;&gt; null then
		if email.sendtoOperatorVoyage then
			oper := _voyage.myOperator;
			if oper &lt;&gt; null then
				operSet.add( oper );
			endif;
		endif;
		
		if email.sendtoOperatorCargo then
			foreach ti in _voyage.allOnshipTIsByCargoTypeId do
				oper := ti.myOperator;
				if oper &lt;&gt; null then
					operSet.addNoDuplicates( oper, false );
				endif;
			endforeach;
			foreach ti in _voyage.allOnsiteTIsByCargoTypeId do
				oper := ti.myOperator;
				if oper &lt;&gt; null then
					operSet.addNoDuplicates( oper, false );
				endif;
			endforeach;
			foreach ti in _voyage.allNotifiedTIsByCargoTypeId do
				oper := ti.myOperator;
				if oper &lt;&gt; null then
					operSet.addNoDuplicates( oper, false );
				endif;
			endforeach;
		endif;
		//15 Oct 2018	NDL	TFS 41387
		if email.sendToOperatorCargoReqs then
			foreach wo in _voyage.allWorkOrders do	
				foreach woDtl in wo.allWoDtls do
					woDtl.getCargoOperatorsForEmail( wodOpSet );
				endforeach;
			endforeach;
			if not wodOpSet.isEmpty then
				foreach oper in wodOpSet do
					operSet.addNoDuplicates( oper, false );
				endforeach;
			endif;
		endif; 
		
	endif;
	
	create emailAddresses transient;
	if not operSet.isEmpty then
		foreach oper in operSet do
			foreach emailAdd in oper.allEmailAddresses do
				emailAddresses.addNoDuplicates( emailAdd, false );
			endforeach;
		endforeach;
	endif;
	
	//11 Jun 2020	NDL	TFS 49542
	/* TFS 51923 This is not needed, this is done in cm_voyage::emailNotify
	if self.freeTxtToAddesses &lt;&gt; null then
		workString := email.toAddresses.trimBlanks;
		if workString &lt;&gt; null and workString[workString.length : 1] &lt;&gt; ";" then
			workString := workString &amp; ";";
		endif;
		email.setAddressees( email.getBccAddresses, email.getCcAddresses, workString &amp; self.freeTxtToAddesses.trimBlanks );
	endif;
	if self.freeTxtBccAddesses &lt;&gt; null then
		workString := email.getBccAddresses;
		if workString &lt;&gt; null and workString[workString.length : 1] &lt;&gt; ";" then
			workString := workString &amp; ";";
		endif;
		email.setAddressees( workString &amp; self.freeTxtBccAddesses, email.getCcAddresses, email.toAddresses );
	endif;
	if self.freeTxtCcAddesses &lt;&gt; null then
		workString := email.getCcAddresses;
		if workString &lt;&gt; null and workString[workString.length : 1] &lt;&gt; ";" then
			workString := workString &amp; ";";
		endif;
		email.setAddressees( email.getBccAddresses, workString &amp; self.freeTxtCcAddesses, email.toAddresses );
	endif;
	*/
	
	if not emailAddresses.isEmpty then
		toAddresses := email.toAddresses.trimBlanks;
		if toAddresses &lt;&gt; null and toAddresses[toAddresses.length : 1] &lt;&gt; ";" then
			toAddresses := toAddresses &amp; ";";
		endif;
		foreach emailAdd in emailAddresses do
			toAddresses := toAddresses &amp; emailAdd.emailAddress.trimBlanks &amp; ";"; 
		endforeach;
		email.setAddressees( email.bccAddresses, email.ccAddresses, toAddresses );
	endif;

epilog

	delete operSet;
	delete emailAddresses;
	delete wodOpSet;

end;</source>
        <Parameter name="email" type="CM_VoyStatusDefaultEmail" usage="io"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
