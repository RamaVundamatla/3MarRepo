<Class name="CMIF_EDIDeckPlan" id="6199fd78-9f22-4f6a-bf07-a73520dec693">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ImplicitInverseRef name="allDeckPlanGCCargoToAdd" id="ad6b082a-badc-4929-9376-a7a0581aba45">
        <memberTypeInverse/>
        <type name="ObjectArray"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allDeckPlanGCCargoToDel" id="7445fa9f-c124-46f6-9785-12b72052d8d7">
        <memberTypeInverse/>
        <type name="ObjectArray"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allDeckPlanGCCargoToUpdate" id="34320946-2112-4f74-80b3-d87710077238">
        <memberTypeInverse/>
        <type name="ObjectArray"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myEDIData" id="859ee438-af62-4964-88e7-10d20bb4d2c1">
        <embedded/>
        <type name="CM_EDIData"/>
    </ImplicitInverseRef>
    <JadeMethod name="cleanUpProxies" id="71101cf3-ebfa-4dda-85e4-14d889071baa">
        <source>cleanUpProxies();
/*
Purpose:			
Date		Who		Reason
14 November 2011	cnwab1	Initial creation
*/

vars
	cmifDeckPlanGCCargo : CMIF_DeckPlanGCCargo;
	obj : Object;
	invalidObj : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, cmifDeckPlanGCCargo.myProxyCargoItem, invalidObj);


	foreach obj in self.allDeckPlanGCCargoToAdd discreteLock do
		cmifDeckPlanGCCargo := obj.CMIF_DeckPlanGCCargo;
		
		delete cmifDeckPlanGCCargo.myProxyCargoItem;
		
	endforeach;
	foreach obj in self.allDeckPlanGCCargoToUpdate discreteLock do
		cmifDeckPlanGCCargo := obj.CMIF_DeckPlanGCCargo;
		
		delete cmifDeckPlanGCCargo.myProxyCargoItem;
		
	endforeach;
	foreach obj in self.allDeckPlanGCCargoToDel discreteLock do
		cmifDeckPlanGCCargo := obj.CMIF_DeckPlanGCCargo;
		
		delete cmifDeckPlanGCCargo.myProxyCargoItem;
		
	endforeach;
	
	self.allDeckPlanGCCargoToAdd.purge;
	self.allDeckPlanGCCargoToUpdate.purge;
	self.allDeckPlanGCCargoToDel.purge;
epilog

end;</source>
    </JadeMethod>
</Class>
