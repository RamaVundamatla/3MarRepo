    <JadeMethod name="showProcessCount" id="44bd444a-4ebe-4dfe-8fbe-35c76a74af29">
        <source>showProcessCount();
// ---------------------------------------------------------------------------
// Created:     01 June 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*
 Version 1.1 - 11-09-03 - Final cut sent to Lucy Williams.
 Version 1.2 - 19-09-03 - Web session licenses are now NOT charged for. 
 Version 1.3 - 03-10-03 - Added a counter for the Monitor process, under 'No charge' grouping.
 Version 1.4 - 16-10-02 - Fix a bug in 5.2 version were Monitor would not be counted correctly.
*/
 
// Version 1.4 - 16/10/2003
 
// Note: If running this from a JadeScript there will be an extra process included on the node executing the 
// script. This is the application the script is attached to while executing.
 
/*

Date		Who		Reason
02 Apr 2008	cnwkpd1	PAR #16421 - Rework to remove extended share locking on JADE system
					objects

*/

vars
	_node : Node;
	_process : Process;
	theNodes 		: NodeDict;
	theProcesses	: ProcessDict; 
	nodeCount,  processCount, nonChargeableLicenses : Integer;
	backgroundApp, devEnv, nonDev, debugger, painter, monitor : Integer;
	nonGUICount, guiCount, guiNoFormCount, webEnabledCount: Integer;
	detailArray : StringArray;
	type, str : String;
	a, b, c, htmlThinSessions, e, f : Integer;
	invalidNode,
	invalidProcess	: Boolean;
	nodeName		: String;
	
begin
	create detailArray transient;

	if process.isInTransactionState then		// PAR #16421
		app.raiseUnexpectedProgramError(class.name, method.name, 'Already in transaction state');
    	return;
    endif;
	
	if process.isInLoadState then				// PAR #16421
		endLoad;
    endif;

	theNodes := system.nodes.cloneSelf(true);			// PAR #16421
	
	on Exception do app.handleDeletedObject(exception, _node, invalidNode);
	on Exception do app.handleDeletedObject(exception, _process, invalidProcess);
	
	// Iterate each node...
	foreach _node in theNodes do
	
		invalidNode := false;
		
		// Get the name of this Node
		nodeName := _node.name;
		
		// Clone the nodes collection of processes
		delete theProcesses;
		theProcesses := _node.processes.cloneSelf(true);
		
		// If we had an exception accessing the node, then skip it
		if invalidNode then
			continue;
		endif;

		nodeCount := nodeCount +1;
		detailArray.add(nodeName);
		detailArray.add("Process Type" &amp; Tab &amp; "App Name" &amp; Tab &amp; "Schema Name");
		
		// Iterate each process within the node...
		foreach _process in theProcesses do
			
			invalidProcess := false;
			
			// Increment Type counters
			if _process.type.Integer = 0 then // Background app
				backgroundApp := backgroundApp + 1;
				processCount := processCount + 1;
				type := 'Background process';
			elseif _process.type.Integer = 1 then // JADE Development Environment
				devEnv := devEnv + 1;
				type := 'JDE';
			elseif _process.type.Integer = 2 and _process.persistentApp.name &lt;&gt; 'JadeMonitor' then // Non development
				nonDev := nonDev + 1;
				processCount := processCount + 1;
				type := 'Non-Dev';
			
				if _process.persistentApp.applicationType = 'S' then
					nonGUICount := nonGUICount + 1;
					type := 'Non-GUI';
				elseif _process.persistentApp.applicationType = 'G' then
					guiCount := guiCount + 1;
					type := 'GUI';
				elseif _process.persistentApp.applicationType = 'F' then
					guiNoFormCount := guiNoFormCount + 1;
					type := 'GUI, No Forms';
				elseif _process.persistentApp.applicationType = 'W' then
					webEnabledCount := webEnabledCount + 1;
					type := 'Web-Enabled';
				endif;     
			
			elseif _process.type.Integer = 3 then // Debugger (don't charge for)
				debugger := debugger + 1 ;
				type := 'Debugger';
				nonChargeableLicenses := nonChargeableLicenses + 1;
			elseif _process.type.Integer = 4 then // Painter (don't charge for)
				painter := painter + 1;
				type := 'Painter';
				nonChargeableLicenses := nonChargeableLicenses + 1;
			elseif _process.persistentApp.name = 'JadeMonitor' then // Monitor (don't charge for)
				monitor := monitor + 1;
				type := 'Monitor';
				nonChargeableLicenses := nonChargeableLicenses + 1;
			endif;
			detailArray.add('  ' &amp; type &amp; Tab &amp; _process.persistentApp.name &amp; Tab &amp; _process.schema.getName);
		endforeach;
		detailArray.add(' ');
	endforeach;
	system.getLicenceUsage( a, b, c, htmlThinSessions, e, f);
	
	// Summary
	str := 'Breakdown of licenses currently being used:' &amp; CrLf &amp; CrLf &amp;
'  - Development licenses: ' &amp; devEnv.String &amp; CrLf &amp; CrLf &amp;
'  - Process licenses: ' &amp; (processCount).String &amp; ' (across ' &amp; nodeCount.String &amp; ' nodes)' &amp; CrLf &amp;
'      - ' &amp; backgroundApp.String &amp; ' Background Processes' &amp; CrLf &amp;
'      - ' &amp; nonGUICount.String &amp; ' Non-GUI' &amp; CrLf &amp;
'      - ' &amp; guiCount.String &amp; ' GUI' &amp; CrLf &amp;
'      - ' &amp; guiNoFormCount.String &amp; ' GUI, No Forms' &amp; CrLf &amp;
'      - ' &amp; webEnabledCount.String &amp; ' Web-Enabled' &amp; CrLf &amp; CrLf &amp;
'  - Non chargeable licenses: ' &amp; (htmlThinSessions + nonChargeableLicenses).String &amp; CrLf &amp;
'      - ' &amp; painter.String &amp; ' Painter' &amp; CrLf &amp;
'      - ' &amp; debugger.String &amp; ' Debugger' &amp; CrLf &amp;
'      - ' &amp; monitor.String &amp; ' Monitor' &amp; CrLf &amp;
'      - ' &amp; htmlThinSessions.String &amp; ' HTML Thin Sessions' &amp; CrLf;

	app.msgBox(str, 'Jade License Usage', MsgBox_OK_Only + MsgBox_Information_Icon);
	
	/*
	write 'Breakdown of licenses currently being used:';
	write '  - Development licenses: ' &amp; devEnv.String;
	write '  - Process licenses: ' &amp; (processCount).String &amp; ' (across ' &amp; nodeCount.String &amp; ' nodes)';
	write '      - ' &amp; backgroundApp.String &amp; ' Background Processes';
	write '      - ' &amp; nonGUICount.String &amp; ' Non-GUI';
	write '      - ' &amp; guiCount.String &amp; ' GUI';
	write '      - ' &amp; guiNoFormCount.String &amp; ' GUI, No Forms';
	write '      - ' &amp; webEnabledCount.String &amp; ' Web-Enabled';
	write '  - Non chargeable licenses: ' &amp; (htmlThinSessions + nonChargeableLicenses).String;
	write '      - ' &amp; painter.String &amp; ' Painter';
	write '      - ' &amp; debugger.String &amp; ' Debugger';
	write '      - ' &amp; monitor.String &amp; ' Montior';
	write '      - ' &amp; htmlThinSessions.String &amp; ' HTML Thin Sessions';
	*/
	/*
	write CrLf &amp; 'Process summary by Node:' &amp; CrLf;
	foreach str in detailArray do
		write str;
	endforeach;
	*/
epilog
	delete detailArray;
	delete theNodes;
	delete theProcesses;
	
end;</source>
    </JadeMethod>
