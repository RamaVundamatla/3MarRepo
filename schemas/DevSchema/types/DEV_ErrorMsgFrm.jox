    <JadeMethod name="clearFilter" id="bf8aa34a-5bdd-4c44-89fb-596bf32484e4">
        <updating/>
        <source>clearFilter() updating;
/*
Purpose:			

Date		Who		Reason
05 July 2023	navab1	 
*/


vars
	txtFilter : CMUI_TextBox;
	filterText 	: String;
	rowIdx,
	colIdx,
	start,
	rows		: Integer;
	cell 		: JadeTableCell;
	cellText 	: String;
	tbl			: Table;
	
begin

	
	txtFilter := self.txtFilterBox;
	
	if txtFilter.text &lt;&gt; "" then
		txtFilter.text 				:= "";
		self.btnClearFilter.enabled := true;
	endif;
	
	if txtFilter.text = "" then
		self.btnClearFilter.enabled := false;
	endif;
	
	tbl := self.tblData;
	start := tbl.fixedRows + 1;
	
	foreach rowIdx in start to tbl.rows do : rowLoop
		tbl.accessRow(rowIdx);
		tbl.accessedRow.visible := true;
	endforeach;

end;</source>
    </JadeMethod>
