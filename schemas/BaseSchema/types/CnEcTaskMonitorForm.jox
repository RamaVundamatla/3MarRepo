    <JadeMethod name="refreshCurrent" id="456a2eb6-8ed8-412f-9818-fd4b5ea29d05">
        <source>refreshCurrent() protected;
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	taskObj			: CnEcBackShedTask;
	itemIndex		: Integer;
	iterObj			: Iterator;
	
begin
	lstPreQueue.clear();
	lstQueue.clear();
	lstRunning.clear();
	lstCompleted.clear();
	
	iterObj := app.myBackShedManager.allBackShedTasks.createIterator();
	
	while iterObj.next(taskObj) do
	
		if taskObj.isScheduled then
			itemIndex := lstQueue.addItem(taskObj.getIdentification());
			lstQueue.itemObject[itemIndex]		:=	taskObj;
			lstQueue.itemBackColor[itemIndex]	:=	taskObj.getStatusColour();
			
		elseif taskObj.completedTimeStamp.isValid then
			itemIndex := lstCompleted.addItem(taskObj.getIdentification());
			lstCompleted.itemObject[itemIndex]		:=	taskObj;
			lstCompleted.itemBackColor[itemIndex]	:=	taskObj.getStatusColour();
			
		elseif taskObj.isRunning then
			itemIndex := lstRunning.addItem(taskObj.getIdentification());
			lstRunning.itemObject[itemIndex]	:=	taskObj;
			lstRunning.itemBackColor[itemIndex]	:=	taskObj.getStatusColour();
			
		else
			itemIndex := lstPreQueue.addItem(taskObj.getIdentification());
			lstPreQueue.itemObject[itemIndex]		:=	taskObj;
			lstPreQueue.itemBackColor[itemIndex]	:=	taskObj.getStatusColour();
		endif;
		
	endwhile;
epilog
	delete iterObj;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resize" id="4a5ffe55-3c41-44cc-8ffd-6b79bd0c01e1">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;
// -----------------------------------------------------------------------------
// Created:		16 December 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	btnClose.move((self.width - btnClose.width - 17), (self.height - btnClose.height - 37), btnClose.width, btnClose.height);
	btnRefresh.move((btnClose.left - btnRefresh.width - 3), btnClose.top, btnRefresh.width, btnRefresh.height);
	btnTaskManager.move((btnRefresh.left - btnTaskManager.width - 3), btnClose.top, btnTaskManager.width, btnTaskManager.height);
	grpKey.move(grpKey.left, (self.height - grpKey.height - 37), grpKey.width, grpKey.height);
	basSplitMain.move(basSplitMain.left, basSplitMain.top, (self.width - basSplitMain.left - 18), (self.height - basSplitMain.top - 68));
	basSplitMain.cnEcResizeContents();
end;</source>
    </JadeMethod>
    <JadeMethod name="showManager" id="b85df45e-d905-412e-9dbc-98acc6f0b825">
