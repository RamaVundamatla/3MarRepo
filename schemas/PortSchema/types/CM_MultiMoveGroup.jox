    <JadeMethod name="addCargoItem" id="56383ab2-dd04-4683-87ae-0985ba3c4517">
        <source>addCargoItem( _ti : CM_TrackedItem input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2015	cnwndl1	Initial creation	Par 36906

*/

vars

	invalidObj : Boolean;
	mmg : CM_MultiMoveGroup;

begin

	if _ti = null then
		return;
	endif;
	
	on Exception do app.handleDeletedObject( exception, _ti, invalidObj );
	

	mmg := _ti.myMultiMoveGroup;
	//if its already in another group, remove it.
	if mmg &lt;&gt; null and mmg &lt;&gt; self then
		mmg.removeCargoItem( _ti );
	endif;
	
	if invalidObj then
		return;
	endif;
	
	if not self.allAssociatedCargo.includes( _ti ) then
		_ti.setMultiMoveGroup( self );
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDefaultTargetLocation" id="766152cc-b858-4ae5-b18f-cb0635da2f88">
        <source>getDefaultTargetLocation( _ti : CM_TrackedItem ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2015	cnwndl1	Initial creation	Par 36906

*/

vars

	currentLc : CM_LocationsController;

begin
	
	if self.targetLocation &lt;&gt; null then
		currentLc := _ti.myPrimaryActualLocation;
		if currentLc = null or currentLc.getFullId &lt;&gt; self.targetLocation then
			return self.targetLocation;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="removeCargoItem" id="ce316c7d-62e9-491b-816f-c1b7495aa3e6">
        <updating/>
        <source>removeCargoItem( _ti : CM_TrackedItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2015	cnwndl1	Initial creation	Par 36906

*/

vars

begin

	if  _ti &lt;&gt; null and self.allAssociatedCargo.includes( _ti ) then
		_ti.setMultiMoveGroup(null);
	endif;
	
	if self.allAssociatedCargo.size &lt; 2 then
		delete self;
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="7b60ff1d-c5b3-49fd-88db-722faf11f4ee">
        <updating/>
        <source>setForCreate(	_pxyMultiMoveGroup : CM_MultiMoveGroup;
				_passport : CM_Passport input
				) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2015	cnwndl1	Initial creation	Par 36906

*/

vars

begin

	self.setForUpdate(_pxyMultiMoveGroup, _passport );

epilog

end;</source>
        <Parameter name="_pxyMultiMoveGroup" type="CM_MultiMoveGroup"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="dd8ff799-886b-4c6f-b6f3-889a46add9ec">
        <updating/>
        <source>setForUpdate(	_pxyMultiMoveGroup : CM_MultiMoveGroup;
				_passport : CM_Passport input
				) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2015	cnwndl1	Initial creation	Par 36906

*/

vars

	cargoId : String;
	ti : CM_TrackedItem;
	cargoTypeInt : Integer;

begin

	self.allCargoIds.clear();
	_pxyMultiMoveGroup.allCargoIds.copy( self.allCargoIds );
	
	self.myCargoType := _pxyMultiMoveGroup.myCargoType;
	self.targetLocation := _pxyMultiMoveGroup.targetLocation;
	
	self.myTerminal := _pxyMultiMoveGroup.myTerminal;
	
	if self.myCargoType &lt;&gt; null then
		cargoTypeInt := myCargoType.id;
	endif;
	foreach cargoId in self.allCargoIds do
		ti := self.myTerminal.allOnsiteTIsByIdCargoType.getAtKeyGeq( cargoId, cargoTypeInt );
		if ti = null or ti.id &lt;&gt; cargoId or ( cargoTypeInt &lt;&gt; 0 and ti.cargoType &lt;&gt; cargoTypeInt ) then
			app.raiseCMException1( Cargo_item_not_found_site, cargoId, null, null );
		else
			self.addCargoItem(ti);
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_pxyMultiMoveGroup" type="CM_MultiMoveGroup"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="5679590d-96a5-429c-b1e9-ca772ed5b69c">
        <updating/>
        <source>setProxy(	_allCargoIds : StringArray input;
			_myCargoType : CM_CargoType;
			_targetLocation : String;
			_terminal : CM_Terminal
			) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2015	cnwndl1	Initial creation	Par 36906

*/

vars

begin

	self.allCargoIds.clear();
	_allCargoIds.copy( self.allCargoIds );
	
	self.myCargoType := _myCargoType;
	self.targetLocation := _targetLocation;
	
	self.myTerminal := _terminal;

epilog

end;</source>
        <Parameter name="_allCargoIds" type="StringArray" usage="input"/>
        <Parameter name="_myCargoType" type="CM_CargoType"/>
        <Parameter name="_targetLocation" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="validateCreate" id="bd7c4d35-a11b-4ab5-a1b8-8788d55a8001">
