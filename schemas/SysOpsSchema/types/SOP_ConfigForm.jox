    <JadeMethod name="btnJobPriority_click" id="c42d2a28-9321-4a97-a07e-c771f7b635b7">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnJobPriority_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 August 2016	cnwma1	Initial creation TFS # 2230:System Config - Issues

*/

vars
	menuAction : CMUI_MenuAction;

begin
	create menuAction transient;
	menuAction.setPropertyValue(CM_MenuAction::extraTableDef.name, ETDef_InExtra);
	self.myAssistant.showJobPriorityForSysConifg( menuAction);
epilog
	delete menuAction;
end;</source>
