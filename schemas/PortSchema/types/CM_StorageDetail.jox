    <JadeMethod name="pxyCreateUpdateProxy" id="b919e93d-637d-49d6-9d4a-ceea9bf75135">
        <source>pxyCreateUpdateProxy() : SelfType;
// 13 September 2012	cnwjre1	CCMS SFW 1295 Free Storage Days
// 21 Jul 2017			cnwma1	TFS #5409:STWO - Storage Slab Auto Commercial Hold
vars
	proxyStorageDetail	: CM_StorageDetail;
begin
	proxyStorageDetail := inheritMethod();
	proxyStorageDetail.chargedDaysType := self.chargedDaysType;
	proxyStorageDetail.freeDaysType := self.freeDaysType;
	proxyStorageDetail.freeStorageDays := self.freeStorageDays;
	proxyStorageDetail.chargeDays := self.chargeDays; // PAR 36275 NEW
	proxyStorageDetail.priorityValue := self.priorityValue;	//18 May 2016	NDL	TFS 1981
	proxyStorageDetail.stopCompletionFreeDays := self.stopCompletionFreeDays;	// TFS 2570
	proxyStorageDetail.myFutureStorageStop :=  self.myFutureStorageStop; //21.07.2017 cnwma1 TFS #5409
	return proxyStorageDetail;
end;
</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="recalculateCriteriaPriorities" id="ed9bd0e7-d809-4bca-b1ba-ed8149448ddf">
        <updating/>
        <source>recalculateCriteriaPriorities() updating;
// CCMS 1295 free storage days
vars
	criteriaObj			: CM_YACriteria;
	priorityTotal		: Real;	//26 Feb 2020	NDL	TFS 48689 change from Integer to Real
	
begin
	priorityTotal	:=	0;
	
	foreach criteriaObj in self.allCriteria do
		priorityTotal	:=	priorityTotal + criteriaObj.calculateInvoicePriority();
	endforeach;
	
	
	self.setPriorityValue(priorityTotal);
end;
</source>
    </JadeMethod>
