    <JadeMethod name="setGridAreaContextMenu" id="b8f01f34-74e7-48ee-b0a0-b00c973843ab">
        <updating/>
        <source>setGridAreaContextMenu(_gridPoint : CMUI_GridPoint input; _x, _y : Integer)updating;
//-----------------------------------------
//Created: March 2003 By: cnwgd1
//-----------------------------------------
// Changed On	By			Reason
// ----------	--------	-------------------------------------------
// 25/01/2013	cnwdap1		PAR #31018 CCM POL 2223 added mnuCargoDiscon
vars
	ti	: CM_TrackedItem;
	theWagon	: CM_Wagon;

begin
	inheritMethod(_gridPoint, _x, _y);
	
	// Set up the menu items here as they are relevant only to the rail
	// form.  They are defined on the super form as this menu also has
	// options which are relevant at the super form level.
	
	if _gridPoint &lt;&gt; null then
		if not _gridPoint.isBoxcar then
			ti := _gridPoint.getTI(_x,_y);
		endif;
	endif;

	if _gridPoint = null or self.myCurrentLocation = null then
		self.doBuildMenuNullWagon(self.frmGridArea, _x, _y);		

	elseif ti = null then
		// display wagon menu options if clicked any part of the wagon except the cargo
		theWagon := _gridPoint.myLocationsController.CM_WagonController.myWagon;
		self.doBuildMenuWagon(theWagon);
		if _gridPoint.isKindOf(YRD_WagonBody) then
			self.doBuildMenuWgnBody(_gridPoint.YRD_WagonBody);
		elseif _gridPoint.isBoxcar then
			self.doBuildMenuBoxcar( theWagon );
		endif;
		
	else
		self.doBuildMenuCargo(ti);
	endif;
	
	if (mnuCargo.visible or mnuWagonConfirm.visible or mnuWagonEdit.visible or
			mnuWagonDelete.visible or mnuPlanTI.visible) and
			(mnuZoomSub.visible or mnuToggleToolbar.visible or
			mnuToggleLegend.visible or mnuToggleExtraInfo.visible) or
			mnuWagonSeals.visible
			then
		mnuGridContextSep.visible := true;
	else
		mnuGridContextSep.visible := false;
	endif;	
	
	// separators for cargo submenu
	if (mnuEnquiry.visible or mnuUnplan.visible or mnuLocationEnquiry.visible) and
			( mnuCargoTaskAdd.visible or mnuCargoTaskComplete.visible or mnuCargoTaskRemarks.visible or	//07 Oct 2015	NDL	Par 37011
				mnuTaskAdd.visible or mnuTaskComplete.visible or mnuStops.visible) then
		self.mnuCargoSep1.visible := true;
	else
		self.mnuCargoSep1.visible := false;
	endif;		
		
	if (  mnuCargoTaskAdd.visible or mnuCargoTaskComplete.visible or mnuCargoTaskRemarks.visible or	//07 Oct 2015	NDL	Par 37011
			mnuTaskAdd.visible or mnuTaskComplete.visible or mnuStops.visible) and
			(mnuAttach.visible or mnuConnect.visible or mnuLCL.visible or
			//mnuCargoRemarks.visible) then											// PAR #31018
			mnuCargoRemarks.visible or mnuCargoDiscon.visible) then					// PAR #31018
		self.mnuCargoSep2.visible := true;
	else
		self.mnuCargoSep2.visible := false;
	endif;
	
	if (  (self.mnuToggleTransportView.caption = app.getErrorString(Hide_graphic_view)) and (self.mnuToggleExtraInfo.caption = app.getErrorString(Show_macro_info)) ) 
	or (  (self.mnuToggleTransportView.caption = app.getErrorString(Show_graphic_view)) and (self.mnuToggleExtraInfo.caption = app.getErrorString(Hide_macro_info)) ) then
		self.mnuToggleInfoGraphic.visible := true;	
		self.mnuToggleGraphicInfo.visible := true;	
	else
		self.mnuToggleInfoGraphic.visible := false;	
		self.mnuToggleGraphicInfo.visible := false;	
	endif;

	self.popupMenu(self.mnuGridAreaContext, _x, _y);
end;</source>
        <Parameter name="_gridPoint" type="CMUI_GridPoint" usage="input"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMenuVisibility" id="a48a0b54-3700-4f1c-8e11-e4e8dc27b4da">
