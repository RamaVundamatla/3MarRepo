    <JadeMethod name="doConfirmContainerIn" id="6614b848-7f13-4a5e-82ea-0b9a6e78b3ef">
        <updating/>
        <source>doConfirmContainerIn() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	Here we are not yet creating or updating the container persistently, just storing the details
			They are created when the user clicks 'Accept' at which point the wagon and the containers are created.

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	errorMsgs				: MobileHandHeldThin::DTO_HandHeldGateErrorDict;
	error					: DTO_HandHeldGateError;
	idx : Integer;
	wagonPos				: MobileHandHeldThin::DTO_WagonPosition;
	wagonId					: String;
	clonedButton : Button;
	
begin
/*	wagonId := self.txtWagonIn.text;
	wagonPos := self.myDTOWagonIn.allDTOWagonPositions[self.showingContainerNumIn];
	
	wagonPos.myDTOContainer.containerId				:= self.txtId.text.trimBlanks.toUpper();
	wagonPos.myDTOContainer.isoTypeCode 			:= self.cmbISOType.text;
	wagonPos.myDTOContainer.customsSeal 			:= self.txtSealCust.text.trimBlanks.toUpper();
	wagonPos.myDTOContainer.operatorSeal 			:= self.txtSealOp.text.trimBlanks.toUpper();
	wagonPos.myDTOContainer.shipperSeal 			:= self.txtSealShip.text.trimBlanks.toUpper();
	wagonPos.myDTOContainer.hazardousChecked 		:= self.chkHaz.value;*/
	
	wagonPos:=self.doUpdateDTOContainer();
	
	create errorMsgs transient;
	self.doClearErrors();
	app.myHandHeldRailGuiAgent.doConfirmContainerInwards(self.myDTOWagonIn, 
												wagonPos, 
												errorMsgs);
	//set the button to either 'confirmed', 'errors' or still requires info
	wagonPos.myDTOContainer.setButtonCaption();
	if (not wagonPos.myDTOContainer.hadErrors) then
		if wagonPos.myDTOContainer.myRealTrackedItem &lt;&gt; null then
			// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
			//self.tblDamage.setTableFromTI(wagonPos.myDTOContainer.myRealTrackedItem.allDamageInstances);
			self.tblDamage.setTableFromTI(wagonPos.myDTOContainer.myRealTrackedItem.allDamageInstancesByPos);
			self.txtDamage.text := wagonPos.myDTOContainer.myRealTrackedItem.remarks;
		endif;
		self.lblInfoCaption.caption := 'CONTAINER ' &amp; wagonPos.myDTOContainer.idx.String &amp; ' CONFIRMED';
		// ###

		while true do
			idx := idx + 1;
			clonedButton := self.btnCloneIn.getControl(idx);
			if clonedButton &lt;&gt; null and clonedButton.tag = self.showingContainerNumIn.String then
				clonedButton.caption := 'CONTAINER ' &amp; self.showingContainerNumIn.String &amp; ' CONFIRMED';
				break;
			endif;
			if idx &gt; 10 then
				break;
			endif;
		endwhile;
		
		
		// ###
		self.doShowFrmMain();
	else
		self.doApplyErrors(errorMsgs);
	endif;
	self.btnDamage.enabled  := wagonPos.myDTOContainer.confirmed;
	
epilog
	if errorMsgs &lt;&gt; null then
		errorMsgs.purge();
	endif;
	
	delete errorMsgs;
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doConfirmContainerOut" id="79938bf8-dd42-46c0-8795-9654b5fae239">
        <updating/>
        <source>doConfirmContainerOut() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	Here we are not yet creating or updating the container persistently, just storing the details
			They are created when the user clicks 'Accept' at which point the wagon and the containers are created.

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	errorMsgs				: MobileHandHeldThin::DTO_HandHeldGateErrorDict;
	error					: DTO_HandHeldGateError;
	wagonPos				: MobileHandHeldThin::DTO_WagonPosition;
	wagonId					: String;
begin
	/*wagonId := self.txtWagonOut.text;
	wagonPos := self.myDTOWagonOut.allDTOWagonPositions[self.showingContainerNumOut];
	
	wagonPos.myDTOContainer.containerId 		:= self.txtId.text.trimBlanks.toUpper();	
	wagonPos.myDTOContainer.customsSeal 		:= self.txtSealCust.text.trimBlanks.toUpper();
	wagonPos.myDTOContainer.operatorSeal 		:= self.txtSealOp.text.trimBlanks.toUpper();
	wagonPos.myDTOContainer.shipperSeal 		:= self.txtSealShip.text.trimBlanks.toUpper();
	wagonPos.myDTOContainer.hazardousChecked 	:= self.chkHaz.value;*/
	
	wagonPos:=self.doUpdateDTOContainer();
	
	create errorMsgs transient;
	self.doClearErrors();
	app.myHandHeldRailGuiAgent.doConfirmConatinerOutwards(self.myDTOWagonOut,
														wagonPos, 
														errorMsgs);
	//set the button to either 'confirmed', 'errors' or still requires info
	wagonPos.setButtonCaption();
	if (not wagonPos.myDTOContainer.hadErrors) then
		// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
		//self.tblDamage.setTableFromTI(wagonPos.myDTOContainer.allDamageInstances);
		self.tblDamage.setTableFromTI(wagonPos.myDTOContainer.allDamageInstancesByDmgePos);
		self.txtDamage.text := wagonPos.myDTOContainer.myRealTrackedItem.remarks;
		self.lblInfoCaption.caption := 'CONTAINER ' &amp; wagonPos.myDTOContainer.idx.String &amp; ' CONFIRMED';
		self.doShowFrmMain();
	else
		self.doApplyErrors(errorMsgs);
	endif;
	self.btnDamage.enabled  := wagonPos.myDTOContainer.confirmed;
	
epilog
	if errorMsgs &lt;&gt; null then
		errorMsgs.purge();
	endif;
	
	delete errorMsgs;
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doConfirmDamageInwards" id="c525f36f-4d75-4be2-b571-a25445e15b70">
        <updating/>
        <source>doConfirmDamageInwards() protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	Damage details stored transiently here as they'll probably be creating a new 
			container, not just updating an existing one.
			
			Everything gets created persistently when they click the accept wagon in.
			
			See doConfirmDamageOutwards - in that instance, there is always an existing container which
			should have its damage details updated immediately

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	damageRemarks		: String;
	containerInfo		: MobileHandHeldThin::DTO_ContainerInfo;
	errors				: String;
begin
	
	containerInfo := self.getCurrentContainerInfo();
	
	if (not containerInfo.confirmed) then
		app.msgBox('You must confirm container ' &amp; self.getShowingContainerNum.String &amp; ' before entering damage info.','Error: Container not yet confirmed.',MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	//self.tblDamage.setProxyFromTable(containerInfo.allDamageInstances,null, errors);
	self.tblDamage.setProxyFromTable(containerInfo.allDamageInstancesByDmgePos, null, errors);
	
	if errors &lt;&gt; null then
		if app.msgBox(errors &amp; CrLf &amp; 'Continue?', 'Entry Warnings - Continue?', MsgBox_OK_Cancel) &lt;&gt; MsgBox_Return_OK then
			return;
		endif;
	endif;
	
	containerInfo.damageRemarks := self.txtDamage.text.trimBlanks;
		
	app.msgBox('Damage details confirmed.','Damage Confirmed', MsgBox_Exclamation_Mark_Icon);
	self.doShowFrmInfo(self.getShowingContainerNum());
	

end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doConfirmDamageInwardsNew" id="6ee926a9-370b-432b-8266-319a8188c878">
        <updating/>
        <source>doConfirmDamageInwardsNew() updating;
/*
Purpose:			

Return Value:		

Date		Who		Reason
23 November 2007	cnwer1	Initial creation - PAR#xxxx
*/
vars
	damageRemarks		: String;
	// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	//damageDict			: MobileHandHeldThin::CM_DamageInstanceByLocDict;
	damageDict			: MobileHandHeldThin::CM_DamageInstanceByDmgePos;
	errorMsgs			: MobileHandHeldThin::DTO_HandHeldGateErrorDict;
	containerInfo		: MobileHandHeldThin::DTO_ContainerInfo;
	errors				: String;
	damageInstance  	: MobileHandHeldThin::CM_DamageInstance;
begin
	containerInfo := self.getCurrentContainerInfo();
	
	create damageDict transient;
	// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	//containerInfo.myPxyTrackedItem.allDamageInstances.purge; 
	containerInfo.myPxyTrackedItem.allDamageInstancesByPos.purge;
	self.tblDamage.setProxyFromTable(damageDict,containerInfo.myPxyTrackedItem,  errors);
	if errors &lt;&gt; null then
		if app.msgBox(errors &amp; CrLf &amp; 'Continue?', 'Entry Warnings - Continue?', MsgBox_OK_Cancel) &lt;&gt; MsgBox_Return_OK then
			return;
		endif;
	endif;
	
	containerInfo.damageRemarks := self.txtDamage.text.trimBlanks;
	
	self.doShowFrmInfo(self.getShowingContainerNum());
epilog
	delete damageDict;
	
	

end;</source>
    </JadeMethod>
    <JadeMethod name="doConfirmDamageOutwards" id="fb73ef36-d74b-40b2-92e8-c73787791bbe">
        <updating/>
        <source>doConfirmDamageOutwards() protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	02 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	damageRemarks		: String;
	// 26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	//damageDict			: MobileHandHeldThin::CM_DamageInstanceByLocDict;
	damageDict			: MobileHandHeldThin::CM_DamageInstanceByDmgePos;
	errorMsgs			: MobileHandHeldThin::DTO_HandHeldGateErrorDict;
	containerInfo		: MobileHandHeldThin::DTO_ContainerInfo;
	errors				: String;
begin
	containerInfo := self.getCurrentContainerInfo();
	
	if (not containerInfo.confirmed) then
		app.msgBox('You must confirm container ' &amp; self.getShowingContainerNum().String &amp; ' before entering damage info.','Error: Container not yet confirmed.',MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	create damageDict transient;
	create errorMsgs transient;
	
	self.tblDamage.setProxyFromTable(damageDict,null, errors);
	
	if errors &lt;&gt; null then
		if app.msgBox(errors &amp; CrLf &amp; 'Continue?', 'Entry Warnings - Continue?', MsgBox_OK_Cancel) &lt;&gt; MsgBox_Return_OK then
			return;
		endif;
	endif;
	
	damageRemarks := self.txtDamage.text.trimBlanks;
	
	app.myHandHeldGuiAgent.doConfirmDamage(self.txtWagonOut.text.trimBlanks,
											containerInfo,
											damageRemarks,
											damageDict,
											errorMsgs);
	
	if (not errorMsgs.isEmpty) then
		app.msgBox('Errors occured when applying damage details. They will now be displayed','Errors occurred', MsgBox_Exclamation_Mark_Icon);
		self.doApplyErrors(errorMsgs);
		self.fldMain.topSheet := self.shtError;
	else
		app.msgBox('Damage details confirmed.','Damage Confirmed', MsgBox_Exclamation_Mark_Icon);
		self.doShowFrmMainOutward();
	endif;

	self.btnDamage.enabled  := containerInfo.myPxyTrackedItem &lt;&gt; null;	
epilog
	
	if damageDict &lt;&gt; null then
		damageDict.purge();
	endif;
	delete damageDict;

	if errorMsgs &lt;&gt; null then
		errorMsgs.purge();
	endif;
	delete errorMsgs;

end;




</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doConfirmDamageOutwardsNew" id="df7f83cb-d51d-4ca7-8bb5-9cd16f49ee2b">
