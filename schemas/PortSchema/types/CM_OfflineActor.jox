    <JadeMethod name="getAdditionalSessionLocks" id="0adb8301-e7ec-4240-9cd9-779cc1c65597">
        <source>getAdditionalSessionLocks() : Boolean;

/*

Purpose:			Get any additional locks required in addition to the Session_Duration one
					on self which are required to ensure correct application copy 
					multiprocessing by the CM_OfflineActor application copies.
				
					Will be required only when there is some inter-dependency that exists
					between multiple CM_OfflineActor instances.

					To be re-implemented as required.
					
				
Return Value:		True if all the additional locks are obtained, false otherwise


Date		Who		Reason

*/

vars

begin
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAndLockValidObject" id="3aeab16b-be66-459f-a09e-caa0f9055cdd">
        <source>getAndLockValidObject(_obj : Object; _lockType : Integer) : Boolean;

/*

Purpose:			Check that obj is a reference to a valid object, and 
					place a lock of the specified type on it to ensure it remains so.


Return Value:		True if the object is valid and locked, false otherwise



Date		Who		Reason

*/

vars
	excOccurred,
	lockObtained	: Boolean;
	
begin
	// Check for null object reference
	if _obj = null then
		return false;
	endif;
	
	on SystemException do app.handleDeletedObject(exception, _obj, excOccurred);
	
	self.lock(_obj, _lockType, Transaction_Duration, LockTimeout_Server_Defined);
	
	lockObtained := not excOccurred;

epilog
	return lockObtained;
	
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_lockType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="incrementRetryCount" id="32b41dd8-0f5b-4f0d-aac0-4dbe5524431f">
        <updating/>
        <source>incrementRetryCount() updating;

/*

Purpose:			Increment the receiver's retryCount by one


Return Value:


Date		Who		Reason
*/

vars

begin
	self.retryCount := self.retryCount + 1;

epilog

end;</source>
    </JadeMethod>
