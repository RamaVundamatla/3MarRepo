    <JadeMethod name="doDragOverAutoScrolling" id="510b96b7-609b-4a29-91fa-1b62314893e4">
        <updating/>
        <source>doDragOverAutoScrolling(frame: Frame input; win: Window input; x: Real; y: Real; state: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	SMALL_CHANGE = 180;
vars
	theSDF : CMUI_ScrollableDrawingFrame;
	horizontalScroll, verticalScroll, pluss : Boolean;
	realXValue, realYValue, smallChange,theXDiff : Integer;	
	now : TimeStamp;
begin
	if not self.doAutoScrolling then
		return;
	endif;
	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support

	if state = Frame.DragOver_Enter then
		self.enteredTS := now;
		self.leaveTS := null;
		app.setMouseMoveTime(10);
		return;
	endif;
	if state = Frame.DragOver_Leave then
		self.leaveTS := now;
		self.enteredTS := null;
		app.setMouseMoveTime(200);
		return;
	endif;

	if state = Window.DragOver_Continue then
		// have they hovered long enough?
		if now.cnEcDiff(self.enteredTS) &lt; 400 then
			return;
		endif;
		
//		process.sleep(100); // PAR7554 AKB2004FEB

		if self.myGridArea &lt;&gt; null then
			theSDF := self.myGridArea.mySDF;
			if theSDF = null then
				return;
			endif;
		else
			return;
		endif;

		// ### work out if I need to AUTO scroll. i.e. am I within 35 pixels of the edge?
		realXValue := ((x - theSDF.clientWidth) + theSDF.myVLabels.width).Integer;
		realYValue := ((theSDF.clientHeight + theSDF.myVScroll.value).Integer - y - theSDF.myHLabels.height).Integer;
		theXDiff := theSDF.myHScroll.value - realXValue;
		if theXDiff &lt; 35 then
			horizontalScroll := true;
			pluss := true;
		elseif (x - theSDF.myHScroll.value) &lt; 25 then
			horizontalScroll := true;
			pluss := false;
		elseif realYValue &lt; 35 then
			verticalScroll := true;
			pluss := true;
		elseif (y - theSDF.myVScroll.value) &lt; 35 then
			verticalScroll := true;
			pluss := false;
		endif;

		// if I am to scroll, how long is it since I was just dragOver continueing and not scrolling?
		if horizontalScroll or verticalScroll then
			if now.cnEcDiff(self.lastTS) &lt; 400 then
				return;
			endif;
			self.lastMouseX := x.Integer;
			self.lastMouseY := y.Integer;
//			self.endTimer(567);
//			self.beginTimer(250,Timer_Continuous,567);
		endif;
		if horizontalScroll and theSDF.myHScroll.visible then
			smallChange := theSDF.myHScroll.smallChange;
			smallChange := SMALL_CHANGE;
			if not pluss then
				smallChange := smallChange * -1;
			endif;
			theSDF.myHScroll.value := theSDF.myHScroll.value + smallChange;
			
			theSDF.scrollControl(ScrollBar_Horizontal, theSDF.myHScroll.value);
		elseif verticalScroll and theSDF.myVScroll.visible then
			smallChange := theSDF.myVScroll.smallChange;
			smallChange := SMALL_CHANGE;
			if not pluss then
				smallChange := smallChange * -1;
			endif;
			theSDF.myVScroll.value := theSDF.myVScroll.value + smallChange;
			theSDF.scrollControl(ScrollBar_Vertical, theSDF.myVScroll.value);
		// no scrolling so set the time.
		else
			self.lastTS := now;
//			self.endTimer(567);
		endif;
	endif;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doDragOverDrawDeskTopRectangle" id="a26b18e0-52e5-4a74-9144-534bd58e74e5">
        <updating/>
        <source>doDragOverDrawDeskTopRectangle(frame: Frame input; win: Window input; x: Real; y: Real; state: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	WIDTH	= 1;
vars
	theHeight, theWidth : Integer;
begin
	theHeight := (self.clientHeight / 2).Integer;
	theWidth := (self.clientWidth / 2).Integer;

	if self.inDragOver then
		frame.drawDeskTopRectangle(0, self.firstMouseX, self.firstMouseY,
											self.lastMouseX, self.lastMouseY, Black, WIDTH);


//		if state = 2 then
//			self.inDragOver := false;
//			self.isDrawDeskTopRectangle := false;
//			return;
//		endif;
	endif;
		
	self.inDragOver := true;
	
	self.lastMouseY := y.Integer;
	self.lastMouseX := x.Integer;


//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. " &amp; self.firstMouseX.String &amp; " " &amp;  self.firstMouseY.String &amp; " " &amp; 
//										self.lastMouseX.String &amp; " " &amp;  self.lastMouseY.String);	
	frame.drawDeskTopRectangle(0, self.firstMouseX, self.firstMouseY,
										self.lastMouseX, self.lastMouseY, Black, WIDTH);

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="dragOver" id="3a479482-21a2-4ebc-9865-c39583c7d936">
        <updating/>
        <source>dragOver(frame: Frame input; win: Window input; x: Real; y: Real; state: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theSDF : CMUI_ScrollableDrawingFrame;
	horizontalScroll, verticalScroll, pluss : Boolean;
	realXValue, realYValue, smallChange,theXDiff : Integer;	
	now : TimeStamp;
begin

	if self.isDrawDeskTopRectangle then
		self.doDragOverDrawDeskTopRectangle(frame, win,x,y,state);
//		return;
	endif;
	if self.doAutoScrolling then
		self.doDragOverAutoScrolling(frame, win,x,y,state);
		// do not return here as may want to auto-mask, etc
		//return;
	endif;

	inheritMethod(frame, win, x, y, state);
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
