    <JadeMethod name="rebuildWLEStatusUnactioned" id="210728d9-f313-452e-b6c3-c87a7e28bb37">
        <updating/>
        <source>rebuildWLEStatusUnactioned(_wle : CM_WorkListEntry input)updating;
/*
Purpose:			
Date				Who			Reason
AUGUST 2014		CNWAB1		Initial creation
24/02/2024 		navcs2 		MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
*/
vars
	obj 		: Object;
	rtnValue 	: Boolean;
	theResult 	: Integer;	//14 Jan 2020 NDL	TFS 46815
begin
	if _wle = null then
		return;
	endif;
	
	if app.msgBox("Be very careful using this feature" &amp; CrLf &amp; "Are you sure you want to proceed?", "Confirm", MsgBox_OK_Cancel) = MsgBox_Retry_Cancel then
		return;
	endif;
	
	
	app.mousePointer := MousePointer_HourGlass;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateWLEStatusDirectWLE(_wle, WLE_UNACTIONED, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Rebuild Entry Unactioned', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateWLEStatus(_wle, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Rebuild Entry Status', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
    </JadeMethod>
    <JadeMethod name="remarksUpdate" id="ea4e48ea-1a10-4e7d-90bc-655e865f33d0">
        <source>remarksUpdate(_obj : CM_Object input);
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------

vars
	remarksFrm	: CMUI_Remarks;
begin
	
	if _obj = null then
		return;
	endif;
	
	// Update the navigator
	remarksFrm := app.loadForm(CMUI_Remarks, CMUI_Assistant, false, false, true, self.myTerminal, self.myMasterMenuAction).CMUI_Remarks;
	self.setNavigatorHeading(remarksFrm.caption); 
	remarksFrm.centreWindow;
	remarksFrm.myCurrentObject := _obj.CM_Object;
	remarksFrm.setMyTerminal(self.myTerminal);
	// cnwsb1 14 May 2003 - CM_BaseForm::showModal() now sets isModal:
	// remarksFrm.isModal := true;
	remarksFrm.showModal;
	
end;</source>
        <Parameter name="_obj" type="CM_Object" usage="input"/>
    </JadeMethod>
    <JadeMethod name="removeWLEForTable" id="9067fc72-c91e-494f-9dab-9b772e2d3254">
        <source>removeWLEForTable(_wle : CM_WorkListEntry) protected;

// Created by cnwdvb1 on 26 February 2007

vars

	tbl : CM_DataTable;

begin

	// Get table for wle
	tbl := self.getWLETableForWLE(_wle);
	
	// If we have a reference, get it out of the dict.
	if tbl &lt;&gt; null then
		self.allTablesByWle.removeKeyEntry(_wle, tbl);
		// If is valid then get rid of entry
		if global.isValidObject(tbl) then
			tbl.removeItemObject(_wle);
		endif;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="resortTblWorkEntries" id="70352b42-d5bb-4b2d-b96d-2840b058acc9">
        <source>resortTblWorkEntries(_table : CM_DataTable input);
//--------------------------------------------------------------
//Created: 01 May 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	obj : Object;
	wle : CM_WorkListEntry;
	idx,
	rtCol,
	rows : Integer;
	colNum : Integer;
	colName : String;
begin

	if _table.row &lt;&gt; _table.fixedRows then // AKB2004FEB
		return;
	endif;
	
	colNum := _table.column;
	colName := _table.allTblDataColPropertyNames[colNum];
	if  colName = ETRow_SeqNumAsString then
		_table.accessColumn(colNum).sortOrder := 1;
		_table.accessColumn(colNum).sortType   := Table.SortType_Numeric;		
	else
		_table.accessColumn(colNum).sortOrder := 1;
		_table.accessColumn(colNum).sortType   := Table.SortType_Alpha;		
	endif;
	
	_table.resortTableByColumn(_table.column);
	
	rows := _table.rows;
	rtCol := _table.getColumnByRowName(ETRow_RadioTelemetry);
	
	foreach idx in 2 to rows do
		obj := _table.accessRow(idx).itemObject;
		if obj &lt;&gt; null and obj.isKindOf(CM_WorkListEntry) then
			wle := obj.CM_WorkListEntry;
		endif;
		self.tblWLESetRowColour(_table, wle, idx, rtCol);
		wle := null;
	endforeach;	
	
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="26d3d149-7077-403f-bb20-bc5a95b6a7c9">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     30 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpBackColor	: Integer;

begin
	inheritMethod(_colorControl);

	tmpBackColor := self.backColor;
	
	self.frmModeStatusBar.backColor	:= tmpBackColor;
	self.frmReport.backColor		:= tmpBackColor;
	self.lstJobs.backColor			:= self.colorControlBack;
	self.splTables.backColor		:= tmpBackColor;
	self.splMain.backColor			:= tmpBackColor;	

end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setDisplayMode" id="69dc33f4-e11e-4a4d-b576-a2c238045070">
        <updating/>
        <source>setDisplayMode(_mode : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.displayMode &lt;&gt; _mode then
		self.displayMode := _mode;
		self.frmModeStatusBar.displayMode := _mode;
	endif;
end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setListAndSelectorHeights" id="f0a0ba61-a79f-4d16-9686-7d9f633f3d46">
        <source>setListAndSelectorHeights(_selectorFixed : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Oct 2012	cnwpjs1	Initial creation 30448

*/

vars

	tmpHeight : Real;

begin

	tmpHeight := self.clientHeight-self.frmToolbar.height-WinBottomMargin;
	
	if _selectorFixed then
		tmpHeight := tmpHeight - frmSelector.top;
	endif;
	
	self.lstJobs.height := lstJobs.listCount*17;
	if self.lstJobs.height &gt; tmpHeight then
		self.lstJobs.height := tmpHeight;
	endif;
	
	if lstJobs.listCount &gt; 0 then
		frmSelector.height := lstJobs.height + lstJobs.top + 15;
	else
		frmSelector.height :=lstJobs.top + 13;
	endif;
	
	

epilog

end;</source>
        <Parameter name="_selectorFixed" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMnuCargoUserObject" id="49714198-989b-46fb-83c3-ea105579e8e0">
        <source>setMnuCargoUserObject();
//--------------------------------------------------
// Created:	15 October 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.myCurrentTrackedItem = null then
		self.mnuEnquiry.userObject := null;	
		self.mnuLocationEnquiry.userObject := null;
	else
		self.mnuLocationEnquiry.userObject := self.myCurrentTrackedItem;	
		self.mnuEnquiry.userObject := self.myCurrentTrackedItem;
	endif;
end;</source>
    </JadeMethod>
