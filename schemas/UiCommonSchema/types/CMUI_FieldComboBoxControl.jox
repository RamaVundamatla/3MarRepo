    <JadeMethod name="addItemObject" id="743bf8ca-743d-4ba2-9ed5-94effd46b7ee">
        <updating/>
        <source>addItemObject(_text : String; _obj : Object) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     20 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	listPointer		: Integer;

begin
	listPointer	:=	self.addItem(_text);
	self.itemObject[listPointer]	:=	_obj;
	
	return listPointer;
end;</source>
        <Parameter name="_text" type="String"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="change" id="0b520e5c-7630-473b-8319-3a7dc236fbe4">
