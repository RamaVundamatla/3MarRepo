    <JadeMethod name="getExtraExtraInfo" id="f2376ba6-23af-4d74-9d51-9b29c6dc8a99">
        <source>getExtraExtraInfo(_dataContainer: CM_DataContainer; _party :CM_EDIParty);
/*
Date		Who		Reason
23 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	etDef		: EntTableDef; 
	etRow		: EntTableRow;
	block		: CM_DataContainerBlock;
	terminal	: CM_Terminal;
	locale		: CM_Locale;
begin
	etDef 		:= app.myController.getEntTableDef (ETDef_EDIPartyEnquiry);
	terminal	:= self.myTerminal;
	locale		:= app.myCurrentLocale;
	
	// name
	etRow := etDef.getEntTableRow (ETRow_Name);
	
	block := _dataContainer.addNewBlock;
	
	block.addNewItem (etRow.getHeading (null, terminal, locale), DC_Label, 1, null);
	block.addNewItem (_party.getDisplayStringForAttribute (ETRow_Name, false), DC_Data, 1, null);
	
	// description
	etRow := etDef.getEntTableRow (ETRow_Description);
	
	block := _dataContainer.addNewBlock;
	
	block.addNewItem (etRow.getHeading (null, terminal, locale), DC_Label, 1, null);
	block.addNewItem (_party.getDisplayStringForAttribute (ETRow_Description, false), DC_Data, 1, null);

	// senders
	etRow := etDef.getEntTableRow (ETRow_Senders);
	
	block := _dataContainer.addNewBlock;
	
	block.addNewItem (etRow.getHeading (null, terminal, locale), DC_Label, 1, null);
	block.addNewItem (_party.getDisplayStringForAttribute (ETRow_Senders, false), DC_Data, 1, null);

epilog

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
        <Parameter name="_party" type="CM_EDIParty"/>
    </JadeMethod>
    <JadeMethod name="getSelectedEDIParty" id="6654a848-1266-4824-9a40-f378e05007ac">
        <source>getSelectedEDIParty():CM_EDIParty protected;
/*
Date		Who		Reason
17 Nov 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	table	:CM_DataTable;
	row		:Integer;
	result	:CM_EDIParty;
begin
	table	:= self.tblData;
	row		:= table.row;
	
	if row &lt;= table.fixedRows then
		return null;
	endif;
	
	result := table.accessRow (row).itemObject.CM_EDIParty;
	
	return result;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="CM_EDIParty"/>
    </JadeMethod>
