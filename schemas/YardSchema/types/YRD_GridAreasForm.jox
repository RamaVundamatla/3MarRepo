vars

	theTIs : CM_TIArray;
begin
	
	self.mousePointer := Window.MousePointer_HourGlass;
	if app.myMoveController = null then
		return;
	endif;
	
	create theTIs transient;
	//epr par 20486 17/3/10
	if _ydc = null then
		return;
	endif;
	
	//14 Sep 2009	NDL 	Par 20514	- Not always just Tis in this coll...
	_ydc.getAllSelectedTis(theTIs);
	
	app.myMoveController.moveTrackedItemsSource(self.myTerminal,theTIs);
	
	
epilog
	delete theTIs;

	self.mousePointer := Window.MousePointer_Default;
end;</source>
