    <JadeMethod name="trxDeleteCamsHistories" id="8bec141b-4026-42d4-b21a-6d57c92782e6">
        <updating/>
        <source>trxDeleteCamsHistories(_protocol : CM_CamProtocol; _camTaskHistToDelete : ObjectArray; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		27 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	camTaskHistory : Object;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	
	foreach camTaskHistory in _camTaskHistToDelete do
		if _protocol.taskHistoryByProtocolSeq.includes(camTaskHistory.CM_CamTaskHistory) then
			app.myUtilityDA.utlDeleteCamTaskHistory(camTaskHistory.CM_CamTaskHistory, _passport);
		endif;
	endforeach;
	

epilog		
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camTaskHistToDelete" type="ObjectArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxDeleteCamsHistory" id="563c24d1-3321-4277-9ac2-96f22dc18ad4">
        <updating/>
        <source>trxDeleteCamsHistory(_protocol : CM_CamProtocol io; _upToDate, _today : Date; _passport : CM_Passport input) updating;
/* ---------------------------------------------------------------------------
   Created:		16 May 2003  by Jason Chapman  (cnwjc2)
  ---------------------------------------------------------------------------

 Changed On   Changed By  Reason
 ----------   ----------  --------------------------------------------------
 29/7/09      J Harliwich  MES1011 Also remove old trans from allProcessedTransactions (just removes off set does not delete objects)
 12/5/2010	  cnwcs5		par 23967 - removed code to get rid of processed transactions 
// 28 Sep 2016	cnwrs1	TFS 2756 PAR38267 allow Cams to run per terminal
 ---------------------------------------------------------------------------
*/
vars
	camTaskHistory : CM_CamTaskHistory;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	
	foreach camTaskHistory in _protocol.taskHistoryByProtocolSeq do
		if camTaskHistory.runDateTime.date &lt; _upToDate then
			app.myUtilityDA.utlDeleteCamTaskHistory(camTaskHistory, _passport);
		else
			break;
		endif;
	endforeach;
	if _passport.hasErrors then
		return;
	endif;
	_protocol.setLastHistoryPurgeDate(_upToDate);
	
// par 23967	app.myUtilityUA.utlRemoveCamsProcessTrans (_protocol, _upToDate, _passport);	// removes trans off allProcessedTransactions and allProcessedEventTransactions
// par 23967	if _passport.hasErrors then
// par 23967		return;
// par 23967	endif;
			
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_protocol" type="CM_CamProtocol" usage="io"/>
        <Parameter name="_upToDate" type="Date"/>
        <Parameter name="_today" type="Date"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxDeleteCamsMoveTAType" id="5daf6e73-8bc3-498d-a383-b3889b0f4463">
        <updating/>
        <source>trxDeleteCamsMoveTAType(_moveTAType : CM_CamsMoveTATypeCritieria input; _camProtocol : CM_CamProtocol io; _passport : CM_Passport input) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 04 August 2023
TFS#		: 59582
Function	:

*** Changes ***
Date			Name		TFS#		Description
20/03/2024		navcs2		ChangeRequest 60397: EUP | FR 54085 - Load Confirmation / Goods Receipt - Multiple Move transaction criteria, Event Only Trigger
****************************************************/

vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	_camProtocol.allMoveTrxCriteria.remove(_moveTAType);				// 20/03/2024	navcs2	ChangeRequest 60397
	
	app.myUtilityDA.utlDeleteCamsMoveTAType(_moveTAType, _passport);
	
	//_camProtocol.addMyMoveTrxCriteria(null);       					// 20/03/2024	navcs2	ChangeRequest 60397
	
epilog		
	self.finaliseActivityWithPassport(_passport);
end;</source>
