    <JadeMethod name="setDefaultForTouched" id="d2177a41-d4da-4dd9-b9f2-90477f8b7f4f">
        <updating/>
        <source>setDefaultForTouched() updating;
/*
Purpose:			
Date		Who		Reason
20 August 2015	cnwab1	Initial creation
*/

vars

begin
	self.alternativeIdTouched := "";
	self.damageTouched := "";
	self.dimensionsTouched := "";
	self.hazardsTouched := "";
	self.overDimensionsTouched := "";
	self.photoTouched := "";
	self.sealsTouched := "";
