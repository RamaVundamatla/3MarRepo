    <JadeMethod name="carriageTempC_lostFocus" id="9f137e25-caa7-410c-86c5-eca852b0256d">
        <updating/>
        <source>carriageTempC_lostFocus(table : CM_EntryTable input; row : Integer; rowName : String; pValue : Any) updating;
// ---------------------------------------------------------------------------
// Created:     02 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	
begin
	if pValue &lt;&gt; null then
		//	table.setValue(row, pValue.Real.userNumberFormat($CM_Temperature));
		//  AER Par 14632
		table.setValue(row, pValue.Real.asStringJMTWithPrecision(PRECISION_TEMPERATURE, false));
	endif;
	self.myAssistant.GTE_Assistant.temperatureFieldLostFocus(pValue.String, table, ETRow_CarriageTempF, false, true);
end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
        <Parameter name="row" type="Integer"/>
        <Parameter name="rowName" type="String"/>
        <Parameter name="pValue" type="Any"/>
    </JadeMethod>
    <JadeMethod name="carriageTempF_lostFocus" id="59ee46c5-2622-47f3-aa7b-f5c1f0ca4de8">
        <updating/>
        <source>carriageTempF_lostFocus(table : CM_EntryTable input; row : Integer; rowName : String; pValue : Any) updating;
// ---------------------------------------------------------------------------
// Created:     02 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	
begin
	if pValue &lt;&gt; null then
		//table.setValue(row, pValue.Real.userNumberFormat($CM_Temperature));
		//  AER Par 14632
		table.setValue(row, pValue.Real.asStringJMTWithPrecision(PRECISION_TEMPERATURE, false));
	endif;
	self.myAssistant.GTE_Assistant.temperatureFieldLostFocus(pValue.String, table, ETRow_CarriageTempC, true, false);
end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
        <Parameter name="row" type="Integer"/>
        <Parameter name="rowName" type="String"/>
        <Parameter name="pValue" type="Any"/>
    </JadeMethod>
    <JadeMethod name="clearEditControls" id="0eac39ea-bb85-473a-9435-97f47e223588">
        <source>clearEditControls();
/*
	Created on 08 February 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	tblMain.clearValues();
	tblExtra.clearValues();
	tblMain.clearAllSelected;
	tblExtra.clearAllSelected;
	
	// DVB changed 30/09/04
	//cmbCommodity.clear;
	cmbCommodity.clear();
	cmbConsignor.clear;
	cmbDestination.clear;
	cmbDischarge.clear;
	cmbTranship.clear();
	cmbISOType.clear;
	cmbOperator.clear;
	cmbBOLType.clear();
	cmbTiType.clear;
	cmbVoyage.clear;
	cmbImexStatus.clear;
	cmbAvGrade.clear();
	cmbProduct.clear();
	cmbFreightFwdr.clear();
	
	cmbBRItem.clear();
	cmbBRItem.myBookingRef := null;
	txtBookingRef.text := null;

end;</source>
    </JadeMethod>
