    <JadeMethod name="getMyRealTrackedItem" id="32040a10-3a3d-4ce3-9661-788caae52fec">
        <updating/>
        <source>getMyRealTrackedItem() : CM_TrackedItem updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 May 2009	cnwjk3	Initial creation

*/

vars
	realTI			: CM_TrackedItem;
	
begin

	if self.myTrackedItem = null then
		return null;
	elseif self.myTrackedItem.isTransient then
		realTI := app.myProxyManager.getRealObject(self.myTrackedItem).CM_TrackedItem;
	else
		realTI := self.myTrackedItem;
	endif;

	return realTI;
	
epilog

end;</source>
