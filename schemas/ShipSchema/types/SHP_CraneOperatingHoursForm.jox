    <JadeMethod name="initDataTable" id="8d0fe346-db24-4acb-9a93-17e2724658ad">
        <updating/>
        <source>initDataTable() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 March 2012	cnwndl1	Initial creation	Par 29368

*/

vars

	theDef : EntTableDef;

begin
	
	theDef := app.myController.getEntTableDef(ETDef_WorkPointOpHrsDisp);

	if theDef &lt;&gt; null then
		self.tblData.setTblDataEntRowsFromDef(theDef);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, "EntTableDef 'Work Point Op Hrs Disp' not found");
	endif;
	
	if self.isSearcherVisible then
		self.zHideSearcher();
	endif;
	
epilog

end;</source>
    </JadeMethod>
