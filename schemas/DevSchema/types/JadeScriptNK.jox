    <JadeMethod name="retroConfigJBL" id="cc362761-2c72-45ea-aacc-0861887f5aeb">
        <source>retroConfigJBL();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 February 2024	navnk30	Initial creation

*/

vars

begin
	app.initialize();
	write "2351.39".asOid().CM_Terminal.getConfig(IsRetrospectiveMode);
	write "2351.39".asOid().CM_Terminal.code;
	
	beginTransaction;
		"2351.39".asOid().CM_Terminal.setConfig(IsRetrospectiveMode, true);
	commitTransaction;
	write "2351.39".asOid().CM_Terminal.getConfig(IsRetrospectiveMode);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyWeightMeasurementType" id="ff550aad-efcc-42bd-be2e-f44678e0d085">
