    <JadeMethod name="setForCreate" id="f58e3851-ab89-4f03-9aeb-e270dbba064c">
        <updating/>
        <source>setForCreate( _proxy : CM_VehicleBookingTimeSlot ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Apr2013	cnwndl1	Initial creation	Par 31393
