    <JadeMethod name="loadReportProfiles" id="09e92c2a-7f6f-49ae-abf3-2631b389026f">
        <updating/>
        <source>loadReportProfiles(report : JadeReportWriterReport) updating;

vars
	profiles : StringArray;
	profile : String;
begin

	cmbProfiles.clear;
	
	profiles := report.getProfiles;
	
	foreach profile in profiles do
		cmbProfiles.addItem(profile);
	endforeach;
epilog
	delete profiles;
end;</source>
        <Parameter name="report" type="JadeReportWriterReport"/>
    </JadeMethod>
    <JadeMethod name="processReport" id="ca3ee1e2-b0b2-46f2-a0ca-0901911d4bba">
        <source>processReport();
/*
Changed On	Changed By	Reason
----------	----------	--------------------------------------------------
18 Mar 2010	consw1		PAR #22886 - Leaking report transients
*/
vars
	params, types : StringArray;
	i : Integer;
	cntrl : Control;
	textString : String;
	aReport : JadeReportWriterReport;
begin

	processReportFromTable();
	return;
	
	aReport := reportManager.getReport(cmbReports.text);	
	
	if aReport = null then
		app.raiseCMException2(ERR_INVALID_VALUE, "the report name ", "Contact Developer", null,null);
		return;
	endif;

	statusLine.caption := "Please wait whilst report is running";	
	
	//Set the report profile if any
	textString := cmbProfiles.text.trimBlanks;
	if textString &lt;&gt; null then
		aReport.setProfile(textString);
	endif;

	//Set the parameters from the text box cloned controls	
	aReport.getParameters(params, types);
	foreach i in 0 to params.size do
		cntrl := txtParameter.getControl(i);
		if cntrl = null then
			return;
		endif;
		textString := cntrl.TextBox.text.trimBlanks;
		if textString &lt;&gt; null then
			aReport.setParameter(params[i], textString);
		endif;
	endforeach;
	
	//Print the report
	aReport.setOutputDestination(JadeReportWriterReport.PRINTER);
	aReport.setPageOptions(Print_A4, Print_Landscape, 1, 10, 10, 10, 10, 10, false, 0);
//	aReport.setPrinterOptions(null, cbPreview.value, true, true, false, null);	
	aReport.setPreviewOptions(cbPreview.value, true, true, false, null);	

	aReport.run;
	
	statusLine.caption := "Report Finished";
	
epilog
	delete aReport;
end;</source>
    </JadeMethod>
    <JadeMethod name="processReportFromTable" id="77bce085-7944-44fd-9bb5-31257272cb54">
        <source>processReportFromTable();
/*
Changed On	Changed By	Reason
----------	----------	--------------------------------------------------
16 Mar 2010	consw1		PAR #22886 - Leaking report transients
*/
vars
	pOpCode, pVoyageCode, pBookRef, pDateStr, pTimeStr : String;
	pDateTime : TimeStamp;
	aReport : JadeReportWriterReport;
	numItems : Integer;
begin
	app.mousePointer := MousePointer_HourGlass; 

	pOpCode := tblParameter.getValueByName('operatorCode').String;
	pVoyageCode := tblParameter.getValueByName('voyageCode').String;
	pBookRef := tblParameter.getValueByName('bookingRef').String;
	pDateStr := tblParameter.getValueByName('receiveDate').String;
	pTimeStr := tblParameter.getValueByName('receiveTime').String;
	
	pDateTime.setDate(pDateStr.asDateJMT);
	pDateTime.setTime(pTimeStr.Time);
	
	if not pDateTime.isValid then
		pDateTime := null;
	endif;
	
	aReport := reportManager.getReport(cmbReports.text);	
	
	if aReport = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Report (' &amp; cmbReports.text &amp; ') not found');
		return;
	endif;

	statusLine.caption := "Please wait whilst report is running";

	//Do Select
	numItems := runBookingRefSelect(pOpCode, pVoyageCode, pBookRef, pDateTime);	

	if numItems &gt; 0 then	
		//Print the report
		aReport.setOutputDestination(JadeReportWriterReport.PRINTER);
		aReport.setPageOptions(Print_A4, Print_Portrait, 1,  0, 0, 10, 10, 0, false,Printer.Duplex_Simplex );
//		aReport.setPrinterOptions(null, cbPreview.value, true, true, false, null);	
		aReport.setPreviewOptions(cbPreview.value, true, true, false, null);	

		aReport.run;
	else
		app.msgBox("No items were found that match the selection criteria", "Report Generator", MsgBox_Information_Icon	);
	endif;
	
epilog	
	delete aReport;
	statusLine.caption := "Report Finished";
	app.mousePointer := MousePointer_Default;				
end;</source>
    </JadeMethod>
    <JadeMethod name="runBookingRefSelect" id="647fb1d9-55ee-437c-94d7-58e6b8606277">
        <source>runBookingRefSelect(opCode, voyageCode, bookingRef : String; receiveDT : TimeStamp) : Integer;

vars
	operator : CM_Operator;
	voyage : CM_Voyage;
	ti : CM_TrackedItem;
	br : CM_BookingRef;
	brDict : CM_BookingRefsByRef;
	checkReceipt : Boolean;
	num : Integer;
begin

	if receiveDT &lt;&gt; null then
		checkReceipt := true;
	endif;
	
	beginTransaction;
	exclusiveLock(app.allReportTIs);
	app.allReportTIs.clear;

	if bookingRef &lt;&gt; null then
		br := self.myTerminal.allBookingRefsByRef[bookingRef.trimRight];
		if br &lt;&gt; null then
			sharedLock(br);
			num := br.selectBookingRefTIs(opCode, voyageCode, bookingRef, receiveDT);
			commitTransaction;
			return num;
		endif;
	endif;

	if opCode &lt;&gt; null then 
		operator := app.myRoot.allOperators[opCode];
		if operator &lt;&gt; null then
			sharedLock(operator);
			num := operator.selectBookingRefTIs(self.myTerminal, voyageCode, receiveDT);
			commitTransaction;
			return num;
		endif;
	endif;

	if voyageCode &lt;&gt; null then
		voyage := self.myTerminal.lookupVoyage(voyageCode, null, false);
		if voyage &lt;&gt; null then
			sharedLock(voyage);
			num := voyage.selectBookingRefTIs(opCode, voyageCode, bookingRef, receiveDT);
			commitTransaction;
			return num;
		endif;
	endif;
	
	foreach br in self.myTerminal.allBookingRefsByRef do
		foreach ti in br.allTIs do
			if checkReceipt then
				if ti.receivedDT = null and ti.receivedDT &lt; receiveDT then
					continue;
				endif;
			endif;
			app.allReportTIs.add(ti);
		endforeach;
	endforeach;
	
	commitTransaction;
	return app.allReportTIs.size;
end;</source>
        <Parameter name="opCode" type="String"/>
        <Parameter name="voyageCode" type="String"/>
        <Parameter name="bookingRef" type="String"/>
        <Parameter name="receiveDT" type="TimeStamp"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setParameterControls" id="ee491b94-c511-497c-9c6b-c58d7f63c409">
        <updating/>
        <source>setParameterControls(report : JadeReportWriterReport) updating;
//Gets a list of the parameters of the report and creates 3 display controls for each one
//Controls are cloned from an original set of controls. 
//Controls are only cloned if they do not already exist
vars
	paramNames, paramTypes : StringArray;
	label : String;
	lblTitle, lblType, txtBox : Control;
	topValue : Real;
	i : Integer;	
begin

	report.getParameters(paramNames, paramTypes);
	
	topValue := lblParamHeading.top;
	
	foreach i in 1 to paramNames.size do
	
		//See if the controls exist. If not clone them
		txtBox := txtParameter.getControl(i);
		lblTitle := lblParameter.getControl(i);
		lblType := lblParamType.getControl(i);
		
		if txtBox = null then
			txtBox := txtParameter.loadControl(i);
		endif;
		if lblTitle = null then
			lblTitle := lblParameter.loadControl(i);
		endif;
		if lblType = null then
			lblType := lblParamType.loadControl(i);
		endif;
		
		lblTitle.Label.caption := paramNames[i].properCase;
		lblType.Label.caption := "(" &amp; paramTypes[i] &amp; ")";
		
		txtBox.top := topValue + txtBox.height + 5;
		lblTitle.top := topValue + txtBox.height + 5;
		lblType.top := topValue + txtBox.height + 5;

		txtBox.visible := true;
		lblTitle.visible := true;
		lblType.visible := true;
				
		topValue := txtBox.top;
		
	endforeach;
epilog
	delete paramNames;
	delete paramTypes;

end;</source>
        <Parameter name="report" type="JadeReportWriterReport"/>
    </JadeMethod>
    <JadeMethod name="tableMethod" id="6e3443c1-d45b-4ca1-852d-2fdb6a13d38b">
        <source>tableMethod();

vars
	entTableDef		: EntTableDef;
	theRow			: Integer;
	theTable		: CM_EntryTable;
	controller		: CMUI_Controller;
begin
	theTable := tblParameter;

	controller := app.myController;
	entTableDef := controller.getEntTableDef(ETDef_DefaultView);
	
	if entTableDef &lt;&gt; null then
		theTable.setEntTableDef(entTableDef, null, GTE_ReportForm::entTableDefSetupWarning.name);
		theTable.adjustHeight(200);
		
		//controller.comboBoxBulkRelease(cmbBulkRelease, null);
		//controller.comboBoxCarrier(cmbFiltCarrier, null);
		//controller.comboBoxConsignor(cmbFiltConsignee, null);
		//controller.comboBoxOperator(cmbFiltOperator, null, null);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'EntTableDef ReportParams not found');
	endif;
//
//
	

	tblParameter.visible := true;
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="495d076f-a0b9-4196-8a87-10a15ff0aca2">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0005479, locale);
	btnCancel.translateCaption(Xlat_0001370, locale);
	btnOK.translateCaption(Xlat_0001371, locale);
	cbPreview.translateCaption(Xlat_0001372, locale);
	lblParamHeading.translateCaption(Xlat_0001373, locale);
	lblParamType.translateCaption(Xlat_0001374, locale);
	lblParameter.translateCaption(Xlat_0001375, locale);
	lblProfiles.translateCaption(Xlat_0001376, locale);
	lblReports.translateCaption(Xlat_0001377, locale);
	statusLine.translateCaption(Xlat_0001378, locale);
end;</source>
    </JadeMethod>
