    <JadeMethod name="translateToDisplayValue" id="65058bdd-ac43-4207-8566-ba15ba91288b">
        <source>translateToDisplayValue(_value: Any): String;
/*

Date		    Who			Reason
28 January 2011	cnwas3	  	par25295
06 May 2013		cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
*/

vars

begin
	if self.myMeasurementType &lt;&gt; null then							// PAR #31155
		return inheritMethod(_value);								// PAR #31155
	endif;															// PAR #31155
	return _value.Decimal.asStringJMTWithPrecision(3, false);
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
