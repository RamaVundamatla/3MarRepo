    <JadeMethod name="cmbIconFilesBuild" id="de669094-4659-4993-a3fb-f133e55fdd0d">
        <source>cmbIconFilesBuild();
/*
Purpose:			

Date		Who		Reason
13 August 2021	navab1	TFS 50421
*/

vars
	iconFIle : CMUI_IconFile;
	root : CMUI_Root;
	idx : Integer;
begin
	root := CMUI_Root.firstInstance;
	
	self.cmbIconFiles2002.clear();
	self.cmbIconFiles2002.sorted := true;
	
	foreach iconFIle in root.allIconFilesByName where iconFIle.year = 2002 do
	
		idx := self.cmbIconFiles2002.addItemObject(iconFIle.name,iconFIle);
		self.cmbIconFiles2002.itemPicture[idx] := iconFIle.icon;
	endforeach;
	
	self.cmbIconFiles2021.clear();
	self.cmbIconFiles2021.sorted := true;
	
	foreach iconFIle in root.allIconFilesByName where iconFIle.year = 2021 do
	
		idx := self.cmbIconFiles2021.addItemObject(iconFIle.name,iconFIle);
		self.cmbIconFiles2021.itemPicture[idx] := iconFIle.icon;
	endforeach;

	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createIconFileIconFromButton" id="2d8b2d47-449e-4a49-94d1-1869fd6d2aef">
        <source>createIconFileIconFromButton();
/*
Purpose:			

Date		Who		Reason
28 September 2021	navab1	TFS 51853
*/

vars
	icon : CMUI_IconFile;
	button : CMUI_ToolbarIcon;
	newName : String;
	root : CMUI_Root;
begin

	root := CMUI_Root.firstInstance;
	
	button := self.tblData.allSelectedObjects.first.CMUI_ToolbarIcon;
	
	if button = null then
		global.beep;
		return;
	endif;

	newName := button.enabledIconNameDisk &amp; "_EN";
	
	icon := root.allIconFilesByName[newName];
	if icon = null then
		beginTransaction;
		create icon;
		icon.setForCreate(root, button.enabledIconNameDisk,newName , button.enabledIconOld, 2002, newName.Binary);
		
		button.myEnabledIconFile := icon;
		commitTransaction;
	else
		beginTransaction;
		button.myEnabledIconFile := icon;
		commitTransaction;
	
	endif;
	newName := button.enabledIconNameDisk &amp; "_DIS";
	
	icon := root.allIconFilesByName[newName];
	if icon = null then
		beginTransaction;
		create icon;
		icon.setForCreate(root, button.disabledIconNameDisk,newName , button.disabledIconOld, 2002, newName.Binary);
		
		button.myDisabledIconFile := icon;
		commitTransaction;
	else
		beginTransaction;
		button.myDisabledIconFile := icon;
		commitTransaction;
	endif;
	
	
	// ### DISK ENABLED KEY
	if button.myEnabledIconFile &lt;&gt; null then
	
		self.tblData.accessCell(self.tblData.row,13).picture := button.myEnabledIconFile.icon;
	endif;
	// ### DISK DISABLED KEY
	if button.myDisabledIconFile &lt;&gt; null then
		self.tblData.accessCell(self.tblData.row,12).picture := button.myDisabledIconFile.icon;
	endif;
	
	global.beep;
	self.tblData.deselectAll();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initialiseTable" id="13196078-7803-4119-baca-c34eeb30b1d4">
        <source>initialiseTable();
 // ### TFS 50421 17SEP2021 NAVAB1
vars
	table : CM_DataTable;
begin
	table := self.tblData;
	
	table.selectionType	:= Table.SelectMode_CurrentRow;
	table.multiSelect := ListBox.MultiSelect_Extended;
	
	table.columns := 13;
	table.rows := 0;
	
	table.addItem("Disabled Disk Name" &amp; Tab &amp; "Enabled Disk Name" &amp; Tab &amp; "Unique" &amp; Tab &amp; "Schema"&amp; Tab &amp; "Form" &amp; Tab &amp; "Button" &amp; Tab &amp; "Caption" &amp; Tab &amp; "Disabled Old" &amp; Tab &amp; "EnabledOld" &amp; Tab &amp; "DisabledNew" &amp; Tab &amp; "EnabledNew" &amp; Tab &amp; "Disabled Current" &amp; Tab &amp; "Enabled Current");
	table.fixedRows := 1;
	
	
	self.cmbIconFiles2002.height := 40;

end;
</source>
    </JadeMethod>
    <JadeMethod name="load" id="4f74101d-7753-417b-816c-480fedbeed9a">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

vars

begin

	app.initialize();

	self.initialiseTable();
	
	if app.msgBox("Populat Table?","Question",MsgBox_Yes_No) = MsgBox_Return_Yes then
		self.populateTable();
	endif;
	self.showButtons();
	
	self.cmbIconFilesBuild();
end;
</source>
    </JadeMethod>
