    <JadeMethod name="hasQueuedEntries" id="e7eb858a-893d-48dd-8154-eabaae2a8adf">
        <source>hasQueuedEntries(pReportName: String): Boolean protected;
// --------------------------------------------------------------------------------
// Created:		10 August 2000 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether a report with the specified
//				has any queue entries.
//
// Parameters:	pReportName - The name of the report.
//
// Returns:		True if the report has any queue entries, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
    theReportDefinition	: CnEcReportDefinition;

begin
	theReportDefinition	:=	app.myBaseRoot.allReportDefinitions[pReportName];
	
	return (theReportDefinition.allReportQueueEntries.cnEcIsNotEmpty());
end;</source>
        <access>protected</access>
        <Parameter name="pReportName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setIsNewEntry" id="6cf4b796-87a3-4845-893f-d005d425913a">
