    <JadeMethod name="displayDischPortForVoyage" id="71382182-8566-47d1-936e-04a7b999a941">
        <source>displayDischPortForVoyage(_voyage : CM_Voyage);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 November 2012	cnwer1	Initial creation SFW 1295

*/

vars
	lDischargePort : CM_Port;
	iter01 : Iterator;
	allPorts : CM_PortByCodeDict;
begin
	if _voyage = null then
		self.displayDischargePort();
		return;
	endif;
	
	self.myLegendTable.rows := 0;
	//self.addRow("Discharge",Red,null,true);							// PAR #30480
	self.addRow(app.getErrorString(DischargePort), Red, null, true);	// PAR #30480
	self.myLegendTable.fixedRows := 1;
	
	create allPorts transient;
	
	_voyage.allPorts.copy(allPorts);
	
	if not allPorts.includes(_voyage.myTerminal.getDefaultPort) then
		allPorts.add(_voyage.myTerminal.getDefaultPort);
	endif;
	
	iter01 := allPorts.createIterator;
	while iter01.next(lDischargePort) do
		self.addRow(lDischargePort.code.trimBlanks,lDischargePort.colour,lDischargePort,false);
	endwhile;
epilog
	delete iter01;
	delete allPorts;
end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
