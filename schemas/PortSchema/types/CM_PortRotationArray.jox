<CollClass name="CM_PortRotationArray" id="9d310075-218c-418c-a0bb-0d4dd641613b">
    <loadFactor>66</loadFactor>
    <memberType name="CM_PortRotation"/>
    <superclass name="CM_ObjectArray"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <JadeMethod name="getForPortCode" id="c5415d48-46cd-41f6-a1bc-efcad8ab6ce4">
        <source>getForPortCode(_portCode : String) : CM_PortRotation;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Dec 2023	navlw1	Bug 60597: 	CUX | EDBIC - Put /voyage/{id} RestAPI doesn't do what the swagger definition suggests

*/

vars
	portRotation : CM_PortRotation;
begin
	foreach portRotation in self do
		if portRotation.myPort &lt;&gt; null and portRotation.myPort.code = _portCode then
			return portRotation;
		endif;
	endforeach;
	return null;
epilog

end;</source>
        <Parameter name="_portCode" type="String"/>
        <ReturnType type="CM_PortRotation"/>
    </JadeMethod>
</CollClass>
