    <JadeMethod name="rol201" id="b1c551ed-ca7b-4f7d-a57b-ef28d3bb57a0">
        <source>rol201();

// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support

constants
	UserCode		= SUPERUSER_Str;
//	MachineId		= '27';
	TerminalCode	= 'DP1';
	InterfaceName	= 'Vocollect';
	
vars
	inputRequest			: String;
	outputResponse			: String;
//	machine					: CM_Machine;
	terminal				: CM_Terminal;
	tcpInterfaceAgent		: CM_TCPInterfaceAgent;
	tcpInterfaceDefinition	: CM_TCPInterfaceDefinition;
	tempStr					: String;
	startTS					: TimeStamp;
	endTS					: TimeStamp;
	interval				: TimeStampInterval;
	
begin
	startTS		:= app.actualTimeServer;		// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	tempStr		:= CrLf &amp; 'Starting ' &amp; method.qualifiedName &amp; Tab &amp; startTS.display;
	write tempStr;
	
	app.initialize;
	app.myCnCntrl.setExceptionHandlerType( CnCntrl.Exception_Handler_Jade_Debug );
	app.myPassport.setMyUser( app.myRoot.allUsers[ UserCode ] );
	
	/*
	// get the data I required to update proxy with
	machine		:= app.myRoot.allMachines[ MachineId ];
	if machine = null then
		tempStr	:= 'Did not find machine ' &amp; MachineId.display;
		write tempStr;
		return;
	endif;
	*/
	
	terminal	:= app.myRoot.allTerminals[ TerminalCode ];
	if terminal = null then
		tempStr	:= 'Did not find terminal ' &amp; TerminalCode.display;
		write tempStr;
		return;
	endif;
	tcpInterfaceDefinition	:= terminal.allInterfaceDefinitions[ InterfaceName ].CM_TCPInterfaceDefinition;
	if tcpInterfaceDefinition = null then
		tempStr	:= 'Did not find tcpInterfaceDefinition ' &amp; InterfaceName.display;
		write tempStr;
		return;
	endif;
	
	/* typical request and response strings
16:23:12.851 Response received 0,
16:22:55.586 Sending SetDown(27,DUG100009,) to jade1.cnwdmast.cnw.co.nz:52275
16:22:48.961 Response received 0,,voice 0301 1
16:22:32.429 Sending Pickup(27,DUG100009,) to jade1.cnwdmast.cnw.co.nz:52275
16:22:09.773 Response received 0,,Q,DUG100009,N,,,2200 twenty footer,voice 0304 1,voice 0301 1
16:21:35.445 Sending NextJob(27) to jade1.cnwdmast.cnw.co.nz:52275

16:18:04.101 Response received 0,,,,,,,,,
16:17:54.320 Sending NextJob(27) to jade1.cnwdmast.cnw.co.nz:52275
16:17:44.554 Response received 0,
16:16:57.976 Sending SendFaultResponse(27,2,yes) to jade1.cnwdmast.cnw.co.nz:52275
16:16:57.976 Response received 0,
16:16:40.242 Sending SendFaultResponse(27,1,yes) to jade1.cnwdmast.cnw.co.nz:52275
16:15:44.445 Response received 2,Answer the questions buddy!,,,,,,,,
16:14:03.429 Sending NextJob(27) to jade1.cnwdmast.cnw.co.nz:52275
16:13:54.507 Response received 0,,1,Are your tyres OK?,1
0,,2,Are your brakes working,1
16:13:40.539 Sending Logon(27,CNWRL1) to jade1.cnwdmast.cnw.co.nz:52275
16:06:17.039 Response received 0,,1,Are your tyres OK?,1
0,,2,Are your brakes working,1
16:06:04.273 Sending Logon(27,CNWRL1) to jade1.cnwdmast.cnw.co.nz:52275
16:05:56.367 Response received 2,Machine () not found for Terminal DP1,,,
16:05:50.054 Sending Logon(,CNWRL1) to jade1.cnwdmast.cnw.co.nz:52275
16:05:32.398 Response received 0,
16:04:55.992 Sending Initialise(CNWRL1) to jade1.cnwdmast.cnw.co.nz:52275
	*/
	
	inputRequest	:= 'Pickup(27,DOUG0000034,)';
	inputRequest	:= 'NextJob(27)';
//	inputRequest	:= 'Initialise(CNWRL1)';
	
	// Create and populate the Interface Agent
	create tcpInterfaceAgent transient;
	
	tcpInterfaceAgent.setPropertyValue( CM_TCPInterfaceAgent::returnErrorCodes.name, true );
	tcpInterfaceAgent.setPropertyValue( CM_TCPInterfaceAgent::dumpCMExceptions.name, false );
	tcpInterfaceAgent.setPropertyValue( CM_TCPInterfaceAgent::suppressWarnings.name, false );
	
	tcpInterfaceAgent.setMyInterfaceDefinition( tcpInterfaceDefinition );
	outputResponse	:= tcpInterfaceAgent.processRequestString( inputRequest );
	write 'outputResponse' &amp; Tab &amp; outputResponse.display;
	
	if app.myPassport.hasErrors then
		write 'Failed' &amp; Tab &amp; app.getErrorString( InterfaceHistory );
		app.myPassport.dumpErrorWarnings;
		return;
	endif;
	
epilog
	delete tcpInterfaceAgent;
	
	endTS		:= app.actualTimeServer;		// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	interval	:= endTS - startTS;
	tempStr		:=	CrLf &amp; 'Approximate time taken' &amp; Tab &amp; interval.display &amp;
					CrLf &amp; 'Finished ' &amp; method.qualifiedName &amp; Tab &amp; endTS.display;
	write tempStr;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="rol202" id="78f6d8d7-a0c2-4a5c-a6d8-8e3b8ae95194">
        <source>rol202();

// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support

constants
	UserCode		= SUPERUSER_Str;
	MachineId		= '27';
	TerminalCode	= 'DP1';
	InterfaceName	= 'Vocollect';
	LocalAddress	= 'jade1.cnwdmast.cnw.co.nz';
	LocalPort		= 52275;
	TcpTimeout		= 60;
	AppCopies		= 2;
	
vars
	inputRequest			: String;
	outputResponse			: String;
	requestStr				: String;
	responseStr				: String;
	machine					: CM_Machine;
	terminal				: CM_Terminal;
	tcpInterfaceDefinition	: CM_TCPInterfaceDefinition;
	realInterfaceHistory	: CM_InterfaceHistory;
	prxInterfaceHistory		: CM_InterfaceHistory;
	interfaceMsgController	: CMIF_InterfaceMsgController;
	tempStr					: String;
	startTS					: TimeStamp;
	endTS					: TimeStamp;
	interval				: TimeStampInterval;
	
begin
	startTS		:= app.actualTimeServer;		// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	tempStr		:= CrLf &amp; 'Starting ' &amp; method.qualifiedName &amp; Tab &amp; startTS.display;
	write tempStr;
	
	app.initialize;
	app.myCnCntrl.setExceptionHandlerType( CnCntrl.Exception_Handler_Jade_Debug );
	app.myPassport.setMyUser( app.myRoot.allUsers[ UserCode ] );
	
	// get the data I required to update proxy with
	machine		:= app.myRoot.allMachines[ MachineId, null ];
	if machine = null then
		tempStr	:= 'Did not find machine ' &amp; MachineId.display;
		write tempStr;
		return;
	endif;
	
	terminal	:= app.myRoot.allTerminals[ TerminalCode ];
	if terminal = null then
		tempStr	:= 'Did not find terminal ' &amp; TerminalCode.display;
		write tempStr;
		return;
	endif;
	tcpInterfaceDefinition	:= terminal.allInterfaceDefinitions[ InterfaceName ].CM_TCPInterfaceDefinition;
	if tcpInterfaceDefinition = null then
		tempStr	:= 'Did not find tcpInterfaceDefinition ' &amp; InterfaceName.display;
		write tempStr;
		return;
	endif;
	
	/* typical request and response strings
	request	"NextJob(27)"	response	"0,,Q,DOUG0000034,N,,,2200 twenty footer,voice 0105 2,voice 0108 1"
	14:47:02.265 Response received 0,,voice 0108 1
	14:47:01.562 Sending Pickup(27,DOUG0000034,) to jade1.cnwdmast.cnw.co.nz:52275
	
	request	"Pickup(27,DOUG0000034,)"	response	"0,,voice 0108 1"
	
	14:49:07.218 Response received 0,
	14:49:07.109 Sending Logoff(27) to jade1.cnwdmast.cnw.co.nz:52275
	14:49:02.171 Response received 0,
	14:49:01.937 Sending SetDown(27,DOUG0000034,) to jade1.cnwdmast.cnw.co.nz:52275
	*/
	
	inputRequest	:= 'Pickup(27,DOUG0000034,)';
	inputRequest	:= 'NextJob(27)';
	inputRequest	:= 'Logon(27,CNWRL1)';
	
	// Create the interfaceMsgController controller
	create interfaceMsgController transient;
	interfaceMsgController.setMyInterfaceDefinition( tcpInterfaceDefinition );
//	interfaceMsgController.setupFromTCPAgent( self );
	interfaceMsgController.setInputRequest( inputRequest );
	interfaceMsgController.validateRequestFormat;			// this also sets the functionName
	interfaceMsgController.setPropertyValue( CMIF_InterfaceMsgController::myMachine.name, machine );
	interfaceMsgController.setPropertyValue( CMIF_InterfaceMsgController::containerId.name, 'Doug000034' );
	
	// now get the formatted strings.
//	interfaceMsgController.createFormatedStrings( true, requestStr, responseStr );
	
	tempStr	:= CrLf &amp; requestStr.display &amp; CrLf &amp; responseStr.display;
	write tempStr;
	
	// create the proxy and update with required data
	create prxInterfaceHistory transient;
	
	prxInterfaceHistory.setPropertyValue( CM_InterfaceHistory::myMachine.name, machine );
	prxInterfaceHistory.setPropertyValue( CM_InterfaceHistory::myTCPInterfaceDefinition.name, tcpInterfaceDefinition );
	
	prxInterfaceHistory.setPropertyValue( CM_InterfaceHistory::formattedRequest.name, requestStr );
	prxInterfaceHistory.setPropertyValue( CM_InterfaceHistory::formattedResponse.name, responseStr );
	prxInterfaceHistory.setPropertyValue( CM_InterfaceHistory::functionName.name, interfaceMsgController.functionName );
	prxInterfaceHistory.setPropertyValue( CM_InterfaceHistory::rawRequest.name, inputRequest );
	prxInterfaceHistory.setPropertyValue( CM_InterfaceHistory::rawResponse.name, outputResponse );
	prxInterfaceHistory.setPropertyValue( CM_InterfaceHistory::requestTimeStamp.name, startTS );
	prxInterfaceHistory.setPropertyValue( CM_InterfaceHistory::responseStatus.name, 1 );	// 0,1 or 2
	prxInterfaceHistory.setPropertyValue( CM_InterfaceHistory::responseTimeStamp.name, app.actualTimeServer );	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	prxInterfaceHistory.setPropertyValue( CM_InterfaceHistory::userCode.name, app.getMyUserCode );
	
	tempStr	:= CrLf &amp; prxInterfaceHistory.formattedRequest.display &amp; CrLf &amp; prxInterfaceHistory.formattedResponse.display;
	write tempStr;
	
	// test the appropriate transactions.
	app.myTrxCA.trxCreateInterfaceHistory( prxInterfaceHistory, realInterfaceHistory, app.myPassport );
	if not app.myPassport.trxCompletedOK then
		tempStr	:= 'Failed' &amp; Tab &amp; app.getErrorString( InterfaceHistory );
		write tempStr;
		app.myPassport.dumpErrorWarnings;
		return;	
	endif;
	
epilog
	delete interfaceMsgController;
	delete prxInterfaceHistory;
	
	endTS		:= app.actualTimeServer;		// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	interval	:= endTS - startTS;
	tempStr		:=	CrLf &amp; 'Approximate time taken' &amp; Tab &amp; interval.display &amp;
					CrLf &amp; 'Finished ' &amp; method.qualifiedName &amp; Tab &amp; endTS.display;
	write tempStr;
	
end;
</source>
    </JadeMethod>
</Class>
