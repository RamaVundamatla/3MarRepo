    <JadeMethod name="setDetailsFromTI" id="e6cab3d2-ce24-452e-9872-af3b1571619e">
        <updating/>
        <source>setDetailsFromTI(_ti : CM_TrackedItem) updating;
/*

Date		Who		Reason
22 May 2014	cnwer1	Initial creation PAR 34174

*/

vars
	tmpOperator : CM_Operator;
begin
	if _ti &lt;&gt; null then
		tmpOperator := app.myRoot.allOperators[_ti.operatorCode];
		if tmpOperator = null then
			app.setContinueCMExceptions(false);		
			app.raiseCMException1(ERR_INVALID_OPERATOR, _ti.operatorCode, 'operator', null);
		endif;
		self.myCargoType := _ti.myCargoType;
	endif;	

	// add into collections - it should be before self.setStatus()
	self.myOperator		:= tmpOperator;
	if self.myOperator &lt;&gt; null and self.myTerminal &lt;&gt; null then
		self.myOperatorTerminal := self.myOperator.getOperatorTerminal(self.myTerminal, true);
	endif;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
