    <JadeMethod name="txtTruck_lostFocus" id="5d500dce-9a23-4f8d-85be-b0c5a1e01ea0">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtTruck_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2017	cnwndl1	Initial creation	TFS 4460

*/

vars

	errMsg : String;

begin

	if txtTruck.text.trimBlanks = null then
		txtTruck.text := lblTruck.caption.toUpper;
	elseif txtTruck.text = lblTruck.caption.toUpper then
		//nothing to do
	else
		self.findTruck( errMsg );
		
		if errMsg &lt;&gt; null then
			self.txtScanTxt.visible := false;
			self.msgBox( errMsg, app.getErrorString(Error), MsgBox_OK_Only, true );
			txtTruck.text := lblTruck.caption.toUpper;
			self.txtTruck.setFocus;
		else
			self.txtScanTxt.visible := true;
			self.txtScanTxt.lostFocus( self.txtScanTxt );
			self.txtScanTxt.setFocus; 
		endif; 
	endif;
	
	txtTruck.selStart := 0;
	txtTruck.selLength := 0;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
</GUIClass>
