    <JadeMethod name="addLocationController" id="215e42d1-c789-40e0-8d9f-b8dcdc788c01">
        <source>addLocationController(_location : CM_LocationsController);
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if not self.allLocationsControllers.includes(_location) then
		self.allLocationsControllers.atPut(1,_location);
	endif;
end;</source>
        <Parameter name="_location" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="causeUpdateDisplayEvents" id="71c06cf1-0f68-4d92-b47c-1e7ce21c5cd2">
        <source>causeUpdateDisplayEvents(_theTI: CM_TrackedItem; _lcArray: CM_LCArray) protected;
// ---------------------------------------------------------------------------
// Created:     19 March 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	locnCntrl : CM_LocationsController;
begin
	inheritMethod(_theTI, _lcArray);

	locnCntrl := _theTI.myOSBackEndLocationPd;
	if locnCntrl &lt;&gt; null then
		if CM_SlotController.hasInstance(locnCntrl) then
			app.myEventManager.createSingleObjInfoNoteEvt(locnCntrl.CM_SlotController.myBayVoyage.myCellularVoyageStructure.myVoyage,
				locnCntrl.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA), locnCntrl);
		
		elseif locnCntrl.myTerminalArea &lt;&gt; null then
			app.myEventManager.createSingleObjInfoNoteEvt(locnCntrl.myTerminalArea, 
				locnCntrl.myTerminal.getTerminalEvent(EVENT_TI_MOVE),  
				locnCntrl);
		endif;
	
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_lcArray" type="CM_LCArray"/>
    </JadeMethod>
    <JadeMethod name="changeLocation" id="7e946f61-b50f-4b56-9911-e9b7cfcc54f6">
        <source>changeLocation(_location : CM_LocationsController; _index : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 September 2018	jlgns1	Initial creation
28/09/2018 	JLGNS1	Bug 40500: STWO - Hold Planning(STWUJMT2)
*/

vars

begin
	if self.allLocationsControllers.size &lt;= _index and _index &gt; 0 then
		self.allLocationsControllers.atPut(_index,_location);
	endif;
	
epilog

end;</source>
        <Parameter name="_location" type="CM_LocationsController"/>
        <Parameter name="_index" type="Integer"/>
    </JadeMethod>
