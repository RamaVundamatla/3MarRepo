vars

begin
	return 'Rail Job Sheet';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="d4bbbc2c-f7f2-4680-bf14-1fa6a62e58f9">
        <source>initialise();
/*
Author:      Steve
Date:        12.01.00
Description: initialise 1. create in/outs for the new window and
						 2. copy any data from jobsByOrder and sortedRequests down to the appropriate
						    CM_RailJSInOutRake objects

--------------------
Fixes
*/

vars
	rjsio : CM_RailJSInOut;
begin
	rjsio := self.inouts[Rail_JSIO_Type_In];	
	if rjsio = null then
		create rjsio;
		rjsio.outwards := Rail_JSIO_Type_In;
		self.inouts.add(rjsio);
//		rjsio.jobSheet := self;
	endif;
	rjsio.initialise(self.myTerminal);
	rjsio := self.inouts[Rail_JSIO_Type_Out];	
	if rjsio = null then
		create rjsio;
		rjsio.outwards := Rail_JSIO_Type_Out;
		self.inouts.add(rjsio);
//		rjsio.jobSheet := self;
	endif;
	rjsio.initialise(self.myTerminal);
	//now check for the requests and add then to another list
	rjsio := self.inouts[Rail_JSIO_Type_Transit];	
	if rjsio = null then
		create rjsio;
		rjsio.outwards := Rail_JSIO_Type_Transit;
		self.inouts.add(rjsio);
//		rjsio.jobSheet := self;
	endif;
	rjsio.initialise(self.myTerminal);
	
	rjsio := self.inouts[Rail_JSIO_Type_Build];	
	if rjsio = null then
		create rjsio;
		rjsio.outwards := Rail_JSIO_Type_Build;
		self.inouts.add(rjsio);
//		rjsio.jobSheet := self;
	endif;
	rjsio.initialise(self.myTerminal);

end;</source>
    </JadeMethod>
</Class>
