    <JadeMethod name="valPackBulkRelease" id="c00df76d-1839-4320-889d-f7363547c733">
        <source>valPackBulkRelease(_pxyTI : CM_TrackedItem);
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		Basically when packing we can allocate the parent TI to a PACKING type bulk release.
//				Packing type bulk releases do not have jobs, requests, WLEs etc. so in here we create a temp request 
//				and pass it to the validation to check that the TI can be allocated to the chosen bulk release
//
// ---------------------------------------------------------------------------
//2/09/2019 	JLGNS1	Bug 46164: LNX - Criteria of Voyage Cutoff Code Does Not Work


vars
	realTI : CM_TrackedItem;
	tmpReleaseRequest : CM_DeliveryRequest;
	tmpBR, realTIBulkRel : CM_BulkRelease; // cnwrd1 26.5.09 ccms 1804
	aReserve : CM_ReserveDetail;
	intReq : CMIF_Request;
	theVoy : CM_Voyage;
	theOp : CM_Operator;
begin
	if (not _pxyTI.isHeldForRelease) then
		if app.myPassport.myTerminal &lt;&gt; null then
			if app.myPassport.myTerminal.getConfig(BulkReleaseReqdForPack).Boolean then
				app.raiseCMException2(ERR_INVALID_VALUE,"Bulk Release","A Release Number must be entered.",null,null);
			endif;
		endif;
		return;
	endif;
	
	//+ cnwmd1 Par 25546 - operator stop check
	theVoy := _pxyTI.myVoyage; 
	theOp := _pxyTI.myOperator;
	if theVoy &lt;&gt; null and theOp &lt;&gt; null and theOp.hasReceivalCutOffForVoyage(theVoy,_pxyTI) then //epr par 36705 2/9/15		//Bug 46164
		app.raiseCMException3(ERR_OP_CARGO_REL_HALT, theOp.code, theVoy.code, app.getErrorString(Packed).toLower, null, null);
		return;
	endif;
	
	realTI := _pxyTI.pxyGetRealObject();
	// cnwdad1 28/05/2007 - PAR #14118.
	//tmpBR := _pxyTI.allBulkReleasesAssigned[BR_TYPE_PACKING,null,null,null];
	tmpBR := _pxyTI.allBulkReleasesAssigned.getAtKeyGeq(BR_TYPE_PACKING,null,null,null);
	
	// Check if the TI is already associated (either assigned or released).  If it has not then
	// do checks
	if realTI &lt;&gt; null then		//Par 34717 / CCMS 2384
		realTIBulkRel := realTI.allBulkReleasesReleased.getAtKeyGeq(BR_TYPE_PACKING, null, null, null); // cnwrd1 26.5.09 ccms 1804 - type pack?
	endif;
	if tmpBR &lt;&gt; null and 
	  ((realTIBulkRel &lt;&gt; tmpBR) and			// PAR 19498 - At least one item has been packed, so the TI has been released
	  (realTIBulkRel &lt;&gt; null) and			//#26529 10/01/2011. Also, there is situation, when the first child is packed and therefore realTI.allBulkReleasesReleased = null. 
	  (not realTI.allBulkReleasesAssigned.includes(tmpBR))) then
	
		// PAR 18863 - Need to look at the ti collections to find the appropriate reserve for
		// this packing container.
		if realTI.allReserveDetails.size &gt; 0 then
			aReserve := realTI.allReserveDetails.first;
		//elseif realTI.allReserveDetailsReleased.size &gt; 0 then
			//aReserve := realTI.allReserveDetailsReleased.first;	// 25/06/2009 cnwar2 #20057
		else
			aReserve := tmpBR.allReserveDetails.first;
		endif;
		
		if (not CM_ReserveSelection.hasInstance(aReserve)) then
			return;
		endif;
		
		create tmpReleaseRequest transient;
		create intReq transient;
		
		aReserve.setInterfaceBP(intReq);			
		tmpReleaseRequest.setFromCMIF_Request(intReq);
		
		// we are here because we have been asigned to a packing bulk release NOW rather than previously,
		// so we need to perform some validation against the reserve detail of the bulk release that would ahve been done
		// when we drag/drop onto the bulk release form.
		// this needs to happen to the realTI as that will have the pre packing properties
		// rather than the post packing properties of the proxyTI
		// the proxyTI properties can have changed (i.e. commority) as part of the packing process and this will invalidate the BR reserve detail tests and could possibly fail.
		
		//_pxyTI.testAgainstRequest(tmpReleaseRequest);  //cnwrd1 -- par 26805 24.1.2011
						
		// PAR 26805: Should we validate against the realTI at this point, because 
		// we can have changed things on the pxyTI for how we want it to be after  
		// it has beenpacked (i.e. commodity).
		realTI.testAgainstRequest(tmpReleaseRequest); //cnwrd1 -- par 26805 24.1.2011
	endif;
	
epilog
	delete tmpReleaseRequest;	
	delete intReq;
end;</source>
        <Parameter name="_pxyTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="valPackage" id="407b5589-9a91-4fab-a398-fcb5257a000e">
        <source>valPackage(_pxyPackage, _realPackage : CM_Package);

// cnwdvb1 16 January 2003 

vars

begin

	self.raiseExceptionIfNull(_pxyPackage, 'Package Proxy');
	_pxyPackage.raiseExceptionIfNotTransient(method);

	_pxyPackage.validate(_realPackage);

end;</source>
        <Parameter name="_pxyPackage" type="CM_Package"/>
        <Parameter name="_realPackage" type="CM_Package"/>
    </JadeMethod>
    <JadeMethod name="valPackageBulk" id="051bfb49-c505-428d-90dc-6ea52feddb27">
        <source>valPackageBulk(	_sourceTi : CM_Bulk;
				_newTiIds : StringArray;
				_quantityPerId : Integer;
				_itemNettWeight : Decimal;
				_cargoType : CM_CargoType;
				_product : CM_Product;
				_operator : CM_Operator;
				_lc : CM_LocationsController;
				_passport : CM_Passport input
				);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2014	cnwndl1	Initial creation

*/

vars

	testDensity : Decimal [16,4];
	descr : String;

begin

	if _sourceTi = null then
		app.raiseCMException(Sourc_bulk_item_packa_break_bu,null,null);
		return;
	endif;
	if _sourceTi.isOffSite then	
		app.raiseCMException1(ERR_TI_NOT_ONSITE,_sourceTi.id,null,null);
		return;
	endif;
	if _newTiIds = null or _newTiIds.isEmpty then
		app.raiseCMException(Cargo_packagi_bulk_found,null,null);
		return;
	endif;
	if _quantityPerId &lt; 1 then
		app.raiseCMException(Not_packag_less_than_item,null,null);
		return;
	endif;
	if _itemNettWeight &lt;= 0 then
		app.raiseCMException(Amoun_item_value_must_greta_th,null,null);
		return;
	endif;
	if _operator = null then
		app.raiseCMException(Please_select_operator,null,null);
		return;
	endif;
	if _lc = null then
		app.raiseCMException(Location_NotFound,null,null);
		return;
	endif;
	if _cargoType = null then
		app.raiseCMException(Select_cargo_type_continu,null,null);
		return;
	else
		if _cargoType.mySystemProductType &lt;&gt; null and _cargoType.mySystemProductType.myDensityDec &lt;&gt; null then		// ### TFS 52193 22Nov2021 NAVPW1
			testDensity := _cargoType.mySystemProductType.myDensityDec.getRawValue.Decimal;							// ### TFS 52193 22Nov2021 NAVPW1
			descr := _cargoType.description;
		endif;
	endif;
	if _cargoType.hasProductTypes then
		if _product = null then
			app.raiseCMException(Please_select_cargo_type_conti,null,null);
			return;
		endif;
		if _product.myDensityDec &lt;&gt; null then																		// ### TFS 52193 22Nov2021 NAVPW1
			testDensity := _product.myDensityDec.getRawValue.Decimal;												// ### TFS 52193 22Nov2021 NAVPW1
			descr := _cargoType.description &amp;  "/" &amp; _product.description;
		endif;
	endif;
	
	if _sourceTi.getDensity &lt;&gt; testDensity then
		app.raiseCMException2(Densi_value_cargo_type_cargo_i, descr &amp; " (" &amp; testDensity.asStringJMT &amp; ")", _sourceTi.id &amp; " (" &amp; _sourceTi.getDensity.asStringJMT &amp; ")",null,null);
		return;
	endif;
	
epilog

end;</source>
        <Parameter name="_sourceTi" type="CM_Bulk"/>
        <Parameter name="_newTiIds" type="StringArray"/>
        <Parameter name="_quantityPerId" type="Integer"/>
        <Parameter name="_itemNettWeight" type="Decimal"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
