    <JadeMethod name="valReportParameterDuplicates" id="6d5133db-1a34-4109-b18a-9463c332d23b">
        <updating/>
        <source>valReportParameterDuplicates(pParameterArray:CnEcReportParameterArray):String updating;
// --------------------------------------------------------------------------------
// Created:		03 June 2000 by cnwdad2
//
// Purpose:		Validation for all of a Report's Parameters.
//
// Parameters:	The object's properties.
//
// Returns:		Null if the transaction is successful, otherwise an error message.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	outerParameterName	: String;
	innerParameterName	: String;
	outerParameterObj	: CnEcReportParameter;
	innerParameterObj	: CnEcReportParameter;

begin
	// Initialize the activity first.
	self.agentInitializeActivity();

	// Arm our base exception handlers.
	on Exception do self.agentExceptionHandler(exception);
	on LockException do self.agentLockExceptionHandler(exception);
	
	// Check for duplicate parameter names.
	
	foreach outerParameterObj in pParameterArray do
		outerParameterName	:=	outerParameterObj.parameterName;
		
		foreach innerParameterObj in pParameterArray do
			innerParameterName	:=	innerParameterObj.parameterName;

			if innerParameterObj &lt;&gt; outerParameterObj then
				if innerParameterName = outerParameterName then
					return "A parameter has already been defined with the name of '" &amp; innerParameterName &amp; "'.";
				endif;
			endif;
		endforeach;
	endforeach;
	
	return null;
end;</source>
        <Parameter name="pParameterArray" type="CnEcReportParameterArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
