    <JadeMethod name="translateForm" id="12e9a737-2d7b-466d-8cc8-8f8f0889d979">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016697, locale);
	btnClose.translateCaption(Xlat_0002861, locale);
	btnSave.translateCaption(Xlat_0002863, locale);
	btnTIAvailIN.translateCaption(Xlat_0002858, locale);
	btnTIAvailOUT.translateCaption(Xlat_0002857, locale);
	lblAvailTI.translateCaption(Xlat_0016698, locale);
	lblColor.translateCaption(Xlat_0002862, locale);
	lblRequests.translateCaption(Xlat_0016699, locale);
	magRequests.translateCaption(Xlat_0002860, locale);
end;</source>
    </JadeMethod>
</GUIClass>
