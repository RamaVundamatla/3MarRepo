        <updating/>
        <source>showDockReleaseForm(_voyage : CM_Voyage; _menuAction : CMUI_MenuAction) updating;
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 11 February 2009
//
// Implemented version: 7.7.1
// 11/2/2009 	cnwsh3 	CCMS1039 PAR18889 AMS Usability enhancements.
// 13/02/2011 	cnwdap1	PAR #26984 Prevent 1090 if user does not have correct security
//----------------------------------------------------------------------
vars
	form : CMUI_BOLReleaseForm;
begin
	form := app.loadForm(CMUI_BOLReleaseForm, CMUI_Assistant, false, false, false, self.myTerminal, _menuAction).CMUI_BOLReleaseForm;
	// PAR # 26984
	if form &lt;&gt; null then
		form.setMyCurrentVoyage(_voyage);
		form.show();
	endif;
epilog
end;</source>
