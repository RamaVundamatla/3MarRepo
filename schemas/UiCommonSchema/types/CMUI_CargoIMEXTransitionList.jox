    <JadeMethod name="setupForm" id="1f76e437-148e-400f-8eaf-5b7dd9c77246">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 March 2018	jlgsl4	TFS 37410 Import MTs IMEX transition status

*/

vars

begin
	inheritMethod();
	self.initTable();
	self.useTableSorting := true;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.minimumHeight := 200;
	self.minimumWidth := 640;
	self.frmQuery.visible := false;
	//self.splMain.stretchWidth := true;
	//self.tblData.stretchToParent := true;
	//self.tblData.stretchWidth := true;
	self.populateDataTable();
	self.mnuContextColourLegend.visible := false;

	// catch all Transition Criteria deletes, and creates &amp; updates done by child form
	self.beginClassNotification(CM_IMEXTransitionCriteria, false, Object_Create_Event, Response_Continuous, 0);
	self.beginClassNotification(CM_IMEXTransitionCriteria, false, Object_Update_Event, Response_Continuous, 0);
	self.beginClassNotification(CM_IMEXTransitionCriteria, false, Object_Delete_Event, Response_Continuous, 0);

	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnEditItem.enabled:= false;
		self.btnNew.enabled := false;
		self.btnDelete.enabled := false;
	endif;

epilog

end;</source>
    </JadeMethod>
