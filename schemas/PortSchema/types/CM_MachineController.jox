    <JadeMethod name="getMyLastKnownTerminalArea" id="b06f09b2-acec-4125-84f9-6d26d176e8d8">
        <source>getMyLastKnownTerminalArea(): CM_TerminalArea;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2019	jlgndl1	Initial creation	TFS 47954

*/

vars

	lastLocation : CM_LocationsController;

begin

	if self.myMachine &lt;&gt; null then
		lastLocation := self.myMachine.myLastKnownLocation;
	endif;
	
	if lastLocation &lt;&gt; null then
		return lastLocation.getMyTerminalArea;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_TerminalArea"/>
    </JadeMethod>
