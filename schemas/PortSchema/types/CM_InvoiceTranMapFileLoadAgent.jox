        <Parameter name="_vesselCategory" type="HMS_VesselCategory"/>
        <Parameter name="_transferType" type="CM_VoyageJobTransferType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createMoveOrResourceMap" id="8256d98c-817f-4697-a370-e34bdd81bce1">
        <updating/>
        <source>createMoveOrResourceMap(_moveType : String; _commodityMapObj : CM_CommodityMap; _tranMapObj :CM_TransServiceBroker; _move : Boolean; _brokerObj	: CM_ServiceBroker output) : Boolean updating, protected;
//** IN PROGRESS
vars
	found		: Boolean;
	className	: String;
	moveFrom	: String;
	moveTo		: String;
	resourceTypeObj : CM_ResourceType;
	proxyMoveMap	: CM_MoveServiceBroker;
	moveMapObj	: CM_ServiceBroker;
	tranTypeObj	: CM_TransactionType;
	proxyResourceMap	: CM_TransResourceServiceBroker;
	resourceMapObj	: CM_ServiceBroker;
begin
	self.getMoveDetails(_moveType, _move, moveFrom, moveTo, resourceTypeObj);
	
	if _move then
		moveMapObj := _commodityMapObj.moveMap[moveFrom, moveTo];
		if moveMapObj = null then
			create proxyMoveMap transient;
			proxyMoveMap.setProxyMSB(moveFrom, moveTo, _commodityMapObj);
			app.myTrxCA.trxCreateInvoiceTMTransaction(proxyMoveMap, moveMapObj, self.passport);
			if (not app.myPassport.trxCompletedOK) then
				self.setAllErrors('Creating move map (' &amp; _moveType &amp; '), row ' &amp; rowCount.String);
				return false;
			endif;
			createCount := createCount + 1;
		endif;
		
		_brokerObj := moveMapObj.CM_MoveServiceBroker;
		
	else
		foreach resourceMapObj in _commodityMapObj.allTransServiceBrokersByType do
			if resourceMapObj.isKindOf(CM_TransResourceServiceBroker) and
			   resourceMapObj.CM_TransResourceServiceBroker.myTransactionType = _tranMapObj.myTransactionType and	// 36559 match on transaction and resource
			   resourceMapObj.CM_TransResourceServiceBroker.myResourceType = resourceTypeObj then
				found := true;
				break;
			endif;
		endforeach;
		if not found then
			resourceMapObj := null;
		endif;

		if resourceMapObj = null then
			create proxyResourceMap transient;
			tranTypeObj := _tranMapObj.myTransactionType;
			proxyResourceMap.setProxyTSB(tranTypeObj.classNameToCreate, _commodityMapObj, tranTypeObj);
			proxyResourceMap.setResourceTypeAndBroker(resourceTypeObj, _tranMapObj);
			app.myTrxCA.trxCreateInvoiceTMTransaction(proxyResourceMap, resourceMapObj, self.passport);
			if (not app.myPassport.trxCompletedOK) then
				self.setAllErrors('Creating resource map (' &amp; _moveType &amp; '), row ' &amp; rowCount.String);
				return false;
			endif;
			createCount := createCount + 1;
		endif;
	
		_brokerObj := resourceMapObj;
	endif;
	
	return true;
epilog
	delete proxyMoveMap;
	delete proxyResourceMap;
end;
</source>
        <access>protected</access>
        <Parameter name="_moveType" type="String"/>
        <Parameter name="_commodityMapObj" type="CM_CommodityMap"/>
        <Parameter name="_tranMapObj" type="CM_TransServiceBroker"/>
        <Parameter name="_move" type="Boolean"/>
        <Parameter name="_brokerObj" type="CM_ServiceBroker" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createProductGroupMap" id="b7e1eed7-c712-4062-8033-fc443753654b">
        <updating/>
        <source>createProductGroupMap(_cargoSubtypeGroup : String; _cargoTypeObj : CM_CargoType; _serviceMapObj : CM_TIServiceMap; _productGroupMapObj : CM_ProductGroupMap output) : Boolean updating, protected;

vars
	found		: Boolean;
	isDefault	: Boolean;
	productGroupObj	: CM_ProductGroup;
	proxyGroupMap,
	productGroupMapObj	: CM_ProductGroupMap;
begin
	//product group
	self.getProductGroupDetails(_cargoSubtypeGroup, _cargoTypeObj, isDefault, productGroupObj);
	
	if productGroupObj = null then
		// Default map
		foreach productGroupMapObj in _serviceMapObj.allProductGroupMaps do
			if productGroupMapObj.myProductGroup = null then
				found := true;
				break;
			endif;
		endforeach;
		if not found then
			productGroupMapObj := null;
		endif;
	else
		productGroupMapObj := _serviceMapObj.allProductGroupMaps[productGroupObj.code];
	endif;
	if productGroupMapObj = null then
		create proxyGroupMap transient;
		proxyGroupMap.setProxy(productGroupObj, _serviceMapObj);
		app.myTrxCA.trxCreateInvoiceTMProductGroup(proxyGroupMap, productGroupMapObj, passport);
		if (not app.myPassport.trxCompletedOK) then
			self.setAllErrors('Creating product group map (' &amp; _cargoSubtypeGroup &amp; '), row ' &amp; rowCount.String);
			return false;
		endif;
		createCount := createCount + 1;
		
	endif;
	
	
	_productGroupMapObj := productGroupMapObj;
	return true;
epilog
	delete proxyGroupMap;
end;
</source>
        <access>protected</access>
        <Parameter name="_cargoSubtypeGroup" type="String"/>
        <Parameter name="_cargoTypeObj" type="CM_CargoType"/>
        <Parameter name="_serviceMapObj" type="CM_TIServiceMap"/>
        <Parameter name="_productGroupMapObj" type="CM_ProductGroupMap" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createProductMap" id="c7f084ff-9b28-4d3c-9a5e-3efa52d2f06a">
        <updating/>
        <source>createProductMap(_cargoSubtype : String; _cargoTypeObj : CM_CargoType; _productGroupObj : CM_ProductGroup; _productGroupMapObj : CM_ProductGroupMap; _productMapObj : CM_ProductMap output) : Boolean updating, protected;

vars
	found		: Boolean;
	isDefault	: Boolean;
	productObj	: CM_Product;
	proxyMap,
	productMapObj	: CM_ProductMap;
begin
	//product group
	self.getProductDetails(_cargoSubtype, _productGroupObj, _cargoTypeObj, isDefault, productObj);
	
	if productObj = null then
		// Default map
		foreach productMapObj in _productGroupMapObj.allProductMaps do
			if productMapObj.myProduct = null then
				found := true;
				break;
			endif;
		endforeach;
		if not found then
			productMapObj := null;
		endif;
	else
		productMapObj := _productGroupMapObj.allProductMaps[productObj.code];
	endif;
	if productMapObj = null then
		create proxyMap transient;
		proxyMap.setProxy(productObj, _productGroupMapObj);
		app.myTrxCA.trxCreateInvoiceTMProduct(proxyMap, productMapObj, passport);
		if (not app.myPassport.trxCompletedOK) then
			self.setAllErrors('Creating product map (' &amp; _cargoSubtype &amp; '), row ' &amp; rowCount.String);
			return false;
		endif;
		createCount := createCount + 1;
		
	endif;
	
	
	_productMapObj := productMapObj;
	return true;
epilog
	delete proxyMap;
end;
</source>
        <access>protected</access>
        <Parameter name="_cargoSubtype" type="String"/>
        <Parameter name="_cargoTypeObj" type="CM_CargoType"/>
        <Parameter name="_productGroupObj" type="CM_ProductGroup"/>
