    <JadeMethod name="getPrevSealNum" id="aecba679-84c8-4d94-8002-629c7e87700e">
        <source>getPrevSealNum():String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 September 2010	cnwndl1	Initial creation

*/

vars

	sealType : CM_SealType;
	sealTi : CM_SealTI;

begin

	// Do we have data stored in the latest version of the way we store operator seal data?
	// If so return the previous value.
	sealType := app.myRoot.getSealType( SealType_Operator );
	if sealType &lt;&gt; null then
		sealTi := self.getSealTI( sealType );
		if sealTi &lt;&gt; null then
			return sealTi.previousSeal;
		endif;
	endif;
	
	//default behaviour if nothing new found.
	return prevSealNum;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSealNum" id="6f2dc720-6869-40e1-b6f2-65fc1dd9134f">
