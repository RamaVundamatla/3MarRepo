    <JadeMethod name="verifySelf" id="8c609220-a5af-4fca-98cd-855a3846fa95">
        <updating/>
        <source>verifySelf() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 August 2008	cnwrd1	Initial creation

*/

vars
	existingItem		: CM_TrackedItem;
	site				: Integer;
	trxStateEntered		: Boolean;
begin

	
	if id.trimBlanks = null then
		app.raiseCMException2(ERR_FIELD_VALUE,id, 'ID', ETRow_Id, self);
	endif;
	
	//th2 for PAR13553 - can already be in transaction state if the user
	//clicks on the 'save and verify' button
	if (not process.isInTransactionState) then
		trxStateEntered := true;
		beginTransaction;	//par 13451 cnwrs1 Feb 2007 this should not be necassary as verifies should be non updating
	endif;
	
	self.verifyOwner();
	
	self.verifyCargoTypeDescr();		// PAR21198 reinstated so if no hook code it will still try and determine cargo type
	//self.setCargoTypeFromDescr();
	self.verifyOpStatus();
	if self.cargoType = TI_CargoType_Container then
		self.verifyAsContainer();
	elseif self.cargoType = TI_CargoType_Generator then
		self.verifyAsGenerator();
	elseif self.isWagon then
		self.verifyAsWagon;
	else
		self.verifyAsTrailer();
	endif;
	
	// self.verifyFrom();
	/*
	self.verifyISOType();
	self.verifyCarrier();
	self.verifyCommodity();
	self.verifyConsignee();
	self.verifyConsignor();
	self.verifyIMEXStatus(terminal);
	self.verifyPorts(terminal);
	self.verifyHazards();
	self.verifyCompany(terminal);
	self.verifyOperator();
	self.verifyProduct();
	self.verifyVolume();
	self.verifyTemperature();	
	voyage := self.verifyVoyage(terminal, site);
	self.verifyLocation(terminal, voyage, site);
	*/
	
	if trxStateEntered then
		commitTransaction;
	endif;

end;</source>
    </JadeMethod>
