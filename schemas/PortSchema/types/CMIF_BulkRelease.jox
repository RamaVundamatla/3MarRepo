    <JadeMethod name="isContainer" id="71f63523-7dbf-4b43-a0e4-1dc65bf546bd">
        <source>isContainer(): Boolean protected;
// --------------------------------------------------------------------------------
// Created:		05 May 2009 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myCargoType = null then
		return false;
	else
		return (self.myCargoType.id = TI_CargoType_Container);
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="releaseOffSite" id="e6d604a6-1ae8-43bb-9b93-3b7d843cb49e">
        <updating/>
        <source>releaseOffSite(_realBulkRelease: CM_BulkRelease input; _passport: CM_Passport input) updating;
//------------------------------------------------
// Created: 07 April 2006 By: cnwgd1
//------------------------------------------------
vars
	tmpTI 					: CM_TrackedItem;
	tmpTISet 				: CM_TISet;
begin

	if _realBulkRelease = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _realBulkRelease');
		return;
	endif;
	
	if self.myVehicle = null then
		self.setVehicle();
	endif;

	if self.myVehicle = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null vehicle');	
		return;
	endif;
	
	//TH2 for par 13700 - note these are pxy TIs - some will be splittable, others not
	//some may not be splitable, but still have had their quantity or weight updated 
	//in the CMUI_ReleaseEntryForm
	foreach tmpTI in self.allTrackedItems do
		tmpTI.splitAndReleaseToRoad(_realBulkRelease, self, _passport);
	endforeach;
	
	//PAR15888 cnwsh3
	//Set to Complete after we have finished releasing the cargo items
	_realBulkRelease.setStatus(BR_COMPLETE, false, false);
	
	// create the vehicle visit record for releasing truck
	//th2 for PAR13700 moved outside to calling method - to include multiple TIs where they are proxies
	create tmpTISet transient;
	tmpTI := _realBulkRelease.allTrackedItemsReleased.first;
	if tmpTI &lt;&gt; null and tmpTI.pxyIsProxy() then
		foreach tmpTI in _realBulkRelease.allTrackedItemsReleased do
			tmpTISet.add(tmpTI.pxyGetRealObject);
		endforeach;
	else//real TIs
		_realBulkRelease.allTrackedItemsReleased.copy(tmpTISet);
	endif;
	
	self.myVehicle.createVisitRecord(self, tmpTISet, null);	
epilog
	delete tmpTISet;
end;</source>
        <Parameter name="_realBulkRelease" type="CM_BulkRelease" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setVehicle" id="90edd102-d70c-42bf-ad9f-e4e05b5c1a15">
        <updating/>
        <source>setVehicle() updating, protected;
//------------------------------------------------
// Created: 07 April 2006 By: cnwgd1
//------------------------------------------------
vars
	pxyVehicle : CM_Vehicle;
begin
	if self.myVehicle &lt;&gt; null then
		return;
	endif;
	
	if self.myCarrier = null then
		self.myCarrier := app.myRoot.allCarriers[self.carrierCode];
	endif;
	
	self.myVehicle := self.myTerminal.vehicles[self.transportId, ""];
	
	if self.myVehicle = null then
	
		create pxyVehicle transient;
		pxyVehicle.setProxy(self.transportId, null, null, 0, self.myCarrier, self.state, false, self.myTerminal);

		app.myUtilityCA.utlCreateVehicle(pxyVehicle, self.myVehicle, app.myPassport);
	endif;
	
epilog
	delete pxyVehicle;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateProxy" id="588e0283-b2c3-4f04-8daf-21e1ba152291">
        <updating/>
        <source>updateProxy(pProxyBulkRelease : CM_BulkRelease io) updating;
// ---------------------------------------------------------------------------
// Created:     22 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
	tmpOperator			: CM_Operator;	
begin
	
	//epr par 30703 15/11/12
	if self.type = BR_TYPE_BOL then
		if self.myTerminal.getConfig(GateInAutoVisitNo).Boolean  then
			self.releaseNo		:=  self.myTerminal.gatePassNextSeqNumber;
		else
			if self.releaseNo = null then
				self.releaseNo := self.myTerminal.getBulkReleaseNextSeqNumber().toUpper;
			endif;
		endif;
	endif;
	
	if self.operatorCode &lt;&gt; null then
		tmpOperator := app.myRoot.allOperators[self.operatorCode];
		if tmpOperator = null then
			app.raiseCMException1(ERR_INVALID_OPERATOR, self.operatorCode, ETRow_Operator, null);
		endif;
	endif;
	//th2 adds for PAR 13700 - should be a seperate config to control this for 7.5.2
	/*if self.type = BR_TYPE_BOL and 
	   app.getMyTerminalConfigDO_NOT_USE(GateInAutoVisitNo).Boolean  and 
	   (self.releaseNo = null or self.releaseNo = app.getErrorString(BOLNumber_AutoGen)) then
		self.releaseNo		:= app.getMyTerminalDO_NOT_USE.gatePassNextSeqNumber;
	endif;*/
	
	pProxyBulkRelease.setFromCMIFBulkRelease(self);

	pProxyBulkRelease.requests.purge;
	if self.type = BR_TYPE_ROAD 
	   or self.type = BR_TYPE_SHIP
	   or self.type = BR_TYPE_BOL then
		self.createRequests(pProxyBulkRelease);
	endif;

	pProxyBulkRelease.allReserveDetails.purge;
	pProxyBulkRelease.allReservePackingChildren.purge;
	
	//PAR15839 Not sure why we needed to exclude BR_TYPE_BOL from this.... cnwsh3 08/02/2008
	//if not self.type = BR_TYPE_BOL then
	self.createReserves(pProxyBulkRelease); // ### &lt;&lt;&lt;&lt;&lt; CCMS 1282
	//endif;
	
	self.myProxyBulkRelease := pProxyBulkRelease;
end;</source>
        <Parameter name="pProxyBulkRelease" type="CM_BulkRelease" usage="io"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="4cd8971d-9630-4795-8e61-dee4df84942a">
        <updating/>
        <source>validateForCreate(_passport: CM_Passport input): Boolean updating;
// --------------------------------------------------------------------------------
// Created:		08 May 2009 by cnwdad1
//
// Purpose:		Standard validation method when receiver is created.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
// cnwdad1 08/05/2009 - CCNS 1735.
	if app.isSubTerminalsOn(self.myTerminal) then
		if self.mySubTerminal = null
		and not self.myTerminal.getConfig(IsSubTerminalAreaDefined).Boolean	//28 Nov 2014	NDL	Par 35295
		then
		//	app.raiseCMException1(REQUIRED_FIELD, app.getString(SubTerminal_GC), ETRow_MySubTerminal, null);
			app.raiseCMException1(Input_required_field_Required, app.getString(SubTerminal_GC), ETRow_MySubTerminal, null); // cnwdb2	PAR 35364
		endif;
	endif;
	
	return inheritMethod(_passport);
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForGCRelease" id="2dca09b2-f16b-425f-8273-fa7b7fefa12f">
        <updating/>
        <source>validateForGCRelease(_passport : CM_Passport input) updating;
//------------------------------------------------
// Created: 07 April 2006 By: cnwgd1
//------------------------------------------------
vars
	totalRequested,
	rem,
	numDel : Integer;
	tmpTI : CM_TrackedItem;
	tmpBR : CM_BulkRelease;
	control : CMIF_TIUpdateController;
begin

	if self.myTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal', ETRow_MyTerminal, null);
		app.raiseCMException(Input_required_field_terminal, ETRow_MyTerminal, null); // cnwdb2	PAR 35364
		
		return;
	endif;

// This doesn't need to be done twice.
//	self.myTerminal.validateBulkReleaseNumber(self.myProxyBulkRelease, 'Gate Pass');	
	
	if self.myVoyage = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Voyage', ETRow_Voyage, null);
		app.raiseCMException(Input_required_field_voyage, ETRow_Voyage, null); // cnwdb2	PAR 35364
	endif;	
		
	if self.allTrackedItems.isEmpty then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Mark', null, null);
		app.raiseCMException(Input_required_field_Mark, null, null); // cnwdb2	PAR 35364
	else
		control := app.createTIUpdateControl(TI_UPDMODE_RELEASE, null, null);
		control.isGeneralCargoRelease := true;
		foreach tmpTI in self.allTrackedItems do
			//PAR15839 
			//Need to check each Cargo Item for validity so reassign as we iterate through the set.
			control.myRealTrackedItem := tmpTI.pxyGetRealObject();
			if tmpTI.site &lt;&gt; TI_SITE_ONSITE then
				app.raiseCMException1(ERR_TI_NOT_ONSITE, tmpTI.id, null, null);
			else
				tmpTI.validateTrackedItem(control, _passport);
			endif;
			rem := rem + tmpTI.quantity;		
		endforeach;
	endif;

	if (not self.dateTimeIn.isValid()) then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Date/Time In', null, null);
		app.raiseCMException(Input_required_field_dateTimIn, null, null);// cnwdb2	PAR 35364
	endif;		
	if (not self.dateTimeOut.isValid()) then
//		app.raiseCMException1(REQUIRED_FIELD, 'Date/Time Out', null, null);
		app.raiseCMException(Input_required_field_dteTimOut, null, null); // cnwdb2	PAR 35364
	endif;

		// DVB Users did not like having to change date every time.
	if self.dateTimeIn.isValid 
	and self.dateTimeOut.isValid 
	and (self.dateTimeIn &gt; self.dateTimeOut) then
		app.raiseCMException1(AutoScheduleDateError, "The Date/Time In must be before the Date/Time Out", null, null);
	endif;												
	
	totalRequested := self.getTotalRequested();
	if totalRequested = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Quantity', null, null);
		app.raiseCMException(Input_required_field_quantity, null, null); // cnwdb2	PAR 35364
	elseif totalRequested &lt; 1
	or totalRequested &gt; rem then
		app.raiseCMException(Quanti_must_excess_total_remai, ETRow_Quantity, null);	
	endif;	

	if self.userPickedUp = null then
	///	app.raiseCMException1(REQUIRED_FIELD, 'Received By', null, null);
		app.raiseCMException(Input_required_field_recivedBy, null, null); // cnwdb2	PAR 35364
	endif;	

	if self.myLoadingCompany = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Loader', ETRow_Loader, null);
		app.raiseCMException(Input_required_field_loader, ETRow_Loader, null); // cnwdb2	PAR 35364
	endif;			

	if self.releaseNo = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Visit Number', null, null)
		app.raiseCMException(Input_required_field_visitNumb, null, null); // cnwdb2	PAR 35364
	endif;

	if self.myUser = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Delivered By', null, null);
		app.raiseCMException(Input_required_field_deliverBy, null, null); // cnwdb2	PAR 35364
	endif;				

	if self.transportId &lt;&gt; null then
		self.myVehicle := self.myTerminal.vehicles[self.transportId, ""];
		if self.myVehicle = null then
			app.raiseCMWarning1(VB_NEW_VEHICLE, self.transportId, ETRow_RegNumber, null, self.myVehicle);
		elseif self.myVehicle.visitRecords.includesKey(self.dateTimeIn) then
			app.raiseCMException1(BookingExists, 'Truck (' &amp; self.transportId &amp; ') at ' &amp; self.dateTimeIn.shortCurrentLocaleFormat, null, null);
		endif;
	else
	//	app.raiseCMException1(REQUIRED_FIELD, 'Truck Number', ETRow_RegNumber, null);
		app.raiseCMException(Input_required_field_truckNum, ETRow_RegNumber, null); // cnwdb2	PAR 35364
	endif;

	if self.myCarrier = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Trucking Company', ETRow_Carrier, null);
		app.raiseCMException(Input_required_field_truckComp, ETRow_Carrier, null); // cnwdb2	PAR 35364
	endif;	

	if self.deliveryReleaseNumber = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Work Number', null, null);
	else
		tmpBR := self.myTerminal.allBulkReleasesByDelRelNo[self.deliveryReleaseNumber];
		if tmpBR &lt;&gt; null 
		and tmpBR &lt;&gt; self.myProxyBulkRelease.pxyGetRealObject() then
			app.raiseCMException2(ERR_INVALID_VALUE, 'Work Number', "'" &amp; self.deliveryReleaseNumber &amp; "' is already in use by release " &amp; tmpBR.code, null, null);
		
		endif;
	endif;			

	if self.gate = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Gate', null, null);
		app.raiseCMException(Input_required_field_gate, null, null);// cnwdb2	PAR 35364
	endif;						

epilog
	delete control;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="343ed2b6-4e6c-4e7a-8dbf-95d5092769ba">
        <updating/>
        <source>validateForUpdate(_passport: CM_Passport input): Boolean updating;
// --------------------------------------------------------------------------------
// Created:		08 May 2009 by cnwdad1
//
// Purpose:		Standard validation method for updates.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
// cnwdad1 08/05/2009 - CCNS 1735.
	if app.isSubTerminalsOn(self.myTerminal) then
		if self.mySubTerminal = null
		and not self.myTerminal.getConfig(IsSubTerminalAreaDefined).Boolean	//28 Nov 2014	NDL	Par 35295
		then
		//	app.raiseCMException1(REQUIRED_FIELD, app.getString(SubTerminal_GC), ETRow_MySubTerminal, null);
			app.raiseCMException1(Input_required_field_Required, app.getString(SubTerminal_GC), ETRow_MySubTerminal, null); // cnwdb2	PAR 35364
		endif;
	endif;
	
	return inheritMethod(_passport);
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="verifyEDIDataTIs" id="9295e7bc-cde5-4238-9ee0-98ab3325169d">
        <source>verifyEDIDataTIs(_passport : CM_Passport input) : Boolean;
/*

Date		Who		Reason
07 September 2016	cnwer1	Initial creation TFS 2606

*/

vars
	release, pxyRelease	: CM_BulkRelease;
	oldStatus, newStatus: Integer;
	doPartial : Boolean;
	ediTI : CM_EDITrackedItem;
begin
	// the CMIF has a reference to the original EDITI so we can set the user object if we get any errors
	on CM_Exception do app.handleCMExceptionUserObject (exception.CM_Exception, ediTI);
	
	foreach ediTI in self.allEDITrackedItems do	
		if ediTI.status = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING or 
		ediTI.status = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X or 
		ediTI.status = CM_EDITrackedItem.EDI_STATUS_DBLOADED then
			return false;
		endif;
	endforeach;
	
	release	:= self.myTerminal.getBulkReleaseFromCode(self.releaseNo);
	doPartial	:=  self.myTerminal.getConfig(EdiReleaseAllowPartial).Boolean;	
	if self.action = CM_EDITrackedItem.EDI_ACTION_DELETE then
		if release = null then
			if doPartial then
				app.raiseCMWarning1(ReleaseRequest_DoesNotExist, self.releaseNo, ETRow_ReleaseRequestNumber, null, null);
			else
				app.raiseCMException1(ReleaseRequest_DoesNotExist, self.releaseNo, ETRow_ReleaseRequestNumber, null);
			endif;
		else
			app.myValDA.valBulkRelease(release, _passport);
		endif;
	else
		// we do not care if the action is an add or update if the release
		// request exists it is assummed to be an update else an add
		if release = null then 
			// create validation transaction
			create pxyRelease transient;								// par 28756
			
			pxyRelease.setFromCMIFBulkRelease(self);		// par 28756
			
			// create validation
			app.myValCA.valBulkRelease(pxyRelease, null, _passport); 	// par 28756
		else 
			// use the existing proxy if it already exists.
			pxyRelease		:= release.pxyGetProxyObject();
			
			if pxyRelease = null then
				// create a suitable proxy
				beginLoad;
				pxyRelease	:=	release.pxyCreateUpdateProxy();
				endLoad;
			endif;
			//cnwmc5 - 14 Nov 2013 - PAR 32086
			release.allPackLocations.copy(self.allPackLocations);
			
			// update this proxy with the EDI Data values, these might have
			// been changed from the loaded values via edit functionality.
			pxyRelease.setFromCMIFBulkRelease(self);
			
			// update validation
			app.myValUA.valBulkRelease(pxyRelease, null, _passport);  //cnwrd1 par 25594 10.12.2010
		endif;				
	endif;

	// now update the EDITI status
	foreach ediTI in self.allEDITrackedItems do
		oldStatus 	:= ediTI.status;
		newStatus	:= oldStatus;
	
		if _passport.hasErrors then 
			// got some new errors
			newStatus := CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS;
		elseif _passport.hasWarnings then
			// got some new warnings
			if oldStatus &lt;&gt; CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS then 
				// did not already have verify errors
				newStatus := CM_EDITrackedItem.EDI_STATUS_VERIFIED_WARNINGS;
			endif;				
		else
			// no new errors/warnings
			if oldStatus &lt;&gt; CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS and 
			   oldStatus &lt;&gt; CM_EDITrackedItem.EDI_STATUS_VERIFIED_WARNINGS then 
				// did not already have verify errors/warnings
				newStatus := CM_EDITrackedItem.EDI_STATUS_VERIFIED;	
			endif;
		endif;		

		if newStatus &lt;&gt; oldStatus then
			app.myTrxUA.trxUpdateEDITIStatus (ediTI, newStatus, _passport);
		endif;
	endforeach;
	
	return true;
epilog
	endLoad;
	//epr TFS 2606 this is verify ok to delete proxy straight after use
	delete pxyRelease;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
