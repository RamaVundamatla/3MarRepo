Once Jade 6 is here rename to CM_VoyageTiTransaction</text>
    <DbClassMap file="transact"/>
    <ExplicitInverseRef name="myStockMovement" id="5ce1df6c-0e60-44f5-a0a5-1bc8450627a7">
