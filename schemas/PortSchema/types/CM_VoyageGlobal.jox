    <JadeMethod name="getMyVessel" id="af80ecbf-0d31-4238-a620-852503df49ae">
        <source>getMyVessel() : CM_Vessel;
//--------------------------------------------------------------
//Created: 30 June 2003 By: cnwgd1
//--------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
23/09/2019 	jlgka1 	TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
============================================================================*/
vars
	vesselObj	: CM_Vessel;
	failedDAC  :CM_DataAccessController;

begin	
	if self.myVessel &lt;&gt; null then
		return self.myVessel;
	endif;
	
	// it not set then try and look up for backwards copatability
	if self.vesselCode &lt;&gt; null then
		vesselObj	:=	app.myRoot.allVessels[self.vesselCode];
		
		if vesselObj &lt;&gt; null and vesselObj.canUserAccessSelf(null, failedDAC,app.myPassport) then
			return vesselObj;
		endif;
	endif;
	
	return null;
end;</source>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
