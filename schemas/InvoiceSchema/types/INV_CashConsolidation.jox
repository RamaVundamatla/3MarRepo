    </JadeMethod>
    <JadeMethod name="doBtnManInvOK" id="85fdc8c1-8d49-4914-83cd-170c13970854">
        <source>doBtnManInvOK();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 August 2019	jlgndl1	Initial creation	TFS 44261

*/

vars

	cashPayment : CM_CashPayment;
	pxyInvLine : CM_InvoiceLine;
	invLineType : CM_InvoiceLineDesc;
	cashInvoice : CM_Invoice;
	newInvLine : CM_InvoiceLine;
	theReturn : Integer;
	qty : Integer;
	amount : Decimal[23,6];
	msg : String;

begin

	cashPayment := self.tblUnassCashP.allSelectedObjects.first.CM_CashPayment;
	cashInvoice := cashPayment.getInvoiceForManualAssign();
	invLineType := self.cmbInvLineType.listObject.CM_InvoiceLineDesc;
	qty := self.txtQtyManual.text.Integer;
	amount := self.txtFinancial.text.asDecimalJMT;
	
	if cashPayment = null then
		msg := app.getErrorString( Unassig_cash_payment_selecte );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		return;
	endif;
	
	if cashInvoice = null then
		msg := app.getErrorString( Invoic_not_found_unassi_paymen );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		return;
	endif;
	
	if invLineType = null then
		msg := app.getErrorString( Invoi_line_type_null_must_prov );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		return;
	endif;
	
	create pxyInvLine transient;
	pxyInvLine.setForCreate(	0,
								true,
								self.txtNarration.text,
								invLineType,
								cashInvoice,
								cashInvoice.debtor,
								cashInvoice.bank,
								self.txtQtyManual.text.Integer,
								app.actualTimeServer()
								);
	pxyInvLine.setTrackedItemOnly( self.myCurrentTrackedItem );

	while true do
	
		app.myTrxUA.trxCashPaymentsCreateInvLine( cashPayment, pxyInvLine, qty, amount, newInvLine, app.myPassport );
		if app.myPassport.trxCompletedOK then
			if newInvLine&lt;&gt; null then
				self.tblCargoInvL.addObject( newInvLine );
			endif;
			break;
		else
			theReturn := app.showErrorWarningDialog("Cash Consolidation - Assign Manual", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		
		break;
		
	endwhile;

	self.showFrmManual( false );

epilog

	delete pxyInvLine;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnUnassign" id="25512274-df40-407d-86f5-c2f93ff1e8d3">
        <source>doBtnUnassign();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 August 2019	jlgndl1	Initial creation	TFS 44261

*/

vars

	msg : String;
	obj : Object;
	cashPayment : CM_CashPayment;
	cashPaymentSet : CM_CashPaymentSet;
	theReturn : Integer;

begin

	if self.myCurrentTrackedItem = null then
		msg := app.getErrorString( No_Cargo_selected );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		return;
	endif;
	
	if self.myCurrentInvoiceLine = null then
		msg := app.getErrorString( Invoice_line_selected );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		return;
	endif;
	
	create cashPaymentSet transient;
	foreach obj in self.tblInvLineCashP.allSelectedObjects do
		if obj.isKindOf( CM_CashPayment ) then
			cashPaymentSet.add( obj.CM_CashPayment );
		endif;
	endforeach;
	if cashPaymentSet.isEmpty then
		msg := app.getErrorString( Assigne_cash_payment_selecte );
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );
		return;
	endif;
	
	while true do
	
		app.myTrxUA.trxCashPaymentsConsolidate( cashPaymentSet, null, app.myPassport );
		if app.myPassport.trxCompletedOK then
			self.refreshObjectDisplay( self.myCurrentInvoiceLine );
			break;
		else
			theReturn := app.showErrorWarningDialog("Cash Consolidation - Unassignm", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknowledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		
		break;
		
	endwhile;
	
epilog

	delete cashPaymentSet;
	self.enableActionButtons();

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnUnselect" id="1e3edf22-06a0-42f7-8384-614f065f4303">
