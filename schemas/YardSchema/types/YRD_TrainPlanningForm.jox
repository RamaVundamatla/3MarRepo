    <JadeMethod name="frmGridArea_mouseMove" id="f2b032e1-6ce4-460c-9794-530409da3876">
        <controlMethod name="Frame::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frmGridArea_mouseMove(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
//
// Purpose:		
//
// Parameters:  
//
// Returns:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// ---------------------------------------------------------------------------
vars

begin
	if button &lt;&gt; 1 then
		return;
	endif;

	self.myCurrentGridAreaFrame := frame.CMUI_GridAreaFrame;

	if app.dragDetected(x, y, origXPos, origYPos) then
		if shift.isControlKeyPressed then
			self.dragSelectStart(frame.CMUI_GridAreaFrame, x, y);
		else
			self.gridAreaMouseMoveEvent(button, x, y);
		endif;
	endif;
	
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
