//
vars
	toolbar	: CMUI_Toolbar;

begin
	toolbar := self.frmSearchToolbar;
	toolbar.addButton(self.btnSearchCollaps, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSearchExpand, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);

	inheritMethod();

	self.mnuTblVShowHideSearch.visible := false;
	self.btnCloseSearchTV.visible := false;
	
	self.btnSaveBase.visible := false;
	self.btnCancelBase.visible := false;

end;</source>
