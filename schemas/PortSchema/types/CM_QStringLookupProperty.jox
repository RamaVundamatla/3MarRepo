// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	return inheritMethod(_value);
end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
