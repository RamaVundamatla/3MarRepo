<Class name="CM_HumidReading" id="de85f5b6-0b43-478f-9485-e2b9e2f57015">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="tempreading"/>
    <PrimAttribute name="dateTime" id="8578cebf-6cae-4caa-bf80-42c26cccc133">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="humidity" id="61405354-fb7d-4447-8a29-9aa0aebdb06f">
        <precision>23</precision>
        <scaleFactor>2</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myHumidityReading" id="99948cb3-12c8-4795-9dc7-3bcb75424f21">
        <embedded/>
        <type name="CM_HumidityReading"/>
        <access>readonly</access>
        <Inverse name="CM_HumidityReading::myHumidReading"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myTIReeferProperties" id="a9529171-8c47-4db9-95b2-41e0c452a0f4">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_TIReeferProperties"/>
        <access>readonly</access>
        <Inverse name="CM_TIReeferProperties::allHumidityReadings"/>
    </ExplicitInverseRef>
    <PrimAttribute name="userId" id="fcdce64f-b4fd-4a55-99fb-585c260ddd34">
        <length>11</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="cloneForTrackedItemRefs" id="34c67149-d11a-4195-a2c2-df8622812bcb">
        <updating/>
        <source>cloneForTrackedItemRefs(_ti : CM_TrackedItem) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/03/2015	cnwdap1		Initial creation PAR #35874 TFS 265
//
vars

begin
	self.myTIReeferProperties := _ti.myReeferProperties;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getDisplayHumidity" id="bdbaf4ee-9931-4523-95d1-568a776318cf">
        <source>getDisplayHumidity() : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/03/2015	cnwdap1		Initial creation PAR #35874 TFS 265
//
vars

begin
	if self.getHumidity = NULL_HUMIDITY then
		return "null";
	endif;
	
	return self.getHumidity.String &amp; Space &amp; CN_PERCENT;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayHumidityValue" id="bd246fe1-d2f3-4952-90f4-2778ccf52f0f">
        <source>getDisplayHumidityValue() : String;
//
// Purpose:			Return just the numeric value of the humidity reading as a string
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/032015	cnwdap1		Initial creation PAR #35874 TFS 265
//
vars

begin
	if self.getHumidity = NULL_HUMIDITY then
		return null;
	endif;
	
//	return self.getHumidity.String;
	return self.getHumidity.asStringJMT;		//25 Jun 2020	NDL	TFS 49669 
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHumidity" id="50865e06-783c-4637-8c11-f7e4c7a3f7ea">
        <source>getHumidity():Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 April 2020	jlgndl1	Initial creation	TFS 47958

*/

vars

begin

	//All Humidity display fields are limited to Decimal 6,2  so don't returm bigger than that
	if self.humidity &gt; 999.99 then
		return 999.99;
	endif;

	return self.humidity;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="d8dc7065-d224-4025-900a-0b15cbeb54d0">
        <updating/>
        <source>setForCreate(_humidParams : CMIF_HumidReading) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/03/2015	cnwdap1		Initial creation PAR #35874 TFS 265
//
vars
	ti		: CM_TrackedItem;

begin
	self.dateTime := _humidParams.dateTime;
	self.setHumidity( _humidParams.getHumidity );
	
	ti := _humidParams.myTrackedItem;
	ti.createReeferPropertiesIfReqd(self.dateTime);
	self.myTIReeferProperties := ti.myReeferProperties;
	
	self.userId := _humidParams.userId;

epilog

end;</source>
        <Parameter name="_humidParams" type="CMIF_HumidReading"/>
    </JadeMethod>
    <JadeMethod name="setHumidity" id="190adc64-dbfa-4837-9bea-2291f804eda0">
        <updating/>
        <source>setHumidity( _humidity : Decimal )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 April 2020	jlgndl1	Initial creation	TFS 47958

*/

vars

begin

	self.humidity := _humidity;

epilog

end;</source>
        <Parameter name="_humidity" type="Decimal"/>
    </JadeMethod>
</Class>
