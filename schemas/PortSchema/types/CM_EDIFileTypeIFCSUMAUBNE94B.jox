<Class name="CM_EDIFileTypeIFCSUMAUBNE94B" id="1d8044f2-71e9-4217-b77b-05dafc5e9b7c">
    <superclass name="CM_EDIFileTypeIFCSUM94B"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <JadeMethod name="create" id="acdd34a4-0d70-45d2-891d-72846cc498af">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//14 Aug 2023	jlirs1	TFS 59845 (57770) Port of Origin BOP

*/

vars

begin
	self.name	:= "IFCSUM 94B - AUBNE Manifest";
	self.type	:= EDIFileType_IFCSUMAUBNE94B;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doImexPortAdjustments" id="86f7ecb1-2336-448f-8502-b6662fe8a2cb">
        <source>doImexPortAdjustments(_cargoTI : CM_EDICargoTI io; _params : CMIF_EDIFACTParams io; _ediPartyRules : CM_EDIPartyIFCSUMRules; _terminal : CM_Terminal) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 02/12/2024	navdap1		MTN-33447 NSW | IFCSUM - Issues When Using 'Create Cargo from GID' EDI Party Option
// 03/01/2025	navdap1		MTN-33756 NSW | IFCSUM - Outbound Tranship Breakbulk Given Incorrect Outgoing Voyage
// 03/04/2025   navsp1      JIRA-34445 NSW | IFCSUM - 1090 Error When Trying to Load a Manifest for Outbound Breakbulk Cargo
vars
	defaultPort : CM_Port;
	voyage : CM_Voyage;

begin
	defaultPort := _terminal.getDefaultPort();
	
	if not _cargoTI.isEDICargoOnShipTI or _params.originPort = defaultPort.code then
		_cargoTI.imexStatus := "EXPORT";
		if _ediPartyRules &lt;&gt; null then									//JIRA-34445
			_cargoTI.setLocationId(_ediPartyRules.defaultLocationID);
		endif;															//JIRA-34445
		
	elseif _cargoTI.isEDICargoOnShipTI or _params.dischargePort = defaultPort.code then
		_cargoTI.imexStatus := "IMPORT";
	endif;
	
	if _params.imexStatus = "TRANSHIP" and (_params.originPort &lt;&gt; null or _params.dischargePort &lt;&gt; null) then
		_cargoTI.imexStatus := "TRANSHIP";
		// MTN-33756 rejig to cater for onship TRANSHIPS and onsite TRANSHIPS
		if _cargoTI.isEDICargoOnShipTI then
			voyage := _terminal.getConfig(DefTranshipOutwardVoyage).CM_Voyage;
			if voyage &lt;&gt; null then
				_params.exportVoyageCode := voyage.code;
			endif;
			
			_cargoTI.setVoyageCode(_params.voyageCode);
			_cargoTI.exportVoyageCode := _params.exportVoyageCode;
		else
			voyage := _terminal.getConfig(DefTranshipInwardVoyage).CM_Voyage;
			if voyage &lt;&gt; null then
				_params.exportVoyageCode := voyage.code;
			endif;
			
			_cargoTI.setVoyageCode(_params.exportVoyageCode);
			_cargoTI.exportVoyageCode := _params.voyageCode;
		endif;
		
		_cargoTI.transhipDischargePort := _params.dischargePort;
		_cargoTI.loadPort := _params.loadPort;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cargoTI" type="CM_EDICargoTI" usage="io"/>
        <Parameter name="_params" type="CMIF_EDIFACTParams" usage="io"/>
        <Parameter name="_ediPartyRules" type="CM_EDIPartyIFCSUMRules"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getCNIData" id="22114021-f3f6-41e5-a63e-2e316ef30d6c">
        <source>getCNIData(_msgHelper: CMIF_EDIFACTHelper io; _ediPartyRules: CM_EDIPartyIFCSUMRules; _ediData: CM_EDIData input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 October 2024	navsp1	Initial creation Bug MTN-19367: NSW | IFCSUM - Incorrect Port of Origin and Destination for Some Items in File

*/

vars
	params : CMIF_EDIFACTParams;
begin
	params 		:= _msgHelper.myCurrentParams;
	if params &lt;&gt; null then
		//LOC+28 segment was assigning values (destination) to previous EDIItem, so clearing here as the TI details start at "CNI".
		params.myEDIItem := null;
	endif;
	inheritMethod(_msgHelper, _ediPartyRules, _ediData);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="io"/>
        <Parameter name="_ediPartyRules" type="CM_EDIPartyIFCSUMRules"/>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getFTXData" id="23b23a82-c894-48dd-9533-c2fe761c2fd4">
        <source>getFTXData(_msgHelper: CMIF_EDIFACTHelper io; _ediPartyRules: CM_EDIPartyIFCSUMRules; _ediData: CM_EDIData input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Nov 2023	navma1 Bug 61475: POB - IFCSUM for Non-Containerised Cargo Issues with Shipper Description and Remarks

*/

vars
	mafiSegment 	: String;
	ifcsumRule 		: CM_EDIRule;
	isMAFIExist,
	useSecondSeg 	: Boolean;
	params 			: CMIF_EDIFACTParams;
	mafiNumber, 
	remarks 		: String;
	ediTransform 	: CM_EDITransformRule;
begin

	params 		:= _msgHelper.myCurrentParams;
	
	if _msgHelper.currentGroup = 5 then
		_msgHelper.setNextField();
		if _msgHelper.currentSubItem = "AAA" then
			mafiSegment := _msgHelper.currentSubItem;
			_msgHelper.setNextField();
			_msgHelper.setNextField();
			_msgHelper.setNextField();
			
			mafiSegment := mafiSegment &amp; "+++" &amp; _msgHelper.currentSubItem;
			
			//jlgka1 TFS 39187, 39185 --&gt; 
			if _ediPartyRules &lt;&gt; null then
				foreach ifcsumRule in _ediPartyRules.allEDIPartyRules where ifcsumRule.isKindOf(CM_EDIEDIFactRule) do
					if ifcsumRule.CM_EDIEDIFactRule.item = ifcsumRule.CM_EDIEDIFactRule.Item_FTX_21_1 and 
						mafiSegment = ifcsumRule.CM_EDIEDIFactRule.value and 
						ifcsumRule.CM_EDIEDIFactRule.function = ifcsumRule.CM_EDIEDIFactRule.Function_FTX_21_1_Mafis  then
						isMAFIExist := true;
					endif;
					if ifcsumRule.CM_EDIEDIFactRule.item     = ifcsumRule.CM_EDIEDIFactRule.Item_FTX_21_1 and
					   ifcsumRule.CM_EDIEDIFactRule.function = ifcsumRule.CM_EDIEDIFactRule.Function_FTX_21_1_IgnoreSeg then
						useSecondSeg := true;
					endif;
				endforeach;
			endif;	
		
			if _ediPartyRules &lt;&gt; null  then
				ediTransform:=_ediPartyRules.myFTXTransform;
			endif;
		
			if not useSecondSeg then
				remarks := _msgHelper.currentSubItem;
				if remarks &lt;&gt; null then														//24.11.2023 navma1 #61475
					params.remarks := params.remarks &amp; Space &amp;  remarks;	
				endif;
			endif;

			while true do																	// TFS 36894
				_msgHelper.setNextSubItem();												// TFS 36894
				if _msgHelper.currentSubItem &lt;&gt; null then									// TFS 36894
					remarks:=_msgHelper.currentSubItem;
					params.remarks := params.remarks &amp; Space &amp; remarks;						// TFS 36894
					if isMAFIExist then
						mafiNumber := mafiNumber &amp; _msgHelper.currentSubItem;				//jlgka1 TFS 39187, 39185
					endif;
				else																		// TFS 36894
					break;																	// TFS 36894
				endif;																		// TFS 36894
			endwhile;																		// TFS 36894
			
			
			//jlier1 TFS 55788 21/12/22
			if ediTransform &lt;&gt; null then
				params.remarks :=ediTransform.transformText(params.remarks );
			endif;
			
			//jlgka1 TFS 39187, 39185 --&gt;
			if isMAFIExist then
				self.createMAFICargoOnShip( params, _ediPartyRules, _msgHelper, _ediData, mafiNumber);
			endif;
			//jlgka1 TFS 39187, 39185 &lt;--
		
			//24.11.2023 navma1 #61475
			if _ediPartyRules &lt;&gt; null and _ediPartyRules.createCargoFromGID then
				if params.myEDIItem &lt;&gt; null and params.myEDIItem.isKindOf(CM_EDICargoTI) &lt;&gt; null then
					params.myEDIItem.CM_EDICargoTI.remarks := params.remarks;
				endif;
			endif;
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="io"/>
        <Parameter name="_ediPartyRules" type="CM_EDIPartyIFCSUMRules"/>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getGIDData" id="73c7d469-058c-48f7-84ad-911a30f6f7d8">
        <source>getGIDData(_msgHelper : CMIF_EDIFACTHelper io; _ediPartyRules : CM_EDIPartyIFCSUMRules; _ediData : CM_EDIData input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Aug 2023	jlirs1	TFS 59845 (57770) Port of Origin BOP
18 Sep 2023	jlirs1	TFS 60538 (59148) Destination and Origin from IFCSUM POB
06 Nov 2023	navdap1	TFS 60997 POB - break-bulk cargo items not created for each GID group
06 Nov 2023	navdap1	TFS 61001 POB - System generated ID should be used to create breakbulk cargo items when the config is ticked on EDI Party rule
06 Nov 2023	navdap1	TFS 61002 POB - Cargo ID should be taken from PCI segment to create breakbulk cargo items when the config is NOT ticked on EDI Party rule
14 Nov 2023	navdap1	TFS 61230 POB - Total Quantity not getting populated from GID segment
24 Nov 2023	navma1  Bug 61475: POB - IFCSUM for Non-Containerised Cargo Issues with Shipper Description and Remarks
12 Dec 2023	navdap1	TFS 61744 POB - IFCSUM - Issues When Using Create Cargo from GID Option
20 Dec 2023	navdap1	TFS 61822 POB - IFCSUM - Issues With Mixed Cargo Export File
12 Aug 2024	navlw1	TFS 65152 NSW - IFCSUM - Enhancements
02 Dec 2024	navdap1	MTN-33447 NSW | IFCSUM - Issues When Using 'Create Cargo from GID' EDI Party Option
11 Dec 2024	navdap1	MTN-33652 NSW IFCSUM Enhancements - Default cargo type issue
*/

vars
	params 			: CMIF_EDIFACTParams;
	terminal 		: CM_Terminal;
	cargoTI 	    : CM_EDICargoTI;
	type 			: CM_CargoType;
	bol 			: CM_EDIBOLHdrTI;
	foundMatch		: Boolean;				// TFS 61744
begin
	if _msgHelper = null then
		return;
	endif;
	
	if _msgHelper.currentGroup = 5 
		or _msgHelper.currentGroup = 6
		or _msgHelper.currentGroup = 7
		or _msgHelper.currentGroup = 8
		or _msgHelper.currentGroup = 9 then
		_msgHelper.setCurrentGroup(5);
	endif;
	
	if _msgHelper.currentGroup &lt;&gt; 5 then
		return;
	endif;
	
	params := _msgHelper.myCurrentParams;
	
	if params.cargoTypeCode = TI_CargoType_Container then
		return;
	endif;
	

	//_msgHelper.setNextField();		// TFS 61230
	_msgHelper.setNextField();
	params.gidCount := _msgHelper.currentField.Integer;	
	
	// For POB, create one TI per GID, not one per GID count
	if _ediPartyRules &lt;&gt; null and _ediPartyRules.createCargoFromGID then

		terminal 	:= _ediData.getMyTerminal();
		
		// TFS 61744
		// TFS 61822 Allow for import or export, create the correct EDI TI
		if params.imexStatus = "IMPORT" then
			if _ediPartyRules.eqdImportCargoSite = TI_SITE_ONSHIP then
				create cargoTI as CM_EDICargoOnShipTI persistent;
			else
				create cargoTI as CM_EDICargoOnSiteTI persistent;
			endif;
		// MTN-33447
		elseif params.imexStatus = "TRANSHIP" then
			if params.dischargePort = _ediPartyRules.getMyTerminal().getConfig(PortDestCode).String then
				// Import Tranship
				create cargoTI as CM_EDICargoOnShipTI persistent;
			else
				// Export Tranship
				create cargoTI as CM_EDICargoOnSiteTI persistent;
			endif;
		// MTN-33447 end of this bit
		else
			if _ediPartyRules.eqdExportCargoSite = TI_SITE_ONSHIP then
				create cargoTI as CM_EDICargoOnShipTI persistent;
			else
				create cargoTI as CM_EDICargoOnSiteTI persistent;
			endif;
		endif;
		// TFS 61744 end
		
		cargoTI.messageMode 		 := "A";
		cargoTI.setForCreateNew(_ediData);
		cargoTI.ediFileIssueDateTime := params.ediFileIssueDateTime;
		//cargoTI.operatorCode 		 := params.voyageOperatorCode;				// TFS 61744
		if _ediPartyRules.myCargoOperator &lt;&gt; null then							// TFS 61744
			cargoTI.operatorCode	 := _ediPartyRules.myCargoOperator.code;	// TFS 61744
		else																	// TFS 61744
			cargoTI.operatorCode	 := params.voyageOperatorCode;				// TFS 61744
		endif;																	// TFS 61744
		
		if params.voyageOperatorCode = null then
			cargoTI.operatorCode 	 := params.senderOperatorCode;
		endif;
		cargoTI.setVoyageCode(params.voyageCode.trimBlanks()[1:30]);
		params.bulkId 				 := params.bulkId + 1;
		
		// TFS 61001 / TFS 61002
		if _ediPartyRules.useSystemGeneratedIds then
			cargoTI.setIdDefault(terminal.generateNextCargoId(true,false,null));
		endif;
		// TFS 61001 / TFS 61002 end
		
		type := app.myRoot.allCargoTypesById[params.cargoTypeCode];
		if type &lt;&gt; null and type.isCommodityRequired then
			cargoTI.commodity := params.defCmdty;
		else
			cargoTI.commodity := null;
		endif;
		
		if cargoTI.isEDICargoOnShipTI then			// TFS 61744
			cargoTI.CM_EDICargoOnShipTI.myEDIBOLHeader := params.myEDIHdr.CM_EDIBOLHdrTI;
		endif;										// TFS 61744
		
		if params.cargoTypeCode = null and _ediPartyRules &lt;&gt; null then
			// MTN-33447 next bit - check HS Rules for cargo type / cargo subtype
			self.checkHSCodeForCargoTypes(_msgHelper, _ediPartyRules);
			// MTN-33447 end of this bit
			
			if params.cargoTypeCode = null and _ediPartyRules.myDefaultCargoType &lt;&gt; null then	// MTN-33652
				params.cargoTypeCode := _ediPartyRules.myDefaultCargoType.id;
			endif;
		endif;
		
		cargoTI.setCargoType(params.cargoTypeCode);
		cargoTI.product := params.cargoSubType; // navlw1 #65152
		
		_msgHelper.setNextField();
		cargoTI.quantity 		:= _msgHelper.currentField.asIntegerJMT();
		cargoTI.totalQuantity 	:= cargoTI.quantity;					// TFS 61230
		cargoTI.remarks  	  	:= params.remarks;
		if cargoTI.cargoType &lt;&gt; TI_CargoType_Container then
			cargoTI.make 		:= params.model;
		endif;
		
		cargoTI.imexStatus      := params.imexStatus;			//07.Feb.24 navsp1 TFS 62131
		
		// TFS 61744 translate consignee / consignor
		// TFS 61822 Set Consignee and Consignor correctly according to imex status
		if params.mySenderOperator &lt;&gt; null then
			if cargoTI.imexStatus = "IMPORT" then
				cargoTI.consignee := params.mySenderOperator.getXlationSystemCode(params.consignee, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch);
				if not foundMatch and _ediPartyRules &lt;&gt; null and _ediPartyRules.piaIsHSCode then  //POB have this set and only want to do this for POB
					cargoTI.consignee := null;
				endif;
			else
				cargoTI.consignor := params.mySenderOperator.getXlationSystemCode(params.consignor, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30];
				if not foundMatch and _ediPartyRules &lt;&gt; null and _ediPartyRules.piaIsHSCode then
					cargoTI.consignor := null;
				endif;
			endif;
		else
			if cargoTI.imexStatus = "IMPORT" then
				cargoTI.consignee := params.consignee;
			else
				cargoTI.consignor := params.consignor[1:30];
			endif;
		endif;
		// TFS 61744 end
		
		//cargoTI.imexStatus      := "IMPORT";					// TFS 61822
		//cargoTI.imexStatus      := params.imexStatus;			// TFS 61822	//07.Feb.24 navsp1 TFS 62131 - Moved to top
		cargoTI.dischargePort   := params.dischargePort;
		
		//if _ediPartyRules &lt;&gt; null then																//24.11.2023 navma1 #61475
			if cargoTI.destinationPort = null /*and _ediPartyRules.useDiscPortAsDestPort */ then		//24.11.2023 navma1 #61475
				cargoTI.destinationPort := params.destination; 
			endif;
		//endif;
		
		cargoTI.loadPort := params.loadPort;
		cargoTI.setPortOfOrigin(params.originPort);
		
		bol := params.myEDIHdr.CM_EDIBOLHdrTI;
		if bol &lt;&gt; null then
			cargoTI.bol 	 := bol.id;
			params.bolNumber := bol.id;
		endif;
		// MTN-33447 start of changes to store BOL number even if we're not creating a BOL header
		if _ediPartyRules &lt;&gt; null and _ediPartyRules.doNotCreateBOL and app.myRoot.canDoEDIFileType(EDIFileType_JSONOnePortVoyage) then
			cargoTI.bol := params.bolNumber;
		endif;
		// MTN-33447 end of this bit
		
		// TFS 61822 Set Shipp Description correctly according to imex status
		if cargoTI.imexStatus = "IMPORT" then
			cargoTI.setShipperDescription(params.consignee);						//24.11.2023 navma1 #61475
		elseif cargoTI.imexStatus = "EXPORT" or not cargoTI.isEDICargoOnShipTI then		// MTN-33447
			cargoTI.setShipperDescription(params.consignor);							// MTN-33447
		endif;
		
		// MTN-33447
		self.doImexPortAdjustments(cargoTI, params, _ediPartyRules, terminal);
		
		params.myEDIItem := cargoTI;
		params.remarks   := null;													//24.11.2023 navma1 #61475
	else
		_msgHelper.setNextField();													//28.11.2023 navma1	#61475
		params.totalQuantity 		:= _msgHelper.currentField.asIntegerJMT();      //28.11.2023 navma1	#61475
		
		params.clearGID(_ediPartyRules);
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="io"/>
        <Parameter name="_ediPartyRules" type="CM_EDIPartyIFCSUMRules"/>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getLOCData" id="c2f12fe4-9619-4c27-b52d-fde645e8bdc9">
        <source>getLOCData(_msgHelper : CMIF_EDIFACTHelper io; _ediPartyRules : CM_EDIPartyIFCSUMRules) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Aug 2023	jlirs1	TFS 59845 (57770) Port of Origin BOP
19 Sep 2023	jlirs1	TFS 60538 (59148) Destination and Origin from IFCSUM POB
02 Oct 2023	jlirs1	TFS POB Corrections
10 Nov 2023	navdap1	TFS 61188 POB - IFCSUM Breakbulk - Location not getting set from EDI Party rule
26 Feb 2024	navdap1	TFS 62188 POB - IFCSUM - Issues with Export Transhipments
11 Apr 2024 navsp1  TFS Bug 63168: POB - IFCSUM - Discharge Port for Export Transhipments not populated correctly when Don't override Discharge Port is not set
14 Aug 2024 navsaa30 Bug 65644: POB - IFCSUM - Issues with Load and Discharge Ports
11 Sep 2024	navdap1	TFS 65152 NSW | IFCSUM Enhancements
04 Oct 2024	navdap1	MTN-32998 NSW | FR - Incorrect Destination and Port of Origin on Non-Containerised Outbound Tranship Cargo
11 Nov 2024	navdap1	MTN-33398 NSW IFCSUM Enhancements - Incorrect Port of Origin and IMEX assigned to Outbound Non-Containerised Cargo
10 Dec 2024	navdap1	MTN-33465 NSW | Transship Load Port - Retain, Report and Extract
25 Feb 2025	navdap1	MTN-34191 NSW | IFCSUM - Some Inbound Tranship Breakbulk Created On Site
*/
vars
	portStr : String;
	params : CMIF_EDIFACTParams;
	foundMatch : Boolean;
	useDiscAsDest : Boolean;
	bol : CM_EDIBOLHdrTI;
	ediCargoTI : CM_EDICargoTI;
	portType  : String;
	deriveIMEXFromLOC : Boolean;		// MTN-33398
begin
	if _msgHelper = null then
		return;
	endif;
	params := _msgHelper.myCurrentParams;
	if params = null then
		return;
	endif;
	if not (_msgHelper.currentGroup = 2	or				// from a EQD
	   _msgHelper.currentGroup = 4 or 
	   _msgHelper.currentGroup = 1) then
		return;
	endif;
	ediCargoTI := params.myEDIItem.CM_EDICargoTI;
	useDiscAsDest := (_ediPartyRules &lt;&gt; null and _ediPartyRules.useDiscPortAsDestPort);
	deriveIMEXFromLOC := (_ediPartyRules &lt;&gt; null and _ediPartyRules.getMyTerminal.getConfig(DeriveIMEXSiteFromLOC).Boolean);	// MTN-33398
	
	_msgHelper.setNextField();
	portType := _msgHelper.currentSubItem;
	_msgHelper.setNextField();
	portStr := _msgHelper.currentSubItem[1:5].trimBlanks();
	if params.myVoyageOperator &lt;&gt; null then
		portStr := params.myVoyageOperator.getXlationSystemCode(portStr, XLATION_TYPE_PORT_BYOP, foundMatch)[1:5];
	endif;
	bol := params.myEDIHdr.CM_EDIBOLHdrTI;

	if portType = "7" or 		// place of delivery
	   portType = "11" then	 	// this is the place of discharge
		if params.imexStatus = null and
		   portStr = params.thisPort then
			params.imexStatus := "IMPORT";
		endif;
		if _msgHelper.currentGroup = 1 then
			params.dischargePort := portStr;
			if useDiscAsDest then
				params.destination := portStr;
			endif;
		elseif _msgHelper.currentGroup = 2 or 
		   _msgHelper.currentGroup = 4 then	
			if _ediPartyRules &lt;&gt; null and 
			   not _ediPartyRules.dontOverrideFileDischargePort then// TFS 62188
			   //params.dischargePort &lt;&gt; null then																									//TFS 63168
					//If the "dontOverrideFileDischargePort" option IS  ticked, then the discharge port defaults to the LOC+11 at the file level,- 	//TFS 63168
					//if it isn't ticked then the discharge port should be derived from the cargo level.											//TFS 63168
					//Also there wont be any POB file having an LOC+11 segment at the file level and cargo level at the same time					//TFS 63168
					params.dischargePort := portStr;																								//TFS 63168
					if useDiscAsDest then																											//TFS 63168
						params.destination := portStr;																								//TFS 63168
					endif;																															//TFS 63168
			else
				if ediCargoTI &lt;&gt; null then  
					if ediCargoTI.dischargePort = null then			//02 Oct 2023	jlirs1	TFS POB Corrections
						ediCargoTI.dischargePort := portStr;
					endif;
					if useDiscAsDest and
					   ediCargoTI.destinationPort = null then		//02 Oct 2023	jlirs1	TFS POB Corrections
						ediCargoTI.destinationPort := portStr;
					endif;
				endif;
				if params.imexStatus.isOneOf("EXPORT", "TRANSHIP")	//16/08/2024  navsaa30  #65644	// MTN-33465
				or (params.imexStatus = null and deriveIMEXFromLOC) then		// MTN-33398
					params.dischargePort := portStr;			
				endif;
				if useDiscAsDest then
					params.destination := portStr;
				endif;
			endif;
			if portType = "7" then
				if params.imexStatus = "IMPORT" then
					if ediCargoTI &lt;&gt; null and
					   ediCargoTI.destinationPort = null then		//02 Oct 2023	jlirs1	TFS POB Corrections  
						ediCargoTI.destinationPort := portStr;
					endif;
					params.destination := portStr;
				elseif params.imexStatus = "TRANSHIP" then
					if ediCargoTI &lt;&gt; null then  
						if params.dischargePort = params.thisPort and
						   ediCargoTI.destinationPort = null then		//02 Oct 2023	jlirs1	TFS POB Corrections
							ediCargoTI.destinationPort := portStr;
						endif;
					endif;
					if params.dischargePort = params.thisPort then
						params.destination := portStr;
					endif;
				elseif params.imexStatus = null and		//02 Oct 2023	jlirs1	TFS POB Corrections
				   params.destination = null then
					params.destination := portStr;
				endif;
			endif;
			
			// TFS 65152 If we are deriving the IMEX status from LOC segments, and discharge port = this port, we're Import
			// If we are deriving the IMEX status from LOC segments, and discharge port &lt;&gt; this port, we're tranship
			if _msgHelper.currentGroup = 4 and portType = "7" and _ediPartyRules &lt;&gt; null then							//TFS 66061 - null check added
				if deriveIMEXFromLOC then
					if params.thisPort = portStr then				// MTN-34191
						params.imexStatus := "IMPORT";			// MTN-32998
					else
						params.imexStatus := "TRANSHIP";
						params.dischargePort := params.thisPort;	// MTN-34191
					endif;
				endif;
			endif;
		endif;

		if bol &lt;&gt; null then
			bol.dischargePort := portStr;
			if useDiscAsDest then
				bol.destinationPort := portStr;  
			endif;
		endif;	
	elseif portType = "9" then	 // this is the port of loading
		if params.imexStatus = null and
		   portStr = params.thisPort then
			params.imexStatus := "EXPORT";
		endif;
		if _msgHelper.currentGroup = 1 then
			params.loadPort := portStr;
		elseif _msgHelper.currentGroup = 2 or 
		   _msgHelper.currentGroup = 4 then	
			params.loadPort := portStr;
			if ediCargoTI &lt;&gt; null and
			   ediCargoTI.loadPort = null then  		//02 Oct 2023	jlirs1	TFS POB Corrections
				ediCargoTI.loadPort := portStr;
			endif;
		endif;

		if bol &lt;&gt; null then		
			bol.loadPort := portStr;
		endif;	
	elseif portType = "20" then	 // this is the country of destination
		if _msgHelper.currentGroup = 1 then
			params.destination := portStr;
		elseif _msgHelper.currentGroup = 2 or 
		   _msgHelper.currentGroup = 4 then	
			if ediCargoTI &lt;&gt; null and
			   ediCargoTI.destinationPort = null then  		//02 Oct 2023	jlirs1	TFS POB Corrections
				ediCargoTI.destinationPort := portStr;
			endif;
			params.destination := portStr;
		endif;
		if bol &lt;&gt; null and
		   bol.destinationPort = null then		//02 Oct 2023	jlirs1	TFS POB Corrections		
			if not useDiscAsDest then
				bol.destinationPort := portStr;
			endif;
		endif;	
	elseif portType = "28" then		// country of destination
		if params.imexStatus = "EXPORT"
		or (params.imexStatus = "TRANSHIP" and params.loadPort = params.thisPort)
		or (params.imexStatus = null and deriveIMEXFromLOC) then					// MTN-33398
			if ediCargoTI &lt;&gt; null and
			   ediCargoTI.destinationPort = null then 			//02 Oct 2023	jlirs1	TFS POB Corrections 
				ediCargoTI.destinationPort := portStr;
			endif;
			params.destination := portStr;
		endif;
		if params.imexStatus = null and		//02 Oct 2023	jlirs1	TFS POB Corrections
		   params.destination = null then
			params.destination := portStr;
		endif;
		if bol &lt;&gt; null and		//02 Oct 2023	jlirs1	TFS POB Corrections
		   bol.destinationPort = null then		
			if not useDiscAsDest then
				bol.destinationPort := portStr;
			endif;
		endif;	
	elseif portType = "27" then			// country of origin
		if _msgHelper.currentGroup = 2 or 
		   _msgHelper.currentGroup = 4 then	
			if params.imexStatus = "IMPORT" or
			   (params.imexStatus = "TRANSHIP" and
				params.dischargePort = params.thisPort) then
				if ediCargoTI &lt;&gt; null and
				   ediCargoTI.getPortOfOrigin = null then  		//02 Oct 2023	jlirs1	TFS POB Corrections
					ediCargoTI.setPortOfOrigin(portStr);
				endif;
				params.originPort := portStr;
			endif;
			if params.imexStatus = null then		//02 Oct 2023	jlirs1	TFS POB Corrections
//			   params.originPort = null then
				params.originPort := portStr;
			endif;
		endif;
	elseif portType = "88" then		//place of receipt
//	   portType = "76" then	 // this is the port of origin
		if _msgHelper.currentGroup = 1 then
			params.originPort := portStr;
		endif;
		if _msgHelper.currentGroup = 2 or 
		   _msgHelper.currentGroup = 4 then	
			if params.imexStatus = "EXPORT"
			or (params.imexStatus = "TRANSHIP" and deriveIMEXFromLOC) then		// MTN-33398
				if ediCargoTI &lt;&gt; null  and 
				   ediCargoTI.getPortOfOrigin = null then  		//02 Oct 2023	jlirs1	TFS POB Corrections
					ediCargoTI.setPortOfOrigin(portStr);
				endif;
				params.originPort := portStr;
			endif;
			if params.imexStatus = null then		//02 Oct 2023	jlirs1	TFS POB Corrections
//			   params.originPort = null then
				params.originPort := portStr;
			endif;
		endif;
		
		// TFS 65152 If we're deriving imex status from port codes, and port code &lt;&gt; this port, we're a Tranship
		if _msgHelper.currentGroup = 4  and _ediPartyRules &lt;&gt; null then
			if deriveIMEXFromLOC then
				if portStr &lt;&gt; params.thisPort then				// MTN-34191
					params.imexStatus := "TRANSHIP";
				else													// MTN-33398
					params.imexStatus := null;							// MTN-33398
				endif;
			endif;
		endif;
		
	elseif portType = "147" then 
		//if ediCargoTI &lt;&gt; null then									// TFS 61188
		if ediCargoTI &lt;&gt; null and _msgHelper.currentField &lt;&gt; null then	// TFS 61188
			ediCargoTI.locationId := _msgHelper.currentField;
		endif;		
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="io"/>
        <Parameter name="_ediPartyRules" type="CM_EDIPartyIFCSUMRules"/>
    </JadeMethod>
    <JadeMethod name="getPCISGPData" id="68a6e938-2a4d-4100-bd84-d6accaba27bd">
        <source>getPCISGPData(_msgHelper: CMIF_EDIFACTHelper io; _ediPartyRules: CM_EDIPartyIFCSUMRules; _ediData: CM_EDIData input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 Nov 2023	navma1	Bug 61475: POB - IFCSUM for Non-Containerised Cargo Issues with Shipper Description and Remarks
07 Dec 2023	navdap1	TFS 61723 POB - IFCSUM - Issue with Mixed Cargo Consignments in IFCSUM
12 Dec 2023	navdap1	TFS 61744 POB - IFCSUM - Issues When Using Create Cargo from GID Option
15 Dec 2023	navdap1	TFS 61767 POB - IFCSUM - Issues with Manifest that Contains Tranship and Export Containers
18 Dec 2023	navdap1	TFS 61802 POB - IFCSUM - HS Code Not Populated When Create Cargo from GID Option Selected
18 Dec 2023	navdap1	TFS 61808 POB - IFCSUM - Import Tranships Created Onsite Rather Than On Ship
19 Dec 2023	navdap1	TFS 61822 POB - IFCSUM - Issues With Mixed Cargo Export File
20 Dec 2023	navdap1	TFS 61813 POB - IFCSUM - BOL Field not populated for containers
2 Feb 2024 navsaa30 Bug 61981: POB - IFCSUM - Multiple Cargo Items Associated with single container
8 Aug 2024 navsaa30	Ticket 64265: NSW - IFCSUM - Inbound Tranships Created Onsite Rather Than Onship
12 Aug 2024	navlw1	TFS 65152 NSW - IFCSUM - Enhancements
02 Oct 2024	navdap1	MTN-19374 NSW - FR Carrier Remarks Not Populated When NAD+CR Provided in IFCSUM
25 Oct 2024 navsp1  JIRA 33157 NSW | FR - IFCSUM - Consignee to Cargo Type Mappings Not Applied to Matching Cargo
31 Oct 2024	navdap1	MTN-33314 NSW | FR - IFCSUM - Incorrect Cargo Sub Type Assigned to Cargo When HS Code not Mapped
02 Dec 2024	navdap1	MTN-33447 NSW | IFCSUM - Issues When Using 'Create Cargo from GID' EDI Party Option
10 Dec 2024 navsp1  MTN-33633 NSW | IFCSUM - Incorrect Outgoing Voyage for Outbound Tranship Container
11 Dec 2024	navdap1	MTN-33653 NSW | IFCSUM - Issue with HS Code and Consignee Cargo Type Mapping
11 Dec 2024	navdap1	MTN-33652 NSW IFCSUM Enhancements - Default cargo type issue
06 Jan 2025 navsp1  MTN-33703 NSW | IFCSUM - Shipper Description Full Text
*/

vars
	params 			: CMIF_EDIFACTParams;
	currentTag 		: String;
	cargoTI			: CM_EDICargoTI;
	terminal 		: CM_Terminal;
	type 			: CM_CargoType;
	bol 			: CM_EDIBOLHdrTI;	
	defaultPort		: CM_Port;
	voyage			: CM_Voyage;
	createOnShip	: Boolean;
	cargoOnSite		: CM_EDICargoTI;
	foundMatch 		: Boolean;
	isSGP			: Boolean;			// TFS 61723
	obj				: Object;			// TFS 61723
	ediTI			: CM_EDICargoTI;	// TFS 61723
	ruleItem		: CM_EDIRule;
	foundHSRule		: Boolean;		// MTN-33314
	ifcsumRule 		: CM_EDIRule;	// MTN-33314
	transConsignee	: String;				// MTN-33653
begin
	if _msgHelper = null then
		return;
	endif;
	
	params 		:= _msgHelper.myCurrentParams;
	isSGP		:= _msgHelper.currentField = "SGP";		// TFS 61723
	
	// in formats where the cargo items are created from the GID count, ignore any PCI or SGP segments
	if _ediPartyRules &lt;&gt; null and _ediPartyRules.createCargoFromGID then
		// TFS 61001 / TFS 61002 If the EDI Party Rule is not configured for system-generated IDs, get the ID from the PCI segment
		_msgHelper.setNextField();
		_msgHelper.setNextField();
		if params.myEDIItem &lt;&gt; null and params.myEDIItem.cargoType &lt;&gt; TI_CargoType_Container then
			if not _ediPartyRules.useSystemGeneratedIds and _msgHelper.currentSubItem &lt;&gt; null then
				params.myEDIItem.id := _msgHelper.currentSubItem[1:30];			// MTN-33652
			endif;
		endif;
		// TFS 61001 end
		
		// TFS 61723 If creating cargo from the GID segment, then the SGP segment contains a container ID 
		// If this container ID matches one of the containers already obtained from a EQD segment, then
		// the GID weight details need to be applied to that container, and the GID deleted
		if isSGP then
			_msgHelper.setFirstField();
			_msgHelper.setNextField();
			
			foreach obj in params.allEDIItems do
				if obj.isKindOf(CM_EDICargoTI) then
					ediTI := obj.CM_EDICargoTI;
					if ediTI.id &lt;&gt; _msgHelper.currentSubItem then
						continue;
					endif;
					if _ediPartyRules &lt;&gt; null and _ediPartyRules.meaIsCargoWeight then
						ediTI.cargoWeight := ediTI.cargoWeight + params.cargoWeight;    // navsaa30  2/2/24  #61981
						ediTI.weight := ediTI.cargoWeight + ediTI.tareWeight;
					else
						ediTI.weight := params.totalWeight;
						ediTI.cargoWeight := ediTI.weight - ediTI.tareWeight;
					endif;
					if params.myEDIItem &lt;&gt; null then
						ediTI.remarks := params.myEDIItem.CM_EDICargoTI.remarks;
					endif;
					ediTI.imexStatus := params.imexStatus;
					ediTI.setPortOfOrigin(params.originPort);
					ediTI.destinationPort := params.destination;
					
					// TFS 61744 translate consignee / consignor
					if ediTI.isEDICargoOnShipTI then
						if params.mySenderOperator &lt;&gt; null then
							ediTI.consignee := params.mySenderOperator.getXlationSystemCode(params.consignee, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30];
							if not foundMatch then
								ediTI.consignee := null;
							endif;
						else
							ediTI.consignee := params.consignee;
						endif;
						ediTI.imexStatus := "IMPORT";
						if _ediPartyRules &lt;&gt; null and _ediPartyRules.isFullShipperDesc then		//MTN-33703
							ediTI.setShipperDescription(params.fullShipperDesc);				//MTN-33703
						else
							ediTI.setShipperDescription(params.consignee);
						endif;
					else
						if params.mySenderOperator &lt;&gt; null then
							ediTI.consignor := params.mySenderOperator.getXlationSystemCode(params.consignor, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30];
							if not foundMatch then
								ediTI.consignor := null;
							endif;
						else
							ediTI.consignor := params.consignor;
						endif;
						ediTI.imexStatus := "EXPORT";
					endif;
					// TFS 61744 end of this bit
					
					ediTI.loadPort := params.loadPort;
					ediTI.dischargePort := params.dischargePort;		// TFS 61822
					ediTI.setHSCode(params.hsCode);						// TFS 61822
					ediTI.bol := params.bolNumber;						// TFS 61813
					delete params.myEDIItem;
					params.allEDIItems.removeInvalidObjects();
				endif;
			endforeach;
			
		else
			// TFS 61802 Need to record the HS code on the current GID-created TI
			if _ediPartyRules &lt;&gt; null and _ediPartyRules.piaIsHSCode and params.myEDIItem &lt;&gt; null and params.myEDIItem.isEDICargo then
				params.myEDIItem.CM_EDICargoTI.setHSCode(params.hsCode);
			endif;
			// TFS 61802 end
		endif;
		// TFS 61723 end
		return;
	endif;
	
	// in formats where a PCI section AND a SGP section is present, the SGP section contains the cargo ids
	// so we need to check whether there is a party rule telling us to use PCI or SGP
	currentTag := _msgHelper.currentTag;
	if _ediPartyRules &lt;&gt; null then
		if _msgHelper.currentTag = "PCI" and not _ediPartyRules.cargoSegmentIsPCI then
			return;
		elseif _msgHelper.currentTag = "SGP" and _ediPartyRules.cargoSegmentIsPCI then
			// Does SGP have a cargo id that we'vwe already processed in it? 
			// This is the parent item for the last processed cargo item
			if _msgHelper.currentGroup = 5 then
				_msgHelper.setNextField();
				if _msgHelper.currentSubItem &lt;&gt; null then
					cargoTI := params.allEDIItems[_msgHelper.currentSubItem].CM_EDICargoTI;
					if cargoTI &lt;&gt; null then
						params.myEDIItem.CM_EDICargoTI.parentCargoID := cargoTI.id;
						params.myEDIItem.CM_EDICargoTI.parentCargoType := cargoTI.cargoTypeDescr;
						params.myEDIItem.CM_EDICargoTI.parentCargoTypeCode := cargoTI.cargoType;
					endif;					 
				endif;
			endif;				
			return;
		endif;
	endif;
	
	if _msgHelper.currentGroup &lt;&gt; 5 then
		return;
	endif;
	_msgHelper.setNextField();
	if _msgHelper.currentTag = "PCI" then
		_msgHelper.setNextField();
	endif;
	
	if _msgHelper.currentSubItem &lt;&gt; null then
		//jlier1 TFS 55464 7/12/22
		cargoTI:= params.allEDIItems.getAtKey(_msgHelper.currentSubItem[1:30]).CM_EDICargoTI;
		terminal := _ediData.getMyTerminal();
		if cargoTI = null then				
			// TFS 65152 if we are deriving imex status from port codes, and load port is "us", 
			// we need to create cargo on site
			if terminal.getConfig(DeriveIMEXSiteFromLOC).Boolean and params.loadPort = terminal.getDefaultPort().code then
				create cargoTI as CM_EDICargoOnSiteTI persistent;
			else
				create cargoTI as CM_EDICargoOnShipTI persistent;
			endif;
			
			cargoTI.messageMode := "A";
			cargoTI.setForCreateNew(_ediData);
			cargoTI.ediFileIssueDateTime := params.ediFileIssueDateTime;
			//jlier1 TFS 57156 22/3/23
			if _ediPartyRules &lt;&gt; null and _ediPartyRules.myCargoOperator &lt;&gt; null then
				cargoTI.operatorCode :=_ediPartyRules.myCargoOperator.code;
			else
				cargoTI.operatorCode := params.voyageOperatorCode;
				if params.voyageOperatorCode = null then
					cargoTI.operatorCode := params.senderOperatorCode;
				endif;
			endif;
			cargoTI.setVoyageCode(params.voyageCode.trimBlanks()[1:30]);
			params.bulkId := params.bulkId + 1;
			cargoTI.vin := _msgHelper.currentSubItem;
			
			if _ediPartyRules &lt;&gt; null and _ediPartyRules.useSystemGeneratedIds then					//24.11.2023 navma1 #61475
				cargoTI.setIdDefault(terminal.generateNextCargoId(true,false,null));
			else
				cargoTI.setId(_msgHelper.currentSubItem[1:30]);
			endif;
			// start navlw1 #65152
			if _ediPartyRules &lt;&gt; null and _ediPartyRules.hasHSCodeTranslation() then
				//params.cargoTypeCode := null;		//JIRA 33157 - commenting, so it can use the consignee cargo type (which sets in PortSchema::CM_EDIFileTypeIFCSUM94B::getNADData) if unable to find one from the HSRule below.
				//params.cargoSubType := null;		//JIRA 33157
				foundHSRule := false;										// MTN-33314
				foreach ruleItem in _ediPartyRules.allEDIPartyRules where ruleItem.isIFCSUMHSRule and ruleItem.CM_EDIIFCSUMHSRule.hsCode = params.hsCode do
					params.cargoTypeCode := ruleItem.CM_EDIIFCSUMHSRule.cargoType;
					params.cargoSubType := ruleItem.CM_EDIIFCSUMHSRule.cargoSubType;
					foundHSRule := true;									// MTN-33314
				endforeach;
				
				// MTN-33314 Repeat the consignee / cargo type checking here
				if not foundHSRule then
					// MTN-33653 repeat the translation here too, because getNADData puts the raw string back on the params
					if params.mySenderOperator &lt;&gt; null then
						transConsignee := params.mySenderOperator.getXlationSystemCode(params.consignee, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch);
					endif;
					
					foreach ifcsumRule in _ediPartyRules.allEDIPartyRules where ifcsumRule.isKindOf(CM_EDIIFCSUMRule) and ifcsumRule.CM_EDIIFCSUMRule.consignee = transConsignee do	// MTN-33653
						if ifcsumRule.CM_EDIIFCSUMRule.cargoType &lt;&gt; null then
							params.cargoTypeCode := ifcsumRule.CM_EDIIFCSUMRule.cargoType;
						endif;
						if ifcsumRule.CM_EDIIFCSUMRule.make &lt;&gt; null then
							params.model := ifcsumRule.CM_EDIIFCSUMRule.make;
						endif;
						foundHSRule := true;
						break;
					endforeach;
					// If still no match on any cargo type mappings, clear out the params cargo type
					if not foundHSRule then
						params.cargoTypeCode := null;
					endif;
				endif;
				// MTN-33314 end of this bit
			endif;
			// end navlw1 #65152
			if params.cargoTypeCode = null and //02 Oct 2023	jlirs1	TFS POB Corrections
			   _ediPartyRules &lt;&gt; null then
				if _ediPartyRules.myDefaultCargoType &lt;&gt; null then
					params.cargoTypeCode := _ediPartyRules.myDefaultCargoType.id;
					params.cargoSubType := null;				// MTN-33314
				endif;
			endif;
			cargoTI.setCargoType(params.cargoTypeCode);	
			cargoTI.product := params.cargoSubType; 													// navlw1 #65152
			cargoTI.carrierRemarks := params.carrierRemarks;											// navlw1 #65152
			cargoTI.imexStatus := "IMPORT";			
			
			// TFS 65152 If we're deriving imex status and site from LOC port codes, we need to switch things up here a bit
			// Make sure we have the correct imex status, we're in the right place, and our tranship dafta is all correct
			if terminal.getConfig(DeriveIMEXSiteFromLOC).Boolean then
				// MTN-33447 refactored into its own method
				self.doImexPortAdjustments(cargoTI, params, _ediPartyRules, terminal);
				/*defaultPort := terminal.getDefaultPort();
				if not cargoTI.isEDICargoOnShipTI or params.originPort = defaultPort.code then
					cargoTI.imexStatus := "EXPORT";
					cargoTI.setLocationId(_ediPartyRules.defaultLocationID);
				elseif cargoTI.isEDICargoOnShipTI or params.dischargePort = defaultPort.code then
					cargoTI.imexStatus := "IMPORT";
				endif;
				if params.imexStatus = "TRANSHIP" and (params.originPort &lt;&gt; null or params.dischargePort &lt;&gt; null) then
					cargoTI.imexStatus := "TRANSHIP";
					voyage := terminal.getConfig(DefTranshipOutwardVoyage).CM_Voyage;
					if voyage &lt;&gt; null then
						params.exportVoyageCode := voyage.code;								
					endif;
					
					cargoTI.setVoyageCode(params.voyageCode);
					cargoTI.exportVoyageCode := params.exportVoyageCode;
					cargoTI.transhipDischargePort := params.dischargePort;
					cargoTI.loadPort := params.loadPort;
				endif;*/
			endif;
			
			cargoTI.consignee  := params.consignee;													   //24.11.2023 navma1 #61475
		else
			// jlika1 TFS 56385 --&gt;				
			if _ediPartyRules &lt;&gt; null and _ediPartyRules.eqdCreateTranship and cargoTI.transitStatus =  TI_TransitStatusInterModal then 
				defaultPort := terminal.getDefaultPort();		
				if defaultPort.code = params.dischargePort then					
					createOnShip := true;
					voyage := terminal.getConfig(DefTranshipOutwardVoyage).CM_Voyage;
					if voyage &lt;&gt; null then
						params.exportVoyageCode := voyage.code;								
						if voyage.allPorts.first() &lt;&gt; null then
							params.transhipDischargePort := voyage.allPorts.first().code;
						endif;				
					endif;
				elseif defaultPort.code = params.loadPort then				
					createOnShip := false;
					if cargoTI.getVoyageCode() &lt;&gt; terminal.getConfig(DefTranshipOutwardVoyage).CM_Voyage.code then	// MTN-33633
						params.exportVoyageCode := cargoTI.getVoyageCode();
					endif;
					voyage := terminal.getConfig(DefTranshipInwardVoyage).CM_Voyage;
					if voyage &lt;&gt; null then
						params.voyageCode := voyage.code;
						params.transhipDischargePort := params.dischargePort;
						// TFS 61767 Don't care about ports of rotation, just use ports from the file
						//if voyage.allPorts.first() &lt;&gt; null then
						//	params.loadPort := voyage.allPorts.first().code;
						//endif;
					endif;
				else
					createOnShip := _ediPartyRules &lt;&gt; null and _ediPartyRules.eqdImportCargoSite &lt;&gt; TI_SITE_ONSITE;		//9/8/24   navsaa30 #65542
					if createOnShip then
						voyage := terminal.getConfig(DefTranshipOutwardVoyage).CM_Voyage;
						if voyage &lt;&gt; null then
							params.exportVoyageCode := voyage.code;
							if voyage.allPorts.first() &lt;&gt; null then
								params.transhipDischargePort := voyage.allPorts.first().code;
							endif;
						endif;
					else
						params.exportVoyageCode := cargoTI.getVoyageCode();
						voyage := terminal.getConfig(DefTranshipOutwardVoyage).CM_Voyage;
						if voyage &lt;&gt; null then
							params.voyageCode := voyage.code;
							params.transhipDischargePort := params.dischargePort;
						endif;
					endif;
				endif;		
				cargoTI.setVoyageCode(params.voyageCode);
				cargoTI.exportVoyageCode := params.exportVoyageCode;
				cargoTI.transhipDischargePort := params.transhipDischargePort;
				cargoTI.loadPort := params.loadPort;
				
				if not createOnShip then				
					cargoOnSite := cargoTI.cloneSelfAs(CM_EDICargoOnSiteTI, false).CM_EDICargoTI;
					cargoOnSite.setMyEDIData(_ediData);
					cargoOnSite.site := TI_SITE_ONSITE;
					cargoOnSite.setLocationId(_ediPartyRules.defaultLocationID);
					
					//replaced in the collection				
					delete cargoTI;
					params.allEDIItems.removeInvalidObjects();
					params.allEDIItems.add(cargoOnSite);
					
					//get the new cargo again to continue code processing...				
					cargoTI := params.allEDIItems[_msgHelper.currentSubItem].CM_EDICargoTI;				
				endif;
			endif;			
			// jlika1 TFS 56385 &lt;--
			//jlier1 TFS 57387 29/3/23
			cargoTI.setConsignment(cargoTI.getConsignment + 1);
		endif;
		
		//jlier1 TFS 57387 29/3/23
		if cargoTI.getConsignment &lt;= 1 then
			type := app.myRoot.allCargoTypesById[cargoTI.cargoType];
			//jlier1 TFS 56687 21/2/23
			if cargoTI.commodity = null then	
				if type &lt;&gt; null and type.isCommodityRequired then
					if type.defaultCommodityCode &lt;&gt; null then
						cargoTI.commodity := type.defaultCommodityCode;
					else
						cargoTI.commodity := params.defCmdty;
					endif;
				else
					cargoTI.commodity := null;
				endif;
			endif;
			cargoTI.dischargePort := params.dischargePort;									// TFS 5370
			cargoTI.loadPort := params.loadPort;											// TFS 5370
			
			if cargoTI.isKindOf(CM_EDICargoOnShipTI) then
				cargoTI.CM_EDICargoOnShipTI.myEDIBOLHeader := params.myEDIHdr.CM_EDIBOLHdrTI;
			endif;
			
			if cargoTI.cargoType = TI_CargoType_Container then
				cargoTI.totalQuantity := 1;							//24.11.2023 navma1 #61475
			else	
				cargoTI.totalQuantity := params.totalQuantity;		//24.11.2023 navma1 #61475
			endif;
			
			_msgHelper.setNextField();
			cargoTI.quantity := _msgHelper.currentField.asIntegerJMT();
			cargoTI.remarks  := params.remarks;
			if cargoTI.cargoType &lt;&gt; TI_CargoType_Container then				//02 Oct 2023	jlirs1	TFS POB Corrections
				cargoTI.make := params.model;
			endif;
											// TFS 3734	
			if params.gidCount&gt; 0 then																									//+TFS36528 Divided by the number in the same segment
				cargoTI.weight := params.totalWeight / params.gidCount;									
				cargoTI.volume := params.totalVolume/params.gidCount;
			endif;
			// If one MEA per GID, and the MEA was before this PCI					// TFS 3734
			if _ediPartyRules &lt;&gt; null and _ediPartyRules.oneMEAPerGID then			// TFS 3734
				cargoTI.weight := params.totalWeight;								// TFS 3734
				cargoTI.volume := params.totalVolume;								// TFS 3734
			endif;	
			
			// jlier1 TFS 56687 21/2/23
			if _ediPartyRules &lt;&gt; null and _ediPartyRules.pia5IsCommodity then
				cargoTI.commodity := params.commodityCodeHeader;				// TFS 3825
			endif;
			
			//jlgka1 TFS 39187 --&gt;
			if _ediPartyRules &lt;&gt; null then
				if cargoTI.destinationPort  = null and _ediPartyRules.useDiscPortAsDestPort then
					cargoTI.destinationPort := params.destination; 
				endif;
			endif;
			//jlgka1 TFS 39187  &lt;--
			
			if cargoTI.destinationPort  = null and 		//02 Oct 2023	jlirs1	TFS POB Corrections
			   params.destination &lt;&gt; null then
				cargoTI.destinationPort := params.destination; 
			endif;
			
			if cargoTI.getPortOfOrigin = null and 		//02 Oct 2023	jlirs1	TFS POB Corrections
			   params.originPort &lt;&gt; null then
				cargoTI.setPortOfOrigin(params.originPort);
			endif;
			
			if _ediPartyRules &lt;&gt; null and _ediPartyRules.isFullShipperDesc.Boolean then			//MTN-33703
				cargoTI.setShipperDescription(params.fullShipperDesc);							//MTN-33703
			else
				//jlier1 TFS 57380 29/3/23
				//if cargoTI.imexStatus = "EXPORT" then										// TFS 61808
				if cargoTI.imexStatus = "EXPORT" or not cargoTI.isEDICargoOnShipTI then		// TFS 61808
					cargoTI.setShipperDescription(params.consignor);
				else
					cargoTI.setShipperDescription(params.consignee);
				endif;
			endif;
			
			if params.mySenderOperator &lt;&gt; null then
				cargoTI.consignor := params.mySenderOperator.getXlationSystemCode(params.consignor, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch)[1:30]; //jlier1 TFS 57423 30/3/23
				if not foundMatch and _ediPartyRules &lt;&gt; null and _ediPartyRules.piaIsHSCode then  //POB have this set and only want to do this for POB
					cargoTI.consignor := null;
				endif;
				cargoTI.consignee := params.mySenderOperator.getXlationSystemCode(params.consignee, XLATION_TYPE_CONSIGNEE_BYOP, foundMatch);
				if not foundMatch and _ediPartyRules &lt;&gt; null and _ediPartyRules.piaIsHSCode then
					cargoTI.consignee := null;
				endif;
			else
				cargoTI.consignor := params.consignor[1:30]; //jlier1 TFS 55464 7/12/22
				cargoTI.consignee := params.consignee;
			endif;
				
			cargoTI.setHSCode(params.hsCode);//jlier1 TFS 55464 7/12/22
			
			bol := params.myEDIHdr.CM_EDIBOLHdrTI;
			if bol &lt;&gt; null then
				cargoTI.bol := bol.id;
				params.bolNumber := bol.id; //jlgka1 TFS 39187
			else
				if params.bolNumber &lt;&gt; null then
					cargoTI.bol := params.bolNumber;
				endif;
			endif;
			
			cargoTI.carrierRemarks := params.carrierRemarks;		// MTN-19374
		endif;
		
		if _ediPartyRules &lt;&gt; null and _ediPartyRules.meaIsCargoWeight then		
			cargoTI.cargoWeight := cargoTI.cargoWeight + params.cargoWeight;	
			cargoTI.weight := cargoTI.tareWeight + cargoTI.cargoWeight;
		endif;
		
		params.myEDIItem := cargoTI;		// store last-created item on params
		
		//jlier1 TFS 57426 12/4/23
		if not params.allEDICargoForGID.includes(cargoTI) then
			params.allEDICargoForGID.add(cargoTI);
		endif;
		
		params.commodityCodeHeader := null;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_msgHelper" type="CMIF_EDIFACTHelper" usage="io"/>
        <Parameter name="_ediPartyRules" type="CM_EDIPartyIFCSUMRules"/>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
    </JadeMethod>
</Class>
