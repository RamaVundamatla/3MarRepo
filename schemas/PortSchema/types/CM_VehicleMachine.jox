    <JadeMethod name="setMyPrimaryActualLocation" id="6c38e28f-f88a-4063-a7b4-f84976b23f3a">
        <updating/>
        <source>setMyPrimaryActualLocation(_primaryActualLocation : CM_YardController; _doLog : Boolean) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
09 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
