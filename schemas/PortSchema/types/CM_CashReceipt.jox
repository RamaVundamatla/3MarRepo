    <JadeMethod name="applyCreditOnProxy" id="c21fca11-668c-44f6-8b20-fb7ce472c0ec">
        <source>applyCreditOnProxy();
/*

Purpose:			
	This Method will be used to re-apply credit in case on unselecting one of the cash payments or adding extra item.
Parameters:			

Return Value:		

Date		Who		Reason
26 Sep 2019	jlgma1	Bug 46582: Cash Credit are not being accounted for correctly.
10 Jan 2020	cnwma1	Bug 48211: JMT - 4 x Issues relating to cash credit totals.

*/

vars
	pxyCashPayment,
	realCashPayment			: CM_CashPayment;
	allDebtorCredits        : ObjectArray;
	allDebtorCreditsAmount  : DecimalArray;
	cashCredit 			    : CM_CashCredit;
	pxyCreditDetail,
	pxyTaxCreditDetail	    : CM_CashCreditDetail;
	pxyCashTaxPayment       : CM_CashPayment;
	index	   			    : Integer;
	creditAvailable ,
	creditApplied,
	creditOnTax,
	creditOnPayment,
	valueOnPayment,
	valueOnPaymentTax	    : Decimal[23,6];
	obj                     : Object;
	configCashTax           : String;
	configInvMultiTax       : Boolean;
	terminal                : CM_Terminal;
	ti                      : CM_TrackedItem;
	now                     : TimeStamp;
begin
	

	if not self.isTransient then
		return;
	endif;
	
	/*
	First we need to delete the current transient credit details on the current payments on the sceen
	to re-apply credit again incase of unselecting or adding extra items.
	*/
	foreach pxyCashPayment in self.allCashPayments discreteLock do
		if not pxyCashPayment.allCashCreditDetails.isEmpty then // ### JIRA 35502 18JUL2025 NAVAB1 performance only do the work if we have credits
			
		realCashPayment := pxyCashPayment.pxyGetRealObject().CM_CashPayment;
		
		if realCashPayment &lt;&gt; null then
			continue;
		endif;
		
	//	if not pxyCashPayment.allCashCreditDetails.isEmpty then
			
			pxyCashPayment.allCashCreditDetails.purge;
			
			/*Tax*/
			if pxyCashPayment.myCashPaymentForTax &lt;&gt; null then
				if not pxyCashPayment.myCashPaymentForTax.allCashCreditDetails.isEmpty then	
					pxyCashPayment.myCashPaymentForTax.allCashCreditDetails.purge();
				endif;
			endif;
		endif;
	endforeach;
	

	create allDebtorCredits 	  transient;
	create allDebtorCreditsAmount transient;
	
	/*
	Get all available credit for that debtor.
	*/
	self.getCreditAvailableForDebtor(allDebtorCredits,allDebtorCreditsAmount);
	
	now 			  := app.actualTimeServer;
	terminal          :=  self.myTerminal;
	configCashTax     := terminal.getConfig(CashAllCashTax).String ;
	configInvMultiTax := terminal.getConfig(InvoiceMultiTaxRates).Boolean ;
	
	/*Re apply credit on only selected payments*/
	if allDebtorCredits.isNotEmpty then // ### JIRA 35502 18JUL2025 NAVAB1 performance only do the work if we have credits
		foreach pxyCashPayment in self.allCashPayments do
			
			realCashPayment := pxyCashPayment.pxyGetRealObject().CM_CashPayment;
			
			if realCashPayment &lt;&gt; null then
				continue;
			endif;
			
			if pxyCashPayment.status &lt;&gt; 0 then
				continue;
			endif;

			ti                := pxyCashPayment.myTrackedItem;
			valueOnPayment 	  := pxyCashPayment.cashValue;
			
			pxyCashTaxPayment := null;
			valueOnPaymentTax := null;
			
			if pxyCashPayment.myCashPaymentForTax &lt;&gt; null then
				pxyCashTaxPayment := pxyCashPayment.myCashPaymentForTax;
				valueOnPaymentTax := pxyCashPayment.myCashPaymentForTax.cashValue;
			endif;
			
			foreach obj in allDebtorCredits do
				index           := index +1 ;
				cashCredit		:= obj.CM_CashCredit;
				creditAvailable := allDebtorCreditsAmount[index];
				
				if creditAvailable &gt; 0 then
					
					if pxyCashTaxPayment &lt;&gt; null then
						if valueOnPayment + valueOnPaymentTax &gt; creditAvailable then
							creditApplied 	:= creditAvailable;
							creditOnPayment := (creditApplied * (valueOnPayment / (valueOnPayment + valueOnPaymentTax))).roundToFiveCents();
							creditOnTax 	:= creditApplied - creditOnPayment;
			
						else
							creditApplied 	:= valueOnPayment + valueOnPaymentTax;			
							creditOnPayment := valueOnPayment;
							creditOnTax 	:= valueOnPaymentTax;
						endif;
					else
						if valueOnPayment  &gt; creditAvailable then
							creditApplied 	:= creditAvailable;
							creditOnPayment := creditAvailable;
			
						else
							creditApplied 	:= valueOnPayment ;			
							creditOnPayment := valueOnPayment;
						endif;
					endif;
					
					valueOnPayment 	   := valueOnPayment    - creditOnPayment;
					if pxyCashTaxPayment &lt;&gt; null then
						valueOnPaymentTax  := valueOnPaymentTax - creditOnTax;
					endif;
					//Create Credit for Tax
					if creditOnTax &gt; 0 then
						if configCashTax = null and configInvMultiTax then		
							create pxyTaxCreditDetail transient;
							pxyTaxCreditDetail.setAppliedProxy(cashCredit, pxyCashTaxPayment, ti, creditOnTax, now);
						endif;
					endif;
		
					if creditOnPayment &gt; 0 then
						create pxyCreditDetail transient;
						pxyCreditDetail.setAppliedProxy(cashCredit, pxyCashPayment, ti, creditOnPayment, now);
					 
						creditAvailable 				 := creditAvailable - creditApplied;
						allDebtorCreditsAmount[index]	 := creditAvailable;
					endif;
				endif;
				
				
				if creditAvailable &lt;= 0 then 
					continue;
				endif;
				
				if  valueOnPayment &lt;= 0  then
					break;
				endif;
			endforeach;
			index := 0;
		endforeach;
	endif;
epilog
	delete allDebtorCredits; //02/05/2024	navkc1 CR63397  Task 63398 - transient leak
	delete allDebtorCreditsAmount; //02/05/2024	navkc1 CR63397  Task 63398  - transient leak
end;</source>
    </JadeMethod>
    <JadeMethod name="applyMinChargeByGroupOnProxy" id="50101133-f1b5-44f7-a12e-6c414aec5e58">
        <source>applyMinChargeByGroupOnProxy(_isInvoiceProforma : Boolean);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 Oct 2019	jlgma1	Bug 46674: JMT - Form - Minimum charges does not calculate minimum charges when grouping invoice lines
15 Jan 2020 cnwma1	Bug 48298: ADP - FW: Ticket 48149 - Minimum Charge Line remove in UAT - ##336278##
// ### JIRA 35502 18JUL2025 NAVAB1 performance moved the pxyGetRealObject() calls to be the last call in all these IF statements instead of the first
*/

vars
	linesByInvAndType 	 : DynaDictionary;
	pxyCashPayment       : CM_CashPayment;
	obj				 	 : Object;
	invLineDesc 		 : CM_InvoiceLineDesc;
	minChargeAmount,
	minTotal			 : Decimal[23,6];
	minLineDesc          : CM_InvoiceLineDesc;
	dynaKey              : String;
	iter                 : Iterator;
	oid                  : String;
	pxyInvLineType       : CM_InvoiceLineDesc;
	invLineGrpArr		 : ObjectArray;
	obj1                 : Object;
	grp                  : CM_InvoiceLineDescGroup;
	firstTI 			 : CM_TrackedItem;
begin
	
	if not self.isTransient then
		return;
	endif;
	
	create linesByInvAndType transient;
	linesByInvAndType.setMembership(CM_CashPayment);
	linesByInvAndType.addExternalKey(String,100, true, false);
	linesByInvAndType.endKeys(true);	
	
	// TFS 47852 Get a TI for the min charge payment to attach to 
	foreach pxyCashPayment in self.allCashPayments do
		if firstTI = null then // TFS 47852
			firstTI := pxyCashPayment.myTrackedItem; // TFS 47852
		endif;
	endforeach;

	/*Delete any Minimum charge by Group for recalculate*/
	foreach pxyCashPayment in self.allCashPayments do
		// ### JIRA 35502 18JUL2025 NAVAB1
		if pxyCashPayment.isMinimumCharge then
			if pxyCashPayment.isMinimumChargeByGroup then   //This will only filter the minimum charge by group ,In case there is any other type of min charge
				if pxyCashPayment.pxyGetRealObject = null then
					delete pxyCashPayment;
				endif;
			endif;
		endif;
	endforeach;

	create invLineGrpArr transient;
	
	/*
		Only selected,Not Real[Not Paid],
	*/
	foreach pxyCashPayment in self.allCashPayments do
		if pxyCashPayment.status &lt;&gt; 0 then
			continue;
		endif;
		
		// ### JIRA 35502 18JUL2025 NAVAB1
		if pxyCashPayment.myInvoiceLine &lt;&gt; null then
			pxyInvLineType := pxyCashPayment.myInvoiceLine.invoiceLineDesc;
		
		elseif pxyCashPayment.myProformaDetail &lt;&gt; null then
			pxyInvLineType := pxyCashPayment.myProformaDetail.myInvoiceLineType;
		endif;
		
		if pxyInvLineType.group = null then
			continue;
		endif;
		
		if pxyInvLineType.group.myMinimumChargeInvoiceLineType = null then
			continue;
		endif;

		
		if pxyCashPayment.pxyIsProxy  then
			if pxyCashPayment.pxyGetRealObject &lt;&gt; null then // PAID
				continue;
			endif;
		endif;
		
		
		invLineGrpArr.addExclusive(pxyInvLineType.group);
		
		dynaKey := pxyInvLineType.getOidString;
		linesByInvAndType.putAtKey(dynaKey,pxyCashPayment);
		
		
	endforeach;
	
	
	
	iter := linesByInvAndType.createIterator;
	
	
	foreach obj1 in invLineGrpArr do
		grp             := obj1.CM_InvoiceLineDescGroup;
		minTotal        := 0;
		minLineDesc     := null;
		minChargeAmount := 0;
		iter.startAtIndex(1);
		while iter.next(obj) do
			
			oid 		    := iter.getCurrentKey(1).String;
			invLineDesc     := oid.asOid.CM_InvoiceLineDesc;
			if grp &lt;&gt; invLineDesc.group then
				continue;
			endif;	
		
			minLineDesc     := invLineDesc.group.myMinimumChargeInvoiceLineType;
			
			if minLineDesc.minimumChargeGroupBy &lt;&gt; CM_InvoiceLineDesc.GROUP_BY_NONE then
				continue;
			endif;
			minChargeAmount := invLineDesc.group.minimumChargeAmount;
			minTotal        :=  minTotal + obj.CM_CashPayment.cashValue;
		endwhile;
		
		if minTotal &lt; minChargeAmount then
			
			// TFS 47852 need to attach the payment to a TI (any TI on the receipt) so that if re calc in cash collection it will be shown. 
			//					Re-calc means calcuate, save and re calculate
			//					These min charge by Invoice are other wise only linked to a cash receipt.
			//					Cash Collection always starts with cargo, so must link this to a TI on the receipt
			//self.createProxyMinCharge(minLineDesc,null,firstTI,minChargeAmount -  minTotal,_isInvoiceProforma);   // TFS 47852 pass in TI //15.01.2020 cnwma1 #48298
			self.createProxyManualPayment(minLineDesc,1,minChargeAmount -  minTotal,null,firstTI,true,true); 								//15.01.2020 cnwma1 #48298
		endif;
	endforeach;
epilog
		
	delete linesByInvAndType;
	delete iter ;
	delete invLineGrpArr;
end;</source>
        <Parameter name="_isInvoiceProforma" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="auditClass" id="ff13b730-15e3-44e6-89f0-a83c7db54d0d">
