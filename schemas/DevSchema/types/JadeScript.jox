	//ti:=gridObj.getLeastOverstowedAvailableTI(cmifRequest.CMIF_YARequest,"2832.6317070".asOid.CM_RTQueueTask);
	if ti &lt;&gt; null then
		write ti.id;
	endif;*/
	/*app.myPassport.errorsToIgnore.add(MACH_LIFT_POWER);
	app.myTrxUA.trxMachineAcceptTask("2296.984".asOid.CM_Machine,"2832.6639491".asOid.CM_RTQueueTask,
									null,					   
								   null ,									   
								   app.myPassport);*/
	
	
epilog
	delete allTIS;
	delete tasks;
end;</source>
