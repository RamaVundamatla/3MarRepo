//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.getFormParent.sysNotify (Object_Delete_Event, self, null);	// tacky i know
epilog

end;</source>
