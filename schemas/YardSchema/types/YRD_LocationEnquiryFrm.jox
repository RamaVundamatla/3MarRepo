    <JadeMethod name="addObjectsToTable" id="0647e626-eb02-497c-858f-d733582759b6">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
//----------------------------------------------------------------
//	Created:	14 March 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod(_numItems);

	if self.filterTerminalArea &lt;&gt; null then
		self.armNotesForObject(self.filterTerminalArea);
	endif;

end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addObjectsToTableSub" id="5dbab358-0ba6-4a74-b483-840376140146">
        <updating/>
        <source>addObjectsToTableSub(_tiID: String; _numItems: Integer io; _tiSet: CM_TISet io; _bolSet : CM_BOLSet io; _breakOut: Boolean io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2014	cnwma1	Initial creation

*/

vars
	tiSet			: CM_TISet;
	allRailLocs		: CM_LCSet;
	lc				: CM_LocationsController;
begin

	create tiSet transient;
	if self.filterYardLocation &lt;&gt; null then
		// Lookup based on the yard location	
		
		self.getTIsForLocationsController(self.filterYardLocation, _numItems, _tiSet, _tiID,  app.myPassport); //cnwrd1 par 24107 10.5.2010
		//epr TFS 37038 no point in copying as alreay has no dups just passed to method
		return;
		
	elseif self.filterTerminalArea &lt;&gt; null then
			// Lookup based on the terminal area
			if self.filterTerminalArea.isRail then	//19 Mar 2012	NDL	Par 29220
				create allRailLocs transient;
				self.filterTerminalArea.CM_Rail.getCurrentLocationsControllers( allRailLocs );
				foreach lc in allRailLocs discreteLock do
					self.getTIsForLocationsController(lc, _numItems, _tiSet, _tiID, app.myPassport);
					//epr TFS 37038 no point in copying as alreay has no dups just passed to method
				endforeach;
				delete allRailLocs;
			
			else
				foreach lc in self.filterTerminalArea.allLocationsControllers discreteLock do
					self.getTIsForLocationsController(lc, _numItems, _tiSet,_tiID, app.myPassport);		 //cnwrd1 par 24107 10.5.2010
					//epr TFS 37038 no point in copying as alreay has no dups just passed to method
				endforeach;
				
			endif;
		
		return;
	else
		inheritMethod(_tiID, _numItems, _tiSet, _bolSet, _breakOut);
	endif;

epilog
	delete tiSet;
	delete allRailLocs;
end;</source>
        <Parameter name="_tiID" type="String"/>
        <Parameter name="_numItems" type="Integer" usage="io"/>
        <Parameter name="_tiSet" type="CM_TISet" usage="io"/>
        <Parameter name="_bolSet" type="CM_BOLSet" usage="io"/>
        <Parameter name="_breakOut" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addPreNoteItemToWagon" id="b4582f19-6060-4512-b380-60fa8d5da69a">
        <updating/>
        <source>addPreNoteItemToWagon( _pxyTI : CM_TrackedItem ) updating;
/*

Purpose:			

Parameters:		Called by YRD_Assistant::addPreNoteFromCargoReceiptForm 	

Return Value:		

Date		Who		Reason
22 March 2013	cnwndl1	Initial creation	Par 31278

*/

vars

	wagCont : CM_BoxcarWagonController;
	boxcarWagonVisit : CM_BoxcarVisit;
	proxyTI : CM_TrackedItem;
	ti : CM_TrackedItem;
	result : Integer;

begin

	if not CM_BoxcarWagonController.hasInstance(self.myStartupObject) then
		return;
	endif;
	
	if _pxyTI = null then
		return;
	endif;
	
	proxyTI := _pxyTI;
	wagCont := self.myStartupObject.CM_BoxcarWagonController;
	boxcarWagonVisit := wagCont.myWagon.CM_BoxcarVisit;
	
	while true do
		// passes in a null for teh yeard location, this forces the creation of a rail receive job / wle.
		app.myTrxCA.trxReceiveExtraCargoFromBoxcar( proxyTI, ti, boxcarWagonVisit, null, app.myPassport );
	
		if app.myPassport.trxCompletedOK then
			self.handleNoteForBoxcarCargo( 0, ti, 0 );
			break;
		else
			result := app.showErrorWarningDialog(self.mnuCreateInBoxcar.caption, app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnSkipErr);
			if result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				// only reprocess the wles that had warnings.
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
			return;
		endif;
	endwhile;

epilog

end;</source>
        <Parameter name="_pxyTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="a08999b1-185d-4b8f-881a-7743d00660c7">
        <source>addToolbarControls() protected;
// -------------------------------------------
// Created 17 February 2004 by cnwdvb1
// -------------------------------------------
// 08/03/2011	cnwcs5	CCMS CPL 2027/PAR 27126 - new toolbar button
vars

	toolbar	: CMUI_Toolbar;
	user	: CM_User;

begin
	inheritMethod();
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnRestriction, CMUI_Toolbar.Control_Alignment_Left);
		
	user := app.getMyUser();
	
	if user &lt;&gt; null and user.canDo(self.myTerminal, Mod_BulkCargo) then
	
		toolbar.addButton(self.btnAdjustStock, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	// 08/03/2011 cnwcs5 - new toolbar button - View Terminal Area Audit Details
	if user &lt;&gt; null and user.canDo(self.myTerminal, PmAdmAuditTALocationView) then
		toolbar.addButton(self.btnTALocnAudit, CMUI_Toolbar.Control_Alignment_Left);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="armNotesForObject" id="2d9ae1ff-9520-4fd6-9d1b-cc41a82ff2f7">
        <source>armNotesForObject(_obj: Object);
//----------------------------------------------------------------
//	Created:	14 March 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if CM_BlockStack.hasInstance(_obj) then
		self.beginNotification(_obj.CM_BlockStack, Object_Update_Event, Response_Continuous, 0);
		return;
	endif;
	
	inheritMethod(_obj);
	
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
