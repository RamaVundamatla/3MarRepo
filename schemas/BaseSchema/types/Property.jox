    <JadeMethod name="cnEcIsProperty" id="5a50881a-6603-40ea-a8ca-b137a2148747">
        <source>cnEcIsProperty(): Boolean;
// -----------------------------------------------------------------------------
// Created:		01 November 2001 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is a
//				Property object.
//
// Parameters:	None
//
// Returns:		True if the receiver is a Property, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
