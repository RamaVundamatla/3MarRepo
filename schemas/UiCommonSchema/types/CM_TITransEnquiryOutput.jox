    <JadeMethod name="initDetailLine" id="61374149-4398-41e1-a6cd-43476e884589">
        <source>initDetailLine(numFrames : Integer; lCaption : String) protected;
// ---------------------------------------------------------------------------
// Created:  May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	
	// make the frames inside the detail frame equal in size and evenly spread accross the line
	if numFrames = 2 then						// not used
		self.frDetail_7.visible := false;
		self.frDetail_6.visible := false;
		self.frDetail_5.visible := false;
		self.frDetail_4.visible := false;
		self.frDetail_3.visible := false;
		self.frDetail_1.width := self.frDetail.width / 5;
		self.frDetail_2.width := self.frDetail.width - self.frDetail_1.width;

		self.frDetail_1.left := 1;
		self.frDetail_2.left := self.frDetail_1.left + self.frDetail_1.width - 1;

		// print the Header tab, hide the unwanted frames
		self.frDetail_1.caption := lCaption;	
		self.frDetail_1.fontBold := true;
		self.frDetail_1.backColor := Black;
		self.frDetail_1.foreColor := White;
		self.frDetail_2.visible := false;
		app.printer.print(self.frDetail);

		// prepare the detail frames
		self.frDetail_1.fontBold := false;
		self.frDetail_1.backColor := White;
		self.frDetail_1.foreColor := Black;
		self.frDetail_2.visible := true;
	endif;
	if numFrames = 3 then					// temperatures
		self.frDetail_7.visible := false;
		self.frDetail_6.visible := false;
		self.frDetail_5.visible := false;
		self.frDetail_4.visible := false;
		self.frDetail_1.width := self.frDetail.width / 5;
		self.frDetail_2.width := self.frDetail_1.width;
		self.frDetail_3.width := self.frDetail.width - (self.frDetail_1.width + self.frDetail_2.width);

		self.frDetail_1.left := 1;
		self.frDetail_2.left := self.frDetail_1.left + self.frDetail_1.width - 1;
		self.frDetail_3.left := self.frDetail_2.left + self.frDetail_2.width - 1;

		// print the Header tab, hide the unwanted frames
		self.frDetail_1.caption := lCaption;	
		self.frDetail_1.fontBold := true;
		self.frDetail_1.backColor := Black;
		self.frDetail_1.foreColor := White;
		self.frDetail_2.visible := false;
		self.frDetail_3.visible := false;
		app.printer.print(self.frDetail);

		// prepare the detail frames
		self.frDetail_1.fontBold := false;
		self.frDetail_1.backColor := White;
		self.frDetail_1.foreColor := Black;
		self.frDetail_2.visible := true;
		self.frDetail_3.visible := true;
	endif;
	if numFrames = 4 then						// not used
		self.frDetail_7.visible := false;
		self.frDetail_6.visible := false;
		self.frDetail_5.visible := false;
		self.frDetail_1.width := self.frDetail.width / 5;
		self.frDetail_2.width := self.frDetail_1.width;
		self.frDetail_3.width := self.frDetail_1.width / 2;
		self.frDetail_4.width := self.frDetail.width - (self.frDetail_1.width + self.frDetail_2.width + self.frDetail_3.width + self.frDetail_4.width);

		self.frDetail_1.left := 1;
		self.frDetail_2.left := self.frDetail_1.left + self.frDetail_1.width - 1;
		self.frDetail_3.left := self.frDetail_2.left + self.frDetail_2.width - 1;
		self.frDetail_4.left := self.frDetail_3.left + self.frDetail_3.width - 1;

		// print the Header tab, hide the unwanted frames
		self.frDetail_1.caption := lCaption;	
		self.frDetail_1.fontBold := true;
		self.frDetail_1.backColor := Black;
		self.frDetail_1.foreColor := White;
		self.frDetail_2.visible := false;
		self.frDetail_3.visible := false;
		self.frDetail_4.visible := false;
		app.printer.print(self.frDetail);

		// prepare the detail frames
		self.frDetail_1.fontBold := false;
		self.frDetail_1.backColor := White;
		self.frDetail_1.foreColor := Black;
		self.frDetail_2.visible := true;
		self.frDetail_3.visible := true;
		self.frDetail_4.visible := true;
	endif;
	if numFrames = 5 then						// transactions
		self.frDetail_7.visible := false;
		self.frDetail_6.visible := false;
		self.frDetail_1.width := self.frDetail.width / 5;
		self.frDetail_2.width := self.frDetail_1.width;
		self.frDetail_3.width := self.frDetail_1.width / 2;
		self.frDetail_4.width := self.frDetail_1.width / 2;
		self.frDetail_5.width := self.frDetail.width - (self.frDetail_1.width + self.frDetail_2.width + self.frDetail_3.width + self.frDetail_4.width);

		self.frDetail_1.left := 1;
		self.frDetail_2.left := self.frDetail_1.left + self.frDetail_1.width - 1;
		self.frDetail_3.left := self.frDetail_2.left + self.frDetail_2.width - 1;
		self.frDetail_4.left := self.frDetail_3.left + self.frDetail_3.width - 1;
		self.frDetail_5.left := self.frDetail_4.left + self.frDetail_4.width - 1;

		// print the Header tab, hide the unwanted frames
		self.frDetail_1.caption := lCaption;	
		self.frDetail_1.fontBold := true;
		self.frDetail_1.backColor := Black;
		self.frDetail_1.foreColor := White;
		self.frDetail_2.visible := false;
		self.frDetail_3.visible := false;
		self.frDetail_4.visible := false;
		self.frDetail_5.visible := false;
		app.printer.print(self.frDetail);

		// prepare the detail frames
		self.frDetail_1.fontBold := false;
		self.frDetail_1.backColor := White;
		self.frDetail_1.foreColor := Black;
		self.frDetail_2.visible := true;
		self.frDetail_3.visible := true;
		self.frDetail_4.visible := true;
		self.frDetail_5.visible := true;
	endif;
	if numFrames = 6 then									// event, warnings
		self.frDetail_7.visible := false;
		self.frDetail_1.width := self.frDetail.width / 5;
		self.frDetail_2.width := self.frDetail_1.width / 2;
		self.frDetail_3.width := self.frDetail_1.width / 2;
		if lCaption = "Event Requests" then					// from 32673 testing, make Organisation and Request bigger to avoid truncating the content
			self.frDetail_4.width := self.frDetail_1.width;
			self.frDetail_5.width := self.frDetail_1.width;
		else
			self.frDetail_4.width := self.frDetail_1.width / 2;
			self.frDetail_5.width := self.frDetail_1.width / 2;
		endif;
		self.frDetail_6.width := self.frDetail.width - (self.frDetail_1.width + self.frDetail_2.width + self.frDetail_3.width + self.frDetail_4.width + self.frDetail_5.width);

		self.frDetail_1.left := 1;
		self.frDetail_2.left := self.frDetail_1.left + self.frDetail_1.width - 1;
		self.frDetail_3.left := self.frDetail_2.left + self.frDetail_2.width - 1;
		self.frDetail_4.left := self.frDetail_3.left + self.frDetail_3.width - 1;
		self.frDetail_5.left := self.frDetail_4.left + self.frDetail_4.width - 1;
		self.frDetail_6.left := self.frDetail_5.left + self.frDetail_5.width - 1;

		// print the Header tab, hide the unwanted frames
		self.frDetail_1.caption := lCaption;	
		self.frDetail_1.fontBold := true;
		self.frDetail_1.backColor := Black;
		self.frDetail_1.foreColor := White;
		self.frDetail_2.visible := false;
		self.frDetail_3.visible := false;
		self.frDetail_4.visible := false;
		self.frDetail_5.visible := false;
		self.frDetail_6.visible := false;
		app.printer.print(self.frDetail);

		// prepare the detail frames
		self.frDetail_1.fontBold := false;
		self.frDetail_1.backColor := White;
		self.frDetail_1.foreColor := Black;
		self.frDetail_2.visible := true;
		self.frDetail_3.visible := true;
		self.frDetail_4.visible := true;
		self.frDetail_5.visible := true;
		self.frDetail_6.visible := true;
	endif;
	// 32673 print all charges columns
	if numFrames = 7 then										// charges
		self.frDetail_1.width := self.frDetail.width / 5;
		self.frDetail_2.width := self.frDetail_1.width / 2;
		self.frDetail_3.width := self.frDetail_1.width / 2;
		self.frDetail_4.width := self.frDetail_1.width / 2;
		self.frDetail_5.width := self.frDetail_1.width / 2;
		self.frDetail_6.width := self.frDetail_1.width / 2;
		self.frDetail_7.width := self.frDetail.width - (self.frDetail_1.width + self.frDetail_2.width + self.frDetail_3.width + self.frDetail_4.width + 
								 self.frDetail_5.width + self.frDetail_6.width);

		self.frDetail_1.left := 1;
		self.frDetail_2.left := self.frDetail_1.left + self.frDetail_1.width - 1;
		self.frDetail_3.left := self.frDetail_2.left + self.frDetail_2.width - 1;
		self.frDetail_4.left := self.frDetail_3.left + self.frDetail_3.width - 1;
		self.frDetail_5.left := self.frDetail_4.left + self.frDetail_4.width - 1;
		self.frDetail_6.left := self.frDetail_5.left + self.frDetail_5.width - 1;
		self.frDetail_7.left := self.frDetail_6.left + self.frDetail_6.width - 1;

		// print the Header tab, hide the unwanted frames
		self.frDetail_1.caption := lCaption;	
		self.frDetail_1.fontBold := true;
		self.frDetail_1.backColor := Black;
		self.frDetail_1.foreColor := White;
		self.frDetail_2.visible := false;
		self.frDetail_3.visible := false;
		self.frDetail_4.visible := false;
		self.frDetail_5.visible := false;
		self.frDetail_6.visible := false;
		self.frDetail_7.visible := false;
		app.printer.print(self.frDetail);

		// prepare the detail frames
		self.frDetail_1.fontBold := false;
		self.frDetail_1.backColor := White;
		self.frDetail_1.foreColor := Black;
		self.frDetail_2.visible := true;
		self.frDetail_3.visible := true;
		self.frDetail_4.visible := true;
		self.frDetail_5.visible := true;
		self.frDetail_6.visible := true;
		self.frDetail_7.visible := true;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="numFrames" type="Integer"/>
        <Parameter name="lCaption" type="String"/>
    </JadeMethod>
    <JadeMethod name="initPrintLine01" id="e85d09a5-443e-41ff-9ade-89acbe188d86">
        <source>initPrintLine01(i : Integer) protected;
// ---------------------------------------------------------------------------
// Created:  May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

		self.frDetail_1.foreColor := Black;
		self.frDetail_2.foreColor := Black;
		self.frDetail_3.foreColor := Black;
		self.frDetail_4.foreColor := Black;
		self.frDetail_5.foreColor := Black;
		self.frDetail_6.foreColor := Black;
		self.frDetail_7.foreColor := Black;
		if i = 1 then								// Heading line
			self.frDetail_1.backColor := Gray;
			self.frDetail_2.backColor := Gray;
			self.frDetail_3.backColor := Gray;
			self.frDetail_4.backColor := Gray;
			self.frDetail_5.backColor := Gray;
			self.frDetail_6.backColor := Gray;
			self.frDetail_7.backColor := Gray;
			self.frDetail_1.fontBold := true;
			self.frDetail_2.fontBold := true;
			self.frDetail_3.fontBold := true;
			self.frDetail_4.fontBold := true;
			self.frDetail_5.fontBold := true;
			self.frDetail_6.fontBold := true;
			self.frDetail_7.fontBold := true;
		else										// details
			self.frDetail_1.backColor := White;
			self.frDetail_2.backColor := White;
			self.frDetail_3.backColor := White;
			self.frDetail_4.backColor := White;
			self.frDetail_5.backColor := White;
			self.frDetail_6.backColor := White;
			self.frDetail_7.backColor := White;
			self.frDetail_1.fontBold := false;
			self.frDetail_2.fontBold := false;
			self.frDetail_3.fontBold := false;
			self.frDetail_4.fontBold := false;
			self.frDetail_5.fontBold := false;
			self.frDetail_6.fontBold := false;
			self.frDetail_7.fontBold := false;
		endif;

end;</source>
        <access>protected</access>
        <Parameter name="i" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="initPrintLine02" id="930febb1-68a2-43ba-9973-a6a4e8a9788a">
        <source>initPrintLine02( frWidth : Integer; str : String; last : Boolean ) protected;
// ---------------------------------------------------------------------------
// Created:  May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	//PAR13401 - now we will have the frame height by windows font size
	if str.length &gt; 0 then
		self.frDetail.height := self.frDetail.getTextHeightForWidth( str, frWidth );
	else
		self.frDetail.height := self.frDetail.getTextHeightForWidth( 'Empty row as one row', frWidth );
	endif;

	if last then
		self.frDetail_1.height := self.frDetail.height;
		self.frDetail_2.height := self.frDetail.height;
		self.frDetail_3.height := self.frDetail.height;
		self.frDetail_4.height := self.frDetail.height;
		self.frDetail_5.height := self.frDetail.height;
		self.frDetail_6.height := self.frDetail.height;
		self.frDetail_7.height := self.frDetail.height;
	else
		self.frDetail_1.height := self.frDetail.height + 1;
		self.frDetail_2.height := self.frDetail.height + 1;
		self.frDetail_3.height := self.frDetail.height + 1;
		self.frDetail_4.height := self.frDetail.height + 1;
		self.frDetail_5.height := self.frDetail.height + 1;
		self.frDetail_6.height := self.frDetail.height + 1;
		self.frDetail_7.height := self.frDetail.height + 1;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="frWidth" type="Integer"/>
        <Parameter name="str" type="String"/>
        <Parameter name="last" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initReport" id="104f9f94-241b-4559-8784-d22ae32a6a35">
        <source>initReport();
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.portteclogo.picture := app.getPicLogoProduct();
	self.picLogo.picture := app.getPicLogoPort();

end;</source>
    </JadeMethod>
    <JadeMethod name="printCharges" id="29203eda-aaf8-4763-9102-cbb1017f330a">
        <source>printCharges(_tbl : CM_DataTable input) protected;
// ---------------------------------------------------------------------------
// Created:  May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	i, 
	numRows		: Integer;
begin
	
	numRows := _tbl.rows;
	if numRows &lt;= _tbl.fixedRows then
		return;
	endif;
	
	// 32673 print Narration as well
	self.initDetailLine(7, "Charges");	
	foreach i in 1 to numRows do
		self.initPrintLine01(i);		
		self.frDetail_1.caption := _tbl.accessCell(i,1).text;
		self.frDetail_2.caption := _tbl.accessCell(i,2).text;
		self.frDetail_3.caption := _tbl.accessCell(i,3).text;
		self.frDetail_4.caption := _tbl.accessCell(i,4).text;
		self.frDetail_5.caption := _tbl.accessCell(i,5).text;
		self.frDetail_6.caption := _tbl.accessCell(i,6).text;
		self.frDetail_7.caption := _tbl.accessCell(i,7).text;

		self.initPrintLine02( self.frDetail_7.width.Integer, self.frDetail_7.caption, (i = numRows) );	//PAR13401
		
		app.printer.print(self.frDetail);
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="printDiscrepancies" id="cd7bd181-aa47-435c-9505-11cb1be902d3">
        <source>printDiscrepancies(_tbl : CM_DataTable input) protected;
// ---------------------------------------------------------------------------
// Created:  May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	i, j, 
	numLines,
	numRows		: Integer;
begin

	numRows := _tbl.rows;
	if numRows &lt;= _tbl.fixedRows then
		return;
	endif;
	
	//self.initDetailLine(2, "Discrepancies");	
	// cnwjk3 PAR 18195 21/11/08
	self.initDetailLine(6, "Overridden Warnings");	

	foreach i in 1 to numRows do
		self.initPrintLine01(i);		
		
		self.frDetail_1.caption := _tbl.accessCell(i,1).text;
		self.frDetail_2.caption := _tbl.accessCell(i,2).text;

		// cnwjk3 PAR 18195 21/11/08
		self.frDetail_3.caption := _tbl.accessCell(i,3).text;
		self.frDetail_4.caption := _tbl.accessCell(i,4).text;
		self.frDetail_5.caption := _tbl.accessCell(i,5).text;
		self.frDetail_6.caption := _tbl.accessCell(i,6).text;

		
		//		numLines := self.getNumLines(self.frDetail_2.caption);
		//self.initPrintLine02(self.frDetail_2.width.Integer, self.frDetail_2.caption, (i = numRows));	//PAR13401	
				
		// cnwjk3 PAR 18195 21/11/08
		self.initPrintLine02(self.frDetail_6.width.Integer, self.frDetail_6.caption, (i = numRows));
		
		app.printer.print(self.frDetail);
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="printEventRequests" id="5fa05e77-1754-4aed-bbe4-c8bf551ce162">
        <source>printEventRequests(_tbl : CM_DataTable input) protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/03/2010	cnwdap1	Initial creation PAR #22671
*/
vars
	i, 
	numLines,
	numRows		: Integer;
	
begin
	numRows := _tbl.rows;
	if numRows &lt;= _tbl.fixedRows then
		return;
	endif;
	
	self.initDetailLine(6, "Event Requests");
	foreach i in 1 to numRows do
		self.initPrintLine01(i);		
	
		self.frDetail_1.caption := _tbl.accessCell(i,1).text;
		self.frDetail_2.caption := _tbl.accessCell(i,2).text;
		self.frDetail_3.caption := _tbl.accessCell(i,3).text;
		self.frDetail_4.caption := _tbl.accessCell(i,4).text;
		self.frDetail_5.caption := _tbl.accessCell(i,5).text;
		self.frDetail_6.caption := _tbl.accessCell(i,6).text;
		self.initPrintLine02( self.frDetail_6.width.Integer, self.frDetail_6.caption, (i = numRows));
		app.printer.print(self.frDetail);
	endforeach;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="printReport" id="587ecbb2-ce43-4b8d-84cc-3a921ef9f73d">
        <source>printReport(ourEnqFrame : CMUI_TransactionEnquiry input; numTemps : Integer);
// ---------------------------------------------------------------------------
// Created:  May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
// ---------------------------------------------------------------------------
// 17/03/2010	cnwdap1	PAR #22671 Print Event Requests table too
// Feb 2012 CCMS 1262 transaction enquiry use new form
vars

begin

	self.printTransactions(ourEnqFrame.tblTrans);
	self.printDiscrepancies(ourEnqFrame.tblDiscrepances);
	self.printCharges(ourEnqFrame.tblCharges);
	if numTemps &gt; 0 then
		self.printTemperatures(ourEnqFrame.tblTemperatures);
	endif;
	self.printEventRequests(ourEnqFrame.tblEventNotify);	// PAR #22671
end;</source>
        <Parameter name="ourEnqFrame" type="CMUI_TransactionEnquiry" usage="input"/>
        <Parameter name="numTemps" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="printTemperatures" id="ac78f184-fb16-4e44-99d7-975e8a57a7b0">
        <source>printTemperatures(_tbl : CM_DataTable input) protected;
// ---------------------------------------------------------------------------
// Created:  May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	i,
	numRows	: Integer;
begin
	
	numRows := _tbl.rows;
	
	self.initDetailLine(3, "Temperatures");	
	foreach i in 1 to numRows do
		self.initPrintLine01(i);		
		self.frDetail_1.caption := _tbl.accessCell(i,1).text;
		self.frDetail_2.caption := _tbl.accessCell(i,2).text;
		self.frDetail_3.caption := _tbl.accessCell(i,3).text;
		self.initPrintLine02(self.frDetail_3.width.Integer, self.frDetail_3.caption, (i = numRows));	//PAR13401	
				
		app.printer.print(self.frDetail);
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="printTransactions" id="b2f1ed2a-11aa-4ad6-ad9a-505fbb84c056">
        <source>printTransactions(_tbl : CM_DataTable input) protected;
// ---------------------------------------------------------------------------
// Created:  May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
vars	
	thePageHeight,
	i, 
	numRows		: Integer;
	editStrings 	: HugeStringArray;
	detailString	: String;
begin
	
	numRows := _tbl.rows;
	if numRows &lt;= _tbl.fixedRows then
		return;
	endif;
	
	self.initDetailLine(5, "Transactions");	
	foreach i in 1 to numRows do
		self.initPrintLine01(i);		
	
		//11 Jun 2010	NDL Par 24419
		self.frDetail_1.caption := _tbl.accessCell(i,_tbl.getColumnByRowName(ETRow_Type)).text;
		self.frDetail_2.caption := _tbl.accessCell(i,_tbl.getColumnByRowName(ETRow_Date)).text;
		self.frDetail_3.caption := _tbl.accessCell(i,_tbl.getColumnByRowName(ETRow_Charged)).text;
		self.frDetail_4.caption := _tbl.accessCell(i,_tbl.getColumnByRowName(ETRow_User)).text;
		
		detailString:=_tbl.accessCell(i,_tbl.getColumnByRowName(ETRow_Details)).text;
		self.frDetail_5.caption := detailString;
		
		self.initPrintLine02( self.frDetail_5.clientWidth, detailString, (i = numRows));	//PAR13401	
		thePageHeight:= app.printer.pageHeight - app.printer.getPrintPosition ;
			
		self.printTransactionsLine();
	endforeach;
epilog
	delete editStrings;
end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="printTransactionsLine" id="1463d21e-1772-4c83-882e-9c714664790a">
        <source>printTransactionsLine() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 May 2012	cnwer1	Initial creation PAR 29482 - break up lines that are too big to print in seperate lines
					otherwise we get 15007 exception
*/

vars
	
	frmHeight,
	thePageHeight,
	i, j		: Integer;
	editStrings 	: HugeStringArray;
	detailString,
	nextLine	: String;
begin
	detailString:=self.frDetail_5.caption;
	thePageHeight:= app.printer.pageHeight - app.printer.getPrintPosition ;
	//epr par 29482 2/5/12
	if thePageHeight = 0 or self.frDetail.clientHeight &lt;= thePageHeight  then 
		app.printer.print(self.frDetail);
	else	

		if detailString = null then
			return;
		endif;
		frmHeight:=self.frDetail.clientHeight;
		detailString.trimWhiteSpace;
		create editStrings transient;
				
		detailString.getTokensForDelimiterHugeNoNul(CrLf.Character,editStrings);
		j:=editStrings.size;
		if j &gt; 1 then
			while frmHeight &gt;= thePageHeight do
				if j = 0 then
					break;
				endif;
				i:= detailString.length -editStrings[j].length-1;
				if i &gt; 1 then
					nextLine:=detailString[i+1:end] &amp;  nextLine;
					detailString:=detailString[1:i]; 	
				endif;
				j:=j-1;
				frmHeight:=self.frDetail.getTextHeightForWidth(detailString,self.frDetail_5.clientWidth);
			endwhile;
		endif;

		self.frDetail_5.caption:=detailString;
		self.initPrintLine02( self.frDetail_5.clientWidth, detailString, false);	//PAR13401
		
		if  self.frDetail.clientHeight &gt; thePageHeight then
			app.printer.newPage;
		endif;
	
		app.printer.print(self.frDetail);
		
		if nextLine = null  then
			return;
		endif;
		
		thePageHeight:= app.printer.pageHeight - app.printer.getPrintPosition ;
	
		self.frDetail_5.caption:=nextLine;
		self.initPrintLine02( self.frDetail_5.clientWidth, nextLine, false);	//PAR13401	
		self.printTransactionsLine();		
	endif;
epilog
	delete editStrings;
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
