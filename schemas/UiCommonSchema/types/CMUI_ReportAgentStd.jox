    <JadeMethod name="getSelectedTransTypes" id="41d5a59c-c82e-4355-9f39-7440318298e5">
        <source>getSelectedTransTypes( _transTypeArray : IntegerArray input );
// getSelectedTransTypeDescrs(_transTypeArray: StringArray input);	// cnwrl1 07/09/2009 PAR 20198 - what it was
// ---------------------------------------------------------------------------
// Created:     09 September 2004 by cnwrs2
//
// Purpose:     Populate the transaction integer array with the selected transaction types.
// ---------------------------------------------------------------------------
vars
	strObj		: Object;
	transObject	: Object;
	
begin
	/* cnwrl1 07/09/2009 PAR 20198 - what it was
	if _transTypeArray = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_transTypeArray', null, null);
		return;
	endif;
	if self.isRowIncluded(ETRow_TransactionType) then
		foreach strObj in self.myLstTblTransact.allSelectedObjects do
			_transTypeArray.add(strObj.CM_String.string);
		endforeach;
	endif;
	cnwrl1 07/09/2009 PAR 20198 - end of what it was */
	
	if _transTypeArray = null then
		app.raiseCMException2( MethodWithNullParam, method.name, '_transTypeArray', null, null );
		return;
	endif;
	_transTypeArray.clear();
	
	if not self.isRowIncluded( ETRow_TransactionType ) then
		return;
	endif;
	
	foreach strObj in self.myLstTblTransact.allSelectedObjects do : trans_loop
		transObject	:= strObj.CM_StringWithObject.object;
		if not transObject.isKindOf( CM_TransactionType ) then
			// they should be CM_TransactionType but just in case
			continue trans_loop;
		endif;
		_transTypeArray.add( transObject.CM_TransactionType.trxType );
	endforeach trans_loop;
	
epilog
	
end;
</source>
        <Parameter name="_transTypeArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
