    <JadeMethod name="setForUpdate" id="749e5863-2a8a-4e3d-b48b-6fbf5b39a251">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
/*
Purpose:			
Parameters:			
Return Value:		
Date		Who		Reason
08 July 2014	cnwmc5	Initial creation
*/
/// 22 Feb 2016	cnwrs1	TFS 3401 fixup EDI Operations update of EDI TIs

vars

begin
	inheritMethod(_proxyEDITI);

	self.billOfLading	:= _proxyEDITI.billOfLading;
	self.dispositionCode:= _proxyEDITI.dispositionCode;
	self.controlNumber  := _proxyEDITI.controlNumber.Integer;
	self.entryType      := _proxyEDITI.entryType;
	self.entryNumber	:= _proxyEDITI.entryNumber;
	self.vesselName 	:= _proxyEDITI.vesselName;
	self.voyageCode		:= _proxyEDITI.voyageCode;
	self.portInBond 	:= _proxyEDITI.portInBond;
	self.portForeign	:= _proxyEDITI.portForeign;
	self.portInTransit	:= _proxyEDITI.portInTransit;
	self.portOfEntry	:= _proxyEDITI.portOfEntry;
	self.remarks 		:= _proxyEDITI.remarks;
	self.postedDate		:= _proxyEDITI.postedDate;
	self.postedTime		:= _proxyEDITI.postedTime;
	self.processedDT	:= _proxyEDITI.processedDT;
	self.ediFileVoyageCode := _proxyEDITI.ediFileVoyageCode;
	self.quantity		:= _proxyEDITI.quantity;		//cnwmc5 - 21 July 2014 - CCMS 2353 PEN
	self.voyageOperator := _proxyEDITI.voyageOperator;
epilog

end;</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setMessageDetails" id="e060ffc5-68a8-4bee-8b91-12010d53a4f5">
