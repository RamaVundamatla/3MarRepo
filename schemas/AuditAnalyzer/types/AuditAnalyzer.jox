<Class name="AuditAnalyzer" id="431dc25b-7831-4acd-bb5a-61580a35f1b2">
    <superclass name="RootSchemaApp"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <ImplicitInverseRef name="controller" id="3c613e99-2748-412d-9b69-fd291f31377f">
        <embedded/>
        <type name="AAControl"/>
    </ImplicitInverseRef>
    <JadeMethod name="dumpJournals" id="8d150b28-d3f4-4d3b-93fb-144189bb85bd">
        <source>dumpJournals(job : AAJob io);
vars
	controller : AAControl;
begin
	
	create controller transient;
	controller.dumpJournals(job.fileName, job.journalPath, job.startJournal, job.endJournal, job.filterStartTime, job.filterEndTime);
	
	terminate;
epilog
	delete controller;
end;
</source>
        <Parameter name="job" type="AAJob" usage="io"/>
    </JadeMethod>
    <JadeMethod name="finalize" id="13f24eca-d6cf-4c36-a4cb-1433d36e6309">
        <updating/>
        <source>finalize() updating;

vars

begin
	delete controller;
end;
</source>
    </JadeMethod>
    <JadeMethod name="initialize" id="a010a303-4ec3-4209-8133-c6cb59f0c14f">
        <updating/>
        <source>initialize() updating;

vars

begin
	create controller transient;
end;
</source>
    </JadeMethod>
</Class>
