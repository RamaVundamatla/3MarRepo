    <JadeMethod name="tStopsOverriddenReason" id="2a6465e2-68c6-42d6-9752-4bf8d375192c">
        <source>tStopsOverriddenReason();
/*

Purpose:			

Date		Who		Reason
06 November 2015	cnwmk3	Initial creation

*/
constants
   ReasonCode                                    : String = "UT_REASON1";
   ReasonDescription                             : String = "Created by Unit test";
vars
   proxyStopReason, proxyUpdateStopReason        : CM_StopOverridenReason;
   realStopReason                                : CM_StopOverridenReason;
begin
 
// create StopOverridden Reason
   create proxyStopReason transient;
   proxyStopReason.setProxy(ReasonCode, ReasonDescription);
   app.myTrxCA.trxCreateStopOverriddenReason(proxyStopReason, realStopReason, app.myPassport);
   self.assertNoTrxErrorsOrWarnings();
   
// update StopOverridden Reason
   beginLoad;
   proxyUpdateStopReason := realStopReason.pxyCreateUpdateProxy();
   endLoad;
   proxyUpdateStopReason.setPropertyValue("description", "Updated by Unit Test");
   app.myTrxUA.trxUpdateStopOverriddenReason(proxyUpdateStopReason, app.myPassport );
   self.assertNoTrxErrorsOrWarnings();
   
// delete StopOverridden Reason
   realStopReason := app.myRoot.allStopOverridenReasonsByCode[ReasonCode];
   if realStopReason &lt;&gt; null then
      app.myTrxDA.trxDeleteStopOverriddenReason(realStopReason, app.myPassport);
	  self.assertNoTrxErrorsOrWarnings();
   endif;
epilog
   delete proxyStopReason;
   delete proxyUpdateStopReason;
end;</source>
    </JadeMethod>
