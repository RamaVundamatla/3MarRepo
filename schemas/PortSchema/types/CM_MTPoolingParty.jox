    <JadeMethod name="erase" id="c10e70f2-6b15-46a7-a307-9a52d431f2a6">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 13/12/2016	cnwdap1		Initial creation TFS 3042 SNO Empty Container Pool Management
//
vars
	opTerm : CM_OperatorTerminal;

begin
	if self.isTransient then
		while true do
			if self.allOperatorTerminals.isEmpty then
				break;
			endif;
			
			opTerm := self.allOperatorTerminals.last;
			if opTerm.isTransient then
				opTerm.erase(_eraseLevel);
			endif;
		endwhile;
	endif;

	inheritMethod(_eraseLevel);	
epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="1f5e4620-2143-4554-a748-30932c22ff0f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 06/12/2016	cnwdap1		Initial creation TFS 3039 SNO Empty Container Pool Management
//
vars

begin
	if _attrName = ETRow_Operators then
		return self.getOperatorsString();
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOperatorsString" id="ecb2b7eb-59a7-4990-aa30-cd4db756e230">
        <source>getOperatorsString() : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 06/12/2016	cnwdap1		Initial creation TFS 3039 SNO Empty Container Pool Management
//
vars
	opTerm : CM_OperatorTerminal;
	str : String;

begin
	foreach opTerm in self.allOperatorTerminals discreteLock do
		if str = null then
			str := opTerm.myOperator.code;
		else
			str := str &amp; Comma &amp; Space &amp; opTerm.myOperator.code;
		endif;
	endforeach;
	
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getYADisplay" id="06394799-4004-4532-9248-f20072ad8194">
