    <JadeMethod name="doDelete" id="9945fe37-6448-47bc-8345-c9d99f993ab7">
        <updating/>
        <source>doDelete()updating, protected;
//--------------------------------------------------
// Created:	13 September 2004 By: cnwgd1
//--------------------------------------------------
// ### JIRA 33543 12DEC2024 NAVAB1 change to use constants
vars
	productCode,
	tmpStr : String;
	cmifMonitor	: CMIF_Monitor;	
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
begin
	if self.myLicenseObject = null then
		return;
	endif;
	
	if (not app.myCurrentUserCan(self.myTerminal, PmAdmConfigMaint)) then
		app.msgBox(app.getErrorString1(VB_SECMOVE, self.caption), "Application Security", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return;
	endif;

	
	if self.cmbLicenseFor.text = ProductStr_JMT_EDI then
		productCode := ProductCode_JMT_EDI;
	elseif self.cmbLicenseFor.text = ProductStr_SUBS then		//18 Jun 2020	NDL	TFS 49569
		productCode := ProductCode_Subs;
	// ### JIRA 33543 12DEC2024 NAVAB1
	elseif self.cmbLicenseFor.text = ProductStr_EWS then
		productCode := ProductCode_EWS;
	else
		productCode := ProductCode_JMT;
	endif;
		
	if self.ckbTerminal.value then
		tmpStr := 'License for';
		productCode := ProductCode_JMT;
	endif;
	
	if (app.msgBox(app.getErrorString2(ConfirmDelete, tmpStr, self.cmbLicenseFor.text), 'Confirm Delete', MsgBox_Exclamation_Mark_Icon + MsgBox_Yes_No + MsgBox_Default_Second) &lt;&gt; MsgBox_Return_Yes) then	
		return;
	endif;

	app.mousePointer := MousePointer_HourGlass;

   	create cmifMonitor transient;
   	app.myPassport.setMyCMIFMonitor(cmifMonitor);
   	cmifMonitor.myParent := self;
   	cmifMonitor.message := 'Deleting License Details';
	self.modalDialogShow('Deleting License Details', null, null, null, 'Deleting License Details', cmifMonitor.message);
   	self.pbProgressBar.visible := true;   	
   	self.updateProgress(cmifMonitor);
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteLicenseKey(self.myLicenseObject, txtName.text, productCode, self.expectedEdition, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.showCurrentLicenseObject(cmbLicenseFor.listObject.CM_Object);	
			break;
		else
			theResult := app.showErrorWarningDialog('Delete License', app.myPassport, ErrWarnMode_Delete);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

epilog
	self.frmModalDialog.visible := false;
	delete cmifMonitor;
   	app.myPassport.setMyCMIFMonitor(null);
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOK" id="b416b11c-0e86-4b14-aa9e-bbf7ba90b850">
        <updating/>
        <source>doOK() updating;
// ---------------------------------------------------------------------------
// Created:     18 December 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// ### JIRA 33543 12DEC2024 NAVAB1 change to use constants
vars
	result			: Integer;
	cmifMonitor		: CMIF_Monitor;
	tmpName			: String;
	tmpKey			: String;
	productCode		: String;
	
begin
	tmpName	:=	self.txtName.text.trimBlanks();
	tmpKey	:=	self.txtKey.text.trimBlanks();
	
	if tmpName = null then
		app.msgBox(app.getErrorString(MustEnterLicenseName), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		self.txtName.setFocus();
		return;
	endif;
	
	if tmpKey = null then
		app.msgBox(app.getErrorString(MustEnterLicenseKey), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		self.txtKey.setFocus();
		return;
	endif;
	
	app.mousePointer	:=	MousePointer_HourGlass;
	
   	create cmifMonitor transient;
   	app.myPassport.setMyCMIFMonitor(cmifMonitor);
   	cmifMonitor.myParent	:=	self;
   	cmifMonitor.message		:=	'Validating License Details';
	self.modalDialogShow('Updating License Details', null, null, null, 'Validating License Details', cmifMonitor.message);
   	self.pbProgressBar.visible := true;
   	self.updateProgress(cmifMonitor);
   	
	if self.cmbLicenseFor.text = ProductStr_JMT_EDI then
		productCode	:=	ProductCode_JMT_EDI;
	elseif self.cmbLicenseFor.text = ProductStr_SUBS then		//18 Jun 2020	NDL	TFS 49569
		productCode := ProductCode_Subs;
	// ### JIRA 33543 12DEC2024 NAVAB1
	elseif self.cmbLicenseFor.text = ProductStr_EWS then
		productCode := ProductCode_EWS;
	else
		productCode	:=	ProductCode_JMT;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateLicense(	self.myLicenseObject,
										tmpName,
										tmpKey,
										productCode,
										self.expectedEdition,
										app.myPassport);
		
		if app.myPassport.trxCompletedOK() then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			self.modalResult := MsgBox_Return_OK;
			
			app.msgBox(	app.getString(License_Restart_Applications),
						ProductStr_JMT,
						MsgBox_Information_Icon + MsgBox_OK_Only);
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(LicenseErrors), app.myPassport, ErrWarnMode_Update);
			
			if app.myPassport.noErrors()
			and result = IDOK
			then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:=	true;
				continue;
			endif;
		endif;
		
		return;
	endwhile;
	
	inheritMethod();	// does unload of form
epilog
	self.frmModalDialog.visible := false;
	delete cmifMonitor;
   	app.myPassport.setMyCMIFMonitor(null);
	app.mousePointer	:=	MousePointer_Default;
end;</source>
    </JadeMethod>
