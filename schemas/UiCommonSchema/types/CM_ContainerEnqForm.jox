    <JadeMethod name="cmbFiltTAType_click" id="27146959-e80d-4d79-bfe0-516d1c013563">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbFiltTAType_click(combobox: ComboBox input) updating;
//--------------------------------------------------------------
//Created: 25 February 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	areaType	: CM_TerminalAreaType;
	termArea	: CM_TerminalArea;
	
begin
	cmbFiltTermArea.gotFocus(cmbFiltTermArea);
	
	if combobox.listObject &lt;&gt; null then
		areaType := 	combobox.listObject.CM_TerminalAreaType;
		termArea := areaType.getFirstAreaForTerminal(self.myTerminal);
		self.myAssistant.comboBoxTerminalArea(cmbFiltTermArea, areaType.type, termArea);
		if termArea &lt;&gt; null then
			tblSearch.setValueByControlName(cmbFiltTermArea.name, termArea.id);
			self.setFilterTerminalArea(termArea);
			self.initForTerminalArea(true);
		//	self.myAssistant.comboBoxLocationControllers(self.cmbFiltYardLocn, termArea.getLCsCollectionForDisplay, false); // If we have a terminal area, it makes sense to prepare its locations. Par 18709. Dec 2008
			self.setYardLocations(termArea);	//26 Sep 2019	NDL	TFS 44661 - ensure always get all LC ( special code in YRD_LocationEnquiryFrm to set Shelves and Racks )
		else
			tblSearch.setValueByControlName(cmbFiltTermArea.name, null);
			self.filterTerminalArea := null;
		endif;
	else
		self.myAssistant.comboBoxTerminalArea(cmbFiltTermArea, TA_TYPE_NULL, null);
	endif;
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
