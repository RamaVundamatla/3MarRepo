    <JadeMethod name="trxUpdateShipMoveExport" id="202f330d-f49b-43a1-8839-cf8a4b6f13b2">
        <updating/>
        <source>trxUpdateShipMoveExport(_machine : CM_Machine input;_ti : CM_TrackedItem input; _newTargetLocn : CM_LocationsController; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		December 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
// ####
	laneLC : CM_LocationsController;
	sourceLocationId	: String;
	histEntry 			: CM_MachineMoveHistory;
	moveTransaction 	: CM_Move;
// #####
	msgStr : String;
	ti : CM_TrackedItem;
	crane	:	CM_Crane;
	shipLC : CM_LocationsController;
	term : CM_Terminal;
	alert : CM_SystemAlert;
	queue 	: CM_RadioTelemetryQueue;
	task : CM_RTQueueTask;
	wle : CM_WorkListEntry;
	job : CM_VoyageJob;
	arbiter : CM_RTQueueArbiter;
	txnParams : CMIF_TITransactionController;
	craneQueue : CM_RadioTelemetryQueue;

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, _passport); 

	_passport.warningsAcknowledged := true;
	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;
	_passport.clearDeferUpdatesCollections();

	ti := _ti;
	term := ti.myTerminal;
	app.setContinueCMExceptions(false);
	
	app.myValUA.valMoveShipExport(_machine, _ti, _passport, task, job);
	
	if _passport.hasErrors() then
		return;
	endif;
	

	beginTransaction;		
	app.setServerTimestampAtTrxStart(null); // ### TFS 52639 21Mar2022 NAVPW1
	
	app.myUtilityUA.utlUpdateShipMoveExport(_machine, _ti, task, job,_newTargetLocn, _passport); 
	
	if _passport.hasErrors() then
		return;
	endif;
	_passport.doDeferredUpdates();
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_newTargetLocn" type="CM_LocationsController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateShipMoveImport" id="0bfcb63d-ad5e-4638-b116-ffda72a9927e">
        <updating/>
        <source>trxUpdateShipMoveImport(_machine : CM_Machine input; _ti : CM_TrackedItem input; 
					_wle : CM_WorkListEntry;
					_job : CM_VoyageJob;
					_quantity 	: Integer;
					_weight 	: Decimal;
					_passport : CM_Passport input) updating;
/*
Purpose:			
Date				Who			Reason
JUNE 2015		CNWAB1		Initial creation
18/09/2017		jlgmd1		TFS 6813 - QNS - Jade application slow

*/
vars
// ####
	ti : CM_TrackedItem;
	term : CM_Terminal;
	wle : CM_WorkListEntry;
	job : CM_VoyageJob;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportSilentLockExHandler(exception, 3, _passport); //epr par 14718

	_passport.setWarningsIgnored(true);
	_passport.setWarningsAcknowledged(true);
	_passport.useTITransactionDeferUpdate := true;
	_passport.useTIDictDeferUpdate := true;			// TFS 6813
	_passport.clearDeferUpdatesCollections();

	ti := _ti;
	term := ti.myTerminal;
	job := _job;
	wle := _wle;
	

	app.setContinueCMExceptions(false);
	

	if _passport.hasErrors() then
		return;
	endif;
	

	beginTransaction;		
	app.setServerTimestampAtTrxStart(null); // ### TFS 52639 21Mar2022 NAVPW1
	
	app.myUtilityUA.utlUpdateShipMoveImport(_machine, _ti,_wle, _job,_quantity,_weight,_passport);
	
	
	if _passport.hasErrors() then
		return;
	endif;
	_passport.doDeferredUpdates();
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
