    <JadeMethod name="doReceiveMessage" id="fbf82c53-e997-4e21-b8d8-9e000b2d66da">
        <updating/>
        <source>doReceiveMessage(_msg : String) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 December 2009	cnwkpd1	PAR #21593 - CCMS MES 1014 - ITS RDT Interface

*/

vars
	xml				: JadeXMLDocument;
	element			: JadeXMLElement;
	messageType		: String;
	
begin
	self.logMessage("Received: " &amp; _msg);
	
	create xml transient;
	xml.parseString(_msg);
	
	// First send the ACK
	self.doCheckForSendACK(xml);
		
	// Then process the message
	element := xml.rootElement.getElementByTagName(XML_Tag_Header).getElementByTagName(XML_Tag_MessageType);
	if element = null then
		self.logMessage("Error - no message type found");
		return;
	endif;
	
	messageType := element.text();
	
	if messageType = Message_Type_Error then
		self.doReceiveError(xml);
		
	elseif messageType = Message_Type_QueueEntry then
		self.doReceiveQueueEntry(xml);
		
	elseif messageType = Message_Type_LogonComplete then
		self.doReceiveLogonComplete(xml);
		
	elseif messageType = Message_Type_DeleteQueueEntry then
		self.doReceiveDeleteQueueEntry(xml);
		
	endif;
	
		
epilog
	delete xml;

end;</source>
        <access>protected</access>
        <Parameter name="_msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="doReceiveQueueEntry" id="a8f750de-56db-4023-b879-3dfd23f9779a">
        <updating/>
        <source>doReceiveQueueEntry(_message : JadeXMLDocument) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 December 2009	cnwkpd1	PAR #21593 - CCMS MES 1014 - ITS RDT Interface

*/

vars
	header,
	body,
	element			: JadeXMLElement;
	xmlNode			: JadeXMLNode;
	row,
	column,
	queueEntryId	: Integer;
	table			: Table;
	refreshSelected	: Boolean;
	
begin
	header := _message.rootElement.getElementByTagName(XML_Tag_Header);
		
	body := _message.rootElement.getElementByTagName(XML_Tag_Body);
	if body = null then
		self.logMessage("Error: no " &amp; XML_Tag_Body &amp; " found");
		return;
	endif;
	
	// Get the unique Queue Id
	element := body.getElementByTagName(XML_Tag_QueueEntryId);
	if element = null then
		self.logMessage("Error: no " &amp; XML_Tag_QueueEntryId &amp; " found");
		return;
	endif;
	
	// Is the Queue Entry already in the table?
	queueEntryId := element.text.Integer;
	row := self.findQueueEntryRow(queueEntryId);
	
	table := self.tblQueueEntries;
	
	if row = null then
		row := table.addItem(null);
	else
		// Need to refresh if the update is to the currently selected entry
		refreshSelected := row = table.row;
		
		foreach column in 1 to table.columns do
			table.setCellText(row, column, null);
		endforeach;
	endif;
	
	// Now load up the row
	foreach column in 1 to table.columns do
		element := body.getElementByTagName(table.getCellText(1, column));
		if element &lt;&gt; null then
			table.setCellText(row, column, element.text());
		endif;
	endforeach;
	
	if refreshSelected then
		self.refreshValuesFromSelected();
	endif;
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_message" type="JadeXMLDocument"/>
    </JadeMethod>
    <JadeMethod name="doSendACK" id="5d62e03b-cd3b-4d89-9df0-494e1175fea1">
