    <JadeMethod name="create" id="edba64e6-19fc-44d6-9fc4-551aac2293b1">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
05 August 2022	navlw1	Initial creation tfs 53854
*/

vars

begin
	create self.allJWTClaims transient;
	create self.myMapperDll transient;
	self.fillNoLoggingCalls();															//navra1 - 24th Aug 2022 - TFS 50365 - Any REST method that does not need logging should be added to list in fillNoLoggingCalls
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createAlert" id="9a9f1650-2de0-458d-8230-913e52004eef">
        <source>createAlert(_errors: String) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
23 Feb 2024		navcs2	ChangeRequest 60787: EUP | Add system alert for File Loading fails 

*/

vars
	alert 	: CM_SystemAlert;
begin
	create alert transient;
	alert.setSeverity(SEVERE_ERROR);
	alert.details := "MasterTerminalAPI POST /SendEDI - Error creating EDI file. Double click for more information";
	
	alert.addLogEntry("Code :96142. Unable to transform message.");
	alert.addLogEntry(_errors);
	
	alert.setMySystemAlertType(app.myRoot.allSystemAlertTypes[EVENT_AT_ExternalInterface]);
	
	alert.myTerminal := app.myPassport.myTerminal;
	
	alert.add();
	
	app.commitAlert();
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_errors" type="String"/>
    </JadeMethod>
