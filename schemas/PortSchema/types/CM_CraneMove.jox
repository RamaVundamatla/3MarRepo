<Class name="CM_CraneMove" id="295471e1-8104-4bbb-b8cb-565c13957b5e">
    <superclass name="CM_Move"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>
MTN does not produce RTEntries for cranes, so there is no pickup/setdown for a crane.
This transaction represents the crane move to or from the ship</text>
    <DbClassMap file="move"/>
    <PrimAttribute name="craneId" id="bc67d991-a560-4755-8e6d-7d5e99f65704">
        <type name="String"/>
    </PrimAttribute>
