    <JadeMethod name="getExtractDetails" id="64584396-cc04-4a0a-baf2-dc0f1d6db1e5">
        <source>getExtractDetails() : String;
// 23659 Apr 2010 invoice transaction map extract to use codes instead of descriptions
vars

begin
	return myQuantityMap.getExtractDetails();
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
