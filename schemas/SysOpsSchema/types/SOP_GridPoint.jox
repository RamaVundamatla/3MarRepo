    </JadeMethod>
    <JadeMethod name="setControllerType" id="3c7c59fe-57ee-4ea1-b99e-719da4208cbd">
        <updating/>
        <source>setControllerType(_cls : Class) updating;
/*
----------   ----------  --------------------------------------------------
Created:	08 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	newPxyLC		: CM_GridController;
//	cls				: Class;
	gridArea		: CM_GridArea;
	gridRow 		: CM_GridRow;
	gridColumn		: CM_GridColumn;
	nameStr			: String;
	power,
	powerDamage		: Boolean;
	width			: Real;
	remarks			: String;
begin
	//cls := self.getLCClassForType(_lcType);
	if (self.myLocationsController.isKindOf(_cls)) then
		return;
	endif;
	
	newPxyLC 		:= self.myGridController.cloneSelfAs(_cls, true).CM_GridController;
	gridArea 		:= self.myGridController.myTerminalArea.CM_GridArea;
	gridRow 		:= self.myGridController.myGridRow;
	gridColumn 		:= self.myGridController.myGridColumn;
	nameStr			:= self.myGridController.name;
	power			:= self.myGridController.power;
	powerDamage		:= self.myGridController.powerDamaged;
	width			:= self.myGridController.width;
	remarks			:= self.myGridController.remarks;
	delete self.myLocationsController;
	
	newPxyLC.setForProxy(PAD_AVAILABLE, NORMAL_USE, gridRow.row, gridColumn.column, nameStr, width, power, powerDamage, remarks, gridArea, false, null, false, null, false, null);
	self.myLocationsController := newPxyLC;
	
	
end;


</source>
        <Parameter name="_cls" type="Class"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="08b75f50-874c-418a-993c-928c867be3e2">
        <updating/>
        <source>setForCreate(_sopGridArea : SOP_GridArea; _gridController : CM_GridController; _picture : Picture) updating;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.myLocationsController := _gridController;
	self.myGridController.setWidth(self.DefaultWidth);
	//self.heightOfStack := _sopGridArea.maxRowHeight;
	self.setForCreateSuperClass(_sopGridArea, _gridController.myGridRow.row, _gridController.myGridColumn.column);
	self.myPicture := _picture;

	self.setUsage(_gridController.getLocationDisplay(), self.myGridArea.SOP_GridArea.type, _picture);

end;</source>
        <Parameter name="_sopGridArea" type="SOP_GridArea"/>
        <Parameter name="_gridController" type="CM_GridController"/>
        <Parameter name="_picture" type="Picture"/>
    </JadeMethod>
    <JadeMethod name="setForDraw" id="36bd232e-ef49-4738-91e2-bc4fc9f3c6c0">
        <updating/>
        <source>setForDraw(_sopGridArea : SOP_GridArea; _gridController : CM_GridController; _picture : Picture) updating;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	picType		: Integer;
begin
	self.myLocationsController := _gridController;
	//self.heightOfStack := _sopGridArea.maxRowHeight;
	self.setForCreateSuperClass(_sopGridArea, _gridController.myGridRow.row, _gridController.myGridColumn.column);
	self.letter := _gridController.getPic();
	self.myPicture := _picture;

end;</source>
        <Parameter name="_sopGridArea" type="SOP_GridArea"/>
        <Parameter name="_gridController" type="CM_GridController"/>
        <Parameter name="_picture" type="Picture"/>
    </JadeMethod>
    <JadeMethod name="setPower" id="7eb7840a-cded-48ae-b22b-edc273bc53e0">
        <updating/>
        <source>setPower(_power : Boolean) protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	15 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.power := _power;
	if self.myGridController &lt;&gt; null then
		self.myGridController.setPower(_power);
	endif;

end;


</source>
        <access>protected</access>
