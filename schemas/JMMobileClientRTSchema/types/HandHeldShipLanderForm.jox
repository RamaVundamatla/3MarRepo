/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	// epr par 20080 24/6/09
	if not validateOKForContainers then
		return;
	endif;
	
	self.doHideFrm(self.frmMain);
	self.doHideFrm(self.frmDamage);
	self.doHideFrm(self.frmFowardCont);
	self.doShowFrm(self.frmAftCont);

	self.btnConfirmAft.default := true;
