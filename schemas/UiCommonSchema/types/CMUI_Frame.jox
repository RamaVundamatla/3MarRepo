    <JadeMethod name="getTextDrawFontSizeForWidth" id="f7b511b3-7041-493f-a974-a17dac79c2b6">
        <updating/>
        <source>getTextDrawFontSizeForWidth(_text : String; _width : Real) updating;
/*

Date		Who		Reason
06 August 2013	cnwer1	Initial creation PAR

*/
constants
	FONTMAX = 20;
	FONTMIN = 2;
	FONTINC = 0.5;
vars
	txtLength : Real;
begin
	
	if _text = null then
		return;
	endif;
	
	if _width = null then
		return;
	endif;
	
	txtLength:=self.drawTextWidth(_text);
	

	if txtLength &lt; _width then
		self.drawFontSize:= FONTMIN; // PAR 32308 - defaults
		
		while txtLength &lt;= _width  and self.drawFontSize &lt;= FONTMAX do
			self.drawFontSize:=self.drawFontSize + FONTINC;
			txtLength:=self.drawTextWidth(_text);

		endwhile;
		self.drawFontSize:=self.drawFontSize - FONTINC;
	elseif txtLength &gt; _width then
		self.drawFontSize:= FONTMAX; // PAR 32308 - defaults

		 
		while txtLength &gt;= _width and self.drawFontSize &gt; FONTMIN do // PAR 32308
			self.drawFontSize:=self.drawFontSize - FONTINC;
			txtLength:=self.drawTextWidth(_text);
		endwhile;
	endif;
epilog

end;</source>
        <Parameter name="_text" type="String"/>
        <Parameter name="_width" type="Real"/>
    </JadeMethod>
    <JadeMethod name="getTextDrawFontSizeForWidthHgt" id="6c8f9741-5f60-496b-bbed-dba5c4b749fb">
        <updating/>
        <source>getTextDrawFontSizeForWidthHgt(_text : String; _width : Real; _height : Real) updating;
/*
Purpose:	TFS 49959		
Date				Who			Reason
October 2020		JLGAB1 initial creation
*/


constants
	FONTMAX = 20;
	FONTMIN = 2;
	FONTINC = 0.5;
vars
	txtLength : Real;
	txtHeight : Real;
begin
	
	if _text = null then
		return;
	endif;
	
	if _height = null then
		return;
	endif;
	
	self.drawFontSize:= FONTMIN; 
	txtLength:=self.drawTextWidth(_text);
	txtHeight:=self.drawTextHeight(_text);
	
	while txtLength &lt;= _width  and txtHeight &lt;= _height and  self.drawFontSize &lt;= FONTMAX do
		self.drawFontSize:=self.drawFontSize + FONTINC;
		txtLength:=self.drawTextWidth(_text);
		txtHeight:=self.drawTextHeight(_text);

	endwhile;
	self.drawFontSize:=self.drawFontSize - FONTINC;
epilog

end;</source>
        <Parameter name="_text" type="String"/>
        <Parameter name="_width" type="Real"/>
        <Parameter name="_height" type="Real"/>
    </JadeMethod>
