	system.jssGetDiskAndMemory(freeMemory, freeDisk, driveName);
	
	write "";
	write "Client:" &amp; CrLf &amp; "-------";
	write "Free memory: " &amp; freeMemory.jssNumberFormat();
	write "Free disk: " &amp; freeDisk.jssNumberFormat();
	write "Drive name: " &amp; driveName;
