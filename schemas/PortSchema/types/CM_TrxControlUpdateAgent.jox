    <JadeMethod name="trxUpdateJobAction" id="06f71455-95c2-4bd2-911c-1a03c7d82944">
        <updating/>
        <source>trxUpdateJobAction(_job : CM_Job; _action : Integer; _actionTS : TimeStamp; _obj : CM_Object; _passport : CM_Passport input) updating;			//23.09.2024  navbs1  #12445
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/03/2024	navkc1 CR 62896 Task 62897: Jade - Job Create Transactions and Events
23 Sep 2024 navbs1 Bug MTN-12445 EUP | FR 54883 - Start and End Times for Operations in Mobile App - Unpack issues
30 Oct 2024 navhl20 CR MTN-33232: EUP - Start End Times for Road and Rail jobs
*/

vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	// ### TFS BUG 64545 11JUNE024 NAVAB1
	app.myPassport.useEventDeferUpdate := true;
	app.myPassport.useTITransactionDeferUpdate := true;
	
	// Start the transaction
	beginTransaction;
	
	// Perform the operation
	app.myUtilityUA.utlUpdateJobAction(_job, _action, _actionTS, _obj, _passport);			//23.09.2024  navbs1  #12445	//30.10.2024 navhl20 #33232

	if  _passport.noErrors then	// ### TFS BUG 64675 17JUNE024 NAVAB1
		_passport.doDeferredUpdates();
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_job" type="CM_Job"/>
        <Parameter name="_action" type="Integer"/>
        <Parameter name="_actionTS" type="TimeStamp"/>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
