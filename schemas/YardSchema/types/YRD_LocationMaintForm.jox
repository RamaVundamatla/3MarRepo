    <JadeMethod name="cmbOrganisation_click" id="f7d3d4d9-c987-4c74-bb04-9379cedfa877">
        <controlMethod name="CMUI_ComboBoxObject::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbOrganisation_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2015	cnwndl1	Initial creation	Par 36588

*/

vars

	org : CM_Organisation;
	
begin

	org := cmbOrganisation.listObject.CM_Organisation;
	
	/* WAS
		if org = null then
		self.mulNotifyEmails.setSelected(null);
	else
		self.mulNotifyEmails.setSelected( org.allSelectedEmailAddresses);
	endif;
	NOW */
	if org = null then
		self.mulNotifyEmails.setAvailable(null, true); // TFS 2198
		self.mulNotifyEmails.setSelected(null); // TFS 2198
	else
		self.mulNotifyEmails.setAvailable( org.allSelectedEmailAddresses, true); // TFS 2198
		self.mulNotifyEmails.setSelected(null); // TFS 2198
	endif;
	
epilog

end;</source>
