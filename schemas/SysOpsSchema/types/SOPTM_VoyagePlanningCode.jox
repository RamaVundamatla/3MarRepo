	formObj.tblInput1.userInputEnabled	:=	false;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="4f4e25cc-1078-4a07-a3e1-c141c8ca3bbf">
        <updating/>
        <source>setupThumbnailDetails() updating;
// ---------------------------------------------------------------------------
// Created:     09 March 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	formObj : SOP_TableMaintForm;

begin
	formObj	:=	self.myForm;
	
	formObj.useProxyObject	:=	true;
	formObj.setTblDataEntRows(ETDef_CodeMaint);
	//12/01/2011 cnwdz2 25840
	//formObj.zClearSortColumns();
	//formObj.zAddSortColumn(ETRow_Code, false);

	formObj.shtTblInput1.caption	:=	'Details';
	formObj.initTblInput(formObj.tblInput1, ETDef_CodeMaint);
	formObj.shtTblInput1.visible	:=	true;

	formObj.mulSelect1.formDisplayEntryMethodName	:=	null;
	formObj.mulSelect2.formDisplayEntryMethodName	:=	null;
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="52badf0f-66bd-4eef-8f33-7ffbddf0101b">
        <updating/>
        <source>showThumbnail(pPlanningCodeObj : CM_VoyagePlanningCode) updating;

vars
	formObj	: SOP_TableMaintForm;
	codeStr	: String;
	
begin
	formObj	:=	self.myForm;
	formObj.tblInput1.clearValues;
	
	codeStr	:=	pPlanningCodeObj.code;

	formObj.tblInput1.setValueByName(ETRow_Code, codeStr);
	formObj.tblInput1.setValueByName(ETRow_Description, pPlanningCodeObj.description);
//	formObj.tblInput1.setValueByName(ETRow_IsSuitableForRelease, pPlanningCodeObj.isSuitableForRelease);
	formObj.tblInput1.setValueByName(ETRow_NotAvailableForEntry, pPlanningCodeObj.notAvailableForEntry);
end;</source>
        <Parameter name="pPlanningCodeObj" type="CM_VoyagePlanningCode"/>
    </JadeMethod>
</Class>
