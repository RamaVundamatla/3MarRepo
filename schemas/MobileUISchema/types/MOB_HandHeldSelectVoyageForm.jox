    <JadeMethod name="setSessionParameters" id="4b346724-c847-4cfc-9194-ddc80e54c278">
        <updating/>
        <source>setSessionParameters() updating;
// Setup the session parameters for the next form
vars
begin
	inheritMethod();
	self.getSessionAgent().myVoyage := self.getVoyage();
	self.getSessionAgent().myJob := self.getJob();
	self.getSessionAgent().myBay := self.getBay();
	self.getSessionAgent().deck := self.getDeck();
end;
</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="e72c2e1c-8080-4bad-9a64-a68fc821288b">
        <updating/>
        <source>setupForm() updating, protected;

vars
	form : MOB_HandHeldForm;
begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;

	inheritMethod();
	self.loadVoyages(self.getSessionAgent.myVoyage);
//	self.loadJobs(self.getSessionAgent.myVoyage, self.getSessionAgent.myJob, self.getSessionAgent.myJob &lt;&gt; null);
	self.loadJobs(self.getSessionAgent.myVoyage, self.getSessionAgent.myJob, true);	//22 Nov 2010	NDL Par 25074
	self.loadBays(self.getSessionAgent.myVoyage, self.getSessionAgent.myJob, self.getSessionAgent.myBay);

	//22 Nov 2010	NDL Par 25074
	//	self.loadDeck(self.getSessionAgent.deck);
	form := self;
	self.myHandHeldCheckerAgent.doApplyConfigColours( form );	//22 Nov 2010	NDL Par 25074
	
	self.setupControlFromParent(	self.frmMain, self, 0, 0 );	//22 Nov 2010	NDL Par 25074
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="7211a690-734b-45d8-a170-6aeee8b68388">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0013139, locale);
	btnBack.translateCaption(Xlat_0013140, locale);
	btnNext.translateCaption(Xlat_0013141, locale);
	lblBay.translateCaption(Xlat_0013142, locale);
	lblJob.translateCaption(Xlat_0013143, locale);
	lblVoyage.translateCaption(Xlat_0013144, locale);
	optOnDeck.translateCaption(Xlat_0013145, locale);
	optUnderDeck.translateCaption(Xlat_0013146, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="validateForm" id="29811b39-72ca-4f37-bc60-236c33a8d4bb">
        <source>validateForm() : Boolean;
begin
	if self.getVoyage() = null then
		self.msgBox(app.getErrorString(Voyage_needs_selected),app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon, false);
		cmbVoyages.setFocus();
		return false;
	endif;
	
	if self.getBay() = null then
		self.msgBox(app.getErrorString(Bay_needs_selected),app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon, false);
		cmbBays.setFocus();
		return false;
	endif;

	return true;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
