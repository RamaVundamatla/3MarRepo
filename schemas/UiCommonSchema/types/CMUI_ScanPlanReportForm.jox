    <JadeMethod name="validateAndPopulate" id="56f79948-fd52-4d7e-a5bc-3a92c3cd4694">
        <source>validateAndPopulate():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2020	jlgndl1	Initial creation	TFS 49963

*/

vars

	selectedBays : CM_BayVoyageByIdDict;
	paperSize : Integer;
	baysPerPage : Integer;
	legend : Integer;
	colour : Integer;
	content : Integer;
	rob : Integer;

begin

	create selectedBays transient;
	self.mulBays.getSelected( selectedBays );
	
	if self.optA4.value then
		paperSize := CMIF_ScanPlanReport.PaperA4;	
	elseif self.optA3.value then
		paperSize := CMIF_ScanPlanReport.PaperA3;
	endif;
	
	if self.optOnePage.value then
		legend := CMIF_ScanPlanReport.LegendOne;
	elseif self.optPageAll.value then
		legend := CMIF_ScanPlanReport.LegendAll;
	endif;
	
	if self.optOneBay.value then
		baysPerPage := CMIF_ScanPlanReport.BaysPerPageOne;
	elseif self.optTwoBay.value then
		baysPerPage := CMIF_ScanPlanReport.BaysPerPageTwo;
	elseif self.optThreeBay.value then
		baysPerPage := CMIF_ScanPlanReport.BaysPerPageThree;
	elseif self.optSixBay.value then
		baysPerPage := CMIF_ScanPlanReport.BaysPerPage2x3;
	elseif self.optTwelveBay.value then
		baysPerPage := CMIF_ScanPlanReport.BaysPerPage3x4;
	endif;
	
	if self.optColNone.value then
		colour := CMIF_ScanPlanReport.ColourNone;
	elseif self.optColDPort.value then
		colour := CMIF_ScanPlanReport.ColourDischargePort;
	elseif self.optColOp.value then
		colour := CMIF_ScanPlanReport.ColourOperator;
	elseif self.optColComm.value then
		colour := CMIF_ScanPlanReport.ColourCommodity;
	elseif self.optColISO.value then
		colour := CMIF_ScanPlanReport.ColourIsoGroup;
	elseif self.optColLPort.value then
		colour := CMIF_ScanPlanReport.ColourLoadPort;
	endif;
	
	if self.optSlotAct.value then
		content := CMIF_ScanPlanReport.ContentActual;
	elseif self.optSlotProp.value then
		content := CMIF_ScanPlanReport.ContentProposed;
	elseif self.optSlotLoad.value then
		content := CMIF_ScanPlanReport.ContentLoad;
	elseif self.optSlotDisc.value then
		content := CMIF_ScanPlanReport.ContentDischarge;
	elseif self.optSlotDandL.value then
		content := CMIF_ScanPlanReport.ContentDischargeAndLoad;
	endif;
	
	if self.optROBGrey.value then
		rob := CMIF_ScanPlanReport.RobGrey;
	elseif self.optROBWhite.value then
		rob := CMIF_ScanPlanReport.RobWhite;
	endif;


	self.myScanPlanAgent.setAgentData(	self.mySelectedVoyage, //_voyage : CM_Voyage; 
										selectedBays, //_selectedBays : CM_BayVoyageByIdDict;
										paperSize, //_paperSize : Integer;
										baysPerPage, //_baysPerPage : Integer;
										legend, //_legend : Integer;
										colour, //_colour : Integer;
										content, //_content : Integer;
										rob, //_rob : Integer;
										self.chkCargoList.value, //_printCargoList : Boolean;
										self.chkProfileSumm.value, //_printProfSumm : Boolean;
										self.chkPreview.value	//_preview : Boolean
										);

	self.myScanPlanAgent.validateMe();
	
	if app.myPassport.hasErrors then
		return false;
	endif;
	
	self.myScanPlanAgent.createCMIFObjsForPrint();
	
	return true;

epilog

	delete selectedBays;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
