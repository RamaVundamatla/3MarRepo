    <JadeMethod name="cashTestPrenoteChildCargo" id="0fb4e8b5-2bac-427a-bbed-41fe05dabec8">
        <updating/>
        <source>cashTestPrenoteChildCargo(_id : String; _drTerm1 : CM_DebtorTerminal; _truckOut : CM_Vehicle) updating, protected;

/*

Purpose:		Cash module testing, create a prenote with child cargo

Parameters:			

Return Value:		


Date		Who		Reason
29/04/2014	cnwjre1	34800
28/11/2019	jlgsl4	TFS 47529 - JMT - Decimal Values on CM_CashReceipt, CM_CashPayment, CM_CashInvoiceProformaAgent
*/

constants

vars
	now			: TimeStamp;
	cargoId		: String;
	msg			: String;
	count		: Integer;
	
	drTerm1 : CM_DebtorTerminal;
	drTerm2 : CM_DebtorTerminal;
	
	cashReceipt : CM_CashReceipt;
	cashPaymentProForma : CM_CashPayment;
	cashPayment : CM_CashPayment;
	paymentMeth : CM_PaymentMethod;

	onsiteTi : CM_TrackedItem;
	packTIs, unpackTIs: CM_TIArray;
	wh: CM_IrregularBlockArea;
	cargo1, cargo2: CM_TrackedItem;
	trans	: CM_TITransaction;
	operator	: CM_Operator;

	endDate : Date;
	cashToPay,
	cashTotal,
	cargoEstimatedCashCharges : Decimal[23,6];//[16, 6]; // TFS 47529
	cashInvoice	: CM_Invoice;
	invLine : CM_InvoiceLine;
	
	carrier : CM_Carrier;
	
	truckIn : CM_Vehicle;
	truckOut : CM_Vehicle;
	vvrIn : CM_VehicleVisitRecord;
	vvrOut : CM_VehicleVisitRecord;
	
	debtorType	: CM_DebtorType;
	cashInvType,
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2  	: CM_InvoiceLineDesc;
	customsAgent	: CM_CustomsAgent;
	debtor 		: CM_DebtorNode;
	
	allTIs 		: CM_TISet;
	allAgents		: ObjectArray;
	agent : CM_CashInvoiceProformaAgent;
	chequeBank : String;
	chequeBranch : String;
	chequeNumber : String;
	chequeDate : Date;
	cashId1,
	cashId2,
	cashId3,
	cashId4 : String;
	
	effectiveDate : Date;
	externalInvoiceNumber,
	externalReferenceNumber : String;
	
	booking		: CM_BookingRef;
	ti			: CM_TrackedItem;
	vvr 		: CM_VehicleVisitRecord;
	voyage1 	: CM_Voyage;
	vessel 		: CM_Vessel;
	cargoType 	: CM_CargoType;
	attachments	: CMIF_InOutAttachmentArray;
	attach		: CMIF_InOutAttachment;		
	product		: CM_Product;
begin
	msg := method.name;
	cargoId := _id;

	truckOut := _truckOut;
	deleteContainer(cargoId);
	self.deleteBooking("UT_NIKBOOKING");
	deleteVoyage("UTVBOOK01");
	deleteVessel("UTBOATNIK");
	self.deleteVehicle("UTNIK");
	
	vessel := addVesselCellular("UTBOATNIK", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNull(vessel);
	voyage1 := addVoyageWithContainerStructur("UTVBOOK01", "UTBOATNIK", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	assertNotNull(voyage1);
	
	booking := self.addBookingForContainer("UT_NIKBOOKING", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage1, "NZAKL", "2200", "MT");
	assertNotNull(booking);
		
	//create cont with child and prenote
	
	cargoType := self.getCargoType("CANNON");
	self.assertNotNull(cargoType);
	create attachments transient;
	create attach transient;
	attach.set(getTerminal,cargoType.type, "CHI0001", "", 5000); 
	attach.myProduct := product;
	attach.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	attachments.add(attach);

	self.opts.addAssoc("Attachment", attachments);

	ti := self.addPrenotedContainer(booking.allBookingRefItems.first, cargoId);
	
	self.assertNotNullMsg(ti,"ti is null");
	self.assertNotNullMsg(ti.allChildren.first(),"Child is null");
	cargo1 := ti.allChildren.first;

	onsiteTi := ti;

	/* probably don't need to do this - the TI and transactions should already have the voyage set
	beginTransaction;
	onsiteTi.setMyVoyage(self.myVoyage, app.myPassport);
	foreach trans in onsiteTi.allTransactions do
		trans.setPropertyValue("voyage", self.myVoyage);
		trans.setPropertyValue("voyageCode", self.myVoyage.code);
		trans.setPropertyValue("myVoyageRelivant", self.myVoyage);
	endforeach;
	commitTransaction;
	*/

	self.assertTrueMsg(onsiteTi &lt;&gt; null, msg &amp; " On Site Cargo '" &amp; cargoId &amp; "' not created...");

	create allTIs transient;
	allTIs.add(onsiteTi);
	allTIs.add(cargo1);
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;
	self.applyAgentToCargo(allTIs, debtorType, customsAgent);

	create allAgents transient;
	agent := self.createProformaAgent(now, onsiteTi);
	cashTotal := agent.cashPayments;
	cashToPay := agent.invoicedCashCharges + agent.estimatedCashCharges - cashTotal;
	allAgents.add(agent);

	agent := self.createProformaAgent(now, cargo1);
	cashTotal := cashTotal + agent.cashPayments;
	cashToPay := cashToPay + agent.invoicedCashCharges + agent.estimatedCashCharges - cashTotal;
	allAgents.add(agent);

	paymentMeth := app.myRoot.allPaymentMethods[PayMethName];
	if paymentMeth = null then
		paymentMeth := CM_PaymentMethod.firstInstance;
	endif;

	cashReceipt := self.createBOLCashReceipt(	paymentMeth,	// _payMeth : CM_PaymentMethod;
					cashToPay,				// _amount : Decimal;
					chequeBank,			// _chequeBank : String;
					chequeBranch,		// _chequeBranch : String;
					chequeNumber,		// _chequeNumber : String;
					chequeDate,			// _chequeDate : Date;
					cashId1,			// _cashId1,
					cashId2,			// _cashId2,
					cashId3,			// _cashId3,
					cashId4,			// _cashId4 : String;
					0,					// _payment1 : Decimal;
					0,					// _payment2 : Decimal;
					effectiveDate,		// _effectiveDate : Date;
					externalInvoiceNumber,	// _externalInvoiceNumber,
					externalReferenceNumber,	// _externalReferenceNumber : String;
					cashToPay,
					cashTotal,
					self.myVoyage,
					_drTerm1,			// _drTerm : CM_DebtorTerminal;
					0,
					0,
					0,
					null,
					allAgents,			// _agents : ObjectArray
					"",					// _taxCode1,
					"",					// _taxCode2,
					""					// _taxCode3: String
					);
	
	// 
	
	self.assertTrueMsg(cashReceipt &lt;&gt; null, msg &amp; " Cash Receipt not created...");
	self.assertTrueMsg(cashReceipt.cashValue &gt; 0, msg &amp; " Cash Receipt value not set");

epilog
	if allAgents &lt;&gt; null then
		allAgents.purge();
	endif;
	delete attach;
	delete attachments;
	delete allAgents;
	delete allTIs;
	delete unpackTIs;
	delete packTIs;
	
end;
</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <Parameter name="_drTerm1" type="CM_DebtorTerminal"/>
        <Parameter name="_truckOut" type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="cashTestSingle" id="f9780e74-fc9c-4e8f-aff4-35e991e041dc">
        <updating/>
        <source>cashTestSingle(_id : String; _drTerm1 : CM_DebtorTerminal; _truckOut : CM_Vehicle) updating, protected;

/*

Purpose:		Cash module testing, gate out a single item before storage is due and with one full payment.

Parameters:			

Return Value:		


Date		Who		Reason
29/04/2014	cnwjre1	After par 33885
28/11/2019	jlgsl4	TFS 47529 - JMT - Decimal Values on CM_CashReceipt, CM_CashPayment, CM_CashInvoiceProformaAgent
*/

constants

vars
	now			: TimeStamp;
	cargoId		: String;
	msg			: String;
	count		: Integer;
	
	drTerm1 : CM_DebtorTerminal;
	drTerm2 : CM_DebtorTerminal;
	
	cashReceipt : CM_CashReceipt;
	cashPaymentProForma : CM_CashPayment;
	cashPayment : CM_CashPayment;
	paymentMeth : CM_PaymentMethod;

	onsiteTi : CM_TrackedItem;
	trans	: CM_TITransaction;

	endDate : Date;
	cashToPay,
	cashTotal,
	cargoEstimatedCashCharges : Decimal[23,6];// [16,4]; // TFS 47529
	cashInvoice	: CM_Invoice;
	invLine : CM_InvoiceLine;
	
	carrier : CM_Carrier;
	
	truckIn : CM_Vehicle;
	truckOut : CM_Vehicle;
	vvrIn : CM_VehicleVisitRecord;
	vvrOut : CM_VehicleVisitRecord;
	
	debtorType	: CM_DebtorType;
	cashInvType,
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2  	: CM_InvoiceLineDesc;
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
	debtor 		: CM_DebtorNode;
	
	allTIs 		: CM_TISet;
	allAgents		: ObjectArray;
	agent : CM_CashInvoiceProformaAgent;
	chequeBank : String;
	chequeBranch : String;
	chequeNumber : String;
	chequeDate : Date;
	cashId1,
	cashId2,
	cashId3,
	cashId4 : String;

	effectiveDate : Date;
	externalInvoiceNumber,
	externalReferenceNumber : String;
	
begin
	msg := method.name;

	truckOut := _truckOut;
	//Now create onsite cargo that will be gated out by truck.
	cargoId := _id;
	onsiteTi := self.addOnsiteCargoForId(cargoId, true, 0);
	// has CM_Create, CM_Receive, CM_SubTermxxx, CM_Wash
	// is Storage, FCL, operator UTC1, null voyage, no stops, no agent assigned, 
	beginTransaction;
	onsiteTi.setMyVoyage(self.myVoyage, app.myPassport);
	foreach trans in onsiteTi.allTransactions do
		trans.setPropertyValue("voyage", self.myVoyage);
		trans.setPropertyValue("voyageCode", self.myVoyage.code);
		trans.setPropertyValue("myVoyageRelivant", self.myVoyage);
	endforeach;
	commitTransaction;

	self.assertTrueMsg(onsiteTi &lt;&gt; null, msg &amp; " On Site Cargo '" &amp; cargoId &amp; "' not created...");

	create allTIs transient;
	allTIs.add(onsiteTi);
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;
	self.applyAgentToCargo(allTIs, debtorType, customsAgent);

	create allAgents transient;
	agent := self.createProformaAgent(now, onsiteTi);
	allAgents.add(agent);
	self.myAgent := agent;
	
	cashTotal := agent.cashPayments;
	cashToPay := agent.invoicedCashCharges + agent.estimatedCashCharges - cashTotal;

	paymentMeth := app.myRoot.allPaymentMethods[PayMethName];
	if paymentMeth = null then
		paymentMeth := CM_PaymentMethod.firstInstance;
	endif;

	cashReceipt := self.createBOLCashReceipt(	paymentMeth,	// _payMeth : CM_PaymentMethod;
					cashToPay,				// _amount : Decimal;
					chequeBank,			// _chequeBank : String;
					chequeBranch,		// _chequeBranch : String;
					chequeNumber,		// _chequeNumber : String;
					chequeDate,			// _chequeDate : Date;
					cashId1,			// _cashId1,
					cashId2,			// _cashId2,
					cashId3,			// _cashId3,
					cashId4,			// _cashId4 : String;
					0,					// _payment1 : Decimal;
					0,					// _payment2 : Decimal;
					effectiveDate,		// _effectiveDate : Date;
					externalInvoiceNumber,	// _externalInvoiceNumber,
					externalReferenceNumber,	// _externalReferenceNumber : String;
					cashToPay,
					cashTotal,
					self.myVoyage,
					_drTerm1,			// _drTerm : CM_DebtorTerminal;
					0,
					0,
					0,
					null,
					allAgents,			// _agents : ObjectArray
					"",					// _taxCode1,
					"",					// _taxCode2,
					""					// _taxCode3: String
					);
	
	// $20 current (Move), $20 proforma (Road Release), 2 x $20 cash payments
	
	self.assertTrueMsg(cashReceipt &lt;&gt; null, msg &amp; " Cash Receipt for on site cargo not created...");

	foreach cashPayment in cashReceipt.allCashPayments do
		if cashPayment.isProformaPayment then
			cashPaymentProForma := cashPayment;
		endif;
	endforeach;
	self.assertTrueMsg(cashPaymentProForma &lt;&gt; null, msg &amp; " Cash Payment Pro Forma for on site cargo not created...");
	//self.allCashObjectsToCleanup.add( cashPaymentProForma );
	self.assertTrueMsg(not onsiteTi.allCashPayments.isEmpty, msg &amp; " Pro Forma not on On Site Cargo...");
	
	// Clear all the stops
	self.deleteStops(onsiteTi);

	vvrOut := createVVR( truckOut, onsiteTi );
	self.assertTrueMsg(vvrOut &lt;&gt; null, msg &amp; " Vehicle Visit Record not created...");
	
	// Clear all the stops again
	self.deleteStops(onsiteTi);
	self.gateInTruck( vvrOut, false );
	
	self.workTruck( vvrOut, 2 );

	self.gateOutTruck( vvrOut, false ); 
	
	// cargo offsite, TI has 2 CM_CashPayment, $20 each neither proforma
	// cash receipt for $40  has a cash invoice with two invoice lines, $20 each UT_ILT9
	// cash receipt extra has the 2 CM_CashPayments
	// cargo now off site, so need to check proforma has been converted to real cash payment....
	count := 0;
	foreach cashPayment in onsiteTi.allCashPayments do
		if cashPayment.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357 tax payment ignore
			continue;
		endif;
		count := count + 1;
		self.assertTrueMsg(not cashPayment.isProformaPayment, msg &amp; " " &amp; count.String &amp; " Cargo Cash Payment should NOT be a pro forma after gate out... " );
		self.assertEqualMsg(cashPayment.cashValue, 20.Decimal, msg &amp; " " &amp; count.String &amp; " Cargo Cash payment value ");
	endforeach;
	assertEqualMsg(count, 2, msg &amp; " Cargo cash payments");

	count := 0;
	foreach cashPayment in cashReceipt.allCashPayments do
		count := count + 1;
		self.assertTrueMsg(not cashPayment.isProformaPayment, msg &amp; " " &amp; count.String &amp; " Receipt Cash Payment should NOT be a pro forma after gate out... " );
		self.assertEqualMsg(cashPayment.cashValue, 20.Decimal, msg &amp; " " &amp; count.String &amp; " Receipt Cash payment value ");
	endforeach;
	assertEqualMsg(count, 2, msg &amp; " Receipt cash payments");
	
	cashInvoice := cashReceipt.myCashInvoice;
	count := 0;
	foreach invLine in cashInvoice.invoiceLines do
		count := count + 1;
		self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_ILT9", msg &amp; " " &amp; count.String &amp; " Invoice line type" );
		self.assertEqualMsg(invLine.lineTotal, 20.Decimal, msg &amp; " " &amp; count.String &amp; " Invoice line value ");
	endforeach;
	assertEqualMsg(count, 2, msg &amp; " Receipt invoice lines");

	count := 0;
	foreach cashPayment in cashInvoice.allCashPayments do
		count := count + 1;
		self.assertEqualMsg(cashPayment.cashValue, 20.Decimal, msg &amp; " " &amp; count.String &amp; " Invoice payment value ");
	endforeach;
	assertEqualMsg(count, 2, msg &amp; " Receipt invoice payments");

epilog
	if allAgents &lt;&gt; null then
		allAgents.purge();
	endif;
	delete allAgents;
	delete allTIs;
	
end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <Parameter name="_drTerm1" type="CM_DebtorTerminal"/>
        <Parameter name="_truckOut" type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="cashTestSingleAgentStorage" id="1222792a-d625-44b1-b200-c5e0a64fe3ca">
        <updating/>
        <source>cashTestSingleAgentStorage(_id : String; _drTerm1 : CM_DebtorTerminal; _truckOut : CM_Vehicle) updating, protected;

/*

Purpose:		Cash module testing, gate out a single item with storage is due and with one full payment.
				Set the agent then change the agent code and gate it out.  The storage charge goes to the default debtor
				and the payment is a no-invoice line one.  Set the agent back and resync the storage transaction.
				The storage charge should go the agent debtor and the payment to the storage invoice line.

Parameters:			

Return Value:		


Date		Who		Reason
23/01/2015	cnwjre1	35356
28/11/2019	jlgsl4	TFS 47529 - JMT - Decimal Values on CM_CashReceipt, CM_CashPayment, CM_CashInvoiceProformaAgent
*/

constants

vars
	now			: TimeStamp;
	cargoId		: String;
	msg			: String;
	count		: Integer;
	
	drTerm1 : CM_DebtorTerminal;
	drTerm2 : CM_DebtorTerminal;
	
	cashReceipt : CM_CashReceipt;
	cashPaymentProForma : CM_CashPayment;
	cashPayment : CM_CashPayment;
	paymentMeth : CM_PaymentMethod;

	onsiteTi : CM_TrackedItem;
	trans	: CM_TITransaction;

	endDate : Date;
	cashToPay,
	cashTotal,
	cargoEstimatedCashCharges : Decimal[23,6];// [16,4]; // TFS 47529
	cashInvoice	: CM_Invoice;
	invLine : CM_InvoiceLine;
	
	carrier : CM_Carrier;
	
	truckIn : CM_Vehicle;
	truckOut : CM_Vehicle;
	vvrIn : CM_VehicleVisitRecord;
	vvrOut : CM_VehicleVisitRecord;
	
	debtorType	: CM_DebtorType;
	cashInvType,
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2  	: CM_InvoiceLineDesc;
	service			: CM_Service;
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
	debtor 		: CM_DebtorNode;
	
	allTIs 		: CM_TISet;
	allAgents		: ObjectArray;
	transSet : CM_TransactionSet;
	obj			: Object;
	agent : CM_CashInvoiceProformaAgent;
	opts	: CM_AssociationDict;	
	chequeBank : String;
	chequeBranch : String;
	chequeNumber : String;
	chequeDate : Date;
	cashId1,
	cashId2,
	cashId3,
	cashId4 : String;
	
	effectiveDate : Date;
	externalInvoiceNumber,
	externalReferenceNumber : String;
	
begin
	msg := method.name;

	// load transaction map to get more than one storage invoice line
	self.tranMapLoadDoubleStorage();	
	truckOut := _truckOut;
	//Now create onsite cargo that will be gated out by truck.
	cargoId := _id;
	onsiteTi := self.addOnsiteCargoForId(cargoId, true, 10);
	// has CM_Create, CM_Receive, CM_SubTermxxx, CM_Wash
	// is Storage, FCL, operator UTCH, null voyage, no stops, no agent assigned, 
	beginTransaction;
	onsiteTi.setMyVoyage(self.myVoyage, app.myPassport);
	foreach trans in onsiteTi.allTransactions do
		trans.setPropertyValue("voyage", self.myVoyage);
		trans.setPropertyValue("voyageCode", self.myVoyage.code);
		trans.setPropertyValue("myVoyageRelivant", self.myVoyage);
	endforeach;
	commitTransaction;

	self.assertTrueMsg(onsiteTi &lt;&gt; null, msg &amp; " On Site Cargo '" &amp; cargoId &amp; "' not created...");

	create allTIs transient;
	allTIs.add(onsiteTi);
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;
	// rate set in prior test, reset it
	service := self.myBank.services["UT_ServiceX11"];		// for storage, rate per day
	self.setServiceRate(service, debtor, "01/01/2013".Date, 10.00);
	drTerm1 := debtor.CM_Debtor.allDebtorTerminals.getAtKey( self.myTerminal );
	self.applyAgentToCargo(allTIs, debtorType, customsAgent);

	create allAgents transient;
	agent := self.createProformaAgent(now, onsiteTi);
	allAgents.add(agent);
	self.myAgent := agent;
	
	cashTotal := agent.cashPayments;
	cashToPay := agent.invoicedCashCharges + agent.estimatedCashCharges - cashTotal;

	paymentMeth := app.myRoot.allPaymentMethods[PayMethName];
	if paymentMeth = null then
		paymentMeth := CM_PaymentMethod.firstInstance;
	endif;

	cashReceipt := self.createBOLCashReceipt(	paymentMeth,	// _payMeth : CM_PaymentMethod;
					cashToPay,				// _amount : Decimal;
					chequeBank,			// _chequeBank : String;
					chequeBranch,		// _chequeBranch : String;
					chequeNumber,		// _chequeNumber : String;
					chequeDate,			// _chequeDate : Date;
					cashId1,			// _cashId1,
					cashId2,			// _cashId2,
					cashId3,			// _cashId3,
					cashId4,			// _cashId4 : String;
					0,					// _payment1 : Decimal;
					0,					// _payment2 : Decimal;
					effectiveDate,		// _effectiveDate : Date;
					externalInvoiceNumber,	// _externalInvoiceNumber,
					externalReferenceNumber,	// _externalReferenceNumber : String;
					cashToPay,
					cashTotal,
					self.myVoyage,
					_drTerm1,			// _drTerm : CM_DebtorTerminal;
					0,
					0,
					0,
					null,
					allAgents,			// _agents : ObjectArray
					"",					// _taxCode1,
					"",					// _taxCode2,
					""					// _taxCode3: String
					);
	
	// $20 current (Move), $20 proforma (Road Release), 2 x $20 cash payments
	
	self.assertTrueMsg(cashReceipt &lt;&gt; null, msg &amp; " Cash Receipt for on site cargo not created...");

	foreach cashPayment in cashReceipt.allCashPayments do
		if cashPayment.isProformaPayment then
			cashPaymentProForma := cashPayment;
		endif;
	endforeach;
	self.assertTrueMsg(cashPaymentProForma &lt;&gt; null, msg &amp; " Cash Payment Pro Forma for on site cargo not created...");
	self.assertTrueMsg(not onsiteTi.allCashPayments.isEmpty, msg &amp; " Pro Forma not on On Site Cargo...");
	
	// simulate agent id change by just clearing the tracked item agent (consignee in the original, customs agent here)
	beginTransaction;
		onsiteTi.setPropertyValue("myCustomsAgent", null);
	commitTransaction;
	// Clear all the stops
	self.deleteStops(onsiteTi);

	vvrOut := createVVR( truckOut, onsiteTi );
	self.assertTrueMsg(vvrOut &lt;&gt; null, msg &amp; " Vehicle Visit Record not created...");
	
	self.gateInTruck( vvrOut, false );
	
	self.workTruck( vvrOut, 2 );

	self.gateOutTruck( vvrOut, false ); 
	
	count := 0;
	foreach cashPayment in onsiteTi.allCashPayments do
		if cashPayment.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357 tax payment ignore
			continue;
		endif;
		count := count + 1;
	//	self.assertTrueMsg(not cashPayment.isProformaPayment, msg &amp; " " &amp; count.String &amp; " Cargo Cash Payment should NOT be a pro forma after gate out... " );
		if count = 1  then
			self.assertEqualMsg(cashPayment.cashValue, 20.Decimal, msg &amp; " " &amp; count.String &amp; " Cargo Cash payment value ");
		else
			// three original unallocated payment lines
			self.assertEqualMsg(cashPayment.myInvoiceLine, null, msg &amp; " " &amp; count.String &amp; " Cargo Cash invoice line null ");
			if count = 2  then
				self.assertEqualMsg(cashPayment.cashValue, 20.Decimal, msg &amp; " " &amp; count.String &amp; " Cargo Cash payment value ");
			elseif count = 3  then
				self.assertEqualMsg(cashPayment.cashValue, 50.Decimal, msg &amp; " " &amp; count.String &amp; " Cargo Cash payment value ");
			elseif count = 4  then
				self.assertEqualMsg(cashPayment.cashValue, 50.Decimal, msg &amp; " " &amp; count.String &amp; " Cargo Cash payment value ");
			endif;
		endif;
	endforeach;
	assertEqualMsg(count, 4, msg &amp; " Cargo cash payments");

	count := 0;
	foreach cashPayment in cashReceipt.allCashPayments do
		count := count + 1;
		//self.assertTrueMsg(not cashPayment.isProformaPayment, msg &amp; " " &amp; count.String &amp; " Receipt Cash Payment should NOT be a pro forma after gate out... " );
		if count = 1  then
			self.assertEqualMsg(cashPayment.cashValue, 20.Decimal, msg &amp; " " &amp; count.String &amp; " Receipt Cash payment value ");
		elseif count = 2  then
			self.assertEqualMsg(cashPayment.cashValue, 20.Decimal, msg &amp; " " &amp; count.String &amp; " Receipt Cash payment value ");
		elseif count = 3  then
			self.assertEqualMsg(cashPayment.cashValue, 50.Decimal, msg &amp; " " &amp; count.String &amp; " Receipt Cash payment value ");
		elseif count = 4  then
			self.assertEqualMsg(cashPayment.cashValue, 50.Decimal, msg &amp; " " &amp; count.String &amp; " Receipt Cash payment value ");
		endif;
	endforeach;
	assertEqualMsg(count, 4, msg &amp; " Receipt cash payments");
	
	// restore the customs agent
	beginTransaction;
		onsiteTi.setPropertyValue("myCustomsAgent", customsAgent);
	commitTransaction;
	// resync
	create transSet transient;
	foreach trans in onsiteTi.allTransactions discreteLock where trans.isKindOf(CM_Storage) or trans.isKindOf(CM_ReleaseRoad) do
		transSet.add(trans);
	endforeach;

	create opts transient;
	opts.addAssoc("updateCustomsAgent", true);
	self.updateInvoiceReevaluate(transSet, onsiteTi, opts);

	// the payments remain unchanged but only one has an invoice line now
	count := 0;
	foreach cashPayment in onsiteTi.allCashPayments do
		if cashPayment.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357 tax payment ignore
			continue;
		endif;
		count := count + 1;
		if count = 1  then
			self.assertEqualMsg(cashPayment.cashValue, 20.Decimal, msg &amp; " " &amp; count.String &amp; " Cargo Cash payment value ");
			self.assertNotNullMsg(cashPayment.myInvoiceLine, msg &amp; " " &amp; count.String &amp; " Cargo Cash invoice line not null ");
		elseif count = 2  then
			self.assertEqualMsg(cashPayment.cashValue, 20.Decimal, msg &amp; " " &amp; count.String &amp; " Cargo Cash payment value ");
		elseif count = 3  then
			self.assertEqualMsg(cashPayment.cashValue, 50.Decimal, msg &amp; " " &amp; count.String &amp; " Cargo Cash payment value ");
		else
			self.assertEqualMsg(cashPayment.cashValue, 50.Decimal, msg &amp; " " &amp; count.String &amp; " Cargo Cash payment value ");
		endif;
	endforeach;
	assertEqualMsg(count, 4, msg &amp; " Cargo reeval cash payments");
	
	count := 0;
	foreach invLine in onsiteTi.invoiceLines do
		count := count + 1;
	endforeach;
	assertEqualMsg(count, 5, msg &amp; " Cargo reeval invoice lines");

epilog
	if allAgents &lt;&gt; null then
		allAgents.purge();
	endif;
	delete allAgents;
	delete allTIs;
	delete transSet;
	delete opts;
	
end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <Parameter name="_drTerm1" type="CM_DebtorTerminal"/>
        <Parameter name="_truckOut" type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="cashTestSingleNotEnoughCash" id="b416b546-4323-4451-bbc9-ceae25987cb7">
        <updating/>
        <source>cashTestSingleNotEnoughCash(_id : String; _drTerm1 : CM_DebtorTerminal; _truckOut : CM_Vehicle) updating, protected;

/*

Purpose:		Cash module testing, gate out a single item before storage is due and with one part payment followed by the balance.

Parameters:			

Return Value:		


Date		Who		Reason
29/04/2014	cnwjre1	After par 33885
28/11/2019	jlgsl4	TFS 47529 - JMT - Decimal Values on CM_CashReceipt, CM_CashPayment, CM_CashInvoiceProformaAgent
*/

constants

vars
	effectiveTS,
	now			: TimeStamp;
	cargoId		: String;
	msg			: String;
	count		: Integer;
	pos1, pos2	: Integer;
	number1,
	number2		: Integer;
	
	cashReceipt1,
	cashReceipt2	: CM_CashReceipt;
	cashPaymentProForma : CM_CashPayment;
	cashPayment : CM_CashPayment;
	paymentMeth : CM_PaymentMethod;

	onsiteTi : CM_TrackedItem;
	trans	: CM_TITransaction;

	cashToPay,
	cashTotal,
	cargoEstimatedCashCharges : Decimal[23,6];//[16, 6]; // TFS 47529
	cashInvoice	: CM_Invoice;
	invLine : CM_InvoiceLine;
	
	truckOut : CM_Vehicle;
	vvrOut : CM_VehicleVisitRecord;
	
	debtorType	: CM_DebtorType;
	cashInvType,
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2  	: CM_InvoiceLineDesc;
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
	debtor 		: CM_DebtorNode;
	
	allTIs 		: CM_TISet;
	allAgents		: ObjectArray;
	agent : CM_CashInvoiceProformaAgent;
	chequeBank : String;
	chequeBranch : String;
	chequeNumber : String;
	chequeDate : Date;
	cashId1,
	cashId2,
	cashId3,
	cashId4 : String;

	effectiveDate : Date;
	externalInvoiceNumber,
	externalReferenceNumber : String;
	
begin
	msg := method.name;
	
	truckOut := _truckOut;
	//Now create onsite cargo that will be gated out by truck.
	cargoId := _id;
	onsiteTi := self.addOnsiteCargoForId(cargoId, true, 0);
	// has CM_Create, CM_Receive, CM_SubTermxxx, CM_Wash
	// is Storage, FCL, operator UTCH, null voyage, no stops, no agent assigned, 
	beginTransaction;
	onsiteTi.setMyVoyage(self.myVoyage, app.myPassport);
	foreach trans in onsiteTi.allTransactions do
		trans.setPropertyValue("voyage", self.myVoyage);
		trans.setPropertyValue("voyageCode", self.myVoyage.code);
		trans.setPropertyValue("myVoyageRelivant", self.myVoyage);
	endforeach;
	commitTransaction;

	self.assertTrueMsg(onsiteTi &lt;&gt; null, msg &amp; " On Site Cargo '" &amp; cargoId &amp; "' not created...");

	create allTIs transient;
	allTIs.add(onsiteTi);
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;
	self.applyAgentToCargo(allTIs, debtorType, customsAgent);

	now := app.actualTimeServer;
	create allAgents transient;
	agent := self.createProformaAgent(now, onsiteTi);
	allAgents.add(agent);
	self.myAgent := agent;
	
	cashToPay := agent.invoicedCashCharges;
	// don't pay any proforma charges so the cargo does not get released
// TFS 45953	foreach invLine in agent.allProformaInvLines do
// TFS 45953		agent.setSelected(true, false, invLine);
// TFS 45953	endforeach;
	agent.allProformaInvLines.purge(); // TFS 45953
		
	paymentMeth := app.myRoot.allPaymentMethods[PayMethName];
	if paymentMeth = null then
		paymentMeth := CM_PaymentMethod.firstInstance;
	endif;

	cashReceipt1 := self.createBOLCashReceipt(	paymentMeth,	// _payMeth : CM_PaymentMethod;
					cashToPay,				// _amount : Decimal;
					chequeBank,			// _chequeBank : String;
					chequeBranch,		// _chequeBranch : String;
					chequeNumber,		// _chequeNumber : String;
					chequeDate,			// _chequeDate : Date;
					cashId1,			// _cashId1,
					cashId2,			// _cashId2,
					cashId3,			// _cashId3,
					cashId4,			// _cashId4 : String;
					0,					// _payment1 : Decimal;
					0,					// _payment2 : Decimal;
					effectiveDate,		// _effectiveDate : Date;
					externalInvoiceNumber,	// _externalInvoiceNumber,
					externalReferenceNumber,	// _externalReferenceNumber : String;
					cashToPay,
					cashTotal,
					self.myVoyage,
					_drTerm1,			// _drTerm : CM_DebtorTerminal;
					0,
					0,
					0,
					null,
					allAgents,			// _agents : ObjectArray
					"",					// _taxCode1,
					"",					// _taxCode2,
					""					// _taxCode3: String
					);
	
	self.assertTrueMsg(cashReceipt1 &lt;&gt; null, msg &amp; " Cash Receipt 1 for on site cargo not created...");

	// Clear all the stops
	self.deleteStops(onsiteTi);

	vvrOut := createVVR( truckOut, onsiteTi );
	self.assertTrueMsg(vvrOut &lt;&gt; null, msg &amp; " Vehicle Visit Record not created...");
	
	self.gateInTruck( vvrOut, true );		// DO expect error

	// create a second receipt for the balance
	allAgents.purge();
	agent := self.createProformaAgent(now, onsiteTi);
	allAgents.add(agent);
	cashTotal := agent.cashPayments;
	cashToPay := agent.invoicedCashCharges + agent.estimatedCashCharges - cashTotal;

	cashReceipt2 := self.createBOLCashReceipt(	paymentMeth,	// _payMeth : CM_PaymentMethod;
					cashToPay,				// _amount : Decimal;
					chequeBank,			// _chequeBank : String;
					chequeBranch,		// _chequeBranch : String;
					chequeNumber,		// _chequeNumber : String;
					chequeDate,			// _chequeDate : Date;
					cashId1,			// _cashId1,
					cashId2,			// _cashId2,
					cashId3,			// _cashId3,
					cashId4,			// _cashId4 : String;
					0,					// _payment1 : Decimal;
					0,					// _payment2 : Decimal;
					effectiveDate,		// _effectiveDate : Date;
					externalInvoiceNumber,	// _externalInvoiceNumber,
					externalReferenceNumber,	// _externalReferenceNumber : String;
					cashToPay,
					cashTotal,
					self.myVoyage,
					_drTerm1,			// _drTerm : CM_DebtorTerminal;
					0,
					0,
					0,
					null,
					allAgents,			// _agents : ObjectArray
					"",					// _taxCode1,
					"",					// _taxCode2,
					""					// _taxCode3: String
					);

	self.assertTrueMsg(cashReceipt2 &lt;&gt; null, msg &amp; " Cash Receipt 2 for on site cargo not created...");

	self.gateInTruck( vvrOut, false );		// expect NO error

	self.workTruck( vvrOut, 2 );

	self.gateOutTruck( vvrOut, false ); 
	
	count := 0;
	foreach cashPayment in onsiteTi.allCashPayments do
		if cashPayment.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357 tax payment ignore
			continue;
		endif;
		count := count + 1;
		self.assertTrueMsg(not cashPayment.isProformaPayment, msg &amp; " " &amp; count.String &amp; " Cargo Cash Payment should NOT be a pro forma after gate out... " );
		if count = 1 then
			self.assertEqualMsg(cashPayment.cashValue, 20.Decimal, msg &amp; " " &amp; count.String &amp; " Cargo Cash payment value ");
		else
			self.assertEqualMsg(cashPayment.cashValue, 20.Decimal, msg &amp; " " &amp; count.String &amp; " Cargo Cash payment value ");
		endif;
	endforeach;
	assertEqualMsg(count, 2, msg &amp; " Cargo cash payments");

	count := 0;
	foreach cashPayment in cashReceipt1.allCashPayments do
		count := count + 1;
		self.assertTrueMsg(not cashPayment.isProformaPayment, msg &amp; " " &amp; count.String &amp; " Receipt Cash Payment should NOT be a pro forma after gate out... " );
		self.assertEqualMsg(cashPayment.cashValue, 20.Decimal, msg &amp; " " &amp; count.String &amp; " Receipt 1 Cash payment value ");
	endforeach;
	assertEqualMsg(count, 1, msg &amp; " Receipt 1 cash payments");
	count := 0;
	foreach cashPayment in cashReceipt2.allCashPayments do
		count := count + 1;
		self.assertTrueMsg(not cashPayment.isProformaPayment, msg &amp; " " &amp; count.String &amp; " Receipt Cash Payment should NOT be a pro forma after gate out... " );
		self.assertEqualMsg(cashPayment.cashValue, 20.Decimal, msg &amp; " " &amp; count.String &amp; " Receipt 2 Cash payment value ");
	endforeach;
	assertEqualMsg(count, 1, msg &amp; " Receipt 2 cash payments");
	
	cashInvoice := cashReceipt1.myCashInvoice;
	count := 0;
	foreach invLine in cashInvoice.invoiceLines do
		count := count + 1;
		self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_ILT9", msg &amp; " " &amp; count.String &amp; " Invoice line type" );
		self.assertEqualMsg(invLine.lineTotal, 20.Decimal, msg &amp; " " &amp; count.String &amp; " Invoice line value ");
	endforeach;
// TFS 45953	assertEqualMsg(count, 2, msg &amp; " Receipt invoice lines");
	assertEqualMsg(count, 1, msg &amp; " Receipt invoice lines"); // TFS 45953 changed to 1 because now using 1 invoice per receipt
	// TFS 45953 removed because now using 1 invoice per receipt //cashInvoice := cashReceipt2.myCashInvoice;
	// TFS 45953 removed because now using 1 invoice per receipt //self.assertTrueMsg(cashInvoice = null, msg &amp; " Second receipt cash invoice null");
	// test for 34555, the externalInvoiceNumber of the two cash receipts should increment by 1
	//  Milaha, format JMT/DPR/&lt;nnnnnn&gt;/yy
	pos1 := cashReceipt1.externalInvoiceNumber.pos("/", 1);
	pos2 := cashReceipt1.externalInvoiceNumber.pos("/",pos1 + 1);
	pos1 := cashReceipt1.externalInvoiceNumber.pos("/", pos2 + 1);
	number1 := 	cashReceipt1.externalInvoiceNumber[pos2 + 1: pos1 - (pos2 + 1)].Integer;
	pos1 := cashReceipt2.externalInvoiceNumber.pos("/", 1);
	pos2 := cashReceipt2.externalInvoiceNumber.pos("/",pos1 + 1);
	pos1 := cashReceipt2.externalInvoiceNumber.pos("/", pos2 + 1);
	number2 := 	cashReceipt2.externalInvoiceNumber[pos2 + 1: pos1 - (pos2 + 1)].Integer;
	self.assertEqualMsg((number2 - number1), 1, "Internal number increment");
	
epilog

	if allAgents &lt;&gt; null then
		allAgents.purge();
	endif;
	delete allAgents;
	delete allTIs;
	
end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <Parameter name="_drTerm1" type="CM_DebtorTerminal"/>
        <Parameter name="_truckOut" type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="cashTestSingleStorageOverpay" id="a2456262-ff23-48c2-959c-63e3f0834ff4">
        <updating/>
        <source>cashTestSingleStorageOverpay(_id : String; _drTerm1 : CM_DebtorTerminal; _truckOut : CM_Vehicle) updating, protected;

/*

Purpose:		Cash module testing, gate out a single item with storage is due and with one full payment.
				Storage charges are in more than one invoice line.
				The payment exceeds the storage and has a new payment with no invoice line created.
Parameters:			

Return Value:		


Date		Who		Reason
29/04/2014	cnwjre1	After par 33885
28/11/2019	jlgsl4	TFS 47529 - JMT - Decimal Values on CM_CashReceipt, CM_CashPayment, CM_CashInvoiceProformaAgent
*/

constants

vars
	now			: TimeStamp;
	debtorName	: String;
	cargoId		: String;
	msg			: String;
	count		: Integer;
	
	drTerm1 : CM_DebtorTerminal;
	drTerm2 : CM_DebtorTerminal;
	
	cashReceipt : CM_CashReceipt;
	cashPaymentProForma : CM_CashPayment;
	cashPayment : CM_CashPayment;
	paymentMeth : CM_PaymentMethod;

	onsiteTi : CM_TrackedItem;
	trans	: CM_TITransaction;

	endDate : Date;
	cashToPay,
	cashTotal,
	cargoEstimatedCashCharges : Decimal[23,6];// [16,4]; // TFS 47529
	cashInvoice	: CM_Invoice;
	invLine : CM_InvoiceLine;
	
	carrier : CM_Carrier;
	
	truckIn : CM_Vehicle;
	truckOut : CM_Vehicle;
	vvrIn : CM_VehicleVisitRecord;
	vvrOut : CM_VehicleVisitRecord;
	
	debtorType	: CM_DebtorType;
	cashInvType,
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2  	: CM_InvoiceLineDesc;
	service			: CM_Service;
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
	debtor 		: CM_DebtorNode;
	
	allTIs 		: CM_TISet;
	allAgents		: ObjectArray;
	agent : CM_CashInvoiceProformaAgent;
	chequeBank : String;
	chequeBranch : String;
	chequeNumber : String;
	chequeDate : Date;
	cashId1,
	cashId2,
	cashId3,
	cashId4 : String;
	
	effectiveDate : Date;
	externalInvoiceNumber,
	externalReferenceNumber : String;
	
begin
	msg := method.name;
	
	// Yard invoice type, ILT11 invoice line type, used with ILT10 in storage, charged to customs agent, calc type Days Since Receival
	invType := self.getInvoiceType("UT_Yard");
	self.addIfNewServiceILD("UT_ServiceX11", "CCT06", "UT_ILT11", null, invType);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT11"];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	debtorName := "UT_Cash1";
	debtor := app.myRoot.myRootCompany.debtorNodes[debtorName].CM_Debtor;
	service := self.myBank.services["UT_ServiceX11"];		// for storage, rate per day
	self.setServiceRate(service, debtor, "01/01/2013".Date, 15.00);
	
	// load a specific transaction map for 2 storage invoice lines
	self.tranMapLoadMultiStorage();

	truckOut := _truckOut;
	//Now create onsite cargo that will be gated out by truck.
	cargoId := _id;
	onsiteTi := self.addOnsiteCargoForId(cargoId, true, 10);

	beginTransaction;
	onsiteTi.setMyVoyage(self.myVoyage, app.myPassport);
	foreach trans in onsiteTi.allTransactions do
		trans.setPropertyValue("voyage", self.myVoyage);
		trans.setPropertyValue("voyageCode", self.myVoyage.code);
		trans.setPropertyValue("myVoyageRelivant", self.myVoyage);
	endforeach;
	commitTransaction;

	self.assertTrueMsg(onsiteTi &lt;&gt; null, msg &amp; " On Site Cargo '" &amp; cargoId &amp; "' not created...");

	create allTIs transient;
	allTIs.add(onsiteTi);
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;
	self.applyAgentToCargo(allTIs, debtorType, customsAgent);

	create allAgents transient;
	agent := self.createProformaAgent(now, onsiteTi);
	allAgents.add(agent);
	self.myAgent := agent;
	
	cashTotal := agent.cashPayments;
	cashToPay := agent.invoicedCashCharges + agent.estimatedCashCharges - cashTotal;

	paymentMeth := app.myRoot.allPaymentMethods[PayMethName];
	if paymentMeth = null then
		paymentMeth := CM_PaymentMethod.firstInstance;
	endif;
/* TFS 45953 change to use the single unit test 'create cash receipt'
	cashReceipt := self.createFullCashReceipt(	paymentMeth,	// _payMeth : CM_PaymentMethod;
					cashToPay,				// _amount : Decimal;
					chequeBank,			// _chequeBank : String;
					chequeBranch,		// _chequeBranch : String;
					chequeNumber,		// _chequeNumber : String;
					chequeDate,			// _chequeDate : Date;
					cashId1,			// _cashId1,
					cashId2,			// _cashId2,
					cashId3,			// _cashId3,
					cashId4,			// _cashId4 : String;
					payment1,			// _payment1 : Decimal;
					payment2,			// _payment2 : Decimal;
					effectiveDate,		// _effectiveDate : Date;
					externalInvoiceNumber,	// _externalInvoiceNumber,
					externalReferenceNumber,	// _externalReferenceNumber : String;
					cashToPay,
					cashTotal,
					self.myVoyage,
					_drTerm1,			// _drTerm : CM_DebtorTerminal;
					allAgents			// _agents : ObjectArray
					);
					*/
	cashReceipt := self.createBOLCashReceipt(	paymentMeth,	// _payMeth : CM_PaymentMethod;
					cashToPay,				// _amount : Decimal;
					chequeBank,			// _chequeBank : String;
					chequeBranch,		// _chequeBranch : String;
					chequeNumber,		// _chequeNumber : String;
					chequeDate,			// _chequeDate : Date;
					cashId1,			// _cashId1,
					cashId2,			// _cashId2,
					cashId3,			// _cashId3,
					cashId4,			// _cashId4 : String;
					0,					// _payment1 : Decimal;
					0,					// _payment2 : Decimal;
					effectiveDate,		// _effectiveDate : Date;
					externalInvoiceNumber,	// _externalInvoiceNumber,
					externalReferenceNumber,	// _externalReferenceNumber : String;
					cashToPay,
					cashTotal,
					self.myVoyage,
					_drTerm1,			// _drTerm : CM_DebtorTerminal;
					0,
					0,
					0,
					null,
					allAgents,			// _agents : ObjectArray
					"",					// _taxCode1,
					"",					// _taxCode2,
					""					// _taxCode3: String
					);
	
					
	
	self.assertTrueMsg(cashReceipt &lt;&gt; null, msg &amp; " Cash Receipt for on site cargo not created...");

	foreach cashPayment in cashReceipt.allCashPayments do
		if cashPayment.isProformaPayment then
			cashPaymentProForma := cashPayment;
		endif;
	endforeach;
	self.assertTrueMsg(cashPaymentProForma &lt;&gt; null, msg &amp; " Cash Payment Pro Forma for on site cargo not created...");

	self.assertTrueMsg(not onsiteTi.allCashPayments.isEmpty, msg &amp; " Pro Forma not on On Site Cargo...");

	// DECREASE the last storage rate so that the payment exceeds the charges
	debtorName := "UT_Cash1";
	debtor := app.myRoot.myRootCompany.debtorNodes[debtorName].CM_Debtor;
	service := self.myBank.services["UT_ServiceX11"];		// for storage, rate per day
	self.setServiceRate(service, debtor, "01/01/2013".Date, 12.00);

	// Clear all the stops
	self.deleteStops(onsiteTi);

	vvrOut := createVVR( truckOut, onsiteTi );
	self.assertTrueMsg(vvrOut &lt;&gt; null, msg &amp; " Vehicle Visit Record not created...");
	
	self.gateInTruck( vvrOut, false );
	
	self.workTruck( vvrOut, 2 );

	self.gateOutTruck( vvrOut, false ); 
	
	count := 0;
	foreach cashPayment in onsiteTi.allCashPayments do
		if cashPayment.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357 tax payment ignore
			continue;
		endif;
		count := count + 1;
		self.assertTrueMsg(not cashPayment.isProformaPayment, msg &amp; " " &amp; count.String &amp; " Cargo Cash Payment should NOT be a pro forma after gate out... " );
		if count = 1 or count = 2 then
			self.assertEqualMsg(cashPayment.cashValue, 20.Decimal, msg &amp; " " &amp; count.String &amp; " Cargo Cash payment value ");
		elseif count = 3 then
			self.assertEqualMsg(cashPayment.cashValue, 40.Decimal, msg &amp; " " &amp; count.String &amp; " Cargo Cash payment value ");
		elseif count = 4 then
			self.assertEqualMsg(cashPayment.cashValue, 75.Decimal, msg &amp; " " &amp; count.String &amp; " Cargo Cash payment value ");
		endif;
	endforeach;
	assertEqualMsg(count, 4, msg &amp; " Cargo cash payments");

	count := 0;
	foreach cashPayment in cashReceipt.allCashPayments do
		count := count + 1;
		self.assertTrueMsg(not cashPayment.isProformaPayment, msg &amp; " " &amp; count.String &amp; " Receipt Cash Payment should NOT be a pro forma after gate out... " );
		if count = 1 or count = 2 then
			self.assertEqualMsg(cashPayment.cashValue, 20.Decimal, msg &amp; " " &amp; count.String &amp; " Receipt Cash payment value ");
		elseif count = 3 then
			self.assertEqualMsg(cashPayment.cashValue, 40.Decimal, msg &amp; " " &amp; count.String &amp; " Receipt Cash payment value ");
		elseif count = 4 then
			self.assertEqualMsg(cashPayment.cashValue, 75.Decimal, msg &amp; " " &amp; count.String &amp; " Receipt Cash payment value ");
		endif;
	endforeach;
	assertEqualMsg(count, 4, msg &amp; " Receipt cash payments");
	
	cashInvoice := cashReceipt.myCashInvoice;
	count := 0;
	foreach invLine in cashInvoice.invoiceLines do
		count := count + 1;
		if count = 1 or count = 2 then
			self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_ILT9", msg &amp; " " &amp; count.String &amp; " Invoice line type" );
			self.assertEqualMsg(invLine.lineTotal, 20.Decimal, msg &amp; " " &amp; count.String &amp; " Invoice line value ");
		elseif count = 3 then
			self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_ILT10", msg &amp; " " &amp; count.String &amp; " Invoice line type" );
			self.assertEqualMsg(invLine.lineTotal, 40.Decimal, msg &amp; " " &amp; count.String &amp; " Invoice line value ");
		else	
			self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_ILT11", msg &amp; " " &amp; count.String &amp; " Invoice line type" );
			self.assertEqualMsg(invLine.lineTotal, 60.Decimal, msg &amp; " " &amp; count.String &amp; " Invoice line value ");
		endif;
	endforeach;
	assertEqualMsg(count, 4, msg &amp; " Receipt invoice lines");

epilog
	if allAgents &lt;&gt; null then
		allAgents.purge();
	endif;
	delete allAgents;
	delete allTIs;
	
end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <Parameter name="_drTerm1" type="CM_DebtorTerminal"/>
        <Parameter name="_truckOut" type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="cashTestSingleWithStorage" id="f17c28f6-4f86-4b76-aee1-acb0b105e3c7">
        <updating/>
        <source>cashTestSingleWithStorage(_id : String; _drTerm1 : CM_DebtorTerminal; _truckOut : CM_Vehicle) updating, protected;

/*

Purpose:		Cash module testing, gate out a single item with storage is due and with one full payment.

Parameters:			

Return Value:		


Date		Who		Reason
29/04/2014	cnwjre1	After par 33885
28/11/2019	jlgsl4	TFS 47529 - JMT - Decimal Values on CM_CashReceipt, CM_CashPayment, CM_CashInvoiceProformaAgent
*/

constants

vars
	now			: TimeStamp;
	cargoId		: String;
	msg			: String;
	count		: Integer;
	
	drTerm1 : CM_DebtorTerminal;
	drTerm2 : CM_DebtorTerminal;
	
	cashReceipt : CM_CashReceipt;
	cashPaymentProForma : CM_CashPayment;
	cashPayment : CM_CashPayment;
	paymentMeth : CM_PaymentMethod;

	onsiteTi : CM_TrackedItem;
	trans	: CM_TITransaction;

	endDate : Date;
	cashToPay,
	cashTotal,
	cargoEstimatedCashCharges : Decimal[23,6];// [16,4]; // TFS 47529
	cashInvoice	: CM_Invoice;
	invLine : CM_InvoiceLine;
	
	carrier : CM_Carrier;
	
	truckIn : CM_Vehicle;
	truckOut : CM_Vehicle;
	vvrIn : CM_VehicleVisitRecord;
	vvrOut : CM_VehicleVisitRecord;
	
	debtorType	: CM_DebtorType;
	cashInvType,
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2  	: CM_InvoiceLineDesc;
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
	debtor 		: CM_DebtorNode;
	
	allTIs 		: CM_TISet;
	allAgents		: ObjectArray;
	agent : CM_CashInvoiceProformaAgent;
	chequeBank : String;
	chequeBranch : String;
	chequeNumber : String;
	chequeDate : Date;
	cashId1,
	cashId2,
	cashId3,
	cashId4 : String;

	effectiveDate : Date;
	externalInvoiceNumber,
	externalReferenceNumber : String;
	
begin
	msg := method.name;

	truckOut := _truckOut;
	//Now create onsite cargo that will be gated out by truck.
	cargoId := _id;
	onsiteTi := self.addOnsiteCargoForId(cargoId, true, 10);
	// has CM_Create, CM_Receive, CM_SubTermxxx, CM_Wash
	// is Storage, FCL, operator UTCH, null voyage, no stops, no agent assigned, 
	beginTransaction;
	onsiteTi.setMyVoyage(self.myVoyage, app.myPassport);
	foreach trans in onsiteTi.allTransactions do
		trans.setPropertyValue("voyage", self.myVoyage);
		trans.setPropertyValue("voyageCode", self.myVoyage.code);
		trans.setPropertyValue("myVoyageRelivant", self.myVoyage);
	endforeach;
	commitTransaction;

	self.assertTrueMsg(onsiteTi &lt;&gt; null, msg &amp; " On Site Cargo '" &amp; cargoId &amp; "' not created...");

	create allTIs transient;
	allTIs.add(onsiteTi);
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;
	self.applyAgentToCargo(allTIs, debtorType, customsAgent);

	create allAgents transient;
	agent := self.createProformaAgent(now, onsiteTi);
	allAgents.add(agent);
	self.myAgent := agent;
	
	cashTotal := agent.cashPayments;
	cashToPay := agent.invoicedCashCharges + agent.estimatedCashCharges - cashTotal;

	paymentMeth := app.myRoot.allPaymentMethods[PayMethName];
	if paymentMeth = null then
		paymentMeth := CM_PaymentMethod.firstInstance;
	endif;

	cashReceipt := self.createBOLCashReceipt(	paymentMeth,	// _payMeth : CM_PaymentMethod;
					cashToPay,				// _amount : Decimal;
					chequeBank,			// _chequeBank : String;
					chequeBranch,		// _chequeBranch : String;
					chequeNumber,		// _chequeNumber : String;
					chequeDate,			// _chequeDate : Date;
					cashId1,			// _cashId1,
					cashId2,			// _cashId2,
					cashId3,			// _cashId3,
					cashId4,			// _cashId4 : String;
					0,					// _payment1 : Decimal;
					0,					// _payment2 : Decimal;
					effectiveDate,		// _effectiveDate : Date;
					externalInvoiceNumber,	// _externalInvoiceNumber,
					externalReferenceNumber,	// _externalReferenceNumber : String;
					cashToPay,
					cashTotal,
					self.myVoyage,
					_drTerm1,			// _drTerm : CM_DebtorTerminal;
					0,
					0,
					0,
					null,
					allAgents,			// _agents : ObjectArray
					"",					// _taxCode1,
					"",					// _taxCode2,
					""					// _taxCode3: String
					);
	
	// $20 current (Move), $20 proforma (Road Release), 2 x $20 cash payments
	
	self.assertTrueMsg(cashReceipt &lt;&gt; null, msg &amp; " Cash Receipt for on site cargo not created...");

	foreach cashPayment in cashReceipt.allCashPayments do
		if cashPayment.isProformaPayment then
			cashPaymentProForma := cashPayment;
		endif;
	endforeach;
	self.assertTrueMsg(cashPaymentProForma &lt;&gt; null, msg &amp; " Cash Payment Pro Forma for on site cargo not created...");
	//self.allCashObjectsToCleanup.add( cashPaymentProForma );
	self.assertTrueMsg(not onsiteTi.allCashPayments.isEmpty, msg &amp; " Pro Forma not on On Site Cargo...");
	
	// Clear all the stops
	self.deleteStops(onsiteTi);

	vvrOut := createVVR( truckOut, onsiteTi );
	self.assertTrueMsg(vvrOut &lt;&gt; null, msg &amp; " Vehicle Visit Record not created...");
	
	self.gateInTruck( vvrOut, false );
	
	self.workTruck( vvrOut, 2 );

	self.gateOutTruck( vvrOut, false ); 
	
	count := 0;
	foreach cashPayment in onsiteTi.allCashPayments do
		if cashPayment.myCashPaymentForInvoice &lt;&gt; null then // TFS 7357 tax payment ignore
			continue;
		endif;
		count := count + 1;
		self.assertTrueMsg(not cashPayment.isProformaPayment, msg &amp; " " &amp; count.String &amp; " Cargo Cash Payment should NOT be a pro forma after gate out... " );
		if count = 1 or count = 2 then
			self.assertEqualMsg(cashPayment.cashValue, 20.Decimal, msg &amp; " " &amp; count.String &amp; " Cargo Cash payment value ");
		else
			self.assertEqualMsg(cashPayment.cashValue, 100.Decimal, msg &amp; " " &amp; count.String &amp; " Cargo Cash payment value ");
		endif;
	endforeach;
	assertEqualMsg(count, 3, msg &amp; " Cargo cash payments");

	count := 0;
	foreach cashPayment in cashReceipt.allCashPayments do
		count := count + 1;
		self.assertTrueMsg(not cashPayment.isProformaPayment, msg &amp; " " &amp; count.String &amp; " Receipt Cash Payment should NOT be a pro forma after gate out... " );
		if count = 1 or count = 2 then
			self.assertEqualMsg(cashPayment.cashValue, 20.Decimal, msg &amp; " " &amp; count.String &amp; " Receipt Cash payment value ");
		else
			self.assertEqualMsg(cashPayment.cashValue, 100.Decimal, msg &amp; " " &amp; count.String &amp; " Receipt Cash payment value ");
		endif;
	endforeach;
	assertEqualMsg(count, 3, msg &amp; " Receipt cash payments");
	
	cashInvoice := cashReceipt.myCashInvoice;
	count := 0;
	foreach invLine in cashInvoice.invoiceLines do
		count := count + 1;
		if count = 1 or count = 2 then
			self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_ILT9", msg &amp; " " &amp; count.String &amp; " Invoice line type" );
			self.assertEqualMsg(invLine.lineTotal, 20.Decimal, msg &amp; " " &amp; count.String &amp; " Invoice line value ");
		else
			self.assertEqualMsg(invLine.invoiceLineDesc.narration, "UT_ILT10", msg &amp; " " &amp; count.String &amp; " Invoice line type" );
			self.assertEqualMsg(invLine.lineTotal, 100.Decimal, msg &amp; " " &amp; count.String &amp; " Invoice line value ");
		endif;
	endforeach;
	assertEqualMsg(count, 3, msg &amp; " Receipt invoice lines");

epilog
	if allAgents &lt;&gt; null then
		allAgents.purge();
	endif;
	delete allAgents;
	delete allTIs;
	
end;</source>
        <access>protected</access>
        <Parameter name="_id" type="String"/>
        <Parameter name="_drTerm1" type="CM_DebtorTerminal"/>
        <Parameter name="_truckOut" type="CM_Vehicle"/>
