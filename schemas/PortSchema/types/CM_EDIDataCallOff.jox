    <JadeMethod name="getDataTypeFromDefName" id="0119147f-5288-4d9e-8231-5d01415ddab2">
        <source>getDataTypeFromDefName(_name: String): Integer;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 29/06/2023	navdap1		Initial creation TFS 58923 EUP CallOff EDI Data Type / EDI Load
//13 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
//11 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
//
vars
	aRequestMultiLine : CM_EDIDataRequestMultiLine;
begin
	if _name = ETDef_EDIDataCallOff then		//11 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
		return EDIDataType_CallOff;
	endif;
	if self.myRequestMultiLine = null then		//13 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
		create aRequestMultiLine transient;
		return aRequestMultiLine.getDataTypeFromDefName(_name);
	endif;
	return self.myRequestMultiLine.getDataTypeFromDefName(_name);

epilog
	if aRequestMultiLine &lt;&gt; null then
		delete aRequestMultiLine;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStrForDefName" id="e2b6bb20-fc5e-4966-90c2-9740f9310106">
        <source>getDisplayStrForDefName(_name: String): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
*/

vars
	aRequestMultiLine : CM_EDIDataRequestMultiLine;
begin
	if _name = ETDef_EDIDataCallOff then
		return app.getErrorString(Call_Off);
	endif;
	if self.myRequestMultiLine = null then		//13 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
		create aRequestMultiLine transient;
		return aRequestMultiLine.getDisplayStrForDefName(_name);
	endif;
	return self.myRequestMultiLine.getDisplayStrForDefName(_name);

epilog
	if aRequestMultiLine &lt;&gt; null then
		delete aRequestMultiLine;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="3046423b-661a-44fb-bd07-19ae7f9946bd">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 29/06/2023	navdap1		Initial creation TFS 58923 EUP CallOff EDI Data Type / EDI Load
// 08/08/2023	navdap1		TFS 59719 EUP - EDI Sender Field - Financial ID
// 08/08/2023	navra1		TFS 59666 EUP - CallOff fields not available in the column organiser
// 12/09/2023	navdap1		TFS 60453 EUP | FR 53824 - EDI Operations Date Range Filter Sometimes Omits Valid or Includes Invalid EDI Data Items
// 01 November 2024	navcs2	MTN-33047 EUP - NTO-1000 - EUP - Additional Data Fields in EDI Operations	
vars
	invalid : Boolean;
	strValue : String;
	debtor : CM_Debtor;		// TFS 59719

begin
	if _attrName = ETRow_ManifestType then
		return self.type &amp; " (" &amp; self.transportationMode &amp; ")";
		
	elseif _attrName = ETRow_HeaderDate then
		return self.headerDate.asStringJMT;
	
	elseif _attrName = ETRow_Guid then
		return self.guid;
		
	elseif _attrName = ETRow_ManifestNumber then
		return self.manifestNumber;
		
	elseif _attrName = ETRow_Receiver then
		return self.receiver;
		
	elseif _attrName = ETRow_Sender then
		// TFS 59719 start
		debtor := app.myRoot.myRootCompany.allDebtorsByCode[self.sender];
		if debtor &lt;&gt; null then
			return self.sender &amp; " - " &amp; debtor.name;
		endif;
		// TFS 59719 end
		return self.sender;
		
	elseif _attrName = ETRow_TransportStatus then
		return self.statusString;
	
	//navra1 - TFS 59666 - 8th Aug 2023 - start
	elseif _attrName = ETRow_Vehicle then
		return self.getVehicleNumber();
	elseif _attrName = ETRow_VbsNumberExternal then
		return self.transportReferenceCustomer;
	elseif _attrName = ETRow_VbSlotType then
		return self.vehicleBookingSlotType;
	//navra1 - TFS 59666 - 8th Aug 2023 - end
	elseif _attrName = ETRow_Status 
	or _attrName = ETRow_CreatedTime // TFS 60453
	// ### TFS BUG 65389 01AUG2024 NAVAB1
	or _attrName = ETRow_NumErrors
	or _attrName = ETRow_NumWarnings
	or _attrName = ETRow_Date
	or _attrName = ETRow_FirstOperatorCode then
		return inheritMethod(_attrName, _short);
	elseif _attrName = ETRow_HasItems then			// 04 November 2024	navcs2	MTN-33047
		if self.hasItems then						// 04 November 2024	navcs2	MTN-33047
			return app.getErrorString(Yes);			// 04 November 2024	navcs2	MTN-33047
		else										// 04 November 2024	navcs2	MTN-33047	
			return app.getErrorString(No);			// 04 November 2024	navcs2	MTN-33047	
		endif;										// 04 November 2024	navcs2	MTN-33047	
	endif;
	
	on Exception do app.handleDeletedObject(exception, self.myRequestMultiLine, invalid);
	if self.myRequestMultiLine &lt;&gt; null then
		strValue := self.myRequestMultiLine.getDisplayStringForAttribute(_attrName, _short);
		if invalid then
			return null;
		endif;
		if  strValue &lt;&gt; null then
			return strValue;
		endif;
	endif;
	
	return inheritMethod(_attrName, _short);
	
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEDIAction" id="5eeef30a-fa50-4b97-ba2d-f0971a3bb0df">
        <source>getEDIAction(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 November 2023	navsp1	Initial creation TFS 61165

*/

vars

begin
	if self.myRequestMultiLine &lt;&gt; null then
		return self.myRequestMultiLine.allEDITrackedItems.first.messageMode;
	else
		return null;
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEDIChildDataTypes" id="1e85c67e-a254-45bc-bf15-2859adcd61c7">
        <source>getEDIChildDataTypes(_types: IntegerArray input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 29/06/2023	navdap1		Initial creation TFS 58923 EUP CallOff EDI Data Type / EDI Load
//13 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
//
vars
	aRequestMultiLine : CM_EDIDataRequestMultiLine;
begin
	_types.add(EDIDataType_CallOff);
	if self.myRequestMultiLine &lt;&gt; null then
		self.myRequestMultiLine.getEDIChildDataTypes(_types);
	else
		create aRequestMultiLine transient;
		aRequestMultiLine.getEDIChildDataTypes(_types);
