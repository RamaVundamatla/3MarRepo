    <JadeMethod name="setNAPIAttributes" id="31c37d0d-e934-4e01-bfe8-21f4d22380bc">
        <updating/>
        <source>setNAPIAttributes(_appName, _appVersion, _apiVersion, _eventType, _payload : String; _createdAt : Real) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 02/11/2020	jlgdap1		Initial creation TFS 50199 MTN Navis API - Audit Log
//
vars

begin
	self.appName := _appName;
	self.appVersion := _appVersion;
	self.apiVersion := _apiVersion;
	self.createdAt := _createdAt;
	self.eventType := _eventType;
	self.generalPayload := _payload;
	
	self.setDescription(_eventType[1:80]);
epilog

end;</source>
