        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     28 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_colorControl);
	
	self.frmItem.backColor		:= self.backColor;
	self.frmAll.backColor		:= self.backColor;
	
	self.setColorsForTable(self.tblAll);
	self.setColorsForEntryTable(self.tblItem);

end;</source>
