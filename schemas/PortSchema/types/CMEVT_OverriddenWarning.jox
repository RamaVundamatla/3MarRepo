    <JadeMethod name="canUserAccessSubject" id="d195062d-e673-4a28-8184-76de07820261">
        <source>canUserAccessSubject(_user : CM_User; _failedDAC  :CM_DataAccessController output; _passport : CM_Passport) : Boolean;
/*
----------   ----------  --------------------------------------------------
Created:	05 October 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.mySubject &lt;&gt; null then
		return self.mySubject.canUserAccessSelf(_user, _failedDAC, _passport);
	endif;
	return true;
	
end;


</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_failedDAC" type="CM_DataAccessController" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="aad15aeb-3507-4673-9067-8ae4daaf323f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
----------   ----------  --------------------------------------------------
Created:	13 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if _attrName = ETRow_ErrorCode then
		return self.errorCode.String;
	elseif _attrName = ETRow_ErrorText then
		return self.errorText;
	elseif _attrName = ETRow_ErrorField then
		return self.fieldName;
	elseif _attrName = ETRow_Entity then
		return self.getUserObjInfo();
	endif;
	
	return inheritMethod(_attrName, _short);


end;


</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUserObjInfo" id="fb475130-7aac-48c1-8546-bc385f1722e1">
        <source>getUserObjInfo() : String;
/*
----------   ----------  --------------------------------------------------
Created:	13 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.mySubject = null then
		return app.getErrorString(None);
	endif;
	
	if (not app.isValidObject(self.mySubject)) then
		return app.getErrorString(Entity_deleted);
	endif;
	
	return self.mySubject.getName();
	
end;


</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateFromWarning" id="4ec10922-41d7-412d-9077-b470c6d39b0a">
        <updating/>
        <source>setForUpdateFromWarning(_eventType 	: CM_EventType;
				_dateTime 	: TimeStamp;
				_terminal 	: CM_Terminal;
				_userCode	: String;
				_errorCode	: Integer;
				_errorText,
				_fieldName	: String;
				_subject	: CM_Object) updating;
/*
----------   ----------  --------------------------------------------------
Created:	12 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
//16 Dec 2013	cnwrs1	Par 33035 - add CamsDateTime to CM_EventTransaction
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.type 			:= _eventType.type;
	self.dateTime 		:= _dateTime;
	self.setCAMSTimeStamp(app.actualTimeServer);	
	self.myEventType 	:= _eventType;
	self.userCode		:= _userCode;
	self.errorCode		:= _errorCode;
	self.errorText		:= _errorText;
	self.fieldName		:= _fieldName;
	
	self.setMySubject(_subject);

	if _terminal &lt;&gt; null then
		self.myTerminal 	:= _terminal;
		self.myRoot 		:= null;
		_terminal.causeEvent(_terminal.getTerminalEvent(EVENT_EVENT_TRANSACTION), false, self);
	else
		self.myTerminal 	:= null;
		self.myRoot 		:= app.myRoot;
		self.myEventType.causeEvent(EVENT_EVENT_TRANSACTION, false, self);
	endif;
	
end;


</source>
        <Parameter name="_eventType" type="CM_EventType"/>
        <Parameter name="_dateTime" type="TimeStamp"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_userCode" type="String"/>
        <Parameter name="_errorCode" type="Integer"/>
        <Parameter name="_errorText" type="String"/>
        <Parameter name="_fieldName" type="String"/>
        <Parameter name="_subject" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setMySubject" id="a798e6a6-6507-4b2e-a96d-b15015df1b9a">
        <updating/>
        <source>setMySubject(_subject : CM_Object) updating;
/*
----------   ----------  --------------------------------------------------
Created:	25 July 2007 By cnwth2

Purpose:	

/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	obj				: CM_Object;
	invalid 		: Boolean;
	
begin
	obj := _subject;
	if obj = null then			// or (not app.isValidObject(obj)) then
		return;
	endif;

	on Exception do app.handleDeletedObject(exception, obj, invalid);
	
	if obj.isTransient then
		obj := obj.pxyGetRealObject();
	endif;
	
	if invalid or obj = null then
		return;
	endif;
	
	//th2 - it appears if there is at least one inversed collection on the
	//other side of this reference, you cannot populate it un-inversed.
	//So currently have to check type:
	if (not CM_TrackedItem.hasInstance(obj)) and
	   (not CM_BulkRelease.hasInstance(obj)) and
	   (not CM_BookingRef.hasInstance(obj)) then
		return;
	endif;
	
//	if not global.isValidObject(obj) then
//		return;
//	endif;

	// Need to check obj is valid by locking it, because exception handle cannot resume 
	// through failed inverse maintenance
	sharedLock(obj);
	if invalid then
		return;
	endif;
	   
	self.mySubject := obj;

end;


</source>
        <Parameter name="_subject" type="CM_Object"/>
    </JadeMethod>
</Class>
