    <JadeMethod name="doSave" id="bb5e30ae-5a90-496a-bb5b-03e87c562690">
        <updating/>
        <source>doSave(): Boolean updating;
// --------------------------------------------------------------------------------
// Created:		02 March 2005 by cnwdad1
//
// Purpose:		Standard method to perform a "Save" operation.
//
// Parameters:	None
//
// Returns:		True if the save ws successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	terminalObj				: CM_Terminal;
	yardAllocationObj		: CM_YardAllocation;
	proxyYAObj				: CM_YardAllocation;
	fillOptionIn			: Integer;
	fillOptionOut			: Integer;
	yaCode					: String;
	yaDescription			: String;
	yaRemarks				: String;
	expiryType				: Integer;
	expiryDate				: Date;
	allowOthers				: Integer;
	noLocation				: Integer;
	priorityAdj				: Integer;
	isTestOverstowWeight	: Boolean;
	isDisabled				: Boolean;
	allTransientCriteriaObj	: CMIF_Array;
	yaColor					: Integer;
	overstowRule			: CM_YAOverstowRule;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	proxyYAObj			:=	self.myProxyYA;
	yardAllocationObj	:=	self.myYardAllocation;
	
	create allTransientCriteriaObj transient;
	self.myCtrlCriteria.allSelectedCPs.copy(allTransientCriteriaObj);
	self.myCtrlCriteria.allDeletedCPs.copy(allTransientCriteriaObj);
	
	terminalObj				:=	app.getMyTerminalDO_NOT_USE();
	fillOptionIn			:=	self.myCmbOptionIn.getCurrentItemData();
	fillOptionOut			:=	self.myCmbOptionOut.getCurrentItemData();
	yaCode					:=	self.myTxtCode.cnEcString();
	yaDescription			:=	self.myTxtDescription.cnEcString();
	yaRemarks				:=	self.myTxtRemarks.cnEcString();
	expiryType				:=	self.getExpiryType();
	expiryDate				:=	self.myTxtExpiryDate.getDate();
	yaColor					:=	self.myLblColorPicker.getColor();
	allowOthers				:=	self.myCmbAllowOthers.getCurrentItemData();
	noLocation				:=	self.myCmbNoLocation.getCurrentItemData();
	overstowRule			:=  self.myCmbOverstowRule.listObject.CM_YAOverstowRule;
	priorityAdj				:=	self.myTxtPriorityAdj.cnEcInteger();
	isTestOverstowWeight	:=	self.myChkTestOverstowWeight.value;
	isDisabled				:=	self.myChkIsDisabled.value;
	
	proxyYAObj.setProxy(yaCode,
						yaDescription,
						yaRemarks,
						fillOptionIn,
						fillOptionOut,
						expiryType,
						expiryDate,
						yaColor,
						null,  //cnwjo3 par 24145
						allowOthers,
						noLocation,
						overstowRule,
						priorityAdj,
						isTestOverstowWeight,
						isDisabled,
						self.allBlockGroupsIn,
						self.allBlockGroupsOut,
						false,
						terminalObj);
	
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		if yardAllocationObj = null then
			app.myTrxCA.trxCreateYardAllocation(proxyYAObj, allTransientCriteriaObj, yardAllocationObj, app.myPassport);
		else
			app.myTrxUA.trxUpdateYardAllocation(proxyYAObj, allTransientCriteriaObj, app.myPassport);
		endif;
	
		if app.myPassport.trxCompletedOK then
			self.setYardAllocation(yardAllocationObj);
			self.myDisplayWindow.yaRefreshAllocation();
			break;
		else
			theResult := app.showErrorWarningDialog("Yard Allocation", app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
	return true;
	
epilog
	delete allTransientCriteriaObj;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSetTxtLocationText" id="a9b5b776-d465-4d16-85bf-2b33ef713bdd">
