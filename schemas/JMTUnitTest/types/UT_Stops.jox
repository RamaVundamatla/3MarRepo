    <JadeMethod name="tCargoStopRequestPermission4" id="dc67dba9-650a-41ac-9a91-6cbf41a35f25">
        <updating/>
        <source>tCargoStopRequestPermission4() updating;
// cnwrs1 PAR 28390
// create cargo stop requests to clear a stop.
// the stop is create by low permission user
// the container is move by a high permission user
// the stop should NOT be cleared
/* Changes

Date		Name	TFS#		Description
============================================================================
10 Sep 2019	cnwrs1	TFS 46030
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
============================================================================*/
constants
	VoyageName		= 'PAR28390';
	BoatName		= 'PAR28390Boat';
	TestOperator	= 'MSK';
	ContainerId1	= 'PAR283901_6';
	BookingId1		= 'PAR28390_6';
	UserDefined		= 'Unit Test Stop';
	StopId			= 220;
	BlockStackName = 'BS283906';
	UserCodeID = "28390";
vars
	bSynchronous		: Boolean;
	isChildIgnore		: Boolean;
	isChildOnly			: Boolean;
	isCoastalIgnore		: Boolean;
	isCoastalOnly		: Boolean;
	isFull				: Boolean;
	isMT				: Boolean;
	xmlBlock			: String;
	clientRef			: String;
	messageType			: String;
	ediText				: String;
	tempStr				: String;
	cm_Stops			: CM_Stops;
	stopsTable			: CM_StopsTable;
	selectedTypes		: CM_CargoBOLTypeSet;
	tempIntegerArray	: IntegerArray;
	setArray : IntegerArray;
	container			: CM_Container;
	bookingRef			: CM_BookingRef;
	fileTypeUser		: CM_EDIFileTypeUser;
	pxyFileTypeUser		: CM_EDIFileTypeUser;
	vessel				: CM_Vessel;
	voyage				: CM_Voyage;
	operator			: CM_Operator;
	ediFile				: CM_EDIFile;
	ediData				: CM_EDIData;
	binaryMsg			: Binary;
	ediControllerAgent	: CM_EDIControllerAgent;
	eventRequest : CM_EventRequestStops;	//par 27724 cnwrs1 22 June 2011
	lc : CM_LocationsController;
	bs : CM_BlockStack;
	user : CM_User;
	pxyUser : CM_User;
//	organisation : CM_Organisation;
	daSet : CM_DataAccessControllerSet; 
	sysSecurityRole	: CM_SecurityRoleSystem;
	secRole	: CM_SecurityRoleTerminal;
	startUserCode : String;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.setTerminalConfig(EDIBaplieROBReplaceDef, false);
	self.setTerminalConfig(EDIBaplieROBExtRawData, false);
	create ediControllerAgent transient;
	create tempIntegerArray transient;
	create setArray transient;
	create selectedTypes transient;
	create pxyFileTypeUser transient;
	
	ediControllerAgent.setTerminal(self.getTerminal);
	operator := self.getOperator(TestOperator);
	startUserCode := app.getMyUserCode();

	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);
	bs := self.addBlockStack (BlockStackName, 1000, null);
	self.assertNotNullMsg(bs, 'Add blockstack ' &amp; BlockStackName &amp; ' failed');
	lc := self.getTerminal.lookupTerminalArea(BlockStackName).CM_TerminalArea.allLocationsControllers.first;
	
	// the block string below represents the XML of the required user file type definition format.
	xmlBlock := self.xmlDef_Stops(UserDefined);
	
	// break up the XML into the proxy CM_EDIFileTypeUser
	pxyFileTypeUser.importMeXML(xmlBlock);
	
	// make sure the required definition name does not already exist.
	fileTypeUser := app.myRoot.allEDIFileTypes[EDIFileType_UserDefined, UserDefined].CM_EDIFileTypeUser;
	if fileTypeUser &lt;&gt; null then
		// if it does exist then delete it.
		app.myTrxDA.trxDeleteEDIFileTypeUser(fileTypeUser, app.myPassport);
		self.assertIsDeleted(fileTypeUser);
		self.assertTrue(app.myPassport.trxCompletedOK());
	endif;
	
	// create the required user definition format.
	app.myTrxCA.trxCreateEDIFileTypeUser(fileTypeUser, pxyFileTypeUser, app.myPassport);
	fileTypeUser := app.myRoot.allEDIFileTypes.getAtKey(EDIFileType_UserDefined, UserDefined).CM_EDIFileTypeUser;
	self.assertNotNullMsg(fileTypeUser, 'User Type ' &amp; UserDefined &amp; ' is missing');
	
	// Make sure the required stops table exists with the required settings for this terminal
	self.deleteStopsTable(StopId);			// first delete if it exists.
	
	isChildIgnore := false;
	isChildOnly := false;
	isCoastalIgnore := false;
	isCoastalOnly := false;
	isFull := true;
	isMT := true;
	self.opts.addAssoc(ETRow_IsChildIgnore, isChildIgnore);
	self.opts.addAssoc(ETRow_IsChildOnly, isChildOnly);
	self.opts.addAssoc(ETRow_IsCoastalIgnore, isCoastalIgnore);
	self.opts.addAssoc(ETRow_IsCoastalOnly, isCoastalOnly);
	self.opts.addAssoc(ETRow_IsFull, isFull);
	self.opts.addAssoc(ETRow_IsMT, isMT);
	self.opts.addAssoc(ETRow_CheckStopAreas, tempIntegerArray);
	self.opts.addAssoc(ETRow_ProcessStopAreas, tempIntegerArray);
	self.opts.addAssoc(ETRow_RequiresInfo, false);
	self.opts.addAssoc(ETRow_CustomsInfoEntry, null);
	self.opts.addAssoc(ETRow_IsNotAvailableForEntry, false);
	self.opts.addAssoc(ETRow_AllowClearanceExpiryDate, false);
	setArray.add(StopApplyImport);
	self.opts.addAssoc(ETRow_SetStopAreas, setArray);
	
	selectedTypes.add(app.myRoot.allCargoTypesById[TI_CargoType_Container]);
	
	stopsTable := self.addStopsTable(StopId,
										'UT' &amp; StopId.display,
										method.name[1 : 30],		// to help identify what has created it
										selectedTypes,
										self.opts);
	
	self.assertNotNullMsg(stopsTable, 'Stop Table ' &amp; StopId.display &amp; ' does not exist');
	
	// now setup the low permission user
	user := app.myRoot.allUsers[UserCodeID];
	beginTransaction;
	delete user;
	commitTransaction;
	create daSet transient;
	create pxyUser transient;
	sysSecurityRole := app.myRoot.allRoles['System Root'].CM_SecurityRoleSystem;
	secRole := app.myRoot.allRoles['Gate Handheld'].CM_SecurityRoleTerminal;
	pxyUser.setProxy(UserCodeID, UserCodeID, EnabledNormalUser,
						app.myPassport.myUser.myOrganisation,
						app.myRoot,
						true, false, false, false, null,
						daSet, sysSecurityRole, null, app.myRoot.allEmailEntities,
						null, null,
						app.myRoot.getDefaultLocale(true), false, false); //cnwrs1 Par 23153 11 Mar 2010
	app.myTrxCA.trxCreateUser(pxyUser, "password", user, app.myPassport);
	
	app.myPassport.setMyUserFromCode(UserCodeID);	//set user to low permission user
	// setup the the edi data here.
	ediText :=
'Stop, this is one of the search keywords
D,ISO Container,' &amp; ContainerId1 &amp; ',' &amp; StopId.display &amp; ',"added via Unit Test"';
	// take the edi Data string make it binary and set up the required EDI Message Type.
	binaryMsg := ediText.Binary;
	bSynchronous := true;									// true = load, false = queue
	messageType := UserDefined[1 : fileTypeUser.name.maxLength];						// ie 63
	clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength];		// ie 30
	ediControllerAgent.setEdiClientRef(clientRef);
	
	// make sure all of the objects are deleted and created correctly.
	ediFile	:= ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	if ediFile &lt;&gt; null then
		beginTransaction;
		if ediFile.ediData = null then
			delete ediFile;
		else
			ediData	:= ediFile.ediData;
			delete ediData;
		endif;
		commitTransaction;
	endif;
	ediFile	:= ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);
	self.assertIsDeleted(ediFile);

	// load the edi data, verify and load to database
	if bSynchronous then
		ediControllerAgent.loadMessageFromWeb(messageType, binaryMsg, ediFile, bSynchronous, null); //jlgka1 TFS 45332
		tempStr	:= 'Failed to load container ' &amp; ContainerId1;
	else
		ediControllerAgent.queueMessageFromWeb(messageType, binaryMsg, ediFile, bSynchronous, null); //jlgka1 TFS 45332
		tempStr	:= 'Failed to queue container ' &amp; ContainerId1;
	endif;
//	self.assertEqualMsg(ediControllerAgent.ediStatusCode, null, tempStr &amp; ' pos 1');
	ediControllerAgent.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg(ediControllerAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_DBLOADED.display, tempStr);

	// get eventrequest and check it is ok.
	eventRequest := self.getTerminal.allEventRequestStopsByCargoID[ContainerId1];
	tempStr	:= 'Failed to load Event stop Request ' &amp; ContainerId1;
	self.assertNotNullMsg(eventRequest, tempStr);
	
	app.myPassport.setMyUserFromCode(startUserCode);	//set user backto higfh permission user

	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel := self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// now set up cleanly
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	voyage := self.addVoyageWithContainerStructur(VoyageName,
													BoatName,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');

	self.assertNotNullMsg(vessel, tempStr);
	// Load  BAPLIE file
	ediText := "
UNB+UNOA:2+AUMEL+MSK+060616:1348+370+++++FES'
UNH+ZIZP9LYA0003AUMEL+BAPLIE:D:95B:UN:SMDG20'
BGM++370+9'
DTM+137:0606161348:201'
TDT+20+"&amp;voyage.code&amp;"+++MSK:172:20+++ZIZP9:103:11:"&amp;vessel.name&amp;"'
LOC+5+AUMEL:139:6'
LOC+61+:139:6'
DTM+132:0606161347:201'
DTM+133:0606161347:201'
LOC+147+0010682::5'
GDS+WINE'
FTX+AAA+++WINE'
MEA+WT++KGM:21000'
LOC+9+AUMEL'
LOC+11+NZAKL'
LOC+83+CNAKL'
LOC+152+CNAKL'
RFF+BM:1'
EQD+CN+"&amp;ContainerId1&amp;"+2210++2+5'
NAD+CA+CPS:172:20'
LOC+147+0010482::5'
GDS+WINE'
FTX+AAA+++WINE'
MEA+WT++KGM:21000'
LOC+9+AUMEL'
LOC+11+NZAKL'
LOC+83+CNAKL'
LOC+152+CNAKL'
RFF+BM:1'
EQD+CN+XNR60001922+2210++2+5'
NAD+CA+CPS:172:20'
LOC+147+0010282::5'
GDS+WINE'
FTX+AAA+++WINE'
MEA+WT++KGM:21000'
LOC+9+AUMEL'
LOC+11+NZAKL'
LOC+83+CNAKL'
LOC+152+CNAKL'
RFF+BM:1'
EQD+CN+XNR60001925+2210++2+5'
NAD+CA+CPS:172:20'
LOC+147+0010182::5'
GDS+WINE'
FTX+AAA+++WINE'
MEA+WT++KGM:21000'
LOC+9+AUMEL'
LOC+11+NZAKL'
LOC+83+CNAKL'
LOC+152+CNAKL'
RFF+BM:1'
EQD+CN+XNR60001928+2210++2+5'
NAD+CA+CPS:172:20'
LOC+147+0010382::5'
GDS+WINE'
FTX+AAA+++GENL'
MEA+WT++KGM:21000'
LOC+9+AUMEL'
LOC+11+NZAKL'
LOC+83+CNAKL'
LOC+152+CNAKL'
RFF+BM:1'
EQD+CN+XNR60002706+2210++2+5'
NAD+CA+CPS:172:20'
LOC+147+0010582::5'
GDS+WINE'
FTX+AAA+++GENL'
MEA+WT++KGM:21000'
LOC+9+AUMEL'
LOC+11+AUSYD'
LOC+83+CNAKL'
LOC+152+CNAKL'
RFF+BM:1'
EQD+CN+XNR60003312+2210++2+5'
NAD+CA+COS:172:20'
UNT+75+ZIZP9AOR0005AUMEL'
UNZ+1+370'
	";
	ediFile := self.ediLoadFileName(ediText, EDIFileType_Unknown, "BAPLIE", "BAPLIE"&amp;method.name);
	self.assertNotNull(ediFile);
	tempStr := "Load failed "&amp;CrLf&amp;app.myPassport.getAllErrorsWarningsAsString();
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_LOADED, tempStr);

	self.ediVerify(ediFile);
	tempStr := "Verify failed "&amp;CrLf&amp;app.myPassport.getAllErrorsWarningsAsString();
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
//	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, tempStr);	

	self.ediDBLoad(ediFile);
	tempStr	:= 'DBLoad failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);

	self.ediMakeActual(ediFile);
	tempStr	:= 'Make Actual failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_MADE_ACTUAL, tempStr);

	container := voyage.allOnshipTIsByCargoTypeId[TI_CargoType_Container, ContainerId1].CM_Container;
//	self.assertEqual(container, eventRequest.myTrackedItem);
//	self.assertEqual(eventRequest.autoCleanup, true);	// par 27724 cnwrs1 22 June 2011

	// and add this required Stop to this container.
	self.opts.addAssoc(self.IgnoreErrors, false);
	self.addStop(container, stopsTable);

	beginTransaction;
	container.setImExStatus(TI_IMEX_STATUS_IMPORT);
	//container.moveToLocation(lc, null, null, null, REAL_MODE, true, true, false, false, false,  false,null,null, app.myPassport);		// TFS 2651
	container.moveToLocation(lc, null, null, null, REAL_MODE, true, true, false, false, false,  false,null,null,null, null,null,app.myPassport);	// TFS 2651
	if app.myPassport.noErrors() then
		app.cmsCommitTransaction(app.myPassport);
	else
		app.cmsAbortTransaction;
	endif;
	
	// Now check the actual data has been loaded correctly.
	// this means the container has the correct stop
	tempStr	:= 'Failed to add stop ' &amp; StopId.display &amp; ' to container ' &amp; ContainerId1;
	cm_Stops := container.getStopByIDAsAtDate(StopId, null);
	self.assertNotNullMsg(cm_Stops, "Stop not found");
	self.assertEqualMsg(cm_Stops.id, StopId, tempStr);
	
	// do a little bit of tidying up here.
	self.opts.addAssoc(ETRow_IsNotAvailableForEntry, true);		// this helps to make sure it is never used!
	self.updateStopsTable(stopsTable, selectedTypes);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete ediControllerAgent;
	delete selectedTypes;
	delete tempIntegerArray;
	delete setArray;
	delete pxyFileTypeUser;
	delete pxyUser;
	delete daSet;
	// currently required if still in transaction state so that the next unit test will be run OK.
	abortTransaction;
end;
</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;DAC ISSUE&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tClearStopsOnUnpack" id="c55d6192-58ab-438e-803a-533252048742">
        <source>tClearStopsOnUnpack();
/*

Purpose:			TFS 1626

Date		Who		Reason
18 March 2016	cnwmk3	Initial creation

*/
constants

	ContId 					: String = "CONT00001";
	Child1Id 				: String = "UT_CHILD01";
	Child2Id 				: String = "UT_CHILD02";
vars
	ti						: CM_TrackedItem;
	selectedTypes			: CM_CargoBOLTypeSet;
	stopsTable				: CM_StopsTable;
	processAreas			: IntegerArray;
	opts 					: CM_AssociationDict;
	cargoType				: Integer;
	attach					: CMIF_InOutAttachment;
	attachments				: CMIF_InOutAttachmentArray;
	childTi1, childTi2		: CM_TrackedItem;
	stop					: CM_Stops;
	stops					: CM_StopsByIdDict;
	unpackTIs				: CM_TIArray;
	setArray, checkArray 	: IntegerArray;
	terminal				: CM_Terminal;
	stopTableTemplate		: CM_StopTableTemplate;
begin
	terminal := self.getTerminal();
	
	// delete the stops and containers
	self.deleteContainer(ContId);
	self.deleteStopsTable(105);
	self.deleteStopsTable(106);
	childTi1 := self.getTrackedItem(Child1Id);
	self.deleteTrackedItem(childTi1, false);
	childTi2 := self.getTrackedItem(Child2Id);
	self.deleteTrackedItem(childTi2, false);
	
	// In terminal config set 'Auto Clear fields on unpack' to true.
	self.setTerminalConfig("DoAutoUnpackClearFields", true);
	
	// create a container
	ti := self.addContainer(ContId, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_IMPORT);	
	
	// create children
	create attachments transient;
	cargoType := app.myRoot.getCargoTypeFromAbbrev("CONT").id;
	create attach transient;
	attach.set(getTerminal, cargoType, Child1Id, "2200", 100); 
	attach.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	attach.imExStatus := ti.getImExStatus;
	attach.commodityCode := "APPL";
	attachments.add(attach);
	
	create attach transient;
	attach.set(getTerminal, cargoType, Child2Id, "2200", 100); 
	attach.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	attach.imExStatus := ti.getImExStatus;
	attach.commodityCode := "APPL";
	attachments.add(attach);
	
	// add children to container ti
	self.ignoreTrxWarnings(true);
	addContainerChildren(ti.CM_Container, attachments);
	assertEqualMsg(ti.numChildren, 2, "Container children incorrect");
	
	// Create a Stop for UT terminal
	create selectedTypes transient;
	selectedTypes.add(app.myRoot.allCargoTypesById[TI_CargoType_Container]);
	create processAreas transient;
	processAreas.add(StopProcessOpImpDeliverRel);
	create setArray transient;
	setArray.add(StopApplyImport);
	create checkArray transient;
	
	create opts transient;
	opts.addAssoc( ETRow_SetStopAreas, setArray );
	opts.addAssoc(ETRow_ProcessStopAreas, processAreas);
	opts.addAssoc(ETRow_IsMT, true);
	
	stopsTable	:= app.myRoot.allAvailableStopsTables[ 105 ];
	if stopsTable = null then
		stopsTable	:= self.addStopsTable(	105,
											"UT_ST",
											'Test 01',
											selectedTypes,
											opts );
	endif;
	self.assertNotNullMsg( stopsTable, 'Stop Table does not exist' );
		
	// Now make sure the stops table template for our terminal exists.
	stopTableTemplate	:= stopsTable.allStopTableTemplates[ terminal, stopsTable ];
	if stopTableTemplate = null then
		stopTableTemplate	:= self.addStopsTableTemplate( stopsTable, terminal);
		self.assertNotNullMsg( stopTableTemplate, 'Create Stop Table Template failed' );
	endif;
	
	// add stop to ti
	addStop(ti, stopsTable);
	
	// do a little bit of tidying up here.
	//opts.copy(self.opts);
	self.opts.addAssoc( ETRow_IsNotAvailableForEntry, true );		// this helps to make sure it is never used!
	self.updateStopsTable( stopsTable, selectedTypes);
	
	// Create a Stop for T01 terminal
	terminal	:= app.myRoot.allTerminals['DP1'];
	self.assertNotNullMsg(terminal, 'Terminal DougPort does not exist!');
	
	// set some of the flags so know that template has been set up correctly.
	setArray.add(StopApplyImport);
	self.opts.addAssoc( ETRow_IsChildIgnore, false );
	self.opts.addAssoc( ETRow_IsChildOnly, false );
	self.opts.addAssoc( ETRow_IsCoastalIgnore, false );
	self.opts.addAssoc( ETRow_IsCoastalOnly, false );
	self.opts.addAssoc( ETRow_IsFull, true );
	self.opts.addAssoc( ETRow_IsMT, true );
	self.opts.addAssoc( ETRow_CheckStopAreas, checkArray );
	self.opts.addAssoc( ETRow_SetStopAreas, setArray );
	self.opts.addAssoc( ETRow_ProcessStopAreas, processAreas );
	
	stopsTable	:= app.myRoot.allAvailableStopsTables[ 106 ];
	if stopsTable = null then
		self.opts.addAssoc("SetupStopTemplate", false);
		stopsTable	:= self.addStopsTable(	106,
											"UT_01",
											'Test 02',
											selectedTypes,
											opts );
	endif;
	self.assertNotNullMsg( stopsTable, 'Stop Table does not exist' );
	
	stopTableTemplate	:= stopsTable.allStopTableTemplates[ terminal, stopsTable ];
	if stopTableTemplate = null then
		stopTableTemplate	:= self.addStopsTableTemplate( stopsTable, terminal);
		self.assertNotNullMsg( stopTableTemplate, 'Create Stop Table Template failed' );
	endif;
	self.assertEqualMsg( stopTableTemplate.isFull, true, 'stopTableTemplate.isFull is invalid' );
	self.assertEqualMsg( stopTableTemplate.isMT, true, 'stopTableTemplate.isMT is invalid' );
	
	// add stop to ti. It should not get added coz this is not set up for UT Terminal.
	self.expectTrxError(Stop_releva_becaus_stop_type);
	addStop(ti, stopsTable);
	
	// enter a value in the Delivery Release field, save ti.
	//beginTransaction;
	//ti.setDeliveryRelease("Testing");
	//commitTransaction;
	
	//unpack the children
	childTi1 := ti.allChildren.first;
	childTi2 := ti.allChildren.last;
	
	// Unpack first child
	create unpackTIs transient;
	unpackTIs.add(childTi1);
	self.unpackContainer(ti, unpackTIs);
	
	// unpack second child
	unpackTIs.clear();
	unpackTIs.add(childTi2);
	self.unpackContainer(ti, unpackTIs);
	self.unpackCompleteContainer(ti);
	
	// Check that the now empty container has no stops, if there are any they should only be ones that should be auto applied.
	ti := self.getTrackedItem(ContId);
	stops := ti.getAllStops();
	foreach stop in stops do
		assertNotEqual(stop.id, 105);
	endforeach;
	
	// do a little bit of tidying up here.
	//opts.copy(self.opts);
	self.opts.addAssoc( ETRow_IsNotAvailableForEntry, true );		// this helps to make sure it is never used!
	self.updateStopsTable( stopsTable, selectedTypes);
	
epilog
	if attachments &lt;&gt; null and not attachments.isEmpty then
		attachments.purge();
	endif;
	delete selectedTypes;
	delete processAreas;
	delete setArray;
	delete opts;
	delete checkArray;
	delete unpackTIs;
	delete attachments;
	self.ignoreTrxWarnings(false);
	self.setTerminalConfig("DoAutoUnpackClearFields", false);
end;</source>
    </JadeMethod>
    <JadeMethod name="tDamageStopStatusHasRefused" id="2ffee4f8-fe40-4064-aa60-bd289fcec9cf">
        <source>tDamageStopStatusHasRefused();
/*
Purpose:	TFS 55314 07NOV2022 NAVAB1 . Should have been done as part of 53862		
			The 2 'apply' options on stops for damage are based on damage statuses. 
			One stop apply is where there is a damage instance with status DAMAGED but no damage instances with a status of REFUSED.
			One stop apply is where there is a damage instance with status REFUSED. there may be other instances with other statuses, that does not matter.

Date		Who		Reason
07NOV2022 NAVAB1 TFS 55314
*/


constants
	TruckId	= "TRK634";
	ContId = "CONTR634";
	VoyCode	= "UT_VOY634";
	VesselCode = "DIAM";
	DamStop1 = 881;
	DamStop2 = 882;
	CodeDS : String = "UT_";
	DescriptionDS : String = "Damage ";
	IsNotAvailableForEntryDS : Boolean = false;
	LevelDS : Integer = 7754; 
vars
	selectedTypes					: CM_CargoBOLTypeSet;
	stopsTable, stopsTable2						: CM_StopsTable;
	stopSetArray, intArray			: IntegerArray;
	vvr								: CM_VehicleVisitRecord;
	operator						: CM_Operator;
	voyage							: CM_Voyage;
	ti								: CM_TrackedItem;
	stop							: CM_Stops;
	count							: Integer;
	damageCode		:CM_DamageDefinitionCode;
	damagePos		:CM_DamagePosition;
	severity : CM_DamageSeverity;
begin
	
	self.setTerminalConfig("NoImportStops", false);

	deleteStopsTable(DamStop1);
	deleteStopsTable(DamStop2);
	self.deleteContainer(ContId);
	self.deleteVehicle(TruckId);
	
	// Create a Stop Type for DAMAGE ONLY NO REFUSED DAMAGE
	create selectedTypes transient;
	selectedTypes.add( app.myRoot.allCargoTypesById[ TI_CargoType_Container ] );
	selectedTypes.add( app.myRoot.getCargoTypeFromAbbrev( "CANNON" ) );
	create stopSetArray transient;
	create intArray transient;
	stopSetArray.add(StopApplyDamagedNotRefused); // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt; AUTO DAMAGE STOP  StopApplyDamagedNotRefused
	self.opts.purge();
	self.opts.addAssoc( ETRow_IsFull, true );
	self.opts.addAssoc(ETRow_RequiresInfo, false);
	self.opts.addAssoc(ETRow_RequiresExpOperatorNo, 0);
	self.opts.addAssoc( ETRow_CheckStopAreas, intArray );
	self.opts.addAssoc( ETRow_SetStopAreas, stopSetArray );
	self.opts.addAssoc( ETRow_ProcessStopAreas, intArray );
	
	stopsTable := addStopsTable(DamStop1, "D" &amp; DamStop1.String, "UT Damage Stop No Refused", selectedTypes, self.opts);
	self.assertNotNullMsg(stopsTable, "Stop No Refused is NULL!");
	
	// Create a second Stop Type for DAMAGE HAS REFUSED DAMAGE
	stopSetArray.clear();
	stopSetArray.add(StopApplyDamagedAndRefused); // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt; AUTO DAMAGE STOP 
	self.opts.removeAssoc( ETRow_SetStopAreas);
	self.opts.addAssoc( ETRow_SetStopAreas, stopSetArray );
	
	stopsTable2 := addStopsTable(DamStop2, "D" &amp; DamStop2.String, "UT Damage Stop Has Refused", selectedTypes, self.opts);
	self.assertNotNullMsg(stopsTable2, "Stop2 Has Refused is NULL!");
	self.assertNotNullMsg(stopsTable, "Stop1 No Refused is NULL!");
	
	// Gate in Full export container
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.deleteVoyage(VoyCode);
	voyage := self.addVoyageWithContainerStructur(VoyCode, VesselCode, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.opts.purge();
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_EXPORT);
	self.opts.addAssoc("Voyage", voyage.code);
	self.opts.addAssoc("DischargePort", app.myRoot.allPorts["NZAKL"].code);
	vvr := self.gateInContainer(TruckId, ContId, "2200", operator.code, "APPL", self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString));
	
	self.assertNotNullMsg(vvr, "VVR is NULL!");
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	// check that the new stop is applied. 
	ti := self.getTrackedItem(ContId);
	count := 0;
	foreach stop in ti.getAllStops do
		if stop.id = stopsTable.id
		or stop.id = stopsTable2.id then
			count := count + 1;
		endif;
	endforeach;
	
	self.assertEqualMsg(count, 0, "Should have no stops, has " &amp; count.String &amp; "!");
	
	
	// Add damage with status DAMAGED shoudl get 1 stop, not the REFUSED stop
	damageCode 	:= app.myRoot.allCargoTypesById [TI_CargoType_Container].allDamageDefinitionCodes.first;
	damagePos	:= app.myRoot.allCargoTypesById [TI_CargoType_Container].allDamagePositions.first;
	
	if damageCode = null then
		damageCode := CM_DamageDefinitionCode.firstInstance;
	endif;
	
	if damagePos = null then
		damagePos := CM_DamagePosition.firstInstance;
	endif;
	
	severity := self.createDamageSeverity(CodeDS &amp; LevelDS.String,DescriptionDS &amp; LevelDS.String,IsNotAvailableForEntryDS,LevelDS);	
	
	self.opts.purge();
	self.opts.addAssoc( "DamageStatus", DamageStatusDamaged ); // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt; DAMAGED REFUSED
	
	self.addDamage (ti, damageCode.code, damagePos.code, severity, 1, "Testing Damage Stop");
	self.assertTrueMsg (ti.damaged, 'Container not damaged');
	
	self.opts.purge();
	self.opts.addAssoc( "DamageStatus", DamageStatusRefused ); // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt; DAMAGED REFUSED
	
	self.addDamage (ti, damageCode.code, damagePos.code, severity, 1, "Testing Damage Stop");
	self.assertTrueMsg (ti.damaged, 'Container not damaged');

	// check that the new stop is applied for refused. 
	count := 0;
	foreach stop in ti.getAllStops do
		if stop.id = stopsTable2.id then
			count := count + 1;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, "Should have 1 stop because of refused damage. Has " &amp; count.String &amp;" stops");

	// check that a new stop has NOT applied for none refused. 
	count := 0;
	foreach stop in ti.getAllStops do
		if stop.id = stopsTable.id then
			count := count + 1;
		endif;
	endforeach;
	self.assertEqualMsg(count, 0, "Should not have stop because of NONE refused damage. Has " &amp; count.String &amp;" stops");
	
	
	self.updateDamageStatusForTI(ti,DamageStatusRepaired); // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt; REPAIRED ALL DAMAGE
	
	// check that the new stop has been cleared. 
	count := 0;
	foreach stop in ti.getAllStops do
		if stop.id = stopsTable.id
		or stop.id = stopsTable2.id then
			count := count + 1;
		endif;
	endforeach;
	self.assertEqualMsg(count, 0, "Should have no stop because damage has been repaired. Has " &amp; count.String &amp;" stops");
	
	// do a little bit of tidying up here.
	self.opts.addAssoc( ETRow_IsNotAvailableForEntry, true );		// this helps to make sure it is never used!
	self.updateStopsTable( stopsTable, selectedTypes);
	
epilog
	delete intArray;
	delete selectedTypes;
	delete stopSetArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="tDamageStopStatusNoneRefused" id="7d0057d8-838b-425c-b341-09d7880dc212">
        <source>tDamageStopStatusNoneRefused();
/*
Purpose:	TFS 55314 07NOV2022 NAVAB1 . Should have been done as part of 53862		
			The 2 'apply' options on stops for damage are based on damage statuses. 
			One stop apply is where there is a damage instance with status DAMAGED but no damage instances with a status of REFUSED.
			One stop apply is where there is a damage instance with status REFUSED. there may be other instances with other statuses, that does not matter.

Date		Who		Reason
07NOV2022 NAVAB1 TFS 55314
*/


constants
	TruckId	= "TRK634";
	ContId = "CONTR634";
	VoyCode	= "UT_VOY634";
	VesselCode = "DIAM";
	DamStop1 = 881;
	DamStop2 = 882;
	CodeDS : String = "UT_";
	DescriptionDS : String = "Damage ";
	IsNotAvailableForEntryDS : Boolean = false;
	LevelDS : Integer = 7754;
vars
	selectedTypes					: CM_CargoBOLTypeSet;
	stopsTable, stopsTable2						: CM_StopsTable;
	stopSetArray, intArray			: IntegerArray;
	vvr								: CM_VehicleVisitRecord;
	operator						: CM_Operator;
	voyage							: CM_Voyage;
	ti								: CM_TrackedItem;
	stop							: CM_Stops;
	count							: Integer;
	damageCode		:CM_DamageDefinitionCode;
	damagePos		:CM_DamagePosition;
	severity : CM_DamageSeverity;
begin
	
	self.setTerminalConfig("NoImportStops", false);


	deleteStopsTable(DamStop1);
	deleteStopsTable(DamStop2);
	self.deleteContainer(ContId);
	self.deleteVehicle(TruckId);
	
	// Create a Stop Type for DAMAGE ONLY NO REFUSED DAMAGE
	create selectedTypes transient;
	selectedTypes.add( app.myRoot.allCargoTypesById[ TI_CargoType_Container ] );
	selectedTypes.add( app.myRoot.getCargoTypeFromAbbrev( "CANNON" ) );
	create stopSetArray transient;
	create intArray transient;
	stopSetArray.add(StopApplyDamagedNotRefused); // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt; AUTO DAMAGE STOP 
	self.opts.purge();
	self.opts.addAssoc( ETRow_IsFull, true );
	self.opts.addAssoc(ETRow_RequiresInfo, false);
	self.opts.addAssoc(ETRow_RequiresExpOperatorNo, 0);
	self.opts.addAssoc( ETRow_CheckStopAreas, intArray );
	self.opts.addAssoc( ETRow_SetStopAreas, stopSetArray );
	self.opts.addAssoc( ETRow_ProcessStopAreas, intArray );
	
	stopsTable := addStopsTable(DamStop1, "D" &amp; DamStop1.String, "UT Damage Stop No Refused", selectedTypes, self.opts);
	self.assertNotNullMsg(stopsTable, "Stop No Refused is NULL!");
	
	// Create a second Stop Type for DAMAGE ONLY HAS REFUSED DAMAGE
	stopSetArray.clear();
	stopSetArray.add(StopApplyDamagedAndRefused); // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt; AUTO DAMAGE STOP 
	
	stopsTable2 := addStopsTable(DamStop2, "D" &amp; DamStop2.String, "UT Damage Stop Has Refused", selectedTypes, self.opts);
	self.assertNotNullMsg(stopsTable2, "Stop Has Refused is NULL!");
	
	
	
	
	// Gate in Full export container
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.deleteVoyage(VoyCode);
	voyage := self.addVoyageWithContainerStructur(VoyCode, VesselCode, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.opts.purge();
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_EXPORT);
	self.opts.addAssoc("Voyage", voyage.code);
	self.opts.addAssoc("DischargePort", app.myRoot.allPorts["NZAKL"].code);
	vvr := self.gateInContainer(TruckId, ContId, "2200", operator.code, "APPL", self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString));
	
	self.assertNotNullMsg(vvr, "VVR is NULL!");
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	// check that the new stop is applied. 
	ti := self.getTrackedItem(ContId);
	count := 0;
	foreach stop in ti.getAllStops do
		if stop.id = stopsTable.id then
			count := count + 1;
		endif;
	endforeach;
	
	self.assertEqualMsg(count, 0, "Should have no stops, has " &amp; count.String &amp; "!");
	
	
	// Add damage with status DAMAGED shoudl get 1 stop, not the REFUSED stop
	damageCode 	:= app.myRoot.allCargoTypesById [TI_CargoType_Container].allDamageDefinitionCodes.first;
	damagePos	:= app.myRoot.allCargoTypesById [TI_CargoType_Container].allDamagePositions.first;
	
	if damageCode = null then
		damageCode := CM_DamageDefinitionCode.firstInstance;
	endif;
	
	if damagePos = null then
		damagePos := CM_DamagePosition.firstInstance;
	endif;
	
	severity := self.createDamageSeverity(CodeDS &amp; LevelDS.String,DescriptionDS &amp; LevelDS.String,IsNotAvailableForEntryDS,LevelDS);	
	
	self.opts.purge();
	self.opts.addAssoc( "DamageStatus", DamageStatusDamaged ); // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt; DAMAGED STATUS
	
	self.addDamage (ti, damageCode.code, damagePos.code, severity, 1, "Testing Damage Stop");
	self.assertTrueMsg (ti.damaged, 'Container not damaged');
	
	self.opts.purge();
	self.opts.addAssoc( "DamageStatus", DamageStatusDamageOk ); // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt; DAMAGED STATUS
	
	self.addDamage (ti, damageCode.code, damagePos.code, severity, 1, "Testing Damage Stop");
	self.assertTrueMsg (ti.damaged, 'Container not damaged');
	
	// check that the new stop is applied. 
	count := 0;
	foreach stop in ti.getAllStops do
		if stop.id = stopsTable.id then
			count := count + 1;
		endif;
	endforeach;
	self.assertEqualMsg(count, 1, "Should have 1 stop because of damage. Has " &amp; count.String &amp;" stops");
	
	// check that the new stop is applied. 
	count := 0;
	foreach stop in ti.getAllStops do
		if stop.id = stopsTable2.id then
			count := count + 1;
		endif;
	endforeach;
	self.assertEqualMsg(count, 0, "Should not have any REFUSED stops. Has " &amp; count.String &amp;" stops");
	
	
	self.updateDamageStatusForTI(ti,DamageStatusRepaired); // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt; REPAIRED ALL DAMAGE
	
	// check that the new stop has been cleared. 
	count := 0;
	foreach stop in ti.getAllStops do
		if stop.id = stopsTable.id
		or stop.id = stopsTable2.id then
			count := count + 1;
		endif;
	endforeach;
	self.assertEqualMsg(count, 0, "Should have no stop because damage has been repaired. Has " &amp; count.String &amp;" stops");
	
	// do a little bit of tidying up here.
	self.opts.addAssoc( ETRow_IsNotAvailableForEntry, true );		// this helps to make sure it is never used!
	self.updateStopsTable( stopsTable, selectedTypes);
	
epilog
	delete intArray;
	delete selectedTypes;
	delete stopSetArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="tSetStopsOnPackUnpack" id="e2a66167-6c7f-4203-895e-0e4977ec06f5">
        <source>tSetStopsOnPackUnpack();
/*

Purpose:			TFS 2143

Date		Who		Reason
22 June 2016	cnwmk3	Initial creation

*/
constants

	ContId 					: String = "CONT002143";
	Child1Id 				: String = "UT_CHILD001";
	Child2Id 				: String = "UT_CHILD002";
vars
	ti						: CM_TrackedItem;
	selectedTypes			: CM_CargoBOLTypeSet;
	stopsTable				: CM_StopsTable;
	processAreas			: IntegerArray;
	opts 					: CM_AssociationDict;
	cargoType				: Integer;
	attach					: CMIF_InOutAttachment;
	attachments				: CMIF_InOutAttachmentArray;
	childTi1, childTi2		: CM_TrackedItem;
	stop					: CM_Stops;
	stops					: CM_StopsByIdDict;
	unpackTIs				: CM_TIArray;
	setArray, checkArray 	: IntegerArray;
	terminal				: CM_Terminal;
	stopTableTemplate		: CM_StopTableTemplate;
	count					: Integer;
begin
	terminal := self.getTerminal();
	
	// delete the stops and containers
	self.deleteContainer(ContId);
	self.deleteStopsTable(107);
	self.deleteStopsTable(108);
	childTi1 := self.getTrackedItem(Child1Id);
	self.deleteTrackedItem(childTi1, false);
	childTi2 := self.getTrackedItem(Child2Id);
	self.deleteTrackedItem(childTi2, false);
	
	// Create a Stop for UT terminal to apply on Pack Complete
	create selectedTypes transient;
	selectedTypes.add(app.myRoot.allCargoTypesById[TI_CargoType_Container]);
	create processAreas transient;
	create setArray transient;
	setArray.add(StopApplyPackComplete);
	create checkArray transient;
	checkArray.add(StopPreventYardMove);
	checkArray.add(StopPreventVoyagePlanning);
	
	self.opts.addAssoc( ETRow_SetStopAreas, setArray );
	self.opts.addAssoc(ETRow_CheckStopAreas, checkArray);
	self.opts.addAssoc( ETRow_ProcessStopAreas, processAreas );
	self.opts.addAssoc( ETRow_IsFull, true );
	
	stopsTable	:= app.myRoot.allAvailableStopsTables[ 107 ];
	if stopsTable = null then
		stopsTable	:= self.addStopsTable(	107,
											"UT_21",
											'Test TFS 2143',
											selectedTypes,
											self.opts );
	endif;
	self.assertNotNullMsg( stopsTable, 'Stop Table does not exist' );
		
	// Now make sure the stops table template for our terminal exists.
	stopTableTemplate	:= stopsTable.allStopTableTemplates[ terminal, stopsTable ];
	if stopTableTemplate = null then
		stopTableTemplate	:= self.addStopsTableTemplate( stopsTable, terminal);
		self.assertNotNullMsg( stopTableTemplate, 'Create Stop Table Template failed' );
	endif;
	
	
	// create a container
	ti := self.addContainer(ContId, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "APPL", TI_IMEX_STATUS_IMPORT);	
	
	// create children
	create attachments transient;
	cargoType := app.myRoot.getCargoTypeFromAbbrev("CONT").id;
	create attach transient;
	attach.set(getTerminal, cargoType, Child1Id, "2200", 100); 
	attach.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	attach.imExStatus := ti.getImExStatus;
	attach.commodityCode := "APPL";
	attachments.add(attach);
	
	create attach transient;
	attach.set(getTerminal, cargoType, Child2Id, "2200", 100); 
	attach.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	attach.imExStatus := ti.getImExStatus;
	attach.commodityCode := "APPL";
	attachments.add(attach);
	
	// add children to container ti
	self.ignoreTrxWarnings(true);
	addContainerChildren(ti.CM_Container, attachments);
	assertEqualMsg(ti.numChildren, 2, "Container children incorrect");
	
	// Pack Complete transaction created
	self.packCompleteContainer(ti.CM_Container);
	
	// Check that on Pack Complete, stop is set on ti
	ti := self.getTrackedItem(ContId);
	stops := ti.getAllStops();
	count := 0;
	foreach stop in stops do
		if stop.id = 107 then
			count := 1;
		endif;
	endforeach;
	self.assertEqual(count, 1);
	
	// do a little bit of tidying up here.
	self.opts.addAssoc( ETRow_IsNotAvailableForEntry, true );		// this helps to make sure it is never used!
	self.updateStopsTable( stopsTable, selectedTypes);
	
	// Create a Stop for terminal UT to apply on Unpack Complete
	delete setArray;
	delete selectedTypes;
	delete processAreas;
	delete checkArray;
	
	create selectedTypes transient;
	selectedTypes.add(app.myRoot.allCargoTypesById[TI_CargoType_Container]);
	create processAreas transient;
	create setArray transient;
	setArray.add(StopApplyUnpackComplete);
	create checkArray transient;
	checkArray.add(StopPreventYardMove);
	checkArray.add(StopPreventVoyagePlanning);
	
	create opts transient;
	opts.addAssoc( ETRow_SetStopAreas, setArray );
	opts.addAssoc( ETRow_CheckStopAreas, checkArray);
	opts.addAssoc( ETRow_ProcessStopAreas, processAreas );
	opts.addAssoc( ETRow_IsMT, true );	
	opts.addAssoc( ETRow_IsFull, false);
	stopsTable	:= app.myRoot.allAvailableStopsTables[ 108 ];
	if stopsTable = null then
		stopsTable	:= self.addStopsTable(	108,
											"UT_43",
											'Test 2143',
											selectedTypes,
											opts );
	endif;
	self.assertNotNullMsg( stopsTable, 'Stop Table does not exist' );
	
	stopTableTemplate	:= stopsTable.allStopTableTemplates[ terminal, stopsTable ];
	if stopTableTemplate = null then
		stopTableTemplate	:= self.addStopsTableTemplate( stopsTable, terminal);
		self.assertNotNullMsg( stopTableTemplate, 'Create Stop Table Template failed' );
	endif;
	self.assertEqualMsg( stopTableTemplate.isMT, true, 'stopTableTemplate.isMT is invalid' );
	
	//unpack the children
	childTi1 := ti.allChildren.first;
	childTi2 := ti.allChildren.last;
	
	// Unpack first child
	create unpackTIs transient;
	unpackTIs.add(childTi1);
	self.unpackContainer(ti, unpackTIs);
	
	// unpack second child
	unpackTIs.clear();
	unpackTIs.add(childTi2);
	self.unpackContainer(ti, unpackTIs);
	
	// Unpack complete transaction created
	self.unpackCompleteContainer(ti);
	
	// Check that the now empty container has stop applied, on Unpacking
	ti := self.getTrackedItem(ContId);
	stops := ti.getAllStops();
	count := 0;
	foreach stop in stops do
		if stop.id = 108 then
			count := 1;
		endif;
	endforeach;
	self.assertEqual(count, 1);
	
	// do a little bit of tidying up here.
	self.opts.addAssoc( ETRow_IsNotAvailableForEntry, true );		// this helps to make sure it is never used!
	self.updateStopsTable( stopsTable, selectedTypes);
	
epilog
	if attachments &lt;&gt; null and not attachments.isEmpty then
		attachments.purge();
	endif;
	delete opts;
	delete selectedTypes;
	delete processAreas;
	delete setArray;
	delete checkArray;
	delete unpackTIs;
	delete attachments;
	self.ignoreTrxWarnings(false);
	//self.setTerminalConfig(DoAutoUnpackClearFields, false);
end;</source>
    </JadeMethod>
    <JadeMethod name="tStopCriteriaIsCoastalFix" id="49ec6294-b25e-4284-8d4d-11e3bcba1c18">
        <source>tStopCriteriaIsCoastalFix();
/*

Purpose:			Tests that Stop Criteria: IsCoastal applies to all cargo in the scenarios below. Tested using Break-Bulk Cargo.

Parameters:			NONE

Return Value:		NONE

Date				Who		Reason
14 December 2023	navpw1	Initial creation TFS: 61769 (61773)

*/

constants
	UT_StopId				: Integer = 927;
	UT_StopCode				: String = "CSTP";
	UT_StopHeading			: String = "Coastal Stop";
	UT_BreakBulk1			: String = "BBLK-61769-1";
	UT_BreakBulk2			: String = "BBLK-61769-2";
	UT_BreakBulk3			: String = "BBLK-61769-3";
	UT_BreakBulk4			: String = "BBLK-61769-4";
	UT_OperatorCode			: String = "UTOP";
	UT_BlockStack			: String = "B61769";
	UT_CargoTypeAbbrev		: String = "BBLK";
	
vars
	noImportStops			: Boolean;
	systemUTHelper			: UT_HelperAdmSys;
	pxyStopsTable,
	stopsTableReal			: CM_StopsTable;
	pxyStopsTableTemplate	: CM_StopTableTemplate;
	pxyStopCriteria,
	stopCriteria			: CM_StopCriteria;
	checkAreasArr,
	setAreasArr,
	processAreasArr			: IntegerArray;
	cargoTypeSet,
	imexStatusSet			: CM_ObjectSet;
	ti						: CM_TrackedItem;
	operator				: CM_Operator;
	blockStack				: CM_BlockStack;
	cargoTypeBB				: CM_CargoBOLType;
	stopCritUpdSuccessful	: Boolean;
	
begin
	self.logMessage("Global Setup: Started");
	noImportStops := self.getTerminalConfig(NoImportStops).Boolean;
	self.setTerminalConfig(NoImportStops, true);
	self.logMessage("No Import Stops Original Value: " &amp; noImportStops.String);
	self.logMessage("No Import Stops New Value: " &amp; true.String);
	self.assertTrueMsg(self.getTerminalConfig(NoImportStops).Boolean, "Terminal Config -&gt; Settings Tab -&gt; 'No Import Stops' should be set to true");
	
	//Delete BlockStack
	self.deleteTerminalArea(UT_BlockStack);
	self.logMessage("Deleted Blockstack: Id:'" &amp; UT_BlockStack);
	
	//Create BlockStack
	blockStack := self.addBlockStack(UT_BlockStack, 10, null);
	self.assertNotNullMsg(blockStack, "Global Setup - blockStack");
	self.logMessage("Added Blockstack: Id:'" &amp; UT_BlockStack);
	
	//Get Operator
	operator := self.getOperator(UT_OperatorCode);
	self.assertNotNullMsg(operator, "Global Setup - operator");
	self.logMessage("Found Operator: Id:'" &amp; UT_OperatorCode);
	
	//create systemUTHelper transient;
	//systemUTHelper.setActiveProfile;
	//systemUTHelper.currentMethodBeingRun := UT_TSW::tTSWDTRMOTLand_1;
	
	//Delete Stops Table
	stopsTableReal := self.getRoot.getStopTableForId(UT_StopId);
	if stopsTableReal &lt;&gt; null then
		self.deleteStopsTable(UT_StopId);
		self.assertIsDeletedMsg(stopsTableReal, "Global Setup - stopsTableReal");
		self.logMessage("Deleted Stops Table: Id:'" &amp; UT_StopId.String &amp; " Code: " &amp; UT_StopCode);
	endif;
	
	//Create Stops Table
	create pxyStopsTable transient;
	pxyStopsTable.setProxy(true, UT_StopCode, UT_StopHeading, UT_StopCode, CustomsReference, UT_StopId, null, false, false, app.myRoot, null, app.myPassport.myUser.code, null);
	
	create pxyStopsTableTemplate transient;
	pxyStopsTableTemplate.setKeys(app.getMyTerminalDO_NOT_USE, pxyStopsTable);
	
	create processAreasArr transient;
	create setAreasArr transient;
	
	create checkAreasArr transient;
	checkAreasArr.add(StopPreventDeliveryRequest);
	checkAreasArr.add(StopPreventReleaseRequest);
	checkAreasArr.add(StopPreventYardMove);
	checkAreasArr.add(StopPreventGateOut);
	
	pxyStopsTableTemplate.setProxy(checkAreasArr,
									setAreasArr,
									processAreasArr,
									null,									// Hold Voyages
									false,
									false,
									false,
									false,
									false,
									false,
									true,
									true);
	
	create cargoTypeSet transient;
	cargoTypeSet.add(app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("BBLK"));
	cargoTypeSet.add(app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("CAR"));
	cargoTypeSet.add(app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("CONT"));
	cargoTypeSet.add(app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("MDF"));
	
	create imexStatusSet transient;
	imexStatusSet.add(app.myRoot.allImexStatuses[TI_IMEX_STATUS_IMPORT]);
	
	create pxyStopCriteria transient;
	pxyStopCriteria.createStopCriteria(cargoTypeSet, YACriteriaType_CargoType, pxyStopCriteria);
	pxyStopCriteria.createStopCriteria(imexStatusSet, YACriteriaType_ImexStatus, pxyStopCriteria);
	pxyStopCriteria.createStopCriteria(CM_YADataBoolean.VALUE_TRUE, YACriteriaType_IsCoastal, pxyStopCriteria);
	pxyStopCriteria.setProxyBaseData(pxyStopsTable);
	
	app.myTrxCA.trxCreateStopsTable(pxyStopsTable, stopsTableReal, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(stopsTableReal, "Global Setup - stopsTableReal");
	self.logMessage("Created Stops Table: Id:'" &amp; UT_StopId.String &amp; " Code: " &amp; UT_StopCode);
	
	delete pxyStopCriteria;
	delete pxyStopsTable;
	
	self.logMessage("Global Setup: Finished" &amp; CrLf);
	
	/*
	**	Test 1 Start - Breakbulk Coastal cargo - it is a break bulk cargo and is coastal but the stop has Is Coastal set to No, so the Stop should not be available to apply
	*/
	
	/*
	** Setup
	*/
	self.logMessage("Test 1 - Started | Details: Breakbulk Coastal cargo - it is a break bulk cargo and is coastal but the stop has Is Coastal set to No, so the Stop should not be available to apply");
	
	cargoTypeBB := app.myRoot.getCargoTypeFromAbbrev(UT_CargoTypeAbbrev);
	self.assertNotNullMsg(cargoTypeBB, "Test 1 - Setup - cargoTypeBB");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_Commodity, "GENL");
	self.opts.addAssoc(UT_OPTS_TotalQuantity, 50);
	self.opts.addAssoc(UT_OPTS_TotalVolume, 50000.Decimal);
	self.opts.addAssoc(UT_OPTS_TotalWeight, 50000.Decimal);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc(UT_OPTS_DestinationPort, "NZAKL");
	self.opts.addAssoc(UT_OPTS_LoadPort, "NZAKL");
	self.opts.addAssoc(UT_OPTS_DischargePort, "NZPOE");
	
	// create cargo - one break-bulk
	ti := self.addCargoAtLocationCommodity(UT_BreakBulk1, cargoTypeBB, operator, blockStack.myLocationsController);
	
	self.assertEqualMsg(ti.totalQuantity, 50, "Test 1 - Setup - ti.totalQuantity Expected: " &amp; 50.String &amp; " | Actual: " &amp; ti.totalQuantity.String);
	self.assertEqualMsg(ti.totalVolume.Real, 50000.Real, "Test 1 - Setup - ti.totalVolume Expected: " &amp; 50000.String &amp; " | Actual: " &amp; ti.totalVolume.String);
	self.assertEqualMsg(ti.totalWeight, 50000.Decimal, "Test 1 - Setup - ti.totalWeight Expected: " &amp; 50000.String &amp; " | Actual: " &amp; ti.totalWeight.String);
	self.assertEqualMsg(ti.getImExStatus, TI_IMEX_STATUS_IMPORT, "Test 1 - Setup - ti.getImExStatus Expected: " &amp; TI_IMEX_STATUS_IMPORT.String &amp; " | Actual: " &amp; ti.getImExStatus.String);
	self.assertEqualMsg(ti.destinationPort, "NZAKL", "Test 1 - Setup - ti.destinationPort Expected: " &amp; "NZAKL" &amp; " | Actual: " &amp; ti.destinationPort);
	self.assertEqualMsg(ti.loadPort, "NZAKL", "Test 1 - Setup - ti.loadPort Expected: " &amp; "NZAKL" &amp; " | Actual: " &amp; ti.loadPort);
	self.assertEqualMsg(ti.dischargePort, "NZPOE", "Test 1 - Setup - ti.dischargePort Expected: " &amp; "NZPOE" &amp; " | Actual: " &amp; ti.dischargePort);
	
	stopsTableReal := self.getRoot.getStopTableForId(UT_StopId);
	pxyStopsTable := app.createUpdateProxy(stopsTableReal).CM_StopsTable;
	
	stopCriteria := pxyStopsTable.myStopCriteria;
	
	beginTransaction;
	delete stopCriteria;
	commitTransaction;
	stopCritUpdSuccessful := true;
	
	create pxyStopCriteria transient;
	pxyStopCriteria.createStopCriteria(cargoTypeSet, YACriteriaType_CargoType, pxyStopCriteria);
	pxyStopCriteria.createStopCriteria(imexStatusSet, YACriteriaType_ImexStatus, pxyStopCriteria);
	pxyStopCriteria.createStopCriteria(CM_YADataBoolean.VALUE_FALSE, YACriteriaType_IsCoastal, pxyStopCriteria);
	pxyStopCriteria.setProxyBaseData(pxyStopsTable);
	
	app.myTrxUA.trxUpdateStopsTable(pxyStopsTable, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(stopsTableReal, "Test 1 - Setup - stopsTableReal");
	
	delete pxyStopsTable;
	
	/*
	** Run
	*/
	ti.setStop(stopsTableReal, true);
	
	/*
	** Assert
	*/
	// Check the cargo for import stop
	self.assertEqualMsg(ti.isStopSet(UT_StopId), false, 'Test 1 - Stop ' &amp; UT_StopId.display &amp; Space &amp; stopsTableReal.heading.display &amp; ' exists for cargo ' &amp; ti.id &amp; ' it should not');
	
	/*
	** Cleanup
	*/
	self.logMessage("Test 1 - Finished - PASSED | Details: Breakbulk Coastal cargo - it is a break bulk cargo and is coastal but the stop has Is Coastal set to No, so the Stop should not be available to apply" &amp; CrLf);
	
	/*
	**	Test 1 End - Breakbulk Coastal cargo - it is a break bulk cargo and is coastal but the stop has Is Coastal set to No, so the Stop should not be available to apply
	*/
	
	/*
	**	Test 2 Start - Breakbulk Coastal cargo - it is a break bulk cargo and is coastal but the stop has Is Coastal set to Yes, so the Stop should be available to apply
	*/
	
	/*
	** Setup
	*/
	self.logMessage("Test 2 - Started | Details: Breakbulk Coastal cargo - it is a break bulk cargo and is coastal but the stop has Is Coastal set to Yes, so the Stop should be available to apply");
	
	cargoTypeBB := app.myRoot.getCargoTypeFromAbbrev(UT_CargoTypeAbbrev);
	self.assertNotNullMsg(cargoTypeBB, "Test 2 - Setup - cargoTypeBB");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_Commodity, "GENL");
	self.opts.addAssoc(UT_OPTS_TotalQuantity, 50);
	self.opts.addAssoc(UT_OPTS_TotalVolume, 50000.Decimal);
	self.opts.addAssoc(UT_OPTS_TotalWeight, 50000.Decimal);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc(UT_OPTS_DestinationPort, "NZAKL");
	self.opts.addAssoc(UT_OPTS_LoadPort, "NZAKL");
	self.opts.addAssoc(UT_OPTS_DischargePort, "NZPOE");
	
	// create cargo - one break-bulk
	ti := self.addCargoAtLocationCommodity(UT_BreakBulk2, cargoTypeBB, operator, blockStack.myLocationsController);
	
	self.assertEqualMsg(ti.totalQuantity, 50, "Test 2 - Setup - ti.totalQuantity Expected: " &amp; 50.String &amp; " | Actual: " &amp; ti.totalQuantity.String);
	self.assertEqualMsg(ti.totalVolume.Real, 50000.Real, "Test 2 - Setup - ti.totalVolume Expected: " &amp; 50000.String &amp; " | Actual: " &amp; ti.totalVolume.String);
	self.assertEqualMsg(ti.totalWeight, 50000.Decimal, "Test 2 - Setup - ti.totalWeight Expected: " &amp; 50000.String &amp; " | Actual: " &amp; ti.totalWeight.String);
	self.assertEqualMsg(ti.getImExStatus, TI_IMEX_STATUS_IMPORT, "Test 2 - Setup - ti.getImExStatus Expected: " &amp; TI_IMEX_STATUS_IMPORT.String &amp; " | Actual: " &amp; ti.getImExStatus.String);
	self.assertEqualMsg(ti.destinationPort, "NZAKL", "Test 2 - Setup - ti.destinationPort Expected: " &amp; "NZAKL" &amp; " | Actual: " &amp; ti.destinationPort);
	self.assertEqualMsg(ti.loadPort, "NZAKL", "Test 2 - Setup - ti.loadPort Expected: " &amp; "NZAKL" &amp; " | Actual: " &amp; ti.loadPort);
	self.assertEqualMsg(ti.dischargePort, "NZPOE", "Test 2 - Setup - ti.dischargePort Expected: " &amp; "NZPOE" &amp; " | Actual: " &amp; ti.dischargePort);
	
	stopsTableReal := self.getRoot.getStopTableForId(UT_StopId);
	pxyStopsTable := app.createUpdateProxy(stopsTableReal).CM_StopsTable;
	
	stopCriteria := pxyStopsTable.myStopCriteria;
	
	stopCritUpdSuccessful := false;
	beginTransaction;
	delete stopCriteria;
	commitTransaction;
	stopCritUpdSuccessful := true;
	
	create pxyStopCriteria transient;
	pxyStopCriteria.createStopCriteria(cargoTypeSet, YACriteriaType_CargoType, pxyStopCriteria);
	pxyStopCriteria.createStopCriteria(imexStatusSet, YACriteriaType_ImexStatus, pxyStopCriteria);
	pxyStopCriteria.createStopCriteria(CM_YADataBoolean.VALUE_TRUE, YACriteriaType_IsCoastal, pxyStopCriteria);
	pxyStopCriteria.setProxyBaseData(pxyStopsTable);
	
	app.myTrxUA.trxUpdateStopsTable(pxyStopsTable, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(stopsTableReal, "Test 2 - Setup - stopsTableReal");
	
	delete pxyStopsTable;
	
	/*
	** Run
	*/
	ti.setStop(stopsTableReal, true);
	self.assertNoTrxErrorsOrWarnings();
	
	/*
	** Assert
	*/
	// Check the cargo for import stop
	self.assertEqualMsg(ti.isStopSet(UT_StopId), true, 'Test 2 - Stop ' &amp; UT_StopId.display &amp; Space &amp; stopsTableReal.heading.display &amp; ' does not exist for cargo ' &amp; ti.id);
	
	/*
	** Cleanup
	*/
	self.logMessage("Test 2 - Finished - PASSED | Details: Breakbulk Coastal cargo - it is a break bulk cargo and is coastal but the stop has Is Coastal set to Yes, so the Stop should be available to apply" &amp; CrLf);
	
	/*
	**	Test 2 End - Breakbulk Coastal cargo - it is a break bulk cargo and is coastal but the stop has Is Coastal set to Yes, so the Stop should be available to apply
	*/
	
	/*
	**	Test 3 Start - Breakbulk Non-Coastal cargo - it is a break bulk cargo and is not coastal but the stop has Is Coastal set to Yes, so the Stop should not be available to apply
	*/
	
	/*
	** Setup
	*/
	self.logMessage("Test 3 - Started | Details: Breakbulk Non-Coastal cargo - it is a break bulk cargo and is not coastal but the stop has Is Coastal set to Yes, so the Stop should not be available to apply");
	
	cargoTypeBB := app.myRoot.getCargoTypeFromAbbrev(UT_CargoTypeAbbrev);
	self.assertNotNullMsg(cargoTypeBB, "Test 3 - cargoTypeBB");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_Commodity, "GENL");
	self.opts.addAssoc(UT_OPTS_TotalQuantity, 50);
	self.opts.addAssoc(UT_OPTS_TotalVolume, 50000.Decimal);
	self.opts.addAssoc(UT_OPTS_TotalWeight, 50000.Decimal);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc(UT_OPTS_DestinationPort, "NZAKL");
	self.opts.addAssoc(UT_OPTS_LoadPort, "US123");
	self.opts.addAssoc(UT_OPTS_DischargePort, "NZPOE");
	
	// create cargo - one break-bulk
	ti := self.addCargoAtLocationCommodity(UT_BreakBulk3, cargoTypeBB, operator, blockStack.myLocationsController);
	
	self.assertEqualMsg(ti.totalQuantity, 50, "Test 3 - Setup - ti.totalQuantity Expected: " &amp; 50.String &amp; " | Actual: " &amp; ti.totalQuantity.String);
	self.assertEqualMsg(ti.totalVolume.Real, 50000.Real, "Test 3 - Setup - ti.totalVolume Expected: " &amp; 50000.String &amp; " | Actual: " &amp; ti.totalVolume.String);
	self.assertEqualMsg(ti.totalWeight, 50000.Decimal, "Test 3 - Setup - ti.totalWeight Expected: " &amp; 50000.String &amp; " | Actual: " &amp; ti.totalWeight.String);
	self.assertEqualMsg(ti.getImExStatus, TI_IMEX_STATUS_IMPORT, "Test 3 - Setup - ti.getImExStatus Expected: " &amp; TI_IMEX_STATUS_IMPORT.String &amp; " | Actual: " &amp; ti.getImExStatus.String);
	self.assertEqualMsg(ti.destinationPort, "NZAKL", "Test 3 - Setup - ti.destinationPort Expected: " &amp; "NZAKL" &amp; " | Actual: " &amp; ti.destinationPort);
	self.assertEqualMsg(ti.loadPort, "US123", "Test 3 - Setup - ti.loadPort Expected: " &amp; "NZAKL" &amp; " | Actual: " &amp; ti.loadPort);
	self.assertEqualMsg(ti.dischargePort, "NZPOE", "Test 3 - Setup - ti.dischargePort Expected: " &amp; "NZPOE" &amp; " | Actual: " &amp; ti.dischargePort);
	
	stopsTableReal := self.getRoot.getStopTableForId(UT_StopId);
	pxyStopsTable := app.createUpdateProxy(stopsTableReal).CM_StopsTable;
	
	stopCriteria := pxyStopsTable.myStopCriteria;
	
	stopCritUpdSuccessful := false;
	beginTransaction;
	delete stopCriteria;
	commitTransaction;
	stopCritUpdSuccessful := true;
	
	create pxyStopCriteria transient;
	pxyStopCriteria.createStopCriteria(cargoTypeSet, YACriteriaType_CargoType, pxyStopCriteria);
	pxyStopCriteria.createStopCriteria(imexStatusSet, YACriteriaType_ImexStatus, pxyStopCriteria);
	pxyStopCriteria.createStopCriteria(CM_YADataBoolean.VALUE_TRUE, YACriteriaType_IsCoastal, pxyStopCriteria);
	pxyStopCriteria.setProxyBaseData(pxyStopsTable);
	
	app.myTrxUA.trxUpdateStopsTable(pxyStopsTable, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(stopsTableReal, "Test 3 - stopsTableReal");
	
	delete pxyStopsTable;
	
	/*
	** Run
	*/
	ti.setStop(stopsTableReal, true);
	
	/*
	** Assert
	*/
	// Check the cargo for import stop
	self.assertEqualMsg(ti.isStopSet(UT_StopId), false, 'Test 3 - Stop ' &amp; UT_StopId.display &amp; Space &amp; stopsTableReal.heading.display &amp; ' does exist for cargo ' &amp; ti.id &amp; ' it should not');
	
	/*
	** Cleanup
	*/
	self.logMessage("Test 3 - Finished - PASSED | Details: Breakbulk Non-Coastal cargo - it is a break bulk cargo and is not coastal but the stop has Is Coastal set to Yes, so the Stop should not be available to apply" &amp; CrLf);
	
	/*
	**	Test 3 End - Breakbulk Non-Coastal cargo - it is a break bulk cargo and is not coastal but the stop has Is Coastal set to Yes, so the Stop should not be available to apply
	*/
	
	/*
	**	Test 4 Start - Breakbulk Non-Coastal cargo - it is a break bulk cargo and is not coastal but the stop has Is Coastal set to No, so the Stop should be available to apply
	*/
	
	/*
	** Setup
	*/
	self.logMessage("Test 4 - Started | Details: Breakbulk Non-Coastal cargo - it is a break bulk cargo and is not coastal but the stop has Is Coastal set to No, so the Stop should be available to apply");
	
	cargoTypeBB := app.myRoot.getCargoTypeFromAbbrev(UT_CargoTypeAbbrev);
	self.assertNotNullMsg(cargoTypeBB, "Test 4 - Setup - cargoTypeBB");
	
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_Commodity, "GENL");
	self.opts.addAssoc(UT_OPTS_TotalQuantity, 50);
	self.opts.addAssoc(UT_OPTS_TotalVolume, 50000.Decimal);
	self.opts.addAssoc(UT_OPTS_TotalWeight, 50000.Decimal);
	self.opts.addAssoc(UT_OPTS_ImexStatus, TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc(UT_OPTS_DestinationPort, "NZAKL");
	self.opts.addAssoc(UT_OPTS_LoadPort, "US123");
	self.opts.addAssoc(UT_OPTS_DischargePort, "NZPOE");
	
	// create cargo - one break-bulk
	ti := self.addCargoAtLocationCommodity(UT_BreakBulk4, cargoTypeBB, operator, blockStack.myLocationsController);
	
	self.assertEqualMsg(ti.totalQuantity, 50, "Test 4 - Setup - ti.totalQuantity Expected: " &amp; 50.String &amp; " | Actual: " &amp; ti.totalQuantity.String);
	self.assertEqualMsg(ti.totalVolume.Real, 50000.Real, "Test 4 - Setup - ti.totalVolume Expected: " &amp; 50000.String &amp; " | Actual: " &amp; ti.totalVolume.String);
	self.assertEqualMsg(ti.totalWeight, 50000.Decimal, "Test 4 - Setup - ti.totalWeight Expected: " &amp; 50000.String &amp; " | Actual: " &amp; ti.totalWeight.String);
	self.assertEqualMsg(ti.getImExStatus, TI_IMEX_STATUS_IMPORT, "Test 4 - Setup - ti.getImExStatus Expected: " &amp; TI_IMEX_STATUS_IMPORT.String &amp; " | Actual: " &amp; ti.getImExStatus.String);
	self.assertEqualMsg(ti.destinationPort, "NZAKL", "Test 4 - Setup - ti.destinationPort Expected: " &amp; "NZAKL" &amp; " | Actual: " &amp; ti.destinationPort);
	self.assertEqualMsg(ti.loadPort, "US123", "Test 4 - Setup - ti.loadPort Expected: " &amp; "NZAKL" &amp; " | Actual: " &amp; ti.loadPort);
	self.assertEqualMsg(ti.dischargePort, "NZPOE", "Test 4 - Setup - ti.dischargePort Expected: " &amp; "NZPOE" &amp; " | Actual: " &amp; ti.dischargePort);
	
	stopsTableReal := self.getRoot.getStopTableForId(UT_StopId);
	pxyStopsTable := app.createUpdateProxy(stopsTableReal).CM_StopsTable;
	
	stopCriteria := pxyStopsTable.myStopCriteria;
	
	stopCritUpdSuccessful := false;
	beginTransaction;
	delete stopCriteria;
	commitTransaction;
	stopCritUpdSuccessful := true;
	
	create pxyStopCriteria transient;
	pxyStopCriteria.createStopCriteria(cargoTypeSet, YACriteriaType_CargoType, pxyStopCriteria);
	pxyStopCriteria.createStopCriteria(imexStatusSet, YACriteriaType_ImexStatus, pxyStopCriteria);
	pxyStopCriteria.createStopCriteria(CM_YADataBoolean.VALUE_FALSE, YACriteriaType_IsCoastal, pxyStopCriteria);
	pxyStopCriteria.setProxyBaseData(pxyStopsTable);
	
	app.myTrxUA.trxUpdateStopsTable(pxyStopsTable, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(stopsTableReal, "Test 4 - Setup - stopsTableReal");
	
	delete pxyStopsTable;
	
	/*
	** Run
	*/
	ti.setStop(stopsTableReal, true);
	self.assertNoTrxErrorsOrWarnings();
	
	/*
	** Assert
	*/
	// Check the cargo for import stop
	self.assertEqualMsg(ti.isStopSet(UT_StopId), true, 'Test 4 - Stop ' &amp; UT_StopId.display &amp; Space &amp; stopsTableReal.heading.display &amp; ' does not exist for cargo ' &amp; ti.id);
	
	/*
	** Cleanup
	*/
	self.logMessage("Test 4 - Finished - PASSED | Details: Breakbulk Non-Coastal cargo - it is a break bulk cargo and is not coastal but the stop has Is Coastal set to No, so the Stop should be available to apply" &amp; CrLf);
	
	/*
	**	Test 4 End - Breakbulk Coastal cargo - it is a break bulk cargo and is coastal but the stop has Is Coastal set to Yes, so the Stop should be available to apply
	*/
	
	/*
	** Global Cleanup
	*/
	self.logMessage("Global Cleanup: Started");
	
	//Delete BlockStack
	self.deleteTerminalArea(UT_BlockStack);
	self.logMessage("Deleted Blockstack: Id:'" &amp; UT_BlockStack);
	
	//Delete TSW LAND HOLD
	stopsTableReal := self.getRoot.getStopTableForId(UT_StopId);
	if stopsTableReal &lt;&gt; null then
		self.deleteStopsTable(UT_StopId);
		self.assertIsDeletedMsg(stopsTableReal, "Global Setup - stopsTableReal");
		self.logMessage("Deleted Stops Table: Id:'" &amp; UT_StopId.String &amp; " Code: " &amp; UT_StopCode);
	endif;
	
	self.logMessage("Global Cleanup: Finished");
	
epilog
	if not stopCritUpdSuccessful then
		abortTransaction;
	endif;
	self.setTerminalConfig(NoImportStops, noImportStops);
	delete systemUTHelper;
	delete pxyStopsTable;
	delete setAreasArr;
	delete checkAreasArr;
	delete processAreasArr;
	delete cargoTypeSet;
	delete imexStatusSet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tStopIdMaxLimitCheck" id="b5e612d4-dd26-4a72-bfd2-ed17b0e14d02">
        <source>tStopIdMaxLimitCheck();
/*

Purpose: To test the stops not created with Id above 999		

Parameters:			

Return Value:		

Date		Who		Reason
02 April 2025	naviv1	Initial creation for MTN-34496 - Unit Test Stops can be Created with Id Above 999 Which is not Supported by MTN

*/
constants

	STOP_CODE					: String	= "TSTOP";
	STOP_ID						: Integer	= 1000;
	STOP_HEADING				: String	= "UT STOP TEST";

vars
	pxyStopsTable,
	realStopsTable,
	stopsTable					: CM_StopsTable;
	pxyStopsTableTemplate		: CM_StopTableTemplate;
	intArray, setArray			: IntegerArray;
begin

	//Delete STOP if exists
	stopsTable := self.getRoot.getStopTableForId(STOP_ID);
	if stopsTable &lt;&gt; null then
		self.deleteStopsTable(STOP_ID);
		self.assertIsDeletedMsg(stopsTable, "stop table not deleted");
	endif;
	
	//Create STOP
	create pxyStopsTable transient;
	pxyStopsTable.setProxy(false, STOP_CODE, STOP_HEADING, STOP_CODE, null, STOP_ID, null, false, false, app.myRoot, null, app.myPassport.myUser.code, null);
	
	create pxyStopsTableTemplate transient;
	pxyStopsTableTemplate.setKeys( app.getMyTerminal(), pxyStopsTable);
	
	create intArray transient;
	create setArray transient;
	setArray.add(StopApplyExport);
	
	pxyStopsTableTemplate.setProxy(	intArray,
									setArray,
									intArray,
									null,									
									false,
									false,
									false,
									false,
									false,
									false,
									false,
									true);
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(StopId_Exceeds_Limit);
	app.myTrxCA.trxCreateStopsTable(pxyStopsTable, realStopsTable, app.myPassport);
	self.assertTrxError(StopId_Exceeds_Limit);
epilog
	delete intArray;
	delete setArray;
	delete pxyStopsTableTemplate;
	delete pxyStopsTable;
end;</source>
    </JadeMethod>
    <JadeMethod name="tStopPreventActions" id="7d4cbe51-bc1a-4b81-9f6f-917c3c6a545f">
        <updating/>
        <source>tStopPreventActions() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/08/2023	navkc1	CR 59610 Task 59613: Jade - Stop Prevention Unit Tests

*/
constants
	TRUCK 			: String = "TRK59613";
	TAREA			: String = "UTSTORE3";
	CARGOID			: String = "UT59613-1";
	CARGOID2		: String = "UT59613-2";
	CARGOID3		: String = "UT59613-3";
	CARGOID4		: String = "UT59613-4";
	CARGOID5		: String = "UT59613-5";
	CARGOID6		: String = "UT59613-6";
	CARGOTYPE		: String = "CONT";
	STOPTABLE		: String = "STOP_UT59613";
	STOPID			: Integer = 901;
	TRAINID			: String = "59613TRAIN";
	WAGONID			: String = "59613WAGON";
	VOYAGEID		: String = "59613VOY";
	VESSELID		: String = "UT59613VES";
	RELID			: String = "59613REL";
	RailAreaId 		: String = "UT59613";
vars
	realTi					: CM_TrackedItem;
	pxyStopTable,
	realStop				: CM_StopsTable;
	terminal				: CM_Terminal;
	operator				: CM_Operator;
	cargoType				: CM_CargoType;
	commodity				: CM_Commodity;
	blockstack				: CM_BlockStack;
	allStopsType			: CM_CargoBOLTypeSet;
	stopCheckArray,
	stopProcessArray,
	stopsSetArray			: IntegerArray;
	pxyStopCriteria			: CM_StopCriteria;
	pxyStopsTableTemplate	: CM_StopTableTemplate;
	pxyVoyage,
	realVoyage				: CM_Voyage;
	train					: CM_Train;
	wagon					: CM_Wagon;
	i						: Integer;
	id						: String;
	releaseReq				: CM_BulkRelease;
	conflictManager 		: CMIF_HMS_ConflictsManager;
	railArea				: CM_Rail;
	railLine				: CM_RailLine;
	moveController			: CMIF_MoveController;
	destination				: CM_LocationsController;
	cmifRakeRegion 			: CMIF_RakeRegion;
	vvr						: CM_VehicleVisitRecord;
	vehicle 				: CM_Vehicle;
begin
	create pxyStopCriteria transient;
	create pxyStopTable transient;
	create pxyStopsTableTemplate transient;
	create stopCheckArray transient;
	create allStopsType transient;
	create stopProcessArray transient;
	create stopsSetArray transient;
	create cmifRakeRegion transient;
	
	terminal 		:= self.getMyTerminal();
	operator 		:= self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString());
	cargoType		:= self.getCargoType(CARGOTYPE);
	blockstack 		:= self.getTerminalArea(TAREA).CM_BlockStack;
	
	if cargoType.allCommodities.size() &gt; 0 then
		commodity := cargoType.allCommodities.first();
	endif;
	
	allStopsType.add(cargoType);
	
	self.deleteRailArea( RailAreaId );
	train := self.getTrain(TRAINID, null);
	wagon := self.getWagon(WAGONID, train);	
	self.deleteWagonAndAssociatedObjs(wagon);
	train := self.getTrain(TRAINID, null);
	self.deleteTrain(TRAINID, train);
	
	foreach i in 1 to 6 do
		id := "UT59613-" &amp; i.String;
		realTi := self.getTrackedItem(id);
		if realTi &lt;&gt; null then
			self.deleteTrackedItem(realTi, false);
		endif;
		
		// 6 for pre note gate in
		if i = 6 then
			realTi := self.addPrenoted(CARGOID6);
			self.deleteStops(realTi);
			break;
		endif;
		
		realTi := self.createTrackedItem(id, cargoType.id, commodity.code, operator, false, blockstack.myLocationsController);
		self.deleteStops(realTi);
	endforeach;
	
	self.deleteStopsTable(STOPID);
	
	railArea := self.addRailArea(RailAreaId, 2, 5);
	train := self.addTrain(TRAINID, null);
	wagon := self.addWagonInRailArea(WAGONID, "UK", railArea, train);
	realVoyage := self.createVesselVoyage(VOYAGEID, VESSELID, operator);
	
	stopCheckArray.add(StopPreventTrainLoad);
	stopCheckArray.add(StopPreventTruckLoad);
	stopCheckArray.add(StopPreventTruckGateIn);
	stopCheckArray.add(StopPreventVoyageDeparture);
	stopCheckArray.add(StopPreventTrainDeparture);
	stopCheckArray.add(StopPreventRelReqAssign);
	stopCheckArray.add(StopPreventTrainUnload);
	
	pxyStopsTableTemplate.setProxy(stopCheckArray, stopsSetArray, stopProcessArray, null, false, false, false, false, false, false,true, true);
	pxyStopsTableTemplate.setPropertyValue("myStopTable", pxyStopTable);
	pxyStopsTableTemplate.setPropertyValue("myTerminal", terminal);
	pxyStopTable.setProxy(false, STOPID.String, STOPID.String, STOPID.String, 0, STOPID, null, false, true, app.myRoot, null, null,
	null	// ### TFS 61382 (61534) 01Dec2023 NAVPW1
	);
	app.myTrxCA.trxCreateStopsTable(pxyStopTable, realStop, app.myPassport);
	
	// ================================================
	// Test #1 - Prevent assign to release request
	// ================================================
	realTi := self.getTrackedItem(CARGOID);
	self.assertNotNull(realTi);
	self.addStop(realTi, realStop);
	
	self.opts.purge();
	self.opts.addAssoc("TotalRequested", 1);
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP);
	releaseReq := self.addReleaseById(RELID, BR_TYPE_ROAD, realTi);
	self.assertTrxError(WARN_TI_HAS_STOP);
	
	// ================================================
	// Test #2 - Prevent voyage departure
	// ================================================
	realTi := self.getTrackedItem(CARGOID2);
	self.assertNotNull(realTi);
	
	beginTransaction;
	realTi.setMyVoyage(realVoyage, app.myPassport);
	commitTransaction;
	self.moveCargo(realTi, null, realVoyage.allVoyageLocations.first(), app.myPassport);
	self.addStop(realTi, realStop);
	
	beginLoad;
	pxyVoyage := realVoyage.pxyCreateUpdateProxy();
	endLoad;
	pxyVoyage.setPropertyValue("status", Voyage_Status_Departed);
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP);
	app.myTrxUA.trxUpdateVoyage(pxyVoyage.myCellularVoyageStructure &lt;&gt; null, false, pxyVoyage, conflictManager, null, false, app.myPassport);
	self.assertTrxError(WARN_TI_HAS_STOP);
	
	// ================================================
	// Test #3 - Prevent Train Load
	// ================================================
	
	railLine := railArea.allRailLinesByIndex.first;
	railLine.switchPositions(wagon, 01);	
	
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	realTi := self.getTrackedItem(CARGOID3);
	self.assertNotNull(realTi);
	self.addStop(realTi, realStop);
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP);
	
	destination := wagon.allLocationsControllersArray[1];

	create moveController transient;
	moveController.setMyTrackedItem(realTi);
	moveController.setMyToPrimaryLocation(destination);
	moveController.setMoveMode(REAL_MODE);
	moveController.isForcedMove := true;

	app.myTrxUA.trxMoveTrackedItemNewRailJob(moveController, app.myPassport);
	
	self.assertTrxError(WARN_TI_HAS_STOP);
	delete moveController;
	// ================================================
	// Test #4 - Prevent Train Unload
	// ================================================
	
	realTi := self.getTrackedItem(CARGOID4);
	self.assertNotNull(realTi);
	
	destination := wagon.allLocationsControllersArray[1];

	create moveController transient;
	moveController.setMyTrackedItem(realTi);
	moveController.setMyToPrimaryLocation(destination);
	moveController.setMoveMode(REAL_MODE);
	moveController.isForcedMove := true;

	app.myTrxUA.trxMoveTrackedItemNewRailJob(moveController, app.myPassport);
	self.addStop(realTi, realStop);
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP);
	self.opts.purge();
	self.opts.addAssoc("ExpectErrors", true);
	self.move(realTi, blockstack);
	self.assertTrxError(WARN_TI_HAS_STOP);
	// ================================================
	// Test #5 - Prevent Train Departure
	// ================================================
	
	cmifRakeRegion.myTrain := train;	
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, false, train, true, app.myPassport);
	self.clearExpectedTrxErrors();
	self.ignoreTrxWarnings(true);
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP);
	app.myTrxUA.trxUpdateRailClearRake(cmifRakeRegion, app.myPassport);
	self.assertTrxError(WARN_TI_HAS_STOP);
	
	// ================================================
	// Test #6 - Prevent Truck Load
	// ================================================
	realTi := self.getTrackedItem("UTDUMMY");
	if realTi &lt;&gt; null then
		self.deleteTrackedItem(realTi, false);
	endif;
	realTi := self.getTrackedItem(CARGOID5);
	self.assertNotNull(realTi);
	self.addStop(realTi, realStop);
	
	self.deleteVehicle(TRUCK);
	vvr := self.gateInContainer(TRUCK, "UTDUMMY", "2200", operator.code, "MT", self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString));
	vehicle := self.getVehicle(TRUCK);
	self.moveVehicleToLane(vvr.vehicle, self.getPGate(self.getProfileSetting(UT_Profile.P_DGATE_PIN).asString), 1);
	self.moveVehicleToYard(vvr.vehicle);
	self.workVehicle(vvr);
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP);
	self.opts.purge();
	self.opts.addAssoc("ExpectErrors", true);
	self.move(realTi, vvr.vehicle.locationsController);
	self.assertTrxError(WARN_TI_HAS_STOP);
	
	self.roadExit(vvr);
	self.deleteVVR(vvr);
	
	// ================================================
	// Test #7 - Prevent Truck Gate In
	// ================================================
	realTi := self.getTrackedItem(CARGOID6);
	self.assertNotNull(realTi);
	self.addStop(realTi, realStop);
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_TI_HAS_STOP);
	self.expectedTrxErrors.add(ERR_CONTAINER_NO);
	self.expectedTrxErrors.add(WARN_BOOKING_REF);
	vvr := self.gateInPrenote(TRUCK, "", "", realTi, self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString));
	self.assertTrxError(WARN_TI_HAS_STOP);
	self.roadExit(vvr);
	self.deleteVVR(vvr);
	
epilog
	delete pxyStopCriteria;
	delete pxyStopsTableTemplate;
	delete pxyStopTable;
	delete stopCheckArray;
	delete allStopsType;
	delete stopsSetArray;
	delete stopProcessArray;
	delete pxyVoyage;
	delete moveController;
	delete cmifRakeRegion;
end;</source>
    </JadeMethod>
    <JadeMethod name="tStopRetainStorageIfImport" id="df6cc35a-b019-4145-9b0f-929a94b8f841">
        <source>tStopRetainStorageIfImport();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 January 2017	cnwma1	Initial creation
TFS 3201:PAR38538 GPHA - Discharge of Tank Containers Raises Null Object Reference
3257:POL - ‘Retain storage as if import’ setting on Stop causing Error

This To test the processing Option - Retain Storage as if Import.
Retain Storage as if Import	Are retained if the IMEX status of the cargo item is changed from Import to Storage; that is, 
if the stop is initially applied because the cargo item has an IMEX status of Import, 
the stop is still retained if the IMEX status is automatically converted to Storage (as happens to empty imports that get converted to storage).
*/
constants
	
	ContId							= "CIMPMTY1";
	VoyCode							= "UT_VOY50";
	VesselCode						= "DIAM";
	BlockStack1						= "UT_BS50";
vars
	selectedTypes					: CM_CargoBOLTypeSet;
	opts							: CM_AssociationDict;
	stopsTable						: CM_StopsTable;
	stopSetArray, intArray			: IntegerArray;

	operator						: CM_Operator;
	voyage							: CM_Voyage;
	ti								: CM_TrackedItem;
	stop							: CM_Stops;
	count							: Integer;
	booking							: CM_BookingRef;
	aPort : CM_Port;
	opr 							: CM_Operator;
	processAreas: IntegerArray;
	strs : StringArray;
	theSlot : CM_LocationsController;
	idx : Integer;
	bs  : CM_BlockStack;
	
begin

	self.setTerminalConfig("NoImportStops", false);
	
	deleteStopsTable(527);
	
	self.deleteContainer(ContId);
	self.deleteTerminalArea(BlockStack1);
	create selectedTypes transient;
	selectedTypes.add( app.myRoot.allCargoTypesById[ TI_CargoType_Container ] );
	
	
	create processAreas transient;
	processAreas.add(StopProcessImportStorage);
	
	create opts transient;
	opts.addAssoc(ETRow_ProcessStopAreas, processAreas);
	
	create intArray transient;
	
	create stopSetArray transient;
	stopSetArray.add(StopApplyImport);
	self.opts.purge();
	self.opts.addAssoc( ETRow_IsFull, true );
	self.opts.addAssoc( ETRow_IsMT, true );
	self.opts.addAssoc( ETRow_CheckStopAreas, intArray );
	self.opts.addAssoc( ETRow_SetStopAreas, stopSetArray );
	self.opts.addAssoc( ETRow_ProcessStopAreas, processAreas );
	
	stopsTable := addStopsTable(527, "UTRET", "Unit Test Retain", selectedTypes, self.opts);
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.deleteVoyage(VoyCode);
	
	voyage := self.addVoyageWithContainerStructur(VoyCode, VesselCode, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	create strs transient;
	strs.clear;
	strs.add("010688");
	voyage.findLocation(strs, false, theSlot, idx);
	
	self.opts.purge();
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc("Voyage", voyage.code);
	self.opts.addAssoc("DischargePort", app.myRoot.allPorts["NZAKL"].code);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	opr := app.myRoot.allOperators["APL"];
	ti := self.addContainerAtLocnDisch(ContId, "2200", "MT", TI_IMEX_STATUS_IMPORT, voyage.myShipBlockStack, app.myRoot.allPorts["NZPOE"], voyage);
	bs := self.addBlockStack(BlockStack1, 20, null);	
	self.move(ti, bs.getLocationsController);
	
	stop := ti.getStop(527);
	
	if stop = null then
	
		self.assertTrueMsg(false,"Stop Shouldn't be removed");
	endif;
epilog
	delete processAreas;
	delete selectedTypes;
	delete opts;
	delete intArray;
	delete  stopSetArray;
	delete strs;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tStopRuntimeTest" id="bcc57f3e-f24d-463e-9fda-3164c472006c">
        <source>tStopRuntimeTest();
// cnwrs1
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 February 2015	cnwgb1	Initial creation
25 February 2015    cnwgb1  Handle Stops with Expiry Dates

*/
constants 
    Block_Stack_1_Name = "GBST_BS1";
    Block_Stack_2_Name = "GBST_BS2";
    Vessel_ID = "GBST_VES";
    Voyage_ID = "GBST_VOY";
    BOL_ID = "GBST_BOL";
    Container_ID = "GBST0000001";
    StopTable_ID = 930;
    StopTable_Code = "UTR";
    StopTable_Heading = "UT RT Test";
vars
	ti: CM_TrackedItem;
    bs1: CM_BlockStack;
    bs2: CM_BlockStack;
	selectedTypes: CM_CargoBOLTypeSet;
	stopsTable: CM_StopsTable;
    checkAreas: IntegerArray;
    dbgPassport: CM_Passport;
	opts : CM_AssociationDict;
	voyage : CM_Voyage;
	bol : CM_BOLIn;
    today : Date;
	yesterday : Date;
    tomorrow : Date;
begin	
    dbgPassport := app.myPassport;
	tomorrow := today+1;
    yesterday := today-1;
    self.opts.addAssoc("ActAsReleasePoint", 0);
    
	self.deleteContainer(Container_ID);
	deleteStopsTable(StopTable_ID);
    
	self.deleteTerminalArea(Block_Stack_1_Name);
	bs1 := self.getTerminalArea(Block_Stack_1_Name).CM_BlockStack;
	self.assertIsDeleted(bs1);

	self.deleteTerminalArea(Block_Stack_2_Name);
	bs2 := self.getTerminalArea(Block_Stack_2_Name).CM_BlockStack;
	self.assertIsDeleted(bs2);
    
    bs1 := self.addBlockStack(Block_Stack_1_Name, 3, 500);
	self.assertNotNull(bs1);
    
    bs2 := self.addBlockStack(Block_Stack_2_Name, 3, 500);
	self.assertNotNull(bs2);

   	self.deleteVoyage(Voyage_ID);
	self.deleteVessel(Vessel_ID);
	self.addVesselCellular(Vessel_ID, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	voyage := addVoyageWithContainerStructur(Voyage_ID, Vessel_ID, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	
	self.deleteBOL(BOL_ID, null);
	bol := self.addBOL(BOL_ID, voyage, self.getOperator(getProfileSetting(UT_Profile.P_OPERATOR).asString), null, self.getTerminal ).CM_BOLIn;

    self.opts.addAssoc(UTTI_BOL, BOL_ID);
    self.opts.addAssoc(UTTI_VoyageCode, Voyage_ID);
    self.opts.addAssoc(UTTI_CustomsExportEntryNumber, "1234");


	ti := self.addContainerOpts(Container_ID, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	self.move(ti, bs1);
    
	// Create a Stop Type
	create selectedTypes transient;
	selectedTypes.add(app.myRoot.allCargoTypesById[TI_CargoType_Container]);
    selectedTypes.add(app.myRoot.getCargoBOLTypeForId(BOLType_GeneralBillOfLading));
 
    create checkAreas transient;
    checkAreas.add(StopPreventYardMove);

	create opts transient;
    opts.addAssoc("IsForcedMove", false);
    opts.addAssoc(ETRow_CheckStopAreas, checkAreas);
	opts.addAssoc( ETRow_AllowClearanceExpiryDate, true );

    // Try a TI Stop

	stopsTable := addStopsTable(StopTable_ID, StopTable_Code, StopTable_Heading, selectedTypes, opts);

    // 1. Try a move that should be stopped
	self.addStop(ti, stopsTable);
    self.expectTrxError(WARN_TI_HAS_STOP);
 	self.move(ti, bs2);
    assertEqualMsg(ti.myPrimaryActualLocation.myTerminalArea.id, bs1.id, "Container in wrong place");
    self.clearExpectedTrxErrors();
    
    // 2. Try a move that shouldn't be stopped
    self.deleteStop(ti, stopsTable);
    self.move(ti, bs2);
    assertEqualMsg(ti.myPrimaryActualLocation.myTerminalArea.id, bs2.id, "Container in wrong place");
	
	//3. Try a move with a cleared stop with a future expiry Date
	self.addStop(ti, stopsTable);
	self.clearStopWithExpiry(ti, stopsTable, null, tomorrow);
	self.move(ti, bs1);
	assertEqualMsg(ti.myPrimaryActualLocation.myTerminalArea.id, bs1.id, "Container in wrong place");
    
	//4. Try a move with a stop with an expired clearance.
	self.clearStopWithExpiry(ti, stopsTable, null, yesterday);
	self.expectTrxError(WARN_TI_HAS_STOP);
 	self.move(ti, bs2);
	assertEqualMsg(ti.myPrimaryActualLocation.myTerminalArea.id, bs1.id, "Container in wrong place");
    self.clearExpectedTrxErrors();
	
	self.deleteStop(ti, stopsTable);
	self.move(ti, bs2);

    // Try a BOL Stop
    
    // 1. Try a move that should be stopped
    self.addBOLStop(bol, stopsTable);
    self.expectTrxError(WARN_TI_HAS_STOP);
 	self.move(ti, bs1);
    assertEqualMsg(ti.myPrimaryActualLocation.myTerminalArea.id, bs2.id, "Container in wrong place");
    self.clearExpectedTrxErrors();
    
    // 2. Try a move that shouldn't be stopped
    self.deleteBOLStop(bol, stopsTable);
    self.move(ti, bs1);
    assertEqualMsg(ti.myPrimaryActualLocation.myTerminalArea.id, bs1.id, "Container in wrong place");
    
	//3. Try a move with a cleared stop with a future expiry Date
    self.addBOLStop(bol, stopsTable);
    self.clearBOLStopWithExpiry(bol, stopsTable, tomorrow);
    self.move(ti, bs2);
    assertEqualMsg(ti.myPrimaryActualLocation.myTerminalArea.id, bs2.id, "Container in wrong place");
    
	// do a little bit of tidying up here.
	opts.copy(self.opts);
	self.opts.addAssoc( ETRow_IsNotAvailableForEntry, true );		// this helps to make sure it is never used!
	self.updateStopsTable( stopsTable, selectedTypes);
	
epilog
	delete selectedTypes;
    delete checkAreas;
	delete opts;

end;</source>
    </JadeMethod>
    <JadeMethod name="tStops" id="313483d7-99da-4b90-b5b7-c0809da52ff3">
        <source>tStops();
/*

Purpose:			testlink test 01-634

Date		Who		Reason
07 February 2017	cnwmk3	Initial creation

*/

constants
	TruckId							= "TRK634";
	ContId							= "CONTR634";
	VoyCode							= "UT_VOY634";
	VesselCode						= "DIAM";
vars
	selectedTypes					: CM_CargoBOLTypeSet;
	opts							: CM_AssociationDict;
	cargoType						: CM_CargoType;
	stopsTable						: CM_StopsTable;
	stopSetArray, intArray			: IntegerArray;
	vvr								: CM_VehicleVisitRecord;
	operator						: CM_Operator;
	voyage							: CM_Voyage;
	ti								: CM_TrackedItem;
	stop							: CM_Stops;
	count							: Integer;
	booking							: CM_BookingRef;
	controller						: CMIF_TIUpdateController;
begin
	
	self.setTerminalConfig("NoImportStops", false);

	ti := self.getTrackedItem("CAR634");
	self.deleteTrackedItem(ti, false);

	deleteStopsTable(55);
	deleteStopsTable(56);
	self.deleteContainer(ContId);
	self.deleteVehicle(TruckId);
	
	// Create a Stop Type
	create selectedTypes transient;
	selectedTypes.add( app.myRoot.allCargoTypesById[ TI_CargoType_Container ] );
	selectedTypes.add( app.myRoot.getCargoTypeFromAbbrev( "CANNON" ) );
	create stopSetArray transient;
	create intArray transient;
	stopSetArray.add(StopApplyExport);
	self.opts.purge();
	self.opts.addAssoc( ETRow_IsFull, true );
	self.opts.addAssoc(ETRow_RequiresInfo, true);
	self.opts.addAssoc(ETRow_RequiresExpOperatorNo, ExportReleaseNumber);
	self.opts.addAssoc( ETRow_CheckStopAreas, intArray );
	self.opts.addAssoc( ETRow_SetStopAreas, stopSetArray );
	self.opts.addAssoc( ETRow_ProcessStopAreas, intArray );
	
	stopsTable := addStopsTable(55, "S634", "Test Export Stop", selectedTypes, self.opts);
	
	// Gate in Full export container
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.deleteVoyage(VoyCode);
	voyage := self.addVoyageWithContainerStructur(VoyCode, VesselCode, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.opts.purge();
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_EXPORT);
	self.opts.addAssoc("Voyage", voyage.code);
	self.opts.addAssoc("DischargePort", app.myRoot.allPorts["NZAKL"].code);
	vvr := self.gateInContainer(TruckId, ContId, "2200", operator.code, "APPL", self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString));
	self.assertNotNull(vvr);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	// check that the new stop is applied. 
	ti := self.getTrackedItem(ContId);
	count := 0;
	foreach stop in ti.getAllStops do
		if stop.id = stopsTable.id then
			count := count + 1;
		endif;
	endforeach;
	self.assertEqual(count, 1);
	
	// // Gate in export cargo
	vvr := self.gateInGC(TruckId, "", "", "CANNON634", "CANNON", operator.code, "APPL", self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString), 10);
	self.assertNotNull(vvr);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	// // check that the new stop is applied. 
	ti := self.getTrackedItem("CANNON634");
	count := 0;
	foreach stop in ti.getAllStops do
		if stop.id = stopsTable.id then
			count := count + 1;
		endif;
	endforeach;
	self.assertEqual(count, 1);
	
	// do a little bit of tidying up here.
	self.opts.addAssoc( ETRow_IsNotAvailableForEntry, true );		// this helps to make sure it is never used!
	self.updateStopsTable( stopsTable, selectedTypes);
	
	delete intArray;
	delete selectedTypes;
	delete stopSetArray;
	
	// Create a Stop Type
	create selectedTypes transient;
	selectedTypes.add( app.myRoot.allCargoTypesById[ TI_CargoType_Container ] );
	selectedTypes.add( app.myRoot.getCargoTypeFromAbbrev( "CAR" ) );
	create stopSetArray transient;
	create intArray transient;
	stopSetArray.add(StopApplyImport);
	self.opts.purge();
	self.opts.addAssoc( ETRow_IsFull, true );
	self.opts.addAssoc(ETRow_RequiresInfo, true);
	self.opts.addAssoc(ETRow_RequiresImpOperatorPIN, ImportReleasePIN);
	self.opts.addAssoc( ETRow_CheckStopAreas, intArray );
	self.opts.addAssoc( ETRow_SetStopAreas, stopSetArray );
	self.opts.addAssoc( ETRow_ProcessStopAreas, intArray );
	
	stopsTable := addStopsTable(56, "S6341", "Test Import Stop", selectedTypes, self.opts);
	
	// Gate in Full export container
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.deleteVoyage(VoyCode);
	voyage := self.addVoyageWithContainerStructur(VoyCode, VesselCode, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.opts.purge();
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_IMPORT);
	self.opts.addAssoc("Voyage", voyage.code);
	self.opts.addAssoc("DischargePort", app.myRoot.allPorts["NZAKL"].code);
	vvr := self.gateInContainer(TruckId, ContId, "2200", operator.code, "APPL", self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString));
	self.assertNotNull(vvr);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	// check that the new stop is applied. 
	ti := self.getTrackedItem(ContId);
	count := 0;
	foreach stop in ti.getAllStops do
		if stop.id = stopsTable.id then
			count := count + 1;
		endif;
	endforeach;
	self.assertEqual(count, 1);
	
	// // Gate in export cargo
	self.opts.purge();
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_IMPORT);
	vvr := self.gateInGC(TruckId, "", "", "CAR634", "CAR", operator.code, null, self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString), 1);
	self.assertNotNull(vvr);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	// // check that the new stop is applied. 
	ti := self.getTrackedItem("CAR634");
	count := 0;
	foreach stop in ti.getAllStops do
		if stop.id = stopsTable.id then
			count := count + 1;
		endif;
	endforeach;
	self.assertEqual(count, 1);
	
	// do a little bit of tidying up here.
	self.opts.addAssoc( ETRow_IsNotAvailableForEntry, true );		// this helps to make sure it is never used!
	self.updateStopsTable( stopsTable, selectedTypes);
epilog
	delete intArray;
	delete selectedTypes;
	delete stopSetArray;
//	deleteStopsTable(55);
//	deleteStopsTable(56);
end;</source>
    </JadeMethod>
    <JadeMethod name="tStopsRequireExtraInfo" id="0bf513e0-e477-4b2f-a40a-f5f00875b4bd">
        <updating/>
        <source>tStopsRequireExtraInfo()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2019	jlgns1	Initial creation
17 June 2019	jlgns1	Bug 44910: SNO - Stop to prevent the receipt of empty containers
*/
constants
	StopTable_ID_1 = 401;
	StopTable_ID_2 = 402;
	Cont_ID_1 = "UTNIK00001";
	Cont_ID_2 = "UTNIK00002";
	
	Vehicle_ID = "UTNICK";
vars
	
	ti1: CM_TrackedItem;
	ti2: CM_TrackedItem;
	vvr1 : CM_VehicleVisitRecord;
	vvr2 : CM_VehicleVisitRecord;
	
	terminal : CM_Terminal;
	stopsTable1: CM_StopsTable;
	stopsTable2: CM_StopsTable;
	originalValue1 : Boolean;
	originalValue2 : Boolean;
	originalValueSet : Boolean;
	keepThese : CM_StopsTableByIdDict;
begin
	self.deleteContainer(Cont_ID_1);
	self.deleteContainer(Cont_ID_2);
	
	self.deleteVehicle(Vehicle_ID);
		
	terminal := app.getTerminalByName("Unit Testing");
	if terminal = null then
		terminal := app.getTerminalByName("Unit Test");
	endif;
		
	stopsTable1 :=  app.myRoot.getStopTableForId(StopTable_ID_1);
	self.assertNotNullMsg(stopsTable1,"Stops table 1");
	self.assertTrueMsg(stopsTable1.getTemplateForTerminal(terminal).isFull,"Stops Table 1 isFull is not set");
	self.assertTrueMsg(stopsTable1.getTemplateForTerminal(terminal).allPreventAreas.includes(StopPreventYardMove),"Stops Table 1 does not include StopPreventYardMove");	
	self.assertTrueMsg(stopsTable1.requiresInfo,"Stops Table 1 does not require extra info");		
		
	stopsTable2 :=  app.myRoot.getStopTableForId(StopTable_ID_2);
	self.assertNotNullMsg(stopsTable2,"Stops table 2");
	self.assertTrueMsg(stopsTable2.getTemplateForTerminal(terminal).isMT,"Stops Table 2 isFull is not set");
	self.assertTrueMsg(stopsTable2.getTemplateForTerminal(terminal).allPreventAreas.includes(StopPreventYardMove),"Stops Table 2 does not include StopPreventYardMove");	
	self.assertFalseMsg(stopsTable2.requiresInfo,"Stops Table 2 require extra info");
		
	originalValue1 := stopsTable1.isNotAvailableForEntry;
	originalValue2 := stopsTable2.isNotAvailableForEntry;
	
	beginTransaction;
	stopsTable1.setPropertyValue(CM_StopsTable::isNotAvailableForEntry.name, false);
	stopsTable2.setPropertyValue(CM_StopsTable::isNotAvailableForEntry.name, false);	
	originalValueSet := true;
	commitTransaction;
	
	
	
	ti1 := self.addPrenoted(Cont_ID_1);
	create keepThese transient;
	keepThese.add( stopsTable1 );	
	//Stop with Extra Info Needed
	self.deleteTiStopsExcept(ti1,keepThese,true);
	self.assertEqualMsg(ti1.getAllStops().size ,1,"More than 1 Stop on TI1");
	self.assertEqualMsg(ti1.getAllStops().first.id,StopTable_ID_1,"TI1 Stop is not 401");
		
    self.expectTrxError(WARN_TI_HAS_STOP);
	self.expectTrxError(ERR_CONTAINER_NO);
	self.opts.addAssoc("ExpectErrors",true);
	vvr1 := self.gateInContainer(Vehicle_ID , Cont_ID_1, "2200", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code, "MT", self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString()));
	self.assertNullMsg(ti1.getPrimaryLocation(REAL_MODE)	,"TI1 Location is not null");	
	
	self.assertEqualMsg(ti1.getAllStops().size ,1,"More than 1 Stop on TI1");
	self.assertEqualMsg(ti1.getAllStops().first.id,StopTable_ID_1,"TI1 Stop is not 401");
	self.clearExpectedTrxErrors();
		
	
	ti2 := self.addPrenoted(Cont_ID_2);
	keepThese.clear();
	keepThese.add( stopsTable2 );	
	//Stop with no Extra Info Needed
	self.deleteTiStopsExcept(ti2,keepThese,true);
	self.assertEqualMsg(ti2.getAllStops().size ,1,"More than 1 Stop on TI2");
	self.assertEqualMsg(ti2.getAllStops().first.id,StopTable_ID_2,"TI2 Stop is not 402");
	self.expectTrxError(WARN_TI_HAS_STOP);
	self.expectTrxError(ERR_CONTAINER_NO);
	vvr2 := self.gateInContainer(Vehicle_ID, Cont_ID_2, "2200", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code, "MT", self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString()));
	self.assertNullMsg(ti2.getPrimaryLocation(REAL_MODE)	,"TI2 Location is not null");	
	self.assertEqualMsg(ti2.getAllStops().size ,1,"More than 1 Stop on TI2");
	self.assertEqualMsg(ti2.getAllStops().first.id,StopTable_ID_2,"TI2 Stop is not 402");
	
	self.clearExpectedTrxErrors();
	
	
	deleteVVR(vvr1);
	deleteVVR(vvr2);
	
epilog
	if originalValueSet then
		if not process.isInTransactionState then
		beginTransaction;
		endif;
		stopsTable1.setPropertyValue(CM_StopsTable::isNotAvailableForEntry.name, originalValue1);
		stopsTable2.setPropertyValue(CM_StopsTable::isNotAvailableForEntry.name, originalValue2);
		commitTransaction;
	endif;
	
	delete keepThese;
end;</source>
    </JadeMethod>
    <JadeMethod name="tStopsTableTemplateTest" id="52bcd493-216f-40bf-bb97-ec2d25272da6">
        <source>tStopsTableTemplateTest();
// cnwrs1 - for emails - August 2009
//27 Jul 2022	navsj20	TFS 53862	EUP - WMS - Damage Recording Extra Details
/*
This method will make sure that a Stops Table Template can be created for more than 1 terminal with different settings.
The 2 terminals used are UT and T01 if either does not exist then this test will fail. 
*/

constants
	InfoRequiredTest	= 95;
	
vars
	stopsTable			: CM_StopsTable;
	stopTableTemplate	: CM_StopTableTemplate;
	terminal			: CM_Terminal;
	myRoot				: CM_Root;
	processArray	: IntegerArray;
	setArray : IntegerArray;
	checkArray : IntegerArray;
	//cargoBOLType		: CM_CargoBOLType; 	// 17 Jul 2022	navsj20	TFS 53862
	cargoBOLType		: Object;			//17 Jul 2022	navsj20	TFS 53862
	selectedTypes		: CM_CargoBOLTypeSet;
	isChildIgnore		: Boolean;
	isChildOnly			: Boolean;
	isCoastalIgnore		: Boolean;
	isCoastalOnly		: Boolean;
	isFull				: Boolean;
	isMT				: Boolean;
	criteria			: CM_YACriteria;
begin
	myRoot		:= app.myRoot;
	terminal	:= app.myRoot.allTerminals[ 'UT' ];
	self.assertNotNullMsg( terminal, 'Terminal UT does not exist!' );
	
	create selectedTypes transient;
	create processArray transient;
	create setArray transient;
	create checkArray transient;
	
	// set up the required values and update stops table
	isChildIgnore		:= false;
	isChildOnly			:= false;
	isCoastalIgnore		:= false;
	isCoastalOnly		:= false;
	isFull				:= true;
	isMT				:= false;
	setArray.add(StopApplyImport);
	processArray.add(StopProcessOpImpDeliverRel);
	self.opts.addAssoc( ETRow_IsChildIgnore, isChildIgnore );
	self.opts.addAssoc( ETRow_IsChildOnly, isChildOnly );
	self.opts.addAssoc( ETRow_IsCoastalIgnore, isCoastalIgnore );
	self.opts.addAssoc( ETRow_IsCoastalOnly, isCoastalOnly );
	self.opts.addAssoc( ETRow_IsFull, isFull );
	self.opts.addAssoc( ETRow_IsMT, isMT );
	self.opts.addAssoc( ETRow_CheckStopAreas, checkArray );
	self.opts.addAssoc( ETRow_SetStopAreas, setArray );
	self.opts.addAssoc( ETRow_ProcessStopAreas, processArray );
	self.opts.addAssoc( ETRow_RequiresInfo, true );
	self.opts.addAssoc( ETRow_CustomsInfoEntry, DeliveryRelease );
	
	selectedTypes.add( app.myRoot.allCargoTypesById[ TI_CargoType_Container ] );
	
	// first make sure previous one is deleted if it exists.
	self.deleteStopsTable( InfoRequiredTest );
	
	stopsTable	:= myRoot.allAvailableStopsTables[ InfoRequiredTest ];
	if stopsTable = null then
		stopsTable	:= self.addStopsTable(	InfoRequiredTest,
											InfoRequiredTest.display,
											'Test Adding Terminal Template',
											selectedTypes,
											self.opts );
	endif;
	self.assertNotNullMsg( stopsTable, 'Stop Table does not exist' );
	
	// make sure the required stop table terminal settings exist and are set.
	if not stopsTable.requiresInfo or stopsTable.requiresInfoType &lt;&gt; DeliveryRelease then
		// set up the required values and update stops table
		self.opts.addAssoc( ETRow_RequiresInfo, true );
		self.opts.addAssoc( ETRow_CustomsInfoEntry, DeliveryRelease );
		// START 27 Jul 2022 navsj20 TFS 53862
		/*foreach cargoBOLType in stopsTable.allCargoTypesNew do
			selectedTypes.add( app.myRoot.allCargoTypesById[ cargoBOLType.id ] );
		endforeach;*/
		if stopsTable.myStopCriteria &lt;&gt; null then
			foreach criteria in stopsTable.myStopCriteria.allCriteria where criteria.myYACriteriaType.type = YACriteriaType_CargoType do
				foreach cargoBOLType in criteria.myYAData.CM_YADataObjects.allObjects do
					if cargoBOLType.isKindOf(CM_CargoBOLType) then
						selectedTypes.add( app.myRoot.allCargoTypesById[ cargoBOLType.CM_CargoBOLType.id ] );
					endif;
				endforeach;
			endforeach;
		endif;
		// END 27 Jul 2022 navsj20 TFS 53862

		self.updateStopsTable( stopsTable, selectedTypes);
		self.assertEqualMsg( stopsTable.requiresInfoType, DeliveryRelease, 'Wrong Info Required Entry' );
	endif;
	
	// Now make sure the stops table template for our terminal exists and has required values.
	stopTableTemplate	:= stopsTable.allStopTableTemplates[ terminal, stopsTable ];
	if stopTableTemplate = null then
		stopTableTemplate	:= self.addStopsTableTemplate( stopsTable, terminal);
		self.assertNotNullMsg( stopTableTemplate, 'Create Stop Table Template failed' );
	endif;
	
	if stopTableTemplate.isFull &lt;&gt; isFull or stopTableTemplate.isMT &lt;&gt; isMT then
		self.updateStopsTableTemplate( stopTableTemplate);
	endif;
	self.assertEqualMsg( stopTableTemplate.isFull, isFull, 'stopTableTemplate.isFull is invalid' );
	self.assertEqualMsg( stopTableTemplate.isMT, isMT, 'stopTableTemplate.isMT is invalid' );
	
	// Now make sure the stops table template for terminal T01 exists and has required values.
	terminal	:= app.myRoot.allTerminals['DP1'];
	self.assertNotNullMsg(terminal, 'Terminal DougPort does not exist!');
	// reset some of the flags so know that template has been set up correctly.
	isFull		:= false;
	isMT		:= true;
	self.opts.addAssoc( ETRow_IsFull, isFull );
	self.opts.addAssoc( ETRow_IsMT, isMT );
	
	stopTableTemplate	:= stopsTable.allStopTableTemplates[ terminal, stopsTable ];
	if stopTableTemplate = null then
		stopTableTemplate	:= self.addStopsTableTemplate( stopsTable, terminal);
		self.assertNotNullMsg( stopTableTemplate, 'Create Stop Table Template failed' );
	endif;
	
	if stopTableTemplate.isFull &lt;&gt; isFull or stopTableTemplate.isMT &lt;&gt; isMT then
		self.updateStopsTableTemplate( stopTableTemplate);
	endif;
	self.assertEqualMsg( stopTableTemplate.isFull, isFull, 'stopTableTemplate.isFull is invalid' );
	self.assertEqualMsg( stopTableTemplate.isMT, isMT, 'stopTableTemplate.isMT is invalid' );
	
	// do a little bit of tidying up here.
	self.opts.addAssoc( ETRow_IsNotAvailableForEntry, true );		// this helps to make sure it is never used!
	self.updateStopsTable( stopsTable, selectedTypes);
	
epilog
	delete processArray;
	delete setArray;
	delete checkArray;
	delete selectedTypes;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tVGMInfoStop" id="3ca082e3-5b94-44d9-9d72-613ef5de30e5">
        <updating/>
        <source>tVGMInfoStop() updating;
/*

Purpose:			TFS 1946

Date		Who		Reason
17/06/2016	cnwmk3	Initial creation
29/06/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
*/
constants
	TruckId							= "TRKVGM";
	ContId							= "CONTRVGM01";
	VoyCode							= "UT_VOY46";
	VesselCode						= "DIAM";
vars
	selectedTypes					: CM_CargoBOLTypeSet;
	opts							: CM_AssociationDict;
	cargoType						: CM_CargoType;
	stopsTable						: CM_StopsTable;
	stopSetArray, intArray			: IntegerArray;
	vvr								: CM_VehicleVisitRecord;
	operator						: CM_Operator;
	voyage							: CM_Voyage;
	ti								: CM_TrackedItem;
	stop							: CM_Stops;
	count							: Integer;
	booking							: CM_BookingRef;
	controller						: CMIF_TIUpdateController;
begin
	deleteStopsTable(60);
	self.deleteContainer(ContId);
	self.deleteVehicle(TruckId);
	// Create a Stop Type
	//  create a new Stop  with required info "SOLAS VGM Details". Save.  Edit the stop and update with terminal details with auto applies on export and for Fulls.
	create selectedTypes transient;
	selectedTypes.add( app.myRoot.allCargoTypesById[ TI_CargoType_Container ] );
	create stopSetArray transient;
	create intArray transient;
	stopSetArray.add(StopApplyExport);
	self.opts.purge();
	self.opts.addAssoc( ETRow_IsFull, true );
	self.opts.addAssoc(ETRow_RequiresInfo, true);
	self.opts.addAssoc(ETRow_CustomsInfoEntry, SOLAS);
	self.opts.addAssoc( ETRow_CheckStopAreas, intArray );
	self.opts.addAssoc( ETRow_SetStopAreas, stopSetArray );
	self.opts.addAssoc( ETRow_ProcessStopAreas, intArray );
	
	stopsTable := addStopsTable(60, "WSTOP", "Unit Test", selectedTypes, self.opts);
	
	// Gate in Full export container with not VGM details i.e. not certified, or weight cert reference or the authorised person check that if weight isn't certified or any of those details missing the new stop is applied. 
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.deleteVoyage(VoyCode);
	voyage := self.addVoyageWithContainerStructur(VoyCode, VesselCode, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.opts.purge();
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_EXPORT);
	self.opts.addAssoc("Voyage", voyage.code);
	self.opts.addAssoc("DischargePort", app.myRoot.allPorts["NZAKL"].code);
	vvr := self.gateInContainer(TruckId, ContId, "2200", operator.code, "APPL", self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString));
	self.assertNotNull(vvr);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	ti := self.getTrackedItem(ContId);
	count := 0;
	foreach stop in ti.getAllStops do
		if stop.id = stopsTable.id then
			count := count + 1;
		endif;
	endforeach;
	self.assertEqual(count, 1);
	
	// Check that the stop can not be cleared from the stops form. 
	self.expectTrxError(ERR_STOP_REQUIRES_INFO);
	self.deleteStop(ti, stopsTable);
	
	// update VGM details
	// To clear edit the is weight certified and  weight cert reference and the authorised person .
	controller := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.getMyUserCode(), null);
	beginTransaction;
	ti.setIsWeightCertified(true, controller, app.myPassport);
	//ti.setWeightCertifiedName("TESTET1", controller, app.myPassport);				// TFS 4492
	//ti.setWeightCertifiedReference("TESTET1", controller, app.myPassport);		// TFS 4492
	ti.setMyVGMDetails(	"TESTET1", "TESTET1", null, null, null, null, null, null,	// TFS 4492
						null, null, null, null, null, controller	);				// TFS 4492
	commitTransaction;
	
	// Check once all 3 fields have values the stop is cleared automatically
		ti := self.getTrackedItem(ContId);
	count := 0;
	foreach stop in ti.getAllStops do
		if stop.id = stopsTable.id then
			count := count + 1;
		endif;
	endforeach;
	self.assertEqual(count, 0);
	
	// Prenote container with all those details set. 
	booking := self.addBookingForContainer("UT_BOOKING01", operator, voyage, "NZAKL", "2200", "APPL");
	assertNotNull(booking);
	
	self.opts.purge();
	self.opts.addAssoc("IsWeightCertified", true);
	self.opts.addAssoc("WeightCertBy", "TESTER");
	self.opts.addAssoc("AuthorisedPerson", "TESTER");
	ti := self.addPrenotedContainer(booking.allBookingRefItems.first,  "PRENOTE0046");
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(ti);
	
	vvr := self.gateInPrenote(TruckId, "", "", ti, self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString));
	self.assertNotNull(vvr);
	
	// Check when gated in the export full container the stop is not set.
	ti := self.getTrackedItem("PRENOTE0046");
	count := 0;
	foreach stop in ti.getAllStops do
		if stop.id = stopsTable.id then
			count := count + 1;
		endif;
	endforeach;
	self.assertEqual(count, 0);
epilog
	self.deleteStopsTable(stopsTable.id);
	delete selectedTypes;
	delete stopSetArray;
	delete intArray;
	delete controller;
end;</source>
    </JadeMethod>
</Class>
