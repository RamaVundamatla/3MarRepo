/*
----------   ----------  --------------------------------------------------
Created:	14 March 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	inheritMethod(_task);


end;
</source>
        <Parameter name="_task" type="CM_AutoTask"/>
    </JadeMethod>
</Class>
