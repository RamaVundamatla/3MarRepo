        <source>cbxCountryFlag_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;

vars

begin
	if obj = null then 
		return null;
	endif;
	
	if obj.CM_Country.isNotAvailableForEntry then 
		return null;
	endif;

	return obj.CM_Country.description;
end;</source>
