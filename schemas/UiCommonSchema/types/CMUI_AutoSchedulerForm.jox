    <JadeMethod name="doLoadSSDefCombo" id="f9d308e2-78bf-4960-a4ca-202bbf4e8d47">
        <source>doLoadSSDefCombo();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 December 2009	cnwas3	Initial creation

*/

vars
	newIndex : Integer;
	format_SS : CM_OutputFormat_SS;
begin
	cmbSSDef.clear();
	foreach format_SS in app.myRoot.allOutputFormats_SS where format_SS.type &lt;&gt; 2 do
