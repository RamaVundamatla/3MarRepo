    <JadeMethod name="includeVoyage" id="59ee7049-a7af-41eb-9e27-38ad9eb0ee6f">
        <source>includeVoyage(_camProtocol: CM_CamProtocol; _voyage: CM_Voyage; _trx: CM_Transaction; _camAgent: CM_CamControllerAgent; _logExcluded: Boolean): Boolean protected;
//
//04 Dec 2014	cnwrs1	 Par 35329 CCMS 2405 - Alabama Steel Cams
//
vars

begin
	return true;
end;
</source>
        <access>protected</access>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_trx" type="CM_Transaction"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
