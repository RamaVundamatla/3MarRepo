    <JadeMethod name="canBeDBLoaded" id="502d5442-8a3a-4f1d-be61-57f6850117ec">
        <source>canBeDBLoaded(): Boolean;
/*
Date		Who		Reason
01 Aug 2012	cnwcs5	Initial creation - par 30136
*/
// 20 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 15 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc

vars
	result : Boolean;
begin
	result := inheritMethod();
	
	if not result then
		if self.status = CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS and 
		   self.canBePartiallyLoaded then
			result := true;
		endif;
	endif;

	return result;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
