<Class name="QRefYardAllocationMethod" id="3cafea6b-c85d-464b-985d-c6e5468173ec">
    <superclass name="CM_QReferenceMethod"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="60f26e61-78d7-41dd-b328-6b8ad2298b36">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 January 2012	cnwndl1	Initial creation	Par 28889

*/

vars
	oper : CM_QueryOperator;
begin
	if self.isTransient then 
		return;
	endif;

	create oper as CM_QReferenceIsOneOf persistent;
	self.allAllowedOperators.add(oper);	
	
	create oper as CM_QStringContains persistent;
	self.allAllowedOperators.add(oper);	
	
epilog


end;</source>
    </JadeMethod>
    <JadeMethod name="getControlTypeForOperator" id="90b4c8aa-535a-4535-b106-5aca7137abea">
        <source>getControlTypeForOperator(_op: CM_QueryOperator): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 January 2012	cnwndl1	Initial creation	Par 28889

*/

vars

begin

	if _op.isKindOf( CM_QReferenceIsOneOf ) then
		return QueryControl_MultiSelect;
	else
		return QueryControl_TextBox;
	endif;
	
epilog

end;</source>
        <Parameter name="_op" type="CM_QueryOperator"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getValueForObject" id="64306a8c-ebfb-440f-a7d7-d151f1b1aacd">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 January 2012	cnwndl1	Initial creation

*/

vars

	any : Any;
	dict : CM_YAByPriorityDict;
	ya : CM_YardAllocation;
	str : String;

begin

	
	if _op &lt;&gt; null and _op.isKindOf( CM_QStringContains ) then
		any := inheritMethod(_obj,_op);
		if any.isKindOf( CM_YAByPriorityDict ) then
			dict := any.CM_YAByPriorityDict;
			if dict = null or dict.isEmpty then
				return null;
			else
				foreach ya in dict discreteLock do
					if str = null then
						str := ya.getListDisplay;
					else
						str := str &amp; ", " &amp;  ya.getListDisplay;
					endif;
				endforeach;
				return str;
			endif;
		else 
			return inheritMethod(_obj,_op);
		endif;
	else
		return inheritMethod(_obj,_op);
	endif;
	

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getWebDataRowName" id="46e73cfb-0f8c-4ec4-bafd-1d83d3d5d02f">
