    <JadeMethod name="copyFrom" id="113845fe-faed-4eeb-90aa-b2aa87197a8b">
        <updating/>
        <source>copyFrom(_moveCounts: CM_KPIMoveCountDtl) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2012	cnwdw1	Initial creation
*/
vars

begin

	self.dischargeGCWeight := _moveCounts.dischargeGCWeight;
	self.dischargeMoveCount := _moveCounts.dischargeMoveCount;
	self.dischargeMoveRate := _moveCounts.dischargeMoveRate;
	self.dischargeTEU:= _moveCounts.dischargeTEU;
	self.dischargeVehicleCount := _moveCounts.dischargeVehicleCount;

	self.loadGCWeight := _moveCounts.loadGCWeight;
	self.loadMoveCount := _moveCounts.loadMoveCount;
	self.loadMoveRate := _moveCounts.loadMoveRate;
	self.loadTEU:= _moveCounts.loadTEU;
	self.loadVehicleCount := _moveCounts.loadVehicleCount;
	
	self.moveGCWeight := _moveCounts.moveGCWeight;
	self.moveCount := _moveCounts.moveCount;
	self.moveRate := _moveCounts.moveRate;
	self.moveTEU:= _moveCounts.moveTEU;
	self.moveVehicleCount := _moveCounts.moveVehicleCount;

epilog

end;</source>
        <Parameter name="_moveCounts" type="CM_KPIMoveCountDtl"/>
    </JadeMethod>
    <JadeMethod name="update" id="437f5b1d-dde1-47d7-b340-9315a1148f87">
        <updating/>
        <source>update(_movement: CM_KPIMovementDtl; _interval: Integer) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2012	cnwdw1	Initial creation
*/
vars

begin
	if _movement.isLoad then
		if _movement.isGC then
			self.loadGCWeight := self.loadGCWeight + _movement.weight;
		elseif _movement.isVehicle then
			self.loadVehicleCount := self.loadVehicleCount + 1;
		else
			self.loadTEU := self.loadTEU + _movement.teu;
		endif;
		self.loadMoveCount := self.loadMoveCount + 1;
		if _interval &gt; 0 then
			self.loadMoveRate := (self.loadMoveCount / _interval) * 60;
		else
			self.loadMoveRate := 0;
		endif;
	elseif _movement.isDischarge then
		if _movement.isGC then
			self.dischargeGCWeight := self.dischargeGCWeight + _movement.weight;
		elseif _movement.isVehicle then
			self.dischargeVehicleCount := self.dischargeVehicleCount + 1;
		else
			self.dischargeTEU := self.dischargeTEU + _movement.teu;
		endif;
		self.dischargeMoveCount := self.dischargeMoveCount + 1;
		if _interval &gt; 0 then
			self.dischargeMoveRate := (self.dischargeMoveRate / _interval) * 60;
		else
			self.dischargeMoveRate := 0;
		endif;
	endif;

	if _movement.isGC then
		self.moveGCWeight := self.moveGCWeight + _movement.weight;
	elseif _movement.isVehicle then
		self.moveVehicleCount := self.moveVehicleCount + 1;
	else
		self.moveTEU := self.moveTEU + _movement.teu;
	endif;
	self.moveCount := self.moveCount + 1;
	if _interval &gt; 0 then
		self.moveRate := (self.moveCount / _interval) * 60;
	else
		self.moveRate := 0;
	endif;

epilog

end;</source>
        <Parameter name="_movement" type="CM_KPIMovementDtl"/>
        <Parameter name="_interval" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateActualFrom" id="13338bf6-792a-414a-8590-781fbc43a7a0">
        <updating/>
        <source>updateActualFrom(_code: String; _type: String; _terminal: CM_Terminal; _from, _at: TimeStamp) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2012	cnwdw1	Initial creation
*/
vars
	keaAgent: CM_KEAAgent;
	movements: CM_KPIMovementDtlArray;
	movement: CM_KPIMovementDtl;

begin
	if _from.isValid then
		create keaAgent transient;
		create movements transient;
		
		keaAgent.getMovements(_from, _at, _terminal, movements);
		foreach movement in movements do
			if movement.targetType =  _type and movement.getPrimeTarget = _code then
				self.loadMoveCount := self.loadMoveCount + 1;
				self.moveCount := self.moveCount + 1;
				self.loadTEU := self.loadTEU + movement.teu;
				self.moveTEU := self.moveTEU + movement.teu;
			elseif movement.sourceType = _type and movement.getPrimeSource = _code then
				self.dischargeMoveCount := self.dischargeMoveCount + 1;
				self.moveCount := self.moveCount + 1;
				self.dischargeTEU := self.dischargeTEU + movement.teu;
				self.moveTEU := self.moveTEU + movement.teu;
			endif;
		endforeach;
	endif;	
			
epilog
	delete movements;
	delete keaAgent;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_from" type="TimeStamp"/>
        <Parameter name="_at" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="updateActualFromTrain" id="01f0e108-d824-485b-a80c-c3ec697c202d">
        <updating/>
        <source>updateActualFromTrain(_train : CM_Train; _at: TimeStamp) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2012	cnwdw1	Initial creation
*/
vars
	terminal: CM_Terminal;
begin
	
	terminal := _train.myTerminal;
	if terminal = null then
		terminal := _train.myTerminalDeparted;
	endif;
	
	self.updateActualFrom(_train.code, CM_LocationsController.Location_Type_RAIL, terminal, _train.arrivalDT, _at);
			
epilog
end;</source>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_at" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="updateActualFromVoyage" id="64122545-fae7-4ae8-b4c4-f2ec94acdbea">
        <updating/>
        <source>updateActualFromVoyage(_voyage : CM_Voyage; _at: TimeStamp; _stats : CMIF_VoyageStats) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2012	cnwdw1	Initial creation
*/
vars

begin
	self.loadMoveCount := _stats.actualLoad;
	self.dischargeMoveCount := _stats.actualDischarge;
	self.moveCount := _stats.actualLoad + _stats.actualDischarge;
	
	self.loadTEU := _stats.actualLoadTEU;
	self.dischargeTEU := _stats.actualDischargeTEU;
	self.moveTEU := _stats.actualLoadTEU + _stats.actualDischargeTEU;


	//self.updateActualFrom(_voyage.code, CM_LocationsController.Location_Type_SHIP, _voyage.myTerminal, _voyage.shipExchangeDate, _at);
epilog
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_at" type="TimeStamp"/>
        <Parameter name="_stats" type="CMIF_VoyageStats"/>
    </JadeMethod>
    <JadeMethod name="updateFromVoyage" id="04badf80-a5b2-46a3-bee7-4e3ae7108a2f">
        <updating/>
        <source>updateFromVoyage(_voyage : CM_Voyage) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2012	cnwdw1	Initial creation
*/
vars

begin
	self.loadMoveCount := _voyage.getLoadMoveCount;
	self.dischargeMoveCount := _voyage.getDischargeMoveCount;
	self.moveCount := self.loadMoveCount + self.dischargeMoveCount;
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="updatePlannedFromTrain" id="4ac2e1fd-fb7e-4bcc-87ef-93bfb3693998">
        <updating/>
