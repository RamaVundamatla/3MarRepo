        <source>delete() updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 February 2014	cnwndl1	Initial creation	Par 33181

*/

vars

begin
	delete self.myNextPage;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doProcessLabelContents" id="3ba3c751-bd2d-403c-8e0a-0766521de59d">
        <updating/>
        <source>doProcessLabelContents( _label : CMUI_Label input):Boolean protected, updating;
/*

Purpose:			

Parameters:			Generic method to handle positionong of text inside the bounds of a control.

Return Value:		

Date		Who		Reason
06 November 2012	cnwndl1	Initial creation	Par 30682

*/

vars

	text : String;
	textPrintWidth : Integer;
	left : Integer;
	top : Integer;
	printAttrib : Integer;
	
begin


	text := _label.caption.trimBlanks;
	textPrintWidth := _label.getTextExtent( text );
	top := ( _label.top + 1 ).Integer;
	//31 Jan 2014	NDL	Par 33181
	printAttrib := 0;
	if _label.fontBold then
		printAttrib := self.BOLD_Attribute;
	endif;
	
	if textPrintWidth &lt; _label.width then
		// The single line of text will fit.
		if _label.alignment.isOneOf( _label.Alignment_Left_Bottom, _label.Alignment_Left_Middle, _label.Alignment_Left_Top ) then
			// Left Align the text
			left :=  _label.left.Integer;
		elseif _label.alignment.isOneOf( _label.Alignment_Right_Bottom, _label.Alignment_Right_Middle, _label.Alignment_Right_Top ) then
			// Right Align the text
			left :=  ( ( _label.left.Integer + _label.width.Integer ) - textPrintWidth ).Integer;
		else
			// Centre the text
			left := ( _label.left + ( (_label.width - textPrintWidth) / 2 ) ).Integer;
		endif;
		self.createAndAddPrintLineDetail( text, top, left, printAttrib );

	else
		// The single line of text is too long.
		self.doProcessLabelContentsTooLong( _label, text, top );
		
	endif;
	
	return true;

epilog


end;</source>
        <access>protected</access>
        <Parameter name="_label" type="CMUI_Label" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doProcessLabelContentsTooLong" id="819b2980-a614-4688-a125-124b57b4c84b">
        <source>doProcessLabelContentsTooLong( _label : CMUI_Label input; _text : String; _top : Integer ):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 February 2014	cnwndl1	Initial creation	Par 33181

*/

vars

	text : String;
	textPrintWidth : Integer;
	textPrintHeight : Integer;
	left : Integer;
	top : Integer;
	subText : String;
	endPos : Integer;
	wordArray : CnStringArray;
	word : String;
	wordPos : Integer;
	wordArraySize : Integer;
	tempStrings : CM_StringDict;
	embeddedCrLf : Boolean;
	wordError : Boolean;
	printAttrib : Integer;
	
begin


	text := _text;
	textPrintWidth := _label.getTextExtent( text );
	top := _top;
	printAttrib := 0;
	if _label.fontBold then
		printAttrib := self.BOLD_Attribute;
	endif;
	
	// The single line of text is too long.
	
	textPrintHeight := _label.getTextHeight( "X" );
	
	// Methodology 1.
	// Try breaking up text based on the embedded spaces.... and present 'nicely', ie as many whole words
	// as we can per line leaving space at the end rather than breaking a word over multiple lines.
	// If all the text fits in the control then run with it, otherwise throw away the temp
	// fields and use the "cram it in" strategy below.

	if text.pos(" ",1) &gt; 0 then
		// worth a try, there is at least one embedded space.
		wordPos := 1;
		
		on Exception do self.handle1035(exception, wordError);
		wordArray := text.cnGetTokens(" ");
		
		if not wordError then
		
			wordArraySize := wordArray.size;
			create tempStrings transient;
	
			while true do
			
				word := wordArray[wordPos];
				embeddedCrLf := word.pos(CrLf,1) &gt; 0; // forced line feed.
				if embeddedCrLf then
					word := word.replaceString(CrLf," ").trimBlanks;
				endif;
				
				if subText = null then
					subText := word;
					if _label.getTextExtent( subText ) &gt;= _label.width.Integer then
						//this single word is too big, we will have to use cram methodology
						break;
					endif;
				else
					subText := subText &amp; " " &amp; word;
					// this one will be ok, we must have already tried it last time thru the loop
				endif;
		
				if embeddedCrLf or ( wordPos = wordArraySize ) or (  _label.getTextExtent( subText &amp; " " &amp; wordArray[wordPos + 1] ) &gt;= _label.width.Integer ) then
					//either we have all of the words left selected, or adding the next word would be too much for a line (i.e we have the max we can fit)
					self.createTempSubLabelText( _label, subText, top, tempStrings, printAttrib );
					if wordPos = wordArraySize then
						// That was everything, so commit the values we have and bail
						self.addMultiplePrintLines( tempStrings );
						return true;
					endif;
					if ( _label.top + _label.height ) &lt; ( top + textPrintHeight ) then
						//label not deep enough for another line of data, so bail and use cram method
						break;
					endif;
					subText := null; //reset so we are ready for the next line
				endif;
				
				wordPos := wordPos + 1;
				
			endwhile;
		
		endif;
	
	endif;
	
	// Methodology 2.
	// last resort - just cram in as much as we can...
	// break it when it reaches max width, store off that line,
	// reposition to the next line, and if we are still inside the control, then try again with whats left. 
	// Continue, until we run out of space in the control or run out of text to print.
	
	top := _top;
	left := ( _label.left ).Integer;
	endPos := 1;
	textPrintHeight := self.getCramTextLineHeight( _label );

	if text.pos(CrLf,1) &gt; 0 then
		text := text.replaceString(CrLf," ").trimBlanks;
	endif;
	
	while true do
		subText := text[1:endPos];
	
		if ( subText = text ) or(  _label.getTextExtent( text[1:endPos + 1] ) &gt;= _label.width.Integer ) then
			//either we have all of the text selected, or one more character would be too much for a line (i.e we have the max we can fit)
			if subText = text then
				self.createAndAddPrintLineDetail( subText, top, left, printAttrib );
				// That was everything, so bail
				break;
			else
				//there is more to come...
				if text[endPos + 1] = " " then
					// we start a new word on the next line.
				else
					// move the counter back a char and replace the last char in our subtext with a continuation char
					if not doingLineUp and subText[subText.length] &lt;&gt; " " then 
						endPos := endPos - 1;
						subText[subText.length] := "-";
						if subText.length &gt; 2 then
							if subText[subText.length - 1:end] = " -" or subText[subText.length - 1:end] = "--" then
								//it was the first char of a new word, drop the hyphen.
								subText[subText.length] := " ";
							endif;
						endif;
					endif;
				endif;
				self.createAndAddPrintLineDetail( subText, top, left, printAttrib );
			endif;
			// set up the next values
			top := top + textPrintHeight;
			if ( _label.top + _label.height + 2 ) &lt; ( top + textPrintHeight) then
				//label not deep enough for another line of data, we've done our best, so just bail
				break;
			endif;
			text := text[endPos + 1:end].trimBlanks;
			endPos := 1;
		else
			// there is enough width and at least one more character available to print
			endPos := endPos + 1;
		endif;
	endwhile; 
		
	return true;

epilog

	if tempStrings &lt;&gt; null then
		if not tempStrings.isEmpty then
			tempStrings.purge();
		endif;
		delete tempStrings;
	endif;
	
	if wordArray &lt;&gt; null then
		delete wordArray;
	endif; 

end;</source>
        <access>protected</access>
        <Parameter name="_label" type="CMUI_Label" usage="input"/>
        <Parameter name="_text" type="String"/>
        <Parameter name="_top" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCramTextLineHeight" id="cf2bb36a-5ac2-4145-b470-5019338d9bec">
        <source>getCramTextLineHeight( _label : CMUI_Label ):Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 February 2014	cnwndl1	Initial creation	Par 33181

*/

vars

	textPrintHeight : Integer;

begin

	textPrintHeight := _label.getTextHeight( "X" );
	return textPrintHeight;

epilog

end;</source>
        <access>protected</access>
