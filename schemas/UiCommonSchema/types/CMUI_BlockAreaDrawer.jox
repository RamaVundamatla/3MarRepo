    <JadeMethod name="drawCell" id="4594448d-f1f9-4dee-8b0b-530b58219b7c">
        <source>drawCell(x, y: Integer) protected;
// Draw a single grid cell
vars
	topLeft, bottomRight: Point;
	colour: Integer;
	cell : Point;
begin
	cell.setX(x);
	cell.setY(y);
	topLeft := cellToPixel(cell);
	bottomRight := topLeft.add(cellSize.x, cellSize.y);
	if not self.isLocation(cell) then
		if self.isSelected(cell) then
			colour := colourSelectedCell;
		else
			colour := colourCell;
			self.drawGrid(x, x, y, y);
		endif;
		self.myDrawingFrame.drawWidth := 1;
		self.myDrawingFrame.drawSolidRectangle(topLeft.x, topLeft.y, bottomRight.x, bottomRight.y, colour);
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawCells" id="14230e9c-a5c6-4266-a7cf-838aaad18ccd">
        <source>drawCells() protected;
// draw all the cells
vars
	obj : Object;
	gridCell : CMUI_BlockGridCell;
begin
	foreach obj in self.myCells do
		gridCell := obj.CMUI_BlockGridCell;
		self.drawCell(gridCell.column, gridCell.row);
	endforeach;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawGrid" id="6c863d5c-5e6c-4654-a9ca-b320834a65df">
        <source>drawGrid(leftColumn, rightColumn, topRow, bottomRow : Integer) protected;
// Draw a grid on to the area
vars
	column, row : Integer;
	x, y : Integer;
	leftTop, rightBottom : Point;
	left, right, top, bottom : Integer;
begin
	self.myDrawingFrame.drawStyle := Frame.DrawStyle_Solid;
	self.myDrawingFrame.drawWidth := gridLineWidth;
	
	left := gridBorderWidth + ((cellSize.x + gridLineWidth) * (leftColumn - 1));
	right := gridBorderWidth + ((cellSize.x + gridLineWidth) * rightColumn);
	foreach row in topRow - 1 to bottomRow do
		y := gridBorderWidth + ((cellSize.y + gridLineWidth) * row);
		self.myDrawingFrame.drawLine(left, y, right, y, colourGridLine);
	endforeach;

	top := gridBorderWidth + ((cellSize.y + gridLineWidth) * (topRow - 1));
	bottom := gridBorderWidth + ((cellSize.y + gridLineWidth) * bottomRow);
	foreach column in leftColumn - 1 to rightColumn do
		x := gridBorderWidth + ((cellSize.x + gridLineWidth) * column);
		self.myDrawingFrame.drawLine(x, top, x, bottom, colourGridLine);
	endforeach;
end;
</source>
        <access>protected</access>
        <Parameter name="leftColumn" type="Integer"/>
        <Parameter name="rightColumn" type="Integer"/>
        <Parameter name="topRow" type="Integer"/>
        <Parameter name="bottomRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawGridBorder" id="cd6184df-f280-4167-be40-74a8663a39d2">
        <source>drawGridBorder() protected;
// Draw a solid border around the grid
vars

begin
	self.myDrawingFrame.drawStyle := Frame.DrawStyle_InsideSolid;
	// The drawrectangle centres the line on the coords of the rectangle
	self.myDrawingFrame.drawWidth := gridBorderWidth * 2 - 1;
	self.myDrawingFrame.drawRectangle(0, 0, self.myDrawingFrame.clientWidth-1, self.myDrawingFrame.clientHeight-1, colourBorder);
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawLabels" id="670cd6f3-5eec-4631-853d-2cf88145f5db">
        <source>drawLabels() protected;
// Draw Labels

// cnwrd1 - 20.06.2008 par #17061
/*

Date		Who		Reason
25 Jun 2008	cnwkpd1	PAR #17218 - Handle 0 or 1 columns without exceptions

*/

constants
	LabelSpacing	: Integer = 2;
	
vars
	pointGap,
	labelWidth,
	pointPos,
	lastEndPos,
	startX: Integer;
	displayText : String;
	theLabel : Label;
	x, y : Integer;
	textHeight : Integer;
	columnLabels, rowLabels : StringArray;
	
begin
	self.myHLabels.drawTextAlign := Window.DrawTextAlign_Center;
	self.myHLabels.drawFontSize := 9;
	textHeight := self.myHLabels.drawTextHeight("1").Integer;
	y := (self.myHLabels.clientHeight / 4).Integer;
	create columnLabels transient;
	self.getColumnLabels(columnLabels);
	
	// cnwrd1 - 20.06.2008 par #17061 start
	create theLabel transient;
	if not columnLabels.isEmpty then				// PAR #17218
		theLabel.caption :=	columnLabels[1];
	endif;
	labelWidth := theLabel.width.Integer ;
	if self.columns() &gt; 1 then						// PAR #17218
		pointGap := (self.myHLabels.width / (self.columns - 1)).Integer;
	endif;
	// cnwrd1 - 20.06.2008 par #17061 end
	
	foreach x in 1 to self.columns do	
		// cnwrd1 - 20.06.2008 par #17061 start
		displayText := columnLabels[x]; 		
	
		pointPos := ((x - 1) * pointGap) + labelWidth;
		if pointPos &lt; lastEndPos then
			continue;
		endif;
		
		if displayText &lt;&gt; null then
			startX := (cellSize.x + gridLineWidth ) * x - (cellSize.x / 2).Integer; //cellSize.x; pointPos - (self.myHLabels.getTextExtent(displayText) / 2).Integer;				
			if startX &lt; lastEndPos then
				continue;
			endif;
		endif;
		
		if displayText &lt;&gt; null and startX &gt;= lastEndPos then
			self.myHLabels.drawTextAt(displayText, startX, y, Black);
			lastEndPos := startX + self.myHLabels.getTextExtent(displayText) + LabelSpacing;
		endif; 
		// cnwrd1 - 20.06.2008 par #17061 end
		
		//self.myHLabels.drawTextAt(columnLabels[x], (cellSize.x + gridLineWidth) * x - (cellSize.x / 2) , y, Black); // -- cnwrd1 - 20.06.2008 par #17061 start
	endforeach;
	self.myVLabels.drawTextAlign := Window.DrawTextAlign_Left;
	self.myVLabels.drawFontSize := 9;
	x := (self.myVLabels.clientWidth / 4).Integer;
	create rowLabels transient;
	self.getRowLabels(rowLabels);
	foreach y in 1 to self.rows do
		self.myVLabels.drawTextAt(rowLabels[y], x, (cellSize.y + gridLineWidth) * y - textHeight, Black);
	endforeach;	
	
	
epilog
	delete columnLabels; 
	delete rowLabels;
	delete theLabel; // cnwrd1 - 20.06.2008 par #17061 
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawLocation" id="81131eff-8fc1-449e-a450-fc1d5b04fafd">
