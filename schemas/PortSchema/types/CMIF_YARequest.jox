    <JadeMethod name="isCargoGroupId_Match" id="de25bbd6-c178-4f3e-957f-1b5f9165abc4">
        <source>isCargoGroupId_Match(_yaData: CM_YADataString): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Jun 2025	navhl20 Bug MTN-35180: TPT | Release By Type Cargo Group / Lot Number
*/

vars
	cargoGRP 	: CM_CargoGroup;
	release		: CM_ReserveSelection;
begin
	release := self.myReserveSelection;
	
	if release &lt;&gt; null then
		cargoGRP := release.myCargoGroup;
	endif;
	
	if cargoGRP &lt;&gt; null then
		return _yaData.doesValueMatch( cargoGRP.id );
	endif;
	
	return inheritMethod(_yaData);
epilog

end;</source>
