    <JadeMethod name="reevalStorageTrans" id="17bde951-b950-49aa-8368-3ea9bb30abd2">
        <source>reevalStorageTrans(_cargo : CM_TrackedItem input);
// ---------------------------------------------------------------------------
// Created:     21 July 2010 by NAVAB1 - re-evaluate storage transactions through the transaction map
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	trans : CM_TransactionSet;
	tran : CM_TITransaction;
begin
	create trans transient;
	
	foreach tran in _cargo.allTransactions discreteLock do
		if tran.isKindOf(CM_Storage) then
			trans.add(tran);
		endif;
	endforeach;
	self.updateInvoiceReevaluate(trans, _cargo, null);

epilog
	delete trans;
end;</source>
        <Parameter name="_cargo" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="returnInvoice" id="5ee2ab10-f728-4b07-94f1-18a6bf0332f1">
        <source>returnInvoice( _invoice : CM_Invoice; _createPending : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 September 2017	jlgndl1	Initial creation	TFS 6759

*/

vars

	creditCMIF : CMIF_InvoiceStatus;
	creditInv : CM_Invoice;
	pendingInv : CM_Invoice;
	
	finIOClass	: CM_ExtFinanceIO;
	invalid : Boolean;
	edition : Integer;
	createdTransient : Boolean;

begin

	create creditCMIF transient;
	creditCMIF.myInvoice := _invoice;
	creditCMIF.narration := _invoice.narration;
	creditCMIF.isZeroRatedTax := _invoice.isZeroRatedTax;
	creditCMIF.doExport := true;
	creditCMIF.myTermsOfTrade := null;
	creditCMIF.purchaseOrderNumber := _invoice.purchaseOrderNumber;
	creditCMIF.toDT := _invoice.toDT;
	creditCMIF.debtorReference := _invoice.debtorReference;
	creditCMIF.newPending := _createPending;
	
	app.myTrxUA.trxUpdInvStatusToReturned(	creditCMIF,	//_creditCMIF : CMIF_InvoiceStatus input;
											creditInv,	//_creditInv : CM_Invoice output;
											pendingInv,	//_pendingInv : CM_Invoice output;
											app.myPassport	//_passport : CM_Passport input
											);
											
	if creditCMIF.doExport and creditInv &lt;&gt; null then
		finIOClass := self.getTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
		if finIOClass &lt;&gt; null then
			on Exception do app.handleDeletedObject( exception, finIOClass, invalid );
			edition := finIOClass.edition;
		endif;
		if finIOClass = null or invalid then
			create finIOClass as CM_DefaultFinanceIO transient;
			createdTransient := true;
		endif;
		finIOClass.export( creditInv );
	endif;

epilog

	delete creditCMIF;
	
	if createdTransient then
		delete finIOClass;
	endif;

end;</source>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_createPending" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDebtorNodeController" id="94e347b1-0303-4a9f-b740-e64e902a4ad0">
        <source>setDebtorNodeController(_debtorName : String; _accountCode : String; _remarks : String; _externalRef : String;
						_debtorNodeController: CMIF_DebtorNode input; _proxyDebtor : CM_DebtorNode input)  protected;
// populate the controller for the debtor from the input parameters plus some default values
// 09/08/2018	jlgdap1	TFS 40092 New parameter for CM_DebtorNode::setProxy
vars
	root	: CM_Root;
	theBank : CM_Bank;
	rdg	 : CM_RootDebtorGroup;
begin
	root := app.myRoot;
	theBank := root.myRootCompany;
	rdg := theBank.getRootDebtorGroup();
	
	_debtorNodeController.isPurchaseOrderMandatory := true;
	_debtorNodeController.billingAddress := "123 Anywhere St" &amp; CrLf &amp; "Some town" &amp; CrLf &amp; "4321 Nowhere";
	_debtorNodeController.decfinName := _accountCode;
	_debtorNodeController.isSuspended := false;
	_debtorNodeController.isZeroRated := false;
	_debtorNodeController.badDebtor := false;
	_debtorNodeController.myBank := theBank;
	_debtorNodeController.myTermsOfTrade := null ;
	
	_debtorNodeController.myParentDebtorNode := null;
	_debtorNodeController.myParentDebtorNode := rdg;

	_debtorNodeController.myPxyDebtorNode := _proxyDebtor;
	_proxyDebtor.setProxySuspend(_debtorNodeController.isSuspended);
	_debtorNodeController.name := _debtorName;
	_debtorNodeController.purchaseOrderCode := "P/O 321";
	_debtorNodeController.externalReference := _externalRef;
	_debtorNodeController.remarks := _remarks;
	_debtorNodeController.doDebtorInvoiceTypes := false;
	_debtorNodeController.doDebtorInvoiceLineTypes := false;
	
	//_proxyDebtor.setProxy(_debtorNodeController.name);								// TFS 40092
	_proxyDebtor.setProxy(_debtorNodeController.name, _debtorNodeController.code);		// TFS 40092

end;</source>
        <access>protected</access>
        <Parameter name="_debtorName" type="String"/>
        <Parameter name="_accountCode" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_externalRef" type="String"/>
        <Parameter name="_debtorNodeController" type="CMIF_DebtorNode" usage="input"/>
        <Parameter name="_proxyDebtor" type="CM_DebtorNode" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setDebtorNodeController1" id="63a021fa-6d17-4441-87c1-b60cd668a0ef">
        <source>setDebtorNodeController1(_debtorName : String; _debtorNodeController: CMIF_DebtorNode input; _proxyDebtor : CM_DebtorNode input)  protected;
// populate the controller for the debtor
// 09/08/2018	jlgdap1	TFS 40092 New parameter for CM_DebtorNode::setProxy
vars
	count	: Integer;
	root	: CM_Root;
	theBank : CM_Bank;
	rdg	 : CM_RootDebtorGroup;
	agent		: CM_CustomsAgent;
	carrier		: CM_Carrier;
	consign		: CM_ConsigneeConsignor;
	debtorType	: CM_DebtorType;
	operator	: CM_Operator;
begin
	root := app.myRoot;
	theBank := root.myRootCompany;
	rdg := theBank.getRootDebtorGroup();
	
	count := 0;
	foreach carrier in root.allCarriers do
		count := count + 1;
		if count &gt; 3 then
			break;
		endif;
		_debtorNodeController.allCarriers.add(carrier);
	endforeach;
	count := 0;
	foreach consign in root.allConsigneeConsignors do
		count := count + 1;
		if count &gt; 3 then
			break;
		endif;
		_debtorNodeController.allConsignors.add(consign);
	endforeach;
	count := 0;
	foreach agent in root.allCustomsAgents do
		if agent.myDebtor = null then
			count := count + 1;
			if count &gt; 3 then
				break;
			endif;
			_debtorNodeController.allCustomsAgents.add(agent);
		endif;
	endforeach;
	count := 0;
	foreach debtorType in root.allDebtorTypes do
		if not debtorType.isSystemGenerated() then
			count := count + 1;
			if count &gt; 3 then
				break;
			endif;
			_debtorNodeController.allDebtorTypes.add(debtorType);
		endif;
	endforeach;
	count := 0;
	foreach operator in root.myRootCompany.rootDebtor.operators do
		count := count + 1;
		if count &gt; 3 then
			break;
		endif;
		_debtorNodeController.allOperators.add(operator);
	endforeach;
	
	_debtorNodeController.allSpecialReleaseTxnTypes.add(TRANS_TYPE_ReeferDaily);
	_debtorNodeController.allSpecialReleaseTxnTypes.add(TRANS_TYPE_ReeferFlatRate);
	_debtorNodeController.isPurchaseOrderMandatory := true;
	_debtorNodeController.billingAddress := "123 Anywhere St" &amp; CrLf &amp; "Some town" &amp; CrLf &amp; "4321 Nowhere";
	_debtorNodeController.decfinName := "Test 123456";
	_debtorNodeController.isSuspended := false;
	_debtorNodeController.isZeroRated := false;
	_debtorNodeController.badDebtor := false;
	_debtorNodeController.myBank := theBank;
	_debtorNodeController.myTermsOfTrade := null ; // CM_InvoiceTermsOfTrade.instances.first;
	
	_debtorNodeController.myParentDebtorNode := null;
	_debtorNodeController.myParentDebtorNode := rdg;

	_debtorNodeController.myPxyDebtorNode := _proxyDebtor;
	_proxyDebtor.setProxySuspend(_debtorNodeController.isSuspended);
	_debtorNodeController.name := _debtorName;
	_debtorNodeController.purchaseOrderCode := "P/O 321";
	_debtorNodeController.remarks := "Some random remarks";
	_debtorNodeController.doDebtorInvoiceTypes := true;
	_debtorNodeController.doDebtorInvoiceLineTypes := true;
	
	//_proxyDebtor.setProxy(_debtorNodeController.name);								// TFS 40092
	_proxyDebtor.setProxy(_debtorNodeController.name, _debtorNodeController.code);		// TFS 40092
	

end;
/*
createPackage(_packageType : Integer; _packageName : String; _description : String; _toAddress : String; _ccAddress : String; _bccAddress : String; 
				_subject : String; _message : String; _user : CM_User; _reports : ObjectArray input) : CM_Package;*/
</source>
        <access>protected</access>
        <Parameter name="_debtorName" type="String"/>
        <Parameter name="_debtorNodeController" type="CMIF_DebtorNode" usage="input"/>
        <Parameter name="_proxyDebtor" type="CM_DebtorNode" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setDebtorNodeController2" id="86940c7d-7bd1-4c63-8b7a-96e239c58c66">
        <source>setDebtorNodeController2(_debtorName : String; _debtorNodeController: CMIF_DebtorNode input; _proxyDebtor : CM_DebtorNode input)  protected;
// populate the controller for the debtor
// 09/08/2018	jlgdap1	TFS 40092 New parameter for CM_DebtorNode::setProxy
vars
	count	: Integer;
	root	: CM_Root;
	theBank : CM_Bank;
	rdg	 : CM_RootDebtorGroup;
	agent		: CM_CustomsAgent;
	carrier		: CM_Carrier;
	consign		: CM_ConsigneeConsignor;
	debtorType	: CM_DebtorType;
	operator	: CM_Operator;
begin
	root := app.myRoot;
	theBank := root.myRootCompany;
	rdg := theBank.getRootDebtorGroup();
	
	count := 0;
	foreach carrier in root.allCarriers do
		count := count + 1;
		if count &gt; 4 then
			break;
		endif;
		_debtorNodeController.allCarriers.add(carrier);
	endforeach;
	count := 0;
	foreach consign in root.allConsigneeConsignors do
		count := count + 1;
		if count &gt; 4 then
			break;
		endif;
		_debtorNodeController.allConsignors.add(consign);
	endforeach;
	count := 0;
	foreach agent in root.allCustomsAgents do
		if agent.myDebtor = null then
			count := count + 1;
			if count &gt; 4 then
				break;
			endif;
			_debtorNodeController.allCustomsAgents.add(agent);
		endif;
	endforeach;
	count := 0;
	foreach debtorType in root.allDebtorTypes do
		if not debtorType.isSystemGenerated() then
			count := count + 1;
			if count &gt; 4 then
				break;
			endif;
			_debtorNodeController.allDebtorTypes.add(debtorType);
		endif;
	endforeach;
	count := 0;
	foreach operator in root.myRootCompany.rootDebtor.operators do
		count := count + 1;
		if count &gt; 4 then
			break;
		endif;
		_debtorNodeController.allOperators.add(operator);
	endforeach;
	
	_debtorNodeController.allSpecialReleaseTxnTypes.add(TRANS_TYPE_ReeferDaily);
	_debtorNodeController.allSpecialReleaseTxnTypes.add(TRANS_TYPE_ReeferFlatRate);
	_debtorNodeController.isPurchaseOrderMandatory := true;
	_debtorNodeController.billingAddress := "123 Anywhere St" &amp; CrLf &amp; "Some town" &amp; CrLf &amp; "4321 Nowhere";
	_debtorNodeController.decfinName := "Test 654321";
	_debtorNodeController.isSuspended := false;
	_debtorNodeController.isZeroRated := false;
	_debtorNodeController.badDebtor := false;
	_debtorNodeController.myBank := theBank;
	_debtorNodeController.myTermsOfTrade := null ; // CM_InvoiceTermsOfTrade.instances.first;
	
	_debtorNodeController.myParentDebtorNode := null;
	_debtorNodeController.myParentDebtorNode := rdg;

	_debtorNodeController.myPxyDebtorNode := _proxyDebtor;
	_proxyDebtor.setProxySuspend(_debtorNodeController.isSuspended);
	_debtorNodeController.name := _debtorName;
	_debtorNodeController.purchaseOrderCode := "P/O 123";
	_debtorNodeController.remarks := "Some random remarks";
	_debtorNodeController.doDebtorInvoiceTypes := true;
	_debtorNodeController.doDebtorInvoiceLineTypes := true;
	
	//_proxyDebtor.setProxy(_debtorNodeController.name);								// TFS 40092
	_proxyDebtor.setProxy(_debtorNodeController.name, _debtorNodeController.code);		// TFS 40092

end;
</source>
        <access>protected</access>
        <Parameter name="_debtorName" type="String"/>
        <Parameter name="_debtorNodeController" type="CMIF_DebtorNode" usage="input"/>
        <Parameter name="_proxyDebtor" type="CM_DebtorNode" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setExportTransDates" id="2390f217-ab3d-4c0f-ab36-54594775f04b">
        <updating/>
        <source>setExportTransDates(_voyage : CM_Voyage) updating;

vars
	count,
	limit	: Integer;
	now,
	transDate : Date;
	cargo	: CM_TrackedItem;
begin
	// set transaction dates back 8-9 days
	limit := _voyage.allExportTIs.size div 2;
	foreach cargo in _voyage.allExportTIs do
		count := count + 1;
		if count &lt; limit then
			transDate := now - 9;
		else
			transDate := now - 8;
		endif;
		self.setTransactionDate(cargo, transDate);
	endforeach;


end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setImportTransDates" id="ea70136f-fd83-4fc5-8762-e46f027ad462">
        <updating/>
        <source>setImportTransDates(_voyage : CM_Voyage) updating;

vars
	count,
	limit	: Integer;
	now,
	transDate : Date;
	cargo	: CM_TrackedItem;
begin
	// set transaction dates back 10-11 days
	limit := _voyage.allImportTIs.size div 2;
	foreach cargo in _voyage.allImportTIs do
		count := count + 1;
		if count &lt; limit then
			transDate := now - 11;
		else
			transDate := now - 10;
		endif;
		self.setTransactionDate(cargo, transDate);
	endforeach;


end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setImportTransDates2" id="8168c0d3-3269-48e0-a8dc-18c82ae667b4">
        <updating/>
        <source>setImportTransDates2(_voyage : CM_Voyage; _date : Date) updating;

vars
	cargo	: CM_TrackedItem;
begin
	foreach cargo in _voyage.allImportTIs do
		self.setTransactionDate2(cargo, _date);
	endforeach;

end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_date" type="Date"/>
    </JadeMethod>
    <JadeMethod name="setInvLinePlaceholders" id="af84da7f-23ae-48cd-b404-0999a536826b">
        <source>setInvLinePlaceholders(_proxyDebtor : CM_Debtor input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Oct 2025	navah1	Initial creation
23 Oct 2025 navah1	Story 36250: LINX | Unit Test for Invoice Subject Placeholder Replacement
*/
vars
	invType	: CM_InvoiceDesc;
	invLineType	: CM_InvoiceLineDesc;
	dit		: CM_DebtorInvType;
	dilt	: CM_DebtorInvLineType;
	package	: CM_PackageInvoice;
	template	: CM_ReportTemplate;
	oa		: ObjectArray;
begin
	// invoice types
	invType := self.getInvoiceType("UT_InvType");
	create dit transient;
	dit.setup(_proxyDebtor, invType, 0);
	
	package := app.myRoot.allPackages[PackageInvoicePost, 'Unit test invoice package'].CM_PackageInvoice;
	if package &lt;&gt; null then
		self.deletePackage(package);
	endif;
	template := self.findReportTemplate();
	create oa transient;
	oa.add(template);
	package := self.createPackage(PackageInvoicePost, 'Unit test invoice package', 'Unit test invoice package', 'test@jadeworld.com', null, null, 
				'INV=@INV STA=@STA VOE=@VOE VOY=@VOY VES=@VES TER=@TER DEBTCODE=@DEBTCODE)', 'Invoice attached', app.getMyUser(), oa).CM_PackageInvoice;
	dit.allPackageInvoices.add(package);

	// invoice line types
	invLineType := self.getInvoiceLineType("UT_ILD01");
	create dilt transient;
	dilt.setup(_proxyDebtor, invLineType, "CODE01");
	invLineType := self.getInvoiceLineType("UT_ILD02");
	create dilt transient;
	dilt.setup(_proxyDebtor, invLineType, "CODE02"); 
epilog
	delete oa;
end;</source>
        <access>protected</access>
        <Parameter name="_proxyDebtor" type="CM_Debtor" usage="input"/>
    </JadeMethod>
