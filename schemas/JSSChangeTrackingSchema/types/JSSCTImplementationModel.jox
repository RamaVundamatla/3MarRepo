<Class name="JSSCTImplementationModel" id="24aadb31-a3b9-4d51-b288-3b65e392b9e2">
    <superclass name="Object"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="jssct_transient"/>
    <JadeMethod name="tryLockForSession" id="56760458-5b16-47d2-b90f-7c5577aa77d5">
        <source>tryLockForSession(pObject: Object): Boolean;
/*
	Try to get a lock on the Object, or return false after trying 10,000 times
*/
vars
	count: Integer;
begin
	while not self.tryLock(pObject, Exclusive_Lock, Session_Duration, LockTimeout_Immediate)	do
		count := count + 1;
		if count &gt; 10000 then
			return (false);
		endif;
		process.sleep(250);
	endwhile;
	return (true);
end;</source>
        <Parameter name="pObject" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tryLockingObject" id="66117df6-cb41-4c79-a9b0-506bdcfd62ce">
