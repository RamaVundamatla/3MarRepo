Date		Who		Reason
27 April 2023	jlier1	Initial creation

*/

vars
	wagon : CM_Wagon;
	release : CM_BulkRelease;
	ti : CM_TrackedItem;
	wle : CM_WorkListEntry;
	wagons : CM_WagonArray;
	resDetail : CM_ReserveDetail;
