    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="allItems" id="7d9c43e8-639b-4d3c-bbf6-81dd0a1dee21">
        <memberTypeInverse/>
        <type name="CMIF_SAPReturnItemArray"/>
    </ImplicitInverseRef>
    <PrimAttribute name="status" id="17f2cf41-6ec8-4e0d-9e9b-d2ed4f183fe5">
