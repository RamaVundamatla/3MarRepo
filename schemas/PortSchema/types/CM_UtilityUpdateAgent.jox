    <JadeMethod name="utlUpdateProformaCriteriaAttr" id="c437fff0-a588-4004-8356-3f413afeabdf">
        <source>utlUpdateProformaCriteriaAttr(_allProformaTrxCrit : CM_ProformCritByBankByPriority; _newCriteriaString : StringArray; _passport : CM_Passport input);
/*

Purpose:			This util go through all the Proforma Transaction Criteria of a bank and remove the criteria that is no longer in the _newCriteriaString list

Parameters:			

Return Value:		

Date		Who		Reason
22/01/2025	navkc1 JIRA Bug MTN-33836: MTN | Attribute was not updated correctly in pro forma transaction selection

*/

vars
	proformaTrxCriteria	: CM_ProformaTransactionCriteria;
	criteriaString	 	: String;
	yaCritType			: CM_YACriteriaType;
	yaCrit				: CM_YACriteria;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(false);
	
	// Go through all the proforma transaction criteria
	foreach proformaTrxCriteria in _allProformaTrxCrit discreteLock do
		exclusiveLock(proformaTrxCriteria);
		
		if _passport.noErrors then
			foreach yaCrit in proformaTrxCriteria.allCriteria do
				yaCritType := yaCrit.myYACriteriaType;
				
				if yaCritType = null then
					continue;
				endif;
				
				criteriaString := yaCritType.description;
				
				// This criteria is in the new criteria list, we good here
				if _newCriteriaString.indexOf(criteriaString) &gt; 0 then
					continue;
				endif;
				
				// Delete this since it's not in the new criteria list
				delete yaCrit;
			endforeach;
		endif;
		
		if _passport.noErrors then
			// Rebuild to remove invalid object as the yaCrit does not have reference to the collection.
			proformaTrxCriteria.allCriteria.rebuild();
			// Now recalculate the priorities
			proformaTrxCriteria.recalculateCriteriaPriorities();
		endif;
	endforeach;
	
epilog
	
end;</source>
        <Parameter name="_allProformaTrxCrit" type="CM_ProformCritByBankByPriority"/>
        <Parameter name="_newCriteriaString" type="StringArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdatePushEventsRoot" id="1d124b88-a9cb-40d7-b0f4-eb98db75562f">
        <updating/>
        <source>utlUpdatePushEventsRoot(_pxyObject : CM_PushEventsRoot; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Mar 2017	cnwkpd1	TFS 3369 - Push Events application

*/

vars
	realObject		: CM_PushEventsRoot;
	expectedEdition	: Integer;

begin
	self.initialiseActivity();
	
	// do validation
	self.raiseExceptionIfNull(_pxyObject, 'Push Events Root');

	app.setContinueCMExceptions(true);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	realObject := self.getRealObjectAndEditionCheck(_pxyObject, 'Push Events Root', _passport).CM_PushEventsRoot;

	if _passport.noErrors then
		// do updates
		realObject.setForUpdate(_pxyObject);
	endif;

end;
</source>
        <Parameter name="_pxyObject" type="CM_PushEventsRoot"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateQryReportSystem" id="bbe13c75-aa35-4b88-a519-e845a09bd22d">
        <source>utlUpdateQryReportSystem(_pxyReportSystem : CM_QryReportSystem input; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     21 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	realReport					: CM_QryReportSystem;
	expectedEdition				: Integer;
	newDefaultTemplate			: CMQF_FilterReports;
begin
	self.initialiseActivity();

	_pxyReportSystem.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyReportSystem.pxyGetRealObjectAndEdition(realReport, expectedEdition);
	
	if realReport = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Product.name, null, null);
		return;
	endif;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realReport);

	if _passport.noErrors and realReport.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'QryReportUser', null, null);
		return;
	endif;
	
	//01 Feb 2021	NDL	TFS 50152
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realReport, true);
	endif;
	
	
	if not realReport.isFormBasedReport then
		if _pxyReportSystem.jrwReportName.isEmpty then
		//	app.raiseCMException1(REQUIRED_FIELD, 'jrw designs', ETRow_JrwReport, null);
			app.raiseCMException(Input_required_field_jrwDesign, ETRow_JrwReport, null); // cnwdb2	PAR 35364
			return;
		endif;

		realReport.jrwReportName.clear();
		_pxyReportSystem.jrwReportName.copy(realReport.jrwReportName);
	endif;
	//there is no 'setForUpdate here - system reports are created from XML of global constants
	//and users can't update system reports as such - we're just updating the report's FILTER OBJECT that 
	//hold default values for criteria
	
	// Par 12847 - 13/11/2006
	if _pxyReportSystem.myFilterObject = null and not _pxyReportSystem.isInternal then
		//it's OK for a user report to not have afilter object - could be selector or external report
		//but system report should ALWAYS have one
		app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy CM_UserReport.myFilterObject is null');
		return;
	endif;
	
	//create new default template object every time (rather than trying to update an existing one.
	delete realReport.myFilterObject;
	
	// Par 12847 - 13/11/2006
	if _pxyReportSystem.myFilterObject &lt;&gt; null then
		newDefaultTemplate := _pxyReportSystem.myFilterObject.cloneSelf(false);
		newDefaultTemplate.cloneReferences(_pxyReportSystem.myFilterObject, false);
		newDefaultTemplate.isDefaultHolder := true;
		realReport.setMyFilterObject(newDefaultTemplate);
	endif;
	realReport.setJRWViewName();
	realReport.setRptAvailabilityAndFormats(_pxyReportSystem.reportAvailability, _pxyReportSystem.reportProcessType, _pxyReportSystem.reportFormats);
	realReport.setReportWebPagesPublic();
	// 35875 allow dev to change description
	if app.isDevelopmentSystemMain() then
		realReport.setReportDescription(_pxyReportSystem.reportDescription);
	endif;
	
	//01 Feb 2021	NDL	TFS 50152
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realReport, false);
	endif;
	
	if _passport.noErrors then
		global.causeEvent(EVENT_QRYREPORTSYSTEM_UPDATE, false, realReport);
	endif;

epilog
	
	
end;</source>
        <Parameter name="_pxyReportSystem" type="CM_QryReportSystem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateQryReportUser" id="2e5191b9-6871-4645-b3ed-821574e41d5f">
        <source>utlUpdateQryReportUser(_proxy : CM_QryReportUser input; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     11 June 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cancelSave		: Boolean;
	realReport		: CM_QryReportUser;
	expectedEdition	: Integer;
	
begin
	self.initialiseActivity();

	_proxy.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxy.pxyGetRealObjectAndEdition(realReport, expectedEdition);
	
	if realReport = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Product.name, null, null);
		return;
	endif;

	app.myValUA.valQueryReportUser(realReport, _proxy);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realReport);

	if _passport.noErrors and realReport.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'QryReportUser', null, null);
		return;
	endif;
	
	//01 Feb 2021	NDL	TFS 50152
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realReport, true);
	endif;
	
	if _passport.noErrors then
		realReport.setForUpdate(_proxy);
	endif;

	if not _passport.noErrors then
		return;
	endif;
	
	self.myUpdateAuditAgent.audUpdateGeneric(realReport, false);
	app.getMyUser().causeEvent(EVENT_QRYREPORTUSER_UPDATE, false, realReport);

	
end;</source>
        <Parameter name="_proxy" type="CM_QryReportUser" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateQueueCleanup" id="48f56461-ba86-44ac-a02a-0c6af8735a8a">
        <source>utlUpdateQueueCleanup(pQueue : CM_RadioTelemetryQueue input; 
			pNumCleaned, pRecuseLevel : Integer io;
			_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     10 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.initialiseActivity();
	
	if pQueue = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'queue', null, null);
		app.raiseCMException(Input_required_field_queue, null, null); // cnwdb2	PAR 35364
		return;
	endif;
	
	if pQueue.myParentQueue &lt;&gt; null then
		exclusiveLock(pQueue.myParentQueue);
	endif;
	exclusiveLock(pQueue);

	pQueue.cleanup(pNumCleaned, pRecuseLevel, _passport);

end;</source>
        <Parameter name="pQueue" type="CM_RadioTelemetryQueue" usage="input"/>
        <Parameter name="pNumCleaned" type="Integer" usage="io"/>
