    <JadeMethod name="validateForDelete" id="92c28da2-0cf9-4fc1-98f3-7f65ef9ec7de">
        <source>validateForDelete();
// -------------------------------------------
// Created 04 February 2005 by cnwdvb1
// -------------------------------------------
vars
	
	size : Integer;

begin

	if not self.allReportTemplates.isEmpty() then
		size := self.allReportTemplates.size;
		app.raiseCMException2(Repor_used_templ_pleas_remov_t, self.heading, size.String, null, null);
		return;
	endif;

end;
</source>
    </JadeMethod>
    <JadeMethod name="xml" id="244c301f-917d-4fb5-aa09-69a0b1145bb0">
        <source>xml() : String;
// -----------------------------------------------------------------------------
// Created:		16 May 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	xmlString, xmlString2 : String;
	idx : Integer;
begin
	foreach idx in 1 to self.jrwReportName.size do
		
		xmlString2 := xmlString2 &amp; formatAsXML('jrw', 
						formatAsXML('jrwReportName', jrwReportName[idx]) &amp;
						formatAsXML('jrwReportProfileName', jrwReportProfileName[idx]));
	endforeach;

	xmlString := formatAsXML('reportName', reportName) &amp;
					formatAsXML('reportType', reportType.String) &amp;
					formatAsXML('filterClassName', filterClassName) &amp;
					formatAsXML('tableDefName', tableDefName) &amp;  
					formatAsXML('tableDefViewName', tableDefViewName) &amp;
					formatAsXML('allJRWs', xmlString2);
					
	xmlString := formatAsXML('CM_QueryReport',  CrLf &amp; xmlString) ;

epilog
	return xmlString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
