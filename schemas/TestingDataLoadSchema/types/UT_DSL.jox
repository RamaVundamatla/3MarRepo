    <JadeMethod name="deleteHMSResourceType" id="57152eb0-59f4-46f8-bfcf-eb8ed59cf424">
        <source>deleteHMSResourceType(_resourceType : Any);

/*

Purpose:		Delete a HMS Resource Type	

Date			Who		Reason
31/01/2012		cnwmh5	Initial creation
05/03/2014		cnwma1	

*/

vars

	resourceType			: HMS_Object;
	resource				: HMS_Resource;

begin
	
	if _resourceType.isKindOf(String) then
		resourceType := app.myRoot.allResourceTypes[_resourceType.String];
	else	
		resourceType := _resourceType.HMS_Object;
	endif;
	
	if resourceType &lt;&gt; null then
		
		beginTransaction;
		foreach resource in resourceType.HMS_ResourceType.allResources do
			resource.setPropertyValue("myResourceType", null);
		endforeach;
		commitTransaction;
		
		app.myTrxDA.trxDeleteHMSObject(resourceType, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;

epilog

end;</source>
        <Parameter name="_resourceType" type="Any"/>
    </JadeMethod>
    <JadeMethod name="deleteHMSTug" id="3dcba407-4062-45d8-bec0-cf77d1145df7">
        <source>deleteHMSTug(_tugCode : String);

/*

Purpose:		Delete a HMS Tug	

Date			Who		Reason
31/01/2012		cnwmh5	Initial creation
05/03/2014		cnwma1	Delete Tug Resources before deleting the tug
*/

vars

	tug		: HMS_Tug;
	hmsObject	: HMS_Object;
	hmsResourceTug		: HMS_ResourceForTug;
begin

	

	tug := app.myRoot.allTugs[_tugCode];
	
	if tug &lt;&gt; null then
		
		beginTransaction;
		foreach hmsResourceTug in tug.allResourcesForTug do
			hmsResourceTug.setPropertyValue("myArrivalResource", null);
			hmsResourceTug.setPropertyValue("myDepartResource", null);
			hmsResourceTug.setPropertyValue("myShiftResource", null);
			hmsResourceTug.setPropertyValue("myTug", null);
			delete hmsResourceTug;		
		endforeach;
		commitTransaction;
		
		hmsObject := tug;
		app.myTrxDA.trxDeleteHMSObject(hmsObject, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;

epilog

end;</source>
        <Parameter name="_tugCode" type="String"/>
    </JadeMethod>
