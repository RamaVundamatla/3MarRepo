    <JadeMethod name="getSealsAtReceiveArray" id="fd6c5576-9884-4ff0-b266-8e700328f783">
        <source>getSealsAtReceiveArray(sealType : String; theSealNumbers : StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 Aug 2018	jlgsl4	TFS 39801 - SNO - Codeco needs 'at Receive' details
01 Jul 2020	NDL	TFS 49606 - If the item was prenoted, the seal checks may be during gate in and so actually be just before 'received'

*/

vars
	sealCheckTrx : CM_SealCheck;
begin	
	sealCheckTrx := self.getTransactionByTypeSameTRX( TRANS_TYPE_SEAL_CHECK ).CM_SealCheck;	
	
	//01 Jul 2020	NDL	TFS 49606 - Nothing found, try earlier.
	if sealCheckTrx = null then
		sealCheckTrx := self.getTransactionByTypePriorTRX( TRANS_TYPE_SEAL_CHECK ).CM_SealCheck;
	endif;
	
	if sealCheckTrx &lt;&gt; null then
		sealCheckTrx.getSealNumbersArray(sealType, theSealNumbers);
	endif;
	
epilog

end;</source>
        <Parameter name="sealType" type="String"/>
        <Parameter name="theSealNumbers" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSealsListAtReceive" id="288a0328-c89f-4686-adf7-c26e1289c287">
        <source>getSealsListAtReceive(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 July 2017	jlgndl1	Initial creation	TFS 5314

*/

vars

	sealCheckTrx : CM_SealCheck;

begin
	
	sealCheckTrx := self.getTransactionByTypeSameTRX( TRANS_TYPE_SEAL_CHECK ).CM_SealCheck;
	
	if sealCheckTrx &lt;&gt; null then
		return sealCheckTrx.getSealNumbersList;
	endif;
	
	return inheritMethod();
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
