        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>useTblData(set: Boolean; _value: Boolean io) updating, mapping, protected;
// ---------------------------------------------------------------------------
// Created:     04 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
