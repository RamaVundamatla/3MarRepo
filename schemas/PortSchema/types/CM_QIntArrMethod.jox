<Class name="CM_QIntArrMethod" id="1c0af737-2f2d-4519-a0a9-bf0a25dd83b7">
    <superclass name="CM_QIntegerMethod"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="b40aaf9e-4b09-4493-bd14-29c2c3d12e86">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields

*/
vars
	oper	: CM_QueryOperator;
	
begin
	if self.isTransient then 
		return;
	endif;
	
	self.allAllowedOperators.purge();
	create oper as CM_QIntArrEquals persistent;
	self.allAllowedOperators.add(oper);

	create oper as CM_QIntArrGreaterThan persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QIntArrLessThan persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QIntArrLessThanEquals persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QIntArrGreaterEquals persistent;
	self.allAllowedOperators.add(oper);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getValueForObject" id="82d45896-17ab-4553-87e0-f566c73713e3">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields

*/
vars
	
begin
	return _obj.sendMsg(self.propertyName);

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="06f50fd9-1e53-415f-a0ae-b373c1c24c8d">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields

*/

vars
	quantity  : Integer;
	returnVal : String;
begin
	if _value.String.isInteger then
		return _value.asStringJMT;
	elseif _value.isKindOf(IntegerArray) then
		foreach quantity in _value.IntegerArray do
			if returnVal = null then
				returnVal := quantity.asStringJMT;
			else
				returnVal := returnVal &amp; ", " &amp; quantity.asStringJMT;
			endif;
		endforeach;
	endif;
	return returnVal;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
