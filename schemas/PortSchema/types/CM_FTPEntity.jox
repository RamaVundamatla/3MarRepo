    <JadeMethod name="addDeleteFailedFiles" id="5966e006-abb1-4e2d-96fb-d5a85dbc9ff6">
        <source>addDeleteFailedFiles(_value : String);
//
//24 Aug 2015	cnwrs1	Par 36815 enable FTP get to continue after a failed file delete by saving off the fileNames
//
vars
	stringArrayOut : StringArrayStateData;
	stringArrayIn : StringArrayStateData;
begin
	global.getExtraData(self.allExtraData, "DeleteFailedFiles", stringArrayOut);
	create stringArrayIn transient;
	if stringArrayOut &lt;&gt; null then
		stringArrayOut.copy(stringArrayIn);
	endif;
	if not stringArrayIn.includes(_value) then
		stringArrayIn.add(_value);
	endif;
	global.setExtraData(self.allExtraData, self, "DeleteFailedFiles", stringArrayIn);
epilog
	delete stringArrayIn;
end;
</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
