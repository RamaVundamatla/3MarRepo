    <JadeMethod name="setTransactionDetails" id="b1b5cdd1-2add-4160-bb0c-e2448bc966bf">
        <updating/>
        <source>setTransactionDetails(_txn : CM_HumidityReading input) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
