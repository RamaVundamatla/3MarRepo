	reservations, quantityReserved : String;
begin

	createCargoReviewData();
	term := self.getTerminal();
	create cargoReviewQueryObj transient;
	create additionalRows transient;
	create groupingRows transient;
	create criteriaHolder transient;
	
	entTableDef := app.myRoot.myEntTableDataRoot.getEntTableDef(ETDef_CGReviewAdditional);
	additionalRows.add(entTableDef.getEntTableRow(ETRow_TotalQuantity));
	additionalRows.add(entTableDef.getEntTableRow(ETRow_Reservations));	
	additionalRows.add(entTableDef.getEntTableRow(ETRow_QuantityReserved));	
	

	
	entTableDef := app.myRoot.myEntTableDataRoot.getEntTableDef(ETDef_CGReviewGrouping);
	groupingRows.add(entTableDef.getEntTableRow(ETRow_CargoTypeDescr));
	groupingRows.add(entTableDef.getEntTableRow(ETRow_MyProduct));
	groupingRows.add(entTableDef.getEntTableRow(ETRow_Commodity));
	groupingRows.add(entTableDef.getEntTableRow(ETRow_CargoGroupId));
	groupingRows.add(entTableDef.getEntTableRow(ETRow_BillOfLading));
	groupingRows.add(entTableDef.getEntTableRow(ETRow_VoyageCode));
	
	cargoReviewQueryObj.deleteGroupings();	
	cargoReviewQueryObj.reset(term,criteriaHolder,groupingRows,additionalRows);

	user := app.getMyUser();
	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,null];
	cargoReviewQueryObj.myEnqController.myTerminal := term;
	cargoReviewQueryObj.myEnqController.myCriteriaLineHolder := criteriaHolder;
	//this terminal only
	criteriaLine := qDef.createCriteriaLine(CM_TrackedItem::myTerminal.name, CM_QueryOperator.Operator_Equal, term);
	criteriaLine.setMyCriteriaLineHolder( criteriaHolder );
	
	criteriaLine := qDef.createCriteriaLine(CM_TrackedItem::cargoType.name, CM_QueryOperator.Operator_Equal, 87821);
	criteriaLine.setMyCriteriaLineHolder( criteriaHolder );
	
	criteriaLine := qDef.createCriteriaLine(CM_TrackedItem::site.name, CM_QueryOperator.Operator_Equal, 3);
	criteriaLine.setMyCriteriaLineHolder( criteriaHolder );

	cargoReviewQueryObj.myEnqController.myContext := self;
	
	cargoReviewQueryObj.reset(term, criteriaHolder, cargoReviewQueryObj.allGroupingRows, cargoReviewQueryObj.allAdditionalRows);
	
	restOfTIs.copy(cargoReviewQueryObj.myEnqController.allObjects);
	cargoReviewQueryObj.doSearch();
	
	querySize := cargoReviewQueryObj.allGroupings.size;
	quantityTotal := cargoReviewQueryObj.allGroupings.at(1).getPropertyValue(ETRow_TotalQuantity).String;
	self.assertTrueMsg( querySize = 4, "Wrong number of grouping rows found in the query.  Expected 1 got " &amp; querySize.String);	
	self.assertTrueMsg( quantityTotal = "10", "Wrong total quantity.  Expected 10 got " &amp; quantityTotal );
	
	//commodity := app.myRoot.allCommodities["COM2"];
	jdo := cargoReviewQueryObj.allGroupings.at(1);	
	createRelReqUsingJDO(jdo, cargoReviewQueryObj, 5, "REL01");
	cargoReviewQueryObj.doSearch();
	
	jdo := cargoReviewQueryObj.allGroupings.at(2);	
	createRelReqUsingJDO(jdo, cargoReviewQueryObj, 4, "REL02");
	createRelReqUsingJDO(jdo, cargoReviewQueryObj, 3, "REL03");
	cargoReviewQueryObj.doSearch();
	
	jdo := cargoReviewQueryObj.allGroupings.at(3);	
	createRelReqUsingJDO(jdo, cargoReviewQueryObj, 12, "REL04");
	cargoReviewQueryObj.doSearch();
	
	jdo := cargoReviewQueryObj.allGroupings.at(4);	
	createRelReqUsingJDO(jdo, cargoReviewQueryObj, 8, "REL05");	
		
	cargoReviewQueryObj.doSearch();
	cargoReviewQueryObj.allGroupingRows.remove(entTableDef.getEntTableRow(ETRow_CargoGroupId));
	cargoReviewQueryObj.allGroupingRows.remove(entTableDef.getEntTableRow(ETRow_BillOfLading));
	cargoReviewQueryObj.doSearch();
	
	
	jdo := cargoReviewQueryObj.allGroupings.at(1);
	querySize := cargoReviewQueryObj.allGroupings.size;
	quantityTotal := jdo.getPropertyValue(ETRow_TotalQuantity).String;
	reservations := jdo.getPropertyValue(ETRow_Reservations).String;
	quantityReserved := jdo.getPropertyValue(ETRow_QuantityReserved).Integer.asStringJMT;
	self.assertTrueMsg( querySize = 2, "Wrong number of grouping rows found in the query.  Expected 2 got " &amp; querySize.String);	
	self.assertTrueMsg(quantityTotal = "25", "Wrong total quantity.  Expected 25 got " &amp; quantityTotal );
	self.assertTrueMsg(reservations = "REL01(5),REL02(4),REL03(3)", "Wrong Reservation.  Expected REL01(5),REL02(4),REL03(3) got " &amp; reservations);
	self.assertTrueMsg(quantityReserved = "12", "Wrong quantity reserved.  Expected 12 got " &amp; quantityReserved );	
	
	
	jdo := cargoReviewQueryObj.allGroupings.at(2);
