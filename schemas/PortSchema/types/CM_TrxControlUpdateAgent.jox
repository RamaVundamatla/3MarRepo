    <JadeMethod name="trxUpdateTCPConnectionDetails" id="449f22d3-7250-4161-9512-ca93c31aba61">
        <updating/>
        <source>trxUpdateTCPConnectionDetails(_pxyTCPConnectionDetails: CM_DeviceTCPConnectionDetails input;
																	_realTCPConnectionDetails: CM_DeviceTCPConnectionDetails input;
																	_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2016	cnwrh7	Initial creation

*/
vars
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	app.setContinueCMExceptions(false);

	beginTransaction;
	app.myUtilityUA.utlUpdateTCPConnectionDetails (_pxyTCPConnectionDetails, _realTCPConnectionDetails,_passport);
epilog
