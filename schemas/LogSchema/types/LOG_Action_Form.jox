    <JadeMethod name="doSave" id="e759da87-500d-4957-b78b-d97ffa010d25">
        <updating/>
        <source>doSave(_exiting : Boolean) : Boolean protected, updating;

vars
	tmpLogDef 	: CMIF_DocketLogDef;
	rtnValue 	: Boolean;
	idx,
	numRows,
	theColumn	: Integer;
	cell		: JadeTableCell;
	
begin
	// Get tracked items from appropriate reference.
	app.mousePointer := MousePointer_HourGlass;
	delete self.myCMIFMonitor;
	create self.myCMIFMonitor transient;
	
	app.myPassport.setMyCMIFMonitor(self.myCMIFMonitor);
   	self.myCMIFMonitor.myParent := self;
   	self.myCMIFMonitor.message := app.getErrorString(Initialising);
	self.modalDialogShow(null, null, null, null, self.getActionDescription, self.myCMIFMonitor.message);
	
	if self.selection = LOGSPECS then
		rtnValue := self.doSaveMultiDef();
		if rtnValue then
			if (not _exiting) then
				self.doRefresh();
			endif;
		endif;
		return rtnValue;
	endif;

	self.allTrackedItems.clear;

	if self.selection = LOGID then
		if self.myLog &lt;&gt; null then
			self.allTrackedItems.add(self.myLog);
		endif;

	elseif self.selection = LOGDOCKET then
		if self.mySelectedDocketDef &lt;&gt; null then
			self.mySelectedDocketDef.allTi.copy(self.allTrackedItems);
		endif;

	elseif self.selection = LOGLOCATION then
		//PAR 9814
		//if self.mySelectedDocketDef &lt;&gt; null then
		//	self.mySelectedDocketDef.allTi.copy(self.allTrackedItems);
		//endif;
		numRows := self.tblSelectData.rows;
		foreach idx in 2 to numRows do
			if self.tblSelectData.accessRow(idx).selected then
				tmpLogDef := self.tblSelectData.accessRow(idx).itemObject.CMIF_DocketLogDef;
				if tmpLogDef &lt;&gt; null then
					tmpLogDef.allTi.copy(self.allTrackedItems);
				endif;
			endif;
		endforeach;
		
	// 17/09/2008 cnwar2 #17957 (CCMS1095)
	elseif self.selection = LOGLOCATDOCKET then
		numRows := self.tblSelectData.rows;
		theColumn := self.tblSelectData.getColumnByRowName(ETRow_SelectedDocket);
		if theColumn &lt;&gt; 0 then
			foreach idx in 2 to numRows do
				cell :=	self.tblSelectData.accessCell(idx, theColumn);
				if cell.text.Integer.Boolean = true then
					tmpLogDef := self.tblSelectData.accessRow(idx).itemObject.CMIF_DocketLogDef;
					if tmpLogDef &lt;&gt; null then
						tmpLogDef.allTi.copy(self.allTrackedItems);
					endif;
				endif;
			endforeach;
		endif;

	elseif self.selection = LOGSPECS then
		if self.mySelectedDocketDef &lt;&gt; null then
			self.mySelectedDocketDef.allTi.copy(self.allTrackedItems);
		endif;
	endif;
	
	if self.allTrackedItems.size &gt; 0 then 
		rtnValue := self.saveTrackedItems();
		if rtnValue then
			if (not _exiting) then
				self.doRefresh();
			endif;
		endif;
	endif;
	
epilog
	
   	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;
	app.mousePointer := MousePointer_Default;	
	return rtnValue;
end;</source>
        <access>protected</access>
        <Parameter name="_exiting" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
