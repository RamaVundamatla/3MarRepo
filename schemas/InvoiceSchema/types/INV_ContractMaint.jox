    <JadeMethod name="doNotableClear" id="a92ada4a-56b3-4dd1-9d43-99c4e666417d">
        <source>doNotableClear();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Feb 2023 navtnr20	TFS CR 55646 Task 55664: UI - Contracts Maint

*/

vars

	removedNotification : Integer;
	anObject : Object;
begin

	foreach anObject in self.allNotableObjects do
		endNotification(anObject, self.myTerminal.getTerminalEvent(Event_InvContractDtlUpdate));
		endNotification(anObject, EventFileAdd);
		endNotification(anObject, EventFileDelete);
	endforeach;
	
	self.allNotableObjects.clear;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPermissions" id="461bfad2-5d7b-4aab-af18-5e3e4d99134b">
        <source>doPermissions();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Feb 2023 navtnr20	TFS CR 55646 Task 55664: UI - Contracts Maint
20/06/2023	navkc1		CR 55653 Task 58729: EUP - Contract Vol Based Initialise Accumulations
07 November 2023	navrv30	Bug 58391: EUP - Audits for Invoice Copy
21 Aug 2024	navnk30	Bug 65602: FR - 54089 - Invoice Contract - permissions
*/

vars

begin
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnRemove.enabled := false;
		self.btnCopy.enabled := false;
		self.btnAdd.enabled := false;
		self.btnUpdate.enabled := false;
//		self.tblData.enabled := false;		//20.08.2024 navnk30 #65602
		self.btnClose.enabled := true;
		self.btnAttachments.enabled := true;
		self.btnSave.enabled := false;
		self.txtDescription.enabled := false;
		self.txtContractID.enabled := false;
		self.cmbDebtor.enabled := false;
		self.mskContractFromEnd.enabled := false;
		self.mskContractFromEndTime.enabled := false;
		self.mskContractFromStart.enabled := false;
		self.mskContractFromStartTime.enabled := false;
		self.chkActive.enabled := false;
		self.chkPrimary.enabled := false;
		self.btnAccumulate.enabled := false;  //20/06/2023	navkc1	CR 55653 Task 58729
		//self.btnAudit.enabled := false;			//11/07/2023 navrv30 #58391		//20.08.2024 navnk30 #65602
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRemove" id="7221a904-a132-4167-8495-c34c59cb3f3f">
        <updating/>
        <source>doRemove(_obj : CM_Object)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Feb 2023 navtnr20	TFS CR 55646 Task 55664: UI - Contracts Maint
16 October 2023	navmv20	Bug 60893: FR - 54089 - Invoice Contract screens - Modal mode
*/

vars
	theReturn : Integer;
	contract	: CM_InvoiceContractDetails;
	form : INV_ContractRateMaint; //16 October 2023	navmv20	Bug 60893
	detailOnRateMaintForm : CM_InvoiceContractDetails; //16 October 2023	navmv20	Bug 60893

begin
	contract := _obj.CM_InvoiceContractDetails;
	if contract = null then
		app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
		return;
	endif;
	
	if app.msgBox(app.getErrorString2(Sure_want_remove_InvContr_Det, contract.auditId(),null), 
							app.getErrorString(CONFIRM_REMOVAL), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;
	
	//16 October 2023	navmv20	Bug 60893 - start
	form := self.myContractRateMaint;
	if form &lt;&gt; null then
		detailOnRateMaintForm := form.myContractDetails;
		if contract = detailOnRateMaintForm then
			form.unloadForm();
		endif;
	endif;
	//16 October 2023	navmv20	Bug 60893 - end
	
	while true do
 	app.myTrxDA.trxDeleteInvContractDtl(contract, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Invoice_contract_delete), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="doTblCFContMenu" id="6fe85f10-edf9-4e2e-91f6-b3f008e2a50c">
        <updating/>
        <source>doTblCFContMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jan 2023 navtnr20	TFS CR 55622 Task 55692: UI - Shipping Terms Maint

*/

vars
	canEdit		: Boolean;
	x1,
	y1			: Real;
begin
	x1 := x;
	y1 := y;
	if (not mouse) then
	    x1 := 1;
	    y1 := 1;
	endif;
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);
	self.mnuColumnOrganiser.visible := true;
	self.mnuColumnOrganiser.userObject := self.tblData;
	if app.isAllowedToInspect then
		self.mnuInspectObject.visible := true;
	else
		self.mnuInspectObject.visible := false;	
	endif;	   
	self.popupMenu(self.mnuContextMenu, x1.Integer, y1.Integer);
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
