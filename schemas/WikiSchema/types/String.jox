<PrimType name="String">
    <JadeMethod name="trimWhiteSpace" id="8fed3634-9439-4498-9071-6f90ea0ffc6f">
        <source>trimWhiteSpace() : String ;
 
constants
        WhiteSpaceCharacters : String = Cr &amp; Lf &amp; Tab &amp; " " ;

vars
        startPos : Integer ;
        endPos : Integer ;
        str : String ;
begin 
        if self = null then
                return null;
        endif;

        // First lets find the first non-white-space character
        startPos := 1 ;
        self.scanWhile( WhiteSpaceCharacters, startPos );
 
        // Does string contain nothing but white-space characters?  If so, return null.
        if startPos = 0 then
                return null;
        endif;
 
        // Now lets find the last non-white-space character by reversing self so we can scanWhile on our
        // white-space characters and then calculate the last non-white-space character based on the string length.
        // We need to add one during this calculation to get the actual last non-white-space character position.
        str := self.reverse;
        endPos := 1 ;
        str.scanWhile( WhiteSpaceCharacters, endPos );
        endPos := self.length - endPos + 1 ;

        // Now we want to take from the startPos for the appropriate length which is endPos - startPos + 1 so we
        // make sure to include the last non-white-space character in the final resultant string
        str  := self[startPos : endPos - startPos + 1 ]; 
 
        return str; 
end;

</source>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
