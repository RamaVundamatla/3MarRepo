    <JadeMethod name="setProxyForCreate" id="fe29c861-abbc-4282-9188-906f93b19389">
        <updating/>
        <source>setProxyForCreate(_slotController : CM_VoyageROROController; _moveType : Integer; _isLoad : Boolean; _qty : Decimal) updating;
// ---------------------------------------------------------------------------
// Created:     02 June 2002 by cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpSlot		: CM_VoyageROROController;
begin
	if _slotController = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_slotController', null, null);
		return;
	endif;

	self.moveType := _moveType;
	self.isLoad := _isLoad;
	self.isDischarge := not _isLoad;
	self.quantity := _qty;


	// Do this check AFTER setting moveType above as the
	// error seting uses moveTypeString
	if (_isLoad and _moveType = DISCHARGE_MOVETYPE) or
	   ((not _isLoad) and _moveType = LOAD_MOVETYPE) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid _isLoad (' &amp; _isLoad.String &amp;
					') for _moveType (' &amp; self.moveTypeString &amp; ')');
		return;
	endif;
	
	self.myROROController := _slotController;

	
end;</source>
        <Parameter name="_slotController" type="CM_VoyageROROController"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_qty" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setProxyForCreateVA" id="3378aebd-595d-4708-b38d-e838f2b95563">
        <updating/>
        <source>setProxyForCreateVA(_roroLC : CM_VoyageROROController; _moveType : Integer; _isLoad : Boolean; _numItems : Integer; _voyAlloc : CM_VoyageAllocation) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 December 2009	cnwas3	Initial creation

*/

vars
	voyAlloc : CM_VoyageAllocation;
begin

	if _roroLC = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_roroLC', null, null);
		return;
	endif;

	self.setMoveType(_moveType);
// PAR 31162	self.isLoad := _isLoad;
	self.quantity := _numItems;
	
	if (_isLoad and _moveType = DISCHARGE_MOVETYPE) or
	   ((not _isLoad) and _moveType = LOAD_MOVETYPE) then

	   app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid _isLoad (' &amp; _isLoad.String &amp;
					') for _moveType (' &amp; self.moveTypeString &amp; ')');
		return;
	endif;
	
	
	self.myLayout := null;
	
	
	self.myROROController := _roroLC;
	self.code := _roroLC.ident;
	
	if _voyAlloc &lt;&gt; null then	
			self.allAllocations.clear(); // do not purge
			self.allAllocations.add(_voyAlloc);		
	endif;

end;</source>
        <Parameter name="_roroLC" type="CM_VoyageROROController"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_numItems" type="Integer"/>
        <Parameter name="_voyAlloc" type="CM_VoyageAllocation"/>
    </JadeMethod>
    <JadeMethod name="setSeqNumber" id="6de033ad-ac87-46de-83b6-c701240a98a8">
