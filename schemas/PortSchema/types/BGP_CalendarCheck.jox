<Class name="BGP_CalendarCheck" id="df5d508d-975e-4c00-ae8a-8318a0bf3760">
    <superclass name="BGP_Request"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Calendar Check&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <ImplicitInverseRef name="allSelectedEmailAddresses" id="b686a7aa-6797-4423-b327-5d35db7d955b">
        <memberTypeInverse/>
        <type name="CM_EmailAddressByAddressDict"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <PrimAttribute name="numDaysNotice" id="e6cdc7db-0b37-404b-9cc3-14488f388ebc">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="action" id="68d24886-a8c3-4fc9-99bc-619b197d3ed5">
        <updating/>
        <source>action(): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 November 2010	cnwndl1	Initial creation

*/

vars

begin
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initRequestFromTask" id="63298c02-0680-40a6-84e8-96d7c52c52c1">
        <updating/>
        <source>initRequestFromTask(_task: CM_AutoTaskCalendarCheck) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 November 2010	cnwndl1	Initial creation

*/

vars

	user : CM_User;

begin
	
	user := _task.myUser;
	if global.isValidObject(user) then
		self.myUser	:= user;
	endif;
	self.myTerminal	:= _task.myTerminal;
	
	self.numDaysNotice	:= _task.numDaysNotice;	
	_task.allSelectedEmailAddresses.copy(self.allSelectedEmailAddresses);
	
	self.initRequestEvent(true, false, _task);

epilog

end;</source>
        <Parameter name="_task" type="CM_AutoTaskCalendarCheck"/>
    </JadeMethod>
</Class>
