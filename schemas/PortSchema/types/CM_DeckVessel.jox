    <JadeMethod name="validateCreate" id="6c103fed-7b5d-415f-91e2-943b055d36e6">
        <source>validateCreate(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 May 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	vesselStructure : CM_ROROVesselStructure;
begin
	inheritMethod(_passport);


	vesselStructure:=self.getROROStructure;
	if vesselStructure = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Roro_vessel_structu_null),null,null );
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Roro_vessel_structu_null),null,null ); // cnwdb2	PAR 35364
		return;
	endif;
	if vesselStructure.allDecksByCode[self.code] &lt;&gt; null then
		app.raiseCMException1(Duplicate_code_must_unique,app.getErrorString(Vessel) &amp; " " &amp; app.getErrorString(Deck),null,null);
	endif;

	
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
