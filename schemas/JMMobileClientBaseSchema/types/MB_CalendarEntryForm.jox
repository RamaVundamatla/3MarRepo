    <JadeMethod name="btnCancel_click" id="7bfb7798-3813-4332-bcb6-c402fec22f7c">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		07 February 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.modalResult	:=	self.MB_MODAL_CANCEL;
	self.unloadForm();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnNow_click" id="6ba6d1b0-6693-49b1-aafc-2671aeb43b59">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnNow_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		07 February 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	txtTime.text		:=	app.actualTimeServer().time.currentLocaleFormatJMT();
	self.aTime			:=	txtTime.text.trimBlanks().Time;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOk_click" id="b78131ab-e7e6-4afa-ad20-8c0e8b0df33c">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOk_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		07 February 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;

	if self.doValidate() then
		self.doUpdateDateTime();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnToday_click" id="0add674d-d0de-49ea-a6a2-c5810c61d7ad">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnToday_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		07 February 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	txtDate.setTextFromDate(app.actualTimeServer().date);
	self.aDate			:=	txtDate.text.trimBlanks().Date;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUpdateDateTime" id="aac3f413-957b-4c06-8cf1-2033dba561cb">
        <updating/>
        <source>doUpdateDateTime() updating, protected;
// --------------------------------------------------------------------------------
// Created:		01 February 2006 by cnwdad1
//
// Purpose:		Updates the date/time values, then closes the form with the modal
//				result set to "select".
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.aDate &lt;&gt; null then
		self.aDate	:=	txtDate.text.Date;
		self.aTimeStamp.setDate(self.aDate);
	endif;
	
	if self.aIsTimeStamp and self.aTime.isValid() then
		self.aTime	:=	txtTime.text.Time;
		self.aTimeStamp.setTime(self.aTime);
	endif;
	
	self.modalResult	:=	self.MB_MODAL_SELECT;
	self.unloadForm();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doValidate" id="93babc0f-6246-4aaf-a5cf-79f47819cdaf">
        <source>doValidate():Boolean protected;
// --------------------------------------------------------------------------------
// Created:		01 February 2006 by cnwdad1
//
// Purpose:		Validates the entered/selected date (and time if appropriate).
//
// Parameters:	None
//
// Returns:		True if the date/time are valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	today, currentDate		: Date;
	currentTime		: Time;
	errorMessage	: String;
	isDateValid		: Boolean;

begin
	isDateValid	:=	true;
	
	if txtDate.text.trimBlanks() &lt;&gt; null then
		currentDate	:=	txtDate.text.trimBlanks().Date;
		
		if not currentDate.isValid() 
		or (currentDate.year &lt; 1950 or currentDate.year &gt; (today.year + 50)) then // PAR 18908
			isDateValid			:=	false;
			errorMessage		:=	"The format of the date is incorrect. Please use 'dd/mm/ccyy' format";
			txtDate.setFocus();
		endif;
	endif;
	
	if self.aIsTimeStamp then
		if txtTime.text &lt;&gt; null then
			currentTime	:=	txtTime.text.trimBlanks().Time;
		endif;
		
		if not currentTime.isValid() then
			if errorMessage = null then
				errorMessage	:=	"The format of the time is incorrect. Please use 'HH:mm' format";
			else
				errorMessage	:=	errorMessage &amp; CrLf &amp; "The format of the time is incorrect. Please use 'HH:mm' format";
			endif;
			
			if isDateValid then
				txtTime.setFocus();
			endif;
		endif;
	endif;
	
	if errorMessage = null then
		return true;
	else
		app.msgBox(errorMessage, "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return false;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDateTime" id="79d18c6f-6154-4771-8468-cf6bfa533a52">
        <updating/>
        <source>setDateTime(_date:Date; _time:Time; _isTimeStamp:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		01 February 2006 by cnwdad1
//
// Purpose:		Sets the receiver's date.
//
// Parameters:	_date - The default date for the receiver.
//				_time - The default time for the receiver.
//				_isTimeStamp - True if the form is to handle a timestamp, as opposed
//					to just handling a date only.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aDate		:=	_date;
	
	if _isTimeStamp then
		self.aTime			:=	_time;
		self.aTimeStamp.setDate(_date);
		self.aTimeStamp.setTime(_time);
		self.aIsTimeStamp	:=	_isTimeStamp;
	endif;
end;</source>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_time" type="Time"/>
        <Parameter name="_isTimeStamp" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="5d0a255a-e652-47d2-b549-1a4e80129e9c">
        <updating/>
        <source>setupForm() updating;
// --------------------------------------------------------------------------------
// Created:		07 February 2006 by cnwdad1
//
// Purpose:		Standard form setup method.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	self.maxButton		:=	false;
	self.minButton		:=	false;
	txtDate.mask		:=	"dd\/MM\/yyyy";
	
	if self.aIsTimeStamp then
		txtTime.mask	:=	"hh:mm";
	endif;
	
	if self.aDate = null then
		self.aDate	:=	app.actualTimeServer.date();// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
		self.aTimeStamp.setDate(self.aDate);
	endif;
	
	if self.aIsTimeStamp and not self.aTime.isValid() then
		self.aTime	:=	app.actualTimeServer.time();// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
		self.aTimeStamp.setTime(self.aTime);
	endif;
	
	txtDate.text	:=	self.aDate.shortFormatJMT();
	txtTime.text	:=	self.aTime.currentLocaleFormatJMT();
	txtDate.setFocus();
	btnOk.default	:=	true;
end;</source>
    </JadeMethod>
</GUIClass>
