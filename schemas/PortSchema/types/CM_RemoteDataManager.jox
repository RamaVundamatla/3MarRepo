    <JadeMethod name="create" id="7e1a41da-2b91-450c-b267-39e02aa7515c">
        <updating/>
        <source>create() updating;


begin

	// TEMPORARY METHOD.
	self.myRoot :=	CM_RemoteDataRoot.firstInstance;
	if self.myRoot = null then
		beginTransaction;
		create self.myRoot persistent;
		commitTransaction;
	endif;
	
			
end;</source>
    </JadeMethod>
    <JadeMethod name="localLockExceptionHandler" id="fcaacec0-272c-4fe0-977b-338be4917f82">
        <source>localLockExceptionHandler(le : LockException) : Integer;
/*

Date		Who		Reason
28/01/2014	cnwjre1	32212 Copy of app.alertLockExceptionHandler with extra code to abort and clear 
*/

constants
	RetryTimeout	= 20000;			// 20 seconds

vars
	lockedBy		: Process;
	lockedByUserCode : String;
	invalidProcess	: Boolean;
	returnVal		: Integer;
	startRetry		: Decimal[20];
	
begin

	returnVal := Ex_Pass_Back;
	
	lockedBy := le.targetLockedBy;
 	if lockedBy = null then
		invalidProcess := true;
	else
		on Exception do app.handleDeletedObject(exception, lockedBy, invalidProcess);
 		lockedByUserCode := lockedBy.userCode;
		on Exception do null;
 	endif;
	if invalidProcess then
		lockedByUserCode := 'not available';
	endif;

	app.writeLog('INFO &gt;&gt; Alert lock found, (' &amp; le.errorCode.String &amp; ') Locked by ' &amp; lockedByUserCode , LogINFO);
	startRetry := app.relativeMachineTime();
	if tryLock(le.lockTarget, le.lockType, le.lockDuration, RetryTimeout) then
		app.writeLog('INFO &gt;&gt; Alert lock cleared on retry after ' &amp; (app.relativeMachineTime() - startRetry).String &amp; ' ms', LogINFO);

		returnVal := Ex_Continue;				// must have the lock if we get to here
		return returnVal;
	endif;
	
	// Didn't get the lock on retry, so pass back the the exception
	app.writeLog('INFO &gt;&gt; Alert lock exception generated (' &amp; le.errorCode.String &amp; ') Locked by ' &amp; lockedByUserCode , LogINFO);
	app.writeLogLockException(le);

	// 32212 additional clearing code so the next transaction runs OK
	app.cmsAbortTransaction();
	app.myPassport.finaliseTransaction(TRXStatus_Aborted);
	//	notify the LockKeeper that a transaction is ending
	app.lockKeeperNotifyEndActivity(app.serverTimestampAtTrxStart, false, app.myPassport);
	// end 32212
	
	returnVal := Ex_Pass_Back;		// let another handler (in this case app.alertExceptionHandler) deal with it

epilog
	return returnVal;

end;</source>
        <Parameter name="le" type="LockException"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
