<CollClass name="CM_EventTransByTypeDateTime" id="9aade957-2d23-4252-89e7-7d7838955a46">
    <duplicatesAllowed/>
    <loadFactor>66</loadFactor>
    <memberType name="CM_EventTransaction"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="eventTrans"/>
    <MemberKey>
        <keyPath>
            <ExplicitInverseRef name="CM_EventTransaction::myEventType"/>
        </keyPath>
        <property name="CM_EventType::type"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_EventTransaction::dateTime"/>
    </MemberKey>
    <JadeMethod name="getFirstOfType" id="3e7c970d-11cd-4d82-8da8-dbf7e996476d">
        <source>getFirstOfType( _type : Integer ):CM_EventTransaction;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2021	navndl1	Initial creation	TFS 51199

*/

vars

	first : CM_EventTransaction;

begin

	first := self.getAtKeyGeq( _type, null );
	if first &lt;&gt; null then
		if first.myEventType = null or first.myEventType.type &lt;&gt; _type then
			first := null;
		endif;
	endif;
	
	return first;

epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="CM_EventTransaction"/>
    </JadeMethod>
</CollClass>
