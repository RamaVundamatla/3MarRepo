    <JadeMethod name="pxyCreateUpdateProxy" id="9578622b-1789-462a-ada2-dea0fb4e2504">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2014	cnwndl1	Initial creation	Par 35346 / CCMS 1408

*/

vars

	pxyWellcarVisit : CM_WellcarVisit;
	well : CM_WellcarWellVisit;
	pxyWell : CM_WellcarWellVisit;

begin

	pxyWellcarVisit := inheritMethod();
	
	foreach well in self.allWagonWellsArray do
		pxyWell := well.pxyCreateUpdateProxy();
		pxyWell.pxySetMyVisit( pxyWellcarVisit );
	endforeach;
	
	return pxyWellcarVisit;

epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
</Class>
