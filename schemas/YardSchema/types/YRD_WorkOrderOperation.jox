    <JadeMethod name="buildJobsheet" id="a3a39d27-077a-49ff-ae83-b38b3dde7d50">
        <updating/>
        <source>buildJobsheet() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 March 2025	navbs1	Initial creation Story MTN-34213: MTN - Work Order Operations screen loading data twice on start-up

*/

vars

begin
    if self.chkJobSheet.value = true then
		self.tblJobSheet.visible		:= true;
		self.dkbRight.visible 	 		:= true;
		self.tblJobsUnallocated.width 	:= self.dkbUnAllocTop.width - 10;
		self.tblWlesUnallocated.width 	:= self.dkbUnAllocTop.width - 10;
		self.setupNotifications();
	else
		self.tblJobSheet.visible		:= false;
		self.dkbRight.visible 			:= false;
		self.tblJobsUnallocated.width 	:= self.dkbUnAllocTop.width - 20;
		self.tblWlesUnallocated.width 	:= self.dkbUnAllocTop.width - 20;
		self.setupNotifications();
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="canCompleteToDoWLE" id="2679ec60-9f8a-4042-9647-130f92f64d06">
        <source>canCompleteToDoWLE(_wle: CM_WOToDoWLE) : Boolean;
/*
Purpose - 	
Who - NAVAB1
Date - 27SEP2023
ADO - CR 60699 TASK 60700 
*/

vars
	task : CM_ToDoTask;
	toDoTask : CM_ToDoTask;
	toDoTaskDesc : CM_ToDoTaskDesc;
	trxType : CM_TransactionType; 
begin
	toDoTaskDesc := _wle.job.CM_WOToDoTaskJob.myToDoTaskDesc;
	trxType := app.myRoot.allTransactionTypes[toDoTaskDesc.trxTypeOnCompletion]; 
	if trxType &lt;&gt; null and trxType.trxGroup &lt;&gt;  TRANS_TYPE_GROUP_WO then 
		if _wle.myTrackedItem = null then
			return false;
		endif;
	endif;

	toDoTask := self.getToDoTask(_wle);

	if toDoTask = null or toDoTask.status = STATUS_COMPLETE then
		return false;
	endif;
	
	return app.myPassport.myUser.canCompleteTodoTask(toDoTask.myTerminal, toDoTask.toDoTaskDesc);

epilog

end;</source>
        <Parameter name="_wle" type="CM_WOToDoWLE"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="chkBulkMode_click" id="630cbd59-4d5d-419c-b149-e37abd5d938b">
