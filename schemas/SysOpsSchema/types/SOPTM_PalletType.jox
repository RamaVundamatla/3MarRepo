    <JadeMethod name="doSave" id="e68c723a-7bc2-4808-8a9f-d6b5a2b4f378">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2017	cnwndl1	Initial creation	TFS 3424

*/

vars

	theForm : SOP_TableMaintForm;
	
	lCode : String;
	lDescription : String;
	lIsFault : Boolean;
	lIsNotAvail : Boolean;
	lHeatTreated : Boolean;
	
	proxyPalletType : CM_PalletType;
	
	rtnValue : Boolean;

begin

	theForm := self.myForm; 
	
	lCode :=	theForm.tblInput1.getValueByName(ETRow_Code).String[1:30];
	lDescription :=	theForm.tblInput1.getValueByName(ETRow_Description).String[1:100];
	lIsFault := theForm.tblInput1.getValueByName(ETRow_IsDefault).Boolean;
	lIsNotAvail := not theForm.tblInput1.getValueByName(ETRow_IsAvailableForEntry).Boolean;
	lHeatTreated := theForm.tblInput1.getValueByName(ETRow_HeatTreated).Boolean;
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_PalletType transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	proxyPalletType := theForm.myProxyObject.CM_PalletType;
	proxyPalletType.setProxy(	lCode, 
								lDescription,
								lIsFault,
								lIsNotAvail
								);
	proxyPalletType.setExtraProxyDetails( lHeatTreated );
								
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreatPalletType(proxyPalletType, theForm.myCurrentObject, app.myPassport);
		rtnValue	:=	app.myPassport.trxCompletedOK;
		
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdatePalletType(proxyPalletType, app.myPassport);
		rtnValue	:=	app.myPassport.trxCompletedOK;
		
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
		
	endif;
	
	return rtnValue;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="f6e5c86d-4031-49d3-a2ec-cb0df7397c9d">
        <source>getCollection(): Collection;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2017	cnwndl1	Initial creation

*/

vars

	handlingType : CM_HandlingType;
	iter :Iterator;
	startObject : CM_HandlingSubType;
	handlingSubType : CM_HandlingSubType;

begin

	self.allHandlingSubTypes.clear();
	handlingType := app.myRoot.allHandlingTypes.getAtKey(TI_HandlingType_Pallets);
	
	handlingType.getValidSubTypes( self.allHandlingSubTypes, true );

	return self.allHandlingSubTypes;

epilog

	delete iter;

end;</source>
        <ReturnType type="Collection"/>
    </JadeMethod>
