    <JadeMethod name="getStorageDaysRWR" id="db2fddfe-087c-43b1-a3cd-01878acdd2b7">
        <source>getStorageDaysRWR():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2018	jlgndl1	Initial creation	TFS 42557

*/

vars

begin

	if self.myTransactionTI = null then
		return 0;
	endif;
	
	if self.myTransactionTI.type &lt;&gt; TRANS_TYPE_STORAGE then
		return 0;	
	endif;


	return self.calculateStorageDays();

epilog

