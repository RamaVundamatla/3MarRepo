<Class name="CM_QStrCustDocLicenseMethod" id="54478b58-7b47-4a53-8c06-92a9acccee13">
    <superclass name="CM_QStringLookupMethod"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="a57a2157-7f3c-41c3-8b44-5b34e0978dc6">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars
	operator	: CM_QStringIsOneOf;
begin
	if self.isTransient() then
		return;
	endif;
	
	create operator as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(operator);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getControlNameForOperator" id="14073c92-16b5-485f-bc62-1bd8f1936806">
        <source>getControlNameForOperator(_operator: CM_QueryOperator): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars

begin
	
	if CM_QReferenceLookup.hasInstance(_operator) then
		return 'cmbCustDocLicense';
	endif;

epilog

end;</source>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValueForObject" id="9994909e-f3c4-47f0-b4ff-2c2b2076158d">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars
	licenseCode	: String;
	license		: CM_CustomLicense;
	terminal	: CM_Terminal;
	
begin

	if self.propertyName = CM_TrackedItem::getCustomDocLicenseCodeForSel.name then
		licenseCode := _obj.sendMsg(self.propertyName).String;
		
		if self.propertyClassName = CM_TrackedItem.name then
			terminal := _obj.CM_TrackedItem.myTerminal;
		elseif self.propertyClassName = CM_TITransaction.name then
			terminal := _obj.CM_TITransaction.myTerminal;
		endif;
		
		if terminal = null then
			return inheritMethod(_obj, _op);
		endif;
		
		license := terminal.allCustomLicenses[licenseCode];
		
		if license &lt;&gt; null then
			return license.code;
		endif;
		
		return inheritMethod(_obj, _op);
		
	else
		return inheritMethod(_obj, _op);
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="13b3ec2f-eea7-4722-aee2-9090cf8a7285">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query
*/

vars
	selectorCriteriaLine	: CM_SelectorCriteriaLine;
	userTerminal			: CM_UserTerminal;
	terminal				: CM_Terminal;
	objSetTerminal			: ObjectSet;
	multiTerminal			: Boolean;
	obj						: Object;
	custDocLicense			: CM_CustomLicense;
begin

	_combo.clear();
	
	// Create transients
	create objSetTerminal transient;
	
	foreach selectorCriteriaLine in _params.allCriteriaLines do
		// Get selected Terminals
		if selectorCriteriaLine.myQueryProperty.propertyName = 'myTerminal' or
			selectorCriteriaLine.myQueryProperty.propertyName = 'getTerminal' then
				selectorCriteriaLine.myQueryOperator.getSearchValueAsObjectSet(objSetTerminal);
		endif;
	endforeach;
	
	// If no Terminal selected, get it from user's access
	if objSetTerminal.isEmpty() then
		foreach userTerminal in app.myPassport.myUser.allUserTerminals do
			if userTerminal.getMyTerminal() &lt;&gt; null then
				objSetTerminal.add(userTerminal.getMyTerminal());
			endif;
		endforeach;
	endif;
	
	// Set is more than 1 terminal
	multiTerminal := (objSetTerminal.size() &gt; 1);
	
	foreach obj in objSetTerminal do
		
		foreach terminal in objSetTerminal as CM_Terminal do
			foreach custDocLicense in terminal.allCustomLicenses do
				if multiTerminal then
					_combo.itemObject[_combo.addItem(custDocLicense.code &amp; " - " &amp; custDocLicense.description&amp; " ( " &amp; obj.CM_Terminal.code &amp; ")" )] := custDocLicense;
				else
					_combo.itemObject[_combo.addItem(custDocLicense.code &amp; " - " &amp; custDocLicense.description)] := custDocLicense;
				endif;
			endforeach;
		endforeach;
	endforeach;

epilog
	delete objSetTerminal;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="59f024c3-481f-4da2-b9b7-79bd7995bd9a">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars
	selectorCriteriaLine	: CM_SelectorCriteriaLine;
	custDocLicense				: CM_CustomLicense;
	selectionValue			: Integer;
	idx						: Integer;
	userTerminal			: CM_UserTerminal;
	objSetTerminal			: ObjectSet;
	terminal				: CM_Terminal;
	obj						: Object;
	multiTerminal			: Boolean;
begin
	
	_tbl.clear();
	_tbl.rows := 0;
	
	create objSetTerminal transient;
	
	foreach selectorCriteriaLine in _params.allCriteriaLines do
		// Get selected Terminals
		if selectorCriteriaLine.myQueryProperty.propertyName = 'myTerminal' or
			selectorCriteriaLine.myQueryProperty.propertyName = 'getTerminal' then
				selectorCriteriaLine.myQueryOperator.getSearchValueAsObjectSet(objSetTerminal);
		endif;
	endforeach;
	
	// If no Terminal selected, get it from user's access
	if objSetTerminal.isEmpty() then
		foreach userTerminal in app.myPassport.myUser.allUserTerminals do
			if userTerminal.getMyTerminal() &lt;&gt; null then
				objSetTerminal.add(userTerminal.getMyTerminal());
			endif;
		endforeach;
	endif;
	
	// Set is more than 1 terminal
	multiTerminal := (objSetTerminal.size() &gt; 1);
	
	foreach terminal in objSetTerminal as CM_Terminal do
		// Only process selected banks
		foreach custDocLicense in terminal.allCustomLicenses do
			selectionValue := 0;
			if _operator &lt;&gt; null then
				if _operator.CM_QStringIsOneOf.allSelectionValues.includes(custDocLicense.code) then
					selectionValue := 1;
				endif;
			endif;
			
			if multiTerminal then
				idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; custDocLicense.code &amp; " - " &amp; custDocLicense.description&amp; " ( " &amp; obj.CM_Terminal.code &amp; ")" );
			else
				idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; custDocLicense.code &amp; " - " &amp; custDocLicense.description);
			endif;
			_tbl.accessRow(idx).itemObject := custDocLicense;
			_tbl.row := idx;
			_tbl.change(_tbl);
		endforeach;
	endforeach;

epilog
	delete objSetTerminal;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="8a387c69-2ab4-47d4-835b-abb1c88e9e38">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars
	custDocLicense		: CM_CustomLicense;
	stringArray		: StringArray;
	numRows,
	index			: Integer;
	string			: String;
begin
	create stringArray transient;

	numRows := _tbl.rows;
	
	foreach index in (_tbl.fixedRows + 1) to numRows do
		string := _tbl.accessCell(index, 1).text;
		
		if string = TableCheckBox_Selected then
			custDocLicense := _tbl.accessRow(index).itemObject.CM_CustomLicense;
			stringArray.add(custDocLicense.code);
		endif;
	endforeach;
	
	_op.setSearchValue(stringArray);

epilog
	delete stringArray;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="aefefd38-9ee5-4f02-a224-869b26906f3f">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars

begin
	if _value.isKindOf(CM_CustomLicense) then
		if _value &lt;&gt; null then
			return _value.CM_CustomLicense.code;
		else
			return null;
		endif;
	else
		return _value.String;
	endif;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="0824ad1d-9687-423e-92ea-9b2910f07fc8">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars
	invalidObj 	: Boolean;
	object 		: CM_CustomLicense;
	returnVal 	: String;
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then
			return _value;
		endif;
		
		if _value.isKindOf(CM_CustomLicense) then
			object := _value.CM_CustomLicense;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.code;
	endif;
	
	return returnVal;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
