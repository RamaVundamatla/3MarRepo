<Class name="CM_DataExtractOnsiteCargo" id="3d5f4f9e-b501-4f76-8395-d9a07c9b875a">
    <superclass name="CM_DataExtractClass"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
