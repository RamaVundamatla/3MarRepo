    <JadeMethod name="displayStatus" id="f825aba2-8c76-4ae1-8117-7bbc28f9f33d">
        <source>displayStatus():String;
// 25/07/0213	cnwcs5	CCMS POL 2221 / par 32094(2) - handle ALL valid statii
vars
	status	:Integer;
begin
	status := self.status;	
	
	if status = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING then
		return app.getString(Ignore);
	
	elseif status = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X then
		return app.getString(Will_not_beprocessed);

	elseif status = CM_EDITrackedItem.EDI_STATUS_VERIFIED then
		return app.getString(Verified);

	elseif status = CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS then
		return app.getString(Verify_errors);
		
	elseif status = CM_EDITrackedItem.EDI_STATUS_VERIFIED_WARNINGS then
		return app.getString(Verify_warnings);
			
	elseif status = CM_EDITrackedItem.EDI_STATUS_DBLOADED then
		return app.getString(DB_Loaded);
		
	elseif status = CM_EDITrackedItem.EDI_STATUS_DBLOADED_ERRORS then
		return app.getString(DB_Load_failed);
		
	elseif status = CM_EDITrackedItem.EDI_STATUS_UNPROCESSED then
		return app.getString(Un_processed);
		
	else
		return app.getString(Invalid);
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
