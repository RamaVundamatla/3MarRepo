    <JadeMethod name="isValidForRT" id="2519dc1e-aaa8-45dd-a059-e976e2d0d205">
        <source>isValidForRT():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

	iter : Iterator;
	criteriaLineHolder : CM_QueryCriteriaLineHolder;

begin

	iter := self.allCriteriaLineHolders.createIterator;
	
	while iter.next( criteriaLineHolder ) do
	
		if not criteriaLineHolder.isValidForRT() then
			return false;
		endif;
		
	endwhile;
	
	return true;

epilog

	delete iter;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isValidForTerminal" id="5cb3634f-a489-43a3-aa2e-4d352b9b8fd8">
        <source>isValidForTerminal( _terminal : CM_Terminal ) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 November 2011	cnwndl1	Initial creation	Par 28466

*/

vars

	criteriaLineHolder : CM_QueryCriteriaLineHolder;
	queryLine : CM_SelectorCriteriaLine;
	valueToMatch : Any;

begin
	
	if _terminal = null then
		return true;
	endif;
	
	valueToMatch := _terminal;

	foreach criteriaLineHolder in self.allCriteriaLineHolders do
		foreach queryLine in criteriaLineHolder.allCriteriaLines do
			if queryLine.myQueryProperty.propertyName = CM_TrackedItem::myTerminal.name then
				return ( queryLine.myQueryOperator.getSearchValue = valueToMatch );
			endif;
		endforeach;
	endforeach;
	
	return true;

epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="replaceVisibleColumnName" id="af0e0ec1-f4f2-4b70-9594-eac9348a5d2a">
        <updating/>
        <source>replaceVisibleColumnName( _old : String; _new : String ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2014	cnwndl1	Initial creation	Par 35215

*/

vars

	index : Integer;

begin

	index := self.allVisibleColumns.indexOf( _old );
	if index &gt; 0 and index &lt;= self.allVisibleColumns.size then
		self.allVisibleColumns[ index ] := _new;
	endif;

epilog

end;</source>
        <Parameter name="_old" type="String"/>
        <Parameter name="_new" type="String"/>
    </JadeMethod>
