    <JadeMethod name="validateMe" id="01f946b3-a28f-4c24-be92-4c222c66f083">
        <source>validateMe() protected;
// ---------------------------------------------------------------------------
// Created:		February 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin
	if self.name = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Customs Agent Name', null, null);
		app.raiseCMException(Input_required_field_cstAgtNme, null, null); // cnwdb2	PAR 35364
	endif;
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Customs Agent Code', null, null);
		app.raiseCMException(Input_required_field_cstAgtCde, null, null); // cnwdb2	PAR 35364

	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
