Identifies a single data cell in a table.</text>
    <DbClassMap file="basehtml"/>
    <PrimAttribute name="cellValue" id="62ef28c1-66b9-4c7c-8814-4c34abe2e12a">
        <type name="String"/>
    </PrimAttribute>
    <ExplicitInverseRef name="myRow" id="af5cb82a-ad0f-4655-a983-9a535af0c211">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CnEcHtmlTableRowTag"/>
        <access>readonly</access>
        <Inverse name="CnEcHtmlTableRowTag::allTableDatas"/>
    </ExplicitInverseRef>
    <PrimAttribute name="tableColumnSpan" id="963bd49a-803d-4fcc-8b18-d1fe09e26291">
        <embedded/>
        <type name="Integer"/>
        <text>Specifies the number of columns a cell should span.</text>
    </PrimAttribute>
    <PrimAttribute name="tableIsNoWrap" id="a9599cf7-95dc-4408-89da-800a231ea401">
        <embedded/>
        <type name="Boolean"/>
        <text>If true, then specifies that the text in the table cannit be wrapped
to fit a smaller cell, forcing the cell to enlarge.</text>
    </PrimAttribute>
    <PrimAttribute name="tableRowSpan" id="7d0986d3-3b6f-4a3e-89ff-f7400d198103">
        <embedded/>
        <type name="Integer"/>
        <text>Specifies the number of rows a cell should span.</text>
    </PrimAttribute>
    <JadeMethod name="buildTagBody" id="70b33659-d2f8-4087-b3cc-7f85125d9be9">
        <source>buildTagBody(): String protected;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	htmlString		: String;

begin
	// Build the table data tag.

	if self.tableColumnSpan &lt;&gt; 0 then
		htmlString	:=	htmlString &amp; ' COLSPAN="' &amp; self.tableColumnSpan.String &amp; '"';
	endif;

	if self.tableRowSpan &lt;&gt; 0 then
		htmlString	:=	htmlString &amp; ' ROWSPAN="' &amp; self.tableRowSpan.String &amp; '"';
	endif;

	if self.tableIsNoWrap then
		htmlString	:=	htmlString &amp; ' NOWRAP';
	endif;

	if self.tableWidth &lt;&gt; null then
		htmlString	:=	htmlString &amp; ' WIDTH="' &amp; self.tableWidth &amp; '"';
	endif;

	htmlString	:=	htmlString &amp; inheritMethod() &amp; '&gt;' &amp; self.cellValue &amp; self.buildChildTags();

	return htmlString;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHtml" id="35b040f9-c749-40ef-b156-73a6a3926be3">
        <source>getHtml(): String;
// --------------------------------------------------------------------------------
// Created:		29 April 2000 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return '&lt;TD' &amp; self.buildTagBody() &amp; '&lt;/TD&gt;' &amp; CrLf;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setRow" id="51951ea6-cb4e-4c28-91b6-01abfe3b18f4">
        <updating/>
        <source>setRow(pTableRowObj:CnEcHtmlTableRowTag) updating;
// -----------------------------------------------------------------------------
// Created:		30 November 2001 by cnwdad1
//
// Purpose:		Set a reference to the receiver's table row (cell).
//
// Parameters:	pTableRowObj - A reference to the table row object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	if self.myRow &lt;&gt; pTableRowObj then
		self.myRow	:=	pTableRowObj;
	endif;
end;</source>
        <Parameter name="pTableRowObj" type="CnEcHtmlTableRowTag"/>
    </JadeMethod>
</Class>
