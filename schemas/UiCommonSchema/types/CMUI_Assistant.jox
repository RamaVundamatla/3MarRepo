    <JadeMethod name="showTransferToBolForm" id="016d851c-d2b1-411f-ae66-3bbb9cea38f2">
        <source>showTransferToBolForm( _bol : CM_BOL; _objArray : ObjectArray ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 April 2016	cnwndl1	Initial creation	TFS 1903

*/

vars

	form : CMUI_TransferToBolForm;
	msg : String;

begin

	if _bol = null then
		msg := app.getErrorString(Input_required_field_bol);
	elseif _objArray.isEmpty then
		msg := app.getErrorString(Cargo_selected_transfer);
	endif;
	if msg &lt;&gt; null then
		app.msgBox(msg,app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return ModalResultError;
	endif;
	
	form := app.loadForm(CMUI_TransferToBolForm, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_TransferToBolForm;
	if form = null then
		return ModalResultError;
	endif;	
	
	if form.setMyFromBOL(_bol,_objArray) then
		form.showModal();
		return form.modalResult;
	endif;
	
	return ModalResultError;
	
epilog

end;</source>
        <Parameter name="_bol" type="CM_BOL"/>
        <Parameter name="_objArray" type="ObjectArray"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showTransferWorkCraneForm" id="7d3150af-e9d2-468a-9524-6387f3f855b7">
        <source>showTransferWorkCraneForm(	_voyageJob : CM_VoyageJob; 
