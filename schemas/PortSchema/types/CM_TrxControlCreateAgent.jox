    <JadeMethod name="trxCreateTITransactions" id="83170df8-511a-4992-8944-ad3587131d9f">
        <updating/>
        <source>trxCreateTITransactions(_txnControllerSet : CMIF_TITxnControllerSet input ; 
						_newTrxSet : CM_TITransactionSet input;
						_passport : CM_Passport input
						) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2016	cnwndl1	Initial creation	TFS 2647 / 2001

*/

vars

	trxController : CMIF_TITransactionController;
	newTITransaction : CM_TITransaction; 

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

		
	// Perform the operation
	foreach trxController in _txnControllerSet do
	
		app.myUtilityCA.utlCreateTITransaction(trxController, newTITransaction, _passport);
	
		if not _passport.noErrors() then
			return;
		endif;
		
		if _newTrxSet &lt;&gt; null and newTITransaction &lt;&gt; null then
			_newTrxSet.addNoDuplicates( newTITransaction, false );
		endif;
	
	endforeach;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_txnControllerSet" type="CMIF_TITxnControllerSet" usage="input"/>
        <Parameter name="_newTrxSet" type="CM_TITransactionSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateTIWithMove" id="269ac9aa-bcb4-4ed6-9ed3-cd013b71b328">
        <updating/>
        <source>trxCreateTIWithMove(	_pxyTI			: CM_TrackedItem input;
						_realTI			: CM_TrackedItem output;
						_moveController	: CMIF_MoveController input;
						_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     14 February 2001 by cnwdwq1
//
// Purpose:			Creates a persistent trackeditem
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 10/06/2010	cnwdap1		Use utlUpadteMoveTrackedItem - this method wasn't
//							calling executeMove, which caused alerts to be created
//							from PortSchema::moveLocationCheck_1
// 25/05/2024 	naviv1		TFS 64243 : CUX | POST &amp; PUT /Cargo APIs - Edit Transaction not created when customs reference data updated via API
// 14/01/2026	navlw1		JIRA-36344 : CUX | API Code 1081 Deadlock issue, lock collections that we use for Parent/Child Cargo
// ---------------------------------------------------------------------------
vars
	beforeEditStr,
	afterEditStr	: String;
	childTI			: CM_TrackedItem;
	terminal 		: CM_Terminal;
	voyage			: CM_Voyage;
	tilcType		: CM_TILCType;
	parentOnShip	: Boolean;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	// Start navlw1 JIRA-36344 14/01/2026
	terminal := _pxyTI.myTerminal;
	voyage := _pxyTI.myVoyage;
	if _moveController &lt;&gt; null and _moveController.myToPrimaryLocation.isTILCController then
		parentOnShip := _moveController.myToPrimaryLocation.CM_TILCController.myTILC.isOnShip;
	endif;
	app.writeLog(method.qualifiedName &amp; Tab &amp; _pxyTI.id &amp; " state is " &amp; _pxyTI.state.String &amp; ",  parentOnShip is " &amp; parentOnShip.String, LogDEBUG);
	
	// Even if we know we're a child cargo item being moved to a trailer on ship, we need to lock the onsite collections
	// because deep in teh bowels of setForCreate we do things with stops and look for duplicate cargo onsite
	self.exclusiveLock(terminal.allOnsiteTIsByCargoTypeId);
	self.exclusiveLock(terminal.allOnsiteTIsByCargoTypeIdRev);
	self.exclusiveLock(terminal.allOnsiteTIsByIdCargoType);
	self.exclusiveLock(terminal.allOnsiteTIsByIdCargoTypeRev);
	app.writeLog(method.qualifiedName &amp; Tab &amp; _pxyTI.id &amp; " locked terminal onsite collections", LogDEBUG);
	
	if _pxyTI.state = TI_STATE_ONSHIP or parentOnShip then
		self.exclusiveLock(voyage.allOnshipTIsByCargoTypeId);
		self.exclusiveLock(voyage.allOnshipTIsByCargoTypeIdRev);
		self.exclusiveLock(voyage.allOnshipTIsByIdCargoType);
		self.exclusiveLock(voyage.allOnshipTIsByIdCargoTypeRev);
		self.exclusiveLock(voyage.allOnshipTIsByAlternativeId);
		self.exclusiveLock(voyage.allOnshipTIsByCargoGroupId);
		app.writeLog(method.qualifiedName &amp; Tab &amp; _pxyTI.id &amp; " locked voyage onship collections", LogDEBUG);
	endif;
	
	self.exclusiveLock(terminal.allNotifiedTIsByAlternativeId);
	self.exclusiveLock(terminal.allNotifiedTIsByCargoTypeId);
	self.exclusiveLock(terminal.allNotifiedTIsByCargoTypeIdRev);
	self.exclusiveLock(terminal.allNotifiedTIsByIdCargoType);
	self.exclusiveLock(terminal.allNotifiedTIsByIdCargoTypeRev);
	app.writeLog(method.qualifiedName &amp; Tab &amp; _pxyTI.id &amp; " locked terminal notified collections", LogDEBUG);
	
	if _pxyTI.isTILC() then
		tilcType := _pxyTI.CM_TILC.myTILCType;
		if tilcType &lt;&gt; null then
			self.exclusiveLock(tilcType.allTILCs);
			app.writeLog(method.qualifiedName &amp; Tab &amp; _pxyTI.id &amp; " locked TILC type collection", LogDEBUG);
		endif;
	endif;
	// End navlw1 JIRA-36344 14/01/2026
	
	// Start the transaction
	beginTransaction;
	
	
	beforeEditStr := "null";	//27-May-2024 naviv1 #64243
	
	app.myUtilityCA.utlCreateTrackedItem(_pxyTI, _realTI, _passport);
	if not _passport.noErrors() or _realTI = null then
		return;
	endif;
	
	//Start - 27-May-2024 naviv1 #64243
	afterEditStr := _realTI.getCustomsReferenceAuditString();
	if afterEditStr = null then
		afterEditStr := "null";
	endif;
	
	if _passport.noErrors and beforeEditStr &lt;&gt; afterEditStr then
		_realTI.createEditForCustomsReferences(beforeEditStr,afterEditStr,_passport);
	endif;
	
	if _realTI.allChildren &lt;&gt; null then
		foreach childTI in _realTI.allChildren do					
			beforeEditStr := "null";									
			afterEditStr := childTI.getCustomsReferenceAuditString();
			if afterEditStr = null then
				afterEditStr := "null";
			endif;
			if _passport.noErrors and beforeEditStr &lt;&gt; afterEditStr then
				childTI.createEditForCustomsReferences(beforeEditStr,afterEditStr,_passport);
			endif;
		endforeach;
	endif;
	//End - 27-May-2024 naviv1 #64243
	
	if _moveController &lt;&gt; null then
		_moveController.setMyTrackedItem(_realTI);
		app.myUtilityUA.utlUpdateMoveTrackedItem(_moveController, _passport);	// cnwdap1 10/06/2010
		//_moveController.executePostMove(_passport);							// cnwdap1 10/06/2010
		
		//_realTI.setMyLocationsPublic(_moveController);						// cnwdap1 10/06/2010
		if  _passport.noErrors() then
			if _moveController.myToPrimaryLocation.myTerminalArea &lt;&gt; null then
				app.myEventManager.createSingleObjInfoNoteEvt(_moveController.myToPrimaryLocation.myTerminalArea,
					_passport.myTerminal.getTerminalEvent(EVENT_TI_MOVE),_moveController.myToPrimaryLocation);
			elseif _moveController.myToPrimaryLocation.isKindOf(CM_VoyageController) then
				app.myEventManager.createSingleObjInfoNoteEvt(_moveController.myToPrimaryLocation.CM_VoyageController.myVoyage,
					_passport.myTerminal.getTerminalEvent(EVENT_TI_MOVE),_moveController.myToPrimaryLocation);
			endif;
		endif;
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
	
end;
</source>
        <Parameter name="_pxyTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_realTI" type="CM_TrackedItem" usage="output"/>
        <Parameter name="_moveController" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateTIsForGenCargo" id="2e7383ab-995c-45cf-b09c-a2884d73a49c">
        <updating/>
        <source>trxCreateTIsForGenCargo(pIntFaceArray : CMIF_TIObjectArray; _validateOnly: Boolean; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     14 December 2000 by cnwrs2
//
// Purpose:     Takes an array of CM_InterfaceObjects (all members should be CM_IntFaceReceival)
//				and creates pre-notified tracked items from these.
//
// Parameters:  The array of interface objects.
//
// Returns:     True if successful.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(true);
	
	beginTransaction;

	if not _validateOnly then
		_passport.useTIDictDeferUpdate := true;
		_passport.useTITransactionDeferUpdate := true;
	endif;
	
	app.myUtilityCA.utlCreateTIsForGenCargo(pIntFaceArray, _validateOnly, _passport);
	
	if _validateOnly then
		app.cmsAbortTransaction();
	else
		if _passport.noErrors() then
			_passport.doDeferredUpdates();
		endif;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="pIntFaceArray" type="CMIF_TIObjectArray"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateTSWWebService" id="78dc3fd5-59cb-4b66-9cf4-025061aa3918">
        <updating/>
        <source>trxCreateTSWWebService(	_pxyTSWWebService : CM_TSWWebService input; 
						_newTSWWebService : CM_TSWWebService output;
