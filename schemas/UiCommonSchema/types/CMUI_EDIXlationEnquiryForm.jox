/*
Date		Who		Reason
11 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars

begin
	self.doPrintOutTable(self.tblData, self.caption,  true, false, true, false);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="30267b15-a629-4bfa-8b34-80a0dd7d0f08">
        <updating/>
        <source>doQuery() updating;
/*
Date		Who		Reason
11 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259 
13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
20 Mar 2017	cnwdap1	TFS 3734 AAT Vehicle Make translation type
01 Feb 2023	jlizm1	TFS 56291 POB - CSV Import of translation terms
19 Feb 2024	jlirs1	TFS 57192 - 57193 Pen Support Import Voyage Translation
*/
vars
	operator		: CM_Operator;
	type			: Integer;
	terminal		: CM_Terminal;
	opTerm			: CM_OperatorTerminal;
	xlationTable	: CM_XlationTable;
	xlation			: CM_Xlation;
	table			: CM_DataTable;
	str				: String;
	cmifMonitor		: CMIF_Monitor;
begin
	operator	:= self.cmbOperator.getCurrentItemObject.CM_Operator;
	type		:= self.cmbType.getCurrentItemData;
	table		:= self.tblData;
	table.rows	:= table.fixedRows;
	
	self.tblInfo.rows	:= 0;
	
	self.doNotableClear;
	
	if type = null then
		app.msgBox (app.getErrorString (Please_select_type), self.caption, MsgBox_OK_Only);
		return;
	endif;
	table.showColumnByColName(ETRow_Criteria);
	table.showColumnByColName(ETRow_Terminal);
	table.showColumnByColName(ETRow_CargoType);
	table.showColumnByColName(ETRow_Operator);
	if type &lt;&gt; CMUI_Assistant.ItemData_All_Operator then
		if type &lt;&gt; XLATION_TYPE_COMMODITY_BYOP and
		   type &lt;&gt; XLATION_TYPE_MTGRADE_BYOP and
		   type &lt;&gt; XLATION_TYPE_VOYAGETERMINAL then		//19 Feb 2024	jlirs1	TFS 57192 - 57193 Pen Support Import Voyage Translation
			table.hideColumnByColName(ETRow_Criteria);
		endif;
		if not CM_XlationTable@isOperatorTerminalXlation(type) then  // jlier1 tfs 54846 30/9/22   
			table.hideColumnByColName(ETRow_Terminal);
		endif;
		if type &lt;&gt; XLATION_TYPE_CARGOSUBTYPE_BYOP then
			table.hideColumnByColName(ETRow_CargoType);
		endif;
	endif;
	
	cmifMonitor := app.myPassport.myCMIFMonitor;
	if cmifMonitor &lt;&gt; null then
		delete cmifMonitor;
	endif;
	//jlier1 TFS  56291 26/1/22 
	create cmifMonitor transient;
	cmifMonitor.myParent := self;
	app.myPassport.setMyCMIFMonitor(cmifMonitor);
	cmifMonitor.message := "Searching...";
	cmifMonitor.partsInJob := JadeTableRowLimit;
	
	self.modalDialogReturnValue := self.ModalDialogReturn_Null;	
	self.modalDialogShow(null, 'Cancel' , null, null, 'Loading Data Translations',  'Please Wait....');
	self.updateProgress(cmifMonitor);
	self.modalDialogReturnValue := 0;
	self.pbProgressBar.visible := true;
	
	if  CM_XlationTable@isSystemXlation(type) or // jlier1 tfs 54846 30/9/22   
		type = CMUI_Assistant.ItemData_All_System then
		table.hideColumnByColName(ETRow_Operator);
		// just looking at system codes
		foreach xlationTable in app.myRoot.allXlationTables do
			if xlationTable.type = type or (type = CMUI_Assistant.ItemData_All_System and xlationTable.isSystemXlationTable) then
				self.doQueryXlationTable (xlationTable, table);
				if self.tblData.rows = JadeTableRowLimit then	// TFS 56291
					break;
				endif;
			endif;
		endforeach;
	elseif type = XLATION_TYPE_WORKPOINT then 
		//epr TFS 42095 22/11/18
		terminal := self.cmbTerminal.getCurrentItemObject.CM_Terminal;	
		if terminal = null then
			app.msgBox (app.getErrorString (Please_select_termina_area), self.caption, MsgBox_OK_Only);
			
			self.cmbTerminal.setFocus;
			return;
		endif;
		self.doQueryXlationTable (terminal.allXlationTables [XLATION_TYPE_WORKPOINT, null], table);
	
	else 
		// must be looking at operator codes
		if operator = null then
			app.msgBox (app.getErrorString (Please_select_operator), self.caption, MsgBox_OK_Only);
			
			self.cmbOperator.setFocus;
			return;
		endif;
		
		if type = CMUI_Assistant.ItemData_All_Operator then
			// all types (we add voyages in next step)
			foreach xlationTable in operator.allXlationTables do
				self.doQueryXlationTable (xlationTable, table);
				if self.tblData.rows = JadeTableRowLimit then	// TFS 56291
					break;
				endif;
			endforeach;
		endif;	
		
		// voyages are a bit different
		if type = CMUI_Assistant.ItemData_All_Operator or CM_XlationTable@isOperatorTerminalXlation(type) then //jlier1 TFS 54846 5/10/22
			terminal := self.cmbTerminal.getCurrentItemObject.CM_Terminal;
			
			if terminal &lt;&gt; null then
				opTerm := operator.allOperatorTerminals[terminal];
				
				if opTerm = null then
					// nothing there
					return;
				endif;
				
				self.doQueryXlationTable (opTerm.allXlationTables [type, null], table);
			else
				foreach opTerm in operator.allOperatorTerminals do
					self.doQueryXlationTable (opTerm.allXlationTables [type, null], table);
					if self.tblData.rows = JadeTableRowLimit then	// TFS 56291
						break;
					endif;
				endforeach;
			endif;
		endif;
		
		if type &lt;&gt; CMUI_Assistant.ItemData_All_Operator and not CM_XlationTable@isOperatorTerminalXlation(type)   then
			if type = XLATION_TYPE_CARGOSUBTYPE_BYOP then
				foreach xlationTable in operator.allXlationTables do
					if xlationTable.type = type then
						self.doQueryXlationTable (xlationTable, table);
						if self.tblData.rows = JadeTableRowLimit then	// TFS 56291
							break;
						endif;
					endif;
				endforeach;
			else
				// just looking for single operator type (not voyage)
				self.doQueryXlationTable (operator.allXlationTables [type, null], table);
			endif;
		endif;
	endif;
	
	app.myPassport.myCMIFMonitor.updateProgress(app.myPassport.myCMIFMonitor.message, 1, 1);
	
	inheritMethod();

epilog
	app.mousePointer := self.MousePointer_Default;									
	delete cmifMonitor;
	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;	
end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryAddItem" id="be4f9485-1d8a-41ef-8ddb-a34f8eb298e7">
        <source>doQueryAddItem(_table :CM_DataTable input; _xlation : CM_Xlation; _coll :CM_XlationSet input) : Boolean protected;

/*

Purpose:			

Parameters:		

Return Value:	true if item added to table

Date		Who		Reason
11 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
01 Feb 2023	jlizm1	TFS 56291 POB - CSV Import of translation terms
*/
vars
	str			: String;
	idx			: Integer;
	xlationOut	: CM_Xlation_Out;
	systemCodeObj : CM_Object;
begin
	//jlier1 TFS 56291 26/1/22
	if self.cmbSystemCod.enabled then
		systemCodeObj :=self.cmbSystemCod.listObject.CM_Object;
		if systemCodeObj &lt;&gt; null and _xlation.getMySystemObject &lt;&gt; systemCodeObj  then
			return false;
		endif;
	endif;

	str := _xlation.getAttributeStringForDefArray(_table.allTblDataEntRows);
	idx := _table.addItemObject(_xlation, str);
	
	if idx = 0 then
		return false;
	endif;
	
	executeWhen JMTDevelopmentEnvironment;
	
	if _xlation.isDisabled then
		_table.accessRow (idx).foreColor	:= LightGray;
	endif;
	
	endExecuteWhen;
	
	self.doNotableAdd (_xlation);
	
	// we also need to know if the outward translation changes
	if _xlation.isKindOf (CM_Xlation_In) then
		xlationOut := _xlation.CM_Xlation_In.getXlationOut;
	endif;
	
	if xlationOut &lt;&gt; null then
		if _coll &lt;&gt; null then
			_coll.removeIfPresent (xlationOut);
		endif;
		
		self.doNotableAdd (xlationOut);
	endif;
	
	return true;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_xlation" type="CM_Xlation"/>
        <Parameter name="_coll" type="CM_XlationSet" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doQueryXlationTable" id="5cd956e5-9051-4ca4-bae2-973460c15734">
        <source>doQueryXlationTable(_xlationTable :CM_XlationTable; _table :CM_DataTable input) protected;
/*
Date		Who		Reason
12 Mar 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
01 Feb 2023	jlizm1	TFS 56291 POB - CSV Import of translation terms
*/
vars
	xlation	:CM_Xlation;
	coll	:CM_XlationSet;
	lastUpdated		: Decimal [20];	
begin
	if _xlationTable = null then 
		return;
	endif;
	
	create coll transient;
	
	_xlationTable.allOutwardTranslations.copy (coll);
	
	foreach xlation in _xlationTable.allInwardTranslations do
		if not self.doQueryAddItem (_table, xlation, coll) then
			continue;
		endif;
		//jlier1 TFS 56291 26/1/22
		if (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then		
			if (not app.myPassport.myCMIFMonitor.updateProgress(app.myPassport.myCMIFMonitor.message, app.myPassport.myCMIFMonitor.partsInJob, _table.rows)) then
				break;
			endif;
			lastUpdated := app.relativeMachineTime;													
		endif;
		
	endforeach;
	
	// coll now includes those outward translations that do no have an inward translation
	// so we need to add these tot he table to
	foreach xlation in coll do
		if not self.doQueryAddItem (_table, xlation, null) then
			continue;
		endif;
		//jlier1 TFS 56291 26/1/22
		if (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then		
			if (not app.myPassport.myCMIFMonitor.updateProgress(app.myPassport.myCMIFMonitor.message, app.myPassport.myCMIFMonitor.partsInJob, _table.rows)) then
				break;
			endif;
			lastUpdated := app.relativeMachineTime;														
		endif;
		
	endforeach;
epilog
	delete coll;
end;</source>
        <access>protected</access>
        <Parameter name="_xlationTable" type="CM_XlationTable"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
