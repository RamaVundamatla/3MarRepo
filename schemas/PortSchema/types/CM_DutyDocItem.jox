    <JadeMethod name="validateCreate" id="76da5e98-54be-4a2d-a91f-3277baa06e99">
        <source>validateCreate(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2012	cnwer1	Initial creation HAT 2189

*/

vars

begin
	if self.myTrackedItem = null then
		app.raiseCMException(Please_select_cargo_itemPOP, null, null);
	endif;

	if self.consignee = null then												// PAR#34845
	//	app.raiseCMException1(REQUIRED_FIELD, "consignee " , null, null); 
		app.raiseCMException(Input_required_field_consignee , null, null);  // cnwdb2	PAR 35364
	endif;
	
	self.validateUpdate(_passport);
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
