    <JadeMethod name="convertQuantityToDays" id="2ed8c790-8b75-4a76-9a76-9cca949292d0">
        <source>convertQuantityToDays( _quantity : Real; _weight : Decimal; _volume : Real; _length : Real;_tiTrans : CM_TITransaction) : Integer ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2018	jlger1	Initial creation 38530

*/

vars
	storageDays	: Integer;
	blockUnit	: Integer;
	chargeByUnits	: Integer;
	units		: Integer;
	amount		: Real;
	convRate	: Real;
begin
	units := self.calculationType;
	if units &lt;&gt; INV_CALC_TYPE_DAYS_SINCE_RECVL and
	   units &lt;&gt; INV_CALC_TYPE_DAYSINCE_SUBTERM and	//28 Jun 2018	NDL	TFS 39338
	   units &lt;&gt; INV_CALC_TYPE_DAYSINCE_REC_TEU and
	   units &lt;&gt; INV_CALC_TYPE_DAYSINCE_REC_RT and	//08 May 2018	NDL	TFS 38525
	   units &lt;&gt; INV_CALC_TYPE_DAYSINCE_SHIP_ST and
	   units &lt;&gt; INV_CALC_TYPE_DAYSINCE_SHIP_EN and
	   units &lt;&gt; INV_CALC_TYPE_DAYSINCE_VOY_IN and
	   units &lt;&gt; INV_CALC_TYPE_DAYSINCE_VOY_OUT and
	   units &lt;&gt; INV_CALC_TYPE_DAYS_WEIGHT and
	   units &lt;&gt; INV_CALC_TYPE_DAYS_VOLUME and
	   units &lt;&gt; INV_CALC_TYPE_DAYS_ONSITE_AT and
	   units &lt;&gt; INV_CALC_TYPE_DAYS_CONNECTED and
	   units &lt;&gt; INV_CALC_TYPE_CARGOWEIGHTCONVT and
	   units &lt;&gt; INV_CALC_TYPE_CARGOLENGTHCONVT and
	   units = INV_CALC_TYPE_CARGOVOLUMECONVT 
	   then
		return 1;
	endif;
	blockUnit := self.theCalcTypeUnit;
	chargeByUnits := self.calculationType;
	if self.myMeasurementType &lt;&gt; null then
		convRate := self.myMeasurementType.conversionRate;
	else
		convRate := 1;
	endif;
	if chargeByUnits =  INV_CALC_TYPE_DISCREPANCYVALUE and self &lt;&gt; null and _tiTrans.isKindOf(CM_BBDiscrepancy)  then	//19 Mar 2018	NDL	TFS 37588
		return _tiTrans.getChargeQuantity.Integer;
	elseif chargeByUnits =  INV_CALC_TYPE_DISCREPANCYABS and self &lt;&gt; null and _tiTrans.isKindOf(CM_BBDiscrepancy)  then	//21 Jun 2018	NDL	TFS 39217
		return _tiTrans.getChargeQuantity.Integer.abs;
	elseif chargeByUnits = INV_CALC_TYPE_CARGOWEIGHTCONVT then
		amount := _weight;
	elseif chargeByUnits = INV_CALC_TYPE_CARGOVOLUMECONVT then
		amount := _volume;
	elseif chargeByUnits = INV_CALC_TYPE_CARGOLENGTHCONVT then
		amount := _length;
	else
		amount := 1;
	endif;
	// safety factor
	if amount = 0 then
		amount := 1;
	endif;
	
	storageDays := ((_quantity * convRate) / amount).Integer;
		
	return storageDays;
epilog

end;</source>
        <Parameter name="_quantity" type="Real"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_volume" type="Real"/>
        <Parameter name="_length" type="Real"/>
        <Parameter name="_tiTrans" type="CM_TITransaction"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createAsSystemType" id="b076bd89-244f-4fb7-b6ce-c3d8c654226b">
        <source>createAsSystemType() : Boolean;
/*
Purpose:			
Date		Who		Reason
30 May 2013	cnwab1	Initial creation
*/

vars

begin
	if self.calculationType = INV_CALC_TYPE_CARGOWEIGHTCONVT		// PAR 31615
	or self.calculationType = INV_CALC_TYPE_CARGOLENGTHCONVT		// PAR 31615
	or self.calculationType = INV_CALC_TYPE_CARGOVOLUMECONVT then		// PAR 31615
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="a80fec6b-c229-4b1b-8c3c-956c6f83e772">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 January 2021	jlgndl1	Initial creation

*/

vars
	iter : Iterator;
	invCont : CMQF_InvoiceContract;
	
begin
	iter := CMQF_InvoiceContract.instances.createIterator;
	while iter.next(invCont) do
		if invCont.allCalculationTypes.includes(self) then
			invCont.allCalculationTypes.remove(self);
		endif;
	endwhile;
	
	self.resetAuditsDuringDelete();	//25 Jan 2021	NDL	TFS 50152
	
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="da421c21-3b23-46f9-8a81-9f4dd40d01d1">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Jan 2017	cnwma1	TFS #2643 :JMT - Audit of Invoice Maintenance Set-up
27 Mar 2020 cnwma1  Bug 49001: STWO - Calculation type changes in remark hook code not logged in audit trail

*/
vars
	txt,
	tmpStr	        : String;
	qtyRange        : CM_QuantityRange;
	hookLinkQty,
	hookLinkRate,
	hookLinekRemarks,
	hookLinkQtyHms,
	hookLinkRateHms : CM_HookLink;
	hookLength      : Integer;
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	

	tmpStr := app.getInvoiceCalcTypeLabel(self.theCalcTypeUnit,true);
	txt    := txt &amp; 'Block Unit' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;
	tmpStr := app.getInvoiceCalcTypeLabel(self.calculationType,true);
	txt    := txt &amp; 'Calculation Type' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;
	if self.amountMin &gt; 0 then
		tmpStr := self.amountMin.asStringJMT;
		txt    := txt &amp; 'Minimum Chargeable Amount' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.amountMax &gt; 0 then
		tmpStr := self.amountMax.asStringJMT;
		txt    := txt &amp; 'Maximum Chargeable Amount' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.myCalendarType1 &lt;&gt; null then
		tmpStr := self.myCalendarType1.description;
		txt    := txt &amp; 'Normal/OverTime Calender' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.myCalendarType2 &lt;&gt; null then
		tmpStr := self.myCalendarType2.description;
		txt    := txt &amp; 'Exclusion Calender' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.allQuantityRanges.size &gt;0 then
		foreach qtyRange in self.allQuantityRanges do
		tmpStr := tmpStr &amp; " "&amp; qtyRange.rangeStart.String &amp; "-" &amp; qtyRange.rangeEnd.String &amp;" every " &amp;qtyRange.daysIncrement.String&amp;" Days" ;
		endforeach;
		tmpStr := tmpStr.trimLeft;
		txt    := txt &amp; 'Escalation Charges' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.integerRange1.size &gt;0 then
		tmpStr := tmpStr&amp; " "&amp; self.getRangeString();
		tmpStr := tmpStr.trimLeft;
		txt    := txt &amp; 'Range' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.booleanList.size &gt; 0 then
		tmpStr := tmpStr&amp; " "&amp; self.getDaysList();
		tmpStr := tmpStr.trimLeft;
		txt    := txt &amp; 'Days' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	
	if self.allHookLinkObjects.size &gt; 0 then
		tmpStr := null;
		if  self.getUserHookLink(HookType_InvoiceQuantity) &lt;&gt; null then
			hookLinkQty := self.getUserHookLink(HookType_InvoiceQuantity) ;
			if  hookLinkQty &lt;&gt; null then
				
				tmpStr  := tmpStr &amp; hookLinkQty.myHookCode.getCurrentJadeCode;
				tmpStr  := tmpStr.replace(Tab,"    ");
				txt     := txt &amp; app.getErrorString(Quantity_hook_code) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
			endif;
		endif;
		
		tmpStr := null;
		if self.getUserHookLink(HookType_InvoiceRate) &lt;&gt; null then
			 hookLinkRate := self.getUserHookLink(HookType_InvoiceRate) ;
			 if  hookLinkRate &lt;&gt; null then
				tmpStr := tmpStr &amp; hookLinkRate.myHookCode.getCurrentJadeCode;
				tmpStr := tmpStr.replace(Tab,"    ");
				txt    := txt &amp; app.getErrorString(Rate_hook_code) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
			endif;
		endif;
		//27.03.2020 cnwma1 #49001
		tmpStr := null;
		if self.getUserHookLink(HookType_InvoiceRemarks) &lt;&gt; null then
			 hookLinekRemarks := self.getUserHookLink(HookType_InvoiceRemarks) ;
			 if  hookLinekRemarks &lt;&gt; null then
				tmpStr := tmpStr &amp; hookLinekRemarks.myHookCode.getCurrentJadeCode;
				tmpStr := tmpStr.replace(Tab,"    ");
				txt    := txt &amp; app.getErrorString(Remarks_hook_code) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
			endif;
		endif;
		
		tmpStr := null;
		if self.getUserHookLink(HookType_HMSInvoiceQuantity) &lt;&gt; null then
			 hookLinkQtyHms := self.getUserHookLink(HookType_HMSInvoiceQuantity) ;
			 if  hookLinkQtyHms &lt;&gt; null then
				tmpStr := tmpStr &amp; hookLinkQtyHms.myHookCode.getCurrentJadeCode;
				tmpStr := tmpStr.replace(Tab,"    ");
				txt    := txt &amp; app.getErrorString(Quantity_hook_code) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
			endif;
		endif;
		
		tmpStr := null;
		if self.getUserHookLink(HookType_HMSInvoiceRate) &lt;&gt; null then
			 hookLinkRateHms := self.getUserHookLink(HookType_HMSInvoiceRate) ;
			 if hookLinkRateHms &lt;&gt; null then	//04 May 2020	NDL	TFS 49001
				tmpStr := tmpStr &amp; hookLinkRateHms.myHookCode.getCurrentJadeCode;
				tmpStr := tmpStr.replace(Tab,"    ");
				txt    := txt &amp; app.getErrorString(Rate_hook_code) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
			endif;
		endif;
	endif;
	
	return txt;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCalcTypeDesc" id="8d4ac189-ec84-46ec-a87a-840ac91db5f7">
        <source>getCalcTypeDesc() : String;
// ---------------------------------------------------------------------------
// Created:		05 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	return app.getInvoiceCalcTypeLabel(self.calculationType,true);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getComboDescription" id="84883965-9a44-49dc-899b-f2cf27fc9c6e">
        <source>getComboDescription() : String;
/*
Purpose:			

Date		Who		Reason
31 August 2023	navab1	BUG 59913
*/

vars

begin
	if self.isVoyageCalcType then
		return "HMS - " &amp; self.description;
	elseif self.isCargoCalcType then
			return "Cargo - " &amp; self.description;
	elseif self.isInventoryType then
		return "Inventory - " &amp; self.description;
	elseif self.isEventCalcType then
			return "Event - " &amp; self.description;
	elseif self.isWorkOrderType then  // ### TFS 59913 15SEP2023 NAVAB1 and not self.isStandardWorkOrder() then
		return "Work Order - " &amp; self.description; 
	elseif self.isBolCalcType then
			return "BOL - " &amp; self.description;
	endif;

	return self.description;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDaysList" id="0bd9553f-86c8-4a30-b37f-d2cd17ed9f3e">
        <source>getDaysList():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Jan 2017	cnwma1	TFS #2643 :JMT - Audit of Invoice Maintenance Set-up


*/

vars
		tot,idx : Integer;
	theFrom, dayIndex : Integer;
	
	theString : String;
begin
	tot := self.booleanList.size;
  foreach idx in 1 to tot do  
	dayIndex := idx;
		if dayIndex =1 then
			if self.booleanList[dayIndex] = true then
				theString := theString &amp; " Monday -";
			endif;
		elseif dayIndex =2 then
			if self.booleanList[dayIndex] = true then
				theString := theString &amp; " Tuesday -";
			endif;
		elseif dayIndex = 3 then
			if self.booleanList[dayIndex] = true then
				theString := theString &amp; " Wednesday -";
			endif;
		elseif dayIndex = 4 then
			if self.booleanList[dayIndex] = true then
				theString := theString &amp; " Thursday -";
			endif;
		elseif dayIndex =5 then
			if self.booleanList[dayIndex] = true then
				theString := theString &amp; " Friday -";
			endif;
		elseif dayIndex  =6 then
			if self.booleanList[dayIndex] = true then
				theString := theString &amp; " Saturday -";
			endif;
		elseif dayIndex = 7 then
			if self.booleanList[dayIndex] = true then
				theString := theString &amp; " Sunday -";
			endif;
		else
		
		endif;

	endforeach;
	theString := theString.truncatedAt(theString.length-2);
	return theString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="3a0a8e35-5b35-4af8-999a-1c2eec6f0c0e">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	mesType : CM_MeasurementType;
begin
	if _attrName = ETRow_Code then
		return self.code;
	elseif _attrName = ETRow_MeasurementType then
		mesType := self.myMeasurementType;
		if mesType = null then
			return "";
		else
			return mesType.name; // &amp; " (" &amp; mesType.conversionRate.asStringJMTWithPrecision(2,false) &amp; ")";
		endif;
	elseif _attrName = ETRow_BlockRateMin then // PAR 34764
		return self.amountMin.asStringJMT(); // PAR 34764
	elseif _attrName = ETRow_BlockRateMax then // PAR 34764
		return self.amountMax.asStringJMT(); // PAR 34764
	elseif _attrName = ETRow_Description then
		return self.description;
	elseif _attrName = ETRow_Services then
		return self.getServicesDesc()[1:250];
	elseif _attrName = ETRow_BlockUnit then
		return app.getInvoiceCalcTypeLabel(self.theCalcTypeUnit,true);
	elseif _attrName = ETRow_CalculationType then
		return self.calculationType.String;
	elseif _attrName = ETRow_CalcTypeDesc then
		return app.getInvoiceCalcTypeLabel(self.calculationType,true);
	elseif _attrName = ETRow_CalendarNormalDates then // PAR 30681
		if self.myCalendarType1 &lt;&gt; null then
			return self.myCalendarType1.description;
		else
			return null;
		endif;
	elseif _attrName = ETRow_CalendarExclusionDates then // PAR 30681
		if self.myCalendarType2 &lt;&gt; null then
			return self.myCalendarType2.description;
		else
			return null;
		endif;
	elseif _attrName = ETRow_Day1 or
	       _attrName = ETRow_Day1Chk then
		if self.booleanList.size &gt;= 1 then
			return app.getYesNo(self.booleanList[1]);
		else
			return null;
		endif;
	elseif _attrName = ETRow_Day2 or
		   _attrName = ETRow_Day2Chk then
		if self.booleanList.size &gt;= 2 then
			return app.getYesNo(self.booleanList[2]);
		else
			return null;
		endif;
	elseif _attrName = ETRow_Day3 or
		   _attrName = ETRow_Day3Chk then
		if self.booleanList.size &gt;= 3 then
			return app.getYesNo(self.booleanList[3]);
		else
			return null;
		endif;
	elseif _attrName = ETRow_Day4 or 
		   _attrName = ETRow_Day4Chk then
		if self.booleanList.size &gt;= 4 then
			return app.getYesNo(self.booleanList[4]);
		else
			return null;
		endif;
	elseif _attrName = ETRow_Day5 or
		   _attrName = ETRow_Day5Chk then
		if self.booleanList.size &gt;= 5 then
			return app.getYesNo(self.booleanList[5]);
		else
			return null;
		endif;
	elseif _attrName = ETRow_Day6 or
		   _attrName = ETRow_Day6Chk then
		if self.booleanList.size &gt;= 6 then
			return app.getYesNo(self.booleanList[6]);
		else
			return null;
		endif;
	elseif _attrName = ETRow_Day7 or
		   _attrName = ETRow_Day7Chk then
		if self.booleanList.size &gt;= 7 then
			return app.getYesNo(self.booleanList[7]);
		else
			return null;
		endif;
	elseif _attrName = ETRow_IsNotAvailableForEntryCk then
		return self.isNotAvailableForEntry.getYesNo();
	elseif _attrName = ETRow_Type then // ### TFS 51219 28MAY2021 NAVAB1
		return self.getTypeString(); // ### TFS 51219 28MAY2021 NAVAB1
	elseif _attrName = ETRow_IsCargoCalcType then
		return self.isCargoCalcType.getYes();
	elseif _attrName = ETRow_IsInventoryType then // ### TFS 51219 28MAY2021 NAVAB1
		return self.isInventoryType.getYes(); // ### TFS 51219 28MAY2021 NAVAB1
	elseif _attrName = ETRow_IsEventCalcType then
		return self.isEventCalcType.getYes();
	elseif _attrName = ETRow_IsVoyageCalcType then
		return self.isVoyageCalcType.getYes();
	elseif _attrName = ETRow_IsBolCalcType then	//31 Oct 2019	NDL	TFS 47100
		return self.isBolCalcType.getYes();
		
	elseif _attrName = ETRow_Range then
		if self.integerRange1.size &gt;= 1 then
			return self.getRangeString();
		else
			return null;
		endif;

	elseif _attrName = ETRow_TimeFrom then
		return self.timeFrom.asStringJMT();

	elseif _attrName = ETRow_TimeTo then
		return self.timeTo.asStringJMT();
	// CCMS 1279 May 2012
	elseif _attrName = ETRow_EscalatingCharges then
		return self.getEscalatingRangeString();
	// next four 24024 CCMS 1151 Aug 2010 cnwjre1 user hook code for invoice quantity and rate
	elseif _attrName = ETRow_QuantityHookCode then
		return app.getErrorString(Doubleclick_view);
	elseif _attrName = ETRow_RateHookCode then
		return app.getErrorString(Doubleclick_view);
	elseif _attrName = ETRow_RemarksHookCode then		// 22/2/18 MAP TFS37124
		return app.getErrorString(Doubleclick_view);
	elseif _attrName = ETRow_HasQtyHookCode then
		return (self.myHookCodeQuantity&lt;&gt;null).getYes();
	elseif _attrName = ETRow_HasRateHookCode then
		return (self.myHookCodeRate&lt;&gt;null).getYes();
	elseif _attrName = ETRow_HasRemarksHookCode then		// 22/2/18 MAP TFS37124
		return (self.myHookCodeRemarks &lt;&gt; null).getYes();
		
	elseif _attrName = ETRow_RateType then	//22 Mar 2019	NDL	TFS 43687
		return app.getCalcRateTypeStr( self.rateType );
	elseif _attrName = ETRow_WeightToUse then 
		return CM_CalculationType@getWeightToUseStr(self.weightOptionToUse); //02/10/2025	navkc1 JIRA 36149
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEscalatingRangeString" id="44419e5c-979c-476c-90fc-8ca4a8373029">
        <source>getEscalatingRangeString() : String protected;
//	CCMS SFW 1279 May 2012 Storage Escalating Charges
vars
	
	theString	: String;
	qtyRange	: CM_QuantityRange;

begin
	foreach qtyRange in self.allQuantityRanges do
		if qtyRange.rangeEnd &gt; 0 then
			if theString &lt;&gt; null then
				theString := theString &amp; ",";
			endif;
			theString := theString &amp; qtyRange.getDisplay();
		endif;
	endforeach;
	
	return theString;
end;	</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementTypeDescription" id="f2c03af0-fee9-4a97-a9db-578c4e12a940">
        <source>getMeasurementTypeDescription() : String;
/*
Purpose:			
Date		Who		Reason
27 May 2013	cnwab1	Initial creation
*/

vars
	mesType : CM_MeasurementType;
begin
	mesType := self.myMeasurementType;
	if mesType = null then
		return "";
	endif;
	
	return mesType.name &amp; " (" &amp; app.getErrorString(Conversion_rate) &amp; " = " &amp; mesType.conversionRate.asStringJMTWithPrecision(4,false) &amp; ")";
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementTypeName" id="1dcf450e-31e7-4150-98fe-9802a670c8dd">
        <source>getMeasurementTypeName() : String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 16 August 2022
TFS#		: 54420
Function	:

*** Changes ***
Date			Name		TFS#		Description
22/09/2022		jlika1		54890		MTN - Invoice extract doesn't include the measurement type text unless the calculation types use a weight convert type.
****************************************************/

vars
	mesType : CM_MeasurementType;
begin
	mesType := self.myMeasurementType;
	
	if mesType = null then
		if self.calculationType = INV_CALC_TYPE_WEIGHT then
			mesType :=  app.getDefaultMeasurementForType(Type_Weight);
		elseif self.calculationType = INV_CALC_TYPE_VOLUME then
			mesType :=  app.getDefaultMeasurementForType(Type_Volume);
		endif;
		
		if mesType = null then
			return "";
		endif;
		
	endif;
	
	return mesType.name;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNumHourBlocks" id="c2df99c0-cd5b-4e8e-87e1-5a3fedfb2ddc">
        <source>getNumHourBlocks(_numMinutes : Integer; _useFreeHrs : Boolean; _wharf : HMS_Wharf) : Integer;
// ---------------------------------------------------------------------------
// Created:		June 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	numMinutes : Real;
	timeTill2ndResource : Integer;
begin
	numMinutes := _numMinutes;
	
	if _useFreeHrs then
		numMinutes := numMinutes - (self.hoursFree * 60);
		// if the free minutes wipes this out then return zero.
		if numMinutes &lt; 0 then
			return 0;
		endif;	
	endif;
	if numMinutes &lt; 0 then
		numMinutes := 0;
	endif;
	if numMinutes &lt; (self.hoursMin * 60) then
		numMinutes := (self.hoursMin * 60);
	endif;
	if numMinutes &gt; (self.hoursMax * 60) and self.hoursMax &lt;&gt; 0 then
		numMinutes := (self.hoursMax * 60);
	endif;

	// timeTill2ndResource is  typically 1.5 hours so convert to minutes. It is used to say when to add an extra block
	if _wharf &lt;&gt; null then
		timeTill2ndResource := ((_wharf.timeTill2ndResource * MillisecondsPerHour) / MillisecondsPerMinute).Integer; // PAR 12319 
	endif;

	if self.hoursBlock &gt; 0 then
//		numMinutes := (numMinutes / (self.hoursBlock * 60)).Real.roundedUp(); PAR 12319
		numMinutes := ((numMinutes- timeTill2ndResource) / (self.hoursBlock * 60)).Real.roundedUp();
	else
		numMinutes := numMinutes / 60;
	endif;

	if numMinutes &lt; 1 then
		numMinutes := 1;
	endif;
	return numMinutes.Integer;
end;</source>
        <Parameter name="_numMinutes" type="Integer"/>
        <Parameter name="_useFreeHrs" type="Boolean"/>
        <Parameter name="_wharf" type="HMS_Wharf"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getQuantityRangeIndex" id="d184a980-f048-4546-be97-2fb494582226">
        <source>getQuantityRangeIndex(_start : Integer; _end : Integer; _daysIncrement : Integer output) : Integer;
//	CCMS SFW 1279 May 2012 Storage Escalating Charges
vars
	idx		: Integer;
	qr		: CM_QuantityRange;
begin
	if self.allQuantityRanges.size = 0 then
		return 0;
	endif;
	
	foreach qr in self.allQuantityRanges do
		idx := idx + 1;
		if qr.rangeStart = _start and
		   qr.rangeEnd = _end then
			_daysIncrement := qr.daysIncrement;
			return idx;
		endif;
	endforeach;
	
	return 0;
end;
</source>
        <Parameter name="_start" type="Integer"/>
        <Parameter name="_end" type="Integer"/>
        <Parameter name="_daysIncrement" type="Integer" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getQuantityRangeValue" id="0bc8e264-0fee-4824-8e0e-959a7e29c94e">
        <source>getQuantityRangeValue(_prevQuantity : Integer; _rangeStart : Integer; _quantity : Integer; _costs : DecimalArray; _isAmount : Boolean) : Real;
//	CCMS SFW 1279 May 2012 Storage Escalating Charges
vars
	idx		: Integer;
	qr		: CM_QuantityRange;
	qty		: Integer;
	range	: Integer;
	count	: Integer;
	total	: Integer;
	baseRate	: Real;
	rate	: Real;
	increment	: Real;
	value	: Real;
	totalValue	: Real;
begin
	if self.allQuantityRanges.size = 0 then
		return 0;
	endif;
	qty := _quantity;
	
	foreach qr in self.allQuantityRanges do
		idx := idx + 1;
		total := total + qr.rangeEnd;
		if (_prevQuantity &gt; 0 and
		    total &gt; _prevQuantity) or
		   (_rangeStart &gt; 0 and
		    qr.rangeStart = _rangeStart) then
			if idx &lt;= _costs.size then
				rate := _costs[idx];
				if qr.daysIncrement &gt; 0 then
					range := qr.daysIncrement;
					increment := 0;
					if idx &lt; _costs.size then
						idx := idx + 1;
						increment := _costs[idx];
					endif;
				else
					range := qr.rangeEnd - qr.rangeStart + 1;
				endif;
				count := 0;
				baseRate := rate;

				while true do
					rate := baseRate + increment * count;			
					if qty &gt; range then
						value := range * rate;
					else
						value := qty * rate;
					endif;
					totalValue := totalValue + value;
					qty := qty - range;
					count := count + 1;
					if qr.daysIncrement = 0 or
					   qty &lt;= 0 then
						break;
					endif;
				endwhile;
			endif;
			if qty &lt;= 0 then
				break;
			endif;
		endif;
	endforeach;
	
	if _isAmount then
		totalValue := rate;
	endif;
	
	return totalValue;
end;
</source>
        <Parameter name="_prevQuantity" type="Integer"/>
        <Parameter name="_rangeStart" type="Integer"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_costs" type="DecimalArray"/>
        <Parameter name="_isAmount" type="Boolean"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getRangeIndex" id="e8affd57-f516-40c7-900e-dbf85856676a">
        <source>getRangeIndex(_item : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	endIdx, aNum, idx : Integer;
begin
	if self.calculationType &lt;&gt; INV_CALC_TYPE_VESSEL_TON_RANGE 
	and self.calculationType &lt;&gt; INV_CALC_TYPE_VESSEL_TON_QTY1  then // PAR 10672
		return 0;
	endif;
	
	endIdx := self.integerRange1.size;
	
	foreach idx in 1 to endIdx do
		if _item &lt;= self.integerRange1[idx] then
			return idx;
		endif;
	endforeach;
	
	return endIdx;
end;</source>
        <Parameter name="_item" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRangeString" id="60ab7481-a749-4499-abd7-ebae72d98170">
        <source>getRangeString() : String;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tot,idx : Integer;
	theFrom, theTo : Integer;
	
	theString : String;

begin
	tot := self.integerRange1.size;
	theFrom := 1;
	foreach idx in 1 to tot do
		if idx &gt; 1 then
			theFrom := (self.integerRange1[idx -1] + 1);
		endif;
		theTo := self.integerRange1[idx];
		if theTo &gt; 0 then
			if theString &lt;&gt; null then
				theString := theString &amp; ",";
			endif;
			theString := theString &amp; theFrom.String &amp; "-" &amp; theTo.String;
		endif;
	endforeach;
	
	return theString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getServicesDesc" id="a282b0a2-20f6-46eb-be46-7df9fb8b2c37">
        <source>getServicesDesc() : String;
// ---------------------------------------------------------------------------
// Created:		07 July 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	aStr : String;
	aService : CM_Service;
begin

	foreach aService in self.allServices do
		if aStr = null then
			aStr := aService.name;
		else
			aStr := aStr &amp; ", " &amp; aService.name;
		endif;
	endforeach;
	return aStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTypeString" id="276c644b-9a05-4bc1-bb40-1f3b6128693d">
        <source>getTypeString() : String;
/*
Purpose:			

Date		Who		Reason
28MAY2021	NAVAB1	TFS 51219
*/


vars

begin
	if self.isCargoCalcType then
		return "Cargo"; // do not translate
	elseif self.isBolCalcType then
		return "BOL"; // do not translate
	elseif self.isEventCalcType then
		return "Event"; // do not translate
	elseif self.isInventoryType then
		return "Inventory"; // do not translate
	elseif self.isVoyageCalcType then
		return "Voyage"; // do not translate
	elseif self.isWorkOrderType then
		return "Work Order"; // do not translate
	endif;
	
	return "";
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUserHookLink" id="cfe6300a-18f2-48bb-ad88-9c83d5e7d1a8">
        <source>getUserHookLink(_hookType:Integer) : CM_HookLink protected;
// 24024 CCMS 1151 Aug 2010 cnwjre1 user hook code for invoice quantity and rate
vars
	hookLinkObj	: CM_HookLink;
	
begin
	foreach hookLinkObj in self.allHookLinkObjects do
		if hookLinkObj.hookType = _hookType then
			return hookLinkObj;
		endif;
	endforeach;
	
	return null;
end;</source>
