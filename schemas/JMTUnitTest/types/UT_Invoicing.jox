    <JadeMethod name="unitTestBeforeClass" id="5d006cf1-a02d-4d8f-a86d-d78bf5a29635">
        <updating/>
        <source>unitTestBeforeClass() updating, protected;
// cnwjre1
//
// Set up invoice line descs for the transaction map load tests and any common invoice objects used across tests
constants
	VoyageName = "UT_VOY1";
	ShipName =  "UT_MESDIAM01";
	TestOperator = 'MSK';
vars
	taxTS	: TimeStamp;
	ioClass : CM_ExtFinanceIO;
	calType1, calType2 	: CM_CalculationType;
	invType : CM_InvoiceDesc;	
	invLineType : CM_InvoiceLineDesc;
	services : CM_ServiceByNameDict;
	glCode	: CM_GLCode;
	bank	: CM_Bank;
	taxCode	: CM_TaxCode;
	taxRate	: CM_TaxRate;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
begin

	inheritMethod();
	ioClass := self.getTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	if ioClass = null then
		self.setInvoiceFinancialClass(CM_DefaultFinanceIO, null);
	endif;
	// TFS 1746 turn these options OFF for all invoicing - they only apply to Otago empty and are now tested in tOtagoStorage
	self.setTerminalConfig(MTsByDebtor, false);
	self.setTerminalConfig(MTsByDebtorExport, false);
	
	self.setMyBank(self.getTerminal().getDefaultCompanyBank());
	self.deleteStorageConfig( true );

	self.deleteTransactionMaps();
	self.deleteInvoiceType("UT_InvType");
	self.deleteInvoiceService("UT_Service98", FORCED_ERASE);
	self.deleteInvoiceService("UT_Service99", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_ILD01", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_ILD02", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_ILD03", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_ILD04", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_ILD05", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_ILD06", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_ILD07", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_ILD08", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_ILD09", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_ILD10", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_ILD11", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_ILD12", FORCED_ERASE);

	create services transient;
	
	invType := self.createInvoiceType("UT_InvType", InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type UT_InvType not created");

	//calType1 := app.myRoot.allCalculationTypesByCode.first();
	// Can't always trust the first calc type to do what we expect it to do
	calType1 := app.myRoot.allCalculationTypesByCode['UTDEF'];
	self.assertNotNullMsg(calType1, "Calculation type not created");
	calType2 := app.myRoot.allCalculationTypesByCode.last();
	self.assertNotNullMsg(calType2, "Calculation type not created");

	glCode := self.myBank.glCodes["UT_GL"];
	if glCode = null then
		glCode := self.createInvoiceGLCode("UT_GL", "");
		self.assertNotNullMsg(glCode, "GL code not created");
	endif;

	services.add(self.createInvoiceService("UT_Service98","UT Remarks 1", calType1, glCode));
	services.add(self.createInvoiceService("UT_Service99","UT Remarks 2", calType1, glCode));
	
	// debtor type SDT4 is Ship Operator
	invLineType := self.createInvoiceLineType("UT_ILD01", calType1, invType, services,"SDT4");
	invLineType := self.createInvoiceLineType("UT_ILD02", calType1, invType, services,"SDT4");
	invLineType := self.createInvoiceLineType("UT_ILD03", calType1, invType, services,"SDT4");
	invLineType := self.createInvoiceLineType("UT_ILD04", calType1, invType, services,"SDT4");
	invLineType := self.createInvoiceLineType("UT_ILD05", calType1, invType, services,"SDT4");
	invLineType := self.createInvoiceLineType("UT_ILD06", calType1, invType, services,"SDT4");
	invLineType := self.createInvoiceLineType("UT_ILD07", calType1, invType, services,"SDT4");
	invLineType := self.createInvoiceLineType("UT_ILD08", calType1, invType, services,"SDT4");
	invLineType := self.createInvoiceLineType("UT_ILD09", calType1, invType, services,"SDT4");
	invLineType := self.createInvoiceLineType("UT_ILD10", calType1, invType, services,"SDT4");
	invLineType := self.createInvoiceLineType("UT_ILD11", calType1, invType, services,"SDT4");
	invLineType := self.createInvoiceLineType("UT_ILD12", calType1, invType, services,"SDT4");
	self.updateOperatorFreeStorageDays(self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), 0, 0);

	self.addIfNewServiceILD("UT_ServiceFirstDischarge", "CCT108", "UT_LineTypeFirstDischarge", glCode, invType);
	
	self.addIfNewServiceILD("UT_ServiceLastLoad", "CCT109", "UT_LineTypeLastLoad", glCode, invType);
	
	// tax code and rate
	bank := self.myBank;
	taxCode := bank.allTaxCodes["GST"];
	if taxCode = null then
		taxCode := self.addTaxCode("GST", "GST tax code", null);
	endif;
	taxTS.setDate("01/01/2010".Date);
	taxTS.setTime("01:01:01".Time);
	taxRate := taxCode.allTaxRates[taxTS];
	if taxRate = null then
		self.addTaxRate(taxCode, 15.00, taxTS);
	endif;
	
	// save the current active transacton map for all terminals
	app.saveTermActiveCargoMapSet2Dflt(self.allSavedTermCargoMapsLocal);					// 21/03/2013 cnwmh5
	
	app.myPassport.setMyTerminal(app.myRoot.allTerminals["UT"]);			// 22/03/2013 cnwmh5
	
	
	// ### TFS BUG 62187 14FEB2024 NAVAB1
	voyage := self.getVoyage(VoyageName);
	if voyage = null then
		vessel := self.getVessel(ShipName);
		if vessel = null then
			vessel := self.addVesselCellular(ShipName, self.getOperator(TestOperator));
			self.assertNotNullMsg(vessel, 'Add vessel failed');
		endif;
		voyage	:= self.addVoyageWithContainerStructur(	VoyageName,
														ShipName,
														TestOperator, 
														self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString);
		self.assertNotNullMsg( voyage, 'Add voyage failed' );
		voyage := self.getVoyage(VoyageName);
		self.assertNotNull(voyage);
	endif;
epilog
	
	delete services;
end;</source>
        <access>protected</access>
    </JadeMethod>
