    <JadeMethod name="getCCEventJSON" id="f2b65871-b8b5-4d22-8b44-a344210855f0">
        <source>getCCEventJSON(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 August 2019	jlger1	Initial creation

*/

vars

ccStuff : CMIF_CCStuff;
	json : String;
	jsonHelper		: CMIF_JsonHelper;
	otherTI : CM_TrackedItem;
	ccEventType : String;
begin
	ccEventType:=self.getCCEventType;
	if ccEventType = null then
		return null;
	endif;
	
	if self.myTrackedItem = null then
		return null;
	endif;
	
	if self.myTrackedItem.externalProfileSecret = null then
		return null;
	endif;

	otherTI:=self.getOtherTrackedItem;
	if otherTI = null then
		return null ;
	endif;
	
	if otherTI.externalProfileSecret = null then
		return null;
	endif;
	
	create ccStuff transient;
	ccStuff.parentSecretId :=self.myTrackedItem.externalProfileSecret ;
	ccStuff.childrenSecretIds.add(otherTI.externalProfileSecret );
	
	ccStuff.deserializeJSON(json);
	
	create jsonHelper transient;

	json:= jsonHelper.formatJsonString(json);
	
	return CN_LEFT_BRACKET &amp; json  &amp;  CN_RIGHT_BRACKET;
epilog
	delete ccStuff;
	delete jsonHelper;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCCEventType" id="55a49ddd-e90c-497a-a4ef-1cf74302b668">
        <source>getCCEventType(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 August 2019	jlger1	Initial creation

*/

vars

	otherTI : CM_TrackedItem;
begin
	if self.action &lt;&gt; ACTION_UNPACK_CHILD then
		return null;
	endif;

	otherTI:=self.getOtherTrackedItem;
	if otherTI = null then
		return null;
	endif;
	
	if otherTI.externalProfileSecret = null then
		return null;
	endif;
	
	return CC_EventType_Unpacked;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="18a70ea1-6b9c-47af-ad8e-cdf3af582f82">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	unpackAmount,
	lDetail : String;
	otherTI,
	theTI	: CM_TrackedItem;
begin

	if _attrName = ETRow_Details 
	or _attrName = ETRow_Action then		//cnwmc5 - 1 Dec 2015 - PAR 37108
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			theTI 	:= self.myTrackedItem;
			otherTI	:= self.getOtherTrackedItem;
			lDetail := "Unpacked ";
			unpackAmount :=self.getUnpackAmount;
			if unpackAmount &lt;&gt; null then
				lDetail:=lDetail &amp; unpackAmount &amp; " x ";
			endif;
			if self.action = ACTION_UNPACK_FROM then
				if theTI &lt;&gt; null then
					lDetail := lDetail &amp; " " &amp; theTI.id;
				endif;
				lDetail := lDetail &amp; " from";
				if otherTI &lt;&gt; null then
					lDetail := lDetail &amp; " " &amp; otherTI.id;
				else
					lDetail := lDetail &amp; " " &amp; self.otherTrackedItemId; //par 11071
				endif;
			else
				if otherTI &lt;&gt; null then
					lDetail := lDetail &amp; " " &amp; otherTI.id;
				else
					lDetail := lDetail &amp; " " &amp; self.otherTrackedItemId; //par11071
				endif;
				lDetail := lDetail &amp; " from";
				if theTI &lt;&gt; null then
					lDetail := lDetail &amp; " " &amp; theTI.id;
				endif;
			endif;
		
			lDetail := lDetail &amp; " " &amp; self.urNumber.String;			
			
			return lDetail;
			
		endif;

	elseif _attrName = ETRow_UnpackedFrom then
		theTI 	:= self.myTrackedItem;
		otherTI	:= self.getOtherTrackedItem;
		if self.action = ACTION_UNPACK_FROM then
			if otherTI &lt;&gt; null then
				lDetail := otherTI.id;
			else
				lDetail := self.otherTrackedItemId;
			endif;
		else
			if theTI &lt;&gt; null then
				lDetail := theTI.id;
			endif;
		endif;
		return lDetail;
	
	elseif _attrName = ETRow_UnpackedTo then
		theTI 	:= self.myTrackedItem;
		otherTI	:= self.getOtherTrackedItem;
		if self.action = ACTION_UNPACK_FROM then
			if theTI &lt;&gt; null then
				lDetail := theTI.id;
			endif;
		else
			if otherTI &lt;&gt; null then
				lDetail := otherTI.id;
			else
				lDetail := self.otherTrackedItemId;
			endif;
		endif;
		return lDetail;
		
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="ad04e251-56e5-4489-9942-4904b59e6d2e">
        <source>getEnquiryRow(): String;
// ---------------------------------------------------------------------------
// Created:  May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	lDetail : String;
	otherTI,
	theTI	: CM_TrackedItem;
	
begin

	theTI 	:= self.myTrackedItem;
//	if global.isValidObject(self.otherTrackedItem) then
	otherTI	:= self.getOtherTrackedItem;
//	endif;
	
	lDetail := inheritMethod();
	lDetail := lDetail &amp; "Unpacked ";

//	if self.secondary then
	if self.action = ACTION_UNPACK_FROM then
		if theTI &lt;&gt; null then
			lDetail := lDetail &amp; " " &amp; theTI.id;
		endif;
		lDetail := lDetail &amp; " from";
		if otherTI &lt;&gt; null then
			lDetail := lDetail &amp; " " &amp; otherTI.id;
		else
			lDetail := lDetail &amp; " " &amp; self.otherTrackedItemId; //par 11071
		endif;
	else
		if otherTI &lt;&gt; null then
			lDetail := lDetail &amp; " " &amp; otherTI.id;
		else
			lDetail := lDetail &amp; " " &amp; self.otherTrackedItemId; //par11071
		endif;
		lDetail := lDetail &amp; " from";
		if theTI &lt;&gt; null then
			lDetail := lDetail &amp; " " &amp; theTI.id;
		endif;
	endif;

	if lDetail &lt;&gt; "" then
		lDetail := lDetail &amp; " " &amp; self.urNumber.String;
	else
		lDetail := self.urNumber.String;
	endif;			
	
	return lDetail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
