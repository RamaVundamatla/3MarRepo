    <JadeMethod name="createAlert" id="1976b3c5-4b97-4eef-a71b-ea98858c5676">
        <source>createAlert();
//Simply raises an event. The AlertThread application running on the jade server
//looks after doing the real work.
vars

begin
	self.causeEvent(EVENT_RAISE_ALERT , true, self);
end;</source>
