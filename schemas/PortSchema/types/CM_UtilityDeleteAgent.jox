    <JadeMethod name="utlDeleteInvTermsOfTrade" id="4ac8e971-18b8-4a14-94b1-d5bf41750529">
        <source>utlDeleteInvTermsOfTrade(pInvTermsOfTrade:CM_InvoiceTermsOfTrade; _passport : CM_Passport input);
//----------------------------------------------
//Created:16 October 2001  By: cnwgd1
//----------------------------------------------
vars
	toDelete : CM_InvoiceTermsOfTrade;

begin

	toDelete := pInvTermsOfTrade;

	if not self.exclusiveLockObjectToDelete(toDelete) then
	    // toDelete is null, invalid or has already been deleted
	    return;
	endif;

	app.myValDA.valInvTermsOfTrade(pInvTermsOfTrade);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(toDelete);
	endif;

	if _passport.noErrors then
		toDelete.setForDelete();
	endif;

epilog
	return;
end;</source>
        <Parameter name="pInvTermsOfTrade" type="CM_InvoiceTermsOfTrade"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteInvoiceAllocation" id="af1a8ab5-5094-4549-89bf-39a4eca183e5">
        <source>utlDeleteInvoiceAllocation(_allocationObj : CM_InvoiceAllocation io; _quantityRangeMap : CM_QuantityRangeMap io; _invLineDesc : CM_InvoiceLineDesc io; 
						   _passport : CM_Passport input);
// --------------------------------------------------------------------------------
// Created:		CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
//
// Purpose:		Remove a specific invoice line desc from the given quantity range map.  If this is the last such, delete the
//				quantity range map.  If this is the last range map for the parent quantity map, delete both the quantity map and
//				the associated invoice allocation.
//
// Parameters:	_allocationObj - A reference to the Yard Allocation to delete.
//				_passport - A reference to the user's "passport" object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	lastQRM	: Boolean;
	lastILD	: Boolean;
	sssb	: CM_SnapShotServiceBroker;
	qm		: CM_QuantityMap;
	mapping, mappingToRemove : CM_TranMapInvoiceLineMapping;
	localDict : CM_QuantityRangeMapDict;
	qrm : CM_QuantityRangeMap;
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	app.myValDA.valYardAllocation(_allocationObj);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	sssb := _allocationObj.myServiceBroker.CM_SnapShotServiceBroker;

// TFS 40620	_quantityRangeMap.allInvoiceLineMaps.remove(_invLineDesc);
// TFS 40620	_quantityRangeMap.allInvoiceLinesUsed.remove(_invLineDesc);
	if _quantityRangeMap = null and _allocationObj.myQuantityMap &lt;&gt; null then //04 Feb 2019	NDL	TFS 43153
		if not _allocationObj.myQuantityMap.allQuantityRanges.isEmpty then
			create localDict transient;
			_allocationObj.myQuantityMap.allQuantityRanges.copy( localDict );
			foreach qrm in localDict do
				qrm.setQuantityMap(null);
			endforeach;
			localDict.purge();
		endif;
		
	elseif _quantityRangeMap &lt;&gt; null then	//04 Feb 2019	NDL	TFS 43153
		foreach mapping in _quantityRangeMap.allTMInvoiceLineMappings do // TFS 40620
			if mapping.myTMInvoiceLineDesc = _invLineDesc then
				mappingToRemove := mapping;
			endif;
		endforeach;
		delete mappingToRemove;
	endif;
	
	
// TFS 40620	if _quantityRangeMap.allInvoiceLinesUsed.size = 0 then
	if _quantityRangeMap = null	//04 Feb 2019	NDL	TFS 43153
	or _quantityRangeMap.allTMInvoiceLineMappings.size = 0
	then
		lastILD := true;
		qm := _allocationObj.myQuantityMap;
		if _quantityRangeMap &lt;&gt; null then	//04 Feb 2019	NDL	TFS 43153
			self.myDeleteAuditAgent.audDeleteGeneric(_quantityRangeMap);
			_quantityRangeMap.erase(NORMAL_ERASE);
		endif;
		if qm.allQuantityRanges.size = 0 then
			lastQRM := true;
			self.myDeleteAuditAgent.audDeleteGeneric(qm);
			qm.erase(NORMAL_ERASE);
			if sssb &lt;&gt; null then	//18 Sep 2017	NDL	TFS 6973
				if sssb.allInvoiceAllocations.includes(_allocationObj) then	//18 Sep 2017	NDL	TFS 6973
					sssb.allInvoiceAllocations.remove(_allocationObj);
				endif;
				if sssb.allInvoiceAllocationsByPriory.includes(_allocationObj) then
					sssb.allInvoiceAllocationsByPriory.removeKeyEntry(_allocationObj.priorityValue.Integer, _allocationObj);
				endif;
			endif;
			if sssb &lt;&gt; null then	//25 July 2019	NDL	Testing data
				app.myEventManager.createSingleObjInfoNoteEvt( sssb, app.myPassport.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_DELETE), _allocationObj );	//04 Feb 2019	NDL	TFS 43153
			endif;
			_allocationObj.erase(NORMAL_ERASE);
		endif;
	endif;
	
	_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_UPDATE), false, sssb);
	
epilog

	delete localDict;	//01 Mar 2019	NDL	TFS 43153
		
end;</source>
        <Parameter name="_allocationObj" type="CM_InvoiceAllocation" usage="io"/>
        <Parameter name="_quantityRangeMap" type="CM_QuantityRangeMap" usage="io"/>
        <Parameter name="_invLineDesc" type="CM_InvoiceLineDesc" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteInvoiceCargoAlloc" id="0b0bbc85-4bd7-475e-825f-1cc8ffb9cd92">
        <source>utlDeleteInvoiceCargoAlloc(_allocationObj : CM_InvoiceAllocation io);
/*
Purpose:			
Date		Who			Reason
MARCH 2015	CNWAB1		Initial creation
01 Jun 2017	cnwkpd1		TFS #4542 - Invoice performance changes
	
*/
vars
	tranMap			: CM_TranMapCargoAllocation;
	tranMapInvent		: CM_TranMapInventoryAllocation;
	
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	app.myValDA.valYardAllocation(_allocationObj);
	
	if not self.checkValidationWithPassport(app.myPassport) then
		return;
	endif;
			
	self.myDeleteAuditAgent.audDeleteGeneric(_allocationObj);
	
	app.setContinueCMExceptions(false);
	
	if _allocationObj.isKindOf(CM_InvoiceInventoryAllocation) then
		tranMapInvent := _allocationObj.CM_InvoiceInventoryAllocation.myTransactionMap;
	
	elseif _allocationObj.isKindOf(CM_InvoiceCargoAllocation) then
		tranMap := _allocationObj.CM_InvoiceCargoAllocation.myTransactionMap;
	endif;
	
	_allocationObj.erase(NORMAL_ERASE);

	// TFS 4542 - Need to rebuild the manual collection after an allocation is deleted

	 // ### TFS 51219 25MAY2021 NAVAB1
	if _allocationObj.isKindOf(CM_InvoiceInventoryAllocation) then
		if tranMapInvent &lt;&gt; null then
			tranMapInvent.recalcAllocationPriorities();
		endif;

		app.myPassport.myTerminal.causeEvent(app.myPassport.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_UPDATE), false, _allocationObj);
		tranMapInvent.causeEvent(app.myPassport.myTerminal.getTerminalEvent(EVENT_INVCARGOALLOC_DELETE), false, _allocationObj); // TFS 7496
	
	elseif _allocationObj.isKindOf(CM_InvoiceCargoAllocation) then
		if tranMap &lt;&gt; null then
			tranMap.recalcAllocationPriorities();
		endif;

		app.myPassport.myTerminal.causeEvent(app.myPassport.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_UPDATE), false, _allocationObj);
		tranMap.causeEvent(app.myPassport.myTerminal.getTerminalEvent(EVENT_INVCARGOALLOC_DELETE), false, _allocationObj); // TFS 7496
	endif;

end;</source>
        <Parameter name="_allocationObj" type="CM_InvoiceAllocation" usage="io"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteInvoiceDesc" id="76afc9c0-ec41-48d2-af7b-11546bf0e489">
