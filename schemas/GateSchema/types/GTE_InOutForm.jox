    <JadeMethod name="setIsFromPrenote" id="c11002a8-1be7-40bc-af10-e292da0b4d8c">
        <source>setIsFromPrenote(_ti: CM_TrackedItem; _gteSheet: GTE_Sheet input);
//----------------------------------------------------------------
//	Created:	05 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if _ti.id = self.fromPrenoteID then
		_gteSheet.setIsFromPrenote(_ti);
	else
		_gteSheet.setIsFromPrenote(null);
	endif;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_gteSheet" type="GTE_Sheet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProductValueByName" id="61933237-36f5-4d7f-9352-8959f773856f">
        <source>setProductValueByName( _prodAttr : CM_ProductAttr; _attrStr : String );
// ------------------------------------------------------------------------------------------
// Created:     11 July 2008		cnwvu1
//
// Purpose:	Par 17524. When a child in the booking reference is gated in, the product values 
//			can be displayed in two ways: either values as described in the booking reference
//			or as default product values 
//			The product values described in the booking reference are zero, then default 
//			product values will be populated.
// ------------------------------------------------------------------------------------------
vars
	table			: CM_EntryTable;
	obj				: Object;
	bookingRefItem	: CM_BookingRefItem;
	valStr			: String;
	assistant		: GTE_Assistant;
begin
	
	if self.topSheet.myMenuAction = null then
		return;
	endif;

	table	:= self.topSheet.myTblExtra;
	
	obj	:= self.topSheet.myMenuAction.myObject;
	
	if obj.isKindOf( CM_BookingRefItem ) then	// this is the child in the booking reference
		bookingRefItem := obj.CM_BookingRefItem;
	endif;
	
	if bookingRefItem &lt;&gt; null then
		valStr := bookingRefItem.cargoIF_GetStringForETRow( _attrStr );
	endif;
	
	if valStr &lt;&gt; null then	
		// when the product value &gt; 0 in the booking reference, the system populates product value from the booking reference
		table.setValueByName( _attrStr, valStr );
	else
		// when the product value = null or zero in the booking reference, the system populates product value as the product default
		if _prodAttr &lt;&gt; null then  // cnwrd1 21/7/2008 par 17558 - set value from booking ref without product
			table.setValueByName( _attrStr, _prodAttr.getDisplayValueString() );
		endif;
	endif;
	

end;</source>
        <Parameter name="_prodAttr" type="CM_ProductAttr"/>
        <Parameter name="_attrStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="setReleaseByType" id="64bb64e1-138d-4e8c-95e9-db7bc8c1dc0c">
        <source>setReleaseByType(_tbl : CM_EntryTable input; _obj : Object);
//--------------------------------------------------------------
//Created: 27 February 2003 By: cnwgd1
//
// Changed On   Changed By  Reason
// ----------   ----------  ------------------------------------
// 23/09/2009	consw1		SFW1035 - get info from ReserveDetail rather than Yard Request
//--------------------------------------------------------------
vars
	releaseByType : Boolean;

begin

	if CM_BulkRelease.hasInstance(_obj) then
//		releaseByType := (_obj.CM_BulkRelease.getDeliveryRequest(false) &lt;&gt; null);
		releaseByType := _obj.CM_BulkRelease.releaseByType;
	
		_tbl.disableRowByName(ETRow_ReleaseByType);
	elseif CM_TrackedItem.hasInstance(_obj) then
		releaseByType := false;
		_tbl.disableRowByName(ETRow_ReleaseByType);		
	else
		releaseByType := self.myTerminal.getConfig(GateOutReleaseByISOType).Boolean;
		_tbl.enableRowByName(ETRow_ReleaseByType);	
	endif;

	/*
	// ### HIDE FROM GDANSK
	vta := self.myTerminal.allTerminalAreas[tblCommon.getRowByName(ETRow_RoadTransAreaId).String].CM_VehicleTransferArea;
	if vta = null then
		vta := self.myTerminal.allTerminalAreas[self.myTerminal.getConfig(DefRoadOpsArea).String.trimRight()].CM_VehicleTransferArea;
	endif;

	if vta &lt;&gt; null and vta.isDualGate then
		_tbl.hideRowByName(ETRow_ReleaseByType,false);
		releaseByType := false;
	endif;
		*/
	_tbl.setValueByName(ETRow_ReleaseByType, releaseByType);

	if releaseByType then			
		self.tblCommon.setValueByName(ETRow_AutoComplete, false);
		self.tblCommon.disableRowByName(ETRow_AutoComplete);
	else
		self.tblCommon.enableRowByName(ETRow_AutoComplete);
		if self.myTerminal.getConfig(GateInAutoComplete).Boolean then 	// dh 27/2/2008 par 15376
			self.tblCommon.setValueByName(ETRow_AutoComplete, true); 	//
		endif; 															//
	endif;
end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="setReleaseFields" id="6ff3c487-e523-472c-9bd0-cf6c91abd578">
        <source>setReleaseFields();
//--------------------------------------------------------------
//Created: 17 February 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	cargoType	: CM_CargoBOLType;
	sheet		: GTE_Sheet;
	mainTbl		: CM_EntryTable;
	extraTbl	: CM_EntryTable;
	cmb			: GTE_ComboBox;
	code		: String;
	tmpRow		: Integer;
	assistant	: GTE_Assistant;
	
begin
	sheet := self.topSheet;
	
	if sheet = null then
		return;
	endif;
	
	code := sheet.myMenuAction.code;
	
	if code &lt;&gt; NavObj_GTE_Out then
		return;
	endif;
	
	assistant := self.myAssistant.GTE_Assistant;
	mainTbl := sheet.myTblMain;
	extraTbl := sheet.myTblExtra;
	cargoType := self.getCargoBOLType(sheet);
	extraTbl.visible := true;

	if assistant.isReleaseByType(mainTbl) then
		mainTbl.showHideRowsByViewName('OutByType', CM_EntryTable.ShowHideRows, false);
		extraTbl.showHideRowsByViewName('bulkRelease', CM_EntryTable.ShowHideRows, false);
		// switch the heading
		cmb := sheet.getControlByName(Cntrl_cmbBulkRelease).GTE_ComboBox;

		if cmb  &lt;&gt; null and cmb.text &lt;&gt; null then
			sheet.setSubHeading(cmb.text);
		else
			sheet.setSubHeading(null);
		endif;

		// Terminology Par 10009
		// Release by ISO type so need to change cargo set from form.
		cargoType := app.myRoot.allCargoTypesById.getAtKey(TI_CargoType_Container);

		// set terminology on Tables and then display.
		mainTbl.setTerminologyRelevant(cargoType, self.myTerminal);
		mainTbl.setRowNamesFromTerminology();
		extraTbl.setTerminologyRelevant(cargoType, self.myTerminal);
		extraTbl.setRowNamesFromTerminology();
		self.tblCommon.setValueByName(ETRow_AutoComplete, false);
	else
		mainTbl.showHideRowsByViewName(cargoType.gateInOutMainTblReleaseView, CM_EntryTable.ShowHideRows, false);
		extraTbl.showHideRowsByViewName(cargoType.gateInOutExtraTblReleaseView, CM_EntryTable.ShowHideRows, false);
		// switch the heading
		cmb := sheet.getControlByName(Cntrl_cmbTI).GTE_ComboBox;
		
		if cmb &lt;&gt; null and cmb.text &lt;&gt; null then
			sheet.setSubHeading(cmb.text);
		else
			sheet.setSubHeading(mainTbl.getValueByName(ETRow_IdCombo).String);
		endif;
		
		mainTbl.hideRowByName(ETRow_MySubTerminal, false);
		// Terminology Par 10009  // set terminology on Tables and then display.
		mainTbl.setTerminologyRelevant(cargoType, self.myTerminal);
		mainTbl.setRowNamesFromTerminology();
		extraTbl.setTerminologyRelevant(cargoType, self.myTerminal);
		extraTbl.setRowNamesFromTerminology();
		self.setAutoComplete();
	endif;
	
	//24/06/2009 cnwdz2 20072
	if not app.isSubTerminalsOn(self.myTerminal) then
		extraTbl.hideRowByName(ETRow_MySubTerminal, false);
		mainTbl.hideRowByName(ETRow_MySubTerminal, false);
		extraTbl.hideRowByName(ETRow_SubTerminalDesc, false);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setStatusLineCaption" id="ac67815a-b000-421d-b78a-8257b58f576d">
        <source>setStatusLineCaption(_str : String);
// ---------------------------------------------------------------------------
// Created:     02 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.staMain.caption := _str;

end;</source>
        <Parameter name="_str" type="String"/>
    </JadeMethod>
    <JadeMethod name="setSubTerminalDefault" id="03f5c8ef-6a6a-4fb2-80cf-97b4e58323f1">
        <source>setSubTerminalDefault(_isReceival:Boolean; _isOverride:Boolean; _tableObj:CM_EntryTable input) protected;
// --------------------------------------------------------------------------------
// Created:		06 May 2009 by cnwdad1
//
// Purpose:		Using currently entered details, determine a default Sub-Terminal
//				for the current cargo.
//
// Parameters:	_isReceival - True if the cargo is being received, otherwise false.
//				_isOverride - If true, the current Sub-Terminal may be overridden.
//				_tableObj - A reference to the current data entry table.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	imexStatusObj	: CM_IMEXStatus;
	imexStatus		: Integer;
	commodityObj	: CM_Commodity;
	commodCode		: String;
	terminalObj		: CM_Terminal;
	subTerminalObj	: CM_SubTerminal;
	cargoTypeObj	: CM_CargoBOLType;
	bulkRelObj		: CM_BulkRelease;
	subTerminaType	: Integer;
	isContainer		: Boolean;
	tmpCombo		: ComboBox;
	releaseType		: Integer;
	
begin
// cnwdad1 12/05/2010 - PAR #24222.
//	if _tableObj.getValueByName(ETRow_MySubTerminal).String &lt;&gt; null then
	if not _isOverride and _tableObj.getValueByName(ETRow_MySubTerminal).String &lt;&gt; null then
		return;
	endif;
	
	terminalObj		:=	self.myTerminal;
	
	if _isReceival then
		// need to get target sub-terminal to send cargo to
		tmpCombo		:=	self.getCellControl(cmbTiType.name).ComboBox;
		if tmpCombo &lt;&gt; null then
			cargoTypeObj	:=	tmpCombo.listObject.CM_CargoBOLType;
		endif;
		tmpCombo		:=	self.getCellControl(cmbImexStatus.name).ComboBox;
		if tmpCombo &lt;&gt; null then
			imexStatusObj	:=	tmpCombo.listObject.CM_IMEXStatus;
		endif;
		
		tmpCombo		:=	self.getCellControl(cmbCommodity.name).ComboBox;
		if tmpCombo &lt;&gt; null then
			commodityObj	:=	tmpCombo.listObject.CM_Commodity;
		endif;
		
		isContainer		:=	false;
		
		if cargoTypeObj &lt;&gt; null then
			if cargoTypeObj.isCargoType() then
				subTerminaType	:=	CM_SubTerminal.Type_TrackedItem;
				isContainer		:=	(cargoTypeObj.id = TI_CargoType_Container);
			else
				subTerminaType	:=	CM_SubTerminal.Type_BOL;
			endif;
		endif;
		
		if imexStatusObj &lt;&gt; null then
			imexStatus	:=	imexStatusObj.code;
		endif;
		
		if commodityObj &lt;&gt; null then
			commodCode	:=	commodityObj.code;
		endif;
		
	else
		// need to get source sub-terminal to take cargo from
		tmpCombo		:=	self.getCellControl(cmbBulkRelease.name).ComboBox;
		if tmpCombo &lt;&gt; null then
			bulkRelObj		:=	tmpCombo.listObject.CM_BulkRelease;
		endif;

		subTerminaType	:=	CM_SubTerminal.Type_BulkRelease;

		if bulkRelObj = null then
			releaseType	:=	BR_TYPE_ROAD;
		else
			releaseType	:=	bulkRelObj.type;
		endif;
	endif;
	
/*	
	isContainer		:=	false;
	
	if cargoTypeObj &lt;&gt; null then
		if cargoTypeObj.isCargoType() then
			if cargoTypeObj.id = TI_CargoType_Container then
				isContainer		:=	true;
				subTerminaType	:=	CM_SubTerminal.Type_TrackedItem;
				releaseType		:=	0;
			else
				subTerminaType	:=	CM_SubTerminal.Type_BulkRelease;
				
global.cnwdad1();	// Would like Richard S to confirm this is ok.
// cnwdad1 27/01/2010 - PAR #22205.
				if bulkRelObj = null then
					releaseType	:=	BR_TYPE_ROAD;
				else
					releaseType		:=	bulkRelObj.type;
				endif;
			endif;
		else
			subTerminaType	:=	CM_SubTerminal.Type_BOL;
			releaseType		:=	0;
		endif;
	endif;
	
	if imexStatusObj &lt;&gt; null then
		imexStatus	:=	imexStatusObj.code;
	endif;
	
	if commodityObj &lt;&gt; null then
		commodCode	:=	commodityObj.code;
	endif;
*/	
	subTerminalObj	:=	terminalObj.getDefaultSubTerminal(	subTerminaType,
															releaseType,	// cnwdad1 27/01/2010 - PAR #22205.
															imexStatus,
															commodCode,
															isContainer);
	
	if subTerminalObj &lt;&gt; null then
		tmpCombo	:=	self.getCellControl(cmbSubTerminal.name).ComboBox;
		tmpCombo.cnEcSetObjectIndex(subTerminalObj);
		_tableObj.setValueByName(ETRow_MySubTerminal, subTerminalObj.code);
//		_tableObj.setValueByControlName(tmpCombo.name, subTerminalObj.code);
//		self.setCellTextFromControl(self.topSheet, tmpCombo, subTerminalObj.code);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_isReceival" type="Boolean"/>
        <Parameter name="_isOverride" type="Boolean"/>
        <Parameter name="_tableObj" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="4d459cb5-fc11-46e7-9b32-38a4416aebd7">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 April 2014	cnwmc5	Initial creation	CCMS 1127

*/

vars

begin
	self.xmlStringTblLogDocketData := self.tblLogDocketData.getXmlStrForColumns(true);
	self.doLoadLogDocketData();
epilog

end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTblMainViewCargoType" id="1d379ee5-ba12-4ea7-8c91-2f4fb71cc853">
        <updating/>
        <source>setTblMainViewCargoType(pCargoType:CM_CargoType; pMainTable:CM_EntryTable input) updating;
//--------------------------------------------------------------
//Created: 21 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	def : EntTableDef;
	defName : String;
	viewName : String;
	view : EntTableView;
begin
	def := pMainTable.myEntTableDef;
	defName := def.name;

	if defName = ETDef_OutMain then
		viewName := pCargoType.gateInOutMainTblReleaseView;
	else
		viewName := pCargoType.gateInOutMainTblReceiveView;
	endif;

	//find the view for viewName
	view := def.allEntTableViews[viewName];

	pMainTable.setTerminologyRelevant(pCargoType, self.myTerminal);
	pMainTable.setRowNamesFromTerminology;
		
	if view &lt;&gt; null then
		pMainTable.showHideRowsByView(view, CM_EntryTable.ShowHideRows, false);
	else
		pMainTable.showHideRowsByList(null, CM_EntryTable.ShowHideRows, false);
	endif;

	self.showHideStops(pMainTable, null, null);

	pMainTable.resetSize();			
end;</source>
        <Parameter name="pCargoType" type="CM_CargoType"/>
        <Parameter name="pMainTable" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromBookingRef" id="52ade25a-4768-4832-a7cd-c260ab68eafe">
        <updating/>
        <source>setValuesFromBookingRef(pBookingRef : CM_BookingRef; pSheet : GTE_Sheet io) protected, updating;
// ---------------------------------------------------------------------------
// Created:     09 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpCombo	: GTE_ComboBox;	
	assistant	: GTE_Assistant;
	mainTbl,
	extraTbl	: CM_EntryTable;
begin
	
	//replaced by:
	self.setDefaultsFromObject(pSheet, pBookingRef);
	
end;</source>
        <access>protected</access>
        <Parameter name="pBookingRef" type="CM_BookingRef"/>
        <Parameter name="pSheet" type="GTE_Sheet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromBulkRelease" id="d5d8837b-c44f-4f07-8de4-0b339577798d">
        <updating/>
        <source>setValuesFromBulkRelease(br : CM_BulkRelease; pSheet : GTE_Sheet io) updating, protected;
// ---------------------------------------------------------------------------
// Created:     10 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/09/2009	consw1		SFW1035 - get info from ReserveDetail rather than Yard Request
// 05/10/2009	cnwdad1		PAR #20969.
// 14/04/2010	cnwdap1		PAR #23565 Freight Forwarder changes
/// 26/04/2010	cnwdap1		PAR #23946 Allow for ConsigneeConsignorCmbOrdDescr system setting when displaying freight forwarder
// ---------------------------------------------------------------------------
vars
	tmpInt		: Integer;
	assistant	: GTE_Assistant;
	mainTbl,
	extraTbl	: CM_EntryTable;
	cmb			: ComboBox;
//	req			: CM_Request;
//	delvReq		: CM_DeliveryRequest;
	tmpStr		: String;
	tmpStr2		: String;
	id			: String;
	ti			: CM_TrackedItem;
	tmpConsignee	: CM_ConsigneeConsignor;
	tmpCombo	: GTE_ComboBox;
	lstTable	: CMUI_ListTable;
	bulkRelease : CM_BulkRelease;
	freightFwdr	: CM_ConsigneeConsignor;
begin
	assistant := self.myAssistant.GTE_Assistant;
	
	mainTbl := pSheet.myTblMain;
	extraTbl := pSheet.myTblExtra;	

	pSheet.setSubHeading(br.code);

	mainTbl.setTableFromObject(br, null);	

	if br.myOperator &lt;&gt; null then
		tmpStr := assistant.displayEntryOperator(br.myOperator);
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_OperatorCode, tmpStr);
		cmb := pSheet.getControlByName(Cntrl_cmbOperator).ComboBox;		
		if cmb &lt;&gt; null then
			cmb.GTE_ComboOperator.setObject(br.myOperator);
		endif;
	endif;

	if br.myOperatorGroup &lt;&gt; null then
		tmpStr := assistant.displayEntryOperatorGroup(br.myOperatorGroup);
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_MyOperatorGroup, tmpStr);
		cmb := pSheet.getControlByName(Cntrl_cmbOperatorGroup).ComboBox;
		if cmb &lt;&gt; null then
			tmpInt := cmb.findObject(br.myOperatorGroup);
			if tmpInt &gt; -1 then
				cmb.listIndex := tmpInt;
				//cmb.text := tmpStr;
			endif;				
		endif;
	else	//when op group = null, just setting the row to null, otherwise it can keep some value from the previous bulk release, edited in the release combobox. cnwvu1
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_MyOperatorGroup, null);
	endif;

	if br.myTransferToTerminal &lt;&gt; null then
		tmpStr := assistant.displayEntryTerminal(br.myTransferToTerminal);
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_MyTransferToTerminal, tmpStr);
		cmb := pSheet.getControlByName(Cntrl_cmbDestTerminal).ComboBox;
		if cmb &lt;&gt; null then
			tmpInt := cmb.findObject(br.myTransferToTerminal);
			if tmpInt &gt; -1 then
				cmb.listIndex := tmpInt;
			endif;				
		endif;
	else	//When dest. terminal = null, just setting the row to null, otherwise it can keep some value from the previous bulk release, edited in the release combobox. Par 16601 July 2008
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_MyTransferToTerminal, null); 
	endif;
	id := br.getMaskIdString;
	assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_IdMask, id);

	tmpStr := assistant.displayEntryBulkRelease(br);
	assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_ReleaseNoCmb, tmpStr);
	///assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_DeliveryReleaseNumber, tmpStr);   // 30/11/2010 cnwmh5 #26400
	cmb := pSheet.getControlByName(Cntrl_cmbBulkRelease).ComboBox;
	if cmb &lt;&gt; null then
		cmb.text := tmpStr.trimRight;
		cmb.listIndex := cmb.findObject(br); // Par 17502
		//cmb.listObject := br;
	endif;

	tmpStr2 := assistant.displayEntryDeliveryReleaseNo(br);				// 30/11/2010 cnwmh5 #26400
	if tmpStr2 &lt;&gt; null then
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_DeliveryReleaseNumber, tmpStr2);
	else
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_DeliveryReleaseNumber, tmpStr);
	endif;
	
// AER 1/10/2007 populate the tblExtra table for the specified bulkRelease	-Par 14997
	bulkRelease := cmb.listObject.CM_BulkRelease;
	if global.isValidObject(bulkRelease) then
		self.showBRDetails(bulkRelease);
	endif;
//	assistant.mainExtraSetValue(mainTbl, extraTbl, 'releaseByType', br.releaseByType);	
/*
	req := br.requests.first;
	
	if req = null then
		return;
	endif;

	// if bulk release has specific TIs, populate the list box with these only
	// RDD 12/10/2001 PAR1471 / PNL306  --  added here 16/10/01 RDD
	// assistant.comboBoxTrackedItemFromBulkRel( br, cmb );

	if br.requests.size = 1 and req.isKindOf(CM_TIRequest) then
		ti := req.CM_TIRequest.trackedItem;
		tmpStr := ti.id;
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_IdCombo, tmpStr);
		cmb := pSheet.getControlByName(Cntrl_cmbTI).ComboBox;
		if cmb &lt;&gt; null then
			cmb.text := tmpStr.trimRight;
		endif;
		tmpCombo := pSheet.getControlByName(Cntrl_cmbTiType).GTE_ComboBox;
		tmpCombo.text := ti.myCargoType.description;
		tmpCombo.click(tmpCombo);
		mainTbl.setValueByControlName(tmpCombo.name, tmpCombo.text);
		
		extraTbl.setTableFromObject(ti, null);
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_MyOperator, ti.operatorCode);		
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_WeightTotal, ti.totalWeight);				
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_CompanyCodeTxt, ti.companyCode);						
		self.showHideStops(mainTbl, extraTbl, ti);
	else
*/
		tmpCombo := pSheet.getControlByName(Cntrl_cmbTiType).GTE_ComboBox;
		tmpCombo.text := br.getMyCargoTypeDescription();
		tmpCombo.click(tmpCombo);
		mainTbl.setValueByControlName(tmpCombo.name, tmpCombo.text);	
//	endif;
	
// cnwdad1 05/10/2009 - PAR #20969.
	if app.isSubTerminalsOn(self.myTerminal) and br.mySubTerminal &lt;&gt; null then
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_MySubTerminal, br.mySubTerminal.code);
	endif;
	
	tmpConsignee := app.myRoot.allConsigneeConsignors[br.consigneeCode];
	if tmpConsignee &lt;&gt; null then
		cmb := pSheet.getControlByName(Cntrl_cmbConsignee).CMUI_ComboConsignors;
		if cmb &lt;&gt; null then
			cmb.CMUI_ComboConsignors.setObject(tmpConsignee);
			assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_ConsigneeCode, cmb.text);
		endif;		
	endif;

//	assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_DeliveryReason, req.CM_YardRequest.reasonCodeDescr);
	assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_DeliveryReason,  br.deliveryReasonDescr);
//	assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_ConsignorVoyageCode, req.CM_YardRequest.consignorVoyageCode);
	assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_ConsignorVoyageCode, br.consignorVoyageCode);
//	assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_EirNumber, req.CM_YardRequest.eirNumber);
	//assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_FreightForwarderCode, br.freightForwarderCode);					// PAR #23565	// PAR #23946
	if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then														// PAR #23946
		freightFwdr := br.myFreightForwarder;																				// PAR #23946
		if freightFwdr &lt;&gt; null then																							// PAR #23946
			assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_FreightForwarderCode, freightFwdr.description);			// PAR #23946
		endif;																												// PAR #23946
	else																													// PAR #23946
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_FreightForwarderCode, br.freightForwarderCode);				// PAR #23946
	endif;																													// PAR #23946
	extraTbl.disableRowByName(ETRow_FreightForwarderCode);																	// PAR #23565
	
	//self.cmbCarrier.setObject listObject := br.myCarrier
	//loose focus
	//tblBulkRelease
	//
	//topRow := self.tblBulkRelease.findObjectInRow(
	//if its a valid row
	//select the row
	//may need to call something to populate the txtBulkRelease
	//tblBulkRelease.topRow := topRow
/*	
	if CM_DeliveryRequest.hasInstance(req) then
		delvReq := req.CM_DeliveryRequest;
		
		cmb := pSheet.getControlByName(Cntrl_cmbISOType).ComboBox;
		if cmb &lt;&gt; null then
			cmb.GTE_ComboISOType.setObject(app.myRoot.allISOTypes[delvReq.isoType]);
			assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_IsoType, cmb.text);
			assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_DoISOGroupCheck, delvReq.doISOGroupCheck );	// RDD Xpose 1231/POT 147 9/8/2001
		endif;

		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_HeavyRated, 	delvReq.heavyRated);
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_QuantityTxt, 	1);
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_Clean, 		delvReq.clean);
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_Remarks, 		delvReq.remarks);
		assistant.mainExtraSetPowerReq(mainTbl, extraTbl, delvReq.needCOU, delvReq.needGenerator);

		id := delvReq.getIdsAsString;
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_IdMask, id);
		self.tblCommon.setValueByName(ETRow_AutoComplete, false);

		lstTable := pSheet.getControlByName(Cntrl_lstMTGrade).CMUI_ListTable;
		if lstTable &lt;&gt; null then
			assistant.setListTableMTGrade(lstTable, delvReq.allAvailabilityGrades);
			assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_AllMTGrades, lstTable.getSelectedString('code'));
		endif;
	endif;
*/
end;</source>
        <access>protected</access>
        <Parameter name="br" type="CM_BulkRelease"/>
        <Parameter name="pSheet" type="GTE_Sheet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromCopiedSheet" id="2fc05c67-46d3-42af-845d-6b3237adcce8">
        <source>setValuesFromCopiedSheet(pOldSheet, pNewSheet : GTE_Sheet);
// ---------------------------------------------------------------------------
// Created:     24 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	oldTbl,
	newTbl	: CM_EntryTable;
	type	: String;
			
begin

	oldTbl := pOldSheet.myTblMain;
	newTbl := pNewSheet.myTblMain;
	newTbl.setValuesFromOtherTable(oldTbl, GTE_InOutForm::setDefaultsCallBackForSheet.name);
	
	// Blank out the code fields dependent on the type
	type := pNewSheet.myMenuAction.code;
	if type = NavObj_GTE_In then
		newTbl.setValueByName(ETRow_IdTextBox, null);
	elseif type = NavObj_GTE_OutById then
		newTbl.setValueByName(ETRow_IdCombo, null);
	elseif type = NavObj_GTE_OutByType then
		// nothing to do
	endif;
	
	oldTbl := pOldSheet.myTblExtra;
	newTbl := pNewSheet.myTblExtra;
	newTbl.setValuesFromOtherTable(oldTbl, 'setDefaultsCallBackForSheet');

end;</source>
        <Parameter name="pOldSheet" type="GTE_Sheet"/>
        <Parameter name="pNewSheet" type="GTE_Sheet"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromLogDocketData" id="d5d9aff6-d97e-49b4-b463-952612fb93dd">
        <updating/>
        <source>setValuesFromLogDocketData(_logDocketData : CM_LogDocketData; _sheet : GTE_Sheet input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     15 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	mainTbl,
	extraTbl				: CM_EntryTable;
	assistant				: GTE_Assistant;
	loopCargoBOLType,
	theTopSheet				: GTE_Sheet;
	cmb						: ComboBox;
	operator				: CM_Operator;
	species					: CM_LogSpecies;
	grade					: CM_LogGrade;
	length					: CM_LogLength;
	failedDAC  :CM_DataAccessController;
	
	sheet : GTE_Sheet;
	
	//cnwmc5 - 2 April 2014 - CCMS 1127
	logType					: CM_LogType;
	treament				: CM_LogTreatment;
	logOrg					: CM_LoggingOrganisation;
	consignor				: CM_ConsigneeConsignor;
	carrier					: CM_Carrier;
	docketErrorType			: CM_DocketErrorType;
	forest					: CM_SourceLocation;
	compart					: CM_SourceSubLocation;
	stand					: CM_SourceSubSubLocation;
	yardLoc					: CM_LocationsController;
	tmpCompare				: CMIF_SearchTypes;
	allLogLocations			: CM_LCByIdExtKeyDict;
	
	//cnwmc5 - 18 August 2014 - PAR 34761
	realBlock			: CM_TerminalArea;
	
	yardTokens			: StringArray;
	block				: String;
	row					: String;
begin
	_sheet.setLogDocketData(_logDocketData);
	self.setDefaultsFromObject(_sheet, _logDocketData);
	
	assistant := self.myAssistant.GTE_Assistant;
	
	mainTbl := _sheet.myTblMain;
	extraTbl := _sheet.myTblExtra;
	
	assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_TruckNumber, _logDocketData.truckId);
	assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_BolNumber, _logDocketData.docketNumber);
	//#par 12348 - 7/11/2006
	assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_WeightGrossTonnes, ((_logDocketData.weightGross /1000).max(0)).String);
	assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_WeightTareTonnes, ((_logDocketData.weightTare /1000).max(0)).String);
	assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_WeightNetTonnes, ((_logDocketData.weightNett /1000).max(0)).String);
	assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_NumItems, _logDocketData.numPieces.String);
	
	//cnwmc5 - 1 April 2014 - CCMS 1127
	assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_FellDate, _logDocketData.date);
	assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_RegNumber, _logDocketData.regNo);
	assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_Activity, _logDocketData.truckCategory);
	extraTbl.setValueByName(ETRow_Activity, _logDocketData.truckCategory);				//cnwmc5 - 9 April 2014 - PAR 33937
	
	if self.fldInOut.sheets &lt;= 3 then
		self.tblCommon.setValueByName(ETRow_RegNumber, _logDocketData.regNo);
		self.txtRegNumber.text := _logDocketData.regNo;
		self.txtRegNumber.lostFocus(self.txtRegNumber);
		
		//cnwmc5 - 1 April 2014 - CCMS 1127
		self.cmbCarrier.setObject(app.myRoot.allCarriers[_logDocketData.carrierCode]);
		self.cmbCarrier.lostFocus(self.cmbCarrier);
		self.tblCommon.setValueByName(ETRow_CarrierCode, _logDocketData.carrierCode);			//cnwmc5 - 9 April 2014 - PAR 33937
		
		self.tblCommon.setValueByName(ETRow_DriverId, _logDocketData.driverId);
		self.tblCommon.setValueByName(ETRow_IsReceiptRequired, _logDocketData.receiptRequired);
	endif;
	
//	assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_BolNumber, _logDocketData.truckId);??
	
	operator := app.myRoot.allOperators[_logDocketData.operatorCode];
	if operator = null or (not operator.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		return;
	endif;

	assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_Supplier, operator.code);
	cmb := _sheet.getControlByName(Cntrl_cmbSupplier).ComboBox;
	if cmb &lt;&gt; null and cmb.listCount &gt; 0 then
		cmb.text := operator.code;
		cmb.listObject := operator;
		//par 18630
		//This method used to call cmb.lostFocus(cmb), but was removed
		//since the lostFocus method was causing issues with people on slow internet connections
		//the lostFocus method was changed but not readded to this part of the code.
		//the two method calls in lostFocus have been pulled into here so that the
		//tables are updated correctly.
		self.setCellTextFromControl(sheet, cmb, cmb.text);
		self.doLogComboSetup(self.myAssistant.GTE_Assistant, cmb.GTE_ComboBox);
	endif;	

	species := operator.getLogSpecies(_logDocketData.logSpeciesCode);
	if species &lt;&gt; null and species.notAvailableForEntry = false then
		cmb := _sheet.getControlByName(Cntrl_cmbLogSpecies).ComboBox;
		if cmb &lt;&gt; null and cmb.listCount &gt; 0 then
			cmb.text := species.code;
			cmb.listObject := species;
			cmb.lostFocus(cmb);
		endif;
	endif;
	
	if species &lt;&gt; null then
		grade := operator.getLogGrade(species.code, _logDocketData.logGradeCode);
		if grade &lt;&gt; null and grade.notAvailableForEntry = false then
			cmb := _sheet.getControlByName(Cntrl_cmbLogGrade).ComboBox;
			if cmb &lt;&gt; null and cmb.listCount &gt; 0 then
				cmb.text := grade.code;
				cmb.listObject := grade;
				cmb.lostFocus(cmb);
			endif;
		endif;
	endif;
	
	if species &lt;&gt; null and grade &lt;&gt; null then
		length := operator.getLogLengthForGrade(species.code, grade.code, _logDocketData.lengthRandom);
		if length &lt;&gt; null and length.notAvailableForEntry = false then
			cmb := _sheet.getControlByName(Cntrl_cmbLogLength).ComboBox;
			if cmb &lt;&gt; null and cmb.listCount &gt; 0 then
				cmb.text := length.code;
				cmb.listObject := length;
				cmb.lostFocus(cmb);
			endif;
		endif;
		
		//cnwmc5 - 1 April 2014 - CCMS 1127
		logType := operator.getLogTypeForGrade(species.code, grade.code, _logDocketData.logTypeCode);
		if logType &lt;&gt; null and logType.notAvailableForEntry = false then	
			cmb := _sheet.getControlByName(Cntrl_cmbLogType).ComboBox;
			if cmb &lt;&gt; null and cmb.listCount &gt; 0 then
				cmb.text := logType.code;
				cmb.listObject := logType;
				cmb.lostFocus(cmb);
			endif;
		endif;
		
		//cnwmc5 - 1 April 2014 - CCMS 1127
		treament := operator.getLogTreatmentForGrade(species.code, grade.code, _logDocketData.logTreatmentCode);
		if treament &lt;&gt; null and treament.notAvailableForEntry = false then
			cmb := _sheet.getControlByName(Cntrl_cmbTreatment).ComboBox;
			if cmb &lt;&gt; null and cmb.listCount &gt; 0 then
				cmb.text := treament.code;
				cmb.listObject := treament;
				cmb.lostFocus(cmb);
			endif;
		endif;
	endif;
	
	//cnwmc5 - 1 April 2014 - CCMS 1127
	logOrg := app.myRoot.allLoggingOrganisations[_logDocketData.loggingOrganisation];
	if logOrg &lt;&gt; null and logOrg.notAvailableForEntry = false then
		cmb := _sheet.getControlByName(Cntrl_cmbLoggingOrg).ComboBox;
		if cmb &lt;&gt; null and cmb.listCount &gt; 0 then
			cmb.text := logOrg.code &amp; Tab &amp; logOrg.description;
			cmb.listObject := logOrg;
			cmb.lostFocus(cmb);
		endif;
	endif;
	
	//cnwmc5 - 1 April 2014 - CCMS 1127
	consignor := app.myRoot.allConsigneeConsignors[_logDocketData.consignorCode];
	if consignor &lt;&gt; null and consignor.isNotAvailableForEntry = false then
		cmb := _sheet.getControlByName(Cntrl_cmbConsignorTop).ComboBox;
		if cmb &lt;&gt; null and cmb.listCount &gt; 0 then
			cmb.text := consignor.code;
			cmb.listObject := consignor;
			cmb.lostFocus(cmb);
		endif;
	endif;
	
	//cnwmc5 - 1 April 2014 - CCMS 1127
	forest := operator.getAllSrcLocn[_logDocketData.forest].CM_SourceLocation;
	if forest &lt;&gt; null and forest.notAvailableForEntry = false then
		cmb := _sheet.getControlByName(Cntrl_cmbSrcLocn).ComboBox;
		if cmb &lt;&gt; null and cmb.listCount &gt; 0 then
			cmb.text := forest.code;
			cmb.listObject := forest;
			cmb.lostFocus(cmb);
		endif;
	endif;
	
	if forest &lt;&gt; null then
		//cnwmc5 - 1 April 2014 - CCMS 1127
		compart := forest.allSubLocations[_logDocketData.compartment].CM_SourceSubLocation;
		if compart &lt;&gt; null and compart.notAvailableForEntry = false then
			cmb := _sheet.getControlByName(Cntrl_cmbSrcSubLocn).ComboBox;
			if cmb &lt;&gt; null and cmb.listCount &gt; 0 then
				cmb.text := compart.code;
				cmb.listObject := compart;
				cmb.lostFocus(cmb);
			endif;
		endif;
	endif;
	
	if compart &lt;&gt; null then
		//cnwmc5 - 1 April 2014 - CCMS 1127
		stand := compart.allSubSubLocations[_logDocketData.stand].CM_SourceSubSubLocation;
		if stand &lt;&gt; null and stand.notAvailableForEntry = false then
			cmb := _sheet.getControlByName(Cntrl_cmbSrcSubSubLocn).ComboBox;
			if cmb &lt;&gt; null and cmb.listCount &gt; 0 then
				cmb.text := stand.code;
				cmb.listObject := stand;
				cmb.lostFocus(cmb);
			endif;
		endif;
	endif;
	
	//cnwmc5 - 1 April 2014 - CCMS 1127
	docketErrorType := app.myRoot.allDocketErrorTypes[_logDocketData.docketError];
	if docketErrorType &lt;&gt; null and docketErrorType.notAvailableForEntry = false then
		cmb := _sheet.getControlByName(Cntrl_cmbDocketError).ComboBox;
		if cmb &lt;&gt; null and cmb.listCount &gt; 0 then
			cmb.text := docketErrorType.code;
			cmb.listObject := docketErrorType;
			cmb.lostFocus(cmb);
		endif;
	endif;
	
	//cnwmc5 - 18 August 2014 - PAR 34761 - changing the way yardLocation is populated... it now needs to be "BlockID [space] RowID"
	create yardTokens transient;
	_logDocketData.yardLocation.getTokensForDelimiter(" ", yardTokens);
	if yardTokens.size &gt; 1 then
		block := yardTokens[1];
		row := yardTokens[2];
		
		create tmpCompare transient;
		create allLogLocations transient;
		tmpCompare.myOperator	:= operator;
		tmpCompare.mySpecies	:= species;
		tmpCompare.myGrade		:= grade;
		tmpCompare.myType 		:= logType;
		tmpCompare.myTreatment	:= treament;
		tmpCompare.myLength		:= length;
		
		realBlock := self.myTerminal.allTerminalAreas[block];
		if realBlock &lt;&gt; null then
			realBlock.availableLocationsForType(tmpCompare, allLogLocations);
		endif;
		//self.myTerminal.availableLocationsForType(tmpCompare, allLogLocations, TA_TYPE_LOGAREA);
		
		if allLogLocations.size &gt; 0 then
			yardLoc := allLogLocations[row];
			if yardLoc &lt;&gt; null then
				cmb := _sheet.getControlByName(Cntrl_cmbLogLocation).ComboBox;
				cmb.listCollection(allLogLocations, false, null);
				cmb.text := yardLoc.CM_LogController.id;
				cmb.listObject := yardLoc;
				cmb.lostFocus(cmb);
			endif;
		endif;
	endif;
epilog
	delete yardTokens;
	delete tmpCompare;
	delete allLogLocations;
end;</source>
        <access>protected</access>
        <Parameter name="_logDocketData" type="CM_LogDocketData"/>
        <Parameter name="_sheet" type="GTE_Sheet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromReceivalTI" id="846cc88f-5a5a-4c4b-92e5-b3d1daa35e67">
        <updating/>
        <source>setValuesFromReceivalTI(pTI : CM_TrackedItem; pSheet : GTE_Sheet io) updating, protected;
// ---------------------------------------------------------------------------
// Created:     27 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.setDefaultsFromObject(pSheet, pTI);
end;</source>
        <access>protected</access>
        <Parameter name="pTI" type="CM_TrackedItem"/>
        <Parameter name="pSheet" type="GTE_Sheet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromReleaseTI" id="b2928201-4ad1-467c-8580-0fb9ea960fe1">
        <updating/>
        <source>setValuesFromReleaseTI(pTI : CM_TrackedItem; pSheet : GTE_Sheet io) updating, protected;
// ---------------------------------------------------------------------------
// Created:     27 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	5/6/01			AA		Consignee set from Tracked Item
// 14/04/2010	cnwdap1		PAR #23565 Display Freight forwarder
// 26/04/2010	cnwdap1		PAR #23946 Allow for ConsigneeConsignorCmbOrdDescr system setting when displaying freight forwarder
// ---------------------------------------------------------------------------
vars
	assistant		: GTE_Assistant;
	tmpCombo		: ComboBox;
	tmpTable		: CM_EntryTable;
	mainTbl			: CM_EntryTable;
	extraTbl		: CM_EntryTable;
	childTI			: CM_TrackedItem;
	tmpRow			: Integer;
	idx				: Integer;
	tmpConsignee	: CM_ConsigneeConsignor;
	tmpStr 			: String;
	freightFwdr		: CM_ConsigneeConsignor;
	
begin
	if pTI = null then
		return;
	endif;
	
	mainTbl 	:= pSheet.myTblMain;
	extraTbl 	:= pSheet.myTblExtra;

	assistant := self.myAssistant.GTE_Assistant;

	pSheet.setSubHeading(pTI.id);
	
	//Reset table based on TI cargo type
	tmpCombo := pSheet.getControlByName(Cntrl_cmbTiType).GTE_ComboBox;
	if pSheet.getCargoType &lt;&gt; pTI.myCargoType then
		tmpCombo.text := pTI.myCargoType.description;
		tmpCombo.click(tmpCombo);
	endif;

	mainTbl.setTableFromObject(pTI, null);
	extraTbl.setTableFromObject(pTI, null);	
	mainTbl.setValueByControlName(tmpCombo.name, tmpCombo.text);

	//Set the consignee if the TI has one and we can show it in the combo
	// PAR10735 consignee fewild not being set. 
	
	tmpCombo := pSheet.getControlByName(cmbConsignee.name).CMUI_ComboConsignors;
	tmpConsignee := app.myRoot.allConsigneeConsignors[pTI.consignee];
	tmpStr := assistant.displayEntryConsignor(tmpConsignee);
	assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_ConsigneeCode, tmpStr);
	tmpCombo.CMUI_ComboConsignors.setObject(tmpConsignee);
	//self.cmbConsignee.setType(CONSIGNEE);
	//self.myAssistant.comboBoxConsignor(cmbConsignee, null, CONSIGNOR);
		
	self.showHideStops(mainTbl, extraTbl, pTI);

	//Import items do not require a delivery reason
	if pTI.isImport then
		assistant.mainExtraHideRow(mainTbl, extraTbl, ETRow_DeliveryReason);
	else
		assistant.mainExtraShowRow(mainTbl, extraTbl, ETRow_DeliveryReason);
		// 	Redisplay delivery reason, which may have been hidden for Import items
		//	RDD PAR 1361 12/9/2001 -- this change made here 16/10/01 RDD
		//	Original fix was RDD PAR 1312 / PWL 832 27/8/2001 in cmbTI_lostFocus
	endif;

	if pTI.deliveryRelease &lt;&gt; null then	
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_DeliveryReleaseNumber, pTI.deliveryRelease.toUpper);
	endif;
	
    assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_IdCombo, pTI.id);
	assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_MyOperator, pTI.operatorCode);
	assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_CompanyCodeTxt, pTI.companyCode);
	assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_SetTemperature, pTI.getDisplayStringForAttribute(ETRow_SetTemperature,false));		// ccms 1355
	//assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_FreightForwarderCode, pTI.freightForwarderCode);	// PAR #23565	// PAR #23946
	if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then														// PAR #23946
		freightFwdr := pTI.myFreightForwarder;																				// PAR #23946
		if freightFwdr &lt;&gt; null then																							// PAR #23946
			assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_FreightForwarderCode, freightFwdr.description);			// PAR #23946
		endif;																												// PAR #23946
	else																													// PAR #23946
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_FreightForwarderCode, pTI.freightForwarderCode);				// PAR #23565
	endif;																													// PAR #23946
	extraTbl.disableRowByName(ETRow_FreightForwarderCode);																	// PAR #23565
	
	idx := assistant.mainExtraGetTableAndRow(mainTbl, extraTbl, ETRow_WeightTotal, tmpTable);
	if idx &gt; 0 then
		if pTI.cargoType &lt;&gt; TI_CargoType_COU and
		   pTI.cargoType &lt;&gt; TI_CargoType_Generator then
			tmpTable.showRow(idx);
			tmpTable.setValue(idx, pTI.totalWeight);
			tmpTable.disableRowByName(ETRow_WeightTotal);
		else
			tmpTable.hideRow(idx);
		endif;
	endif;
	
	if app.isSubTerminalsOn(self.myTerminal) then
		if pTI.mySubTerminal &lt;&gt; null then
			assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_MySubTerminal, pTI.mySubTerminal.code);
			//16/03/2011 cnwdz2 27183
			tmpCombo := pSheet.getControlByName(self.Cntrl_cmbSubTerminal).CMUI_ComboBox;	
			tmpCombo.listIndex	:=	tmpCombo.findObject(pTI.mySubTerminal);	
		endif;
		
		if not mainTbl.getValueByName(ETRow_ReleaseByType).Boolean then
			if pTI.mySubTerminal &lt;&gt; null then
				extraTbl.setValueByName(ETRow_SubTerminalDesc, pTI.mySubTerminal.code);
			endif;
		endif;
	else
		mainTbl.hideRowByName(ETRow_MySubTerminal, false);
		extraTbl.hideRowByName(ETRow_SubTerminalDesc, false);
	endif;
	
	tmpRow := extraTbl.getRow(GTE_Assistant.ATTACH_RowName &amp; '1');
	if tmpRow &gt; 0 then
		// delete existing Attachment lines from the table
		extraTbl.rows := tmpRow - 1;
	endif;
	
	//create children transient; //PAR 22954
	if (not pTI.allChildren.isEmpty) then //cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
		idx := 0;
		//pTI.getAllChildren(children);//PAR 22954
		foreach childTI in pTI.allChildren do
			idx := idx + 1;
			tmpRow := extraTbl.addAttribute(GTE_Assistant.ATTACH_RowName &amp; idx.String, app.getErrorString(Attachment) &amp; ' (' &amp; idx.String &amp; ')', Table.InputType_None, 0, true);
			extraTbl.setValue(tmpRow, childTI.id);
		endforeach;
	endif;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="pTI" type="CM_TrackedItem"/>
        <Parameter name="pSheet" type="GTE_Sheet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromReserveDetail" id="2004ccea-cce7-4480-9faf-ed7ed872d79d">
        <updating/>
        <source>setValuesFromReserveDetail(_res : CM_ReserveDetail; pSheet : GTE_Sheet io) updating, protected;
// ---------------------------------------------------------------------------
// Created:		March 2008 By Andrew Bishop cnwab1
//
// Purpose:		PAR 16242, now list reserve details in job list not bulk releases
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/09/2009	consw1		SFW1035 - get info from ReserveDetail rather than Yard Request
// 05/10/2009	cnwdad1		PAR #20969.
// 08/12/2009	cnwmh5		PAR 21565 - set sub terminal combos listObject
// 12/02/2010	cnwdad1		PAR #22328 - Changed to set the Customs Entry Number field.
// 14/04/2010	cnwdap1		PAR #23565 Show Freight forwarder
// 26/04/2010	cnwdap1		PAR #23946 Allow for ConsigneeConsignorCmbOrdDescr system setting when displaying freight forwarder
// 23/06/2023	navkc1		CR 58406 Task 58408: Jade - Release Request All Tracked Items
// ---------------------------------------------------------------------------
vars
	tmpInt		: Integer;
	assistant	: GTE_Assistant;
	mainTbl,
	extraTbl	: CM_EntryTable;
	cmb			: ComboBox;
	req			: CM_Request;
	delvReq		: CM_DeliveryRequest;
	tmpStr		: String;
	tmpStr2		: String;
	id			: String;
	ti			: CM_TrackedItem;
	tmpConsignee	: CM_ConsigneeConsignor;
	tmpCombo	: GTE_ComboBox;
	lstTable	: CMUI_ListTable;
	br, bulkRelease : CM_BulkRelease;
	tmpCombo2		: CMUI_ComboBox;				// 08/12/2009 cnwmh5 #21565
	freightFwdr		: CM_ConsigneeConsignor;
begin
	br := _res.myReserveHeader;
	assistant := self.myAssistant.GTE_Assistant;
	
	mainTbl := pSheet.myTblMain;
	extraTbl := pSheet.myTblExtra;	

	pSheet.setSubHeading(br.code);

	mainTbl.setTableFromObject(br, null);	

	if br.myOperator &lt;&gt; null then
		tmpStr := assistant.displayEntryOperator(br.myOperator);
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_OperatorCode, tmpStr);
		cmb := pSheet.getControlByName(Cntrl_cmbOperator).ComboBox;		
		if cmb &lt;&gt; null then
			cmb.GTE_ComboOperator.setObject(br.myOperator);
		endif;
	endif;

	if br.myOperatorGroup &lt;&gt; null then
		tmpStr := assistant.displayEntryOperatorGroup(br.myOperatorGroup);
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_MyOperatorGroup, tmpStr);
		cmb := pSheet.getControlByName(Cntrl_cmbOperatorGroup).ComboBox;
		if cmb &lt;&gt; null then
			tmpInt := cmb.findObject(br.myOperatorGroup);
			if tmpInt &gt; -1 then
				cmb.listIndex := tmpInt;
				//cmb.text := tmpStr;
			endif;				
		endif;
	endif;

	if br.myTransferToTerminal &lt;&gt; null then
		tmpStr := assistant.displayEntryTerminal(br.myTransferToTerminal);
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_MyTransferToTerminal, tmpStr);
		cmb := pSheet.getControlByName(Cntrl_cmbDestTerminal).ComboBox;
		if cmb &lt;&gt; null then
			tmpInt := cmb.findObject(br.myTransferToTerminal);
			if tmpInt &gt; -1 then
				cmb.listIndex := tmpInt;
			endif;				
		endif;
	endif;
	id := br.getMaskIdString;
	assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_IdMask, id);

	tmpStr := assistant.displayEntryBulkRelease(br);
	assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_ReleaseNoCmb, tmpStr);
	///assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_DeliveryReleaseNumber, tmpStr);	// 30/11/2010 cnwmh5 #26400
	cmb := pSheet.getControlByName(Cntrl_cmbBulkRelease).ComboBox;
	if cmb &lt;&gt; null then
		cmb.text := tmpStr.trimRight;
		cmb.listObject := br;
	endif;
	
	tmpStr2 := assistant.displayEntryDeliveryReleaseNo(br);				// 30/11/2010 cnwmh5 #26400
	if tmpStr2 &lt;&gt; null then
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_DeliveryReleaseNumber, tmpStr2);
	else
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_DeliveryReleaseNumber, tmpStr);
	endif;
	
// cnwdad1 05/10/2009 - PAR #20969.
	if app.isSubTerminalsOn(self.myTerminal) and br.mySubTerminal &lt;&gt; null then
		// 08/12/2009 cnwmh5 #21565 - Start
		tmpCombo2 := pSheet.getControlByName(self.Cntrl_cmbSubTerminal).CMUI_ComboBox;
		if tmpCombo2 &lt;&gt; null then
			tmpCombo2.text := br.mySubTerminal.code;
			tmpCombo2.click(tmpCombo2);
		endif;
		// 08/12/2009 cnwmh5 #21565 - End
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_MySubTerminal, br.mySubTerminal.code);
	endif;
	
// AER 1/10/2007 populate the tblExtra table for the specified bulkRelease	-Par 14997
	bulkRelease := cmb.listObject.CM_BulkRelease;
	if global.isValidObject(bulkRelease) then
		self.showBRDetails(bulkRelease);
	endif;
//	assistant.mainExtraSetValue(mainTbl, extraTbl, 'releaseByType', br.releaseByType);	

	// 13/08/2008 cnwar2 #16563 - set from reserve
	if _res.isKindOf(CM_ReserveSelection) then
		cmb := pSheet.getControlByName(Cntrl_cmbISOType).ComboBox;
		if cmb &lt;&gt; null then
			cmb.GTE_ComboISOType.setObject(_res.CM_ReserveSelection.myISOType);
			assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_IsoType, cmb.text);
			//assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_DoISOGroupCheck, _res.CM_ReserveSelection.doISOGroupCheck );
		endif;
		id := _res.CM_ReserveSelection.getIdsAsString();
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_IdMask, id);
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_HeavyRated, 	_res.CM_ReserveSelection.heavyRated);
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_QuantityTxt, 	1);
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_Clean, 		_res.CM_ReserveSelection.clean);
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_Remarks, 		_res.CM_ReserveSelection.remarks);
		
		lstTable := pSheet.getControlByName(Cntrl_lstMTGrade).CMUI_ListTable;
		if lstTable &lt;&gt; null then
			assistant.setListTableMTGrade(lstTable, _res.CM_ReserveSelection.allAvailabilityGrades);
			assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_AllMTGrades, lstTable.getSelectedString('code'));
		endif;
	elseif CM_ReserveTI.hasInstance(_res) then
		//PAR17915 - 16/9/2008 cnwsh3
		//For a CM_ReserveTI, there should only ever be one ti.
		//ti := _res.allTrackedItems.first;
		ti := _res.getFirstTI(false); //23/06/2023	navkc1	CR 58406 Task 58408
		
		tmpStr := ti.id;
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_IdCombo, tmpStr);
		cmb := pSheet.getControlByName(Cntrl_cmbTI).ComboBox;
		if cmb &lt;&gt; null then
			cmb.text := tmpStr.trimRight;
		endif;
		tmpCombo := pSheet.getControlByName(Cntrl_cmbTiType).GTE_ComboBox;
		tmpCombo.text := ti.myCargoType.description;
		tmpCombo.click(tmpCombo);
		mainTbl.setValueByControlName(tmpCombo.name, tmpCombo.text);
		extraTbl.setTableFromObject(ti, null);
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_MyOperator, ti.operatorCode);		
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_WeightTotal, ti.totalWeight);				
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_CompanyCodeTxt, ti.companyCode);						
// cnwdad1 12/02/2010 - PAR #22328.
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_CustomsEntryNumber, ti.customsEntryNumber);
		self.showHideStops(mainTbl, extraTbl, ti);
		
		if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then												// PAR #23946
			freightFwdr := ti.myFreightForwarder;																		// PAR #23946
			if freightFwdr &lt;&gt; null then																					// PAR #23946
				assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_FreightForwarderCode, freightFwdr.description);	// PAR #23946
			endif;																										// PAR #23946
		else																											// PAR #23946
			assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_FreightForwarderCode, ti.freightForwarderCode);		// PAR #23565
		endif;																											// PAR #23946
	endif;

	//epr par 20876 for some reason this code had been commented out put back in to fix par
	req := br.requests.first;
	
	if req = null then
		return;
	endif;

	// if bulk release has specific TIs, populate the list box with these only
	// RDD 12/10/2001 PAR1471 / PNL306  --  added here 16/10/01 RDD
	// assistant.comboBoxTrackedItemFromBulkRel( br, cmb );

	if br.requests.size = 1 and req.isKindOf(CM_TIRequest) then
		ti := req.CM_TIRequest.trackedItem;
		tmpStr := ti.id;
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_IdCombo, tmpStr);
		cmb := pSheet.getControlByName(Cntrl_cmbTI).ComboBox;
		if cmb &lt;&gt; null then
			cmb.text := tmpStr.trimRight;
		endif;
		tmpCombo := pSheet.getControlByName(Cntrl_cmbTiType).GTE_ComboBox;
		tmpCombo.text := ti.myCargoType.description;
		tmpCombo.click(tmpCombo);
		mainTbl.setValueByControlName(tmpCombo.name, tmpCombo.text);
		
		extraTbl.setTableFromObject(ti, null);
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_MyOperator, ti.operatorCode);		
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_WeightTotal, ti.totalWeight);				
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_CompanyCodeTxt, ti.companyCode);						
		self.showHideStops(mainTbl, extraTbl, ti);
		
		if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then												// PAR #23946
			freightFwdr := ti.myFreightForwarder;																		// PAR #23946
			if freightFwdr &lt;&gt; null then																					// PAR #23946
				assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_FreightForwarderCode, freightFwdr.description);	// PAR #23946
			endif;																										// PAR #23946
		else																											// PAR #23946
			assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_FreightForwarderCode, ti.freightForwarderCode);		// PAR #23565
		endif;																											// PAR #23946
	else
		tmpCombo := pSheet.getControlByName(Cntrl_cmbTiType).GTE_ComboBox;
		//tmpCombo.text := br.getMyCargoTypeDescription();
		tmpCombo.text := _res.getCargoTypeDescr();		// 17/11/2008 cnwar2 #18465
		tmpCombo.click(tmpCombo);
		mainTbl.setValueByControlName(tmpCombo.name, tmpCombo.text);	
	endif;

	tmpConsignee := app.myRoot.allConsigneeConsignors[br.consigneeCode];
	if tmpConsignee &lt;&gt; null then
		cmb := pSheet.getControlByName(Cntrl_cmbConsignee).CMUI_ComboConsignors;
		if cmb &lt;&gt; null then
			cmb.CMUI_ComboConsignors.setObject(tmpConsignee);
			assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_ConsigneeCode, cmb.text);
		endif;		
	endif;

//	assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_DeliveryReason, req.CM_YardRequest.reasonCodeDescr);
	assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_DeliveryReason, br.deliveryReasonDescr);
//	assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_ConsignorVoyageCode, req.CM_YardRequest.consignorVoyageCode);
	assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_ConsignorVoyageCode, br.consignorVoyageCode);
//	assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_EirNumber, req.CM_YardRequest.eirNumber);
	//assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_FreightForwarderCode, br.freightForwarderCode);				// PAR #23565	// PAR #23946
	if ti = null or ti.freightForwarderCode = null then	// display reqeust ff code if TI hasn't got one					// PAR #23946
		if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then												// PAR #23946
			freightFwdr := br.myFreightForwarder;																		// PAR #23946
			if freightFwdr &lt;&gt; null then																					// PAR #23946
				assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_FreightForwarderCode, freightFwdr.description);	// PAR #23946
			endif;																										// PAR #23946
		else																											// PAR #23946
			assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_FreightForwarderCode, br.freightForwarderCode);		// PAR #23946
		endif;																											// PAR #23946
	endif;																												// PAR #23946
	extraTbl.disableRowByName(ETRow_FreightForwarderCode);																// PAR #23565
	
	/*if CM_DeliveryRequest.hasInstance(req) then
		delvReq := req.CM_DeliveryRequest;

		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_HeavyRated, 	delvReq.heavyRated);
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_QuantityTxt, 	1);
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_Clean, 		delvReq.clean);
		assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_Remarks, 		delvReq.remarks);
		assistant.mainExtraSetPowerReq(mainTbl, extraTbl, delvReq.needCOU, delvReq.needGenerator);

		self.tblCommon.setValueByName(ETRow_AutoComplete, false);

		lstTable := pSheet.getControlByName(Cntrl_lstMTGrade).CMUI_ListTable;
		if lstTable &lt;&gt; null then
			assistant.setListTableMTGrade(lstTable, delvReq.allAvailabilityGrades);
			assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_AllMTGrades, lstTable.getSelectedString('code'));
		endif;
	endif;*/
	// This should be set from the reserve above.
end;</source>
        <access>protected</access>
        <Parameter name="_res" type="CM_ReserveDetail"/>
        <Parameter name="pSheet" type="GTE_Sheet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromStockOrder" id="a0038e52-a66b-4ec2-a8e1-2faece549a6c">
        <updating/>
        <source>setValuesFromStockOrder(_sheet : GTE_Sheet; _header : CM_StockOrderHeader) updating;
//-----------------------------------------
//Created: October 2002 By: cnwgd1
//-----------------------------------------
vars
	order		: CM_StockOrderLine;
	tmpCombo	: ComboBox;
begin

	if _header &lt;&gt; null then
		//At this stage we are only concerned with domestic log releases
		//which have a one to one relationship.
		order := _header.allStockOrderLines.first;
	endif;

	if order &lt;&gt; null and order.isKindOf(CM_StockOrderProductLine) then
		self.setValuesFromStockOrderLog(_sheet, order.CM_StockOrderProductLine);
	else
		
		tmpCombo := _sheet.getControlByName(Cntrl_cmbLogSpecies).GTE_ComboBox;
		if tmpCombo &lt;&gt; null then
			tmpCombo.text := null;
			tmpCombo.listObject := null;						
			tmpCombo.lostFocus(tmpCombo);
		endif;
		
		tmpCombo := _sheet.getControlByName(Cntrl_cmbConsignor).CMUI_ComboConsignors;				
		if tmpCombo &lt;&gt; null then
			tmpCombo.text := null;	
			tmpCombo.lostFocus(tmpCombo);
		endif;
		
		tmpCombo := _sheet.getControlByName(Cntrl_cmbConsignee).CMUI_ComboConsignors;				
		if tmpCombo &lt;&gt; null then
			tmpCombo.text := null;	
			tmpCombo.lostFocus(tmpCombo);
		endif;
		
		tmpCombo := _sheet.getControlByName(GTE_InOutForm::cmbLogLocation.name).GTE_ComboBox;				
		if tmpCombo &lt;&gt; null then
			tmpCombo.text := null;
			tmpCombo.listObject := null;
			tmpCombo.lostFocus(tmpCombo);					
		endif;
		return;
	endif;

end;</source>
        <Parameter name="_sheet" type="GTE_Sheet"/>
        <Parameter name="_header" type="CM_StockOrderHeader"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromStockOrderLog" id="7e9a8d19-a040-4ce7-8230-471f99ae37df">
        <updating/>
        <source>setValuesFromStockOrderLog(_sheet : GTE_Sheet; _stockOrder : CM_StockOrderProductLine) updating, protected;
//-----------------------------------------
//Created: October 2002 By: cnwgd1
//-----------------------------------------
vars
	tmpCombo	: GTE_ComboBox;
	logProduct	: CM_ProductLog;
	allocation	: CM_StockOrderAllocation;
	logLocation	: CM_LocationsController;
	tmpCmbCons	: CMUI_ComboConsignors;
	stkOrder	: CM_StockOrderProductLine;
	gateSheet	: GTE_Sheet;
	consign		: CM_ConsigneeConsignor;
begin

	gateSheet := _sheet;
	stkOrder := _stockOrder;
	if stkOrder = null then
		return;
	endif;
	
	if stkOrder.myProduct &lt;&gt; null
	and stkOrder.myProduct.cargoType = TI_CargoType_Log then
		logProduct := stkOrder.myProduct.CM_ProductLog;
	else //Only handling logs at present
		return;
	endif;

	tmpCombo 			:= gateSheet.getControlByName(Cntrl_cmbLogSpecies).GTE_ComboBox;
	if tmpCombo &lt;&gt; null then
		tmpCombo.text 		:= logProduct.speciesCode;	
		tmpCombo.listObject := logProduct.myLogSpecies;
		tmpCombo.lostFocus(tmpCombo);
	endif;
	
	tmpCombo 			:= gateSheet.getControlByName(Cntrl_cmbLogGrade).GTE_ComboBox;				
	if tmpCombo &lt;&gt; null then
		tmpCombo.text 		:= logProduct.gradeCode;	
		tmpCombo.listObject := logProduct.myLogGrade;
		tmpCombo.lostFocus(tmpCombo);
	endif;
	
	tmpCombo 			:= gateSheet.getControlByName(Cntrl_cmbTreatment).GTE_ComboBox;				
	if tmpCombo &lt;&gt; null then
		tmpCombo.text 		:= logProduct.treatmentCode;	
		tmpCombo.listObject := logProduct.myLogTreatment;
		tmpCombo.lostFocus(tmpCombo);
	endif;

	tmpCombo 			:= gateSheet.getControlByName(Cntrl_cmbLogType).GTE_ComboBox;				
	if tmpCombo &lt;&gt; null then
		tmpCombo.text 		:= logProduct.typeCode;	
		tmpCombo.listObject := logProduct.myLogType;
		tmpCombo.lostFocus(tmpCombo);
	endif;

	tmpCombo 			:= gateSheet.getControlByName(Cntrl_cmbLogLength).GTE_ComboBox;				
	if tmpCombo &lt;&gt; null then
		tmpCombo.text 		:= logProduct.lengthCode;	
		tmpCombo.listObject := logProduct.myLogLength;
		tmpCombo.lostFocus(tmpCombo);
	endif;
	
	if (not stkOrder.allStockAllocations.isEmpty) then
		//Domestic log releases can only be one location (field is optional)
		allocation		:= stkOrder.allStockAllocations.first;
		tmpCombo 		:= gateSheet.getControlByName(GTE_InOutForm::cmbLogLocation.name).GTE_ComboBox;				
		if tmpCombo &lt;&gt; null then
			if (tmpCombo.findObject(allocation.myLocationsController) &lt; 1) then
				tmpCombo.itemObject[tmpCombo.addItem(allocation.myLocationsController.displayEntry)] := allocation.myLocationsController;
			endif;
			tmpCombo.text 		:= allocation.myLocationsController.displayEntry;	
			tmpCombo.listObject := allocation.myLocationsController.CM_LogController;
			tmpCombo.lostFocus(tmpCombo);
		endif;
	endif;	

	tmpCmbCons := gateSheet.getControlByName(self.Cntrl_cmbConsignee).CMUI_ComboConsignors;
	if tmpCmbCons &lt;&gt; null then
		consign := stkOrder.getConsignee();
		if consign &lt;&gt; null then
			tmpCmbCons.setObject(consign);
			tmpCmbCons.lostFocus(tmpCmbCons);	
		endif;
	endif;	

end;</source>
        <access>protected</access>
        <Parameter name="_sheet" type="GTE_Sheet"/>
        <Parameter name="_stockOrder" type="CM_StockOrderProductLine"/>
    </JadeMethod>
    <JadeMethod name="setVolumeFromHLW" id="ee9dc6f2-cbae-402d-96b8-8dc97caf1960">
        <source>setVolumeFromHLW( table : CM_EntryTable input);
//-----------------------------------------------------------------------
//	Created:	30 May 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	length,	width,	height	: Integer;
	volume : Decimal[23,4];
	product : CM_Product;
	productCntrl : CMUI_ComboProduct;
	pSheet : GTE_Sheet;
begin
	//get value from table
	length			:= table.getValueByNameIfVisible(ETRow_MyLength).Integer;
	width			:= table.getValueByNameIfVisible(ETRow_MyWidth).Integer;
	height			:= table.getValueByNameIfVisible(ETRow_MyHeight).Integer;
	
	//don't bother doing calculation if fields are empty;
	//or values are 0 (can't work out volume)
	if length = 0 or width = 0 or height = 0 then
		return;
	endif;

	//get product
	pSheet := self.topSheet;
	productCntrl := pSheet.getControlByName(GTE_InOutForm::cmbProduct.name).CMUI_ComboProduct;
	product := productCntrl.listObject.CM_Product;
	
	if product = null then
		return;  //return, couldnt find product code from table
	endif;
	
	table.setValueByName ( ETRow_MyVolume, product.calculateVolume(length,width,height));
end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="d1ebcaea-c5c9-4c11-b3de-7335300d625f">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     09 August 2002 by cnwth2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	intArray	: IntegerArray;
	theMdiFrame	: Form;
	imex		: CM_IMEXStatus;
	idx			: Integer;

begin
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;

	self.trkLayoutIn.setPictures();
	self.trkLayoutIn.setMargins(10, 10, 10, 10);
	self.trkLayoutIn.myDoorsCheckBox.visible := false;

	self.trkLayoutOut.setPictures();
	self.trkLayoutOut.setMargins(10, 10, 10, 10);
	self.trkLayoutOut.addToFront := true;

	shtInOut.visible := false;
	
	// shift new btn off screen.  This is set to default when
	// user is in the txtNewItem textbox.
	btnNewItem.top := 0 - btnNewItem.height;
	btnNewItem.visible := true;
	
	maxSheetId := 0;

	btnDeleteCurrent.enabled := false;

	self.setNavigatorHeading(app.getErrorString(Road));

	self.initTblInOutCommon(tblCommon);
	self.initShtJobs();
	self.initShtLogDocketData();
	self.setAutomaticCellControls();
	self.armNotification();
	
//	self.txtBulkRelease.parentAspect := Control.ParentAspect_StretchBoth;
	
	// DVB changed to use new flags 05/04/05
	if app.isInterTerminalTransferEnabled() then
		self.initShtTransfers();
		self.shtTransfers.visible := true;
		self.fillTblTransfers();
	endif;
	
	self.setAutoComplete();
	self.sortColumnLogDocketData := 1;
	
	self.setColorsForEntryTable(tblCommon);
	
	self.setCaption(self.caption);
	
	self.fldInOut.useSheetBackColors := true;
	self.fldInOut.setDefaultSheetBackColors();
	// fldInOut sheet colours initalised in cloneSheet and deleteSheet methods
	self.fldLeft.useSheetBackColors := true;
	self.fldLeft.setDefaultSheetBackColors();
	self.fldLeft.initSheetBackColors();
	
	//Par 8969
	if self.myTerminal.defaultCargoType = TI_CargoType_Log then
		self.tblCommon.goToRowByName(ETRow_RegNumber);
		self.tblCommon.setFocus;
	else
		// doWindowEvents is a fudge as sometimes the setFocus does
		// not cause the app.activeControl to be set correctly which
		// then causes problems when the user tabs into tblCommon
		// (after Save tab key does not go to first row in tblCommon) - rjs Jun2303
		txtNewItem.doWindowEvents(0);
		txtNewItem.setFocus();
	endif;
	
	self.beginNotification(app.myPassport, self.myTerminal.getTerminalEvent(Event_Road_Receipt_Report), Response_Continuous, 0);
	
	
	// TFS 2734 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.txtNewItem.enabled:= false;
		self.tblCommon.userInputEnabled := false;
		self.shtInOut.disableAllChildren();
		self.shtJobs.disableAllChildren();
		self.shtLogDocketData.disableAllChildren;
		self.shtTransfers.disableAllChildren();
		
	endif;
	
epilog
	if intArray &lt;&gt; null then
		delete intArray;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="showBRDetails" id="3ed2f280-ddf1-460e-a519-c545a50f168a">
        <source>showBRDetails(_bulkRelease : CM_BulkRelease);
// ---------------------------------------------------------------------------
// Created:		14 October 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// Changed on	By		Reason
// ----------	-------	------------------------------------------------------
// 14/04/2010	cnwdap1	PAR #23565 Freight Forwarder in Extras table for releases
// 26/04/2010	cnwdap1	PAR #23946 Allow for ConsigneeConsignorCmbOrdDescr system setting when displaying freight forwarder
// 25/08/2010	cnwjo3	PAR #25538 removed ETRow_AllocatedItems
// ---------------------------------------------------------------------------
vars
	aSheet		: GTE_Sheet;
	extraTbl	: CM_EntryTable;
	mainTbl		: CM_EntryTable;
	assistant	: GTE_Assistant;
	cnt			: Integer;
	idx			: Integer;
	aTI			: CM_TrackedItem;
	data		: String;
	freightFwdr	: CM_ConsigneeConsignor;
	
begin
	// removed 1. should check obj not class, 2. is done already before method is called
	//if global.isValidObject(CM_BulkRelease) then
		if self.fldInOut.topSheet = null then
			return;
		endif;
		
		if  not self.fldInOut.topSheet.isKindOf(GTE_Sheet) then
			return;
		endif;

		aSheet := self.fldInOut.topSheet.GTE_Sheet;
		assistant := self.myAssistant.GTE_Assistant;
		extraTbl := aSheet.myTblExtra;
		mainTbl := aSheet.myTblMain;
		
		if assistant.isReleaseByType(mainTbl) then
			extraTbl.setValueByName(ETRow_BrTotalRequested, _bulkRelease.getDisplayStringForAttribute(ETRow_TotalRequested, false));
			extraTbl.setValueByName(ETRow_BrOutstanding, _bulkRelease.getTotalOutstanding.String);
			extraTbl.setValueByName(ETRow_BrRequestsActioned, _bulkRelease.getDisplayStringForAttribute(ETRow_RequestsBeingActioned, false));
			extraTbl.setValueByName(ETRow_BrDelivered, _bulkRelease.getDisplayStringForAttribute(ETRow_DeliveredToDate, false));
			//extraTbl.setValueByName(ETRow_FreightForwarderCode, _bulkRelease.getDisplayStringForAttribute(ETRow_FreightForwarderCode, false));	// PAR #23565
			if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then																// PAR #23946
				freightFwdr := _bulkRelease.myFreightForwarder;																				// PAR #23946
				if freightFwdr &lt;&gt; null then																									// PAR #23946
					assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_FreightForwarderCode, freightFwdr.description);					// PAR #23946
				endif;																														// PAR #23946
			else																															// PAR #23946
				assistant.mainExtraSetValue(mainTbl, extraTbl, ETRow_FreightForwarderCode, _bulkRelease.freightForwarderCode);				// PAR #23946
			endif;																															// PAR #23946
			
			if app.isSubTerminalsOn(self.myTerminal) then
				extraTbl.setValueByName(ETRow_MySubTerminal, _bulkRelease.getDisplayStringForAttribute(ETRow_MySubTerminal, false));
			endif;

			// ### ITEMS Delivered
			cnt		:=	_bulkRelease.releasedItemStrings.size;
			data	:=	"";
			
			if cnt &gt; 0 then
				foreach idx in 1 to cnt do
					data := data &amp; _bulkRelease.releasedItemStrings[idx].removeTabCrLfs() &amp; Cr;
				endforeach;
			endif;
			
			extraTbl.setValueByName(ETRow_BrItemsDelivered,data);
			
			// ### ITEMS Assigned
			data := "";
			
			foreach aTI in _bulkRelease.allTrackedItemsAssigned do
				data := data &amp; aTI.id &amp; Cr;
			endforeach;
			
			extraTbl.setValueByName(ETRow_BrAttachments,data);
			extraTbl.userInputEnabled := false;
		endif;
		
		//23/06/2009 cnwdz2 20072
		if not app.isSubTerminalsOn(self.myTerminal) then
			extraTbl.hideRowByName(ETRow_MySubTerminal, false);
			mainTbl.hideRowByName(ETRow_MySubTerminal, false);
		endif;
	//endif;
end;</source>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="showBulkReleaseDtl" id="5e99017d-a288-45f1-b1e7-afe06f8099f8">
        <source>showBulkReleaseDtl();

	/*
	Date		Who		Reason
	23 Oct 2008	cnwdz2	Par18353 - handle invalid object reference.
	25 Aug 2010 cnwjo3	Par25538 - removed Allocated items
	*/

vars
	data : String;
	assistant : GTE_Assistant;
	bulkRelease	: CM_BulkRelease;
	aSheet : GTE_Sheet;
	cnt, idx : Integer;
	extraTbl, mainTbl : CM_EntryTable;
	aTI : CM_TrackedItem;
	txtBRStr : String;
	reserve : CM_ReserveDetail;
	invalidBulkRelease : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, bulkRelease, invalidBulkRelease);
	
	if self.tblBulkRelease.row &gt; self.tblBulkRelease.fixedRows 
	and self.tblBulkRelease.accessRow(self.tblBulkRelease.row).selected then
// WAS PAR 16242		bulkRelease := self.tblBulkRelease.accessRow(self.tblBulkRelease.row).itemObject.CM_BulkRelease;
		reserve := self.tblBulkRelease.accessRow(self.tblBulkRelease.row).itemObject.CM_ReserveDetail;
		bulkRelease := reserve.myReserveHeader;
	//	if global.isValidObject(bulkRelease) then //23 Oct 2008	cnwdz2	Par18353
/* WAS
		txtBRStr := "Total Requested" &amp; Tab &amp; bulkRelease.getDisplayStringForAttribute(ETRow_TotalRequested, false) &amp; CrLf &amp;
						"Outstanding" &amp; Tab &amp; bulkRelease.getTotalOutstanding.String &amp; CrLf &amp; 
						"Being Actioned" &amp; Tab &amp; bulkRelease.getDisplayStringForAttribute(ETRow_RequestsBeingActioned, false) &amp; CrLf &amp; 
						"Delivered To Date" &amp; Tab &amp; bulkRelease.getDisplayStringForAttribute(ETRow_DeliveredToDate, false) &amp; CrLf  &amp;
						bulkRelease.getReleaseDetails() &amp; CrLf &amp; 
						"Allocated Items:" &amp; Tab &amp; bulkRelease.getDisplayStringForAttribute(ETRow_AllocatedItems, false) &amp; CrLf;
	NOW */		
			txtBRStr := "Total Requested" &amp; Tab &amp; reserve.getDisplayStringForAttribute(ETRow_TotalRequested, false) &amp; CrLf &amp;
						"Outstanding" &amp; Tab &amp;  reserve.getDisplayStringForAttribute(ETRow_QuantityRemaining, false) &amp; CrLf &amp;
						
						"Being Actioned" &amp; Tab &amp; reserve.getDisplayStringForAttribute(ETRow_RequestsBeingActioned, false) &amp; CrLf &amp;
						"Delivered To Date" &amp; Tab &amp; bulkRelease.getDisplayStringForAttribute(ETRow_DeliveredToDate, false) &amp; CrLf  &amp;
						reserve.getReleaseDetails();
			// ### ITEMS Assigned
			data := "";
			foreach aTI in bulkRelease.allTrackedItemsAssigned do
				if data = null then
					data := aTI.id;
				else
					data := data &amp; ', ' &amp; aTI.id;
				endif;
			endforeach;
			txtBRStr := txtBRStr &amp; CrLf &amp; "Attachments:" &amp; Tab &amp; data &amp; CrLf;		
			// ### ITEMS Delivered
			cnt := bulkRelease.releasedItemStrings.size;
			data := "";
			if cnt &gt; 0 then
				foreach idx in 1 to cnt do
					data := data &amp; bulkRelease.releasedItemStrings[idx] &amp; CrLf;		
				endforeach;
			endif;		
			txtBRStr := txtBRStr &amp;  CrLf &amp; "Items Delivered:" &amp; CrLf &amp; data;		
			
			//23 Oct 2008	cnwdz2	Par18353
			if invalidBulkRelease then 
				return;
			endif;
			
			self.txtBulkRelease.text := txtBRStr;
		//endif;
	endif;

end;
</source>
    </JadeMethod>
    <JadeMethod name="showHideStop" id="31bef141-3973-4d3e-980d-ca2cec571278">
        <source>showHideStop(pTblMain, pTblExtra : CM_EntryTable input; pField : String; pValue : Boolean);
// ---------------------------------------------------------------------------
// Created:     17 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx			: Integer;
	tmpTable	: CM_EntryTable;
	
begin

	idx := self.myAssistant.GTE_Assistant.mainExtraGetTableAndRow(pTblMain, pTblExtra, pField, tmpTable);
	if idx &gt; 0 then
		tmpTable.setValue(idx, pValue);
		if pValue then
			tmpTable.showRow(idx);
		else
			tmpTable.hideRow(idx);
		endif;
	endif;

end;</source>
        <Parameter name="pTblMain" type="CM_EntryTable" usage="input"/>
        <Parameter name="pTblExtra" type="CM_EntryTable" usage="input"/>
        <Parameter name="pField" type="String"/>
        <Parameter name="pValue" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showHideStops" id="693d4cd2-e787-4454-b493-d84a2a799df6">
        <source>showHideStops(pTblMain, pTblExtra : CM_EntryTable input; pTI : CM_TrackedItem);
// ---------------------------------------------------------------------------
// Created:     17 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	aStopTable			: CM_StopsTable;
	allowedStopTables	: CM_StopsTableByIdDict;
	passPort		: CM_Passport;
begin
	passPort := app.myPassport;
	
	if passPort &lt;&gt; null
	and passPort.myUser &lt;&gt; null then
		allowedStopTables := passPort.myUser.getStopsToMaintForTerminal(passPort.myTerminal);
	else
		allowedStopTables := app.myRoot.allStopsTable;
	endif;
	
	//foreach aStop in app.myRoot.allStopsTable do
	
	if allowedStopTables  &lt;&gt; null then//added by cnwyl1 0505
		foreach aStopTable in allowedStopTables do
			if pTI = null then
				self.showHideStop(pTblMain, pTblExtra, aStopTable.getAttrName, false);
			else
				self.showHideStop(pTblMain, pTblExtra, aStopTable.getAttrName, pTI.isStopSet(aStopTable.id));
			endif;
		endforeach;
	endif;//added by cnwyl1 0505

end;</source>
        <Parameter name="pTblMain" type="CM_EntryTable" usage="input"/>
        <Parameter name="pTblExtra" type="CM_EntryTable" usage="input"/>
        <Parameter name="pTI" type="CM_TrackedItem"/>
    </JadeMethod>
