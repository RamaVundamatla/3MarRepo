    <JadeMethod name="addToolbarControls" id="30fbccc3-5948-455e-a356-4b93e7a64ad1">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:     21 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	frm				: CMUI_Toolbar;
begin
//	inheritMethod();
	frm := self.frmToolbar;

	frm.addButton(self.btnNewCalendar, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnCalendarYear, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnNewDate, CMUI_Toolbar.Control_Alignment_Left);
	
	if not self.viewOnly then // if view only permision then dont add seperator as buttons will not be visible. 
		frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	frm.addButton(self.btnCopy, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnEdit, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);

	if not self.viewOnly then // if view only permision then dont add seperator as buttons will not be visible. 
		frm.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	frm.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);
	
	frm.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);

	frm.positionToolbarControls();
	frm.visible := true;
	
	frm := self.frmPropToolbar;
	frm.addButton(self.btnPropSave, CMUI_Toolbar.Control_Alignment_Left);
	frm.addButton(self.btnPropCancel, CMUI_Toolbar.Control_Alignment_Right);
	frm.positionToolbarControls();
	frm.visible := true;	
end;</source>
        <access>protected</access>
    </JadeMethod>
