//	self.carriageTempC := NULL_TEMPERATURE;
//	self.packTempC := NULL_TEMPERATURE;
//	self.packTempF := app.temperatureConversion(true, NULL_TEMPERATURE);	//NULL_TEMPERATURE;		//cnwmc5 - 4 September 2014
	
	self.setNullReeferDetails();	//25 Nov 2014	NDL	Par 35275
epilog

