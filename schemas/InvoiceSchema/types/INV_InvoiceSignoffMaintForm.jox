    <JadeMethod name="addObjectToTable" id="da13a3f5-bdb0-4eb8-b861-e1083643fb52">
        <updating/>
        <source>addObjectToTable(_obj: Object; _numItems: Integer io; _breakOut: Boolean io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 May 2018	jlgndl1	Initial creation	TFS 38535

*/

vars

begin
	if not _obj.isKindOf(CM_InvoiceSignoffUser) then
		return;
	endif;
	
	if _obj.CM_InvoiceSignoffUser.myBusinessUnit &lt;&gt; self.myCurrentBank then
		return;
	endif;
	
	if _obj.CM_InvoiceSignoffUser.myBusinessUnit &lt;&gt; null
	and not _obj.CM_InvoiceSignoffUser.myBusinessUnit.terminal = self.myTerminal then
		return;
	endif;
	
	inheritMethod(_obj, _numItems, _breakOut);

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_numItems" type="Integer" usage="io"/>
        <Parameter name="_breakOut" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addObjectsToTable" id="75810d6f-dda5-4984-b039-4000853f1e2f">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 May 2018	jlgndl1	Initial creation	TFS 38535

*/

vars
	signoffUser : CM_InvoiceSignoffUser;
	tmpPassport	: CM_Passport;
	breakOut	: Boolean;
begin

	self.setMyDataClass();
	
	self.myCurrentBank := self.cmbBank.listObject.CM_Bank;
	if self.myCurrentBank = null then
		return;
	endif;

	self.setCaption( app.getErrorString( Invoice_signoff_users ) &amp; " " &amp; self.myCurrentBank.code);
	tmpPassport := app.myPassport;
	
	foreach signoffUser in self.myCurrentBank.allInvoiveSignoffUsers do
		if self.includeObject(signoffUser, tmpPassport) then
			self.addObjectToTable(signoffUser, _numItems, breakOut);
		endif;
		if breakOut then
			break;
		endif;
	endforeach;

end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
