<Class name="JSSCTNotificationObjectTA" id="ae6a1884-7c46-4ff0-9427-199530d6129b">
    <superclass name="JSSCTTransactionAgent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="jssct_transient"/>
    <ImplicitInverseRef name="applicationSchema" id="a811c265-d8cf-4039-9d52-2096483593f6">
        <embedded/>
        <type name="Schema"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myNotificationObject" id="74b5e5c4-b24d-41cd-bd9d-0b36496ffec7">
        <embedded/>
        <type name="JSSCTNotificationObject"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myPersistentInstance" id="cac9b062-2206-4968-929f-aaeb057918fe">
        <embedded/>
        <type name="JSSCTNotificationObject"/>
    </ImplicitInverseRef>
    <PrimAttribute name="sharedTransient" id="6bf56337-fd8b-428e-b529-e65aab230976">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="usageCount" id="f6f64488-9e93-4aba-808d-e18ee52f4d0d">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="doCreate" id="750af23e-eb92-46df-9dd5-b6059442b8e0">
        <updating/>
        <source>doCreate(): Boolean updating, protected;
/*
*/
begin
	if self.sharedTransient then
		create self.myNotificationObject sharedTransient;
	else
		create self.myNotificationObject persistent;
	endif;
	self.myNotificationObject.createEntity(self);

	return (true);
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="99af5966-d228-4d42-aac1-008a70d87bc3">
        <updating/>
        <source>doDelete(): Boolean updating, protected;

vars

begin
	delete self.myNotificationObject;

	return (true);
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUpdate" id="e2cf41d8-31aa-49da-ba17-997d17a6e299">
        <updating/>
        <source>doUpdate(): Boolean updating, protected;
/*
*/
begin
	if self.sharedTransient then
		//	at this stage, the usageCount is an increment or decrement according to it's value
		self.usageCount := self.myNotificationObject.usageCount + self.usageCount;
		self.myNotificationObject.updateEntity(self);
	endif;
	return (true);
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
