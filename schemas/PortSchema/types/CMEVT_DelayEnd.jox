<Class name="CMEVT_DelayEnd" id="af48bb4e-95bf-4d57-9fe6-eeef7fa7ac35">
    <superclass name="CM_EventTransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="eventTrans"/>
    <ExplicitInverseRef name="myDelay" id="f3588d74-a06c-42db-b0c2-ca3ed956dfbe">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CM_Delay"/>
        <access>readonly</access>
        <Inverse name="CM_Delay::myEventEnd"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myMachineHistory" id="6c65834f-c4b9-4990-971a-5c8239c3cd9a">
        <embedded/>
        <type name="CM_MachineDelayHistory"/>
        <access>readonly</access>
        <Inverse name="CM_MachineDelayHistory::myDelayEndEvent"/>
    </ExplicitInverseRef>
    <JadeMethod name="create" id="02ae8f70-6f97-4b0a-acc8-792d5fe3ce92">
        <updating/>
        <source>create() updating;
/*
----------   ----------  --------------------------------------------------
Created:	14 February 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.type	:= EVT_DelayEnd;

end;


</source>
    </JadeMethod>
    <JadeMethod name="delete" id="7dd873c2-8c4e-4534-a5db-e5082dea9676">
        <updating/>
        <source>delete() updating;
/*
Purpose:	Remove any machine history for the delay event

Date		Who		Reason
05 April 2011	cnwcs5	Initial creation - CCMS 1132/par 27316
*/
vars
	history	:CM_MachineDelayHistory;
begin
	history := self.myMachineHistory;
	
	if history &lt;&gt; null then
		history.erase (NORMAL_ERASE);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getBank" id="599e7667-703c-420d-915b-42ea2b87f4a6">
        <source>getBank() : CM_Bank;
// ---------------------------------------------------------------------------
// Created:		18 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aVoy : CM_Voyage;
begin
	aVoy := self.getVoyage();
	if aVoy &lt;&gt; null then
		if aVoy.myDischargeCompany &lt;&gt; null then
			return aVoy.myDischargeCompany;
		endif;
	endif;
	return inheritMethod();
end;</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="getDebtor" id="b285e379-3c1c-412f-9ea3-4ee49983acc2">
        <source>getDebtor() : CM_Debtor;
// ---------------------------------------------------------------------------
// Created:		18 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aVoy : CM_Voyage;
begin
	aVoy := self.getVoyage();
	if aVoy &lt;&gt; null then
		if aVoy.myDebtor &lt;&gt; null then
			return aVoy.myDebtor.CM_Debtor; // &lt;&lt;&lt; this is virtual
		endif;
	endif;
	
	return inheritMethod();
end;</source>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getEndTS" id="2d89f809-46de-4b30-b041-d03708b538f5">
        <source>getEndTS() : TimeStamp;
// ---------------------------------------------------------------------------
// Created:		17 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.myDelay &lt;&gt; null then
		return self.myDelay.endDT;
	endif;
	return self.dateTime; 
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getName" id="3b9ce7d2-313a-41d9-bd14-08898f331189">
        <source>getName(): String;
// ---------------------------------------------------------------------------
// Created:		18 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.myDelay &lt;&gt; null then
		return self.myDelay.getDescription(false);
	else
		return inheritMethod();
	endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStartTS" id="fcccf38a-5a8e-4a2a-bf9f-201c15f69713">
        <source>getStartTS() : TimeStamp;
// ---------------------------------------------------------------------------
// Created:		17 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.myDelay &lt;&gt; null then
		return self.myDelay.startDT;
	endif;
	return self.dateTime;
end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getVoyage" id="fa19521a-0256-4699-a6ce-bd52d92105b0">
        <source>getVoyage() : CM_Voyage;
// ---------------------------------------------------------------------------
// Created:		17 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if self.myDelay &lt;&gt; null then
		return self.myDelay.myVoyage;
	endif;
	return null;
end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setDetailsFromCMIF" id="ec85e154-5dfa-4138-8d90-c41966c0730e">
        <updating/>
        <source>setDetailsFromCMIF(_eventType: CM_EventType; _cmifEventTrx: CMIF_DelayEventCtrl) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/02/2025	navkc1 JIRA Bug MTN-33582: MTN | Event Charging Refactor

*/

vars
	delay	: CM_Delay;
	machine	: CM_Machine;
begin
	
	delay := _cmifEventTrx.myDelay;
	
	if delay &lt;&gt; null then
		delay.setMyEventEnd(self);
		
		machine := delay.myMachine;
		
		if machine &lt;&gt; null then
			machine.addDelayEndHistory(self);
		endif;
		
	endif;
	
	// Keep this at the bottom so it calculate the charges after all details are entered
	inheritMethod(_eventType, _cmifEventTrx);
	
epilog

end;</source>
        <Parameter name="_eventType" type="CM_EventType"/>
        <Parameter name="_cmifEventTrx" type="CMIF_DelayEventCtrl"/>
    </JadeMethod>
</Class>
