    <JadeMethod name="menuSItemProperties_click" id="f88548d5-71fd-48bd-ad86-a1058873d9a5">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>menuSItemProperties_click(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

