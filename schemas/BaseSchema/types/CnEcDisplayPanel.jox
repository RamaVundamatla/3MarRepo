    <JadeMethod name="mouseUp" id="a4ed7796-b1d3-422b-86c6-8120b391fbc8">
        <updating/>
        <source>mouseUp(cntrl : BaseControl input; button : Integer; shift : Integer; x : Real; y : Real) updating;
// --------------------------------------------------------------------------------
// Created:		12 August 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars

begin
	if self.isInPainter() then
		self.resizeTables();
	endif;

	inheritMethod(cntrl, button, shift, x, y);
end;</source>
        <Parameter name="cntrl" type="BaseControl" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="paint" id="485eab8a-c3ad-4177-b407-3d0a10f323e6">
        <updating/>
        <source>paint(cntrl: BaseControl input) updating;
// --------------------------------------------------------------------------------
// Created:		12 August 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.resizeTables();
	inheritMethod(cntrl);
end;</source>
        <Parameter name="cntrl" type="BaseControl" usage="input"/>
    </JadeMethod>
    <JadeMethod name="refreshSelectedRow" id="3af85cc1-ed93-492b-a4a4-cef8159eb38b">
        <updating/>
        <source>refreshSelectedRow() updating;
// --------------------------------------------------------------------------------
// Created:		02 January 2002 by cnwdad1
//
// Purpose:		Refreshes the display information for the currently selected row in
//				the data table.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rowValues		: HugeStringArray;
	columnWidths	: IntegerArray;
	theRowObject	: Object;

begin
	theRowObject	:=	self.myDataTable.getRowObject();
	
	create rowValues transient;
	create columnWidths transient;
	
	if theRowObject &lt;&gt; null and app.isValidObject(theRowObject) then
		self.displayPanel(theRowObject, rowValues, columnWidths);
		self.buildDisplayTable(rowValues, columnWidths);
	else
		self.clearDisplay();
	endif;
epilog
	delete rowValues;
	delete columnWidths;
end;</source>
    </JadeMethod>
    <JadeMethod name="resizeColumnWidths" id="e4f227f5-1886-4c66-aeff-56aac0490d69">
        <source>resizeColumnWidths();
// --------------------------------------------------------------------------------
// Created:		16 August 1999 by cnwdad1
//
// Purpose:		Resizes the columns of the data table according to developer-specified dimensions.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	colCount	: Integer;
	colWidth	: Integer;

begin
	// Resize the data table's column widths.

	colCount	:=	1;			// Column 1 is already used, so we need to start incrementing from 1 onwards.

	foreach colWidth in self.dataColumnWidths do
		colCount	:=	colCount + 1;

		if (colCount &lt;= self.myDataTable.columns) then
			self.myDataTable.columnWidth[colCount]	:=	(self.myDataTable.width * (colWidth / 100)).Integer;
		endif;
	endforeach;

	// Resize the display table's column widths.

	self.myDisplayTable.accessMode	:=	Table.AccessMode_Column;
	colCount						:=	0;

	foreach colWidth in self.displayColumnWidths do
		colCount	:=	colCount + 1;

		if (colCount &lt;= self.myDisplayTable.columns) then
			self.myDisplayTable.columnWidth[colCount]	:=	(self.myDisplayTable.width * (colWidth / 100)).Integer;
			self.myDisplayTable.column					:=	colCount;
			self.myDisplayTable.backColor				:=	Cn_LightGray;
		endif;
	endforeach;

	self.myDisplayTable.accessMode	:=	Table.AccessMode_Sheet;
end;</source>
    </JadeMethod>
    <JadeMethod name="resizeTables" id="c3d09ece-3181-45e1-9327-80e9dcd8371b">
        <source>resizeTables();
// --------------------------------------------------------------------------------
// Created:		11 August 1999 by cnwdad1
//
// Purpose:		Positions and sizes the data and display tables, and the vertical
//				splitter bar on the Panel control.
//
// Parameters:	None
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	ratio		: Decimal[4,2];
	separation	: Integer;

begin
	if (self.dataToDisplayRatio &lt; 1) or (self.dataToDisplayRatio &gt; 100) then
		ratio	:=	0.50;
	else
		ratio	:=	self.dataToDisplayRatio / 100;
	endif;

	if (self.myVerticalSplitter = null) then
		separation	:=	5;
	else
		separation	:=	self.myVerticalSplitter.width.Integer;
	endif;

	if (self.myDataTable &lt;&gt; null) then
		self.myDataTable.move(-1, -1, ((self.width * ratio) - (separation div 2)), (self.height - 1));
		self.myDataTable.positionScrollbar();
		self.resizeColumnWidths();
	endif;

	if (self.myDisplayTable &lt;&gt; null) and (self.myDataTable &lt;&gt; null) then
		self.myDisplayTable.move((self.myDataTable.width + (separation div 2)), self.myDataTable.top, ((self.width - self.myDataTable.width) - separation), (self.myDataTable.height - 1));
		self.resizeColumnWidths();
	endif;

	if (self.myVerticalSplitter &lt;&gt; null) and (self.myDataTable &lt;&gt; null) then
		self.myVerticalSplitter.move((self.myDataTable.left + self.myDataTable.width), self.myDataTable.top, self.myVerticalSplitter.width, self.height);
		self.myVerticalSplitter.zOrder(1);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setDataToDisplayRatio" id="5b7ec158-4417-48c8-987c-9a83f6df5d25">
        <updating/>
        <source>setDataToDisplayRatio(value: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		12 August 1999 by cnwdad1
//
// Purpose:		Updates the ratio (percent in width) of the data table compared to
//				the display table.
//
// Parameters:	value (Integer) - The percent of the panel width used by the data table.
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars

begin
	if (dataToDisplayRatio &lt;&gt; value) then 
		dataToDisplayRatio	:=	value;
		self.resizeTables();
	endif;
end;</source>
        <Parameter name="value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="221f10e5-20b6-40d3-bed8-d27a3c46505f">
        <updating/>
        <source>windowCreated(cntrl : Control input; persistCntrl : Control) updating;
// --------------------------------------------------------------------------------
// Created:		11 August 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 28/02/2003	cnwdad1		Changed from setting background color with a global
//							constant to use the getSystemColor() method.
// --------------------------------------------------------------------------------
begin
	self.show3D		:=	Control.Show3D_Use3D;
	self.tabStop	:=	true;
	self.initializeDataTable();
	self.initializeDisplayTable();
	self.initializeVerticalSplitter();
	self.resizeTables();
	self.backColor	:=	self.getSystemColor(Window.Color_3DFace);		// cnwdad1 28/02/2003.

	inheritMethod(cntrl, persistCntrl);
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
