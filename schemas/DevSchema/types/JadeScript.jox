    <JadeMethod name="testSMTP" id="e0805120-09ad-4f60-9f98-d3e8b85103d5">
        <source>testSMTP();

constants

	Double_Semi = ";;";
	Single_Semi	= ";";
vars
	sm: CM_SmtpConnection;
	msg : String;
	toAddress : String;
	fromAddress : String;
	timeOut : Integer;
	tmpDir : String;
	tmpStr : String;
	sendSubject : String;
	sendMessage : String;
	pos : Integer;
	str : String;
begin
	app.initialize;
	toAddress := "rsargent@jadeworld.com";
	fromAddress := "cnwdmast@jadeworld.com";
	sendSubject := "Hello";
	sendMessage	:=	"This is a message";
	msg := 'Using CardSchema to send mail';
	app.writeLog(app.name&amp;' '&amp;msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	

	
	create sm;	
	//epr par 34068 6/11/14 changed encoding type to Base64 so could send message with extended ascii characters like ŕ in italian
	sm.encodingType := CnSmtpConnection.Base64; 
//	sm.beginNotification(sm, CnSmtpConnection.Completion_Event_Type, Response_Cancel, 0);
	sm.setLoggingRequired(true);
	app.writeLog(sm.contentType,LogINFO);	//25 Nov 2019	NDL	TFS 47053
	app.writeLog( app.name&amp;' '&amp;msg,LogINFO);	//25 Nov 2019	NDL	TFS 47053
	//Set up the mail server name
	sm.name			:= "smtp.cnw.co.nz";
//	sm.name := app.myRoot.getConfig(AutoSmtpServer).String;
	write sm.name;
/*	timeOut := app.myRoot.getConfig(AutoEmailTimeout).Integer;
	if timeOut &lt; 2 or timeOut &gt; 60 then
		timeOut := 30;
	endif;
	sm.timeout := timeOut * 1000;
*/
	//Set up the message parameters
//	sm.sendFrom	:= fromAddress;		// Who the message is from ...							
	pos := 2;
	str := app.cnGetServerMiscPath()[3:end];
	str := str[1:end].scanUntil("\", pos) &amp; "@jadeworld.com";
	
	sm.sendFrom		:= str;
	
//	tmpStr := toAddress.doInvalidCharacterSweep();
//	tmpStr := tmpStr.replaceString(Double_Semi, Single_Semi);
	//sm.sendTo		:=	self.toAddress.replaceString(Double_Semi, Single_Semi);  		// Who the message is to ...
	sm.sendTo := toAddress;
write tmpStr;	
//	tmpStr := self.ccAddresses.doInvalidCharacterSweep();
//	tmpStr := tmpStr.replaceString(Double_Semi, Single_Semi);
    //sm.cc			:=	self.ccAddresses.replaceString(Double_Semi, Single_Semi);		// CC Addresses;
//    sm.cc			:= tmpStr;
    
//    tmpStr := self.bccAddresses.doInvalidCharacterSweep();
//	tmpStr := tmpStr.replaceString(Double_Semi, Single_Semi);
   // sm.bcc			:=	self.bccAddresses.replaceString(Double_Semi, Single_Semi);		// Blind cc addresses
//	sm.bcc			:= tmpStr;
   
	sm.subject := sendSubject;		// The message subject ...                    		
    sm.message := sendMessage;		// The message text itself ...
	
//	tmpDir := app.getTempDirectoryFromSysConfig(); //PAR22336 - cnwsh3 - try and provide a location away from the temp dir to process.
//	app.checkTempDirFolderPath(tmpDir, method.qualifiedName, CMIF_ConfigRoot.name &amp; '::' &amp; CMIF_ConfigRoot::systemTempDir.name);//PAR22336 - cnwsh3 30/07/2010
    //Create the attachments
/*    foreach obj in self.allAttachedFiles do
		file := app.writeBinaryToFile(obj.CM_FileDataStorageHeader, tmpDir);
		if file &lt;&gt; null then
		    create attachment;								
		    attachment.fileName			:=	file;
			attachment.mySmtpConnection	:=	sm;
			attachment.encodingType		:= CnSmtpConnection.Base64; // adm 100709 Par 20094
//			attachment.contentType := self.getContentType(file);
		endif;
	endforeach;*/

	app.writeLog("*****Sending email:" &amp; CrLf &amp;
		Tab &amp; "To: " &amp; sm.sendTo &amp; CrLf &amp; 
		Tab &amp; "From: " &amp; sm.sendFrom &amp; CrLf &amp;
		Tab &amp; "Subject: " &amp; sm.subject &amp; CrLf &amp;
		Tab &amp; "Message: " &amp; sm.message &amp; CrLf &amp;
		Tab &amp; "Via : " &amp; sm.name,
		LogINFO);
    //Send the message and its attachments
    sm.send; 	
	
epilog
//	delete sm;
end;
</source>
    </JadeMethod>
    <JadeMethod name="testSal2" id="13b5e6c1-b3b7-4b92-9cda-f0fb3b96046f">
        <source>testSal2();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 December 2016	cnwma1	Initial creation
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels

*/


vars
	theCalcType : CM_CalculationType;
	newRate : Real;
	transDt,calDt : Date;
	allCalendarDates : CM_CalendarDatesByDateTimedict;
begin
	

	theCalcType := app.myRoot.allCalculationTypesByCode["SCT2"];
		
	if theCalcType = null then	
		app.invLog("Invalid CalculationType Used", LogINFO.String);
	endif;
	
	
	if theCalcType.myCalendarType1 &lt;&gt; null then
		create allCalendarDates transient;
		theCalcType.myCalendarType1.getAllCalendarDatesForDay( null, allCalendarDates);
		app.invLog("CalculationType Calendar USed =" &amp;theCalcType.myCalendarType1.description, LogINFO.String);
		if allCalendarDates.size &gt;0 then
			app.invLog("Is Holiday = true", LogINFO.String);
		endif;
	endif;
	


epilog
	delete allCalendarDates;
end;</source>
    </JadeMethod>
    <JadeMethod name="testWeightField" id="fbba5aa4-f1ed-4fc4-8f52-457365fdc1ce">
        <source>testWeightField();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2025	naviv1	Initial creation

*/

constants
	TEST_WEIGHT = 15000.0000;
vars

