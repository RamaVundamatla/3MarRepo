    <JadeMethod name="validateForUpdate" id="3fd038c8-be12-4770-9c04-7f69d5f689ed">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2023 navtnr20	TFS CR 57983 Task 57984: EUP - INCO Terms TRX Layer
*/

vars
	realInvoiceINCOMapping,realinvoice,incoTermMap   : CM_InvoiceINCOMapping;
	invLineDesc: 			CM_InvoiceLineDesc;
begin
	
	if self.myINCOTerm = null then
		app.raiseCMException(Input_require_myinco_term, null ,self);
	endif;
	
	if self.myDebtorType = null then
		app.raiseCMException(Input_required_field_debtor, null ,self);
	endif;
	
	realinvoice := app.myProxyManager.getRealObject(self).CM_InvoiceINCOMapping;
	
	foreach invLineDesc in self.allInvoiceLineTypes do
       realInvoiceINCOMapping := self.myINCOTerm.allINCOTermMappingsByInvLnType[invLineDesc];
        if realInvoiceINCOMapping &lt;&gt; null 
		and realInvoiceINCOMapping &lt;&gt; realinvoice then
            app.raiseCMException2(Invoice_linetyp_already_exists, invLineDesc.narration, realInvoiceINCOMapping.myDebtorType.description, null,null); 
        endif;
	endforeach;
		
	foreach incoTermMap in self.myINCOTerm.allINCOTermMappings do
		if incoTermMap &lt;&gt; realinvoice and incoTermMap.myDebtorType = self.myDebtorType then
			app.raiseCMException2(Debto_type_alrea_invoi_line_ma,self.myDebtorType.description,self.myINCOTerm.code,null,null); 
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
</Class>
