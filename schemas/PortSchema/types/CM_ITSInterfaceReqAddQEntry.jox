<Class name="CM_ITSInterfaceReqAddQEntry" id="cc2ea2bd-2443-4851-98d6-562e59fa37ae">
    <superclass name="CM_ITSInterfaceRequestInternal"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Created when a RT Queue entry is added or changed.

This will trigger JMT to check active machines in the queue for sending their next Queue Entry to ITS.
Note this is just a trigger for sending the next queue entry, not necessarily this one.</text>
    <DbClassMap file="jmtinterface"/>
    <ExplicitInverseRef name="myRTQueueEntry" id="85dbc73e-bfe6-4a1f-afc3-6fb2bac053b8">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_RTQueueEntry"/>
        <access>readonly</access>
        <Inverse name="CM_RTQueueEntry::allITSInternalAddRequests"/>
    </ExplicitInverseRef>
    <PrimAttribute name="queueEntryID" id="359017fc-d94b-40e0-b0a2-5e4e5b587dba">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="populateCmifMessage" id="773ff8ad-66b3-4a49-bc26-4fa42133d0f5">
        <source>populateCmifMessage(_cmifMsg: CMIF_ITSInterfaceMsg input; _validateFormat: Boolean);

/*

Purpose:			Get property values that may be stored in xml data.

Parameters:			_validateFormat - if true, an exception will be raised when invalid xml data is encountered.

Return Value:		_cmifMsg will be populated with values from message.


Date		Who		Reason
08 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	inheritMethod(_cmifMsg, _validateFormat);
	
	_cmifMsg.messageType 	:= ITS_MESSAGETYPE_INTERNALADDQE;
	_cmifMsg.queueEntryId 	:= self.queueEntryID;

epilog

end;</source>
        <Parameter name="_cmifMsg" type="CMIF_ITSInterfaceMsg" usage="input"/>
        <Parameter name="_validateFormat" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="1a055038-8a7e-41fa-8822-cc73d8d1c0c4">
        <updating/>
        <source>setForCreate(_pxyObject: CM_ITSInterfaceReqAddQEntry; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		None


Date		Who		Reason
26 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface
11 Mar 2011	cnwkpd1	PAR #27058 - Lock on Queue Entry moved here to prevent deadlocks

*/

vars
	invalidQ		: Boolean;
	
begin
	inheritMethod(_pxyObject, _passport);
	
	self.queueEntryID	:= _pxyObject.queueEntryID;
	
	// PAR #27058 - Lock the queue entry, if it does not exist then raise an exception to abort this
	// transaction
	on Exception do app.handleDeletedObject(exception, _pxyObject.myRTQueueEntry, invalidQ);
	sharedLock(_pxyObject.myRTQueueEntry);
	
	if invalidQ then
		app.raiseCMException1(Task_been_deleted, _pxyObject.queueEntryID.String, null, null);
		return;
	endif;
	
	self.myRTQueueEntry	:= _pxyObject.myRTQueueEntry;

epilog

end;</source>
        <Parameter name="_pxyObject" type="CM_ITSInterfaceReqAddQEntry"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="639df409-1fab-4513-b0a0-c55223f3fe24">
        <updating/>
        <source>setProxy(	_queueEntry		: CM_RTQueueEntry;
			_interfaceDefn	: CM_ITSInterfaceDefinition	) updating;

/*

Purpose:			Standard method for setting the proxy object's properties.

Parameters:			The entry that has been added to the RT Queue.

Return Value:		None


Date		Who		Reason
26 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	self.createdTS		:= app.actualTimeServer();
	self.priority		:= self.Priority_Low;
	self.queueEntryID	:= self.getInstanceIdForObject(_queueEntry).Integer;

	self.myUser			:= null;
	self.myMachine		:= null;
	self.myRTQueueEntry	:= _queueEntry;
	
	self.myITSInterfaceDefinition := _interfaceDefn;
	
epilog

end;</source>
        <Parameter name="_queueEntry" type="CM_RTQueueEntry"/>
        <Parameter name="_interfaceDefn" type="CM_ITSInterfaceDefinition"/>
    </JadeMethod>
</Class>
