    <JadeMethod name="addVehicleVisitRecord" id="deea98c8-1189-4bdd-b225-9cb6150916fd">
        <source>addVehicleVisitRecord(_truck: String; _state: String; _driver: String; _gateName: String): CM_VehicleVisitRecord;
/*
Date		Who		Reason
06 June 2012	cnwcs5	Initial creation - Messina Interface testing 
13/05/2022	 	navhl20 TFS 53430  EUP - Sub Carrier registration in MTN
*/
vars
	proxy, vvr	: CM_VehicleVisitRecord; 
	gate		: CM_Gate;
	aGate		: CM_GateArea;
	now			: TimeStamp;
	yic, driver : String;
begin
	// Create the Vehicle Visit Record
	gate := self.getGate(_gateName);

	if gate &lt;&gt; null then
		aGate := gate.getFirstAGate_IN();
	endif;	
	
	yic := self.opts.str("YardInterchangeArea");
	
	if _driver = null then
		driver := self.opts.str ("Driver");
	else
		driver := _driver;
	endif;
	
	create proxy transient;
	
	//proxy.setProxyFlexiGate(driver, driver, self.getProfileStr(UT_Profile.P_CARRIER), _truck, _state, yic,self.getTerminal(), gate, self.getGateLane(aGate, 1), null);		//13/05/2022 navhl20 TFS 53430
	proxy.setProxyFlexiGate(driver, driver, self.getProfileStr(UT_Profile.P_CARRIER),null, _truck, _state, yic,self.getTerminal(), gate, self.getGateLane(aGate, 1), null);		//13/05/2022 navhl20 TFS 53430			
				
	proxy.setAutoComplete(self.opts.bool("AutoComplete"));
	proxy.setTimeIn(now.date, now.time);
	
	app.myTrxCA.trxCreateVehicleVisitFlexi(proxy, vvr, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	return vvr;
epilog
	delete proxy;
end;

</source>
        <Parameter name="_truck" type="String"/>
        <Parameter name="_state" type="String"/>
        <Parameter name="_driver" type="String"/>
        <Parameter name="_gateName" type="String"/>
        <ReturnType type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="createCamProtocol" id="a07e392b-f9df-4910-a153-f5a3864f4558">
        <source>createCamProtocol(_name :String; _camGroup :CM_CamGroup; _camProtocolDesc :CM_CamProtocolDesc; 
						_prefix, _jrwReportName :String; _transactions :StringArray; _filter : CMQF_CamTransactionTemplate):CM_CamProtocol protected;
/*
Date		Who		Reason
05/06/2012	cnwcs5	Initial creation - messina JMT to CICs CAM protocols
*/
vars
	camProtocol				: CM_CamProtocol;
	emailEntity 			: CM_EmailEntity;
	scheduleTimes 			: TimeArray;
	freightForwarders 		: CM_ConsigneeConsignorSet;
	allCoarriExportPorts 	: CM_PortByCodeDict;
	emailCopyAddresses 		: CM_EmailEntityByTypeNameDict;
	packOperators 			: CM_OperatorByCodeDict;
	packExportConsignees 	: CM_ConsignByCodeDict;
	camEditTriggerFields 	: CM_CamEditTriggerFieldDict;
	camTrainEventTypes 		: CM_EventTypeByNameDict;
	allPackAreas 			: CM_TAByIdDict;
	now						: TimeStamp;
	emailMessage, emailSubject, destPath	:String;
	includeAllFields, emailEnabled, fileTransferEnabled, singleTrxPerFile	: Boolean;
	field					: CM_CamEditTriggerField;
	folder	:FileFolder;
	assoc	:CM_Association;
	lRegisteredCargoTypes : IntegerArray;
begin
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	
	emailEntity 	:= app.myRoot.allEmailEntities[1, "Mr. Testing"];

	if _prefix = '1046' then
		// create edit trigger fields for id &amp; operator
		field := CM_CamUserDefRepDesc.firstInstance.allCamEditTriggerFields['String', 'id'];
		
		self.assertNotNull (field);
		
		camEditTriggerFields.add (field);
		
		field := CM_CamUserDefRepDesc.firstInstance.allCamEditTriggerFields['String', 'operatorCode'];
		
		self.assertNotNull (field);
		
		camEditTriggerFields.add (field);
		// just email for 1046
	
		if emailEntity &lt;&gt; null then
			emailEnabled	:= true;
			emailSubject	:= 'CAMS 1046 Subject';
			emailMessage	:= 'CAMS 1046 Message';
		endif;
	elseif _prefix = '1009' or _prefix = '1004' then
		includeAllFields := true;
		
		if _prefix = '1009' then
			CM_CamUserDefRepDesc.firstInstance.allCamEditTriggerFields.copy (camEditTriggerFields);
		endif;
		 
		// file transfer just for 1046
		// fileTransferEnabled 	:= true;
		// cannot set single trx per file when i ad-hoc mode- it does not work
		
		assoc := self.getProfileSetting (UT_Profile.P_CAMS_DIRECTORY);
	
		if assoc &lt;&gt; null then
			destPath := assoc.asString &amp; 'XFER';
		else
			destPath := self.getTerminal.getConfig_FileDirectory (CamsFileDirectory).String &amp; 'XFER';
		endif;
		
		create folder transient;
		 
		folder.fileName 					:= destPath;
		folder.usePresentationFileSystem	:= true;
		 
		if not folder.isAvailable then
			folder.make();			
		endif;

	endif;
	
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	
// do not change these parameters - it will break all the unit tests !!!	
	camProtocol 	:= self.addCamProtocol(_name, _name, allCoarriExportPorts, _camGroup, null, emailEntity, false, emailCopyAddresses, false, emailMessage, emailSubject,
	                                   now, now, false, _prefix, "csv", null, packOperators, packExportConsignees, null, _camProtocolDesc, _transactions,
									   false, 1, false, scheduleTimes, 
									   false, false, false, false, false, false, false, false, false, false, false, false, 
									   false, false, false, false, false, false, false, false,  emailEnabled, singleTrxPerFile, fileTransferEnabled, includeAllFields, 
									   999999, 6, 100000, 0, '', destPath, _jrwReportName, camEditTriggerFields, camTrainEventTypes, _filter, false, 0, self.getTerminal, false, false, false, false, false, false, false, true /* null voyage*/, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);

	self.assertNotNullMsg(camProtocol, 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString());
	self.assertNotNull(camProtocol);
									   
	return camProtocol;
epilog
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete folder;
	delete lRegisteredCargoTypes;
end;</source>
        <access>protected</access>
        <Parameter name="_name" type="String"/>
        <Parameter name="_camGroup" type="CM_CamGroup"/>
        <Parameter name="_camProtocolDesc" type="CM_CamProtocolDesc"/>
        <Parameter name="_prefix" type="String"/>
        <Parameter name="_jrwReportName" type="String"/>
        <Parameter name="_transactions" type="StringArray"/>
        <Parameter name="_filter" type="CMQF_CamTransactionTemplate"/>
        <ReturnType type="CM_CamProtocol"/>
    </JadeMethod>
    <JadeMethod name="createCamProtocolEvent" id="8ce97a2c-5f82-41c3-a0ed-2db7d03b0764">
        <source>createCamProtocolEvent(_name :String; _camGroup :CM_CamGroup; _camProtocolDesc :CM_CamProtocolDesc; 
						_prefix, _jrwReportName :String; _events :CM_EventTypeByNameDict):CM_CamProtocol protected;
/*
Date		Who		Reason
05/06/2012	cnwcs5	Initial creation - messina JMT to CICs CAM protocols
*/
vars
	camProtocol				: CM_CamProtocol;
	emailEntity 			: CM_EmailEntity;
	scheduleTimes 			: TimeArray;
	freightForwarders 		: CM_ConsigneeConsignorSet;
	allCoarriExportPorts 	: CM_PortByCodeDict;
	emailCopyAddresses 		: CM_EmailEntityByTypeNameDict;
	packOperators 			: CM_OperatorByCodeDict;
	packExportConsignees 	: CM_ConsignByCodeDict;
	camEditTriggerFields 	: CM_CamEditTriggerFieldDict;
	trxColl 				: StringArray;
	allPackAreas 			: CM_TAByIdDict;
	now						: TimeStamp;
	emailMessage, emailSubject, destPath	:String;
	includeAllFields, emailEnabled, fileTransferEnabled, singleTrxPerFile	: Boolean;
	field					: CM_CamEditTriggerField;
	folder	:FileFolder;
	assoc	:CM_Association;
	lRegisteredCargoTypes : IntegerArray;
begin
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create trxColl transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	
	emailEntity 	:= app.myRoot.allEmailEntities[1, "Mr. Testing"];

	
// do not change these parameters - it will break all the unit tests !!!	
	camProtocol 	:= self.addCamProtocol(_name, _name, allCoarriExportPorts, _camGroup, null, emailEntity, false, emailCopyAddresses, false, emailMessage, emailSubject,
	                                   now, now, false, _prefix, "csv", null, packOperators, packExportConsignees, null, _camProtocolDesc, trxColl,
									   false, 1, false, scheduleTimes, 
									   false, false, false, false, false, false, false, false, false, false, false, false, 
									   false, false, false, false, false, false, false, false,  emailEnabled, singleTrxPerFile, fileTransferEnabled, includeAllFields, 
									   999999, 6, 100000, 0, '', destPath, _jrwReportName, camEditTriggerFields, _events, null, false, 0, self.getTerminal, false, false, false, false, false, false, false, true /* null voyage*/, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);

	self.assertNotNullMsg(camProtocol, 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString());
	self.assertNotNull(camProtocol);
									   
	return camProtocol;
epilog
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete trxColl;
	delete allPackAreas;
	delete folder;
	delete lRegisteredCargoTypes;
end;</source>
        <access>protected</access>
        <Parameter name="_name" type="String"/>
        <Parameter name="_camGroup" type="CM_CamGroup"/>
        <Parameter name="_camProtocolDesc" type="CM_CamProtocolDesc"/>
        <Parameter name="_prefix" type="String"/>
        <Parameter name="_jrwReportName" type="String"/>
        <Parameter name="_events" type="CM_EventTypeByNameDict"/>
        <ReturnType type="CM_CamProtocol"/>
    </JadeMethod>
    <JadeMethod name="par22028_EDIMsg" id="6cebb153-7f7a-4f81-b458-e98fffbc5acd">
        <source>par22028_EDIMsg(pMessage:String) protected;
// --------------------------------------------------------------------------------
// Created:		17 December 2009 by cnwdad1
//
// Purpose:		This method will load the actual EDI message.
//
// Parameters:	pMessage - The EDI message - this would normally be the contents of
//					the EDI (CSV) file.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	ediDataObj		: CM_EDIData;
	ediFileObj		: CM_EDIFile;
	tempStr : String;
	
begin
	ediFileObj	:=	self.ediLoadFileName(pMessage, EDIDataType_CargoFieldUpdate, "CargoFieldUpd", "CargoFieldUpd"&amp;method.name);	// EDIFileType_UserDefined
	self.assertNotNullMsg(ediFileObj, "EDI File (Load)");
	tempStr	:= 'Load failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(ediFileObj.ediData, tempStr);
	
	ediDataObj	:=	ediFileObj.ediData;
	self.assertNotNullMsg(ediDataObj, "EDI Data");
	
	self.ediVerify(ediFileObj);
	tempStr	:= 'Verify Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, tempStr);
	
	self.ediDBLoad(ediFileObj);
	tempStr	:= 'DBLoad Failed' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString;
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr &amp; pMessage);
epilog
	beginTransaction;
	ediFileObj.erase(NORMAL_ERASE);
	ediDataObj.erase(NORMAL_ERASE);
	commitTransaction;
	
//	self.assertDeleted(ediFileObj.getOidString());
//	self.assertDeleted(ediDataObj.getOidString());
end;</source>
        <access>protected</access>
        <Parameter name="pMessage" type="String"/>
    </JadeMethod>
    <JadeMethod name="receiveCargoById_Rail" id="aa8fe07e-2602-4b73-96e6-996194d8182f">
        <source>receiveCargoById_Rail(_bs :CM_BlockStack; _ti, _cargoType :String; _operator:CM_Operator;
							_isoCode, _commodity, _voyage :String):CM_TrackedItem protected;
/*
Date		Who		Reason
05 June 2012	cnwcs5	Initial creation - par 
// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/
constants
	TRAIN		= "UTCICSIN";
	RAILAREA	= 'UTCICS';
	WAGONCLASS		: String = "UK";
	WAGONMASTERCODE	: String = "UK2102";
	YA = 'UT_YA';
vars
	ti			: CM_TrackedItem;
	cargoType	: CM_CargoType;
	wagonClass	:CM_WagonClass;
	wagonMaster, pxyMaster	:CM_WagonMaster;
	train,pxyTrain		:CM_Train;
	wagonColl	:CM_WagonArray;
	railArea	:CM_Rail;
//	railIORake 	:CM_RailJSInOutRake;
	railLine	:CM_RailLine;
	tiColl		:CM_TIByIdDups;
	wagon		:CM_Wagon;
	trainSet	: CM_TrainSet;
	cmifRakeRegion	: CMIF_RakeRegion;
	wle			:CM_WorkListEntry;
	wc			:CMIF_WagonMoveController;
	booking		:CM_BookingRef;
	voyage		:CM_Voyage;
begin
	voyage 		:= self.getVoyage (_voyage);
	cargoType := getRoot.getCargoTypeFromAbbrevOrDescr( _cargoType );
	
	if cargoType.id = TI_CargoType_Container then
	
	else
	
	endif;
	
	self.assertNotNull (cargoType);
	
	ti := self.getTrackedItemByCargoType (_ti, cargoType.id);
	
	if ti &lt;&gt; null and ti.bookingReference &lt;&gt; null then
		self.deleteBooking (ti.bookingReference);
	endif;
	
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, false); // AKB added false
	endif;

	wagonMaster := self.getRoot.allWagonMasters[WAGONMASTERCODE];
	wagonClass := self.getRoot.allWagonClasses[WAGONCLASS];
	
	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons( wagonMaster );
	endif;
	
	self.deleteTrain(TRAIN,null);
	self.deleteRailArea(RAILAREA);
	
	self.disableAllYA (true);
	self.deleteYA (YA);
	self.addYACatchAll (YA, _bs);
	
//	----------------------------------------------------------------------------------------------
//	Add the train/wagons etc
//	----------------------------------------------------------------------------------------------
	train := self.addTrain(TRAIN,null);
	self.assertNotNullMsg(train, "For some reason couldn't create train");
	
	railArea := self.addRailArea(RAILAREA, 4, 5);
	self.assertNotNullMsg(railArea, "For some reason couldn't create rail area");
		
	railLine := railArea.allRailLinesByIndex.first; 
	self.assertNotNullMsg(railLine, "For some reason couldn't find rail line");
		
	create pxyMaster transient;
	
	pxyMaster.setProxy(	WAGONMASTERCODE, wagonClass,CM_Carrier.firstInstance, 450,60000, 15000);
	pxyMaster.setPropogateChanges(false);
	
	app.myTrxCA.trxCreateWagonMaster( pxyMaster, wagonMaster, app.myPassport );	
	
	self.assertNoTrxErrorsOrWarnings ();
//	------------------------------------------------	
// 	create wagon - with cargo to be received by rail 
//	------------------------------------------------	
//	_opts.addAssoc( UTTI_State, 0 );
//	_opts.addAssoc(UTTI_State,TI_STATE_NOTIFIED );
	
	self.ignoreTrxWarnings(true);
	
	if cargoType.id = TI_CargoType_Container then
		ti := self.addContainerOpts(_ti,  _isoCode, _commodity, _operator).CM_Container;
	else
/*		if _voyage &lt;&gt; null and _voyage &lt;&gt; NULL_VOYAGE_CODE then
			booking := self.addBookingForGeneralCargo ("CMS" &amp; _ti [(_ti.length - 3):end], _operator, voyage, _opts.str ("DestinationPort"), cargoType.id, 1);
			
			_opts.addAssoc("BookingItem", booking.allBookingRefItems.first);
		else
			_opts.addAssoc("BookingItem", null);
		endif;	
*/		
		// 25.01.2017 cnwmh5
		self.opts.purge();
		self.opts.addAssoc("MoveMode", PLANNING_MODE);
		ti := self.createTrackedItem (_ti, cargoType.id, _commodity, _operator, false, 
			_bs.myLocationsController);
		
		self.assertNoTrxErrorsOrWarnings;
		
		if ti.isKindOf (CM_TILC) then 
			// we need a trailer type
			beginTransaction;
			ti.CM_TILC.setMyType (CM_TILCType.firstInstance);
			commitTransaction;
		endif;
	endif;
	
	self.assertNotNullMsg (ti, _ti &amp; ' not created');
	
	create tiColl transient;
	create wagonColl transient;
	
	tiColl.add (ti);
	
//	wagon := self.addWagonToTrainOption2(train, wagonMaster, tiColl, false);
	wagon := self.addWagonToTrainOption3(train, WAGONMASTERCODE, wagonClass, ti, true, false);
	
	self.assertNotNullMsg(wagon, "Couldn't create a wagon");
	
	app.myTrxUA.trxUpdateWagonPosition(railLine, wagon, 1, app.myPassport);
	

	// we have a train and wagon but it has not arrived yet
	pxyTrain := app.createUpdateProxy(train).CM_Train;
	pxyTrain.setProxyDetails(app.actualTimeServer);	// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	self.ignoreTrxWarnings(true);

	app.myTrxUA.trxUpdateTrain(pxyTrain, false, app.myPassport);
	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Update Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());

	railLine.switchPositions(wagon, 01);	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Switch Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());

	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train, true, app.myPassport);  //in
	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Confirm IN Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
//	----------------------------------------------------------------------------------------------------------
//	move the cargo
//	----------------------------------------------------------------------------------------------------------
	wle := ti.allWorklistEntries.first;
	
	self.assertNotNull (wle);
	
	self.moveQueuedCargo (wle);

//	----------------------------------------------------------------------------------------------------------
//	now depart the train
//	----------------------------------------------------------------------------------------------------------
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, false, train, false, app.myPassport);  //iout
	
	// clear the entire train.
	create cmifRakeRegion transient;	
	cmifRakeRegion.myTrain := train;
	cmifRakeRegion.allWagons.add (wagon);
	cmifRakeRegion.clearAll	:= false;
	
	self.ignoreTrxWarnings(true);

	app.myTrxUA.trxUpdateRailClearRake(cmifRakeRegion, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());

	create trainSet transient;  
	trainSet.add(train);
	app.myTrxUA.trxUpdateTrainsDeparture(trainSet, app.myPassport);  
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Depart Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());

	return ti;
epilog
	delete tiColl;
	delete wagonColl;
	delete pxyTrain;
	delete pxyMaster;
	delete trainSet;
	delete wc;
	
	delete cmifRakeRegion;

	self.disableAllYA (false);
end;</source>
        <access>protected</access>
        <Parameter name="_bs" type="CM_BlockStack"/>
        <Parameter name="_ti" type="String"/>
        <Parameter name="_cargoType" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_isoCode" type="String"/>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_voyage" type="String"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="releaseContainerById_Rail" id="a8dba3da-f7c9-43fc-9ed7-4644a2a2f150">
        <source>releaseContainerById_Rail(_bs :CM_BlockStack; _container :String; _operator:CM_Operator;
							_isoCode, _commodity, _voyage :String):CM_Container protected;
/*
Date		Who		Reason
05 June 2012	cnwcs5	Initial creation - par 
// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/
constants
	TRAIN		= "UTCICS";
	RAILAREA	= 'UTCICS';
	WAGONCLASS		: String = "UK";
	WAGONMASTERCODE	: String = "UK2102";
vars
	container	: CM_Container;
	release		: CM_BulkRelease;
	
	wagonClass	:CM_WagonClass;
	wagonMaster, pxyMaster	:CM_WagonMaster;
	train,pxyTrain		:CM_Train;
	railArea	:CM_Rail;
	railIORake 	:CM_RailJSInOutRake;
	railLine	:CM_RailLine;
	tiColl		:CM_TIByIdDups;
	wagon		:CM_Wagon;
	cmifObjects : ObjectArray;
	intFaceBP	: CMIF_BuildPriority;
	cmifRequest	: CMIF_Request;
	trainSet	: CM_TrainSet;
	cmifRakeRegion	: CMIF_RakeRegion;
	obj			:Object;
	wle			:CM_WorkListEntry;
	controller	: CMIF_MoveController;
	lc			:CM_LocationsController;
begin
	deleteContainer(_container);
	deleteReleaseRequest(_container);

	wagonMaster := self.getRoot.allWagonMasters[WAGONMASTERCODE];

	if wagonMaster &lt;&gt; null then
		self.deleteWagonMasterAndWagons( wagonMaster );
	endif;
	
	self.deleteTrain(TRAIN,null);
	self.deleteRailArea(RAILAREA);
//	----------------------------------------------------------------------------------------------
//	Add the train/wagons etc
//	----------------------------------------------------------------------------------------------
	train := self.addTrain(TRAIN,null);
	self.assertNotNullMsg(train, "For some reason couldn't create train");
	
	railArea := self.addRailArea(RAILAREA, 4, 5);
	self.assertNotNullMsg(railArea, "For some reason couldn't create rail area");
	
	foreach obj in railArea.allRailJSInOut discreteLock do
		railIORake := obj.CM_RailJSInOutRake;
		if railIORake.getIoType() = Rail_JSIO_Type_Out then
			break;
		endif;
		railIORake := null;
	endforeach;
	
	self.assertNotNull(railIORake);
	
	railLine := railArea.allRailLinesByIndex.first; 
	self.assertNotNullMsg(railLine, "For some reason couldn't find rail line");
		
	create pxyMaster transient;
	
	pxyMaster.setProxy(	WAGONMASTERCODE, wagonClass,CM_Carrier.firstInstance, 450,60000, 15000);
	pxyMaster.setPropogateChanges(false);
	
	app.myTrxCA.trxCreateWagonMaster( pxyMaster, wagonMaster, app.myPassport );	
	
	self.assertNoTrxErrorsOrWarnings ();
	
	// create wagon - with cargo to be received by rail 
	create tiColl transient;
	
	wagon := self.addWagonToTrainOption2(train, wagonMaster, tiColl, false);

	self.assertNotNullMsg(wagon, "Couldn't create a wagon");
	
	// we have a train and wagon but it has not arrived yet
	pxyTrain := app.createUpdateProxy(train).CM_Train;
	pxyTrain.setProxyDetails(app.actualTimeServer);// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	self.ignoreTrxWarnings(true);

	app.myTrxUA.trxUpdateTrain(pxyTrain, false, app.myPassport);
	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Update Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());

	railLine.switchPositions(wagon, 01);	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Switch Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());

	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train, true, app.myPassport);  //in
	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Confirm IN Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
//	-----------------------------------------------------------------------------------------------------------	
// 	now the train has arrived
//	-----------------------------------------------------------------------------------------------------------
	
//	create cargo and release to train
	self.opts.addAssociation (UTTI_VoyageCode, _voyage);
	self.opts.addAssociation (UTTI_IMEX, TI_IMEX_STATUS_IMPORT);
	
	container := self.addContainerOpts(_container,  _isoCode, _commodity, _operator).CM_Container;

	self.move(container, _bs.myLocationsController);
	
	// remove all stops
	self.opts.addAssoc("CENum", "144");
	self.opts.addAssoc("customsNumber", "144");
	
	self.deleteStops(container);
	self.assertNoTrxErrorsOrWarnings();
	
	self.opts.addAssoc ("Operator", _operator);
	self.opts.addAssoc("ISOType", '2200');
	
	if _commodity = "MT" then
		self.opts.addAssoc ("FullRelease", false);
	else
		self.opts.addAssoc ("FullRelease", true);
	endif;
	
	release := self.addReleaseByTypeRequestOpts (_container, BR_TYPE_RAIL, TI_CargoType_Container);
	
	self.opts.addAssoc("release", release);
	
	// assign release to outwards rail area
	create cmifObjects transient;
	create intFaceBP transient;
	
	cmifObjects.add(intFaceBP);
	
	intFaceBP.mode := 1;
	
	release.allReserveDetails.copy(intFaceBP.allReservesToProcess);
	release.setInterfaceBP(intFaceBP, railIORake);
	
	cmifRequest := intFaceBP.allCMIFRequests.first;
	self.assertNotNull(cmifRequest);
	
	
	cmifRequest.quantityTxt := release.allReserveDetails.first.totalRequested;
	
	app.myTrxUA.trxUpdateAssignOutwardRail(cmifObjects, railIORake, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();

	// At this point the releases are showing on the rail ops form but with no TI assigned
	self.assertEqualMsg (release.allRequestsBeingActioned.size, 1, 'Expecting 1 request being actioned');

//	----------------------------------------------------------------------------------------------------------
// 	assign TIs to the release, assign releases to wagon and complete the moves 
//	----------------------------------------------------------------------------------------------------------
	wle := release.allRequestsBeingActioned.first.allWorkListEntries.first;
	
	create controller transient;
	controller.setMyOriginatingLocation(container.myPrimaryActualLocation);
	controller.setMyTrackedItem(container);
	controller.setMyWorkListEntry(wle);
	self.assertEqualMsg (container.CM_Container.availabilityGrade, 0, 'Availability grade is no longer 0');
	
	app.myTrxUA.trxUpdateWLEAssignTI(controller, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	
	delete pxyTrain;
	
	pxyTrain := app.createUpdateProxy(train).CM_Train;
	pxyTrain.setProxyDetails(app.actualTimeServer);// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	self.ignoreTrxWarnings(true);

	app.myTrxUA.trxUpdateTrain(pxyTrain, false, app.myPassport);
	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Update Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());

	railLine.switchPositions(wagon, 01);	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Switch Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());

	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train, true, app.myPassport);  //in
	
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Confirm IN Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());
	
	wle := release.allRequestsBeingActioned.first.allWorkListEntries.first;
	
	lc 	:= wagon.getNextFreeWagonContForRequest(wle.myRequest.CM_DeliveryRequest);
	
	self.assertNotNullMsg (lc, 'No wagon space left');
	app.myTrxUA.trxAssignWleToWagonController(wle.CM_YardWLE, 1, lc.CM_WagonController, false, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings ();
	
	self.queueWLE (wle);
	self.moveQueuedCargo (wle);
	
	// now depart the train
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, false, train, false, app.myPassport);  //iout
	
	// clear the entire train.
	create cmifRakeRegion transient;	
	cmifRakeRegion.myTrain := train;
	cmifRakeRegion.allWagons.add (wagon);
	cmifRakeRegion.clearAll	:= false;
	
	self.ignoreTrxWarnings(true);

	app.myTrxUA.trxUpdateRailClearRake(cmifRakeRegion, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());

	create trainSet transient;  
	trainSet.add(train);
	app.myTrxUA.trxUpdateTrainsDeparture(trainSet, app.myPassport);  
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Train Depart Errors &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());

	return container;
epilog
	delete tiColl;
	delete pxyTrain;
	delete pxyMaster;
	delete trainSet;
	delete cmifRakeRegion;
	delete controller;
	
	if cmifObjects &lt;&gt; null then
		foreach obj in cmifObjects do
			intFaceBP := obj.CMIF_BuildPriority;
			
			delete intFaceBP.myProxyRailJob;
			intFaceBP.allCMIFRequests.purge;
			delete intFaceBP;
	
		endforeach;
		cmifObjects.purge;
	endif;
	delete cmifObjects;
end;</source>
        <access>protected</access>
        <Parameter name="_bs" type="CM_BlockStack"/>
        <Parameter name="_container" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_isoCode" type="String"/>
        <Parameter name="_commodity" type="String"/>
        <Parameter name="_voyage" type="String"/>
        <ReturnType type="CM_Container"/>
    </JadeMethod>
    <JadeMethod name="tJMT_To_CICS" id="2f226769-babe-4863-ab10-a08156022e32">
        <updating/>
        <source>tJMT_To_CICS()updating;
// cnwrs1
/*
Date		Who		Reason
05/06/2012	cnwcs5	Initial creation - All JMT to CICs CAM protocols
// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
11 Jun 2019	jlgsl4	TFS 41215 - add pre-road-receive seal to Codeco
// 14 Oct 2022	navak20 53862 EUP - WMS - Damage Recording Extra Details
*/
constants
	VOYAGE 		= 'CICS001';
	VESSEL		= 'CICSVESSEL';
	OPERATOR 	= 'MSL';
	PORT		= 'NZAKL';
	
	CAMGROUP 	= 'UT_MSL';
	PROTOCOL1004 	= 'UTCICS_MES1004';
	PROTOCOL1006 	= 'UTCICS_MES1006';
	PROTOCOL1007 	= 'UTCICS_MES1007';
	PROTOCOL1008 	= 'UTCICS_MES1008';
	PROTOCOL1009 	= 'UTCICS_MES1009';
	PROTOCOL1011 	= 'UTCICS_MES1011';
	PROTOCOL1012 	= 'UTCICS_MES1012';
	PROTOCOL1046 	= 'UTCICS_MES1046';
	
	PROTOCOLEVENT	= 'UTCICS_EVENT';
	
	TRUCK	= 'UT_TRUCK';
	DRIVER	= 'UT_DRIVER';
	CARRIER	= 'UT_CARRIER';
//	I1004	
	BLOCKSTACK	= 'CICSBS';
	CONTAINER1	= 'UTMTROAD001';	// MT import road release
	CONTAINER2 	= 'UTMTROAD002';	// MT import road release
	CONTAINER3	= 'UTMTROAD003';	// MT import road release
	CONTAINER4 	= 'UTMTROAD004';	// MT import road release
	CONTAINER5 	= 'UTMTRAIL001';	// MT import rail release
	CONTAINER6 	= 'UTMTRAIL002';	// MT import rail release
	CONTAINER18 	= 'UTFLROAD018';	// Full import road release
	CONTAINER19 	= 'UTFLRAIL019';	// Full import rail release
	CONTAINER20		= 'UTMTROAD020';	// MT Import road release - will have ediSendDate set but should not be included
//	I1006/I1009	
	CONTAINER7 	= 'UTFLROAD001';	// Full export road receipt
	CONTAINER8 	= 'UTMTROAD005';	// MT export road receipt
	CONTAINER9 	= 'UTFLRAIL001';	// Full export rail receipt
	CONTAINER10	= 'UTMTRAIL003';	// MT export rail receipt
//	I1007/I1046
	CONTAINER11	= 'UTMTROAD006';	// MT storage road receipt
	CONTAINER12 = 'UTMTRAIL004';	// MT storage rail receipt
//	I1008
	GC001		= 'GCEXRD1';		// Widget road receipt
	CARGOTYPE1	= 'UT_WIDGET';
	GC002		= 'GCEXRD2';		// Long trailer raod receipt
	CARGOTYPE2	= 'TL';				// Long trailer
	GC003		= 'GCEXRD3';		// Truck road receipt
	CARGOTYPE3	= 'UT_TRUCK';
	GC004		= 'GCEXRL1';		// Widget rail receipt
	GC005		= 'GCEXRL2';		// Long trailer rail receipt
	GC006		= 'GCEXRL3';		// Truck rail receipt
//	I1011
	CONTAINER13	= 'UTMTSHIP001';	// MT ship release
	CONTAINER14	= 'UTRFSHIP002';	// Reefer ship release
//	I1012
	CONTAINER15	= 'UTMTSHIP003';	// MT ship receive
	CONTAINER16	= 'UTRFSHIP004';	// Reefer ship receive
//	I1046
	CONTAINER17	= 'UTMTYARD001';	// MT conatiner in yard
	
	BOL1011 = 'BOL1011';
	BOL1012 = 'BOL1012';
	CodeDS : String = "UT_";	// 14.10.2022 navak20 TFS 53862// ### 28OCT2022 CUT DAY 
	DescriptionDS : String = "Damage ";	// 14.10.2022 navak20 TFS 53862
	IsNotAvailableForEntryDS : Boolean = false;	// 14.10.2022 navak20 TFS 53862
	LevelDS : Integer = 7774;	// 14.10.2022 navak20 TFS 53862// ### 28OCT2022 CUT DAY 
vars

	voyage		:CM_Voyage;
	emailColl	:CM_EmailEntityByTypeNameDict;
	operator	:CM_Operator;
	opColl		:CM_OperatorByCodeDict;
	ffColl		:CM_ConsigneeConsignorSet;
	camGroup	:CM_CamGroup;
	bs 			:CM_BlockStack;
	protocol	:CM_CamProtocol;
	
	carrier		:CM_Carrier; 
	defCarrier	:String;
	
	port		:CM_Port;
	slot 		:CM_LocationsController;
	crane		:CM_Machine;
	
	container,
	damCont1, damCont2, damCont3 :CM_Container;
	ti, pxyTI	:CM_TrackedItem;
	cargoType	:CM_CargoType;
	bol			:CM_BOL;
	release		:CM_Release;
	
	startTS, endTS, origStartTS	:TimeStamp;
	strDamage		:String;
	strs			:StringArray;
	int				:Integer;
	damageCode		:CM_DamageDefinitionCode;
	damagePos		:CM_DamagePosition;
	
	tempDesc		: String;
	severity		: CM_DamageSeverity;
	
begin

	/*
	// 12/06/2014 cnwmh5 - since deleting cam group will get that to delete protocols
	self.deleteCamProtocol (PROTOCOL1004);
	self.deleteCamProtocol (PROTOCOL1006);
	self.deleteCamProtocol (PROTOCOL1007);
	self.deleteCamProtocol (PROTOCOL1008);
	self.deleteCamProtocol (PROTOCOL1009);
	self.deleteCamProtocol (PROTOCOL1011);
	self.deleteCamProtocol (PROTOCOL1012);
	self.deleteCamProtocol (PROTOCOL1046);
	self.deleteCamProtocol (PROTOCOLEVENT);
	*/
	self.setTerminalConfig(AllowRTSwithoutVGM, true);
	self.deleteStopsTable(981);
	self.deleteStopsTable(983);
	
	self.deleteCamGroup (CAMGROUP);
	
	self.deleteVoyage (VOYAGE);
	self.deleteVessel (VESSEL);
	self.deleteVehicle (TRUCK);
	self.deleteCarrier (CARRIER);
	
	self.deleteContainer (CONTAINER1);
	self.deleteContainer (CONTAINER2);
	self.deleteContainer (CONTAINER3);
	self.deleteContainer (CONTAINER4);
	self.deleteContainer (CONTAINER5);
	self.deleteContainer (CONTAINER6);
	self.deleteContainer (CONTAINER7);
	self.deleteContainer (CONTAINER8);
	self.deleteContainer (CONTAINER9);
	self.deleteContainer (CONTAINER10);
	self.deleteContainer (CONTAINER11);
	self.deleteContainer (CONTAINER13);
	self.deleteContainer (CONTAINER14);
	self.deleteContainer (CONTAINER15);
	self.deleteContainer (CONTAINER16);
	self.deleteContainer (CONTAINER17);
	self.deleteContainer (CONTAINER18);
	self.deleteContainer (CONTAINER19);
	self.deleteContainer (CONTAINER20);
	
	self.deleteCargo (GC001, CARGOTYPE1);
	self.deleteCargo (GC002, CARGOTYPE2);
	self.deleteCargo (GC003, CARGOTYPE3);
	self.deleteCargo (GC004, CARGOTYPE1);
	self.deleteCargo (GC005, CARGOTYPE2);
	self.deleteCargo (GC006, CARGOTYPE3);
	// ### 28OCT2022 CUT DAY self.deleteDamageSeverity(severity);	// 14.10.2022 navak20 TFS 53862
	operator := self.getOperator (OPERATOR);
	self.assertNotNullMsg (operator, OPERATOR &amp; ' operator not found');
	//severity := self.getMyTerminal.allDamageSeverities[DamageSeverity_2.String];	// 14.10.2022 navak20 TFS 53862
	severity := self.createDamageSeverity(CodeDS &amp; LevelDS.String,DescriptionDS &amp; LevelDS.String,IsNotAvailableForEntryDS,LevelDS);	// 14.10.2022 navak20 TFS 53862
	bol := self.getBOL(BOL1011, BOLType_GeneralBillOfLading, operator.code);
	
	if bol &lt;&gt; null then
		self.deleteBOL (BOL1011, bol);
	endif;
	
	bol := self.getBOL(BOL1012, BOLType_GeneralBillOfLading, operator.code);
	
	if bol &lt;&gt; null then
		self.deleteBOL (BOL1012, bol);
	endif;
		
	self.deleteTerminalArea (BLOCKSTACK);
		
	self.disableAllYA (true);
	
	self.opts.addAssoc ("CommodityRequired", false);

	if app.myRoot.getCargoTypeFromAbbrevOrDescr (CARGOTYPE1) = null then
		self.addCargoType (CARGOTYPE1, false);
	endif;
	
	self.opts.addAssoc ("TrackAs", ProductType_Vehicle);
	
	if app.myRoot.getCargoTypeFromAbbrevOrDescr (CARGOTYPE3) = null then
		self.addCargoType (CARGOTYPE3, false);
	endif;
	
	voyage := self.createVesselVoyage ( VOYAGE,VESSEL, operator);
	
	bs := self.addBlockStack (BLOCKSTACK, null, null);
		
	self.assertNotNull (bs);
		
	create emailColl transient;
	carrier := self.addCarrier (CARRIER, CARRIER, emailColl, false, true, true, null);

	self.assertNotNull (carrier);
	
	self.setTerminalConfig(DefRailCarrier, carrier.code);
	
	beginTransaction;

	// make sure default tare weight for 2200 is 1000kg
	app.myRoot.allISOTypes['2200'].setPropertyValue (CM_ISOType::tareKilos.name, 2000);
	commitTransaction;

	create ffColl transient;
	create opColl transient;

	
	CM_Operator.instances.copy (opColl);
	
	camGroup := self.addCamGroup (CAMGROUP, CAMGROUP, OPERATOR, null, null, null, false, false, false, opColl, ffColl, 10, 'MSL');
	
	self.assertNoTrxErrorsOrWarnings ();
	self.assertNotNullMsg (camGroup, 'Cam group not created');
	
//	----------------------------------------------------------------------------------------------------------------------------
//	I1004 - Create a release that is outside the start/endTS.  We will change the edisenddate later and see if it gets picked up
//	----------------------------------------------------------------------------------------------------------------------------
	self.opts.addAssoc (UTTI_Consignee, CM_ConsigneeConsignor.firstInstance.code);
	self.opts.addAssociation ("operImportReleasePin", "144");

	self.opts.addAssoc("OperatorPin", "144");	// 28/05/2013 cnwar2 #31458 - set the opImpRel PIN on the container - the PIN supplied to the gate out process will be validated against this

	container := self.releaseContainerByID_Road (TRUCK, DRIVER, bs, self.getSingleGate, CONTAINER20, operator, '2200', 'MT', VOYAGE);
	
	self.assertNotNull (container);
	self.opts.addAssoc (UTTI_Consignee, null);	// for later
	self.opts.addAssociation ("operImportReleasePin", null);

	
	process.sleep (100);
	// make sure the release date time is b4 our start date time for cams
	startTS 	:= app.actualTimeServer;	// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	origStartTS	:= startTS;
	
	// save release transaction for later
	release := container.getTransRelease;
	
	self.assertNotNull (release);
//	-----------------------------
//	I1011 - Release Cargo to Ship
//	-----------------------------
	port := app.myRoot.allPorts[PORT];
	self.assertNotNull (port);

	bol := self.addBOL('BOL1011', voyage, operator, null, self.getTerminal);
	self.opts.addAssoc (UTTI_BOL, bol.number);

	// ### 20 MT
	container := self.addContainerAtLocnDisch(CONTAINER13, "2200", "GENL", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage);
	self.assertNotNullMsg(container,'Adding Container ' &amp; CONTAINER13.display &amp; ' failed.' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString);

	beginTransaction;
	container.setDestinationPort ("NZWEL");
	commitTransaction;
	// ### 20 REEFERS
	container := self.addContainerAtLocnDisch(CONTAINER14, "2232", "REEF", TI_IMEX_STATUS_EXPORT, bs.myLocationsController, port, voyage);
	
	self.assertNotNullMsg(container, 'Adding Container ' &amp; CONTAINER14.display &amp; ' failed.' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString);
	
	beginTransaction;
	container.setDestinationPort ("NZNSN");
	commitTransaction;
//	-----------------------------
//	I1012 - Receive Cargo from Ship
//	-----------------------------
	port := app.myRoot.allPorts[self.getTerminal.getConfig(PortDestCode).String];
	self.assertNotNull (port);
	
	// create on-ship cargo
	bol := self.addBOL('BOL1012', voyage, operator, null, self.getTerminal);
	self.opts.addAssoc (UTTI_BOL, bol.number);
	// ### 20 GENERALS
	create strs transient;
	strs.clear;
	strs.add("030682");
	voyage.findLocation(strs, false, slot, int);
	container := self.addContainerAtLocnDisch(CONTAINER15, "2200", "MT", TI_IMEX_STATUS_IMPORT, slot, port, voyage);
	self.assertTrueMsg((container.getImExStatus() =TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	beginTransaction;
	container.setLoadPort ("NZWEL");
	commitTransaction;
	
	// make this one hazardous
	self.addTIHazard (container, '1.2', false);
	
	self.assertTrueMsg (container.isHazardous, 'Container not hazardous');
	
	// ### 20 REEFERS
	strs.clear;
	strs.add("030684");
	voyage.findLocation(strs, false, slot, int);
	container := self.addContainerAtLocnDisch(CONTAINER16, "2232", "REEF", TI_IMEX_STATUS_IMPORT, slot, port, voyage);
	self.assertTrueMsg((container.getImExStatus() =TI_IMEX_STATUS_IMPORT), "ImEx on Imports is wrong" );
	beginTransaction;
	container.setLoadPort ("NZLYT");
	commitTransaction;
	
	// make this one damaged
	damageCode 	:= app.myRoot.allCargoTypesById [TI_CargoType_Container].allDamageDefinitionCodes.first;
	damagePos	:= app.myRoot.allCargoTypesById [TI_CargoType_Container].allDamagePositions.first;
	
	if damageCode = null then
		damageCode := CM_DamageDefinitionCode.firstInstance;
	endif;
	
	if damagePos = null then
		damagePos := CM_DamagePosition.firstInstance;
	endif;
	
	self.addDamage (container, damageCode.code, damagePos.code, severity, 1, "Testing I1009");	// 11.07.2022 navak20 TFS 53862
	damCont1 := container;
	
	self.assertTrueMsg (container.damaged, 'Container not damaged');
	
	app.myTrxUA.trxSetDfltDischargeColourCode(voyage.myCellularVoyageStructure, app.myPassport);
	self.assertNoTrxErrorsOrWarnings ();
	
	crane := self.getFirstCrane;
	self.assertNotNullMsg(crane, 'Failed to get crane ');

	self.createVoyageDischargeJobs (voyage, crane.id);
	self.createVoyageLoadJobs (voyage, PORT, crane.id);
	self.planLoadItems (voyage, crane.id);
	self.loadAllJobsToOps(voyage, true);
	self.planDischargeItems(voyage, bs, crane.id);
	self.moveAllCargo (voyage);
	
//	-----------------------------
//	I1004 - MT Releases
//	-----------------------------
	self.opts.purge;
	self.opts.addAssociation ("operImportReleasePin", "144");
	self.opts.addAssoc  ("DeliveryReleaseReason", DEL_SNT);
	self.opts.addAssoc (UTTI_Remarks, 'I1004 Testing');
	self.opts.addAssoc ("CreateDeliveryRequest", true);

// 	Release MT by Road - no consignee, no booking
	self.releaseContainerByID_Road (TRUCK, DRIVER, bs, self.getSingleGate, CONTAINER1, operator, '2200', 'MT', VOYAGE);
//	Release Full by Road - no consignee, no booking
	self.releaseContainerByID_Road (TRUCK, DRIVER, bs, self.getSingleGate, CONTAINER2, operator, '2200', 'GENL', VOYAGE);
// 	Release MT by Road - has consignee, no booking I1004
	self.opts.addAssoc (UTTI_Consignee, CM_ConsigneeConsignor.firstInstance.code);
	self.releaseContainerByID_Road (TRUCK, DRIVER, bs, self.getSingleGate, CONTAINER3, operator, '2200', 'MT', VOYAGE);
// 	Release Full by Road - has consignee, no booking - should NOT be include in I1004
	self.releaseContainerByID_Road (TRUCK, DRIVER, bs, self.getSingleGate, CONTAINER18, operator, '2200', 'GENL', VOYAGE);
// 	Release MT by Road - no consignee, no booking 1004
	self.opts.addAssoc (UTTI_Consignee, null);
	self.opts.addAssoc (UTTI_BookingRef, "BKCICS004");
	self.releaseContainerByID_Road (TRUCK, DRIVER, bs, self.getSingleGate, CONTAINER4, operator, '2200', 'MT', VOYAGE);
//	Release MT by Rail - has consignee, no booking I1004
	self.opts.addAssoc (UTTI_Consignee, CM_ConsigneeConsignor.firstInstance.code);
	self.opts.addAssoc (UTTI_BookingRef, null);
	self.opts.addAssoc ('Carrier', carrier);
	self.releaseContainerById_Rail (bs, CONTAINER5, operator, '2200', 'MT', VOYAGE);
//	Release Full by Rail - has consignee, no booking - should NOT be included in I1004
	self.releaseContainerById_Rail (bs, CONTAINER19, operator, '2200', 'GENL', VOYAGE);
//	Release MT by Rail - no consignee, no booking
	self.opts.addAssoc (UTTI_Consignee, null);
	self.releaseContainerById_Rail (bs, CONTAINER6, operator, '2200', 'MT', VOYAGE);
//	Set the ediSendDateTime for our release transaction created earlier - it will be within start/endTS but the option to include the release is not set
//  need to update the transaction using trx *****************
	//beginTransaction;
	//release.setPropertyValue (CM_TITransaction::camsTimeStamp.name, app.actualTimeAppServer);
	
	app.myTrxDA.trxDeleteTITransaction (release, null, app.myPassport);	// need to do this so we can undelete		// 12/10/18 MAP TFS41191

	self.setTerminalConfig(CamsCreateTrxAudit, true);

	app.myTrxUA.trxUndeleteTITransaction (release, app.myPassport);	// 

	self.setTerminalConfig(CamsCreateTrxAudit, false);

	//commitTransaction;
//	--------------------------------
//	I1006 - Receive Export Container
//	--------------------------------
// 	full export road 
	self.opts.addAssoc (UTTI_Remarks, 'I1006 Testing');
	self.opts.addAssoc ("Driver", DRIVER);
	container := self.receiveContainerIntoYard_Road (TRUCK, bs, self.getSingleGate, CONTAINER7, operator, '2200', 'GENL', voyage, 'NZZQN', 'NZBLU', TI_IMEX_STATUS_EXPORT, null); // TFS 41215
	
	beginTransaction;
	container.setSealNumCustoms ('CusSeal001');
	container.setSealNumShippers ('ShipSeal001');
	container.setSealNumOperators ('OpSeal001');
	container.setMark ('Mark001');
	container.setRemarks ('I1006 Testing', null);
	container.setDescription ('I1006 Dewcription');
	container.setWeightTare (1000);
	commitTransaction;
// 	MT Export road 
	container := self.receiveContainerIntoYard_Road (TRUCK, bs, self.getSingleGate, CONTAINER8, operator, '2200', 'MT', voyage, 'NZZQN', 'NZBLU', TI_IMEX_STATUS_EXPORT, null); // TFS 41215
	
	beginTransaction;
	container.setSealNumCustoms ('CusSeal002');
	container.setSealNumShippers ('ShipSeal002');
	container.setSealNumOperators ('OpSeal002');
	container.setMark ('Mark002');
	container.setRemarks ('I1006 Testing', null);
	container.setDescription ('I1006 Description');
	container.setWeightTare (1000);
	commitTransaction;
	
// 	Full Export rail 
	self.opts.addAssoc ("DestinationPort", 'NZZQN');
	self.opts.addAssoc ("DischargePort", 'NZBLU');
	self.opts.addAssoc ("IMEX", TI_IMEX_STATUS_EXPORT);
	
	container := self.receiveCargoById_Rail (bs, CONTAINER9, 'CONT',operator, '2200', 'GENL', voyage.code).CM_Container;
	
	beginTransaction;
	container.setSealNumCustoms ('CusSeal003');
	container.setSealNumShippers ('ShipSeal003');
	container.setSealNumOperators ('OpSeal003');
	container.setMark ('Mark003');
	container.setRemarks ('I1006 Testing', null);
	container.setDescription ('I1006 Description');
	commitTransaction;
// 	MT Export rail 	
	container := self.receiveCargoById_Rail (bs, CONTAINER10,  'CONT', operator, '2200', 'MT', voyage.code).CM_Container;
	
	beginTransaction;
	container.setSealNumCustoms ('CusSeal004');
	container.setSealNumShippers ('ShipSeal004');
	container.setSealNumOperators ('OpSeal004');
	container.setMark ('Mark004');
	container.setRemarks ('I1006 Testing', null);
	container.setDescription ('I1006 Dewcription');
	commitTransaction;
	
	
//	--------------------------------
//	I1007 - Receive Storage Container
//	--------------------------------
	self.opts.addAssoc (UTTI_Remarks, 'I1007 Testing');
	self.opts.addAssoc ("IMEX", TI_IMEX_STATUS_STORAGE);
	//self.opts.addAssoc (UTTI_TotalWeight, 1000);
	container := self.receiveContainerIntoYard_Road (TRUCK, bs, self.getSingleGate, CONTAINER11, operator, '2200', 'MT', voyage, 'NZZQN', 'NZBLU', TI_IMEX_STATUS_STORAGE, null); // TFS 41215
	container := self.receiveCargoById_Rail(bs, CONTAINER12,  'CONT',operator, '2200', 'MT', voyage.code).CM_Container;
//	--------------------------------
//	I1008 - Receive Export Cargo
//	--------------------------------
// 	GC Export - I1008
	ti := self.receiveGCIntoYard_Road (TRUCK, bs, self.getSingleGate, GC001, operator, CARGOTYPE1, null, voyage, 'NZZQN', 'NZBLU', TI_IMEX_STATUS_EXPORT);
// 	GC Export (Trailer) - I1008
	ti := self.receiveGCIntoYard_Road (TRUCK, bs, self.getSingleGate, GC002, operator, CARGOTYPE2, null, voyage, 'NZZQN', 'NZBLU', TI_IMEX_STATUS_EXPORT);
// 	GC Export (Truck) - I1008
	ti := self.receiveGCIntoYard_Road (TRUCK, bs, self.getSingleGate, GC003, operator, CARGOTYPE3, null, voyage, 'NZZQN', 'NZBLU', TI_IMEX_STATUS_EXPORT);
	
	self.opts.addAssoc ("IMEX", TI_IMEX_STATUS_EXPORT);
// 	GC Export - I1008
	ti := self.receiveCargoById_Rail (bs, GC004, CARGOTYPE1, operator,  null, null, voyage.code);
// 	GC Export (Trailer) - I1008
	ti := self.receiveCargoById_Rail (bs, GC005, CARGOTYPE2, operator, null, null, voyage.code);
// 	GC Export (Truck) - I1008
	ti := self.receiveCargoById_Rail (bs, GC006, CARGOTYPE3, operator, null, null, voyage.code);

// 	now run the protocols
	endTS := app.actualTimeServer;// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	
	self.zJMT_To_CICS_1004 (PROTOCOL1004, camGroup, startTS, endTS);
	self.zJMT_To_CICS_1006 (PROTOCOL1006, camGroup, startTS, endTS);
	self.zJMT_To_CICS_1007 (PROTOCOL1007, camGroup, startTS, endTS);
	self.zJMT_To_CICS_1008 (PROTOCOL1008, camGroup, startTS, endTS);
	self.zJMT_To_CICS_1011 (PROTOCOL1011, camGroup, startTS, endTS);
	self.zJMT_To_CICS_1012 (PROTOCOL1012, camGroup, startTS, endTS);

//	-------------------------------------------------------
//	I1009 - Edit Cargo Record - all trigger fields selected
//	-------------------------------------------------------
// 	containers 7-10 are all on site so use these for editing
	startTS := app.actualTimeServer;	// so we don't pick up edits from creating the cargo above
	
	container := self.getTrackedItem (CONTAINER7).CM_Container;
	
	beginLoad;
	pxyTI := container.pxyCreateUpdateProxy ();
	endLoad;
	
	pxyTI.setSealNumOperators ("op007");
	pxyTI.setSealNumShippers ("ship007");
	
	app.myTrxUA.trxUpdateTrackedItem (pxyTI, "Testing I009", TI_UPDMODE_NORMAL, null, app.myPassport);

	delete pxyTI;
//	hazard edit	
	container := self.getTrackedItem (CONTAINER8).CM_Container;
	
	self.addTIHazard (container, '1.2', false);
//	commodity edit - should not be included
	container := self.getTrackedItem (CONTAINER9).CM_Container;
	
	self.editCommodity (container, 'BISC');
//	discharge port edit	- should not be included
	ti := self.getTrackedItem (GC006);

	self.editDischargePort (ti, 'NZNSN');
// 	damage edit		
	container := self.getTrackedItem (CONTAINER10).CM_Container;

	self.addDamage (container, CM_DamageDefinitionCode.firstInstance.code, CM_DamagePosition.firstInstance.code, severity, 1, "Testing I1009");
	damCont2 := container;
	
	strDamage := container.getDamageCodesCSV;
	
	
//  remove hazards
	container := self.getTrackedItem (CONTAINER15).CM_Container;
	
	beginLoad;
	pxyTI := container.pxyCreateUpdateProxy ();
	endLoad;
		
	pxyTI.allTIHazards.purge;
	
	app.myTrxUA.trxUpdateTrackedItem (pxyTI, "Testing I009", TI_UPDMODE_NORMAL, null, app.myPassport);

	self.assertNoTrxErrorsOrWarnings ();
	
	self.assertFalseMsg (container.isHazardous, 'Container still hazardous');
	
	delete pxyTI;
	
//  remove damage
	container := self.getTrackedItem (CONTAINER16).CM_Container;

	beginLoad;
	pxyTI := container.pxyCreateUpdateProxy ();
	endLoad;

	pxyTI.purgeAllDamageInstance; 
	pxyTI.setDamaged (false);

	app.myPassport.setWarningsIgnored (true);
	
	app.myTrxUA.trxUpdateTrackedItem (pxyTI, null, TI_UPDMODE_NORMAL, null, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings ();
	
	self.assertFalseMsg (container.damaged, container.id &amp; ' - Container still damaged');
	
	delete pxyTI;
// 	now run the protocol
	endTS := app.actualTimeServer;// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	self.zJMT_To_CICS_1009 (PROTOCOL1009, camGroup, startTS, endTS, strDamage);

//	--------------------------------
//	I1046 - Edit Fleet Cargo
//	--------------------------------
// 	containers 11-12 are all on site so use these for editing	
//	update id
	container := self.getTrackedItem (CONTAINER11).CM_Container;
	
	beginLoad;
	pxyTI := container.pxyCreateUpdateProxy ();
	endLoad;
	
	pxyTI.setPropertyValue (CM_Container::id.name, 'UTMTROAD076');
	
	self.expectTrxError(ERR_CONTAINER_NO);
	
	app.myTrxUA.trxUpdateTrackedItem (pxyTI, "Testing I046", TI_UPDMODE_NORMAL, null, app.myPassport);
	
	self.assertTrueMsg (app.myPassport.trxCompletedOK, 'could not update id. ' &amp; app.myPassport.getErrorsAndWarningsAsString);

	delete pxyTI;
//	update id, carrier remarks, and operator	
	container := self.getTrackedItem (CONTAINER12).CM_Container;
	
	beginLoad;
	pxyTI := container.pxyCreateUpdateProxy ();
	endLoad;
	
	pxyTI.setPropertyValue (CM_Container::id.name, 'UTMTRAIL908');
	pxyTI.setPropertyValue (CM_Container::carrierRemarks.name, 'Testing MSL Interface I1046');
	pxyTI.setOperatorCode ('MSK', app.myPassport);
	
	self.expectTrxError(ERR_CONTAINER_NO);
	app.myTrxUA.trxUpdateTrackedItem (pxyTI, "Testing I046", TI_UPDMODE_NORMAL, null, app.myPassport);

	self.assertNoTrxErrorsOrWarnings ();
	
	delete pxyTI;
		
//	add a new container - should be NOT included
	container := self.addContainer (CONTAINER17, operator, '2200', 'MT', TI_IMEX_STATUS_STORAGE).CM_Container;
	
// 	now run the protocol - don't update startTS as we shoul not pick up other updates for I1009
	endTS := app.actualTimeServer;// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	self.zJMT_To_CICS_1046 (PROTOCOL1046, camGroup, startTS, endTS);
	
	// this next test just checks no transients left behind
	self.zJMT_To_CICS_Events (PROTOCOLEVENT, camGroup, origStartTS, endTS);	
	
	// 27/05/2015 cnwmh5 - trxUpdateCamProtocol
	protocol := self.getTerminal().camProtocols[PROTOCOL1046];
	self.assertNotNull(protocol);
	tempDesc := protocol.description;
	self.opts.purge();
	self.opts.addAssoc("Description", tempDesc &amp; "AAA");
	self.updateCamProtocol(protocol);
	self.assertEqual(protocol.description, tempDesc &amp; "AAA");
	self.opts.purge();
	self.opts.addAssoc("Description", tempDesc);
	self.updateCamProtocol(protocol);
	self.assertEqual(protocol.description, tempDesc);
	
	// 25/06/2015 cnwmh5 - trxToggleCamProtocolHold
	app.myTrxUA.trxToggleCamProtocolHold(protocol, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(protocol.status, CAM_IDLESTATUS);
	app.myTrxUA.trxToggleCamProtocolHold(protocol, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(protocol.status, CAM_HOLDSTATUS);
	
	// 16/09/2015 cnwmh5
	ti := self.getTrackedItem(CONTAINER7);
	beginTransaction;
	ti.setRemarks(self.createdByUnitTest(ti.remarks), true);
	commitTransaction;
	ti := self.getTrackedItem(CONTAINER8);
	beginTransaction;
	ti.setRemarks(self.createdByUnitTest(ti.remarks), true);
	commitTransaction;
	ti := self.getTrackedItem(CONTAINER9);
	beginTransaction;
	ti.setRemarks(self.createdByUnitTest(ti.remarks), true);
	commitTransaction;
	ti := self.getTrackedItem(CONTAINER10);
	beginTransaction;
	ti.setRemarks(self.createdByUnitTest(ti.remarks), true);
	commitTransaction;
	
	self.deleteAllDamage(damCont1);// ### 28OCT2022 NAVAB1 CUT DAY
	self.deleteAllDamage(damCont2);// ### 28OCT2022 NAVAB1 CUT DAY
	self.deleteDamageSeverity(severity);// ### 28OCT2022 NAVAB1 CUT DAY
	
epilog

	endLoad;													// 19/04/2013 cnwmh5 #31457
	
	self.disableAllYA(false);						// 02/02/2015 cnwmh5 - Add enabling of YA's
	
	delete opColl;
	delete ffColl;
	delete emailColl;
	delete strs;
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;Failing1&lt;/Category&gt;
    &lt;Category CanDelete="true"&gt;DAC ISSUE&lt;/Category&gt;
    &lt;Category CanDelete="true"&gt;CreateTrackedItemFixed&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
