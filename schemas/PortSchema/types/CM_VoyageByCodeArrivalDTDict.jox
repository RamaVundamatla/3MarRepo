<CollClass name="CM_VoyageByCodeArrivalDTDict" id="65ef5814-7bb1-4d25-aafe-c31675d67334">
    <duplicatesAllowed/>
    <loadFactor>66</loadFactor>
    <memberType name="CM_Voyage"/>
    <superclass name="CM_ExtKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="voyages"/>
    <ExternalKey name="code">
        <length>31</length>
        <type name="String"/>
    </ExternalKey>
    <ExternalKey name="arrivalDate">
        <type name="TimeStamp"/>
    </ExternalKey>
    <JadeMethod name="removeObject" id="dc0f2f79-9124-4794-bfa2-f4a96413a6a4">
        <lockReceiver/>
        <updating/>
        <source>removeObject(_obj : MemberType) : Boolean updating, lockReceiver;
// ---------------------------------------------------------------------------
// Created:     27 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
12 Aug 2008	cnwkpd1	PAR #17719 - Change removeKey to removeKeyEntry to handle duplicate keys

*/

vars
	iter	: Iterator;
	tmpObj	: MemberType;
	keyCode	: String;
	keyDT	: TimeStamp;
begin
	iter := self.createIterator();
	
	while iter.next(tmpObj) do
		if tmpObj = _obj then
			self.getIteratorKeys(keyCode, keyDT, iter);
			self.removeKeyEntry(keyCode, keyDT, tmpObj);		// PAR #17719
			return true;
		endif;
	endwhile;

	return false;

epilog
	delete iter;
end;</source>
        <Parameter name="_obj" type="MemberType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
