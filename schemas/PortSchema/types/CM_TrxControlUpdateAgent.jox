    <JadeMethod name="trxProcessEDIConsignoreeAll" id="ed35f0d5-24c1-4288-91c3-87e34e72ca5b">
        <updating/>
        <source>trxProcessEDIConsignoreeAll(_ediData : CM_EDIData input; _allAddConsignorees : CM_ConsignArray;
								_allUpdConsignorees : CM_ConsignArray;
								_allDelConsignorees : CM_ConsignArray;
								_validateOnly : Boolean; _passport : CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		08 March 2010 by cnwdad1
//
// Purpose:		Adds, updates and deletes Consignee/Consignor objects in the supplied
//				parameter arrays.
//
// Parameters:	_allAddConsignorees - An array of Consignee/Consignors to add.
//				_allConsignorees - An array of Consignee/Consignors to update.
//				_allDelConsignorees - An array of Consignee/Consignors to delete.
//				_passport - A reference to the current user's passport object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//21 Feb 2013	cnwrs1	Par 31143 EDI TRX not handling dbLoadErrors after no verify errors take 3
//04 Aug 2014	cnwrs1	Par 34668	EDI Status can be wrong if doDeferredUpdate fails
// --------------------------------------------------------------------------------
vars
	consignObj		: CM_ConsigneeConsignor;
	realConsignobj	: CM_ConsigneeConsignor;
	status 			: Integer;
begin
	// Always initialize the activity first.
	self.initialiseActivityWithPassport(_passport, method);
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
	
	beginTransaction;
	
	foreach consignObj in _allAddConsignorees do
		app.myUtilityCA.utlCreateConsigneeConsignor(consignObj, realConsignobj, _passport);
	endforeach;
	
	foreach consignObj in _allUpdConsignorees do
		app.myUtilityUA.utlUpdateConsigneeConsignor(consignObj, _passport);
	endforeach;
	
	foreach consignObj in _allDelConsignorees do
		app.myUtilityDA.utlDeleteConsigneeConsignor(consignObj, _passport);
	endforeach;
	if _validateOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		return;
	else
		if _passport.noErrors() then
			// sucessful DB Load so update status in same transaction
			_passport.doDeferredUpdates();
			if _passport.noErrors() then
				// use passport to get new status for EDI Data
				status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
				app.myUtilityUA.utlSetEDIDataStatusAfterVerify(_ediData, status);
			endif;
		endif;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);

	if _validateOnly or _passport.hasErrors then
		// use passport to get new status for EDI Data
		status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(_ediData, status);	// par 27392 cnwrs1 14 Apr 2011
	endif;
	_passport.allCurrentCellularVoyages.clear;
end;</source>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_allAddConsignorees" type="CM_ConsignArray"/>
        <Parameter name="_allUpdConsignorees" type="CM_ConsignArray"/>
        <Parameter name="_allDelConsignorees" type="CM_ConsignArray"/>
        <Parameter name="_validateOnly" type="Boolean"/>
