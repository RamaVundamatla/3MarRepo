<ExternalCollClass name="EDB_CarrierDict" id="24f18cdf-f49e-4b15-8c9a-3449e1acd4b6">
    <externalDatabase name="EDB_PortDss"/>
    <includesPredicate>( ( carrier."code" = ? ) AND ( carrier."description" = ? ) AND ( carrier."edition" = ? ) AND ( carrier."oid" = ? ) )</includesPredicate>
    <includesPredicateInfo>AQAAAAIAAAADAAAABAAAAA==</includesPredicateInfo>
    <keyEqPredicate>( carrier."oid" = ? )</keyEqPredicate>
    <keyEqPredicateInfo>AQAAAA==</keyEqPredicateInfo>
    <keyGeqPredicate>( carrier."oid" &gt;= ? )</keyGeqPredicate>
    <keyGeqPredicateInfo>AQAAAA==</keyGeqPredicateInfo>
    <keyGtrPredicate>( carrier."oid" &gt; ? )</keyGtrPredicate>
    <keyGtrPredicateInfo>AQAAAA==</keyGtrPredicateInfo>
    <keyLeqPredicate>( carrier."oid" &lt;= ? )</keyLeqPredicate>
    <keyLeqPredicateInfo>AQAAAA==</keyLeqPredicateInfo>
    <keyLssPredicate>( carrier."oid" &lt; ? )</keyLssPredicate>
    <keyLssPredicateInfo>AQAAAA==</keyLssPredicateInfo>
    <orderByList>carrier."oid" ASC </orderByList>
    <memberType name="EDB_Carrier"/>
    <superclass name="ExternalDictionary"/>
    <transient/>
    <sharedTransientAllowed/>
