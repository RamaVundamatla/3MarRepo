    <JadeMethod name="isStagingComplete" id="a4433a09-9df1-49c6-9727-54e36a2cfa80">
        <source>isStagingComplete(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 July 2021	jlier1	Initial creation TFS 51626  

*/

vars
	ct : CM_CargoType;
	weightRequested : Decimal [16,4];
	weightReleased : Decimal [16,4];
	weightStaged : Decimal [16,4];
	weightStagedString : String;
	qtyRequested : Integer;
	qtyReleased : Integer;
	qtyStaged : Integer;
	lc : CM_LocationsController;
begin	

	ct:= self.getCargoType;
	if ct &lt;&gt; null and ct.isBulkMulti then
		weightReleased := self.getWeightReleased();
		weightRequested := self.weightRequested;
		weightStaged := self.getWeightStaged;		
		return ( weightReleased + weightStaged &gt;= weightRequested );
		
	else
		qtyRequested := self.getTotalRequested;
		qtyReleased := self.getTotalReleased;
		qtyStaged := self.getTotalStaged(null,lc,null);		
		return  ( qtyReleased + qtyStaged &gt;= qtyRequested );
		
	endif;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
