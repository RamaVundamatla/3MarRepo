    <JadeMethod name="mnuGetFailedTests_click" id="ac75be3d-1586-4499-90f2-1a5d54202fda">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuGetFailedTests_click(menuItem: MenuItem input) updating;
/*

Purpose:			
	extract all failed tests into a .unl 'FailingTests' file. Stored in C:\temp
Parameters:			

Return Value:		

Date		Who		Reason
18 November 2014	cnwdb2	Initial creation

*/


vars

	file  						: File  ;
	testRuns					: UM_UnitTestRun;
	unitTestResults				: UM_UnitTestResult;
	root 						: UM_Root ; 	
	iter				    	: Iterator;	
	ts							: TimeStamp;
	tempTimeStamp				: TimeStamp;
	date 						: Date ; 
	methNameCol 				: StringArray  ; 
	currentDate 				: String ; 
	str 						: String ;  
	getDateEntered   			: String ; 
	version						: String;
	
begin
	create methNameCol transient ; 

	root := UM_Root.firstInstance() ;
	
	if root = null then // if there is no first instance of root then leave.
		return ; 
	endif ; 
	
	getDateEntered := app.cnGetServerTime.date.format("dd/MM/yyyy");	
	
	read getDateEntered ; // specify the date to extract
	
	if getDateEntered = null or getDateEntered = "" then
		currentDate :=  date.day().String &amp; "/" &amp; date.month().String &amp; "/" &amp; date.year().String ; 
	else
		currentDate := getDateEntered ; 
	endif ; 

	if currentDate.Date.isValid() then
		ts.setDate(currentDate.Date);
		ts.setTime("00:00:00".Time);
	else
		self.jmtRaiseException("An invalid Date has been entered") ; 
		return ; 
	endif ; 
	//iter := root.allUnitTestRuns.createIterator;
	
	//testRuns := root.allUnitTestRuns.getAtKeyGeq(ts) ; 
	iter := root.allUnitTestRuns.createIterator;
	//root.allUnitTestRuns.getIteratorKeys(ts, iter);
	root.allUnitTestRuns.startKeyGeq(ts, iter) ;
	while iter.next(testRuns) do
	
	
		if testRuns.startTS.date &gt; ts.date then
			break;
		endif;
	
		/*
		tempTimeStamp := testRuns.startTS;
		if tempTimeStamp.date &lt; testRuns.endTS.date then
			tempTimeStamp := testRuns.endTS;
		endif;
		if tempTimeStamp = null then						
			tempTimeStamp := testRuns.startTS;
		endif;
		if tempTimeStamp.date &gt; ts.date then
			break  ;
		endif;
		*/
		
		
		foreach unitTestResults in testRuns.allFailed do
			if  unitTestResults.myClassMethod.methodName[1:1] = "v" then
				continue;
			endif;
		
			methNameCol.add("Method " &amp; unitTestResults.myClassMethod.className &amp; " " &amp; unitTestResults.myClassMethod.methodName) ;
		endforeach ; 
		
	endwhile;

	version := CM_Version.VERSION;
	version := version.replaceString(".", "");
	
	if methNameCol.size &gt; 0 then
	
		create file;
		file.fileName := "c:\temp\FailingTests" &amp; version &amp; ".unl";
		if file.isAvailable() then //Clear the file of contents if it already exists 
			file.purge() ; 
		endif ; 
	
		foreach str in methNameCol do
			file.writeLine(str) ; 
		endforeach ;	 
	endif ; 

epilog
	delete methNameCol ; 
	delete file ; 
	delete iter;
end;</source>
