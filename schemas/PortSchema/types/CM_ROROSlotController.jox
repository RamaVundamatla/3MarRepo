    <JadeMethod name="getAftLC" id="dd5052c5-3e12-4c83-90d3-5bb153549488">
        <source>getAftLC(): CM_ROROSlotController;
/*
Purpose:			
Date		Who		Reason
08 August 2011	cnwab1	Initial creation
*/

vars
	aftSlot : CM_ROROSlotDefn;
	aftLocn : CM_ROROLocnDefn;
begin
	if self.mySlotDefn = null then
		return null;
	endif;

	if self.mySlotDefn.myROROLocnDen = null then
		return null;
	endif;
	
	if self.mySlotDefn.myROROLocnDen.myAdjacentSlotAft = null then
		return null;
	endif;
	aftLocn := self.mySlotDefn.myROROLocnDen.myAdjacentSlotAft;
	
	aftSlot := aftLocn.allROROSlotDefnByOrdinal[aftLocn.ordinal,self.mySlotDefn.ordinal];
	
	if aftSlot = null then
		return null;
	endif;
	
	return aftSlot.CM_ROROSlotDefnVoyage.mySlotController;

epilog

end;</source>
        <ReturnType type="CM_ROROSlotController"/>
    </JadeMethod>
