    <JadeMethod name="comboBoxGenerator" id="e06c90ab-5095-4797-8526-a120c1f84230">
        <source>comboBoxGenerator(_cmb : ComboBox input; _isNoseMounted ,_isUnderSlung : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Feb 2018	cnwma1  ChangeRequest 36813: PEN - Gen Sets, Chassis &amp; Reefers
*/

vars
	tiMaster : CM_TIMaster;
begin
	
	_cmb.clear();
	_cmb.sorted := false;
	_cmb.addItem(null);
	
	foreach tiMaster in app.myRoot.allTiMasters discreteLock where  tiMaster.isGenerator  do
	
	if  tiMaster.CM_TIMasterGenerator.isNoseMounted  &lt;&gt; _isNoseMounted then
		continue;
	endif;
	
	if  tiMaster.CM_TIMasterGenerator.isUnderSlung  &lt;&gt; _isUnderSlung then
		continue;
	endif;
	
	_cmb.itemObject[_cmb.addItem(self.displayEntryGenerator(tiMaster))] := tiMaster;
	endforeach;
epilog

end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_isNoseMounted" type="Boolean"/>
        <Parameter name="_isUnderSlung" type="Boolean"/>
    </JadeMethod>
