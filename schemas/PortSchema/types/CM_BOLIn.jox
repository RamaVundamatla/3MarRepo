    <JadeMethod name="getDataForDef" id="665fa5c5-9462-400d-ae72-e7cbac214150">
        <source>getDataForDef(_entTableDef: EntTableDef; _headings: StringArray input; _data: HugeStringArray input; _terminal : CM_Terminal);
//--------------------------------------------------------------
//Created: 04 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	entTableRow 	: EntTableRow;
	ti 				: CM_TrackedItem;
	bolTerminal		: CM_BOLTerminal;
	bolType			: CM_BOLType;
begin

	if _entTableDef.name = ETDef_LogData then
		bolType := app.myRoot.allBOLTypes[self.bolType];
		bolTerminal := self.allBOLTerminals[_terminal];
		if bolTerminal &lt;&gt; null then
			bolTerminal.getDataForDef(_entTableDef, _headings, _data, _terminal);
		else
			foreach entTableRow in _entTableDef.allEntTableRows do
				foreach ti in self.allTrackedItems do
					ti.getDataForAttribute(entTableRow.name, entTableRow.getHeading(bolType, null, app.myCurrentLocale), _headings, _data);
				endforeach;
			endforeach;
		endif;		
	else
		inheritMethod(_entTableDef, _headings, _data, _terminal);
	endif;

end;</source>
        <Parameter name="_entTableDef" type="EntTableDef"/>
        <Parameter name="_headings" type="StringArray" usage="input"/>
        <Parameter name="_data" type="HugeStringArray" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
