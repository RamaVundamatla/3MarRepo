    <JadeMethod name="isEDIType" id="7ce7ad22-f0df-42f1-8802-0ed5fd162e82">
        <source>isEDIType() : Boolean;
/*
Purpose:	

Date		Who		Reason
14 March 2025	navab1	JIRA 34233
*/

vars

begin
	if self.myReceivalCutoffTermDef = null then
		return false;
	endif;
	
	return self.myReceivalCutoffTermDef.isEDIType();
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="a34aa521-a7b1-4e9e-98d5-b9b92cf06d00">
        <updating/>
        <source>setForCreate(_proxy : CM_ReceivalCutoff) updating;

/*
Date		Who		Reason
27 May 2009	cnwar2	Initial creation

*/

vars

begin
	self.code 				:= _proxy.code;
	self.cutoffDateTime 	:= _proxy.cutoffDateTime;
	self.earliestDateTime 	:= _proxy.earliestDateTime;
	self.cutoffDateTimePN	:= _proxy.cutoffDateTimePN; 	//04/03/2025	navkc1 JIRA Story MTN-34227
	self.earliestDateTimePN	:= _proxy.earliestDateTimePN;	//04/03/2025	navkc1 JIRA Story MTN-34227
end;</source>
        <Parameter name="_proxy" type="CM_ReceivalCutoff"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="209d8d75-32bb-41e0-ab55-26fcb8dbc205">
        <updating/>
        <source>setForUpdate(_cutoffDateTime : TimeStamp; _earliestDateTime : TimeStamp; _cutOffDateTimePN : TimeStamp; _earliestDateTimePN : TimeStamp) updating;
// ---------------------------------------------------------------------------
// Created:	25 March 2010 By Graeme Black cnwgb1
// Purpose:	Update the timestamp attributes PAR 23207
//			(From EDI probably)
// ---------------------------------------------------------------------------
vars
begin
	self.cutoffDateTime := _cutoffDateTime;
	self.earliestDateTime := _earliestDateTime;
	self.cutoffDateTimePN := _cutOffDateTimePN;		//04/03/2025	navkc1 JIRA Story MTN-34227
	self.earliestDateTimePN := _earliestDateTimePN; //04/03/2025	navkc1 JIRA Story MTN-34227
epilog
end;</source>
        <Parameter name="_cutoffDateTime" type="TimeStamp"/>
        <Parameter name="_earliestDateTime" type="TimeStamp"/>
        <Parameter name="_cutOffDateTimePN" type="TimeStamp"/>
        <Parameter name="_earliestDateTimePN" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setRecCutoffDef" id="fa8883ad-7c6c-4d10-8356-4a3d6bc452b6">
        <updating/>
        <source>setRecCutoffDef(_receivalCutoffDef : CM_ReceivalCutoffTermDef) updating;

/*
Date		Who		Reason
27 May 2009	cnwar2	Initial creation

*/
vars

begin
	self.myReceivalCutoffTermDef := _receivalCutoffDef;
end;</source>
        <Parameter name="_receivalCutoffDef" type="CM_ReceivalCutoffTermDef"/>
    </JadeMethod>
