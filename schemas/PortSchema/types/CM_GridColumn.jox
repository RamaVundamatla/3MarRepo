    <JadeMethod name="getMaxWidth" id="16e179fa-625d-4f1c-8e14-9faefe41e099">
        <source>getMaxWidth() : Real;
// ---------------------------------------------------------------------------
// Created:     26 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpMaxWidth		: Real;
	tmpGridController : CM_GridController;
begin

	foreach tmpGridController in self.allControllersByRow do
		if tmpGridController.isGap() then // PAR 18682
			tmpMaxWidth := tmpMaxWidth.max(tmpGridController.width);
		else
			tmpMaxWidth := 1;
			break;
		endif;
	endforeach;

	return tmpMaxWidth;
	
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getMaxWidthOLD" id="8d34ab0f-28ac-44c5-8c61-a1c85d37266d">
        <source>getMaxWidthOLD() : Real;
// ---------------------------------------------------------------------------
// Created:     26 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpMaxWidth		: Real;
	tmpGridController : CM_GridController;
begin

	foreach tmpGridController in self.allControllersByRow do
		if (not CM_GapController.hasInstance(tmpGridController)) then
			tmpMaxWidth := 1;
			break;
		else
			tmpMaxWidth := tmpMaxWidth.max(tmpGridController.width);
		endif;
	endforeach;

	return tmpMaxWidth;
	
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
