<PrimType name="TimeStamp">
    <Constant name="ENCRYPTBASEDATE" id="c44169e4-b77f-4d48-8ab8-4561adf835ae">
        <source>'26MAY1998'.Date</source>
        <type name="Date"/>
    </Constant>
    <Constant name="ENCRYPTBASETIME" id="c27ab901-ca80-4417-a107-f497989ed81e">
        <source>'00:00:00:00'.Time</source>
        <type name="Time"/>
    </Constant>
    <JadeMethod name="cnEcAddDays" id="49a15a91-7259-43d1-a38b-916fa2f31b13">
        <source>cnEcAddDays(pDays:Integer):TimeStamp;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of days to the
//				receiver timestamp.
//
// Parameters:	pDays (Integer) - The number of days to add (or subtract).
//
// Returns:		The resulting timestamp.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	currentTimestamp	: TimeStamp;
	
begin
	currentTimestamp	:=	self;
	currentTimestamp.setDate(self.date.cnEcAddDays(pDays));
	
	return currentTimestamp;
end;</source>
        <Parameter name="pDays" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="cnEcAddHours" id="3ae7c528-fde5-455b-8325-c781dc2dcfae">
        <source>cnEcAddHours(pHours:Integer):TimeStamp;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of hours to the
//				receiver timestamp.
//
// Parameters:	pHours (Integer) - The number of hours to add (or subtract).
//
// Returns:		The resulting timestamp.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 05/05/2006	cnwdad1		Changed to handle more hours than one day's worth, so
//							that the date is also adjusted accordingly.
// --------------------------------------------------------------------------------
vars
	adjustTime		: Time;
	newTS			: TimeStamp;
	adjustDays		: Integer;
	residualHours	: Integer;
	
begin
	if pHours.abs() &lt; CNEC_HOURS_IN_DAY then
		if pHours &gt; 0 then
			adjustTime.setTime(pHours, 0, 0, 0);
			return self + adjustTime;
		else
			adjustTime.setTime(-pHours, 0, 0, 0);
			return self - adjustTime;
		endif;
	else
		newTS			:=	self;
		adjustDays		:=	pHours div CNEC_HOURS_IN_DAY;
		newTS.setDate(self.date.cnEcAddDays(adjustDays));
		residualHours	:=	pHours - (adjustDays * CNEC_HOURS_IN_DAY);
		return newTS.cnEcAddHours(residualHours);
	endif;
end;</source>
        <Parameter name="pHours" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="cnEcAddMinutes" id="38ad0b8b-7042-4318-92c1-9086dffef8de">
        <source>cnEcAddMinutes(pMinutes:Integer):TimeStamp;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of minutes to the
//				receiver timestamp.
//
// Parameters:	pMinutes (Integer) - The number of minutes to add (or subtract).
//
// Returns:		The resulting timestamp.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 04/05/2006	cnwdad1		Changed to handle more minutes than one day's worth, so
//							that the date is also adjusted accordingly.
// --------------------------------------------------------------------------------
vars
	adjustTime		: Time;
	newTS			: TimeStamp;
	adjustDays		: Integer;
	residualMinutes	: Integer;
	
begin
	if pMinutes.abs() &lt; CNEC_MINUTES_IN_DAY then
		if pMinutes &gt; 0 then
			adjustTime.setTime(0, pMinutes, 0, 0);
			return self + adjustTime;
		else
			adjustTime.setTime(0, -pMinutes, 0, 0);
			return self - adjustTime;
		endif;
	else
		newTS			:=	self;
		adjustDays		:=	pMinutes div CNEC_MINUTES_IN_DAY;
		newTS.setDate(self.date.cnEcAddDays(adjustDays));
		residualMinutes	:=	pMinutes - (adjustDays * CNEC_MINUTES_IN_DAY);
		return newTS.cnEcAddMinutes(residualMinutes);
	endif;
end;</source>
        <Parameter name="pMinutes" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="cnEcAddMonths" id="6e44fc53-840c-495f-ab54-a76c8fb48c85">
        <source>cnEcAddMonths(pMonths:Integer):TimeStamp;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of months to the
//				receiver timestamp.
//
// Parameters:	pMonth (Integer) - The number of months to add (or subtract).
//
// Returns:		The resulting timestamp.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	currentTimestamp	: TimeStamp;
	
begin
	currentTimestamp	:=	self;
	currentTimestamp.setDate(self.date.cnEcAddMonths(pMonths));
	
	return currentTimestamp;
end;</source>
        <Parameter name="pMonths" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="cnEcAddSeconds" id="145f9331-aca0-4031-af2c-c02c4890c49e">
        <source>cnEcAddSeconds(pSeconds:Integer):TimeStamp;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of seconds to the
//				receiver timestamp.
//
// Parameters:	pSeconds (Integer) - The number of seconds to add (or subtract).
//
// Returns:		The resulting timestamp.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 05/05/2006	cnwdad1		Changed to handle more seconds than one day's worth, so
//							that the date is also adjusted accordingly.
// --------------------------------------------------------------------------------
vars
	adjustTime		: Time;
	newTS			: TimeStamp;
	adjustDays		: Integer;
	residualSeconds	: Integer;
	
begin
	if pSeconds.abs() &lt; CNEC_SECONDS_IN_DAY then
		if pSeconds &gt; 0 then
			adjustTime.setTime(0, 0, pSeconds, 0);
			return self + adjustTime;
		else
			adjustTime.setTime(0, 0, -pSeconds, 0);
			return self - adjustTime;
		endif;
	else
		newTS			:=	self;
		adjustDays		:=	pSeconds div CNEC_SECONDS_IN_DAY;
		newTS.setDate(self.date.cnEcAddDays(adjustDays));
		residualSeconds	:=	pSeconds - (adjustDays * CNEC_SECONDS_IN_DAY);
		return newTS.cnEcAddSeconds(residualSeconds);
	endif;
end;</source>
        <Parameter name="pSeconds" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="cnEcAddWeeks" id="efa4561d-5b73-4ba5-bb50-eefe17f98eec">
        <source>cnEcAddWeeks(pWeeks:Integer):TimeStamp;
// --------------------------------------------------------------------------------
// Created:		13 June 2007 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of weeks to the
//				receiver.
//
// Parameters:	pWeeks (Integer) - The number of weeks to add (or subtract).
//
// Returns:		The resulting timestamp.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	noDays	: Integer;
	
begin
	noDays	:=	pWeeks * 7;
	
	return self.cnEcAddDays(pWeeks);
end;</source>
        <Parameter name="pWeeks" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="cnEcAddYears" id="db45e39f-0dfe-46a3-8c97-afc0bcc171e0">
