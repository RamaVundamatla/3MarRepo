    <JadeMethod name="readOnly" id="d3fdc806-f381-4c9e-bafe-a21ba7c21085">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>readOnly(set: Boolean; value: Boolean io) updating, mapping, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2019	jlgndl1	Initial creation	TFS 42997

*/

vars

begin

	inheritMethod(set, value);
	
	if not self.isInPainter then // ### TFS 55106 20SEP2022 NAVAB1 could not save any form that had this class in it
		if set then
			foreach index in 1 to self.rows do
				self.accessRow(index).enabled := not value;
			endforeach;
		endif;
	endif;
	

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="rowChecked" id="28a102b1-57f9-4f46-87d2-7fbf4a7988fc">
        <updating/>
        <source>rowChecked(pRow : Integer) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     01 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if pRow &gt; 0 and pRow &lt;= self.rows then
		if self.accessCell(pRow, self.chkBoxColumn).text[1] = TableCheckBox_Selected then
			return true;
		endif;
	endif;
	
	return false;
	
end;</source>
        <Parameter name="pRow" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="rowColumnChg" id="38318061-265f-44fc-825b-3394fcf980d8">
        <updating/>
        <source>rowColumnChg(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     01 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	
	inheritMethod(table);
	
	if table.column &lt;&gt; self.chkBoxColumn then
		// always set the column to the checkBox column so that the
		// spacebar can be used to set/unset the checkbox.
		table.column := self.chkBoxColumn;
		self.doManually := true;
	else
		self.doManually := false;
	endif;
	
	//self.highlightRow(self.row);

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="selectAll" id="19fe05a5-ad17-48e0-98f8-0c7b8842a28c">
        <updating/>
        <source>selectAll()updating;
// ---------------------------------------------------------------------------
// Created:		August 2007 By Andrew Bishop NAVAB1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

/*

--------------------------------------------Note--------------------------------------------

If displayCollection or listCollection is used, only the displayed rows are included in the rows count.
Using selectAll method doesn't select all the rows as some of them are not included in the rows
If that's the case, use setSelected() method instead.

*/

vars
	numRows,
	rowIdx		: Integer;
	jRow		: JadeTableRow;
begin
	numRows := self.rows;
	if numRows = 0 then
		return;
	endif;
	
	self.allSelectedObjects.clear();

	foreach rowIdx in 1 to numRows do
		jRow := self.accessRow(rowIdx);
		if not jRow.visible then
			continue;
		endif;
		if jRow.itemObject &lt;&gt; null then
			self.addSelectedObject(jRow.itemObject);
		else
		//epr TFS 47132 20/12/19 noticed with container length this did not have an obj so could not select all
			self.accessCell(rowIdx, self.chkBoxColumn).text := TableCheckBox_Selected;
		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="setAllToFalse" id="241a82b5-bf1e-42d9-8c18-7128d20c9568">
        <updating/>
        <source>setAllToFalse()updating;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 29 August 2003
//
//-----------------------------------------------------------------------
vars
	idx,
	max			: Integer;
	obj			: Object;
	objArray	: ObjectArray;
begin
	max := self.rows;
	
	if max &lt; 1 then
		return;
	endif;
	
	objArray := self.allSelectedObjects;
	foreach idx in 1 to max do
		self.accessCell(idx, self.chkBoxColumn).text := TableCheckBox_NotSelected;
		
		obj := self.accessRow(idx).itemObject;
		if (objArray.includes(obj)) then
			objArray.remove(obj);
		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="setAllToTrue" id="b735260d-302e-48c6-958b-04962ff99e71">
        <updating/>
        <source>setAllToTrue()updating;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 29 August 2003
//
//-----------------------------------------------------------------------
vars
	idx,
	max			: Integer;
	obj			: Object;
	objArray	: ObjectArray;
begin
	max := self.rows;
	
	if max &lt; 1 then
		return;
	endif;
	
	objArray := self.allSelectedObjects;
	foreach idx in 1 to max do
		self.accessCell(idx, self.chkBoxColumn).text := TableCheckBox_Selected;
		
		obj := self.accessRow(idx).itemObject;
		if (not objArray.includes(obj)) then
			objArray.add(obj);
		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="setAvailableOptions" id="32661abb-fa8b-49c1-a79a-ecd355fceabd">
        <updating/>
        <source>setAvailableOptions(_objArr : ObjectArray) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 April 2025	navpw1	Initial creation JIRA: MTN-34402

*/

vars
	cmStrArr : CM_CMStringArray;
	cmString : CM_String;
	
begin
	if _objArr.isKindOf(CM_CMStringArray) then
		cmStrArr := _objArr.CM_CMStringArray;
		foreach cmString in cmStrArr do
			self.addItemObject(cmString.CM_String.string, cmString);
		endforeach;
	endif;
	
end;</source>
        <Parameter name="_objArr" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="setChkBoxColumn" id="faea9cec-1a88-4888-b311-59910fa5047a">
        <updating/>
        <source>setChkBoxColumn(pInt :Integer) updating;

vars

begin
	chkBoxColumn	:= pInt;
end;</source>
        <Parameter name="pInt" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setRowSelect" id="439289b3-d692-49dd-adc8-b6bb08db5583">
        <updating/>
        <source>setRowSelect(pRow : Integer; _select : Boolean) updating;
//-----------------------------------------
// Created: November 2005 By: cnwgd1
//-----------------------------------------
vars
	obj : Object;
begin

	if pRow &gt; 0 and pRow &lt;= self.rows then
		
		obj := self.accessRow(pRow).itemObject;
		
		if obj &lt;&gt; null then
			if _select then
				if (not self.allSelectedObjects.includes(obj)) then
					self.allSelectedObjects.add(obj);
				endif;
			elseif self.allSelectedObjects.includes(obj) then
				self.allSelectedObjects.remove(obj);
			endif;
		endif;
		
		if self.allSelectedObjects.includes(self.accessRow(pRow).itemObject) then
			self.accessCell(pRow, self.chkBoxColumn).text := TableCheckBox_Selected;
		else
			self.accessCell(pRow, self.chkBoxColumn).text := TableCheckBox_NotSelected;
		endif;

	endif;

end;</source>
        <Parameter name="pRow" type="Integer"/>
        <Parameter name="_select" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSelected" id="d4ed1480-ecf1-414d-a364-0954e7afb2e9">
        <updating/>
        <source>setSelected(_coll : Collection) updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     Copies the collection passed in into the allSelectedObjects and
//				sets the "checked" flag on the table.
//
// Parameters:  _coll - collection of items to be selected
//
// Returns:     The selected string.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/10/2012	cnwcs5		Minor tweaks 
// ---------------------------------------------------------------------------
vars
	idx, max, col	: Integer;
	rowObject 		: Object;
	member 			: Any;
	displayColl,
 	selectedColl	: Collection;
	
begin
	displayColl 	:= self.getCollection; 
	selectedColl	:= self.allSelectedObjects;
	
	if displayColl = null then	// 09 Jul 2012 NDL Par 29703
		// this control is not currently relying on the "displayCollection" method, i.e if populated has been populated manually
		// so all items that are valid are in the table, and can be queried..

		//22 May 2012	NDL	Par 29381
		selectedColl.clear;
		
		max := self.rows;
		col := self.chkBoxColumn;
		
		foreach idx in 1 to max do
			rowObject := self.accessRow(idx).itemObject;
			
			if rowObject = null or _coll = null  or not _coll.includes(rowObject) then
				self.accessCell(idx, col).text := TableCheckBox_NotSelected;
			else
				self.accessCell(idx, col).text := TableCheckBox_Selected;
				selectedColl.add(rowObject);
			endif;
		endforeach; 

	else
		//Old way - Could result in objects in the passed in collection that were not included in
		//the display being left in the selected objects collection.
		
		// 09 Jul 2012 NDL Par 29703
		// The Old way mostly reinstated for controls that are implemented using the "displayCollection" method.
		// The items that we are selecting are not necessarily visible in the table (so not currently included).
		// But they should still be in the displayColl and if they are can be selected.
		
		selectedColl.clear;
		
		if _coll &lt;&gt; null then 
			// 09 Jul 2012 NDL Par 29703
			foreach member in _coll do
				if displayColl.includes( member ) then
					selectedColl.add(member.Object);
				endif;
			endforeach;
		endif;
		
		max := self.rows;
		col := self.chkBoxColumn;
		
		foreach idx in 1 to max do
			if selectedColl.includes(self.accessRow(idx).itemObject) then
				self.accessCell(idx, col).text := TableCheckBox_Selected;
			else
				self.accessCell(idx, col).text := TableCheckBox_NotSelected;
			endif;
		endforeach;
	
	endif;
	
end;</source>
        <Parameter name="_coll" type="Collection"/>
    </JadeMethod>
    <JadeMethod name="setSelectedString" id="ff5d1806-5c43-4b4d-99dc-ff84f3a5c94b">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>setSelectedString(_string: String)updating, clientExecution;
//--------------------------------------------------
// Created:	05 May 2005 By: cnwgd1
//--------------------------------------------------
//Date			Who		Reason
//11 April 2025	navpw1	MTN-34402: Modified so that now we also select the object not just the string
vars
	col,
	idx,
	max	: Integer;
	obj : Object;
	member : Any;
	
begin
	if _string = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'null _string');
		return;
	endif;

	max := self.rows;
	
	if max &lt; 1 then
		return;
	endif;

	if self.chkBoxFirst then
		col := self.chkBoxColumn + 1;
	else
		col := self.chkBoxColumn - 1;
	endif;	
	
	foreach idx in 1 to max do
		obj := self.accessRow(idx).itemObject;
		if CM_TransactionType.hasInstance(obj) then
			if obj.CM_TransactionType.description = _string then
				self.accessCell(idx, self.chkBoxColumn).text := TableCheckBox_Selected;					
			endif;
		elseif self.accessCell(idx, col).text = _string then
			self.accessCell(idx, self.chkBoxColumn).text := TableCheckBox_Selected;	
			self.allSelectedObjects.add(self.accessRow(idx).itemObject);
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_string" type="String"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="ae7259fa-9c7f-44fc-b135-c76fc2cf5a7e">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// ---------------------------------------------------------------------------
// Created:     01 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	col	: JadeTableColumn;
	idx	: Integer;

begin

	inheritMethod(cntrl, persistCntrl);
	
	if self.columns &lt;= 1 then
		self.columns := 2;
	endif;
 
	foreach idx in 1 to self.columns do
		col := self.accessColumn(idx);
		if idx = self.chkBoxColumn then
			// setup the checkbox column
			col.inputType := InputType_CheckBox;
		else
			// setup the text column
			col.inputType := InputType_None;
			col.partialTextIndication := true;
		endif;
	endforeach;

end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
