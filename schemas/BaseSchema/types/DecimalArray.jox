<CollClass name="DecimalArray">
    <JadeMethod name="cnEcDoSort" id="66dc51ab-fea2-4e89-b821-13dd53f153c5">
        <lockReceiver/>
        <updating/>
        <source>cnEcDoSort(pSorterObj : CnEcSorter) lockReceiver, updating, protected;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		Refer to method implementation on the Array class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	decimalValue	: Decimal[23,2];
	sortKeyObj		: Object;

begin
	foreach decimalValue in self do
		pSorterObj.addKey(decimalValue);
	endforeach;
	
	self.purge();
	
	foreach sortKeyObj in pSorterObj.allKeys do
		self.add(sortKeyObj.CnEcSortKey.getKey().Decimal);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pSorterObj" type="CnEcSorter"/>
    </JadeMethod>
</CollClass>
