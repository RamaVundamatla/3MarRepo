    <JadeMethod name="setStatusText" id="ce1f70f4-04ca-4b6d-a673-406a0c7e0848">
        <source>setStatusText();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 July 2014	cnwmc5	Initial creation

*/

vars

begin

	self.staMain.caption := "Number Entries: " &amp; self.myBOL.customsQuantityEntered.asStringJMT().cnEcPadTrailing(10, " ") &amp; 
							"Number Released: " &amp; self.myBOL.customsQuantityReleased.asStringJMT().cnEcPadTrailing(10, " ") &amp;
							"Number Stops: " &amp; self.myBOL.allStops.size().asStringJMT();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="4ada6688-a172-43b8-a8e5-1621b0bd8382">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 July 2014	cnwmc5	Initial creation

*/

vars
	caption : String;
begin
	
	inheritMethod();
	
	caption := app.getErrorString(CustomsStatus) &amp; " - " &amp; app.getErrorString(Voyage) &amp; " " &amp; self.myBOL.myVoyage.code &amp; " - " &amp; app.getErrorString(BOL) &amp; " " &amp; self.myBOL.number;
	
	self.setCaption(caption);
	self.setNavigatorHeading(self.caption);
	self.setStatusText();
	
	self.minimumHeight 	:= 400;
	self.minimumWidth 	:= 600;
	
	self.btnEditTV.visible := false; // TFS 2734
	self.btnSaveBase.visible := false; // TFS 2734
epilog

end;</source>
    </JadeMethod>
