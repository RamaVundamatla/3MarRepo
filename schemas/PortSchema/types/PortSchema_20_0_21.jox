    <JadeMethod name="updateIsCargoSubTypeReqForCG" id="78e821fe-4547-41c1-9235-d5fa6627d2e1">
        <source>updateIsCargoSubTypeReqForCG(_controller : CnEcReleaseController);
/*

Purpose: This script will update the property "isSubCargoTypeRequired" to "false" if the product type of the cargo type is cargo group	
		
Parameters:			

Return Value:		

Date		Who		Reason
29 August 2023	navsp1	Initial creation TFS Bug 58664: EUP - Cargo Type track as Cargo Group - should not support SubTypes

*/

vars
	cargotype			: CM_CargoType;						
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;

	app.writeLog( method.qualifiedName &amp; "Update 'Cargo Sub Type Required' value set as 'false' for cargo group specific cargotype ", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Update 'Cargo Sub Type Required' value set as 'false' for cargo group specific cargotype ") ;
	endif;
	
	beginTransaction;
	
	foreach cargotype in app.myRoot.allCargoTypesById do
		if cargotype.productType &lt;&gt; null and cargotype.productType = ProductType_CargoGroup and cargotype.isSubCargoTypeRequired then
			cargotype.setIsSubCargoTypeRequired(false);
		endif;
	endforeach;		
	
	commitTransaction;
	
	app.writeLog( method.qualifiedName &amp; "Update 'Cargo Sub Type Required' value set as 'false' for cargo group specific cargotype ", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Update 'Cargo Sub Type Required' value set as 'false' for cargo group specific cargotype ") ;	
	endif;
	
	self.addScriptRun(method.name);
	
epilog

end;</source>
