    <JadeMethod name="utlDeleteDelay" id="6cfa9b43-6a9e-49bd-8855-7ba71bc0c7ac">
        <source>utlDeleteDelay(_delay: CM_Delay io; _passport : CM_Passport input);
/*
----------   ----------  --------------------------------------------------
Created:	16 February 2007 By cnwmo1

Changed On  Changed By  Reason

08/11/2012	cnwcs5		par 30519 - add notifications	
11 Apr 2017	cnwma1		TFS #4027:MSL - Voyage Side Profile - delay not showed
21 Sep 2020 cnwma1 	    ChangeRequest 49906: MTN - Ops View External Webservice
----------  ----------  --------------------------------------------------
*/
vars
	jobSheet	: CM_VoyageJobSheet;
	voyage		: CM_Voyage;
begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valDelay(_delay);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;

	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_delay);
	endif;

	if _passport.noErrors then
		//jobSheet 	:= _delay.getVoyageJobSheet();  //11/04/2017 cnwma1 TFS #4027
		if _delay.myWorkPoint &lt;&gt; null then          //11/04/2017 cnwma1 TFS #4027
			jobSheet := _delay.getVoyageJSRoRoHold();
		else
			jobSheet := _delay.getVoyageJSLoLo();
		endif;
		
		voyage		:= _delay.myVoyage;
		
		//21.09.2020 cnwma1 TFS #49906
		if _passport.isOpsViewEnabled(_delay.myTerminal) then
			_delay.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_DELETE,
										   BGP_OpsViewWSRequest.OPS_TYPE_DELAY,
										   _delay
										   );
		endif;
		//21.09.2020 cnwma1 TFS #49906
	
		_delay.erase(NORMAL_ERASE);
		
		if jobSheet &lt;&gt; null then
			jobSheet.doUpdateVoyageKPI();
		endif;
		
		// par 30519 - cause notification of delete
		if voyage &lt;&gt; null then
			voyage.causeEvent (voyage.myTerminal.getTerminalEvent(EVENT_DELAY_DELETE), false, _delay);
		endif;
	endif;
epilog
	
end;
</source>
        <Parameter name="_delay" type="CM_Delay" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteDelayType" id="8d405629-3bcf-4244-ae06-7ee70d9ea4cf">
        <source>utlDeleteDelayType(pDelayType:CM_DelayType io; _passport : CM_Passport input);
/*
----------   ----------  --------------------------------------------------
Created:	31 January 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valDelayType(pDelayType);
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;


	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(pDelayType);
	endif;
    
	//21.09.2020 cnwma1 TFS #49906
	if _passport.isOpsViewEnabled(null) then
		pDelayType.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_DELETE,
									 BGP_OpsViewWSRequest.OPS_TYPE_DELAYTYPE,
									 pDelayType);
	endif;
	//21.09.2020 cnwma1 TFS #49906
	
	if _passport.noErrors then
		pDelayType.erase(NORMAL_ERASE);
	endif;

epilog
	return;

end;
</source>
        <Parameter name="pDelayType" type="CM_DelayType" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
