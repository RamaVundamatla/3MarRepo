    <JadeMethod name="loadDataForFirstTime" id="d4558cbc-bdfb-49a9-8a31-00dbf838927d">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
/*

Purpose:			Initializes the form for the first time data is loaded. By laoding combo boxes with data

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
30 September 2022	navpw1	Initial creation TFS: 54565 (54384)
21 December 2022	navkc1	Bug 55879: PNL - Invoicing - Creating a Manual Invoice takes 30 seconds to load
01/02/2023			navkc1	TFS CR 55305 Task 55537 UI - Invoice List UI changes
10 Apr 2023 		navtnr20	TFS CR 55303	Task 55531: UI - Invoice NEW UI Changes Invoice Copy
28 Apr 2023 		navnmk20	Bug 57663: EUP - Incorrect Statuses Available when copying an invoice
23 May 2023 navtnr20 	Bug 58089: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 070.b
*/

begin
	self.doCmbDebtorBuild(self.cmbDebtorInvProp); 
	//self.cmbDebtorInvProp.removeItem(1); // 03/02/2023	navkc1	TFS CR 55305 TASK 55536
	//self.doCmbStatusInvPropBuild();																	// 28.4.2023 navmk20 TFS 57663
	self.doCmbStatusInvPropBuild(self.myCurrentBank.getMyInvoiceProcess, CM_Invoice.INVOICE_PENDING);	// 28.4.2023 navmk20 TFS 57663
	self.doCmbCategoryBuild(); // 01/02/2023	navkc1	TFS CR 55305 TASK 55537
	self.doCmbInvoiceTypeBuild(self.cmbInvTypeInv, false); // moved down after status build - 10 Apr 2023 navtnr20	TFS CR 55303	Task 55531: UI - Invoice NEW UI Changes Invoice Copy
	self.doBuildWorkOrder(); //navtnr20 22-05-2023 BUG 58089
	/* // 21/12/2022	navkc1	#55879 - load them when user select the invoice type.
	self.doCmbCargoGroupTypeBuild();
	self.doCmbBolBuild();
	self.doCmbBookingBuild();
	self.doCmbReleaseRequestBuild();
	*/
	
end;</source>
        <access>protected</access>
    </JadeMethod>
