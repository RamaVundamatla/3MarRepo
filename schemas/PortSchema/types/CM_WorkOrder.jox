// ----------	--------	-----------------------------------------------------------------------
// 11/05/2018	jlgdap1		Initial creation TFS 38501 PEL1 Work Order Changes
//
vars
	wod : CM_WorkOrderDtl;

begin
	foreach wod in self.allWoDtls discreteLock do
		if wod.isWorkOrderForReceival or wod.isWorkOrderForRelease then
			return true;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
