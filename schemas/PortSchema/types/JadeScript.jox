    <JadeMethod name="childCargoType" id="d9ce39d2-8cb9-4852-b144-50cd78efaada">
        <source>childCargoType(_cmif : CMIF_CalcTypeQuantityHook) : Real;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2024	navhl20	Initial creation
23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
*/

vars
	newQty 		: Real;
	child 		: CM_TrackedItem;
	cargoType 	: CM_CargoType;
	transaction : CM_TITransaction;
	cargo 		: CM_TrackedItem;
	desc 		: String;
begin
	newQty := _cmif.origQty;
	transaction := _cmif.myTransaction.CM_TITransaction;
	cargo := transaction.myTrackedItem;
	child := cargo.allChildren.first;
	if child &lt;&gt; null then
		cargoType := child.myCargoType;
	endif;
	if cargoType &lt;&gt; null then
	        desc := cargoType.description;
		if desc = "GENERAL CARGO" then
			newQty := 1;
		elseif desc= "Personal Vehicles" then
			newQty :=  2;
		elseif desc = "MOBILE UNIT" then
			newQty :=  3;
		else 
			newQty :=  0;
		endif;
	endif;
	app.invLog("Cargo Type for the Container is : " &amp; desc.String, LogINFO.String);
	return newQty;
end;</source>
        <Parameter name="_cmif" type="CMIF_CalcTypeQuantityHook"/>
        <ReturnType type="Real"/>
    </JadeMethod>
