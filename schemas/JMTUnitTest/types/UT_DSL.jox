    <JadeMethod name="deleteStop" id="078fb6ad-5598-4ddd-b094-7119243badf1">
        <source>deleteStop(_ti: CM_TrackedItem; _stopTable: CM_StopsTable);
//17 November 2008	cnwdw1	
// Delete a stop to a tracked item
vars
	tiSet: CM_TISet;
	ceNum : String;
	proxy: CM_TrackedItem;
	stop: CM_Stops;
begin
	if self.opts.includesKey("CENum") then											// 09/04/2013 cnwmh5
		ceNum := self.opts.str("CENum");
	endif;
	
	proxy	:= app.createUpdateProxy( _ti ).CM_TrackedItem;
	stop := proxy.getStop( _stopTable.id );
	if _stopTable.requiresInfo then
			proxy.setRequiresInformation( _stopTable.requiresInfoType, ceNum );
	endif;
	delete stop;
	
	create tiSet transient;
	tiSet.add(proxy);
	
	app.myTrxUA.trxUpdateTrackedItems( tiSet, TI_UPDMODE_NORMAL, null, app.myPassport );
	checkTrxResult();
epilog
	delete tiSet;
	delete proxy;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_stopTable" type="CM_StopsTable"/>
    </JadeMethod>
    <JadeMethod name="deleteStopForTIById" id="24b63324-341f-4d5b-9c99-5f4b37a8b2aa">
        <source>deleteStopForTIById(_tiObj:CM_TrackedItem input; _stopId:Integer);
// --------------------------------------------------------------------------------
// Created:		15 April 2010 by cnwdad1
//
// Purpose:		Deletes the specified Stop in a Tracked Item.
//
// Parameters:	_tiObj - The Tracked Item object to remove the Stop from.
//				_stopId - The Stop id.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allStops		: IntegerArray;
	
begin
	if _stopId = 0 then
		return;
	elseif app.myRoot.allStopsTable[_stopId] = null then
		return;
	endif;
	
	create allStops transient;
	allStops.add(_stopId);
	app.myTrxDA.trxDeleteStops(_tiObj, allStops, app.myPassport);
epilog
	delete allStops;
end;</source>
        <Parameter name="_tiObj" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_stopId" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="deleteStops" id="91677f5d-2a41-4a86-bae0-fde6fbe441b5">
        <source>deleteStops(_ti: CM_TrackedItem);
//17 November 2008	cnwdw1	
// Remove all stops for a tracked item
vars
	tiSet	 : CM_TISet;
	ceNum 	 : String;
	proxy	 : CM_TrackedItem;
	stop	 : CM_Stops;
	stopType : CM_StopsTable;
	iter	 : Iterator;
	
begin
	// AKB Bulk Delete Voyages
	if _ti = null then															//27.07.2023 navma1
		return;
	endif;
	
	if _ti.getAllStops.isEmpty then
		return;
	endif;

	if self.opts.includesKey("CENum") then										// 09/04/2013 cwnmh5
		ceNum := self.opts.str("CENum");
	else
		ceNum := "999";
	endif;
	
	proxy	:= app.createUpdateProxy( _ti ).CM_TrackedItem;
	iter	:= proxy.getAllStops.createIterator();
	while iter.next(stop) do 
		stopType := stop.myStopsTable;
		if stopType &lt;&gt; null and stopType.requiresInfo then
			proxy.setRequiresInformation( stopType.requiresInfoType, ceNum );
		endif;
	endwhile;
	proxy.getAllStops.purge();
	create tiSet transient;
	tiSet.add(proxy);
	
	app.myTrxUA.trxUpdateTrackedItems( tiSet, TI_UPDMODE_NORMAL, null, app.myPassport );

	if app.myPassport.hasErrorsOrWarnings() then
		app.myPassport.setPropertyValue("status",TRXStatus_Committed);
		self.purgeStops(_ti);
		if _ti.getAllStops.isEmpty then
			app.myPassport.clearErrorsWarnings;
		endif;
	endif;

epilog
	delete tiSet;
	delete proxy;
	delete iter;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="deleteStopsOfType" id="f76da4d2-9749-4558-98ff-bb95c97da7c4">
        <source>deleteStopsOfType(_id: Integer);
//17 November 2008	cnwdw1	
// remove all stops of type _id
vars
	tiSet: CM_TISet;
	stop: CM_Stops;
	stopsTable: CM_StopsTable;
	garbageStartValue : Boolean;
begin
	garbageStartValue := app.isGarbageCollectionProcess;
	stopsTable := app.myRoot.allStopsTable[_id];
	beginTransaction;
	stopsTable.setPropertyValue("allowClearanceExpiryDate",null);
	commitTransaction;
		
		
	if stopsTable &lt;&gt; null then
		app.isGarbageCollectionProcess := true;
		create tiSet transient;
		foreach stop in stopsTable.allStops do
			beginTransaction;
			stop.setPropertyValue("clearanceExpiryDate",null);
			commitTransaction;
	
			if stop.myBOL &lt;&gt; null then
				app.myTrxDA.trxDeleteBOLStop(stop.myBOL.CM_BOLIn, stopsTable, app.myPassport);
			else
				tiSet.clear;
				tiSet.add(stop.myTrackedItem);
				app.myTrxDA.trxDeleteStopForTIsBulk(tiSet, stopsTable, self.opts.str("CENum"), app.myPassport);
			endif;
			checkTrxResult();
		endforeach;
	endif;
epilog
	app.isGarbageCollectionProcess := garbageStartValue;
	delete tiSet;
end;</source>
        <Parameter name="_id" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="deleteStopsTable" id="67cef7da-72cf-47d3-b10f-047cd85024fe">
        <source>deleteStopsTable(_id: Integer);
//12 November 2008	cnwdw1	
//
vars
	stopsTable: CM_StopsTable;
begin
	stopsTable := app.myRoot.allStopsTable[_id];
	if stopsTable &lt;&gt; null then
		deleteStopsOfType(_id);
		self.ignoreTrxWarnings(true);
		//app.myPassport.setWarningsIgnored(true);
		app.myTrxDA.trxDeleteStopsTable(stopsTable, app.myPassport);
		assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
		assertNullMsg(app.myRoot.allStopsTable[_id], "StopsTable was not deleted");
	endif;
end;</source>
        <Parameter name="_id" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="deleteStorageConfig" id="4d78376f-5afd-40ca-92e0-27f45b32bcbb">
        <source>deleteStorageConfig( _restoreDefault : Boolean );
// CCMS 1295 free storage days
// 06 Oct 2017	jlgrh7 TFS #7228 ADP - Storage Configuration Validation and Auditing
vars
	storageConfig	: CM_StorageConfig ;
	terminal		: CM_Terminal;
	storageDetail : CM_StorageDetail;
	yaCriteria : CM_YACriteria;
	
	criteriaTypes : CM_YACriteriaTypeArray;
	firstDayTimeCutoff	: Time;
	triggersIntArray : IntegerArray;
	
	allPxyTriggers : CM_StorageTriggerByType;
	triggerInt : Integer;
	pxyStorageTrigger : CM_StorageTrigger;
	proxyStorageConfig : CM_StorageConfig;
	
	realStorageConfig : CM_StorageConfig;
	
begin

	terminal := self.getTerminal();
	storageConfig := terminal.myStorageConfig;
	if storageConfig &lt;&gt; null then
	//app.myTrxDA.trxde
	//+TFS7228 Clear CM_StorageConfig's data before it can be deleted
		beginTransaction;
			foreach storageDetail in storageConfig.allStorageDetails do
				foreach yaCriteria in storageDetail.allCriteria do
					yaCriteria.setYardAllocation(null);
					delete yaCriteria;
				endforeach;
				delete storageDetail;
			endforeach;
		commitTransaction;
		app.myTrxDA.trxDeleteStorageConfig(storageConfig, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
	//23 Jul 2019	NDL	TFS 45574
	if _restoreDefault then
	
		firstDayTimeCutoff := "00:00".Time;
	
		create criteriaTypes transient;
		criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
		criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_OperatorItem]);
		criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_ContentsStatus]);
		
		create triggersIntArray transient;
		triggersIntArray.add( StorageDebtor );
		triggersIntArray.add( IMEX_EX_TO_IM );
		triggersIntArray.add( IMEX_EX_TO_ST );
		triggersIntArray.add( IMEX_IM_TO_EX );
		triggersIntArray.add( IMEX_IM_TO_ST );
		triggersIntArray.add( IMEX_IM_TO_TR );
		triggersIntArray.add( IMEX_ST_TO_EX );
		triggersIntArray.add( IMEX_ST_TO_IM );
		triggersIntArray.add( IMEX_TR_TO_EX );
		triggersIntArray.add( IMEX_TR_TO_IM );
		triggersIntArray.add( IMEX_TR_TO_ST );
		triggersIntArray.add( SubTerminal );
		triggersIntArray.add( VoyageChange );
		
		create allPxyTriggers transient;
		foreach triggerInt in triggersIntArray do
			create pxyStorageTrigger transient;
			pxyStorageTrigger.setProxy( triggerInt, false, null);
			allPxyTriggers.add(pxyStorageTrigger);
		endforeach;
		
		create proxyStorageConfig transient;
		proxyStorageConfig.setProxy(criteriaTypes,	//_criteria : CM_YACriteriaTypeArray; 
									allPxyTriggers,	//_triggers : CM_StorageTriggerByType;
									firstDayTimeCutoff,	//_firstDayTimeCutoff : Time;
									false,	//_includeFirstDay : Boolean;
									true,	//_includeLastDay : Boolean; 
									terminal,	//_terminal : CM_Terminal;
									CM_StorageConfig.ShipReceivalActualDischarge,	//_shipReceivalType : Integer;
									CM_StorageConfig.ShipReleaseActualLoad,	//_shipReleaseType : Integer;
									null,	//_calendar : CM_Calendar;
									null,	//_compulsory : CM_Calendar
									Storage_RoadActualReceival, //09/06/2023	navkc1	CR 58007 Task 58006 
									Storage_RailActualReceival, //09/06/2023	navkc1	CR 58007 Task 58006
									Storage_UnpackActualUnpack //09/06/2023	navkc1	CR 58007 Task 58006
									);
		
		app.myTrxCA.trxCreateStorageConfig( proxyStorageConfig, realStorageConfig,null, app.myPassport );
		
		if allPxyTriggers &lt;&gt; null then
			if not allPxyTriggers.isEmpty then
				allPxyTriggers.purge();
			endif;
			delete allPxyTriggers;
		endif;
		delete proxyStorageConfig;
		
		
	endif;

epilog
	
	delete criteriaTypes;
	delete triggersIntArray;
	if allPxyTriggers &lt;&gt; null then
		if not allPxyTriggers.isEmpty then
			allPxyTriggers.purge();
		endif;
		delete allPxyTriggers;
	endif;
	delete proxyStorageConfig;
	
end;
</source>
        <Parameter name="_restoreDefault" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="deleteStorageDetail" id="7387bf9e-3577-48c1-ae92-0547ea08953a">
