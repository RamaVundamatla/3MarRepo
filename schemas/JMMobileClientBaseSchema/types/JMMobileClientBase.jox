    <JadeMethod name="getPersistentAppByNameJMT" id="0507b155-9ab1-4bd5-acae-7c6ad97c5e10">
        <source>getPersistentAppByNameJMT(_schemaName:String; _appName : String) : Application;

vars
	tmpApp	: Application;
begin
	foreach tmpApp in Application.instances do
		if tmpApp.schema &lt;&gt; null
		and tmpApp.schema.name = _schemaName
		and tmpApp.name = _appName
		then
			return tmpApp;
		endif;
	endforeach;
	
	return null;
end;</source>
        <Parameter name="_schemaName" type="String"/>
        <Parameter name="_appName" type="String"/>
        <ReturnType type="Application"/>
    </JadeMethod>
