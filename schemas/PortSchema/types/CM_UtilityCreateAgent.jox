    <JadeMethod name="utlCreateLayoutGraphic" id="a3c5e645-fcfa-44ac-bcb2-2903a4557a51">
        <source>utlCreateLayoutGraphic(pProxyLayoutGraphic : CM_LayoutGraphic input; 
					pNewLayoutGraphic : CM_LayoutGraphic output;
					_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theRealTerminal : CM_Terminal;
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	app.myValCA.valLayoutGraphic(pProxyLayoutGraphic);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	app.setContinueCMExceptions(false);
	
	theRealTerminal := pProxyLayoutGraphic.myTerminal;
	if theRealTerminal &lt;&gt; null then
		if theRealTerminal.isTransient then
			theRealTerminal := pProxyLayoutGraphic.myTerminal.pxyGetRealObject;
		endif;
	endif;
	create pNewLayoutGraphic as pProxyLayoutGraphic.class persistent;
	
	pNewLayoutGraphic.setTerminal(theRealTerminal,pNewLayoutGraphic.label);
	pNewLayoutGraphic.setForCreate(pProxyLayoutGraphic); // Populate Real Stack from Proxy
end;</source>
        <Parameter name="pProxyLayoutGraphic" type="CM_LayoutGraphic" usage="input"/>
        <Parameter name="pNewLayoutGraphic" type="CM_LayoutGraphic" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
