<CollClass name="CM_SnapshotFieldArray" id="68a1a152-4713-4ec5-8c71-c0fd6242c28e">
    <loadFactor>66</loadFactor>
    <memberType name="CM_SnapshotField"/>
    <superclass name="ObjectArray"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="snapshots"/>
    <JadeMethod name="getFieldByPropertyName" id="e6f4cd2f-82cf-4ff1-8229-741acbeb263e">
        <source>getFieldByPropertyName( _propName : String; _heading : String ) : CM_SnapshotField;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 December 2009	cnwndl1	Initial creation	CCMS 1023

*/

vars
	iter : Iterator;
	field : CM_SnapshotField;
begin
	iter := self.createIterator;
	while iter.next( field ) do
		if field.propertyName &lt;&gt; _propName then
			continue;
		endif;
		if field.heading &lt;&gt; _heading then
			continue;
		endif;
		return field;
	endwhile;
	return null;
epilog
	delete iter;
end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_heading" type="String"/>
        <ReturnType type="CM_SnapshotField"/>
    </JadeMethod>
</CollClass>
