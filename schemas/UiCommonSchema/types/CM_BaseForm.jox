    <JadeMethod name="doPrintOutTable" id="8553624b-8a3f-4cbf-a522-509d2c85083a">
        <source>doPrintOutTable(_dataTable : Table input; _headerStr : String; _preview : Boolean; 
		_whiteBG, _useOrigTableColumnWidths : Boolean; _portrait : Boolean) ;
// ---------------------------------------------------------------------------
// Created:		June 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	gtpdataTable : CM_GenericTablePrint;
	now : TimeStamp;
	tmpJadeReport : JadeReport;

begin
	now := self.systemToLocalTime(app.actualTimeServer());	// 10/6/16 cnwmp6 TFS 488 - Multi timezone support
	app.mousePointer := MP_HOURGLASS;
	app.printer.suppressDialog := true;

	create gtpdataTable transient;
	gtpdataTable.whiteBackground := _whiteBG;
	
	if _portrait then
		app.printer.setMargins(Print_Portrait,0,0,10,10);
	else
		app.printer.setMargins(Print_Landscape,0,0,10,10);
	endif;
	gtpdataTable.frHeader.width := app.printer.pageWidth;

	gtpdataTable.setHeaders(_headerStr, null );
	
	create tmpJadeReport transient;
	tmpJadeReport.description := _headerStr[1:60];
	
	if _preview then  // if print preview required then set report
		app.printer.setReport(tmpJadeReport);
	endif;
	app.printer.setHeader(gtpdataTable.frHeader);

	gtpdataTable.frFooter.width := app.printer.pageWidth;
	gtpdataTable.lblTheUser.caption := app.getMyUserCode;
	gtpdataTable.lblTheDatePrinted.caption := now.String;
	gtpdataTable.useOrigTableColumnWidths := _useOrigTableColumnWidths;

	app.printer.setFooter(gtpdataTable.frFooter);

	if _dataTable &lt;&gt; null then
		gtpdataTable.printTable(_dataTable, (not _portrait), null);
	else
		self.printControlData(gtpdataTable, null);
	endif;

	app.printer.close;
	if _preview then // if print preview call method 
		app.printPreview(tmpJadeReport, true);
	endif;
	
	
epilog
	app.printer.close;

	delete gtpdataTable;
	app.mousePointer := MP_DEFAULT;
end;</source>
        <Parameter name="_dataTable" type="Table" usage="input"/>
        <Parameter name="_headerStr" type="String"/>
        <Parameter name="_preview" type="Boolean"/>
        <Parameter name="_whiteBG" type="Boolean"/>
        <Parameter name="_useOrigTableColumnWidths" type="Boolean"/>
        <Parameter name="_portrait" type="Boolean"/>
    </JadeMethod>
