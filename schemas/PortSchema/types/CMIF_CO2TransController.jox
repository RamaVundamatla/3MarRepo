<Class name="CMIF_CO2TransController" id="1ce704ac-6e55-4800-aeb0-29aeb0238605">
    <superclass name="CMIF_TITransactionController"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="tempreading"/>
    <ImplicitInverseRef name="myCO2Reading" id="f70b77a3-cc99-4aa0-839d-243bd5c69a27">
        <embedded/>
        <type name="CM_CO2Reading"/>
    </ImplicitInverseRef>
    <JadeMethod name="setFromTransaction" id="de639abc-ec98-4ad3-83fe-c9e082b8810e">
        <updating/>
        <source>setFromTransaction(_txn : CM_CO2ReadingTransaction) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/12/2025	navdap1		Initial creation MTN-36569 CPL | Reefer Runner Integration
//
vars

begin
	inheritMethod(_txn);
	self.myCO2Reading := _txn.myCO2Reading;
	
epilog

end;</source>
        <Parameter name="_txn" type="CM_CO2ReadingTransaction"/>
    </JadeMethod>
    <JadeMethod name="setTransactionDetails" id="4b258069-0dcb-4011-9172-883e49c7ed9e">
        <updating/>
        <source>setTransactionDetails(_txn : CM_CO2ReadingTransaction input) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/12/2025	navdap1		Initial creation MTN-36569 CPL | Reefer Runner Integration

vars

begin
	inheritMethod(_txn);
	_txn.setMyCO2Reading(self.myCO2Reading);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_txn" type="CM_CO2ReadingTransaction" usage="input"/>
    </JadeMethod>
</Class>
