	permArray.add(PmVoyageHoldOpsDate);
epilog

end;</source>
        <Parameter name="permArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getQuantityForMove" id="02e08662-87dc-4ddd-bdf7-5d9f6ffb4c7b">
        <source>getQuantityForMove(_moveController : CMIF_MoveController input) : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/02/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
// 02/03/2017	cnwdap1		TFS 3516 LNX Hold Planning Quantity
// 19/10/2017	jlgdap1		TFS 7492 LNX Voyage Hold Jobs - need to keep track of weight as well as quantity for LNX
//
vars
	ti : CM_TrackedItem;
	form : CMUI_MoveAmountForm;
	quantity : Integer;							// TFS 7492

begin
	ti := _moveController.myTrackedItem;
	if ti = null or _moveController = null then
		return true;
	endif;
	if not (ti.myCargoType.isBreakBulkMulti or ti.myCargoType.isBulkMulti) then
		return true;
	endif;
	
	app.mousePointer := MousePointer_Default;
	
	create form transient;
	form.myTrackedItem := ti;
	if ti.canMergeBreakBulk then													// TFS 3516
		form.myWorkListEntry := _moveController.myWorkListEntry;					// TFS 3516
	endif;																			// TFS 3516
	if _moveController.myToPrimaryLocation &lt;&gt; null then
		form.targetLocation := _moveController.myToPrimaryLocation.getFullId;
	else
		form.targetLocation := "Off Site";
	endif;
		
	if form.showModal &lt;&gt; IDOK then
		return false;
	endif;
	if form.byQuantity then
		quantity := form.getQuantity;	
		//epr TFS 8222 7/12/17
		// TFS 7492
		_moveController.setWeight( _moveController.weight / _moveController.quantity * quantity);	// TFS 7492
		//_moveController.quantity := form.getQuantity;											// TFS 7492
		_moveController.setQuantity( quantity);													// TFS 7492
	else
		_moveController.setWeight( form.getWeightMovedKgs);
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="217122c5-3dd1-4624-b68d-6ab0d26fcc8b">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27 January 2017	cnwdap1		Initial creation PAR #
//
vars
	xmlStr	: String;
	loadArea, dischargeArea, dischargeSubArea, xmlLoad, xmlDischarge : String;	

begin
	xmlStr := inheritMethod();
	
	// table columns
	xmlStr := xmlStr &amp; self.tblJobDetails.getXmlStrForColumns(true);
	
	// load and discharge areas
	if self.myDischargeArea &lt;&gt; null then
		dischargeArea := self.myDischargeArea.id;
		if self.myDischargeSubArea &lt;&gt; null then
			if self.myDischargeSubArea.isKindOf(CM_LocationsController) then
				dischargeSubArea := self.myDischargeSubArea.CM_LocationsController.ident;
			elseif self.myDischargeSubArea.isKindOf(CM_GridColumn) then
				dischargeSubArea := self.myDischargeSubArea.CM_GridColumn.label;
			elseif self.myDischargeSubArea.isKindOf(CM_RoRoController) then
				dischargeSubArea := self.myDischargeSubArea.CM_RoRoController.ident;
			elseif self.myDischargeSubArea.isKindOf(CM_GridRow) then
				dischargeSubArea := self.myDischargeSubArea.CM_GridRow.label;
			endif;
		endif;
	endif;
	if self.myLoadArea &lt;&gt; null then
		loadArea := self.myLoadArea.getFullId;
	endif;
	xmlDischarge := global.formatAsXMLPrefix(self.XMLTag_DischargeArea) &amp; 
				dischargeArea &amp; 
				global.formatAsXMLSuffix(self.XMLTag_DischargeArea) &amp;
				global.formatAsXMLPrefix(self.XMLTag_DischargeSubArea) &amp; 
				dischargeSubArea &amp; 
				global.formatAsXMLSuffix(self.XMLTag_DischargeSubArea);
	xmlLoad := global.formatAsXMLPrefix(self.XMLTag_LoadArea) &amp; 
				loadArea &amp; 
				global.formatAsXMLSuffix(self.XMLTag_LoadArea);
	xmlStr := xmlStr &amp; xmlDischarge &amp; xmlLoad;
	
	xmlStr := xmlStr &amp; global.formatAsXML( self.chkCurrentVoys.name, self.chkCurrentVoys.value.String );	//22 Feb 2021	NDL	TFS 50834
	
	return xmlStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleDeletedJob" id="153d68a4-6e29-4d4d-a7fc-26c2fa1ded6b">
        <updating/>
        <source>handleDeletedJob(_job : CM_VoyageHoldJob) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/02/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
//
vars

begin
	self.cmbJob.removeObject(_job);
	
	if self.myCurrentJob = _job then
		app.msgBox(app.getErrorString1(XLAT_Viewed_Object_Deleted, app.getErrorString(Job)), app.getErrorString(Object_Deleted), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		
		// clear all details and refresh job id combo from current voyage
		self.myCurrentJob := null;
		self.cmbJob.listIndex := -1;
		self.txtJobRemarks.text := null;
		self.txtShiftRemarks.text := null;
		self.txtShiftStartDate.setDate(null);
		self.txtShiftStartTime.setTime(null);
		self.txtShiftEndDate.setDate(null);
		self.txtShiftEndTime.setTime(null);
		self.shtJobDetails.caption := null;
		self.tblJobDetails.rows := self.tblJobDetails.fixedRows;
		
		self.doHandleRemarkSaveBtns( null );	//03 Jul 2017
		
	endif;
epilog

end;</source>
        <Parameter name="_job" type="CM_VoyageHoldJob"/>
    </JadeMethod>
    <JadeMethod name="handleDeletedWLE" id="b33050e7-bb38-4b0a-9448-186bf1df7f4d">
        <source>handleDeletedWLE(_wle : CM_WorkListEntry);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/01/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
//
vars
	idx : Integer;

begin
	if self.tblJobDetails.findObjectInRow(_wle, idx) then
		self.tblJobDetails.removeItem(idx);
	endif;
	if self.allDisplayedWLEs.includes(_wle) then
		self.allDisplayedWLEs.remove(_wle);
	endif;
epilog

end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="0ae9ee11-032d-44a6-9e6a-e9e3ea1c44c8">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/01/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enahncements
//
vars
	dischargeArea, dischargeSubArea, loadArea : String;
	area : CM_LocationsController;
	dict : CM_GeneralCCtrByHatchPlaceDict;
	hatch : CM_LocationsController;
	voyage : CM_Voyage;

begin
	inheritMethod(_userWindow);
	
	if _userWindow = null then
		return;
	endif;
	
	voyage := self.myCurrentVoyage;
	if voyage = null then
		voyage := app.getMyCurrentVoyage;
	endif;
	
	dischargeArea := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XMLTag_DischargeArea).String.removeCrLfs.trimBlanks;
	dischargeSubArea := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XMLTag_DischargeSubArea).String.removeCrLfs.trimBlanks;
	loadArea := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.XMLTag_LoadArea).String.removeCrLfs.trimBlanks;
	if dischargeArea &lt;&gt; null then
		self.cmbDischLoad.listIndex := self.cmbDischLoad.findStringExact(1, dischargeArea);
		self.myDischargeArea := self.myTerminal.allTerminalAreas[dischargeArea];
		if self.myDischargeArea &lt;&gt; null then
			self.cmbSubArea.listIndex := self.cmbSubArea.findStringExact(1, dischargeArea &amp; " - " &amp; dischargeSubArea);
			foreach area in self.myDischargeArea.allLocationsControllers discreteLock do
				if area.ident = dischargeSubArea then	
					self.myDischargeSubArea := area;
					break;
				endif;
			endforeach;
		endif;
	endif;
	if loadArea &lt;&gt; null then
		self.cmbDischLoad.listIndex := self.cmbDischLoad.findStringExact(1, loadArea);
		if voyage &lt;&gt; null and voyage.myShipBlockStack.getFullId = loadArea then
			self.myLoadArea := voyage.myShipBlockStack;
		elseif voyage &lt;&gt; null and voyage.myGeneralCargoVoyage &lt;&gt; null then
			dict := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace;
			foreach hatch in dict discreteLock, reversed where hatch.getFullId = loadArea do
				self.myLoadArea := hatch;
			endforeach;
		endif; 
	endif;
	
	self.chkCurrentVoys.value := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.chkCurrentVoys.name).Boolean;	//22 Feb 2021	NDL	TFS 50834
	
epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="loadCombos" id="e73c2ca5-14ee-4180-b2f4-aa9847ca6d5a">
        <updating/>
        <source>loadCombos() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 26/01/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
//
vars
	startDT, endDT : TimeStamp;
	workPoint : CM_WorkPoint;
	area : CM_TerminalArea;
	idx : Integer;

begin
	if self.myCurrentVoyage = null then
		return;
	endif;
	
	// load work points 
	self.cmbWorkPoint.sorted := true;
	self.cmbWorkPoint.clear;
	foreach workPoint in self.myTerminal.allWorkPointsByCode where not workPoint.isNotAvailableForEntry do
		idx := self.cmbWorkPoint.addItem(workPoint.code &amp; " - " &amp; workPoint.description);
		self.cmbWorkPoint.itemObject[idx] := workPoint;
	endforeach;
	
	self.loadLocationsCombo(true);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadCurrentVoyage" id="49a0fb41-f64d-4e87-8925-50d71a2a8e96">
        <updating/>
        <source>loadCurrentVoyage() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 26/01/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
// 24/02/2024 	navcs2 		MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
vars
	idx 	: Integer;
	sheet 	: CMUI_Sheet;
	table 	: CM_DataTable;
	job 	: CM_Job;
begin
	self.doNotableClear;
	self.clearJobDetails();
	
	if self.myCurrentVoyage = null then
		self.tblJobDetails.rows := self.tblJobDetails.fixedRows;
		return;
	endif;
	
	if not self.listeningForClassNotes then
		self.listeningForClassNotes := true;
		self.beginClassNotification( CM_TrackedItem, false, Any_System_Event, Response_Continuous, 1);
		self.beginClassNotification(CM_VoyageHoldJob, false, Any_System_Event, Response_Continuous, 1);
	endif;
	
	// clear jobs combo and load with current jobs (for workpoint if workpoint is selected
	self.loadJobsForVoyageWP();
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="c45c76d1-6e29-4cb9-abff-41338dab4846">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 26/01/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
//
vars
	voyage : CM_Voyage;

begin
	app.mousePointer	:=	Busy;
	inheritMethod();
	
	voyage := self.myCurrentVoyage;
	
	self.myCurrentVoyage := null;
	self.doBuildComboVoyages();
	
	if voyage &lt;&gt; null and global.isValidObject(voyage) and self.cmbVoyage.findObject(voyage) &lt;&gt; null then
		self.setMyCurrentVoyage(voyage);
	else
		voyage := app.getMyCurrentVoyage();
		// check if voyage is for this terminal
		if voyage &lt;&gt; null and voyage.myTerminal &lt;&gt; self.myTerminal then
			voyage := null;
		endif;
	endif;
	
	if self.myCurrentVoyage = null and voyage &lt;&gt; null and global.isValidObject(voyage) then
		self.setMyCurrentVoyage(voyage);
	endif;
	self.cmbVoyage.listIndex := self.cmbVoyage.findObject(self.myCurrentVoyage);
	
	self.loadCurrentVoyage();
	
epilog
	app.mousePointer := Idle;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadJobDetails" id="1bb2465f-0f4e-4bac-9f6a-80900e49b8db">
        <updating/>
        <source>loadJobDetails(_job : CM_VoyageHoldJob) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 26/01/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
// 16/02/2017	cnwdap1		TFS 3455 Remove timezone stuff
// 22/02/2017	cnwdap1		TFS 3489 LNX DLR/SOB
//
// 3/11/2019	jlgns1		TFS 3827 XLAT_FormCaptions need to be sorted out
// 24/02/2024 	navcs2 		MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
vars
	coll 		: CM_WLEArray;
	ti 			: CM_TrackedItem;
	str 		: String;
	idx 		: Integer;
	translation : XLAT_Translation;
	wleArray 	: CM_WLEArray;							// TFS 3489
	isSOB 		: Boolean;								// TFS 3489
	shift 		: CM_Shift;
begin
	if _job = null then
		return;
	endif;
	
	self.myCurrentJob := _job;
	self.myCurrentWLE := null;			// TFS 42872 jlgzm1 22/08/2019
	self.myCurrentTrackedItem := null; 	// TFS 42872 
	idx := self.cmbWorkPoint.findObject(_job.myJobSheet.myWorkPoint);
	self.cmbWorkPoint.listIndex := idx;
	self.loadLocationsCombo(_job.isDischarge);
	
	self.txtJobRemarks.text := _job.remarks;
	
	shift := _job.myShift; // TFS 3548
	if shift &lt;&gt; null then // TFS 3548
		self.txtShiftRemarks.text := shift.remarks;
		self.txtShiftStartDate.setDate(shift.startDateTime.date); // TFS 3548
		self.txtShiftStartTime.setTime(shift.startDateTime.time); // TFS 3548
		self.txtShiftEndDate.setDate(shift.endDateTime.date); // TFS 3548
		self.txtShiftEndTime.setTime(shift.endDateTime.time);	 // TFS 3548
	else	
		self.txtShiftStartDate.setDate(_job.actualStartTs.date);
		self.txtShiftStartTime.setTime(_job.actualStartTs.time);
		self.txtShiftEndDate.setDate(_job.actualEndTs.date);
		self.txtShiftEndTime.setTime(_job.actualEndTs.time);	// TFS 3494 was .actualStartTS

	endif;
	
	self.doHandleRemarkSaveBtns( null );	//03 Jul 2017
	
	
	self.tblJobDetails.rows := self.tblJobDetails.fixedRows;
	self.tblJobDetails.clearAllSelected();
	
	create wleArray transient;								// TFS 3489
	_job.getAllWLEs(wleArray);								// TFS 3489
	if wleArray.isNotEmpty then
		ti := wleArray.first.myTrackedItem;						// TFS 3489
		if ti &lt;&gt; null and ti.isSOB then							// TFS 3489
			isSOB := true;										// TFS 3489
		endif;													// TFS 3489
	endif;
	//if _job.isDischarge then								// TFS 3489
	if _job.isDischarge and not isSOB then					// TFS 3489
		translation := app.zGetTranslatedText(XLAT_FormCaptions, Xlat_0021768);
		if translation &lt;&gt; null then
			self.lblDischLoad.setCaptionForTranslation(translation.text);
		endif;
		translation := app.zGetTranslatedText(XLAT_FormCaptions, Xlat_0021760);
		if translation &lt;&gt; null then
			self.btnDischLoad.setCaptionForTranslation(translation.text);
		endif;
/*		 using populateJobDetailsLocation below
		if self.myDischargeArea &lt;&gt; null then
			self.cmbDischLoad.listIndex := self.cmbDischLoad.findObject(self.myDischargeArea);
		else
			self.cmbDischLoad.listIndex := -1;
		endif;
		*/
		self.lblSubArea.visible := true;
		self.cmbSubArea.visible := true;
	else
		translation := app.zGetTranslatedText(XLAT_FormCaptions, Xlat_0021772);
		if translation &lt;&gt; null then
			self.lblDischLoad.setCaptionForTranslation(translation.text);
		endif;
		translation := app.zGetTranslatedText(XLAT_FormCaptions, Xlat_0021763);
		if translation &lt;&gt; null then
			self.btnDischLoad.setCaptionForTranslation(translation.text);
		endif;
/*		 using populateJobDetailsLocation below
		if self.myLoadArea &lt;&gt; null then
			self.cmbDischLoad.listIndex := self.cmbDischLoad.findObject(self.myLoadArea);
		else
			self.cmbDischLoad.listIndex := -1;
		endif;
		*/
		self.lblSubArea.visible := false;
		self.cmbSubArea.visible := false;
	endif;
	self.populateJobDetailsLocation(_job);
	
	create coll transient;
	_job.getAllWLEs(coll);
	self.loadWLEDetailsToTable(coll);
	
	if _job.myShift &lt;&gt; null then
		self.shtJobDetails.caption := _job.jobId &amp; Space &amp; _job.myVoyageJobSheet.myWorkPoint.code &amp; Space &amp; _job.myShift.code &amp; " - " &amp; _job.getJobTypeDescription;
	else
		self.shtJobDetails.caption := _job.jobId &amp; Space &amp; _job.myVoyageJobSheet.myWorkPoint.code &amp; " - " &amp; _job.getJobTypeDescription;
	endif;
	
	/* using populateJobDetailsLocation above
	self.setDischargeLoadArea(_job);
	if self.myDischargeArea &lt;&gt; null and _job.isDischarge then
		self.cmbDischLoad_click(self.cmbDischLoad);
	endif;
	*/
	
epilog
	delete coll;
	delete wleArray;						// TFS 3489
end;</source>
        <Parameter name="_job" type="CM_VoyageHoldJob"/>
    </JadeMethod>
    <JadeMethod name="loadJobsForVoyageWP" id="16c0a079-72c2-4b2f-91c2-c3695d482b45">
        <updating/>
        <source>loadJobsForVoyageWP() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 26/01/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
//
vars
	job : CM_Job;
	workPoint : CM_WorkPoint;

begin
	self.cmbJob.clear;
	if self.myCurrentVoyage = null then
		return;
	endif;
	
	self.clearJobDetails();
	workPoint := self.cmbWorkPoint.getCurrentItemObject().CM_WorkPoint;
	foreach job in self.myCurrentVoyage.allVoyageJobs do
		if not job.isKindOf(CM_VoyageHoldJob) then
			continue;
		endif;
		if workPoint &lt;&gt; null and job.CM_VoyageHoldJob.getMyWorkPointObject &lt;&gt; workPoint then
			continue;
		endif;
		
		self.cmbJob.addItemObject(job.id, job);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="loadLocationsCombo" id="f85d75d0-f4eb-4ead-8adf-3142182efba0">
        <updating/>
        <source>loadLocationsCombo(_discharge : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/02/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
// 16/03/2017	cnwdap1		TFS 3516 LNX Hold Planning Quantity
// 14/08/2018	jlgdap1		TFS 40003 PEL1 Voyage to Road Moves
// 16/08/2019	jlgzm1		TFS 42872 Direct Release Between HOLD Voyages and Rail
//
vars
	area : CM_TerminalArea;
	dict : CM_GeneralCCtrByHatchPlaceDict;
	hatch : CM_LocationsController;
	job : CM_Job;								// TFS 40003
	wle, voyageWle : CM_WorkListEntry;			// TFS 40003
	tmpLC : CM_LocationsController; 			// TFS 42872

begin
	self.cmbDischLoad.clear();
	self.cmbSubArea.clear();						// TFS 3516
	
	if _discharge then
		// TFS 40003 load trucks on site with a release request for any cargo in this job
		if self.myCurrentJob &lt;&gt; null then
			foreach job in self.myTerminal.myRoadJobSheet.allJobsByOrder do
				foreach wle in job.workListEntries where not wle.isCompleteForJob do
					foreach voyageWle in self.myCurrentJob.workListEntries do
						if wle.getMyTrackedITem = voyageWle.getMyTrackedITem then
							self.cmbDischLoad.addItemObject(wle.locationTarget, wle.getTargetLocation);
						endif;
					endforeach;
				endforeach;
			endforeach;
			
			// TFS 42872 Start
			// Add locations for Direct release moves
			foreach voyageWle in self.myCurrentJob.workListEntries do
				if voyageWle.isDRLinkedByFM then
					tmpLC := voyageWle.getTargetLocation();
					if tmpLC &lt;&gt; null then
						// double check that location hasn't already been added
						if self.cmbDischLoad.findObject(tmpLC) = -1 then
							self.cmbDischLoad.addItemObject(tmpLC.getFullId, tmpLC);
						endif;
					endif;
				endif;
			endforeach;
			// TFS 42872 End
			
		endif;
		// TFS 40003 end
		
		// then load terminal areas
		foreach area in self.myTerminal.allTerminalAreas discreteLock do
			if area.isSwapStack or area.isGateArea then
				continue;
			endif;
			
			self.cmbDischLoad.addItemObject(area.id, area);
		endforeach;
	else
		// load ship block stack and holds
		if self.myCurrentVoyage.myShipBlockStack &lt;&gt; null then
			self.cmbDischLoad.addItemObject(self.myCurrentVoyage.myShipBlockStack.getFullId(), self.myCurrentVoyage.myShipBlockStack);
		endif;
		
		if self.myCurrentVoyage.myGeneralCargoVoyage &lt;&gt; null then
			dict := self.myCurrentVoyage.myGeneralCargoVoyage.allLocationsByHatchPlace;
		
			foreach hatch in dict discreteLock, reversed do
				self.cmbDischLoad.addItemObject(hatch.getFullId, hatch);		
			endforeach;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_discharge" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadWLEDetailsToTable" id="d5b26140-87aa-4c5e-8af3-0745377aab84">
        <updating/>
        <source>loadWLEDetailsToTable(_coll : CM_WLEArray) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/01/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operatios Enhancements
// 15/10/2021	navdap1		TFS 51935 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
//
vars
	wle, displayedWle : CM_WorkListEntry;
	str : String;
	idx : Integer;

begin
	self.tblJobDetails.rows := self.tblJobDetails.fixedRows;
	self.myCurrentWLE := null; // TFS 42872 jlgzm1 12/07/2019
	self.myCurrentTrackedItem := null;
	foreach wle in _coll do
		//if wle.myTrackedItem.hasBeenMerged then 								// TFS 51935
		if wle.myTrackedItem = null or wle.myTrackedItem.hasBeenMerged then 	// TFS 51935
			continue;
		endif;
		str := wle.getAttributeStringForDefArray(self.tblJobDetails.allTblDataEntRows);
		idx := self.tblJobDetails.addItem(str);
		self.tblJobDetails.accessRow(idx).itemObject := wle;
		self.doColourTableRow(wle, self.myCurrentJob, idx);
		self.doNotableAdd(wle);
	endforeach;

epilog
	
end;</source>
        <Parameter name="_coll" type="CM_WLEArray"/>
    </JadeMethod>
