	self.locationArray.add("D4044");
	self.statusArray.add("D4044 D4044 | Aft: D4039 | 4 x CONT AUBRI  U20G| 3 x CONT AUSYD  U40G | UT313670084, UT313670085, UT313670054, UT313670055, UT313670056, UT313670082, UT313670083 Job: 207");
	
