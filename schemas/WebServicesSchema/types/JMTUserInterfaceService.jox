        <ReturnType type="WS_MachineStatusResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="machineDoGetNext" id="d76d662c-15e7-49c2-88c6-caf942632e7c">
        <source>machineDoGetNext()  : WS_MachineStatusResponse webService;
/*

Date		Who		Reason
22 May 2017	cnwer1	Initial creation TFS 995

*/

vars

response		: WS_MachineStatusResponse;
	completedOK		: Boolean;
	wsMachineTasks : WS_MachineStatus;
	allIMVTasks : CM_RTQueueTaskArray;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null ;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
	self.validateCurrentMachine(true);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	// PAR 20338 18807
	app.myPassport.setupForDeadlockReplay(-100, 2000);
	
	while true do
		self.setIgnoreWarnings(true);
		app.myTrxUA.trxMachineGetNext(currentSession.myCurrentMachine,app.myPassport);
		
		if app.myPassport.noTrxReplayAllowed() then	//15 Jan 2013	NDL	Par 30920
			break;
		endif;

	endwhile;
	
	
	if app.myPassport.noErrors then
		create wsMachineTasks transient;
		wsMachineTasks.setProxyFromObject(currentSession.myCurrentMachine);	
		response.myMachineStatus:=wsMachineTasks;
		
		//epr tfs 5451 24/7/17
		if currentSession.myCurrentMachine.isIMV then
			//interested in imv task states
			create allIMVTasks transient;
			currentSession.myCurrentMachine.allCurrentQueueTasks.copy(allIMVTasks);
		
			app.myTrxUA.trxMachineSetTaskStates(currentSession.myCurrentMachine,allIMVTasks,app.myPassport);
		endif;
		
	endif;
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	// ...
	delete allIMVTasks;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;
end;</source>
        <ReturnType type="WS_MachineStatusResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="machineDoIMVComplete" id="d604b081-829d-4eb4-9df8-0f1411ce46e1">
        <source>machineDoIMVComplete(_request : WS_MachineAcceptTasksRequest)  : WS_MachineStatusResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 October 2021	jlier1	Initial creation

*/

vars
	response : WS_MachineStatusResponse;
	task : CM_RTQueueTask;
	completedOK : Boolean;
	wle : CM_WorkListEntry;
	cargo : CM_TrackedItem;
	targetLocation : CM_LocationsController;
	voyage : CM_Voyage;
	mobileAgent 		: CMIF_MobileGenericAgent;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null ;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
		
	self.validateCurrentMachine(true);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	//epr TFS 5535 4/8/17 
	task := app.myPassport.getObjectOfTypeFromOid(_request.taskOid,CM_RTQueueTask).CM_RTQueueTask;
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	
	if task = null then
		app.raiseCMException(Input_required_field_RTQue,null,null);
		completedOK := true;
		return response;
	endif;

	cargo:=task.ti;
	if cargo = null then
		app.raiseCMException(Input_required_field_cargoId,null,null);
		completedOK := true;
		return response;
	endif;
	
	targetLocation:=task.targetLocation;
	if targetLocation = null then
		app.raiseCMException1(Location_NotFound,null,null,null);
		completedOK := true;
		return response;
	endif;
	
	if not targetLocation.isKindOf(CM_VoyageController) then
		app.raiseCMException(Cannot_load_voyage_locatio,null,null);
		completedOK := true;
		return response;
	endif;
	
	voyage :=targetLocation.CM_VoyageController.myVoyage;
	
	wle:=task.myEntry.myWorkListEntry;
	
	create mobileAgent transient;
	mobileAgent.setMyTerminal(app.myPassport.myTerminal);
	mobileAgent.setMyVoyage(voyage);
	mobileAgent.setIsFromWeb(true);
	mobileAgent.setChecksState( CMIF_MobileGenericAgent.ShipLoadCargo);
	self.setIgnoreWarnings(true);
	mobileAgent.doLanderLoad(cargo,targetLocation,wle,0,0);
	
	completedOK := true;
	return response;
	
epilog
	delete mobileAgent;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="_request" type="WS_MachineAcceptTasksRequest"/>
        <ReturnType type="WS_MachineStatusResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="machineDoMultiPickup" id="b44225e7-32eb-4ede-bec5-1e463eef6930">
        <source>machineDoMultiPickup(_request : WS_MultiMoveRequest) : WS_MachineStatusResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Aug 2021 navma1 ChangeRequest 51485: PRP - Multi-Roll Pickup Enhancement

*/

vars
	response		: WS_MachineStatusResponse;
	completedOK		: Boolean;
	cmifMultiItem   : CMIF_MultiMoveItem;
	allCmifItems    : CMIF_Array;
	rtqTask         : CM_RTQueueTask;
	targetLoc		: String;
	moveRequestItem : WS_MoveItem;
	terminal 	    : CM_Terminal;
	machine         : CM_Machine;
	wsMachineStatus : WS_MachineStatus;
	
begin

// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null ;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	terminal := app.myPassport.myTerminal;
	
	// Create the response
	create response transient;

	
	self.validateCurrentMachine(true);
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	machine := currentSession.myCurrentMachine;

	//[1] Prepare Items
	create allCmifItems transient;
	foreach moveRequestItem in _request.allMoveItems do
		
		targetLoc := moveRequestItem.targetLocation;
		rtqTask   := app.myPassport.getObjectOfTypeFromOid(moveRequestItem.taskOid,CM_RTQueueTask).CM_RTQueueTask;
		
		if targetLoc &lt;&gt; null and rtqTask &lt;&gt; null then
			create cmifMultiItem transient;
			cmifMultiItem.setCmifDetails(rtqTask,targetLoc);
			allCmifItems.add(cmifMultiItem);
		endif;
	endforeach;
	
	//[2] Call pickup Trx
	if allCmifItems.isNotEmpty() then
			
		app.myPassport.setupForDeadlockReplay(-100, 2000);
		while true do
			self.setIgnoreWarnings(true);
			
			app.myTrxUA.trxMachinePickupMultiTask(machine,allCmifItems, app.myPassport);
		
			if app.myPassport.noTrxReplayAllowed() then	
				break;
			endif;
	
		endwhile;
	endif;
	
	if app.myPassport.noErrors then
		create wsMachineStatus transient;
		wsMachineStatus.setProxyFromObject(machine);	
		response.myMachineStatus := wsMachineStatus;
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
epilog
	// Tidy up any local transients
	// ...
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	if allCmifItems &lt;&gt; null then
		allCmifItems.purge;
	endif;
	delete allCmifItems;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

	process.setPersistentDeadlockPriority(0);
	app.myPassport.replayingDeadlocks := false;
end;</source>
        <Parameter name="_request" type="WS_MultiMoveRequest"/>
        <ReturnType type="WS_MachineStatusResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="machineDoMultiSetdown" id="7bf694e7-acd9-4be8-8b02-002eb5018734">
        <source>machineDoMultiSetdown(_request : WS_MultiMoveRequest) : WS_MachineStatusResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Sep 2021 navma1 ChangeRequest 51485: PRP - Multi-Roll Pickup Enhancement

*/

vars
	response		: WS_MachineStatusResponse;
	completedOK		: Boolean;
	cmifMultiItem   : CMIF_MultiMoveItem;
	allCmifItems    : CMIF_Array;
	rtqTask         : CM_RTQueueTask;
	targetLoc		: String;
