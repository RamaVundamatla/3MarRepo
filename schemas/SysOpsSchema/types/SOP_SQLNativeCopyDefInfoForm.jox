    <JadeMethod name="setupForm" id="52107267-1200-4146-b9a3-afbc589495fc">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 May 2010	#cnwdz2	 

*/

vars

begin
	inheritMethod();
	app.mousePointer := Idle;
	self.txtDefName.maxLength := self.maxDefNameLength;
	self.txtDefName.setFocus();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="70ae4af4-dfee-4f9c-ab3d-2b84c46dc029">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014939, locale);
	lblDefName.translateCaption(Xlat_0014940, locale);
	lblInfo.translateCaption(Xlat_0014941, locale);
end;</source>
    </JadeMethod>
</GUIClass>
