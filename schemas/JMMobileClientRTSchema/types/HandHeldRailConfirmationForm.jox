    <JadeMethod name="setLogicalFocus" id="16088e49-243b-4cbc-afa0-b97c838e316c">
        <source>setLogicalFocus() protected;
/*
----------   ----------  --------------------------------------------------
Created:	14 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin

	if self.fldMain.topSheet = self.shtError then
		self.txtWrongData.setFocus;
	elseif self.frmContInfo.visible then
		self.txtId.setFocus();
	elseif self.frmDamage.visible then
		self.tblDamage.setFocus();
	elseif self.fldMain.topSheet = self.shtInward then
		self.txtWagonIn.setFocus();
	elseif self.fldMain.topSheet = self.shtOutward then
		self.txtWagonOut.setFocus();
	endif;
	
end;


</source>
