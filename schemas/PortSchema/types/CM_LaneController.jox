    <JadeMethod name="setRFIDTagReader" id="1458b11e-b579-4971-a447-86fd83420daa">
        <source>setRFIDTagReader(_reader :CM_RFIDTagReader; _read : Boolean);
// ---------------------------------------------------------------------------
// Created:     29 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ld	: CM_LDRFIDTagReader;
	
begin
	self.raiseExceptionIfNotTransient (method);
	
	ld := self.getLaneDevice_RFIDTagReader(_read);
	
	if _reader = null then
		if ld &lt;&gt; null then
			// they are resetin gthe rfid tag reader
			delete ld;
		endif;
		return;
	endif;
	
	if ld = null then
		create ld transient;
		if _read then
			ld.setType(CM_LaneDevice.Type_RFIDTagReaderRead);
		else
			ld.setType(CM_LaneDevice.Type_RFIDTagReaderAssign);
		endif;
		// do this here so inverse mainenance happens after type has been set
		ld.setMyLaneController (self);
	endif;
	
	ld.setRFIDTagReader(_reader);
epilog

end;</source>
        <Parameter name="_reader" type="CM_RFIDTagReader"/>
        <Parameter name="_read" type="Boolean"/>
    </JadeMethod>
