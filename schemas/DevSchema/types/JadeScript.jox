    <JadeMethod name="kpdAnalyseADPTransientFile" id="47997ad7-458d-4cb3-9f05-b6db9ba45e88">
        <source>kpdAnalyseADPTransientFile();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2015	cnwkpd1	PAR #36286 - Changes for Unicode JADE


*/

constants
	TDBFileName		= "D:\adpc_36685\tdb_AEADSVTOS01-ADP2_0060c_1[187.234].tmp";
	LogFileName		= "D:\adpc_36685\messages.txt";
	MessageStart	= "Code :88787".Binary;
	MessageEnd		= #[3F].Binary;
	ChunkSize		= 1000000;
	
vars
	inFile,
	outFile			: File;
	count,
	chunks,
	pos,
	endPos,
	len				: Integer;
	bin				: Binary;
	msg				: String;
	
begin
	create inFile transient;
	inFile.kind := File.Kind_Binary;
	inFile.fileName := TDBFileName;
	inFile.open();
	
	create outFile transient;
	outFile.openOutput(LogFileName);
	
	while not inFile.endOfFile() do
		bin := inFile.readBinary(ChunkSize);
		
		pos := 1;
		len := bin.length();
		
		while pos &lt; len do
			pos := bin.posBinary(MessageStart, pos);
			
			if pos = 0 then
				break;
			endif;
			
			endPos := bin.posBinary(MessageEnd, pos);
			
			if endPos = 0 then
				msg := bin[pos:end].String;
				outFile.writeLine(msg);
				count := count + 1;
				break;
			endif;
			
			msg := bin[pos:endPos-pos].String;
			outFile.writeLine(msg);
			count := count + 1;
			
			pos := endPos + 1;
		endwhile;
		
		chunks := chunks + 1;
		write chunks.String &amp; " chunks read, " &amp; count.String &amp; " messages found";
		
	endwhile;
	
	inFile.close();
	outFile.close();
		
epilog
	delete inFile;
	delete outFile;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdAnalyseAudits" id="d31098a0-6559-495d-88ad-1f19e4c63c04">
        <source>kpdAnalyseAudits();
/*

Purpose:			Analyse the composition of the CM_AuditObject instances in the
					system to work out what can be deleted from old Unit Test runs


Date		Who		Reason
08 Aug 2012	cnwkpd1	Initial creation
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	audit 			: CM_AuditObject;
	oa 				: ObjectArray;
	iter			: Iterator;
	dict			: DynaDictionary;
	int				: CM_StateInteger;
	log				: File;
	year,
	month,
	hour			: Integer;
	usercode		: String;
	date			: Date;
	time			: Time;
	count			: Integer;
	line			: String;
	
begin
	create log transient;
	log.openOutput("c:\temp\" &amp; method.name &amp; "-" &amp; app.actualTimeServer.getNumeralString &amp; ".log");// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	write "Writing output to " &amp; log.fileName;
	
	create oa transient;
	CM_AuditObject.allInstances(oa, 0, true);
	
	write "Analysing " &amp; oa.size.String &amp; " CM_AuditObject instances";
	
	create dict transient;
	dict.setMembership(CM_StateInteger);
	dict.addExternalKey(Integer, null, false, true);		// Year
	dict.addExternalKey(Integer, null, false, true);		// Month
	dict.addExternalKey(Integer, null, false, true);		// Hour
	dict.addExternalKey(String, 30, false, true);			// Usercode
	dict.endKeys(false);
	
	iter := oa.createIterator();
	
	while iter.next(audit) do
		date := audit.creationTime.date();
		year := date.year;
		month := date.month;
		hour := audit.creationTime.time.hour;
		usercode := audit.userCode;
		
		int := dict.getAtKey(year, month, hour, usercode).CM_StateInteger;
		if int = null then
			create int transient;
			dict.putAtKey(year, month, hour, usercode, int);
		endif;
		
		int.setValue(int.value + 1);
		
		count := count + 1;
		if count mod 10000 = 0 then
			write count.String &amp; " CM_AuditObject instances processed";
		endif;
		
	endwhile;
	
	delete iter;
	iter := dict.createIterator();
	
	while iter.next(int) do
		dict.getIteratorKeys(year, month, hour, usercode, iter);
		
		line := year.String &amp; Tab &amp;
				month.String &amp; Tab &amp;
				hour.String &amp; Tab &amp;
				usercode.String &amp; Tab &amp;
				int.value.String;
				
		write line;
		log.writeLine(line);
	endwhile;
	
	log.close();
	
epilog
	delete iter;
	if dict &lt;&gt; null then
		dict.purge();
		delete dict;
	endif;
	delete log;
	delete oa;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdAnalyseBackgroundNodeLogs" id="162abe94-56fd-4421-9244-ba6d2682133e">
        <source>kpdAnalyseBackgroundNodeLogs();
/*

Purpose:			Analyse a sequence of CM_BackgroundNodeAgent stable collection logs, looking for
					any anomalies

Parameters:			None

Return Value:		None

Date		Who		Reason
03 May 2012	cnwkpd1	PAR #29384 - Diagnostic code for stable collection inconsistency checks

*/

vars
	ff				: FileFolder;
	fn				: FileNode;
	f				: File;
	line			: String;
	fields			: StringArray;
	jdo				: JadeDynamicObject;
	dict			: DynaDictionary;
	objStr,
	nameStr,
	keyStr			: String;
	highestEdition,
	editionVal,
	sizeVal			: Integer;
	
begin
	create ff transient;
	ff.fileName := ff.browseForFolder("Select log directory", "C:\temp\cnwdmast_logs\BackgroundNodeAgent");
	ff.mask := CM_BackgroundNodeAgent.name &amp; "*.log";
	
	create fields transient;
	create dict transient;
	dict.setMembership(JadeDynamicObject);
	dict.addExternalKey(String, 100, false, true);
	dict.endKeys(false);
	
	write "Starting analysis of logs in " &amp; ff.fileName;
	
	foreach fn in ff.files() do
		write "Analysing " &amp; fn.fileName;
		if fn.isKindOf(File) then
			f := fn.File;
			f.kind := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
			f.mode := File.Mode_Input;
			
			f.open();
			
			while not f.endOfFile() do
				line := f.readLine();
				line.csvToStringArray(fields, ',');
				
				if fields.size &lt; 6 then
					continue;			// Not a valid log line
				endif;
				
				objStr := fields[2];
				nameStr := fields[3];
				keyStr := fields[4];
				editionVal := fields[5].Integer;
				sizeVal := fields[6].Integer;
				
				jdo := dict.getAtKey(keyStr).JadeDynamicObject;
				if jdo = null then
					create jdo transient;
					jdo.addProperty("objStr", String);
					jdo.addProperty("nameStr", String);
					jdo.addProperty("keyStr", String);
					jdo.addProperty("editionVal", Integer);
					jdo.addProperty("sizeVal", Integer);
					jdo.addProperty("loggedError", Boolean);
					
					jdo.setPropertyValue("objStr", objStr);
					jdo.setPropertyValue("nameStr", nameStr);
					jdo.setPropertyValue("keyStr", keyStr);
					jdo.setPropertyValue("editionVal", editionVal);
					jdo.setPropertyValue("sizeVal", sizeVal);
					
					dict.putAtKey(keyStr, jdo);
				else
					if not jdo.getPropertyValue("loggedError").Boolean then
						highestEdition := jdo.getPropertyValue("editionVal").Integer;
						if highestEdition &gt; editionVal then
							write "Edition error at " &amp; line;
							jdo.setPropertyValue("loggedError", true);
						endif;
					endif;
					jdo.setPropertyValue("editionVal", editionVal);
				endif;
			
			endwhile;
		endif;
	endforeach;
	
	write "Finished";
		
epilog
	delete ff;
	if dict &lt;&gt; null then
		dict.purge;
		delete dict;
	endif;
	delete fields;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdAnalyseEmailLogs" id="36ed3d75-de29-4044-880d-10795279f048">
        <source>kpdAnalyseEmailLogs();
/*

Purpose:			Analyse a sequence of BGP Email logs, looking for SMTP server response times

Parameters:			None

Return Value:		None

Date		Who		Reason
14 Aug 2013	cnwkpd1	PAR #32151 - DPH email server timeouts

*/

vars
	ff				: FileFolder;
	fn				: FileNode;
	f				: File;
	line			: String;
	fields			: StringArray;
	
	dateStr,
	timeStr			: String;
	
	ts1,
	ts2				: TimeStamp;
	
	getNextLine		: Boolean;
	
	log				: File;
	
begin
	create ff transient;
	ff.fileName := ff.browseForFolder("Select log directory", "C:\temp\dphpjmt1");
	ff.mask := "bgpcontroller_email*.log";
	
	create log transient;
	log.openOutput("c:\temp\email_analysis.csv");
	
	write "Starting analysis of logs in " &amp; ff.fileName;
	
	create fields transient;
	
	ts1 := null;
	ts2 := null;
	getNextLine := false;
			
	foreach fn in ff.files() do
		write "Analysing " &amp; fn.fileName;
		if fn.isKindOf(File) then
			f := fn.File;
			f.kind := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
			f.mode := File.Mode_Input;
			
			f.open();
			
			while not f.endOfFile() do
				line := f.readLine();
				line.csvToStringArray(fields, ' ');
				
				if fields.size &lt; 3 then
					getNextLine := false;
					continue;			// Not a valid log line
				endif;
				
				dateStr := fields[1];
				timeStr := fields[2];
				
				if getNextLine then
					ts2.setDate(dateStr.Date);
					ts2.setTime(timeStr.Time);
					
					write ts1.dataDumpFormat() &amp; "," &amp; ts2.dataDumpFormat() &amp; "," &amp; (ts2 - ts1).String;
					log.writeLine(ts1.dataDumpFormat() &amp; "," &amp; ts2.dataDumpFormat() &amp; "," &amp; (ts2 - ts1).String);
					
					ts1 := null;
					ts2 := null;
					getNextLine := false;
				
					continue;
				endif;
				
				if fields[3] = "FileName" then
					ts1.setDate(dateStr.Date);
					ts1.setTime(timeStr.Time);
					
					getNextLine := true;
				
					continue;
				endif;
			endwhile;
		endif;
	endforeach;
	
	log.close();
	
	write "Finished";
		
epilog
	delete ff;
	delete fields;
	delete log;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdAnalyseITSExtract" id="27ab8fdd-1290-4ccf-bbca-faf8c2d62a6d">
        <source>kpdAnalyseITSExtract();
/*

Purpose:			Perform an analysis of a CSV file extracted from the ITS interface message 
					enquiry

Parameters:			None

Return Value:		None

Date		Who		Reason
22 Apr 2015	cnwkpd1	PAR #35832 - Message for truck load missing from RMG

*/

constants
	CSVFileName		= "c:\temp\mespjmt\CP37_messages_2015-04-08.csv";
	Delimiter		= ",";
	MachineId		= "CP37";
	
vars
	csvFile			: File;
	processedCol,
	machineCol,
	msgTypeCol,
	cargoIDCol,
	queueEntryCol	: Integer;
	line			: String;
	columns			: StringArray;
	queueObj		: JadeDynamicObject;
	queueDict		: DynaDictionary;
	processedDT		: TimeStamp;
	msgType			: String;
	cargoID			: String;
	queueID			: Integer;
	
begin
	create csvFile transient;
	csvFile.kind := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	csvFile.openInput(CSVFileName);
	
	create columns transient;
	// Read header line
	line := csvFile.readLine();
	line.csvToStringArray(columns, Delimiter);
	
	processedCol := columns.indexOf('Processed');
	machineCol := columns.indexOf('Machine');
	msgTypeCol := columns.indexOf('Message Type');
	cargoIDCol := columns.indexOf('Cargo Id');
	queueEntryCol := columns.indexOf('Queue Entry Id');
	
	create queueDict transient;
	queueDict.setMembership(JadeDynamicObject);
	queueDict.addExternalKey(Integer, 0, false, false);
	queueDict.endKeys(false);	
	
	while not csvFile.endOfFile() do
		line := csvFile.readLine();
		line.csvToStringArray(columns, Delimiter);

		// Skip unprocessed lines
		if columns[processedCol] = null then
			continue;
		endif;
		// Skip stuff not for this machine
		if columns[machineCol] &lt;&gt; MachineId then
			continue;
		endif;
		
		processedDT := columns[processedCol].TimeStamp;
		msgType := columns[msgTypeCol];
		cargoID := columns[cargoIDCol];
		queueID := columns[queueEntryCol].Integer;
		
		if msgType = "QueueEntry" then
			queueObj := queueDict.getAtKey(queueID).JadeDynamicObject;
			if queueObj = null then
				create queueObj transient;
				queueObj.addProperty("queueID", Integer);
				queueObj.setPropertyValue("queueID", queueID);
				queueObj.addProperty("cargoID", String);
				queueObj.setPropertyValue("cargoID", cargoID);

				queueDict.putAtKey(queueID, queueObj);
			else
				// Do nothing, the entry is already there
			endif;
		
		elseif msgType = "DeleteQueueEntry" then
			if cargoID = "ALL" then
				queueDict.purge();
			else
				queueObj := queueDict.getAtKey(queueID).JadeDynamicObject;
				if queueObj = null then
					write "&gt;&gt;&gt;&gt; Error entry " &amp; queueID.String &amp; " not found for DeleteQueueEntry";
				else
					queueDict.removeKey(queueID);
					delete queueObj;
				endif;
			endif;
		endif;
		
		write processedDT.String &amp; Tab &amp; 
			  msgType &amp; Tab &amp;
			  cargoID &amp; Tab &amp;
			  queueDict.size().String;
		
	endwhile;
	
epilog
	delete columns;

end;</source>
    </JadeMethod>
    <JadeMethod name="kpdAnalyseITSLogs" id="23931712-2237-44b9-9335-75392cd95283">
        <source>kpdAnalyseITSLogs();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 February 2012	cnwkpd1	PAR #28262 - CCMS 1223 - Delivery Mechanisms

*/

constants
	TerminalCode	= "DP1";
	MachineCode		= "27";
	InterfaceCode	= "ITSTest";
	
vars
	term			: CM_Terminal;
	machine			: CM_Machine;
	interface		: CM_ITSInterfaceDefinition;
	
begin
	term := CM_Root.firstInstance.allTerminals[TerminalCode];
	if term = null then
		return;
	endif;
	
	interface := term.allInterfaceDefinitions[InterfaceCode].CM_ITSInterfaceDefinition;
	if interface = null then
		return;
	endif;
	
	machine := term.machines[MachineCode];
	if machine = null then
		return;
	endif;
	
	self.kpdAnalyseITSLogsForMachine(interface, machine, null);
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="kpdAnalyseITSLogsForMachine" id="99ff6898-7a57-41d9-b68a-876a3605f5a9">
        <source>kpdAnalyseITSLogsForMachine(_interface : CM_ITSInterfaceDefinition;
							_machine : CM_Machine;
							_startTime : TimeStamp);
/*

Purpose:			Analyse the ITS Interface message logs for a given interface/machine,
					looking for the messages preceding a NAK

Parameters:			Interface and Machine to check, and starting timestamp to check from

Return Value:		None

Date		Who		Reason
22 Feb 2012	cnwkpd1	PAR #29125 - Issues with ITS interface

*/

constants
	MaxMessagesToShow	= 5;
	
vars
	messages		: HugeStringArray;
	messageLine		: String;
	itsMessage		: CM_ITSInterfaceMessage;
	iter			: Iterator;
	request			: CM_ITSInterfaceRequestMessage;
	response		: CM_ITSInterfaceResponse;
	isNak			: Boolean;
	
begin
	create messages transient;
	
	iter := _machine.allITSInterfaceMessages.createIterator();
	_machine.allITSInterfaceMessages.startKeyGeq(_startTime, iter);
	
	while iter.next(itsMessage) do
		if itsMessage.myITSInterfaceDefinition = _interface then
			isNak := false;
			messageLine := null;
			
			if itsMessage.isKindOf(CM_ITSInterfaceRequestMessage) then
				request := itsMessage.CM_ITSInterfaceRequestMessage;
				messageLine := request.createdTS.asStringJMT() &amp; Tab &amp; request.messageXML;
				isNak := request.messageXML.pos("&gt;NAK&lt;", 1) &gt; 0;
				
			elseif itsMessage.isKindOf(CM_ITSInterfaceResponse) then
				response := itsMessage.CM_ITSInterfaceResponse;
				messageLine := response.createdTS.asStringJMT() &amp; Tab &amp; response.messageType &amp; " " &amp; response.messageBodyXML;
	
			endif;
			
			if messageLine &lt;&gt; null then
				messages.add(messageLine);
				if messages.size &gt; MaxMessagesToShow then
					messages.removeAt(1);
				endif;
				
				if isNak then
					foreach messageLine in messages do
						write _machine.id &amp; Tab &amp; messageLine;
					endforeach;
					write " ";
				endif;
			endif;
			
		endif;
	
	endwhile;
	
	
epilog
	delete messages;
	delete iter;
	
end;</source>
        <Parameter name="_interface" type="CM_ITSInterfaceDefinition"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_startTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="kpdAnalyseInformationLogs" id="85a14a80-6979-4176-939c-9871a7b3b91e">
        <source>kpdAnalyseInformationLogs();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Feb 2012	cnwkpd1	PAR #29165 - CCMS SFW 1272 - Reduce physical database size

*/

vars
	oa				: ObjectArray;
	info			: CM_Information;
	countInfo,
	countLines		: Integer64;
	iter			: Iterator;
	
begin
	create oa transient;
	CM_Information.allInstances(oa, 0, true);
	iter := oa.createIterator();
	
	write "Processing " &amp; oa.size().String &amp; " CM_Information instances";
	
	while iter.back(info) do
		countInfo := countInfo + 1;
		countLines := countLines + info.allInformationLines.size();
		
		if countInfo mod 1000 = 0 then
			write countInfo.String &amp; " processed, average count = " &amp; (countLines / countInfo).String;
		endif;
	
	endwhile;

	write countInfo.String &amp; " processed, average count = " &amp; (countLines / countInfo).String;

epilog
	delete iter;
	delete oa;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdAnalyseJMTSchemas" id="4882fe5a-a7c1-4c42-8ec1-31d6bc92955e">
        <source>kpdAnalyseJMTSchemas();
/*

Purpose:			Analyse the JMT released schemas to document the number of classes

Parameters:			None

Return Value:		None

Date		Who		Reason
06 Dec 2012	cnwkpd1	JMT Architecture overview
// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	agent			: DEV_ReleaseExtractAgent;
	schemaNames,
	highLevelClsNames	: StringArray;
	schemaName,
	className		: String;
	scm				: Schema;
	cls				: Class;
	file			: File;
	classes			: ClassColl;
	
begin
	create file transient;
	file.openOutput("c:\temp\JMT_analysis_" &amp; app.actualTimeServer.getNumeralString &amp; ".txt");	// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	create agent transient;
	create schemaNames transient;
	agent.getReleaseSchemas(schemaNames);

	create highLevelClsNames transient;
	highLevelClsNames.add("CM_Object");
	highLevelClsNames.add("Collection");
	highLevelClsNames.add("CMUI_Object");
	highLevelClsNames.add("CMIF_Object");
	highLevelClsNames.add("CM_Query");
	highLevelClsNames.add("CM_Transient");
	highLevelClsNames.add("EntTableEntity");
	highLevelClsNames.add("CnEcBaseEntity");
	highLevelClsNames.add("JadeWebService");
	highLevelClsNames.add("WS_Object");
	highLevelClsNames.add("Form");
	highLevelClsNames.add("Control");
	
	create classes transient;
	
	foreach schemaName in schemaNames do
		scm := rootSchema.getSchema(schemaName);
		
		foreach className in highLevelClsNames do
			cls := scm.getClass(className);
			
			if cls = null then
				write className &amp; " not found in schema " &amp; schemaName;
				continue;
			endif;
			
			if cls.schema &lt;&gt; scm then
				write className &amp; " found in schema " &amp; schemaName &amp; " is actually in schema " &amp; cls.schema.name;
				continue;
			endif;	
			
			classes.clear();
			cls.allLocalSubclasses(classes);
			
			file.writeLine(schemaName &amp; Tab &amp; className &amp; Tab &amp; classes.size.String);
		
		endforeach;
	
	endforeach;
	
	file.close();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="kpdAnalyseJommsgConnectedProcs" id="78ba0d93-f481-4a52-a1b7-c806de260f92">
        <source>kpdAnalyseJommsgConnectedProcs();
/*

Purpose:			Analyse a sequence of jommsg logs and maintain a list of currently connected 
					processes, by application server and application

Parameters:			None

Return Value:		None

Date		Who		Reason
02 Dec 2014	cnwkpd1	JADE PAR #62022 investigation

*/

constants
	LocalProcessSignOn	= "Jom: Local process sign-on:";
	LocalProcessDelete	= "Jom: Local process delete:";
	AppServerPID		= "0178c-";
	StartingDate		= "25/11/2014".Date;
	EndingDate			= "01/12/2014".Date;
	
vars
	ff				: FileFolder;
	fn				: FileNode;
	f				: File;
	outFile			: File;
	
	line			: String;
	fields			: StringArray;
	pos				: Integer;
	
	date			: Date;
	time			: Time;
	threadId		: String;
	processId		: String;
	schemaName		: String;
	appName			: String;
	
	action			: String;
	msg				: String;
	
	dict			: DynaDictionary;
	iter			: Iterator;
	
	jdo				: JadeDynamicObject;
	
begin
	create ff transient;
	ff.usePresentationFileSystem := true;
	
//	ff.fileName := ff.browseForFolder("Select log directory", "C:\temp\qnspjmt");
	ff.fileName := "c:\temp\POL_AppServer";
	
	ff.mask := "jommsg*.log";
	
	create fields transient;
	
	create dict transient;
	dict.setMembership(JadeDynamicObject);
	dict.addExternalKey(String, 30, false, false);		// Schema name
	dict.addExternalKey(String, 30, false, false);		// Application name
	dict.addExternalKey(String, 30, false, false);		// Process id
	dict.endKeys(false);
	
	iter := dict.createIterator();
	
	create outFile transient;
	outFile.usePresentationFileSystem := ff.usePresentationFileSystem;
	outFile.openOutput(ff.fileName &amp; "\process_analysis_" &amp; EndingDate.formatAsYYYYMMDD &amp; ".log");
	msg := "Date,Time,Action,Schema,Application,Process ID,All PIDs";
	outFile.writeLine(msg);
	write msg;
	
	write "Starting analysis of logs in " &amp; ff.fileName;
	
	foreach fn in ff.files() do
		write "Analysing " &amp; fn.fileName;
		if fn.isKindOf(File) then
			f := fn.File;
			f.kind := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
			f.mode := File.Mode_Input;
			
			f.open();
			
			while not f.endOfFile() do
				line := f.readLine();
				
				// Is it something we are interested in?
				if line.pos(LocalProcessSignOn, 1) &gt; 0 or line.pos(LocalProcessDelete, 1) &gt; 0 then
					// Parse the line
					line.csvToStringArray(fields, ' ');

					if fields.size &lt; 16 then			// not a valid line
						continue;
					endif;
				else
					continue;
				endif;
				
				// Check date
				date := fields[1].Date;
				if date &lt; StartingDate or date &gt; EndingDate then			// skip dates not interested in
					continue;
				endif;

				// If filtering by App Server, then check we are interested 
				threadId := fields[3];
				if AppServerPID &lt;&gt; null and threadId.pos(AppServerPID, 1) = 0 then
					continue;
				endif;
				
				// Get the time
				time := fields[2].Time;

				// Get process, schema and app
				processId := fields[8];
				processId := processId[processId.pos('[', 1) + 1:end];
				pos := 1;
				processId := processId.scanUntil(']', pos);
				
				schemaName := fields[15];
				pos := 1;
				schemaName := schemaName[5:end].scanUntil(',', pos);
				
				appName := fields[16];
				pos := 1;
				appName := appName[5:end].scanUntil(',', pos);
				
				// If this is a signon, then need to create a signed on process
				if line.pos(LocalProcessSignOn, 1) &gt; 0 then
			
					create jdo transient;
					jdo.addProperty("processId", String);
						
					jdo.setPropertyValue("processId", processId);
						
					dict.putAtKey(schemaName, appName, processId, jdo);					
				
				// If this is a delete, then need to remove the process from the list
				elseif line.pos(LocalProcessDelete, 1) &gt; 0 then
				
					iter.reset();
					while iter.next(jdo) do
						if jdo.getPropertyValue("processId").String = processId then
							dict.removeKeyEntry(schemaName, appName, processId, jdo);
							delete jdo;
							break;
						endif;
					endwhile;
				
				endif;
				
				msg := date.format('dd/MM/yyyy') &amp; ',' &amp;
					   time.format('HH:mm:ss') &amp; "." &amp; time.milliSecond.String.padLeadingZeros(3) &amp; ',' &amp;
					   fields[7] &amp; "," &amp;
					   schemaName &amp; "," &amp;
					   appName &amp; "," &amp;
					   processId &amp; ",";
						  
				iter.reset();
				while iter.next(jdo) do
					msg := msg &amp; jdo.getPropertyValue("processId").String &amp; '|';
				endwhile;
				
				outFile.writeLine(msg);
				write msg;
				
			endwhile;
		endif;
	endforeach;
	
	outFile.close();
	
	write "Finished";
		
epilog
	delete ff;
	if dict &lt;&gt; null then
		dict.purge();
		delete dict;
	endif;
	delete fields;
	delete iter;
	delete outFile;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdAnalyseJommsgMachineNetwork" id="67953521-025d-4b66-a5f7-8afe5c63fdf7">
        <source>kpdAnalyseJommsgMachineNetwork();
/*

Purpose:			Analyse a sequence of jommsg logs looking for network disconnects for machines, and produce
					a CSV file with the analysis

Parameters:			None

Return Value:		None

Date		Who		Reason
25 May 2012	cnwkpd1	Milaha network issues

*/

constants
	SearchString	= "JadApp: Thin Client read request aborted/reset";
	StartingDate	= "01/06/2012".Date;
	EndingDate		= "04/06/2012".Date;
	
vars
	ff				: FileFolder;
	fn				: FileNode;
	f				: File;
	outFile			: File;
	
	line			: String;
	fields			: StringArray;
	
	date			: Date;
	time			: Time;
	computer		: String;
	ipAddress		: String;
	ts				: TimeStamp;
	
	dict			: DynaDictionary;
	rtDevice		: CM_RTDeviceVehicleMount;
	machine			: CM_Machine;
	machHistory		: CM_MachineHistory;
	iter			: Iterator;
	
	machineName		: String;
	lastMove		: String;
		
begin
	create ff transient;
//	ff.fileName := ff.browseForFolder("Select log directory", "C:\temp\qnspjmt");
	ff.usePresentationFileSystem := false;
	
	ff.fileName := "e:\cnwdmast\logs";
//	ff.fileName := "e:\qnspjmt\logs";
	
	ff.mask := "jom*.log";
//	ff.mask := "jommsg1*.log";
	
	create fields transient;
	create dict transient;
	dict.setMembership(CM_RTDeviceVehicleMount);
	dict.addMemberKey(CM_RTDeviceVehicleMount::computerName.name, false, true);
	dict.endKeys(false);

	foreach rtDevice in CM_RTDeviceVehicleMount.instances do
		if rtDevice.computerName &lt;&gt; null and rtDevice.myMachine &lt;&gt; null then
			dict.add(rtDevice);
		endif;
	endforeach;
	
	create outFile transient;
	outFile.usePresentationFileSystem := false;
	outFile.openOutput(ff.fileName &amp; "\network_analysis_" &amp; EndingDate.formatAsYYYYMMDD &amp; ".log");
	outFile.writeLine("Date,Time,Computer,IP Address,Machine,Last Move");
	
	write "Starting analysis of logs in " &amp; ff.fileName;
	
	foreach fn in ff.files() do
		write "Analysing " &amp; fn.fileName;
		if fn.isKindOf(File) then
			f := fn.File;
			f.kind := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
			f.mode := File.Mode_Input;
			
			f.open();
			
			while not f.endOfFile() do
				line := f.readLine();
				
				if line.pos(SearchString, 1) &gt; 0 then

					line.csvToStringArray(fields, ' ');

					if fields.size &lt; 14 then			// not a valid line
						continue;
					endif;
					
					date := fields[1].Date;
					
					if date &lt; StartingDate or date &gt; EndingDate then			// skip dates not interested in
						continue;
					endif;
					
					time := fields[2].Time;
					computer := fields[13];
					ipAddress := fields[14];
					ipAddress := ipAddress[2:ipAddress.length - 2];		// strip brackets
					
					rtDevice := dict[computer].CM_RTDeviceVehicleMount;
					if rtDevice = null then
						continue;
					endif;
					
					machine := rtDevice.myMachine;
					machineName := machine.code;
					lastMove := "&lt;not found&gt;";
					
					ts.setDate(date);
					ts.setTime(time);
					
					// Now go backwards from the time looking for a prior move
					delete iter;
					iter := machine.history.createIterator();
					machine.history.startKeyLeq(ts, iter);
					while iter.back(machHistory) do
						// Only interested in less than one hour ago
						if machHistory.dateTime.minutesDiff(ts) &gt; 60 then
							break;
						endif;
						if machHistory.isKindOf(CM_MachineMoveHistory) then
							lastMove := machHistory.getDisplayString().replace(Tab, ' ');
							break;
						endif;
					endwhile;
					
					line := (date.format('dd/MM/yyyy') &amp; ',' &amp;
							 time.format('HH:mm:ss') &amp; "." &amp; time.milliSecond.String.padLeadingZeros(3) &amp; ',' &amp;
							 computer &amp; ',' &amp;
							 ipAddress &amp; ',' &amp;
							 machineName &amp; ',' &amp;
							 lastMove);
							 
					outFile.writeLine(line);
					write line;
				endif;
			
			endwhile;
		endif;
	endforeach;
	
	outFile.close();
	
	write "Finished";
		
epilog
	delete ff;
	delete dict;
	delete fields;
	delete iter;
	delete outFile;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdAnalyseJommsgReconnects" id="3a3c194b-6471-42ca-9dd9-47ddf0c21a49">
        <source>kpdAnalyseJommsgReconnects();

/*

Purpose:			Analyse a sequence of jommsg logs looking for reconnects, and produce a CSV file with the analysis

Parameters:			None

Return Value:		None

Date		Who		Reason
30 May 2012	cnwkpd1	PAR #29636 Milaha network issues

*/

constants
	NetworkErrorString	= "JadApp: Thin Client read request aborted/reset";
	ConnectionLost		= "JadApp: Connection lost  ";
	ReconnectFailure	= "JadApp: Thin Client attempted reconnect failed - client no longer running on the App Server";
	ReconnectSuccess	= "JadApp: Thin Client reconnect succeeded";
	StartingDate		= "21/11/2012".Date;
	EndingDate			= "23/01/2014".Date;
	
vars
	ff				: FileFolder;
	fn				: FileNode;
	f				: File;
	outFile			: File;
	
	line			: String;
	fields			: StringArray;
	
	date			: Date;
	time			: Time;
	computer		: String;
	ipAddress		: String;
	ts,
	lastNetworkError	: TimeStamp;
	
	dict			: DynaDictionary;
	rtDevice		: CM_RTDeviceVehicleMount;
	machine			: CM_Machine;
	machHistory		: CM_MachineHistory;
	iter			: Iterator;
	
	machineName		: String;
	lastMove		: String;
	
	jdo				: JadeDynamicObject;
	dict2			: DynaDictionary;
	
	lineNo			: Integer;
	
begin
	create ff transient;
//	ff.fileName := ff.browseForFolder("Select log directory", "C:\temp\qnspjmt");
	ff.usePresentationFileSystem := true;
	
//	ff.fileName := "e:\cnwdmast\logs";
	ff.fileName := "C:\temp\pnlpjmt";
//	ff.fileName := "e:\qnspjmt\logs";
	
	ff.mask := "jommsg*.log";
	
	create fields transient;
	create dict transient;
	dict.setMembership(CM_RTDeviceVehicleMount);
	dict.addMemberKey(CM_RTDeviceVehicleMount::computerName.name, false, true);
	dict.endKeys(false);
	
	create dict2 transient;
	dict2.setMembership(JadeDynamicObject);
	dict2.addExternalKey(String, 65, false, true);
	dict2.endKeys(false);

	foreach rtDevice in CM_RTDeviceVehicleMount.instances do
		if rtDevice.computerName &lt;&gt; null and rtDevice.myMachine &lt;&gt; null then
			dict.add(rtDevice);
		endif;
	endforeach;
	
	create outFile transient;
	outFile.usePresentationFileSystem := ff.usePresentationFileSystem;
	outFile.openOutput(ff.fileName &amp; "\reconnect_analysis_" &amp; EndingDate.formatAsYYYYMMDD &amp; ".log");
	outFile.writeLine("Date,Time,Computer,IP Address,Machine,Reconnect Delay (ms),Success/Fail");
	
	write "Starting analysis of logs in " &amp; ff.fileName;
	
	foreach fn in ff.files() do
		write "Analysing " &amp; fn.fileName;
		if fn.isKindOf(File) then
			f := fn.File;
			f.kind := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
			f.mode := File.Mode_Input;
			
			f.open();
			
			lineNo := 0;
			
			while not f.endOfFile() do
				line := f.readLine();
				
				lineNo := lineNo + 1;
				
				// Is it a network error?
				if line.pos(NetworkErrorString, 1) &gt; 0 then

					line.csvToStringArray(fields, ' ');

					if fields.size &lt; 14 then			// not a valid line
						continue;
					endif;
					
					date := fields[1].Date;
					
					if date &lt; StartingDate or date &gt; EndingDate then			// skip dates not interested in
						continue;
					endif;
					
					time := fields[2].Time;
					
					ts.setDate(date);
					ts.setTime(time);
					
					computer := fields[13];
					ipAddress := fields[14];
					ipAddress := ipAddress[2:ipAddress.length - 2];		// strip brackets
					
					machine := null;
					machineName := "&lt;none&gt;";
					
					rtDevice := dict[computer].CM_RTDeviceVehicleMount;
					if rtDevice &lt;&gt; null then
						machine := rtDevice.myMachine;
						machineName := machine.code;
					endif;

					jdo := dict2.getAtKey(ipAddress).JadeDynamicObject;
					if jdo = null then
						create jdo transient;
						jdo.addProperty("ipAddress", String);
						jdo.addProperty("computer", String);
						jdo.addProperty("machineName", String);
						jdo.addProperty("lastNetworkError", TimeStamp);
						
						jdo.setPropertyValue("ipAddress", ipAddress);
						jdo.setPropertyValue("computer", computer);
						jdo.setPropertyValue("machineName", machineName);
						
						dict2.putAtKey(ipAddress, jdo);
					endif;
					
					if machineName &lt;&gt; "&lt;none&gt;" then		// in case jdo was created by "Connection lost" entry
						jdo.setPropertyValue("machineName", machineName);
					endif;
					jdo.setPropertyValue("lastNetworkError", ts);

				// Is it a connection lost?
				elseif line.pos(ConnectionLost, 1) &gt; 0 then

					line.csvToStringArray(fields, ' ');

					if fields.size &lt; 14 then			// not a valid line
						continue;
					endif;
					
					date := fields[1].Date;
					
					if date &lt; StartingDate or date &gt; EndingDate then			// skip dates not interested in
						continue;
					endif;
					
					time := fields[2].Time;
					
					ts.setDate(date);
					ts.setTime(time);
					
					ipAddress := fields[8];
					ipAddress := ipAddress[2:ipAddress.length - 2];		// strip brackets
					
					machine := null;
					machineName := "&lt;none&gt;";
					
					jdo := dict2.getAtKey(ipAddress).JadeDynamicObject;
					if jdo = null then
						create jdo transient;
						jdo.addProperty("ipAddress", String);
						jdo.addProperty("computer", String);
						jdo.addProperty("machineName", String);
						jdo.addProperty("lastNetworkError", TimeStamp);
						
						jdo.setPropertyValue("ipAddress", ipAddress);
						jdo.setPropertyValue("computer", computer);
						jdo.setPropertyValue("machineName", machineName);
						
						dict2.putAtKey(ipAddress, jdo);
					endif;
					
					jdo.setPropertyValue("lastNetworkError", ts);

				// Is it a successful reconnect
				elseif line.pos(ReconnectSuccess, 1) &gt; 0 then

					line.csvToStringArray(fields, ' ');

					if fields.size &lt; 10 then			// not a valid line
						continue;
					endif;
					
					date := fields[1].Date;
					
					if date &lt; StartingDate or date &gt; EndingDate then			// skip dates not interested in
						continue;
					endif;
					
					time := fields[2].Time;
					
					ts.setDate(date);
					ts.setTime(time);
					
					ipAddress := fields[10];
					ipAddress := ipAddress[2:ipAddress.length - 2];		// strip brackets
					
					// Find the last disconnect
					jdo := dict2.getAtKey(ipAddress).JadeDynamicObject;
					
					if jdo = null then
						continue;
					endif;
					
					lastNetworkError := jdo.getPropertyValue("lastNetworkError").TimeStamp;
					jdo.setPropertyValue("lastNetworkError", null);
					
					if lastNetworkError &lt;&gt; null then
						line := (date.format('dd/MM/yyyy') &amp; ',' &amp;
								 time.format('HH:mm:ss') &amp; "." &amp; time.milliSecond.String.padLeadingZeros(3) &amp; ',' &amp;
								 jdo.getPropertyValue("computer").String &amp; ',' &amp;
								 jdo.getPropertyValue("ipAddress").String &amp; ',' &amp;
								 jdo.getPropertyValue("machineName").String &amp; ',' &amp;
								 ts.milliSecondsDiff(lastNetworkError).String &amp; ',' &amp;
								 'SUCCESS');
					
						outFile.writeLine(line);
						write line;
					endif;
					
				// Is it a failed reconnect
				elseif line.pos(ReconnectFailure, 1) &gt; 0 then

					line.csvToStringArray(fields, ' ');

					if fields.size &lt; 20 then			// not a valid line
						continue;
					endif;
					
					date := fields[1].Date;
					
					if date &lt; StartingDate or date &gt; EndingDate then			// skip dates not interested in
						continue;
					endif;
					
					time := fields[2].Time;
					
					ts.setDate(date);
					ts.setTime(time);
					
					ipAddress := fields[20];
					ipAddress := ipAddress[2:ipAddress.length - 2];		// strip brackets

					// Find the last disconnect
					jdo := dict2.getAtKey(ipAddress).JadeDynamicObject;
					
					if jdo = null then
						continue;
					endif;
					
					lastNetworkError := jdo.getPropertyValue("lastNetworkError").TimeStamp;
					jdo.setPropertyValue("lastNetworkError", null);
					
					if lastNetworkError &lt;&gt; null then
						line := (date.format('dd/MM/yyyy') &amp; ',' &amp;
								 time.format('HH:mm:ss') &amp; "." &amp; time.milliSecond.String.padLeadingZeros(3) &amp; ',' &amp;
								 jdo.getPropertyValue("computer").String &amp; ',' &amp;
								 jdo.getPropertyValue("ipAddress").String &amp; ',' &amp;
								 jdo.getPropertyValue("machineName").String &amp; ',' &amp;
								 ts.milliSecondsDiff(lastNetworkError).String &amp; ',' &amp;
								 'FAIL');
								 
						outFile.writeLine(line);
						write line;
					endif;
					
				endif;
			
			endwhile;
		endif;
	endforeach;
	
	outFile.close();
	
	write "Finished";
		
epilog
	delete ff;
	delete dict;
	if dict2 &lt;&gt; null then
		dict2.purge();
		delete dict2;
	endif;
	delete fields;
	delete iter;
	delete outFile;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdAnalyseLockTable" id="7dbcb339-6cc8-4467-89f8-c24249903f2e">
        <source>kpdAnalyseLockTable();

/*

Purpose:			Perform a quick analysis of the Lock Table to see how many of each type there
					are in the system

Parameters:			

Return Value:		


Date		Who		Reason
12 April 2010	cnwkpd1	PAR #23525 - System performance enhancements

*/

constants
	MaxLocks		= 100000;
		
vars
	locks			: LockArray;
	aLock			: Lock;
	lockCounts		: IntegerArray;
	dict			: DynaDictionary;
	type,
	duration,
	kind			: String;
	iter			: Iterator;
	count			: Integer;
	
begin
	create locks transient;
	system.getLocks(locks, MaxLocks);
	
	if locks.size = MaxLocks then
		app.msgBox("More than " &amp; MaxLocks.String &amp; " locks", "Error", MsgBox_OK_Only);
		return;
	endif;
	
	create dict transient;
	dict.setMembership(IntegerArray);
	dict.addExternalKey(String, 30, false, true);
	dict.addExternalKey(String, 30, false, true);
	dict.addExternalKey(String, 30, false, true);
	dict.endKeys(false);
	
	foreach aLock in locks do
		if aLock.type.Integer = Share_Lock then
			type := "Shared lock";
		elseif aLock.type.Integer = Exclusive_Lock then
			type := "Exclusive lock";
		elseif aLock.type.Integer = Reserve_Lock then
			type := "Reserve lock";
		elseif aLock.type.Integer = Update_Lock then
			type := "Update lock";
		else
			type := "Unknown";
		endif;

		if aLock.kind = Lock.Kind_Node then
			kind := "Node";
		elseif aLock.kind = Lock.Kind_Normal then
			kind := "Normal";
		elseif aLock.kind = Lock.Kind_Local then
			kind := "Local";
		else
			kind := "Unknown";
		endif;
		
		if aLock.duration.Integer = Transaction_Duration then
			duration := "Transaction";
		elseif aLock.duration.Integer = Session_Duration then
			duration := "Session";
		else
			duration := "Unknown";
		endif;
		
		lockCounts := dict[type, duration, kind].IntegerArray;
		if lockCounts = null then
			create lockCounts transient;
			lockCounts[1] := 1;
			dict.putAtKey(type, duration, kind, lockCounts);
		else
			lockCounts[1] := lockCounts[1] + 1;
		endif;
		
		count := count + 1;

	endforeach;
	
	write "Finished, total locks analysed = " &amp; count.String;
	
	iter := dict.createIterator();
	while iter.next(lockCounts) do
		dict.getIteratorKeys(type, duration, kind, iter);
		
		write type &amp; Tab &amp; duration &amp; Tab &amp; kind &amp; Tab &amp; lockCounts[1].String;
	endwhile;
	
	
epilog
	delete iter;
	
	if locks &lt;&gt; null then
		locks.purge();
		delete locks;
	endif;
	
	if dict &lt;&gt; null then
		dict.purge();
		delete dict;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdAnalyzeDumps" id="3d3befee-a1af-4e3b-9823-237a7ac2d19f">
        <source>kpdAnalyzeDumps();

/*

Purpose:			Analyze cn_dump files


Return Value:		None


Date		Who		Reason
01 Aug 2008	cnwkpd1	JMT Support

*/

constants
	Exception_String = "Exception";
	Receiver_String	= "     Receiver:";
	CallStack_String = "Call Stack History:";
	Occurred_String	= "Exception occurred at";
	
vars
	fn				: FileNode;
	f				: File;
	ff				: FileFolder;
	line			: String;
	
	analysisFile	: File;
	
	errorCode,
	timeStamp,
	receiver,
	stack1,
	stack2,
	stack3,
	outputLine		: String;
	
	foundCallStack,
	foundReceiver,
	foundException	: Boolean;

	pos,
	occLen,
	callLen,
	recLen,
	excLen			: Integer;
	
begin
	create ff transient;
	ff.fileName := "c:\temp\C3_Dumps";
	ff.mask := "cn_dump_*.log";
	
	create analysisFile transient;
	analysisFile.openOutput(ff.fileName &amp; "\analysis.txt");
	
	analysisFile.writeLine("Error Code" &amp; Tab &amp;
						   "Date" &amp; Tab &amp;
						   "Time" &amp; Tab &amp;
						   "Receiver" &amp; Tab &amp;
						   "Call Stack 1" &amp; Tab &amp;
						   "Call Stack 2" &amp; Tab &amp;
						   "Call Stack 3" &amp; Tab &amp;
						   "Dump File Name");
	
	callLen := CallStack_String.length;
	recLen := Receiver_String.length;
	excLen := Exception_String.length;
	occLen := Occurred_String.length;
	
	foreach fn in ff.files do
	
		if not fn.isKindOf(File) then
			continue;
		endif;
		
		f := fn.File;
		f.kind := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
		f.mode := File.Mode_Input;
		f.open;
		
		app.writeStatement( "Processing file " &amp; f.fileName);

		errorCode := null;
		timeStamp := null;
		receiver := null;
		stack1 := null;
		stack2 := null;
		stack3 := null;
		
		foundException := false;
		foundReceiver := false;
		foundCallStack := false;
		
		while not f.endOfFile do

			line := f.readLine;
			if line.length &lt; 1 then
				continue;
			endif;
			
			// Keep reading until we find the first line starting with "Exception"
			if not foundException then
				if line.length &lt; excLen then
					continue;
				endif;
				if line[1:excLen] = Exception_String then
					foundException := true;
					pos := excLen + 2;
					errorCode := line.scanUntil(" ", pos);
					
					// Get next line for timestamp
					line := f.readLine;
					timeStamp := line[occLen + 2:line.pos("(", 1) - occLen - 4];
				endif;
				continue;
			endif;
			
			// Then read until Receiver
			if not foundReceiver then
				if line.length &lt; recLen then
					continue;
				endif;
				if line[1:recLen] = Receiver_String then
					foundReceiver := true;
					receiver := line[recLen + 2:end];
				endif;
				continue;
			endif;
			
			// Then read through to call stack
			if not foundCallStack then
				if line.length &lt; callLen then
					continue;
				endif;
				if line[1:callLen] = CallStack_String then
					foundCallStack := true;
				endif;
				continue;
			endif;

			// Then just read the 2 top stack lines
			if line.pos("++ Source line:", 1) &gt; 0 then
				continue;
			endif;
			
			if stack1 = null then
				stack1 := line.trimBlanks;
				continue;
			elseif stack2 = null then
				stack2 := line.trimBlanks;
				continue;
			else
				stack3 := line.trimBlanks;
				break;
			endif;
		endwhile;
		
		outputLine := errorCode &amp; Tab &amp;
					  timeStamp.TimeStamp.date.String &amp; Tab &amp;
					  timeStamp.TimeStamp.time.String &amp; Tab &amp;
					  receiver &amp; Tab &amp;
					  stack1 &amp; Tab &amp;
					  stack2 &amp; Tab &amp;
					  stack3;
		
		app.writeStatement( outputLine);
			  
		analysisFile.writeLine(outputLine &amp; Tab &amp; f.name);
		
		app.writeStatement( "File " &amp; f.fileName &amp; " processed" &amp; CrLf);
		
	endforeach;

	
epilog
	delete ff;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdCheckAndDeleteRootdef" id="00855ed4-3cac-451f-b547-2fa58a39d509">
        <source>kpdCheckAndDeleteRootdef();
/* cnwkpd1

Purpose:			Check all RootSchema class instances stored in the _rootdef map file and ensure they are
					all still connected to JMT objects in some way
					
Parameters:			

Return Value:		

Date		Who		Reason
24 Jan 2014	cnwkpd1	PAR #33353 - tidy up creation of RootSchema classes
27 Nov 2014	cnwkpd1	PAR #35261 - Changes to prepare for JADE 7.1

*/

vars
	classesToCheck	: StringArray;
	clsName			: String;
	
	props			: ObjectArray;
	property		: Property;
	propIter		: Iterator;
	cls				: Class;
	
	oa				: ObjectArray;
	allObjects		: ObjectSet;
	iter			: Iterator;
	obj,
	refObj,
	firstObj,
	lastObj			: Object;
	count			: Integer;
	
	lg				: CM_LayoutGraphic;

begin
	app.initialize();
	
	// Set up the list of RootSchema classes that need to be checked
	create classesToCheck transient;
//	classesToCheck.add(StringArray.name);
//	classesToCheck.add(IntegerArray.name);
//	classesToCheck.add(PointArray.name);
//	classesToCheck.add(HugeStringArray.name);
//	classesToCheck.add(DynaDictionary.name);
	classesToCheck.add(JadeDynamicObject.name);
	
	// Get all the instances of all these classes
	create allObjects transient;
	create oa transient;
	iter := oa.createIterator();
	
	foreach clsName in classesToCheck do
		oa.clear();
		rootSchema.getClass(clsName).allInstances(oa, 0, false);
		
		app.writeLog(oa.size.String &amp; ' instances of ' &amp; clsName &amp; ' found', LogINFO);
		
		oa.copy(allObjects);
	endforeach;
	
	app.writeLog(allObjects.size.String &amp; ' instances of all selected classes found', LogINFO);
	
	// Search all properties for non-exclusive references of any of the selected classes
	create props transient;
	Property.allInstances(props, 0, true);
	
	app.writeLog('Processing ' &amp; props.size.String &amp; ' properties', LogINFO);
	
	propIter := props.createIterator();
	while propIter.next(property) do
	
		if property.subId.Integer = null  and classesToCheck.includes(property.type.name) then
			cls := property.schemaType.Class;
			
			app.writeLog('Found non-attribute property ' &amp; 
				   property.schemaType.schema.name &amp; '::' &amp;
				   property.schemaType.name &amp; '::' &amp;
				   property.name &amp;
				   ' (' &amp; property.type.name &amp; ')', LogINFO);
			
			oa.clear();
			
			cls.allInstances(oa, 0, true);
	
			app.writeLog(oa.size.String &amp; ' instances of ' &amp; cls.name &amp; ' found', LogINFO);
	
			iter.reset();
	
			while iter.next(obj) do
				
				refObj := obj.getPropertyValue(property.name).Object;
				if refObj &lt;&gt; null then
					if allObjects.includes(refObj) then
						allObjects.remove(refObj);
					else
						app.writeLog('&gt;&gt;&gt;&gt; ' &amp; obj.String &amp; ' has invalid ' &amp; property.name &amp; ' (' &amp; refObj.String &amp; ')', LogINFO);
					endif;
				endif;
				
			endwhile;
			
		endif;
		
	endwhile;
	
	// And if PointArray is being checked, then also check the CM_LayoutGraphic::allLocationPointPolygons collections
	if classesToCheck.includes(PointArray.name) then
		oa.clear();
		CM_LayoutGraphic.allInstances(oa, 0, true);
		
		app.writeLog(oa.size.String &amp; ' instances of ' &amp; CM_LayoutGraphic.name &amp; ' found', LogINFO);
		
		iter.reset();
		while iter.next(lg) do
			foreach obj in lg.allLocationPointPolygons do
				if allObjects.includes(obj) then
					allObjects.remove(obj);
				else
					app.writeLog('&gt;&gt;&gt;&gt; ' &amp; lg.String &amp; ' has invalid object (' &amp; obj.String &amp; ') in allLocationPointPolygons', LogINFO);
				endif;		
			endforeach;
		endwhile;
	endif;
		
	
	app.writeLog(allObjects.size.String &amp; ' instances of all selected classes not associated', LogINFO);
	
	// Find first and last unassociated instance of each class
	firstObj := allObjects.first();
	lastObj := null;
	count := 0;
	
	foreach obj in allObjects do
		if lastObj &lt;&gt; null and self.getClassForObject(obj).name &lt;&gt; lastObj.class.name then
			app.writeLog(count.String &amp; ' instances of ' &amp; lastObj.class.name &amp; ' not associated', LogINFO);
			app.writeLog('First ' &amp; firstObj.String &amp; ' created ' &amp; firstObj.creationTime.String, LogINFO);
			app.writeLog('Last ' &amp; lastObj.String &amp; ' created ' &amp; lastObj.creationTime.String, LogINFO);
			firstObj := obj;
			count := 0;
		endif;
		
		lastObj := obj;
		count := count + 1;
	endforeach;
	
	if firstObj &lt;&gt; null and lastObj &lt;&gt; null then
		app.writeLog(count.String &amp; ' instances of ' &amp; lastObj.class.name &amp; ' not associated', LogINFO);
		app.writeLog('First ' &amp; firstObj.String &amp; ' created ' &amp; firstObj.creationTime.String, LogINFO);
		app.writeLog('Last ' &amp; lastObj.String &amp; ' created ' &amp; lastObj.creationTime.String, LogINFO);
	endif;
	
	allObjects.inspectModal();

	//beginTransaction;
	//allObjects.purge();
	//commitTransaction;
	
	
epilog
	delete allObjects;
	delete iter;
	delete oa;
	delete props;
	delete propIter;
	delete classesToCheck;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdCheckDbFileFreeSpace" id="058b6693-293e-4e2e-b012-6039ea7bee8c">
        <source>kpdCheckDbFileFreeSpace();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Aug 2017	jlgkpd1	Initial creation

*/
	
vars
	dbFile				: DbFile;
	free				: Decimal[20];
	mapFileNames		: StringArray;
	logFile				: File;
	logFileName			: String;
	
begin
	create mapFileNames transient;
	mapFileNames.add("audit");
	mapFileNames.add("edi");
	mapFileNames.add("information");
	mapFileNames.add("externdb");
	mapFileNames.add("infoEDISent");

	logFileName := app.dbPath;
	logFileName := logFileName[4:end];		// get rid of drive stuff
	logFileName := logFileName[1:logFileName.pos("\", 1) - 1];

	create logFile transient;
	logFile.openOutput("c:\temp\" &amp; logFileName &amp; "_free_space.txt");
	
	write "Checking free space for map files " &amp; mapFileNames.concatenate(" ");

	foreach dbFile in DbFile.instances where mapFileNames.isEmpty or mapFileNames.includes(dbFile.name) do
		write "Processing file " &amp; dbFile.name;
		
		dbFile.changeAccessMode(DbFile.Mode_ReadOnly);
        dbFile.getFreeSpace(free);
        dbFile.changeAccessMode(DbFile.Mode_Update);
		
		logFile.writeLine(dbFile.name &amp; Tab &amp; free.String);
	endforeach;
	
	write "Finished";
	
	
epilog
	delete mapFileNames;
	delete logFile;
		
end;

</source>
    </JadeMethod>
    <JadeMethod name="kpdCheckDynaDictExHandler" id="31440f29-be71-4a50-9717-cb5076236336">
        <source>kpdCheckDynaDictExHandler(_exc : Exception;
						  _dict : DynaDictionary;
						  _invalid : Boolean io) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 July 2013	cnwkpd1	PAR #30400 - SFW 1290 - Transaction EDI file type

*/

vars

begin
	write "&gt;&gt;&gt; " &amp; _exc.errorCode.String &amp; " errorObject=" &amp; _exc.errorObject.String &amp; " _dict=" &amp; _dict.String;
	
	_invalid := true;
	
	return Ex_Resume_Next;
	
epilog

end;</source>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_dict" type="DynaDictionary"/>
        <Parameter name="_invalid" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="kpdCheckDynaDicts" id="9a8b0265-65b7-438a-b38c-b206c49a74f6">
        <source>kpdCheckDynaDicts();
/*

Purpose:			Check DynaDictionary instances for errors for JADE PAR #60052

Parameters:			

Return Value:		

Date		Who		Reason
31 Jul 2013	cnwkpd1	JADE PAR #60052

*/

vars
	dict			: DynaDictionary;
	obj				: Object;
	s				: String;
	count,
	bad				: Integer;
	badDicts		: ObjectArray;
	invalid			: Boolean;
	
begin
	on Exception do self.kpdCheckDynaDictExHandler(exception, dict, invalid);
	
	create badDicts transient;

	foreach dict in DynaDictionary.instances do
		
		count := null;
		bad := null;
		invalid := false;
		
		foreach obj in dict do
			
			count := count + 1;
			if not app.isValidObject(obj) then
				bad := bad + 1;
			endif;
			
		endforeach;
		
		if invalid or bad &gt; 0 or count &lt;&gt; dict.size() then
			write dict.String &amp; ", size=" &amp; dict.size().String &amp; ", count=" &amp; count.String &amp; ", bad=" &amp; bad.String;
			badDicts.add(dict);
		else			
			write dict.String &amp; ", size=" &amp; dict.size().String &amp; ", count=" &amp; count.String &amp; ", bad=" &amp; bad.String;
		endif;
		
	endforeach;
	
	badDicts.inspectModal();
	
epilog
	delete badDicts;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdCheckEntTableDefs" id="3bd8bed6-c7da-4046-ad00-a8f650c56611">
        <source>kpdCheckEntTableDefs();

/*

Purpose:			Check all the EntTableRowHeaders, looking for any where there are multiple EntTableRow 
					objects with different maximium lengths


Return Value:		None


Date		Who		Reason
07 May 2008	cnwkpd1	PAR #16691 - String too long from EntTableDef maintenance forms

*/

vars
	etrh			: EntTableRowHeader;
	etr				: EntTableRow;
	etcc			: EntTableCellControl;
	firstOne,
	hasMax			: Boolean;
	maxLen,
	len				: Integer;
	
begin
	foreach etrh in EntTableRowHeader.instances do
		firstOne := true;
		hasMax := false;
		maxLen := 0;

		foreach etr in etrh.allEntTableRows where etr.controlName = null do
			len := kpdCheckEntTableDefsGetMax(etr);
			
			if len = 0 then
				if hasMax then
					app.writeStatement( "&gt;&gt;&gt;&gt; " &amp; etrh.String &amp; " " &amp; etr.String &amp; " no max, but previous ones did");
				endif;
			else
				if not firstOne then
					if not hasMax then
						app.writeStatement( "&gt;&gt;&gt;&gt; " &amp; etrh.String &amp; " " &amp; etr.String &amp; " has max, but previous ones did not");
					else
						if len &lt;&gt; maxLen then
							app.writeStatement( "&gt;&gt;&gt;&gt; " &amp; etrh.String &amp; " " &amp; etr.String &amp; " has different max from previous");
						endif;
					endif;
					
				endif;
				
				hasMax := true;
				maxLen := len;
			endif;
				
			firstOne := false;
		endforeach;
		
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="kpdCheckEntTableDefsGetMax" id="6419a108-4e38-4278-93d6-b96729d453f7">
        <source>kpdCheckEntTableDefsGetMax(_etr : EntTableRow) : Integer;

/*

Purpose:			


Return Value:		


Date		Who		Reason
07 May 2008	cnwkpd1	PAR #16691 - String too long from EntTableDef maintenance forms

*/

vars

begin
	if _etr.myEntTableCellControl = null then
		return 0;
	endif;
	
	return _etr.myEntTableCellControl.getPropertyValue(EntTableTextBox::maxLength.name).Integer;
	

epilog

end;</source>
        <Parameter name="_etr" type="EntTableRow"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="kpdCheckGlobalVoyageColls" id="c77799cf-9738-4407-838c-94b021b7db33">
        <source>kpdCheckGlobalVoyageColls();

/*

Purpose:			


Return Value:		


Date		Who		Reason
10 Apr 2008	cnwkpd1	PAR #16378 - Initial creation

*/

vars
	globalVoyage	: CM_VoyageGlobal;
	voyage			: CM_Voyage;
	keyArrivalDT	: TimeStamp;
	keyTerminal		: CM_Terminal;
	iter			: Iterator;
	checked,
	errors			: Integer;
	invalidVoyage	: Boolean;
	
begin
	on Exception do app.handleDeletedObject(exception, voyage, invalidVoyage);
	
	foreach globalVoyage in CM_VoyageGlobal.instances do
	
		// Check dictionary keys on allVoyages manual collection
		delete iter;
		iter := globalVoyage.allVoyages.createIterator;
		while iter.next(voyage) do
			checked := checked + 1;
			globalVoyage.allVoyages.getIteratorKeys(keyArrivalDT, keyTerminal, iter);

			invalidVoyage := false;
			
			if voyage.arrivedDT &lt;&gt; keyArrivalDT or voyage.myTerminal &lt;&gt; keyTerminal then
				errors := errors + 1;
				
				if voyage.arrivedDT &lt;&gt; keyArrivalDT then
					write "&gt;&gt;&gt;&gt;" &amp; Tab &amp; globalVoyage.String &amp; 
								   Tab &amp; voyage.String &amp; 
								   Tab &amp; "arrivedDT=" &amp; voyage.arrivedDT.String &amp;
								   Tab &amp; "key=" &amp; keyArrivalDT.String;
				endif;
				
				if voyage.myTerminal &lt;&gt; keyTerminal then
					app.writeStatement( "&gt;&gt;&gt;&gt;" &amp; Tab &amp; globalVoyage.String &amp; 
								   Tab &amp; voyage.String &amp; 
								   Tab &amp; "myTerminal=" &amp; voyage.myTerminal.String &amp;
								   Tab &amp; "key=" &amp; keyTerminal.String);
				endif;
			endif;
			
			if invalidVoyage then
				errors := errors + 1;
				app.writeStatement( "&gt;&gt;&gt;&gt;" &amp; Tab &amp; globalVoyage.String &amp; 
							   Tab &amp; voyage.String &amp; 
							   Tab &amp; "keyArrivalDT=" &amp; keyArrivalDT.String &amp;
							   Tab &amp; "keyTerminal=" &amp; keyTerminal.String &amp;
							   Tab &amp; "invalid CM_Voyage");
			endif;

		endwhile;
		
		// Now check that all the required voyages (from the inversed collections) are in the
		// manual collection
		foreach voyage in globalVoyage.allVoyagesArriving do
			if not globalVoyage.allVoyages.includesObject(voyage) then
				app.writeStatement( "&gt;&gt;&gt;&gt;" &amp; Tab &amp; globalVoyage.String &amp; 
							   Tab &amp; voyage.String &amp; 
							   Tab &amp; "is in allVoyagesArriving, but not allVoyages");
			endif;
		endforeach;

		foreach voyage in globalVoyage.allVoyagesDeparting where not globalVoyage.allVoyagesArriving.includes(voyage) do
			if not globalVoyage.allVoyages.includesObject(voyage) then
				app.writeStatement( "&gt;&gt;&gt;&gt;" &amp; Tab &amp; globalVoyage.String &amp; 
							   Tab &amp; voyage.String &amp; 
							   Tab &amp; "is in allVoyagesDeparting, but not allVoyages");
			endif;
		endforeach;
		
	endforeach;

	app.writeStatement( checked.String &amp; " dictionary entries checked, " &amp; errors.String &amp; " errors found");
	
			
epilog
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdCheckGridAreas" id="f7670d1a-280b-43ee-84ba-fd5fee86e4fc">
        <source>kpdCheckGridAreas();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 March 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift

*/

vars
	areas			: ObjectArray;
	area			: CM_GridArea;
	iter			: Iterator;
	gridCont		: CM_GridController;
	
begin
	create areas transient;
	CM_GridArea.allInstances(areas, 0, true);
	iter := areas.createIterator;
	
	while iter.next(area) do
		write area.String &amp; " " &amp; area.id &amp; 
				" rows=" &amp; area.numberOfRows.String &amp; 
				" columns=" &amp; area.numberOfColumns.String &amp; 
				" height=" &amp; area.heightOfStack.String;
				
		if area.allGridControllersByRowColumn.size &lt;&gt; area.numberOfRows * area.numberOfColumns then
			write "&gt;&gt;&gt;&gt; incorrect number of grid controllers (" &amp; area.allGridControllersByRowColumn.size.String &amp; " " &amp; area.id;
		endif;
		continue;
		foreach gridCont in area.allGridControllersByRowColumn do
			if gridCont.row &gt; area.numberOfRows then
				write "&gt;&gt;&gt;&gt; Row out of bounds " &amp; gridCont.getName;
			endif;
			if gridCont.column &gt; area.numberOfColumns then
				write "&gt;&gt;&gt;&gt; Column out of bounds " &amp; gridCont.getName;
			endif;
		endforeach;
	endwhile;
	
			
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="kpdCheckInvoiceReportTemplates" id="a9346868-0c50-45fa-b6cf-eedf25030749">
        <source>kpdCheckInvoiceReportTemplates();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2015	cnwkpd1	PAR #36903 - Templated invoice reports not working correctly

*/

vars
	ci				: CMQF_Invoice;
	oa				: ObjectArray;
	iter			: Iterator;
	firstBank		: CM_Bank;
	firstTerminal	: CM_Terminal;
	msg				: String;
	templates,
	badCount		: Integer;
	
begin
	create oa transient;
	CMQF_Invoice.allInstances(oa, 0, true);
	
	iter := oa.createIterator();
	while iter.next(ci) do
		if ci.myBGPRequest &lt;&gt; null and ci.myBGPRequest.myReportTemplate &lt;&gt; null then
		
			templates := templates + 1;
			
			firstBank := ci.allCompaniesByCode.first();
			firstTerminal := ci.allTerminals.first();
			
			msg := "No company";
			if app.isValidObject(firstBank) then
				if firstBank.terminal = firstTerminal then
					msg := "Company matches first Terminal";
				else
					msg := "&gt;&gt;&gt;&gt; Company does not match first Terminal";
					badCount := badCount + 1;
				endif;
			endif;
			
			write ci.myBGPRequest.myReportTemplate.name &amp; Tab &amp; 
				ci.allCompaniesByCode.size().String &amp; Tab &amp;
				firstBank.String &amp; Tab &amp;
				ci.allTerminals.size().String &amp; Tab &amp;
				firstTerminal.String &amp; Tab &amp;
				msg;
		endif;	
	endwhile;
	
	write templates.String &amp; " templates checked, " &amp; badCount.String &amp; " errors found";
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="kpdCheckLocksForObject" id="cd23f9e0-4206-4529-aed5-bf4215646767">
        <source>kpdCheckLocksForObject();
/*

Purpose:			Find any locks for a given object, and dump out the details

Date		Who		Reason
02 Mar 2012	cnwkpd1	PAR #29165 - CCMS SFW 1272 - Reduce physical database size

*/

constants
	MaxLocks		= 100000;
		
vars
	locks			: LockArray;
	aLock			: Lock;
	lockCounts		: IntegerArray;
	dict			: DynaDictionary;
	type,
	duration,
	kind			: String;
	iter			: Iterator;
	count			: Integer;
	targetObj		: Object;
	
begin
	// Set up your target object here
	targetObj := CM_Root.firstInstance().allTerminals["T01"].allVoyagesByCode;

	create locks transient;
	system.getLocks(locks, MaxLocks);
	
	foreach aLock in locks do
		if aLock.type.Integer = Share_Lock then
			type := "Shared lock";
		elseif aLock.type.Integer = Exclusive_Lock then
			type := "Exclusive lock";
		elseif aLock.type.Integer = Reserve_Lock then
			type := "Reserve lock";
		elseif aLock.type.Integer = Update_Lock then
			type := "Update lock";
		else
			type := "Unknown";
		endif;

		if aLock.kind = Lock.Kind_Node then
			kind := "Node";
		elseif aLock.kind = Lock.Kind_Normal then
			kind := "Normal";
		elseif aLock.kind = Lock.Kind_Local then
			kind := "Local";
		else
			kind := "Unknown";
		endif;
		
		if aLock.duration.Integer = Transaction_Duration then
			duration := "Transaction";
		elseif aLock.duration.Integer = Session_Duration then
			duration := "Session";
		else
			duration := "Unknown";
		endif;
		
		lockCounts := dict[type, duration, kind].IntegerArray;
		if lockCounts = null then
			create lockCounts transient;
			lockCounts[1] := 1;
			dict.putAtKey(type, duration, kind, lockCounts);
		else
			lockCounts[1] := lockCounts[1] + 1;
		endif;
		
		count := count + 1;

	endforeach;
	
	write "Finished, total locks analysed = " &amp; count.String;
	
	iter := dict.createIterator();
	while iter.next(lockCounts) do
		dict.getIteratorKeys(type, duration, kind, iter);
		
		write type &amp; Tab &amp; duration &amp; Tab &amp; kind &amp; Tab &amp; lockCounts[1].String;
	endwhile;
	
	
epilog
	delete iter;
	
	if locks &lt;&gt; null then
		locks.purge();
		delete locks;
	endif;
	
	if dict &lt;&gt; null then
		dict.purge();
		delete dict;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdCheckPointArrays" id="73bb71d2-fcf8-4d73-b9c2-d437fd8506da">
        <source>kpdCheckPointArrays();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Jan 2014	cnwkpd1	PAR #33353 - tidy up creation of RootSchema classes
27 Nov 2014	cnwkpd1	PAR #35261 - Changes to prepare for JADE 7.1

*/

vars
	props			: ObjectArray;
	property		: Property;
	propIter		: Iterator;
	cls				: Class;
	
	oa				: ObjectArray;
	allArrays		: ObjectSet;
	iter			: Iterator;
	obj				: Object;
	arr				: PointArray;
	
	lg				: CM_LayoutGraphic;
	
	startDelete		: Decimal[20];
	deleteCount		: Integer;
	
begin
	// Get all the unconnected StringArray instances
	create oa transient;
	iter := oa.createIterator();
	PointArray.allInstances(oa, 0, false);
	
	write oa.size.String &amp; ' instances of PointArray found';
	
	create allArrays transient;
	oa.copy(allArrays);
	oa.clear();
	
	// Search all properties for non-exclusive StringArray references
	create props transient;
	Property.allInstances(props, 0, true);
	
	write 'Processing ' &amp; props.size.String &amp; ' properties';
	
	propIter := props.createIterator();
	while propIter.next(property) do
	
		if property.type.name = PointArray.name and property.subId.Integer = null then
			cls := property.schemaType.Class;
			
			write 'Found non-attribute PointArray ' &amp; 
				   property.schemaType.schema.name &amp; '::' &amp;
				   property.schemaType.name &amp; '::' &amp;
				   property.name;
			
			oa.clear();
			
			cls.allInstances(oa, 0, true);
	
			write oa.size.String &amp; ' instances of ' &amp; cls.name &amp; ' found';
	
			iter.reset();
	
			while iter.next(obj) do
				
				arr := obj.getPropertyValue(property.name).PointArray;
				if arr &lt;&gt; null then
					if allArrays.includes(arr) then
						allArrays.remove(arr);
					else
						write '&gt;&gt;&gt;&gt; ' &amp; obj.String &amp; ' has invalid ' &amp; property.name &amp; arr.String;
					endif;
				endif;
				
			endwhile;
			
		endif;
		
	endwhile;
	
	// And also check the CM_LayoutGraphic::allLocationPointPolygons collections
	oa.clear();
	CM_LayoutGraphic.allInstances(oa, 0, true);
	
	write oa.size.String &amp; ' instances of ' &amp; CM_LayoutGraphic.name &amp; ' found';
	
	iter.reset();
	while iter.next(lg) do
		foreach obj in lg.allLocationPointPolygons do
			if allArrays.includes(obj) then
				allArrays.remove(obj);
			else
				write '&gt;&gt;&gt;&gt; ' &amp; lg.String &amp; ' has invalid object (' &amp; obj.String &amp; ') in allLocationPointPolygons';
			endif;		
		endforeach;
	endwhile;
	
	
	write allArrays.size.String &amp; ' instances of PointArray not associated';
	
	if not allArrays.isEmpty then
		write 'First ' &amp; allArrays.first.String &amp; ' created ' &amp; allArrays.first.creationTime.String;
		write 'Last ' &amp; allArrays.last.String &amp; ' created ' &amp; allArrays.last.creationTime.String;
	endif;
	
	// Now delete as many of the objects as possible in the allowed time
	startDelete := app.relativeMachineTime();
	
	beginTransaction;
	foreach obj in allArrays do
		delete obj;
		deleteCount := deleteCount + 1;
		
		if deleteCount mod 10000 = 0 then
			
			write deleteCount.String &amp; ' instances deleted';
			
			commitTransaction;
			beginTransaction;
		
		endif;
	endforeach;
	commitTransaction;

	
epilog
	delete allArrays;
	delete iter;
	delete oa;
	delete props;
	delete propIter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdCheckRootdefIInstances" id="94f495d5-a7cd-4f8e-b53b-18c03a1b0706">
        <source>kpdCheckRootdefIInstances();
/*

Purpose:			Check all RootSchema class instances stored in the _rootdef map file and ensure they are
					all still connected to JMT objects in some way
					
Parameters:			

Return Value:		

Date		Who		Reason
21 Jan 2014	cnwkpd1	Tidy up development environment map files
27 Nov 2014	cnwkpd1	PAR #35261 - Changes to prepare for JADE 7.1

*/

vars
	classesToCheck	: StringArray;
	clsName			: String;
	
	props			: ObjectArray;
	property		: Property;
	propIter		: Iterator;
	cls				: Class;
	
	oa				: ObjectArray;
	allObjects		: ObjectSet;
	iter			: Iterator;
	obj,
	refObj,
	firstObj,
	lastObj			: Object;
	count			: Integer;
	
	lg				: CM_LayoutGraphic;

	startDelete		: Decimal[20];
	deleteCount		: Integer;
	
begin
	// Set up the list of RootSchema classes that need to be checked
	create classesToCheck transient;
	classesToCheck.add(StringArray.name);
	classesToCheck.add(IntegerArray.name);
	classesToCheck.add(PointArray.name);
	classesToCheck.add(HugeStringArray.name);
	classesToCheck.add(DynaDictionary.name);
	classesToCheck.add(JadeDynamicObject.name);
	
	// Get all the instances of all these classes
	create allObjects transient;
	create oa transient;
	iter := oa.createIterator();
	
	foreach clsName in classesToCheck do
		oa.clear();
		rootSchema.getClass(clsName).allInstances(oa, 0, false);
		
		write oa.size.String &amp; ' instances of ' &amp; clsName &amp; ' found';
		
		oa.copy(allObjects);
	endforeach;
	
	write allObjects.size.String &amp; ' instances of all selected classes found';
	
	// Search all properties for non-exclusive references of any of the selected classes
	create props transient;
	Property.allInstances(props, 0, true);
	
	write 'Processing ' &amp; props.size.String &amp; ' properties';
	
	propIter := props.createIterator();
	while propIter.next(property) do
	
		if property.subId.Integer = null  and classesToCheck.includes(property.type.name) then
			cls := property.schemaType.Class;
			
			write 'Found non-attribute property ' &amp; 
				   property.schemaType.schema.name &amp; '::' &amp;
				   property.schemaType.name &amp; '::' &amp;
				   property.name &amp;
				   ' (' &amp; property.type.name &amp; ')';
			
			oa.clear();
			
			cls.allInstances(oa, 0, true);
	
			write oa.size.String &amp; ' instances of ' &amp; cls.name &amp; ' found';
	
			iter.reset();
	
			while iter.next(obj) do
				
				refObj := obj.getPropertyValue(property.name).Object;
				if refObj &lt;&gt; null then
					if allObjects.includes(refObj) then
						allObjects.remove(refObj);
					else
						write '&gt;&gt;&gt;&gt; ' &amp; obj.String &amp; ' has invalid ' &amp; property.name &amp; ' (' &amp; refObj.String &amp; ')';
					endif;
				endif;
				
			endwhile;
			
		endif;
		
	endwhile;
	
	// And if PointArray is being checked, then also check the CM_LayoutGraphic::allLocationPointPolygons collections
	if classesToCheck.includes(PointArray.name) then
		oa.clear();
		CM_LayoutGraphic.allInstances(oa, 0, true);
		
		write oa.size.String &amp; ' instances of ' &amp; CM_LayoutGraphic.name &amp; ' found';
		
		iter.reset();
		while iter.next(lg) do
			foreach obj in lg.allLocationPointPolygons do
				if allObjects.includes(obj) then
					allObjects.remove(obj);
				else
					write '&gt;&gt;&gt;&gt; ' &amp; lg.String &amp; ' has invalid object (' &amp; obj.String &amp; ') in allLocationPointPolygons';
				endif;		
			endforeach;
		endwhile;
	endif;
		
	
	write allObjects.size.String &amp; ' instances of all selected classes not associated';
	
	// Find first and last unassociated instance of each class
	firstObj := allObjects.first();
	lastObj := null;
	count := 0;
	
	foreach obj in allObjects do
		if lastObj &lt;&gt; null and self.getClassForObject(obj).name &lt;&gt; lastObj.class.name then
			write count.String &amp; ' instances of ' &amp; lastObj.class.name &amp; ' not associated';
			write 'First ' &amp; firstObj.String &amp; ' created ' &amp; firstObj.creationTime.String;
			write 'Last ' &amp; lastObj.String &amp; ' created ' &amp; lastObj.creationTime.String;
			firstObj := obj;
			count := 0;
		endif;
		
		lastObj := obj;
		count := count + 1;
	endforeach;
	
	if firstObj &lt;&gt; null and lastObj &lt;&gt; null then
		write count.String &amp; ' instances of ' &amp; lastObj.class.name &amp; ' not associated';
		write 'First ' &amp; firstObj.String &amp; ' created ' &amp; firstObj.creationTime.String;
		write 'Last ' &amp; lastObj.String &amp; ' created ' &amp; lastObj.creationTime.String;
	endif;
	
/*
	// Now delete as many of the objects as possible in the allowed time
	startDelete := app.relativeMachineTime();

	beginTransaction;
	foreach obj in allObjects do
		delete obj;
		deleteCount := deleteCount + 1;
		
		if deleteCount mod 10000 = 0 then
			
			write deleteCount.String &amp; ' instances deleted';
			
			commitTransaction;
			beginTransaction;
		
		endif;
	endforeach;
	commitTransaction;
*/	
	
epilog
	delete allObjects;
	delete iter;
	delete oa;
	delete props;
	delete propIter;
	delete classesToCheck;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdCheckSealAnalysis" id="6662c412-488b-407f-a3f0-5e3c6bbb67ea">
        <source>kpdCheckSealAnalysis();
/*

Purpose:			Produce an extract file of the different Seal numbers in the database, so some
					analysis of the various combinations can be done

Parameters:			None 

Return Value:		Output file with raw data for analysis
/* Changes

Date		Name	TFS#		Description
============================================================================
05 Dec 2012	cnwkpd1	PAR #30765  
					CCMS 2238 	Multiple Seal numbers for Maersk EDI
12 May 2016	cnwns1	TFS 488  	Multi Timezone Support
29 Mar 2019 jlgka1	TFS 44020	Change StringArray to HugeStringArray.
============================================================================*/

constants
	MaxTIsToCheck	= 1000;	
vars
	term			: CM_Terminal;
	ti				: CM_TrackedItem;
	count			: Integer;
	isOtago			: Boolean;
	origSeal,
	ediSeal			: String;
	log				: File;
	customsSeals	: HugeStringArray; // jlgka1 TFS 44020
	customsST,
	operatorST,
	shipperST		: CM_SealType;
	
begin
	app.initialize();
	
	create log transient;
	log.openOutput("c:\temp\CCMS2238_raw_seals" &amp; app.actualTimeServer.getNumeralString &amp; ".log");	// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	log.writeLine("Terminal,Cargo Type,Cargo ID,Seal Type,Seal Number,Seal Prefix");

	create customsSeals transient;

	customsST := app.myRoot.getSealType(SealType_Customs);
	operatorST := app.myRoot.getSealType(SealType_Operator);
	shipperST := app.myRoot.getSealType(SealType_Shipper);
		
	foreach term in app.myRoot.allTerminals discreteLock do : terminalLoop
	
		foreach ti in term.allOnsiteTIsByCargoTypeId discreteLock do
		
			count := count + 1;
			if MaxTIsToCheck &lt;&gt; 0 and count &gt; MaxTIsToCheck then
				break terminalLoop;
			endif;
			
			if ti.operatorCode &lt;&gt; 'MSK' and ti.operatorCode &lt;&gt; 'CET' then
				continue;
			endif;

			customsSeals.clear();
				
			ti.getSealNumCustomsStringArray(customsSeals);
			
			foreach origSeal in customsSeals do
				self.kpdCheckSealWriteSeal(log, term, ti, customsST, origSeal);
			endforeach;
			
			self.kpdCheckSealWriteSeal(log, term, ti, operatorST, ti.getSealNum());
			self.kpdCheckSealWriteSeal(log, term, ti, shipperST, ti.getSealNumShipper());

		endforeach;
		
	endforeach;

	log.close();
	
epilog
	delete customsSeals;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdCheckSealNumbersEDI" id="d4134368-b03c-4cbd-8b61-b868368402c2">
        <source>kpdCheckSealNumbersEDI();
/*

Purpose:			Check through all the onsite containers in a database, to determine which (if any)
					would have their seal numbers reformatted for a Maersk COARRI EDI file.
					
					Main line code cloned from CM_CamMskCOARRIDesc

Parameters:			None

Return Value:		Output to a log file
/* Changes

Date		Name	TFS#		Description
============================================================================
04 Dec 2012	cnwkpd1	PAR #30765  CCMS 2238 - Multiple Seal numbers for Maersk EDI
12 May 2016	cnwns1	TFS 488 	Multi Timezone Support
29 Mar 2019 jlgka1	TFS 44020	Change StringArray to HugeStringArray.
============================================================================*/

constants
	MaxTIsToCheck	= 1000;
	
vars
	str 				: String;
    seal 				: String;
	pos 				: Integer;
	minLength 			: Integer;
	sealLength 			: Integer;
	prefix, 
	suffix 				: String;
	customSeals 		: HugeStringArray; // jlgka1 TFS 44020
	sealNumCustomsFirst : String;	
	term				: CM_Terminal;
	ti					: CM_TrackedItem;
	count				: Integer;
	isOtago				: Boolean;
	origSeal,
	ediSeal				: String;
	log					: File;	
begin
	app.initialize();
	
	create log transient;
	log.openOutput("c:\temp\CCMS2238_" &amp; app.actualTimeServer.getNumeralString &amp; ".log");	// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	log.writeLine("Terminal,Cargo Type,Cargo ID,Original Seal,EDI Seal");
		
	isOtago := app.myRoot.isClientPortOtago;
	
	foreach term in app.myRoot.allTerminals discreteLock do : terminalLoop
	
		foreach ti in term.allOnsiteTIsByCargoTypeId discreteLock do
		
			count := count + 1;
			if MaxTIsToCheck &lt;&gt; 0 and count &gt; MaxTIsToCheck then
				break terminalLoop;
			endif;
			
			if ti.operatorCode &lt;&gt; 'MSK' and ti.operatorCode &lt;&gt; 'CET' then
				continue;
			endif;
						
			origSeal := null;
			ediSeal := null;
			
			if isOtago then //ccms 1693 cnwrs1 May 2008 new reformatting rules 
				//15 Sep 2010	NDL	Par 25608 - change to using method 'getSealNumCustomsStringArray'
				delete customSeals;
				create customSeals transient;
				
				ti.getSealNumCustomsStringArray(customSeals);
				
				if not customSeals.isEmpty then
					seal := customSeals.first;
					
					if customSeals.size &gt; 1 then //must be 1 
						foreach str in customSeals do
							if str[1:5] = "NZMAF" or
							   str[1:5] = "NZFSA" then
								seal := str; //use first of these 
								break;
							endif;
						endforeach;
					endif;
				
				elseif ti.getSealNum &lt;&gt; null then	//15 Sep 2010	NDL	Par 25608
					seal := ti.getSealNum;	//15 Sep 2010	NDL	Par 25608
				elseif ti.getSealNumShipper &lt;&gt; null then//15 Sep 2010	NDL	Par 25608 - change from direct ref to using method 'getSealNumShipper'
					seal := ti.getSealNumShipper;//15 Sep 2010	NDL	Par 25608 - change from direct ref to using method 'getSealNumShipper'
				else
					continue;
				endif;
				
				origSeal := seal;
				
				// setup minlength 
				if seal[1:5] = 'ML-NZ' then
					minLength := 12;
				else
					minLength := 13;
				endif;
				if seal.length &gt;= minLength then
					ediSeal := seal; //longer then min so do not reformat
				else
					pos := 1;
					prefix := seal.scanUntil('0123456789', pos); //find alpha prefix
					if pos &lt; 2 then // 0 all alpha, 1 starts numeric
						ediSeal := seal; //no alpha prefix or no numeric following alpha prefix then do nothing
					else 
						sealLength := seal.length; //save current length
						suffix := seal[pos:sealLength-pos+1];
						str := prefix &amp; suffix.padZeros(minLength-prefix.length); //newseal is prefix and suffix padded with zeros
						ediSeal := str;
					endif;
				endif;
			else //ccms 1693 cnwrs1 May 2008 leave existing behaviour alone for non Port Otago
			
				//15 Sep 2010	NDL	Par 25608 - change to using method 'getSealNumCustomsFirst' or 'getSealNumCustoms'
				sealNumCustomsFirst := ti.getSealNumCustomsFirst;
				seal := sealNumCustomsFirst.cnEcPadTrailing(12, ' ');//PAR 11771 [1:12];
				if sealNumCustomsFirst.length = 0 then
				elseif
				   (sealNumCustomsFirst.length = 11 or
					sealNumCustomsFirst.length = 12) and 
					seal[1:5] = 'NZMAF' and
					seal[6:sealNumCustomsFirst.length] = seal[6:sealNumCustomsFirst.length].Integer.String then
					str := sealNumCustomsFirst;
					origSeal := sealNumCustomsFirst;
					ediSeal := str;
				else
					str := 'NZMAF' &amp; seal.stripAlpha.padZeros(8)[1:8];
					origSeal := sealNumCustomsFirst;
					ediSeal := str;
				endif;
				
			endif;
			
			if ediSeal = null then
				//15 Sep 2010	NDL	Par 25608 - change from direct ref to using method 'getSealNum'
				seal := ti.getSealNum.cnEcPadTrailing(12, ' ');//PAR 11771 [1:12];
				if ti.getSealNum.length = 0 then
				elseif
				   ti.getSealNum.length = 12 and 
					seal[1:5] = 'ML-NZ' and
					seal[6:ti.getSealNum.length] = seal[6:ti.getSealNum.length].Integer.String then
					str := ti.getSealNum;
					origSeal := str;
					ediSeal := str;
				else
					str :='ML-NZ' &amp; seal.stripAlpha.padZeros(7)[1:7];
					origSeal := ti.getSealNum;
					ediSeal := str;
				endif;
			endif;
			
			if ediSeal = null then
				//15 Sep 2010	NDL	Par 25608 - change from direct ref to using method 'getSealNumShipper'
				seal := ti.getSealNumShipper;
				origSeal := seal;
				ediSeal := seal;
			endif;
			
			if origSeal &lt;&gt; ediSeal then
				log.writeLine(term.code &amp; "," &amp; ti.cargoTypeDescr &amp; "," &amp; ti.id &amp; "," &amp; origSeal &amp; "," &amp; ediSeal);
			endif;
		
		endforeach;
		
	endforeach;
	
	log.close;
		
epilog
	delete customSeals;
	
end;

</source>
    </JadeMethod>
    <JadeMethod name="kpdCheckSealWriteSeal" id="9d000eb5-450f-49b6-8eae-72c8e780bb14">
        <source>kpdCheckSealWriteSeal(_file : File;
					  _term : CM_Terminal;
					  _ti : CM_TrackedItem;
					  _sealType : CM_SealType;
					  _seal : String);
					  
/*

Purpose:			Write a log message to the file with details as passed in

Parameters:			

Return Value:		

Date		Who		Reason
05 Dec 2012	cnwkpd1	PAR #30765 - CCMS 2238 - Multiple Seal numbers for Maersk EDI

*/

vars
	newSeal,
	prefix			: String;
	pos				: Integer;
	
begin
	newSeal := _seal.trimBlanks();
	if newSeal = null then
		return;
	endif;
	
	pos := 1;
	prefix := newSeal.scanUntil('0123456789', pos);
	
	_file.writeLine(_term.code &amp; "," &amp; _ti.cargoTypeDescr &amp; "," &amp; _ti.id &amp; "," &amp; _sealType.sealType &amp; "," &amp; newSeal &amp; "," &amp; prefix);
	
epilog

end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_sealType" type="CM_SealType"/>
        <Parameter name="_seal" type="String"/>
    </JadeMethod>
    <JadeMethod name="kpdCheckStringArrays" id="7783b9d3-39dc-435c-b687-d7b59ab3f59e">
        <source>kpdCheckStringArrays();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Jan 2014	cnwkpd1	Tidy up StringArray instances
27 Nov 2014	cnwkpd1	PAR #35261 - Changes to prepare for JADE 7.1

*/

vars
	props			: ObjectArray;
	property		: Property;
	propIter		: Iterator;
	cls				: Class;
	
	oa				: ObjectArray;
	allArrays		: ObjectSet;
	iter			: Iterator;
	obj				: Object;
	sa				: StringArray;
	
begin
	// Get all the unconnected StringArray instances
	create oa transient;
	iter := oa.createIterator();
	StringArray.allInstances(oa, 0, false);
	
	write oa.size.String &amp; ' instances of StringArray found';
	
	create allArrays transient;
	oa.copy(allArrays);
	oa.clear();
	
	// Search all properties for non-exclusive StringArray references
	create props transient;
	Property.allInstances(props, 0, true);
	
	write 'Processing ' &amp; props.size.String &amp; ' properties';
	
	propIter := props.createIterator();
	while propIter.next(property) do
	
		if property.type.name = StringArray.name and property.subId.Integer = null then
			cls := property.schemaType.Class;
			
			write 'Found non-attribute StringArray ' &amp; 
				   property.schemaType.schema.name &amp; '::' &amp;
				   property.schemaType.name &amp; '::' &amp;
				   property.name;
			
			oa.clear();
			
			cls.allInstances(oa, 0, true);
	
			write oa.size.String &amp; ' instances of ' &amp; cls.name &amp; ' found';
	
			iter.reset();
	
			while iter.next(obj) do
				
				sa := obj.getPropertyValue(property.name).StringArray;
				if sa &lt;&gt; null then
					if allArrays.includes(sa) then
						allArrays.remove(sa);
					else
						write '&gt;&gt;&gt;&gt; ' &amp; obj.String &amp; ' has invalid ' &amp; property.name &amp; sa.String;
					endif;
				endif;
				
			endwhile;
			
		endif;
		
	endwhile;
	
	write allArrays.size.String &amp; ' instances of StringArray not associated';
	
	if not allArrays.isEmpty then
		write 'First ' &amp; allArrays.first.String &amp; ' created ' &amp; allArrays.first.creationTime.String;
		write 'Last ' &amp; allArrays.last.String &amp; ' created ' &amp; allArrays.last.creationTime.String;
	endif;
	
	//beginTransaction;
	//allArrays.purge();
	//commitTransaction;
	
epilog
	delete allArrays;
	delete iter;
	delete oa;
	delete props;
	delete propIter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdCheckTimeStamps" id="b19dc1ea-bf52-4baa-8c99-ea2d41ae59ed">
        <source>kpdCheckTimeStamps();
/*

Purpose:			Check all the TimeStamp type properties on objects created during a benchmark run
					to ensure they are within the scope fo the run.  This is to check that the setting
					of a time zone has not impacted the TimeStamps stored in the database.

Parameters:			

Return Value:		

Date		Who		Reason
18 Jul 2016	cnwkpd1	TFS 488 - Multi Timezone Support


*/

constants
	StartTime		= '2016/07/17 14:42:49'.TimeStamp;
	EndTime			= '2016/07/17 16:26:45'.TimeStamp;
	ModCount		= 10000;
	
vars
	classes			: ClassColl;
	cls				: Class;
	objects			: ObjectArray;
	object			: Object;
	classIter,
	objectIter		: Iterator;
	properties,
	tsProperties	: PropertyColl;
	prop			: Property;
	i				: Integer;
	ts				: TimeStamp;
	
begin
	app.initialize();
	
	create classes transient;
	CM_Object.withAllSubclasses(classes);
	classIter := classes.createIterator();
	
	create objects transient;
	create tsProperties transient;
	
	while classIter.next(cls) do
		delete properties;
		properties := cls.allPropertiesUpTo(CM_Object);
		tsProperties.clear();
		foreach prop in properties do	
			if prop.getType.name = TimeStamp.name then
				tsProperties.add(prop);
			endif;
		endforeach;
		if tsProperties.isEmpty then
			self.kpdLog('Skipping class ' &amp; cls.name &amp; ', no TimeStamp properties found');
			continue;
		endif;
		
		self.kpdLog('Checking class ' &amp; cls.name &amp; ' instances');
		
		i := 0;
		foreach object in cls.instances do
			i := i + 1;
			if i mod ModCount = 0 then
				write ' Class ' &amp; cls.name &amp; ' ' &amp; i.String &amp; ' checked';
			endif;
			
			if object.creationTime() &lt; StartTime or object.creationTime &gt; EndTime then
				continue;
			endif;
			
			foreach prop in tsProperties do
				ts := object.getPropertyValue(prop.name).TimeStamp;
				if ts.isValid then
					if ts &lt; StartTime or ts &gt; EndTime then
						self.kpdLog(' &gt;&gt;&gt;&gt; ' &amp; object.String &amp; ' ' &amp; prop.name &amp; ' ' &amp; ts.String);
					endif;
				endif;
			endforeach;
		endforeach;
	
	endwhile;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="kpdCheckTranslations" id="3904fc0b-2edd-4730-aa80-5f134dd0c15f">
        <source>kpdCheckTranslations();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 March 2012	cnwkpd1	PAR #29165 - CCMS SFW 1272 - Reduce physical database size

*/

vars
	constantCategory		: ConstantCategory;
	constant				: Constant;
	locale					: CM_Locale;
	existingTranslations	: XLAT_TranslatableTextByCatNmbr;
	translatableText		: XLAT_TranslatableText;
	category				: XLAT_Category;
	tmpCategoryDict,
	tmpConstantDict			: ConstantNDict;
	portScm					: Schema;
	checked,
	bad						: Integer;
	
begin
	write "Starting";
	
	portScm := rootSchema.getSchema("PortSchema");
	constantCategory := portScm.getCategory(XLAT_FormCaptions);
	
	tmpConstantDict := constantCategory.getConstants();
	
	category := CM_Root.firstInstance().allXLAT_Categories[XLAT_FormCaptions];
	
	foreach constant in tmpConstantDict do
		checked := checked + 1;
		
		if constant.valueAsInteger.String &lt;&gt; constant.getSource().trimBlanks() then
			bad := bad + 1;
			write constant.name &amp; Tab &amp; constant.valueAsInteger.String &amp; Tab &amp; constant.getSource();
		endif;
//		translatableText := category.allTranslatableText[constant.valueAsInteger];
	
	endforeach;
	
	write "Finished, " &amp; checked.String &amp; " constants checked, " &amp; bad.String &amp; " mismatches found";
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdCheckVehicleVisits" id="3e12f761-b888-454e-bfd5-5802e53054c0">
        <source>kpdCheckVehicleVisits();

/*

Purpose:			Check the Vehicle Visits to see if there are any with cargo from multiple 
					Consignees/Consignors/Operators.
					Check Penn database for analysis of TFS 1773

Parameters:			

Return Value:		


Date		Who		Reason
13 Apr 2016	cnwkpd1	TFS 1773 - Automatic Dock Receipt

*/

constants
	MaxCount		= 1000;
	
vars
	vvr				: CM_VehicleVisitRecord;
	ti				: CM_TrackedItem;
	messages		: HugeStringArray;
	i 				: Integer;
	consignees,
	consignors,
	operators		: ObjectSet;
	consignee,
	consignor		: CM_ConsigneeConsignor;
	operator		: CM_Operator;
	
begin
	create messages transient;
	create consignees transient;
	create consignors transient;
	create operators transient;
	
	foreach vvr in CM_VehicleVisitRecord.instances reversed do	
		i := i + 1;
		if i &gt; MaxCount then
			break;
		endif;
		
		consignees.clear();
		consignors.clear();
		operators.clear();
		
		foreach ti in vvr.allReceivedTrackedItems discreteLock do
			consignee := ti.getConsigneeObject();
			if consignee &lt;&gt; null then
				if not consignees.includes(consignee) then
					if consignees.size() = 1 then
						messages.add(vvr.String &amp; " " &amp; vvr.visitNumber &amp; " has multiple Consignees");
					endif;
					consignees.add(consignee);
				endif;
			endif;

			consignor := ti.getConsignorObject();
			if consignor &lt;&gt; null then
				if not consignors.includes(consignor) then
					if consignors.size() = 1 then
						messages.add(vvr.String &amp; " " &amp; vvr.visitNumber &amp; " has multiple Consignors");
					endif;
					consignors.add(consignor);
				endif;
			endif;

			operator := ti.myOperator;
			if operator &lt;&gt; null then
				if not operators.includes(operator) then
					if operators.size() = 1 then
						messages.add(vvr.String &amp; " " &amp; vvr.visitNumber &amp; " has multiple Operators");
					endif;
					operators.add(operator);
				endif;
			endif;
		endforeach;
		
		foreach ti in vvr.allReleasedTrackedItems discreteLock do
			consignee := ti.getConsigneeObject();
			if consignee &lt;&gt; null then
				if not consignees.includes(consignee) then
					if consignees.size() = 1 then
						messages.add(vvr.String &amp; " " &amp; vvr.visitNumber &amp; " has multiple Consignees");
					endif;
					consignees.add(consignee);
				endif;
			endif;

			consignor := ti.getConsignorObject();
			if consignor &lt;&gt; null then
				if not consignors.includes(consignor) then
					if consignors.size() = 1 then
						messages.add(vvr.String &amp; " " &amp; vvr.visitNumber &amp; " has multiple Consignors");
					endif;
					consignors.add(consignor);
				endif;
			endif;

			operator := ti.myOperator;
			if operator &lt;&gt; null then
				if not operators.includes(operator) then
					if operators.size() = 1 then
						messages.add(vvr.String &amp; " " &amp; vvr.visitNumber &amp; " has multiple Operators");
					endif;
					operators.add(operator);
				endif;
			endif;
		endforeach;
		
	endforeach;
	
	messages.inspectModal();
			
	
epilog
	delete messages;
	delete consignees;
	delete consignors;
	delete operators;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdCheckWindowCaptions" id="046baca6-0945-43f8-a4a4-b4ca402f0dbb">
        <source>kpdCheckWindowCaptions();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 October 2016	cnwkpd1	TFS 488 - Multi Timezone Support


*/

vars
	win				: Window;
	oa				: ObjectArray;
	iter			: Iterator;
	f				: File;
	caption			: String;
	i 				: Integer;
	
begin
	create oa transient;
	Window.allInstances(oa, 0, true);
	write 'Checking ' &amp; oa.size().String &amp; ' Window instances';
	
	create f transient;
	f.openOutput('c:\temp\kpdCheckWindowCaptions.log');
		
	iter := oa.createIterator();
	while iter.next(win) do
		i := i + 1;
		if i mod 1000 = 0 then
			write i.String &amp; ' instances processed';
		endif;
	
		caption := win.getCaption();
		if caption &lt;&gt; null then
			if caption.pos('_', 1) &lt;&gt; 0 then
				f.writeLine(caption &amp; Tab &amp; win.String);
			endif;
		endif;
	
	endwhile;
	
	write 'Finished';
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="kpdCompactDBFiles" id="9c18130d-0835-49e4-bf5e-e5f512af540b">
        <source>kpdCompactDBFiles();

/*

Purpose:			Perform an online DB compact of a list of names dat files


Date		Who		Reason
22 Aug 2012	cnwkpd1	Dev environment cleanup

*/

vars
	dba				: JadeDatabaseAdmin;
	dbFile			: DbFile;
	dbFiles			: DbFileArray;
	
	files			: StringArray;
	
begin
	// Setup list of files to compact here
	create files transient;
	//files.add("unitTest");
	files.add("containr");
	files.add("audit");
	
	// Run the compact
	create dba transient;
	create dbFiles transient;
	dba.getDbFiles(DbFile.Kind_User_Data, dbFiles);
	
	foreach dbFile in dbFiles do
		if not files.includes(dbFile.name)then
			continue;
		endif;
		
		write "Compacting " &amp; dbFile.name &amp; ".dat (File size=" &amp; dbFile.getFileLength().String &amp; ").  Please wait...";
		dbFile.compactFile();
		write "Finished compacting " &amp; dbFile.name &amp; ".dat (File size=" &amp; dbFile.getFileLength().String &amp; ").";
		
	endforeach;
	
epilog
	delete dba;
	delete dbFiles;
	delete files;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdCopyLogsFromServer" id="cd276acc-b191-4a59-b1c6-957e9f15a6c1">
        <source>kpdCopyLogsFromServer();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 December 2011	cnwkpd1	PAR #28262 - CCMS 1223 - Delivery Mechanisms

*/
vars
	ff : FileFolder;
	fn : FileNode;
	inFile,
	outFile : File;
	b : Binary;
	
begin
	create ff transient;
	ff.usePresentationFileSystem := false;
	
	ff.fileName := 'c:\JMT\Logs';
	ff.mask := 'jom*.log';
	
	foreach fn in ff.files do
		create inFile transient;
		inFile.usePresentationFileSystem := false;
		inFile.kind := File.Kind_Binary;
		inFile.openInput(fn.fileName);
		
		create outFile transient;
		outFile.usePresentationFileSystem := true;
		outFile.kind := File.Kind_Binary;
		outFile.openOutput('c:\temp\' &amp; fn.name);
		
		while not inFile.endOfFile() do
			outFile.writeBinary(inFile.readBinary(20000));
		endwhile;
		
		inFile.close();
		delete inFile;
	
		outFile.close();
		delete outFile;
	endforeach;
	
epilog
	delete inFile;
	delete outFile;
	delete ff;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdCountClasses" id="f1a9f424-547a-4891-abb4-456fc9cde00d">
        <source>kpdCountClasses();

vars
	cls : Class;
	pt : PrimType;
	total, totalRoot, totalProps, totalMeths, totalPrimMeths, totalForms, totalControls : Integer;
	mdlTotal, mdlRoot, mdlMeths, mdlPrimMeths : Integer;
	i, n, prevCrPos, totalLOC, loop : Integer;
	oa : ObjectArray;
	o : Object;
	m : Method;
	s : String;
	codeLine	: String;

	releaseSchemas : StringArray;
	agent : DEV_ReleaseExtractAgent;
	
begin
	foreach loop in 1 to 2 do
	
		if loop = 1 then
			create agent transient;
			create releaseSchemas transient;
			agent.getReleaseSchemas(releaseSchemas);
			releaseSchemas.add("JMTUnitTest");
		else
			releaseSchemas.clear();
		endif;

		total := 0;
		totalRoot := 0;
		totalForms := 0;
		totalControls := 0;
		mdlTotal := 0;
		mdlRoot := 0;
		mdlMeths := 0;
		mdlPrimMeths := 0;
		totalProps := 0;
		totalMeths := 0;
		totalPrimMeths := 0;
		totalLOC := 0;
		
		delete oa;
		create oa transient;
	
		Class.allInstances(oa, 0, true);
	
		foreach o in oa do : classLoop
			cls := o.Class;
			if cls.isKindOf(ActiveXGuiClass) or cls.inheritsFrom(ActiveXInterface) then
				continue;
			endif;
	
			if not releaseSchemas.isEmpty and not releaseSchemas.includes(cls.schema.name) then
				continue;
			endif;
			
			if cls.schema.name[1:4] = "Jade" or cls.schema.name[1:4] = "Root" then
				continue;
			endif;
	
			total := total + 1;
			if cls.inheritsFrom(Form) then
				totalForms:=totalForms+1;
			endif;
			if cls.inheritsFrom(Control) then
				totalControls:=totalControls+1;
			endif;
			
			if cls.schema.name = "PortSchema" then
				mdlTotal := mdlTotal + 1;
			endif;
			
			totalProps := totalProps + cls.getPropertyValue("properties").PropertyNDict.size;
	
			foreach m in cls.getPropertyValue("methods").MethodNDict do
				totalMeths := totalMeths + 1;
				
				if cls.schema.name = "PortSchema" then
					mdlMeths := mdlMeths + 1;
				endif;
	
				if not m.isKindOf(JadeMethod) then
					continue;
				endif;
	
				s := m.getPropertyValue("source").String.trimBlanks;
				n := s.length;
				i := 1;
				
				while i &lt; n do
					codeLine := s.scanUntil(Cr, i).trimBlanks;
					if codeLine &lt;&gt; null then
						totalLOC := totalLOC + 1;					
					endif;
					if i = 0 then
						break;
					endif;
					i := i + 1;
				endwhile;
			endforeach;  // method in the class
	
			if cls.superschemaType &lt;&gt; null then
				// subschema copy - don't count as a root class
				continue;
			endif;
			
			totalRoot := totalRoot + 1;
	
			if cls.schema.name = "PortSchema" then
				mdlRoot := mdlRoot + 1;
			endif;
			
		endforeach; // Class in the schemas
	
		oa.clear;
	
		PrimType.allInstances(oa, 0, true);
	
		foreach o in oa do
			pt := o.PrimType;
			
			if not releaseSchemas.isEmpty and not releaseSchemas.includes(pt.schema.name) then
				continue;
			endif;
		
			if cls.schema.name[1:4] = "Jade" or cls.schema.name[1:4] = "Root" then
				continue;
			endif;
	
			foreach m in pt.getPropertyValue("methods").MethodNDict do
				totalPrimMeths := totalPrimMeths + 1;
				
				if pt.schema.name = "PortSchema" then
					mdlPrimMeths := mdlPrimMeths + 1;
				endif;
	
				if not m.isKindOf(JadeMethod) then
					continue;
				endif;
	
				s := m.getPropertyValue("source").String.trimBlanks;
				n := s.length;
				i := 1;
				
				while i &lt; n do
					codeLine := s.scanUntil(Cr, i).trimBlanks;
					if codeLine &lt;&gt; null then
						totalLOC := totalLOC + 1;					
					endif;
					if i = 0 then
						break;
					endif;
					i := i + 1;
				endwhile;
	
			endforeach; // Method in the type
	  
		endforeach; // Primitive type in the schemas
	
		write "------------------------------------------------------------------------";
		if loop = 1 then
			write "Released Schemas";
		else
			write "All Schemas";
		endif;
		write " ";
		
		write "Total classes in all schemas = " &amp; total.String;
		write "Total classes in model = " &amp; mdlTotal.String;
		write "Total forms in all schemas = " &amp; totalForms.String;
		write "Total controls in all schemas = " &amp; totalControls.String;
		write "Total classes (excluding subschema copies) in all schemas = " &amp; totalRoot.String;
		write "Total classes (excluding subschema copies) in model = " &amp; mdlRoot.String;
		write "Total properties in classes in all schemas = " &amp; totalProps.String;
		write "Total methods in classes in all schemas = " &amp; totalMeths.String;
		write "Total methods in model classes = " &amp; mdlMeths.String;
		write "Total primitive methods in all schemas = " &amp; totalPrimMeths.String;
		write "Total primitive methods in model schema = " &amp; mdlPrimMeths.String;
		write "Total methods in all schemas = " &amp; (totalMeths + totalPrimMeths).String;
		write "Total lines of code in all schemas = " &amp; totalLOC.String;

	endforeach;

epilog
	delete oa;
	delete agent;
	delete releaseSchemas;

end;</source>
    </JadeMethod>
    <JadeMethod name="kpdCountMapFileInstances" id="d5314f1a-ff41-4cd8-8677-2ec8791425e8">
        <source>kpdCountMapFileInstances();

/*

Purpose:


Return Value:


Date			Who			Reason
07 March 2001	KPD			Initial creation

*/

constants
	MinimumReported		: Integer = 0;
	
vars
	dbClassMap			: DbClassMap;
	cls					: Class;
	size				: Integer;
	mapFileNames		: StringArray;
	logFile				: File;
	logFileName			: String;
	
begin
	create mapFileNames transient;
//	mapFileNames.add("transact");
//	mapFileNames.add("audit");
//	mapFileNames.add("snapshots");
//	mapFileNames.add("containr");
	mapFileNames.add("unitTest");
	
//	mapFileNames.add("unitTest");

	logFileName := app.dbPath;
	logFileName := logFileName[4:end];		// get rid of drive stuff
	logFileName := logFileName[1:logFileName.pos("\", 1) - 1];

	create logFile transient;
	logFile.openOutput("c:\temp\" &amp; logFileName &amp; "_instance_counts.txt");
	
	write "Counting instances for map files " &amp; mapFileNames.concatenate(" ");

	foreach dbClassMap in DbClassMap.instances where mapFileNames.isEmpty or mapFileNames.includes(dbClassMap.diskFile.name) do
		cls := dbClassMap.diskClass;
		write "Processing class " &amp; cls.name;
		
		size := cls.countPersistentInstances;
		if size &gt; MinimumReported then
			logFile.writeLine(dbClassMap.diskFile.name &amp; Tab &amp; cls.name &amp; Tab &amp; size.String);
		endif;
	endforeach;
	
	write "Finished";
	
	
epilog
	delete mapFileNames;
	delete logFile;
		
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdCreateAllSQLTables" id="c85c4eae-7c5f-4864-ad6b-ac38104eff01">
        <source>kpdCreateAllSQLTables();
/*

Purpose:			Create a SQL command to create all the tables for a named SQL 
					Native extract definition

Parameters:			

Return Value:		

Date		Who		Reason
31 Jan 2012	cnwkpd1	Initial creation

*/

vars
	def			: CM_DataDumpExtractDef;
	extractClass : CM_DataDumpExtractClass;
	file		: File;
	dump        : String;
	xdbAgent    : CM_ExternalDatabaseAgent;

begin
	app.initialize();
	
	create xdbAgent transient;
	
	foreach def in CM_DataDumpExtractDef.instances do // where def.description = "Full Data Extract" do
	
		delete file;
		create file transient;
		file.openOutput("c:\temp\" &amp; def.description &amp; "_create_all_tables.sql");
		
		foreach extractClass in def.allDataDumpExtractClasses do
			dump := xdbAgent.buildCreateTableString(extractClass);
			
			dump := dump.replace("[dbo]", "[" &amp; def.edbConnectionString &amp; "].[dbo]");
			
			file.writeLine(dump);
		endforeach;
		
		file.close;

	endforeach;

epilog
	delete file;
	delete xdbAgent;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="kpdCreateDefaultWebConfigs" id="4fd5e780-ea3e-48fe-96e2-c40eab879925">
        <source>kpdCreateDefaultWebConfigs();

/*

Purpose:			Create the default Web Site configs for a new dev environment (or a refreshed one).
					Will create HTML config "WebDefault" and Web Service config "WebServiceDefault"

Parameters:			None

Return Value:		None


Date		Who		Reason
21 Jun 2010	cnwkpd1	JMT 7.8.2 release

*/

vars
	realConfig,
	proxyConfig		: CM_WebSiteConfig;
	
	name,
	envName			: String;
	
	printer			: CM_PrinterDef;
	
	website,
	downloadFileDirPath,
	downloadFileDirURL	: String;
	downloadFileTimeout : Integer;
	helpFileURL			: String;
	
begin
	app.initialize();
	
	envName := app.myCnKarmaCntrl.environmentId.toLower();
	website := "web1." &amp; envName &amp; ".cnw.co.nz";
	
	// HTML first
	name := "WebDefault";
	realConfig := app.myRoot.allWebSiteConfigs[name];
	if realConfig &lt;&gt; null then
		proxyConfig := app.createUpdateProxy(realConfig).CM_WebSiteConfig;
		write "Updating " &amp; name &amp; " " &amp; realConfig.String;
	else
		write "Creating new " &amp; name;
		
		create proxyConfig transient;
		proxyConfig.setAsWebService(false);
	endif;

	printer := app.myRoot.allPrinterDefsByLogicalName["PDF PRINTER"];
	if printer = null then
		foreach printer in app.myRoot.allPrinterDefsByLogicalName do
			if printer.printerIsPDF then
				break;
			endif;
		endforeach;
	endif;
	
	proxyConfig.setForProxy(	"JMTLoginPage",				// login,	
								"JMTCurrentRptsPage",		// currentReports,
								"JMTChangePasswordPage",	// password,	
								null,						// download,
								"JMTInfoDtlPage",			// info,
								"JMTReportListPage",		// list,
								"JMTReportOutputPage",		// output,
								"JMTReportCriteriaPage",	// criteria,
								"JMTPageHeaderLoggedIn",	// headerIn,
								"JMTPageHeaderLoggedOut",	// headerOut,
								"JMTPageFooter",			// footer,
								"WebExampleSchema",			// schema,
								name,
								false,						// isSecure,
								"BGPUSER",					// userCode,
								"bin_public",				// virtualDirectory,
								website,					// machineName,
								"JMTEventReqStopMaint",		// eventReqStopMaintPage,
								"JMTEventReqStopView",		// eventReqStopViewPage,
								"JMTEventNotifyMaint",		// eventNotifyMaintPage,
								"JMTEventNotifyView",		// eventNotifyViewPage,
								"JMTPrenotificationMaint",	// prenotesMaintPage,
								"JMTPrenotificationView",	// prenotesViewPage,
								30,							// timeout,
								printer,					// printer
								"WebExampleApp",			// webApplicationName,
								app.myRoot,
								null,						// downloadFileDirPath,
								null,						// downloadFileDirURL,
								null,						// downloadFileTimeout,
								null,
								null,						// helpFileURL;
								null,						// defaultLoggingLevel
								null						// responseTimeout
								);
	
	app.myTrxUA.trxUpdateWebSiteConfig(proxyConfig, realConfig, app.myPassport);
	
	if (not app.myPassport.trxCompletedOK) then
		app.showErrorsAsMsgBox(app.myPassport.allErrors, false);
	endif;
	
	// Now do Web Service
	delete proxyConfig;
	
	name := "WebServiceDefault";
	realConfig := app.myRoot.allWebSiteConfigs[name];
	if realConfig &lt;&gt; null then
		proxyConfig := app.createUpdateProxy(realConfig).CM_WebSiteConfig;
		write "Updating " &amp; name &amp; " " &amp; realConfig.String;
	else
		write "Creating new " &amp; name;
		
		create proxyConfig transient;
		proxyConfig.setAsWebService(true);
	endif;
	
	downloadFileDirPath := app.cnGetServerMiscPath() &amp; "/htdocs/downloads";
	downloadFileDirURL := "http://" &amp; website &amp; "/htdocs/downloads";
	helpFileURL := downloadFileDirURL &amp; "/help.pdf";
	
	proxyConfig.setForProxy(	null,						// login,	
								null,						// currentReports,
								null,						// password,	
								null,						// download,
								null,						// info,
								null,						// list,
								null,						// output,
								null,						// criteria,
								null,						// headerIn,
								null,						// headerOut,
								null,						// footer,
								null,						// schema,
								name,
								false,						// isSecure,
								"BGPUSER",					// userCode,
								null,						// virtualDirectory,
								null,						// machineName,
								null,						// eventReqStopMaintPage,
								null,						// eventReqStopViewPage,
								null,						// eventNotifyMaintPage,
								null,						// eventNotifyViewPage,
								null,						// prenotesMaintPage,
								null,						// prenotesViewPage,
								30,							// timeout,
								printer,					// printer
								null,						// webApplicationName,
								app.myRoot,
								downloadFileDirPath,		// downloadFileDirPath,
								downloadFileDirURL,			// downloadFileDirURL,
								30,							// downloadFileTimeout,
								helpFileURL,
								null,						// helpFileURL
								null,						// defaultLoggingLevel
								null						// responseTimeout
								);
	
	app.myTrxUA.trxUpdateWebSiteConfig(proxyConfig, realConfig, app.myPassport);
	
	if (not app.myPassport.trxCompletedOK) then
		app.showErrorsAsMsgBox(app.myPassport.allErrors, false);
		return;
	endif;

	
epilog
	delete proxyConfig;
end;
</source>
    </JadeMethod>
    <JadeMethod name="kpdCreateEmptyUserDefinedCSV" id="0da4039e-7790-4917-923a-325304416274">
        <source>kpdCreateEmptyUserDefinedCSV();
/*

Purpose:			Create an empty CSV file (headings only) that matches the definition given

Parameters:			None

Return Value:		None

Date		Who		Reason
28 Sep 2012	cnwkpd1	PAR #30400 - SFW 1290 - Transaction EDI file type

*/

constants
//	FileDefName		= "KPD All Cargo On Site";
	FileDefName		= "KPD All Transaction";
	
vars
	file			: File;
	cmd				: CMDFileSave;
	ediFileType		: CM_EDIFileTypeUser;
	ediFieldMT		: CM_EDIFieldMappingType;
	ediField		: CM_EDIFieldMapping;
	line			: String;
	
begin
	app.initialize();
	
	ediFileType := app.myRoot.allEDIFileTypes[EDIFileType_UserDefined, FileDefName].CM_EDIFileTypeUser;
	if ediFileType = null then
		app.msgBox("EDI File Definition " &amp; FileDefName &amp; " not found", "Error", 0);
		return;
	endif;
	
	create cmd transient;
	cmd.fileName := FileDefName &amp; ".csv";
	
	if cmd.open() &lt;&gt; 0 then
		return;
	endif;
	
	create file transient;
	file.openOutput(cmd.fileName);
	
	ediFieldMT := ediFileType.allEDIFieldMappingTypes.first();
	if ediFieldMT = null then
		app.msgBox("EDI File Definition " &amp; FileDefName &amp; " has no mappings", "Error", 0);
		return;
	endif;
	
	foreach ediField in ediFieldMT.allEDIFieldMappings do
		if line &lt;&gt; null then
			line := line &amp; ",";
		endif;
		line := line &amp; ediField.userDesc;
	endforeach;
	
	file.writeLine(line);
	
	file.close();
	
	
epilog
	delete file;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdCreateTestOnSiteCargoCSV" id="e5c5fdc2-b53f-46c2-8305-07f09d4fa869">
        <source>kpdCreateTestOnSiteCargoCSV();
/*

Purpose:			Create a pair of CSV files to test On Site Cargo and Transaction import

Parameters:			None

Return Value:		None

Date		Who		Reason
28 Sep 2012	cnwkpd1	PAR #30400 - SFW 1290 - Transaction EDI file type

*/

constants
	FileDefNameTI	= "KPD All Cargo On Site";
	FileDefNameTran	= "KPD All Transaction";
	OverwriteID		= true;				// set to true to create test data
	OverwriteIDStart	= "XKPD";
	
vars
	cargoFile,
	transFile		: File;
	ff				: FileFolder;
	folderName		: String;
	ediFileType		: CM_EDIFileTypeUser;
	ediFieldMT		: CM_EDIFieldMappingType;
	ediField		: CM_EDIFieldMapping;
	line			: String;
	tis				: CM_TIArray;
	ti				: CM_TrackedItem;
	trans			: CM_TITransaction;
	now				: TimeStamp;
	firstField		: Boolean;
	value			: String;

begin
	app.initialize();
	
	create tis transient;
	tis.add(CM_Container.lastInstance());
//	tis.add('2367.5877'.asOid.CM_Container);
	
	// First do Cargo
	ediFileType := app.myRoot.allEDIFileTypes[EDIFileType_UserDefined, FileDefNameTI].CM_EDIFileTypeUser;
	if ediFileType = null then
		app.msgBox("EDI File Definition " &amp; FileDefNameTI &amp; " not found", "Error", 0);
		return;
	endif;
	
	ediFieldMT := ediFileType.allEDIFieldMappingTypes.first();
	if ediFieldMT = null then
		app.msgBox("EDI File Definition " &amp; FileDefNameTI &amp; " has no mappings", "Error", 0);
		return;
	endif;
	
	create ff transient;
	folderName := ff.browseForFolder(null, "c:\temp");
	if folderName = null then
		return;
	endif;

	create cargoFile transient;
	cargoFile.openOutput(folderName &amp; "/" &amp; FileDefNameTI &amp; "_" &amp; now.getNumeralString &amp; ".csv");

	// Write headings
	line := null;
	foreach ediField in ediFieldMT.allEDIFieldMappings do
		if line &lt;&gt; null then
			line := line &amp; ",";
		endif;
		line := line &amp; ediField.userDesc;
	endforeach;
	
	cargoFile.writeLine(line);
	
	// Now extract all the Tracked Items in the array
	foreach ti in tis do
		firstField := true;
		
		foreach ediField in ediFieldMT.allEDIFieldMappings do
			if firstField then
				line := null;
				firstField := false;
			else
				line := line &amp; ",";
			endif;
			value := self.kpdGetExportValueFromTI(ti, ediField.propName).csvEncode;
			if OverwriteID and ediField.propName = "id" then
				value[1:OverwriteIDStart.length] := OverwriteIDStart;
			endif;
			line := line &amp; value;
		endforeach;
	
		cargoFile.writeLine(line);
	endforeach;
		
	cargoFile.close();
	
	// Then do the transactions
	ediFileType := app.myRoot.allEDIFileTypes[EDIFileType_UserDefined, FileDefNameTran].CM_EDIFileTypeUser;
	if ediFileType = null then
		app.msgBox("EDI File Definition " &amp; FileDefNameTran &amp; " not found", "Error", 0);
		return;
	endif;
	
	ediFieldMT := ediFileType.allEDIFieldMappingTypes.first();
	if ediFieldMT = null then
		app.msgBox("EDI File Definition " &amp; FileDefNameTran &amp; " has no mappings", "Error", 0);
		return;
	endif;
	
	create transFile transient;
	transFile.openOutput(folderName &amp; "/" &amp; FileDefNameTran &amp; "_" &amp; now.getNumeralString &amp; ".csv");

	// Write headings
	line := null;
	foreach ediField in ediFieldMT.allEDIFieldMappings do
		if line &lt;&gt; null then
			line := line &amp; ",";
		endif;
		line := line &amp; ediField.userDesc;
	endforeach;
	
	transFile.writeLine(line);
	
	// Now extract all the Tracked Items' Transactions in the array
	foreach ti in tis do
		
		foreach trans in ti.allTransactions do
		
			firstField := true;
			
			foreach ediField in ediFieldMT.allEDIFieldMappings do
				if firstField then
					line := null;
					firstField := false;
				else
					line := line &amp; ",";
				endif;
				value := self.kpdGetExportValueFromTITrans(trans, ediField.propName).csvEncode;
				if OverwriteID and ediField.propName = "id" then
					value[1:OverwriteIDStart.length] := OverwriteIDStart;
				endif;
				line := line &amp; value;
			endforeach;
		
			transFile.writeLine(line);
		endforeach;
	endforeach;
		
	transFile.close();
	
epilog
	delete cargoFile;
	delete tis;
	delete ff;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdCreateVoyageRecTrans" id="840cbea1-b2e3-44ca-9450-eb036e292e46">
        <source>kpdCreateVoyageRecTrans();

/*

Purpose:			Create missing Ship Receive transactions for containers discharged since
					a given date and time


Date		Who		Reason
15 Aug 2012	cnwkpd1	PAR #30208 - Lander to IMV discharge not creating Receive transactions

*/

constants
	UpdateDB		= false;
	TerminalCode	= "DOH";
	StartTime		= "19/07/2012 00:00".TimeStamp;
	EndTime			= "25/08/2012 23:59".TimeStamp;
	
vars
	file 			: File;
	term			: CM_Terminal;
	voyageCodes		: StringArray;
	voyageCode		: String;
	voyages			: CM_VoyageArray;
	voyage			: CM_Voyage;
	jobSheet		: CM_VoyageJobSheet;
	wle				: CM_WorkListEntry;
	ti				: CM_TrackedItem;
	tiTran			: CM_TITransaction;
	moveTran		: CM_Move;
	typeArray 		: IntegerArray;
	transType		: Integer;
	txnParams		: CMIF_TITransactionController;	
	iter			: Iterator;
	updateCount		: Integer;
	
begin
	app.initialize();
	app.myPassport.setMyUserFromCode("SUPERUSER");

	create file transient;
	file.openOutput("c:\temp\CreateVoyageReceive_" &amp; app.actualTimeServer().getNumeralString &amp; ".log");
	
	file.writeLine("Running Voyage Receive creation for Terminal " &amp; TerminalCode &amp; ", update mode = " &amp; UpdateDB.String);
	
	term := app.myRoot.allTerminals[TerminalCode];
	if term = null then
		file.writeLine("Terminal " &amp; TerminalCode &amp; " not found, exiting");
		app.msgBox("Terminal " &amp; TerminalCode &amp; " not found", 'Error', 0);
		return;
	endif;
	
	app.myPassport.setMyTerminal(term);
	create txnParams transient;
	txnParams.myTerminal := term;
	
	create typeArray transient;
	
	if UpdateDB then
		beginTransaction;
	endif;
	
	// Now look at all Move transactions from the start date
	iter := term.allTITransactionsByTypeDate.createIterator();
	term.allTITransactionsByTypeDate.startKeyGeq(TRANS_TYPE_MOVE, StartTime, iter);

	while iter.next(tiTran) do
		if tiTran.type &lt;&gt; TRANS_TYPE_MOVE then
			break;
		endif;
		if tiTran.dateTime &gt; EndTime then
			break;
		endif;
		
		// Skip any deleted transactions
		if tiTran.deleted then
			continue;
		endif;
		
		// Skip any that are not CM_Move (should not happen)
		if not tiTran.isKindOf(CM_Move) then
			continue;
		endif;
		moveTran := tiTran.CM_Move;
		
		ti := tiTran.myTrackedItem;
		if ti = null then
			continue;
		endif;

		// Looking for Queued Move where sourceLocation starts with the voyageCode
		if moveTran.typeString &lt;&gt; "Queued" then
			continue;
		endif;
		
		if moveTran.voyageCode = null then
			continue;
		endif;
		if not moveTran.sourceLocn.startsWith(moveTran.voyageCode) then
			continue;
		endif;
		
		// Check this TI was received by Ship
		if ti.receiptTransportMode &lt;&gt; TI_TRANSMODE_SHIP and
		   ti.receiptTransportMode &lt;&gt; TI_TRANSMODE_NULL then
			continue;
		endif;
		
		if ti.getLastTransOfType(TRANS_TYPE_REC_SHIP) &lt;&gt; null then
			file.writeLine("    TI " &amp; ti.id &amp; " has ship receive trans " &amp; tiTran.dateTime.display() &amp;
						   " voyage " &amp; moveTran.voyageCode &amp; ", skipping");
			continue;
		endif;
		
		if ti.getLastTransOfTypeAdv(TRANS_TYPE_RECEIVE) &lt;&gt; null then
			file.writeLine("&gt;   TI " &amp; ti.id &amp; " has receive trans " &amp; tiTran.dateTime.display() &amp; ", skipping");
			continue;
		endif;
		
		// Ignore non-forced moved
		if not moveTran.forced and not moveTran.systemGenerated then
			file.writeLine("    TI " &amp; ti.id &amp; " " &amp; tiTran.dateTime.display() &amp; " was not forced and not system generated, skipping");
			continue;
		endif;

		// Need to create receive transaction
		typeArray.clear();
		typeArray.add(TRANS_TYPE_REC_SHIP);
		typeArray.add(TRANS_TYPE_WHARFAGE);
		app.addTiTxnSubTerminalReceive(ti, TI_TRANSMODE_SHIP, typeArray);
		
		txnParams.dateTime := moveTran.dateTime;
		txnParams.userId := moveTran.userId;
		txnParams.myTrackedItem := ti;

		// Create the transactions
		foreach transType in typeArray do
			txnParams.type := transType;
			if UpdateDB then
				txnParams.createTransaction(app.myPassport);
			endif;
			file.writeLine("&gt;&gt;  Creating trans type " &amp; transType.String &amp; 
						   " " &amp; moveTran.dateTime.display() &amp;
						   ' for ' &amp; ti.id &amp; " voyage " &amp; moveTran.voyageCode);
		endforeach;
		updateCount := updateCount + 1;
		if UpdateDB then
			commitTransaction;
			beginTransaction;
		endif;
		
	endwhile;
	
	if UpdateDB then
		commitTransaction;
	else
		abortTransaction;
	endif;
	
	file.writeLine("Finished processing all transactions, " &amp; updateCount.String &amp; " TIs updated");
	
	file.close();
	
epilog
	delete file;
	delete txnParams;
	delete typeArray;
	delete voyageCodes;
	delete voyages;
	delete iter;
	abortTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdEmailSettingsCheck" id="310e29f3-9902-4de0-9011-03687529cdff">
        <source>kpdEmailSettingsCheck();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 Sep 2010	cnwkpd1	Fix issue of JMT test systems generating invalid emails
24/10/2012	cnwcs5	par 30297 - Remove "Run EDI Root" BGP task type
*/

constants
	DummyAddress	= 'bitbucket';
	EmailDomain		= '@jadeworld.com';
	
vars
	file			: File;
	sender,
	dummyRecipient	: String;
	
begin
	app.initialize();
	
	create file transient;
	file.kind := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	file.mode := File.Mode_Append;
	file.fileName := "c:\temp\EmailInfo.txt";
	file.open();
	
	file.writeLine('------------------ BEFORE ------------------------------------------');
	file.writeLine(app.myCnKarmaCntrl.environmentId);
	file.writeLine('SystemTestMode=' &amp; app.myRoot.getConfig(BgpEmailTestMode).Boolean.String);
	file.writeLine('AutoSmtpServer=' &amp; app.myRoot.getConfig(AutoSmtpServer).String);
	file.writeLine('AutoSendersEmailAddress=' &amp; app.myRoot.getConfig(AutoSendersEmailAddress).String);
	
	file.writeLine('AutoSupportEmailAddress=' &amp; app.myRoot.getConfig(AutoSupportEmailAddress).String);
	//file.writeLine('AutoEmailAddress=' &amp; app.myRoot.getConfig(AutoEmailAddress).String);
	file.writeLine('AutoDisableEmailAddress=' &amp; app.myRoot.getConfig(AutoDisableEmailAddress).String);
	
	sender := app.myCnKarmaCntrl.environmentId.toLower &amp; EmailDomain;
	dummyRecipient := DummyAddress &amp; EmailDomain;
	
	beginTransaction;
	app.myRoot.setConfig(AutoSendersEmailAddress, sender, true);
	app.myRoot.setConfig(AutoSupportEmailAddress, dummyRecipient, true);
	//app.myRoot.setConfig(AutoEmailAddress, dummyRecipient);
	app.myRoot.setConfig(AutoDisableEmailAddress, dummyRecipient, true);
	commitTransaction;

	file.writeLine('------------------ AFTER ------------------------------------------');
	file.writeLine(app.myCnKarmaCntrl.environmentId);
	file.writeLine('SystemTestMode=' &amp; app.myRoot.getConfig(BgpEmailTestMode).Boolean.String);
	file.writeLine('AutoSmtpServer=' &amp; app.myRoot.getConfig(AutoSmtpServer).String);
	file.writeLine('AutoSendersEmailAddress=' &amp; app.myRoot.getConfig(AutoSendersEmailAddress).String);
	
	file.writeLine('AutoSupportEmailAddress=' &amp; app.myRoot.getConfig(AutoSupportEmailAddress).String);
	//file.writeLine('AutoEmailAddress=' &amp; app.myRoot.getConfig(AutoEmailAddress).String);
	file.writeLine('AutoDisableEmailAddress=' &amp; app.myRoot.getConfig(AutoDisableEmailAddress).String);

	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="kpdFindBadCauseEvent" id="64ce2349-1823-47e1-9636-ac080d7e225b">
        <source>kpdFindBadCauseEvent();
/*

Purpose:			Find possible misuse of Object::causeEvent with system event numbers

Parameters:			

Return Value:		

Date		Who		Reason
12 Oct 2016	cnwkpd1	JADE 7.1.08 upgrade issues

*/

constants
	CauseEvent		= "causeEvent(";

vars
	scm				: Schema;
	schemas			: SchemaColl;
	cls				: Class;
	methods			: MethodSet;
	meth			: Method;
	source,
	token,
	token2			: String;
	sourceLen,
	causeLen,
	pos,
	pos2			: Integer;
	log				: File;
	constant		: Constant;
	processedMeths	: ObjectSet;
	
begin
	causeLen := CauseEvent.length();
	
	create log transient;
	log.openOutput("c:\temp\CauseEvent\method_list_" &amp; app.actualTime.getNumeralString() &amp; ".log");
	
	create schemas transient;
	rootSchema.withAllSubschemas(schemas);
	
	create methods transient;
	create processedMeths transient;
	
	foreach scm in schemas where scm &lt;&gt; rootSchema do
		write "Processing schema " &amp; scm.name;
		
		// check local classes, not superschema classes
		foreach cls in scm.allClasses() where cls.schema = scm do
			write "Processing class " &amp; cls.name;
			
			methods.clear();
			cls.allMethods(methods);
			
			foreach meth in methods do
				if processedMeths.includes(meth) then
					continue;
				endif;
				processedMeths.add(meth);
				
				write "Processing method " &amp; meth.name;
				
				source := self.findPossibleTransLeaksRemFlf(meth.getSource());
				sourceLen := source.length();
				
				pos := 1;
				while pos &lt; sourceLen do
					pos := source.pos(CauseEvent, pos);
					// causeEvent not used in this method
					if pos = 0 then
						break;
					endif;
					
					pos := pos + causeLen;
					if pos &gt; sourceLen then
						break;
					endif;
					
					// get the first parameter to the causeEvent call
					token := source.scanUntil(',;', pos).trimBlanks();
					if pos = 0 then
						break;
					endif;
					
					// if it includes getTerminalEvent then it's probably OK
					if token.pos('getTerminalEvent', 1) &lt;&gt; 0 then
						continue;
					endif;

					// if it includes .mySystemAlertType then it's probably OK
					if token.pos('.mySystemAlertType', 1) &lt;&gt; 0 then
						continue;
					endif;
					
					// if it includes .BGP then it's probably OK
					if token.pos('.BGP', 1) &lt;&gt; 0 then
						continue;
					endif;

					// if it is a "tmpEvent" then it's probably OK
					if token = 'tmpEvent' then
						continue;
					endif;
					
					// if the parameter includes 'event', 'update' and 'voyage' then its probably OK
					token2 := token.toLower();
					if token2.pos('event', 1) &lt;&gt; 0 and token2.pos('voyage', 1) &lt;&gt; 0 and token2.pos('update', 1) &lt;&gt; 0 then
						continue;
					endif;

					
					// if the parameter is an Integer, then check it is valid
					if token.isInteger then
						if token.Integer &gt;= User_Base_Event then
							continue;
						endif;
					endif;
					
					// if the parameter is a constant with an Integer value, then check it
					constant := scm.getConstant(token);		// Global Constant
					if constant = null then
						constant := cls.getConstantInHTree(token);		// Class Constant
					endif;
					if constant = null then
						pos2 := token.reversePosIndex('.', token.length());
						if pos2 &lt;&gt; 0 then
							token2 := token[pos2+1:end];
							constant := cls.getConstantInHTree(token2);		// Class Constant (as objref.&lt;constant&gt;)
						endif;
					endif;				
					
					if constant &lt;&gt; null then
						if constant.valueAsInteger &gt;= User_Base_Event then
							continue;
						endif;
					endif;
					
					// got to here, then this method needs looking at
					log.writeLine(scm.name &amp; "::" &amp; meth.qualifiedName &amp; " uses causeEvent with " &amp; token);
				endwhile;
			endforeach;
		endforeach;
	endforeach;
	
	log.close();
	
epilog
	delete log;
	delete schemas;
	delete methods;
	delete processedMeths;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdFindControls" id="41c80ae3-624c-437a-8a1a-fbe14d3d7c09">
        <source>kpdFindControls();

/*

Purpose:	This JadeScript will read though all the forms in the named schema(s) below, and
			perform the following checks on specific controls on those forms :

			1. For TextBox controls, look for passwordField set to true
			

Date		Who		Reason
20 Oct 2011	cnwkpd1	PAR #28510 - Logon issues in Windows Mobile 6.5

*/

vars
	schemaNames			: StringArray;
	schemaName			: String;
    targetSchema		: Schema;
   	allFormsInLocale	: FormNameDict;
    form				: Form;
    control				: Control;
    i					: Integer;
	agent				: DEV_ReleaseExtractAgent;
	
begin
	create schemaNames transient;
	create agent transient;
	agent.getReleaseSchemas(schemaNames);
	
	foreach schemaName in schemaNames do
		targetSchema := rootSchema.getSchema(schemaName);

		write "Processing forms for schema " &amp; targetSchema.name;
	
		allFormsInLocale := targetSchema.getBaseLocale.getForms;   
	
		foreach form in allFormsInLocale do
	
			// Now check the controls
			foreach i in 1 to form.controlCount do
				control := form.controls(i);
				if control.isKindOf(TextBox) then
					if control.TextBox.passwordField then
						write schemaName &amp; "::" &amp; form.name &amp; "::" &amp; control.name &amp; ".passwordField = " &amp; true.String;
					endif;				
				endif;
			endforeach;
	
		endforeach;
	endforeach;
	
epilog
	delete schemaNames;
	delete agent;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdFindExportedPackageInfo" id="cb269c32-6d1f-48d7-adc4-31242c5a85c2">
        <source>kpdFindExportedPackageInfo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 January 2016	cnwkpd1	PAR #36286 - Changes for Unicode JADE

*/

vars
	
	jep : JadeExportedPackage;
	jec : JadeExportedClass;

begin

	foreach jep in JadeExportedPackage.instances where jep.name = "MobileHandHeldThin" do
		if jep.isLatestVersion then
			write CrLf &amp; "LATESTVERSION" &amp; CrLf;
		else
			write CrLf &amp; "CURRENTVERSION" &amp; CrLf;
		endif;
		
		foreach jec in jep.getPropertyValue('classes').JadeExportedClassNDict do
			write jec.originalClass.schema.name &amp; "::" &amp; jec.originalClass.name;
		endforeach;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdFindInstanceCreatedAtTime" id="3d60c8cd-68c9-43c2-92bc-fcb7a1018ce2">
        <source>kpdFindInstanceCreatedAtTime();
/*

Purpose:			Find the first instance of a given class created after a given time

Parameters:			None

Return Value:		None

Date		Who		Reason
07 Sep 2017	jlgkpd1	Initial creation

*/

constants
	//ClassToFind		= CM_PortRotation.name;
	TimeToFind		= "06/09/2017 09:00".TimeStamp;
	
vars
	highInstance,
	lowInstance,
	instance		: Integer64;
	lowObj,
	highObj,
	obj				: Object;
	oidStr			: String;
	cls				: Class;
	classToFind		: String;
		
begin
	classToFind		:= CM_PortRotation.name;
	cls := currentSchema.getClass(classToFind);
	if cls = null then
		return;
	endif;
	
	write "Finding instance of " &amp; cls.name &amp; " created after " &amp; TimeToFind.String;
	
	lowObj := cls.firstInstance();
	if lowObj.creationTime() &gt; TimeToFind then
		write "Found instance " &amp; lowObj.String;
		return;
	endif;
	lowInstance := self.getInstanceIdForObject64(lowObj);
	
	highObj := cls.lastInstance();
	if highObj.creationTime() &lt; TimeToFind then
		write "&gt;&gt;&gt;&gt; No instances created after " &amp; TimeToFind.String;
		return;
	endif;
	highInstance := self.getInstanceIdForObject64(highObj);
	
	while true do : outer
		// Find the midpoint
		instance := (lowInstance + highInstance) div 2;
		
		// Find the next valid object from the midpoint
		while instance &lt; highInstance - 1 do
			oidStr := cls.number.String &amp; '.' &amp; instance.String;
			obj := oidStr.asOid;
			
			if app.isValidObject(obj) then
				write "Testing object " &amp; obj.String &amp; " created " &amp; obj.creationTime.String;
				if obj.creationTime &lt; TimeToFind then
					lowObj := obj;
					lowInstance := instance;
				else
					if obj = highObj then
						break outer;
					endif;
					highObj := obj;
					highInstance := instance;
				endif;
			endif;
			
			instance := instance + 1;
		endwhile;

	endwhile;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="kpdFindNonExclusiveColls" id="d947f9a7-a5d2-43b3-a7e5-0beb85802bd9">
        <source>kpdFindNonExclusiveColls();
/*

Purpose:			Find any non-exclusive collections of a named set of classes


Date		Who		Reason
27 Aug 2012	cnwkpd1	PAR #30262 - "Leaking" persistent RootSchema arrays

*/

vars
	classColl		: ClassColl;
	cls				: Class;
	prop			: Property;
	scm				: Schema;
	classNames		: StringArray;
	
begin
	// Add in classes we're interested in here
	create classNames transient;
	classNames.add(StringArray.name);
	classNames.add(HugeStringArray.name);
	classNames.add(PointArray.name);

	create classColl transient;
	
	scm := rootSchema.getSchema(PortSchema.name);
	cls := scm.getClass(Object.name);
	
	cls.allLocalSubclasses(classColl);
	
	foreach cls in classColl do
//		write "Checking class " &amp; cls.name;
		
		foreach prop in cls.getProperties where prop.subId.Integer = 0 do
			if classNames.includes(prop.type.name) then
				write "&gt;&gt;&gt;&gt; " &amp; cls.name &amp; "::" &amp; prop.name &amp; " : " &amp; prop.type.name;
			endif;		
		endforeach;
	endforeach;
	
epilog
	delete classNames;
	delete classColl;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdFindPropertiesAndMethods" id="e943aaa6-96d3-4efd-89d6-573279bee17a">
        <source>kpdFindPropertiesAndMethods();

/*

Purpose:			Find properties and methods containing any one of a series of strings

Parameters:			None

Return Value:		None


Date		Who		Reason
07 Aug 2008	cnwkpd1	APM - find lengths, heights and weights

*/

vars
	strings			: StringArray;
	features		: ObjectArray;
	feature			: Feature;
	iter			: Iterator;
	keyString		: String;
	count			: Integer;
	
	dict			: ObjectLongNameDict;
	file			: File;
		
begin
	create strings transient;
	strings.add("weight");
	strings.add("height");
	strings.add("length");
	strings.add("volume");
	
	create dict transient;
	
	create features transient;
	iter := features.createIterator();
	
	Property.allInstances(features, 0, true);
	
	while iter.next(feature) do
		if self.kpdFindPropsCheckName(feature.name.toLower, strings) then
			keyString := feature.schemaType.schema.name.padBlanks(32) &amp; 
 						 feature.schemaType.name.padBlanks(32) &amp;
						 feature.name;
			app.writeStatement( keyString);
			if not dict.includesKey(keyString) then
				dict.putAtKey(keyString, feature);
			endif;
		endif;
		
		count := count + 1;
		if count mod 10000 = 0 then
			app.writeStatement( count.String &amp; " properties checked");
		endif;
	endwhile;
	
	features.clear();
	iter.reset;
	
	JadeMethod.allInstances(features, 0, true);
	
	while iter.next(feature) do
		if self.kpdFindPropsCheckName(feature.name.toLower, strings) then
			keyString := feature.schemaType.schema.name.padBlanks(32) &amp; 
 						 feature.schemaType.name.padBlanks(32) &amp;
						 feature.name;
			app.writeStatement( keyString);
			if not dict.includesKey(keyString) then
				dict.putAtKey(keyString, feature);
			endif;
		endif;
		
		count := count + 1;
		if count mod 10000 = 0 then
			app.writeStatement( count.String &amp; " methods checked");
		endif;
	endwhile;
	
	create file transient;
	file.openOutput("c:\temp\measurement_properties.txt");
	
	app.writeStatement( "Finished, " &amp; dict.size.String &amp; " matching features found, writing to file " &amp; file.fileName);
	
	delete iter;
	iter := dict.createIterator();
	while iter.next(feature) do
		file.writeLine(feature.schemaType.schema.name &amp; Tab &amp; 
					   feature.schemaType.name &amp; Tab &amp;
					   feature.name &amp; Tab &amp;
					   feature.class.name);
	endwhile;
	
	app.writeStatement( "File creation complete");
	
	
epilog
	delete dict;
	delete iter;
	delete features;
	delete strings;
	delete file;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdFindPropsCheckName" id="5f85c452-bd4a-4e2f-b79e-1211852e1510">
        <source>kpdFindPropsCheckName(_name : String; _substrings : StringArray) : Boolean;

/*

Purpose:			Check the passed in name to see if it contains any of the strings in substrings

Parameters:			name to check and array of substrings

Return Value:		Trus if the name contains one or more of the substrings


Date		Who		Reason
07 Aug 2008	cnwkpd1	APM - imperial measurements

*/

vars
	s				: String;
	
begin
	foreach s in _substrings do
		if _name.pos(s, 1) &gt; 0 then
			return true;
		endif;
	endforeach;
	
	return false;
	
	
epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_substrings" type="StringArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="kpdFixJadeUserProfiles" id="293bf988-1fc6-488d-9726-9b0f26328efd">
        <source>kpdFixJadeUserProfiles();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 Jan 2009	cnwkpd1	JADE PAR #49153 - Debugger performance issues

*/

constants
	SaveOnExit_BubbleInspector = 1; 	// Checked | Checked
    SaveOnExit_None = 2; 				// Unchecked | Unchecked
    SaveOnExit_Only = 3; 				// Checked | Unchecked
	
vars
    jadeUserProfile : JadeUserProfile;
	currentValue : Integer;
	
begin
    foreach jadeUserProfile in JadeUserProfile.instances do
		currentValue := jadeUserProfile.getPropertyValue("debugOptions").Integer;
		
		write jadeUserProfile.getName.padBlanks(30) &amp; Tab &amp; currentValue.String;
		
		if currentValue &lt;&gt; SaveOnExit_Only then
			beginTransaction;
			jadeUserProfile.setPropertyValue("debugOptions", SaveOnExit_Only);
			commitTransaction;
		endif;
    endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="kpdFixUnicodeCMStrings" id="7c95997c-cf6d-458d-b88d-f5d78f42d4b8">
        <source>kpdFixUnicodeCMStrings();
/*

Purpose:			Conversion script to be run in a converted Unicode environment to 
					fix up any CM_Strings objects

Parameters:			None

Return Value:		None

Date		Who		Reason
06 Jul 2015	cnwkpd1	PAR #36286 - Changes for Unicode JADE

*/

constants
	NullCharacter	= #[00 00];
	
vars
	cmStrings		: CM_Strings;
	strings			: HugeStringArray;
	convertedFile,
	errorsFile,
	nochangeFile	: File;
	oldSize			: Integer;
	now				: TimeStamp;
	count			: Integer;
	first			: String;
	
begin
	if not app.isUnicode then
		write "This method can only be run in a Unicode environment";
		return;
	endif;
	
	write "Processing " &amp; CM_Strings.countPersistentInstances().String &amp; " instances";
	
	now := app.actualTimeServer;
	
	create convertedFile transient;
	convertedFile.openOutput("c:\temp\FixUnicodeCMStrings_converted_" &amp; now.getNumeralString &amp; ".log");
	write "Logging converted output to " &amp; convertedFile.fileName;

	create errorsFile transient;
	errorsFile.openOutput("c:\temp\FixUnicodeCMStrings_errors_" &amp; now.getNumeralString &amp; ".log");
	write "Logging errors output to " &amp; errorsFile.fileName;

	create nochangeFile transient;
	nochangeFile.openOutput("c:\temp\FixUnicodeCMStrings_nochange_" &amp; now.getNumeralString &amp; ".log");
	write "Logging no change output to " &amp; nochangeFile.fileName;
	
	create strings transient;
	
	beginTransaction;
	
	foreach cmStrings in CM_Strings.instances do
		count := count + 1;
		if count mod 10000 = 0 then
			write count.String &amp; " instances processed";
		endif;
		
		if cmStrings.size() = 0 then			// nothing to convert
			self.kpdFixUnicodeWriteFile(nochangeFile, cmStrings, "Empty");
			continue;
		endif;
		
		if cmStrings.bstrings.posBinary(NullCharacter, 1) &gt; 0 then		// is already a Unicode version
			self.kpdFixUnicodeWriteFile(nochangeFile, cmStrings, "Valid Unicode");
			continue;
		endif;
		
		oldSize := cmStrings.size();
		
		self.kpdFixUnicodeGetStrings(cmStrings.bstrings, strings);
		
		if strings.size() = oldSize then
			self.kpdFixUnicodeWriteFile(convertedFile, cmStrings, "Before");
			cmStrings.clear();
			cmStrings.addStrings(strings);
			self.kpdFixUnicodeWriteFile(convertedFile, cmStrings, "After");
		elseif oldSize = 1 then			// Special case, can just convert Binary to Unicode String (no nulls)
			self.kpdFixUnicodeWriteFile(convertedFile, cmStrings, "Before");
			first := cmStrings.at(1);
			cmStrings.clear();
			cmStrings.add(first);
			self.kpdFixUnicodeWriteFile(convertedFile, cmStrings, "After (Special)");
		else
			self.kpdFixUnicodeWriteFile(errorsFile, cmStrings, "New size is " &amp; strings.size().String);
			
			cmStrings.clear();
		endif;
		
	endforeach;
	
	abortTransaction;

	convertedFile.close();
	nochangeFile.close();
	errorsFile.close();
	
	write "Finished, " &amp; count.String &amp; " instances processed";
	
epilog
	delete convertedFile;
	delete nochangeFile;
	delete errorsFile;
	delete strings;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdFixUnicodeGetStrings" id="9237535c-f38b-4004-bb05-1040f909d59b">
        <source>kpdFixUnicodeGetStrings(_bin : Binary;
						_strings : HugeStringArray input);
/*

Purpose:			Emulates the old CM_Strings getStrings behaviour to allow conversion
					of the data in a Unicode database that has been converted from ANSI

Parameters:			Binary from a converted CM_Strings object as input
					HugeStringArray to return the resulting data

Return Value:		HugeStringArray populated with the values from the passed in Binary

Date		Who		Reason
06 Jul 2015	cnwkpd1	PAR #36286 - Changes for Unicode JADE

*/

vars
	pointer : Integer;
	tStr : String;
	lenStr : Integer;

begin
	_strings.clear();
	
	lenStr := _bin.length();

	pointer := 1;
	while pointer &lt;= lenStr do
		tStr := _bin.unpackCString(pointer);
		_strings.add(tStr[1:2047].trimBlanks);		//protect against String Too Long 
		pointer := pointer + tStr.length + 1;
	endwhile;
	
epilog

end;</source>
        <Parameter name="_bin" type="Binary"/>
        <Parameter name="_strings" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="kpdFixUnicodeWriteFile" id="487d547a-29da-4fd6-8808-7d964a66e4fb">
        <source>kpdFixUnicodeWriteFile(_file : File input;
					   _strings : CM_Strings;
					   _message : String);
/*

Purpose:			Write details of passed in CM_Strings object to the passed in file

Parameters:			

Return Value:		

Date		Who		Reason
09 Jul 2015	cnwkpd1	PAR #36286 - Changes for Unicode JADE

*/

vars
	first			: String;
	
begin
	if _strings.size() &gt; 0 then
		first := _strings.at(1);
	endif;
	
	_file.writeLine(self.getObjectStringForObject(_strings) &amp; "," &amp; 
					_strings.creationTime().asStringJMT() &amp; "," &amp; 
					_strings.size().String &amp; "," &amp; 
					"|" &amp; first &amp; "|" &amp; "," &amp; 
					_message);
	
epilog

end;</source>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_strings" type="CM_Strings"/>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
    <JadeMethod name="kpdFixYADataObjects" id="29c6cf87-8408-4b52-a9ea-bd1430f722b0">
        <source>kpdFixYADataObjects();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 September 2009	cnwkpd1	PAR #19112 - New IsAvailable YA Criteria

*/

vars
	oa 				: ObjectArray;
	yado 			: CM_YADataObjects;
	o 				: Object;
	iter 			: Iterator;
	invalidCount 	: Integer;
	badOnes			: ObjectSet;
	
begin
	create oa transient;
	CM_YADataObjects.allInstances(oa, 0, true);
	
	create badOnes transient;
	
	iter := oa.createIterator();
	while iter.next(yado) do
		foreach o in yado.allObjects where not app.isValidObject(o) do
			badOnes.addNoDuplicates(yado, false);
			break;
		endforeach;
	endwhile;
	
	badOnes.inspectModal();
	
	delete iter;
	iter := badOnes.createIterator();
	
	while iter.next(yado) do
		write "Tidying up " &amp; yado.String;
		beginTransaction;
		yado.allObjects.removeInvalidObjects();
		commitTransaction;
	endwhile;
	
	
epilog
	delete oa;
	delete badOnes;
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdForceMachineDeadlock" id="5f0a8997-c8d9-4d73-8770-6aeb00653512">
        <source>kpdForceMachineDeadlock();
/*

Purpose:			Can be used to generate a deadlock in a Machine working a Discharge.
					Sequence of testing required:
					
					1. Set constant values to match the terminal, machine, voyage and container to discharge
					2. Move the Machine to the correct crane queue for the voyage
					3. Enter Discharge mode on the device
					4. Enter the container number in the search box on the device, click Find
					5. Check that the container is displayed in the table
					6. Run this script, and wait for the first dialog to display
					7. On the Machine, select the container line, and click Accept
					8. When the device displays the hourglass, click OK on the JadeScript dialog - this shoudl result in a deadlock 
					   on the Machine 


Date		Who		Reason
14 Dec 2012	cnwkpd1	PAR #30799 - Force a Machine to get a deadlock in Crane Pickup

*/

constants
	TestTerminal	= "DP1";
	TestVoyageCode	= "KPD001";
	TestContainerID	= "SHIP1112231";
	TestMachineID	= "FLKD";
	
vars
	term			: CM_Terminal;
	voyage			: CM_Voyage;
	ti				: CM_TrackedItem;
	machine			: CM_Machine;
	str				: String;
	
begin
	app.initialize();
	
	process.setPersistentDeadlockPriority(999);
	
	term := app.myRoot.allTerminals[TestTerminal];
	if term = null then
		return;
	endif;
	
	voyage := term.allVoyagesByCode.getAtKeyGeq(TestVoyageCode, null);
	if voyage = null or voyage.code &lt;&gt; TestVoyageCode then
		return;
	endif;
	
	ti := voyage.allOnshipTIsByCargoTypeId[TI_CargoType_Container, TestContainerID];
	if ti = null then
		return;
	endif;
	
	machine := term.machines[TestMachineID];
	if machine = null then
		return;
	endif;
	
	exclusiveLock(machine.myPrimaryQueue.allEntries);
	
	str := "Queue entries locked, click OK to lock ti";
	read str;
	
	exclusiveLock(ti);
	
	str := "TI locked, click OK to release locks";
	read str;
	
	unlock(machine.myPrimaryQueue.allEntries);
	unlock(ti);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="kpdForceMachineDeadlock2" id="8922e2c5-7c15-4b08-925f-dd7699938670">
        <source>kpdForceMachineDeadlock2();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 January 2013	cnwndl1	Initial creation

*/

/*

Purpose:			Can be used to generate a deadlock in a Machine accepting a twin or tandem containers moves.
					Sequence of testing required:
					
					1. Set constant values to match the terminal, and the two containers to move
					2. Move the Machine to the queue with the twin liftable moves
					3. Select the two boxes in order 1 and 2 on the machine
					4. Run this script, and wait for the first dialog to display.
					5. On the Machine, click Accept (Locks the 1st box and attempts to then lock the second )
					6. When the device displays the hourglass, click OK on the JadeScript dialog - this should result
						in a deadlock on the Machine. 


Date		Who		Reason
14 Dec 2012	cnwkpd1	PAR #30799 - Force a Machine to get a deadlock in Crane Pickup

*/

constants
	TestTerminal	= "NDL";
	TestContainerID1	= "THOM1234002";
	TestContainerID2	= "THOM1234003";
	
vars
	term			: CM_Terminal;
	ti1				: CM_TrackedItem;
	ti2				: CM_TrackedItem;
	str				: String;
	
begin
	app.initialize();
	
	process.setPersistentDeadlockPriority(999);
	
	term := app.myRoot.allTerminals[TestTerminal];
	if term = null then
		return;
	endif;

	
	ti1 := term.allOnsiteTIsByCargoTypeId[TI_CargoType_Container, TestContainerID1];
	if ti1 = null then
		return;
	endif;
	ti2 := term.allOnsiteTIsByCargoTypeId[TI_CargoType_Container, TestContainerID2];
	if ti2 = null then
		return;
	endif;
	
	
	exclusiveLock(ti2);
	
	str := "2nd TI Locked, click OK to lock ti";
	read str;
	
	exclusiveLock(ti1);
	
	str := "1st TI locked, click OK to release locks";
	read str;
	
	unlock(ti2);
	unlock(ti1);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="kpdFormatXMLFile" id="e576ef70-d9b7-4bbc-b86c-d593e7915770">
        <source>kpdFormatXMLFile();
/*

Purpose:			Format an XML file using the JADE XML classes

Parameters:			

Return Value:		

Date		Who		Reason
01 Sep 2014	cnwkpd1	PAR #34713 - .NET EDI transform integration

*/

vars
	cmd				: CMDFileOpen;
	xml				: JadeXMLDocument;
	
begin
	create cmd transient;
	cmd.initDir := "c:\temp\XSDTest";
	
	if cmd.open() = 0 then
		create xml transient;
		
		xml.parseFile(cmd.fileName);
		
		xml.indentString := Tab;
		
		xml.writeToFile(cmd.fileName &amp; ".new");
	endif;
	
epilog
	delete cmd;
	delete xml;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdGenerateStripSourceBatFile" id="62ef12f2-96e2-4a23-9c4e-eafc93f1e594">
        <source>kpdGenerateStripSourceBatFile();
/*

Purpose:			Generate a batch file to strip all the sources from a JMT environment

Date		Who		Reason
01 Mar 2012	cnwkpd1	Initial creation

*/

constants
	DBPath			= "d:\JBLTest\server\c_system";
	BinPath			= "d:\JBLTest\server\c_bin";
	IniFile			= "d:\JBLTest\JBLTest.ini";
	BatchFile		= "c:\temp\strip_sources_JBLTest.bat";
	
vars
	schemas			: StringArray;
	agent			: DEV_ReleaseExtractAgent;
	f				: File;
	scm				: String;
	command			: String;
	
begin
	create agent transient;
	create schemas transient;
	
	agent.getReleaseSchemas(schemas);
	
	create f transient;
	f.openOutput(BatchFile);
	
	foreach scm in schemas do
		command := BinPath &amp; "/jadloadb.exe path=" &amp; DBPath &amp; " ini=" &amp; IniFile;
		command := command &amp; " executeSchema=RootSchema executeClass=Schema executeMethod=_removeSourceFromSchema executeParam=";
		command := command &amp; scm;
		
		f.writeLine(command);
	endforeach;
	
	f.close();
	
epilog
	delete f;
	delete schemas;
	delete agent;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdGenerateWSGetReqTemplate" id="04c6501b-41fb-4631-8f44-78ed227e1daa">
        <source>kpdGenerateWSGetReqTemplate() : String;
/*

Purpose:			Return a schema file template for a generated Web Service wrapper class which
					is used as part of a request to an External Web Service

Parameters:			None

Return Value:		Method template, with tags marking the insert points

Date		Who		Reason
05 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	returnVal		: String;
	
begin
	returnVal := 
'jadeVersionNumber "7.1.08";
schemaDefinition
&lt;&lt;OutputSchema&gt;&gt; subschemaOf &lt;&lt;OutputSuperschema&gt;&gt; partialDefinition, patchVersion=7, patchVersioningEnabled = true;

typeHeaders
	&lt;&lt;OutputClass&gt;&gt; subclassOf &lt;&lt;OutputSuperclass&gt;&gt; transient, transientAllowed, subclassTransientAllowed, highestOrdinal = 2, number = 10051;
 
membershipDefinitions
 
typeDefinitions
	&lt;&lt;OutputClass&gt;&gt; completeDefinition
	(
		setModifiedTimeStamp "&lt;&lt;User&gt;&gt;" "7.1.08" 7 &lt;&lt;GenerationTimestamp&gt;&gt;;
	attributeDefinitions
&lt;&lt;AttributeDefinitions&gt;&gt; 
	jadeMethodDefinitions
		copyToRealWSObject(_realRequest: &lt;&lt;InputClass&gt;&gt; input; _createdObjects : ObjectSet input) number = 1001;
		setModifiedTimeStamp "&lt;&lt;User&gt;&gt;" "7.1.08" 7 &lt;&lt;GenerationTimestamp&gt;&gt;;
	)
 
inverseDefinitions
databaseDefinitions
 
typeSources
	&lt;&lt;OutputClass&gt;&gt; (
	jadeMethodSources
copyToRealWSObject
{
copyToRealWSObject(_realRequest: &lt;&lt;InputClass&gt;&gt; input;
				   _createdObjects : ObjectSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
&lt;&lt;LongDate&gt;&gt;	&lt;&lt;User&gt;&gt;	#37190 - Pelindo 1 INAPORTNET Integration

*/

vars

begin
	inheritMethod(_realRequest, _createdObjects);
	
&lt;&lt;CopyAttributesToRequest&gt;&gt;
epilog

end;
}

	)
';
	
	return returnVal;	
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="kpdGenerateWSGetRespTemplate" id="1a1ebdfa-245c-4d5e-85cd-2fbbbcce17bd">
        <source>kpdGenerateWSGetRespTemplate() : String;
/*

Purpose:			Return a schema file template for a generated Web Service wrapper class which
					is used as part of a response from an External Web Service

Parameters:			None

Return Value:		Method template, with tags marking the insert points

Date		Who		Reason
05 Jun 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	returnVal		: String;
	
begin
	returnVal := 
'jadeVersionNumber "7.1.08";
schemaDefinition
&lt;&lt;OutputSchema&gt;&gt; subschemaOf &lt;&lt;OutputSuperschema&gt;&gt; partialDefinition, patchVersion=7, patchVersioningEnabled = true;

typeHeaders
	&lt;&lt;OutputClass&gt;&gt; subclassOf &lt;&lt;OutputSuperclass&gt;&gt; transient, transientAllowed, subclassTransientAllowed, highestOrdinal = 2, number = 10051;
 
membershipDefinitions
 
typeDefinitions
	&lt;&lt;OutputClass&gt;&gt; completeDefinition
	(
		setModifiedTimeStamp "&lt;&lt;User&gt;&gt;" "7.1.08" 7 &lt;&lt;GenerationTimestamp&gt;&gt;;
	attributeDefinitions
&lt;&lt;AttributeDefinitions&gt;&gt; 
	jadeMethodDefinitions
		setFromRealWSObject(_realWSObject: &lt;&lt;InputClass&gt;&gt;) updating, number = 1001;
		setModifiedTimeStamp "&lt;&lt;User&gt;&gt;" "7.1.08" 7 &lt;&lt;GenerationTimestamp&gt;&gt;;
	)
 
inverseDefinitions
databaseDefinitions
 
typeSources
	&lt;&lt;OutputClass&gt;&gt; (
	jadeMethodSources
setFromRealWSObject
{
setFromRealWSObject(_realWSObject: &lt;&lt;InputClass&gt;&gt;) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
&lt;&lt;LongDate&gt;&gt;	&lt;&lt;User&gt;&gt;	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars

begin
	inheritMethod(_realWSObject);
	
&lt;&lt;CopyAttributesFromResponse&gt;&gt;
epilog

end;
}

	)
';
	
	return returnVal;	
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="kpdGenerateWSSAPAgentTestSingle" id="723b4541-f2be-4e35-be19-3580ae86f017">
        <source>kpdGenerateWSSAPAgentTestSingle();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2018	jlgkpd1	TFS #37190 - Pelindo 1 INAPORTNET Integration

*/

vars
	ca 				: CM_SAPWSConsumerAgent;
	req				: CMIF_SAPGetExchRateReq;
	resp 			: CMIF_SAPGetExchRateResp;
	
begin
	app.initialize();
	
	create ca transient;
	ca.usercode := "IGMT_USER";
	ca.password := "igateway01";
	
	write ca.getDefaultBaseEndpoint;
	
	create req transient;
	req.date := "20180101";
	req.exRateType := "M";
	req.fromCurr := "USD";
	req.toCurr := "IDR";
		
	write req.returnAsXMLString() &amp; CrLf;
		
	write "Calling Web Service getExchangeRateRequest_SI";
		
	resp := ca.getExchangeRateRequest_SI(req);
		
	if resp &lt;&gt; null then
		write resp.returnAsXMLString();
	else
		write "&gt;&gt;&gt;&gt; Error, null response";
	endif;
	
epilog
	delete ca;
	delete req;
	delete resp;
	app.finalize();
	
end;
</source>
