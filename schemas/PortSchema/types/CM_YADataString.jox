    <JadeMethod name="isValueUsed" id="4054cbeb-a789-450c-9241-795ed0c46913">
        <source>isValueUsed(_allValues: Any): Boolean;
// --------------------------------------------------------------------------------
// Created:		11 March 2010 by consw1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 11 Mar 2010	consw1	PAR #22784 - Initial creation
// --------------------------------------------------------------------------------
vars
	paramValue	: String;
	
begin
	foreach paramValue in _allValues.StringArray do
		if paramValue = self.value then
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <Parameter name="_allValues" type="Any"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
