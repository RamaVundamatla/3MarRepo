    <JadeMethod name="addOperatorGroup" id="e1172c4a-4faa-4ed0-a921-77c2590be2ae">
        <source>addOperatorGroup(_operatorGroupCode, _operatorGroupDesc : String) : CM_OperatorGroup;

/*

Purpose:		Create an operator group

Date			Who		Reason
06/03/2014		cnwmh5	Initial creation

*/

vars

	pxyOperatorGroup				: CM_OperatorGroup;
	operatorGroup					: CM_OperatorGroup;
	
	codeGroups						: CM_CodeGroupsByTypeDict;

begin

	self.deleteOperatorGroup(_operatorGroupCode);

	create codeGroups transient;
	
	create pxyOperatorGroup transient;
	pxyOperatorGroup.setProxy(_operatorGroupCode, _operatorGroupDesc, codeGroups, true);
	
	app.myTrxCA.trxCreateOperatorGroup(pxyOperatorGroup, operatorGroup, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	return operatorGroup;

epilog

	delete codeGroups;
	delete pxyOperatorGroup;

end;</source>
