    <JadeMethod name="doSave" id="8931a64b-bd22-43d4-bc4f-d051dc3e7b48">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	pxyCgAssign : CM_CargoGroupAssignment;
	id : String;
	result : Integer;

begin

	id := self.tblCGInput.getValueByName( ETRow_AssignmentId ).String;

	if self.mode = Mode_Add then
		create pxyCgAssign transient;
		pxyCgAssign.setBaseProxy( id, self.myTerminal );
	elseif self.mode = Mode_Update then
		pxyCgAssign := self.myProxyObject.CM_CargoGroupAssignment;
		pxyCgAssign.setId( id );
	else
		return false;
	endif;
	
	
	while true do
		if self.mode = Mode_Add then
			app.myTrxCA.trxCreateCGAssignment( pxyCgAssign, self.myCurrentObject, app.myPassport );
		elseif self.mode = Mode_Update then
			app.myTrxUA.trxUpdateCGAssignmentId( pxyCgAssign, app.myPassport );
		endif;
	
		if not app.myPassport.trxCompletedOK then
			result := app.showErrorWarningDialog(app.getErrorString(Cargo_group_notified), app.myPassport, ErrWarnMode_AddUpdate);
			
			if app.myPassport.noErrors and result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
					
			return false;
			
		else
			return true;
			
		endif;
	endwhile;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getTblCGNXML" id="c9b5aa9f-fb67-4966-ab04-4d5b9ddea9d0">
        <updating/>
        <source>getTblCGNXML(_userWindow: CM_UserWindow) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	tmpStr	: String;

begin

	tmpStr := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.tblCGN.XMLTag_Table &amp; self.tblCGN.name);
	self.xmlStrTblCGN := global.formatAsXMLPrefix(self.tblCGN.XMLTag_Table &amp; self.tblCGN.name) &amp; tmpStr &amp; global.formatAsXMLSuffix(self.tblCGN.XMLTag_Table &amp; self.tblCGN.name);


epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="cda8bf0e-8c59-4518-9dbd-36d1f8cd7faf">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

	str : String;

begin

	str := inheritMethod();
	
	str := str &amp; self.xmlStrTblCGN;
	
	return str;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="includeObjectCGAssign" id="3899dee5-2739-4649-b13e-45616efc2cee">
        <updating/>
        <source>includeObjectCGAssign( _cgAssign : CM_CargoGroupAssignment; _numItems : Integer; _breakOut : Boolean output ): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 July 2018	jlgndl1	Initial creation	TFS 39186

*/

vars

begin

	if self.filterCGAId &lt;&gt; null then
		if _cgAssign.id.pos( filterCGAId, 1 ) &lt; 1 then
			return false;
		endif;
	endif;
	
	if self.filterCGId &lt;&gt; null then
		if not _cgAssign.notifiedIncludesId(filterCGId) then
			return false;
		endif;
	endif;
	
	if self.filterEdiTSFrom.date.isValid or self.filterEdiTSTo.date.isValid then
		if not _cgAssign.isEdiLoadedBetween( self.filterEdiTSFrom, self.filterEdiTSTo ) then
			return false;
		endif;
	endif;
	
	if self.filterGrpCompTSFrom.date.isValid or self.filterGrpCompTSTo.date.isValid then
		if not _cgAssign.isCompletedBetween( self.filterGrpCompTSFrom, self.filterGrpCompTSTo ) then
			return false;
		endif;
	endif;
	
	if self.filterStatus = 1 then  // not complete
		if not _cgAssign.isInProgress then
			return false;
		elseif _cgAssign.isCompleted then
			return false;
		endif;
		
	elseif self.filterStatus = 2 then// completed
		if not _cgAssign.isInProgress then
			return false;
		elseif not _cgAssign.isCompleted then
			return false;
		endif;
	elseif self.filterStatus = 3 then// Not started
		if _cgAssign.isInProgress then
			return false;
		endif;
	endif; 

	if self.filterAssignmentType = 1 then	//	Selectable
		if not _cgAssign.isSelectable then
			return false;
		endif;
		
	elseif self.filterAssignmentType = 2 then	//	Pre-assigned
		if not _cgAssign.isPreAssigned then
			return false;
		endif;
	endif;
	
	if self.filterCargoType &lt;&gt; null then
		if self.filterSubCargoType &lt;&gt; null then
			if not _cgAssign.notifiedIncludesSubCargoType(filterSubCargoType) then
				return false;
			endif;
		else
			if not _cgAssign.notifiedIncludesCargoType(filterCargoType) then
				return false;
			endif;
		endif;
	endif;

	return true;

epilog

end;</source>
        <Parameter name="_cgAssign" type="CM_CargoGroupAssignment"/>
        <Parameter name="_numItems" type="Integer"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
