    <JadeMethod name="buildSelf" id="135b9aab-5436-4fdd-b1ac-a30649745927">
        <updating/>
        <source>buildSelf() updating, protected;
// --------------------------------------------------------------------------------
// Created:		20 February 2006 by cnwdad1
//
// Purpose:		Instantiates the appropriate controls, and sets them all up.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	controlWidth	: Real;
	controlLeft		: Real;
	comboboxObj		: CMUI_FieldComboBoxControl;
	
begin
	inheritMethod();
	
	create comboboxObj transient;
	
//	self.height := self.height - 10;
	
	self.myComboBox		:=	comboboxObj;
	comboboxObj.parent	:=	self;
	self.form.addControl(comboboxObj);
	controlLeft			:=	self.myLabel.left + self.myLabel.width + CMUI_FieldFrame.HORIZONTAL_SPACING;
	controlWidth		:=	self.clientWidth() - controlLeft;
	comboboxObj.move(controlLeft, 0, controlWidth, comboboxObj.height);
	
	if app.doNotFIlterCombos then // ### TFS 55105 07NOV2022 NAVAB1
		comboboxObj.style	:= comboboxObj.Style_DropDownComboList; // ### TFS 55105 07NOV2022 NAVAB1
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
