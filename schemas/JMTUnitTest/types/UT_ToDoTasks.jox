    <JadeMethod name="basicCreateCM_ResourceType" id="1d98d4ba-4bf1-4fe7-a682-3a00f1132408">
        <source>basicCreateCM_ResourceType( lCode : String; _autoApplyResourceType : CM_ResourceType ) : CM_ResourceType protected;
//cnwndl1
/*

Purpose:			

Parameters:			

Return Value:		


Date		     Who		Reason
11 January 2010	 cnwndl1	Initial creation	CCMS MES 1006
02 Nov	   2022  navds20    ChangeRequest 56635:[54261] EUP - Todo Task Resources Maintenance
23.12.2022       navds21    ChangeRequest 54349[54262]: EUP - Enable Is Mandatory for ToDo Task Resources
01 Dec 2023 	 navlc30 	ChangeRequest 60748: EUP | VAS Mobile App - [53813.070] [BackEnd] Automatic VAS Resources
*/

vars

	lDescription : String;
	lNumDecimals : Integer;
	lUnitDescription : String;
	lHasBeenUsed : Boolean;
	lIsAvailable : Boolean;
	lIsFromToDateTimeRequired : Boolean;		//cnwmc5 - 22 Sep 2015 - PAR 36920
	
	toDoColl : CM_ToDoTaskDescBySortKey;
	transTypeSet : CM_TransactionTypeSet;
	transResourceBrokers : CM_TransSBByTransTypeType;//CM_TransResourceBrokerDict;
	eventTypes : CM_EventTypeByTypeDict;
	
	proxy : CM_ResourceType;
	real : CM_ResourceType;
	isMandatory : Boolean; //23.12.2022 navds21 TFS #54349[54262]
begin

	real := app.myRoot.allTaskResourceTypes[lCode];
	if real &lt;&gt; null then
		return real;
	endif;

	create proxy transient;
	create toDoColl transient;
	create transTypeSet transient;
	create transResourceBrokers transient;
	create eventTypes transient;
	
	lDescription := lCode &amp; "(Description)";
	lNumDecimals := 2;
	lUnitDescription := "Hours";
	lHasBeenUsed := false;
	lIsAvailable := true;
	lIsFromToDateTimeRequired := false;
	
	//23.12.2022 navds21 TFS #54349[54262]
	if self.opts.includesKey("IsMandatory") then
		isMandatory := self.opts.bool("IsMandatory");
	endif;
	//23.12.2022 navds21 TFS #54349[54262]
	
	/*proxy.setProxy(lCode, lDescription, lNumDecimals, lUnitDescription, lHasBeenUsed, 											//01.12.2023 navlc30 #60748
	lIsAvailable, toDoColl, eventTypes, transTypeSet, transResourceBrokers, lIsFromToDateTimeRequired, 
	self.opts.str(JadeCode), null, self.opts.str(UserCode),
	TODO_TYPE_GROUP_TI,isMandatory, null, null);*/		//cnwmc5 - 22 Sep 2015 - PAR 36920 //02/11/2022 navds20 TFS #56635[54261]  //23.12.2022 navds21 TFS #54349[54262]

	proxy.setProxy(lCode, lDescription, lNumDecimals, lUnitDescription, lHasBeenUsed, 
	lIsAvailable, toDoColl, eventTypes, transTypeSet, transResourceBrokers, lIsFromToDateTimeRequired, 								//01.12.2023 navlc30 #60748
	self.opts.str(JadeCode), null, self.opts.str(UserCode),
	TODO_TYPE_GROUP_TI,isMandatory, null, _autoApplyResourceType);

	app.myTrxCA.trxCreateResourceType(proxy, real, app.myPassport);
	
	return real;
		
epilog

	delete proxy;
	
	delete toDoColl;
	delete transTypeSet;
	delete transResourceBrokers;
	delete eventTypes;
end;</source>
        <access>protected</access>
        <Parameter name="lCode" type="String"/>
        <Parameter name="_autoApplyResourceType" type="CM_ResourceType"/>
        <ReturnType type="CM_ResourceType"/>
    </JadeMethod>
    <JadeMethod name="basicCreateCM_TransactionType" id="96ed7190-2ce1-4595-8e7f-47cdc126cbcb">
        <source>basicCreateCM_TransactionType(lDescription : String):CM_TransactionType protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 January 2010	cnwndl1	Initial creation		CCMS MES 1006

*/

vars

	proxy : CM_TransactionType;
	real : CM_TransactionType;
	tmpTransType : CM_TransactionType;
	tmpNum : Integer;
	
begin
  
	real := app.myRoot.allTransactionTypesByDesc[lDescription];
	
	create proxy transient;
	
	tmpTransType := app.myRoot.allTransactionTypes.last;
	if tmpTransType &lt;&gt; null then
		tmpNum := tmpTransType.trxType;
	endif;
	tmpNum := (TransactionTypeJMTMax + 1).max(tmpNum) + 1;
	
	proxy.setProxy(	lDescription,	//_description : String;
					tmpNum,	//_type : Integer;
					TRANS_TYPE_GROUP_TI,	//_group : Integer;
					"CM_Wash",	//_classNameToCreate : String;
					true,	//_canCompleteToDoTask : Boolean;
					app.myRoot	//_root : CM_Root
					);

	app.myTrxCA.trxCreateTransactionType(proxy, real, app.myPassport);
	
	return real;

epilog
	delete proxy;
end;</source>
        <access>protected</access>
        <Parameter name="lDescription" type="String"/>
        <ReturnType type="CM_TransactionType"/>
    </JadeMethod>
    <JadeMethod name="basicCreateInvoiceMappingObjs" id="66562430-d8d4-4e36-91da-894de8117c4f">
        <source>basicCreateInvoiceMappingObjs(	_tranMap : CM_TranMap;	
								_transType : CM_TransactionType;
								_resourceType : CM_ResourceType;
								_transServiceBroker : CM_ServiceBroker output;
								_resourceBroker : CM_ServiceBroker output;
								_errMessage : String output
								) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 January 2010	cnwndl1	Initial creation	CCMS MES 1006

*/

vars
	bank : CM_Bank;
//	tranMap : CM_TranMap;
    serviceMap : CM_TIServiceMap; 
	productGroupMap : CM_ProductGroupMap;
	productMap : CM_ProductMap;
    imexMap : CM_ImexServiceMap;
    contentMap : CM_ContentsMap;
    commodityMap : CM_CommodityMap;
	
	quantityMap : CM_QuantityMap;
	quantityRangeMap : CM_QuantityRangeMap;
	invoiceLineDesc : CM_InvoiceLineDesc;
	invoiceType : CM_InvoiceDesc;
	
	proxyTransServiceBroker : CM_TransServiceBroker;
	proxyResourceBroker : CM_TransResourceServiceBroker;
	
	pxyQRM, realQRM : CM_QuantityRangeMap;
	pxyMapping		: CM_TranMapInvoiceLineMapping;
	
begin

	bank := self.getTerminal.getDefaultCompanyBank();
	
	//kludge to find the first useful commodity map for the terminal, given we can't create the InvoiceSchema based CMIF objects....
	if bank = null then
		_errMessage := "Failed to find CM_Bank";
		return;
	endif;
	
	
//	tranMap := bank.myCurrentTranMapCargo.first;
	if _tranMap = null then
		_errMessage := "Failed to find CM_TranMap";
		return;
	endif;
	
	serviceMap := _tranMap.allTIServices.first;
	if serviceMap = null then
		_errMessage := "Failed to find CM_TIServiceMap";
		return;
	endif;
	
	productGroupMap := serviceMap.allProductGroupMaps.first;
	if productGroupMap = null then
		_errMessage := "Failed to find CM_ProductGroupMap";
		return;
	endif;
	
	productMap := productGroupMap.allProductMaps.first;
    if productMap = null then
		_errMessage := "Failed to find CM_ProductMap";
		return;
	endif;
	
	imexMap := productMap.allImExMaps.first;
	if imexMap = null then
		_errMessage := "Failed to find CM_ImexServiceMap";
		return;
	endif;
	
	contentMap := imexMap.contentsMaps.first;
	if contentMap = null then
		_errMessage := "Failed to find CM_ContentsMap";
		return;
	endif;
	
	commodityMap := contentMap.commoditiesMap.first;
	if commodityMap = null then
		_errMessage := "Failed to find CM_CommodityMap";
		return;
	endif;
         
	create proxyTransServiceBroker transient;
	proxyTransServiceBroker.setProxyTSB(	_transType.classNameToCreate,	//_className : String;
											commodityMap,	//_comMap : CM_CommodityMap;
											_transType	//_tt : CM_TransactionType
											);

	app.myTrxCA.trxCreateInvoiceTMTransaction(proxyTransServiceBroker,_transServiceBroker,app.myPassport);
	if not app.myPassport.trxCompletedOK() then
		_errMessage := app.myPassport.getAllErrorsWarningsAsString();
		return;
	endif;
	
	
	create proxyResourceBroker transient;
	proxyResourceBroker.setProxyTSB(	_transType.classNameToCreate,	//_className : String;
										commodityMap,	//_comMap : CM_CommodityMap;
										_transType	//_tt : CM_TransactionType
										);
	proxyResourceBroker.setResourceTypeAndBroker(	_resourceType,	//_resourceType : CM_ResourceType;
													_transServiceBroker.CM_TransServiceBroker	//_transServiceBroker : CM_TransServiceBroker
													);

	app.myTrxCA.trxCreateInvoiceTMTransaction(proxyResourceBroker,_resourceBroker,app.myPassport);
	if not app.myPassport.trxCompletedOK() then
		_errMessage := app.myPassport.getAllErrorsWarningsAsString();
		return;
	endif;
	
	quantityMap := _resourceBroker.myChildQuantityMap;
	if quantityMap = null then
		_errMessage := "Failed to find CM_QuantityMap";
		return;
	endif;
	
	quantityRangeMap := quantityMap.allQuantityRanges.first;
	if quantityRangeMap = null then
		_errMessage := "Failed to find CM_QuantityRangeMap";
		return;
	endif;
	
	invoiceType := bank.invoiceTypes.first;
	if invoiceType = null then
		_errMessage := "Failed to find a CM_InvoiceDesc - This is part of the static data permanently set up in 'Unit Test' terminal";
		return;
	endif;
	
	invoiceLineDesc := bank.invoiceLineDescriptors.getAtKey("Extra Services").CM_InvoiceLineDesc;
	if invoiceLineDesc = null or not bank.invoiceTypes.includes(invoiceLineDesc.invoiceType) then
		_errMessage := "Failed to find CM_InvoiceLineDesc 'Extra Services' - This is part of the static data permanently set up in 'Unit Test' terminal";
		return;
	endif;

	// change the mapping on the quantity range from 'Void' to 'Extra Services'
	pxyQRM := app.createUpdateProxy(quantityRangeMap).CM_QuantityRangeMap;
	pxyQRM.clear();

	pxyQRM.setProxy(quantityMap, pxyQRM.rangeStart.Integer, pxyQRM.rangeEnd.Integer,0);
// TFS 40620	pxyQRM.allInvoiceLineMaps.putAtKey(0,invoiceLineDesc);
// TFS 40620	pxyQRM.allInvoiceLinesUsed.add(invoiceLineDesc);
	// QNS 2177
	create pxyMapping transient;
	pxyMapping.update(0, invoiceLineDesc, pxyQRM, bank.getInvLineGroupAll(), null, null, null, null, null);
		
	app.myTrxUA.trxUpdateInvoiceTMQtyRange(pxyQRM, app.myPassport);

	if not app.myPassport.trxCompletedOK() then
		_errMessage := app.myPassport.getAllErrorsWarningsAsString();
		return;
	endif;
	
	
epilog

	delete proxyTransServiceBroker;
	delete proxyResourceBroker;
	delete pxyQRM;
	
end;</source>
        <access>protected</access>
        <Parameter name="_tranMap" type="CM_TranMap"/>
        <Parameter name="_transType" type="CM_TransactionType"/>
        <Parameter name="_resourceType" type="CM_ResourceType"/>
        <Parameter name="_transServiceBroker" type="CM_ServiceBroker" usage="output"/>
        <Parameter name="_resourceBroker" type="CM_ServiceBroker" usage="output"/>
        <Parameter name="_errMessage" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="tAutoToDoTaskComplete" id="77a805f1-37be-4bbd-bd65-8e0d4dade4ed">
        <source>tAutoToDoTaskComplete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Aug 2016	cnwmp6	Initial creation	TFS 2443
23 Jan 2023	navma1	ChangeRequest 54349[54262]: EUP - Enable Is Mandatory for ToDo Task Resources
*/
constants
	ToDoDesc = 'UT Auto To Do Task';
	ToDoShort = 'UT Auto ToDo';
	Completion = QUEUE_MODE;
	Creation = PLANNING_MODE;
	ContainerId = "UTMP0000011";
	CargoID = "UTMP0000012";

vars
	toDoTask: CM_ToDoTaskDesc;
	term: CM_Terminal;
	pxyObjMatch,
	realObjMatch: CM_ObjectMatchCriteria;
	actions: IntegerArray;
	container,
	cargo: CM_TrackedItem;
	packTIs: CM_TIArray;
	tiToDo: CM_TiToDoTask;
	tiSet: CM_TISet;
	found: Boolean;
	toDoComp: CM_ToDoTask;
	availableResourceGroups,
	mandatoryResourceGroups		: CM_ResourceTypeGroupByCode;
	
begin
	term := self.getTerminal();
	self.assertNotNullMsg(term, "Test 1 - terminal");

	// delete todo taks
	toDoTask := app.myRoot.allToDoTaskDescsByShortDesc.getAtKey(ToDoShort);
	if toDoTask &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTask);
	endif;
	// create basic to do task
	toDoTask := self.basicCreateCM_ToDoTaskDesc(ToDoDesc, ToDoShort, null, null, null); 
	self.assertNotNullMsg(toDoTask, "Test 2 - to do task not created");
	self.assertTrueMsg(app.myPassport.noErrors, "Test 3 - " &amp; app.myPassport.getAllErrorsAndWarningsAsStr());
	
	// add attributes to make to do task apply automatically
	create actions transient;
	actions.add(TRANS_TYPE_PackComplete);
	actions.add(TRANS_TYPE_UnpackComplete);
	assertEqualMsg(actions.size(), 2, "Test 4 - wrong number of children");
	create pxyObjMatch as CM_TaskCriteria transient;
	create availableResourceGroups transient;
	create mandatoryResourceGroups transient;
	pxyObjMatch.CM_TaskCriteria.setProxyBaseData(actions, Completion, Creation, term, toDoTask, availableResourceGroups, mandatoryResourceGroups);
	app.myTrxCA.trxCreateObjMatchCrit(pxyObjMatch, realObjMatch, app.myPassport);
	self.assertNotNullMsg(realObjMatch, "Test 5 - real");
	self.assertTrueMsg(app.myPassport.noErrors, "Test 6 - " &amp; app.myPassport.getAllErrorsAndWarningsAsStr());

	// create container to pack
	self.deleteContainer(ContainerId);
	container := self.addContainerOpts(ContainerId, "2200", "MT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertNotNullMsg(container, "Test 7 - container");

	// create cargo to be packed into container
	self.deleteContainer(CargoID);
	cargo := self.addContainerOpts(CargoID, "2200", "GENL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertNotNullMsg(cargo, "Test 8 - cargo");

	// do the pack
	create packTIs transient;
	packTIs.add(cargo);
	self.packContainer(container.CM_Container, packTIs);
	self.packCompleteContainer(container.CM_Container);
	self.assertEqualMsg(container.numChildren, 1, "Test 9 - container not packed with cargo");
	
	// check for existence of auto-created to do task
	found := false;
	foreach tiToDo in toDoTask.allTiToDoTasksToComplete do
		if tiToDo.toDoTaskDescDesc = ToDoDesc then
			found := true;
			break;
		endif;
	endforeach;
	self.assertTrueMsg(found, "Test 10 - no auto generated to do task");

	// complete the to do task
	create tiSet transient;
	tiSet.add(container);
	self.completeToDoTask(toDoTask, tiSet,null);				//23.01.2023 navma1 #54349[54262]
	found := false;
	foreach toDoComp in container.allToDoTasksCompleted do
		if tiToDo.toDoTaskDescDesc = ToDoDesc then
			found := true;
			break;
		endif;
	endforeach;
	self.assertTrueMsg(found, "Test 11 - to do task not completed");

	// check moves have been created
	self.assertNotEqualMsg(container.allQueuedFutureMoves.size(), 0, "Test 12 - no queued move");
	self.assertNotEqualMsg(container.allPlannedFutureMoves.size(), 0, "Test 13 - no planned move");

epilog
	beginTransaction;
		container.removeToDoTaskComplete(ToDoDesc, app.myPassport);
	commitTransaction;
	self.deleteContainer(CargoID);
	self.deleteContainer(ContainerId);
	self.deleteToDoTaskDescription(toDoTask);
	delete actions;
	delete pxyObjMatch;
	delete packTIs;
	delete tiSet;
	delete availableResourceGroups;
	delete mandatoryResourceGroups;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tAutoToDoTaskComplete2" id="bda2a38e-5156-4de9-8932-825d4b1bb0f1">
        <source>tAutoToDoTaskComplete2();
/*
//cnwrs1
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Oct 2016	cnwrs1	TFS 2845 Par 38329 1090 in Port Nelson
10 Sep 2019	cnwrs1	TFS 46030
23 Jan 2023	navma1	ChangeRequest 54349[54262]: EUP - Enable Is Mandatory for ToDo Task Resources
*/
constants
	VesselId			: String = "AOR";
	VoyageId			: String = "UT_URORA2845";
	ShipLine			: String = "CMA";
	CargoCntr			: String = "APZU1232845";
	BlockStackId		: String = "UT_RDBS2845";
	YardIC				= "UT_RD_IC";
	YardAlloc			= 'RDALLOC';
	CraneTransferAreaId	= "CTA2845";
	CraneId				= "C845";
	ToDoDesc = 'UT Auto To Do Task';
	ToDoShort = 'UT Auto ToDo';
	Completion = QUEUE_MODE;
	Creation = PLANNING_MODE;
	ContainerId = "UTMP0002845";
	CargoID = "UTMC0002845";
vars
	toDoTask: CM_ToDoTaskDesc;
	term: CM_Terminal;
	pxyObjMatch,
	realObjMatch: CM_ObjectMatchCriteria;
	actions: IntegerArray;
	container,
	cargo: CM_TrackedItem;
	packTIs: CM_TIArray;
	tiToDo: CM_TiToDoTask;
	tiSet: CM_TISet;
	found: Boolean;
	toDoComp: CM_ToDoTask;
	yardIC : CM_InterchangeArea;
	bs : CM_BlockStack;
	moveController : CMIF_MoveController;
	operator : CM_Operator;
	voyage : CM_Voyage;
	cta	: CM_CraneTransferArea;
	tas	: StringArray;
	crane : CM_Machine;
	dischargePort : CM_Port;
	loadPort : CM_Port;
	bayName	: String;
	slots : CM_SlotControllerArray;
	tmpLoadCC : CMIF_LoadColorCode;
	voyageJob : CM_VoyageJob;
	wle : CM_WorkListEntry;
	voyageQueue	: CM_VoyageQueue;
	craneQueue : CM_VoyageCraneQueue;
	isDoClearanceCheck : Boolean;
	availableResourceGroups,
	mandatoryResourceGroups		: CM_ResourceTypeGroupByCode;
	
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	term := self.getTerminal();
	self.assertNotNullMsg(term, "Test 1 - terminal");
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertNotNull(operator);

	cargo := self.getTrackedItem(CargoCntr);
	self.deleteTrackedItem(cargo, true);
	cargo := self.getTrackedItem(CargoID);
	beginTransaction;
	delete cargo;
//	cargo.erase(NORMAL_ERASE);
	commitTransaction;
	self.deleteTrackedItem(cargo, true);
	cargo := self.getTrackedItem(ContainerId);
	self.deleteTrackedItem(cargo, true);
	//Delete Voyage  &amp; Voyage if exist
	self.deleteVoyage(VoyageId);
    self.assertNoTrxErrorsOrWarnings();

	// Create Voyage
	voyage := self.addVoyageWithContainerStructur(VoyageId,VesselId,operator.code,ShipLine);
	self.assertNotNull(voyage);
	
	// Delete CNTR from YARD
	self.deleteContainer(ContainerId);
	self.assertNoTrxErrorsOrWarnings();

	// delete todo taks
	toDoTask := app.myRoot.allToDoTaskDescsByShortDesc.getAtKey(ToDoShort);
	if toDoTask &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTask);
	endif;
	
	// create basic to do task
	toDoTask := self.basicCreateCM_ToDoTaskDesc(ToDoDesc, ToDoShort, null, null, null); 
	self.assertNotNullMsg(toDoTask, "Test 2 - to do task not created");
	self.assertTrueMsg(app.myPassport.noErrors, "Test 3 - " &amp; app.myPassport.getAllErrorsAndWarningsAsStr());
	
	// add attributes to make to do task apply automatically
	create actions transient;
	actions.add(TRANS_TYPE_PackComplete);
	actions.add(TRANS_TYPE_UnpackComplete);
	assertEqualMsg(actions.size(), 2, "Test 4 - wrong number of children");
	create pxyObjMatch as CM_TaskCriteria transient;
	create availableResourceGroups transient;
	create mandatoryResourceGroups transient;
	pxyObjMatch.CM_TaskCriteria.setProxyBaseData(actions, Completion, Creation, term, toDoTask, availableResourceGroups, mandatoryResourceGroups);
	app.myTrxCA.trxCreateObjMatchCrit(pxyObjMatch, realObjMatch, app.myPassport);
	self.assertNotNullMsg(realObjMatch, "Test 5 - real");
	self.assertTrueMsg(app.myPassport.noErrors, "Test 6 - " &amp; app.myPassport.getAllErrorsAndWarningsAsStr());

	// create the terminal areas - gridded block stack, block stack and interchange
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("HideOverview", true);
	yardIC := self.addInterchangeArea(YardIC, null);
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("StockControlled", true);
	self.opts.addAssoc("DefaultYIC", yardIC);
	bs := self.addBlockStack(BlockStackId, 20, null);		
	
	// create container to pack
	self.deleteContainer(ContainerId);
	container := self.addContainerAtLocation(ContainerId, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "2200", 
		"MT", TI_IMEX_STATUS_EXPORT, bs.allLocationsControllers.first);
	self.assertNotNullMsg(container, "Test 7 - container");


	// create cargo to be packed into container
//	self.deleteContainer(CargoID);
	cargo := self.addContainerAtLocation(CargoID, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), "2200", 
		"GENL", TI_IMEX_STATUS_EXPORT, bs.allLocationsControllers.first);
	self.assertNotNullMsg(cargo, "Test 8 - cargo");
	
	// do the pack
	create packTIs transient;
	packTIs.add(cargo);
	self.packContainer(container.CM_Container, packTIs);
	self.packCompleteContainer(container.CM_Container);
	self.assertEqualMsg(container.numChildren, 1, "Test 9 - container not packed with cargo");

	// set container ready to ship
	self.opts.purge();
	self.opts.addAssoc("ReadyToShip", true);
	self.updateTI(container);

	// check for existence of auto-created to do task
	found := false;
	foreach tiToDo in toDoTask.allTiToDoTasksToComplete do
		if tiToDo.toDoTaskDescDesc = ToDoDesc then
			found := true;
			break;
		endif;
	endforeach;
	assertTrueMsg(found, "Test 10 - no auto generated to do task");
	
	// remove stops
	self.deleteStops(container);
	self.deleteStops(cargo);

	// queue it to ship
	// create the crane transfer area
	self.deleteMachine(CraneId);
	cta := self.addCraneTransferArea(CraneTransferAreaId);
	self.assertNotNull(cta);
	
	// create the crane
	create tas transient;
	tas.add(cta.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	self.deleteMachine(CraneId);
	crane := self.addCrane(CraneId, null, tas, null);
	self.assertNotNull(crane);
	delete tas;
	
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;
	loadPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	//create discharge job
	bayName := '07';
	create slots transient;
	self.getJobSlotControllers(VoyageId, bayName, DeckOnDeck, 1, 1, 1, slots);
	assertEqual(slots.size, 1);
	//dischargeTi := self.addContainerAtLocnDisch(CargoCntr , "2200", "GENL", 1, slots[1], dischargePort, voyage);
	
	// Color code and Create Discharge Jobs
	//self.voyageDischargeColourCode(voyage);
	create tmpLoadCC transient;
	self.markSlotsAsLoadJob(slots, tmpLoadCC);
	//self.markSlotsAsDischargeCC(slots, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	
	voyageJob := self.addVoyageJob(voyage, CraneId, slots, false);
	assertTrueMsg(voyageJob &lt;&gt; null, "Voyage job 1 not created");
	//jobs.add(voyageJob);
	
	foreach wle in voyageJob.workListEntries do
		if wle.myTrackedItem = null then
		beginTransaction;
			wle.setMyTrackedItem(container);
			commitTransaction;
		endif;
		self.movePlannedWLE(wle.myTrackedItem, slots[1], wle);
	endforeach;
	
	self.opts.purge();
	self.opts.addAssoc("Operator", operator);
	self.opts.addAssoc("ISOType", '2200');

	//load to ops
//rs	self.loadAllJobsToOps(voyage, true);				
	
	self.addMachineRule( bs, crane.CM_Crane.transferArea, RTMoveMethod_23); //simple single straddle moves
	self.addMachineRule( crane.CM_Crane.transferArea, bs, RTMoveMethod_23); 
		
	voyageQueue := self.addVoyageQueue(voyage);
	craneQueue := self.addVoyageCraneQueue(voyage, voyageQueue, crane);
	
	// Create Queues
	//create wles transient;
	//foreach job in jobs do
/*		foreach request in voyageJob.allRequests do
			foreach wle in request.allWorkListEntries do
				if wle.CM_VoyageWLE.myRequest.CM_SlotRequest.isLoad then
					//wles.add(wle);
					self.autoplanWLE(wle);
				else
					//wles.add(wle);
					self.queueWLE(wle);
				endif;

			endforeach;
		endforeach;*/
	//endforeach;
	
/*	// do the pack
	create packTIs transient;
	packTIs.add(cargo);
	self.packContainer(container.CM_Container, packTIs);
	self.packCompleteContainer(container.CM_Container);
	self.assertEqualMsg(container.numChildren, 1, "Test 9 - container not packed with cargo");

	// check for existence of auto-created to do task
	found := false;
	foreach tiToDo in toDoTask.allTiToDoTasksToComplete do
		if tiToDo.toDoTaskDescDesc = ToDoDesc then
			found := true;
			break;
		endif;
	endforeach;
	assertTrueMsg(found, "Test 10 - no auto generated to do task");*/

	// complete the to do task
	create tiSet transient;
	tiSet.add(container);
	self.completeToDoTask(toDoTask, tiSet,null);			//23.01.2023 navma1 #54349[54262]
	found := false;
	foreach toDoComp in container.allToDoTasksCompleted do
		if tiToDo.toDoTaskDescDesc = ToDoDesc then
			found := true;
			break;
		endif;
	endforeach;
	self.assertTrueMsg(found, "Test 11 - to do task not completed");

	// check moves have been created
	self.assertNotEqualMsg(container.allQueuedFutureMoves.size(), 0, "Test 12 - no queued move");
	self.assertNotEqualMsg(container.allPlannedFutureMoves.size(), 0, "Test 13 - no planned move");
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	if container &lt;&gt; null then
		beginTransaction;
		container.removeToDoTaskComplete(ToDoDesc, app.myPassport);
		commitTransaction;
	endif;
	delete actions;
	delete pxyObjMatch;
	delete packTIs;
	delete tiSet;
	delete moveController;
	delete tmpLoadCC;
	delete slots;
	delete availableResourceGroups;
	delete mandatoryResourceGroups;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="tAutoToDoTaskManual" id="55ed78c5-e077-4166-ae4a-9ccf0d4e1c42">
        <source>tAutoToDoTaskManual();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Sep 2016	cnwmp6	Initial creation	TFS 2443
23 Jan 2023	navma1	ChangeRequest 54349[54262]: EUP - Enable Is Mandatory for ToDo Task Resources
*/
constants
	ToDoDesc = 'UT Auto To Do Task';
	ToDoShort = 'UT Auto ToDo';
	Completion = QUEUE_MODE;
	Creation = PLANNING_MODE;
	ContainerId = "UTMP0000021";

vars
	toDoTask: CM_ToDoTaskDesc;
	term: CM_Terminal;
	pxyObjMatch,
	realObjMatch: CM_ObjectMatchCriteria;
	container: CM_TrackedItem;
	tiSet: CM_TISet;
	availableResourceGroups,
	mandatoryResourceGroups		: CM_ResourceTypeGroupByCode;
	
begin
	term := self.getTerminal();
	self.assertNotNullMsg(term, "Test 1 - terminal");

	// delete todo taks
	toDoTask := app.myRoot.allToDoTaskDescsByShortDesc.getAtKey(ToDoShort);
	if toDoTask &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTask);
	endif;
	// create basic to do task
	toDoTask := self.basicCreateCM_ToDoTaskDesc(ToDoDesc, ToDoShort, null, null, null); 
	self.assertNotNullMsg(toDoTask, "Test 2 - to do task not created");
	self.assertTrueMsg(app.myPassport.noErrors, "Test 3 - " &amp; app.myPassport.getAllErrorsAndWarningsAsStr());
	
	// add attributes to make to do task apply automatically
	create pxyObjMatch as CM_TaskCriteria transient;
	create availableResourceGroups transient;
	create mandatoryResourceGroups transient;
	pxyObjMatch.CM_TaskCriteria.setProxyBaseData(null, Completion, Creation, term, toDoTask, availableResourceGroups, mandatoryResourceGroups);
	app.myTrxCA.trxCreateObjMatchCrit(pxyObjMatch, realObjMatch, app.myPassport);
	self.assertNotNullMsg(realObjMatch, "Test 4 - real");
	self.assertTrueMsg(app.myPassport.noErrors, "Test 5 - " &amp; app.myPassport.getAllErrorsAndWarningsAsStr());

	// create container for to do task
	self.deleteContainer(ContainerId);
	container := self.addContainerOpts(ContainerId, "2200", "MT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertNotNullMsg(container, "Test 6 - container");

	// add a to do task to the container
	create tiSet transient;
	tiSet.add(container);
	self.addToDoTask(toDoTask, tiSet);
	assertEqualMsg(container.allToDoTasksToDo.size(), 1, "Test 7 - Container " &amp; container.id &amp; " has no to do tasks");

	// check planned move from creation of to do task
	self.assertEqualMsg(container.allPlannedFutureMoves.size(), 1, "Test 8 - no planned move");

	// complete the to do task
	self.completeToDoTask(toDoTask, tiSet,null);			
	self.assertEqualMsg(container.allToDoTasksToDo.size(), 0, "Test 9 - to do task not completed");

	// check queued move from completion of to do task
	self.assertEqualMsg(container.allQueuedFutureMoves.size(), 1, "Test 10 - no queued move");

epilog
	beginTransaction;
		container.removeToDoTaskComplete(ToDoDesc, app.myPassport);
	commitTransaction;
	self.deleteContainer(ContainerId);
	self.deleteToDoTaskDescription(toDoTask);
	delete pxyObjMatch;
	delete tiSet;
	delete availableResourceGroups;
	delete mandatoryResourceGroups;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tBasicTaskTransactAndResource" id="77f656f3-6887-4b40-86c7-55d0774a35e7">
        <source>tBasicTaskTransactAndResource();
/* cnwndl1

Purpose:			

	This test has some static data already declared in 'Unit Test' terminal that is mandatory.

		a CM_Service named "Extra Service" - 'Service Schedule'
		a CM_RateEntry for 'Extra Service' - Rate History'
		a CM_InvoiceDesc for 'Extra Services' - 'Invoice Types'
		a CM_InvoiveLineDesc for Extra services - 'Invoice Line Mapping' &amp; 'Invoice Line Types'

Parameters:			

Return Value:		


Date			Who		Reason
11 January 2010	cnwndl1	Initial creation
08/04/2011		cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
01 Dec 2023 	navlc30 ChangeRequest 60748: EUP | VAS Mobile App - [53813.070] [BackEnd] Automatic VAS Resources
*/

constants

	ToDoResource : String = "UT_ResTyp2";
	TransactionType : String = "UT_TransTyp2";
	ToDoDesc : String = "UT_ToDoDesc";
	ContainerId : String = "UTTU7162534";
	
vars

	resourceType : CM_ResourceType;
	transType : CM_TransactionType;
	toDoTaskDesc : CM_ToDoTaskDesc;
	toDoTaskDescToDel : CM_ToDoTaskDesc;
	transServiceBroker : CM_ServiceBroker;
	resourceBroker : CM_ServiceBroker;
	errMessage : String;
	ti : CM_TrackedItem;
	tiTask : CM_ToDoTask;
	newTrans : CM_Transaction;
	proxyResourceTypeUsage, resourcetypeUsage : CM_ResourceTypeUsage;
	bank : CM_Bank;
	tiTask2 : CM_ToDoTask;
	newTrans2 : CM_Transaction;
	
	tiSet : CM_TISet;
	pxyTI : CM_TrackedItem;
	resourceUsageProxys : CM_ResourceTypeUsageSet;
	controller : CMIF_TiTransactionResync;
	
	cargoMap : CM_TranMap;
	
begin

	
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	
	// Make sure we are using the default settings,
	// just in case someone else has been dicking with them.
	cargoMap := bank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(cargoMap,"Default cargo map not found");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);
	
	
	

	// Create a 'to do resource type' CM_ResourceType 
	//resourceType := self.basicCreateCM_ResourceType(ToDoResource);										//01.12.2023 navlc30 #60748 
	resourceType := self.basicCreateCM_ResourceType(ToDoResource, null);									//01.12.2023 navlc30 #60748
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertTrueMsg(resourceType &lt;&gt; null, "Resource Type of '" &amp; ToDoResource &amp; "' not created.");

	
	// Create a transaction type.
	transType := app.myRoot.allTransactionTypesByDesc[TransactionType];
	if transType = null then
		transType := self.basicCreateCM_TransactionType(TransactionType);
		self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
		self.assertTrueMsg(transType &lt;&gt; null, "Transaction Type of '" &amp; TransactionType &amp; "' not created.");
	endif;

	
	// Create a to do task description CM_ToDoTaskDesc and link the resource.
	foreach toDoTaskDesc in app.myRoot.allToDoTaskDescsByShortDesc do
		if toDoTaskDesc.description = ToDoDesc then
			toDoTaskDescToDel := toDoTaskDesc;
			break;
		endif;
	endforeach;
	if toDoTaskDescToDel &lt;&gt; null then
		self.deleteToDoTaskDescription( toDoTaskDescToDel );
	endif;
	toDoTaskDesc := self.basicCreateCM_ToDoTaskDesc(ToDoDesc, null, transType, null, resourceType); //cnwrs1 CCMS 1826 29 July 2010
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertTrueMsg(toDoTaskDesc &lt;&gt; null, "To Do Task Description of '" &amp; ToDoDesc &amp; "' not created.");

	
	// Create an invoice mapping for the resource of the transaction
	basicCreateInvoiceMappingObjs(	cargoMap,	//_tranMap : CM_TranMap;	
									transType,	//_transType : CM_TransactionType;
									resourceType,	//_resourceType : CM_ResourceType;
									transServiceBroker,	//_transServiceBroker : CM_ServiceBroker output;
									resourceBroker,	//_resourceBroker : CM_ServiceBroker output;
									errMessage	// _errMessage : String
									);
	self.assertTrueMsg(errMessage.trimBlanks = null, errMessage);
	self.assertTrueMsg(transServiceBroker &lt;&gt; null, "Failed to create the Transaction Service Broker");
	self.assertTrueMsg(resourceBroker &lt;&gt; null, "Failed to create the Resource Transaction Service Broker");
	
	
	// Create a container and assign the task.
	ti := self.getTerminal.lookupTrackedItem(ContainerId, TI_CargoType_Container, TI_STATE_UNDEFINED, null, false);
	self.assertTrueMsg(ti = null, "Tracked item '" &amp; ContainerId &amp; "' already exists!");
	ti := createContainer(	ContainerId,	//id: String;
							"2200",	//_isoType: String;
							"GB1",	//_commodity: String;
							self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),	//_operator: CM_Operator
							false
							);
	self.assertTrueMsg(ti &lt;&gt; null, "Tracked item '" &amp; ContainerId &amp; "' not created.");
	beginTransaction;
	tiTask := ti.addToDoTask( toDoTaskDesc.description.trimBlanks , app.myPassport );
	commitTransaction;
	self.assertTrueMsg(tiTask &lt;&gt; null, "Task '" &amp; toDoTaskDesc.description.trimBlanks &amp; "' not created for '" &amp; ContainerId &amp; "'.");

	
	// Complete the task against the container and get the transaction.
	beginTransaction;
	tiTask.CM_TiToDoTask.setTaskComplete(app.myPassport, true, newTrans);
	commitTransaction;
	self.assertTrueMsg(tiTask.CM_TiToDoTask.isCompleted, "Task '" &amp; toDoTaskDesc.description.trimBlanks &amp; "' not complete for '" &amp; ContainerId &amp; "'.");
	self.assertTrueMsg(newTrans &lt;&gt; null, "Transaction not created for '" &amp; ContainerId &amp; "'.");
	
	//should be no charges because we didn't add any resourceTypeUsages (eventhoigh the transaction was allowed them.)
	self.assertTrueMsg(newTrans.allResourceUsages.isEmpty, "Resource Usages weren't created yet there should be none associated with the transaction.");
	self.assertTrueMsg(newTrans.CM_TITransaction.allInvoiceLines.isEmpty, "With no Resource Usages there should be no charges yet.");
	

	// Add a resource usage against the transaction.
	create proxyResourceTypeUsage transient;
	proxyResourceTypeUsage.setProxy(	resourceType,	//_resourceType : CM_ResourceType;
										newTrans.CM_TITransaction,	//_transaction : CM_TITransaction;
										false,	//_noCharge : Boolean;
										20.0,	//_quantity : Decimal;
										"Cheap shot",	//_remarks : String;
										CM_InvoiceLine.STATUS_NORMAL,	//_status : Integer;
										null, null,null,null,null);		//cnwmc5 - 22 Sep 2015 - PAR 36920
	app.myTrxCA.trxCreateResourceTypeUsage(proxyResourceTypeUsage, resourcetypeUsage, app.myPassport);
	
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertTrueMsg(resourcetypeUsage &lt;&gt; null, "Resource Usage not created.");
	self.assertTrueMsg(not newTrans.allResourceUsages.isEmpty, "Resource Usage has not been associated with the transaction.");
	self.assertTrueMsg(newTrans.CM_TITransaction.allInvoiceLines.isEmpty, "Manual add of Resource Usages alone should not cause charges yet.");
	
	
	// Force invoice line creation via a resync of the transaction.
	create controller transient;
	controller.myTrackedItem := ti;
	controller.allTransactions.add(newTrans.CM_TITransaction);
	app.myTrxUA.trxUpdateRsyncTrans(controller, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	self.assertTrueMsg(not newTrans.CM_TITransaction.allInvoiceLines.isEmpty, "Resource Usage charges should now have been created.");
	
	
	//add a second task
	beginTransaction;
	tiTask2 := ti.addToDoTask( toDoTaskDesc.description.trimBlanks , app.myPassport );
	commitTransaction;
	self.assertTrueMsg(tiTask2 &lt;&gt; null, "Task 2 '" &amp; toDoTaskDesc.description.trimBlanks &amp; "' not created for '" &amp; ContainerId &amp; "'.");
	
	
	//complete the second task adding resources as we complete it. 
	create tiSet transient;
	beginLoad;
	pxyTI := ti.pxyCreateUpdateProxy();
	endLoad;
	tiSet.add(pxyTI);
	create resourceUsageProxys transient;
	proxyResourceTypeUsage.setProxy(	resourceType,	//_resourceType : CM_ResourceType;
										null,	//_transaction : CM_TITransaction;
										false,	//_noCharge : Boolean;
										5.0,	//_quantity : Decimal;
										"Cheaper shot",	//_remarks : String;
										CM_InvoiceLine.STATUS_NORMAL,	//_status : Integer;
										null, null,null,null,null);		//cnwmc5 - 22 Sep 2015 - PAR 36920
	resourceUsageProxys.add(proxyResourceTypeUsage);
	app.myTrxUA.trxUpdateTIToDoTaskCmpltBulk( toDoTaskDesc, tiSet, resourceUsageProxys, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());		
	newTrans2 := ti.allTransactions.last;
	self.assertTrueMsg(newTrans2 &lt;&gt; null, "New transaction should have been created.");
	self.assertTrueMsg(newTrans2.CM_TITransaction.myToDoTask = tiTask2, "New transaction(2) should be related to the new task(2).");
	self.assertTrueMsg(not newTrans2.CM_TITransaction.allInvoiceLines.isEmpty, "Resource Usage charges should have been created for the new transaction.");
	self.assertTrueMsg(newTrans2.CM_TITransaction.allInvoiceLines.first.quantity = 5, "Transaction quantity should be 5");
	
	
	// update the quantity on the transaction2 resource usage after creating the charge.
	delete proxyResourceTypeUsage;
	beginLoad;
	proxyResourceTypeUsage := newTrans2.allResourceUsages.first.pxyCreateUpdateProxy();
	endLoad;
	proxyResourceTypeUsage.setProxy(	resourceType,	//_resourceType : CM_ResourceType;
										newTrans2.CM_TITransaction,	//_transaction : CM_TITransaction;
										false,	//_noCharge : Boolean;
										4.0,	//_quantity : Decimal;
										"Cheapest shot",	//_remarks : String;
										CM_InvoiceLine.STATUS_NORMAL,	//_status : Integer;
										null, null,null,null,null);		//cnwmc5 - 22 Sep 2015 - PAR 36920
	app.myTrxUA.trxUpdateResourceTypeUsage(proxyResourceTypeUsage, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	
	// quantity is no longer derived so need an explicit resync
	controller.allTransactions.clear();
	controller.allTransactions.add(newTrans2.CM_TITransaction);
	app.myTrxUA.trxUpdateRsyncTrans(controller, app.myPassport);
	
	self.assertTrueMsg(newTrans2.CM_TITransaction.allInvoiceLines.first.quantity = 4, "Transaction quantity should be 4");
	
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete controller;
	delete resourceUsageProxys;
	delete proxyResourceTypeUsage;
	delete tiSet;
	delete pxyTI;
	
	if newTrans &lt;&gt; null then
		foreach resourcetypeUsage in newTrans.allResourceUsages do
			beginTransaction;
			delete resourcetypeUsage;
			commitTransaction;
		endforeach;
	endif;
	
	if newTrans2 &lt;&gt; null then
		foreach resourcetypeUsage in newTrans2.allResourceUsages do
			beginTransaction;
			delete resourcetypeUsage;
			commitTransaction;
		endforeach;
	endif;
	
	deleteContainer(ContainerId);
	
	if resourceBroker &lt;&gt; null then
		beginTransaction;
		delete resourceBroker;
		commitTransaction;
	endif;
	
	if transServiceBroker &lt;&gt; null then
		beginTransaction;
		delete transServiceBroker;
		commitTransaction;
	endif;
	
	if toDoTaskDesc &lt;&gt; null then
		toDoTaskDesc.validateForDelete();
		beginTransaction;
		delete toDoTaskDesc;
		commitTransaction;
	endif;
	
	if transType &lt;&gt; null then
		transType.validateForDelete();
		beginTransaction;
		delete transType;
		commitTransaction;
	endif;
	
	if resourceType &lt;&gt; null then
		if resourceType.hasBeenUsed and resourceType.allUsageContexts.isEmpty then
			beginTransaction;
			resourceType.setPropertyValue(CM_ResourceType::hasBeenUsed.name, false);
			commitTransaction;
		endif;
		resourceType.validateForDelete();
		beginTransaction;
		delete resourceType;
		commitTransaction;
	endif;
		
end;</source>
    </JadeMethod>
    <JadeMethod name="tCreateDimensionToDoTask" id="5dce2829-0faa-4980-a967-4186db27edff">
        <source>tCreateDimensionToDoTask();
// cnwndl1
// cnwrd1
//18 December 2009	cnwml2
//23 Jan 2023		navma1	ChangeRequest 54349[54262]: EUP - Enable Is Mandatory for ToDo Task Resources

vars
	container1, 
	pxyTI 			: CM_TrackedItem;
	tiSet 			: CM_TISet;
	toDoTaskDesc 	: CM_ToDoTaskDesc;
	root			: CM_Root;
	passport		: CM_Passport;
begin
	passport := app.myPassport;					//23.01.2023 navma1 #54349[54262]
	root 	 := app.myRoot;						//23.01.2023 navma1 #54349[54262]
	
	self.deleteContainer("UTMAT0001");
	container1 := self.addContainerOpts("UTMAT0001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	

	create tiSet transient;
	tiSet.add(container1);
	
	toDoTaskDesc := root.allToDoTaskDescsByShortDesc["Dimension"];  
		
	self.addToDoTask(toDoTaskDesc, tiSet);
	assertEqual(container1.allToDoTasksToDo.size, 1);
	
	delete tiSet;

	pxyTI := app.createUpdateProxy(container1.CM_TrackedItem).CM_TrackedItem;
	
	create tiSet transient;
	tiSet.add(pxyTI);
	
	pxyTI.CM_Container.setOverHeight(25, null, passport);
	pxyTI.CM_Container.setOverLengthFront(25,null, passport);
	pxyTI.CM_Container.setOverLengthRear(25, null, passport);
	pxyTI.CM_Container.setOverWidthLeft(25, null, passport);
	pxyTI.CM_Container.setOverWidthRight(25, null, passport);
	
	self.completeToDoTask(toDoTaskDesc, tiSet,null);						//23.01.2023 navma1 #54349[54262]
	assertEqual(container1.allToDoTasksToDo.size, 0);
	assertEqual(container1.allToDoTasksCompleted.size, 1);
	assertEqual(container1.CM_Container.overHeight.Integer, 25);
	assertEqual(container1.CM_Container.overLengthFront.Integer, 25);
	assertEqual(container1.CM_Container.overLengthRear.Integer, 25);
	assertEqual(container1.CM_Container.overWidthLeft.Integer, 25);
	assertEqual(container1.CM_Container.overWidthRight.Integer, 25);
	

	assertEqual(container1.allTransactions.last.isKindOf(CM_Dimension), true);
	assertEqual(container1.allTransactions.last.CM_Dimension.overFront.Integer, 25);
	assertEqual(container1.allTransactions.last.CM_Dimension.overBack.Integer, 25);
	assertEqual(container1.allTransactions.last.CM_Dimension.overLeft.Integer, 25);
	assertEqual(container1.allTransactions.last.CM_Dimension.overRight.Integer, 25);
	assertEqual(container1.allTransactions.last.CM_Dimension.overHeight.Integer, 25);

epilog
	delete tiSet;
	delete pxyTI;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCreateToDoEventRequests" id="21add741-7585-4c14-8215-00ea3e609b8b">
        <source>tCreateToDoEventRequests();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2014	cnwndl1	Initial creation	Par 35160	CIG CCMS 2434
16 Jan 2017	cnwma1	TFS #2885:QNS - Additional Data Mapping in Customs Message
*/

constants
	Containerid  : String = "UREQ0123210";
	RefString	 : String = "UnitTestRef";
vars
	container 				: CM_TrackedItem;
	organisation 			: CM_Organisation;
	addresses 				: CM_StringArray;
	term 					: CM_Terminal;
	tmpUser 				: CM_User;
	toDoObj 				: CM_ToDoTaskDesc;
	cmifEventReq 			: CMIF_EventRequestController;
	pxyEventRequestStops 	: CM_EventRequestStops;
	pxyColl 				: CM_ObjectArray;
	trxType 				: Integer;
	trxClass 				: Class;
	tiToDo 					: CM_ToDoTask;
	realEventRequestStop 	: CM_EventRequestStops;
	tiSet 					: CM_TISet;
	tiTrx 					: CM_TITransaction;
	hasMandatoryRes			: Boolean;
	toDoRemarks				: String;
	resourceUsageProxys 	: CM_ResourceTypeUsageSet;
	proxyResourceTypeUsage  : CM_ResourceTypeUsage;
	toDoTaskDesc		    : CM_ToDoTaskDesc; 
	resourceType			: CM_ResourceType;
	mandatoryResCount		: Integer;
	idx, totTaskDesc : Integer;
begin

	//create cargo
	
	self.deleteContainer(Containerid);
	container := self.addContainerOpts(Containerid, "2200", "MT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertTrueMsg( container &lt;&gt; null, "Container " &amp; Containerid &amp; " not created");
	
	organisation := app.myRoot.allOrganisations[ UT_DSL.MasterTermOrg ];
	term 		 := self.getTerminal;
	tmpUser 	 := app.getMyUser;
	
	
	//create a todo task from an 'Event Request Stop' one for every todo task in the system
	create addresses transient;
	create cmifEventReq transient;
	addresses.add( app.myRoot.getConfig(AutoSupportEmailAddress).String);  // bitBucket...
	create pxyColl transient;

	foreach toDoObj in CM_ToDoTaskDesc.instances do
	
		if not toDoObj.isAvailableForCargoType(container.cargoType) then
			continue;
		endif;
		if toDoObj.isForGenSetAttachDetach() then
			continue;
		endif;
		if toDoObj.trxTypeOnCreation &lt;&gt; null then
			trxType := toDoObj.trxTypeOnCreation;
			trxClass := global.getTiTxnClassForType(trxType, true);
			if trxClass = CM_StopAdd then
				continue;
			endif;
		endif;
		if toDoObj.trxTypeOnCompletion &lt;&gt; null then
			// CR 57924 TASK 57920 NAVAB1 24MAY23 - work order transaction do not get created for TIs
			if  toDoObj.myTransactionType &lt;&gt; null
			and toDoObj.myTransactionType.isForWorkOrder() then 
				continue; // ignore this to do task
			endif;
			trxType := toDoObj.trxTypeOnCompletion;
			trxClass := global.getTiTxnClassForType(trxType, true);
			if trxClass = CM_ConnectPower then
				continue;
			endif;
		endif;
			
		create pxyEventRequestStops transient;
		pxyColl.add( pxyEventRequestStops );
		
		toDoRemarks := "Testing To Do Remarks";
			
		pxyEventRequestStops.setProxyRequestStops( EventRequestTypeToDo,	//_type : Integer;
													addresses,	//_addresses : CM_StringArray;
													toDoObj.description,	//_remarks : String;
													container.id,	//_cargoId : String;
													tmpUser,	//_user : CM_User;
													container.myCargoType,	//_cargoType : CM_CargoType;
													organisation,	//_organisation : CM_Organisation;
													term,	//_terminal : CM_Terminal;
													EventRequestPending,	//_status : Integer;
													false,	//_isClear : Boolean;
													false,	//_isNotify : Boolean;											
													RefString,	//_ref : String;
													false,	//_cleanup : Boolean;
													null,	//_stopTable : CM_StopsTable;
													null,	//_additionalReqInfo : String;
													null,	//_expiryDate : Date;
													false,	//_isEDI : Boolean;
													toDoObj,	//_toDoDesc : CM_ToDoTaskDesc;
													null,	//_grade : CM_MTGrade;
													null,	//_cargoRemarks : String
													null,	//_custAgent : CM_CustomsAgent 30 Jun 2015	NDL	Par 36543
													toDoRemarks,	//_toDoRemarks		: String	//06 Oct 2015	NDL	Par 37011
													null,	//_tiBOL		//cnwmc5 - 11 Jan 2016 - PAR 37275
													null,	//_clearCustAgent		//cnwmc5 - 11 Jan 2016 - PAR 37275
													null,   // 16/01/2017 cnwma1 TFS #2885
													null,   // 16/01/2017 cnwma1 TFS #2885
													null    // 16/01/2017 cnwma1 TFS #2885
													);
																			
		cmifEventReq.allPxyCargoUpdateRequests.add(pxyEventRequestStops);

	endforeach;
	
	app.myTrxUA.trxUpdateEventRequest(cmifEventReq, app.myPassport);
	self.assertTrueMsg( app.myPassport.noErrors, "Errors creating Cargo Event Requests (to do tasks) " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	foreach tiToDo in container.allToDoTasksToDo do
		realEventRequestStop := null;
		realEventRequestStop := tiToDo.CM_TiToDoTask.findEventRequestStop();
		self.assertTrueMsg( realEventRequestStop &lt;&gt; null, "To Do Task '" &amp; tiToDo.toDoTaskDesc.description &amp; "' can't find its Event Request" );
	endforeach;
	
	create tiSet transient;
	tiSet.add(container);
	
	totTaskDesc := CM_ToDoTaskDesc.instances.size + 2;// CR 57924 TASK 57920 NAVAB1 24MAY23 

	while not container.allToDoTasksToDo.isEmpty do
		// CR 57924 TASK 57920 NAVAB1 24MAY23 
		idx := idx + 1;
		if idx &gt; totTaskDesc then
			self.assertTrueMsg(false,"Breaking endless loop");
			break;
		endif;
		
		mandatoryResCount   := 0;
		hasMandatoryRes     := false;
		tiToDo 				:= container.allToDoTasksToDo.first;
		toDoTaskDesc		:= tiToDo.getMyToDoTaskDesc();
		hasMandatoryRes		:= toDoTaskDesc.hasMandatoryResources;

		self.assertTrueMsg( tiToDo &lt;&gt; null, 		 	  "To Do Task not found waiting to be done.");
		self.assertTrueMsg( tiToDo.remarks = toDoRemarks, "To Do Task not populated with its remarks.");
		
		//23.01.2023 navma1 #54349[54262]
		if hasMandatoryRes then
			create resourceUsageProxys transient;									//23.01.2023 navma1 #54349[54262]
			
			mandatoryResCount := toDoTaskDesc.getMandatoryResourcesCount();			//23.01.2023 navma1 #54349[54262]
			foreach resourceType in toDoTaskDesc.allResourceTypes as CM_ResourceType do 
				create proxyResourceTypeUsage transient;
				proxyResourceTypeUsage.setProxy(	resourceType,					//_resourceType : CM_ResourceType;
													null,							//_transaction 	: CM_TITransaction;
													false,						    //_noCharge 	: Boolean;
													5.0,							//_quantity		: Decimal;
													resourceType.description,		//_remarks 		: String;
													CM_InvoiceLine.STATUS_NORMAL,	//_status 		: Integer;
													null, null,null,null,null);		
				resourceUsageProxys.add(proxyResourceTypeUsage);
			endforeach;
		endif;
		//23.01.2023 navma1 #54349[54262]
	
		self.completeToDoTask(toDoTaskDesc, tiSet,resourceUsageProxys);			//23.01.2023 navma1 #54349[54262]
		
		if resourceUsageProxys &lt;&gt; null then
			resourceUsageProxys.purge();
			delete resourceUsageProxys;
		endif;
		
		if toDoTaskDesc.myTransactionType = null then
			break;
		else
			tiTrx := container.allTransactions.last;
			self.assertTrueMsg( tiTrx.myToDoTask = tiToDo, 		"Completion of To Do Task '" 			  &amp; toDoTaskDesc.description &amp; "' failed to create transaction." );
			self.assertTrueMsg( tiTrx.getReference = RefString, "Completion Transaction for To Do Task '" &amp; toDoTaskDesc.description &amp; "' hasm't got the reference on it." );
			if hasMandatoryRes then
				self.assertTrueMsg( tiTrx.allResourceUsages.size = toDoTaskDesc.allResourceTypes.size, toDoTaskDesc.description &amp; " Resource Count not correct" );
			endif;
		endif;
	endwhile;

epilog
	if resourceUsageProxys &lt;&gt; null then
		resourceUsageProxys.purge();
		delete resourceUsageProxys;
	endif;
	delete addresses;
	delete cmifEventReq;
	if pxyColl &lt;&gt; null and not pxyColl.isEmpty then
		pxyColl.purge();
	endif;
	delete pxyColl;
	delete tiSet;
	self.deleteContainer(Containerid);

end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;DAC ISSUE&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tCreateTwoToDoTasksCompleteOne" id="aec07064-095f-45d6-a863-191e01fedd76">
        <source>tCreateTwoToDoTasksCompleteOne();
// cnwrs1 Par 28737
//23 Jan 2023		navma1	ChangeRequest 54349[54262]: EUP - Enable Is Mandatory for ToDo Task Resources
constants
	ToDoTaskCode1 : String = "UT_28737_1";
	ToDoTaskCode2 : String = "UT_28737_2";
	Containerid : String = "UTMAT28737";
vars
	toDoTaskDesc1 : CM_ToDoTaskDesc;
	toDoTaskDesc2 : CM_ToDoTaskDesc;
	container : CM_TrackedItem;
	tiSet : CM_TISet;
begin
	//setup new todo task desc with all sub terms available.
	toDoTaskDesc1 := app.myRoot.allToDoTaskDescsByShortDesc[ToDoTaskCode1];
	self.deleteToDoTaskDescription(toDoTaskDesc1);
	self.opts.addAssoc(ETRow_TransactionToCreate, 97);
	toDoTaskDesc1 := self.createToDoTaskDesc(ToDoTaskCode1);
	self.assertNotNullMsg(toDoTaskDesc1, "Add To Do Task failed");
	toDoTaskDesc2 := app.myRoot.allToDoTaskDescsByShortDesc[ToDoTaskCode2];
	self.deleteToDoTaskDescription(toDoTaskDesc2);
	self.opts.addAssoc(ETRow_TransactionToCreate, 97);
	toDoTaskDesc2 := self.createToDoTaskDesc(ToDoTaskCode2);
	self.assertNotNullMsg(toDoTaskDesc2, "Add To Do Task failed");
	
	self.deleteContainer(Containerid);
	container := self.addContainerOpts(Containerid, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	create tiSet transient;
	tiSet.add(container);
	self.addToDoTask(toDoTaskDesc1, tiSet);
	assertEqual(container.allToDoTasksToDo.size, 1);
	self.addToDoTask(toDoTaskDesc2, tiSet);
	assertEqual(container.allToDoTasksToDo.size, 2);
	
	self.completeToDoTask(toDoTaskDesc2, tiSet,null);		//23.01.2023 navma1 #54349[54262]
	assertEqual(container.allToDoTasksToDo.size, 1);		//should be 1 ??
	assertEqual(container.allToDoTasksCompleted.size, 1);	//should be 1 ??

	self.completeToDoTask(toDoTaskDesc1, tiSet,null);		//23.01.2023 navma1 #54349[54262]
	assertEqual(container.allToDoTasksToDo.size, 0);		//should be 1 ??
	assertEqual(container.allToDoTasksCompleted.size, 2);	//should be 1 ??
epilog
	delete tiSet;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tCreateWeighToDoTask" id="9adc0df6-a07f-4531-8765-a3d1b56a2230">
        <source>tCreateWeighToDoTask();
// cnwndl1
// cnwrd1
//18 December 2009	cnwml2
//23 Jan 2023		navma1	ChangeRequest 54349[54262]: EUP - Enable Is Mandatory for ToDo Task Resources

vars
	container1,
	pxyTI 			: CM_TrackedItem;
	tiSet 			: CM_TISet;
	toDoTaskDesc	: CM_ToDoTaskDesc;
begin
	self.deleteContainer("UTMAT0001");
	container1 := self.addContainerOpts("UTMAT0001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	

	create tiSet transient;
	tiSet.add(container1);
	
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc["Weight"];  		//18 is Weigh To Do Task			// 01/07/2013 cnwmh5
	
	self.addToDoTask(toDoTaskDesc, tiSet);
	assertEqual(container1.allToDoTasksToDo.size, 1);
	
	delete tiSet;

	pxyTI := app.createUpdateProxy(container1.CM_TrackedItem).CM_TrackedItem;
	
	create tiSet transient;
	tiSet.add(pxyTI);
	
	pxyTI.setTotalWeight(6000, null, app.myPassport);
	pxyTI.setIsWeightCertified(true, null, app.myPassport);

	self.completeToDoTask(toDoTaskDesc, tiSet,null);			//23.01.2023 navma1 #54349[54262]
	assertEqual(container1.allToDoTasksToDo.size, 0);
	assertEqual(container1.allToDoTasksCompleted.size, 1);
	assertEqual(container1.totalWeight.Integer, 6000);
	assertEqual(container1.isWeightCertified, true);
	
epilog
	delete tiSet;
	delete pxyTI;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCreateWeighToDoTaskVGM" id="927fd75e-db1b-46b4-900a-08fd81cc7e0f">
        <source>tCreateWeighToDoTaskVGM();
// cnwrs1
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------
// 29/06/2017	cnwdap1		TFS 4492 SNO VERMAS Changes
// 23 Jan 2023	navma1		ChangeRequest 54349[54262]: EUP - Enable Is Mandatory for ToDo Task Resources
//
vars
	container1, pxyTI : CM_TrackedItem;
	tiSet : CM_TISet;
	toDoTaskDesc : CM_ToDoTaskDesc;
begin
	self.deleteContainer("UTMAT0001");
	container1 := self.addContainerOpts("UTMAT0001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	

	create tiSet transient;
	tiSet.add(container1);
	
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc["Weight"];  		//18 is Weigh To Do Task			// 01/07/2013 cnwmh5
	self.setTerminalConfig(ToDoTaskRemoveVGM, toDoTaskDesc);
	
	self.addToDoTask(toDoTaskDesc, tiSet);
	assertEqual(container1.allToDoTasksToDo.size, 1);
	
	delete tiSet;

	pxyTI := app.createUpdateProxy(container1.CM_TrackedItem).CM_TrackedItem;
	
	create tiSet transient;
	tiSet.add(pxyTI);
	
	pxyTI.setTotalWeight(6000, null, app.myPassport);
	pxyTI.setIsWeightCertified(true, null, app.myPassport);
	pxyTI.setMyVGMDetails(	"Heavon", "God", null, null, null, null, null, 		// TFS 4492
							null, null, null, null, null, null, null	);		// TFS 4492
	self.completeToDoTask(toDoTaskDesc, tiSet,null);							//23.01.2023 navma1 #54349[54262]
	assertEqual(container1.allToDoTasksToDo.size, 0);
	assertEqual(container1.allToDoTasksCompleted.size, 1);
	assertEqual(container1.totalWeight.Integer, 6000);
	assertEqual(container1.isWeightCertified, true);
	
epilog
	delete tiSet;
	delete pxyTI;
end;</source>
    </JadeMethod>
    <JadeMethod name="tMaintainToDoTaskQueryProps" id="8d7cf110-5724-4a81-b433-a4dac4549648">
        <source>tMaintainToDoTaskQueryProps();
// cnwrs1
/*
Date		Who		Reason
14 November 2011	cnwcs5	Initial creation - CCMS RIO 2230 / par 28261 Start/Stop Times
*/
constants
	TASK_DESCRIPTION	= 'UT Requires Task to be Done';
	TASK_SHORTDESC		= 'UT Req Task';
vars
	toDoTaskDesc	:CM_ToDoTaskDesc;
	propTask, propComplete, 
	propDate, prop	:CM_QueryProperty;
	qDef			:CM_QueryDefinition;
	code			:Integer;
begin
	// DELETE todo task if it already exists
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc [TASK_SHORTDESC];
	
	if toDoTaskDesc &lt;&gt; null then
		self.deleteToDoTaskDescription (toDoTaskDesc);
	endif;
	
	self.assertIsDeleted (toDoTaskDesc);

// ---------------------
// CREATE totdo task
// ---------------------
	toDoTaskDesc := self.basicCreateCM_ToDoTaskDesc(TASK_DESCRIPTION, TASK_SHORTDESC, null, null, null); 
	
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
	self.assertTrueMsg(toDoTaskDesc &lt;&gt; null, "To Do Task Description of '" &amp; TASK_DESCRIPTION &amp; "' not created.");
	
	// CHECK query properties have been created correctly
	code 	:= toDoTaskDesc.code;
	qDef	:= app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, 0];
	
	self.assertNotNull (qDef);
	self.assertTrue (qDef.isKindOf (CM_QDefTrackedItem));
	
	// basic todo task query property
	propTask := qDef.allQueryProperties [CM_QBooleanToDoTaskProperty.PREFIX_PROPERTY_NAME &amp; code.String];

	self.assertNotNull (propTask);
	self.assertTrue (propTask.isKindOf (CM_QBooleanToDoTaskProperty));
	
	// todo task completed query property
	propComplete := qDef.allQueryProperties [CM_QBooleanToDoTaskCompletePro.PREFIX_PROPERTY_NAME &amp; code.String];

	self.assertNotNull (propComplete);// **
	self.assertTrue (propComplete.isKindOf (CM_QBooleanToDoTaskCompletePro));
	
	// todo task completed query property
	propDate := qDef.allQueryProperties [CM_QDateToDoTaskCompletedProp.PREFIX_PROPERTY_NAME &amp; code.String];

	self.assertNotNull (propDate);
	self.assertTrue (propDate.isKindOf (CM_QDateToDoTaskCompletedProp));
	
// --------------------
// update the NICE name
// --------------------
	self.updateToDoTaskDescription (toDoTaskDesc, TASK_SHORTDESC &amp; '*');
	
	assertTrue (propTask.niceName = (CM_QBooleanToDoTaskProperty.PREFIX_NICE_NAME &amp; toDoTaskDesc.shortDescription));
	assertTrue (propDate.niceName = (CM_QDateToDoTaskCompletedProp.PREFIX_NICE_NAME &amp; toDoTaskDesc.shortDescription));
	assertTrue (propComplete.niceName = (CM_QBooleanToDoTaskCompletePro.PREFIX_NICE_NAME &amp; toDoTaskDesc.shortDescription));
	
// ------------------------------
// now get rid of the todo task
// -------------------------------
	self.deleteToDoTaskDescription (toDoTaskDesc);
	
	// check all query p[roperties have been deleted for this todo task
	foreach qDef in app.myRoot.allQueryDefinitionObjects do
		if qDef.type &lt;&gt; qDef.TrackedItem_Query_Type then
			continue;
		endif;
		
		foreach prop in qDef.allQueryProperties do
			if not prop.isToDoTaskProperty then
				continue;
			endif;
			
			self.assertFalse (prop.isKindOf (CM_QBooleanToDoTaskProperty) and prop.CM_QBooleanToDoTaskProperty.toDoTaskCode = code); 
			self.assertFalse (prop.isKindOf (CM_QBooleanToDoTaskCompletePro) and prop.CM_QBooleanToDoTaskCompletePro.toDoTaskCode = code); 
			
			if prop.isKindOf (CM_QDateToDoTaskCompletedProp) and 
				prop.CM_QDateToDoTaskCompletedProp.toDoTaskCode = code then
				write prop;
			endif;
			
			self.assertFalse (prop.isKindOf (CM_QDateToDoTaskCompletedProp) and prop.CM_QDateToDoTaskCompletedProp.toDoTaskCode = code); 
		endforeach;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tToDoTaskEventRef" id="35af6655-c11a-43ee-82e4-6ea139a5ff6b">
        <source>tToDoTaskEventRef();
/*

Purpose:			TFS 2144

Date		Who		Reason
20 Jun 2016	cnwmk3	Initial creation
16 Jan 2017	cnwma1	TFS #2885:QNS - Additional Data Mapping in Customs Message
23 Jan 2023	navma1	ChangeRequest 54349[54262]: EUP - Enable Is Mandatory for ToDo Task Resources
*/
constants
	ContainerId					= "CONTR002144";
	RefString1					= "Reference1";
	RefString2					= "Reference2";
vars
	container					: CM_TrackedItem;
	organisation				: CM_Organisation;
	term						: CM_Terminal;
	tmpUser						: CM_User;
	toDoObj						: CM_ToDoTaskDesc;
	cmifEventReq				: CMIF_EventRequestController;
	pxyEventRequestStops		: CM_EventRequestStops;
	pxyColl						: CM_ObjectArray;
	tiSet						: CM_TISet;
	trxn						: CM_TITransaction;
	toDoRemarks 				: String;
	count						: Integer;
begin
	//create cargo onsite
	self.deleteContainer(ContainerId);
	container := self.addContainerOpts(ContainerId, "2200", "MT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertTrueMsg( container &lt;&gt; null, "Container " &amp; ContainerId &amp; " not created");
	
	organisation := app.myRoot.allOrganisations[ UT_DSL.MasterTermOrg ];
	term := self.getTerminal;
	tmpUser := app.getMyUser;
	
	//Create a To-Do task Cargo Update Request for a cargo item onsite, include a reference
	toDoObj := CM_ToDoTaskDesc.instances.first.CM_ToDoTaskDesc;
	
	create cmifEventReq transient;
	create pxyColl transient;
	create pxyEventRequestStops transient;
	pxyColl.add( pxyEventRequestStops );
		
	toDoRemarks := "Testing To Do Remarks";
			
	pxyEventRequestStops.setProxyRequestStops( EventRequestTypeToDo,	//_type : Integer;
													null,	//_addresses : CM_StringArray;
													toDoObj.description,	//_remarks : String;
													container.id,	//_cargoId : String;
													tmpUser,	//_user : CM_User;
													container.myCargoType,	//_cargoType : CM_CargoType;
													organisation,	//_organisation : CM_Organisation;
													term,	//_terminal : CM_Terminal;
													EventRequestPending,	//_status : Integer;
													false,	//_isClear : Boolean;
													false,	//_isNotify : Boolean;											
													RefString1,	//_ref : String;
													false,	//_cleanup : Boolean;
													null,	//_stopTable : CM_StopsTable;
													null,	//_additionalReqInfo : String;
													null,	//_expiryDate : Date;
													false,	//_isEDI : Boolean;
													toDoObj,	//_toDoDesc : CM_ToDoTaskDesc;
													null,	//_grade : CM_MTGrade;
													null,	//_cargoRemarks : String
													null,	
													toDoRemarks,	
													null,	
													null,	
													null,   // 16/01/2017 cnwma1 TFS #2885
													null,   // 16/01/2017 cnwma1 TFS #2885
													null    // 16/01/2017 cnwma1 TFS #2885
													);
																			
	cmifEventReq.allPxyCargoUpdateRequests.add(pxyEventRequestStops);
	
	app.myTrxUA.trxUpdateEventRequest(cmifEventReq, app.myPassport);
	self.assertTrueMsg( app.myPassport.noErrors, "Errors creating Cargo Event Requests (to do tasks) " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	// Complete the To-Do task.
	create tiSet transient;
	tiSet.add(container);
	self.completeToDoTask(toDoObj, tiSet,null);			//23.01.2023 navma1 #54349[54262]
	
	// Create another To-Do task Cargo Update Request for the same cargo item, with the same To-Do task, but a different reference
	delete cmifEventReq;
	delete pxyColl;
	delete pxyEventRequestStops;
	app.doWindowEvents(1000);
	create cmifEventReq transient;
	create pxyColl transient;
	create pxyEventRequestStops transient;
	pxyColl.add( pxyEventRequestStops );
	pxyEventRequestStops.setProxyRequestStops( EventRequestTypeToDo,	//_type : Integer;
													null,	//_addresses : CM_StringArray;
													toDoObj.description,	//_remarks : String;
													container.id,	//_cargoId : String;
													tmpUser,	//_user : CM_User;
													container.myCargoType,	//_cargoType : CM_CargoType;
													organisation,	//_organisation : CM_Organisation;
													term,	//_terminal : CM_Terminal;
													EventRequestPending,	//_status : Integer;
													false,	//_isClear : Boolean;
													false,	//_isNotify : Boolean;											
													RefString2,	//_ref : String;
													false,	//_cleanup : Boolean;
													null,	//_stopTable : CM_StopsTable;
													null,	//_additionalReqInfo : String;
													null,	//_expiryDate : Date;
													false,	//_isEDI : Boolean;
													toDoObj,	//_toDoDesc : CM_ToDoTaskDesc;
													null,	//_grade : CM_MTGrade;
													null,	//_cargoRemarks : String
													null,	
													toDoRemarks,	
													null,	
													null,
													null,   // 16/01/2017 cnwma1 TFS #2885
													null,   // 16/01/2017 cnwma1 TFS #2885
													null    // 16/01/2017 cnwma1 TFS #2885
												);
													
																			
	cmifEventReq.allPxyCargoUpdateRequests.add(pxyEventRequestStops);
	
	app.myTrxUA.trxUpdateEventRequest(cmifEventReq, app.myPassport);
	self.assertTrueMsg( app.myPassport.noErrors, "Errors creating Cargo Event Requests (to do tasks) " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	// Complete the To-Do task.
	self.completeToDoTask(toDoObj, tiSet,null);		//23.01.2023 navma1 #54349[54262]
	
	// Check the transactions of the cargo item, the reference numbers should not be the same.
	count := 0;
	foreach trxn in container.allTransactions do
		if trxn.isKindOf(CM_TaskAdd) then
			if trxn.getDetails.cnContains("Reference = 'Reference1'") then
				count := count + 1;
			endif;
		endif;
	endforeach;
	self.assertEqual(count , 1);
	
	count := 0;
	foreach trxn in container.allTransactions do
		if trxn.isKindOf(CM_TaskAdd) then
			if trxn.getDetails.cnContains("Reference = 'Reference2'") then
				count := count + 1;
			endif;
		endif;
	endforeach;
	self.assertEqual(count , 1);
epilog
	delete cmifEventReq;
	delete pxyColl;
	delete pxyEventRequestStops;
	delete tiSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tToDoTaskMandatoryResGrps" id="8a0fc192-fe4f-4fb8-96af-6184fb853d0d">
        <source>tToDoTaskMandatoryResGrps();
/*

Purpose:			Tests Mandatory Resource Type Groups on To Do Task Desc Criteria

Parameters:			NONE

Return Value:		NONE

Date				Who		Reason
12 December 2023	navpw1	Initial creation TFS: 58758 (60742)

*/

constants
	UT_TaskDesc_Code1				: String	= "UT_58758-1";
	UTResourceTypeMan				: String	= "UTMAN";
	UTResourceTypeForklift			: String	= "UTForkLift";
	UTResourceTypeWood				: String	= "UTWood";
	UT_ResourceGroupMachineCode		: String	= "UTMACHINE";
	UT_ResourceGroupMachineDesc		: String	= "UTMachine";
	UT_ResourceGroupMaterialCode	: String	= "UTMATERIAL";
	UT_ResourceGroupMaterialDesc	: String	= "UTMaterial";
	UT_ResourceGroupPersonnelCode	: String	= "UTPERSONNEL";
	UT_ResourceGroupPersonnelDesc	: String	= "UTPersonnel";
	UT_BLOCKSTACK					: String	= 'UTB58758';
	UT_OPERATOR						: String	= 'UTOP';
	CONTAINERTEST1					: String	= "58758-1";
	CONTAINERTEST2					: String	= "58758-2";
	
vars
	realResourceTypeMan,
	realResourceTypeForklift,
	realResourceTypeWood			: CM_ResourceType;
	toDoTaskDesc					: CM_ToDoTaskDesc;
	ti1,
	ti2								: CM_TrackedItem;
	tiSet							: CM_TISet;
	tiTask1,
	tiTask2							: CM_ToDoTask;
	resourceUsageProxys				: CM_ResourceTypeUsageSet;
	
	utSystemHelper					: UT_HelperAdmSys;
	toDoTasks						: CM_ToDoTaskDescBySortKey;
	pxyResourceTypeGroup,
	realResourceTypeGroupMachine,
	realResourceTypeGroupMaterial,
	realResourceTypeGroupPersonnel	: CM_ResourceTypeGroup;
	testString,
	completeTestString				: String;
	pxyTaskCriteria,
	realTaskCriteria				: CM_TaskCriteria;
	actions							: IntegerArray;
	availableResourceGroups,
	mandatoryResourceGroups			: CM_ResourceTypeGroupByCode;
	blockStack						: CM_BlockStack;
	operator						: CM_Operator;
	pxyResourceUsage				: CM_ResourceTypeUsage;
	transactionCompleted,
	transactionCompletedMan,
	transactionCompletedForklift,
	transactionCompletedWood,
	toDoTaskTranComplete			: Boolean;
	terminal						: CM_Terminal;
	
begin
	/*
	** Global Setup - Started
	*/
	self.logMessage("Global Setup - Started");
	testString := "Test";
	completeTestString := method.qualifiedName &amp; Space &amp; "-" &amp; Space &amp; testString &amp; Space &amp; "1.1" &amp; Colon;
	terminal := app.myPassport.myTerminal;
	
	//Delete Terminal Area
	self.deleteTerminalArea(UT_BLOCKSTACK);
	self.logMessage("Deleted blockstack: " &amp; UT_BLOCKSTACK);
	
	create utSystemHelper transient;
	utSystemHelper.setActiveProfile;
	utSystemHelper.currentMethodBeingRun := UT_ToDoTasks::tToDoTaskMandatoryResGrps;
	
	//Delete To Do Task Desc
	utSystemHelper.xDeleteToDoTaskDesc(UT_TaskDesc_Code1);
	self.logMessage("Deleted To Do Task Desc: " &amp; UT_TaskDesc_Code1);
	
	//Get Resource Types
	realResourceTypeMan := app.myRoot.allTaskResourceTypes[UTResourceTypeMan];
	realResourceTypeForklift := app.myRoot.allTaskResourceTypes[UTResourceTypeForklift];
	realResourceTypeWood := app.myRoot.allTaskResourceTypes[UTResourceTypeWood];
	
	//Change hasBeenUsed on Resource Types
	if realResourceTypeMan &lt;&gt; null then
		beginTransaction;
		realResourceTypeMan.setPropertyValue(CM_ResourceType::hasBeenUsed.name, false);
		commitTransaction;
		self.logMessage("Changed hasBeenUsed on resource type: " &amp; UTResourceTypeMan &amp; " | to value 'false'");
	endif;
	transactionCompletedMan := true;
	
	if realResourceTypeForklift &lt;&gt; null then
		transactionCompletedForklift := false;
		beginTransaction;
		realResourceTypeForklift.setPropertyValue(CM_ResourceType::hasBeenUsed.name, false);
		commitTransaction;
		
		self.logMessage("Changed hasBeenUsed on resource type: " &amp; UTResourceTypeForklift &amp; " | to value 'false'");
	endif;
	transactionCompletedForklift := true;
	
	if realResourceTypeWood &lt;&gt; null then
		beginTransaction;
		realResourceTypeWood.setPropertyValue(CM_ResourceType::hasBeenUsed.name, false);
		commitTransaction;
		self.logMessage("Changed hasBeenUsed on resource type: " &amp; UTResourceTypeWood &amp; " | to value 'false'");
	endif;
	transactionCompletedWood := true;
	
	//Delete Resource Types
	self.deleteResourceType(UTResourceTypeMan);
	self.logMessage("Deleted Resource Type: " &amp; UTResourceTypeMan);
	
	self.deleteResourceType(UTResourceTypeForklift);
	self.logMessage("Deleted Resource Type: " &amp; UTResourceTypeForklift);
	
	self.deleteResourceType(UTResourceTypeWood);
	self.logMessage("Deleted Resource Type: " &amp; UTResourceTypeWood);
	
	//Delete Resource Type Groups
	utSystemHelper.xDeleteResourceTypeGroup(UT_ResourceGroupMachineCode);
	self.logMessage("Deleted Resource Type Group: " &amp; UT_ResourceGroupMachineCode);
	
	utSystemHelper.xDeleteResourceTypeGroup(UT_ResourceGroupMaterialCode);
	self.logMessage("Deleted Resource Type Group: " &amp; UT_ResourceGroupMaterialCode);
	
	utSystemHelper.xDeleteResourceTypeGroup(UT_ResourceGroupPersonnelCode);
	self.logMessage("Deleted Resource Type Group: " &amp; UT_ResourceGroupPersonnelCode);
	
	//Create To Do Task Desc
	self.opts.purge;
	self.opts.addAssoc(UT_OPTS_CompleteTransType, TRANS_TYPE_TASKCOMPLETE);
	self.opts.addAssoc(UT_OPTS_CreateTransType, TRANS_TYPE_TASKADD);
	toDoTaskDesc := utSystemHelper.xCreateToDoTaskDesc(method.qualifiedName, UT_TaskDesc_Code1, "CONT");
	self.assertNoTrxErrorsOrWarnings();
	self.logMessage("Created To Do Task Desc: " &amp; UT_TaskDesc_Code1);
	
	create toDoTasks transient;
	toDoTasks.add(toDoTaskDesc);
	
	//Create Resource Types
	realResourceTypeMan := self.addToDoTaskResource(UTResourceTypeMan, UTResourceTypeMan, "MAN", 0, false, true, toDoTasks);
	self.logMessage("Created Resource Type: " &amp; UTResourceTypeMan);
	
	realResourceTypeForklift := self.addToDoTaskResource(UTResourceTypeForklift, UTResourceTypeForklift, "Machine", 0, false, true, toDoTasks);
	self.logMessage("Created Resource Type: " &amp; UTResourceTypeForklift);
	
	realResourceTypeWood := self.addToDoTaskResource(UTResourceTypeWood, UTResourceTypeWood, "Item", 0, false, true, toDoTasks);
	self.logMessage("Created Resource Type: " &amp; UTResourceTypeWood);
	
	delete toDoTasks;
	
	//Create Resource Type Groups
	create pxyResourceTypeGroup transient;
	pxyResourceTypeGroup.allResourceTypes.add(realResourceTypeForklift);
	pxyResourceTypeGroup.setProxy(UT_ResourceGroupMachineCode, UT_ResourceGroupMachineDesc, false);
	realResourceTypeGroupMachine := utSystemHelper.xCreateResourceTypeGroup(pxyResourceTypeGroup);
	self.assertNotNullMsg(realResourceTypeGroupMachine, completeTestString &amp; " realResourceTypeGroupMachine");
	self.logMessage("Created Resource Type Group: " &amp; UT_ResourceGroupMachineCode);
	
	delete pxyResourceTypeGroup;
	
	create pxyResourceTypeGroup transient;
	pxyResourceTypeGroup.allResourceTypes.add(realResourceTypeWood);
	pxyResourceTypeGroup.setProxy(UT_ResourceGroupMaterialCode, UT_ResourceGroupMaterialDesc, false);
	realResourceTypeGroupMaterial := utSystemHelper.xCreateResourceTypeGroup(pxyResourceTypeGroup);
	self.assertNotNullMsg(realResourceTypeGroupMaterial, completeTestString &amp; " realResourceTypeGroupMaterial");
	self.logMessage("Created Resource Type Group: " &amp; UT_ResourceGroupMaterialCode);
	
	delete pxyResourceTypeGroup;
	
	create pxyResourceTypeGroup transient;
	pxyResourceTypeGroup.allResourceTypes.add(realResourceTypeMan);
	pxyResourceTypeGroup.setProxy(UT_ResourceGroupPersonnelCode, UT_ResourceGroupPersonnelDesc, false);
	realResourceTypeGroupPersonnel := utSystemHelper.xCreateResourceTypeGroup(pxyResourceTypeGroup);
	self.assertNotNullMsg(realResourceTypeGroupPersonnel, completeTestString &amp; " realResourceTypeGroupPersonnel");
	self.logMessage("Created Resource Type Group: " &amp; UT_ResourceGroupPersonnelCode);
	
	delete pxyResourceTypeGroup;
	
	//Create To Do Task Criteria
	create pxyTaskCriteria transient;
	create actions transient;
	actions.add(TRANS_TYPE_PackComplete);
	actions.add(TRANS_TYPE_UnpackComplete);
	self.assertEqualMsg(actions.size(), 2, completeTestString &amp; " wrong number of children");
	
	create availableResourceGroups transient;
	create mandatoryResourceGroups transient;
	mandatoryResourceGroups.add(realResourceTypeGroupMachine);
	mandatoryResourceGroups.add(realResourceTypeGroupMaterial);
	availableResourceGroups.add(realResourceTypeGroupMachine);
	availableResourceGroups.add(realResourceTypeGroupMaterial);
	availableResourceGroups.add(realResourceTypeGroupPersonnel);
	pxyTaskCriteria.setProxyBaseData(actions, QUEUE_MODE, PLANNING_MODE, app.myPassport.myTerminal, toDoTaskDesc, availableResourceGroups, mandatoryResourceGroups);
	realTaskCriteria := utSystemHelper.xCreateTaskCriteria(pxyTaskCriteria);
	delete actions;
	delete pxyTaskCriteria;
	delete availableResourceGroups;
	delete mandatoryResourceGroups;
	self.assertNotNullMsg(realTaskCriteria, completeTestString &amp; " realTaskCriteria");
	self.logMessage("Created To Do Task Criteria for Terminal: " &amp; terminal.code);
	
	//Create BlockStack
	blockStack := self.addBlockStack(UT_BLOCKSTACK, 10, null);
	self.assertNotNullMsg(blockStack, "Global Setup - blockStack");
	self.logMessage("Created blockstack: " &amp; UT_BLOCKSTACK);
	
	//Get Operator
	operator := self.getOperator(UT_OPERATOR);
	self.assertNotNullMsg(operator, "Global Setup - operator");
	
	//Create Containers for testing
	ti1 := self.addContainerAtLocation(CONTAINERTEST1, operator, "22G1", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.myLocationsController);
	self.logMessage("Created Container: " &amp; CONTAINERTEST1);
	
	ti2 := self.addContainerAtLocation(CONTAINERTEST2, operator, "22G1", "GENL", TI_IMEX_STATUS_IMPORT, blockStack.myLocationsController);
	self.logMessage("Created Container: " &amp; CONTAINERTEST2);
	
	self.logMessage("Global Setup - Finished" &amp; CrLf);
	
	/*
	** Global Setup - Finished
	*/
	
	/*
	** Test 1 - Start - Complete to do task on container with all resource groups
	*/
	self.logMessage("Test 1 - Started | Details: Complete to do task on container with all resource groups");
	//Add to do task to containers
	completeTestString := method.qualifiedName &amp; Space &amp; "-" &amp; Space &amp; testString &amp; Space &amp; "1" &amp; Colon;
	beginTransaction;
	tiTask1 := ti1.addToDoTask(toDoTaskDesc.description.trimBlanks , app.myPassport);
	tiTask2 := ti2.addToDoTask(toDoTaskDesc.description.trimBlanks , app.myPassport);
	commitTransaction;
	toDoTaskTranComplete := true;
	self.logMessage("Added to do task to Tis: " &amp; CONTAINERTEST1 &amp; ", " &amp; CONTAINERTEST2);
	
	create resourceUsageProxys transient;
	create pxyResourceUsage transient;
	pxyResourceUsage.setProxy(realResourceTypeForklift,
							null,							//_transaction : CM_TITransaction;
							null,
							1,
							"Rem1",
							CM_InvoiceLine.STATUS_NORMAL,
							null,							//_fromDateTime : TimeStamp
							null,							//_toDateTime : TimeStamp
							null,
							null,
							null
							);
	resourceUsageProxys.add(pxyResourceUsage);
	
	create pxyResourceUsage transient;
	pxyResourceUsage.setProxy(realResourceTypeWood,
							null,							//_transaction : CM_TITransaction;
							null,
							2,
							"Rem2",
							CM_InvoiceLine.STATUS_NORMAL,
							null,							//_fromDateTime : TimeStamp
							null,							//_toDateTime : TimeStamp
							null,
							null,
							null
							);
	resourceUsageProxys.add(pxyResourceUsage);
	
	create pxyResourceUsage transient;
	pxyResourceUsage.setProxy(realResourceTypeMan,
							null,							//_transaction : CM_TITransaction;
							null,
							3,
							"Rem3",
							CM_InvoiceLine.STATUS_NORMAL,
							null,							//_fromDateTime : TimeStamp
							null,							//_toDateTime : TimeStamp
							null,
							null,
							null
							);
	resourceUsageProxys.add(pxyResourceUsage);
	
	self.logMessage("Created resource usages for: " &amp; UTResourceTypeForklift &amp; ", " &amp; UTResourceTypeWood &amp; ", " &amp; UTResourceTypeMan);
	
	create tiSet transient;
	tiSet.add(ti1);
	tiSet.add(ti2);
	
	self.logMessage("Running TRX");
	app.myTrxUA.trxUpdateTIToDoTaskCmpltBulk(toDoTaskDesc, tiSet, resourceUsageProxys, app.myPassport);
	self.logMessage("TRX Finished");
	self.assertNoTrxErrorsOrWarnings();
	
	self.logMessage("Test Cleanup - Started");
	resourceUsageProxys.purge;
	delete tiSet;
	delete resourceUsageProxys;
	self.logMessage("Test Cleanup - Finished");
	
	self.logMessage("Test 1: Finished - PASSED | Details: Complete to do task on container with all resource groups" &amp; CrLf);
	
	
	/*
	** Test 1 - Finish - Complete to do task on container with all resource groups
	*/
	
	/*
	** Test 2 - Start - Complete to do task on container with mandatory resource groups only
	*/
	self.logMessage("Test 2 - Started | Details: Complete to do task on container with mandatory resource groups only");
	//Add to do task to containers
	completeTestString := method.qualifiedName &amp; Space &amp; "-" &amp; Space &amp; testString &amp; Space &amp; "1" &amp; Colon;
	toDoTaskTranComplete := false;
	beginTransaction;
	tiTask1 := ti1.addToDoTask(toDoTaskDesc.description.trimBlanks , app.myPassport);
	tiTask2 := ti2.addToDoTask(toDoTaskDesc.description.trimBlanks , app.myPassport);
	commitTransaction;
	toDoTaskTranComplete := true;
	self.logMessage("Added to do task to Tis: " &amp; CONTAINERTEST1 &amp; ", " &amp; CONTAINERTEST2);
	
	create resourceUsageProxys transient;
	create pxyResourceUsage transient;
	pxyResourceUsage.setProxy(realResourceTypeForklift,
							null,							//_transaction : CM_TITransaction;
							null,
							1,
							"Rem1",
							CM_InvoiceLine.STATUS_NORMAL,
							null,							//_fromDateTime : TimeStamp
							null,							//_toDateTime : TimeStamp
							null,
							null,
							null
							);
	resourceUsageProxys.add(pxyResourceUsage);
	
	create pxyResourceUsage transient;
	pxyResourceUsage.setProxy(realResourceTypeWood,
							null,							//_transaction : CM_TITransaction;
							null,
							2,
							"Rem2",
							CM_InvoiceLine.STATUS_NORMAL,
							null,							//_fromDateTime : TimeStamp
							null,							//_toDateTime : TimeStamp
							null,
							null,
							null
							);
	resourceUsageProxys.add(pxyResourceUsage);
	
	self.logMessage("Created resource usages for: " &amp; UTResourceTypeForklift &amp; ", " &amp; UTResourceTypeWood &amp; ", " &amp; UTResourceTypeMan);
	
	create tiSet transient;
	tiSet.add(ti1);
	tiSet.add(ti2);
	
	self.logMessage("Running TRX");
	app.myTrxUA.trxUpdateTIToDoTaskCmpltBulk(toDoTaskDesc, tiSet, resourceUsageProxys, app.myPassport);
	self.logMessage("TRX Finished");
	self.assertNoTrxErrorsOrWarnings();
	
	self.logMessage("Test Cleanup - Started");
	resourceUsageProxys.purge;
	delete tiSet;
	delete resourceUsageProxys;
	self.logMessage("Test Cleanup - Finished");
	
	self.logMessage("Test 2: Finished - PASSED | Details: Complete to do task on container with mandatory resource groups only" &amp; CrLf);
	
	/*
	** Test 2 - Finish - Complete to do task on container with mandatory resource groups only
	*/
	
	/*
	** Test 3 - Start - Complete to do task on container with 1 resource group only (Missing 1 mandatory group)
	*/
	self.logMessage("Test 3 - Started | Details: Complete to do task on container with 1 resource group only (Missing 1 mandatory group)");
	//Add to do task to containers
	completeTestString := method.qualifiedName &amp; Space &amp; "-" &amp; Space &amp; testString &amp; Space &amp; "3" &amp; Colon;
	toDoTaskTranComplete := false;
	beginTransaction;
	tiTask1 := ti1.addToDoTask(toDoTaskDesc.description.trimBlanks , app.myPassport);
	tiTask2 := ti2.addToDoTask(toDoTaskDesc.description.trimBlanks , app.myPassport);
	commitTransaction;
	toDoTaskTranComplete := true;
	self.logMessage("Added to do task to Tis: " &amp; CONTAINERTEST1 &amp; ", " &amp; CONTAINERTEST2);
	
	create resourceUsageProxys transient;
	create pxyResourceUsage transient;
	pxyResourceUsage.setProxy(realResourceTypeForklift,
							null,							//_transaction : CM_TITransaction;
							null,
							1,
							"Rem1",
							CM_InvoiceLine.STATUS_NORMAL,
							null,							//_fromDateTime : TimeStamp
							null,							//_toDateTime : TimeStamp
							null,
							null,
							null
							);
	resourceUsageProxys.add(pxyResourceUsage);
	
	self.logMessage("Created resource usages for: " &amp; UTResourceTypeForklift);
	
	create tiSet transient;
	tiSet.add(ti1);
	tiSet.add(ti2);
	
	self.logMessage("Running TRX");
	app.myTrxUA.trxUpdateTIToDoTaskCmpltBulk(toDoTaskDesc, tiSet, resourceUsageProxys, app.myPassport);
	self.logMessage("TRX Finished");
	self.assertTrxErrorMsg(Mandatory_res_type_grps_miss, completeTestString &amp; "Expected to raise error with code: " &amp; Mandatory_res_type_grps_miss.String &amp; " | Actual: no error raised");
	
	self.logMessage("Test Cleanup - Started");
	resourceUsageProxys.purge;
	delete tiSet;
	delete resourceUsageProxys;
	self.logMessage("Test Cleanup - Finished");
	
	self.logMessage("Test 3: Finished - PASSED | Details: Complete to do task on container with 1 resource group only (Missing 1 mandatory group)" &amp; CrLf);
	
	/*
	** Test 3 - Finished - Complete to do task on container with 1 resource group only (Missing 1 mandatory group)
	*/
	
	/*
	** Global Cleanup
	*/
	self.logMessage("Global Cleanup: Started");
	
	self.deleteTerminalArea(UT_BLOCKSTACK);
	self.logMessage("Deleted blockstack: " &amp; UT_BLOCKSTACK);
	
	utSystemHelper.xDeleteToDoTaskDesc(UT_TaskDesc_Code1);
	self.logMessage("Deleted To Do Task Desc: " &amp; UT_TaskDesc_Code1);
	
	transactionCompleted := false;
	
	beginTransaction;
	realResourceTypeMan.setPropertyValue(CM_ResourceType::hasBeenUsed.name, false);
	realResourceTypeForklift.setPropertyValue(CM_ResourceType::hasBeenUsed.name, false);
	realResourceTypeWood.setPropertyValue(CM_ResourceType::hasBeenUsed.name, false);
	commitTransaction;
	transactionCompleted := true;
	
	self.logMessage("Changed hasBeenUsed on resource type: " &amp; UTResourceTypeMan &amp; " | to value 'false'");
	self.logMessage("Changed hasBeenUsed on resource type: " &amp; UTResourceTypeForklift &amp; " | to value 'false'");
	self.logMessage("Changed hasBeenUsed on resource type: " &amp; UTResourceTypeWood &amp; " | to value 'false'");
	
	self.deleteResourceType(UTResourceTypeMan);
	self.logMessage("Deleted Resource Type: " &amp; UTResourceTypeMan);
	
	self.deleteResourceType(UTResourceTypeForklift);
	self.logMessage("Deleted Resource Type: " &amp; UTResourceTypeForklift);
	
	self.deleteResourceType(UTResourceTypeWood);
	self.logMessage("Deleted Resource Type: " &amp; UTResourceTypeWood);
	
	utSystemHelper.xDeleteResourceTypeGroup(UT_ResourceGroupMachineCode);
	self.logMessage("Deleted Resource Type Group: " &amp; UT_ResourceGroupMachineCode);
	
	utSystemHelper.xDeleteResourceTypeGroup(UT_ResourceGroupMaterialCode);
	self.logMessage("Deleted Resource Type Group: " &amp; UT_ResourceGroupMaterialCode);
	
	utSystemHelper.xDeleteResourceTypeGroup(UT_ResourceGroupPersonnelCode);
	self.logMessage("Deleted Resource Type Group: " &amp; UT_ResourceGroupPersonnelCode);
	
	self.logMessage("Global Cleanup: Finished");
	
epilog
	delete utSystemHelper;
	delete tiSet;
	
	if resourceUsageProxys &lt;&gt; null and resourceUsageProxys.isNotEmpty then
		resourceUsageProxys.purge;
	endif;
	
	delete resourceUsageProxys;
	
	if not transactionCompleted or not transactionCompletedForklift or not transactionCompletedMan or not transactionCompletedWood or not toDoTaskTranComplete then
		abortTransaction;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tTrnsForUserDefinedTasks" id="5f0c426c-b46f-40b5-8204-139a6ca25981">
        <source>tTrnsForUserDefinedTasks();
/*

Purpose:			

Date		Who		Reason
05 Ape2016	cnwmk3	Initial creation
15 Oct 2019	jlgsl4	TFS 46767 - PEN - GenSet Trailer Linking
02 Nov 2022 navds20 ChangeRequest 56635:[54261] EUP - Todo Task Resources Maintenance
23 Jan 2023	navma1	ChangeRequest 54349[54262]: EUP - Enable Is Mandatory for ToDo Task Resources
*/
constants
	ToDoTaskCode1 		: String = "UT_1694";
	ContainerId 		: String = "UTCONTR1694";
vars
	toDoTaskDesc		: CM_ToDoTaskDesc;
	proxyToDoTask		: CM_ToDoTaskDesc;
	container 			: CM_TrackedItem;
	tiSet 				: CM_TISet;
	tiTrn				: CM_TITransaction;
	selectedCargoTypes	: ObjectArray;
	vvr					: CM_VehicleVisitRecord;
begin
	//setup new todo task desc with TRANS_TYPE_WASH
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[ToDoTaskCode1];
	self.deleteToDoTaskDescription(toDoTaskDesc);
	self.opts.addAssoc(ETRow_TransactionToCreate, TRANS_TYPE_WASH);
	toDoTaskDesc := self.createToDoTaskDesc(ToDoTaskCode1);
	self.assertNotNullMsg(toDoTaskDesc, "Add To Do Task failed");
	
	self.deleteContainer(ContainerId);
	container := self.addContainerOpts(ContainerId, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	create tiSet transient;
	tiSet.add(container);
	
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[ToDoTaskCode1];  
		
	self.addToDoTask(toDoTaskDesc, tiSet);
	assertEqual(container.allToDoTasksToDo.size, 1);
	
	self.completeToDoTask(toDoTaskDesc, tiSet,null);			//23.01.2023 navma1 #54349[54262]
	
	// check that TRANS_TYPE_WASH transaction is created
	tiTrn := container.allTransactions.last;
	self.assertTrue(tiTrn.isKindOf(CM_Wash));
	assertEqual(tiTrn.id, ContainerId);
	assertEqual(tiTrn.typeString, "Washed");
	assertEqual(container.CM_Container.washDT, tiTrn.dateTime);
	assertEqual(container.CM_Container.isClean, true);
	delete tiSet;
	
//setup new todo task desc with TRANS_TYPE_CONNECT
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[ToDoTaskCode1];
	self.deleteToDoTaskDescription(toDoTaskDesc);
	self.opts.addAssoc(ETRow_TransactionToCreate, TRANS_TYPE_CONNECT);
	toDoTaskDesc := self.createToDoTaskDesc(ToDoTaskCode1);
	self.assertNotNullMsg(toDoTaskDesc, "Add To Do Task failed");
	
	self.deleteContainer(ContainerId);
	container := self.addContainerOpts(ContainerId, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	create tiSet transient;
	tiSet.add(container);
	
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[ToDoTaskCode1];  
		
	self.addToDoTask(toDoTaskDesc, tiSet);
	assertEqual(container.allToDoTasksToDo.size, 1);
	
	self.completeToDoTask(toDoTaskDesc, tiSet,null);				//23.01.2023 navma1 #54349[54262]
	
	// check that TRANS_TYPE_CONNECT transaction is created
	tiTrn := container.allTransactions.last;
	self.assertTrue(tiTrn.isKindOf(CM_Connect));
	assertEqual(tiTrn.id, ContainerId);
	assertEqual(tiTrn.typeString, "Connected");
	assertEqual(container.CM_Container.getLastConnectDT(), tiTrn.dateTime);
	delete tiSet;
	
	//setup new todo task desc with TRANS_TYPE_HIDE
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[ToDoTaskCode1];
	self.deleteToDoTaskDescription(toDoTaskDesc);
	self.opts.addAssoc(ETRow_TransactionToCreate, TRANS_TYPE_HIDE);
	toDoTaskDesc := self.createToDoTaskDesc(ToDoTaskCode1);
	self.assertNotNullMsg(toDoTaskDesc, "Add To Do Task failed");
	
	self.deleteContainer(ContainerId);
	container := self.addContainerOpts(ContainerId, "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
	create tiSet transient;
	tiSet.add(container);
	
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[ToDoTaskCode1];  
		
	self.addToDoTask(toDoTaskDesc, tiSet);
	assertEqual(container.allToDoTasksToDo.size, 1);
	
	self.completeToDoTask(toDoTaskDesc, tiSet,null);				//23.01.2023 navma1 #54349[54262]
	
	// check that TRANS_TYPE_HIDE transaction is created
	tiTrn := container.allTransactions.last;
	self.assertTrue(tiTrn.isKindOf(CM_HideLined));
	assertEqual(tiTrn.id, ContainerId);
	assertEqual(tiTrn.typeString, "Hide-Lined");
	assertEqual(container.CM_Container.hideLinedDT, tiTrn.dateTime);
	self.assertEqual(container.CM_Container.hideLined, true);
	delete tiSet;
	
	//setup new todo task desc with TRANS_TYPE_CONNECTPOWER
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[ToDoTaskCode1];
	self.deleteToDoTaskDescription(toDoTaskDesc);
	self.opts.addAssoc(ETRow_TransactionToCreate, TRANS_TYPE_CONNECT_POWER);
	toDoTaskDesc := self.createToDoTaskDesc(ToDoTaskCode1);
	self.assertNotNullMsg(toDoTaskDesc, "Add To Do Task failed");
	
	self.deleteContainer(ContainerId);
	self.opts.purge();
	self.opts.addAssoc("AllowableTimeOffPower", 2.Decimal);
	self.deleteVehicle("UT_TRK01");
	vvr := self.gateInContainer("UT_TRK01", ContainerId, "2200", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code, "APPL", self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString));
	container := self.getTrackedItem(ContainerId);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	create tiSet transient;
	tiSet.add(container);
	
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[ToDoTaskCode1];  
		
	self.addToDoTask(toDoTaskDesc, tiSet);
	assertEqual(container.allToDoTasksToDo.size, 1);
	
	self.completeToDoTask(toDoTaskDesc, tiSet,null);					//23.01.2023 navma1 #54349[54262]
	
	// check that TRANS_TYPE_CONNECTPOWER transaction is created
	tiTrn := container.allTransactions.last;
	self.assertTrue(tiTrn.isKindOf(CM_ConnectPower));
	assertEqual(tiTrn.id, ContainerId);
	assertEqual(tiTrn.typeString, "Power Connected");
	assertEqual(container.CM_Container.getFirstConnectDT, tiTrn.dateTime);
	self.assertEqual(container.CM_Container.getLastConnectDT, tiTrn.dateTime);
	delete tiSet;


//setup new todo task desc with TRANS_TYPE_INSPECT
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[ToDoTaskCode1];
