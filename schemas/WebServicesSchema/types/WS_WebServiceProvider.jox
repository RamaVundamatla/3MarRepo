    <JadeMethod name="create" id="10794b6a-2ba0-4349-bd39-7ce3799b6044">
        <updating/>
        <source>create() updating;

/*

Purpose:			Initialise for new web service request

Parameters:			None

Return Value:		None


Date		Who		Reason
12 Dec 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars
	passport		: CM_Passport;
	
begin
	// Initialise passport for no user unconditionally
	passport := app.myPassport;
	passport.setForLogon(null);
	
	if currentSession &lt;&gt; null and currentSession.myUser &lt;&gt; null then
		passport.setForLogon(currentSession.myUser);
	endif;
	
	create self.myWebServiceAgent transient;
end;
</source>
    </JadeMethod>
