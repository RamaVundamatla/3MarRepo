    <JadeMethod name="displayExtraInfo" id="591faf1c-606f-4f18-b25b-362d7a4fbd13">
        <source>displayExtraInfo()protected;
//--------------------------------------------------
// Created:	15 July 2005 By: cnwgd1
//--------------------------------------------------
vars
	dataContainer : CM_DataContainer;
	wle 		: CM_WorkListEntry;
	strArray	: HugeStringArray;
begin
	
	self.tblInfo.rows := 0;
	if self.myCurrentVessel = null then
		return;
	endif;
	
	create dataContainer transient;
	dataContainer.headerColour := self.colorHeadingColumn;
	dataContainer.valueColour := self.colorValueColumn;

	self.myCurrentVessel.getExtraInfo(dataContainer);

	self.tblInfo.userObject	:=	self.myCurrentVessel; // this is used to redraw this info
	self.showExtraInformation(dataContainer, self.tblInfo, true,false,4,1,4,1,1);
	
	
epilog
	delete dataContainer;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayVessels" id="02798749-6a52-41ba-8722-16e5ab6bb7ed">
        <updating/>
        <source>displayVessels()updating, protected;
//--------------------------------------------------
// Created:	18 July 2005 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 31/03/2016	cnwdap1		PAR #35843 Make monitor time-based rather than object count based
vars
	rowPointer		: Integer;
	vesselObj		: CM_Vessel;
	passportObj		: CM_Passport;
	iteratorObj		: Iterator;
	allVesselsObj	: Dictionary;
	saveSelected	: CM_Vessel;
	monitorObj		: CMIF_Monitor;	
	cnt				: Integer;
	partsInJob		: Integer;
	partsDone 		: Integer;
	failedDAC  :CM_DataAccessController;
	lastUpdate		: Decimal [20];							// PAR #35843
	
begin
	//app.mousePointer := self.MousePointer_HourGlass;
	passportObj	:=	app.myPassport;
	self.tblData.rows	:=	self.tblData.fixedRows;
	self.tblInfo.rows	:=	0;
	self.picVessel.picture	:=	null;
	self.tblData.clearAllSelected();
	saveSelected	:=	self.myCurrentVessel;
	monitorObj		:=	passportObj.myCMIFMonitor;
	
	if monitorObj = null then
		create monitorObj transient;
		monitorObj.myParent	:=	self;
		passportObj.setMyCMIFMonitor(monitorObj);
	endif;

	self.modalDialogReturnValue	:=	self.ModalDialogReturn_Null;
	self.modalDialogShow(null, 'Cancel' , null, null, 'Loading Vessels',  'Please Wait....');
	self.pbProgressBar.visible	:=	true;
	allVesselsObj				:=	app.myRoot.allVessels;
	
	if self.filterCode &lt;&gt; null then
		// Filtering by code		
		vesselObj	:=	allVesselsObj[self.filterCode].CM_Vessel;
		
		if vesselObj &lt;&gt; null 	// par14186
			and vesselObj.canUserAccessSelf(null, failedDAC,passportObj) then
				self.tblDataDisplayRow(vesselObj);
				return;
		endif;
			
		// vessel not found
		// show all vessels that start with the entered code
		iteratorObj	:=	allVesselsObj.createIterator();
		allVesselsObj.startKeyGeq(self.filterCode, iteratorObj);

		partsInJob	:=	allVesselsObj.size();
		monitorObj.updateProgress(monitorObj.message, partsInJob, partsDone);
		
		while iteratorObj.next(vesselObj) do
			if not vesselObj.canUserAccessSelf(null, failedDAC,passportObj) then
				continue;
			endif;
			
			partsDone	:=	partsDone + 1;
			cnt	:=	cnt + 1;
			
			if self.filterCode &lt;&gt; null then
				if (not vesselObj.code.startsWith(self.filterCode)) then
					break;
				endif;
			endif;
			
			if self.includeVessel(vesselObj, passportObj) then
				self.tblDataDisplayRow(vesselObj);
			endif;

			//if cnt = 100 then																			// PAR #35843
			if (app.relativeMachineTime - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	// PAR #35843
				if (not monitorObj.updateProgress(monitorObj.message, partsInJob, partsDone)) then
					break;
				endif;
				
				cnt	:=	0;
				lastUpdate := app.relativeMachineTime;													// PAR #35843
			endif;
		endwhile;
	else
		self.displayVesselsForDict(allVesselsObj);
	endif;
epilog
	if saveSelected &lt;&gt; null then
		if self.tblData.findObjectInRow(saveSelected, rowPointer) then
			self.tblData.selectRow(rowPointer, false);
			self.setSelectedVessel(saveSelected);
		else
			self.setSelectedVessel(null);
		endif;
	else
		self.setSelectedVessel(null);
	endif;
	
	delete iteratorObj;
	self.statusLine.caption	:=	(self.tblData.rows-self.tblData.fixedRows).String &amp; ' rows found.';
	self.tblData.colourRows(self.colorRow1, self.colorRow2);
	delete monitorObj;
	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible	:=	false;
	app.mousePointer	:=	self.MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayVesselsForDict" id="6511fa08-5295-4f8a-8a47-62077825a562">
        <source>displayVesselsForDict(_vesselDict : Dictionary)protected;
//--------------------------------------------------
// Created:	18 July 2005 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 31/03/2016	cnwdap1		PAR #35843 Make monitor time-based rather than object count based
vars
	vesselObj	: CM_Vessel;
	passportObj	: CM_Passport;
	iteratorObj	: Iterator;
	monitorObj	: CMIF_Monitor;
	cnt,
	partsInJob,
	partsDone : Integer;
	failedDAC  :CM_DataAccessController;
	lastUpdate	: Decimal [20];									// PAR #35843
	
begin
	if _vesselDict = null then
		return;
	endif;
	
	passportObj	:=	app.myPassport;
	monitorObj	:=	passportObj.myCMIFMonitor;
	
	if monitorObj &lt;&gt; null then
		partsInJob := _vesselDict.size;
		monitorObj.updateProgress(monitorObj.message, partsInJob, partsDone);
	endif;
	
	iteratorObj := _vesselDict.createIterator();

	while iteratorObj.next(vesselObj) do
		if not vesselObj.canUserAccessSelf(null, failedDAC,passportObj) then
			continue;
		endif;
		
		partsDone	:=	partsDone+1;
		cnt			:=	cnt + 1;
		
		if self.includeVessel(vesselObj, passportObj) then
			self.tblDataDisplayRow(vesselObj);
		endif;

		if monitorObj &lt;&gt; null then
			//if cnt = 100 then																			// PAR #35843
			if (app.relativeMachineTime - lastUpdate) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then	// PAR #35843
				if (not monitorObj.updateProgress(monitorObj.message, partsInJob, partsDone)) then
					break;
				endif;
				
				cnt	:=	0;
				lastUpdate := app.relativeMachineTime;													// PAR #35843
			endif;
		endif;
	endwhile;
epilog
	delete iteratorObj;
end;</source>
        <access>protected</access>
        <Parameter name="_vesselDict" type="Dictionary"/>
    </JadeMethod>
