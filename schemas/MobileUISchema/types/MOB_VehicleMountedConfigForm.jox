    <JadeMethod name="translateForm" id="e2a0a3b1-1cc3-4dea-984d-7cda5d1b88eb">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014858, locale);
	btnAbout.translateCaption(Xlat_0018501, locale);
	btnCancel.translateCaption(Xlat_0018502, locale);
	btnChgLocale.translateCaption(Xlat_0014860, locale);
	btnChgPW.translateCaption(Xlat_0014861, locale);
	btnChgQ.translateCaption(Xlat_0014862, locale);
	btnChgScreenSize.translateCaption(Xlat_0015241, locale);
	btnDay.translateCaption(Xlat_0014863, locale);
	btnMenu.translateCaption(Xlat_0014864, locale);
	btnNight.translateCaption(Xlat_0014865, locale);
	btnSave.translateCaption(Xlat_0014866, locale);
 //	grpScreenMode.translateCaption(Xlat_0014867, locale);
	lblChgLocale.translateCaption(Xlat_0014868, locale);
	lblChgScreenSize.translateCaption(Xlat_0015242, locale);
	lblConfirmPW.translateCaption(Xlat_0014869, locale);
	lblCurrentPW.translateCaption(Xlat_0014870, locale);
	lblNewPW.translateCaption(Xlat_0014871, locale);
	lblUser.translateCaption(Xlat_0014872, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
