    <JadeMethod name="getUserCode" id="bf689e56-ac01-4ef4-88df-284a0a823cc7">
        <source>getUserCode() : String;
// -------------------------------------------
// Created 25 August 2004 by cnwdvb1
// -------------------------------------------
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
vars
	isInvalid : Boolean;
begin
	if self.myUser &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, self.myUser, isInvalid);
		return self.myUser.code;
		if isInvalid then
			return null;
		endif;
	endif;
	return null;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initRequestEvent" id="21cdafad-17f2-4b9b-ab60-b48f5ebe73e8">
        <updating/>
        <source>initRequestEvent(_checkRequestCanBeProcessed, _isImmediate : Boolean; _updateCallbackObj : Object) updating;
//
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
//
vars

begin
	
	if _checkRequestCanBeProcessed then
		self.checkRequestCanBeProcessed();
	endif;
	if _updateCallbackObj &lt;&gt; null and not _updateCallbackObj.isTransient then
		self.myUpdateCallbackObject := _updateCallbackObj;
	endif;
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;' cause Event '&amp;BGP_Object.BGP_ActionRequest.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
	self.causeEvent(BGP_Object.BGP_ActionRequest, _isImmediate, null);

end;</source>
        <Parameter name="_checkRequestCanBeProcessed" type="Boolean"/>
        <Parameter name="_isImmediate" type="Boolean"/>
        <Parameter name="_updateCallbackObj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="initRequestFromController" id="1803131d-93f0-491f-b8cb-9ac161b0718b">
        <updating/>
        <source>initRequestFromController(_controller : BGP_Controller) updating;

// cnwdvb1 11 December 2002 

vars

	user : CM_User;

begin

	user := _controller.BGP_AutoTimerController.myCurrentAutoTask.myUser;
	if global.isValidObject(user) then
		self.myUser	:= user;
	endif;
	self.myTerminal	:= _controller.BGP_AutoTimerController.myCurrentAutoTask.myTerminal;	
	self.initRequestEvent(true, false, _controller.BGP_AutoTimerController.myCurrentAutoTask);

end;</source>
        <Parameter name="_controller" type="BGP_Controller"/>
    </JadeMethod>
    <JadeMethod name="initRequestFromTask" id="ae983ae9-693e-48fb-b7d8-3aea46371f0c">
        <updating/>
        <source>initRequestFromTask(_task : CM_AutoTask) updating;
// -------------------------------------------
// Created 28 June 2004 by cnwdvb1
// -------------------------------------------
vars
	user : CM_User;
begin
	user := _task.myUser;
	
	if global.isValidObject(user) then
		self.myUser	:= user;
	endif;
	
	self.myTerminal	:= _task.myTerminal;
	//11 Jul 2016	NDL	TFS 2296
	if app.myPassport.myTerminal &lt;&gt; self.myTerminal and self.myTerminal &lt;&gt; null then
		app.myPassport.setMyTerminal(self.myTerminal);
	endif;
	
	self.initRequestEvent(true, false, _task);
end;</source>
        <Parameter name="_task" type="CM_AutoTask"/>
    </JadeMethod>
