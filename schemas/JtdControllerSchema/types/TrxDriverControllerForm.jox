    <JadeMethod name="mnuDriversCloneMachine_click" id="62469fbb-ef11-4e42-8223-8649386ffb04">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuDriversCloneMachine_click(menuItem: MenuItem input) updating;

vars
	f : MachineSelectionForm;
	n : Integer;
	
begin
	create f transient;
	f.lblPrompt.caption := "Please select the machine for which drivers are to be cloned:";
	
	if f.showModal &lt;&gt; 0 then
		return;
	endif;
	
	if f.mySelectedMachineDesc = null then
		return;
	endif;
	
	if not app.readInteger("Enter the number times to clone each driver on " &amp;
		f.mySelectedMachineDesc.name &amp; ':', true, 0, MaxClones, n)
	then
		return;
	endif;
	
	if n &lt; 1 then
		return;
	endif;
	
	app.mySession.doCmdCloneMachine(f.mySelectedMachineDesc, n);

epilog
	delete f;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
