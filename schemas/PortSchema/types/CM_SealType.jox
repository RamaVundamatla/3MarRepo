    <JadeMethod name="setProxy" id="d6e3d89c-8d8b-496b-987f-2ad324504be6">
        <updating/>
        <source>setProxy(	_sealType: String; 
			_description: String;
			_allCargoTypes: CM_CargoTypeSet;
			_allowMultipleSealNums: Boolean;
			_notAvailableForEntry: Boolean;
			_showSealOnCheck: Boolean;
			_savePrevSeal : Boolean;
			_useForTrucks : Boolean) updating;
			
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
							CCMS 1131 PAR 23715 
06 April 2023		jlizm1	TFS 57098 EUP Seal numbers on trucks

*/
vars

begin
	self.sealType 		:= _sealType;
	self.description	:= _description;
	self.allowMultipleSealNums := _allowMultipleSealNums;
	self.notAvailableForEntry := _notAvailableForEntry;
	self.showSealOnCheck := _showSealOnCheck;
	self.savePreviousSeal := _savePrevSeal;
	self.useForTrucks := _useForTrucks;

	self.allCargoTypes.clear;
	if _allCargoTypes &lt;&gt; null then
		_allCargoTypes.copy(self.allCargoTypes);
	endif;
end;</source>
        <Parameter name="_sealType" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_allCargoTypes" type="CM_CargoTypeSet"/>
        <Parameter name="_allowMultipleSealNums" type="Boolean"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
        <Parameter name="_showSealOnCheck" type="Boolean"/>
        <Parameter name="_savePrevSeal" type="Boolean"/>
        <Parameter name="_useForTrucks" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setWagonClasses" id="c207b24f-a14b-4395-b1cf-13432453639f">
        <source>setWagonClasses(_wagonClasses : CM_WagonClassByCodeDict);
/*

Purpose:			

