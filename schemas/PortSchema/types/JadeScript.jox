    <JadeMethod name="rel842_tfs1455" id="9da124c0-bc54-488a-b6a9-de7678c6f38f">
        <source>rel842_tfs1455();
//
//16 Mar 2016	cnwrs1	TFS 1455 Add Freight Tons
//
vars
	agent	: EntTableAgent;
	array : StringArray;
	release : PortSchema_8_4_2;
	ddAgent : CM_DataDumpMaintenanceAgent;
begin
	app.initialize();
	app.myRoot.createQueryDefinitionObjects();
	create release transient;
	release.createYATypesStandard();
	create ddAgent transient;
	ddAgent.maintainDataDumpClasses();
	ddAgent.maintainDataDumpFeatureUpdate();
	ddAgent.maintainDataDumpDefStoredProcs();	
	if app.myPassport.trxCompletedOK then	
		app.writeStatement("End dataDumpInstall");
	endif;
	create agent transient;
	create array transient;
	agent.myEntTableDataRoot := app.myRoot.myEntTableDataRoot;
	array.add ("ETRow_FreightTons");
	array.add ("ETDef_DefaultDataTable");
	array.add("ETDef_WHGeneralData");
	array.add("ETDef_GeneralData");
	agent.trxUpdateFromConstant(array);
	app.writeStatement("Finished");
	return;

	write ETRow_FreightTons;
	write ETDef_DefaultDataTable;
	write ETDef_WHGeneralData;
	write ETDef_GeneralData;
	write YACriteriaType_FreightTons;
epilog
	delete agent;
	delete array;
	delete release;
	delete ddAgent;
end;
</source>
    </JadeMethod>
