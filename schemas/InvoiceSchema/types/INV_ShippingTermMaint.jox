    <JadeMethod name="tblData_click" id="498dfd6e-cd2f-488c-b148-974842d4f907">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_click(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Jan 2023 navtnr20	TFS CR 55622 Task 55692: UI - Shipping Terms Maint
06 October 2023	navmv20 Bug 60635: FR | 54089 EUP -Invoice Contracts - Shipping Terms
*/

vars

begin
	if self.tblData.row &gt; 1 then
		self.btnAdd.enabled := true;
		self.btnRemove.enabled := true;
		self.btnUpdate.enabled := true;
	endif;
	
	self.populateShipMapping(); //06/10/2023	navmv20 Bug 60635
epilog

end;</source>
