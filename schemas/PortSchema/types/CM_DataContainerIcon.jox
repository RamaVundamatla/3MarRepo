    <PrimAttribute name="character" id="f10c6f6b-4457-4e74-9684-6cb3cca1d439">
        <embedded/>
        <type name="Character"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="colour" id="97d2e93c-09cb-4c53-a08a-a20a7c72cdb6">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="font" id="138286a9-2468-4396-aeb2-f2c3a3dfcd89">
        <length>31</length>
