    <JadeMethod name="doMnuContext4Click" id="b4d00df2-a3d3-417d-8d6b-22cbf80273f7">
        <updating/>
        <source>doMnuContext4Click(theMenuItem: MenuItem) updating;

vars

	theForm		: SOP_TableMaintForm;
	tableRow 	: JadeTableRow;
	obj			: Object;
	row			: Integer;

begin

	self.doClearRTTasks();
	return;
	theForm := self.myForm;
	row :=  theForm.tblView2.row;
	if row &gt; 0 then
		tableRow := theForm.tblView2.accessRow(row);
		if tableRow = null then
			return;
		endif;
		obj := tableRow.itemObject;
	endif;
	obj.inspectModal;
	

	
end;</source>
