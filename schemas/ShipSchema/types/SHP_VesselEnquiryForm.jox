    <JadeMethod name="tblDataDisplayRow" id="6cce2163-6b82-4e2b-9eec-4d62b2c85daf">
        <source>tblDataDisplayRow(_vessel : CM_Vessel);
//--------------------------------------------------
// Created:	06 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	str : String;
	idx : Integer;
	cell : JadeTableCell;	
	failedDAC  :CM_DataAccessController;
begin
	if (not _vessel.canUserAccessSelf(null, failedDAC,app.myPassport)) then
		return;
	endif;

	str := _vessel.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
	idx := self.tblData.addItemObject(_vessel, str);

end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
