<CollClass name="Btree">
    <JadeMethod name="addNoDuplicates" id="d24d963c-41fe-466b-9bca-cb0c6a466384">
        <lockReceiver/>
        <updating/>
        <source>addNoDuplicates(value : MemberType; raiseException: Boolean):Boolean lockReceiver, updating;
// ---------------------------------------------------------------------------
// Created:     26 June 2002 by cnwsb1
//
// Purpose:     Use this method to add items to a collection where you don't want
//              an item or a key to be included more than once. Use of this method
//              avoids the need to prefix all adds with an "includes" test.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	retValue : Boolean;	//28 Jan 2015 - To let us know if we added or not.

begin

	retValue := false;	// default value
	if raiseException then
		on Exception do self.addNoDupsHaltExHandler(exception, value);
	else
		on Exception do self.addNoDuplicatesExHandler(exception);
	endif;
	
	self.add(value);
	retValue := true; // we succeeeded
	
	// If self.add raises a 1309 (object already in collection) or a
	// 1310 (duplicate key), or exception handler will return to here
	// without "value" having been added to the collection and we'll
	// return silently
epilog
	return retValue;
end;</source>
        <Parameter name="value" type="MemberType"/>
        <Parameter name="raiseException" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="addNoDuplicatesExHandler" id="005f5b8f-2454-406b-9c4e-f8f1c10952c8">
        <source>addNoDuplicatesExHandler(exObj : Exception) : Integer protected;
// ---------------------------------------------------------------------------
// Created:     26 June 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	ObjectAlreadyInCol = 1309;
	DuplicateKey = 1310;

vars
	errorCode : Integer;
		
begin
	errorCode := exObj.errorCode;
	
	// Is this one of the errors we want to handle...?	
	if errorCode = ObjectAlreadyInCol or errorCode = DuplicateKey then
		// ...Yes, so resume back to the method that armed us
		return Ex_Resume_Next;
	endif;

	// Otherwise an unexpected error, so pass back to the next handler
	return Ex_Pass_Back;
end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addNoDupsHaltExHandler" id="7cdabc50-4591-4e4c-9e3c-cd641e22f134">
        <source>addNoDupsHaltExHandler(exObj : Exception; _any: Any) : Integer protected;
// ---------------------------------------------------------------------------
// Created:     26 June 2002 by cnwsb1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
	ObjectAlreadyInCol = 1309;
	DuplicateKey = 1310;

vars
	errorCode : Integer;
		
begin
	errorCode := exObj.errorCode;
	
	// Is this one of the errors we want to handle...?	
	if errorCode = ObjectAlreadyInCol or errorCode = DuplicateKey then
		app.raiseCMException1(VB_DUPLICATED_ITEM, _any.getTypeJMT().name &amp; " or it's key", 'code', null);
		//return Ex_Abort_Action; //- cnwmd1, Par 25506 No need for this - never gets to this code
	endif;

	// Otherwise an unexpected error, so pass back to the next handler
	return Ex_Pass_Back;
end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="_any" type="Any"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="copyNoDuplicates" id="7f9d1c70-03cf-4c8e-8c91-57611e07fdf3">
        <source>copyNoDuplicates(_set : Btree input; _raiseException: Boolean);
/*
Created:			17 October 2002 by cnwdwq1
Updated:			9/08/2010 cnwjo3 - self.copy(_set) added instead of adding each item seperately
					19/08/2010 cnwmd1 - Removed above changes - restored the original code.
						Coping each duplicate seperately is less efficient but when a duplicate is found,
						at least the target collection will contain all none duplicates instead of none.
						The exception handler can also include the duplicate item id in the exception message.
						
						Added Unit Test - UT_JMT::tBtreeCopyNoDups
*/
vars
	ob : MemberType;
begin
	foreach ob in self do
		_set.addNoDuplicates(ob, _raiseException);
	endforeach;
end;</source>
        <Parameter name="_set" type="Btree" usage="input"/>
        <Parameter name="_raiseException" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeIfPresent" id="33ebb29a-8cdd-490d-91fe-4c86daceaae6">
        <lockReceiver/>
        <updating/>
        <source>removeIfPresent(value : MemberType) : Boolean lockReceiver, updating;
// ---------------------------------------------------------------------------
// Created:     29 May 2003 by cnwsb1
//
// Purpose:		Use this method to remove items from a collection where it doesn't
//				matter if the item was present or not.  Use of this method
//				avoids the need to prefix all removes with an "includes" test.
//
//				Altered to return true if the object was found in the dict
//				and removed
// ---------------------------------------------------------------------------
vars
	exOccured	: Boolean;
begin
	// get an exception if attempt to remove a null from a collection
	if value = null then
		return false;
	endif;
	on Exception do self.removeIfPresentExHandler(exception, exOccured);
	self.remove(value);
	// If self.remove raises a 1301 (entry not found in collection), our
	// exception handler will return to here and we'll return silently
	
	return (not exOccured);

end;</source>
        <Parameter name="value" type="MemberType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeIfPresentExHandler" id="6b40c1df-2989-4234-8ef0-c7bb4cdecaa4">
        <source>removeIfPresentExHandler(exObj : Exception; _exOccured : Boolean output) : Integer protected;
// ---------------------------------------------------------------------------
// Created:     29 May 2003 by cnwsb1
// ---------------------------------------------------------------------------

constants
	EntryNotInCollection = 1301;
	
vars
	errorCode : Integer;
		
begin
	errorCode := exObj.errorCode;
	
	// Is this one of the errors we want to handle...?	
	if errorCode = EntryNotInCollection then
		// ...Yes, so resume back to the method that armed us
		_exOccured := true;
		return Ex_Resume_Next;
	endif;

	// Otherwise an unexpected error, so pass back to the next handler
	return Ex_Pass_Back;
end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="_exOccured" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="synchroniseContents" id="bfab65c6-edc7-4eca-9ef4-beab11b53b93">
        <lockReceiver/>
        <updating/>
        <source>synchroniseContents(_withColl : Collection) lockReceiver, updating;
/*

Purpose:			Synchronise the contents of the receiver with those in the passed in collection,
					removing any members from the receiver that are not in the collection, and adding
					any new ones.

Parameters:			Collection to compare with

Return Value:		None

Date		Who		Reason
18 May 2017	cnwkpd1	TFS 3369 - Push Events application

*/

vars
	member			: Any;
	
begin
	// Check edge conditions first for performance
	if _withColl.isEmpty() then
		self.clear();
	
	elseif self.isEmpty() then
		_withColl.copy(self);
	
	else
		// Remove anything from the receiver that is not in the passed collection
		foreach member in self do
			if not _withColl.includes(member) then
				self.remove(member);
			endif;
		endforeach;
		
		// Add anything in the passed collection that is not in the receiver
		foreach member in _withColl do
			if not self.includes(member) then
				self.add(member);
			endif;
		endforeach;
	endif;
	
epilog

end;</source>
        <Parameter name="_withColl" type="Collection"/>
    </JadeMethod>
</CollClass>
