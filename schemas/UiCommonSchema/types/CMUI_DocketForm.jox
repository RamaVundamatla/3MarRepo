	self.btnSelectAllTV.enabled := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="cmbCarrier_lostFocus" id="c00b8e63-5ca2-43a3-823b-c3973469c3f0">
        <controlMethod name="CMUI_ComboBoxObject::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCarrier_lostFocus(combobox: ComboBox input) updating;
// -------------------------------------------
// Created 15 September 2004 by cnwdvb1
// 15/01/2015   cnwma1		 PAR #35462 Carrier Drop-down Fields	
// -------------------------------------------
vars
		tbl			: CM_EntryTable;
begin

	//tblMain.setValueByControlName(combobox.name, combobox.text);  // 12/01/2015 cnwma1 PAR #35462
	tbl := combobox.parent.CM_EntryTable;
	if not CM_EntryTable.hasInstance(combobox.parent) then
		return;
	endif;
	
	if combobox.listObject &lt;&gt; null then
		tbl.setValueByControlName(combobox.name, combobox.listObject.CM_Carrier.code);
	else
		tbl.setValueByControlName(combobox.name, null);
	endif;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbConsignor_lostFocus" id="e48250e2-a5a6-4a09-8f42-45fd5f09d452">
