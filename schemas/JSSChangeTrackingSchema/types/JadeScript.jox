    <JadeMethod name="purgeSystem" id="7672f9ca-3d8f-49bb-9d87-cf00c1645a94">
        <updating/>
        <source>purgeSystem() updating;

// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support

vars
	myChangeObjectTA: JSSChangeTrackingObjectTA;
	changeClass: JSSCTChangeTrackingClass;
	changeInstance: JSSCTChangeTrackingObject;
	iter: Iterator;
	count: Integer;
	exceptionCode: Integer;
	exceptionCount: Integer;
begin
	on Exception do handleException(exception, exceptionCode, exceptionCount);

	create myChangeObjectTA transient;
write "Started Changes " &amp; app.actualTimeServer.String;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	myChangeObjectTA.myDeleteClass := null;
	beginTransaction;
	foreach changeClass in JSSCTChangeTrackingRoot.firstInstance.allChangeClasses do
		myChangeObjectTA.myChangeClass := changeClass;
		iter := changeClass.allChangesByOid.createIterator;
		while iter.next(changeInstance) do
			myChangeObjectTA.myChangeObject := changeInstance;
			myChangeObjectTA.deleteEntityInTransState();
			count := count + 1;
			if count &gt; 9999 then
				commitTransaction;
				count := 0;
				beginTransaction;
			endif;
		endwhile;
		commitTransaction;
write changeClass.className &amp; " deleted " &amp; app.actualTimeServer.String;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
		count := 0;
		beginTransaction;
	endforeach;
	commitTransaction;
	myChangeObjectTA.myChangeClass := null;
	count := 0;
write "Started Deletes " &amp; app.actualTimeServer.String;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	beginTransaction;
	foreach changeClass in JSSCTChangeTrackingRoot.firstInstance.allDeleteClasses do
		myChangeObjectTA.myDeleteClass := changeClass;
		iter := changeClass.allChangesByOid.createIterator;
		while iter.next(changeInstance) do
			myChangeObjectTA.myChangeObject := changeInstance;
			myChangeObjectTA.deleteEntityInTransState();
			count := count + 1;
			if count = 2042 then
				count := 2042;
			endif;
			if count &gt; 9999 then
				commitTransaction;
				count := 0;
				beginTransaction;
			endif;
		endwhile;
		commitTransaction;
write changeClass.className &amp; " deleted " &amp; app.actualTimeServer.String;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
		count := 0;
		beginTransaction;
	endforeach;
	commitTransaction;
//
	beginTransaction;
	delete JSSCTChangeTrackingRoot.firstInstance;
	delete JSSCTNibblerManager.firstInstance;
	commitTransaction;
//
//
	beginTransaction;
	JSSCTChangeTrackingObject.instances.purge;
	commitTransaction;
//
	if JSSCTChangeByTimeDictsByName.firstInstance &lt;&gt; null then
		beginTransaction;
		JSSCTChangeByTimeDictsByName.firstInstance.purge;
		delete JSSCTChangeByTimeDictsByName.firstInstance;
		commitTransaction;
	endif;
write "Finished " &amp; app.actualTimeServer.String;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
epilog
	delete myChangeObjectTA;
end;</source>
    </JadeMethod>
    <JadeMethod name="removeClassCollection" id="4c722a3a-5a20-4b17-8023-5c5a90a5b8bd">
        <updating/>
        <source>removeClassCollection() updating;

vars
	class: JSSCTChangeTrackingClass;
begin
	beginTransaction;
	class := JSSCTChangeTrackingRoot.firstInstance.allChangeClasses["Diary", false];
	if class &lt;&gt; null then
		JSSCTChangeTrackingRoot.firstInstance.allChangeClasses.remove(class);
		delete class;
	endif;
	class := JSSCTChangeTrackingRoot.firstInstance.allDeleteClasses["Diary", true];
	if class &lt;&gt; null then
		JSSCTChangeTrackingRoot.firstInstance.allDeleteClasses.remove(class);
		delete class;
	endif;
	commitTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="rsTest" id="5f479cf2-9e29-4def-84b0-6a0159b32093">
        <source>rsTest();
vars
	objArray: ObjectArray;
	object: Object;
	jss: JSSCTChangeTrackingObject;
	count1,count2,count3: Integer;
	file:File;
begin
	write "Start "&amp;method.name;
	create objArray transient;
	create file transient;
	file.fileName := "c:\temp\changetracker.log";
	file.mode := File.Mode_Output;
	JSSCTChangeTrackingObject.allInstances(objArray,0,true);
	write "number to process="&amp;objArray.size.String;
	foreach object in objArray do
		count2 := count2 + 1;
//		if not global.isValidObject(object) then
//			count3 := count3 + 1;
//		endif;
//		file.writeLine(count2.String&amp;' '&amp;object.String);
		jss := object.JSSCTChangeTrackingObject;
		file.writeLine(count2.String&amp;' '&amp;jss.String&amp;' '&amp;jss.className&amp;' '&amp;jss.changeObjectID);
		if jss.className = "CM_Bank" then
			write jss.changeObject.String;
			count1 := count1 + 1;
		endif;
	endforeach;
epilog
	write "Fin  "&amp;method.name&amp;' '&amp;count1.String&amp;' '&amp;count2.String&amp;' '&amp;count3.String;
	file.close;
	delete file;
	delete objArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="rsTest2" id="b01e1e14-d554-450c-b10e-f76e6db9826d">
        <source>rsTest2();

vars
	changeClass: JSSCTChangeTrackingClass;
	changeInstance: JSSCTChangeTrackingObject;
	deleteClass: JSSCTChangeTrackingClass;
	deleteInstance: JSSCTChangeTrackingObject;
	startingDate: Date;
	iterDict: Iterator;
	iterInstance: Iterator;
begin
	write "Start "&amp;method.name;
	iterDict := "5363.1.5189.3.1".asOid.JSSCTChangeByTimeDictsByName.createIterator();
//		write class.name&amp;"::"&amp;method.name&amp;' '&amp;self.myChangeTrackingRoot.allChangesByTimeDicts.String;
	beginTransaction;

	while iterDict.next(changeClass) do
		self.tryLock(changeClass, Share_Lock, Session_Duration, 60000);
		iterInstance := changeClass.allChangesByOid.createIterator();
		write class.name&amp;"::"&amp;method.name&amp;' '&amp;changeClass.className.String;
		while iterInstance.next(changeInstance) do
//			write class.name&amp;"::"&amp;method.name&amp;' '&amp;changeInstance.String;
			self.tryLock(changeInstance, Share_Lock, Transaction_Duration, 60000);
			self.unlock(changeInstance);
		endwhile;
		self.unlock(changeClass);
	endwhile;

	commitTransaction;
//	self.monitor(self.myTitle &amp; " - Commiting after " &amp; count.String &amp; " instances deleted...", true);
epilog
	write "Fin. "&amp;method.name;

end;</source>
    </JadeMethod>
    <JadeMethod name="rsTest3" id="6a681a9c-cf24-4c76-9468-cb7220e8aaa0">
        <source>rsTest3();

vars
	count1,count2:Integer;
	col: MemberKeyDictionary;
	objArray: ObjectArray;
	object: Object;
begin
	write "Start "&amp;method.name;
	create objArray transient;
	MemberKeyDictionary.allInstances(objArray,0,true);
	write " there are "&amp;objArray.size.String&amp;" dicts to process.";
	foreach object in objArray do
		col := object.MemberKeyDictionary;
		count1 := col.size;
		beginTransaction;
		col.rebuild;
		commitTransaction;
		if col.size &lt;&gt; count1 then
			write col.String&amp;' was='&amp;count1.String&amp;' now='&amp;col.size.String;
		endif;
	endforeach;
epilog
	write "Fin. "&amp;method.name;
end;</source>
    </JadeMethod>
    <JadeMethod name="rsTest34413" id="e2ff7092-df4d-4055-b086-cea0d3023b7d">
        <source>rsTest34413();
vars
	ctInterface : JSSCTChangeTrackingInterface;
	pFromTimeStamp : TimeStamp;
	pToTimeStamp : TimeStamp;
	date : Date;
	ts : TimeStamp;
	idx,i : Integer;
	time : Time;
	pClassName : String;
	changeObject	: JSSChangeTrackingObjectTA;
	myChangeObjectTA: JSSChangeTrackingObjectTA;
	msg : String;
	changedTs : TimeStamp;
	result : Integer;
begin
	create ctInterface transient;
	create changeObject transient;
	pClassName := "CM_BOLIn";
	date := "01/07/2014".Date;
	time := "11:55:38".Time;
	ts.setDate(date);
	ts.setTime(time);
	pFromTimeStamp := ts;
	time := "11:57:39".Time;
	ts.setTime(time);
	pToTimeStamp := ts;
	idx := ctInterface.selectClassChanges(pClassName, pFromTimeStamp, pToTimeStamp, null);
	app.msgBox("From:"&amp;pFromTimeStamp.String&amp;" to:"&amp;pToTimeStamp.String&amp;' number='&amp;idx.String,"",0);
//	foreach i in 1 to idx do
	while ctInterface.getNextClassChange(changeObject) = 0 do
//		result := ctInterface.getNextClassChange(changeObject);
		if result = 0 then
			msg := msg&amp;changeObject.changeObjectID&amp;' '&amp;changeObject.changeTimestamp.String&amp;CrLf;
		else
		msg := msg&amp;'result='&amp;result.String;
		endif;
	endwhile;
	app.msgBox("",msg,0);
epilog
	delete ctInterface;
	delete changeObject;
end;</source>
    </JadeMethod>
    <JadeMethod name="rsTest5B" id="404e01ef-fb60-4860-b984-eca2900a0256">
        <source>rsTest5B();
//
//21 Jul 2016	cnwrs1	Par 38030 C3 Change tracker
constants
	TheClass = "All5B";
	FileName = "d:\Testdb\logs\ObjectFind";
vars
	changeInstance: JSSCTChangeTrackingObject;
	changeInstanceFirst: JSSCTChangeTrackingObject;
	changeInstanceLast: JSSCTChangeTrackingObject;
	changeClass: JSSCTChangeTrackingClass;
	file : File;
	msg : String;
	numObjsTested : Integer;
	numObjsTestedTotal : Integer;
	numObjsFound : Integer;
	numObjsFoundTotal : Integer;
	numObjsNotFound : Integer;
	numObjsNotFoundTotal : Integer;
	numCCTObjsNotFound : Integer;
	numCCTObjsNotFoundTotal : Integer;
	numInvalidObj : Integer;
	numInvalidObjTotal : Integer;
	numOutSideTimeInterval : Integer;
	numOutSideTimeIntervalTotal : Integer;
	numUpdateObj : Integer;
	numUpdateObjTotal : Integer;
	totalCount : Integer;
	numClasses : Integer;
	instId : Integer;
	instIdFirst : Integer;
	instIdLast : Integer;
	classId : Integer;
	portSchema : Schema;
	oidString : String;
	portClass : Class;
	changeObject : Object;
	ts : TimeStamp;
	root: JSSCTChangeTrackingRoot;
	invalidObject : Boolean;
	trxTimeFirst : TimeStamp;
	trxTimeLast : TimeStamp;
	createdTime : TimeStamp;
begin
	ts := app.actualTimeServer();
	create file transient;
	file.fileName := FileName&amp;TheClass&amp;".log";
	file.mode := File.Mode_Output;
	root := JSSCTChangeTrackingRoot.firstInstance;
	portSchema := rootSchema.getSchema("PortSchema");
	write "";
	on Exception do app.handleDeletedObject(exception, changeObject, invalidObject);
	//check all classes in ChangeTracker
	foreach changeClass in root.allChangeClasses do
		changeInstanceFirst := changeClass.allChangesByOid.first;
		if changeInstanceFirst = null then
			// change tracker has no changes for that class
			continue;
		endif;
		numClasses := numClasses + 1;
		changeObject := changeInstanceFirst.changeObject;
		classId := self.getClassNumberForObject(changeObject);
		portClass := portSchema.getClassByNumber(classId);
//		if changeClass.className &lt;&gt; "CM_Container" then
//			continue;
//		endif;
//		if changeClass.className = "CM_Carrier" then
//			break;
//		endif;
		ts := app.actualTimeServer();
		msg := ts.String&amp;" Start "&amp;method.name&amp;' for '&amp;changeClass.className;
		write msg;
		file.writeLine(msg);
		//clear out all totals
		numObjsTested := 0;
		numObjsFound := 0;
		numObjsNotFound := 0;
		numCCTObjsNotFound := 0;
		numInvalidObj := 0;
		numOutSideTimeInterval := 0;
		numUpdateObj := 0;
		// find the earliest instance and the last instance for this class
		instIdFirst := 0;
		instIdLast := 0;
		trxTimeFirst := null;
		trxTimeLast := null;
		// this section is too slow but not sure how to speed it up as the collection is in oidString order which is not oid order as 2.2 and 2.12 will be in the wrong order
		foreach changeInstance in changeClass.allChangesByOid do
			invalidObject := false;
			changeObject := changeInstance.changeObject;
			instId := self.getInstanceIdForObject(changeObject).Integer;
			createdTime := changeObject.getPropertyValue("createdTime").TimeStamp;
			if not invalidObject then
				if changeObject.edition = 1 then
					// only interested in creates not updates
					if instIdFirst = 0 then	//first Time;
						instIdFirst := instId;
						instIdLast := instId;
						trxTimeFirst := changeObject.creationTime;
						trxTimeLast := changeObject.creationTime;
					endif;
					if instId &lt; instIdFirst then	// lowest inst number
						instIdFirst := instId;
						trxTimeFirst := changeObject.creationTime; //actual creation date/time of PortSchema object not the change tracker object fot the first instance, just for reference
					endif;
					if instId &gt; instIdLast then	// highest instance number
						instIdLast := instId;
						trxTimeLast := changeObject.creationTime; //actual creation date/time of PortSchema object not the change tracker object for the last instance, just for reference
					endif;
				endif;
			endif;
		endforeach;
		if instIdFirst = null then	// didnt find any single edition changeObjects
			continue;
		endif;
		instId := instIdFirst;
		changeObject := portClass.lastInstance;
		ts := app.actualTimeServer();
		// list out the starting details, first is the lowest instance number last is the highest instance number
		msg := ts.String&amp;" First="&amp;instIdFirst.String&amp;' '&amp;trxTimeFirst.String&amp;" Last="&amp;instIdLast.String&amp;' '&amp;trxTimeLast.String&amp;' Last DB instance='&amp;self.getInstanceIdForObject(changeObject).Integer.String;
		write msg;
		file.writeLine(msg);
		
		// now we run thru every instance from the lowest istance to the highest instance
		while true do
			invalidObject := false;
			numObjsTested := numObjsTested + 1;
//			if numObjsTested &gt; 80000000 then
//				break;
//			endif;
			// turn the next instance number into anactual portachema object
			oidString := classId.String&amp;'.'&amp;instId.String;
			changeObject := oidString.asOid;
			// force the deleted object exception if the generated oid does not exist
			createdTime := changeObject.getPropertyValue("createdTime").TimeStamp;
			if not invalidObject then
				if changeObject &lt;&gt; null then 
					if changeObject.edition &lt;&gt; 1 then
						// change tracker updates not craete so just count them 
						numUpdateObj := numUpdateObj + 1;
					else
						if createdTime &gt; trxTimeFirst and
						   createdTime &lt; trxTimeLast then
							if changeClass.allChangesByOid[oidString] &lt;&gt; null then
								// the object has been created and has a change tracker record this is the normal case
								numObjsFound := numObjsFound + 1 ;
							else
								// this is the problem area we have an instid that was created in the time period that change tracker is covering but we dont have a change tracker record.
								if numCCTObjsNotFound &lt; 100 then
									msg := "No JSSCT Change object "&amp;changeObject.String&amp;' '&amp;oidString.String;
									file.writeLine(msg);
								endif;
								numCCTObjsNotFound := numCCTObjsNotFound + 1;
							endif;
						else
							// the object was created outside our change tracker time period wouldn't expect there to be any 
							numOutSideTimeInterval := numOutSideTimeInterval + 1;
						endif;
					endif;
				else
					// not likly to happen so should be zero
					numObjsNotFound := numObjsNotFound + 1;
				endif;
			else
				// we count how many of the generated oids are invalid but we are not interested in then, it just means the object has been deletd in PortSchema after it has been created
				numInvalidObj := numInvalidObj + 1;
			endif;
			// increment the instance number for the next cycle
			instId := instId + 1;
			//if the next instance is greater then the last then break the while look and move on to the next class
			if instId &gt; instIdLast then
				break;
			endif;
			// is the log file is getter too big create another one
			if file.fileLength &gt;  (100 * 1048576) then
				file.close;
				file.fileName := FileName&amp;TheClass&amp;".log";
				file.mode := File.Mode_Append;
				file.open;
				ts := app.actualTimeServer();
				msg := FileName&amp;TheClass&amp;""&amp; "_" &amp; ts.Date.format('yyyMMdd') &amp; "_" &amp; ts.Time.format('HHmmss') &amp; ".log";
				file.rename(msg);
				file.close;
				file.fileName := FileName&amp;TheClass&amp;".log";
				file.mode := File.Mode_Output;
				file.open;
			endif;
		endwhile;
		// wrapup the totals for the current class
		ts := app.actualTimeServer();
		totalCount := numObjsFound + numObjsNotFound + numCCTObjsNotFound + numInvalidObj + numUpdateObj + numOutSideTimeInterval;
		msg := ts.String&amp;" Fin  "&amp;changeClass.className&amp;' numObjsTested='&amp;numObjsTested.String&amp;' numObjsFound='&amp;numObjsFound.String&amp;' numObjsNotFound='&amp;numObjsNotFound.String&amp;' numCCTObjsNotFound='&amp;numCCTObjsNotFound.String&amp;' numInvalidObj='&amp;numInvalidObj.String&amp;' numObjUpdate='&amp;numUpdateObj.String&amp;' numOutSideTimeInterval='&amp;numOutSideTimeInterval.String&amp;' instIds='&amp;(instIdLast-instIdFirst+1).String&amp;' TotalCounted='&amp;totalCount.String;
		write msg;
		file.writeLine(msg);
		// accumulate totals
		numObjsTestedTotal := numObjsTestedTotal + numObjsTested;
		numObjsFoundTotal := numObjsFoundTotal + numObjsFound;
		numObjsNotFoundTotal := numObjsNotFoundTotal + numObjsNotFound;
		numCCTObjsNotFoundTotal := numCCTObjsNotFoundTotal + numCCTObjsNotFound;
		numInvalidObjTotal := numInvalidObjTotal + numInvalidObj;
		numOutSideTimeIntervalTotal := numOutSideTimeIntervalTotal + numOutSideTimeInterval;
		numUpdateObjTotal := numUpdateObjTotal + numUpdateObj;
	endforeach;
epilog
	ts := app.actualTimeServer();
	msg := ts.String&amp;" Fin  "&amp;method.name&amp;' numObjsTestedTotal='&amp;numObjsTestedTotal.String&amp;' numObjsFoundTotal='&amp;numObjsFoundTotal.String&amp;' numObjsNotFoundTotal='&amp;numObjsNotFoundTotal.String&amp;' numCCTObjsNotFoundTotal='&amp;numCCTObjsNotFoundTotal.String&amp;' numInvalidObjTotal='&amp;numInvalidObjTotal.String&amp;' numOutSideTimeIntervalTotal='&amp;numOutSideTimeIntervalTotal.String;
	write msg;
	file.writeLine(msg);
	file.close;
	delete file;
end;
</source>
    </JadeMethod>
    <JadeMethod name="rsTestBeginSession" id="01fce85b-af87-4290-a827-79579ad1ad62">
        <source>rsTestBeginSession();

vars
	int, journalHandle:Integer;
begin
	write 'Start.';
	int := call beginSession(journalHandle);
	write self.class.name&amp;'::'&amp;method.name&amp;' '&amp;int.String;
	int := call endSession(journalHandle);
	write self.class.name&amp;'::'&amp;method.name&amp;' '&amp;int.String;
epilog
	write 'Fin.';	
end;</source>
    </JadeMethod>
    <JadeMethod name="rsTestJade6" id="f0c8e729-7ffb-4c0f-baec-332a1be225a7">
