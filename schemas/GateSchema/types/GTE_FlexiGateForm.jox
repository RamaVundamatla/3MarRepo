    <JadeMethod name="doContextMenuBuild" id="dbad1745-8c62-4df9-8e26-d16cbaef0c64">
        <updating/>
        <source>doContextMenuBuild(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 September 2011	cnwndl1	Initial creation	Par 24455

*/

vars

	theObject : Object;

begin

	self.mnuSelect.visible := false;
	self.mnuTTDelete.visible := false;
	self.mnuTTColOrg.visible := false;
	self.mnuInspect2.visible := false;

	if table = self.tblBulkRelease or table = self.tblTransfers then
	
		if table.row &gt; table.fixedRows then
			theObject := table.accessRow(table.row).itemObject;
			
			if theObject &lt;&gt; null then
		
				if table = self.tblTransfers then
					self.mnuSelect.visible := true;
					self.mnuSelect.userObject := theObject;
					self.mnuTTDelete.visible := true;
					self.mnuTTDelete.userObject := theObject;
				endif;
			
				self.mnuInspect2.visible := app.isAllowedToInspect();
				self.mnuInspect2.userObject := theObject;
			
			endif;
			
		endif;
		
		self.mnuTTColOrg.visible := true;
		self.mnuTTColOrg.userObject := table;
		// TFS 2198 CNWAB1
		if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
			self.mnuSelect.visible := false;
			self.mnuTTDelete.visible := false;
			self.mnuTTColOrg.visible := false;
			self.mnuInspect2.visible := false;
		
		endif;
	
		return self.showContextMenu(mnuTermTsfr, table, conwin, mouse, x, y);
	
	endif;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuSelect.visible := false;
		self.mnuTTDelete.visible := false;
		self.mnuTTColOrg.visible := false;
		self.mnuInspect2.visible := false;
	
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doEnableDateTimeAutoComplete" id="b0b35b83-ee21-4816-94c5-0a4a17aa12a0">
        <updating/>
        <source>doEnableDateTimeAutoComplete(_show : Boolean) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 August 2009	cnwas3	Initial creation
// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	nowLocal : TimeStamp;
begin

	//01 Oct 2020	NDL	TFS 49189
	if self.myTerminal.roadProcessIsASPA then
		//We always want the users to be able to set the date and time for teh ASPA road process
		self.lblTimeIn.enabled := true;
		self.lblDateIn.enabled := true;
		
		self.txtDateIn.enabled := true;
		self.txtTimeIn.enabled := true;
		
		if not self.txtDateIn.getDate.isValid then
			nowLocal := self.systemToLocalTime(app.actualTimeServer());	
			self.txtDateIn.setDate(nowLocal.date());					
			self.txtTimeIn.setTime(nowLocal.time());					
		endif;
	
	else
	
		self.lblTimeIn.enabled := _show;
		self.lblDateIn.enabled := _show;
		
		self.txtDateIn.enabled := _show;
		self.txtTimeIn.enabled := _show;
		
		if not _show then
			nowLocal := self.systemToLocalTime(app.actualTimeServer());	// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			self.txtDateIn.setDate(nowLocal.date());					// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			self.txtTimeIn.setTime(nowLocal.time());					// 12 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		endif;
		
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doEnhancedVBSAssociationForRR" id="29ca4c99-e6af-40fa-91ca-3a72f3cf9404">
        <updating/>
        <source>doEnhancedVBSAssociationForRR(_pCode : String) : Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Mar 2025	navlc30	Initial creation
21 Mar 2025 navlc30 JIRA 34264-TPT | FR 33661.020 VBS - One Release Request and VBS slot per Truck - No VBS Appointment
31 Mar 2025 navlc30 JIRA 34265 TPT | FR 33661.030 VBS - One Release Request and One VBS slot - Off Schedule
03 Apr 2025 navlc30 JIRA 34266 TPT | FR 33661.040 VBS - One Release Request and Multiple VBS - On Schedule
*/

constants

NoVehicleBooking = "No Vehicle Booking Available";
VehicleOutOfSchedule = "Vehicle Visit is out of schedule";
NoVBSSelected = "No VBS Selected";

vars
	compareCode : String;
	bulkRelease	: CM_BulkRelease;	
	isCompleted : Boolean;	
	realVVR					: CM_VehicleVisitRecord;
	result		: Integer;
	vehicleBookingSlot : CM_VehicleBookingTimeSlot;
	isVehicleOnSchedule : Boolean;
	reason : String;
begin

	compareCode := _pCode.toUpper;
	
	self.myAssistant.getBulkRelease(compareCode, bulkRelease, isCompleted);
	
	if self.myRealVVR &lt;&gt; null then
		realVVR := self.myRealVVR;
	endif;
	
	if bulkRelease &lt;&gt; null then
		//No VBS	
		if bulkRelease.allVBTimeslotsById.isEmpty() then
			result := self.myAssistant.showEnhancedVBSNoBookingWarn(self, realVVR);
			reason := NoVehicleBooking;
		//ONE VBS																				//31.03.2025 navlc30 #34265
		elseif bulkRelease.allVBTimeslotsById.size = 1 then
			vehicleBookingSlot  := bulkRelease.allVBTimeslotsById.first;
			isVehicleOnSchedule := vehicleBookingSlot.isVehicleVisitOnSchedule(realVVR);
			if not isVehicleOnSchedule then
				result := self.myAssistant.showVBSEnhancedOutOfSchedule(self, realVVR, bulkRelease);
				reason := VehicleOutOfSchedule;
			endif;
		else
		//Multiple VBS																			//03.04.2025 navlc30 #34266
			result := self.myAssistant.showVBSEnhancedAssociateForm(self, realVVR, bulkRelease);
			reason := NoVBSSelected;
		endif;
		if result = ModalResultCancel then
			self.doVehicleVisitCancel(reason);
			
			self.driverIDScanned := false;		// TFS 46854
			self.btnCheckID.visible := false;	// TFS 46854
			self.clearForm();
			self.txtRegno.setFocus();			// PAR #35805
			self.btnFind.enabled := true;
			
		endif;	
	endif;
	
	return result;
	
epilog

end;</source>
        <Parameter name="_pCode" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doFKeys" id="39d18ae9-7943-4cf4-bf72-56bac0a3b3f0">
        <updating/>
        <source>doFKeys(keyCharCode: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:     29 July 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	return ;
	
	if keyCharCode = J_key_F3 then
		self.btnFind.click(self.btnFind);
	endif;
	if keyCharCode = J_key_F4 then
		self.btnSave.click(self.btnSave);
	endif;
	if keyCharCode = J_key_F5 then
		self.btnInMT.click(self.btnInMT);
	endif;
	if keyCharCode = J_key_F6 then
		self.btnOutMT.click(self.btnOutMT);
	endif;
	if keyCharCode = J_key_F7 then
		self.btnInFull.click(self.btnInFull);
	endif;
	if keyCharCode = J_key_F8 then
		self.btnOutFull.click(self.btnOutFull);
	endif;
	if keyCharCode = J_key_F9 then
		self.btnInOther.click(self.btnInOther);
	endif;
	if keyCharCode = J_key_F10 then
		self.btnOutOther.click(self.btnOutOther);
	endif;
epilog

end;</source>
        <Parameter name="keyCharCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doHideChassisDetails" id="d122c87f-0695-4927-ae51-b0b5f01b46f1">
        <updating/>
        <source>doHideChassisDetails(_hide : Boolean) protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 Jun 2009	cnwjk3	Initial creation
05 Jul 2013 cnwer1	Par 31956 - resizing trailer details correctly 
10 Jan 2019	NDL		TFS 40479
08 Aug 2022	navkc1	Bug 54476: MTN - Clicking hide trailer details causes UI issue in road gate.
*/

vars
	
begin
	if _hide then 
		self.grpTrailerIn.visible := false;
		self.grpTrailerOut.visible := false;
		self.grpTotals.top := self.grpTop.top + self.grpTop.height + 1;		
		self.frmButtons.top := self.grpTotals.top + self.grpTotals.height + 5;
		// Grow into the space we just freed up on the form
		self.chkHideChassis.value := true;
		self.fldrDetails.height := self.fldrDetails.height + self.grpTrailerIn.height + self.grpTrailerOut.height; // ### TFS 51980 21Sep2021 NAVPW1
	else
	
		if self.myTerminal.roadProcessIsASPA then	//09 Oct 2020	NDL	TFS 49189
		
			self.lblOperatorIn.visible := false;
			self.cmbOperatorIn.visible := false;
			self.lblTrailIMEX.visible := false;
			self.cmbTrailIMEX.visible := false;
			self.lblWgtTareChass.visible := false;
			self.txtTareChassIN.visible := false;
			self.chkLockReceive.visible := false;
			self.grpTrailerIn.height := self.txtChassisIDIn.top + self.txtChassisIDIn.height + 5;
			
			self.frmButtons.visible := true;
			self.grpTrailerIn.visible := true;
			self.grpTrailerOut.visible := false;	
			self.grpTotals.top :=  self.grpTrailerIn.top + self.grpTrailerIn.height + 1;
			self.frmButtons.top := self.grpTotals.top + self.grpTotals.height + 5;
		
			self.chkHideChassis.value := false;
			// 08/08/2022	navkc1	#54476 --&gt;
			if not self.isFirstLaunched then
				self.fldrDetails.height := self.fldrDetails.height - self.grpTrailerIn.height - self.grpTrailerOut.height;
			else
				self.isFirstLaunched := false;
			endif;
			// 08/08/2022	navkc1	#54476 &lt;--
		else
			self.frmButtons.visible := true;
			self.grpTrailerIn.visible := true;
			self.grpTrailerOut.visible := true;	
			self.grpTotals.top :=  self.grpTrailerOut.top + self.grpTrailerOut.height + 1;
			self.frmButtons.top := self.grpTotals.top + self.grpTotals.height + 5;
		
			self.chkHideChassis.value := false;
			// 08/08/2022	navkc1	#54476 --&gt;
			if not self.isFirstLaunched then
				self.fldrDetails.height := self.fldrDetails.height - self.grpTrailerIn.height - self.grpTrailerOut.height;
			else
				self.isFirstLaunched := false;
			endif;
			// 08/08/2022	navkc1	#54476 &lt;--
		endif;

	endif;
	
	self.btnFindTrailer.visible:=false;
	self.fldrDetails.top := self.frmButtons.top;
	self.height :=self.frmButtons.top + self.frmButtons.clientHeight + self.lblGatePrinter.clientHeight + self.cmbPrinter.clientHeight + 50;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_hide" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMnuCargoLabelPrint" id="25fb81fc-3fcd-4036-a3d4-a3bb475c4dbd">
        <source>doMnuCargoLabelPrint(_selectedItem : Object);
/*

Purpose:			Print Bar Code Labels

Parameters:			_selectedItem is when only 1 label is required
					when null print all for this Vehicle Visit
Return Value:		

Date			Who		Reason
08 March 2010	conkc1	Initial creation

*/
vars
	tiArray : CM_ObjectArrayActual;
	obj     : Object;
begin
	
	if self.myRealVVR.allGateEntities.isEmpty then
		return;
	endif;
	
	create tiArray transient;

	foreach obj in self.myRealVVR.allGateEntities do
		if obj.isKindOf(CMGTE_Receival) then
			if _selectedItem = null or _selectedItem = obj then
				tiArray.add( obj.CMGTE_Receival );
			endif;
		elseif obj.isKindOf(CMGTE_ReceivalByType) then	// 06 Aug 2010	NDL	Par 25335
			if _selectedItem = null or _selectedItem = obj then
				tiArray.add( obj.CMGTE_ReceivalByType );
			endif;
		endif;
	endforeach;
	
	if tiArray.isEmpty then
		return;
	endif;
	
	self.myAssistant.showCargoIdLabelPrintForm(tiArray);

epilog

	delete tiArray;
	
end;</source>
        <Parameter name="_selectedItem" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doMnuTransferDelete" id="3a18da92-fdd6-4ea7-978b-d81f208dec51">
        <updating/>
        <source>doMnuTransferDelete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 September 2011	cnwndl1	Initial creation	Par 24455

*/

vars

	ti : CM_TrackedItem;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin

	ti := self.tblTransfers.accessRow(self.tblTransfers.row).itemObject.CM_TrackedItem;
	
	if ti = null then
		return;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxRemoveTransfer(ti, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.populateTblTransfers();
			break;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(Delete), app.myPassport, ErrWarnMode_Delete);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOpenBoomForEntry" id="c3206a60-1579-46e2-969e-fd3b1ea34982">
        <source>doOpenBoomForEntry( _realVVR : CM_VehicleVisitRecord; _preProcTruckLocation : CM_LocationsController );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 February 2019	jlgndl1	Initial creation	TFS 42940

*/

vars

	gateLane : CM_GateAreaLaneController;
	boom : CM_Boom;
	boomMess : String;
	debugMess : String;
	ts : TimeStamp;
	mess : String;

begin

	if _realVVR &lt;&gt; null and _preProcTruckLocation &lt;&gt; null then
		if _preProcTruckLocation.isKindOf(CM_GateAreaLaneController) then
			gateLane := _preProcTruckLocation.CM_GateAreaLaneController;
			if gateLane &lt;&gt; null then
				boom := gateLane.getBoom(true);
				if boom = null then
					boom := gateLane.getBoom(false);
				endif;
				if boom &lt;&gt; null then 
					ts := app.actualTimeAppServer;
					app.mousePointer := Busy;
					boom.boomUp( boomMess, debugMess );
					app.mousePointer := Idle;
				endif;
				if boomMess &lt;&gt; null then
					app.beep;
					mess := _realVVR.visitNumber &amp; app.getErrorString(Gate_entry_proce_boom_fiale_op) &amp; " " &amp; ts.time.asStringJMT &amp; CrLf;
					app.msgBox( mess &amp; boomMess, app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Information_Icon);
				endif;
			endif;
		endif;
	endif;

epilog

	app.mousePointer := Idle;

end;</source>
        <Parameter name="_realVVR" type="CM_VehicleVisitRecord"/>
        <Parameter name="_preProcTruckLocation" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="doPrintBuckSlip" id="861d4ea5-d510-4743-b33a-9a2f7950c00f">
        <source>doPrintBuckSlip(realVVR :CM_VehicleVisitRecord input) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 August 2012	cnwer1	Initial creation CCMS MES 1280

*/

//8.2.2 version 18 June 2013	NDL	Par 31842
vars

	printCopies	: Integer;
	printConfirm : GTE_PrintConfirmationForm;	// PAR #28733
	printerName : String;
	
begin

	if self.myTerminal.roadProcessIsASPA then	//24 Nov 2020	NDL	TFS 50400
		return;
	endif;
	
	// 26912 Feb 2011 allow more than one copy printed for Messina - at this stage use the terminal Road Receipt copies value
	printCopies := 1;
	//12 Jun 2015	NDL - checking par 36197, Messina don't have "isClientMessina" set anyway, so no one should be using this
//	if app.myRoot.isClientMessina then
//		printCopies := self.myTerminal.getConfig(GateReceiptCopies).Integer;
//	endif;
	
	printerName := self.cmbPrinter.text;
		
	if self.myTerminal.getConfig(DisplayPrintConfirmation).Boolean then
		create printConfirm transient;
		printConfirm.setPrintDetails(printCopies, printerName, self);
		printCopies := printConfirm.showModal;
		printerName := self.cmbPrinter.text; // may have been updated within GTE_PrintConfirmationForm 
	endif;
	
	if realVVR = null or realVVR.myRoadJob = null then	//To fix 1090s
		return;
	endif;
	
	if printCopies &gt; 0 then
		realVVR.myRoadJob.printDriverDetails(printCopies, self.myTerminal.getConfig(PrintPreview).Boolean, null, printerName);
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="realVVR" type="CM_VehicleVisitRecord" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doPrintInterchangeReport" id="6a66fe2b-96a8-43b9-a74f-23e4351ae53e">
        <source>doPrintInterchangeReport( _realVVR :CM_VehicleVisitRecord input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 January 2019	jlgndl1	Initial creation	TFS 40479

*/

vars
	defaultPrinterName : String;
	printerName : String;
begin
	defaultPrinterName := app.printer.getPrinterName;
	if _realVVR = null or _realVVR.myRoadJob = null then	//
		return;
	endif;
	if self.myTerminal.getConfig( PrintInterchange ).Boolean then
		printerName := self.cmbPrinter.text;
		_realVVR.myRoadJob.printInterchangeReport( 1, self.myTerminal.getConfig(PrintPreview).Boolean, printerName);
	endif;

epilog
	app.printer.setPrinter( defaultPrinterName );
end;</source>
        <Parameter name="_realVVR" type="CM_VehicleVisitRecord" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doQuery" id="bdd936b1-271e-48b6-a138-eae9d19155cc">
        <updating/>
        <source>doQuery(_vvr :CM_VehicleVisitRecord) updating;
// ---------------------------------------------------------------------------
// Created:     19 August 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 09/02/2011		cnwdap1			PAR #26929 Prevent maintenance of cancelled vehicle visit records
// 18/12/2013		cnwdap1			PAR #32849 CCMS PEN 2321 Security Gate - can also enter a bat number to search on
// 04/05/2015		cnwdap1			PAR #36079 Logging to track how BAT number is overwriting vehicle visit number
// 14/09/2016		cnwma1			TFS #2619:SPT - Road Gate loading incorrect release/prenote details when entering the Reg Code
// 30/10/2019		jlgdap1			TFS 46854 SNO Driver Integrity Checking for Cargo Release
// 26/02/2020		jlgdap1			TFS 48688 SNO Driver Identity check for some variances in road gate process 
//	24 Feb 2021	NDL	TFS 50849 - Remove deug messages relative to Par 36079
// ---------------------------------------------------------------------------

vars
	tmpStr : String;
	tmpVVR	: CM_VehicleVisitRecord;
	newVVR : Boolean;						// TFS 48688
begin
	tmpStr := self.txtVisitNumber.text;
//	app.writeLog(method.qualifiedName &amp; " Started with self.txtVisitNumber.text of '" &amp; self.txtVisitNumber.text &amp; "'", LogINFO);	// PAR #36079
	
	if tmpStr &lt;&gt; null then
		//tmpVVR := self.myTerminal.getVehicleVisitRecordByTran(tmpStr); //14/09/2016 cnwma1 TFS #2619
		if _vvr &lt;&gt; null and _vvr.visitNumber =tmpStr then  //14/09/2016 cnwma1 TFS #2619
			tmpVVR :=_vvr;
		else
			tmpVVR := self.myTerminal.getVehicleVisitRecordByTran(tmpStr);
		endif;
		
		if tmpVVR &lt;&gt; null and tmpVVR.visitNumber &lt;&gt; tmpStr then								// PAR #32849
			tmpVVR := null;																	// PAR #32849
//			app.writeLog(method.qualifiedName &amp; " no VVR found direct for " &amp; tmpStr, LogINFO);			// PAR #36079
		endif;																				// PAR #32849
		
		// PAR #32849 if we didn't find a match on VVR number, and the site has a security gate, 
		// look for an incomplete and uncancelled visit record that has the entered Bat Number assigned to it
		if tmpVVR = null and self.myTerminal.getConfig(SiteHasSecurityGate).Boolean then	// PAR #32849
			tmpVVR := self.myTerminal.getVehicleVisitForBatNumber(tmpStr);					// PAR #32849
//			if tmpVVR &lt;&gt; null then																			// PAR #36079
//				app.writeLog(method.qualifiedName &amp; " VVR found via bat check for " &amp; tmpStr, LogINFO);	// PAR #36079
//				if tmpVVR.getSecurityGateArrivedDetail = null then											// PAR #36079
//					app.writeLog(method.qualifiedName &amp; " VVR has no security gate arrival", LogINFO);	// PAR #36079
//				else																						// PAR #36079
//					app.writeLog(method.qualifiedName &amp; " VVR has a security gate arrival", LogINFO);		// PAR #36079
//				endif;																						// PAR #36079
//			endif;																							// PAR #36079
		endif;																				// PAR #32849
		
		if tmpVVR = null then
			app.msgBox('No record found for transaction ' &amp; tmpStr, 'Error', 0);
			self.clearForm();
			return;
		endif;
		
		self.clearLayout(); // 26 may 2011	NDL	Par 27585
		
		if self.myRealVVR = null then				// TFS 48688
			newVVR := true;							// TFS 48688
		endif;										// TFS 48688
		self.setMyCurrentVVR(tmpVVR);
		// PAR #26929
		//epr TFS 2982 29/11/16 
		if not self.myRealVVR.isUpdatable or self.myRealVVR.isCancelled then	// PAR #26929
			self.myTrkFlexiLayIn.disableDoorsDirections();
			self.myTrkFlexiLayOut.disableDoorsDirections();
			self.enableFieldsAfterQuery(false);

			self.allowAddToTruck(tmpVVR);	// 26 May 2011	NDL Par 27585
		endif;
		
		self.cmbRFID.listIndex := -1;	//23 Apr 2012	NDL	Par 29417
		if self.myRealVVR.myRoadJob &lt;&gt; null then
			self.btnPrint.visible := true;
			self.btnPrint.enabled := true;
			//23 Apr 2012	NDL	Par 29417
			if self.myRealVVR.myRoadJob.getMyRFIDTag &lt;&gt; null and self.cmbRFID.visible then
				self.myAssistant.comboBoxRFIDTag( self.cmbRFID, self.myTerminal, self.myRealVVR.myRoadJob.myRFIDTag );
			endif;
		else
			self.btnPrint.visible := false;
		endif;
		
		// PAR #32849 if we've enquired on a vehicle visit that has no gate (only been to the Security Gate),
		// build the gate combo so it defaults to the default gate
		if self.myRealVVR.myGateIn = null then					// PAR #32849
			self.doBuildGateCombo();							// PAR #32849
		endif;													// PAR #32849
		
		if newVVR then								// TFS 48688
			self.txtDriverCode.enabled := true;		// TFS 48688
			self.cmbDriver.enabled := true;			// TFS 48688
		endif;										// TFS 48688
		self.releaseRequiresDriverIDCheck();		// TFS 48688
		// TFS 46854 start
		if self.cmbDriver.visible and self.cmbDriver.listIndex &gt; 0 then
			self.btnCheckID.visible := false;
		elseif self.txtDriverCode.visible and self.txtDriverCode.text &lt;&gt; null then
			self.btnCheckID.visible := false;
		endif;
		// TFS 46854 end
		
	else
		app.msgBox('You must enter a transaction number to search for.' &amp; tmpStr, 'Error', 0);
		self.clearForm();
	endif;
	
epilog

end;</source>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="doRemoveGTE" id="54e2c42b-1ae1-4710-ae80-dfe528fe4ec1">
        <updating/>
        <source>doRemoveGTE() updating;
// ---------------------------------------------------------------------------
// Created:     08 August 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theReturn, row	: Integer;
	realGTE 		: CMGTE_Entity;	
	realGTEId		: String;
begin
	
	row := self.tblItems.row;
	
	if row &lt;= self.tblItems.fixedRows then
		//app.msgBox("Please select an item to remove.","Removal Problem", MsgBox_Exclamation_Mark_Icon);
		app.msgBox(app.getErrorString(SELECT_ITEM_TO_REMOVE),app.getErrorString(MSGBOX_REMOVAL_PROBLEM), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	realGTE := self.tblItems.accessRow(row).itemObject.CMGTE_Entity;
	if realGTE &lt;&gt; null then			
		//if app.msgBox("Are you sure that you want to remove item " &amp; realGTE.getTableDisplayString &amp; "?", "Confirm Removal", MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		if app.msgBox(app.getErrorString1(WARNING_REMOVE_ITEM,realGTE.getTableDisplayString), app.getErrorString(CONFIRM_REMOVAL), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			return;
		endif;
	else
		return;
	endif;
	
	while true do
		if realGTE.isKindOf(CMGTE_Release)or realGTE.isKindOf(CMGTE_Container) then //cnwas3 begin
			realGTEId:=realGTE.getID();		
		endif;	//cnwas3 end
		app.myTrxDA.trxDeleteVehicleVisitGTE(realGTE, app.myPassport);
		if app.myPassport.trxCompletedOK then
			if realGTE.isKindOf(CMGTE_Release) then //cnwas3 begin
				///self.myTrkFlexiLayOut.removeContainer(realGTEId);
				self.myTrkFlexiLayOut.removeContainer(realGTE);			// 17/12/2010 cnwmh5 #26635
			elseif realGTE.isKindOf(CMGTE_Container) then
				///self.myTrkFlexiLayIn.removeContainer(realGTEId);
				self.myTrkFlexiLayIn.removeContainer(realGTE);			// 17/12/2010 cnwmh5 #26635
			endif;	//cnwas3 end
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(TRANSACTION), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
	
	//20 Sep 2011	NDL	Par 24455
	self.populateTblBulkRelease(self.cmbCarrier.listObject.CM_Carrier);
	self.populateTblTransfers();
	self.setReceiveReleaseTotals();	//10 Jan 2019	NDL	TFS 40479
	

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="22c2c35a-d3a8-46e0-b38f-c63369a5ab25">
        <updating/>
        <source>doSave() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     26 September 2008 by cnwab1
//
/* Changes

Date		Name	TFS#		Description
============================================================================
19/02/2010	consw1	PAR #21937	Do not print Buck Slip when doing auto complete
23/02/2010	cnwcs5	par 18061 	prompt for rfid tag
09/02/2011	cnwdap1	PAR #26929 	prevent erroneous "you have changed something" messages
								when doing a Vehicle Visit find
23/11/2011	cnwdap1	PAR #28733	CCMS SFW 1261 Show confirmation dialog for printing 
								buckslip if configured to do so
04/10/2013 	cnwer1	PAR 32613   removed reference to doPrintTickets always did nothing anyway because at that point self.myRealVVR was null
19/12/2013	cnwdap1	PAR #32849 	CCMS PEN 2321 Raise a notification for the Security Gate Monitor screen
10/12/2015  cnwma1	PAR #37193 	Appointment Number Not Displayed on Receive Cargo Screen
26/07/2018  cnwma1	Bug 39489: 	SNO - RTS issue
21/08/2018 	jlgns1	Bug 39807: 	PEN - Clip On Unit disappears from a container when a chassis is received at the same time
09/11/2018 	jlgrh7 	TFS #41447 	SNO - Error Code 75793
24/04/2019 	jlgka1	44428 		PEN - Chassis Error.
30/10/2019	jlgdap1	TFS 46854	SNO Driver Identity Checking for Cargo Release
30/03/2022  navhl20 TFS 52777   EUP - INT - Generic API: record-scan
13/05/2022  navhl20 TFS 53430 	EUP - Sub Carrier registration in MTN
12/07/2022	navmd1	TFS 52777	Tidy up/review code
03/05/2023	navpw1	TFS 54049	(55840) - Hide Vehicle Booking Associate form if the vbs process is nto standard
08/02/2024	navhl20 ChangeRequest 62084:[62379] EUP | Retrospective Operations - [54177.010] - Road Entry
21/03/2024	jlizm1	TFS 63084 	Gate required driver
28/05/2024	navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
12/08/2024	navdap1	TFS 65606 CUX - Save button on Road Gate not responding
============================================================================*/

vars
	result					: Integer;
	pxyVVR,
	realVVR					: CM_VehicleVisitRecord;
	printReceipt,
	printBuckSlip			: Boolean;	
	gate					: CM_Gate;
	arrAllWarnings			: HugeStringArray;			// cnwjk3 PAR 23206 18/03/2010
	allProformaLines		: ObjectSet;
	defaultPrinterName		: String;
	printCopies				: Integer;
	preProcTruckLocation	: CM_LocationsController;	//18 Feb 2019	NDL	TFS 42940
	showWeighForm			: Boolean;					//05 Jul 2019	NDL	TFS 44965
	weighBridge				: CM_WeighBridgeObj;		//05 Jul 2019	NDL	TFS 44965
	vehicle					: CM_Vehicle;				//05 Jul 2019	NDL	TFS 44965
	nowLocal				: TimeStamp;				//09 Oct 2020	NDL	TFS 49189
	pxyGateScanRecord		: CM_GenericGateScanRecord;
	vbsProcess				: CM_VBSProcess;			// ### TFS 54049 (55840) 03May2023 NAVPW1
	reqDriver				: Boolean;					// TFS 63084
	term					: CM_Terminal;
begin
	//jlgka1 TFS 44428 --&gt;
	app.myPassport.clearErrorsWarnings();
	//jlgka1 TFS 44428 &lt;--
	
	app.myPassport.hadDeadlock := false;		// TFS 65606
	
	//03 Sep 2012	NDL	Par 30286
	defaultPrinterName := app.printer.getPrinterName;
	
	//Start 13/05/2022  navhl20 TFS 53430
	if isSubCarrierMandatory and self.cmbSubCarrier.listIndex = -1 then 
		app.msgBox( app.getErrorString(Input_Require_Subcarrier_Field), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	//End 13/05/2022  navhl20 TFS 53430
	
	term 			:= self.myTerminal;										//28.05.2024 navma1 #64224
	printBuckSlip	:= term.getConfig(PrintBuckslip).Boolean;
	reqDriver 		:= term.getConfig(KnownTruckDriverRequired).Boolean;	// TFS 63084
	
	if self.myRealVVR &lt;&gt; null then
		realVVR := self.myRealVVR;
		pxyVVR := app.createUpdateProxy(self.myRealVVR).CM_VehicleVisitRecord;
		pxyVVR.setIsUpdatable(false);
	else
		create pxyVVR transient;
		pxyVVR.setIsUpdatable(true); //jlier1	TFS  59732 6/9/23
	endif;

	if not self.saveProxyVVR(pxyVVR) then
		return false;
	endif;
	
	self.allVehicleBookingTimeslots.copyNoDuplicates(pxyVVR.allVehicleBookingSlots, false);	// ### TFS 54049 (55840) 16May2023 NAVPW1
	
	
	//app.myPassport.setWarningsIgnored(true);
	
	if pxyVVR.driverCode = null then
		if self.btnCheckID.visible or reqDriver then
			app.raiseCMException(ERR_Driver_Code_Blank, null, null);		// TFS 46854
		endif;
	endif;
	
	if pxyVVR.isRoadJobAutoComplete then
		printBuckSlip := false;
	endif;
	
	if printBuckSlip then
		if self.cmbPrinter.listIndex &lt; 1 then	///8.2.2 version 18 June 2013	NDL	Par 31842
			app.raiseCMException(Input_required_field_printer,null,null); //cnwdb2 PAR 35364

			return false;
		endif;
		
	endif;
	self.doSavePrenotes(pxyVVR) ;				//+TFS41447
		
	// ### TFS CR 64297 TASK 64299 28MAY2024 NAVAB1
	if app.myPassport.hadDeadlock = true then
		return false;
	endif;

	if app.myPassport.hasErrors then
		app.showErrorWarningDialog(app.getErrorString(Errors), app.myPassport, ErrWarnMode_AddUpdate);// 28 Dec 2018 NDL TFS 42699 - re-instate the message display for errors removed by 41447
		return false;
	endif;
	
	// have to do this before the main trx and not in that trx because the pro forma does it's calc and aborts
	// check terminal is cash enabled
	// have to update the receival tis from the GTE objects	
	if term.isCashOnlyEnabled then							//28.05.2024 navma1 #64224
		create allProformaLines transient;
		if not self.doCashOnlyValidation(allProformaLines) then
			return false;
		endif;
	endif;
	
	// cnwjk3 PAR 23206 18/03/2010			
	// Transfer all saved warnings to the passport			// cnwjk3 PAR 23206 18/03/2010
	create arrAllWarnings transient;						// cnwjk3 PAR 23206 18/03/2010
	self.getCollatedWarnings(arrAllWarnings);				// cnwjk3 PAR 23206 18/03/2010
	app.myPassport.saveExternalWarnings(arrAllWarnings);	// cnwjk3 PAR 23206 18/03/2010
	app.myPassport.setWarningsAcknowledged(true);			// cnwjk3 PAR 23206 18/03/2010
															// cnwjk3 PAR 23206 18/03/2010
	
	//18 Feb 2019	NDL	TFS 42940
	if realVVR &lt;&gt; null and realVVR.vehicle &lt;&gt; null then
		preProcTruckLocation := realVVR.vehicle.myPrimaryActualLocation; // where the truck was before the save. No point in opening the boom, its already in the yard.
	endif;
	
	while true do
		//26 May 2011	NDL	Par 27585
	self.doSaveAdditions(pxyVVR, realVVR,allProformaLines, app.myPassport);	//26 May 2011	NDL	Par 27585
		
		// ### TFS CR 64297 TASK 64298 28MAY2024 NAVAB1
		if app.myPassport.hadDeadlock = true then
			return false;
		endif;
		
        if app.myPassport.trxCompletedOK then
			self.allVehicleBookingTimeslots.clear(); // ### TFS 54049 (55840) 16May2023 NAVPW1
            break;
        else
			// Strip out the warnings we know that we don't want to see again.									// cnwjk3 PAR 23206 29/03/2010
			app.myPassport.removeWarnings(arrAllWarnings);														// cnwjk3 PAR 23206 29/03/2010
			if app.myPassport.noErrors() and app.myPassport.noWarnings then  // Can happen with attachments		// cnwjk3 PAR 23206 29/03/2010
				app.myPassport.warningsAcknowledged     := true;											// cnwjk3 PAR 23206 29/03/2010
				continue;																					// cnwjk3 PAR 23206 29/03/2010			
			endif;																								// cnwjk3 PAR 23206 29/03/2010

			result := app.showErrorWarningDialog(app.getErrorString(GateInOut), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged     := true;
					continue;
			endif;
			return false;
        endif;
        break;
	
	endwhile;
	
	if app.myPassport.noErrors then
		if self.myAssistant.myCurrentGateScanRecord &lt;&gt; null then
			pxyGateScanRecord := app.createUpdateProxy(self.myAssistant.myCurrentGateScanRecord).CM_GenericGateScanRecord;
			if pxyGateScanRecord &lt;&gt; null then
				pxyGateScanRecord.setVehicleVisitRecord(realVVR);
				app.myTrxUA.trxUpdateGateScanRecord(pxyGateScanRecord, app.myPassport);
				// ... and if this fails ?
			endif;
		endif;
	endif;
	
	//05 Jul 2019	NDL	TFS 44965
	if realVVR &lt;&gt; null then
		if realVVR.hasWeighInVVRD &lt;&gt; null then	//VisitRecord_WeighBridgeIn - TwoReadings style weigh bridge.
			//nothing to do here, we only weigh once when coming in and we have already done it.
		else
			weighBridge := self.myTerminal.allWeighBridges.getMyTwoReadingsWeighBridge();
			//check if we do have a 'two readings' weigh bridge associated with our PC.
			if weighBridge &lt;&gt; null then
				//we do have a 'two readings' weigh bridge, are the rest of the stars aligned.
				showWeighForm := realVVR.autoShowWeighBridgeAtGate();
				if showWeighForm then
					vehicle := realVVR.vehicle;
					self.myAssistant.showWeighForm( self, vehicle, null, null);
				endif;
			endif;
		endif;
	endif;
	
	//23 Apr 2012	NDL	Par 29417
	if not self.applyRFIDtoJob( realVVR.myRoadJob ) then
		// ### TFS CR 64297 TASK 64298 28MAY2024 NAVAB1
		if app.myPassport.hadDeadlock = true then
			return false;
		endif;
		
		
		return false;
	endif;	
	
	// the job has been saved - we may need to show the rfid tag form
	self.myAssistant.GTE_Assistant.showRFIDTagFormForRoadEntry (realVVR.myRoadJob);	// 23/02/2010 cnwcs5 par 18061
	
	gate := self.cmbGate.listObject.CM_Gate;		// cnwjk3 15/10/09 PAR 21333
	self.driverIDScanned := false;				// TFS 46854
	self.clearForm();
	self.doChangeGate(gate);						// cnwjk3 15/10/09 PAR 21338
	
	//09 Apr 2013	NDL	Par 31393
	if self.myTerminal.isVehicleBookingEnabled then
		vbsProcess := self.myVBSProcess;
		//if realVVR &lt;&gt; null then
		//if realVVR &lt;&gt; null and realVVR.myVehicleBookingTimeslot = null then	//20 Oct 2014	NDL	Par 35008
		//Should show form if the vbsProcess is either Standard or null
		if vbsProcess = null or (vbsProcess &lt;&gt; null and vbsProcess.isVbsStandard) and realVVR &lt;&gt; null and realVVR.myVehicleBookingTimeslot = null then		// ### TFS 54049 (55840) 03May2023 NAVPW1
			if not self.myTerminal.hideTheVbsAssocForm( realVVR ) then	//15 May 2015	NDL	Par 36234
				self.myAssistant.showVehicleBookingAssociation( self, realVVR, null, null );
			endif;
		endif;
	endif;
	
	if printBuckSlip then
		//epr refactored code block into method 
		self.doPrintBuckSlip(realVVR);
	endif;
	self.doPrintInterchangeReport(realVVR);	//11 Jan 2019	NDL	TFS 40479
	
	//29 Nov 2012	NDL	Par 30745
	if realVVR &lt;&gt; null and realVVR.isRoadJobAutoComplete and self.chkReceiptReq.value then
		printCopies := self.myTerminal.getConfig(GateReceiptCopies).Integer;
		if printCopies &gt; 0 then
			//realVVR.printReceipt( printCopies, self.myTerminal.getConfig(PrintPreview).Boolean, self.myTerminal, self.myTerminal.getRoadReceiptReport().String, null, null);
			//12 Dec 2013	NDL	Par 33184
			realVVR.printRoadReceipt(	printCopies,	//_copies : Integer;
										self.myTerminal.getConfig(PrintPreview).Boolean,	//_printPreview : Boolean;
										null	//_printerLogicalName : String
										);
		endif;
	endif;
	
	self.doOpenBoomForEntry( realVVR, preProcTruckLocation );	//18 Feb 2019	NDL	TFS 42940
	
	self.detailsChangedVehicle := false;	// PAR #26929
	if realVVR &lt;&gt; null then																					// PAR #32849
		realVVR.causeEvent(realVVR.myTerminal.getTerminalEvent(EVENT_VEHICLEVISIT_UPDATE), false, realVVR);	// PAR #32849
	endif;																									// PAR #32849
	// Make way for the next VVR to be created
	self.myRealVVR := null;
	self.btnRecordWeight.enabled := false;		// 21/6/17 MAP TFS4273
	
	if self.myVehicleBookingTimeslot &lt;&gt; null then       // 10/12/2015 cnwma1 PAR #37193
		self.myVehicleBookingTimeslot := null;
	endif;
	
	//09 Oct 2020	NDL	TFS 49189
	if self.myTerminal.roadProcessIsASPA then
		nowLocal := self.systemToLocalTime(app.actualTimeServer());	
		self.txtDateIn.setDate(nowLocal.date());					
		self.txtTimeIn.setTime(nowLocal.time());					
	endif;
	
	if self.chkOpsRetrospective.visible then				//08.02.2023 navhl20 #62084[62379]
		self.txtDateIn.enabled := true;	
		self.txtTimeIn.enabled := true;	
		self.lblDateIn.enabled := true;	
		self.lblTimeIn.enabled := true;	
	endif;
	
	return true;
	
epilog
	//03 Sep 2012	NDL	Par 30286
	app.printer.setPrinter( defaultPrinterName );
	
	delete arrAllWarnings;					// cnwjk3 PAR 23206 18/03/2010
	delete pxyVVR;
	app.myPassport.clearErrorsToIgnore(); // PAR 17703 AKB2008SEP
	
	if allProformaLines &lt;&gt; null then
		allProformaLines.purge;
	endif;
	delete allProformaLines;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveAdditions" id="92e368ef-0816-40e0-8698-fbc43d153b81">
        <updating/>
        <source>doSaveAdditions(_pxyVVR : CM_VehicleVisitRecord;
				_realVVR : CM_VehicleVisitRecord io;
				_allProformaLines : ObjectSet input;
				_passport : CM_Passport input) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2011	cnwndl1	Initial creation	Par 27585
15 May 2018 cnwma1	Bug 38547: PENN - Gen Set Displayed as onsite when it has left the Terminal
19/6/2025   jlier1 MTN-34221 refactoring validation so is before trx - validation only never set so removed
*/

vars
	realEntities,
	entityArray : CMGTE_EntityArray;
	gteEntity : CMGTE_Entity;
begin

	if _realVVR &lt;&gt; null and not _realVVR.isUpdatable and _realVVR.myRoadJob &lt;&gt; null then //15/05/2018 cnwma1 Bug 38547
		//epr changes for CCMS 1386 ROB gate cargo

		// find the entities that need saving 
		create entityArray transient;
		foreach gteEntity in _pxyVVR.allGateEntities do
			if gteEntity = _pxyVVR.myInCMGTE_Chassis or
			   gteEntity = _pxyVVR.myOutCMGTE_Chassis then
				continue;
			endif;
			if (gteEntity.myYardRequest &lt;&gt; null and 				//cnwas3 28028
				gteEntity.status = CMGTE_Entity.Status_Unactioned) then
				
				continue;
			endif;
			entityArray.add(gteEntity);
		endforeach;
		
	
		app.myTrxCA.trxCreateInOutFlexiGateEntitys(_realVVR, entityArray,realEntities, true, _passport);
		
	else
		app.myTrxCA.trxCreateInOutFlexiJob(_pxyVVR, _realVVR,_allProformaLines, _passport);
		
	endif;
	
epilog
	delete entityArray;
	delete realEntities;
end;</source>
        <access>protected</access>
        <Parameter name="_pxyVVR" type="CM_VehicleVisitRecord"/>
        <Parameter name="_realVVR" type="CM_VehicleVisitRecord" usage="io"/>
        <Parameter name="_allProformaLines" type="ObjectSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSavePrenotes" id="65113d13-e4f6-40f3-ae29-947ab273cd92">
        <updating/>
        <source>doSavePrenotes(_pxyVVR : CM_VehicleVisitRecord) : Boolean updating, protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/08/2012	cnwer1	Initial creation CCMS MES 1035
10/04/2014	cnwdap1	PAR #33606 CCMS SFW 1366 Bulk
21/08/2018 	jlgns1	Bug 39807: PEN - Clip On Unit disappears from a container when a chassis is received at the same time - added a return value
09/11/2018 	jlgrh7  TFS #41447 SNO - Error Code 75793
28/05/2024  navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
*/

vars
	pxyTI,
	ti				: CM_TrackedItem;
	gteEntity, 
	realGTE 		: CMGTE_Entity;
	pxyTISet 		: CM_TISet;
	result 			: Integer;
	arrAllWarnings  : HugeStringArray;
	gteChildEntity	: CMGTE_Entity;
	childTi 		: CM_TrackedItem;
	cargoType		: CM_CargoType;
begin

	create pxyTISet transient;
	
	foreach gteEntity in _pxyVVR.allGateEntities discreteLock do
		if not gteEntity.isKindOf(CMGTE_Receival) then
			continue;
		endif;
		ti:=gteEntity.CMGTE_Receival.myTrackedItem;
		if ti = null then
			continue;
		endif;
		
		if not ti.isPreNote() then
			continue;
		endif;
		
		cargoType := ti.myCargoType;			//28.05.2024 navma1 #64224
		
		if ti.canSplitTotalQuantity and 
		((cargoType.isBreakBulkMulti and ti.totalQuantity &gt; gteEntity.CMGTE_Receival.totalQuantity) or
		(cargoType.isBulkMulti and cargoType.isTrackByWeight and ti.totalWeight &gt; gteEntity.CMGTE_Receival.weightTotal) or		// PAR #33606
		(cargoType.isBulkMulti and cargoType.isTrackByVolume and ti.totalVolume &gt; gteEntity.CMGTE_Receival.volumeTotal)) then	// PAR #33606
			continue;
		endif;
		
		pxyTI := app.createUpdateProxy(ti).CM_TrackedItem;
		pxyTISet.add(pxyTI);									//+TFS41447		pxoy objects will be deleted proplerly later on 
		pxyTI.setPxyFromCMGTE_Receival(gteEntity.CMGTE_Receival, app.myPassport);   
		
	endforeach;	
	
	if  pxyTISet.isEmpty then
		return true;//Bug 39807
	endif;
	
	create arrAllWarnings transient;						// cnwjk3 PAR 23206 18/03/2010
	self.getCollatedWarnings(arrAllWarnings);				// cnwjk3 PAR 23206 18/03/2010
	app.myPassport.saveExternalWarnings(arrAllWarnings);	// cnwjk3 PAR 23206 18/03/2010
	app.myPassport.setWarningsAcknowledged(true);	
	
	
	
	while true do

		app.myTrxUA.trxUpdateTrackedItems(pxyTISet, TI_UPDMODE_NORMAL, null, app.myPassport);
		
		// ### TFS CR 64297 TASK 64299 28MAY2024 NAVAB1
		if app.myPassport.hadDeadlock = true then
			return false;
		endif;

		if app.myPassport.trxCompletedOK then		
			break;
		else
			// Strip out the warnings we know that we don't want to see again.							
			app.myPassport.removeWarnings(arrAllWarnings);													
			result := app.showErrorWarningDialog(app.getErrorString(Errors), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
	
		break;
	endwhile;
	
	// update successful have to go round and update the gte tiEdition to stop object edition mis match error
	
	foreach gteEntity in _pxyVVR.allGateEntities discreteLock do
		if not gteEntity.isKindOf(CMGTE_Receival) then
			continue;
		endif;
		ti:=gteEntity.CMGTE_Receival.myTrackedItem;
		if ti = null then
			continue;
		endif;
		
		gteEntity.CMGTE_Receival.updatetTIEdition();
		
		//18 Feb 2016	NDL	Par 37559
		foreach gteChildEntity in gteEntity.CMGTE_Receival.allChildren do
			childTi := gteChildEntity.CMGTE_Receival.myTrackedItem;
			if childTi = null then
				continue;
			endif;
			gteChildEntity.CMGTE_Receival.updatetTIEdition();
		endforeach;
		
		realGTE:=gteEntity.pxyGetRealObject();
		if realGTE &lt;&gt; null then
			self.saveWarningsForObject(app.myPassport, realGTE, true /*true = clear out existing warnings*/);
		endif;
	endforeach;
	
	return not app.myPassport.hasErrors;//Bug 39807
	
epilog
	pxyTISet.purge;
	delete pxyTISet;
	delete arrAllWarnings;		
end;</source>
        <access>protected</access>
        <Parameter name="_pxyVVR" type="CM_VehicleVisitRecord"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowHideDriverCodeName" id="1540fc64-74d8-409b-852b-af001f12a888">
        <source>doShowHideDriverCodeName();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10/01/2011	cnwdz2	Initial creation
// par 26613
13/06/2024	jlizm1	TFS 63908 Allow duplicate driver names
*/

vars

begin
	
	if self.myTerminal.getConfig(HideRGateDriverCodeName).Boolean then 
		self.lblDriverCode.visible := false;
		self.txtDriverCode.visible := false;
		self.cmbDriverCode.visible := false;
		self.lblDriverName.visible := false;		
		self.txtDriverName.visible := false;
		
		if self.lblRegno.visible then
			self.lblRegno.left := DriverCode_Left;			
			self.txtRegno.left := DriverCodeTxt_Left;
		endif;
		
		if self.lblState.visible then
			self.lblState.left := Gate_Left;			
			self.txtState.left := GateTxt_Left;
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doShowHideState" id="f0bbb33f-74df-4d24-a320-3ce09ba475b5">
        <source>doShowHideState();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 March 2010	cnwrd1	Initial creation
// par 21158
*/

vars

begin

	if self.myTerminal.getConfig(ShowVehicleState).Boolean then 
		self.lblState.visible := true;
		self.txtState.visible := true;
	else
		self.lblState.visible := false;
		self.txtState.visible := false;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblItemsCopyItem" id="f5cfc098-32af-4ce0-8bb3-0a443057f3cb">
        <updating/>
        <source>doTblItemsCopyItem() updating;
// -----------------------------------------------------------------------------
// Created:		31 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------

vars
	row		: Integer;
	tranNum : String;
	vvRec : CM_VehicleVisitRecord;
	table : CM_DataTable;
	gteEntity	: CMGTE_Entity;
	
begin
	table := self.tblItems;
	
	row := table.row;
	if row &lt;= table.fixedRows then
		return;
	endif;
	
	gteEntity := table.accessRow(row).itemObject.CMGTE_Entity;		// The real getEntity
	if gteEntity = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'getEntity not found for row ' &amp; row.String);
		return;
	endif;
	
	if self.isOKToProceed() then
		self.displayDataUpdate(self.myRealVVR, tranNum, true, gteEntity);
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblItemsDblClick" id="051bb651-95a4-472b-a2a5-721fae38bd98">
        <updating/>
        <source>doTblItemsDblClick() updating;
// ---------------------------------------------------------------------------
// Created:     07 August 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	row		: Integer;
	tranNum : String;
	vvRec : CM_VehicleVisitRecord;
	table : CM_DataTable;
	gteEntity	: CMGTE_Entity;
	
begin
	table := self.tblItems;
	
	row := table.row;
	if row &lt;= table.fixedRows then
		return;
	endif;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;
	
	gteEntity := table.accessRow(row).itemObject.CMGTE_Entity;		// The real getEntity
	if gteEntity = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'getEntity not found for row ' &amp; row.String);
		return;
	endif;
	
	if not self.isVVRUpdatable() then
		self.displayDataUpdate(self.myRealVVR, tranNum, false, gteEntity);
	elseif self.isOKToProceed() then
		self.displayDataUpdate(self.myRealVVR, tranNum, false, gteEntity);
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdateChangeStatus" id="eb2510f5-bfd2-4574-8d86-8a2e73eff444">
        <updating/>
        <source>doUpdateChangeStatus() updating;
// ---------------------------------------------------------------------------
// Created:     09 October 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theReturn : Integer;
begin
	if self.myRealVVR = null then
		return;
	endif;
	while true do
		app.myTrxUA.trxUpdateInOutGateStatus(self.myRealVVR,CMGTE_Entity.Status_Cancelled, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Change Status", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdateVVRec" id="fd6488e2-d7c6-49d9-8a75-9955df1e5bdc">
        <updating/>
        <source>doUpdateVVRec() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     19 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 10/12/2015       cnwma1 			PAR #37193 Appointment Number Not Displayed on Receive Cargo Screen
// 30/09/2016		cnwdap1			TFS 2720 Prevent 2 vehicle visit reords for the same vehicle
// 11/05/2023		navpw1			TFS: 54049 (55840) - Added code to assign vbs timeslot dependant on whether we are in slot type validation or standard process
// ---------------------------------------------------------------------------

vars
	pxyVVR, 
	realVVR					: CM_VehicleVisitRecord;
	doUpdate				: Boolean;
	vehicle					: CM_Vehicle;						// TFS 2720
	vbsProcess				: CM_VBSProcess;					// ### TFS 54049 (55840) 05May2023 NAVPW1
	isVbsStandardProcess	: Boolean;							// ### TFS 54049 (55840) 05May2023 NAVPW1
	
begin
	self.setErrorsToIgnore(app.myPassport, self.myTerminal); 	//cnwmc5 - 9 Sep 2015 - PAR 36814
	
	if self.myRealVVR = null then								// TFS 2720
		vehicle := self.getVehicle();							// TFS 2720
		if vehicle &lt;&gt; null then									// TFS 2720
			if not self.checkVehicleVisit(vehicle) then			// TFS 2720
				return false;									// TFS 2720
			endif;												// TFS 2720
		endif;													// TFS 2720
	endif;														// TFS 2720
	
	if self.myRealVVR = null then
		create pxyVVR transient;
	else
		doUpdate := true;
		pxyVVR := app.createUpdateProxy(self.myRealVVR).CM_VehicleVisitRecord;
	endif;
	
	if not self.saveProxyVVR(pxyVVR) then
		return false;
	endif;
	
	vbsProcess := self.myVBSProcess;
	
	if vbsProcess = null or (vbsProcess &lt;&gt; null and vbsProcess.isVbsStandard) then
		isVbsStandardProcess := true;
	endif;
	
	// ### TRX
	while true do
		if doUpdate then
			app.myTrxUA.trxUpdateVehicleVisitFlexi(pxyVVR, app.myPassport);
		else
			app.myTrxCA.trxCreateVehicleVisitFlexi(pxyVVR, realVVR, app.myPassport);
		endif;
		
		self.detailsChangedVehicle :=not app.myPassport.trxCompletedOK;
		
		//epr TFS 46815 30/9/19
		if app.showTrxErrorDialog(app.getErrorString(GateInOut)) then 
			continue;
		endif;
		
		if app.myPassport.trxCompletedOK then
			/*if realVVR &lt;&gt; null then
				self.setMyCurrentVVR(realVVR);
				if self.myVehicleBookingTimeslot &lt;&gt; null then
					self.doVvrAssocToVbtsStandard(self.myVehicleBookingTimeslot);
				endif;
			endif;*/
			
			// ### TFS 54049 (55840) 05May2023 NAVPW1
			if realVVR &lt;&gt; null then
				self.setMyCurrentVVR(realVVR);
			endif;
			
			if realVVR &lt;&gt; null and isVbsStandardProcess and self.myVehicleBookingTimeslot &lt;&gt; null then
				self.doVvrAssocToVbtsStandard(self.myVehicleBookingTimeslot);
			endif;
			// ### TFS 54049 (55840) 05May2023 NAVPW1
			
			self.enableActionButtons(true);
		endif;
		
		break;
	endwhile;
	
	
	return self.myRealVVR &lt;&gt; null;
	
epilog
	delete pxyVVR;
	app.myPassport.clearErrorsToIgnore(); // PAR 17703 AKB2008SEP

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUserNotifications" id="3653c71f-a4fe-4151-8cdc-bf2f3720857d">
        <updating/>
        <source>doUserNotifications(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:     19 August 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 21/02/2025		naviv1			JIRA-29374- EUP | Transaction Instrumentation - Gate
// 14 Jan 2026 		navhl20 		Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
// ---------------------------------------------------------------------------

vars
	localEvent 	: Integer;
	invalidObj 	: Boolean;
	vvRec 		: CM_VehicleVisitRecord;
	realGTE		: CMGTE_Entity;
	rfid,
	vvrRfid		: CM_RFIDTag;
	realVvr		: CM_VehicleVisitRecord;
	
begin

	// Handle deleted object exceptions
	on Exception do app.handleDeletedObject(exception, vvRec, invalidObj);

	localEvent := self.myTerminal.getEventFromTerminalEvent(eventType);

	// Exit early if userInfo is null
	if userInfo = null then
		return;
	endif;

	// Handle different event types
	if localEvent = Event_RFIDTagFree then
		rfid := userInfo.CM_RFIDTag;
		if self.cmbRFID.findObject(rfid) &lt; 1 then
			self.cmbRFID.itemObject[self.cmbRFID.addItem(rfid.code)] := rfid;
		endif;
		
	elseif localEvent = Event_RFIDTagInUse then
		rfid := userInfo.CM_RFIDTag;
		if self.cmbRFID.findObject(rfid) &gt; 0 then
			realVvr := self.myRealVVR;
			if realVvr &lt;&gt; null then
				vvrRfid := realVvr.getMyRFIDTag();
			endif;
			if vvrRfid &lt;&gt; null and vvrRfid = rfid then
				self.cmbRFID.listIndex := self.cmbRFID.findObject(rfid);
			else
				self.cmbRFID.removeObject(rfid);
			endif;
		endif;
		
	elseif localEvent = EVENT_VEHICLEVISIT_UPDATE then
		vvRec := userInfo.CM_VehicleVisitRecord;
		if vvRec.status = CM_VehicleVisitRecord.Status_Cancelled then
			if myRealVVR &lt;&gt; vvRec then
				return;
			endif;
			
			app.msgBox(app.getErrorString1(VehicVisit_update_another_user, myRealVVR.visitNumber), 'Vehicle Visit Update', MsgBox_Exclamation_Mark_Icon);

			self.clearForm();
			self.txtRegno.setFocus();
			self.btnFind.enabled := true;
			return;
		endif;
	
		if invalidObj then
			return;
		endif;

		if myRealVVR &lt;&gt; vvRec then
			return;
		endif;

		self.displayTransactions(vvRec);
		
	elseif localEvent = EVENT_VEH_VISIT_TRANSACTION then
		if self.myRealVVR = null then
			return;
		endif;
		
		realGTE := userInfo.CMGTE_Entity;
		self.displayTransactions(self.myRealVVR);
	endif;

epilog
	
end;
</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="doVehicleVisitCancel" id="bc838929-d035-4b56-9f09-996001e360d8">
        <updating/>
        <source>doVehicleVisitCancel(_reason :String) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 September 2009	cnwjk3	Initial creation
21/09/2009			cnwcs5	Renamed to reflect what it is doing
22/09/2009			cnwcs5	Add reason Parameter
*/

vars
	theReturn	: Integer;
begin
	//process.debugJK();
	while true do
		app.myTrxUA.trxUpdateVVRCancel(self.myRealVVR, _reason, app.myPassport);
		
        if app.myPassport.trxCompletedOK then
                // Clear errors/warnings from form and err/warnings window
                self.clearErrorWarnings();
                break;
        else
                theReturn := app.showErrorWarningDialog(app.getErrorString(GateInOut), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
                if app.myPassport.noErrors and
                   theReturn = IDOK then
                        // there must have just been warnings that the user has acknoledged so ..
                        app.myPassport.warningsAcknowledged     := true;
                        continue;
                endif;
                self.setAllErrorWarnings(app.myPassport);       // copies errors to this form and shows in err/warnings window
                return;
        endif;
        break;
	endwhile;	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_reason" type="String"/>
    </JadeMethod>
    <JadeMethod name="doVvrAssocToVbts" id="0da398eb-c476-4ce4-8e57-0afdf25889b5">
        <updating/>
        <source>doVvrAssocToVbts(_vbsts : CM_VehicleBookingTimeSlot) protected, updating;
/*

Purpose:			Associates the vehicle booking timeslot to the vehicle visit dependant on the Vbs process

Parameters:			_vbsts	CM_VehicleBookingTimeSlot	The vehicle booking time slot to associate to the vehicle visit

Return Value:		NONE

Date		Who		Reason
09 May 2023	navpw1	Initial creation TFS: 54049 (55840)

*/

vars
	vbsProcess	: CM_VBSProcess;
	proxyVVR,
	realVVR		: CM_VehicleVisitRecord;
	doUpdate	: Boolean;
	
begin
	if _vbsts = null then
		return;
	endif;
	vbsProcess := self.myVBSProcess;
	
	if vbsProcess &lt;&gt; null and vbsProcess.isVbsSlotValidation then
		self.doVvrAssocToVbtsSlotValidation(_vbsts);
		
	else
		self.doVvrAssocToVbtsStandard(_vbsts);
		
	endif;
	
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_vbsts" type="CM_VehicleBookingTimeSlot"/>
    </JadeMethod>
    <JadeMethod name="doVvrAssocToVbtsSlotValidation" id="8b25fc63-8479-42d3-8456-bf4d0315f643">
        <source>doVvrAssocToVbtsSlotValidation(_vbsts : CM_VehicleBookingTimeSlot) protected;
/*

Purpose:			Associates the vehicle booking timeslot to the vehicle visit for the vbs slot type validation process

Parameters:			_vbsts		CM_VehicleBookingTimeSlot	The vehicle booking time slot to associate to the vehicle visit
					_proxyVVR	CM_VehicleVisitRecord		The proxy vehicle visit record to associate the vbs time slot to

Return Value:		NONE

Date		Who		Reason
03 May 2023	navpw1	Initial creation TFS: 54049 (55840)

*/

vars
	
begin
	if _vbsts = null or _vbsts.myVehicleVisitRecord &lt;&gt; null then
		return;
	endif;
	
	self.allVehicleBookingTimeslots.addNoDuplicates(_vbsts, false);
	
end;</source>
        <access>protected</access>
        <Parameter name="_vbsts" type="CM_VehicleBookingTimeSlot"/>
    </JadeMethod>
    <JadeMethod name="doVvrAssocToVbtsStandard" id="61b9a821-f994-4677-8c89-8da03e743d52">
        <source>doVvrAssocToVbtsStandard( _vbsts : CM_VehicleBookingTimeSlot ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Oct 2014	cnwndl1	Initial creation	Par 35008
10 Sep 2021	navdap1	TFS 51248 SNO Truck Appointment and Pre-Notes
08 Aug 2024 navcs2	ChangeRequest 63928: EUP | Trailer Type in a VBS Slot
*/

vars

	proxy : CM_VehicleBookingTimeSlot;
	theReturn : Integer;
	loadState : Boolean;
	strArray : StringArray;
	deliveryIds, pickupIds : StringArray;				// TFS 51248

begin

	if _vbsts = null or _vbsts.myVehicleVisitRecord &lt;&gt; null then
		return;
	endif;
	
	if self.myRealVVR = null or self.myRealVVR.myVehicleBookingTimeslot &lt;&gt; null then
		return;
	endif;
	
	app.cmsBeginLoad(loadState);
	proxy := _vbsts.pxyCreateUpdateProxy().CM_VehicleBookingTimeSlot;
	app.cmsEndLoad(loadState);
	
	create strArray transient;
	create deliveryIds transient;									// TFS 51248
	create pickupIds transient;										// TFS 51248
	//_vbsts.getTiIdsFromBookedItemsOrVvr(strArray);				// TFS 51248
	_vbsts.getTiIdsFromBookedItemsOrVvr(deliveryIds, pickupIds);	// TFS 51248
	deliveryIds.copy(strArray);										// TFS 51248
	pickupIds.copy(strArray);										// TFS 51248
	
	proxy.setProxy(	_vbsts.bookingTSstart,	//_scheduleTSstart : TimeStamp;
					_vbsts.bookingTSend,	//_scheduleTSend : TimeStamp;
					_vbsts.myVehicleBookingTerminal,	//_myVBTerminal : CM_VehicleBookingTerminal;
					_vbsts.myCarrier,	//_myCarrier : CM_Carrier;
					null,				//_mySubCarrier : CM_Carrier;
					_vbsts.myDriver,	//_myDriver : CM_DriverDetails;
					_vbsts.myVehicle,	//_myVehicle : CM_Vehicle;
					_vbsts.remarks,	//_remarks : String;
					_vbsts.includesDelivery,	//_includesDelivery : Boolean;
					_vbsts.includesPickUp,	//_includesPickUp : Boolean;
					strArray,	//_bookedTiIds : StringArray;
					self.myRealVVR,	//_myVehicleVisitRecord : CM_VehicleVisitRecord
					_vbsts.myVBTimeSlotType,	//_myVBTimeslotType : CM_VehicleBookingTimeSlotType
					_vbsts.id,	//_id : String;
					_vbsts.allBookingRefs,	//_allBookingRefs : CM_BookingRefSet;
					_vbsts.allBulkReleases,	//_allBulkReleases : CM_BulkReleaseSet
					null,	//_allVBSTimeSlots : CM_VehicleBookingTSItemSet;
					_vbsts.preGateInCheck,	//_preGateInCheck : Boolean; //08Feb2023 navsp1 TFS 55580
					_vbsts.preGateOutCheck,	//_preGateOutChck : Boolean; //08Feb2023 navsp1 TFS 55580
					null,	//_kioskCheck : Boolean;
					null,	//_externalReference : String
					null	//_myTILCType : CM_TILCType	// 08 Aug 2024 navcs2	ChangeRequest 63928
					);
					
	while true do
		//app.myTrxUA.trxUpdateVehicleBooking(proxy, app.myPassport);					// TFS 51248
		app.myTrxUA.trxUpdateVehicleBooking(proxy, null, null, app.myPassport);			// TFS 51248
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Vehicle_schedul_booking_slot), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;

epilog

	delete strArray;
	delete deliveryIds;				// TFS 51248
	delete pickupIds;				// TFS 51248
	delete proxy;
	
	app.cmsEndLoad(loadState);

end;</source>
        <access>protected</access>
        <Parameter name="_vbsts" type="CM_VehicleBookingTimeSlot"/>
    </JadeMethod>
    <JadeMethod name="enableActionButtons" id="6c929f59-96f5-4078-b357-f5eb295a1efc">
        <updating/>
        <source>enableActionButtons(_enabled : Boolean) protected, updating;
// ---------------------------------------------------------------------------
// Created:     07 October 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 01/11/2019		jlgdap1			TFS 46854 SNO Driver Identity Checking for Cargo Release
// 25/02/2020		jlgdap1			TFS 48688 SNO Driver Identity Check for some variances in road gate process
// ---------------------------------------------------------------------------

vars
	enable : Boolean;
	entity : CMGTE_Entity;						// TFS 46854
	checkID, relFull, relAll : String;			// TFS 46854
	showDriverCheck : Boolean;					// TFS 46854
	ti : CM_TrackedItem;						// TFS 46854

begin
	enable := _enabled and app.myPassport.myUser.canDo(self.myTerminal, self.permissionMaint);
		
	self.btnInOther.enabled := enable;
	self.btnInFull.enabled := enable;
	self.btnInMT.enabled := enable;
	self.btnOutOther.enabled := enable;
	self.btnOutFull.enabled := enable;
	self.btnOutMT.enabled := enable;
	self.btnRelAction.enabled:=enable; //epr par 37297 8/1/16
	
	self.mnuUpdateItem.visible     := enable;
	self.mnuCopyItem.visible       := enable;
	self.mnuRemove.visible         := enable;
	self.mnuPrintLabel.visible     := enable;
	self.mnuPrintAllLabels.visible := false;	// 06 Aug 2010	NDL	Par 25335
	if self.mnuRemove.visible then
		self.mnuRemove.visible := app.myPassport.myUser.canDo(self.myTerminal, PmAdmFlexiGateRemove);
	endif;
	
	self.mnuUpdateVehicle.visible := enable;
	self.btnSave.enabled := enable;
	//self.btnClear.enabled := enable;
	// TFS 48688 code to check and enable driver id check button moved to a new method - see history for details
	self.releaseRequiresDriverIDCheck();			
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_enabled" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="enableFields" id="a5d152c5-b727-41fc-a6cf-f5cafbd0e122">
        <source>enableFields(_enabled : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     26 November 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 28/02/2011		cnwcs5			par 22778 
// 30/10/2019		jlgdap1			TFS 46854 SNO Driver Identity Checking for Cargo Release
// 26/02/2020		jlgdap1			TFS 48688 SNO Driver Identity check for some variances in road gate process
// 13/05/2022 		navhl20 		TFS 53430  EUP - Sub Carrier registration in MTN
// 13/06/2024		jlizm1			TFS 63908 Allow duplicate driver names
// ---------------------------------------------------------------------------

vars
	enable : Boolean;

begin 
	enable := _enabled;
	
	if not app.myPassport.myUser.canDo(self.myTerminal, self.permissionMaint) then
		enable := false;
		self.enableFieldsAfterQuery(false);
	endif;

	// Main
	self.txtDriverCode.enabled 	:= enable;
	self.txtDriverName.enabled	:= enable;				// TFS 48688
	self.lblDriverName.enabled 	:= enable;				// TFS 48688
	self.cmbDriver.enabled		:= enable;				// TFS 46854
	self.cmbDriverCode.enabled	:= enable;
	self.lblDriverCode.enabled 	:= enable;				// 28/02/2011 cnwcs5 par 22778
	self.txtRegno.enabled 		:= enable;
	self.cmbRegNo.enabled		:= enable;				// TFS 46854
	self.cmbCarrier.enabled 	:= enable;
	self.cmbSubCarrier.enabled  := enable;     			//13/05/2022 navhl20 TFS 53430
	self.cmbGateLanes.enabled 	:= enable;
	self.cmbGate.enabled 		:= enable;
	self.txtState.enabled 		:= enable;
	self.cmbInterchange.enabled := enable;				// cnwjk3 ccms 1071 18/02/10
	
	// TFS 46854 start
	if self.driverIDScanned or self.btnCheckID.visible then
		if self.myTerminal.getConfig(KnownTruckDriverRequired).Boolean then
			self.cmbDriver.enabled 	   := false;
		else
			self.txtDriverCode.enabled := false;
			self.cmbDriverCode.enabled := false;
			self.txtDriverName.enabled := false;		// TFS 48688
			self.lblDriverName.enabled := false;		// TFS 48688
		endif;
		self.lblDriverCode.enabled := false;
	endif;
	// TFS 46854 end

	//20/12/2010 cnwdz2 26614
	if enable then
		self.setTxtPinToNullOrVbsId();
	endif;
	
	// Receive Trailer
	self.txtChassisIDIn.enabled := enable;
	self.chkLockReceive.enabled := enable;		//10 Jan 2019	NDL	TFS 40479
	if self.chkLockReceive.value then			//10 Jan 2019	NDL	TFS 40479
		self.txtTareChassIN.enabled := false;
		self.cmbTrlrTypeIn.enabled  := false;
		self.cmbOperatorIn.enabled  := false;
		self.cmbTrailIMEX.enabled   := false;
	else
		self.txtTareChassIN.enabled := enable;
		self.cmbTrlrTypeIn.enabled  := enable;
		self.cmbOperatorIn.enabled  := enable;
		self.cmbTrailIMEX.enabled   := enable;
	endif;
	
	// Release Trailer
	self.cmbTrlTypeOut.enabled   := enable;
	self.cmbOperatorOut.enabled  := enable;
	self.txtChassisIDOut.enabled := enable;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_enabled" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="enableFieldsAfterClear" id="bde6fa59-eeb1-4a34-9d32-b8a291fe3b18">
        <updating/>
        <source>enableFieldsAfterClear() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 September 2009	cnwas3	Initial creation

*/


begin

	self.enableFieldsAfterQuery(true);

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="enableFieldsAfterQuery" id="ddda9eff-1011-4e4b-b538-6a6dd792d0ca">
        <source>enableFieldsAfterQuery(_enabled : Boolean) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 September 2009	cnwas3	Initial creation

*/
vars
	control : Control;
	idx : Integer;
	enable : Boolean;
	
begin
	enable := _enabled and app.myPassport.myUser.canDo(self.myTerminal, self.permissionMaint);

	foreach idx in 1 to self.controlCount do
		control := self.controls(idx);
		if control.isKindOf(CMUI_Label) or 
		   control.isKindOf(CMUI_TextBox) or
		   control.isKindOf(CMUI_ComboBox) or
		   control.isKindOf(CMUI_CheckBox) then
		   
			control.enabled 					:= enable;	
			
		endif;		
	endforeach;
	
	
//	self.txtVisitNumber.enabled := true;
	self.txtVisitNumber.enabled := app.myCurrentUserCan(self.myTerminal, PmAdmEnterVVR);	//01 Oct 2020	NDL	TFS 49189
	self.cmbPrinter.enabled := app.myCurrentUserCan(self.myTerminal, PmGteCanPrintFlexiGate);
	
end;</source>
        <access>protected</access>
        <Parameter name="_enabled" type="Boolean"/>
    </JadeMethod>
