    <JadeMethod name="tblDisplayRow" id="3568551f-b591-4aec-814b-eb6ca8ac8eae">
        <source>tblDisplayRow();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 MAY 2023 navtnr20	TFS CR 57989 Task 57990: EUP - INCO Terms Maintenance

*/

vars
	tbl					: CM_DataTable;
	invLineDesc			: CM_InvoiceLineDesc;
	idx					: Integer;
	str 				: String;
	//invLineDesc: 			CM_InvoiceLineDesc;
	mapping : CM_InvoiceINCOMapping;
	invalid	: Boolean;
begin

	tbl := self.tblData;
	tbl.rows := tbl.fixedRows;
	
	if self.myINCOTerm = null then
		return;
	endif;
	
	foreach mapping in self.myINCOTerm.allINCOTermMappings do
		on Exception do app.handleDeletedObject( exception, mapping, invalid );
		
		if invalid then
			tbl.removeDeletedObject(mapping);
			return;
		endif;
		
		str := mapping.getAttributeStringForDefArray(tbl.allTblDataEntRows);
		idx := tbl.addItem(str);
		tbl.accessRow(idx).itemObject := mapping;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="a7360e42-1512-4e70-bca1-a8520ddaa606">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 19 May 2023 18:07:47.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026024, locale);
	btnAdd.translateCaption(Xlat_0026025, locale);
	btnAudits.translateCaption(Xlat_0026026, locale);
	btnClose.translateCaption(Xlat_0026027, locale);
	btnRemove.translateCaption(Xlat_0026028, locale);
	btnSave.translateCaption(Xlat_0026029, locale);
	btnUpdate.translateCaption(Xlat_0026030, locale);
	lblCode.translateCaption(Xlat_0026031, locale);
	lblDescription.translateCaption(Xlat_0026032, locale);
	mappings.translateCaption(Xlat_0026033, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="updatINCOTerm" id="774114ed-2a3c-4609-a22d-f0e98a1bf454">
        <updating/>
        <source>updatINCOTerm()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 MAY 2023 navtnr20	TFS CR 57989 Task 57990: EUP - INCO Terms Maintenance

*/

vars
	pxyINCOTerm,
	realINCOTerm:CM_InvoiceINCOTerm;
	code,desc : String;
	theReturn : Integer;
begin
	pxyINCOTerm := app.createUpdateProxy(self.myINCOTerm).CM_InvoiceINCOTerm;
	if self.txtCode &lt;&gt; null then
		code := self.txtCode.text.String;
	endif;
	if self.txtDescription &lt;&gt; null then
		desc := self.txtDescription.text.String;
	endif;	
	pxyINCOTerm.setProxy(code,desc,self.myCurrentBank);
	while true do
		app.myTrxUA.trxUpdateInvINCOTerms(pxyINCOTerm, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			app.msgBox(app.getErrorString(Inco_terms_update_success), app.getErrorString(Message),MsgBox_OK_Only);
			//self.unloadForm();
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Inco_term_updated), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		break;
	endwhile;
epilog
	delete pxyINCOTerm;
end;</source>
    </JadeMethod>
