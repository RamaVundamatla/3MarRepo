// Created:		19 February 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	combo : CMUI_ComboBox;
	endItm, lstIdx : Integer;
begin
	combo := _combo;
	endItm := combo.listCount();
	
	foreach lstIdx in 1 to endItm do
