			form.menuMappingSetActive.checked := false;
			form.menuSItemDelete.visible := allowUpdates; 
			form.menuSItemDelete.enabled := allowUpdates;
			form.btnDelete.enabled := allowUpdates; 
		endif;
		
	endif;
end;</source>
