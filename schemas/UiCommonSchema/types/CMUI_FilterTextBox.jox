<GUIClass name="CMUI_FilterTextBox" id="10f66c83-017a-4c69-ba66-92aab8dbcb9e">
    <superclass name="CMUI_TextBox"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <Constant name="TimerConstant" id="94a5683a-6eca-41fe-8038-4b61adbd393d">
        <source>23121963</source>
        <type name="Integer"/>
    </Constant>
    <ImplicitInverseRef name="parentGroupBox" id="5d968642-93ef-42a8-9f04-5f771fa2cf35">
        <embedded/>
        <type name="CMUI_MultiSelectFilterGroupBox"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="keyDown" id="1e59f765-fe31-4351-8656-bbd2ea0d6efe">
        <controlMethod name="TextBox::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>keyDown(textbox: TextBox input; keyCode: Integer io; shift: Integer) updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/03/2023	navcs2	ChangeRequest 57299:[57300]: EUP - Create new filter multi-select group box control

*/

vars
	type,
	remaining		: Integer;
begin
	self.foreColor := Black;
	
	if self.getTimerStatus(self.TimerConstant, type, remaining) then
		self.endTimer(self.TimerConstant);  
	endif;
			
	self.beginTimer(100, Timer_OneShot, self.TimerConstant);
	inheritMethod(textbox, keyCode, shift);

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setGroupBoxParent" id="c3e9dcd9-c202-4cee-a51c-39ac0aab65a1">
        <updating/>
        <source>setGroupBoxParent(_groupBox: CMUI_MultiSelectFilterGroupBox) updating;
/*

Purpose:			

Parameters:			

Return Value:

Date		Who		Reason
24/03/2023	navcs2	ChangeRequest 57299:[57300]: EUP - Create new filter multi-select group box control

*/

vars

begin
	self.parentGroupBox := _groupBox;
epilog

end;</source>
        <Parameter name="_groupBox" type="CMUI_MultiSelectFilterGroupBox"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="9d4ef012-e667-4d60-8794-5e6b4418e4d7">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24/03/2023	navcs2	ChangeRequest 57299:[57300]: EUP - Create new filter multi-select group box control
09 Jul 2024	navnk30	ChangeRequest 64536: MTN - Adding Filter to column organizer screen - Selected Columns. Task 64537.
*/

vars

begin
	//self.parentGroupBox.filterAvailable();			//09.07.2024 navnk30 #64536 Task 64537
	self.parentGroupBox.handleFilterTextChange(self);	//09.07.2024 navnk30 #64536 Task 64537
epilog

end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
