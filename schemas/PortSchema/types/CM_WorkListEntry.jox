        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="unQueueDirectorWithTI" id="b50b09df-6a3c-4d0f-95a4-52c08cc49e57">
        <updating/>
        <source>unQueueDirectorWithTI(_passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 November 2011	cnwrd1	Initial creation
09 Feb 2012	cnwkpd1	PAR #28731 - fix transient leaks

*/

vars
	term		: CM_Terminal;
	iter		: Iterator;
	task,
	directorTask		: CM_RTQueueTask;
	taskArray			: CM_RTQueueTaskArray;
	entry				: CM_RTQueueEntry;	
	currentTaskStatus 	: Integer;
	currentMyMachine	: CM_Machine;
	theTI : CM_TrackedItem;
begin
	
	theTI := self.myTrackedItem;
	term := self.getMyTerminal();
		
	foreach entry in self.allRTQueueEntries do 
		//-------------
		//Call the delete method on each task, this undoes the queued moves etc
		//-------------

		if term &lt;&gt; null then
			entry.causeEvent(term.getTerminalEvent(RTQueueEntry_Update_Event), false, false);	
		endif;
		
		create taskArray transient;
		entry.allTasks.copy(taskArray);
		iter := taskArray.createIterator();
		while iter.next(task) do
			if (not task.taskType = TASK_DIRECTOR ) then
				if task.taskType = TASK_PICKUP or task.taskType = TASK_MOVE then
					currentTaskStatus	:= task.status; 				
					currentMyMachine := task.myMachine;				
				endif;
				task.setStatusDirectorUndo(TASK_UNACTIONED);
				task.deleteTask();
			else
				directorTask := task;
			endif;
		endwhile;

		if directorTask &lt;&gt; null then
			directorTask.setStatusDirectorUndo(currentTaskStatus);	//set back to what it was...
			directorTask.setMachine(currentMyMachine);
		endif;
		delete iter;
		delete taskArray;
		
		theTI.removeFromQueue(entry );
	endforeach;
	if _passport &lt;&gt; null then
		//can be null as no need to cause update event when erasing self as the delete event will be sent
		app.myEventManager.createSingleObjInfoNoteEvt(self, _passport.myTerminal.getTerminalEvent(WLE_Update_Event), self);
	endif;
	
	self.unassignTI();
	
epilog
	delete iter;
	delete taskArray;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="unQueueWLE" id="d70f4352-8253-4a52-a426-d99633c607a9">
        <updating/>
        <source>unQueueWLE(_passport : CM_Passport input) updating;
//Removes this WLE from the RT Queue
// 06/12/2010	cnwdap1		PAR #26426 If this WLE has  TBA TI, raise a note so the Ship Load List screen knows about it
//								even if we have no RT queue job, and delete the TBA TI if it's part of a Voyage WLE
// 22/12/2010	cnwdap1		PAR #26636 deletion of TBA TI is now done in wle.setMyTrackedItem (which is called from usassignTI)
// 30/08/2012	cnwcs5		par 30292 - use updateObjectEdition instead of updateEdition 
// 04/03/2025	navdap1		MTN-34024 PRP | Deadlock 1081, Yard Allocation &amp; Release Request Performance
vars
	tmpJob 	: CM_YardInternalJob;
	//tbaTI	: CM_TrackedItem;		// PAR #26426	// PAR #26636
	terminal: CM_Terminal;			// PAR #26426
begin
	if self.allRTQueueEntries.isEmpty then
		// PAR #26426 send note if we're part of a release request and we want to see release requests on load lists
		terminal := self.getMyTerminal();
		if terminal = null and _passport &lt;&gt; null then
			terminal := _passport.myTerminal;
		endif;
		if terminal &lt;&gt; null and (terminal.getConfig(ShowRelReqOnShipLoadList).Boolean or terminal.getConfig(ShowRelReqOnRailLoadList).Boolean) then
			if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.isTBAorIsRRP then
				if CM_VoyageWLE.hasInstance(self) then
					//tbaTI := self.myTrackedItem;	// PAR #26636
					self.unassignTI;
					//tbaTI.erase(NORMAL_ERASE);	// PAR #26636
				endif;
				if _passport &lt;&gt; null then
					app.myEventManager.createSingleObjInfoNoteEvt(self, _passport.myTerminal.getTerminalEvent(WLE_Update_Event), self);
				endif;
			endif;
		endif;
		// PAR #26426 end
		return;	//Nothing to do..
	endif;
	
	self.exclusiveLock(self);						// MTN-34024
	self.exclusiveLock(self.allRTQueueEntries);		// MTN-34024
	
	while self.allRTQueueEntries.isEmpty = false do
		self.allRTQueueEntries.last.deleteEntry( false, null);
	endwhile;
	
	if _passport &lt;&gt; null then
		//can be null as no need to cause update event when erasing self as the delete event will be sent
		app.myEventManager.createSingleObjInfoNoteEvt(self, _passport.myTerminal.getTerminalEvent(WLE_Update_Event), self);
	endif;

	//This will cause updated event for YRD_RequestInternalMoveForm
	if CM_YardInternalJob.hasInstance(self.job) then
		tmpJob := self.job.CM_YardInternalJob;
		if tmpJob.type = Depot_Request 
		or tmpJob.type = Controller_Strip then
			self.updateObjectEdition(tmpJob);	// par 30292
		endif;
	endif;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="unassignTI" id="a9ce3d8a-7a4a-44f5-8cdd-684b7f123f79">
        <updating/>
        <source>unassignTI()updating;
// ---------------------------------------------------------------------------
// Created:		22 July 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
vars
	theTI : CM_TrackedItem;
	job: CM_Job;
begin
	theTI := self.myTrackedItem;
	if self.myRequest &lt;&gt; null then
		self.myRequest.removeBulkReleaseTI(theTI);
	endif;
	
	self.setMyTrackedItem(null);
	self.myBOL := null;
	
	
	job := self.job;
	if  self.myRequest &lt;&gt; null and self.myRequest.isKindOf(CM_ROROGCRequest) then
		/*
			//the request is created with wles.size = request.quantity for RORO GC when a ti is assigned with quantity  &gt; 1 need to 
			//delete some of the unassigned wles 
			// This method can also end up deleting self :-(
		*/
		//The above is no longer true. 
		//If a TI is assigned with quantity &gt; 1, only one WLE is created with a matching quantity
		// tfs42863 jlgzm1 11/07/2019
		if theTI &lt;&gt; null and theTI.canSplitTotalQuantity then
			//need to merge any unassigned wles back together
			self.myRequest.CM_ROROGCRequest.cleanupWLEs();
		else
			self.setQuantity(1);
			self.myRequest.createWLEs();
		endif;
	endif;
	if job &lt;&gt; null then
		job.updateTICollectionsUnassign(theTI);
	endif;

end;</source>
    </JadeMethod>
