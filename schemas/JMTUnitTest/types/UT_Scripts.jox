    <JadeMethod name="uExportTrackedItemsToCsv" id="952a2f5f-fb82-4121-aabb-1f8ceaec8262">
        <source>uExportTrackedItemsToCsv();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2015	cnwdw1	Initial creation
*/
vars
	terminalCode: String;
	terminal: CM_Terminal;
	csvFile: File;
	oa : ObjectArray;
	obj : Object;
	iter : Iterator;
	ti : CM_TrackedItem;
begin
	terminalCode := "Enter Terminal Code";
	read terminalCode;
	terminal := self.getRoot.allTerminals[terminalCode];
	
	create oa transient;
	
	create csvFile transient;
	csvFile.openOutput("C:\temp\DMASTTIS.CSV");
	csvFile.writeLine("Id,Type,Operator,ISO,Commodity,IMEX,Terminal,Location,QuanityCreated");
	
	CM_TrackedItem.allInstances(oa, 0, true);
	iter := oa.createIterator;
	while iter.next(ti) do
		if terminal &lt;&gt; null and ti.myTerminal &lt;&gt; terminal then
			continue;
		endif;
		csvFile.writeLine(
			ti.id &amp; "," &amp;
			ti.myCargoType.abbreviation &amp; "," &amp;
			ti.myOperator.code &amp; "," &amp;
			ti.isoTypeDesc &amp; "," &amp;
			ti.commodity &amp; "," &amp;
			ti.getImExStatusString() &amp; "," &amp;
			ti.myTerminal.code &amp; "," &amp;
			ti.locationId &amp; "," &amp;
			ti.createdTime.asStringJMT);
	endwhile;
	csvFile.close();

	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="uExtractVoyageWLEs" id="af8a1e82-b25b-4bc0-b734-501ba0547f3a">
        <source>uExtractVoyageWLEs();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 July 2011	cnwdw1	Initial creation
*/
vars
	voyageId: String;
	voyage: CM_Voyage;
	wle: CM_WorkListEntry;
	vwle: CM_VoyageWLE;
	jobSheet: CM_VoyageJobSheet;
	wles: CM_WLEByCompletedDate;
	xml: String;
	mode: String;
	type: String;
	craneStart: TimeStamp;
	terminal: CM_Terminal;
	
begin
	voyageId := "Enter Voyage Name (or prefix)";
	
	read voyageId;
	terminal := CM_Root.firstInstance.allTerminals[self.getProfileSetting(UT_Profile.P_TERMINAL).asString];
	
	voyage	:= terminal.allVoyagesByCode.getAtKeyGeq(voyageId, null);
	if voyage = null or voyage.code &lt;&gt; voyageId  then
		voyage	:= terminal.allVoyagesArchived.getAtKeyGeq(voyageId, null);
		if voyage = null or voyage.code &lt;&gt; voyageId then
			return;
		endif;
	endif;
	
	xml := '&lt;Voyage Name="' &amp; voyageId &amp; '" Vessel="' &amp; voyage.vesselName &amp; '"&gt;';
	
	foreach jobSheet in voyage.allJobSheets do
		xml := xml &amp; '&lt;Crane Name="' &amp; jobSheet.crane &amp; '"&gt;';
		craneStart := jobSheet.workStarted;
		foreach wle in jobSheet.allCompletedWLEsByDate do
			vwle := wle.CM_VoyageWLE;
			if vwle.isReceipt then
				mode := "Discharge";
			else
				mode := "Load";
			endif;
			
			if vwle.myTrackedItem = null then
				continue;
			endif;
			if vwle.myTrackedItem.isContainer then
				type := vwle.myTrackedItem.CM_Container.getISOType;
			else
				type := vwle.myTrackedItem.myCargoType.abbreviation;
			endif;
			xml := xml &amp; '&lt;WLE Cargo="' &amp; vwle.myTrackedItem.id &amp; '"' &amp;
			                ' Mode="' &amp; mode &amp; '"' &amp;
							' Start="' &amp; craneStart.formatAsYYYYMMDDHHmmSS() &amp; '"' &amp;
							' Finish="' &amp; vwle.completedDate.formatAsYYYYMMDDHHmmSS() &amp; '"' &amp;
							' Source="' &amp; vwle.locationSource &amp; '"' &amp;
							' Target="' &amp; vwle.locationTarget &amp; '"' &amp;
							' TEU="' &amp; vwle.myTrackedItem.getNumTEU().String &amp; '"' &amp;
							' Type="' &amp; type &amp; '"' &amp;
							'/&gt;';
			craneStart := vwle.completedDate;
		endforeach;
		xml := xml &amp; '&lt;/Crane&gt;';
	endforeach;
	xml := xml &amp; "&lt;/Voyage&gt;";
	
	writeToFile(xml, "VoyageWLEs.xml");
	
epilog
	delete wles;
end;</source>
    </JadeMethod>
    <JadeMethod name="uFillROROWithCargo" id="52d6c68b-c99c-4c29-916e-74624dd61a16">
        <source>uFillROROWithCargo();
/*
Purpose:			
Date		Who		Reason
18 July 2012	NAVAB1	Initial creation
*/

vars
	voyageDeck : CM_DeckVoyage;
	voyageCode, deckCode : String;
	voyage : CM_Voyage;
begin
	voyageCode := "BLKPIG01";
	read voyageCode;
	
	voyage := self.getTerminal().allVoyagesByCode.getAtKeyGeq(voyageCode, null);
	if voyage = null then
		app.msgBox("Invalid voyage code","ERROR", MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	// CONTAINERS
	deckCode := "4";
	read deckCode;
	voyageDeck:= voyage.myROROStructure.allDecksByCode[deckCode];
	if voyageDeck = null then
		app.msgBox("Invalid deck code","ERROR", MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	self.addROROVoyageContainers(voyageDeck,true, 0);
	
	// GC
	deckCode := "3";
	read deckCode;
	voyageDeck:= voyage.myROROStructure.allDecksByCode[deckCode];
	if voyageDeck = null then
		app.msgBox("Invalid deck code","ERROR", MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	self.addROROVoyageGC(voyageDeck);

epilog

end;</source>
    </JadeMethod>
