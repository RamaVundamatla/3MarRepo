    <JadeMethod name="prepareAuditDetail" id="e9b70dad-4515-483d-abe2-d348f860cd14">
        <source>prepareAuditDetail(_str : String io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 April 2023	navhl20	ChangeRequest 57301:[57303] EUP - [Framework] - Improve Audits on Work orders
21/04/2023	navcs2	Bug 57691: MTN - WO - Audits are missing for the totalActioned
*/

vars
	tmpStr	 	: String;
	wagon		: CM_Wagon;
begin
	inheritMethod(_str);
	tmpStr := null;
	if self.allWagons.isNotEmpty then
		foreach wagon in self.allWagons do
			if tmpStr = null then
				tmpStr := tmpStr &amp; wagon.id;
			else
				tmpStr :=tmpStr &amp; Comma &amp; wagon.id;
			endif;
		endforeach;
		_str := _str &amp; app.getErrorString(Wagons) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	// 21/04/2023	navcs2	Bug 57691 Start
	tmpStr := null;
	if self.allWagonsActioned.isNotEmpty then
		tmpStr := self.allWagonsActioned.size.String;
		_str := _str &amp; "Number Actioned" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	else
		tmpStr := 0.String;
		_str := _str &amp; "Number Actioned" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	// 21/04/2023	navcs2	Bug 57691 End
epilog

end;</source>
        <Parameter name="_str" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="b09f5e41-0e25-49d0-991a-ed909df7615a">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
19 December 2022	navcs2	ChangeRequest 56833:[56834] EUP - VAS Train Work Order

*/

vars
	pxy 			: SelfType;
	completedOK		: Boolean;
begin
	pxy := inheritMethod();
	
	self.allWagons.copy(pxy.allWagons);
	self.allWagonsActioned.copy(pxy.allWagonsActioned);
	self.allWagonsCompleted.copy(pxy.allWagonsCompleted);
	
	completedOK := true;
	return pxy;
epilog
	
	if not completedOK then			
		delete pxy;
	endif;
end;
</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="f949d058-0aa4-4162-ae98-471ca60d62b2">
        <updating/>
        <source>setForUpdate(_pxyWoDDtl: CM_WodToDoWagon) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 December 2022	navcs2	Initial creation
20 Mar 2023  		navhl20 Defect 57233: MTN - Editing Vas Tasks is not working correctly
// ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1
*/

vars

begin
	inheritMethod(_pxyWoDDtl);
	self.allWagons.clear();																//20.3.2023 navhl20	#57233
	_pxyWoDDtl.allWagons.copyNoDuplicates(self.allWagons, false);
epilog

end;</source>
        <Parameter name="_pxyWoDDtl" type="CM_WodToDoWagon"/>
    </JadeMethod>
