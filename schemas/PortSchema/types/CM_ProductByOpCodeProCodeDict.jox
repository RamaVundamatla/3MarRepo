<CollClass name="CM_ProductByOpCodeProCodeDict" id="20723168-569e-4d3d-a7a3-48d7409b345d">
    <memberType name="CM_Product"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="terminal"/>
    <MemberKey>
        <keyPath>
            <ExplicitInverseRef name="CM_Product::myOperator"/>
        </keyPath>
        <property name="CM_Operator::code"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_Product::code"/>
    </MemberKey>
    <JadeMethod name="findProductByCode" id="0f630189-78cb-4ad8-9050-c31c767d4f35">
        <source>findProductByCode(_code : String) : CM_Product;

/*

Purpose:			Find the first CM_Product in the receiver dictionary with a code
					matching the passed in value, for any Operator

Parameters:			Product code to find

Return Value:		First matching CM_Product, or null if there are none


Date		Who		Reason
09 Jul 2008	cnwkpd1	PAR #17254 - Speed up EDI Product load
11/07/2025	naviv1	MTN-35226 : MTN - Usage of Iterator.getCurrentKeys  
*/

constants
	HighValues		= #FF.Character.String;
	
vars
	product			: CM_Product;
	operatorKey,
	productKey		: String;
	iter			: Iterator;
	
begin
	iter := self.createIterator();
	self.startKeyGeq(null, _code, iter);
	
	while iter.next(product) do
		iter.getCurrentKeys(operatorKey,productKey);  //MTN-35226
		
		// We have a match, so return it
		if productKey = _code then
			return product;
		endif;
		
		// If the product key is less than what we're looking for, then skip forward for the
		// current operator
		if productKey &lt; _code then
			self.startKeyGeq(operatorKey, _code, iter);
			continue;
		endif;
		
		// Otherwise, need to jump to the end of the current operator
		self.startKeyGeq(operatorKey, HighValues, iter);
	endwhile;
	
	// Got to here, then no match
	return null;
	
	
epilog
	delete iter;
	
end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="CM_Product"/>
    </JadeMethod>
</CollClass>
