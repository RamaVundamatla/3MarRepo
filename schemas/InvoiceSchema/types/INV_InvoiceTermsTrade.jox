    <JadeMethod name="doDelete" id="65a604e4-37fa-4146-950b-6ad32a81af68">
        <updating/>
        <source>doDelete(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theReturn : Integer;
begin
 
	while true do
 	app.myTrxDA.trxDeleteInvTermsOfTrade(self.myCurrentObject.CM_InvoiceTermsOfTrade, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			return true;
		else
			theReturn := app.showErrorWarningDialog("Invoice Terms Of Trade", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		break;
	endwhile;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
