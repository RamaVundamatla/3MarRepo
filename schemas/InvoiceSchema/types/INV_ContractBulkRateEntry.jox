    <JadeMethod name="doPermissions" id="6def2b06-0a23-49cf-ae95-98e57f9dc714">
        <source>doPermissions();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 March 2023  navmv20 TFS 55651 Task 57072: UI - Contract Bulk Edit UI

*/

vars

begin
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mskNewFromDate.enabled := false;
		self.mskNewFromTime.enabled := false;
		self.mskNewToDate.enabled := false;
		self.mskNewToTime.enabled := false;
		self.txtNewRate.enabled := false;
		self.btnSave.enabled := false;
		self.btnClose.enabled := false;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doTblBulkContMenu" id="b6a5c78a-bbbe-4e46-acfe-d3a151aaf9c4">
        <updating/>
        <source>doTblBulkContMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 March 2023  navmv20 TFS 55651 Task 57072: UI - Contract Bulk Edit UI

*/

vars
	canEdit		: Boolean;
	x1,
	y1			: Real;
begin
	x1 := x;
	y1 := y;
	if (not mouse) then
	    x1 := 1;
	    y1 := 1;
	endif;
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);
	self.mnuColumnOrganiser.visible := true;
	self.mnuColumnOrganiser.userObject := self.tblData;	 
	if app.isAllowedToInspect then 
		self.mnuInspectObject.visible := true;
	else
		self.mnuInspectObject.visible := false;	
	endif;
	self.popupMenu(self.mnuContextMenu, x1.Integer, y1.Integer);
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUpdateRateEntries" id="4e16fea6-9b8a-465d-8457-c42b59120a7f">
        <updating/>
        <source>doUpdateRateEntries()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 March 2023  navmv20 TFS 55651 Task 57072: UI - Contract Bulk Edit UI

*/

vars
	proxyRateEntry,
	entry,
	pxyObj					: CM_InvoiceContractRateEntry;
	theReturn			    : Integer;
	bulkRates 				: CMIF_InvoiceContractBulkRates;
	fromTS			 		: TimeStamp;
	toTS					: TimeStamp;
	cpu						: Decimal[23,6];
	
	newFromTS,
	newToTS					: TimeStamp;
	newCpu                  : Decimal[23,6];
	
	selectedRateEntries     : ObjectSet;
	rowSt,
	rowEnd,
	index					: Integer;
	
begin
	fromTS.setDate(self.mskNewFromDate.text.asDateJMT());
	fromTS.setTime(self.mskNewFromTime.text.asTimeJMT());
	toTS.setDate(self.mskNewToDate.text.asDateJMT());
	toTS.setTime(self.mskNewToTime.text.asTimeJMT());
	cpu := self.txtNewRate.text.Decimal;
	
	create bulkRates transient;
	
	rowSt := tblData.fixedRows + 1;
	rowEnd := tblData.rows;
	create selectedRateEntries transient;
	foreach index in rowSt to rowEnd do
		if tblData.accessRow(index).selected then
			entry := tblData.accessRow(index).itemObject.CM_InvoiceContractRateEntry;
			pxyObj := app.createUpdateProxy(entry).CM_InvoiceContractRateEntry;
			selectedRateEntries.add(pxyObj);
		endif;
	endforeach;
	
	if selectedRateEntries.isEmpty then
		app.msgBox(app.getErrorString(Record_selected), app.getErrorString(Warning),MsgBox_OK_Only);
		return;
	endif;
	
	foreach proxyRateEntry in selectedRateEntries as CM_InvoiceContractRateEntry do
		if fromTS &lt;&gt; null then
			newFromTS := fromTS;
		else
			newFromTS := proxyRateEntry.fromTS;
		endif;
		
		if toTS &lt;&gt; null then
			newToTS := toTS;
		else
			newToTS := proxyRateEntry.toTS;
		endif;
		
		if cpu &lt;&gt; null then
			newCpu := cpu;
		else
			newCpu := proxyRateEntry.costPerUnit;
		endif;
		proxyRateEntry.setProxy(proxyRateEntry.id,newCpu,proxyRateEntry.fromAmount,proxyRateEntry.toAmount,newFromTS,newToTS, proxyRateEntry.myInvoiceContractRate,
		proxyRateEntry.myBusinessUnit);
	endforeach;
	
	selectedRateEntries.copy(bulkRates.allPxyRateEntries);
	bulkRates.createProxyRateEntriesForDates();
	
	while true do
		app.myTrxUA.trxUpdateCntrctDtlRtEntries(bulkRates, app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			self.tblDisplayRow();
			app.msgBox(app.getErrorString(Invoice_contrac_update_sucess), app.getErrorString(Message),MsgBox_OK_Only);
			
			delete selectedRateEntries;
			delete bulkRates;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Invoice_contract_update), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);
		endif;
		break;
	endwhile;
	
epilog
	self.mousePointer := Window.MousePointer_Default;
	delete bulkRates;
	delete selectedRateEntries;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="65441fcd-d0cd-4253-8674-fd061ba4e2ac">
