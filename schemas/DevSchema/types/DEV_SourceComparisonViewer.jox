        <updating/>
        <source>tblDiffMethods_dblClick(table: Table input) updating;
/*
Purpose:	

Date		Who		Reason
23 October 2025	navab1	JIRA 36455
*/

vars

begin
	if table.row = table.fixedRows then
		table.CM_DataTable.resortTableByColumn(table.column);
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="645cd3da-d5b6-456c-8e5f-7afb72926903">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 July 2022	navpw1	Initial creation

*/

vars

begin
	if eventTag = self.Timer_Filter then 
		self.doFilter();
		return;
	endif;
	
epilog

end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="toggleForm" id="66ab0c32-fa5b-4286-b380-1d255d6ca8f7">
        <source>toggleForm(_enabled : Boolean) protected;
/*

Purpose:			Toggles the form controls (Used if the form is busy)

Parameters:			_enabled:	Boolean		Whether we are enabling or disabling our controls

Return Value:		

Date		Who		Reason
04 November 2021	navpw1	Initial creation TFS: 52202

*/

begin
	//Set whether our controls are enabled or not
	self.jeLoaded.enabled 				:= _enabled;
	self.jeCurrent.enabled 				:= _enabled;
	self.qlbMissingMethods.enabled 		:= _enabled;
	self.qlbGlobalConstants.enabled 	:= _enabled;
	self.qlbDifferentMethods.enabled 	:= _enabled;
	self.qlbClassData.enabled 			:= _enabled;
	
	//Refresh our controls
	self.jeLoaded.refreshNow();
	self.jeCurrent.refreshNow();
	self.qlbMissingMethods.refreshNow();
	self.qlbGlobalConstants.refreshNow();
	self.qlbDifferentMethods.refreshNow();
	self.qlbClassData.refreshNow();

end;</source>
        <access>protected</access>
        <Parameter name="_enabled" type="Boolean"/>
    </JadeMethod>
