    <JadeMethod name="getDisplayStringForAttribute" id="dc9ac7f4-ab58-4879-9a85-2e8345f7f5fb">
        <source>getDisplayStringForAttribute( _attrName : String; _short : Boolean ) : String;

vars

begin
//	if _attrName = ETRow_ImportVoyage then		// cnwrl1 14/07/2010 PAR 23499 - what it was
//		return self.importVoyageCode;			// cnwrl1 14/07/2010 PAR 23499 - what it was
	if _attrName = ETRow_ImportVoyageCode then
		return self.getVoyageCode();
	else
		return inheritMethod(_attrName, _short);
	endif;
end;
</source>
