        <updating/>
        <source>mnuDockTopLeft2_click(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:     09 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	obj : Object;
begin
	if process.isJLGAB1()
	and app.isSpecial() then
		obj := self.lstTest.listObject;
		if obj &lt;&gt; null then
			obj.inspect;
		
		endif;
	else
	self.doDockTopLeft((not menuItem.checked));
	endif;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
