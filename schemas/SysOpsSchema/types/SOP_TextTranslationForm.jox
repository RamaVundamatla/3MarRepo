    <JadeMethod name="mnuContextClipboard_click" id="e16f7638-4e9e-46ae-9698-5cc355fc34a4">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuContextClipboard_click(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:     05 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	table	: Table;
	col		: Integer;
	tempStr	: String;
	
begin
	if self.fldData.topSheet = self.shtFormCaptions then
		table := self.tblFormCaptions;
		col := 6;
	elseif self.fldData.topSheet = self.shtMessages then
		table := self.tblMessages;
		col := 2;
	elseif self.fldData.topSheet = self.shtMenuEntities then
		table := self.tblMenuEntities;
		col := 2;
	elseif self.fldData.topSheet = self.shtPermissions then
		table := self.tblPermissions;
		col := 2;
	elseif self.fldData.topSheet = self.shtReportNames then
		table := self.tblReportNames;
		col := 2;
	elseif self.fldData.topSheet = self.shtTableEntitys then
		table := self.tblTableEnts;
		col := 2;
	endif;
	
	if table.row &gt; table.fixedRows and col &gt; 0 and col &lt; table.columns then
//		write table.accessCell(table.row, col).text;	// cnwrl1 11/11/2009 PAR 19951 - what it was
		tempStr	:= table.accessCell(table.row, col).text;
		write tempStr;
		app.copyStringToClipboard( tempStr );
	endif;
	
epilog
	
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
