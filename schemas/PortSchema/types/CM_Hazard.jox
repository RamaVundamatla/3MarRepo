    <JadeMethod name="exportAsXMLDocIgnoreAttr" id="a7e04db3-c68a-4a35-8bb8-5ddf226cb299">
        <source>exportAsXMLDocIgnoreAttr(_property: Property input): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

begin
	if _property = CM_Hazard::description then
