    <JadeMethod name="getOIDAndDescForAttribute" id="6aa19511-266f-41b9-8737-625701496681">
        <source>getOIDAndDescForAttribute(_attrName : String; _getCalculatedDate : Boolean; _oid : String output): String;
// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.	
vars
	runDate			: Date;
begin
	runDate := self.systemToLocalTime(app.actualTimeServer()).Date;	// 28/4/16 cnwmp6 TFS 488 - Multi timezone support
	
	if _attrName = ETRow_Carrier or
	   _attrName = ETRow_CarrierCode then
		return self.carrierCode;
	
	elseif _attrName = ETRow_GangNumber then
		return self.gangNumber;
		
	elseif _attrName = ETRow_Hatch then
		if self.logHatch &lt;&gt; null then
			return self.logHatch.String;
		else
			return Any_String;
		endif;
	
	elseif _attrName = ETRow_LoggingOrganisation then
		return self.loggingOrganisation;
	
	//elseif _attrName = ETRow_LogLot then
	elseif _attrName = ETRow_LogLot or  _attrName = ETRow_Lot then	//11 Dec 2012	NDL Par 30696
		if self.getMyLogLot &lt;&gt; null then
			return self.getMyLogLot.String;
		else
			return Any_String;
		endif;
	
	elseif _attrName = ETRow_MyLogSpecies or
		_attrName = ETRow_LogSpecies then
		if self.getMyLogSpecies &lt;&gt; null then
			_oid := self.getMyLogSpecies.getOidAsString(); //20/07/2010 cnwdz2 24513
			return self.getMyLogSpecies.code;
		endif;
		return Any_String;
		
	elseif _attrName = ETRow_MyLogGrade or
		_attrName = ETRow_LogGrade then
		if self.getMyLogGrade &lt;&gt; null then
			_oid := self.getMyLogGrade.getOidAsString(); //20/07/2010 cnwdz2 24513
			return self.getMyLogGrade.code;
		endif;
		return Any_String;
		
	elseif _attrName = ETRow_MyLogType or
		_attrName = ETRow_LogType then
		if self.getMyLogType &lt;&gt; null then
			_oid := self.getMyLogType.getOidAsString(); //20/07/2010 cnwdz2 24513
			return self.getMyLogType.code;
		endif;
		return Any_String;

	elseif _attrName = ETRow_MyLogTreatment or
		_attrName = ETRow_LogTreatment then
		if self.getMyLogTreatment &lt;&gt; null then
			_oid := self.getMyLogTreatment.getOidAsString(); //20/07/2010 cnwdz2 24513
			return self.getMyLogTreatment.code;
		endif;
		return Any_String;

	elseif _attrName = ETRow_MyLogLength or
		_attrName = ETRow_LogLength then
		if self.getMyLogLength &lt;&gt; null then
			_oid := self.getMyLogLength.getOidAsString(); //20/07/2010 cnwdz2 24513
			return self.getMyLogLength.code;
		endif;
		return Any_String;

	elseif _attrName = ETRow_MatchDateStart then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.matchStartDateTplType, self.matchStartDateTplFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.matchStartDateTplType, self.matchStartDateTplFactor);
		endif;
		
	elseif _attrName = ETRow_MatchDateEnd then
		if _getCalculatedDate then
			return self.setDateFromTemplate(self.matchEndDateTplType, self.matchEndDateTplFactor, runDate).shortFormatJMT();
		else
			return self.getTemplateDateStr(self.matchEndDateTplType, self.matchEndDateTplFactor);
		endif;
		
	
	elseif _attrName = ETRow_MatchTimeStart then
		//return self.matchStartDate.time.String;
		return self.matchStartDate.time.asStringJMT();  //par 18944 cnwjo3

	elseif _attrName = ETRow_MatchTimeEnd then
		//return self.matchEndDate.time.String;
		return self.matchEndDate.time.asStringJMT();  //par 18944 cnwjo3
	
	elseif _attrName = ETRow_Place then
		return app.vesselPlaceEnumToStr(self.logPlace);		
	
	elseif _attrName = ETRow_SrcLocation then
		if self.sourceLocation &lt;&gt; null then
			return self.sourceLocation;
		else
			return Any_String;
		endif;
		
	elseif _attrName = ETRow_SrcSubLocation then
		if sourceSubLocation &lt;&gt; null then
			return self.sourceSubLocation;
		else
			return Any_String;
		endif;
		
	elseif _attrName = ETRow_SrcSubSubLocation then
		if sourceSubSubLocation &lt;&gt; null then
			return self.sourceSubSubLocation;
		else
			return Any_String;
		endif;
	
	elseif _attrName = ETRow_VoyageAllocated then  //18/05/2009 cnwdz2 par19257 changed ETRow_Voyage to ETRow_VoyageAllocated
		if self.getMyVoyageGlobalAllocated &lt;&gt; null then
			_oid := self.getMyVoyageGlobalAllocated.getOidAsString(); //20/07/2010 cnwdz2 24513
			return self.getMyVoyageGlobalAllocated.code;
		else
			return Any_String;
		endif;

	elseif _attrName = ETRow_VoyageActual then
		if self.getMyVoyageGlobalActual &lt;&gt; null then
			_oid := self.getMyVoyageGlobalActual.getOidAsString(); //20/07/2010 cnwdz2 24513
			return self.getMyVoyageGlobalActual.code;
		else
			return Any_String;
		endif;
	endif;

	return inheritMethod(_attrName, _getCalculatedDate, _oid);

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleLocationsController" id="cd3d25bc-ec38-432e-b3c6-9b6f803fe1d5">
        <updating/>
        <source>handleLocationsController(_lc : CM_LocationsController; 
						_collection : Collection input; 
						_passport : CM_Passport;
						_breakOut : Boolean output) protected, updating;
// ---------------------------------------------------------------------------
// Created:     19 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/
vars
	sohLoc		: CM_SOHLocation;
	proLog		: CM_ProductLog;
	proIter		: Iterator;
	ti			: CM_TrackedItem;
	passport	: CM_Passport;
	voyController		: CM_LogVoyageController;
	querySelf		: CMQF_Log;
begin
	querySelf := self;
	passport := app.myPassport;
	if CM_LogVoyageController.hasInstance(_lc) then
		voyController := _lc.CM_LogVoyageController;
		if ((querySelf.logHatch &lt;&gt; null and querySelf.logHatch &lt;&gt; voyController.hatch) or
		   (querySelf.logPlace &lt;&gt; null and querySelf.logPlace &lt;&gt; voyController.place)) then
			return;
		endif;
	endif;
	
	proIter := _lc.allProductLocations.createIterator;
	while proIter.next(sohLoc) do
		if (not CM_ProductLog.hasInstance(sohLoc.myProduct)) then
			continue;
		endif;
		
		proLog := sohLoc.myProduct.CM_ProductLog;
		if (not querySelf.includesProduct(proLog)) then
			continue;
		endif;
		
		foreach ti in sohLoc.allTrackedItems discreteLock do
			if querySelf.checkStatusIncludesObject(ti, _passport, _breakOut) then
//			if querySelf.includesObject(ti.CM_Log, passport, _breakOut) then
				//collection.add(ti);
				self.addToCollection(ti, _collection); ////#cnwdz2	 CCMS 1108 par22177 
			endif;
			
//			if _breakOut then
//				break;
//			endif;
		endforeach;

	endwhile;

epilog
	delete proIter;		// PAR #26678
	
end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="handleLogLot" id="dc7d837a-9619-40cd-bf1d-b2230602ccc8">
        <updating/>
        <source>handleLogLot(_logLot : CM_LogLot; 
			_collection : Collection input; 
			_passport : CM_Passport;
			_breakOut : Boolean output) protected, updating;
// ---------------------------------------------------------------------------
// Created:     27 February 2004	cnwth2
//
// Purpose:     
//	14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  			 
// ----------   ----------  --------------------------------------------------
vars
	voyController		: CM_LogVoyageController;
	querySelf			: CMQF_Log;
	locIter				: Iterator;
	hatchKey,
	placeKey			: Integer;
begin
	if _logLot = null then
		return;
	endif;
	
	querySelf := self;
	locIter := _logLot.allLocationsByHatchPlace.createIterator;
	_logLot.allLocationsByHatchPlace.startKeyGeq(querySelf.logHatch, querySelf.logPlace, locIter);
	
	while locIter.next(voyController) do
		locIter.getCurrentKeys(hatchKey, placeKey); //MTN-35226
		
		if (querySelf.logHatch &lt;&gt; null and querySelf.logHatch &lt;&gt; hatchKey) or
		   (querySelf.logPlace &lt;&gt; null and querySelf.logPlace &lt;&gt; placeKey) then
			break;
		endif;
		
		self.handleLocationsController(voyController, _collection, _passport, _breakOut);
	endwhile;


epilog
	delete locIter;	
end;</source>
        <access>protected</access>
        <Parameter name="_logLot" type="CM_LogLot"/>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="1e00760b-af82-4409-a7ce-33f5ea2e4279">
        <updating/>
        <source>includesObject(_log : CM_Log; _passport : CM_Passport; _breakOut : Boolean output): Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     10 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	bolIn			: CM_BOLIn;
	querySelf		: CMQF_Log;
	failedDAC  :CM_DataAccessController;

begin
	querySelf := self;
	querySelf.numSearched := querySelf.numSearched + 1;
	
	bolIn := _log.myReceivalBOL;
	if bolIn = null then
		return false;
	endif;
	
	if querySelf.matchStartDate.isValid and bolIn.matchTime &lt; querySelf.matchStartDate then
		return false;
	elseif querySelf.matchEndDate.isValid and bolIn.matchTime &gt; querySelf.matchEndDate then
		return false;
	endif;
	
	if (querySelf.consignor = null or querySelf.consignor = _log.consignor)
	and (querySelf.sedSmallerThan = 0 or querySelf.sedSmallerThan &gt;= _log.sedMean)
	and (querySelf.sedGreaterThan = 0 or querySelf.sedGreaterThan &lt;= _log.sedMean)
	and (querySelf.carrierCode = null or _log.carrier = querySelf.carrierCode)
	and (querySelf.gangNumber = null or bolIn.myExtension.CM_BOLExtLogIn.gangNumber.toUpper = querySelf.gangNumber.toUpper)
	//and(querySelf.loggingOrganisation = null or bolIn.loggingOrganisation.toUpper = querySelf.loggingOrganisation.toUpper) //#cnwdz2	 CCMS 1108 par22177 
	and(querySelf.loggingOrganisation = null or bolIn.getLoggingOrganisation().toUpper = querySelf.loggingOrganisation.toUpper)
	and (querySelf.sourceLocation = null or  bolIn.sourceLocation = querySelf.sourceLocation)
	and (querySelf.sourceSubLocation = null or  bolIn.sourceSubLocation = querySelf.sourceSubLocation)
	and (querySelf.sourceSubSubLocation = null or  bolIn.sourceSubSubLocation = querySelf.sourceSubSubLocation)
	and (querySelf.myOperator = null or querySelf.myOperator = _log.myOperator)
	and (querySelf.getMyLogSpecies = null or querySelf.getMyLogSpecies = _log.myLogSpecies)
	and (querySelf.getMyLogGrade = null or querySelf.getMyLogGrade = _log.myLogGrade)
	and (querySelf.getMyLogType = null or querySelf.getMyLogType = _log.myLogType)
	and (querySelf.getMyLogTreatment = null or querySelf.getMyLogTreatment = _log.myLogTreatment)
	and (querySelf.getMyLogLength = null or querySelf.getMyLogLength = _log.myLogLength)
	and (querySelf.getMySubTerminal = null or querySelf.getMySubTerminal = _log.mySubTerminal) //28/04/2009 cnwdz2 ccms1735
	then
		if not _log.canUserAccessSelf(null, failedDAC,_passport) then
			return false;
		endif;

		querySelf.numFound := querySelf.numFound + 1;

		return true;
	endif;
	
	return false;
end;</source>
        <access>protected</access>
        <Parameter name="_log" type="CM_Log"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesProduct" id="e1423ff2-b368-4288-8375-38054f988600">
        <source>includesProduct(_proLog: CM_ProductLog): Boolean;
// ---------------------------------------------------------------------------
// Created:     06 September 2002 by cnwth2
//
// Purpose:     This is called 'includesProduct' rather than includesObject (which takes a TI)
//				because CM_ProductLog does not inherit from CM_TrackedItem
//
// ----------   ----------  --------------------------------------------------
vars
	querySelf		: CMQF_Log;
begin
	querySelf := self;
	
	if (querySelf.myOperator = null or _proLog.myOperator = querySelf.myOperator) and
		(querySelf.getMyLogSpecies = null or _proLog.myLogSpecies = querySelf.getMyLogSpecies) and
		(querySelf.getMyLogGrade = null or _proLog.myLogGrade = querySelf.getMyLogGrade) and
		(querySelf.getMyLogType = null or _proLog.myLogType = querySelf.getMyLogType) and
		(querySelf.getMyLogTreatment = null or _proLog.myLogTreatment = querySelf.getMyLogTreatment) and
		(querySelf.getMyLogLength = null or _proLog.myLogLength = querySelf.getMyLogLength) then
		
		return true;
	endif;
	
	return false;
end;</source>
        <Parameter name="_proLog" type="CM_ProductLog"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDatesForTemplateRun" id="8b5338fc-8daa-4b4a-8043-337c88168521">
        <updating/>
        <source>setDatesForTemplateRun(_runDate: Date) updating;
// ---------------------------------------------------------------------------
// Created:     12 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod(_runDate);
	
	self.matchEndDate.setDate(self.setDateFromTemplate(self.matchEndDateTplType, 
											self.matchEndDateTplFactor, 
											_runDate));
											
	self.matchStartDate.setDate(self.setDateFromTemplate(self.matchStartDateTplType, 
											self.matchStartDateTplFactor, 
											_runDate));

end;</source>
        <Parameter name="_runDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="setFromTemplate" id="7f0be410-25b5-454c-8e12-0018efe51f48">
        <updating/>
        <source>setFromTemplate(_obj: CMQF_Log; _runDate: Date; _allEventData : CM_EventDataByTypeDict) updating;
// ---------------------------------------------------------------------------
// Created:     07 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_obj, _runDate, _allEventData);
	
	self.matchStartDate.setDate(self.setDateFromTemplate(self.matchStartDateTplType, self.matchStartDateTplFactor, _runDate));
	
	if self.matchEndDate.time = null then //only a consideration for data pre 715 i - as after that time automatically sets to 23:59:59:999
		self.matchEndDate.setDate(self.setDateFromTemplate(self.matchEndDateTplType, self.matchEndDateTplFactor, _runDate) + 1);
	else
		self.matchEndDate.setDate(self.setDateFromTemplate(self.matchEndDateTplType, self.matchEndDateTplFactor, _runDate));
	endif;
	
end;</source>
        <Parameter name="_obj" type="CMQF_Log"/>
        <Parameter name="_runDate" type="Date"/>
        <Parameter name="_allEventData" type="CM_EventDataByTypeDict"/>
    </JadeMethod>
