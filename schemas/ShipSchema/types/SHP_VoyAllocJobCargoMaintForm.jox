    <JadeMethod name="displayFoundTIs" id="a734f3d3-2e3e-41ab-89b9-e4238439bfdc">
        <source>displayFoundTIs();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 December 2012	cnwrd1	Initial creation

*/

vars
	iter 	:	Iterator;
	idx		: Integer;
	aTI		: CM_TrackedItem;
begin

	if allFoundTIs.isEmpty then
		return;
	endif;
	
	iter := self.allFoundTIs.createIterator();
	
	while iter.next(aTI) do	
		if self.allSelectedCargo.includes(aTI) then
			continue;
		endif;
		idx := self.tblResults.updateItemObject(aTI, self.colorRow1, self.colorRow2, app.myPassport);
		self.tblResults.accessRow(idx).itemObject := aTI;
	endwhile;	
	
	
epilog
	delete iter;
end;</source>
    </JadeMethod>
