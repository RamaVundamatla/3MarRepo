    <JadeMethod name="tblCargo_click" id="2287514f-1e6c-4d53-a14d-b3d0c7fe4df2">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCargo_click(table: Table input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 July 2009	cnwmd1	Initial creation

*/

vars

begin
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	if table.row &gt; table.fixedRows then
		self.mnuInspectObject.userObject := table.accessRow(table.row).itemObject;
	else
		self.mnuInspectObject.userObject := null;
	endif;
	self.setControlsForAddEditDelete(true);
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblCargo_contextMenu" id="d883d039-0bcb-4943-9836-7929cf2e352f">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCargo_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 July 2009	cnwmd1	Initial creation

*/

vars

begin

//	self.mnuContext.visible := true;	// PAR 20108
	self.mnuInspectObject.visible := self.mnuInspectObject.userObject &lt;&gt; null and app.isAllowedToInspect();
	self.mnuColumnOrganiser.visible := true;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuCargoEdit.visible := false;
		self.mnuRemoveCargo.visible := false;
		self.mnuCargoInTransit.visible := false;
		self.mnuCargoInTransitNOT.visible := false;
		self.mnuCargoEnquiry.enabled:= true;
	endif;
	
	
	return self.showContextMenu(mnuContext, table, conwin, mouse, x, y);
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblCargo_dblClick" id="4ae8eb69-0bd4-4530-929a-ca4206a84e99">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCargo_dblClick(table: Table input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 July 2009	cnwmd1	Initial creation

*/

vars

begin
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	if table.row &gt; table.fixedRows then
		//self.doCargoEnquiry();
		self.doCargoEdit();
	else
		table.CM_DataTable.resortTableByColumn(table.column);
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="ee59bbcd-e1fb-4281-9cbc-d63900325407">
