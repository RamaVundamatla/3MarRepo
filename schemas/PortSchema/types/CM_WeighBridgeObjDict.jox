    <JadeMethod name="getMyDefaultWeighBridge" id="368c57cd-ced2-48bc-ac56-be6ce28b4473">
        <source>getMyDefaultWeighBridge() : CM_WeighBridgeObj;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 July 2021	navndl1	Initial creation	TFS 51575

*/

vars

	weighBridge : CM_WeighBridgeObj;
	computerName : String;

begin

	weighBridge := self.getMyTwoReadingsWeighBridge();
	if weighBridge &lt;&gt; null then
		return weighBridge;
	endif;
	
	computerName := process.getComputerName();

	foreach weighBridge in self do
		if weighBridge.computerName.toUpper &lt;&gt; computerName.toUpper then
			continue;
		endif;
		return weighBridge;
	endforeach;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_WeighBridgeObj"/>
    </JadeMethod>
    <JadeMethod name="getMyTwoReadingsWeighBridge" id="c38e5a27-23f8-40df-a791-79f6c76d1b76">
        <source>getMyTwoReadingsWeighBridge() : CM_WeighBridgeObj;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 July 2019	jlgndl1	Initial creation	TFS 44965

*/

vars

	weighBridge : CM_WeighBridgeObj;
	computerName : String;

begin
	
	computerName := process.getComputerName();

	foreach weighBridge in self do
		if not weighBridge.isTwoReadings then
			continue;
		endif;
		if weighBridge.computerName.toUpper &lt;&gt; computerName.toUpper then
			continue;
		endif;
		return weighBridge;
	endforeach;
	
	return null;

epilog

end;</source>
        <ReturnType type="CM_WeighBridgeObj"/>
    </JadeMethod>
</CollClass>
