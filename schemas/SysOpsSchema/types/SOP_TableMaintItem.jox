    <JadeMethod name="setupMultiSelect6" id="0eb06b13-bb73-4629-afad-92aaa66061ff">
        <source>setupMultiSelect6(	_name : String;
					_collection : Collection; 
					_displayMethodName : String);
vars

begin
	self.myForm.shtMultiSelect6.visible := true;
	self.myForm.mulSelect6.visible:=true;
	self.myForm.shtMultiSelect6.visible := true;
	self.myForm.shtMultiSelect6.caption:=_name;
	self.myForm.mulSelect6.setupControl(_name,_collection,_displayMethodName);
	if not self.myForm.chkAnyTriggField.lockRight then	//12 Jul 2016	NDL	TFS 2272
		self.myForm.chkAnyTriggField.parent	:= self.myForm.mulSelect6;
		self.myForm.chkAnyTriggField.left	:= self.myForm.mulSelect6.width - self.myForm.chkAnyTriggField.width;
		self.myForm.chkAnyTriggField.lockRight := true;	//12 Jul 2016	NDL	TFS 2272
	endif;
end;
</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_collection" type="Collection"/>
        <Parameter name="_displayMethodName" type="String"/>
    </JadeMethod>
