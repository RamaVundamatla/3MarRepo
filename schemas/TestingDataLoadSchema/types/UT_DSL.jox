    <JadeMethod name="deleteTiStopsExcept" id="2469419d-f729-4101-a349-1b44de68dc7d">
        <source>deleteTiStopsExcept( _ti : CM_TrackedItem input; _keepThese : CM_StopsTableByIdDict; _clearOldValues : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 July 2015	cnwndl1	Initial creation	Par 36543

*/

vars
	
	garbageStartValue : Boolean;
	tiStops : CM_StopsByIdDict;
	deleteStops : CM_StopsTableSet;
	stop : CM_Stops;
	stopsTable: CM_StopsTable;
	tiSet: CM_TISet;
	info : String;

begin

	garbageStartValue := app.isGarbageCollectionProcess;

	create tiSet transient;
	create deleteStops transient;
	tiSet.add(_ti);

	
	tiStops := _ti.getAllStops();
	foreach stop in tiStops do
		stopsTable := stop.myStopsTable;
		if not _keepThese.includes(stopsTable) then
			deleteStops.add( stopsTable );
		endif;
	endforeach;
	
	if not deleteStops.isEmpty then
		app.isGarbageCollectionProcess := true;
		foreach stopsTable in deleteStops do
			info := null;	//allowed if app.isGarbageCollectionProcess = true;
			app.myTrxDA.trxDeleteStopForTIsBulk(tiSet, stopsTable, info, app.myPassport);
			self.assertTrueMsg( app.myPassport.noErrors, "Failed cleaning up stop '" &amp; stopsTable.heading &amp; "' - " &amp; app.myPassport.getErrorsAndWarningsAsString);
		endforeach;
	endif;
	

epilog

	app.isGarbageCollectionProcess := garbageStartValue;
	delete tiSet;
	delete deleteStops;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_keepThese" type="CM_StopsTableByIdDict"/>
        <Parameter name="_clearOldValues" type="Boolean"/>
    </JadeMethod>
