<Class name="CM_RTDeviceVehicleMount">
    <JadeMethod name="importPLXMLReference" id="e60a929a-8caa-442b-aa08-d5061a3b7f9c">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = CM_RTDeviceVehicleMount::myRadioTelemetry.name then
		return app.getMyTerminalDO_NOT_USE().radioTelemetry;
	elseif _name = CM_RTDeviceVehicleMount::myMachine.name then
		return app.getMyTerminalDO_NOT_USE().machines[_theCode];
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
        <Parameter name="_referencesBlock" type="String"/>
        <ReturnType type="Object"/>
    </JadeMethod>
</Class>
