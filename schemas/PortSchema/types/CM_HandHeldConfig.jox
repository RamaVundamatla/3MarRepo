    <JadeMethod name="populateTransientSearchView" id="8697f5fe-ed0c-407f-8e05-a67294e6e81a">
        <source>populateTransientSearchView( _entTable : EntTableDef; _view : EntTableView input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2016	cnwndl1	Initial creation	TFS 2850 / 2370

*/

vars

	view : EntTableView;
	tempEntRow, entTableRow : EntTableRow;

begin

	_view.setProxy( "HandHeld", "Hand Held Config View");
	foreach tempEntRow in self.allVisibleSearchRows do
		entTableRow := _entTable.getEntTableRow( tempEntRow.name );
		if entTableRow &lt;&gt; null then
			_view.addRow( entTableRow );
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_entTable" type="EntTableDef"/>
        <Parameter name="_view" type="EntTableView" usage="input"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="f7e10246-1dea-48c4-b5dd-bc6cd7356a48">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2016	cnwndl1	Initial creation	TFS 2850 / 2370

*/

vars

	proxy : CM_HandHeldConfig;
	entRow : EntTableRow;
	proxyRow : EntTableRowProxy;

begin

	proxy := inheritMethod();
	
	proxy.myTerminal := self.myTerminal;

	foreach entRow in self.allVisibleResultsCols do
		create proxyRow transient;
		proxyRow.setBasicDetails(entRow.name, entRow.getRawHeadingValue, entRow.inputType, true);
		proxy.allVisibleResultsCols.add( proxyRow );
	endforeach;
	
	foreach entRow in self.allVisibleSearchRows do
		create proxyRow transient;
		proxyRow.setBasicDetails(entRow.name, entRow.getRawHeadingValue, entRow.inputType, true);
		proxy.allVisibleSearchRows.add( proxyRow );
	endforeach;
	
	//07 Dec 2016	NDL	TFS 3008 / 2370
	foreach entRow in self.allVisibleViewRows do
		create proxyRow transient;
		proxyRow.setBasicDetails(entRow.name, entRow.getRawHeadingValue, entRow.inputType, true);
		proxy.allVisibleViewRows.add( proxyRow );
	endforeach;
	
	return proxy;
	
epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="60923a9d-2d6d-4870-87d6-a9ceaaa8fbb5">
        <updating/>
        <source>setForCreate( _proxy : CM_HandHeldConfig ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2016	cnwndl1	Initial creation	TFS 2850 / 2370

*/

vars

begin

