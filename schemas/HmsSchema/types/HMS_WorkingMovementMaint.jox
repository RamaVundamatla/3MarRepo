    <JadeMethod name="tblResources_keyDown" id="80010014-cf4f-481a-82b7-081c5cf2db00">
        <controlMethod name="CM_DataTable::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblResources_keyDown(table: Table input; keyCode: Integer io; shift: Integer) updating;
//--------------------------------------------------
// Created:	24 February 2005 By: cnwgd1
//--------------------------------------------------
vars
	cntrl : Control;
begin
	
	if shift = 0
	and keyCode = J_key_Tab
	and table.userInputEnabled	
	and table.row &gt; table.fixedRows then
		
		self.aOrigValueInteger := table.rows;
		//if at the end of the last row then a new row will be added
		self.doQueryRowColumnChange(table, table.row+1);
		if table.rows &gt; self.aOrigValueInteger then
			//A new row has been added, reset key code
			//To prevent jade from re-setting the column
			keyCode := 0;
		endif;

	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblResources_queryRowColChg" id="a599390b-6f62-41bd-bfdf-db285347f4f3">
        <controlMethod name="CM_DataTable::queryRowColChg"/>
