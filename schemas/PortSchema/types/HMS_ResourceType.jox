    <JadeMethod name="setForUpdate" id="4c3630b6-f9cd-42ca-8436-5aad80b315da">
        <updating/>
        <source>setForUpdate(_pxyResourceType: HMS_ResourceType; _passport: CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------
// 14/11/2012	cnwdap1		PAR #30741 CCMS 2232 Display Resource codes on Harbour View
// 09/09/2022	navgm20 	ChangeRequest 54739: EUP - PLAN - Berth planning by bollards
// 29/09/2022   navsj20		ChangeRequest 54739: EUP - PLAN - Berth planning by bollards

vars
	obj: HMS_Resource;	//29 Sep 2022	navsj20	TFS 54739
begin
	inheritMethod(_pxyResourceType, _passport);
	
	self.code 			:= _pxyResourceType.code.toUpper.trimBlanks;
	self.description	:= _pxyResourceType.description;
	self.myRoot			:= _pxyResourceType.myRoot;
	self.iconDownString	:= _pxyResourceType.iconDownString;
	self.iconUpString	:= _pxyResourceType.iconUpString;
	self.iconLocationString	:= _pxyResourceType.iconLocationString;	
	self.iconVisibleOnView := _pxyResourceType.iconVisibleOnView;		
	self.isNotAvailableForEntry := _pxyResourceType.isNotAvailableForEntry; // CCMS 1350
	self.isMarineService := _pxyResourceType.isMarineService; // CCMS 1350

	self.isActionDateTimeRequired := _pxyResourceType.isActionDateTimeRequired;		
	self.isFromToDateTimeRequired := _pxyResourceType.isFromToDateTimeRequired;		
	self.isQuantityRequired := _pxyResourceType.isQuantityRequired;		
	self.numDecimalPlaces := _pxyResourceType.numDecimalPlaces;		
	self.quantityUnits := _pxyResourceType.quantityUnits;		
	
	self.displayCodeOnView := _pxyResourceType.displayCodeOnView;		// PAR #30741
	// START 29 Sep 2022	navsj20	TFS 54739
	if self.category = HMS_CategoryBollard and _pxyResourceType.category = HMS_CategoryNone then
		foreach obj in allResources where obj.myBerth &lt;&gt; null do
			obj.setMyBerth(null);
		endforeach;
	endif;
	self.category		:=	_pxyResourceType.category; 	
	// END 29 Sep 2022	navsj20	TFS 54739
	if app.isConverting then
		self.myHarbourBunkers := _pxyResourceType.myHarbourBunkers;
		self.myHarbourPhone := _pxyResourceType.myHarbourPhone;
	endif;
	
end;</source>
        <Parameter name="_pxyResourceType" type="HMS_ResourceType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="2d876c62-36cc-41f4-9331-19fbf2d37397">
