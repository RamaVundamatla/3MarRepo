    <JadeMethod name="doResizeControls" id="72463af8-a7b3-4521-8055-ed96a7731e22">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2015	cnwndl1	Initial creation	Par 36782

*/

vars

	cTop : Real;
	stdWidth : Real;
	cWidth : Real;
	stdHeight : Real;
	cHeight : Real;
	cLeft : Real;
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	cTop := self.resizedMargin;
	cWidth := stdWidth;
	cHeight := stdHeight;
	tabIndex := 4000;
	
	if _initialSetup then
		self.txtBatNo.setAndIncrementTabIndex( tabIndex );
		self.txtBatNo.visible := true;
	endif;
	self.txtBatNo.move( 	self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
								
	cTop := cTop + self.txtBatNo.height + ( self.resizedMargin );
	if _initialSetup then
		self.lblRequest.setAndIncrementTabIndex( tabIndex );
		self.lblRequest.visible := true;
	endif;
	self.lblRequest.move( self.resizedMargin,
							 cTop,
							 cWidth,
							 cHeight ); 
								
	cTop := cTop + self.lblRequest.height;
	if _initialSetup then
		self.cmbSourceArea.setAndIncrementTabIndex( tabIndex );
		self.cmbSourceArea.visible := true;
	endif;
	self.cmbSourceArea.move( self.resizedMargin,
							 cTop,
							 cWidth,
							 cHeight ); 
							 
	cTop := cTop + self.cmbSourceArea.height + ( self.resizedMargin );
	if _initialSetup then
		self.lblPackLoadTarg.setAndIncrementTabIndex( tabIndex );
		self.lblPackLoadTarg.visible := true;
	endif;
	self.lblPackLoadTarg.move( self.resizedMargin,
							 cTop,
							 cWidth,
							 cHeight );
								
	cTop := cTop + self.lblPackLoadTarg.height;
	if _initialSetup then
		self.cmbTruck.setAndIncrementTabIndex( tabIndex );
		self.cmbTruck.visible := true;
	endif;
	self.cmbTruck.move( self.resizedMargin,
							 cTop,
							 cWidth,
							 cHeight );
							 						 						 
	cTop := cTop + self.cmbTruck.height + ( self.resizedMargin );
	if _initialSetup then
		self.cmbTrailer.setAndIncrementTabIndex( tabIndex );
		self.cmbTrailer.visible := true;
	endif;
	self.cmbTrailer.move( self.resizedMargin,
							 cTop,
							 cWidth,
							 cHeight );
							 
	cTop := cTop + self.cmbTrailer.height + ( self.resizedMargin );
	if _initialSetup then
		self.cmbParent.setAndIncrementTabIndex( tabIndex );
		self.cmbParent.visible := true;
	endif;
	self.cmbParent.move( self.resizedMargin,
							 cTop,
							 cWidth,
							 cHeight ); 
							 
	cTop := cTop + self.cmbParent.height + ( self.resizedMargin );
	cWidth := stdWidth - self.getSearchButtonSpace();
	if _initialSetup then
		self.txtParentId.setAndIncrementTabIndex( tabIndex );
		self.txtParentId.visible := false;
	endif;
	self.txtParentId.move( self.resizedMargin,
						 cTop,
						 cWidth,
						 stdHeight );
						 
	cWidth := self.getStdControlHeight();
	if _initialSetup then
		self.btnPartCargoId.setAndIncrementTabIndex( tabIndex );
		self.btnPartCargoId.visible := false;
	endif;
	self.btnPartCargoId.move( self.txtParentId.left + self.txtParentId.width + self.resizedMargin,
						 cTop,
						 cWidth,
						 cHeight );
						 
	cTop := cTop + self.txtParentId.height + self.resizedMargin;
	cWidth := stdWidth;
	if _initialSetup then
		self.lblCargoType.visible := true;
		self.lblCargoType.setAndIncrementTabIndex( tabIndex );
	endif;
	self.lblCargoType.move( self.resizedMargin,
							 cTop,
							 cWidth,
							 cHeight ); 
							 
	cTop := cTop + self.lblCargoType.height + self.resizedMargin;
	if _initialSetup then
		self.lblCargoDesc.visible := true;
		self.lblCargoDesc.setAndIncrementTabIndex( tabIndex );
	endif;
	self.lblCargoDesc.move( self.resizedMargin,
							 cTop,
							 cWidth,
							 cHeight );
							 
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="findBatAndRequest" id="11a706d9-e5a4-4b9d-998b-cb9ca2a359d8">
        <updating/>
        <source>findBatAndRequest() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2015	cnwndl1	Initial creation	Par 36782

*/

vars

	batString : String;
	roadJob : CM_RoadJob;
	request : CM_Request;
	term : CM_Terminal;
	selectedBulkRelease : CM_BulkRelease;
	truck : CM_Vehicle;
	newIndex : Integer;
	ti : CM_TrackedItem;
	vvr : CM_VehicleVisitRecord;

begin

	self.cmbTruck.clear();
	self.cmbParent.clear();
	self.cmbTrailer.clear();
	
	self.cmbTruck.enabled := true;
	self.cmbParent.enabled := true;
	self.cmbTrailer.enabled := true;
	
	self.myBat := null;
	self.myRFIDTag := null;
	self.myBulkRelease := null;
	self.requestedItemCount := 0;

	batString := self.txtBatNo.text;
	
	if batString.trimBlanks = null or batString = self.lblBatNo.caption.toUpper then
		if batString = null then
			self.txtBatNo.text := self.lblBatNo.caption.toUpper;
		endif;
		
		
	else
		//find an active road release.
		term := self.myMobileDataAgent.myTerminal;
		
		self.myBat := self.myTerminal.allBatNumbersInUse.getAtKey( batString );
		if self.myBat &lt;&gt; null then
			roadJob := self.myBat.myRoadJob;
		endif;
		
		if roadJob = null then
			self.myRFIDTag := self.myTerminal.allRFIDTagsByCode.getAtKey( batString );
			if self.myRFIDTag &lt;&gt; null then
				roadJob := self.myRFIDTag.myRoadJob;
			endif;
		endif; 
		
		//26 Nov 2015	NDL	Par 37084
		if roadJob = null then
			vvr := term.getVehicleVisitForBatNumber( batString );
			if vvr &lt;&gt; null then
				roadJob := vvr.myRoadJob;
			endif;
		endif;
			
		if roadJob &lt;&gt; null then
			self.myBulkRelease := roadJob.getMyBulkRelease;
			truck := roadJob.myVehicle;
			
			if self.myBulkRelease &lt;&gt; null then
				
				if truck &lt;&gt; null then
					newIndex := self.cmbTruck.addItem( truck.regNumber );
					self.cmbTruck.itemObject[newIndex] := truck; 
					
					foreach ti in truck.locationsController.allTrackedItems do
						if ti.isROB then
							if ti.isChassis then
								newIndex := self.cmbTrailer.addItem( ti.id );
								self.cmbTrailer.itemObject[newIndex] := ti; 
							else
								newIndex := self.cmbParent.addItem( ti.id );
								self.cmbParent.itemObject[newIndex] := ti; 
							endif;
						endif;
					endforeach; 
				endif;
				
				self.getProspectiveParentCargo();
			
			endif;
			
		endif;
		
	endif;
	
	if self.cmbTruck.listCount &lt; 1 then
		self.cmbTruck.addItem( app.getErrorString(No_associated_truck) );
		self.cmbTruck.enabled := false;
		self.cmbTruck.listIndex := 1;	
	else
		self.cmbTruck.addItemAt( app.getErrorString(Associated_truck),1 );
	endif;
	
	if self.cmbTrailer.listCount &lt; 1 then
		self.cmbTrailer.addItem( app.getErrorString(No_associated_trailers) );
		self.cmbTrailer.enabled := false;
		self.cmbTrailer.listIndex := 1;	
	else
		self.cmbTrailer.addItemAt( app.getErrorString(Associated_trailers),1 );
		self.cmbTrailer.listIndex := 1;
	endif;
	
	if self.cmbParent.listCount &lt; 1 then
		self.cmbParent.addItem( app.getErrorString(No_associated_parents) );
		self.cmbParent.enabled := false;
		self.cmbParent.listIndex := 1;
	else
		self.cmbParent.addItemAt( app.getErrorString(Associated_parents),1 );
		self.cmbParent.listIndex := 1;
	endif;
	
	if self.myBulkRelease = null then
		if batString.trimBlanks = null or batString = self.lblBatNo.caption.toUpper then
			self.lblRequest.caption := null;
		elseif self.myBat = null and self.myRFIDTag = null then
			self.lblRequest.caption := app.getErrorString(Bat_number_not_found);
		elseif truck = null then
			self.lblRequest.caption := app.getErrorString(Number_no_current_truck);
		else
			self.lblRequest.caption := app.getErrorString1(Truck_no_request, truck.regNumber);
		endif;
	else
		if self.myBulkRelease.releaseByType then
			self.requestedItemCount := self.myBulkRelease.getTotalOutstanding;
			self.lblRequest.caption := app.releaseRequestTypeEnumToString( self.myBulkRelease.type ) &amp; " " &amp; app.getErrorString(Release_by_Type) &amp; " ["
			&amp; self.requestedItemCount.String &amp; " " &amp; app.getErrorString(INV_Items) &amp; "]";
		else
			self.requestedItemCount := self.myBulkRelease.allTrackedItemsAssigned.size;
			self.lblRequest.caption := app.releaseRequestTypeEnumToString( self.myBulkRelease.type ) &amp; " " &amp; app.getErrorString(Release_by_ID) &amp; " ["
			&amp; self.requestedItemCount.String &amp; " " &amp; app.getErrorString(INV_Items) &amp; "]";
		endif;
	endif;
	
	if truck &lt;&gt; null then
		self.cmbTruck.listIndex := self.cmbTruck.findObject(truck);
		self.setMyTruck( truck );
	else
		self.setMyTruck( null );
	endif;
	self.setMyTrackedItem( null );
	
	self.txtParentId.visible := ( not self.cmbParent.enabled ) and ( not self.cmbTrailer.enabled ) and ( self.myBulkRelease &lt;&gt; null );
	self.btnPartCargoId.visible := self.txtParentId.visible;
	
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getProspectiveParentCargo" id="02122b1a-7c86-4daf-a136-c767b0b6ccd1">
        <updating/>
        <source>getProspectiveParentCargo() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2015	cnwndl1	Initial creation	Par 36782
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars

	ti : CM_TrackedItem;
	reserve : CM_ReserveDetail;
	opTerm : CM_OperatorTerminal;
	newIndex : Integer;
	reason : String;
	allTis	: CM_TISet;
begin

	if self.myBulkRelease = null then
		return;
	endif;

	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	
	if not self.myBulkRelease.releaseByType then
		// Release by id
		// get the nominated parents
		foreach reserve in self.myBulkRelease.allReserveDetails do	
			reserve.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
			//foreach ti in reserve.allTrackedItems do
			foreach ti in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
				if self.myBulkRelease.allTrackedItemsReleased.includes(ti) then
					continue;
				endif;
				if ti.isChassis then
					newIndex := self.cmbTrailer.addItem( ti.id );
					self.cmbTrailer.itemObject[newIndex] := ti; 
				elseif ti.isContainer then
					newIndex := self.cmbParent.addItem( ti.id );
					self.cmbParent.itemObject[newIndex] := ti; 
				endif;
			endforeach;
		endforeach;
		
	else
		// release by type
		// get the prospective parents
		opTerm := self.myBulkRelease.myOperatorTerminal;
		if opTerm &lt;&gt; null then
			foreach reserve in self.myBulkRelease.allReserveDetails do
				if not reserve.isKindOf( CM_ReserveSelection ) then
					continue;
				endif;
				foreach ti in opTerm.allOnsiteTIsByCargoTypeId do
					if self.myBulkRelease.allTrackedItemsReleased.includes(ti) then
						continue;
					endif;
					if ti.isChassis then
						if ti.testAgainstReserveSelection( reserve.CM_ReserveSelection, reason, true, null ) then
							newIndex := self.cmbTrailer.addItem( ti.id );
							self.cmbTrailer.itemObject[newIndex] := ti; 
						endif;
					elseif ti.isContainer then
						if ti.testAgainstReserveSelection( reserve.CM_ReserveSelection, reason, true, null ) then
							newIndex := self.cmbParent.addItem( ti.id );
							self.cmbParent.itemObject[newIndex] := ti; 
						endif;
					endif;
				endforeach;
			endforeach;
		endif;
	endif;

epilog
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="2e2fdc6e-cacc-46f3-8fce-3891f9b603f9">
        <updating/>
        <source>handleBtnOne() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 August 2015	cnwndl1	Initial creation	Par 36782

*/

vars
begin

	inheritMethod();
		
	if myTruck = null and myTrailer = null and not myBulkRelease.isPackingType then   // PAR 36471
		self.msgBox(app.getErrorString(Packi_relea_must_used_when_pac), app.getErrorString(Error), MsgBox_OK_Only, false );
		self.txtBatNo.setFocus();
		return;
	endif;
	
	if self.myTrailer &lt;&gt; null then
	
		self.myMobileGenericAgent.setTruck( null );
		self.myMobileGenericAgent.setMyLocationsController(	self.myTrailer.CM_TILC.allLCs.first );
		self.myMobileGenericAgent.setMyBulkRelease( self.myBulkRelease );
		self.myMobileGenericAgent.setMyYardLocation( self.cmbSourceArea.listObject.CM_LocationsController );
		self.gotoForm( MOB_HHBRLocLoaderAllCargo, false );
		
	elseif self.myTrackedItem &lt;&gt; null then
	
		self.myMobileGenericAgent.setPackContainerDetails(	null,	//_stockBookingRef : CM_BookingRef;
																null,	//_stockBookingRefItem : CM_BookingRefItem;
																null,	//_exportBookingRef : CM_BookingRef;
																null,	//_exportBookingRefItem : CM_BookingRefItem;
																self.myTrackedItem	//_trackedItem : CM_TrackedItem
																);	
		self.myMobileGenericAgent.setMyBulkRelease( self.myBulkRelease );
		self.myMobileGenericAgent.setMyYardLocation( self.cmbSourceArea.listObject.CM_LocationsController );
		
		self.gotoForm( MOB_HHPackContainerUpdForm, false );
	
	elseif self.myTruck &lt;&gt; null then

		self.myMobileGenericAgent.setMyLocationsController(	self.myTruck.locationsController );
		self.myMobileGenericAgent.setMyBulkRelease( self.myBulkRelease );
		self.myMobileGenericAgent.setMyYardLocation( self.cmbSourceArea.listObject.CM_LocationsController );
		self.gotoForm( MOB_HHBRLocLoaderAllCargo, false );
			
	endif;

epilog

end;</source>
