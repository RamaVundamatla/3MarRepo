		portion := newValue/ self.totalWeight;
		self.txtClearedQuantity.text := (self.totalQuantity * portion).Integer.String;
		self.txtClearedVolume.setValue(self.totalVolume * portion);

		if ti.isCargoGroupItem() then
			self.displaySubDetails();
