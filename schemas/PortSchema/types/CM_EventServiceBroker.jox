vars

begin
	self.myEventType := _event;
	self.myTranMap := _tmTM;

end;</source>
        <Parameter name="_event" type="CM_EventType"/>
        <Parameter name="_tmTM" type="CM_TranMapEvent"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="ee167981-6e17-42dd-bc05-5cb2e2a18d07">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 January 2017	cnwma1	Initial creation

*/

vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_EventServiceBroker::myChildQuantityMap.name  or 
	propName = CM_EventServiceBroker::myEventType.name 
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
