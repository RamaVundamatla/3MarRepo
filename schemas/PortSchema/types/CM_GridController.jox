    <JadeMethod name="isOverDimensions" id="6b249b5b-b211-45a7-9e45-10fbfd533452">
        <source>isOverDimensions(_yaAgent :CM_YAAutoplanAgent input): Boolean;
//27 October 2010	cnwml2
//PAR 25712
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	topTI : CM_TrackedItem;
begin

	if not _yaAgent.isOnlyCheckRealCargo then		// PAR 28770 
		topTI := self.getTopTI(QUEUE_MODE);
	endif;
	
	if topTI = null then
		topTI := self.getTopTI(REAL_MODE);	
	endif;

	if topTI = null then
		return false;
	endif;
	

	if topTI.isOverDimensions then
		_yaAgent.addLogEntry(AP_Log_YA_Default,"You are trying to place cargo on top of " &amp; topTI.id.trimRight &amp; " which is Overdimensional", true);
		return true;
	endif;
	
epilog

end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOverStowedVoyageJob" id="4efe5d0f-e9eb-40e5-b214-1d986d7423ef">
        <source>isOverStowedVoyageJob(_ti : CM_TrackedItem): Boolean;
// ---------------------------------------------------------------------------
// Created:		October 2006 By Andrew Bishop cnwab1
//
// Purpose:		Used on  Job Operations. Makes item go RED is overstowed.
//					However it is OK to be overstowed by a TI for the same voyage and disch port, 
//					or if item  on top is for an earlier job for the same voyage
//
// ---------------------------------------------------------------------------
vars

	dischargePort	: String;
	voy				: CM_Voyage;
	ti				: CM_TrackedItem;
	aJob, oJob : CM_Job;
	aWLE, oWLE : CM_VoyageWLE;
	aJS, oJS : CM_JobSheet;
	aJobIdx,oJobIdx, aWLEidx, oWLEidx : Integer;
	localTis : CM_TIArray;	//10 Feb 2011	NDL	Par 26936
	overstowController : CMIF_OverstowController;
begin

//	if self.allTrackedItems.last = _ti then
	if self.allTrackedItems.last = _ti and not self.myTerminalArea.CM_GridArea.useSideAccessRules then	//10 Feb 2011	NDL	Par 26936
		return false;
	endif;

// ### PAR 21709	create reqs transient;// ### PAR 20559
	
	// GET INFO FOR PASSED IN TI
	voy 			:= _ti.myVoyage;
	dischargePort	:= _ti.dischargePort;
	
	aWLE := _ti.getVoyageWLEUnactioned(true);
	if aWLE = null then
		aWLE := _ti.getVoyageWLEUnactioned(false);
	endif;
	if aWLE &lt;&gt; null then
		aJob := aWLE.job;
		if aJob &lt;&gt; null then
			// ### PAR 20559
			// ### PAR 21709 reqs.clear();
			// ### PAR 21709 aJob.CM_VoyageJob.doSortReqsInToSeqOrder(reqs);
			aWLEidx := aWLE.getSeqNum(); // ### PAR 21709 reqs.indexOf(aWLE.myRequest.CM_SlotRequest);
			// ###	PAR 20559		
			aJS := aJob.myJobSheet;
			if aJS &lt;&gt; null then // PAR 26945
				aJobIdx := aJS.allJobsByOrder.indexOf(aJob);
			endif;
		endif;
	endif;
	
	create localTis transient;
	//epr TFS 37584 4/5/18
	create overstowController transient;
	overstowController.setParams(null,_ti,false,null,null);
	overstowController.getAllOverstows();
	
	overstowController.allOverstowTIs.copy(localTis);
	
//	foreach ti in self.allTrackedItems reversed, discreteLock do 
	foreach ti in localTis reversed, discreteLock do //10 Feb 2011	NDL	Par 26936

		// ####
	    // GET INFO FOR TIs ON TOP
		oJob := null;
		oJS := null;
		oJobIdx := 9999999;
		oWLEidx := 9999999;// ### PAR 20559
		oWLE := ti.getVoyageWLEUnactioned(true); // LOAD
		if oWLE = null then
			oWLE := ti.getVoyageWLEUnactioned(false); // DISCHARGE
		endif;
		if oWLE &lt;&gt; null then
			oJob := oWLE.job;
			if oJob &lt;&gt; null then
				// ### PAR 20559
				// ### PAR 21709reqs.clear();
				// ### PAR 21709oJob.CM_VoyageJob.doSortReqsInToSeqOrder(reqs);
				oWLEidx := oWLE.getSeqNum(); // ### PAR 21709 reqs.indexOf(oWLE.myRequest.CM_SlotRequest);
				// ###	PAR 20559		
				oJS := oJob.myJobSheet;
				if oJS &lt;&gt; null then // PAR 26945
					oJobIdx := oJS.allJobsByOrder.indexOf(oJob);
				endif;
			endif;
		endif;
		// ####
		
		if ti = _ti then
			return false;
		elseif ti.myVoyage &lt;&gt; voy then
			return true;
		elseif ti.dischargePort &lt;&gt; dischargePort then
			if oJS &lt;&gt; aJS then // different crane
				return true;
			else // same crane
				if aJob &lt;&gt; oJob // different job
				and oJobIdx &gt; aJobIdx then // container on top is in a job that is after my job
					return true;
				endif;
			endif;
		else // same voyage same disch port
			if oJS &lt;&gt; aJS then // different crane
				return true;
			else // same crane
				if aJob &lt;&gt; oJob then // different job
					if oJobIdx &gt; aJobIdx then // container on top is in a job that is after my job
						return true;
					else
						return false;
					endif;
				else // same job // ### PAR 20559
					if oWLEidx &gt; aWLEidx then // ### PAR 20559 container on top is in same job but the sequence after my sequence
						return true;// ### PAR 20559
					else
						continue;// ### PAR 20559
					endif;
				endif;
			endif;
		endif;
	endforeach;

	return false;

epilog
	// ### PAR 21709 delete reqs;
	delete localTis;	//10 Feb 2011	NDL	Par 26936
	delete overstowController;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
