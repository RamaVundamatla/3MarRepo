    <JadeMethod name="createDamageInstance" id="ecdf4300-d292-475e-9e0d-472cf4ff60a6">
        <source>createDamageInstance(_damageCmb, _severityCmb : ComboBox; 
					 _damageInstanceDict : MobileHandHeldThin::CM_DamageInstanceByDmgePos input) protected;
					 //_damageInstanceDict : MobileHandHeldThin::CM_DamageInstanceByLocDict input) protected;
/*
----------   ----------  --------------------------------------------------
Created:	20 September 2006 By cnwth2

Purpose:	

Changed On  Changed By  Reason
26/08/2009 	cnwsh3 		CCMS SFW1066 PAR20321 - Recording Damage Details - method signature changed to use CM_DamagePosition object dict.
01/07/2022  navak20 ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
----------   ----------  --------------------------------------------------
*/
vars
	damageDefCode			: MobileHandHeldThin::CM_DamageDefinitionCode;
	damageInstance			: MobileHandHeldThin::CM_DamageInstance;
	damagePosition			: MobileHandHeldThin::CM_DamagePosition;
	remarks					: String;
	quantity				: Integer;
	isNewDamage				: Boolean;
	isRepaired				: Boolean;
begin
	damageDefCode := _damageCmb.listObject.MobileHandHeldThin::CM_DamageDefinitionCode;
	
	if damageDefCode = null then
		return;
	endif;
	
	create damageInstance transient;

	damageInstance.setProxy(null, 
							null,
							damageDefCode,
							damagePosition,//_damageCmb.tag.Integer,
							remarks,
							isNewDamage,
							quantity,
							//_severityCmb.text.Integer,		// 11.07.2022 navak20 TFS 53862
							//isRepaired,						// 11.07.2022 navak20 TFS 53862
							//null	//_locationStr 	: String	01 Mar 2016	NDL	TFS 1593		// 11.07.2022 navak20 TFS 53862
							null,	// 11.07.2022 navak20 TFS 53862
							null,	//_locationStr 	: String	01 Mar 2016	NDL	TFS 1593
							null, null, null, null, null, null, null, null, null	//July 1, 2022 navak20 TFS 53862
							);
	_damageInstanceDict.add(damageInstance);
end;


</source>
        <access>protected</access>
        <Parameter name="_damageCmb" type="ComboBox"/>
        <Parameter name="_severityCmb" type="ComboBox"/>
        <Parameter name="_damageInstanceDict" type="MobileHandHeldThin::CM_DamageInstanceByDmgePos" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doApplyErrors" id="4801df0c-593f-41b8-87b6-ed1588b6f608">
        <source>doApplyErrors(_errorMsgs : MobileHandHeldThin::DTO_HandHeldGateErrorDict) protected;
/*
----------   ----------  --------------------------------------------------
Created:	14 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	
	errorMsg		: MobileHandHeldThin::DTO_HandHeldGateError;
	str				: String;
begin
	
	foreach errorMsg in _errorMsgs do
		str := str &amp; errorMsg.errorDescr &amp; '.' &amp; CrLf;
		//th2 doesn't seem to be a way including global constants from port schema into
		//the MobileHandHeldThin package
		//foward container fields
		if errorMsg.errorNo = 82135 then //Err_GateFoward_Id
			self.clearFowardContainerId();
		elseif errorMsg.errorNo = 82137 then //Err_Gate_FowardCustSeal
			self.clearFowardContainerSealCust();
		elseif errorMsg.errorNo = 82138 then //Err_Gate_FowardOpSeal
			self.clearFowardContainerSealOp();
		elseif errorMsg.errorNo = 82139 then //Err_Gate_FowardShipSeal
			self.clearFowardContainerSealShip();
			
		//aft container fields
		elseif errorMsg.errorNo = 82136 then //Err_Gate_AftId
			self.clearAftContainerId();
		elseif errorMsg.errorNo = 82141 then //Err_Gate_AftCustSeal
			self.clearAftContainerSealCust();
		elseif errorMsg.errorNo = 82140 then //Err_Gate_AftOpSeal
			self.clearAftContainerSealOp();
		elseif errorMsg.errorNo = 82142 then //Err_Gate_AftShipSeal
			self.clearAftContainerSealShip();
		endif;
	endforeach;
	//app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '-assigning error text "' &amp; str &amp; '"');
	self.txtWrongData.text := str;
end;


</source>
        <access>protected</access>
        <Parameter name="_errorMsgs" type="MobileHandHeldThin::DTO_HandHeldGateErrorDict"/>
    </JadeMethod>
    <JadeMethod name="doCheckImport" id="cc0dca89-22ed-4662-bc15-5e3a3b37a99f">
        <source>doCheckImport(_fwd : Boolean; _id : String);

vars
begin
	if _id.length &gt; 10 then
		if app.myHandHeldShipLanderGuiAgent.myHandHeldShipLanderAgent.isContainerImport(_id) then
			self.enableSeals(false,_fwd, true);
		else
			self.enableSeals(false,_fwd, false);
		endif;
	elseif _id = null then
			self.enableSeals(true,_fwd, true);
	endif;

end;
</source>
        <Parameter name="_fwd" type="Boolean"/>
        <Parameter name="_id" type="String"/>
    </JadeMethod>
