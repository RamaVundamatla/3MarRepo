    <JadeMethod name="cmbVoyage_lostFocus" id="eeb9fa12-feaf-499f-8a2c-3171d089f175">
        <controlMethod name="ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbVoyage_lostFocus(combobox: ComboBox input) updating;
//--------------------------------------------------------------
//Created: 11 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	logAss : LOG_Assistant;
begin

	self.tblHeaderDtls.setValueByControlName(combobox.name, combobox.text);
	if origValueStr &lt;&gt; combobox.text then
		self.filterVoyage := combobox.listObject .CM_Voyage; //self.myAssistant.getVoyageFromCombo(combobox.text).CM_LogVoyage;
		if self.filterVoyage &lt;&gt; null then
			logAss := self.myAssistant.LOG_Assistant;
			logAss.comboBoxLogVoyageLots(cmbLot, self.filterVoyage, null);
			cmbLot.lostFocus(cmbLot);
			self.setNavigatorHeading(self.filterVoyage.code);
			//logAss.comboBoxAssignedLocations(self.cmbLocations, self.filterVoyage, null);		// 26/05/2010 cnwar2 #24188
			//cmbLocations.lostFocus(cmbLocations);												// moved to setupShtLocationDtls
			logAss.comboBoxVoyageOperator(self.cmbSupplier, null,self. filterVoyage);
			cmbSupplier.lostFocus(cmbSupplier);			
		endif;
	endif;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
