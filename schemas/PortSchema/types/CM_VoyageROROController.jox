    <JadeMethod name="updateRORORequestAttribute" id="e5121ae5-20b0-48d2-a3e8-bde51e684ec1">
        <updating/>
        <source>updateRORORequestAttribute(_isLoad : Boolean; _loadCC : CMIF_LoadColorCode input; _moveType : Integer; _passport : CM_Passport input) : CM_RORORequest updating;
/*
Purpose:			
Date				Who			Reason
NOVEMBER 2011		CNWAB1		Initial creation
*/

vars
	theLinkedRequest,
	pxySlotRequest,
	realSlotRequest	: CM_RORORequest;
	tmpSlot,
	theLinkedSlot	: CM_VoyageROROController;
	theTI			: CM_TrackedItem;
	theMoveType,
	voyUpdEvent		: Integer;
	tmpVoyage		: CM_Voyage;
	isCreate,
	needAftRequest	: Boolean;
	is53 			: Boolean;		
	wle				: CM_WorkListEntry;
	trans			: Boolean;			
	voyAlloc : CM_VoyageAllocation;
begin
	tmpVoyage 	:= self.myVoyage;
	voyUpdEvent := _passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA);

	if _isLoad then
		realSlotRequest := self.myRORORequestLoad;
	else
		realSlotRequest := self.myRORORequestDischarge;
	endif;
	if realSlotRequest &lt;&gt; null then
		if realSlotRequest.isComplete then
			realSlotRequest := null; 
		endif;
		
		if realSlotRequest &lt;&gt; null then
			if realSlotRequest.getAttrIsBackend() then // 40 backs are not included in jobs so do not get completed, so check the forward slot
				if realSlotRequest.getFwdSlotReq() &lt;&gt; null and realSlotRequest.getFwdSlotReq.isComplete then
					realSlotRequest := null;
				endif;
			// if front end then need to check that back end doesn't already have something in it
			else
				if _isLoad and _loadCC &lt;&gt; null and _loadCC.myBulkReleaseReserveDetail &lt;&gt; null then
					// PAR #26426 create a persistent TBA TI so we can track it in the Ship Load List form
					//theTI := _loadCC.myBulkReleaseReserveDetail.createPlanningTrackedItem(self.getStowageId(null), self);			// PAR #26426
					if self.myTerminal.getConfig(ShowRelReqOnShipLoadList).Boolean then												// PAR #26426
						trans := false;																								// PAR #26426
					else																											// PAR #26426
						trans := true;																								// PAR #26426
					endif;																											// PAR #26426

					
					
					
					
					
//#########################					
//#########################					
//#########################					
//#########################					
//#########################					
//#########################					
//#########################					
//theTI := _loadCC.myBulkReleaseReserveDetail.createPlanningTrackedItem(self.getStowageId(null), self, trans);	



// NEED TO DO
















					// PAR #26426 if we have a wle attached, assign the TBA TI to it, and set bulk release details
					if realSlotRequest.allWorkListEntries.size = 1 then
						wle := realSlotRequest.allWorkListEntries.first;
						// only asign the TBA TI if its persitent
						if not trans then
							wle.assignTIandBOL(theTI, null);
						endif;
						// we're planned, so add request to bulk release "being actioned" collection
						if _loadCC.myBulkReleaseReserveDetail &lt;&gt; null then
							realSlotRequest.setMyOriginatingBulkRelease(_loadCC.myBulkReleaseReserveDetail.myReserveHeader);
						endif;
						// and update wle planned location
						wle.setLocations(null, self.getStowageId(null));
					endif;
					// PAR #26426 end
					if realSlotRequest.myROROController.has20FTInBackend(theTI) then
						return realSlotRequest;
					endif;
				endif;
				// 13/07/2010 cnwmh5 #24827 - End
			endif;
		endif;
	endif;

	if realSlotRequest = null or 
	   (realSlotRequest &lt;&gt; null and
	   realSlotRequest.myJob &lt;&gt; null and
	   realSlotRequest.myJob.isJobComplete) then // REWORK JOB
	   
		realSlotRequest := null;
	   	isCreate := true;

		if _isLoad then
			if _loadCC &lt;&gt; null then
				voyAlloc := _loadCC.createAllocationFromLoadCC(LOAD_MOVETYPE, self);
			endif;
		endif;

		realSlotRequest := self.updateRORORequestVA(_isLoad, voyAlloc, _loadCC.quantity, _moveType, _passport);

		if _passport.hasErrors then
			// something went wrong in the above set
			return null;
		endif;
		
	endif;
	return realSlotRequest;

epilog
	delete pxySlotRequest;
	
	//07 Jan 2011	NDL	Transient leak in unit test UT_VoyageOps MtReleaseUsingHatchman
	if trans then
		if theTI &lt;&gt; null and theTI.isTransient then
			if not theTI.allJobsShipRelease.isEmpty then
				theTI.allJobsShipRelease.purge;
			endif;
			delete theTI;
		endif;
	endif;
end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_loadCC" type="CMIF_LoadColorCode" usage="input"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_RORORequest"/>
    </JadeMethod>
    <JadeMethod name="updateRORORequestVA" id="81361acb-42a5-4867-9c6d-579525074aa9">
        <updating/>
        <source>updateRORORequestVA(_isLoad : Boolean; _voyAlloc : CM_VoyageAllocation; _numItems : Integer; _moveType : Integer; _passport : CM_Passport input): CM_RORORequest updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 December 2009	cnwas3	Initial creation

*/

vars
	theLinkedRequest,
	pxyRequest,
	realRequest	: CM_RORORequest;
	tmpSlot,
	theLinkedSlot	: CM_VoyageROROController;
	theTI			: CM_TrackedItem;
	theMoveType,
	voyUpdEvent		: Integer;
	tmpVoyage		: CM_Voyage;
	isCreate,
	needAftRequest	: Boolean;
	
begin

	realRequest := self.createUpdateRORORequest(_isLoad, _voyAlloc, _numItems, _moveType, null, _passport); // PAR 28585
	/*
	tmpVoyage := self.myVoyage;

	voyUpdEvent := _passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA);
	
	if _isLoad then
		realRequest := self.myRORORequestLoad;
	else
		realRequest := self.myRORORequestDischarge;
	endif;	
	
	
	if realRequest = null or 
	   (realRequest &lt;&gt; null and
	   realRequest.myJob &lt;&gt; null and
	   realRequest.myJob.isJobComplete) then // REWORK JOB
	   
		realRequest := null;
	   	isCreate := true;

		// we need to create a request
		create pxyRequest as self.getRequestClass() transient;
		pxyRequest.setProxyForCreateVA(self, LOAD_MOVETYPE, _isLoad,_numItems,_voyAlloc);		
		if _passport.hasErrors then
			// something went wrong in the above set
			return null;
		endif;
	else
		pxyRequest := realRequest.pxyCreateUpdateProxy();
		pxyRequest.setProxyForCreateVA(self, LOAD_MOVETYPE, _isLoad,_numItems,_voyAlloc);		
	endif;

	theMoveType := pxyRequest.moveType;

	if theMoveType = NULL_MOVETYPE then
		if _isLoad then
			theMoveType := LOAD_MOVETYPE;
		else
			theMoveType := DISCHARGE_MOVETYPE;
		endif;
		pxyRequest.setMoveType(theMoveType);		
	endif;
	

	if isCreate then
		app.myUtilityCA.utlCreateSlotRequestRORO(pxyRequest, realRequest, _passport);
	else
		app.myUtilityUA.utlUpdateSlotRequestRORO(pxyRequest, _passport, true);
	endif;
	
	*/
	return realRequest;

epilog
	delete pxyRequest;
end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_voyAlloc" type="CM_VoyageAllocation"/>
        <Parameter name="_numItems" type="Integer"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_RORORequest"/>
    </JadeMethod>
    <JadeMethod name="updateSlotRequestDLRSOB" id="b9e8a067-f7d0-40db-b595-5f38a4449b9d">
        <updating/>
        <source>updateSlotRequestDLRSOB(_isLoad : Boolean; _moveType : Integer; _passport : CM_Passport input) : CM_RORORequest updating;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/

vars
	theLinkedRequest,
	realSlotRequest, fwdReq, aftReq	: CM_RORORequest;
	tmpSlot,
	theLinkedSlot	: CM_VoyageROROController;
	theTI			: CM_TrackedItem;
	theMoveType,
	voyUpdEvent		: Integer;
	tmpVoyage		: CM_Voyage;
	isCreate,
	needAftRequest	: Boolean;
	is53 			: Boolean;			//cnwas3 PAR 24273
	wle				: CM_WorkListEntry;	// PAR #26426
	trans			: Boolean;			// PAR #26426

begin
	// PAR 30388 tmpVoyage 	:= self.myDeck.myVoyageStructure.myVoyage;
	tmpVoyage := self.getMyVoyage();
	voyUpdEvent := _passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA);

	if _isLoad then
		realSlotRequest := self.myRORORequestLoad;
	else
		realSlotRequest := self.myRORORequestDischarge;
		if realSlotRequest = null then
			self.createDischargeCC(_moveType, true, _passport);
			realSlotRequest := self.myRORORequestDischarge;
			app.myEventManager.createSingleObjInfoNoteEvt(tmpVoyage,	voyUpdEvent, self); // PAR 31144
			return realSlotRequest;
		endif;
	endif;

	
	if realSlotRequest &lt;&gt; null then
		if realSlotRequest.isComplete then
			realSlotRequest := null; 
		endif;
		
		if realSlotRequest &lt;&gt; null then
			if realSlotRequest.isBackEndRequest() then // 40 backs are not included in jobs so do not get completed, so check the forward slot
				fwdReq := realSlotRequest.getFwdSlotReq().CM_RORORequest;
				if fwdReq &lt;&gt; null and fwdReq.isComplete then
					realSlotRequest := null;
				endif;
			endif;
		endif;
	endif;
	
	if realSlotRequest &lt;&gt; null then
		exclusiveLock(realSlotRequest);
		if realSlotRequest.isBackEndRequest() then
			app.raiseCMException1(SlotRequestUpdateFromBack, self.getFullId, null, null);
			return realSlotRequest;
		endif;
		/* PAR 33585 stop the SOB / DLR being a toggle - always set it.
		if realSlotRequest.isRehandle or realSlotRequest.isSoB then
			realSlotRequest.setMoveType(NULL_MOVETYPE); 
			app.myEventManager.createSingleObjInfoNoteEvt(tmpVoyage,	voyUpdEvent, self); // PAR 32223
			if realSlotRequest.isDischarge then
				realSlotRequest.setLinkedRequest(null);
			endif;
		else
		*/
			// PAR 33585 if changing a linked slot from DLR to SOB then change the linked item as well
			if (realSlotRequest.isRehandle and _moveType = SOB_MOVETYPE)
			or (realSlotRequest.isSoB and _moveType = DLR_MOVETYPE) then
				if realSlotRequest.isLinked() then
					if realSlotRequest.myRequestLinkedDischarge &lt;&gt; null then
						realSlotRequest.myRequestLinkedDischarge.setMoveType(_moveType); 
					elseif realSlotRequest.myRequestLinkedLoad &lt;&gt; null then
						realSlotRequest.myRequestLinkedLoad.setMoveType(_moveType); 
					endif;
				endif;
			endif;

			realSlotRequest.setMoveType(_moveType); //SOB_MOVETYPE DLR_MOVETYPE
			app.myEventManager.createSingleObjInfoNoteEvt(tmpVoyage,	voyUpdEvent, self); // PAR 31144
		//endif;
	else // PAR 32223
		if _isLoad then
		else
			self.createDischargeCC(_moveType, true, _passport);
			app.myEventManager.createSingleObjInfoNoteEvt(tmpVoyage,	voyUpdEvent, self); // TIDY UP
			
			return self.myRORORequestDischarge;
		endif;
	endif;

	return realSlotRequest;

epilog
	
end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_RORORequest"/>
    </JadeMethod>
    <JadeMethod name="validateForEDIDischarge" id="12b6a75f-4332-46c7-adbb-d3d969cd1ebc">
        <source>validateForEDIDischarge(_ediStowAdviceTI: CM_EDIStowAdviceTI): Boolean;
/*
Purpose:			
Date				Who			Reason
NOVEMBER 2011		CNWAB1		Initial creation
*/

vars
	found 			: Boolean;
	ti				: CM_TrackedItem;
	slotReqDisch	: CM_RORORequest;
	tmpStowAdviceTI	: CM_EDIStowAdviceTI;
begin

	tmpStowAdviceTI := _ediStowAdviceTI;
	
	if (not self.allTrackedItems.isEmpty) then
		found := false;
		foreach ti in self.allTrackedItems do
			if ti.id = tmpStowAdviceTI.id then
				found := true;
				break;
			endif;
		endforeach;
		if not found then
			//was a warning in 731 - user can now edit ID's in 732 so make it an error
			app.raiseCMException2(ERR_STOWAGE_FIELD, tmpStowAdviceTI.id, "DLR tracked item id'.  It does not match the item in this position "
									&amp; tmpStowAdviceTI.stowageId &amp; ", '" &amp; ti.id, 'Stowage', tmpStowAdviceTI);
			return false;
		endif;
	endif;
	
	//disch for DLR
	slotReqDisch := self.myRORORequestDischarge;
	if slotReqDisch &lt;&gt; null then
		if not (slotReqDisch.isLinked and slotReqDisch.isRehandle) then	//linked DLR discharges will be deleted so ignore
			if slotReqDisch.myJob = null then
				app.raiseCMException3(ERR_SLOT_REQUEST_DEFINED, self.getFullId,"Discharge","Job Not Created", 'Stowage', tmpStowAdviceTI);
				return false;
			elseif slotReqDisch.myJob.isJobComplete = false then
				app.raiseCMException3(ERR_SLOT_REQUEST_DEFINED, self.getFullId,"Discharge",slotReqDisch.myJob.jobId, 'Stowage', tmpStowAdviceTI);
				return false;
			endif;
		endif;
	endif;

	return true;
	
end;</source>
        <Parameter name="_ediStowAdviceTI" type="CM_EDIStowAdviceTI"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForEDILoad" id="7a5ce7ec-6697-4c50-af8c-1f24e98464af">
        <source>validateForEDILoad(_ediStowAdviceTI: CM_EDIStowAdviceTI; dlrIDs: StringArray; _ignoreNotMarkedDisch: Boolean): Boolean;
/*
Purpose:			
Date				Who			Reason
NOVEMBER 2011		CNWAB1		Initial creation
*/

vars
begin
	
	if (not _ignoreNotMarkedDisch)
	and self.allTrackedItems.isNotEmpty
	and self.myRORORequestDischarge = null then
		if not dlrIDs.includes(self.allTrackedItems.first.id) then
			app.raiseCMWarning1(WARN_CCSLOT_TRA_PRESENT, self.getStowageId(null) &amp; " (load)", 'Stowage', _ediStowAdviceTI, self);
			return false;
		endif;
	endif;

	return true;
	
end;</source>
        <Parameter name="_ediStowAdviceTI" type="CM_EDIStowAdviceTI"/>
        <Parameter name="dlrIDs" type="StringArray"/>
        <Parameter name="_ignoreNotMarkedDisch" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateLoadCCDischargePort" id="412672c8-5b19-4c0f-b188-ddad6d4a5cc6">
        <source>validateLoadCCDischargePort(_dischargePort : CM_Port);
/*
Purpose:			
Date		Who		Reason
04 August 2011	cnwab1	Initial creation
*/

vars

	tmpSlotDefn : CM_ROROSlotDefn;
	disPort : CM_Port;
	slotIter : Iterator;
	pocCurrentOrder,
	pocNewOrder : Integer;
	voy : CM_Voyage;
begin
	voy := self.myDeck.CM_DeckVoyage.myVoyageStructure.myVoyage;
	if voy = null then
		return;
	endif;
	pocCurrentOrder := voy.allPorts.indexOf(_dischargePort);


epilog



end;</source>
        <Parameter name="_dischargePort" type="CM_Port"/>
    </JadeMethod>
    <JadeMethod name="validateMoveFrom" id="d353614a-eafb-45b9-9259-d89bc924b0af">
        <source>validateMoveFrom(control: CMIF_MoveController);
// ---------------------------------------------------------------------------
// Created:     02 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpTI : CM_TrackedItem;
	term : CM_Terminal;
begin
	inheritMethod(control);

	self.validateSlotRequestMoveFrom(control);
					
end;</source>
        <Parameter name="control" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="validateMoveTo" id="6c40a049-d9e6-4d58-8be6-53f6efb7de48">
        <source>validateMoveTo(control: CMIF_MoveController input);
/*
 ------------------------------------------------------------------------
Created:			24 September 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
----------		----------		-----------------------------------------
15/04/2024		navdap1			TFS 63688 MSL Warning Related to Exceeding the Maximum Pile Weight
---------------------------------------------------------------------------
*/
vars
	lc	: CM_LocationsController;
	theTI, tmpTI, onshipTI	: CM_TrackedItem;
	tmpFM : CM_FutureMove;
	tmpWLE : CM_WorkListEntry;
	thisJob,
	job : CM_Job;
	fromLC	: CM_LocationsController; 
begin
	theTI := control.myTrackedItem;
	if self = control.myToPrimaryLocation then
		inheritMethod(control);
		if control.moveMode = REAL_MODE and theTI.isRehandle then
			if theTI.isOnShip then
				if control.myWorkListEntry &lt;&gt; null then
					thisJob := control.myWorkListEntry.job;
				endif;
				// its on the ship but check if the discharge DLR has completed
				if thisJob = null then
					//It must be a shift on board move, carry on...
				elseif thisJob.jobType = JOB_TYPE_SOB then
					// Carry on..					
				else
					foreach job in theTI.allJobsShipReceive do
						if job = thisJob then
							continue;
						endif;
						if job.isRelease then
							// Belts and braces - You never know, Ignore the Load job.
							continue;
						endif;
						if not job.isJobComplete then
							// Error, cannot move DLR to ship as it is still on the ship
							app.raiseCMException2(TI_DLRDischargeNotComplete, theTI.id, job.jobId, null, null);				
							return;
						endif;			
					endforeach;
				endif;
			endif;
		endif;
		
		// ## PAR 25513
		if control.moveMode = REAL_MODE  then
			if not self.myTerminal.getConfig(ShipAllowLoadifnoDisch).Boolean then
				if self.myRORORequestDischarge &lt;&gt; null then
					tmpTI := self.myRORORequestDischarge.getTrackedItem();
					if tmpTI &lt;&gt; null then
						onshipTI := self.allTrackedItems.first;
						if tmpTI = onshipTI and onshipTI &lt;&gt; null then
							app.raiseCMException3(Cargo_that_locat_colou_coded_d, onshipTI.id, self.getFullId(),theTI.id, null, null);
						endif;
					endif;
				endif;
			endif;
		endif;
		// ## PAR 25513
		if control.moveMode = QUEUE_MODE  then
			if not self.myTerminal.getConfig(ShipAllowLoadifnoDisch).Boolean then
				if self.myRORORequestDischarge &lt;&gt; null then
					tmpWLE := self.myRORORequestDischarge.allWorkListEntries.first;
					if tmpWLE &lt;&gt; null then
						tmpFM := tmpWLE.myFutureMove;
						if tmpFM &lt;&gt; null then
							if tmpFM.moveType &lt;&gt; TI_FutureMoveQueued then
								tmpFM := null;
							endif;
						endif;
						if tmpFM = null then
							onshipTI := self.allTrackedItems.first;
							if onshipTI &lt;&gt; null then
								app.raiseCMException3(Cargo_that_locat_colou_codedee, onshipTI.id, self.getFullId(),theTI.id, null, null);
							endif;
						endif;
					endif;
				endif;
			endif;
		endif;
		
		//03 Nov 2014	NDL	Par 35017 - migrated down from CM_VoyageController
		if control.moveMode = QUEUE_MODE or  control.moveMode = PLANNING_MODE then
			if fromLC &lt;&gt; null and (fromLC.isWagon or fromLC.isVehicle) then
				if control.moveMode = QUEUE_MODE then
					app.raiseCMException(NoQueue_Rail_To_Voyage, null, null);
				endif;
			endif;
		endif;
		
		//------------------- RE-ENTRANT PROTECTION PORTION - CALLED ONCE -----------------------------
		//As the primary target we have already been locked by the control object.
		//(or by the caller)
		//-------------------
		//------------------
		//get the extent of the TI in terms of other LC's of this type we have to span
		//------------------
		if not self.getSpannedToLCs(control) then
			//Not enough space!
			app.raiseCMException2(Err_MoveSize, theTI.id, self.getFullId(), null, null);
			return;	
		endif;
		//------------------
		//check each one of these, RENTRANT call.
		//------------------
		control.doToSecondaryLocationsLock();

		foreach lc in control.myToSecondaryLocations do
			lc.validateMoveTo(control);			
		endforeach;
		
		// 12/07/2010 cnwmh5 #24827 - Start
		//---------------------------
		// Check to see nothing in backend
		//---------------------------
		if control.myTrackedItem &lt;&gt; null then
			self.has20FTInBackend(control.myTrackedItem) ;
		endif;
		// 12/07/2010 cnwmh5 #24827 - End
		
	endif;
	
	// DVB put this here so a forced move still sets up secondary locations. 02/09/03
	if control.isForcedMove then
		return;
	endif;
	//------------------------
	//This is the standard stuff to validate any move here	
	//------------------------
	if self.includesTI(theTI, control.moveMode) then
		//-----------------
		//If the TI is already here, then simply return. They must be shifting it?
		//-----------------
		return;
	endif;
	
	//---------------------------
	// Check it is compatible with slot request/job
	//---------------------------
	self.validateSlotRequestMoveTo(control);
	
	//-------------------------
	//Perform these tests only once
	//-------------------------
	if self &lt;&gt; control.myToPrimaryLocation then
		return;
	endif;

	
	if control.indexForEDIBayPlan &lt;&gt; 0 then
		//If this is a real EDI move (make actual), ignore the checks below
	else
		if control.moveMode = REAL_MODE then 
			self.testPileWeight(theTI,ShpDisplayMode_Actual);	
		elseif control.moveMode = QUEUE_MODE then 				// TFS 63688
			self.testPileWeight(theTI,ShpDisplayMode_Queued);	// TFS 63688
		else
			self.testPileWeight(theTI,ShpDisplayMode_Proposed);	
		endif;

		self.testPileHeight(theTI);	
		self.testPileHazardous(theTI);	
		
	endif;

	
end;</source>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateRequestDelete" id="2fc7542e-9639-4f12-9492-69dd70e2caab">
        <source>validateRequestDelete(_isLoad : Boolean);
/*
Purpose:			
Date		Who		Reason
28 June 2011	cnwab1	Initial creation
*/

vars
	expectedEdition : Integer;
	tmpRequest : CM_RORORequest;
	plnTI : CM_TrackedItem;
begin

		exclusiveLock(self);
		
//		if tmpSlot.edition &lt;&gt; expectedEdition then
//			app.raiseCMException1(ObjectUpdatedByAnotherUserSave, app.getErrorString(Slot) &amp; ' ' &amp; tmpSlot.ident, null, null);
//			return;
//		endif;

	if _isLoad then
		tmpRequest := self.myRORORequestLoad;
	else
		tmpRequest := self.myRORORequestDischarge;
	endif;
	
	if tmpRequest &lt;&gt; null then
		if tmpRequest.myJob &lt;&gt; null then
			if tmpRequest.myJob.CM_VoyageJob.isLoadedToOperations then
				app.raiseCMException1(ERR_JOB_LOADED, tmpRequest.myJob.jobId, null, null);
				return;
			elseif tmpRequest.isLoad then	
				plnTI := tmpRequest.getTIofMode(PLANNING_MODE);	// PAR 25517																					// 17/05/2010 cnwmh5 #24149
				if plnTI &lt;&gt; null then	// PAR 25517
					app.raiseCMWarning1(Colour_coding_being_erased_pla,plnTI.id , null, null, null);		// 17/05/2010 cnwmh5 #24149
				endif;
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateSlotRequestMoveFrom" id="9a998478-9a60-4e5a-9aec-f738a2fefeca">
        <source>validateSlotRequestMoveFrom(control : CMIF_MoveController) protected;
/*
------------------------------------------------------------------------
Created:			18 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	tmpRequestDich	: CM_RORORequest;
	moveTI, dischargeTI : CM_TrackedItem;
begin
	moveTI := control.myTrackedItem;
	
	tmpRequestDich := self.myRORORequestDischarge;
	if tmpRequestDich = null then
		if (not self.isOnboardMove(control)) and 
		   control.moveMode = REAL_MODE and
		   control.myToPrimaryLocation &lt;&gt; null then		// added as doing a shuffle moves to null before moving back in correct order
			if control.isForcedMove = false then
				app.raiseCMException5(Err_NoColourCode, self.getFullId, app.getErrorString(Discharge), app.getErrorString(Discharge), moveTI.id, 'from this slot', null, null);
				return;
			endif;
		endif;
	else
		dischargeTI := tmpRequestDich.getTrackedItem();
		// only stop the instant move if the discharge CC is for the TI that we are moving
		if self.isOnboardMove(control) 
		and control.moveMode = REAL_MODE
		and moveTI = dischargeTI
		and (not tmpRequestDich.isComplete)
		// SOB has a discharge slot request and is a move onboard!!! At some point the user will want to actually move the cargo!!!!!
		and (not tmpRequestDich.isSOB)
		and (not dischargeTI.directDelivery)	//07 Feb 2013	NDL	Par 31102
		then 
			// prevent an onboard move instant if the slot has been marked up
			// for discharge
			app.raiseCMException1(SlotMarkedForDischCannotMove, self.ident, null, null);
			return;
		endif;
		
		
		if tmpRequestDich.myJob = null
		and control.isForcedMove = false
		and control.myToPrimaryLocation &lt;&gt; null then
			if control.moveMode &lt;&gt; REAL_MODE then
				if tmpRequestDich.moveType = NULL_MOVETYPE then
					return;
				else
					app.raiseCMException4(Err_SeqNoJob, self.getStowageId(moveTI), app.getErrorString(Discharge).toLower, moveTI.id, app.getErrorString(From).toLower, null, null);
					return;
				endif;
			elseif not self.isOnboardMove(control) then
				if tmpRequestDich.moveType = NULL_MOVETYPE then
					return;
				else
					app.raiseCMException4(Err_SeqNoJob, self.getStowageId(moveTI), app.getErrorString(Discharge).toLower, moveTI.id, app.getErrorString(From).toLower, null, null);
					return;
				endif;
			
			endif;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="control" type="CMIF_MoveController"/>
    </JadeMethod>
    <JadeMethod name="validateSlotRequestMoveTo" id="d7c32543-714d-42a8-816a-fd95bcb8d246">
        <source>validateSlotRequestMoveTo(_control : CMIF_MoveController input) protected;
/*
------------------------------------------------------------------------
Created:			18 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
------------------------------------------------------------------------
*/
vars
	fwdSlotRequest : CM_RORORequest;
	aOK : Boolean;
	sr : CM_RORORequest;
	ti	: CM_TrackedItem;
begin
	//We are moving TO this slotController, therefore we MUST have a load colour code
	sr := self.myRORORequestLoad;
	if sr = null then
		if self.isOnboardMove(_control) = false then	//If its not an onboard instant move...
			app.raiseCMException5(Err_NoColourCode, self.getFullId, app.getErrorString(Load), app.getErrorString(Load), _control.myTrackedItem.id, app.getErrorString(This_slot), null, null);
		endif;
		return;
	endif;
	
	// PAR 31878
	if _control.moveMode = PLANNING_MODE then
		if self.isOnboardMove(_control) = false then	//If its not an onboard instant move...
			if _control.myWorkListEntry = null then
				app.raiseCMException(Work_list_entry_ref,null, null);
				
			endif;
		endif;
	endif;
	
	if _control.moveMode = REAL_MODE then
		if sr.moveType = NULL_MOVETYPE then // AKB2003MAR added
			return;
		else
			
			if sr.myJob = null 
			and _control.isForcedMove = false
			and self.isOnboardMove(_control) = false then
				aOK := false;
				fwdSlotRequest := self.myRORORequestLoad.getFwdSlotReq().CM_RORORequest;
				// we have slot requests for the back ends of 40's but that slot request has no WLEs no job and no TI so check the forward slot for a 40 colour coded up
				if fwdSlotRequest &lt;&gt; null  and fwdSlotRequest.myJob &lt;&gt; null then
// PAR 30253					if (fwdSlotRequest.getAttrIs40()) then
					if (fwdSlotRequest.getAttrIsNOT20()) then
						aOK := true;
					endif;
				endif;
				if not aOK then
					app.raiseCMException4(Err_SeqNoJob, self.getStowageId(_control.myTrackedItem), app.getErrorString(Load).toLower, _control.myTrackedItem.id,app.getErrorString(To).toLower, null, null);
					return;
				endif;
			endif;
		endif;
	endif;
	// AKB2003NOV. When planning to the ship, i.e. LOAD colour coding, we have already validated the TI
	//					against the SlotRequest as part of assigning it to the job and the WLE, so do not do it again, 
	//					also we get the backend of 40s validating as well
	if _control.moveMode &lt;&gt; PLANNING_MODE then 
		sr.validateMoveTo(_control);
	else
		if (_control.myTrackedItem &lt;&gt; null) and
		   (_control.myTrackedItem.state = TI_STATE_NOTIFIED) then
			app.raiseCMWarning1(ERR_PLANMOVE_PRENOTE, _control.myTrackedItem.id, null, null, _control.myTrackedItem);
		endif;
	endif;
	
	
end;</source>
        <access>protected</access>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
</Class>
