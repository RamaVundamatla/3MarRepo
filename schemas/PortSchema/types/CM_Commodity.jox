    <JadeMethod name="getTextForAuditStrOnCargoType" id="74555b0e-48d7-48e7-9f3d-6e45df32a2ff">
        <source>getTextForAuditStrOnCargoType() : String;
/*

Purpose:			Returns Audit Text for Cargo Type

Parameters:			NONE

Return Value:		String:	Audit text to use for Cargo Type

Date		Who		Reason
03 June 2022	navpw1	Initial creation TFS: 53752

*/

begin
	return self.code &amp; "/" &amp; self.description &amp; Cr;
	
