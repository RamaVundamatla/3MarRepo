    <JadeMethod name="actionForCreate" id="852486c6-b76e-4076-9061-6fd72dd938fd">
        <updating/>
        <source>actionForCreate(pProxy: CM_Object io; _passport : CM_Passport input): Boolean updating;
//--------------------------------------------------------------
//Created: 13 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	request : CM_Request;
	job : CM_RoadJob;
begin

	self.myPersistentBOL := self.myTerminal.allBOLOutUnmatched.getAtKey(self.operatorCode, self.bolType, self.bolNumber);
	
	if self.myPersistentBOL = null then
		self.myPersistentBOL := self.myTerminal.createBillOfLading(self.myProxyBOL, _passport);
	endif;
	
	if self.transportMode = TI_TRANSMODE_ROAD
	and (self.bolType = BOLType_Log) then
		job := self.getInOutJob();
		if job = null then
			return false;
		endif;
		//Should change to setMyJobRecRel
		self.myPersistentBOL.setMyJobReceive(job);
	
		if _passport.noErrors then
			// create the request
			create self.myProxyBOLRequest transient;
			self.myProxyBOLRequest.setProxy(self.consigneeCode, null /* _consignorVoyageCode */,
										    self.myStockOrder.orderNo /* _deliveryNumber */,
										    null /* _eirNumber */,
											null /* _freightForwarderCode */,
										    null /* _freightPayerCode */,
										    false /* _isReceipt */,
										    null /* _reasonCode */,
										    null /* _reasonCodeDescr */,
										    null /* _remarks */,
										    true /* _removeStops */,
										    app.getMyUserCode,
										    null /* _voyageCode */,
										    job, self.myPersistentBOL);
		endif;
		
		if _passport.noErrors then	
			//Validate the request (TI is already validated)
			self.myProxyBOLRequest.validate(self.myUserObject);
		endif;
		
		if _passport.hasErrors() then
			return false;
		endif;

		//Add the request to the job		
		request := job.addRequest(self.myProxyBOLRequest, _passport);
		if request = null or _passport.hasErrors then
			return false;
		endif;
		
	endif;
	
	//archive associated weighBridge object if any
	if self.myLogDocketData &lt;&gt; null then
		app.myUtilityUA.utlUpdateLogDocketDataArchive(self.myLogDocketData, self.myPersistentBOL, _passport);	
	endif;

	if self.bolType = BOLType_GeneralDocket or self.bolType = BOLType_GeneralBillOfLading then
		self.actionForCreateGCBulkLoadOut(_passport);
	endif;		
	
epilog
	return _passport.noErrors();	
end;</source>
        <Parameter name="pProxy" type="CM_Object" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="actionForCreateGCBulkLoadOut" id="21d5aab4-5c5d-415b-a50b-35c0aa626285">
        <source>actionForCreateGCBulkLoadOut(_passport : CM_Passport input);
//--------------------------------------------------
// Created:	09 February 2006 By: cnwgd1
//--------------------------------------------------
vars
	newBBlk,
	tmpBBlk : CM_BreakBulkGeneric;
	obj : Object;
	line : CMIF_BOLOutLine;
	tiUpdCntrl : CMIF_TIUpdateController;	
begin

	if self.allBOLOutLines = null then
		return;
	endif;	
	if self.allBOLOutLines.isEmpty then
		return;
	endif;
	
	tiUpdCntrl := app.createTIUpdateControl(TI_UPDMODE_RELEASE, null, self.myUserObject);
	
	foreach obj in self.allBOLOutLines do
		if CMIF_BOLOutLine.hasInstance(obj) then
			line := obj.CMIF_BOLOutLine;
		else
			continue;
		endif;
		if CM_BreakBulkGeneric.hasInstance(line.myTrackedItem) then
			tmpBBlk := line.myTrackedItem.CM_BreakBulkGeneric;
		else
			continue;
		endif;
		
		if line.quantityTaken &lt; 1 then
			// haven't taken it so remove it otherwise it will be attached to the BOL and sent off site
			if self.allTrackedItems.includes(tmpBBlk) then
				self.allTrackedItems.remove(tmpBBlk);
			endif;					
			continue;
		endif;
		
		if tmpBBlk.quantity &lt;= line.quantityTaken then
			// they are taking it so add to collection so that it will be attached to the BOL and sent off site
			if (not self.allTrackedItems.includes(tmpBBlk)) then
				self.allTrackedItems.add(tmpBBlk);
			endif;
		else
			// only taken part of the quantity so we need to create a split TI
			newBBlk := tmpBBlk.cloneSelf(false);
			newBBlk.cloneReferences(tmpBBlk, tiUpdCntrl, _passport);
			newBBlk.setPropertyValue(CM_TrackedItem::quantity.name, line.quantityTaken);
			tmpBBlk.setPropertyValue(CM_TrackedItem::quantity.name, (tmpBBlk.quantity - line.quantityTaken));			
			self.allTrackedItems.add(newBBlk);
			if self.allTrackedItems.includes(tmpBBlk) then
				self.allTrackedItems.remove(tmpBBlk);
			endif;			
		endif;
		
	endforeach;

epilog
	delete tiUpdCntrl;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getBOLClass" id="6703b5c9-7ff8-492b-8355-9f1eb0b82ed5">
        <source>getBOLClass(): Class;
// ---------------------------------------------------------------------------
// Created:     24 June 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return CM_BOLOut;

end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="dd58237a-054e-488b-9ee2-b14ff59d4413">
        <updating/>
        <source>validateForCreate(_passport : CM_Passport input): Boolean updating;
//--------------------------------------------------------------
//Created: 14 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tiUpdCntrl		: CMIF_TIUpdateController;
	
begin

	self.myBOLType := app.myRoot.allBOLTypes[self.bolType];
	if self.myBOLType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Docket/Bill of Lading Type', 'bolType', self.myUserObject);
		app.raiseCMException(Input_required_field_dockBill, 'bolType', self.myUserObject); // cnwdb2	PAR 35364
		return _passport.noErrors();
	endif;
	if self.myTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal', 'terminal', self.myUserObject);
		app.raiseCMException(Input_required_field_terminal, 'terminal', self.myUserObject); // cnwdb2	PAR 35364
		return _passport.noErrors();
	endif;

	if self.myProxyBOL &lt;&gt; null then
		self.myProxyBOL.erase(NORMAL_ERASE);
		self.myProxyBOL := null;
	endif;
	
	self.myPersistentBOL := null;

	if self.bolType = BOLType_Log and self.transportMode = TI_TRANSMODE_ROAD then
		// An order is required for general BOLs (and must be validated here as there
		// is a collection of orders against a BOLOut, so there is no way to tell
		// if one has been added in this transaction just by validating the BOLOut).
		if self.myStockOrder = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Order Number', 'orderNumber', self.myUserObject); 
			app.raiseCMException(Input_required_field_OrderNum, 'orderNumber', self.myUserObject); // cnwdb2	PAR 35364
		endif;
	endif;

	if self.transportMode = TI_TRANSMODE_ROAD then
		if self.myIntFaceInOutCommon &lt;&gt; null then
			self.carrierCode := self.myIntFaceInOutCommon.carrierCode;
			self.regNumber := self.myIntFaceInOutCommon.regNumber;
		endif;
	endif;

	self.myProxyBOL := self.myTerminal.createBOL(CM_BOLOut, true);

	self.myProxyBOL.setPxyFromCMIF_BOL(self, _passport);

	tiUpdCntrl := app.createTIUpdateControl(TI_UPDMODE_RELEASE, null, self.myUserObject);

	self.myProxyBOL.validateForCreate(tiUpdCntrl, self.headerOnly, _passport);

epilog
	if tiUpdCntrl &lt;&gt; null then
		delete tiUpdCntrl;
	endif;
	return _passport.noErrors();
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreateSubClasses" id="d7a14fca-8bc1-4d1b-952d-cde43d69c8ee">
        <updating/>
        <source>validateForCreateSubClasses(_passport : CM_Passport input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     14 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tiUpdCntrl		: CMIF_TIUpdateController;
	
begin

	tiUpdCntrl := app.createTIUpdateControl(TI_UPDMODE_RECEIPT, _passport.userCode, self.myUserObject);
	self.myProxyBOL.validateForCreate(tiUpdCntrl, self.headerOnly, _passport);

epilog
	if tiUpdCntrl &lt;&gt; null then
		delete tiUpdCntrl;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="41dba965-dd53-4e8b-a502-2d6dcab52e30">
        <updating/>
        <source>validateForUpdate(_passport : CM_Passport input): Boolean updating;
//--------------------------------------------------------------
//Created: 12 July 2002 By: cnwsb1
//
//Purpose: Written for BOL Out Packed.  We wanted to use the same mechanism
//         for updates as creates - which means no proxy for the update.
//
//--------------------------------------------------------------
vars

begin

	inheritMethod(_passport);

	if self.myBulkRelease = null and
	   self.processOption = Process_Pack then
		if _passport.myTerminal &lt;&gt; null then
			if _passport.myTerminal.getConfig(BulkReleaseReqdForPack).Boolean then
				app.raiseCMException2(ERR_INVALID_VALUE,"Container Bulk Release","A Release Number must be entered.",null,null);
			endif;
		endif;
	endif;
	
	if self.myProxyBOL = null and
	   self.myPersistentBOL = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'proxy BOL / persistent BOL', null, self.myUserObject);
		app.raiseCMException(Input_required_field_proxBol, null, self.myUserObject);// cnwdb2	PAR 35364
		return _passport.noErrors();
	endif;
	
	if self.myProxyBOL = null then
		app.createUpdateProxy(self.myPersistentBOL);
	endif;
	
	self.myProxyBOL.setPxyFromCMIF_BOL(self, _passport);

	return _passport.noErrors;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
