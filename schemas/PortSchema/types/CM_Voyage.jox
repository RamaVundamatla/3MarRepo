    <JadeMethod name="getNumForEventType" id="4fe2828d-3ad0-45c6-8667-965ff3d4f3c7">
        <source>getNumForEventType(_eventType : Integer) : Integer protected;
/* ---------------------------------------------------------------------------
Created:     01 July 2010 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	event		: CM_EventTransaction;
	totNum		: Integer;
	
begin

	foreach event in self.allEventTransactionsByType 
			where event.type = _eventType do
		totNum := totNum + event.amount.Integer; //epr par 36902 14/6/15
	endforeach;

	return totNum;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_eventType" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
