    <JadeMethod name="initForm" id="7b8d533c-07eb-464a-a24b-24dea0992f30">
        <updating/>
        <source>initForm() updating;
// ---------------------------------------------------------------------------
// Created:     05 March 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed on	By			Reason
// ==========	==========	==================================================
// 11/08/2011	cnwdap1		PAR #27972 Bulk release type no longer translatable, replaced by string constants
// 20 May 2022	navak20	ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
//	17 Aug 2022 navtnr20 ChangeRequest 54441: EUP - Additional Field - Country of Origin
vars
	port : String;
	thePort : CM_Port;
begin
	//navsp1 15 Feb 2022 TFS#52839 -- start
	//if not self.openWithSavedSettings then					//+cnwml2 PAR22544
	//	self.mnuEnhanced.checked :=app.myPassport.myTerminal.getConfig(UseBookingSummView).Boolean;
	//endif;
	//navsp1 15 Feb 2022 TFS#52839 -- end
	inheritMethod();
	
	self.useTblDataContextMenu := true;
	self.showFilterOnStartup := true; 	// PAR 18160 - Show the filter frame
	self.showDataOnStartup 	:= false; 	// PAR 18160 - Do not populate the data table with data
	
	cmbTransportMode.sorted := false;
	cmbTransportMode.height := cmbTransportMode.height;

	

	//cmbTransportMode.addItem( app.getErrorString(BR_TYPE_DESCR_ROAD));  // cnwrd1 par 18519 6.3.09	// PAR #27972
	//cmbTransportMode.addItem( app.getErrorString(BR_TYPE_DESCR_RAIL));								// PAR #27972
	cmbTransportMode.addItem( BR_TYPE_ROAD_STR);  // cnwrd1 par 18519 6.3.09							// PAR #27972
	cmbTransportMode.addItem( BR_TYPE_RAIL_STR);														// PAR #27972
	cmbTransportMode.addItem( app.getErrorString(Road_rail));	
	cmbTransportMode.addItem( app.getErrorString(View_Additions));
	
	cmbExtraTransMod.addItem(TI_TRANSMODE_ROAD_STR);
	cmbExtraTransMod.addItem(TI_TRANSMODE_RAIL_STR);


	if self.viewTransportMode = null or
	   (self.viewTransportMode &lt;&gt; null and
	   //self.viewTransportMode &lt;&gt; app.getErrorString(BR_TYPE_DESCR_ROAD) and	// PAR #27972
	   //self.viewTransportMode &lt;&gt; app.getErrorString(BR_TYPE_DESCR_RAIL) and	// PAR #27972
	   self.viewTransportMode &lt;&gt; BR_TYPE_ROAD_STR and							// PAR #27972
	   self.viewTransportMode &lt;&gt; BR_TYPE_RAIL_STR and							// PAR #27972
	   self.viewTransportMode &lt;&gt; app.getErrorString(Road_rail) and
	   self.viewTransportMode &lt;&gt; ViewAdditions) then
		self.viewTransportMode := app.getErrorString(Road_rail);
	endif;
/*
	if self.viewTransportMode = null or
	   (self.viewTransportMode &lt;&gt; null and
	   self.viewTransportMode &lt;&gt; ViewRoad and
	   self.viewTransportMode &lt;&gt; ViewRail and
	   self.viewTransportMode &lt;&gt; ViewRoadRail and
	   self.viewTransportMode &lt;&gt; ViewAdditions) then
		self.viewTransportMode := ViewRoadRail;
	endif;
	*/
	
	cmbTransportMode.text := self.viewTransportMode;
	
	// used to default next added item
	//Changed to allow for Rail being the initial transport mode. Otherwise the wagon field is not shown when adding a rail prenote.
	//self.lastTransportMode := TI_TRANSMODE_ROAD;
	if self.viewTransportMode = null or 
	   self.viewTransportMode &lt;&gt; TI_TRANSMODE_RAIL_STR then
		self.lastTransportMode := TI_TRANSMODE_ROAD;
	else
		self.lastTransportMode := TI_TRANSMODE_RAIL;
	endif;

	self.myAssistant.comboBoxSubTerminal(cmbSubTerminal, null, self.myTerminal); //15/04/2009 cnwdz2 ccms1735
	
	self.myAssistant.comboBoxISOType(cmbCouISOType, null);
	self.myAssistant.setCarrierTransportMode(self.cmbCarrierPN,cmbTransportMode.text);		//cnwas3 par 24344
//	self.myAssistant.comboBoxTransportMode(tblExtra, ETRow_ReceiptTransportMode, self.lastTransportMode);
	self.doLoadIMEXStatuses();
	
	self.loadCmbShippingLine();				// May 20, 2022 navak20 TFS #53204
	self.loadCmbCountryOfOrigin();			//17.08.2022 navtnr20 54441
	
	self.txtTrackedItemID.automaticCellControl := true;
	self.cmbConsignee.sorted:= true;
	self.cmbConsignee.setType(CONSIGNEE);
	
	self.doLoadStops();
	self.myAssistant.listTableToDoTasks(self.lstToDo, self.myTerminal);

	if app.showMandatoryFields() then
		self.showMandatoryFields();
	endif;
	self.doLoadTrains(); // PAR 22766
	if self.viewTransportMode &lt;&gt; TI_TRANSMODE_RAIL_STR then // PAR 22766
		self.tblSearch.hideRowByName(ETRow_Train, false); // PAR 22766
	endif;
	
	//self.showHideTranshipColumn();
end;</source>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="63f51e11-738d-4b15-ab6b-128a9d5cdfa4">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
// ---------------------------------------------------------------------------
// Created:     02 October 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpTransMode	: String;
begin
	inheritMethod(_userWindow);
	
	if _userWindow = null then
		return;
	endif;
	
	tmpTransMode := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_TransportMode).String;
	if tmpTransMode &lt;&gt; null then
		self.viewTransportMode := tmpTransMode;
	endif;

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initMainTable" id="9482a286-54ee-4ae9-a9f9-066d926e7c61">
