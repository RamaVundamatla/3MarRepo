    <JadeMethod name="load" id="d41a78e4-7867-405e-adc2-f1c01c9bd082">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

vars

begin
beginNotification(process, StopBenchmark, Response_Continuous, 0);
beginNotification(system, StopBenchmark, Response_Continuous, 0);
end;</source>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="2fe5ebc4-53f1-4003-9f01-d6edfb75de01">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;

vars

begin

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="f070026d-2112-468d-8af3-31e036cbc8e1">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;

vars

begin


	if eventType = 1000 then
		terminate;
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
