    <JadeMethod name="jtdStartMethodTracking" id="2dd795bb-e7bf-48f5-a4db-82f6dbf7544e">
        <source>jtdStartMethodTracking();

vars
	rr:AtcgControl;
begin
	rr:=global.atcgMyControl;
	rr.addLogLine("Starting...");
	rr.stopMethodTracking;
	beginTransaction;
	rr.targetProcessName:="AtcgRecordApp";
	rr.targetSchemas.clear;
	rr.targetSchemas.add("JtdMobileDriverSchema");
	rr.targetSchemas.add("ShipSchema");
	rr.targetSchemas.add("YardSchema");
	rr.targetSchemas.add("GateSchema");
	rr.targetSchemas.add("MobileServerSchema");
	rr.buildMethodSet;
	rr.getTargetProcess;
	rr.generatingSource:=true;
	rr.generatingValidation:=true;
	rr.genValTableRowLimit:=10;
	commitTransaction;

	rr.startMethodTracking;
	rr.addLogLine("Finished");
	
	//app.atcgLog.rollOverLog;
	if false then AtcgControl.firstInstance.capture; endif;  // hyperlink to method
end;
</source>
    </JadeMethod>
    <JadeMethod name="jtdStopMethodTracking" id="e0960c79-f206-4675-90cc-115b5b3977ea">
        <source>jtdStopMethodTracking();

begin
	global.atcgMyControl.stopMethodTracking;
end;
</source>
    </JadeMethod>
    <JadeMethod name="mjw" id="fd55072d-16bd-49e4-b12e-7707929cb603">
