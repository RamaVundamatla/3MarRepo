    <JadeMethod name="create" id="e1a71253-667a-4e85-a98c-61c97eb86cb1">
        <updating/>
        <source>create() updating;
/*
----------   ----------  --------------------------------------------------
Created:	13 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.beginNotification(self, EVENT_ACTCAP_START, Response_Continuous, null);
	self.beginNotification(self, EVENT_ACTCAP_STOP, Response_Continuous, null);
	//for listening all nodes
	self.beginNotification(system, EVENT_ACTCAP_START, Response_Continuous, null);
	self.beginNotification(system, EVENT_ACTCAP_STOP, Response_Continuous, null);	

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="d38e9f09-d93d-4a5f-ad78-b0978691d73a">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 Nov 2016	cnwkpd1	TFS 2900 - CICE performance issues

*/

vars

begin
	self.endNotificationForSubscriber(self);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getModeDescr" id="d88fcaff-ac77-47f7-9e67-da6abee4f24b">
        <source>getModeDescr() : String;
/*
----------   ----------  --------------------------------------------------
Created:	14 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.captureMode = null then
		return 'No mode';
	elseif self.captureMode = self.CaptureMode_Transaction then
		return 'Transaction';
	elseif self.captureMode = self.CaptureMode_FormLoad then
		return 'Form Load';
	elseif self.captureMode = self.CaptureMode_Search then
		return 'Search';
	elseif self.captureMode = self.CaptureMode_Report then
		return 'Report';
	elseif self.captureMode = self.CaptureMode_DebugMisc then
		return 'Misc';
	elseif self.captureMode = self.CaptureMode_FormRefresh then
		return 'Form Refresh';
	elseif self.captureMode = self.CaptureMode_FormUserNote then
		return 'Form User Notifications';
	elseif self.captureMode = self.CaptureMode_FormSystemNote then
		return 'Form System Notifications';
		
	else
		return 'Unhandled mode!';
	endif;
	

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getParamsDelimited" id="9501fd88-e4e1-4e82-a961-053b176bfaf7">
        <source>getParamsDelimited() : String;
/*
----------   ----------  --------------------------------------------------
Created:	14 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	str		: String;
begin
	str := self.captureMode.String &amp; self.Param_Delimiter &amp;  
		self.doProfile.String &amp; self.Param_Delimiter &amp;  
		self.captureDiagnositcs.String &amp; self.Param_Delimiter &amp;  
		self.captureSecurity.String &amp; self.Param_Delimiter &amp;  
		self.captureEntDef.String &amp; self.Param_Delimiter &amp;  
		self.captureConfig.String &amp; self.Param_Delimiter &amp;  
		self.listeningAll.String &amp; self.Param_Delimiter &amp;  
		self.profilerMethodCount.String &amp; self.Param_Delimiter &amp;  
		self.durationThreshold.String &amp; self.Param_Delimiter &amp;  
		self.profileRemoteExecutions.String &amp; self.Param_Delimiter &amp;  
		self.reportActualTime.String &amp; self.Param_Delimiter &amp;  
		self.reportCacheStatistics.String &amp; self.Param_Delimiter &amp;  
		self.reportLoadTimes.String &amp; self.Param_Delimiter &amp;  
		self.reportMethodSize.String &amp; self.Param_Delimiter &amp;  
		self.reportStatistics.String &amp; self.Param_Delimiter &amp;  
		self.reportTotalTime.String;
	return str;			
		

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="logConfig" id="682c1c3d-c634-4612-9a94-7e58407219c2">
        <source>logConfig(_msg : String);
/*
----------   ----------  --------------------------------------------------
Created:	12 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if (not self.currentlyCapturing) or (not self.captureConfig) then
		return;
	endif;
	
	self.logMsg(EVENT_ACTCAP_CONFIG, _msg);


end;</source>
        <Parameter name="_msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="logDiagnostic" id="46066d12-de9d-4fd3-8c69-a26e8eca36c8">
        <source>logDiagnostic(_msg : String);
/*
----------   ----------  --------------------------------------------------
Created:	13 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin

	if app.isSpecial and _msg.pos("Event dispatched&gt;&gt;", 1) = 0 then			// 30/09/2010 cnwmh5 #25632
		app.writeStatement(_msg);
	endif;

	if (not self.currentlyCapturing) or (not self.captureDiagnositcs) then
		return;
	endif;

	self.logMsg(EVENT_ACTCAP_DIAGNOSTIC, _msg);

end;</source>
        <Parameter name="_msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="logEntTableDef" id="3c274a11-2488-493b-87a1-2305b61fa88d">
        <source>logEntTableDef(_msg : String);
/*
----------   ----------  --------------------------------------------------
Created:	13 June 2006 By cnwth2

Purpose:	Log the activity of an Entry Table Definition lookup

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if (not self.currentlyCapturing) or (not self.captureEntDef) then
		return;
	endif;
	
	self.logMsg(EVENT_ACTCAP_ENTDEF, _msg);

end;</source>
        <Parameter name="_msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="logMsg" id="bde53f0a-94a2-4e63-8c8e-089134354613">
        <source>logMsg(_eventType : Integer; _msg : String) protected;
/*
----------   ----------  --------------------------------------------------
Created:	14 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if self.listeningAll then
		system.causeEvent(_eventType, true, _msg);	
	else
		self.causeEvent(_eventType, true, _msg);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="logProfile" id="7337f66d-90e2-4757-85a2-3e3f8ea61b95">
        <source>logProfile(_fileName : String);
/*
----------   ----------  --------------------------------------------------
Created:	09 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if (not self.currentlyCapturing) or (not self.doProfile) then
		return;
	endif;
	
	self.logMsg(EVENT_ACTCAP_PROFILE, _fileName);

end;</source>
        <Parameter name="_fileName" type="String"/>
    </JadeMethod>
    <JadeMethod name="logSecurity" id="458dccba-be41-46dc-ad12-4f40242239cc">
