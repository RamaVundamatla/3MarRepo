    <JadeMethod name="utlUpdateRemoveEmailFromUser" id="45fe4f6d-c388-42e2-9349-ff03a3855a34">
        <updating/>
        <source>utlUpdateRemoveEmailFromUser(_emailAddress : CM_EmailAddress2; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 September 2014	cnwmc5	Initial creation	PAR 34888

*/

vars
	user : CM_User;
begin
	
	self.initialiseActivity();
	
	user := app.getMyUser();
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(user, true);
	endif;
	
	user.removeEmailAddress(_emailAddress);
	
