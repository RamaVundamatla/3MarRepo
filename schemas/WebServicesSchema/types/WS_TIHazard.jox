<Class name="WS_TIHazard" id="b9526839-eff3-4f7a-8d5c-c00a1981a4fa">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Represents Hazard classes in the system</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="acidsBases" id="dd4e70c0-1501-4d8a-b56f-eecd78155d42">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="code" id="8af9a7ea-fbc3-4081-a550-3cf152883a69">
        <type name="String"/>
        <text>This is usually the United Nations (UN) hazard code; ex: 5.1 is the UN hazard code for oxidizing agents.</text>
    </PrimAttribute>
    <PrimAttribute name="description" id="7a58c4ce-2894-4685-bf9b-61f6680584e0">
        <type name="String"/>
        <text>The Hazard Class Description.</text>
    </PrimAttribute>
    <PrimAttribute name="flashpointTemperature" id="1b9bd923-cc6a-439a-b6fd-9b3745d927fd">
        <embedded/>
        <type name="Real"/>
    </PrimAttribute>
    <PrimAttribute name="limitedQuantity" id="0d26bdee-5bd2-4723-ab80-bb551aa3b143">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>Limited quantity for that Dangerous goods code</text>
    </PrimAttribute>
    <PrimAttribute name="marinePollutant" id="6400f56e-49ae-4ebe-a8d2-3074ceea9e83">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="packingGroup" id="9720ee7f-5ea5-4153-b1fd-01dea29b1aaf">
        <length>6</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="undgCodes" id="82abff61-e545-4025-ac6f-502809096cd4">
        <length>81</length>
        <embedded/>
        <type name="String"/>
        <text>Dangerous Goods Codes ex. 3054 = CYCLOHEXANTHIOL (CYCLOHEXYLMERCAPTAN)</text>
    </PrimAttribute>
    <JadeMethod name="getDisplayDetails" id="b305ea23-2acf-4a1a-acc8-acf2129b1397">
        <source>getDisplayDetails() : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 17/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars

begin
	if self.description = null then
		return self.code;
	else
		return "("  &amp; self.code &amp; ")  " &amp; self.description;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="faa28cbe-a1cd-4f09-9e99-d44506a8ffe8">
        <updating/>
        <source>setProxyFromObject(_object: CM_Object) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/07/2010	cnwdz2	23027
16/07/2015	cnwdap1	PAR #36421 Hazardous Materials Handling
*/

vars
	hazardClass		: CM_HazardClass;
	tiHazard		: CM_TIHazard;
	
begin
	inheritMethod(_object);
	
	if _object.isKindOf(CM_TIHazard) then
		tiHazard := _object.CM_TIHazard;
		self.code := tiHazard.code;
		self.description := tiHazard.description;
		//cnwmc5 - some hazards on TIs weren't getting the description copied...
		if self.description = null then
			self.description := app.myRoot.allHazardClasses[self.code].description;
		endif;
		self.limitedQuantity := tiHazard.limitedQuantity.String;
		self.undgCodes := tiHazard.getUndgCodesAsString(true);		//25 Sep 2019	NDL	TFS 46633 - Leave as truncated version, but use new method
		self.packingGroup := tiHazard.packingGroup;						// PAR #36421
		self.marinePollutant := tiHazard.isMarinePollutant;
		self.acidsBases := tiHazard.acidsBases;
		self.flashpointTemperature := tiHazard.flashpointTemperature;
		
	elseif _object.isKindOf(CM_HazardClass) then
		hazardClass := _object.CM_HazardClass;
		self.code := hazardClass.code;
		self.description :=  hazardClass.description;
		
	endif;
	
epilog

end;</source>
        <Parameter name="_object" type="CM_Object"/>
    </JadeMethod>
</Class>
