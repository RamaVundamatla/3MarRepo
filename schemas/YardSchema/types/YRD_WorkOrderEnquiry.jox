    <JadeMethod name="doTblInfoDbClick" id="bdf46875-51cd-4971-a588-692551752807">
        <updating/>
        <source>doTblInfoDbClick(table: Table input) updating;
/*

Purpose:		TFS 39518	

Parameters:			

Return Value:		

Date		Who		Reason
18 Jul 2018	jlgab1	Initial creation
30 Aug 2022 navma1	Bug 54696: MTN - Work Orders - Double clicking on the Packing Cargo on the Extra Info table is taking to Parent cargo 
15 Mar 2023 navma1	ChangeRequest 55442:[54989] EUP - Pack Cargo Work Order - Enhancement
17 Mar 2023 navhl20 Defect 57173: MTN - 75776 exception when double clicking on the Vehicle on the Info table
*/

vars
	obj	: Object;
	invalid	: Boolean;
begin
	if table.row &lt;= table.fixedRows or table.column &lt;= table.fixedColumns then
		return;
	endif;
	
	app.mousePointer := MousePointer_HourGlass;
	
	on Exception do app.handleDeletedObject(exception, obj, invalid);
	
	obj := table.accessCell(table.row, table.column).itemObject.Object;
	
	//27/05/2025	navkc1 JIRA MTN-34972
	if obj &lt;&gt; null then
		obj.edition();
	endif;
	
	//07/05/2025	navkc1 JIRA MTN-34592
	if invalid then
		return;
	endif;
	
	if obj &lt;&gt; null then

		if obj.isKindOf(CM_CashReceipt) then
			self.doCashShowReceipts();
			return;
		endif;
		if obj.isKindOf(CM_Invoice) then
			self.doCashShowInvoices();
			return;
		endif;
		
		if obj.isKindOf(CM_TrackedItem) then		//30.08.2022 navma1 #54696
			self.doShowCargoEnquiry(null);		
			return;
		endif;
		
		if obj.isKindOf(CM_WorkOrderDtl) then		//30.08.2022 navma1 #54696
			self.doShowCargoEnquiry(obj.CM_WorkOrderDtl);		
			return;
		endif;
		
		
		if obj.isKindOf(CM_BulkRelease) then		//15.03.2023 navma1 #55442:[54989]
			self.doShowBulkRelease(obj.CM_BulkRelease);		
			return;
		endif;
		
		if obj.isKindOf(CM_VehicleVisitRecord) then				//17.3.2023 navhl20 #57173
			self.doShowVehicle(obj.CM_VehicleVisitRecord);		
			return;
		endif;
		
		if obj.isKindOf(CM_VehicleBookingTimeSlot) then			//17.3.2023 navhl20 #57173
			self.doShowVBS(obj.CM_VehicleBookingTimeSlot);		
			return;
		endif;
		
		if obj.isKindOf(CM_Wagon) then							//17.3.2023 navhl20 #57173
			self.doShowWagon(obj.CM_Wagon);		
			return;
		endif;
		
		if obj.isKindOf(CM_Train) then							//17.3.2023 navhl20 #57173
			self.doShowTrain(obj.CM_Train);		
			return;
		endif;
	endif;
	
	inheritMethod(table);

epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doViewAudits" id="46b7cfbc-fb36-4d1c-8bdf-f3bf7cd68ce3">
        <source>doViewAudits();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 January 2010	cnwrd1	Initial creation
25/06/2018  cnwma1	ChangeRequest 38635: PEL1 - SAP Cancellations

*/

vars
	selObj : Object;
	row : Integer;
	wo : CM_WorkOrder;
begin

	row := self.tblData.row;
	selObj := self.tblData.accessRow(row).itemObject;

	if selObj.isKindOf(CM_WorkOrder) then
		wo := selObj.CM_WorkOrder;

	elseif selObj.isKindOf(CM_WorkOrderDtl) then
		wo := selObj.CM_WorkOrderDtl.getMyParent;
	else
		// nothing to audit
		return;
	endif;
	
	app.viewAuditForm( wo, self.myAssistant.class, self.myTerminal);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doViewTransactions" id="9ee8e7a0-855b-48c2-9bb1-9d9eb2b84086">
        <source>doViewTransactions();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/01/2023	navcs2	ChangeRequest 56633:[56211] 54253.101 - Work order Transactions
11 Jul 2023 navhl20 Bug 59047: MTN - The Refresh button on the Transaction Enquiry is refreshing all the transactions.
*/

vars
	form	: CMUI_TransactionEnquiry;
	selObj	: Object;
	//col		: ObjectArray;
	wod		: CM_WorkOrder;
	wodtl	: CM_WorkOrderDtl;
begin
	
	//create col transient;																												//11.7.2023 navhl20 #59047
	
	selObj  := self.tblData.allSelectedObjects.first;
	
	if selObj.isKindOf(CM_WorkOrder) then
		wod := selObj.CM_WorkOrder; 																									//11.7.2023 navhl20 #59047
		//selObj.CM_WorkOrder.allTransactions.copy(col);																				//11.7.2023 navhl20 #59047
	elseif selObj.isKindOf(CM_WorkOrderDtl) then 
		wodtl := selObj.CM_WorkOrderDtl;																								//11.7.2023 navhl20 #59047
		//selObj.CM_WorkOrderDtl.allWODtlTransactions.copy(col);																		//11.7.2023 navhl20 #59047
	endif;
	
	//if col.isNotEmpty then																											//11.7.2023 navhl20 #59047
	form := app.loadForm(CMUI_TransactionEnquiry, CMUI_Assistant, false, false, true, self.myTerminal, self.myMasterMenuAction).CMUI_TransactionEnquiry;
	//form.CMUI_TransactionEnquiry.displaySelectorResults(col, form.CMUI_TransactionEnquiry.Mode_WO_Transaction_Enquiry);				//11.7.2023 navhl20 #59047
	if wod &lt;&gt; null then																													//11.7.2023 navhl20 #59047
		form.myWorkOrder := wod;
	elseif wodtl &lt;&gt; null then
		form.myWorkOrderDtl := wodtl;
	endif;
	form.show();
	//endif;																															//11.7.2023 navhl20 #59047
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getCargoWOdtlTaskNos" id="d4af310c-3175-4ff7-ad5f-658218ba9022">
        <source>getCargoWOdtlTaskNos( _cargoWoToInclude : IntegerArray input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2018	jlgndl1	Initial creation	TFS 40157

*/

vars

	rowIndex : Integer;
	include : Boolean;
	intValue : Integer;

begin

	foreach rowIndex in 1 to self.tblCargoWO.rows do
		include := self.tblCargoWO.accessCell(rowIndex, 1).text = "1";
		if include then
			intValue := self.tblCargoWO.accessCell(rowIndex, 3).text.Integer;
			_cargoWoToInclude.add( intValue );
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_cargoWoToInclude" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryType" id="1473835c-5f13-4da6-acaa-f039cb6baba0">
        <source>getEnquiryType(): Integer protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2009	cnwmd1	Initial creation

*/

vars

begin
	if self.enquiryType = self.EnqType_Task then
		return self.EnqType_Task;
	elseif self.enquiryType = self.EnqType_WorkOrder then
		return self.EnqType_WorkOrder;
	else
		app.raiseUnexpectedProgramError( class.name, method.name, 'Unknown enquiry type' );
		return null;
	endif;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
