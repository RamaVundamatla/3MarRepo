    <JadeMethod name="getTISizes" id="e69b1fce-1948-4cbf-b733-c9246ec003bf">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_RDTYardForm::getTISizes"/>
        </interfaceImplements>
        <source>getTISizes(_mode : Integer; _ta : CM_TerminalArea; _xGridOffsetFt, _yGridOffsetFt : Real io);

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 June 2010	cnwjk3	Initial creation

*/

vars

begin
	// We only really get the offsets of TIs as we draw them based on their actual size (in FT)
	
	if _ta.isKindOf(CM_GridArea) then
		if _ta.isKindOf(CM_StraddleStack) then
			if _mode = CMIF_RDTDrawElement.MODE_TOPDOWN then
				_xGridOffsetFt := 0;// defaulting for portrait view
				_yGridOffsetFt := 0;// defaulting for portrait view
			elseif _mode = CMIF_RDTDrawElement.MODE_FACE then
				_xGridOffsetFt := 0;// defaulting for portrait view
				_yGridOffsetFt := 0;// defaulting for portrait view			
			elseif _mode = CMIF_RDTDrawElement.MODE_END then
				_xGridOffsetFt := 0;// defaulting for portrait view
				_yGridOffsetFt := 0;// defaulting for portrait view			
			endif;				
		else
			if _mode = CMIF_RDTDrawElement.MODE_TOPDOWN then
				_xGridOffsetFt := 0;// defaulting for portrait view
				_yGridOffsetFt := 0;// defaulting for portrait view
			elseif _mode = CMIF_RDTDrawElement.MODE_FACE then
			
				_xGridOffsetFt := 0;// defaulting for portrait view
				_yGridOffsetFt := 0;// defaulting for portrait view
			elseif _mode = CMIF_RDTDrawElement.MODE_END then
				_xGridOffsetFt := 0;// defaulting for portrait view
				_yGridOffsetFt := 0;// defaulting for portrait view			
			endif;							
		endif;
	elseif _ta.isKindOf(CM_Rail) then
			if _mode = CMIF_RDTDrawElement.MODE_TOPDOWN then
				_xGridOffsetFt := 1;// defaulting for portrait view
				_yGridOffsetFt := 0;// defaulting for portrait view
			elseif _mode = CMIF_RDTDrawElement.MODE_FACE then			
				_xGridOffsetFt := 0;// defaulting for portrait view
				_yGridOffsetFt := 0;// defaulting for portrait view
			elseif _mode = CMIF_RDTDrawElement.MODE_END then
				// Not supported
			endif;					
	endif;
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_xGridOffsetFt" type="Real" usage="io"/>
        <Parameter name="_yGridOffsetFt" type="Real" usage="io"/>
    </JadeMethod>
