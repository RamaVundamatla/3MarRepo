    <JadeMethod name="deleteTransactionMaps" id="99d76967-8cca-46c3-b3a6-cf0e7606e65d">
        <source>deleteTransactionMaps();
// delete all invoice transaction maps other than the default one, so other invoice objects can be deleted
vars
	tm	: CM_TranMap;
	bank	: CM_Bank;
begin
	bank := self.getTerminal().getDefaultCompanyBank();
	self.resetDefaultTranMap();
	foreach tm in bank.myCurrentTranMapCargo do
		if tm.name &lt;&gt; "Default" and not tm.isActive then
			self.deleteInvoiceTransactionMap(1, tm.name);
		endif;
	endforeach;
end;
</source>
    </JadeMethod>
