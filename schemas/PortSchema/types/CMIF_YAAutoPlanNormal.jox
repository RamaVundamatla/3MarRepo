        <source>isRollingLength_Match(_yaData: CM_YADataString): Boolean;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 03 June 2022
TFS#		: 53316
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

