        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="extractInvoiceLineMapping" id="f1444d7e-601d-4c29-b4eb-d5d6f55e72e0">
        <source>extractInvoiceLineMapping(_file : File input; _bank : CM_Bank input) : Integer;
/*

Purpose:			Extracts the invoice line mappings using the agent to an xml format

Parameters:			_file	File	The file to use
					_bank	CM_Bank	The bank to use for the export

Return Value:		Integer	Represents how many invoice line mapping we have exported

Date		Who		Reason
28 September 2022	navpw1	Initial creation TFS: 54566

*/

vars
	agent : CMIF_InvoiceLineMapping;
	
begin
	create agent transient;
	return agent.doExtractInvLnTypMapXmlFile(_file, _bank);
	
epilog
