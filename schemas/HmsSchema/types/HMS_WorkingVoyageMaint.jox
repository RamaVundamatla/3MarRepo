    <JadeMethod name="setDelayButtonState" id="e55b8145-bd5f-4336-8518-a37f2ff3d07c">
        <source>setDelayButtonState();

vars

begin
	// This method sets the enabled/disabled state on the delay add,edit and delete 
	// buttons
	if self.myCurrentWorkingVoyage.ofClonedVoyage = null then
		// Voyage ADD mode - set all buttons to disabled
		btnEditDelay.enabled:=false;
		btnEditDelay.enabled:=false;
		btnDeleteDelay.enabled:=false;
	else
		// EDIT mode - enable ADD button and EDIT/DELETE is delay is selected
		btnEditDelay.enabled:=true;
		if self.myCurrentWorkingVoyage.allCMIFVoyageDelays.size&gt;0 then
			self.tblDelays.row:=2;
			self.tblDelays.column:=1;
			btnEditDelay.enabled:=true;
			btnDeleteDelay.enabled:=true;
		else
			btnEditDelay.enabled:=false;
			btnDeleteDelay.enabled:=false;
		endif;
	endif;


end;</source>
    </JadeMethod>
    <JadeMethod name="setFormReadOnly" id="1489dcab-daba-4c3d-ac6a-c316caca24b5">
        <updating/>
        <source>setFormReadOnly() updating;

vars
	userCanEdit : Boolean;
begin
	userCanEdit := self.canEdit;
 	// This method set the enable=true/false on form controls according to the value of the canEdit

	if not userCanEdit then
 		// Disable form controls
		self.btnApply.enabled := false;
		self.btnSaveBase.enabled := false;
 	else
 		// Enable form controls
 		self.btnApply.enabled := true;
 		self.btnSaveBase.enabled := true;
 	endif;

	//Set controls according to whether the user can edit or not.
 	self.tbxVoyageCode.enabled := userCanEdit;
 	self.tbxComments.enabled := userCanEdit;
 	self.gbxTimeTable.enabled := userCanEdit;
 	self.gbxShipClass.enabled := userCanEdit;
 	self.gbxCargoLoad.enabled := userCanEdit;
 	self.gbxCargoDischarge.enabled := userCanEdit;
 	self.gbxStevedoreDis.enabled := userCanEdit;
 	self.gbxStevedoresLoad.enabled := userCanEdit;
 	self.gbxDelays.enabled := userCanEdit;

 	self.btnAddMovement.enabled := userCanEdit;
 	self.btnDeleteMove.enabled := userCanEdit;
 	self.btnEditMovement.enabled := userCanEdit; 	
 	self.tblMovements.enabled := userCanEdit; 	 	 	

end;</source>
    </JadeMethod>
    <JadeMethod name="setLastVoyageDefaults" id="ade18199-ebcb-48cb-9b1b-1ad607a3fe63">
        <updating/>
        <source>setLastVoyageDefaults(_newVessel : CM_Vessel)updating;
//-----------------------------------------
//Created: 1 April 2005 By: cnwgd1
//-----------------------------------------
vars
	tmpVoyData:			HMS_VoyageData;
	lastVoyage:			CM_Voyage;
	commodity: 			CM_Commodity;
	cargoForecast		: CM_CargoForecast; // ### TFS 53132 14Apr2022 NAVPW1
	stevedore:			CM_Stevedore;
	dwellTime:			Integer;
begin
	if _newVessel = null then
		return;
	endif;

	if self.myCurrentWorkingVoyage.ofClonedVoyage &lt;&gt; null then
		return;
	endif;

	// ADD mode - new voyage - use allClonedMovements

	//AJA 2/8/00: Prefill voyage details using the data from the last voyage of this vessel...
	lastVoyage := self.myHarbour.getVesselsLastVoyage(_newVessel.code);

	if lastVoyage = null then
		return;
	endif;

	tmpVoyData := lastVoyage.myHMSVoyageData;

	if tmpVoyData.myPortFrom &lt;&gt; null then		// 30/8/19 MAP TFS45296
		self.cbxPortFrom.setObject(tmpVoyData.myPortFrom);
	endif;
	if tmpVoyData.myPortTo &lt;&gt; null then			// 30/8/19 MAP TFS45296
		self.cbxPortTo.setObject(tmpVoyData.myPortTo);
	endif;
	
	self.incrementDepartureTime(lastVoyage.arrivedDT, lastVoyage.departedDT); //Make dwell time same as last voyage

	//PAR 3791 AJA 10/11/00: Set the berth, accounting for preferred berths
	self.myCurrentWorkingVoyage.allClonedMovements.first.myBerth := tmpVoyData.getMyBerth;
	
	self.loadPreferredBerthList();

	while lbxCargoForDis.listCount &gt; 0 do		//Empty the cargo for discharge listbox
		lbxCargoForDis.listIndex := 1;
		lbxCargoForDis_dblClick(lbxCargoForDis);
	endwhile;
	
	/*foreach commodity in tmpVoyData.allCommodityDischarge do	//&amp; prefill with cargo from last voyage
   		lbxAllCargoDis.listIndex := lbxAllCargoDis.findObject(commodity);
   		lbxAllCargoDis_dblClick(lbxAllCargoDis);    
	endforeach;*/ // ### TFS 53132 11Apr2022 NAVPW1 - Commented out

	// ### TFS 53132 11Apr2022 NAVPW1
	foreach cargoForecast in lastVoyage.allCargoForecasts where cargoForecast.mode = CM_CargoForecast.Mode_Discharge do //&amp; prefill with cargo from last voyage
		if cargoForecast.myCommodity = null then
			continue;
		endif;
		
		lbxAllCargoDis.listIndex := lbxAllCargoDis.findObject(cargoForecast.myCommodity);
   		lbxAllCargoDis_dblClick(lbxAllCargoDis);
	endforeach;
	// ### TFS 53132 11Apr2022 NAVPW1
	
	while lbxCargoForLoad.listCount &gt; 0 do		//Cargo for load
		lbxCargoForLoad.listIndex := 1;
		lbxCargoForLoad_dblClick(lbxCargoForLoad);
	endwhile;
	
    /*foreach commodity in tmpVoyData.allCommodityLoad do
   		lbxAllCargoLoad.listIndex := lbxAllCargoLoad.findObject(commodity);
   		lbxAllCargoLoad_dblClick(lbxAllCargoLoad);    
	endforeach;*/ // ### TFS 53132 11Apr2022 NAVPW1 - Commented out
	
	// ### TFS 53132 11Apr2022 NAVPW1
	foreach cargoForecast in lastVoyage.allCargoForecasts where cargoForecast.mode = CM_CargoForecast.Mode_Load do //&amp; prefill with cargo from last voyage
		if cargoForecast.myCommodity = null then
			continue;
		endif;
		
		lbxAllCargoLoad.listIndex := lbxAllCargoLoad.findObject(cargoForecast.myCommodity);
   		lbxAllCargoLoad_dblClick(lbxAllCargoLoad);
	endforeach;
	// ### TFS 53132 11Apr2022 NAVPW1
	
	while lbxSteveForDis.listCount &gt; 0 do		//Discharge Stevedores
		lbxSteveForDis.listIndex := 1;
		lbxSteveForDis_dblClick(lbxSteveForDis);
	endwhile;
	
	foreach stevedore in tmpVoyData.allStevedoresDischarge do
		lbxAllSteveDis.listIndex := lbxAllSteveDis.findObject(stevedore);
		lbxAllSteveDis_dblClick(lbxAllSteveDis);    
	endforeach;

	while lbxSteveForLoad.listCount &gt; 0 do		//Load Stevedores
		lbxSteveForLoad.listIndex := 1;
		lbxSteveForLoad_dblClick(lbxSteveForLoad);
	endwhile;
	
    foreach stevedore in tmpVoyData.allStevedoresLoad do
   		lbxAllSteveLoad.listIndex := lbxAllSteveLoad.findObject(stevedore);
   		lbxAllSteveLoad_dblClick(lbxAllSteveLoad);    
	endforeach;	

end;</source>
        <Parameter name="_newVessel" type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrentVessel" id="c5546bbc-16b0-4d91-929d-73b03b70422e">
        <updating/>
        <source>setMyCurrentVessel(_vessel : CM_Vessel)updating;

vars

begin
	self.endNotificationForSubscriber(self);
	self.allNotableObjects.clear();
	self.myCurrentVessel := _vessel;
	if self.myCurrentVessel &lt;&gt; null then
		self.addNotableObject(self.myCurrentVessel);
	else
		self.loadSummaryTbl();
	endif;
end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="setMyCurrentWorkingVoyage" id="028f31d1-9c16-46a4-8ae2-cd99119309ab">
        <updating/>
        <source>setMyCurrentWorkingVoyage(_workingVoyage : CMIF_HMS_WorkingVoyage)updating;
//--------------------------------------------------
// Created:	11 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.myCurrentWorkingVoyage := _workingVoyage;
	if _workingVoyage &lt;&gt; null then
		self.setMyCurrentVessel(_workingVoyage.getMyVessel());
	else
		self.myCurrentVessel := null;
	endif;
end;</source>
        <Parameter name="_workingVoyage" type="CMIF_HMS_WorkingVoyage"/>
    </JadeMethod>
    <JadeMethod name="setSelectedMovement" id="c34bace4-68ac-4b6a-946c-e2a653d413f5">
        <updating/>
        <source>setSelectedMovement(movement : CMIF_HMS_WorkingMovement) updating;

vars

begin
	// clear all current selections
	
	self.tblMovements.setSelectedMovement(movement);
	self.enableMoveEditDelete();
	// Set new selected movement on controller
	if self.myViewController &lt;&gt; null 
	and movement &lt;&gt; null then
		if movement &lt;&gt; self.myViewController.myCurrentWorkingMovement then
    		self.myViewController.view_NewSelectedMovement(movement, false);
   		endif;
   	endif;

end;</source>
        <Parameter name="movement" type="CMIF_HMS_WorkingMovement"/>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="3eb2e0fd-0a6a-4a10-ac8b-e006962ebffc">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
//--------------------------------------------------
// Created:	20 June 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.loadDelayTable();
end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="47db44d4-66f5-479b-8096-6f606ae63edd">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------------------
//Created: 21 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod();

	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;	
		
	self.setNavigatorHeading(self.caption);
	self.myHarbour := self.myTerminal.myHarbour;

	self.cmbVessel.isVesselComboByName := self.myTerminal.getConfig(VesselComboByName).Boolean;	
	self.picShipBitmapSmmy.stretch := self.picShipBitmapSmmy.Stretch_ToControl;				
	self.loadCollections();
	self.initSummaryTable();
	self.initMovementTable();
	self.initDelayTable();	 	
		
	self.fldVoyageMaint.useSheetBackColors := true;
	self.fldVoyageMaint.setDefaultSheetBackColors();
	self.fldVoyageMaint.initSheetBackColors();

	self.canEdit := app.myCurrentUserCan(self.myTerminal, self.permissionMaint);	
		
	// Load form depending on whether it is operating in ADD or EDIT mode
	if self.myCurrentWorkingVoyage &lt;&gt; null then
		// EDIT mode
		self.loadEditVoyage();
		// Modified by Russell 04/08/99
		// ------------------------------
		if self.myCurrentWorkingVoyage.voyageStatus = HMS_VoyageIsLocked then
			self.canEdit := false;
		endif;
		if (not self.myCurrentWorkingVoyage.myHMSVoyageData.isTransient) then
		 	self.cmbVessel.enabled := false;
		 	self.cmbTerminalHMS.enabled := false;		
		else
		 	self.cmbVessel.enabled := canEdit;
		 	self.cmbTerminalHMS.enabled := canEdit;				
		endif;
		self.gbxMovements.visible := true;	
		self.shtDelays.visible := true;			
		// ------------------------------
	elseif self.myHarbour &lt;&gt; null then
		// ADD mode
		self.loadAddVoyage();
	 	self.cmbVessel.enabled := canEdit;
 		self.cmbTerminalHMS.enabled := canEdit;				
	endif;	
	self.setFormReadOnly();
	self.cmbVessel.style := ComboBox.Style_DropDownList;

end;</source>
    </JadeMethod>
    <JadeMethod name="showVesselMaintenance" id="ab56478b-52ad-47b3-a6db-5743d6357378">
        <updating/>
        <source>showVesselMaintenance(_vessel : CM_Vessel) updating;
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//-----------------------------------------
vars

begin
	
	if _vessel = null then
		return;
	endif;

	self.myAssistant.showVesselDefForm(_vessel, self.myMasterMenuAction, _vessel &lt;&gt; null);

end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="showVoyageDelayForm" id="162ee8e2-f07d-499b-833d-667a8f4ea366">
        <updating/>
        <source>showVoyageDelayForm(_edit : Boolean) updating;
//--------------------------------------------------
// Created:	11 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	form : HMS_VoyageDelayMaint;
	delay : CMIF_HMS_VoyageDelay;
begin

 	if _edit then
		delay := self.tblDelays.accessRow(self.tblDelays.row).itemObject.CMIF_HMS_VoyageDelay;
		if delay = null then
			app.msgBox('Cannot perform edit as there is no delay selected.', 'Error', MsgBox_Stop_Icon  + MsgBox_OK_Only);	
			self.tblDelays.setFocus();
			return;		
		endif;
	endif;
	
	form := app.loadForm(HMS_VoyageDelayMaint, HMS_Assistant, false, false, true, self.myTerminal, self.myMasterMenuAction).HMS_VoyageDelayMaint;	

	if form = null then
		return;
	endif;

 	form.mySelectedWorkingVoyage := self.myCurrentWorkingVoyage;
	form.mySelectedWorkingDelay := delay;
	form.setMyTerminal(self.myTerminal);
	form.showModal;	

 	if form.modalResult = IDOK then
		self.loadDelayTable(); 	
	endif;				

end;</source>
        <Parameter name="_edit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showWorkingMovementForm" id="2ea7391c-b03a-48ac-b163-c0024e83081c">
        <source>showWorkingMovementForm(_doEdit : Boolean);
//--------------------------------------------------
// Created:	28 April 2004 By: cnwgd1
//--------------------------------------------------
vars
begin
	if self.tblMovements.currentMovement = null then
		return;
	endif;

	self.myAssistant.HMS_Assistant.showWorkingMovementForm(self.tblMovements.currentMovement, self.myCurrentWorkingVoyage, _doEdit, self.myMasterMenuAction, self.myViewController);	


end;</source>
        <Parameter name="_doEdit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="00adbcdd-8e1b-4817-9f1f-3c11f24a2eb0">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
//--------------------------------------------------
// Created:	19 August 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.handleNotification(eventType, theObject, eventTag);
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblDelays_contextMenu" id="69005783-76c3-43d9-982f-e7ab3de3c48a">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDelays_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//--------------------------------------------------
// Created:	20 June 2005 By: cnwgd1
//--------------------------------------------------
vars
	x1, y1 : Real;

begin

	x1 := x;
	y1 := y;
	if not mouse then  // if keyboard, use current listIndex value
	    x1 := 1;
	    y1 := 1;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
	popupMenu(self.mnuDelayTable, x1.Integer, y1.Integer);
	return false;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblMovements_dblClick" id="338c93ee-f0c6-4d6a-95ac-7daeb8732c5e">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMovements_dblClick(table: CM_DataTable input) updating;
//--------------------------------------------------
// Created:	11 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if table.row &lt;= table.fixedRows then
		table.resortTableByColumn(table.column);
		table.colourRows(self.colorRow1, self.colorRow2);
		return;
	endif;
	if self.btnEditMovement.enabled then
 		self.btnEditMovement.click(self.btnEditMovement);
 	endif;
end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblMovements_gotFocus" id="8fa8b9b0-24d0-4bbc-9042-ac6cb64c4d4a">
        <controlMethod name="CM_DataTable::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMovements_gotFocus(table: Table input) updating;
//--------------------------------------------------
// Created:	11 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
  	table.rowColumnChg(table);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblMovements_keyDown" id="24a2847a-ca90-4b62-9672-6116e2a9a5d7">
        <controlMethod name="CM_DataTable::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMovements_keyDown(table: Table input; keyCode: Integer io; shift: Integer) updating;
//--------------------------------------------------
// Created:	11 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if (keyCode=13 or keyCode=40) and tblMovements.row+1&lt;=tblMovements.rows then
  		// move selected row down one row
  		tblMovements.row:=tblMovements.row+1;
  	elseif (keyCode=38) and tblMovements.row&gt;2 then
  		// move selected row up one row
  		tblMovements.row:=tblMovements.row-1;
  	endif;
	tblMovements.rowColumnChg(tblMovements);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblMovements_rowColumnChg" id="480ca52c-c347-43bc-9ec0-3fa05c8beac1">
        <controlMethod name="CM_DataTable::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMovements_rowColumnChg(table: Table input) updating;
//--------------------------------------------------
// Created:	11 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	currRow	: Integer;
begin

	if self.tblMovements.row &gt; self.tblMovements.fixedRows then
		currRow := self.tblMovements.row;
		self.setSelectedMovement(self.tblMovements.accessRow(currRow).itemObject.CMIF_HMS_WorkingMovement);
	endif;	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblSummary_change" id="ac5e0abc-6112-4e9a-8b50-d6064d2cdd8f">
        <controlMethod name="Table::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblSummary_change(table: Table input) updating;

vars

begin
 	// A change has occurred: Enable the 'Apply' button
	enableDisableApplyBtn(true);
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="404670fc-959a-42b3-a35e-9ca44bc493b0">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006130, locale);
	btnAddCargoDis.translateCaption(Xlat_0001993, locale);
	btnAddCargoLoad.translateCaption(Xlat_0001987, locale);
	btnAddDelay.translateCaption(Xlat_0002011, locale);
	btnAddMovement.translateCaption(Xlat_0001994, locale);
	btnAddSteveDis.translateCaption(Xlat_0001995, locale);
	btnAddSteveLoad.translateCaption(Xlat_0001988, locale);
	btnApply.translateBubbleHelp(Xlat_0002026, locale);
	btnApply.translateCaption(Xlat_0002027, locale);
	btnDeleteDelay.translateCaption(Xlat_0001996, locale);
	btnDeleteMove.translateCaption(Xlat_0002034, locale);
	btnEditDelay.translateCaption(Xlat_0001999, locale);
	btnEditMovement.translateCaption(Xlat_0001989, locale);
	btnRemoveCargoDis.translateCaption(Xlat_0001979, locale);
	btnRemoveCargoLoa.translateCaption(Xlat_0001980, locale);
	btnRemoveSteveDis.translateCaption(Xlat_0001981, locale);
	btnRemoveSteveLoa.translateCaption(Xlat_0001982, locale);
	btnShipDetails.translateBubbleHelp(Xlat_0001992, locale);
	btnShipDetails.translateCaption(Xlat_0001997, locale);
	gbxDelays.translateCaption(Xlat_0002021, locale);
	gbxMovements.translateCaption(Xlat_0002000, locale);
	gbxShipClass.translateCaption(Xlat_0002001, locale);
	gbxStevedoreDis.translateCaption(Xlat_0001990, locale);
	gbxStevedoresLoad.translateCaption(Xlat_0001983, locale);
	gbxSummary.translateCaption(Xlat_0002018, locale);
	gbxTimeTable.translateCaption(Xlat_0002002, locale);
	lblAllCargoTypes.translateCaption(Xlat_0001986, locale);
	lblAllCargoTypes1.translateCaption(Xlat_0001984, locale);
