<Class name="FileNode">
    <JadeMethod name="isAvailableOverNetwork" id="e6a0455a-3d2f-45c3-adbb-e14c7ef790b8">
        <source>isAvailableOverNetwork(retries:Integer) : Boolean;

vars
	count:Integer;
begin
	foreach count in 1 to retries do
		if self.isAvailable then 
			return true;
		endif;
		process.sleep(1000);
	endforeach;
	
	return false;
end;</source>
        <Parameter name="retries" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
