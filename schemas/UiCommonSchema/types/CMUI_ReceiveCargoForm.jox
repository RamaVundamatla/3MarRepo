    <JadeMethod name="doShowPicture" id="46a68b44-bb05-49aa-9952-d87f56947d54">
        <source>doShowPicture() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2009	cnwdap1	Initial creation

*/

vars

begin
	return; // JLGAB1 TOOLBAR NOPIX



	if self.currentEntTableDef.isOneOf(ETDef_NewItem, ETDef_ContainerFull, ETDef_ContainerFullReefer, ETDef_MinContainerDetails, ETDef_AttachmentDetails) then
		self.picTitleEmpty.visible := false;
		self.picTitleFull.visible := true;
		self.picTitleOther.visible := false;
		self.lblMainDetails.left := self.picTitleFull.left + self.picTitleFull.width;
	elseif self.currentEntTableDef = ETDef_ContainerEmpty then
		self.picTitleFull.visible := false;	
		self.picTitleEmpty.visible := true;
		self.picTitleOther.visible := false;
		self.lblMainDetails.left := self.picTitleEmpty.left + self.picTitleEmpty.width;
	elseif self.currentEntTableDef.isOneOf(ETDef_CreateNewCargo,ETDef_GeneralCargo, ETDef_AttachmentGeneral) then
		self.picTitleFull.visible := false;	
		self.picTitleEmpty.visible := false;
		self.picTitleOther.visible := true;
		self.lblMainDetails.left := self.picTitleOther.left + self.picTitleOther.width;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doShowVehicleBookings" id="9abf71dd-dbbc-46ce-8dba-6640612e6e6d">
        <source>doShowVehicleBookings();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 April 2013	cnwndl1	Initial creation	Par 31393
08 Dec   2015   cnwma1 PAR #37193 Appointment Number Not Displayed on Receive Cargo Screen
*/

vars

	byRoad : Boolean;
	carrier : CM_Carrier;
	vssSlot : CM_VehicleBookingTimeSlot;

begin

	if not self.myTerminal.isVehicleBookingEnabled then
		//self.grpVehicleBook.visible := false;			//cnwmc5 - 31 Oct 2013 - PAR 32891
		self.grpVehicleBook.isHidden := true;			//cnwmc5 - 31 Oct 2013 - PAR 32891
		return;
	endif;
	
	//23 Aug 2021	NDL	TFS 51416
	if self.cmbTransportMode.getString() &lt;&gt; BR_TYPE_ROAD_STR then
		self.grpVehicleBook.isHidden := true;
		self.grpVehicleBook.visible := false;
		return;
	endif;
	
	if self.myProxyTrackedItem = null then
		//self.grpVehicleBook.visible := false;			//cnwmc5 - 31 Oct 2013 - PAR 32891
		self.grpVehicleBook.isHidden := true;			//cnwmc5 - 31 Oct 2013 - PAR 32891
		return;
	endif;
	
	self.grpVehicleBook.isHidden := false;				//cnwmc5 - 1 Nov 2013 - PAR 32891
	self.btnVehicleBook.visible := false;				//cnwmc5 - 31 Oct 2013 - PAR 32891
	
	self.grpVehicleBook.visible := true;
	self.lblVehicleBook.visible := false;
	self.lblVehicleBook.caption := app.getErrorString(No_Vehicle_booking);
	
//	byRoad := ( self.cmbTransportMode.getString() = BR_TYPE_ROAD_STR );
	byRoad := self.isFlexiGateForm;	//13 Feb 2014	NDL	Par 33500
	if not byRoad then
		self.grpVehicleBook.enabled := false;
		return;
	endif;
	
	//12 Feb 2014	NDL	Par 33500
	if self.myProxyTrackedItem &lt;&gt; null and self.myProxyTrackedItem.myVehicleBookingTimeslot &lt;&gt; null then
		self.lblVehicleBook.caption := self.myProxyTrackedItem.getDisplayStringForAttribute(ETRow_VsBookingSlot,false);
		self.cmbCarrier.setForObject(self.myProxyTrackedItem.myVehicleBookingTimeslot.myCarrier);
	elseif self.myTI &lt;&gt; null and self.myTI.myVehicleBookingTimeslot &lt;&gt; null then
		self.lblVehicleBook.caption := self.myTI.getDisplayStringForAttribute(ETRow_VsBookingSlot,false);
		self.cmbCarrier.setForObject(self.myTI.myVehicleBookingTimeslot.myCarrier);
	elseif self.myProxyTrackedItem &lt;&gt; null then
		self.lblVehicleBook.caption := self.myProxyTrackedItem.getDisplayStringForAttribute(ETRow_VsBookingSlot,false);
	elseif self.myTI &lt;&gt; null then
		self.lblVehicleBook.caption := self.myTI.getDisplayStringForAttribute(ETRow_VsBookingSlot,false);
	else
		//who knows
	endif;
	
	if self.lblVehicleBook.caption = app.getErrorString(No_Vehicle_booking)then   // 08/12/2015 cnwma1 PAR #37193 
		if self.myCurrentVehicleVisit &lt;&gt; null then
			if self.myCurrentVehicleVisit.myVehicleBookingTimeslot &lt;&gt; null then
				self.lblVehicleBook.caption:=  self.myCurrentVehicleVisit.myVehicleBookingTimeslot.getDescription(true);
			endif;
		endif;
	endif;
	carrier := self.cmbCarrier.getObject.CM_Carrier;
	if carrier = null then
		grpVehicleBook.enabled := false;
		return;
	endif;
	
	grpVehicleBook.enabled := true;
	self.lblVehicleBook.visible := true;
	

epilog

	
end;</source>
    </JadeMethod>
    <JadeMethod name="doShowVehicleBookingsClick" id="818363d4-4909-4b34-9fe7-3b60693ae4b8">
        <source>doShowVehicleBookingsClick();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 April 2013	cnwndl1	Initial creation

*/

vars

	carrier : CM_Carrier;
	vbSlot : CM_VehicleBookingTimeSlot;

begin
	carrier := self.cmbCarrier.getObject.CM_Carrier;
	self.myAssistant.showVehicleBookingAssociation( self, null, self.myProxyTrackedItem, carrier );	
	self.lblVehicleBook.caption := self.myProxyTrackedItem.getDisplayStringForAttribute(ETRow_VsBookingSlot,false);
	vbSlot := self.myProxyTrackedItem.myVehicleBookingTimeslot;
	if vbSlot &lt;&gt; null then
		self.dateExpArrival.setValue( vbSlot.bookingTSstart.Date );
		self.timeExpArrival.setValue( vbSlot.bookingTSstart.Time );
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doUpdateAdditionalDetails" id="4b2b1e0f-2513-479d-a93a-a40eb4c6fdc2">
        <updating/>
        <source>doUpdateAdditionalDetails(	_description : String;
							_stops, _tasks : ObjectArray;
							_stow : CM_SpecialStow;
							_lifts : ObjectArray;
							_freightForwarder : CM_ConsigneeConsignor;
							_customsAgent : CM_CustomsAgent;
							_bol, _consVoyage, _eirNumber, _purchaseOrder, _shippingReference ,_transportMode, _wagon, _wagonTrain : String;
							_wagonClass : CM_WagonClass;	//12 May 2014	NDL	Par 33615
							_subTerminal : CM_SubTerminal;
							_curtainsIn : Boolean;
							_coolingType, _voltageType : String;
							_businessUnit : CM_Bank;
							_remarksAdditional1 : String;
							_remarksAdditional2 : String;
							_shipLine	:	CM_ShippingLine;	//20 may 2022 navgm20  TFS 53204
							_countryOfOrigin : CM_Country;		// 16.08.2022 navak20 TFS 54441
							_invoiceContractId : CM_InvoiceContract;
							_isOverlanded : Boolean //06/04/2023	navkc1	CR# 56431 Task 56440
							) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 August 2009	cnwdap1	Initial creation
25 November  2015	cnwma1  PAR #36943 Shipping Reference error during extract
15 March 2016		cnwdap1	PAR #37606 "Not available for entry" Customs Agent
20 may 2022	navgm20 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
16 August 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin
06 April 2023	navkc1	CR# 56431 Task 56440: UI - Receive Cargo Form
*/
vars

begin
	self.txtDescription.setValue(_description);
	
	self.lstAllStops.clearSelected;
	_stops.copy(self.lstAllStops.allSelectedObjects);
	self.lstToDoTasks.clearSelected;
	_tasks.copy(self.lstToDoTasks.allSelectedObjects);
	
	self.cmbSpecialStow.setForObject(_stow);
	
	self.lstSpecialLift.clearSelected;
	_lifts.copy(self.lstSpecialLift.allSelectedObjects);
	
	self.cmbShippingLine.setForObject(_shipLine);		//20 may 2022 navgm20  TFS 53204
	self.cmbCtryOfOrigin.setForObject(_countryOfOrigin);		// 16.08.2022 navak20 TFS 54441
	self.cmbFreightFwdr.setForObject(_freightForwarder);
	self.cmbCustomsAgent.setForObject(_customsAgent);
	if _customsAgent &lt;&gt; null and _customsAgent.isNotAvailableForEntry then				// PAR #37606
		// add an entry for the customs agent manually									// PAR #37606
		if self.cmbCustomsAgent.listIndex = -1 then										// PAR #37606
			self.cmbCustomsAgent.getEmbeddedControl.ComboBox.listIndex := self.cmbCustomsAgent.addItemObject(_customsAgent.code &amp; Tab &amp; _customsAgent.name, _customsAgent);	// PAR #37606
		endif;																			// PAR #37606
	endif;																				// PAR #37606
	
	self.txtHouseBOL.setValue(_bol);
	self.txtConsignVoy.setValue(_consVoyage);
	self.txtEquipXchg.setValue(_eirNumber);
	self.txtPurchaseOrder.setValue(_purchaseOrder);
	self.txtShippingRef.setValue(_shippingReference);		//25/11/2015 cnwma1 PAR #36943
	self.cmbTransportMode.setForText(_transportMode);
	self.txtWagon.setValue(_wagon);
	self.cmbWagonClass.setForObject(_wagonClass);		// PAR #33615
	self.txtWagonTrain.setValue(_wagonTrain);	//04 Nov 2009	NDL Par 21519
	self.cmbSubTerminal.setForObject(_subTerminal);
	
	self.chkCurtainsIn.setValue(_curtainsIn);
	self.cmbCoolingType.setForText(_coolingType);
	self.cmbVoltageType.setForText(_voltageType);
	
	self.chkOverlanded.setValue(_isOverlanded); //06/04/2023	navkc1	CR# 56431 Task 56440
	
	self.cmbBusUnit.setForObject(_businessUnit);
	 // ### TFS BUG 57332 29MAR2023 NAVAB1 self.cmbInvContractID.setForObject(_invoiceContractId);//21.02.2023 navtnr20 TFS CR 55648 Task 55663
	
	if _invoiceContractId &lt;&gt; null then	
		self.cmbInvContractID.getEmbeddedControl.ComboBox.listIndex := self.cmbInvContractID.addItemObject(_invoiceContractId.contractId,_invoiceContractId);	
	endif;
	//03 May 2018	NDL	TFS 37795
	if self.isPreNoteForm and self.myProxyTrackedItem &lt;&gt; null then
		self.myProxyTrackedItem.setRemarksAdditionals( _remarksAdditional1, _remarksAdditional2 );
	endif;
	
	self.setAdditionalDetailsLabel();
epilog

end;</source>
        <Parameter name="_description" type="String"/>
        <Parameter name="_stops" type="ObjectArray"/>
        <Parameter name="_tasks" type="ObjectArray"/>
        <Parameter name="_stow" type="CM_SpecialStow"/>
        <Parameter name="_lifts" type="ObjectArray"/>
        <Parameter name="_freightForwarder" type="CM_ConsigneeConsignor"/>
        <Parameter name="_customsAgent" type="CM_CustomsAgent"/>
        <Parameter name="_bol" type="String"/>
        <Parameter name="_consVoyage" type="String"/>
        <Parameter name="_eirNumber" type="String"/>
        <Parameter name="_purchaseOrder" type="String"/>
        <Parameter name="_shippingReference" type="String"/>
        <Parameter name="_transportMode" type="String"/>
        <Parameter name="_wagon" type="String"/>
        <Parameter name="_wagonTrain" type="String"/>
        <Parameter name="_wagonClass" type="CM_WagonClass"/>
        <Parameter name="_subTerminal" type="CM_SubTerminal"/>
        <Parameter name="_curtainsIn" type="Boolean"/>
        <Parameter name="_coolingType" type="String"/>
        <Parameter name="_voltageType" type="String"/>
        <Parameter name="_businessUnit" type="CM_Bank"/>
        <Parameter name="_remarksAdditional1" type="String"/>
