    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="_usergui"/>
    <ExplicitInverseRef name="myDateBox" id="50f9a891-94e4-4ab4-aaad-ab27860e08e0">
        <kind>parent</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CMUI_FieldDateMaskControl"/>
