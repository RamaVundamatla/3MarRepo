    <JadeMethod name="setupForm" id="dd357590-eb0f-4719-9f21-4f4b272b3f31">
        <updating/>
        <source>setupForm() updating;
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//-----------------------------------------
begin
	// This method loads all collections into comboboxes
	inheritMethod();
	//self.btnOk.caption := '&amp;Find';
	//self.btnClose.caption := '&amp;Close';
	
// cnwdad1 11/07/2008 - PAR #17493.
	if self.myTerminal.myHarbour = null then
		app.raiseCMException1(HMSNoHarbourForTerminal, self.myTerminal.name, null, null);
		self.unloadForm();
		return;
	endif;
	
	self.initCombos();
	self.initTblMatchsFound();
	self.setDateDefaults();
	self.setCriteriaForCurrentVoyage();
	self.fldSearchSelect.useSheetBackColors := true;
	self.fldSearchSelect.setDefaultSheetBackColors();
	self.fldSearchSelect.initSheetBackColors();
	
	if self.myViewController = null then
		self.lblSearch_1.visible := false;
	endif;

	if (not app.myCurrentUserCan(self.myTerminal, self.permissionMaint)) then
		self.btnExportData.enabled := false;
	endif;
end;</source>
    </JadeMethod>
