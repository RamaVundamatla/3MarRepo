gt;0&lt;/m20&gt;&lt;m40&gt;0&lt;/m40&gt;&lt;mt&gt;0&lt;/mt&gt;&lt;vt&gt;0&lt;/vt&gt;&lt;hv&gt;0&lt;/hv&gt;&lt;pw&gt;0&lt;/pw&gt;&lt;rf&gt;0&lt;/rf&gt;&lt;is30&gt;0&lt;/is30&gt;&lt;is45&gt;0&lt;/is45&gt;&lt;is53&gt;0&lt;/is53&gt;&lt;oc&gt;1&lt;/oc&gt;&lt;ot&gt;3&lt;/ot&gt;&lt;na&gt;0&lt;/na&gt;&lt;wc&gt;0&lt;/wc&gt;&lt;d20&gt;1&lt;/d20&gt;&lt;d40&gt;0&lt;/d40&gt;&lt;f40&gt;0&lt;/f40&gt;&lt;m20&gt;0&lt;/m20&gt;&lt;m40&gt;0&lt;/m40&gt;&lt;mt&gt;0&lt;/mt&gt;&lt;vt&gt;0&lt;/vt&gt;&lt;hv&gt;0&lt;/hv&gt;&lt;pw&gt;0&lt;/pw&gt;&lt;rf&gt;0&lt;/rf&gt;&lt;is30&gt;0&lt;/is30&gt;&lt;is45&gt;0&lt;/is45&gt;&lt;is53&gt;0&lt;/is53&gt;&lt;oc&gt;1&lt;/oc&gt;&lt;ot&gt;4&lt;/ot&gt;&lt;na&gt;0&lt;/na&gt;&lt;wc&gt;0&lt;/wc&gt;&lt;d20&gt;1&lt;/d20&gt;&lt;d40&gt;0&lt;/d40&gt;&lt;f40&gt;0&lt;/f40&gt;&lt;m20&gt;0&lt;/m20&gt;&lt;m40&gt;0&lt;/m40&gt;&lt;mt&gt;0&lt;/mt&gt;&lt;vt&gt;0&lt;/vt&gt;&lt;hv&gt;0&lt;/hv&gt;&lt;pw&gt;0&lt;/pw&gt;&lt;rf&gt;0&lt;/rf&gt;&lt;is30&gt;0&lt;/is30&gt;&lt;is45&gt;0&lt;/is45&gt;&lt;is53&gt;0&lt;/is53&gt;&lt;oc&gt;1&lt;/oc&gt;&lt;ot&gt;5&lt;/ot&gt;&lt;na&gt;0&lt;/na&gt;&lt;wc&gt;0&lt;/wc&gt;&lt;d20&gt;1&lt;/d20&gt;&lt;d40&gt;0&lt;/d40&gt;&lt;f40&gt;0&lt;/f40&gt;&lt;m20&gt;0&lt;/m20&gt;&lt;m40&gt;0&lt;/m40&gt;&lt;mt&gt;0&lt;/mt&gt;&lt;vt&gt;0&lt;/vt&gt;&lt;hv&gt;0&lt;/hv&gt;&lt;pw&gt;0&lt;/pw&gt;&lt;rf&gt;0&lt;/rf&gt;&lt;is30&gt;0&lt;/is30&gt;&lt;is45&gt;0&lt;/is45&gt;&lt;is53&gt;0&lt;/is53&gt;&lt;oc&gt;1&lt;/oc&gt;&lt;ot&gt;6&lt;/ot&gt;&lt;na&gt;0&lt;/na&gt;&lt;wc&gt;0&lt;/wc&gt;&lt;d20&gt;1&lt;/d20&gt;&lt;d40&gt;0&lt;/d40&gt;&lt;f40&gt;0&lt;/f40&gt;&lt;m20&gt;0&lt;/m20&gt;&lt;m40&gt;0&lt;/m40&gt;&lt;mt&gt;0&lt;/mt&gt;&lt;vt&gt;0&lt;/vt&gt;&lt;hv&gt;0&lt;/hv&gt;&lt;pw&gt;0&lt;/pw&gt;&lt;rf&gt;0&lt;/rf&gt;&lt;is30&gt;0&lt;/is30&gt;&lt;is45&gt;0&lt;/is45&gt;&lt;is53&gt;0&lt;/is53&gt;&lt;oc&gt;1&lt;/oc&gt;&lt;ot&gt;7&lt;/ot&gt;&lt;na&gt;0&lt;/na&gt;&lt;wc&gt;0&lt;/wc&gt;&lt;d20&gt;1&lt;/d20&gt;&lt;d40&gt;0&lt;/d40&gt;&lt;f40&gt;0&lt;/f40&gt;&lt;m20&gt;0&lt;/m20&gt;&lt;m40&gt;0&lt;/m40&gt;&lt;mt&gt;0&lt;/mt&gt;&lt;vt&gt;0&lt;/vt&gt;&lt;hv&gt;0&lt;/hv&gt;&lt;pw&gt;0&lt;/pw&gt;&lt;rf&gt;0&lt;/rf&gt;&lt;is30&gt;0&lt;/is30&gt;&lt;is45&gt;0&lt;/is45&gt;&lt;is53&gt;0&lt;/is53&gt;&lt;/USLOTS&gt;&lt;/BAY&gt;&lt;HATCH&gt;&lt;/HATCH&gt;&lt;SECTIONS&gt;&lt;/SECTIONS&gt;&lt;TANKS&gt;&lt;/TANKS&gt;
				]]&gt;&lt;/layout&gt;
			&lt;ROROVesselStructure/&gt;
			&lt;ROROConfig&gt;
				&lt;RoRoDeckLabelPrefix&gt;D&lt;/RoRoDeckLabelPrefix&gt;
				&lt;RoRoLaneLabelPrefix&gt;LN&lt;/RoRoLaneLabelPrefix&gt;
				&lt;RoRoLaneNumberLength&gt;2&lt;/RoRoLaneNumberLength&gt;
				&lt;RoRoLaneCodeIsZeroFilled/&gt;
				&lt;RoRoLocationCodeIsZeroFilled/&gt;
				&lt;RoRoLocationNumberLength&gt;3&lt;/RoRoLocationNumberLength&gt;
				&lt;RoRoRotatedLabel&gt;R&lt;/RoRoRotatedLabel&gt;
				&lt;RoRoSubDeckLabelPrefix&gt;S&lt;/RoRoSubDeckLabelPrefix&gt;
				&lt;RoRoOutOfTwistLockSuffix&gt;''&lt;/RoRoOutOfTwistLockSuffix&gt;
				&lt;RoRoGeneralCargoSuffix&gt;''&lt;/RoRoGeneralCargoSuffix&gt;
				&lt;RoRoLaneWidth&gt;3.0&lt;/RoRoLaneWidth&gt;
				&lt;RoRoLaneLength&gt;75.0&lt;/RoRoLaneLength&gt;
				&lt;RoRoLaneGap&gt;0.5&lt;/RoRoLaneGap&gt;
				&lt;RoRoLocationWidth&gt;2.4&lt;/RoRoLocationWidth&gt;
				&lt;RoRoLocationLength&gt;6.0&lt;/RoRoLocationLength&gt;
				&lt;RoRoLocationGap&gt;1&lt;/RoRoLocationGap&gt;
				&lt;RoRoAutoGenerateStartEnd&gt;3&lt;/RoRoAutoGenerateStartEnd&gt;
			&lt;/ROROConfig&gt;
		&lt;/UT_JJRORO&gt;
    &lt;/Vessel&gt;	
	&lt;System&gt;
		&lt;InvoiceLineDescs&gt;
			&lt;InvoiceLineDesc&gt;
				&lt;name&gt;Extra Services&lt;/name&gt;
				&lt;invoiceType&gt;
					&lt;description&gt;Extra Services&lt;/description&gt;
					&lt;type&gt;InvoiceTypeStorage&lt;/type&gt;
				&lt;/invoiceType&gt;
				&lt;calculationType&gt;CCT02&lt;/calculationType&gt;
				&lt;invoiceService&gt;
					&lt;description&gt;Extra Service&lt;/description&gt;
				&lt;/invoiceService&gt;
				&lt;debtorType&gt;UT_DT1&lt;/debtorType&gt;
			&lt;/InvoiceLineDesc&gt;
		&lt;/InvoiceLineDescs&gt;
	&lt;/System&gt;
&lt;/DataToLoad&gt;
";
vars

	openFile					: CMDFileOpen;
	obj							: Object;
	terminal					: CM_Terminal;

	xmlDoc						: JadeXMLDocument;
	xmlElement					: JadeXMLElement;
	elementDataToLoad			: JadeXMLElement;

begin

	//on FileException do fileExceptionHandler(exception, "Import");
	on Exception do handleFormatException(exception, "Import");
	
	//create openFile transient;
//	openFile.filter := "XML Definition (*.xml)|*.xml";
//	if openFile.open() &lt;&gt; 0 then
//		return;
//	endif;

	
	create xmlDoc transient;
//	xmlDoc.parseFile(openFile.fileName);
	xmlDoc.parseString(XMLDocument);
	
	elementDataToLoad := xmlDoc.getElementByTagName(DataToLoad);
	if elementDataToLoad = null then
		return;
	endif;
	
	foreach obj in elementDataToLoad.childNodes do
		xmlElement := obj.JadeXMLElement;
	
		if xmlElement.tagName.toUpper() = "System".toUpper() then
			self.processSystem(xmlElement);
		elseif xmlElement.tagName.toUpper() = "Vessel".toUpper() then
			self.processVesselDetails(xmlElement);
		elseif xmlElement.tagName.toUpper() = "Harbour".toUpper() then
			self.processHarbourDetails(xmlElement);
		elseif xmlElement.tagName.toUpper() = "Terminal".toUpper() then
			self.processTerminalDetails(xmlElement);
		endif;
	endforeach;
	
	
	// non xml stuff
	///write "Setting up stuff for PTN010010";
	///self.processPTN010010Details();
	
	// setup DefAvailabilityGrade for all terminals.  Required so can delete availability grade
	write 'Setting Default Availability Grade all terminals';
	beginTransaction;
	foreach terminal in app.myRoot.allTerminals do
		terminal.setConfig(DefAvailabilityGrade, "0");
	endforeach;
	commitTransaction;
	
	write "Setting up Root Misc";
	self.processRootMisc();
	
epilog

	delete xmlDoc;
	delete openFile;

end;
</source>
    </JadeMethod>
</Class>
