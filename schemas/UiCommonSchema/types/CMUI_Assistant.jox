        <source>displayEntryVoyageExclNull(pVoyage : CM_Voyage) : String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 02 February 2023
TFS#		: 56385
Function	: Display Voyage Object Excluding the Null Voyage

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars

	 failedDAC : CM_DataAccessController;

begin
	if pVoyage.isNullVoyage then
		return null;
	endif;
	
	if pVoyage = null then
		return null;
	endif;

	if (not pVoyage.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		return null;
	endif;
	
	return pVoyage.getDisplayDetails(false);

end;</source>
        <Parameter name="pVoyage" type="CM_Voyage"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayEntryVoyageJobList" id="093810f4-e33b-49c7-bd66-06c78a0da11c">
