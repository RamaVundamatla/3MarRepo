    <JadeMethod name="initialiseRoot" id="1355b2c1-4dea-49e9-badf-1e0fe8b270ba">
        <updating/>
        <source>initialiseRoot() updating, protected;

vars
	root : Root;
	
begin
	if Root.instances.isEmpty then
		beginTransaction;
			create root;
		commitTransaction;
	endif;
	setMyRoot(Root.firstInstance);
end;</source>
