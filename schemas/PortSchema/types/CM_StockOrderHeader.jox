    <JadeMethod name="updateDischargePort" id="1e009286-48b2-429f-ad73-2bc1d5248349">
        <updating/>
        <source>updateDischargePort(_dischPortCode : String) updating;
//--------------------------------------------------------------
//Created: 09 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	disPort : CM_Port;
begin
	//disPort	:= app.myRoot.allPorts[_dischPortCode];
	disPort	:= app.myRoot.allPorts[_dischPortCode];
	if self.myVoyage &lt;&gt; null and disPort &lt;&gt; null then
		self.myVoyage.addPortToAllPorts(disPort);
	endif;
end;</source>
        <Parameter name="_dischPortCode" type="String"/>
