    <JadeMethod name="handleEnterOKClick" id="a3336e8a-80e7-414f-8ae5-c14abee3583c">
        <updating/>
        <source>handleEnterOKClick()updating;
// ---------------------------------------------------------------------------
// Created:     01 May 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	ti 			: CM_TrackedItem;
	job 		: CM_RoadJob;
	id 			: String;
	bulkRel 	: CM_BulkRelease;
begin
	id := self.txt_CargoID.text.trimBlanks.toUpper;
	if id = null then
		return;
	endif;
	if self.itemAlreadyInTable(id, self.tbl_CargoIDs) then
		app.msgBox(app.getErrorString(Duplicate_entry), '', MsgBox_OK_Only);
		self.txt_CargoID.text := '';
		self.txt_CargoID.setFocus;
		return;
	endif;
	ti := self.myMobileDataAgent.findOnsiteCargoByID(id);
	if ti = null then
		app.msgBox(app.getErrorString(Item_NotFound), app.getErrorString(Item_NotFound), MsgBox_OK_Only);
		return;
	endif;
	bulkRel := ti.getBulkReleaseAssignedOfType(BR_TYPE_ROAD, BR_ACTIVE);
	if bulkRel &lt;&gt; null and not self.allBulkReleases.includes(bulkRel) and not bulkRel.isWaybill() then
		app.msgBox("This item is not for this release.", '', MsgBox_OK_Only);
		return;
	endif;
	// pack the item
	job := self.myRoadJob;
	self.doContainerSave(ti, job, null, false);
	self.loadCargoIDsTbl(self.tbl_CargoIDs);
	if self.allBulkReleases.size &lt;&gt; 0 then
		self.loadPackingReqTbl(self.tbl_PackingRqst);
	endif;
	self.txt_CargoID.text := '';
	self.txt_CargoID.setFocus;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadCargoIDsTbl" id="8461c87a-d89c-4971-98e8-d04f8b73f78a">
        <updating/>
        <source>loadCargoIDsTbl(tbl: CM_MobTable io) updating;
// ---------------------------------------------------------------------------
// Created:     30 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
// 11/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
vars
	cargoItem  : CM_TrackedItem;
	count 		: Integer;
	invalidObject : Boolean;
	roadJob		: CM_RoadJob;
begin
	tbl.rows := 1;
	count := 0;
	
	roadJob := self.myRoadJob;
	if roadJob &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, roadJob, invalidObject); 	
		foreach cargoItem in  roadJob.allReleaseTrackedItems 
		where cargoItem.getPrimaryLocation(REAL_MODE) &lt;&gt; null
		and cargoItem.getPrimaryLocation(REAL_MODE).isKindOf(CM_VehicleController) 
		and cargoItem.getPrimaryLocation(REAL_MODE).CM_VehicleController.vehicle = roadJob.myVehicle  do
			count := count +1;
			self.addCargoChildToTable(tbl, cargoItem, count);
		endforeach;
	endif;
	self.txt_GrossWeight.text := self.getTotalWeight();


end;</source>
        <Parameter name="tbl" type="CM_MobTable" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadPackingReqTbl" id="5b14e68a-99c6-4f6c-8550-de08f7e2a084">
        <updating/>
        <source>loadPackingReqTbl(_tbl: CM_MobTable io) updating;
// ---------------------------------------------------------------------------
// Created:     30 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	reserve : CM_ReserveDetail;
	release : CM_BulkRelease;
	currentRow : Integer;
begin
	_tbl.rows := 1;
	currentRow := _tbl.rows;
	
	foreach release in self.allBulkReleases do
		foreach reserve in release.allReserveDetails do
			self.addReserveToTable(_tbl, reserve, currentRow);
		endforeach;
	endforeach;
end;</source>
        <Parameter name="_tbl" type="CM_MobTable" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processForCloseForm" id="048fec86-f9cf-47f7-a580-4620f6ab3015">
        <updating/>
        <source>processForCloseForm(): Boolean updating;

vars
	thisDevice	: String;
	isClose		: Boolean;
	
begin
	if not inheritMethod() then
		return false;
	endif;
	
	isClose	:=	true;
	
	if self.myRoadJob &lt;&gt; null then
		thisDevice := app.myMobileGUIAgent.strDevice;
	// no truck complete process for this form now
/*		if self.myMobileDataAgent.deviceIsLastOnJob(myRoadJob, app.myMobileGUIAgent.strDevice) 
		and app.myCurrentUserCan(self.myMobileDataAgent.myTerminal, PmGteRoadExitUpdate)
		then
			if app.msgBox(app.getErrorString(TruckCompleted), "", MsgBox_Yes_No) = MsgBox_Return_Yes then
				if not self.doCompleteTruck() then
					isClose	:=	false;
				endif;
			endif;
		endif;
*/	
		app.myTrxUA.trxUpdateRoadJobDevices(self.myRoadJob, thisDevice, self.myRoadJob.Remove_Device, app.myPassport);
		self.myRoadJob := null;
	endif;
	
	return isClose;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupCargoIDsTable" id="8a566f82-5bdb-45d6-a826-8e24e1f94c46">
        <source>setupCargoIDsTable(_tbl: CM_MobTable input; intColumns  :Integer output; strHeader : String output);
// ---------------------------------------------------------------------------
// Created:     30 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.getTblCargoIDsSetting(intColumns, strHeader);
	inheritMethod(_tbl,intColumns,strHeader);
end;</source>
        <Parameter name="_tbl" type="CM_MobTable" usage="input"/>
        <Parameter name="intColumns" type="Integer" usage="output"/>
        <Parameter name="strHeader" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="16a4d7df-d8ac-4794-b529-2072bb3aaf9c">
        <updating/>
        <source>setupForm() updating, protected;
// ---------------------------------------------------------------------------
// Created:     by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 22/03/2011	cnwdap1		PAR #19664 Set focus to the cargo id field so drivers don't need
//										to do this manually
vars
	truck : CM_Vehicle;
	release : CM_BulkRelease;
	dev : String;
begin
	self.myTruck := self.myRoadJob.myVehicle;
	inheritMethod();
	self.sht_Request.caption := app.getErrorString(Load_request);
	self.sht_CargoID.caption := app.getErrorString(Truck) &amp;" " &amp;self.myTruck.code;
	
	if app.getMyTerminalDO_NOT_USE().getConfig(AllowMobileRoadExit).Boolean then						//+cnwml2 PAR19692
		self.btn_Complete.visible := true;
	else
		self.btn_Complete.visible := false;
	endif;
	
	btn_Details.visible := false;
	dev := app.myMobileGUIAgent.strDevice;
	self.myMobileDataAgent.setupRoadJob(self.myRoadJob, dev);
	loadCargoIDsTbl(self.tbl_CargoIDs);
	beginNotification(self.myRoadJob,Object_Delete_Event ,Response_Continuous, 0);
	beginNotification(self.myRoadJob,Object_Update_Event ,Response_Continuous, 0);
	
	// PAR #19664
	self.txt_CargoID.setFocus();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupPackingTable" id="9239e111-2c15-4898-902e-122fb84d7a27">
        <source>setupPackingTable(_tbl: CM_MobTable io; intColumns: Integer io; strHeader: String io);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 May 2009	#cnwdz2	 

*/

vars

begin
	self.getTblLoadSettings(intColumns, strHeader);
	_tbl.wordWrap := true;
	_tbl.scrollBars := _tbl.ScrollBars_None;
	inheritMethod(_tbl, intColumns, strHeader);
epilog

end;</source>
        <Parameter name="_tbl" type="CM_MobTable" usage="io"/>
        <Parameter name="intColumns" type="Integer" usage="io"/>
        <Parameter name="strHeader" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="c64e5363-3130-4ac7-b347-d5398dbe28e7">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;

vars

begin
	if theObject = myRoadJob then
		if eventType = Object_Delete_Event then
			if not blnRoadExit then							//+cnwml2 PAR19692
				app.msgBox(app.getErrorString(RoadJobDeleted),"Truck Done", MsgBox_OK_Only);
				self.forceClose := true;
			endif;
			self.unloadForm;
		elseif eventType = Object_Update_Event then
			self.loadCargoIDsTbl(self.tbl_CargoIDs);
		endif;
	endif;
end;
</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="87d777b9-77a1-4446-a278-25b3374ebbdc">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018470, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
