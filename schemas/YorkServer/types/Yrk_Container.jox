    <JadeMethod name="setAlarmOff" id="15527b0c-df8f-4acf-a9f7-bd35e58ffac0">
        <updating/>
        <source>setAlarmOff() updating;

vars

begin
	self.alarm := "N";
end;</source>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="716eec7d-ed6d-4ea7-9b24-bfa3153a48b9">
        <updating/>
        <source>setForUpdate(_alarm,_bulbMode,_client,_comMode,_contType,_drains,_facType,_fanSet,_id,_remark:String;
             _height,_length:Integer;
             _intervalDefrost,_hmc,_tempActSetpoint,_tempDefrost,_tempExpSetpoint,_tempMax,_tempMin,_tempReturn,_tempSupply,_vent:Real;
             _config:Yrk_Configuration;_location:String) updating;

vars

begin
	self.alarm := "N";
	self.bulbMode := _bulbMode;
	self.client := _client;
	self.comMode := _comMode;
	self.contType := _contType;
	self.drains := _drains;
	self.facType := _facType;
	self.fanSet := _fanSet;
	self.height := _height;
	self.hmc := _hmc;
	self.id := _id;
	self.intervalDefrost := _intervalDefrost;
	self.length := _length;
	self.remark := _remark;
	self.tempActSetpoint := _tempActSetpoint;
	self.tempDefrost := _tempDefrost;
	self.tempExpSetpoint := _tempExpSetpoint;
	self.tempMax := _tempMax;
	self.tempMin := _tempMin;
	self.tempReturn := _tempReturn;
	self.tempSupply := _tempSupply;
	self.vent := _vent;
	self.myConfiguration := _config;
	self.locationID := _location;
end;</source>
        <Parameter name="_alarm" type="String"/>
        <Parameter name="_bulbMode" type="String"/>
        <Parameter name="_client" type="String"/>
        <Parameter name="_comMode" type="String"/>
        <Parameter name="_contType" type="String"/>
        <Parameter name="_drains" type="String"/>
        <Parameter name="_facType" type="String"/>
        <Parameter name="_fanSet" type="String"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_remark" type="String"/>
        <Parameter name="_height" type="Integer"/>
        <Parameter name="_length" type="Integer"/>
        <Parameter name="_intervalDefrost" type="Real"/>
        <Parameter name="_hmc" type="Real"/>
        <Parameter name="_tempActSetpoint" type="Real"/>
        <Parameter name="_tempDefrost" type="Real"/>
        <Parameter name="_tempExpSetpoint" type="Real"/>
        <Parameter name="_tempMax" type="Real"/>
        <Parameter name="_tempMin" type="Real"/>
        <Parameter name="_tempReturn" type="Real"/>
        <Parameter name="_tempSupply" type="Real"/>
        <Parameter name="_vent" type="Real"/>
        <Parameter name="_config" type="Yrk_Configuration"/>
        <Parameter name="_location" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTempSupply" id="680c9a9a-a8b7-4ad8-b5a3-ff3643217d23">
        <updating/>
        <source>setTempSupply(_temp:Real) updating;

vars

begin
	self.tempSupply := _temp;
	
	if _temp &gt; -2.0 then
		self.tempReturn := _temp + 0.2;
	else
		self.tempReturn := NULL_TEMPERATURE;
	endif;
	
	if _temp &lt; self.tempMin or _temp &gt; self.tempMax then
		self.alarm := "Y";
	endif;

end;</source>
        <Parameter name="_temp" type="Real"/>
    </JadeMethod>
    <JadeMethod name="sizeTypeString" id="f7b7acfb-d3a6-48a1-a653-273e6d23c163">
        <source>sizeTypeString():String;

vars
	message: String;
begin
	message := self.length.String.padBlanks(3)[1:2]&amp;self.height.String.padBlanks(3)[1:2]&amp;self.contType.padBlanks(2);
	return message;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="tempString" id="88bda1a3-d353-4696-bf48-e105f8491416">
        <source>tempString(_temp:Real):String protected;

vars
	message: String;
	tString: String;
	tReal: Real;
	tInteger: Integer;
begin
	if _temp = NULL_TEMPERATURE then
		return "        C";
	endif; 
	//message := (_temp.userNumberFormat($CM_Temperature)&amp;"C").String.padLeftBlanks(9);
	//	AER Par 14632
	message := (_temp.asStringJMTWithPrecision(PRECISION_TEMPERATURE, false)&amp;"C").String.padLeftBlanks(9);
	return message[1:9];
end;</source>
        <access>protected</access>
        <Parameter name="_temp" type="Real"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="tempsCommTimes" id="902a7f91-972a-47f8-8b68-7e502fe513cd">
        <source>tempsCommTimes():String;

vars
	message	: String;
	firstCom: TimeStamp;
	now		: TimeStamp;
	time	: Time;
begin

	if firstCom.time.minute &gt; 10 then
		time.setTime(firstCom.time.hour, firstCom.time.minute-4, 00, 00);
	else
		time.setTime(firstCom.time.hour, 00, 00, 00);
	endif;
	
	firstCom.setTime(time);
	
	message := self.tempString(self.tempMin)&amp;	
		self.tempString(self.tempMax)&amp;	
		self.tempString(self.tempMin)&amp;
		app.timeOfActLMT(firstCom)&amp;
		app.timeOfActLMT(now);

	return message;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="ventString" id="1385f646-db1d-4b9f-bdca-47ed543a6c7f">
        <source>ventString(_vent:Real):String;

vars
	message: String;
begin
	//message := (_vent.userNumberFormat($CM_Temperature)&amp;"M").String.padLeftBlanks(9);
	//	AER Par 14632
	message := (_vent.asStringJMTWithPrecision(PRECISION_TEMPERATURE, false)&amp;"M").String.padLeftBlanks(9);
	return message[1:9];
end;</source>
        <Parameter name="_vent" type="Real"/>
        <ReturnType type="String"/>
    </JadeMethod>
