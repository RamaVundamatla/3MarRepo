    <JadeMethod name="setBankAvailAllocCriteria" id="38d17918-16ad-42cd-ac95-d01a223334eb">
        <updating/>
        <source>setBankAvailAllocCriteria() protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 August 2012	cnwndl1	Initial creation

*/

vars

	critTypeStrArray : StringArray;
	propString : String;
	critType : CM_YACriteriaType;

begin

	create critTypeStrArray transient;
	
	critType := app.myRoot.allYACriteriaTypes.getAtKey(2);	//Cargo Type
	//critTypeStrArray.add( critType.getTypeName );
	critTypeStrArray.add( critType.description );	//09 Oct 2013	NDL	Par 32456
	critType := app.myRoot.allYACriteriaTypes.getAtKey(5);	// Commodity
	//critTypeStrArray.add( critType.getTypeName );
	critTypeStrArray.add( critType.description );	//09 Oct 2013	NDL	Par 32456
	critType := app.myRoot.allYACriteriaTypes.getAtKey(14);	// Iso Type
	//critTypeStrArray.add( critType.getTypeName );
	critTypeStrArray.add( critType.description );	//09 Oct 2013	NDL	Par 32456
	
	//app.myTrxUA.trxUpdateBankProforma(self.myBank, critTypeStrArray, app.myPassport);
	app.myTrxUA.trxUpdateBankProforma(self.myBank, critTypeStrArray, false, app.myPassport); //22/01/2025	navkc1 JIRA Bug MTN-33836
	
	self.assertTrueMsg(app.myPassport.noErrors, "Bank Criteria update failed - " &amp; app.myPassport.getAllErrorsWarningsAsString);

epilog

	delete critTypeStrArray;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setBankProFormaAllocBBlk" id="874cf24f-ac4b-4ba0-8ab5-3e99d5c2aead">
        <source>setBankProFormaAllocBBlk() protected;
/*
Purpose - 	
Who - NAVAB1
Date - 02MAY2025
ADO - JIRA 34760
*/

vars

	proxyCriteria: CM_YACriteria;
	proxyProCrit : CM_ProformaTransactionCriteria;
	realProCrit : CM_ProformaTransactionCriteria;
	itemCode : String;
	value : Any;
	criterias: CMIF_Array;
	cmifCriteria : CMIF_YACriteriaPriority;
	selectedTrxTypes : CM_TransactionTypeByType;
	str : String;
	critType : CM_YACriteriaType;
	ct	: CM_CargoType;
begin
	// delete old instances first - these were accumulating
	beginTransaction;
	self.myBank.allProformaCriteria.purge();
	commitTransaction;

	create criterias transient;
	
	critType := app.myRoot.allYACriteriaTypes.getAtKey(2);	//Cargo Type
	create proxyCriteria transient;
	itemCode := critType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	
	if self.opts.includesKey("CargoType") then
		ct := self.opts.obj("CargoType").CM_CargoType;
		self.assertNotNullMsg(ct, "Failed to get cargo type");
		value := ct.abbreviation;
	endif;
	self.assertNotNullMsg(value, "Failed to get cargo type abbr");
	proxyCriteria.setProxy(critType, value, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	criterias.add(cmifCriteria);
	
	create selectedTrxTypes transient;
	selectedTrxTypes.add( app.myRoot.allTransactionTypes[TRANS_TYPE_REC_SHIP] );
	
	create proxyProCrit transient;
	proxyProCrit.setProxy( criterias, selectedTrxTypes, 2, self.myBank, null, null, null, null, null,null );
	app.myTrxCA.trxCreateProformaCriteria(proxyProCrit, realProCrit, app.myPassport);
	self.assertTrueMsg(app.myPassport.noErrors, "Pro Forma allocation create failed - " &amp; app.myPassport.getAllErrorsWarningsAsString);
	delete proxyProCrit;
	
	//Add units to the transactions associated with the allocation....
	self.addUnitToProFormaAlloc( realProCrit );
	
	self.allProCriteria.add( realProCrit );

epilog
	if criterias &lt;&gt; null then
		if not criterias.isEmpty then
			criterias.purge();
		endif;
		delete criterias;
	endif;
	delete criterias;
	delete selectedTrxTypes;
	delete proxyProCrit;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setBankProFormaAllocations" id="72ec9dd0-9b64-4301-875b-e0de1f2b7008">
        <source>setBankProFormaAllocations() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 August 2012	cnwndl1	Initial creation

*/

vars

	proxyCriteria: CM_YACriteria;
	proxyProCrit : CM_ProformaTransactionCriteria;
	realProCrit : CM_ProformaTransactionCriteria;
	itemCode : String;
	value : Any;
	criterias: CMIF_Array;
	cmifCriteria : CMIF_YACriteriaPriority;
	selectedTrxTypes : CM_TransactionTypeByType;
	str : String;
	critType : CM_YACriteriaType;

begin
	// delete old instances first - these were accumulating
	beginTransaction;
	self.myBank.allProformaCriteria.purge();
	commitTransaction;

	create criterias transient;
	
	critType := app.myRoot.allYACriteriaTypes.getAtKey(2);	//Cargo Type
	create proxyCriteria transient;
	itemCode := critType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	value := app.myRoot.allCargoTypesById[TI_CargoType_Container].CM_CargoType.abbreviation;
	proxyCriteria.setProxy(critType, value, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	criterias.add(cmifCriteria);
	
	create selectedTrxTypes transient;
	selectedTrxTypes.add( app.myRoot.allTransactionTypes[2] ); // Edit transaction
	selectedTrxTypes.add( app.myRoot.allTransactionTypes[11] ); // Wash
	selectedTrxTypes.add( app.myRoot.allTransactionTypes[12] ); // Seal
	selectedTrxTypes.add( app.myRoot.allTransactionTypes[101] ); // Information
	
	create proxyProCrit transient;
	proxyProCrit.setProxy( criterias, selectedTrxTypes, 2, self.myBank, null, null, null, null, null,null );
	app.myTrxCA.trxCreateProformaCriteria(proxyProCrit, realProCrit, app.myPassport);
	self.assertTrueMsg(app.myPassport.noErrors, "Pro Forma allocation create failed - " &amp; app.myPassport.getAllErrorsWarningsAsString);
	delete proxyProCrit;
	
	//Add units to the transactions associated with the allocation....
	self.addUnitToProFormaAlloc( realProCrit );
	
	self.allProCriteria.add( realProCrit );

epilog
	if criterias &lt;&gt; null then
		if not criterias.isEmpty then
			criterias.purge();
		endif;
		delete criterias;
	endif;
	delete criterias;
	delete selectedTrxTypes;
	delete proxyProCrit;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setTaxOnBank" id="64d05c48-1237-4a3d-a15a-c86e5a260af7">
        <source>setTaxOnBank( _enable : Boolean ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin

	if self.myBank &lt;&gt; null then
		beginTransaction;
		if _enable then
			self.myBank.setPropertyValue( CM_Bank::taxPercentageRate.name, 15.0 );
			self.myBank.setPropertyValue( CM_Bank::taxNarration.name, "GST" );
		else
			self.myBank.setPropertyValue( CM_Bank::taxPercentageRate.name, 0.0 );
			self.myBank.setPropertyValue( CM_Bank::taxNarration.name, null );
		endif;
		commitTransaction;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tAgentDebtor" id="f4c8dd98-c0b1-4d6d-aa30-aa3ebd3622e7">
        <source>tAgentDebtor();
// cnwma1
// cnwjre1	CCMS GLT 2342
//	Test new trxCreateAgentDebtor and trxUpdateAgentDebtor
vars

	cmif		: CMIF_AgentDebtor;
	realAgent	: CM_Object;
	consignee	: CM_ConsigneeConsignor;
	customsAgent : CM_CustomsAgent;
	debtor,
	realDebtor	: CM_Debtor;
begin


	self.deleteConsigneeConsignor("UXAD1");
	self.deleteConsigneeConsignor("UXAD2");
	self.deleteCustomsAgent("UXAD2");
	self.deleteDebtor("UXAD1 Debtor");
	self.deleteDebtor("UXAD1 Debtor 2");
	self.deleteDebtor("UXAD2 Debtor");
	self.deleteDebtor("UXAD2 Debtor 2");
	
	create cmif transient;

	// first consignee add
	cmif.agentCode := "UXAD1";
	cmif.agentDescription := "Consignee and debtor";
	cmif.debtorName := "UXAD1 Debtor";
	cmif.debtorAddress := "123 Here" &amp; CrLf &amp; "456 There";
	cmif.isCashOnly := true;
	cmif.isConsignor := true;
	cmif.isConsignee := true;
	cmif.isFreightForwarder := true;
	cmif.agentType := CONSIGNEE;
	
	app.myTrxCA.trxCreateAgentDebtor(cmif, realAgent, realDebtor, app.myPassport);
	self.assertNotNullMsg(realAgent,"Agent Debtor " &amp; cmif.agentCode &amp; " Was not created, itis NULL!");
	
	self.assertTrueMsg(realAgent.isKindOf(CM_ConsigneeConsignor), "Is consignee");
	consignee := realAgent.CM_ConsigneeConsignor;
	self.assertEqualMsg(consignee.description, "Consignee and debtor", "Consignee description");
	
	self.assertNotNullMsg(realDebtor, "First debtor");
	self.assertEqualMsg(realDebtor.name, "UXAD1 Debtor", "Debtor name");
	
	
	// consignee update
	cmif.agentDescription := "Consignee AND debtor";
	cmif.debtorName := "UXAD1 Debtor 2";
	app.myTrxUA.trxUpdateAgentDebtor(cmif, realAgent, realDebtor, app.myPassport);
	self.assertEqualMsg(consignee.description, "Consignee AND debtor", "Consignee description 2");
	self.assertEqualMsg(realDebtor.name, "UXAD1 Debtor 2", "Debtor name updated");

	// second consignee add, existing debtor
	cmif.agentCode := "UXAD2";
	cmif.agentDescription := "Consignee with existing debtor";
	debtor := CM_Root.firstInstance.myRootCompany.debtors["UT_Cash4"];
	cmif.myDebtor := debtor;
	app.myTrxCA.trxCreateAgentDebtor(cmif, realAgent, realDebtor, app.myPassport);
	consignee := realAgent.CM_ConsigneeConsignor;
	
	self.assertNotNullMsg(consignee,"Agent Debtor " &amp; cmif.agentCode &amp; " Was not created, it is NULL!");
	
	
	self.assertEqualMsg(consignee.description, "Consignee with existing debtor", "Consignee 2 description");
	self.assertEqualMsg(consignee.debtor.name, "UT_Cash4", "Debtor for consignee 2");

	// Customs agent
	cmif.agentCode := "UXAD2";
	cmif.agentDescription := "Customs agent and debtor";
	cmif.debtorName := "UXAD2 Debtor";
	cmif.debtorAddress := "234 Here" &amp; CrLf &amp; "567 There";
	cmif.myDebtor := null;
	cmif.isCashOnly := true;
	cmif.agentType := CUSTOMS_AGENT;
	realAgent := null;
	realDebtor := null;
	
	app.myTrxCA.trxCreateAgentDebtor(cmif, realAgent, realDebtor, app.myPassport);
	
	self.assertNotNullMsg(realAgent,"Agent Debtor " &amp; cmif.agentCode &amp; " Was not created, itis NULL!");

	self.assertTrueMsg(realAgent.isKindOf(CM_CustomsAgent), "Is customs agent");
	customsAgent := realAgent.CM_CustomsAgent;
	self.assertEqualMsg(customsAgent.name, "Customs agent and debtor", "Customs agent description");
	
	self.assertNotNullMsg(realDebtor, "Second debtor");
	self.assertEqualMsg(realDebtor.name, "UXAD2 Debtor", "C/A Debtor name");
	
	// customs agent, change description and debtor name
	cmif.agentDescription := "Customs agent AND debtor";
	cmif.debtorName := "UXAD2 Debtor 2";
	app.myTrxUA.trxUpdateAgentDebtor(cmif, realAgent, realDebtor, app.myPassport);
	self.assertEqualMsg(customsAgent.name, "Customs agent AND debtor", "C/A agent description 2");
	self.assertEqualMsg(realDebtor.name, "UXAD2 Debtor 2", "C/A Debtor name updated");
	
	// customs agent, change to a different debtor
	debtor := CM_Root.firstInstance.myRootCompany.debtors["UT_Cash4"];
	cmif.myDebtor := debtor;
	app.myTrxUA.trxUpdateAgentDebtor(cmif, realAgent, realDebtor, app.myPassport);
	self.assertEqualMsg(customsAgent.myDebtor.name, "UT_Cash4", "C/A new Debtor");

epilog
	delete cmif;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCashAPINotPrepay" id="c82738b7-643a-41e4-8bc0-58a0f248d4ef">
        <updating/>
        <source>tCashAPINotPrepay() updating;
/*
Purpose - 	when a cash receipt is created by the cash API the cash receipt shoudl have a paymentType of zero (PaymentType_None), not a valu of 2 (PaymentType_PrePay).
Who - NAVAB1
Date -05JUN2025
ADO - JIRA 35031
*/


constants
	CEN = "UTCEN";
	CEN2 = "UTCEN2";
	VOYCODE = "CASHAPIVOY";
	VESSCODE = "CASHAPIVESS";
	CARGOID = "33930-1";
	CARGOID2 = "33930-2";
	CARGOID3 = "33930-3";
	CARGOID4 = "33930-4";
	CARGOID5 = "33930-5";
	TRANMAP = "CASHAPI";
	EXTUSER1 = "USER1";
	EXTUSER2 = "USER2";
	INVLINEDESC1 = "UT33930-1";
	INVLINEDESC2 = "UT33930-2";
	INVLINEDESC3 = "UT33930-3";
	INVLINEDESC4 = "UT33930-4";
	TODOTASKDESC = "33930TDT";
	TRUCKID = "33930T";
	CARRIERID = "33930C";
vars
	err,
	fileContext,				
	itemCode,
	cargoId3,
	voyCode,
	agentId					: String;
	
	today,
	effectiveDate 			: Date;
	
	ts						: TimeStamp;
	
	vvr						: CM_VehicleVisitRecord;
	tm						: CM_TranMap;
	voyage					: CM_Voyage;
	operator				: CM_Operator;
	ti, ti3		: CM_TrackedItem;
	debtorType				: CM_DebtorType;
	customagent				: CM_CustomsAgent;
	terminal				: CM_Terminal;
	debtorNode				: CM_DebtorNode;
	debtor					: CM_Debtor;
	debtorTerminal			: CM_DebtorTerminal;
	bank					: CM_Bank;
	proxyCriteria			: CM_YACriteria;
	proxyProCrit 			: CM_ProformaTransactionCriteria;
	realProCrit 			: CM_ProformaTransactionCriteria;
	value 					: Any;
	criterias				: CMIF_Array;
	cmifCriteria 			: CMIF_YACriteriaPriority;
	selectedTrxTypes		: CM_TransactionTypeByType;
	critType 				: CM_YACriteriaType;
	pxyTransService 		: CM_TransServiceBroker;
	cashReceipt3		: CM_CashReceipt;
	invLineDesc1,
	invLineDesc2,
	invLineDesc3,
	invLineDesc4			: CM_InvoiceLineDesc;
	services				: CM_ServiceByNameDict;
	cmifCashAgent			: CMIF_CashInvoiceProformaCtrl;
	tiSet					: CM_TISet;
	toDoTaskDesc			: CM_ToDoTaskDesc;
	ta1						: CM_TerminalArea;
	tiTrans					: CM_TITransaction;
	storageConfig			: CM_StorageConfig;
begin
	//return;
	create services transient;
	create cmifCashAgent transient;
	create tiSet transient; 
	// Terminal Area
	ta1 := self.addBlockStack("UTPHT1",9999999,null);
	self.assertNotNullMsg(ta1, "Failed to create TA1");
	// Terminal
	terminal := self.getMyTerminal();
	
	// Operator
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	// Custom Agent
	
	customagent := self.addCustomsAgent("APIAGENT", "UTCASHAPI");
	self.assertNotNullMsg(customagent, "Failed to create customs agent");
	
	// Delete Truck
	self.deleteVehicle(TRUCKID);
	self.deleteCarrier(CARRIERID);
	
	// Create To Do Task Desc
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[TODOTASKDESC];
	if toDoTaskDesc &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTaskDesc);
	endif;
	
	self.opts.purge();
	self.opts.addAssoc("CargoType", app.myRoot.allCargoTypesById[TI_CargoType_BreakBulk]);
	toDoTaskDesc := self.createToDoTaskDesc(TODOTASKDESC);
	self.assertNotNullMsg(toDoTaskDesc, "Failed to create to do task desc");
	
	
	// Debtor
	debtor := self.getDebtor("APIDEBT");
	if debtor = null then
		debtorNode := self.addDebtor("APIDEBT", PaymentType_None);
		debtor := debtorNode.CM_Debtor;
	endif;
	beginTransaction;
		customagent.setDebtor(debtor);
	commitTransaction;
	debtorTerminal := debtor.allDebtorTerminals[terminal];
	self.setDebtorCashOnly(debtor, terminal, true);
	
	// Set terminal to Cash config
	self.enableCashOnlyTerminal(terminal, true);
	self.setTerminalConfig(CashRoadExitChkServices, true);
	self.setTerminalConfig(CashOnlyInDebtOption, 1);
	
	// Get Invoice Line Type
	invLineDesc1 := self.getInvoiceLineType(INVLINEDESC1); // Days Since receival
	self.assertNotNullMsg(invLineDesc1, "Failed to get invoice line type 1");
	invLineDesc2 := self.getInvoiceLineType(INVLINEDESC2); // Cargo Value of 1
	self.assertNotNullMsg(invLineDesc2, "Failed to get invoice line type 2");
	invLineDesc3 := self.getInvoiceLineType(INVLINEDESC3); // Storage days on site by volune
	self.assertNotNullMsg(invLineDesc3, "Failed to get invoice line type 3");
	invLineDesc4 := self.getInvoiceLineType(INVLINEDESC4); // Storage days on site by volume
	self.assertNotNullMsg(invLineDesc4, "Failed to get invoice line type 4");
	
	// Setup transaction mapping
	tm := self.getTransactionMap(TRANMAP);
	if tm = null then
		tm := self.createTransactionMap(TRANMAP);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;	
	self.assertNotNullMsg(tm, "Failed to create transaction mapping");
	app.myTrxUA.trxUpdateBankTMActive(tm, app.myPassport);
	
	fileContext := 
'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Transfer Type,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?,Is Work Order Requested?
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) †,(Default),,,**Any**,All,VOID
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),Released - Road,,(Default),(Default) †,(Default),,,**Any**,All,UT33930-1
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),Todo Task Added,,(Default),(Default) ›,(Default),,,**Any**,All,UT33930-2
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),Storage,,(Default),|CCT07|Days Onsite At 00:00:00 »,08 to 12,,,**Any**,Highest 1,UT33930-3
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),Storage,,(Default),|CCT07|Days Onsite At 00:00:00 »,13 to MAX,,,**Any**,Highest 1,UT33930-4';

	self.transactionMapLoad(fileContext, null);
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	
	// Setup cash config
	debtorType := app.myRoot.allDebtorTypes["SDT6"];
	self.assertNotNullMsg(debtorType, "Failed to get cash debtor type");
	self.setTerminalConfig(CashDebtorType, debtorType);
	
	bank := terminal.getDefaultCompanyBank();
	
	create criterias transient;
	critType := app.myRoot.allYACriteriaTypes.getAtKey(19);	//Operator
	create proxyCriteria transient;
	itemCode := critType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	value := operator.code;
	proxyCriteria.setProxy(critType, value, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	criterias.add(cmifCriteria);
	
	create selectedTrxTypes transient;
	selectedTrxTypes.add( app.myRoot.allTransactionTypes[32] ); // Receive Ship
	
	create proxyProCrit transient;
	proxyProCrit.setProxy( criterias, selectedTrxTypes, 2, bank, null, null, null, null, null,null );
	app.myTrxCA.trxCreateProformaCriteria(proxyProCrit, realProCrit, app.myPassport);
	self.assertTrueMsg(app.myPassport.noErrors, "Pro Forma allocation create failed - " &amp; app.myPassport.getAllErrorsWarningsAsString);
	delete proxyProCrit;
	
	// Setup storage config
	self.deleteStorageConfig(true);
	storageConfig := terminal.myStorageConfig;
	
	// Hacky way to include first day, so the storage gets calculated 
	beginTransaction;
		storageConfig.setPropertyValue("includeFirstDay", true);
	commitTransaction;
	
	// Create voyage
	self.opts.purge();
	
	self.opts.addAssoc("dateArrival", today.addDays(-30));
	voyage := self.createVesselVoyage(VOYCODE, VESSCODE, operator);
	self.assertNotNullMsg(voyage, "Failed to create voyage");
	cargoId3 := CARGOID3&amp;today.asStringJMT();
	self.opts.purge();
	
	// Create cargo 3
	ti3 := self.getTrackedItem(cargoId3);
	if ti3 &lt;&gt; null then
		self.deleteTrackedItem(ti3, true);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;
	
	// Cargo 3
	ti3 := self.addCargoForVoyage(voyage, cargoId3);
	self.assertNotNullMsg(ti3, "Failed to creatt TI3");
	self.editIMEXStatus(ti3, TI_IMEX_STATUS_IMPORT, true);
	
	// Set Customs Agent and Customs Entry Number to all cargo
	beginTransaction;
	ti3.setCustomsAgent(customagent);
	ti3.setCustomsEntryNumber(CEN);
	commitTransaction;
	
	// Discharge Cargo and set it to be 30 days ago
	tiSet.clear();
	tiSet.add(ti3);
	self.moveCargo(ti3, tiSet, ta1.allLocationsControllers.first(), app.myPassport);
	beginTransaction;
		foreach ti in tiSet do
			tiTrans := ti.getLastTransOfType(TRANS_TYPE_REC_SHIP); // Received Ship transaction
			ts.setDate(today.addDays(-30));
			tiTrans.setPropertyValue("dateTime", ts);
			ti.setPropertyValue("receivedDT", ts);
		endforeach;
	commitTransaction;
	
	self.opts.purge();
	self.opts.addAssoc("CENum", CEN);
	
	// Delete stops
	foreach ti in tiSet do
		self.deleteStops(ti);
	endforeach;
	
	tiSet.clear();
	
		
		// Init details for Cash CMIF
		voyCode := voyage.code;
		today := app.actualTimeServer().date();
		effectiveDate := today.addDays(30);
		agentId := customagent.code;
		
		// Initialize CMIF	
		delete cmifCashAgent;
		create cmifCashAgent transient;
		cmifCashAgent.initialize(voyCode, null, CEN, cargoId3, effectiveDate, voyage.arrivedDT.date(), terminal, agentId, false, true);
		cmifCashAgent.doValidateCashCalculate(err);
		self.assertNullMsg(err, "TI3 - CMIF agent validation failed - " &amp; err&amp; ", " &amp; app.myPassport.getAllErrorsWarningsAsString());
		
		// Do calulate cash amout
		cmifCashAgent.doCalculate();
		
		// Get Cash receipt
		cashReceipt3 := cmifCashAgent.myNewCashReceipt;
		self.assertNotNullMsg(cashReceipt3, "CR3 - Failed to create cash receipt");
		self.assertTrueMsg(cashReceipt3.paymentType = PaymentType_None, "CR3 - wrong payment Type");
		
	
epilog
	self.deleteVehicle(TRUCKID);
	self.resetDefaultTranMap();
	self.deleteVoyage(VOYCODE);
	self.deleteTrackedItem(ti3, true);
	self.deleteVessel(VESSCODE);
	if criterias &lt;&gt; null then
		criterias.purge();
	endif;
	delete criterias;
	delete selectedTrxTypes;
	delete proxyProCrit;
	if realProCrit &lt;&gt; null then
		app.myTrxDA.trxDeleteProformaCriteria(realProCrit, app.myPassport);
	endif;
	if cashReceipt3 &lt;&gt; null then
		app.myTrxDA.trxDeleteCashReceipt(cashReceipt3);
	endif;
	delete pxyTransService;
	delete services;
	delete cmifCashAgent;
	delete tiSet;
	if vvr &lt;&gt; null and app.isValidObject(vvr) then
		self.deleteVVR(vvr);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCashChildCargo" id="286253a6-67ee-4d24-8928-dda61411ca16">
        <updating/>
        <source>tCashChildCargo() updating;
// cnwma1

/*

Purpose:		Cash module testing with child cargo and parent container all being charged together.  Par 34800.

Parameters:			

Return Value:		


Date		Who		Reason
26/08/2014	cnwjre1	Par 34800.
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
*/

constants

vars
	isDutyDoc	: Boolean;
	multiTax	: Boolean;
	noImportStops	: Boolean;
	cargoId		: String;
	debtorName	: String;
	cargoIds	: StringArray;
	
	drTerm1 : CM_DebtorTerminal;
	drTerm2 : CM_DebtorTerminal;
	currentFinClass	: CM_ExtFinanceIO;
	
	costs : DecimalArray;
	service : CM_Service;
	debtorRate : CM_DebtorRate;

	endDate : Date;
	
	carrier : CM_Carrier;
	truckOut : CM_Vehicle;
	
	debtor		: CM_Debtor;
	proxyDebtor		: CM_Debtor;
	debtorNode	: CM_DebtorNode;
	debtorNodeController	: CMIF_DebtorNode;
	debtorType	: CM_DebtorType;
	cashInvType,
	invType			: CM_InvoiceDesc;
	invLineType1  	: CM_InvoiceLineDesc;
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
begin

	cashInvType := self.getInvoiceType("UT_InvType");		// cash receipt invoice type

	// turn off duty docs to get all the latest code; turn off terminal multi tax to avoid tax
	isDutyDoc := self.myTerminal.getConfig(DutyDocumentationEnabled).Boolean;
	multiTax := self.myTerminal.getConfig(InvoiceMultiTaxRates).Boolean;
	noImportStops := self.myTerminal.getConfig(NoImportStops).Boolean;
	// set Oracle financials to get their external cash receipt number
	currentFinClass := getInvoiceFinancialClass();
	self.setInvoiceFinancialClass(CM_OracleFinancials, null);
	self.setTerminalConfig(DutyDocumentationEnabled, false);
	self.setDefaultBankCashInvoiceType(cashInvType);
	self.setTerminalConfig(InvoiceMultiTaxRates, false);
	self.setTerminalConfig(NoImportStops, true);

	create cargoIds transient;
	self.deleteContainer("UTTU0010191");
	
	self.setTaxOnBank( false );
	
	// use an operator with a known non-cash debtor
	operator := self.getOperator("UTC1");
	if operator = null then
		operator := self.addOperatorSimple("UTC1", "Cash Test Operator");
	endif;
	debtorName := "UT_Debtor1";
	debtor := app.myRoot.myRootCompany.debtorNodes[debtorName].CM_Debtor;
	if debtor = null then
		create debtorNodeController transient;
		create proxyDebtor transient;
		self.setDebtorNodeController1(debtorName, debtorNodeController, proxyDebtor);
		app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		debtor := debtorNode.CM_Debtor;
	endif;

	beginTransaction;
		operator.setPropertyValue(CM_Operator::debtor.name, debtor);
	commitTransaction;
	self.myOperator := operator;
	
	endDate := app.actualTimeServer.Date + 10;	// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support

	//set terminal to be cash enabled.
	self.enableCashOnlyTerminal( self.myTerminal, true );
	
	//set up criteria permitted for this Bank in this terminal on pro forma allocation
	self.setBankAvailAllocCriteria();
	
	//set up Bank pro forma allocation
	self.setBankProFormaAllocations();
	
	//create Method of payment if needed
	self.myPaymentMethod :=  app.myRoot.allPaymentMethods.getAtKey(PayMethName);
	if self.myPaymentMethod = null then
		self.myPaymentMethod := self.createPaymentMethod(PayMethName);
	endif;
	self.assertTrueMsg(self.myPaymentMethod &lt;&gt; null, "Payment Method not created...");
	
	//create cash only debtor.
	self.myDebtor1 := app.myRoot.myRootCompany.debtors[DrNameOne];
	if self.myDebtor1 = null then
		self.myDebtor1 := self.addCashOnlyDebtor( DrNameOne );
	endif;
	self.assertTrueMsg(self.myDebtor1 &lt;&gt; null, "Cash only Debtor not created...");
	drTerm1 := self.myDebtor1.allDebtorTerminals.getAtKey( self.myTerminal );
	self.assertTrueMsg(drTerm1 &lt;&gt; null, "Debtor/Terminal not created...");
	self.assertTrueMsg(drTerm1.isCashOnly, "Debtor/Terminal is not cash only...");
	
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;

	// Voyage invoice type, ILT8 invoice line type, used in ship receive, charged to shipping operator, calc type Cargo Quantity
	invType := self.addIfNewInvoiceType("UT_Voyage");
	self.addIfNewServiceILD("UT_ServiceX8", "CCT01", "UT_ILT8", null, invType);
	// set service rate
	service := self.myBank.services["UT_ServiceX8"];		// for receive ship
	self.setServiceRate(service, debtor, "01/01/2013".Date, 100.00);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT8"];
	debtorType := app.myRoot.allDebtorTypes["SDT4"];	// cargo operator
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;

	// Yard invoice type, ILT9 invoice line type, used in yard and road release, charged to customs agent, calc type Cargo Quantity
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.addIfNewServiceILD("UT_ServiceX9", "CCT01", "UT_ILT9", null, invType);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT9"];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := self.myBank.services["UT_ServiceX9"];		// for move and road release
	self.setServiceRate(service, debtor, "01/01/2013".Date, 20.00);
	
	// Yard invoice type, ILT10 invoice line type, used in storage, charged to customs agent, calc type Days Since Receival
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.addIfNewServiceILD("UT_ServiceX10", "CCT06", "UT_ILT10", null, invType);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT10"];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := self.myBank.services["UT_ServiceX10"];		// for storage, rate per day
	self.setServiceRate(service, debtor, "01/01/2013".Date, 10.00);
	service := self.myBank.services["UT_ServiceX8"];			// receive ship, to get a value on the invoice lines
	self.setServiceRate(service, debtor, "01/01/2013".Date, 5.00);
	
	debtor := operator.debtor;
	service := self.myBank.services["UT_ServiceX8"];			// receive ship, to get a value on the invoice lines
	self.setServiceRate(service, debtor, "01/01/2013".Date, 5.00);
	
	self.myVoyage := self.createVesselVoyageCash("JMT STAR", "JSTAR001", operator.code);
	self.assertTrueMsg(self.myVoyage &lt;&gt; null, "Voyage '" &amp; CashVoyageCode &amp; "' not created...");
	// create carrier and truck
	self.deleteVehicle(VehicleNumOut);
	carrier := self.addCarrier(CarrierName, CarrierName, self.allEmails, false, true, true, self.myDebtor1);
	self.assertNotNull(carrier);
	truckOut := self.addVehicle(VehicleNumOut, carrier, self.myTerminal);
	self.assertTrueMsg(truckOut &lt;&gt; null, "Truck not created...");
	
	self.tranMapLoadCashUnpack();
	
	//Now create onsite cargo that will be gated out by truck.
	cargoId := "UTTU0010191";
	self.cashTestChildCargo(cargoId, drTerm1, truckOut);

epilog
	if currentFinClass &lt;&gt; null then
		self.setInvoiceFinancialClass(currentFinClass.class, null);
	endif;

	delete costs;
	delete debtorRate;
	delete cargoIds;
	
	self.resetDefaultTranMap();
end;</source>
    </JadeMethod>
    <JadeMethod name="tCashCredit" id="9c9481d4-8ff5-4e0e-be95-f1e10a17b243">
        <updating/>
        <source>tCashCredit() updating;
// cnwma1

/*

Purpose:		Cash credit creation.

Parameters:			

Return Value:		


Date		Who		Reason
Feb 2016	cnwjre1	37141 cash credits etc
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
*/

constants

vars
	isDutyDoc	: Boolean;
	multiTax	: Boolean;
	noImportStops	: Boolean;
	cargoId		: String;
	debtorName	: String;
	sa,
	cargoIds	: StringArray;
	
	drTerm1 : CM_DebtorTerminal;
	drTerm2 : CM_DebtorTerminal;
	currentFinClass	: CM_ExtFinanceIO;
	
	costs : DecimalArray;
	service : CM_Service;
	debtorRate : CM_DebtorRate;

	endDate : Date;
	
	carrier : CM_Carrier;
	truckOut : CM_Vehicle;
	
	rootDebtor,
	debtor		: CM_Debtor;
	proxyDebtor		: CM_Debtor;
	debtorNode	: CM_DebtorNode;
	debtorNodeController	: CMIF_DebtorNode;
	debtorType	: CM_DebtorType;
	cashInvType,
	invType			: CM_InvoiceDesc;
	invLineType1  	: CM_InvoiceLineDesc;
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
begin

	cashInvType := self.getInvoiceType("UT_InvType");		// cash receipt invoice type

	// turn off duty docs to get all the latest code; turn off terminal multi tax to avoid tax
	isDutyDoc := self.myTerminal.getConfig(DutyDocumentationEnabled).Boolean;
	multiTax := self.myTerminal.getConfig(InvoiceMultiTaxRates).Boolean;
	noImportStops := self.myTerminal.getConfig(NoImportStops).Boolean;
	// set Oracle financials to get their external cash receipt number
	currentFinClass := getInvoiceFinancialClass();
	self.setInvoiceFinancialClass(CM_OracleFinancials, null);
	self.setTerminalConfig(DutyDocumentationEnabled, false);
	self.setDefaultBankCashInvoiceType(cashInvType);
	self.setTerminalConfig(InvoiceMultiTaxRates, false);
	self.setTerminalConfig(NoImportStops, true);

	create cargoIds transient;
	self.deleteContainer("UTUT8989101");
	// ids with valid check digits
	self.getCargoIds(cargoIds);
	foreach cargoId in cargoIds do
		self.deleteContainer(cargoId);
	endforeach;
	
	self.setTaxOnBank( false );
	rootDebtor := app.myRoot.myRootCompany.rootDebtor;

	// use an operator with a known non-cash debtor
	operator := self.getOperator("UTC1");
	if operator = null then
		operator := self.addOperatorSimple("UTC1", "Cash Test Operator");
	endif;
	debtorName := "UT_Debtor1";
	debtor := app.myRoot.myRootCompany.debtorNodes[debtorName].CM_Debtor;
	if debtor = null then
		create debtorNodeController transient;
		create proxyDebtor transient;
		self.setDebtorNodeController1(debtorName, debtorNodeController, proxyDebtor);
		app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		debtor := debtorNode.CM_Debtor;
	endif;

	beginTransaction;
		operator.setPropertyValue(CM_Operator::debtor.name, debtor);
	commitTransaction;
	self.myOperator := operator;
	
	endDate := app.actualTimeServer.Date + 10;	// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support

	//set terminal to be cash enabled.
	self.enableCashOnlyTerminal( self.myTerminal, true );
	
	//set up criteria permitted for this Bank in this terminal on pro forma allocation
	self.setBankAvailAllocCriteria();
	
	//set up Bank pro forma allocation
	self.setBankProFormaAllocations();
	
	//create Method of payment if needed
	self.myPaymentMethod :=  app.myRoot.allPaymentMethods.getAtKey(PayMethName);
	if self.myPaymentMethod = null then
		self.myPaymentMethod := self.createPaymentMethod(PayMethName);
	endif;
	self.assertTrueMsg(self.myPaymentMethod &lt;&gt; null, "Payment Method not created...");
	
	//create cash only debtors.
	self.myDebtor1 := app.myRoot.myRootCompany.debtors[DrNameOne];
	if self.myDebtor1 = null then
		self.myDebtor1 := self.addCashOnlyDebtor( DrNameOne );
	endif;
	self.assertTrueMsg(self.myDebtor1 &lt;&gt; null, "Cash only Debtor not created...");
	drTerm1 := self.myDebtor1.allDebtorTerminals.getAtKey( self.myTerminal );
	self.assertTrueMsg(drTerm1 &lt;&gt; null, "Debtor/Terminal not created...");
	self.assertTrueMsg(drTerm1.isCashOnly, "Debtor/Terminal is not cash only...");
	// clear any prior credits etc
	self.zPurgeCashDebtor(drTerm1);
	
	self.myDebtor2 := app.myRoot.myRootCompany.debtors[DrNameTwo];
	if self.myDebtor2 = null then
		self.myDebtor2 := self.addCashOnlyDebtor( DrNameTwo );
	endif;
	drTerm2 := self.myDebtor2.allDebtorTerminals.getAtKey( self.myTerminal );
	// clear any prior credits etc
	self.zPurgeCashDebtor(drTerm2);

	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;

	// Voyage invoice type, ILT8 invoice line type, used in ship receive, charged to shipping operator, calc type Cargo Quantity
	invType := self.addIfNewInvoiceType("UT_Voyage");
	self.addIfNewServiceILD("UT_ServiceX8", "CCT01", "UT_ILT8", null, invType);
	// set service rate
	service := self.myBank.services["UT_ServiceX8"];		// for receive ship
	self.setServiceRate(service, debtor, "01/01/2013".Date, 100.00);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT8"];
	debtorType := app.myRoot.allDebtorTypes["SDT4"];	// cargo operator
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;

	// Yard invoice type, ILT9 invoice line type, used in yard and road release, charged to customs agent, calc type Cargo Quantity
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.addIfNewServiceILD("UT_ServiceX9", "CCT01", "UT_ILT9", null, invType);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT9"];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := self.myBank.services["UT_ServiceX9"];		// for move and road release
	self.setServiceRate(service, debtor, "01/01/2013".Date, 20.00);
	self.setServiceRate(service, rootDebtor, "01/01/2013".Date, 20.00);
	
	// Yard invoice type, ILT10 invoice line type, used in storage, charged to customs agent, calc type Days Since Receival
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.addIfNewServiceILD("UT_ServiceX10", "CCT06", "UT_ILT10", null, invType);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT10"];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	// Yard invoice type, ILT11 invoice line type, used in storage, charged to customs agent, calc type Days Since Receival
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.addIfNewServiceILD("UT_ServiceX11", "CCT06", "UT_ILT11", null, invType);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT10"];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	// set the rates
	service := self.myBank.services["UT_ServiceX10"];		// for storage, rate per day
	self.setServiceRate(service, debtor, "01/01/2013".Date, 10.00);
	self.setServiceRate(service, rootDebtor, "01/01/2013".Date, 10.00);
	service := self.myBank.services["UT_ServiceX11"];		// for storage, rate per day
	self.setServiceRate(service, debtor, "01/01/2013".Date, 10.00);
	self.setServiceRate(service, rootDebtor, "01/01/2013".Date, 10.00);
	service := self.myBank.services["UT_ServiceX8"];			// receive ship, to get a value on the invoice lines
	self.setServiceRate(service, debtor, "01/01/2013".Date, 5.00);
	self.setServiceRate(service, rootDebtor, "01/01/2013".Date, 10.00);
	
	debtor := operator.debtor;
	service := self.myBank.services["UT_ServiceX8"];			// receive ship, to get a value on the invoice lines
	self.setServiceRate(service, debtor, "01/01/2013".Date, 5.00);
	
	self.myVoyage := self.createVesselVoyageCash("JMT STAR", "JSTAR001", operator.code);
	self.assertTrueMsg(self.myVoyage &lt;&gt; null, "Voyage '" &amp; CashVoyageCode &amp; "' not created...");
	self.deleteVehicle(VehicleNumOut);
	// create carrier and truck
	carrier := self.addCarrier(CarrierName, CarrierName, self.allEmails, false, true, true, self.myDebtor1);
	self.assertNotNull(carrier);
	truckOut := self.addVehicle(VehicleNumOut, carrier, self.myTerminal);
	self.assertTrueMsg(truckOut &lt;&gt; null, "Truck not created...");
	
	self.tranMapLoadCashFull();
	
	// create a receipt and a credit against it
	cargoId := cargoIds[1];
	self.creditTest1(cargoId, drTerm1);

	// create a receipt and two credits against it
	cargoId := cargoIds[2];
	self.creditTest2(cargoId, drTerm1);
	
	// create a receipt, a credit from it and a second receipt which will use the credit with some left over
	create sa transient;
	sa.add(cargoIds[3]);
	sa.add(cargoIds[4]);
	sa.add(cargoIds[5]);
	sa.add(cargoIds[6]);
	sa.add(cargoIds[7]);
	self.creditTest3(sa, drTerm1);
epilog
	if currentFinClass &lt;&gt; null then
		self.setInvoiceFinancialClass(currentFinClass.class, null);
	endif;

	delete costs;
	delete debtorRate;
	delete cargoIds;
	delete sa;

	self.resetDefaultTranMap();
end;</source>
    </JadeMethod>
    <JadeMethod name="tCashDraftBGPFutureActor01" id="66bb3a0c-bf6a-4647-9661-ca4f91a72d9b">
        <updating/>
        <source>tCashDraftBGPFutureActor01() updating;
// JIRA 35050 10JUN2025 - check BGP is created after a draft cash receipt is created by cash API.
constants
	CEN = "UTCEN";
	CEN2 = "UTCEN2";
	VOYCODE = "CASHAPIVOY";
	VESSCODE = "CASHAPIVESS";
	CARGOID = "CASHAPITI";
	CARGOID2 = "CASHAPITI2";
	TRANMAP = "CASHAPI";
	EXTUSER1 = "USER1";
	EXTUSER2 = "USER2";

vars
	cargoId,
	cargoId2,
	responseInString,
	loginJson,
	voyCode,
	agentId			: String;
	
	today,
	effectiveDate : Date;
	
	totalAmount		: Decimal[23,6];
	
	expectFailure 	: Boolean;
	
	tm				: CM_TranMap;
	voyage			: CM_Voyage;
	operator		: CM_Operator;
	ti,
	ti2				: CM_TrackedItem;
	
	debtorType		: CM_DebtorType;
	
	customagent		: CM_CustomsAgent;
	
	terminal		: CM_Terminal;
	
	debtorNode		: CM_DebtorNode;
	debtor			: CM_Debtor;
	debtorTerminal	: CM_DebtorTerminal;
	
	bank			: CM_Bank;
	
	proxyCriteria	: CM_YACriteria;
	proxyProCrit 	: CM_ProformaTransactionCriteria;
	realProCrit 	: CM_ProformaTransactionCriteria;
	itemCode 		: String;
	value 			: Any;
	criterias		: CMIF_Array;
	cmifCriteria 	: CMIF_YACriteriaPriority;
	selectedTrxTypes: CM_TransactionTypeByType;
	critType 		: CM_YACriteriaType;
	
	fileContext		: String;
	pxyTransService : CM_TransServiceBroker;
	
	receiptNumber	: Integer;
	request			: String;
	isPaymentAllowed : Boolean;
	cashReceipt,
	cashReceipt2,
	cashReceiptForBoth	: CM_CashReceipt;
	offlineActor	: CM_OfflineFutureActor;
begin
	//return;
	loginJson := '{
   "userId": "' &amp; UT_WebFramework.USERCODE &amp; '",
   "password": "' &amp; UT_WebFramework.PASSWORD &amp; '",
    "applicationId" : "internalAPI",
    "scope" : {
        "complexId" : "Master Terminal",
		"facilityId": "' &amp; "UT" &amp; '",
        "operatorId" : "Navis",
        "yardId" : "MTN"
    }}';
	
	// Terminal
	terminal := self.getMyTerminal();
	// Operator
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	// Custom Agent
	customagent := self.addCustomsAgent("APIAGENT", "UTCASHAPI");
	self.assertNotNullMsg(customagent, "Custom Agent is null");
	// Debtor
	debtor := self.getDebtor("APIDEBT");
	if debtor = null then
		debtorNode := self.addDebtor("APIDEBT", PaymentType_None);
		debtor := debtorNode.CM_Debtor;
	endif;
	beginTransaction;
		customagent.setDebtor(debtor);
	commitTransaction;
	debtorTerminal := debtor.allDebtorTerminals[terminal];
	
	// Set terminal to Cash config
	self.enableCashOnlyTerminal(terminal, true);
	self.setTerminalConfig(UseCashStatusAdvBGP, true);
	self.setTerminalConfig(InvoiceRoundLineTotal, 6);
	// Setup transaction mapping
	tm := self.getTransactionMap(TRANMAP);
	if tm = null then
		tm := self.createTransactionMap(TRANMAP);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;
	
	self.assertNotNullMsg(tm, "CASHAPI Transaction Map is null");
	app.myTrxUA.trxUpdateBankTMActive(tm, app.myPassport);
	
	fileContext := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Transfer Type,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?,Is Work Order Requested?
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ?,(Default),,,**Any**,All,VOID
Cargo,CASHAPI,(Default),(Default),(Default),(Default),(Default),(Default),Received - Ship,,(Default),(Default) ?,(Default),,,**Any**,All,UTCASHAPI';

	self.transactionMapLoad(fileContext, null);
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	
	// Setup cash config
	debtorType := app.myRoot.allDebtorTypes["SDT6"];
	self.assertNotNullMsg(debtorType, "Debtor type is null");
	self.setTerminalConfig(CashDebtorType, debtorType);
	
	bank := terminal.getDefaultCompanyBank();
	
	create criterias transient;
	critType := app.myRoot.allYACriteriaTypes.getAtKey(19);	//Operator
	create proxyCriteria transient;
	itemCode := critType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	value := operator.code;
	proxyCriteria.setProxy(critType, value, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	criterias.add(cmifCriteria);
	
	create selectedTrxTypes transient;
	selectedTrxTypes.add( app.myRoot.allTransactionTypes[30] ); // Receive Ship
	
	create proxyProCrit transient;
	proxyProCrit.setProxy( criterias, selectedTrxTypes, 2, bank, null, null, null, null, null,null );
	app.myTrxCA.trxCreateProformaCriteria(proxyProCrit, realProCrit, app.myPassport);
	self.assertTrueMsg(app.myPassport.noErrors, "Pro Forma allocation create failed - " &amp; app.myPassport.getAllErrorsWarningsAsString);
	delete proxyProCrit;
	
	// Setup storage config
	self.deleteStorageConfig(true);
	
	// Create voyage
	voyage := self.createVesselVoyage(VOYCODE, VESSCODE, operator);
	self.assertNotNullMsg(voyage, "voyage is null");
	cargoId := CARGOID&amp;today.asStringJMT();
	cargoId2 := CARGOID2&amp;today.asStringJMT();
	
	// Create cargo 1
	ti := self.getTrackedItem(cargoId);
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, true);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;
	
	// Create cargo 2
	ti2 := self.getTrackedItem(cargoId2);
	if ti2 &lt;&gt; null then
		self.deleteTrackedItem(ti2, true);
		self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	endif;
	
	// Cargo 1
	ti := self.addCargoForVoyage(voyage, cargoId);
	self.assertNotNullMsg(ti, "TI is null");
	self.editIMEXStatus(ti, TI_IMEX_STATUS_IMPORT, true);
	beginTransaction;
	ti.setCustomsAgent(customagent);
	ti.setCustomsEntryNumber(CEN);
	commitTransaction;
	
	// Cargo 2
	ti2 := self.addCargoForVoyage(voyage, cargoId2);
	self.assertNotNullMsg(ti2, "TI2 is null");
	self.editIMEXStatus(ti2, TI_IMEX_STATUS_IMPORT, true);
	beginTransaction;
	ti2.setCustomsAgent(customagent);
	ti2.setCustomsEntryNumber(CEN2);
	commitTransaction;
	
	voyCode := voyage.code;
	today := app.actualTimeServer().date();
	effectiveDate := today.addDays(5);
	agentId := customagent.code;
	
	/*
	Scenario 1 - Missing Param - Should get error message
	*/	
	request := '{
						"bolCode" : "",
						"cargoID" : "",
						"customsAgentCode" : "",
						"customsEntryNumber" : "",
						"effectiveDate" : "",
						"externalFinancialID" : "",
						"externalReceiptNumber" : "",
						"externalRef1" : "",
						"externalTransaction" : "",
						"externalUserCode" : "",
						"remarks" : "",
						"shipReleaseDate" : "",
						"voyageCode" : ""
					}';
	// Call API for scenario 1
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaForExternal.name, request, responseInString, totalAmount, receiptNumber, expectFailure, isPaymentAllowed);

	// Verify response Scenario 1 - Missing Param Should get error message
	//self.assertTrueMsg(responseInString.pos('\"customsEntryNumber\" cannot be null.', 1) &gt; 0, "custsomEntryNumber required fields error not found"); //13/02/2025	navkc1 JIRA Story MTN-33879
	self.assertTrueMsg(responseInString.pos('\"customsAgentCode\" cannot be null', 1) &gt; 0, "customsAgentCode required fields error not found");
	//self.assertTrueMsg(responseInString.pos('\"voyageCode\" and \"customsEntryNumber\" cannot be both null. Either \"voyageCode\" or \"customsEntryNumber\" must be entered.', 1) &gt; 0, "voyageCode and customsEntryNumber required fields error not found"); //13/02/2025	navkc1 JIRA Story MTN-33879
	self.assertTrueMsg(responseInString.pos('\"externalUserCode\" cannot be null', 1) &gt; 0, "externalUserCode required fields error not found");
	self.assertTrueMsg(responseInString.pos('\"effectiveDate\" cannot be null', 1) &gt; 0, "effectiveDate required fields error not found");
	
	/*
	Scenario 2 - Good scenario - Cargo ID entered, Voyage code not entered. Should still get the CargoID from onsite and allActiveVoyage collection.
	*/

	request := '{
						"bolCode" : "",
						"cargoID" : "'&amp;cargoId&amp;'",
						"customsAgentCode" : "'&amp;agentId&amp;'",
						"customsEntryNumber" : "'&amp;CEN&amp;'",
						"effectiveDate" : "'&amp;effectiveDate.asStringJMT()&amp;'",
						"externalFinancialID" : "",
						"externalReceiptNumber" : "",
						"externalRef1" : "",
						"externalTransaction" : "",
						"externalUserCode" : "'&amp;EXTUSER1&amp;'",
						"remarks" : "",
						"shipReleaseDate" : "",
						"voyageCode" : ""
					}';
	// Call API for scenario 2
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaForExternal.name, request, responseInString, totalAmount, receiptNumber, expectFailure, isPaymentAllowed);
	// Verify response Scenario 2 - Good scenario - Should get cash receipt and amount
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	cashReceipt := debtorTerminal.allCashReceipts[receiptNumber];
	self.assertTrueMsg(cashReceipt &lt;&gt; null, "Cash receipt should not be null");
	self.assertTrueMsg(cashReceipt.cashValue = 12.551495, "Total amount is not correct"); //27/06/2025 NAVKC1 JIRA 35258
	self.assertTrueMsg(isPaymentAllowed, "Is Payment Allowed should be true");
	
	/*
	Scenario 3 - Different external user code
	*/
	request := '{
						"bolCode" : "",
						"cargoID" : "'&amp;cargoId&amp;'",
						"customsAgentCode" : "'&amp;agentId&amp;'",
						"customsEntryNumber" : "'&amp;CEN&amp;'",
						"effectiveDate" : "'&amp;effectiveDate.asStringJMT()&amp;'",
						"externalFinancialID" : "",
						"externalReceiptNumber" : "",
						"externalRef1" : "",
						"externalTransaction" : "",
						"externalUserCode" : "'&amp;EXTUSER2&amp;'",
						"remarks" : "",
						"shipReleaseDate" : "",
						"voyageCode" : ""
					}';
	// call API for scenario 3
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaForExternal.name, request, responseInString, totalAmount, receiptNumber, expectFailure, isPaymentAllowed);
	// Verify response Scenario 3 - Different external user code - Should get error
	self.assertTrueMsg(responseInString.pos('errorCode":96771,"text":"Cash Receipt API validation failed. '&amp; cargoId&amp;' is being processed by '&amp;EXTUSER1&amp;'"',1) &gt; 0, "Shoud get error other user processed the cashreceipt");
	self.assertTrueMsg(not isPaymentAllowed, "isPaymentAllowed should be false");
	
	app.myTrxDA.trxDeleteCashReceipt(cashReceipt);
	
	/*
	Scenario 4 - Good scenario. Voyage and Cargo ID entered.
	*/
	request := '{
						"bolCode" : "",
						"cargoID" : "'&amp;cargoId2&amp;'",
						"customsAgentCode" : "'&amp;agentId&amp;'",
						"customsEntryNumber" : "'&amp;CEN2&amp;'",
						"effectiveDate" : "'&amp;effectiveDate.asStringJMT()&amp;'",
						"externalFinancialID" : "",
						"externalReceiptNumber" : "",
						"externalRef1" : "",
						"externalTransaction" : "",
						"externalUserCode" : "'&amp;EXTUSER2&amp;'",
						"remarks" : "",
						"shipReleaseDate" : "",
						"voyageCode" : "'&amp;VOYCODE&amp;'"
					}';
	// call API for scenario 4
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaForExternal.name, request, responseInString, totalAmount, receiptNumber, expectFailure, isPaymentAllowed);
	// Verify response Scenario 4 - Good scenario Voyage and Cargo ID entered.
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	cashReceipt := debtorTerminal.allCashReceipts[receiptNumber];
	self.assertTrueMsg(cashReceipt &lt;&gt; null, "Cash receipt should not be null");
	self.assertTrueMsg(cashReceipt.cashValue = 12.551495, "Total amount is not correct"); //27/06/2025 NAVKC1 JIRA 35258
	self.assertTrueMsg(isPaymentAllowed, "Is Payment Allowed should be true");
	
	// Take Cargo 2 - Check BGP
	offlineActor := app.myRoot.getFutureActor(cashReceipt, CM_CashStatusAdvanceProcess);
	self.assertNotNullMsg(offlineActor, "BGP not created for the draft receipt");
	
	app.myTrxDA.trxDeleteCashReceipt(cashReceipt);
	
	
	/* //01/10/2024 navkc1 JIRA 19366  - adding more scenario
	Scenario 5 - 
				Cargo 1 in draft receipt 1
				Cargo 2 in draft receipt 2
				
				Now if call the API for both Cargo 1 and Cargo 2, MTN should delete both current draft receipt, and create one for both cargo. I.e Cargo 1 and Cargo 2 in draft receipt 1
	*/
	// Cargo 1
	request := '{
						"bolCode" : "",
						"cargoID" : "'&amp;cargoId&amp;'",
						"customsAgentCode" : "'&amp;agentId&amp;'",
						"customsEntryNumber" : "'&amp;CEN&amp;'",
						"effectiveDate" : "'&amp;effectiveDate.asStringJMT()&amp;'",
						"externalFinancialID" : "",
						"externalReceiptNumber" : "",
						"externalRef1" : "",
						"externalTransaction" : "",
						"externalUserCode" : "'&amp;EXTUSER1&amp;'",
						"remarks" : "",
						"shipReleaseDate" : "",
						"voyageCode" : "'&amp;VOYCODE&amp;'"
					}';
	// call API to create draft receipt for cargo 1
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaForExternal.name, request, responseInString, totalAmount, receiptNumber, expectFailure, isPaymentAllowed);
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	cashReceipt := debtorTerminal.allCashReceipts[receiptNumber];
	self.assertTrueMsg(cashReceipt &lt;&gt; null, "Cash receipt for Cargo 1 should not be null");
	// Cargo 2
	beginTransaction;
	ti2.allCustomsEntryNumbers.clear();
	ti2.setCustomsEntryNumber(CEN);
	commitTransaction;
	request := '{
						"bolCode" : "",
						"cargoID" : "'&amp;cargoId2&amp;'",
						"customsAgentCode" : "'&amp;agentId&amp;'",
						"customsEntryNumber" : "'&amp;CEN&amp;'",
						"effectiveDate" : "'&amp;effectiveDate.asStringJMT()&amp;'",
						"externalFinancialID" : "",
						"externalReceiptNumber" : "",
						"externalRef1" : "",
						"externalTransaction" : "",
						"externalUserCode" : "'&amp;EXTUSER1&amp;'",
						"remarks" : "",
						"shipReleaseDate" : "",
						"voyageCode" : "'&amp;VOYCODE&amp;'"
					}';
	// call API to create draft receipt for cargo 2
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaForExternal.name, request, responseInString, totalAmount, receiptNumber, expectFailure, isPaymentAllowed);
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	cashReceipt2 := debtorTerminal.allCashReceipts[receiptNumber];
	self.assertTrueMsg(cashReceipt2 &lt;&gt; null, "Cash receipt for Cargo 2 should not be null");
	// Now Cargo 1 is in cash receipt 1, Cargo 2 is in cash receipt 2
	// Do a API call again for Cargo 1 and Cargo 2 in a single request
	request := '{
						"bolCode" : "",
						"cargoID" : "'&amp;cargoId&amp;','&amp;cargoId2&amp;'",
						"customsAgentCode" : "'&amp;agentId&amp;'",
						"customsEntryNumber" : "'&amp;CEN&amp;'",
						"effectiveDate" : "'&amp;effectiveDate.asStringJMT()&amp;'",
						"externalFinancialID" : "",
						"externalReceiptNumber" : "",
						"externalRef1" : "",
						"externalTransaction" : "",
						"externalUserCode" : "'&amp;EXTUSER1&amp;'",
						"remarks" : "",
						"shipReleaseDate" : "",
						"voyageCode" : "'&amp;VOYCODE&amp;'"
					}';
	// call API to create draft receipt for both cargo
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaForExternal.name, request, responseInString, totalAmount, receiptNumber, expectFailure, isPaymentAllowed);
	self.assertNoTrxErrorsPassport(app.myPassport.getErrorsAndWarningsAsString());
	cashReceiptForBoth := debtorTerminal.allCashReceipts[receiptNumber];
	self.assertTrueMsg((cashReceipt = null or not app.isValidObject(cashReceipt)), "Cash Receipt 1 should be null/invalid, MTN should have delete it");
	self.assertTrueMsg((cashReceipt2 = null or not app.isValidObject(cashReceipt2)), "Cash Receipt 2 should be null/invalid, MTN should have delete it");
	self.assertTrueMsg(cashReceiptForBoth &lt;&gt; null, "Cash receipt for both should not be null");
	self.assertTrueMsg(cashReceiptForBoth.cashValue = 25.10299, "Total amount of Cash Receipt for both is not correct"); //27/06/2025 NAVKC1 JIRA 35258
	
	app.myTrxDA.trxDeleteCashReceipt(cashReceipt);
	
	/*
	Scenario 6 - Missing Customs Param when Customs Agent is selected in the Cash Config - Should get error message
	*/	
	request := '{
						"bolCode" : "",
						"cargoID" : "",
						"customsAgentCode" : "'&amp;agentId&amp;'",
						"customsEntryNumber" : "",
						"effectiveDate" : "'&amp;effectiveDate.asStringJMT()&amp;'",
						"externalFinancialID" : "",
						"externalReceiptNumber" : "",
						"externalRef1" : "",
						"externalTransaction" : "",
						"externalUserCode" : "'&amp;EXTUSER1&amp;'",
						"remarks" : "",
						"shipReleaseDate" : "",
						"voyageCode" : ""
					}';
	// Call API for scenario 1
	self.webServiceCallWithParams(CM_UnitTestAgent::wsRESTPutProformaForExternal.name, request, responseInString, totalAmount, receiptNumber, expectFailure, isPaymentAllowed);

	// Verify response Scenario 1 - Missing Param Should get error message
	self.assertTrueMsg(responseInString.pos('\"voyageCode\" and \"customsEntryNumber\" cannot be null. \"customsEntryNumber\" must be entered at least.', 1) &gt; 0, "voyageCode and customsEntryNumber required fields error not found"); //13/02/2025	navkc1 JIRA Story MTN-33879
	
	
epilog
	self.resetDefaultTranMap();
	self.deleteVoyage(VOYCODE);
	self.deleteTrackedItem(ti, true);
	self.deleteTrackedItem(ti2, true);
	self.deleteVessel(VESSCODE);
	if criterias &lt;&gt; null then
		criterias.purge();
	endif;
	delete criterias;
	delete selectedTrxTypes;
	delete proxyProCrit;
	if realProCrit &lt;&gt; null then
		app.myTrxDA.trxDeleteProformaCriteria(realProCrit, app.myPassport);
	endif;
	if cashReceipt &lt;&gt; null then
		app.myTrxDA.trxDeleteCashReceipt(cashReceipt);
	endif;
	if cashReceipt2 &lt;&gt; null then
		app.myTrxDA.trxDeleteCashReceipt(cashReceipt2);
	endif;
	if cashReceiptForBoth &lt;&gt; null then
		app.myTrxDA.trxDeleteCashReceipt(cashReceiptForBoth);
	endif;
	delete pxyTransService;

end;</source>
    </JadeMethod>
    <JadeMethod name="tCashEscalatingStorage" id="6da04bed-10e3-439b-9d0b-39fee2c5a7db">
        <updating/>
        <source>tCashEscalatingStorage() updating;
// cnwma1
// cnwjre1 
//	create an invoice line per range (full escalating) with 5 additional days free
//	33923 container receive date 10/09/2013 effective date 16/04/2014
//  28 Oct 2021 navma1 ChangeRequest 52163: SAL - Unicode Arabic Support Business Requirements
// 10 September 2023 navmv20 CR 58250 Task 58252: Jade - New mapping methods
// 28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
vars
	now				: TimeStamp;
	quantity		: Real;
	effectiveDate	: Date;
	terminal		: CM_Terminal;
	invType			: CM_InvoiceDesc;
	invoiceLine		: CM_InvoiceLine;
	bs				: CM_BlockStack;
	voy 			: CM_Voyage;
	cargo 			: CM_TrackedItem;
	aPort 			: CM_Port;
	tran 			: CM_TITransaction;
	tranTS 			: TimeStamp;
	tranDate 		: Date;
	operator		: CM_Operator;
	debtor			: CM_Debtor;
	agent 		    : CM_CashInvoiceProformaAgent;
	tiArray 		: CM_TIArray;
begin
	terminal := self.getTerminal();

	bs:= self.getTerminalArea("UTSTORE3").CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	self.deleteTerminalArea("UTSTORE3");

	////////////////////////////////////////////////////////////////////
	// Create Invoice Type, Services and Invoice Line Types
	////////////////////////////////////////////////////////////////////
	invType := self.addIfNewInvoiceType("UT_InvTypeStore3");
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeStore3 not created");
	if invType.invoiceType &lt;&gt; InvoiceTypeStorage then
		beginTransaction;
		invType.invoiceType := InvoiceTypeStorage;
		commitTransaction;
	endif;

	self.addIfNewServiceILD("UT_ServStore1", "CCT06", "UT_LTStore1", null, invType);
	self.addIfNewServiceILD("UT_ServStore1", "CCT06", "UT_LTStore2", null, invType);
	self.addIfNewServiceILD("UT_ServStore1", "CCT06", "UT_LTStore3", null, invType);
	self.addIfNewServiceILD("UT_ServStore1", "CCT06", "UT_LTStore4", null, invType);
	self.addIfNewServiceILD("UT_ServStore1", "CCT06", "UT_LTStore5", null, invType);
	self.addIfNewServiceILD("UT_ServStore1", "CCT06", "UT_LTStore6", null, invType);

	// the invoicing debtor is that of the operator
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;
	self.setDebtorCashOnly(debtor, terminal, true);

	// Need to map to above invoice line types, using quantity ranges
	self.tranMapLoadCashEscStorage();
	
	// create a container with retrospective transactions 
	voy := self.createVesselVoyage3();
	aPort := app.myRoot.allPorts["NZAKL"];
	bs:= addBlockStack("UTSTORE3", 100, null);

	// Create Storage Transactions
	cargo := bs.myTerminal.allOnsiteTIsByCargoTypeId[TI_CargoType_Container,"STOR4300113"];
	if cargo &lt;&gt; null then
		self.deleteCargo(cargo.id, cargo.myCargoType.abbreviation.toUpper);
	endif;
	cargo := self.addContainerAtLocnDisch("STOR4300113", "2200", "MT", TI_IMEX_STATUS_STORAGE, bs.myLocationsController, aPort, voy);
	
	tranDate := "10/09/2013".Date;		// receival date
	tranTS.setDate(tranDate);
	foreach tran in cargo.allTransactions do
		tranTS.setDate(tranDate);
		tranTS.setTime(tran.dateTime.time);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	beginTransaction; // ### TFS BUG 60548 10OCT2023 NAVAB1
	cargo.evaluateFreeStorageDays(null,true); //10/092023 navmv20 CR 58250 Task 58252	//28.05.2024 navma1 #64224
	commitTransaction;
		
	create tiArray transient;
	tiArray.add(cargo);
	//app.myTrxUA.trxUpdateTIAddStorageDays( cargo, 5, "UT Extra Days", app.myPassport);
	app.myTrxUA.trxUpdateTIAddStorageDays( tiArray, 5, "UT Extra Days", app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	beginTransaction; 							// ### TFS BUG 60548 10OCT2023 NAVAB1
	cargo.evaluateFreeStorageDays(null,true);  //10/09/2023 navmv20 CR 58250 Task 58252		//22.05.2024 navma1 #64224
	commitTransaction;
	self.assertEqual(cargo.additionalStorageDays, 5);
	effectiveDate := "16/04/2014".Date;
	now.setDate(effectiveDate);
	agent := self.createProformaAgent(now, cargo);
	
	foreach invoiceLine in agent.allProformaInvLines do
		quantity := quantity + invoiceLine.quantity;
	endforeach;
	self.assertEqualMsg(quantity, 198.Real, "Pro forma invoice line quantity");
	
epilog
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;
	self.setDebtorCashOnly(debtor, terminal, false);
	delete tiArray;
	delete agent;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCashModuleFull" id="2f00dac4-add7-4897-ac62-a3bdc23b9726">
        <updating/>
        <source>tCashModuleFull() updating;
// cnwma1

/*

Purpose:		Cash module testing with no pre-payments and cash payments tied to receipts.  Includes payments of extra charges
					but not part payments as such.  All cargo is import.

Parameters:			

Return Value:		


Date		Who		Reason
29/04/2014	cnwjre1	After par 33885
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
*/

constants

vars
	isDutyDoc	: Boolean;
	multiTax	: Boolean;
	noImportStops	: Boolean;
	cargoId		: String;
	debtorName	: String;
	cargoIds	: StringArray;
	
	drTerm1 : CM_DebtorTerminal;
	drTerm2 : CM_DebtorTerminal;
	currentFinClass	: CM_ExtFinanceIO;
	
	costs : DecimalArray;
	service : CM_Service;
	debtorRate : CM_DebtorRate;

	endDate : Date;
	
	carrier : CM_Carrier;
	truckOut : CM_Vehicle;
	
	rootDebtor,
	debtor		: CM_Debtor;
	proxyDebtor		: CM_Debtor;
	debtorNode	: CM_DebtorNode;
	debtorNodeController	: CMIF_DebtorNode;
	debtorType	: CM_DebtorType;
	cashInvType,
	invType			: CM_InvoiceDesc;
	invLineType1  	: CM_InvoiceLineDesc;
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
	defaultVoyageProcess  : CM_VoyageProcessDefault;
	currentCode : String;
begin
	cashInvType := self.getInvoiceType("UT_InvType");		// cash receipt invoice type
	
	// turn off duty docs to get all the latest code; turn off terminal multi tax to avoid tax
	isDutyDoc := self.myTerminal.getConfig(DutyDocumentationEnabled).Boolean;
	multiTax := self.myTerminal.getConfig(InvoiceMultiTaxRates).Boolean;
	noImportStops := self.myTerminal.getConfig(NoImportStops).Boolean;
	// set Oracle financials to get their external cash receipt number
	currentFinClass := getInvoiceFinancialClass();
	self.setInvoiceFinancialClass(CM_OracleFinancials, null);
	self.setTerminalConfig(DutyDocumentationEnabled, false);
	self.setDefaultBankCashInvoiceType(cashInvType);
	self.setTerminalConfig(InvoiceMultiTaxRates, false);
	self.setTerminalConfig(NoImportStops, true);
	self.setTerminalConfig(CashInvoiceEveryReceipt, true); // TFS 45953

	create cargoIds transient;
	self.deleteContainer("UTUT8989101");
	// ids with valid check digits
	self.getCargoIds(cargoIds);
	foreach cargoId in cargoIds do
		self.deleteContainer(cargoId);
	endforeach;
	
	self.setTaxOnBank( false );
	rootDebtor := app.myRoot.myRootCompany.rootDebtor;

	// use an operator with a known non-cash debtor
	operator := self.getOperator("UTC1");
	if operator = null then
		operator := self.addOperatorSimple("UTC1", "Cash Test Operator");
	endif;
	debtorName := "UT_Debtor1";
	debtor := app.myRoot.myRootCompany.debtorNodes[debtorName].CM_Debtor;
	if debtor = null then
		create debtorNodeController transient;
		create proxyDebtor transient;
		self.setDebtorNodeController1(debtorName, debtorNodeController, proxyDebtor);
		app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		debtor := debtorNode.CM_Debtor;
	endif;

	beginTransaction;
		operator.setPropertyValue(CM_Operator::debtor.name, debtor);
	commitTransaction;
	self.myOperator := operator;
	
	endDate := app.actualTimeServer.Date + 10;	// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support

	//set terminal to be cash enabled.
	self.enableCashOnlyTerminal( self.myTerminal, true );
	
	//set up criteria permitted for this Bank in this terminal on pro forma allocation
	self.setBankAvailAllocCriteria();
	
	//set up Bank pro forma allocation
	self.setBankProFormaAllocations();
	
	//create Method of payment if needed
	self.myPaymentMethod :=  app.myRoot.allPaymentMethods.getAtKey(PayMethName);
	if self.myPaymentMethod = null then
		self.myPaymentMethod := self.createPaymentMethod(PayMethName);
	endif;
	self.assertTrueMsg(self.myPaymentMethod &lt;&gt; null, "Payment Method not created...");
	
	//create cash only debtors.
	self.myDebtor1 := app.myRoot.myRootCompany.debtors[DrNameOne];
	if self.myDebtor1 = null then
		self.myDebtor1 := self.addCashOnlyDebtor( DrNameOne );
	endif;
	self.assertTrueMsg(self.myDebtor1 &lt;&gt; null, "Cash only Debtor not created...");
	drTerm1 := self.myDebtor1.allDebtorTerminals.getAtKey( self.myTerminal );
	self.assertTrueMsg(drTerm1 &lt;&gt; null, "Debtor/Terminal not created...");
	self.assertTrueMsg(drTerm1.isCashOnly, "Debtor/Terminal is not cash only...");
	
	self.myDebtor2 := app.myRoot.myRootCompany.debtors[DrNameTwo];
	if self.myDebtor2 = null then
		self.myDebtor2 := self.addCashOnlyDebtor( DrNameTwo );
	endif;
	drTerm2 := self.myDebtor2.allDebtorTerminals.getAtKey( self.myTerminal );

	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;

	// Voyage invoice type, ILT8 invoice line type, used in ship receive, charged to shipping operator, calc type Cargo Quantity
	invType := self.addIfNewInvoiceType("UT_Voyage");
	self.addIfNewServiceILD("UT_ServiceX8", "CCT01", "UT_ILT8", null, invType);
	// set service rate
	service := self.myBank.services["UT_ServiceX8"];		// for receive ship
	self.setServiceRate(service, debtor, "01/01/2013".Date, 100.00);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT8"];
	debtorType := app.myRoot.allDebtorTypes["SDT4"];	// cargo operator
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;

	// Yard invoice type, ILT9 invoice line type, used in yard and road release, charged to customs agent, calc type Cargo Quantity
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.addIfNewServiceILD("UT_ServiceX9", "CCT01", "UT_ILT9", null, invType);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT9"];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := self.myBank.services["UT_ServiceX9"];		// for move and road release
	self.setServiceRate(service, debtor, "01/01/2013".Date, 20.00);
	self.setServiceRate(service, rootDebtor, "01/01/2013".Date, 20.00);
	
	// Yard invoice type, ILT10 invoice line type, used in storage, charged to customs agent, calc type Days Since Receival
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.addIfNewServiceILD("UT_ServiceX10", "CCT06", "UT_ILT10", null, invType);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT10"];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	// Yard invoice type, ILT11 invoice line type, used in storage, charged to customs agent, calc type Days Since Receival
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.addIfNewServiceILD("UT_ServiceX11", "CCT06", "UT_ILT11", null, invType);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT10"];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	// set the rates
	service := self.myBank.services["UT_ServiceX10"];		// for storage, rate per day
	self.setServiceRate(service, debtor, "01/01/2013".Date, 10.00);
	self.setServiceRate(service, rootDebtor, "01/01/2013".Date, 10.00);
	service := self.myBank.services["UT_ServiceX11"];		// for storage, rate per day
	self.setServiceRate(service, debtor, "01/01/2013".Date, 10.00);
	self.setServiceRate(service, rootDebtor, "01/01/2013".Date, 10.00);
	service := self.myBank.services["UT_ServiceX8"];			// receive ship, to get a value on the invoice lines
	self.setServiceRate(service, debtor, "01/01/2013".Date, 5.00);
	self.setServiceRate(service, rootDebtor, "01/01/2013".Date, 10.00);
	
	debtor := operator.debtor;
	service := self.myBank.services["UT_ServiceX8"];			// receive ship, to get a value on the invoice lines
	self.setServiceRate(service, debtor, "01/01/2013".Date, 5.00);
	
	self.myVoyage := self.createVesselVoyageCash("JMT STAR", "JSTAR001", operator.code);
	self.assertTrueMsg(self.myVoyage &lt;&gt; null, "Voyage '" &amp; CashVoyageCode &amp; "' not created...");
	// create carrier and truck
	self.deleteVehicle(VehicleNumOut);
	carrier := self.addCarrier(CarrierName, CarrierName, self.allEmails, false, true, true, self.myDebtor1);
	self.assertNotNull(carrier);
	truckOut := self.addVehicle(VehicleNumOut, carrier, self.myTerminal);
	self.assertTrueMsg(truckOut &lt;&gt; null, "Truck not created...");
	
	self.tranMapLoadCashFull();
	
	//Now create onsite cargo that will be gated out by truck.
	cargoId := cargoIds[1];
	self.cashTestSingle(cargoId, drTerm1, truckOut);

	cargoId := cargoIds[2];
	self.cashTestSingleNotEnoughCash(cargoId, drTerm1, truckOut);
	
	cargoId := cargoIds[3];
	self.cashTestSingleWithStorage(cargoId, drTerm1, truckOut);
	
	cargoId := cargoIds[4];
	self.cashTestSingleStorageOverpay(cargoId, drTerm1, truckOut);
	
	cargoId := cargoIds[5];
	self.cashTestNoCurrentCharges(cargoId, drTerm1, truckOut);

	cargoId := cargoIds[6];
	self.cashTestSingleAgentStorage(cargoId, drTerm1, truckOut);
epilog
	if currentFinClass &lt;&gt; null then
		self.setInvoiceFinancialClass(currentFinClass.class, null);
	endif;
	
	delete costs;
	delete debtorRate;
	delete cargoIds;
	//self.epilogCleanup();
	self.resetDefaultTranMap();
end;</source>
    </JadeMethod>
    <JadeMethod name="tCashMultiAgentReceipts" id="3680b611-cf87-4749-9de4-eeaf7ef5ae94">
        <updating/>
        <source>tCashMultiAgentReceipts() updating;
// cnwma1
// cnwjre1
/* ---------------------------------------------------------------------------
Created:     May 2014

Purpose:    Cash collection setting customs agent and resynching transactions; cash receipt saved details expanded.

        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	cargoMap	: CM_TranMap;
	debtorType	: CM_DebtorType;
	invType			: CM_InvoiceDesc;
	invLineType1	: CM_InvoiceLineDesc;
	customsAgent	: CM_CustomsAgent;
	debtor1,
	debtor2,
	debtor3	: CM_Debtor;
	service : CM_Service;
	voyage	: CM_Voyage;
	cargoColl	: CM_TISet;
	allTIs		: CM_TISet;
	ti			: CM_TrackedItem;

	allAgents		: ObjectArray;
	proformaLines	: CM_InvoiceLineBySeqNumDict;
	bank			: CM_Bank;
	receipt,
	cashReceipt1,
	cashReceipt2,
	cashReceipt3	: CM_CashReceipt;
	paymentMeth : CM_PaymentMethod;
	agent : CM_CashInvoiceProformaAgent;
	carrier : CM_Carrier;
	truck : CM_Vehicle;
	
	allowUnderpay,
	multiTax,
	noImportStops	: Boolean;
	bankTaxRate		: Real;
	now		: TimeStamp;
	count	: Integer;
	chequeBank : String;
	chequeBranch : String;
	chequeNumber : String;
	chequeDate : Date;
	cashId1,
	cashId2,
	cashId3,
	cashId4 : String;
	effectiveDate : Date;
	externalInvoiceNumber,
	externalReferenceNumber : String;
	drTerm : CM_DebtorTerminal;
begin

	//set terminal to be cash enabled.
	self.enableCashOnlyTerminal( self.myTerminal, true );

	invType := self.getInvoiceType("UT_InvType");		// cash receipt invoice type
	// turn off stuff we don't want and set options we do want
	//allowUnderpay := self.myTerminal.getConfig(CashCollectAllowUnderpay).Boolean;
	noImportStops := self.myTerminal.getConfig(NoImportStops).Boolean;
	bankTaxRate := self.myBank.taxPercentageRate;
	multiTax := self.myTerminal.getConfig(InvoiceMultiTaxRates).Boolean;
	beginTransaction;
		self.myBank.taxPercentageRate := 0;
	commitTransaction;
	self.setTerminalConfig(NoImportStops, true);
	self.setDefaultBankCashInvoiceType(invType);
	self.setTerminalConfig(InvoiceMultiTaxRates, false);


	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor1 := customsAgent.myDebtor;
	customsAgent := app.myRoot.allCustomsAgents['UTCA2'];
	debtor2 := customsAgent.myDebtor;
	customsAgent := app.myRoot.allCustomsAgents['UTCA3'];
	debtor3 := customsAgent.myDebtor;

	// clean up old receipts
	drTerm := debtor1.allDebtorTerminals[self.myTerminal];
	if drTerm &lt;&gt; null then
		self.deleteCashReceipts(drTerm);
	endif;
	drTerm := debtor2.allDebtorTerminals[self.myTerminal];
	if drTerm &lt;&gt; null then
		self.deleteCashReceipts(drTerm);
	endif;
	drTerm := debtor3.allDebtorTerminals[self.myTerminal];
	if drTerm &lt;&gt; null then
		self.deleteCashReceipts(drTerm);
	endif;

	// Voyage invoice type, ILT8 invoice line type, used in receive, charged to shipping operator, calc type Cargo Quantity
	invType := self.addIfNewInvoiceType("UT_Voyage");
	self.addIfNewServiceILD("UT_ServiceX8", "CCT01", "UT_ILT8", null, invType);
	// set service rate
	service := self.myBank.services["UT_ServiceX8"];		// for receive ship
	self.setServiceRate(service, debtor1, "01/01/2013".Date, 100.00);
	self.setServiceRate(service, debtor2, "01/01/2013".Date, 100.00);
	self.setServiceRate(service, debtor3, "01/01/2013".Date, 100.00);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT8"];
	debtorType := app.myRoot.allDebtorTypes["SDT4"];	// cargo operator
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;

	// Yard invoice type, ILT9 invoice line type, used in yard and road release, charged to customs agent, calc type Cargo Quantity
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.addIfNewServiceILD("UT_ServiceX9", "CCT01", "UT_ILT9", null, invType);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT9"];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := self.myBank.services["UT_ServiceX9"];		// for move and road release
	self.setServiceRate(service, debtor1, "01/01/2013".Date, 20.00);
	self.setServiceRate(service, debtor2, "01/01/2013".Date, 20.00);
	self.setServiceRate(service, debtor3, "01/01/2013".Date, 20.00);
	
	// Yard invoice type, ILT10 invoice line type, used in storage, charged to customs agent, calc type Days Since Receival
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.addIfNewServiceILD("UT_ServiceX10", "CCT06", "UT_ILT10", null, invType);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT10"];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := self.myBank.services["UT_ServiceX10"];		// for storage, rate per day
	self.setServiceRate(service, debtor1, "01/01/2013".Date, 10.00);
	self.setServiceRate(service, debtor2, "01/01/2013".Date, 10.00);
	self.setServiceRate(service, debtor3, "01/01/2013".Date, 10.00);
	
	create cargoColl transient;
	voyage := self.createPartialReceiptCargo(cargoColl);
	
	// the first two items are picked up and paid for by Customs Agent 1
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	cashReceipt1 := self.doCashReceipt(cargoColl, customsAgent, 2, voyage.code, "BOL001");

	// the next two items are picked up and paid for by Customs Agent 2
	customsAgent := app.myRoot.allCustomsAgents['UTCA2'];
	cashReceipt2 := self.doCashReceipt(cargoColl, customsAgent, 2, voyage.code, "BOL001");

	// the last two items are picked up and paid for by Customs Agent 3
	customsAgent := app.myRoot.allCustomsAgents['UTCA3'];
	cashReceipt3 := self.doCashReceipt(cargoColl, customsAgent, 2, voyage.code, "BOL001");

	self.validateCashReceipt(cashReceipt1, 1);
	self.validateCashReceipt(cashReceipt2, 2);
	self.validateCashReceipt(cashReceipt3, 3);
	
	// create truck and vehicle visit record.
	carrier := self.addCarrier(CarrierName, CarrierName, self.allEmails, false, true, true, null);
	self.assertNotNull(carrier);
	self.deleteVehicle(VehicleNumOut);
	truck := self.addVehicle(VehicleNumOut, carrier, self.myTerminal);
	self.assertTrueMsg(truck &lt;&gt; null, "Truck not created...");
	
	// first box out
	ti := cashReceipt1.allTrackedItems.first;
	self.gateOutCargo(ti, truck, 1);

	// second box out
	ti := cashReceipt1.allTrackedItems.last;
	self.gateOutCargo(ti, truck, 2);
	
	// third box out
	ti := cashReceipt2.allTrackedItems.first;
	self.gateOutCargo(ti, truck, 3);

	// fourth box out
	ti := cashReceipt2.allTrackedItems.last;
	self.gateOutCargo(ti, truck, 4);
	
	// fifth box out
	ti := cashReceipt3.allTrackedItems.first;
	self.gateOutCargo(ti, truck, 5);

	// sixth box out
	ti := cashReceipt3.allTrackedItems.last;
	self.gateOutCargo(ti, truck, 6);
	
	self.validateCashReceiptRelease(cashReceipt1, 1);
	self.validateCashReceiptRelease(cashReceipt2, 2);
	self.validateCashReceiptRelease(cashReceipt3, 3);
	
	// check reporting collection
	count := 0;
	foreach receipt in myTerminal.allCashReceipts do
		count := count + 1;
	endforeach;
	self.assertTrueMsg(count &gt;= 3, "Terminal allCashReceipts has at least the three receipts");

epilog
	beginTransaction;
		self.myBank.taxPercentageRate := bankTaxRate;
	commitTransaction;

	delete cargoColl;
	delete allTIs;
	if allAgents &lt;&gt; null then
		allAgents.purge();
	endif;
	delete allAgents;
	// delete this tran map so following tests can delete the invoice line descs etc
	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	app.myTrxUA.trxUpdateBankTMActive(cargoMap, app.myPassport);
	self.deleteInvoiceTransactionMap(1, 'CashPartial');
	self.resetDefaultTranMap();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tCashMultipleReceipts2" id="219f6f10-8397-4417-923e-c4eb7b231cbd">
        <updating/>
        <source>tCashMultipleReceipts2() updating;
// cnwma1

/*

Purpose:	Cash module testing of 2 receipts, each for 2 cargo items.  The first is for pro forma charges only, both cargo items, the first cargo is released and the invoice posted.
			The second receipt is for actual charges for the first cargo item (on already-posted invoice) then the second cargo item is released.
			The payments and storage invoice lines for the second cargo item used to both go to the posted invoice but shouldn't now, instead the invoice lines go to 
			a new cash invoice for the first receipt and the cash payments stay on the invoice of the second receipt.
			The option for separate invoice per cash receipt is set.
Parameters:			

Return Value:		


Date		Who		Reason
June 2016	cnwjre1	After TFS 2073 and 2186
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
*/

constants

vars
	isDutyDoc	: Boolean;
	multiTax	: Boolean;
	noImportStops	: Boolean;
	cargoId1,
	cargoId2	: String;
	debtorName	: String;
	cargoIds	: StringArray;
	
	drTerm1 : CM_DebtorTerminal;

	currentFinClass	: CM_ExtFinanceIO;
	
	costs : DecimalArray;
	service : CM_Service;
	debtorRate : CM_DebtorRate;

	endDate : Date;
	
	debtor		: CM_Debtor;
	proxyDebtor		: CM_Debtor;
	debtorNode	: CM_DebtorNode;
	debtorNodeController	: CMIF_DebtorNode;
	debtorType	: CM_DebtorType;
	cashInvType,
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2  	: CM_InvoiceLineDesc;
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
begin

	cashInvType := self.getInvoiceType("UT_InvType");		// cash receipt invoice type

	// turn off duty docs to get all the latest code; turn off terminal multi tax to avoid tax
	isDutyDoc := self.myTerminal.getConfig(DutyDocumentationEnabled).Boolean;
	multiTax := self.myTerminal.getConfig(InvoiceMultiTaxRates).Boolean;
	noImportStops := self.myTerminal.getConfig(NoImportStops).Boolean;
	// set default financial to get their external cash receipt number
	currentFinClass := getInvoiceFinancialClass();
	self.setInvoiceFinancialClass(CM_ADPInterface, null);
	self.setTerminalConfig(DutyDocumentationEnabled, false);
	self.setDefaultBankCashInvoiceType(cashInvType);
	self.setTerminalConfig(InvoiceMultiTaxRates, false);
	self.setTerminalConfig(NoImportStops, true);
	self.setTerminalConfig(CashInvoiceEveryReceipt, true);
	
	create cargoIds transient;
	// ids with valid check digits
	self.getCargoIds(cargoIds);
	foreach cargoId1 in cargoIds do
		self.deleteContainer(cargoId1);
	endforeach;
	
	self.setTaxOnBank( false );
	
	// use an operator with a known non-cash debtor
	operator := self.getOperator("UTC1");
	if operator = null then
		operator := self.addOperatorSimple("UTC1", "Cash Test Operator");
	endif;
	debtorName := "UT_Debtor1";
	debtor := app.myRoot.myRootCompany.debtorNodes[debtorName].CM_Debtor;
	if debtor = null then
		create debtorNodeController transient;
		create proxyDebtor transient;
		self.setDebtorNodeController1(debtorName, debtorNodeController, proxyDebtor);
		app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		debtor := debtorNode.CM_Debtor;
	endif;

	beginTransaction;
		operator.setPropertyValue(CM_Operator::debtor.name, debtor);
	commitTransaction;
	self.myOperator := operator;
	
	endDate := app.actualTimeServer.Date + 10;	// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support

	//set terminal to be cash enabled.
	self.enableCashOnlyTerminal( self.myTerminal, true );
	
	//set up criteria permitted for this Bank in this terminal on pro forma allocation
	self.setBankAvailAllocCriteria();
	
	//set up Bank pro forma allocation
	self.setBankProFormaAllocations();
	
	//create Method of payment if needed
	self.myPaymentMethod :=  app.myRoot.allPaymentMethods.getAtKey(PayMethName);
	if self.myPaymentMethod = null then
		self.myPaymentMethod := self.createPaymentMethod(PayMethName);
	endif;
	self.assertTrueMsg(self.myPaymentMethod &lt;&gt; null, "Payment Method not created...");
	
	//create cash only debtors.
	self.myDebtor1 := app.myRoot.myRootCompany.debtors[DrNameOne];
	if self.myDebtor1 = null then
		self.myDebtor1 := self.addCashOnlyDebtor( DrNameOne );
	endif;
	self.assertTrueMsg(self.myDebtor1 &lt;&gt; null, "Cash only Debtor not created...");
	drTerm1 := self.myDebtor1.allDebtorTerminals.getAtKey( self.myTerminal );
	self.assertTrueMsg(drTerm1 &lt;&gt; null, "Debtor/Terminal not created...");
	self.assertTrueMsg(drTerm1.isCashOnly, "Debtor/Terminal is not cash only...");
	// clear any credits etc from prior tests such as tCashCredit
	self.zPurgeCashDebtor(drTerm1);
	
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;
	drTerm1 := debtor.allDebtorTerminals.getAtKey( self.myTerminal );
	self.assertTrueMsg(drTerm1 &lt;&gt; null, "Debtor/Terminal not created...");
	self.assertTrueMsg(drTerm1.isCashOnly, "Debtor/Terminal is not cash only...");
	// clear any credits etc from prior tests such as tCashCredit
	self.zPurgeCashDebtor(drTerm1);

	// Voyage invoice type, ILT8 invoice line type, used in ship receive, charged to shipping operator, calc type Cargo Quantity
	invType := self.addIfNewInvoiceType("UT_Voyage");
	self.addIfNewServiceILD("UT_ServiceX8", "CCT01", "UT_ILT8", null, invType);
	// set service rate
	service := self.myBank.services["UT_ServiceX8"];		// for receive ship
	self.setServiceRate(service, debtor, "01/01/2013".Date, 100.00);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT8"];
	debtorType := app.myRoot.allDebtorTypes["SDT4"];	// cargo operator
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;

	// Yard invoice type, ILT9 invoice line type, used in yard and road release, charged to customs agent, calc type Cargo Quantity
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.addIfNewServiceILD("UT_ServiceX9", "CCT01", "UT_ILT9", null, invType);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT9"];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := self.myBank.services["UT_ServiceX9"];		// for move and road release
	self.setServiceRate(service, debtor, "01/01/2013".Date, 20.00);
	
	// Yard invoice type, ILT10 and ILT11 invoice line type, used in storage, charged to customs agent, calc type Days Since Receival
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.addIfNewServiceILD("UT_ServiceX10", "CCT06", "UT_ILT10", null, invType);
	self.addIfNewServiceILD("UT_ServiceX11", "CCT06", "UT_ILT11", null, invType);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT10"];
	invLineType2 := self.myBank.invoiceLineDescriptors["UT_ILT11"];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	invLineType2.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := self.myBank.services["UT_ServiceX10"];		// for storage, rate per day
	self.setServiceRate(service, debtor, "01/01/2013".Date, 20.00);
	service := self.myBank.services["UT_ServiceX11"];		// for double storage, rate per day
	self.setServiceRate(service, debtor, "01/01/2013".Date, 40.00);
	service := self.myBank.services["UT_ServiceX8"];			// receive ship, to get a value on the invoice lines
	self.setServiceRate(service, debtor, "01/01/2013".Date, 100.00);
	
	debtor := operator.debtor;
	service := self.myBank.services["UT_ServiceX8"];			// receive ship, to get a value on the invoice lines
	self.setServiceRate(service, debtor, "01/01/2013".Date, 5.00);
	
	self.myVoyage := self.createVesselVoyageCash("JMT STAR", "JSTAR001", operator.code);
	self.assertTrueMsg(self.myVoyage &lt;&gt; null, "Voyage '" &amp; CashVoyageCode &amp; "' not created...");

	self.tranMapLoadMultipleReceipts();
	
	// two receipts, each should have its own cash invoice, post the first one before releasing the cargo
	cargoId1 := cargoIds[1];
	cargoId2 := cargoIds[2];
	self.cashTestMultipleReceipts2(cargoId1, cargoId2, drTerm1, 1);
	
epilog
	if currentFinClass &lt;&gt; null then
		self.setInvoiceFinancialClass(currentFinClass.class, null);
	endif;

	delete costs;
	delete debtorRate;
	delete cargoIds;
	self.resetDefaultTranMap();
end;</source>
    </JadeMethod>
    <JadeMethod name="tCashMultipleReceipts2a" id="084911d9-8c9c-4728-9afd-4aec1532560e">
        <updating/>
        <source>tCashMultipleReceipts2a() updating;
// cnwma1

/*

Purpose:		Cash module testing of 2 receipts, each for the same one cargo item.  The first is current and pro forma charges as at 4 days ago, 
				the second receipt is for pro forma charges as at today.
				The debtor is changed to be credit (no longer cash-only) and 
				the cargo released and the resulting receipts and invoice(s) checked.

Parameters:			

Return Value:		


Date		Who		Reason
June 2016	cnwjre1	TFS 2073 and 2186
*/

constants

vars
	isDutyDoc	: Boolean;
	multiTax	: Boolean;
	noImportStops	: Boolean;
	cargoId1,
	cargoId2	: String;
	debtorName	: String;
	cargoIds	: StringArray;
	
	drTerm1 : CM_DebtorTerminal;

	currentFinClass	: CM_ExtFinanceIO;
	
	costs : DecimalArray;
	service : CM_Service;
	debtorRate : CM_DebtorRate;

	endDate : Date;
	
	debtor		: CM_Debtor;
	proxyDebtor		: CM_Debtor;
	debtorNode	: CM_DebtorNode;
	debtorNodeController	: CMIF_DebtorNode;
	debtorType	: CM_DebtorType;
	cashInvType,
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2  	: CM_InvoiceLineDesc;
	customsAgent	: CM_CustomsAgent;
	operator		: CM_Operator;
begin

	cashInvType := self.getInvoiceType("UT_InvType");		// cash receipt invoice type

	// turn off duty docs to get all the latest code; turn off terminal multi tax to avoid tax
	isDutyDoc := self.myTerminal.getConfig(DutyDocumentationEnabled).Boolean;
	multiTax := self.myTerminal.getConfig(InvoiceMultiTaxRates).Boolean;
	noImportStops := self.myTerminal.getConfig(NoImportStops).Boolean;
	// set default financial to get their external cash receipt number
	currentFinClass := getInvoiceFinancialClass();
	self.setInvoiceFinancialClass(CM_ADPInterface, null);
	self.setTerminalConfig(DutyDocumentationEnabled, false);
	self.setDefaultBankCashInvoiceType(cashInvType);
	self.setTerminalConfig(InvoiceMultiTaxRates, false);
	self.setTerminalConfig(NoImportStops, true);
	self.setTerminalConfig(CashInvoiceEveryReceipt, false);
	// TFS 45953 self.setTerminalConfig(CashShowParentAndChildItems, true);
	
	create cargoIds transient;
	// ids with valid check digits
	self.getCargoIds(cargoIds);
	foreach cargoId1 in cargoIds do
		self.deleteContainer(cargoId1);
	endforeach;
	
	self.setTaxOnBank( false );
	
	// use an operator with a known non-cash debtor
	operator := self.getOperator("UTC1");
	if operator = null then
		operator := self.addOperatorSimple("UTC1", "Cash Test Operator");
	endif;
	debtorName := "UT_Debtor1";
	debtor := app.myRoot.myRootCompany.debtorNodes[debtorName].CM_Debtor;
	if debtor = null then
		create debtorNodeController transient;
		create proxyDebtor transient;
		self.setDebtorNodeController1(debtorName, debtorNodeController, proxyDebtor);
		app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		debtor := debtorNode.CM_Debtor;
	endif;

	beginTransaction;
		operator.setPropertyValue(CM_Operator::debtor.name, debtor);
	commitTransaction;
	self.myOperator := operator;
	
	endDate := app.actualTimeServer.Date + 10;	// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support

	//set terminal to be cash enabled.
	self.enableCashOnlyTerminal( self.myTerminal, true );
	
	//set up criteria permitted for this Bank in this terminal on pro forma allocation
	self.setBankAvailAllocCriteria();
	
	//set up Bank pro forma allocation
	self.setBankProFormaAllocations();
	
	//create Method of payment if needed
	self.myPaymentMethod :=  app.myRoot.allPaymentMethods.getAtKey(PayMethName);
	if self.myPaymentMethod = null then
		self.myPaymentMethod := self.createPaymentMethod(PayMethName);
	endif;
	self.assertTrueMsg(self.myPaymentMethod &lt;&gt; null, "Payment Method not created...");
	
	//create cash only debtors.
	self.myDebtor1 := app.myRoot.myRootCompany.debtors[DrNameOne];
	if self.myDebtor1 = null then
		self.myDebtor1 := self.addCashOnlyDebtor( DrNameOne );
	endif;
	self.assertTrueMsg(self.myDebtor1 &lt;&gt; null, "Cash only Debtor not created...");
	drTerm1 := self.myDebtor1.allDebtorTerminals.getAtKey( self.myTerminal );
	self.assertTrueMsg(drTerm1 &lt;&gt; null, "Debtor/Terminal not created...");
	self.assertTrueMsg(drTerm1.isCashOnly, "Debtor/Terminal is not cash only...");
	// clear any credits etc from prior tests such as tCashCredit
	self.zPurgeCashDebtor(drTerm1);
	
	customsAgent := app.myRoot.allCustomsAgents['UTCA1'];
	debtor := customsAgent.myDebtor;
	drTerm1 := debtor.allDebtorTerminals.getAtKey( self.myTerminal );
	self.assertTrueMsg(drTerm1 &lt;&gt; null, "Debtor/Terminal not created...");
	self.assertTrueMsg(drTerm1.isCashOnly, "Debtor/Terminal is not cash only...");
	// clear any credits etc from prior tests such as tCashCredit
	self.zPurgeCashDebtor(drTerm1);

	// Voyage invoice type, ILT8 invoice line type, used in ship receive, charged to shipping operator, calc type Cargo Quantity
	invType := self.addIfNewInvoiceType("UT_Voyage");
	self.addIfNewServiceILD("UT_ServiceX8", "CCT01", "UT_ILT8", null, invType);
	// set service rate
	service := self.myBank.services["UT_ServiceX8"];		// for receive ship
	self.setServiceRate(service, debtor, "01/01/2013".Date, 100.00);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT8"];
	debtorType := app.myRoot.allDebtorTypes["SDT4"];	// cargo operator
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;

	// Yard invoice type, ILT9 invoice line type, used in yard and road release, charged to customs agent, calc type Cargo Quantity
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.addIfNewServiceILD("UT_ServiceX9", "CCT01", "UT_ILT9", null, invType);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT9"];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := self.myBank.services["UT_ServiceX9"];		// for move and road release
	self.setServiceRate(service, debtor, "01/01/2013".Date, 20.00);
	
	// Yard invoice type, ILT10 and ILT11 invoice line type, used in storage, charged to customs agent, calc type Days Since Receival
	invType := self.addIfNewInvoiceType("UT_Yard");
	self.addIfNewServiceILD("UT_ServiceX10", "CCT06", "UT_ILT10", null, invType);
	self.addIfNewServiceILD("UT_ServiceX11", "CCT06", "UT_ILT11", null, invType);

	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILT10"];
	invLineType2 := self.myBank.invoiceLineDescriptors["UT_ILT11"];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	invLineType2.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	service := self.myBank.services["UT_ServiceX10"];		// for storage, rate per day
	self.setServiceRate(service, debtor, "01/01/2013".Date, 20.00);
	service := self.myBank.services["UT_ServiceX11"];		// for double storage, rate per day
	self.setServiceRate(service, debtor, "01/01/2013".Date, 40.00);
	service := self.myBank.services["UT_ServiceX8"];			// receive ship, to get a value on the invoice lines
	self.setServiceRate(service, debtor, "01/01/2013".Date, 100.00);
	
	debtor := operator.debtor;
	service := self.myBank.services["UT_ServiceX8"];			// receive ship, to get a value on the invoice lines
	self.setServiceRate(service, debtor, "01/01/2013".Date, 5.00);
	
	self.myVoyage := self.createVesselVoyageCash("JMT STAR", "JSTAR001", operator.code);
	self.assertTrueMsg(self.myVoyage &lt;&gt; null, "Voyage '" &amp; CashVoyageCode &amp; "' not created...");

	self.tranMapLoadMultipleReceipts();
	
	cargoId1 := cargoIds[1];
	self.cashTestMultipleReceipts2a(cargoId1, drTerm1, 0);

	
epilog
	if currentFinClass &lt;&gt; null then
		self.setInvoiceFinancialClass(currentFinClass.class, null);
	endif;

	delete costs;
	delete debtorRate;
	delete cargoIds;
	self.resetDefaultTranMap();
end;</source>
