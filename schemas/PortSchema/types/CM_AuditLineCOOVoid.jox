    <JadeMethod name="myOwnershipChange" id="be4ad78d-b96c-49c5-aa9e-beba44f6188f">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>myOwnershipChange(set : Boolean; _value : CM_OwnershipChange io) updating, mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/12/2023	navkc1 ChangeRequest 58261 Task 58260: Jade - COO Invoice Issues Send Email

*/

vars

begin
	if set then
		self.myOwnershipChange := _value;
		self.cooApprovalDT := _value.dateTimeCOO;
		self.cooApprovalUserCode := _value.userCodeApproved;
	else
		_value := self.myOwnershipChange;
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_OwnershipChange" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setRemarks" id="ce47d38a-88e3-47a4-a00e-e360397e1c1d">
        <updating/>
        <source>setRemarks() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/12/2023	navkc1 ChangeRequest 58261 Task 58260: Jade - COO Invoice Issues Send Email

*/

vars

begin
	if self.hasVoided then
		self.remarks := "Ownership Change voided Invoice Line " &amp; self.invLineNumber.String &amp; ", Invoice " &amp; self.sequenceNum.String;
	else
		self.remarks := "Ownership Change failed to void Invoice Line " &amp; self.invLineNumber.String &amp; ", Invoice " &amp; self.sequenceNum.String &amp; " is posted.";
	endif;

epilog

end;</source>
    </JadeMethod>
