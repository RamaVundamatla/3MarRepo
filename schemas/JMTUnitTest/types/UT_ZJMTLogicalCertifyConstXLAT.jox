		freePassList.add("CMUI_MoveUnactionedJobs");
		freePassList.add("CMUI_SelGateContainerLengths");
		freePassList.add("CMUI_StopInformationForm");
		freePassList.add("CMUI_SysOpsXlationForm");
		freePassList.add("CMUI_TILCTypeFormOld");
		freePassList.add("CMUI_UnpackDetails");
		freePassList.add("CMUI_VehicleSchedDayTemplate");
		freePassList.add("CMUI_VehicleSchedTermTemplate");
		freePassList.add("CMUI_VehicleScheduleAssociate");
		freePassList.add("CMUI_VehicleScheduleDayView");
		freePassList.add("CMUI_YACargoCheckCriteriaForm");
		freePassList.add("CMUI_YACriteriaRTVConfigMaintF");
		freePassList.add("CMUI_YardAllocationEnquiryForm");
		freePassList.add("CM_ContainerEnqFormSAVE");
		freePassList.add("GC_AreaForm");
		freePassList.add("GC_CodeMaintForm");
		freePassList.add("GTE_GateDefinitonForm");
		freePassList.add("GTE_InOutExpressForm");
		freePassList.add("GTE_VehicleVisitEnqOldForm");
		freePassList.add("INV_CashReceiptMultiORIG");
		freePassList.add("INV_CashReceipt");
		freePassList.add("INV_RateTableCSVExtractForm");
		freePassList.add("MOB_DarrellTest");
		freePassList.add("MOB_HHBreakBulkDiscrepancy");
		freePassList.add("MOB_HHBreakBulkMerge");
		freePassList.add("MOB_HHBreakBulkSplit");
		freePassList.add("MOB_HHGateCheckContainer");
		freePassList.add("MOB_HH_ITSTruckAction");
		freePassList.add("MOB_HH_ITSTruckLoader");
		freePassList.add("MOB_HH_ITSTruckUnloader");
		freePassList.add("MOB_HandHeldRailConfirmForm");
		freePassList.add("MOB_HandHeldReeferEnquiryForm");
		freePassList.add("MOB_HandHeldSealsForm");
		freePassList.add("MOB_HandHeldMoveForm");
		freePassList.add("SHP_CreateNewCargoForm");
		freePassList.add("SHP_DelayEnquiryForm");
		freePassList.add("SHP_DelaysForm");
		freePassList.add("SHP_SetCurrentVoyage");
		freePassList.add("SHP_ShipDefnForm");
		freePassList.add("SOP_WagonPositionRuleFormOld");
		freePassList.add("SOP_YardAllocationForm");
		freePassList.add("YRD_ConnectAttach");
		freePassList.add("YRD_RailOpsForm");
		freePassList.add("YRD_TrailerAreasForm");
		freePassList.add("YRD_VoyageEnquiryOLD");
	
	
	
	
	foreach constOb in constantCategory.cnEcGetConstants() do
		delete meths;
		delete methodNameArray;
		create methodNameArray transient;
		create meths transient;
		
		
		
		
		
		constOb.getMethodRefs(meths);
					
		foreach meth in meths do	
			assertTrueMsg(xStringContains(meth.getSource,constOb.name),"Method " &amp; meth.name &amp; " source does not contain " &amp; constOb.name);
			methNameString := meth.schemaType.schema.name &amp; "," &amp;  meth.schemaType.name;
			
			if not methodNameArray.includes(methNameString) then
				methodNameArray.add(methNameString);
			endif;
		endforeach;	
			
			
		delete xmlDoc;
		create xmlDoc transient;
		xmlDoc.parseString(constOb.text);
		xmlElement := xmlDoc.getElementByTagName(XMLTag_Header);
				
//			// Get the text
//		textElement := xmlElement.findElement(XMLTag_Msg, null);
//		if textElement &lt;&gt; null then
//			text := textElement.text;
//		endif;
	
		// get the form Schema
		xmlAttribute := xmlElement.getAttributeByName(XML_Tag_SchemaName);
		if xmlAttribute &lt;&gt; null then
			schemaName := xmlAttribute.value;
		endif;
		
		conSchema := rootSchema.getSchema(schemaName);
		
		self.assertNotNullMsg(conSchema, "Conschema is null. Name: " &amp; schemaName);
		
			// get the form class
		xmlAttribute := xmlElement.getAttributeByName(XML_Tag_FormClass);
		if xmlAttribute &lt;&gt; null then
			className := xmlAttribute.value;
		endif;
		
		conClass := conSchema.getClass(className);
			
		methNameString := schemaName &amp; "," &amp;  className;	
			
		if not freePassList.includes(className) then
			self.assertNotNullMsg(conClass, "Conclass is null. Name: " &amp; className);
			
			
			self.assertTrueMsg(methodNameArray.includes(methNameString),"XML Class not in Array");
		endif;
		
		
		
	
		
	//*/
	endforeach;
		
epilog

	if meths &lt;&gt; null then
		delete meths;
	endif;

	if 	methodNameArray &lt;&gt; null then
		delete	methodNameArray;
	endif;

delete xmlDoc;
delete freePassList;
end;</source>
