    <JadeMethod name="validateForDelete" id="b7f20212-4aab-421f-92e5-1c1a314f1f74">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theTIs : CM_TIArray;
	theVoyCode : String;
begin
	theVoyCode := self.myCellularVoyageStructure.getDisplayDetails(true);
	
	create theTIs transient;
	if not self.allSlotRequestByMoveType.isEmpty then
		app.raiseCMException2(ErrCannotRemoveBay,"Voyage " &amp; theVoyCode,"Bay " &amp; self.id &amp; " has colour coding.", null, null);
	endif;

	if self.hasPlannedTIs(true) then
		app.raiseCMException2(ErrCannotRemoveBay,"Voyage " &amp; theVoyCode,"Bay " &amp; self.id &amp; " has Load Planned Cargo.", null, null);
	endif;
	if self.hasPlannedTIs(false) then
		app.raiseCMException2(ErrCannotRemoveBay,"Voyage " &amp; theVoyCode,"Bay " &amp; self.id &amp; " has Discharge Planned Cargo.", null, null);
	endif;	
	
	theTIs.clear;
	self.getAllProposedTIs(theTIs);
	if not theTIs.isEmpty then
		app.raiseCMException2(ErrCannotRemoveBay,"Voyage " &amp; theVoyCode,"Bay " &amp; self.id &amp; " has Proposed Cargo.", null, null);
	
	endif;
	theTIs.clear;
	self.getAllTrackedItems(REAL_MODE,theTIs);
	if not theTIs.isEmpty then
		app.raiseCMException2(ErrCannotRemoveBay,"Voyage " &amp; theVoyCode,"Bay " &amp; self.id &amp; " has Actual Cargo.", null, null);
	endif;
	
epilog
	delete theTIs;
end;</source>
    </JadeMethod>
</Class>
