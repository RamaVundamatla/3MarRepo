    <JadeMethod name="checkHasOrdersForOperator" id="d220aa80-d446-4917-b76b-9a62dfa17fe9">
        <source>checkHasOrdersForOperator(_operator: CM_Operator): Boolean;
//--------------------------------------------------------------
//Created: 21 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	summary : CM_StockOrderSummary;
begin

	foreach summary in self.allStockOrderSummaries do
		if summary.myOperator = _operator then
			return true;
