        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_qualifier" type="String"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_typeQual" type="String"/>
        <Parameter name="_typeAgency" type="String"/>
        <Parameter name="_supplier" type="String"/>
        <Parameter name="_status" type="String"/>
        <Parameter name="_contentsStatus" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeFTXSegment" id="f9c1424c-a6db-4cd0-91f3-254cdf8b0171">
        <source>makeFTXSegment(_protocol :CM_CamProtocol; _group :HugeStringArray input; _subject, _function, _text, _literal:String):String protected;
/*
Purpose:	Make a FTX segment

Date		Who		Reason
09 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
constants
	MESSAGE	= "FTX";
vars
	msg	:String;
	plus, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	msg := MESSAGE &amp; plus &amp; 
			_subject &amp; plus &amp;
			_function &amp; plus &amp;
			_text;
			
	if _literal &lt;&gt; null then
		msg := msg &amp; plus &amp; _literal;
	endif;
	
	msg := msg &amp; singleQuote;
	
	if _group &lt;&gt; null then
		_group.add (msg);
	endif;
			
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_subject" type="String"/>
        <Parameter name="_function" type="String"/>
        <Parameter name="_text" type="String"/>
        <Parameter name="_literal" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeFTX_VGMSegment" id="102dc2d0-aea7-444e-94f9-c8b428491fec">
        <source>makeFTX_VGMSegment(_protocol : CM_CamProtocol; _group : HugeStringArray input; _vgmDetails : CM_VGMDetails) : String protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 07/07/2017	cnwdap1		Initial creation TFS 4492 SNO VERMAS Changes
//
constants
	MESSAGE = "FTX";
	
vars
	msg : String;
	plus, colon, singleQuote : String;
	solasMethod : String;

begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	if _vgmDetails.vgmCommsType &lt;&gt; null then
		// SOLAS method is coming from the VGM details
		solasMethod := _vgmDetails.vgmCommsType;
	else
		// SM1/SM2 is coming from the weigh authority itself
		solasMethod := _vgmDetails.myWeighAuthTerminal.myWeighAuthority.solasMethod;
	endif;
	msg := MESSAGE &amp; plus &amp; "ABS" &amp; plus &amp; plus &amp; 
			solasMethod &amp; colon &amp;
			_vgmDetails.vgmDocumentDetails &amp; colon &amp;
			"SMD" &amp; singleQuote;
			
	if _group &lt;&gt; null then
		_group.add (msg);
	endif;
			
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_vgmDetails" type="CM_VGMDetails"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeGIDSegment" id="fc615675-0536-47a7-8930-2e606d4057df">
        <source>makeGIDSegment(_protocol :CM_CamProtocol; _group :HugeStringArray input; _number :Integer):String protected;
/*
Purpose:	Make a GID segment

Date		Who		Reason
09 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
constants
	MESSAGE	= "GID";
vars
	msg	:String;
	plus, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	msg := MESSAGE &amp; plus &amp; _number.String	&amp; singleQuote;
	
	if _group &lt;&gt; null then
		_group.add (msg);
	endif;
	
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_number" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeLOCSegment" id="ba26ea20-3d66-422e-ac41-b5f74f3b0eec">
        <source>makeLOCSegment(_protocol :CM_CamProtocol; _group :HugeStringArray input; _type, _code, _qual1, _qual2,
				_relLoc, _relQual1, _relQual2 :String):String protected;
/*
Purpose:	Make a UNZ segment

Date		Who		Reason
09 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//13 Feb 2018   jlgsl4	TFS 36897 - corrected handling of null _relLoc, _relQual1, _relQual2

constants
	MESSAGE	= "LOC";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
	
begin
	if _code = null then	// 13/09/2012 cnwar2 #30322
		return null;
	endif;

	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	msg := MESSAGE &amp; plus &amp; 
			_type &amp; plus &amp; 
			_code;
			
	if _qual1 &lt;&gt; null or _qual2 &lt;&gt; null then
		msg := msg &amp; colon &amp; _qual1;
		if _qual2 &lt;&gt; null then
			msg := msg &amp; colon &amp; _qual2;
		endif;
	endif;

	if _relLoc &lt;&gt; null then	// TFS 36897 - no output if _relLoc null
		msg := msg &amp; plus &amp; _relLoc; // add +relLoc
		if _relQual1 &lt;&gt; null then
			msg := msg &amp; colon &amp; _relQual1; // add :_relQual1
			if _relQual2 &lt;&gt; null then
				msg := msg &amp; colon &amp; _relQual2; // add :_relQual2
			endif;
		endif;
	endif;
	
	if _group &lt;&gt; null then
		_group.add (msg);
	endif;
	
	msg := msg &amp; singleQuote;
			
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_qual1" type="String"/>
        <Parameter name="_qual2" type="String"/>
        <Parameter name="_relLoc" type="String"/>
        <Parameter name="_relQual1" type="String"/>
        <Parameter name="_relQual2" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMEASegment" id="a39efd09-cde6-4878-add2-07a3758b5861">
        <source>makeMEASegment(_protocol :CM_CamProtocol; _group :HugeStringArray input; _type, _detail, _unit :String; _value:Any):String protected;
/*
Purpose:	Make a MEA segment
Parameters: _value could be Decimal or String

Date		Who		Reason
09 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray

constants
	MESSAGE	= "MEA";
vars
	msg, value					:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	if _value.isKindOf (Decimal) then
		value := _value.Decimal.asStringWeightJMT;
	else
		value := _value.String;
	endif;
	
	msg := MESSAGE &amp; plus &amp; 
			_type.String &amp; plus &amp;
			_detail &amp; plus &amp;
			_unit &amp; colon &amp; value;
			
	msg := msg &amp; singleQuote;
			
	if _group &lt;&gt; null then
		_group.add (msg);
	endif;
	
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_detail" type="String"/>
        <Parameter name="_unit" type="String"/>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMEASegmentForTotalWeight" id="91425d58-3f26-46d2-8272-82391be5b0bc">
        <source>makeMEASegmentForTotalWeight(_protocol :CM_CamProtocol;
							_group :HugeStringArray input;
							_ti : CM_TrackedItem;
							_tiTransaction : CM_TITransaction )  protected;
/*

Date		Who		Reason
16 February 2016	cnwer1	Initial creation PAR 37551 EDI VGM TFS 1429

*/

vars
	measurementQualifier,
	measurementDetail,
	measurementUnit : String;
	totalWeight : Decimal [14,4];
begin
		
	measurementQualifier:=self.getMeasurementQualifier();
	measurementDetail:= "G";
	/*if _tiTransaction &lt;&gt; null and _tiTransaction.totalWeight &lt;&gt; 0  then
		totalWeight:=_tiTransaction.totalWeight;
		if _protocol.useVGM and _tiTransaction.isWeightCertified and not _tiTransaction.isEmpty  then
			measurementDetail:= "VGM";
		endif;
	else*/
		totalWeight:=_ti.totalWeight;
		if  _protocol.useVGM and _ti.isWeightCertified and not _ti.isEmpty then
			measurementDetail:= "VGM";
		endif;
	//endif;
	measurementUnit:="KGM";
	
	self.makeMEASegment(_protocol,_group,measurementQualifier ,measurementDetail,measurementUnit,totalWeight);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTransaction" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="makeMessageDTM_VGM" id="a9b24544-255e-449b-bd6d-3b83b78597f7">
        <source>makeMessageDTM_VGM(_protocol : CM_CamProtocol; _group : HugeStringArray input; _ti : CM_TrackedItem) : String protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 06/07/2017	cnwdap1		Initial creation TFS 4492 SNO VERMAS Changes
// 19 Sep 2017	jlgrs1	TFS 6957 Codeco/Coarri VGM extra details
//
vars
	msg : String;

begin
	if _ti.isKindOf(CM_Container) and _ti.CM_Container.myVGMDetails &lt;&gt; null then
		if _ti.CM_Container.myVGMDetails.vgmDeterminationDT &lt;&gt; null then
			msg := self.makeDTM_VGMSegment(_protocol, _group, "798", _ti.CM_Container.myVGMDetails.vgmDeterminationDT);
		endif;
//		if _ti.CM_Container.myVGMDetails.vgmDocsIssuedDT &lt;&gt; null then
//			msg := self.makeDTM_VGMSegment(_protocol, _group, "137", _ti.CM_Container.myVGMDetails.vgmDocsIssuedDT);
//		endif;
	endif;
	
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageDimensionsData" id="6c7eea7c-1adc-444b-bb82-b811775b1f92">
        <source>makeMessageDimensionsData(_protocol :CM_CamProtocol; _group :HugeStringArray input; _ti :CM_TrackedItem) protected;
/*
Purpose:	Output DIM segments		

Date		Who		Reason
10 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	if _ti.cargoType &lt;&gt; TI_CargoType_Container then	
		// process as gross dimensions
		_group.add("DIM" &amp; plus &amp; "1" &amp; plus &amp; "CMT" &amp; colon &amp; _ti.length.asStringMeasurementJMT() &amp; colon &amp; _ti.width.asStringMeasurementJMT() &amp; colon &amp; _ti.height.asStringMeasurementJMT() &amp; singleQuote); 
	else			
		// process as overdimensions adm 240909 Par 20434 //cnwrs1 par 20611 oct 2009
		if _ti.CM_Container.overLengthFront &lt;&gt; 0 then
			_group.add("DIM" &amp; plus &amp; "5" &amp; plus &amp; "CMT" &amp; colon &amp; _ti.CM_Container.overLengthFront.asStringMeasurementJMT() &amp; singleQuote);
		endif;
		if _ti.CM_Container.overLengthRear &lt;&gt; 0 then
			_group.add("DIM" &amp; plus &amp; "6" &amp; plus &amp; "CMT" &amp; colon &amp; _ti.CM_Container.overLengthRear.asStringMeasurementJMT() &amp; singleQuote);
		elseif (_ti.CM_Container.overLengthFront = null and _ti.CM_Container.length &lt;&gt; null) then // do old version
			_group.add("DIM" &amp; plus &amp; "9" &amp; plus &amp; "CMT" &amp; colon &amp; _ti.CM_Container.length.asStringMeasurementJMT() &amp; singleQuote);
		endif;
		if _ti.CM_Container.overWidthRight &lt;&gt; 0 then
			_group.add("DIM" &amp; plus &amp; "7" &amp; plus &amp; "CMT" &amp; colon &amp; colon &amp; _ti.CM_Container.overWidthRight.asStringMeasurementJMT() &amp; singleQuote); 
		endif;
		if _ti.CM_Container.overWidthLeft &lt;&gt; 0 then
			_group.add("DIM" &amp; plus &amp; "8" &amp; plus &amp; "CMT" &amp; colon &amp; colon &amp; _ti.CM_Container.overWidthLeft.asStringMeasurementJMT() &amp; singleQuote);
		elseif (_ti.CM_Container.overWidthRight = null and _ti.width &lt;&gt; null) then // do old version
			_group.add("DIM" &amp; plus &amp; "9" &amp; plus &amp; "CMT" &amp; colon &amp; colon &amp; _ti.CM_Container.width.asStringMeasurementJMT() &amp; singleQuote);
		endif;
		if _ti.CM_Container.overHeight &lt;&gt; 0 then
			_group.add("DIM" &amp; plus &amp; "9" &amp; plus &amp; "CMT" &amp; colon &amp; colon &amp; colon &amp; _ti.CM_Container.overHeight.asStringMeasurementJMT() &amp; singleQuote);
		elseif _ti.CM_Container.height &lt;&gt; null then // do old version
			_group.add("DIM" &amp; plus &amp; "9" &amp; plus &amp; "CMT" &amp; colon &amp; colon &amp; colon &amp; _ti.CM_Container.height.asStringMeasurementJMT() &amp; singleQuote);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="makeMessageFTX_VGM" id="ea433538-2800-44d0-9fa0-f0b4eea88532">
        <source>makeMessageFTX_VGM(_protocol : CM_CamProtocol; _group : HugeStringArray input; _ti : CM_TrackedItem) : String protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 07/07/2017	cnwdap1		Initial creation TFS 4492 SNO VERMAS Changes
//
vars
	msg, solasMethod : String;

begin
	if _ti.isKindOf(CM_Container) and _ti.CM_Container.myVGMDetails &lt;&gt; null then
		if _ti.CM_Container.myVGMDetails.myWeighAuthTerminal &lt;&gt; null then
			if _ti.CM_Container.myVGMDetails.myWeighAuthTerminal.myWeighAuthority &lt;&gt; null then
				solasMethod := _ti.CM_Container.myVGMDetails.myWeighAuthTerminal.myWeighAuthority.solasMethod;
			endif;
		endif;
		if _ti.CM_Container.myVGMDetails.vgmCommsType.isOneOf("SM1", "SM2") or solasMethod &lt;&gt; null then
			msg := self.makeFTX_VGMSegment(_protocol, _group, _ti.CM_Container.myVGMDetails);
		endif;
	endif;
	
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageHazardsData" id="8aa1ca50-74eb-4ef7-ab56-73aec9be1925">
        <source>makeMessageHazardsData(_ti :CM_TrackedItem; _protocol :CM_CamProtocol; _group :HugeStringArray input)protected;
/*
Purpose:			
Parameters:		_group	- group to add DGS segment to		
Return Value:		

Date		Who		Reason
10 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars
	haz					:CM_Hazard;
	code				:String;
	plus, singleQuote	: Character;
begin
	if _ti.allTIHazards.isEmpty then									
		return;
	endif;
	
	plus 		:= _protocol.elementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	foreach haz in _ti.allTIHazards do : haz_loop
		if haz.CM_TIHazard.allUNDGCodes.isEmpty then
			_group.add( "DGS" &amp; plus &amp; "IMD" &amp; plus &amp; haz.code.trimRight &amp; singleQuote );
		else
			foreach code in haz.CM_TIHazard.allUNDGCodes do : code_loop
				_group.add( "DGS" &amp; plus &amp; "IMD" &amp; plus &amp; haz.code.trimRight &amp; plus &amp; code.trimBlanks.toUpper &amp; singleQuote );
			endforeach code_loop;
		endif;
	endforeach haz_loop;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="makeMessageHeader" id="5e6f0076-d4dd-438b-b2d8-13f488371ab4">
        <updating/>
        <source>makeMessageHeader(_camFile : CM_CamFile input; _camTaskHistory : CM_CamTaskHistory input; _unhSeqNumber : Integer io; 
					_type : String; _fileType : String; _coll :HugeStringArray input) : String updating;
// 10/02/2011	cnwcs5	CCMS JMT 1977/PAR 26531 - changed _camFile/_camTaskHistory parameter usage from io to input
// 09/05/2011	cnwcs5 	CCMS SCT 2058/par 27460 - replace literals with characters defined on protocol
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//17/06/2016    cnwma1  TFS# 2159:CPL - Wrong Header for CODECO D.95B

vars
	protocol : CM_CamProtocol;
	strLine : String;
	
begin
	_unhSeqNumber 	:= _unhSeqNumber + 1;
	protocol 		:= _camTaskHistory.camProtocol;
		
	// UNH
	if protocol.camGroup.code.trimBlanks = "COL" then
		strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeUNHSegment (protocol, _unhSeqNumber, _fileType, "D", "95B", "UN", "ITIG12", null, _camTaskHistory.runDateTime), _coll);		//cnwmc5 - 15 Oct 2014 - CCMS 2380
	else
		//strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeUNHSegment (protocol, _unhSeqNumber, _fileType, "D", "95B", "UN", "ITG12", null, _camTaskHistory.runDateTime), _coll);			//cnwmc5 - 15 Oct 2014 - CCMS 2380   -//17/06/2016 cnwma1  TFS#2159
		strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeUNHSegment (protocol, _unhSeqNumber, _fileType, "D", "95B", "UN", "SMDG16", null, _camTaskHistory.runDateTime), _coll);			//+17/06/2016 cnwma1  TFS#2159
	endif;

	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeBGMSegment (protocol, _type, _unhSeqNumber, 9, null), _coll);
	
	_camFile.incrementMessageCount();
	return strLine;
end;</source>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_fileType" type="String"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageNAD_VGM" id="82ec7446-bcaa-47f0-bdd7-c13a7aa1afec">
        <source>makeMessageNAD_VGM(_protocol : CM_CamProtocol; _group : HugeStringArray input; _ti : CM_TrackedItem) : String protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/05/2016	cnwdap1		Initial creation TFS #2061 COPARN/CODECO/COARRI/EDI VGM Updates
// 31/08/2016   cnwma1 		TFS #2612:POL - NAD+AM segment in VERMAS requires max 35 characters
//
vars
	msg : String;

begin
	if _ti.weightCertifiedName &lt;&gt; null then
		msg := self.makeNAD_VGMSegment(_protocol, _group, "AM", _ti.weightCertifiedName.toUpper[1:35], null, null); //31/08/2016 cnwma1 TFS #2612
	endif;
	if _ti.weightCertifiedReference &lt;&gt; null then
		msg := self.makeNAD_VGMSegment(_protocol, _group, "SPC", _ti.weightCertifiedReference.toUpper[1:35], null, null);  //31/08/2016 cnwma1 TFS #2612
	endif;
	
	return msg;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageRFF_BM_for_162" id="ac36d8ed-1bff-4347-a14f-a29a52efb165">
        <source>makeMessageRFF_BM_for_162(_protocol :CM_CamProtocol; _group :HugeStringArray input; _ti :CM_TrackedItem) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 January 2021	jlgndl1	Initial creation	TFS 50708 - NON Std stuff for GPHA

*/

vars

	msg, value	:String;

begin

	if not _protocol.includeRFFBM162 then
		return;
	endif;

	value := _ti.billOfLading.trimRight;
	if value = null then
		return;
	endif;
	
	self.makeRFFSegment (_protocol, _group, "BM", value);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="makeMessageRFF_CN" id="7e6705b1-521d-4e39-822a-b1eef3398372">
        <source>makeMessageRFF_CN(_protocol :CM_CamProtocol; _group :HugeStringArray input; _ti :CM_TrackedItem) protected;
/*

Date		Who		Reason
23 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars
	ref	:String;
begin
	if not _protocol.isSendCarrierReference then
		return;
	endif;
	
	ref := _ti.getCarrierReference;

	if ref &lt;&gt; null then
		self.makeRFFSegment (_protocol, _group, "CN", ref);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="makeMessageRFF_CT" id="45faeb5b-52df-4996-883c-2c7da5ec3448">
        <source>makeMessageRFF_CT(_protocol :CM_CamProtocol; _group :HugeStringArray input; _ti :CM_TrackedItem) protected;
/*
Purpose:			
Parameters:			
Return Value:		
Date		Who		Reason
16 October 2014	cnwmc5	Initial creation
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars
	bol	:String;
begin
	if not _protocol.isSendCarrierReference then
		return;
	endif;
	
	bol := _ti.getReceivalBOLNumber;

	if bol &lt;&gt; null then
		self.makeRFFSegment (_protocol, _group, "CT", bol);
	endif;
epilog

end;</source>
        <access>protected</access>
