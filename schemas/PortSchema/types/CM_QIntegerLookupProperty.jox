// ---------------------------------------------------------------------------
// Created:     04 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	return 30;	// will apply for any subclass that uses description

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getQueryOperatorForYADataConv" id="21a283b1-9bb0-4914-a6c9-f9a577370759">
        <source>getQueryOperatorForYADataConv(): Class;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

	iter : Iterator;
	queryOper : CM_QueryOperator;
	class : Class;
	className : String;

begin
	
	//first choice
	iter := self.allAllowedOperators.createIterator;
	while iter.next( queryOper ) do
		class := queryOper.class;
		if class = CM_QIntegerIsOneOf then
			return class;
		endif;
	endwhile;
	delete iter;
	
	//second choice
	iter := self.allAllowedOperators.createIterator;
	while iter.next( queryOper ) do
		class := queryOper.class;
		if class = CM_QIntegerLookupEqual then
			return class;
		endif;
	endwhile;
	
	
	return null;

epilog

	delete iter;

end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="67ffa1f3-1fde-4062-818f-b2e5de20a559">
        <source>translateStringToSearchValue(_value: Any; _criteriaLine: CM_SelectorCriteriaLine): Any;
// ---------------------------------------------------------------------------
// Created:     11 April 2008		cnwvu1	
// ---------------------------------------------------------------------------
vars

begin
	
		// when not found. Par 17092	cnwvu1, June 2008
	if _value = null then
	//	app.raiseCMException1( REQUIRED_FIELD, _criteriaLine.myQueryProperty.niceName, null, self );
		app.raiseCMException1( Input_required_field_Required, _criteriaLine.myQueryProperty.niceName, null, self ); // cnwdb2	PAR 35364


	else
		app.raiseCMException2( ERR_FIELD_VALUE, _value.String, _criteriaLine.myQueryProperty.niceName, null, self );
	endif;

	return _value.String;

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
