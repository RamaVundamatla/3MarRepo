end;</source>
    </JadeMethod>
    <JadeMethod name="getBRDisplay" id="ea306546-8265-4b05-b324-80bb7e693d05">
        <source>getBRDisplay(_br : CM_BookingRef) :String;
// ---------------------------------------------------------------------------
// Created:     29 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 27/12/2012	cnwdap1		PAR #30882 CCMS PNL 2244 Release request specific totals
vars
	expected,
	onSite,
	total,
	packed : Integer;
	item,marks,
	bookingRefNo, 
	locations : String;
	brItem					: CM_BookingRefItem;
	bulkRelAss	: CM_BulkRelease; // the bulk release associated with the booking reference
	bulkChild  : CM_ReserveDetail;
	countPacked : Integer;
	release		: CM_BulkRelease;		// PAR #30882
begin
	bookingRefNo := _br.bookingReference;
	if not _br.allReleaseRequests.isEmpty then											// PAR #30882
		release := _br.allReleaseRequests.first;		// actually 1-to-1				// PAR #30882
		release.getTICategoryDetails(true, packed, onSite, total, expected, locations);	// PAR #30882
	else																				// PAR #30882
		_br.getTICategoryDetails(true, packed, onSite, total, expected, locations);
	endif;																				// PAR #30882
	marks := _br.getShippingMarks;

/*	bulkRelAss := _br.allReleaseRequests.first;
	countPacked := 0;
	// check to see if the relationship between the booking reference and the bulk release exists
	if bulkRelAss &lt;&gt; null then // dh added this line 25/6/2008
		if _br = bulkRelAss.myBookingRefStock then
			foreach bulkChild in bulkRelAss.allReservePackingChildren do
			// add the number of all release cargo for each packing release child.
				countPacked := countPacked + bulkChild.allTrackedItemsReleased.size;
			endforeach;
		endif;
	endif;
*/	return bookingRefNo &amp; Tab &amp; marks &amp; Tab &amp; onSite.String &amp; Tab &amp; expected.String &amp; Tab &amp; packed.String;
end;</source>
        <Parameter name="_br" type="CM_BookingRef"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTableSettings" id="4ac56fb9-d63e-48f2-b715-b1ef38717828">
        <source>getTableSettings(_columns: Integer output; _header: String output);
/*
	Created on 28 April 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars

begin
	_columns := 5;
	_header := app.getErrorString(Item) &amp;"#" &amp; Tab &amp; app.getErrorString(Marks) &amp; Tab &amp; app.getErrorString(INV_On_Site)&amp; Tab &amp; app.getErrorString(Expected) &amp; Tab &amp; app.getErrorString(TransType_14);
end;</source>
        <Parameter name="_columns" type="Integer" usage="output"/>
        <Parameter name="_header" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="loadTable" id="6d4698e8-0cff-4841-8354-4c74a21d0b2c">
        <updating/>
        <source>loadTable() updating;
// ---------------------------------------------------------------------------
// Created:     29 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	br : CM_BookingRef;
	allBRs : CM_BookingRefsByOperatorRef;
begin
	self.tbl_Items.rows := 1;
	if self.myVoyage &lt;&gt; null then
		allBRs := self.myVoyage.allBookingRefs;
		foreach br in allBRs do
			if br &lt;&gt; null and br.isStockBookingRef then
				self.addBRToTable(self.tbl_Items, br);
			endif;
		endforeach;	
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setVoyage" id="ab5be23f-4ce2-4601-9176-b17fbd0bc126">
        <updating/>
        <source>setVoyage(_voyage : CM_Voyage)updating;
// ---------------------------------------------------------------------------
// Created:     29 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.myVoyage := _voyage;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="bc8adae5-8bbc-4806-a7fe-10b5257a69fd">
        <updating/>
        <source>setupForm() updating, protected;
// ---------------------------------------------------------------------------
// Created:     29 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();
//	self.tbl_Items.autoSize := Table.AutoSize_Row;
	self.tbl_Items.accessColumn(3).alignment := Table.Alignment_Center_Middle;
	self.tbl_Items.accessColumn(4).alignment := Table.Alignment_Center_Middle;
	self.btn_Menu.caption := "Back";
	self.btn_Details.caption := "Order Details";
	self.lbl_Head.caption := app.getErrorString(Voyage) &amp; " : " &amp; self.myVoyage.code;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showObjSelected" id="5109cbaa-4912-478d-bf0e-d66d088183ef">
        <source>showObjSelected(_obj: CM_Object);
// ---------------------------------------------------------------------------
// Created:     30 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	form : MOB_CEBookingRefForm;
	br : CM_BookingRef;
	desc : String;
	invalidObject : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, br, invalidObject);

	if _obj &lt;&gt; null and _obj.isKindOf(CM_BookingRef) then
		br := _obj.CM_BookingRef;
		// 24447 check availability by doing a de-reference, if invalid do nothing
		desc := br.description;
		if invalidObject then
			return;
		endif;

		create form transient;
		form.setBookingRef(br);
		form.show();
	endif;
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="8822562e-efd3-4179-b1de-ffdc6d42e18e">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018469, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
