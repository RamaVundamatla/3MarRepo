    <JadeMethod name="handleBerthingChangeNote" id="06325c27-25f5-4dc1-a043-dccda1ac4df8">
        <updating/>
        <source>handleBerthingChangeNote() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	
begin

	app.msgBox('The berthing of the currently selected voyage has been changed.' &amp; CrLf &amp;
			'The voyage will now be re-displayed.', 
			'Voyage Planning - Berthing change detected', MsgBox_Exclamation_Mark_Icon);

	// this will reset the berthing flag
	self.myBulkDrawingController.setFromVoyage(self.myCurrentVoyage);
	
	// now redraw the info
	self.redraw; 
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleHoldMouseDownEvent" id="952211df-50ed-46d9-9cc2-723210b8f6e3">
        <updating/>
        <source>handleHoldMouseDownEvent(frame : SHP_BulkDrawingFrame input; button : Integer; shift : Integer; x : Real; y : Real) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	obj : Object;
	hold : CM_GeneralCargoController;

begin
	frame.enableEvent("mouseMove", true);

	if button = Window.MouseButton_Left and shift = 0 or shift.isAltKeyPressed() then
		self.origXPos := x;
		self.origYPos := y;
		self.aMyOriginalWindow := frame;

		obj := frame.getObjectForPosition(x.Integer, y.Integer);
		
		if (obj = null and (not self.hasChanged))
		or not obj.isKindOf(CM_GeneralCargoController)	// ### AKB2005JUNE. maybe a hatchlid in cust seq mode
		then
			return;
		endif;
		
		self.tblGridAreaInfo.rows := 0;
		self.tblPopupInfo.rows := 0;
		
		if global.isValidObject(app.myMoveController) then
			app.myMoveController.mySlotRequest := null;
		endif;	
		
		app.myDraggedTrackedItem := null;
		
		if self.workingMode = WorkMode_Volume then
			self.handleHoldMouseDownEventPlan(self.myBulkDrawingController, obj.CM_GeneralCargoController, shift);
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="frame" type="SHP_BulkDrawingFrame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="handleHoldMouseDownEventPlan" id="1498f191-6c11-4443-833a-459b72baf2d5">
        <updating/>
        <source>handleHoldMouseDownEventPlan(_drawController : SHP_BulkDrawingController; _hold : CM_GeneralCargoController; shift : Integer) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	ti : CM_TrackedItem;
	slotRequest : CM_SlotRequest;
	planMove : CM_FutureMove;
	lcs : CM_LCArray;
	obj : Object;

begin
	if _hold = null then
		return;
	endif;
	
	if self.workingMode = WorkMode_Volume then
		self.moveModeForm := _drawController.moveMode;
		if self.displayMode = ShpDisplayMode_ColCodeDisch then

			// #### DISCHARGE
			ti := _hold.allTrackedItems.first;
			if ti &lt;&gt; null then
				// only if we are not already planned
	
				planMove := ti.getFutureMoveOfType(PLANNING_MODE, TI_FutureMoveDLRDischarge);
				if planMove = null then
					planMove := ti.getFutureMoveOfType(PLANNING_MODE, TI_FutureMovePlanned);
				endif;
				if planMove = null then
					app.myDraggedTrackedItem := ti;
					self.setMoveControllerSource(ti);
					//app.myMoveController.mySlotRequest := theSlotRequest;
				endif;					
			endif;
		else
			// ##### LOAD
		/*	if theSlotRequest &lt;&gt; null and theSlotRequest.myJob &lt;&gt; null and theSlotRequest.myJob.isJobComplete then
				theSlotRequest := null;
			endif;
			// if the load is complete check for a rework SlotRequest and switch to that
			if theSlotRequest = null then
				theSlotRequest := _slot.mySlotRequestDischarge;
				if theSlotRequest &lt;&gt; null then
					if not (theSlotRequest.isSOB or theSlotRequest.isRehandle) then
						theSlotRequest := null;
					endif;
					if theSlotRequest &lt;&gt; null then
						if theSlotRequest.myJob &lt;&gt; null and theSlotRequest.myJob.isJobComplete then
							theSlotRequest := null;
						endif;
					endif;							
				endif;
				if theSlotRequest &lt;&gt; null then
					theTI := theSlotRequest.getTrackedItem();
					// only if we are not already planned
					if theTI &lt;&gt; null
					and theTI.getPrimaryLocation(PLANNING_MODE) = null then
						app.myDraggedTrackedItem := theTI;
						self.setMoveControllerSource(theTI);
						app.myMoveController.mySlotRequest := theSlotRequest;
						
					endif;					
				endif;
			endif;

			// may have been erased so will be null move type
			if theSlotRequest &lt;&gt; null and (theSlotRequest.moveType = LOAD_MOVETYPE or theSlotRequest.isRehandle or theSlotRequest.isSOB) then
				self.setMoveControllerTarget(_slot);
				//jared: set mySlotRequest for other forms
				app.myMoveController.mySlotRequest := theSlotRequest;
				// PAR #28615 self.setMoveControllerTarget method just deleted the app.myMoveController that knew whether 
				// we were ignoring weight validation checks or not - need to reinstate this flag on the new move controller
				app.myMoveController.ignoreWeightValidation := self.chkIgnoreWeightV.value;
				
				app.myMoveController.autoSeqLoadPlan := false;
				if shift.isAltKeyPressed() 
				and not (theSlotRequest.isRehandle or theSlotRequest.isSOB) then
				
					app.myMoveController.autoSeqLoadPlan := true;
				endif;
				
				if theTI &lt;&gt; null then
					app.myMoveController.setMyTrackedItem(theTI);
				endif;
			endif;	*/
		endif;
	endif;

	if app.myMoveController &lt;&gt; null then
		app.myMoveController.myOriginatingForm := self;
	endif;
	
epilog
	delete lcs;
end;</source>
        <access>protected</access>
