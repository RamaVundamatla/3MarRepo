<Class name="CM_QRefLocationProperty" id="810a7f73-1a53-418a-8675-d788e7ab478c">
    <superclass name="CM_QReferenceLookupProperty"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="e1df4acb-cac3-4cae-87b4-965a10e1e155">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 October 2019	jlger1	Initial creation TFS 47132

*/

vars

	queryOperator	: CM_QueryOperator;
begin

	if self.isTransient then	
		return;
	endif;

	create queryOperator as CM_QReferenceIsOneOf persistent;
	self.allAllowedOperators.add(queryOperator);	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getListBoxPropertyName" id="328762e3-8c43-4e5c-999b-9529b742c18b">
        <source>getListBoxPropertyName(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 January 2020	jlgndl1	Initial creation	TFS 47780

*/

vars

begin

	if self.propertyName = "myPrimaryActualLocation" then
		return CM_LocationsController::ident.name;
	else
		return inheritMethod();
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="e6cac53e-4850-4ba6-a936-e30363a6482c">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 October 2019	jlger1	Initial creation TFS 47132

*/

vars
	tas				: ObjectSet;
	taCrit		: CM_SelectorCriteriaLine;
	obj : Object;
	location : CM_LocationsController;
	shelf : CM_RackShelfController;
	qrl : CM_QReferenceLookup;
begin
	_combo.clear();

	create tas transient;
	taCrit:=_params.findCriteriaByName(CM_TrackedItem::myTerminalArea.name);
	if taCrit &lt;&gt; null then		
		taCrit.myQueryOperator.getSearchValueAsObjectSet(tas);
	endif;
	
	foreach obj in tas discreteLock  do
		foreach location in obj.CM_TerminalArea.allLocationsControllers discreteLock do
			if location.isRack then
				foreach shelf in location.CM_IrregularBlockController.allSubLocations do
					_combo.itemObject[_combo.addItem(shelf.displayEntry)] := shelf;
				endforeach;
				continue;
			elseif location.isDeparted then	//07 Aug 2020	NDL	TFS 49849 - don't show departed wagons
				continue;
			endif;

			_combo.itemObject[_combo.addItem(location.displayEntry)] := location;
		
		endforeach;
		
		
	endforeach;
	
	if CM_QReferenceLookup.hasInstance(_queryOperator) then
		qrl := _queryOperator.CM_QReferenceLookup;
		if global.isValidObject(qrl.mySelectionValue) then
			if _combo.findObject(qrl.mySelectionValue)  &gt; 0 then
				_combo.listObject := qrl.mySelectionValue;
			endif;
		endif;
	endif;
	
epilog
	delete tas;


end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="1a89d5bc-2ca1-4fbb-af8c-36f6965cd2fc">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QReferenceIsOneOf; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 October 2019	jlger1	Initial creation

*/

vars
	selectionValue		: Integer;
	ut					: CM_UserTerminal;
	user				: CM_User;
	idx					: Integer;
	tas				: ObjectSet;
	taCrit		: CM_SelectorCriteriaLine;
	obj : Object;
	location : CM_LocationsController;
begin
	_tbl.clear;
	_tbl.rows := 0;
	_tbl.sortColumn[1] := 2; // TFS 7821

	
	create tas transient;
	taCrit:=_params.findCriteriaByName(CM_TrackedItem::myTerminalArea.name);
	if taCrit &lt;&gt; null then		
		taCrit.myQueryOperator.getSearchValueAsObjectSet(tas);
	endif;
	
	foreach obj in tas discreteLock  do
		foreach location in obj.CM_TerminalArea.allLocationsControllers discreteLock do
			if location.isDeparted then	//07 Aug 2020	NDL	TFS 49849 - don't show departed wagons
				continue;
			endif;
			selectionValue := 0;
			if _operator &lt;&gt; null and _operator.allSelectionValues.includes(location) then
				selectionValue := 1;
			endif;
			idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; location.displayEntry);
			_tbl.accessRow(idx).itemObject := location;
			_tbl.row := idx;
			_tbl.change(_tbl);
		endforeach;
	endforeach;

epilog
	delete tas;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QReferenceIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="showCriteria" id="4fde9529-b23c-44e5-bbfc-581416417dfb">
        <source>showCriteria(lineHolder: CM_QueryCriteriaLineHolder input): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Nov 2019	jlger1	Initial creation  47132

*/

vars

begin
	
	return lineHolder.findCriteriaByName(CM_TrackedItem::myTerminalArea.name) &lt;&gt; null;
	


epilog

end;</source>
        <Parameter name="lineHolder" type="CM_QueryCriteriaLineHolder" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="4e99ba00-f4e9-4004-b487-950d3862591c">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 October 2019	jlger1	Initial creation

*/

vars

begin
	if _value &lt;&gt; null and _value.isKindOf(CM_LocationsController) then
		return _value.CM_LocationsController.displayEntry;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="32f0d190-946e-49b2-8eb9-ec222eb4d908">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 October 2019	jlger1	Initial creation

*/

vars
	returnVal		: CM_LocationsController;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			// PAR #18348
			return _value;
		endif;

		if _value.isKindOf(CM_LocationsController) then
			returnVal := _value.CM_LocationsController;
		endif;
	endif;
	
	return returnVal;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
