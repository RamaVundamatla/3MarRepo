<GUIClass name="MB_Line3D" id="9bf725c6-0ee9-43e3-9a15-9424ac0f8de5">
    <superclass name="Frame"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <DbClassMap file="_usergui"/>
    <Constant name="DEFAULT_HEIGHT" id="cf57abb6-ab2f-4917-8105-caf2486208e7">
        <source>2</source>
        <type name="Integer"/>
    </Constant>
    <JadeMethod name="create" id="95525e33-49c8-4f1d-b34e-590650590140">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		08 February 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.borderStyle		:=	0;
	self.caption			:=	null;
	self.height				:=	self.DEFAULT_HEIGHT;
	self.bevelColor			:=	self.getSystemColor(Window.Color_3DHighlight);		// cnwdad1 28/02/2003.
	self.bevelInner			:=	0;
	self.bevelInnerWidth	:=	0;
	self.bevelOuter			:=	1;
	self.bevelOuterWidth	:=	1;
	self.bevelShadowColor	:=	self.getSystemColor(Window.Color_3DDkShadow);		// cnwdad1 28/02/2003.
	self.boundaryBrush		:=	0;
	self.boundaryWidth		:=	0;
	self.boundaryColor		:=	self.getSystemColor(Window.Color_3DFace);			// cnwdad1 28/02/2003.
	self.show3D				:=	Control.Show3D_Use3D;
end;</source>
    </JadeMethod>
    <JadeMethod name="height" id="61d35154-1093-4210-b45d-7c0b2c1dc357">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>height(set: Boolean; value: Real io) updating, mapping, clientExecution;
// --------------------------------------------------------------------------------
// Created:		08 February 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if set then
		value	:=	self.DEFAULT_HEIGHT;
		inheritMethod(set, value);
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="move" id="96702f77-6e1e-4d09-ac3a-cd7220878f20">
        <executionLocation>client</executionLocation>
        <source>move(x: Real; y: Real; width: Real; height: Real) clientExecution;
// --------------------------------------------------------------------------------
// Created:		08 February 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(x, y, width, self.DEFAULT_HEIGHT);
end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="width" type="Real"/>
        <Parameter name="height" type="Real"/>
    </JadeMethod>
