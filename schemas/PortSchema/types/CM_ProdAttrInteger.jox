    <JadeMethod name="setProxy" id="5fd81b0c-ccb6-4cb5-9767-ce7dcfc4c690">
        <updating/>
        <source>setProxy(_realProdAttr: CM_ProdAttrInteger) updating;
// ---------------------------------------------------------------------------
// Created:     11 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod(_realProdAttr);
	self.maxValue 		:= _realProdAttr.maxValue;
	self.minValue 		:= _realProdAttr.minValue;
	self.value 			:= _realProdAttr.value;
	self.multiplier		:= _realProdAttr.multiplier;

end;</source>
        <Parameter name="_realProdAttr" type="CM_ProdAttrInteger"/>
    </JadeMethod>
