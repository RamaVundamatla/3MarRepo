    <JadeMethod name="getTerminal" id="a0111dd5-7285-4abc-8878-b75ab7a04d45">
        <source>getTerminal(): CM_Terminal;
// ---------------------------------------------------------------------------
// Created:     09 October 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//05 Dec 2024 		navma1	 		MTN-33567 MTN - Charges Are Not Created When adding Events
// ---------------------------------------------------------------------------

vars
	term  : CM_Terminal;
	wagon : CM_Wagon;
begin
	term := inheritMethod();
	
	if term = null then
		wagon := self.myWagon;				//05.12.2024 navma1 #MTN-33567
		if wagon &lt;&gt; null then
			return wagon.getTerminal();
		endif;
	endif;
	
	return term;
epilog

end;</source>
        <ReturnType type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getTrain" id="21477cd1-c3e0-4f18-a2f0-ecb47900175a">
