    <JadeMethod name="trxUpdateMoveMenuItem" id="f1e22d42-2037-4660-9915-ded1bdbfbe02">
        <updating/>
        <source>trxUpdateMoveMenuItem(	_oldParent:CM_MenuEntity input;
						_newParent:CM_MenuEntity input;
						_pickupEntity:CM_MenuEntity input;
						_hoverObject:CM_MenuEntity;
						_isUnopenedFolder:Boolean;
						_passport:CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		27 October 2005 by cnwdad1
//
// Purpose:		Moves a Menu Entity object from one parent entity to another.
//
// Parameters:	_oldParent - A reference to the Menu entity's old parent entity.
//				_newParent - A reference to the Menu entity's new parent entity.
//				_pickupEntity - A reference to the Menu Entity that is being moved.
//				_hoverObject - A reference to the Menu entity which the "pickup"
//					entity is being inserted over (i.e. the hover object will move
//					down one slot).
//				_isUnopenedFolder - True if, on the GUI where the user is dragging
//					the Menu entity being moved), the menu tree is expanded.
//				_passport - A reference to the user passport thingy.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Always initialize the activity first.
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers.
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;

	app.myUtilityUA.utlUpdateMoveMenuItem(	_oldParent,
											_newParent,
											_pickupEntity,
											_hoverObject,
											_isUnopenedFolder,
											_passport);
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_oldParent" type="CM_MenuEntity" usage="input"/>
        <Parameter name="_newParent" type="CM_MenuEntity" usage="input"/>
        <Parameter name="_pickupEntity" type="CM_MenuEntity" usage="input"/>
        <Parameter name="_hoverObject" type="CM_MenuEntity"/>
        <Parameter name="_isUnopenedFolder" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateMoveTIUndo" id="2c876164-4403-41c9-b179-ec9cb44322af">
        <updating/>
        <source>trxUpdateMoveTIUndo(_theControl : CMIF_MoveController input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		April  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 27 Oct  2024  navma1		MTN-33238 SNO - Error 1081 when  UnPlan Cargo items
// ---------------------------------------------------------------------------

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	_passport.useTIDictDeferUpdate 			:= true;				//27.10.2024 navma1	 #MTN-33238
	_passport.useTITransactionDeferUpdate	:= true;				//27.10.2024 navma1	 #MTN-33238
	
	beginTransaction;

	app.myUtilityUA.utlUpdateMoveTIUndo(_theControl, _passport);
	
	if _passport.noErrors then										//27.10.2024 navma1	 #MTN-33238
		_passport.doDeferredUpdates();
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_theControl" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateMoveTIsUndoForMode" id="a7f2d9db-da13-4943-9673-a4814a176032">
        <updating/>
        <source>trxUpdateMoveTIsUndoForMode(_tis : CM_TISet; _moveMode : Integer; _passport : CM_Passport input) updating;
//-----------------------------------------
//Created: May 2003 By: cnwgd1
//-----------------------------------------
// Changed On	By			Reason
// ----------	--------	----------------------------------------------
// 03/02/2015	cnwdap1		PAR #35397 CCMS SFW 1394 Only switch controller to planning mode if we were asked to uplan
//							(stops a request to unqueue a planned queued TI switching to unplanning rather than unqueuing)
//24 Feb 2025	navbs1	    Bug MTN-28384: MTN - Un Plan Cargo items Doesn't use Deferred Updates 
vars
	isLoad	: Boolean;
	alertCreated : Boolean;
	control : CMIF_MoveController;
	ti		: CM_TrackedItem;
	aDFM, aLFM	: CM_FutureMove;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(true);
	
	if _moveMode = REAL_MODE then
	//	app.raiseCMException(ERR_INVALID_MODE, null, null);
		app.raiseCMException1( Invalid_move_mode_passed, method.qualifiedName, null, null );	//13 Apr 2021	NDL	TFS 50906
		return;
	endif;

	create control transient;
	control.setMoveMode(_moveMode);	
	control.isSystemMove := true;
		
	foreach ti in _tis do
		exclusiveLock(ti);
	
		control.setMyWorkListEntry(null);			// TFS 2521 Aug 2016 this seems to have been set from a prior TI and cause problems later
		control.setMyTrackedItem(ti);
		control.setMyToPrimaryLocation(null);
		
		// 28736 Dec 2011 cnwjre1 extra setup for planned DLRs; isLoad setting from CM_BaseForm doBuildUnplanMenu
		//    as then used by doUnplanTI
		//if ti.getPrimaryLocation(PLANNING_MODE) &lt;&gt; null then								// PAR #35397
		if ti.getPrimaryLocation(PLANNING_MODE) &lt;&gt; null and _moveMode = PLANNING_MODE then	// PAR #35397
			isLoad := true;
			if ti.isRehandle then
				aDFM := ti.getFutureMoveOfType(PLANNING_MODE,TI_FutureMoveDLRDischarge);
				aLFM := ti.getFutureMoveOfType(PLANNING_MODE,TI_FutureMoveDLRLoad);
				if aLFM = null and
				   aDFM &lt;&gt; null then
					isLoad := false;
				endif;
			endif;
			control.setForCreateUnplan(ti, null, null, isLoad);
		endif;
		// end 28736
		beginTransaction;	
	
		_passport.useTIDictDeferUpdate := true;												//24.02.2025 navbs1 #28384
		_passport.useTITransactionDeferUpdate := true;										//24.02.2025 navbs1 #28384
		
		app.myUtilityUA.utlUpdateMoveTIUndo(control, _passport);
		if _passport.hasErrors then
			alertCreated := true;
			app.convertErrorsWarningsToAlert('Tracked item ' &amp; ti.id &amp; ' move not undone', _passport.allErrorWarnings);
			app.cmsAbortTransaction();
		else
			_passport.doDeferredUpdates();													//24.02.2025 navbs1 #28384
			app.cmsCommitTransaction(_passport);
		endif;
	endforeach;

	if _passport.noErrors and (not process.isInTransactionState) then
		// Done so that finaliseActivityWithPassport will commit correctly
		beginTransaction;
	endif;
	
	if alertCreated then
		app.raiseCMException1(SystemAlertCreated, 'Moving Tracked Items', null, self);
	endif;
		
epilog
	delete control;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_tis" type="CM_TISet"/>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateMovementPath" id="a6315613-0e23-47d9-b8f3-fd0829a74b87">
