    <JadeMethod name="setProxy" id="ca23e7af-c936-4c0c-818b-fab8f65e4c0a">
        <updating/>
        <source>setProxy(pID,
		 pComment : String; 
		 pType : Integer;
		 pHeight : Integer;
		 pRows : Integer;	//29 Aug 2011	NDL	Par 28076
		 pColumns : Integer;	//29 Aug 2011	NDL	Par 28076
		 pEnforceMaxCapacity : Boolean;	//29 Aug 2011	NDL	Par 28076
		 pTypeString : String;
		 pMax : Integer;
		 pRel : Boolean;
		 pControllers: CM_LCArray;
		 pTerm : CM_Terminal;
		 _autoRestrictionEnabled,
		 pAutoPlanEnabled,
		 _stockControlled, 
		 _isOverlapped : Boolean;
		 _hideFromOverView : Boolean;
		 _allInterchangeAreas	:CM_InterchangeAreaArray;	// par 24292
		_defaultInterchangeArea: CM_InterchangeArea;
		_doCreateLogicalDelTrx : Boolean	//03 Aug 2017	NDL	TFS 5679
		) updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26/05/2010		cnwcs5	par 24292 - change _allInterchangeAreas parameter from set to array
begin
	self.raiseExceptionIfNotTransient(method);
	setProxyTerminalArea(pID, pComment, pType, pRel, pTerm, _autoRestrictionEnabled, _stockControlled, _hideFromOverView, _allInterchangeAreas,_defaultInterchangeArea);
	
	//29 Aug 2011	NDL	Par 28076
	self.rows := pRows;
	self.columns := pColumns;
	self.enforceMaxCapacity := pEnforceMaxCapacity;
	
	self.height := pHeight;
	self.maxCapacity := pMax;
    self.autoPlanEnabled := pAutoPlanEnabled;
    self.setIsOverlapped(_isOverlapped);
   // FD for 1446 : AutoplanEnabled fields only make sense to road ,rail ,crane transfer area, 
   // even though it is also set for other block stack area.   
   
   self.setDoCreateLogicalDelTrx( _doCreateLogicalDelTrx );	//03 Aug 2017	NDL	TFS 5679
	
end;</source>
        <Parameter name="pID" type="String"/>
        <Parameter name="pComment" type="String"/>
        <Parameter name="pType" type="Integer"/>
        <Parameter name="pHeight" type="Integer"/>
        <Parameter name="pRows" type="Integer"/>
        <Parameter name="pColumns" type="Integer"/>
        <Parameter name="pEnforceMaxCapacity" type="Boolean"/>
        <Parameter name="pTypeString" type="String"/>
        <Parameter name="pMax" type="Integer"/>
        <Parameter name="pRel" type="Boolean"/>
        <Parameter name="pControllers" type="CM_LCArray"/>
        <Parameter name="pTerm" type="CM_Terminal"/>
        <Parameter name="_autoRestrictionEnabled" type="Boolean"/>
        <Parameter name="pAutoPlanEnabled" type="Boolean"/>
        <Parameter name="_stockControlled" type="Boolean"/>
        <Parameter name="_isOverlapped" type="Boolean"/>
        <Parameter name="_hideFromOverView" type="Boolean"/>
        <Parameter name="_allInterchangeAreas" type="CM_InterchangeAreaArray"/>
        <Parameter name="_defaultInterchangeArea" type="CM_InterchangeArea"/>
        <Parameter name="_doCreateLogicalDelTrx" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="shiftTI" id="ff2cfcfe-7c04-493a-a7f9-3f81311f0c44">
        <updating/>
        <source>shiftTI(ti : CM_TrackedItem; mode : Integer; shiftBy : Integer) updating;
//Shifts the passed in box in the block stack's collection.
//Comment from DQ 06/08/2002. This is now almost impossoble tpo impliment, as the array
//is maintained by jade, we'd have to re-write each TI to its location. Leave?
vars
	lc : CM_BlockController;
	tiColl : CM_TIArray;
	oldPos : Integer;
	newPos : Integer;
	numTIs	: Integer;
	aStr : String;
begin

	if  shiftBy = 0 then
		return;
 	endif;
	exclusiveLock(self);
	if ti = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException(ERR_INVALID_TI_ID, null, null);
		return;
	endif;

	lc := self.myLocationsController;

	exclusiveLock(lc);

	sharedLock(ti);
	
	create tiColl transient;
	
	if mode = REAL_MODE then
		lc.allTrackedItems.copy(tiColl);
		aStr := "Actual";
	elseif mode = PLANNING_MODE then
		lc.getAllPlannedTrackedItems(tiColl, true, false);
		aStr := "Planned";
	else
		//Queued mode...
		
		 lc.getAllQueuedTrackedItems(tiColl, true);
		aStr := "Queued";
	endif;

	//----------------------------------------------
	// Calculate the new position in the collection
	//----------------------------------------------
	oldPos := tiColl.indexOf( ti );
	if oldPos = 0 then
		//Hmm, box is not where they say it is!
		app.setContinueCMExceptions(false);
		app.raiseCMException2(ERR_KEY_NOT_FOUND, ti.id, "Block Stacks' " &amp; aStr &amp; " list of Items", null, null);
		return;
	endif;
	newPos := oldPos + shiftBy;

	numTIs :=  tiColl.size;

	if newPos &lt; 1 then        // Make sure we have not exceeded the ends
		newPos := 1;
	elseif newPos &gt; numTIs then
		newPos := numTIs;
	elseif newPos = oldPos then
  		return;
  	endif;

	tiColl.remove( ti );

	tiColl.insert( newPos, ti );
	
epilog
	delete tiColl;
end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <Parameter name="mode" type="Integer"/>
        <Parameter name="shiftBy" type="Integer"/>
    </JadeMethod>
