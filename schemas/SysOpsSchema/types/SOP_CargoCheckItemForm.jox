    <JadeMethod name="doEditCriteria" id="7b48ffba-ad0b-4de1-91af-c7dc4543d6f5">
        <updating/>
        <source>doEditCriteria() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 February 2010	cnwdap1	Initial creation
*/
vars
	
begin
	//epr refactored part of tfs  1882 13/5/16
	if self.myAssistant.showCritieriaMaintForm(self,self.myTerminal,CMUI_YACriteriaMaintForm.CargoCheckCritieria, self.allCriteria) then
		self.isCriteriaModified := true;
		self.displayCriteriaDesc();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="f79ff443-f2d2-4883-8510-a5cc75ab41f4">
        <updating/>
        <source>doSave() : Boolean updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 January 2010	cnwdap1	Initial creation
*/
vars
	name					: String;
	toDoTaskDesc			: CM_ToDoTaskDesc;
	toDoTask				: CM_ToDoTask;
	requiredExtraInfo		: String;
	required				: Boolean;
	rtnValue 				: Boolean;
	result 					: Integer;
	allTransientCriteriaObj	: CMIF_Array;
	
begin
	if self.myProxyCargoCheckItem = null then	
		create self.myProxyCargoCheckItem transient;
	endif;
	
	name := self.txtName.text.trimBlanks;
	if self.cmbToDoTask.listIndex &gt; 0 then
		toDoTaskDesc := self.cmbToDoTask.itemObject[self.cmbToDoTask.listIndex].CM_ToDoTaskDesc;
	endif;
	if self.cmbExtraInfo.listIndex &gt; 0 then
		requiredExtraInfo := self.cmbExtraInfo.itemText[self.cmbExtraInfo.listIndex];
	endif;
	required := self.chkRequired.value;
	if self.myCargoCheckItem &lt;&gt; null then
		toDoTask := self.myCargoCheckItem.myToDoTask;
	endif;
	
	self.myProxyCargoCheckItem.setProxy(name, toDoTaskDesc, toDoTask, requiredExtraInfo, required, self.myCargoCheck);

	while true do
	
		// if transient criteria array has been created during warning/error loop, then purge and recreate - it may be out of date
		if allTransientCriteriaObj &lt;&gt; null then
			allTransientCriteriaObj.purge;
			delete allTransientCriteriaObj;		// need to put this because of transient leaking. cnwvu1 16/09/2010
		endif;
		
		create allTransientCriteriaObj transient;
		self.getCriteriaAllCMIF(allTransientCriteriaObj);
		
		if self.myCargoCheckItem = null then	
			app.myTrxCA.trxCreateCargoCheckItem(self.myProxyCargoCheckItem, allTransientCriteriaObj, self.myCargoCheck, self.myCargoCheckItem, app.myPassport);
			rtnValue	:=	app.myPassport.trxCompletedOK;
			
		else
			app.myTrxUA.trxUpdateCargoCheckItem(self.myProxyCargoCheckItem, allTransientCriteriaObj, app.myPassport);
			rtnValue	:=	app.myPassport.trxCompletedOK;
		endif;
			
		if (not rtnValue) then
			result := app.showErrorWarningDialog('Cargo Check Items', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			//we had a cancelled update - refresh data
//			if self.myCargoCheckItem &lt;&gt; null then
				
//				self.myProxyCargoCheckItem := app.createUpdateProxy(self.myCargoCheckItem).CM_CargoCheckItem;
//			endif;
			return false;
		else
			self.clearErrorWarnings();
		endif;
		break;
	endwhile;
	
	return rtnValue;
epilog
	allTransientCriteriaObj.purge;
	delete allTransientCriteriaObj;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveNext" id="079b3282-37f1-4db7-909d-4067c124ddba">
        <updating/>
        <source>doSaveNext() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 February 2010	cnwdap1	Initial creation
*/
vars
	rtnValue : Boolean;
	
begin
	rtnValue := doSave;
	if rtnValue then
		self.init(self.myCargoCheck, null);
		self.setupForm;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getCriteriaAllCMIF" id="d9b035ef-9ea2-4da8-ae11-2e03b80f0040">
        <updating/>
        <source>getCriteriaAllCMIF(_cmifArray : CMIF_Array input) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 February 2010	cnwdap1	Initial creation
*/
vars
	criteria		: CM_YACargoCheckCriteria;
	cmifCriteria	: CMIF_YACriteriaPriority;
	cmifObject		: CMIF_Object;

begin
	// Create transient maintenance objects for all existing criteria and mark for delete action
	if self.myCargoCheckItem &lt;&gt; null then
		foreach criteria in self.myCargoCheckItem.allCriteria do
			cmifCriteria := criteria.getTransient();
			cmifCriteria.setFlag(false, false, true);
			_cmifArray.add(cmifCriteria);
		endforeach;
	endif;
	
	// Now do all criteria on myself
	foreach cmifObject in self.allCriteria do
		criteria := cmifObject.CMIF_YACriteriaPriority.myProxy.CM_YACargoCheckCriteria;
		
		if self.myCargoCheckItem = null then
		endif;
		
		self.getCriteriaSingleCMIF(_cmifArray, criteria.myYACriteriaType, criteria.myYAData.getDataValue());
	endforeach;
epilog

end;</source>
        <Parameter name="_cmifArray" type="CMIF_Array" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaSingleCMIF" id="202568af-90d2-43b8-a5f3-e2e2937c896f">
        <source>getCriteriaSingleCMIF(_cmifArray : CMIF_Array input; _criteriaType :CM_YACriteriaType; _value : Any);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 February 2010	cnwdap1	Initial creation
*/
vars
	cmifObject		: CMIF_Object;
	cmifCriteria	: CMIF_YACriteriaPriority;
	proxyCriteria	: CM_YACargoCheckCriteria;
	itemCode		: String;

begin
	// Check if a maintenance object already exists - if it does it will have a Delete action
	// Convert it to a Change action
	if self.myCargoCheckItem &lt;&gt; null then
		foreach cmifObject in _cmifArray do
			cmifCriteria 	:= cmifObject.CMIF_YACriteriaPriority;
			proxyCriteria	:= cmifCriteria.myProxy.CM_YACargoCheckCriteria;
			if proxyCriteria.myYACriteriaType = _criteriaType and cmifCriteria.isDeleted then
				// change value of existing criteria
				proxyCriteria.setProxy(proxyCriteria.myYACriteriaType, _value, proxyCriteria.code);
				cmifCriteria.setFlag(false, true, false);
				return;
			endif;
		endforeach;
	endif;
	
	// Create an Add action Criteria request
	create proxyCriteria transient;
	itemCode := _criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	proxyCriteria.setProxy(_criteriaType, _value, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	cmifCriteria.setFlag(true, false, false);
	_cmifArray.add(cmifCriteria);
	
epilog

end;</source>
        <Parameter name="_cmifArray" type="CMIF_Array" usage="input"/>
        <Parameter name="_criteriaType" type="CM_YACriteriaType"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="init" id="b440f535-6c65-46f3-8a91-773770ed7ca2">
        <updating/>
        <source>init(	_cargoCheck : CM_CargoCheck;
		_cargoCheckItem : CM_CargoCheckItem	) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28/01/2010	cnwdap1	Initial creation CCMS 1071
*/
vars

begin
	self.myCargoCheck 		:= _cargoCheck;
	self.myCargoCheckItem	:= _cargoCheckItem;
	
	if _cargoCheckItem &lt;&gt; null then
		self.btnNext.visible := false;
  		self.myProxyCargoCheckItem := app.createUpdateProxy(_cargoCheckItem).CM_CargoCheckItem;
	else
		if self.myProxyCargoCheckItem &lt;&gt; null then
			delete self.myProxyCargoCheckItem;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_cargoCheck" type="CM_CargoCheck"/>
        <Parameter name="_cargoCheckItem" type="CM_CargoCheckItem"/>
    </JadeMethod>
    <JadeMethod name="isTruckContext" id="fc63948a-12a3-4b41-908f-9c6160287251">
        <source>isTruckContext() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
13 September 2023		jlizm1	Initial creation TFS 59985 Truck Seals design changes

*/

vars

begin

	if self.context = TRUCK_CHECK_LOAD_COMPLETE then
		return true;
	endif;
	
	return false;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isVoyageOpsLiveContext" id="3befeacf-a81e-4fc0-90f9-9b678b61bd03">
        <source>isVoyageOpsLiveContext() : Boolean;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 24 Jan 2024
TFS#		: 62140
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	if  self.context.isOneOf(CARGO_CHECK_CONTEXT_VOYOP_LOAD, CARGO_CHECK_CONTEXT_VOYOP_DISC) then
		return true;
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isWagonContext" id="c1d0f0c8-30ad-450c-9a3f-d1e4b29d629e">
        <source>isWagonContext():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
11 March 2015		cnwndl1	Initial creation	Par 35828
04 November 2022	jlizm1	TFS 54118 Assigning Releases to Wagons

*/

vars

begin

	if self.context.isOneOf( WAGON_CHECK_CONTEXT_PLACE_IN, WAGON_CHECK_CONTEXT_PLACE_OUT, WAGON_CHECK_LOAD_COMPLETE ) then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="abf92743-fc49-425d-95d2-2b19c452d57b">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28/01/2010	cnwdap1	Initial creation
15/07/2014	cnwdap1	PAR #34568 CCMS SFW 1389 New Alternative Id Cargo Check
21/04/2015	cnwdap1	PAR #36094 CCMS SFW 1413 TFS 313 Cold Store Enhancements
21/07/2022	jlika1	TFS 53741 EUP  - Max Wagon Payload
13/09/2023	jlizm1	TFS 59985 Truck Seals design changes
24/01/2023	jlika1	TFS 62138 62140 CUX | Add Location Check - Check Extra info
08 Aug 2025	navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes
16 Sep 2025 navhl20 Defect MTN-36050: The page goes blank after clicking on the Photo Checks on the Truck Unloader app
08 Oct 2025 navhl20 Story MTN-36217: TPT | Enable Uploading of Photos into MTN Production
*/
vars
	cargoCheckItem 			: CM_CargoCheckItem;
	reqdExtraInfo			: String;
	idx						: Integer;
	toDoTaskDesc			: CM_ToDoTaskDesc;
	crit, proxyCriteria		: CM_YACargoCheckCriteria;
	cmifCriteria			: CMIF_YACriteriaPriority;
	itemCode				: String;
	value					: Any;	
begin
	self.showToolbar := true;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	inheritMethod();
	
	self.context := self.myCargoCheck.context;	//11 Mar 2015	NDL	Par 35828
	
	if self.myCargoCheckItem &lt;&gt; null then
		toDoTaskDesc			:= self.myCargoCheckItem.myToDoTaskDesc;
		reqdExtraInfo 			:= self.myCargoCheckItem.requiredExtraInfo;
		self.txtName.text 		:= self.myCargoCheckItem.name;
		self.chkRequired.value 	:= self.myCargoCheckItem.required;
		
		foreach crit in self.myCargoCheckItem.allCriteria do
			create proxyCriteria transient;
			itemCode := crit.myYACriteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
			value := crit.myYAData.getDataValue();
			proxyCriteria.setProxy(crit.myYACriteriaType, value, itemCode);
			cmifCriteria := proxyCriteria.getTransient();
			self.allCriteria.add(cmifCriteria);
		endforeach;
		self.displayCriteriaDesc();
		
		if reqdExtraInfo = EXTRA_INFO_LOCATION_CHECK then
			self.chkRequired.enabled := false;
		else 
			self.chkRequired.enabled := true;
		endif;
			
	else
		toDoTaskDesc			:= null;
		self.txtName.text 		:= null;
		self.chkRequired.value	:= null;
	endif;
	
	if self.isWagonContext or self.isTruckContext then
		self.lblToDoTask.visible := false;
		self.cmbToDoTask.visible := false;
		self.lblCrit.visible := false;
		self.lblCriteria.visible := false;
		self.btnCriteriaEdit.visible := false;
	else
		self.myAssistant.comboBoxToDoTasks(cmbToDoTask, toDoTaskDesc);
	endif;
	
	self.cmbExtraInfo.clear;
	self.cmbExtraInfo.addItem("");
	if self.isWagonContext then
		self.cmbExtraInfo.addItem(EXTRA_INFO_DAMAGE);
		self.cmbExtraInfo.addItem(EXTRA_INFO_SEALS);
		self.cmbExtraInfo.addItem(EXTRA_INFO_WAGON_WEIGHTS);
	elseif self.isTruckContext then
		self.cmbExtraInfo.addItem(EXTRA_INFO_SEALS);
		self.cmbExtraInfo.addItem(EXTRA_INFO_PHOTO);				//08.08.2025 navhl20 #35650
	else
		self.cmbExtraInfo.addItem(EXTRA_INFO_ALTERNATIVE_ID);		// PAR #34568
		self.cmbExtraInfo.addItem(EXTRA_INFO_DAMAGE);
		self.cmbExtraInfo.addItem(EXTRA_INFO_QUICK_DAMAGE); //jlier1 TFS 58968 12/9/23
		self.cmbExtraInfo.addItem(EXTRA_INFO_DIMENSION);
		self.cmbExtraInfo.addItem(EXTRA_INFO_HAZARD_SYMBOLS);
		self.cmbExtraInfo.addItem(EXTRA_INFO_IS_OD);
		self.cmbExtraInfo.addItem(EXTRA_INFO_PHOTO);
		self.cmbExtraInfo.addItem(EXTRA_INFO_SEALS);
		self.cmbExtraInfo.addItem(EXTRA_INFO_SPECIAL_LIFT);	//31 May 2010	NDL	Par 23903
		self.cmbExtraInfo.addItem(EXTRA_INFO_WEIGHT);
		self.cmbExtraInfo.addItem(EXTRA_INFO_TEMPERATURE);			// PAR #36094
	endif;
	
	if isVoyageOpsLiveContext then
		self.cmbExtraInfo.addItem(EXTRA_INFO_LOCATION_CHECK);
	endif;
	
	if reqdExtraInfo &lt;&gt; null then
		idx := self.cmbExtraInfo.findStringExact(0, reqdExtraInfo);
		self.cmbExtraInfo.listIndex := idx;
	else
		self.cmbExtraInfo.listIndex := -1;
	endif;
	cmbExtraInfo.setFocus();
	
	self.height := 350;  // ### TFS 52535 08DEC2021 NAVAB1 was 250;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="e755532c-0faa-45cd-8aea-4c2636d6e9cc">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 26 March 2015.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0020380, locale);
	btnCriteriaEdit.translateBubbleHelp(Xlat_0020381, locale);
	btnNext.translateBubbleHelp(Xlat_0020382, locale);
	btnNext.translateCaption(Xlat_0020383, locale);
	lblCrit.translateCaption(Xlat_0020384, locale);
	lblName.translateCaption(Xlat_0020385, locale);
	lblReqdExtraInfo.translateCaption(Xlat_0020386, locale);
	lblRequired.translateCaption(Xlat_0020387, locale);
	lblToDoTask.translateCaption(Xlat_0020388, locale);
end;</source>
    </JadeMethod>
