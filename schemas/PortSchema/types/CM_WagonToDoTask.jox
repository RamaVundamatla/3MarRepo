    <JadeMethod name="getToDoObject" id="f5d15ffc-2809-441c-9e26-7f912a2f6442">
        <source>getToDoObject(): CM_Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2024 navhl20 Bug 64261: EUP | VAS - Not able to complete TODO jobs

*/

vars

begin
	return self.myWagonToDo;
epilog

end;</source>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="myTerminal" id="f2499a12-482a-445d-8167-11ade2ace036">
        <methodInvocation>mapping</methodInvocation>
        <source>myTerminal(set: Boolean; _value: CM_Terminal io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date  		Who	   Reason
06 Jun 2023 navma1 Bug 58265: MTN - Complete ToDo security role setting is missing for all the new event todo tasks.
*/

vars

begin
	if set then
		return;
	endif;
	
	if self.myWagonToDo &lt;&gt; null then
		_value := self.myWagonToDo.getMyTerminal();
	elseif self.myWagonComplete &lt;&gt; null then 
		_value := myWagonComplete.getMyTerminal();  
	else
		_value := null;
	endif;
	
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_Terminal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="194414c9-2b30-4b76-b490-8d898ed4cf63">
        <updating/>
        <source>setForCreate(_status : Integer; _toDoTaskDesc : CM_ToDoTaskDesc; _toDoRemarks : String; _passport : CM_Passport input; _wagon : CM_Wagon; _wod : CM_WorkOrderToDoDtl) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 November 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen

*/

vars
	transType	: Integer;
	event		: CMEVT_WagonTransaction;
begin

	self.setForCreateToDoTask(_status, _toDoTaskDesc, _toDoRemarks, _passport.userCode);
	self.myWagonToDo := _wagon;

	transType :=  self.getToDoTaskCreateEventInt;
	
	if transType &lt;&gt; null then
		event := self.myWagonToDo.createTransaction(app.actualTime, transType, null, null, null, false, null,self, _wod ); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
	endif;
end;</source>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
        <Parameter name="_toDoRemarks" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_wagon" type="CM_Wagon"/>
        <Parameter name="_wod" type="CM_WorkOrderToDoDtl"/>
    </JadeMethod>
    <JadeMethod name="updateWagonComplete" id="90e3c8e7-47bc-4e2b-96c1-2224cb830fd1">
        <updating/>
        <source>updateWagonComplete()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
30 November 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen

*/

vars

begin
	self.myWagonComplete := self.myWagonToDo;
	self.myWagonToDo := null;
epilog

end;</source>
    </JadeMethod>
</Class>
