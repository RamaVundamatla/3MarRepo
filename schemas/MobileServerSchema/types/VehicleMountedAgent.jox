    <JadeMethod name="getNextOverstowTI" id="61365de5-369e-46f0-b7bd-d015eb677107">
        <updating/>
        <source>getNextOverstowTI(_containerId, _locationId : String io; _errorMsgs : DTO_HandHeldGateErrorDict input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
15 Sep 2006	cnwer1	Initial creation - PAR#xxxx
02 Jul 2010 cnwer1	PAR 24469
*/
vars
	ti : CM_TrackedItem;
	task : CM_RTQueueTask;
	allOSTIs : CM_TIArray; 
	sideAccess : Integer;
begin
	task:=self.getCurrentTask;
	ti:=getCurrentTaskTI;
	create allOSTIs transient;
	
	task.getAllOverstowedTIs(allOSTIs,sideAccess,self.myMachine);
	
	if allOSTIs.size = 0 then		
		return;
	endif;
	
	
	overstowTI:=allOSTIs.first;
	if overstowTI = null then
		return;
	endif;
	_containerId:=overstowTI.id;
	_locationId:=overstowTI.myPrimaryActualLocation.getFullIdTI(overstowTI);
	
epilog
	delete allOSTIs;
end;</source>
        <Parameter name="_containerId" type="String" usage="io"/>
        <Parameter name="_locationId" type="String" usage="io"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getNumberQueueEntries" id="ea5c6d15-4924-4749-8c8a-3e4ac58b51b8">
        <updating/>
        <source>getNumberQueueEntries(_queue : CM_RadioTelemetryQueue input) : Integer updating , protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
07 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

	rtQueueEntry : CM_RTQueueEntry;
	allEntries : CM_RTQueueEntryArray;
	count : Integer;
begin
// just incase all entries changes copy to a collection
	create allEntries transient;
	 _queue.allEntries.copy(allEntries);
	foreach rtQueueEntry in allEntries discreteLock do
		if not self.queryDisplayRTEntry(rtQueueEntry) then
			continue;
		endif;
		count:=count+1;
	endforeach;

	return count;
epilog
	delete allEntries;
end;</source>
        <access>protected</access>
        <Parameter name="_queue" type="CM_RadioTelemetryQueue" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
