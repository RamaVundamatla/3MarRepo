    <JadeMethod name="displayJobRequest" id="95669760-c9ff-4010-8cef-07870224c574">
        <source>displayJobRequest();
//--------------------------------------------------
// Created:	05 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpTime : Time;
	tmpUser : CM_User;
	tmpEmail : CM_EventRequestEmail;
	tmpNotifyReq : CM_EventRequestNotification;
	tmpStopsReq : CM_EventRequestStops;
	tmpCargoType : CM_CargoBOLType;
begin

	tmpUser := app.getMyUser();
	
/*	if self.myEventRequest = null then
		//self.txtRecipients.text := tmpUser.getEmailAddress();	
		self.cmbOrganisation.setObject(tmpUser.myOrganisation);		
		if self.eventRequestType = EventRequestTypeNotifyStr then
			tmpEmail := tmpUser.allEventRequestEmail[EventRequestTypeNotify];
		else
			tmpEmail := tmpUser.allEventRequestEmail[EventRequestTypeStops];
		endif;
		
		if tmpEmail &lt;&gt; null then
			foreach tmpTime in tmpEmail.allRunTimes do
				self.lstTime.addItem(tmpTime.currentLocaleFormatJMT);
			endforeach;		
		endif;
		return;
	endif;
	
	if self.cmbCargoType.visible then
		tmpCargoType := self.myEventRequest.getMyCargoType();
		if tmpCargoType &lt;&gt; null then
			self.cmbCargoType.listIndex := self.cmbCargoType.findObject(tmpCargoType);
		endif;
	endif;
	
	if CM_EventRequestNotification.hasInstance(self.myEventRequest) then
		tmpNotifyReq := self.myEventRequest.CM_EventRequestNotification;
		self.lstTableRequest.setSelectedString(tmpNotifyReq.getActivityDisplayString());
		self.txtCargoId.text := tmpNotifyReq.cargoId;
			
	elseif CM_EventRequestStops.hasInstance(self.myEventRequest) then
		tmpStopsReq := self.myEventRequest.CM_EventRequestStops;
		self.lstTableRequest.addSelectedObject(tmpStopsReq.myStopsTable);		
		self.txtCargoId.text := tmpStopsReq.cargoId;
		self.optClear.value := tmpStopsReq.isClear;
	endif;

	if self.myEventRequest.myOrganisation &lt;&gt; null then
		self.cmbOrganisation.setObject(self.myEventRequest.myOrganisation);
	endif;

	self.txtRecipients.text := self.myEventRequest.getEmailAddresses(null);
	self.ckbNotify.value := self.txtRecipients.text &lt;&gt; null;
	self.ckbCleanup.value := self.myEventRequest.doNotAutoCleanup;
	
	self.txtRemarks.text := self.myEventRequest.remarks;
	self.txtReference.text := self.myEventRequest.reference;
	
	tmpEmail := self.myEventRequest.myEventRequestEmail;
			
	if tmpEmail &lt;&gt; null then
		foreach tmpTime in tmpEmail.allRunTimes do
			self.lstTime.addItem(tmpTime.currentLocaleFormatJMT);
		endforeach;		
	endif;
	*/

end;</source>
    </JadeMethod>
