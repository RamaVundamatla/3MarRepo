    <JadeMethod name="loadForm" id="751f8b21-5e04-4c31-a003-7a7ce8be26fb">
        <updating/>
        <source>loadForm() updating;

vars
	theForm	: Form;

begin
	theForm := getForm(name, false);	// false to ignore first one
	
	if theForm &lt;&gt; null then	// if there's another form already running, go to it
		theForm.setFocus();
		unloadForm();
	endif;

	if aMyForm = null then
		unloadForm();
	endif;

	aMyLesson 		:= null;
	aIsAbortLesson := false;


	txtText.backColor 		:= self.BACKGROUND_COLOR;
	txtTextAction.backColor := self.BACKGROUND_COLOR;
	lstLessons.backColor 	:= self.BACKGROUND_COLOR;
	lblCaption.zOrder(1);

 	aTeachDrawWidth	:= 3;
 	aTeachDrawColor	:= LightGreen;

	self.getLessonByFormName();

	chkPin.value := false;
end;</source>
    </JadeMethod>
