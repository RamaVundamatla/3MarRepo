    <JadeMethod name="getCargo" id="88f55d57-79c3-40ec-87a2-33aed767f76d">
        <source>getCargo(	_selectedCargo : CM_TISet input;
			_cargoType : CM_CargoType
			) : Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 July 2009	cnwmd1	Initial creation

*/

vars
	cargoStr, invalidCargoStr : String;
	hsarr : HugeStringArray;
	cargo : CM_TrackedItem;
	cargoTypeId : Integer;
begin
	if _cargoType = null then
		app.raiseCMException(Please_select_cargo_type, self.cmbCargoType.name, null);
		return false;
	endif;
	
	cargoTypeId := _cargoType.id;
	
	create hsarr transient;
	cargoStr := self.txtSourceList.text;
	cargoStr.parseCSV(hsarr);
		
	foreach cargoStr in hsarr do
		cargo :=self.myTerminal.allOnsiteTIsByCargoTypeId[cargoTypeId, cargoStr].CM_TrackedItem;
		if cargo &lt;&gt; null then
			_selectedCargo.add(cargo);
		else
			if invalidCargoStr &lt;&gt; null then
				invalidCargoStr := invalidCargoStr &amp; "," &amp; cargoStr;
			else
				invalidCargoStr := cargoStr;
			endif;
		endif;
	endforeach;
	
	if invalidCargoStr &lt;&gt; null then
		if self.myCurrentWorkOrder.approvedByDT.isValid() then
			app.raiseCMException1(Follow_cargo_items_could_found, invalidCargoStr, self.txtSourceList.name, null );
			return false;
		else
			app.raiseCMWarning1(Follow_cargo_items_could_found, invalidCargoStr, self.txtSourceList.name, null, null);
		endif;
	endif;
	return true;
epilog
	delete hsarr;
end;</source>
        <access>protected</access>
        <Parameter name="_selectedCargo" type="CM_TISet" usage="input"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getFormCaption" id="7023e887-4e41-4ba1-80ea-16e13ff030a3">
        <source>getFormCaption() : String protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04/08/2009	cnwmd1	Initial creation
22/05/2018	jlgdap1	TFS 38560 Voyage Work Orders
*/

vars

begin
	if self.workOrderMode = WorkOrderMode_Cargo then				// TFS 38560
		if self.mode = self.Mode_Add then
			return app.getErrorString(New_Work_Order);
		elseif self.mode = self.Mode_Update then
			return app.getErrorString(Edit_work_order);
		endif;
	elseif self.workOrderMode = WorkOrderMode_Voyage then			// TFS 38560
		if self.mode = self.Mode_Add then							// TFS 38560
			return app.getErrorString(New_Voyage_Work_Order);		// TFS 38560
		elseif self.mode = self.Mode_Update then					// TFS 38560
			return app.getErrorString(Edit_Voyage_Work_Order);		// TFS 38560
		endif;														// TFS 38560
	endif;															// TFS 38560
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSourceDisplay" id="6de5424d-39b0-477d-a9f0-89e8adef60f0">
        <source>getSourceDisplay(_workOrder : CM_WorkOrder) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2009	cnwmd1	Initial creation

*/

vars
	table : Table;
begin
	self.cmbCargoType.setObject(_workOrder.CM_WorkOrderTI.mySource.getMyCargoType());
	self.txtSourceList.text := _workOrder.getSourceString();
	
	self.tbCargo.rows :=0;
	table := self.tbCargo ;
	_workOrder.populateSourceDisplayTable( table );

	
epilog

end;</source>
