    <JadeMethod name="tblDisplayRow" id="c38190ad-e08b-43e8-a653-089b9aa185b3">
        <source>tblDisplayRow();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2023 navmv20 CR 60503 Task 60505: UI - Contract Rate Entry UI Changes

*/

vars
	tbl					: CM_EntryTable;
	idx					: Integer;
	str 				: String;
	rateEntry			 : CM_InvoiceContractRateEntry;
	maxLength,numDecimalPlaces : Integer;
	increment : Decimal[3,2];
begin
	
	tbl := self.tblData;
	tbl.rows := tbl.fixedRows;
	
	self.getNumberFormat(maxLength,numDecimalPlaces, increment);
	
	if self.myContractRateEntryDates &lt;&gt; null then
		foreach rateEntry in self.myContractRateEntryDates.allInvoiceContractRateEntries do
			str := null;
			str := rateEntry.fromAmount.asStringJMTWithPrecision(numDecimalPlaces, false) &amp; Tab;
			str := str &amp; rateEntry.toAmount.asStringJMTWithPrecision(numDecimalPlaces, false) &amp; Tab;
			str := str &amp; rateEntry.costPerUnit.asStringJMTWithPrecision(4, false);
			idx := tbl.addItem(str);
			tbl.accessRow(idx).itemObject := rateEntry;
		endforeach;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="849eaf7e-5516-443c-aa00-2b70837fda0c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 14 February 2024 12:14:10.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026513, locale);
	btnAudit.translateCaption(Xlat_0026557, locale);
	btnClose.translateCaption(Xlat_0026514, locale);
	btnNew.translateCaption(Xlat_0026515, locale);
	btnRemove.translateCaption(Xlat_0026516, locale);
	btnSave.translateCaption(Xlat_0026517, locale);
	lblCalcTypeForRange.translateCaption(Xlat_0026692, locale);
	lblEnd.translateCaption(Xlat_0026518, locale);
	lblStart.translateCaption(Xlat_0026519, locale);
	mnuContextMenu.translateCaption(Xlat_0026520, locale);
	mnuInspectObject.translateCaption(Xlat_0026521, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="0a39891a-91b6-4d24-b446-5f3fd4af92b7">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*
Purpose:			

Date		Who		Reason
28 November 2023	navab1	BUG 61268
14 Oct 2024 navlc30 JIRA 19508 UI - Contract Enquiry extra tables for results
*/

vars

begin
	/*if self.myParentForm &lt;&gt; null then														//14.10.2024 navlc30 #19508
		self.myParentForm.INV_ContractRateMaint.myRateEntryForm := null;
	endif;*/

	if self.myParentForm &lt;&gt; null then
		if self.myParentForm.isKindOf(INV_ContractRateMaint) then							//14.10.2024 navlc30 #19508
			self.myParentForm.INV_ContractRateMaint.myRateEntryForm := null;
		elseif  self.myParentForm.isKindOf(INV_ContractEnquiry) then
			self.myParentForm.INV_ContractEnquiry.myRateEntriesMaintForm := null;
		endif;
	endif;	
	
	
	inheritMethod();
epilog

end;</source>
    </JadeMethod>
</GUIClass>
