    <JadeMethod name="setProxy" id="7fb3a328-3f22-4efe-99e2-a953947e34ea">
        <updating/>
        <source>setProxy(address: CM_Address) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
18 July 2023	navcs2	ChangeRequest 57650: MTN - Refactor getCustomer(s) REST Webservice
1/08/2023		navcs2	Bug 59583: MTN - isoCountryCode not populating in the addresses segment
*/

vars
	country	: CM_Country;    //1/08/2023 navcs2	Bug 59583
begin
	country := CM_Country@lookupCountryByCode(address.countryCode);  	//1/08/2023 navcs2	Bug 59583
	
	if country &lt;&gt; null and country.isoCode3 &lt;&gt; null then 				//1/08/2023 navcs2	Bug 59583
		self.isoCountryCode := country.isoCode3;						//1/08/2023 navcs2	Bug 59583
	else																//1/08/2023 navcs2	Bug 59583
		self.isoCountryCode := address.countryCode;						//1/08/2023 navcs2	Bug 59583
	endif;																//1/08/2023 navcs2	Bug 59583
	
	self.city := address.city;
	self.description := address.description;
	self.email := address.email;
	self.id := address.code;
	self.line1 := address.addr1;
	self.line2 := address.addr2;
	self.line3 := address.addr3;
	self.postCode := address.postCode;
	self.region := address.region;
	if address.isDefault then						
		self.type := WS_RestAddressObject.BILLING;	
	elseif address.isAlternative then
		self.type := WS_RestAddressObject.ALTERNATE;
	else
		self.type := WS_RestAddressObject.OTHER;	
	endif;
epilog

end;</source>
        <Parameter name="address" type="CM_Address"/>
    </JadeMethod>
</Class>
