    <JadeMethod name="windowAccessExceptionHandler" id="98f488c5-53ee-4bbb-8016-07e1fa4f3784">
        <source>windowAccessExceptionHandler(ex : Exception) : Integer;

vars

begin
	if ex.errorCode = ERR_KEY_NOT_FOUND then
		return Ex_Resume_Next;
	else
		return Ex_Pass_Back;
	endif;
end;</source>
        <Parameter name="ex" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
