	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " all Damage Status converted", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" all Damage Status converted") ;
	endif;
	
	self.addScriptRun(method.name);
epilog

end;</source>
