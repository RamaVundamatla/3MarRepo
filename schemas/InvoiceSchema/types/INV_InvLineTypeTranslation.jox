    <JadeMethod name="addObjectsToTable" id="32a5ce43-2ff8-41bc-8cdc-e12e67358c4c">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
/*

Purpose:			Adds our objects to the table

Parameters:			_numItems	Integer	The number of items added to the table. Is an io so we can use this outside our method

Return Value:		NONE

Date			Who		Reason
31 August 2022	navpw1	Initial creation TFS: 54564 (54379)

*/

vars
	invoiceLineNarration 	: CM_InvoiceLineNarration;
	breakOut				: Boolean;
	
begin
	self.setMyDataClass();

	self.setCaption("Invoice Line Translations " &amp; self.myInvoiceLineDesc.narration);
	
	foreach invoiceLineNarration in myInvoiceLineDesc.allInvoiceLineNarrations do
		self.addObjectToTable(invoiceLineNarration, _numItems, breakOut);
		if breakOut then
			break;
		endif;
	endforeach;
	
end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="cmbLocale_lostFocus" id="93f8ea6e-0e98-4725-9676-836359d3c656">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbLocale_lostFocus(combobox: ComboBox input) updating;
/*

Purpose:			Sets the table value from the combo box value when the focus has been lost

Parameters:			combobox	ComboBox	The combo box the focus was lost from

Return Value:		NONE

Date			Who		Reason
31 August 2022	navpw1	Initial creation TFS: 54564 (54379)

*/

begin
	self.tblEntDetail.setValueByControlName(combobox.name,combobox.text);

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="5f0bc46d-53d1-467a-a286-2267f01eedff">
        <updating/>
        <source>create() updating;
/*

Purpose:			Creates the form by setting default permissions for the form

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
31 August 2022	navpw1	Initial creation TFS: 54564 (54379)

*/

begin
	self.permissionView  	:= PmAdmInvLineDescriView;
	self.permissionMaint 	:= PmAdmInvLineDescrMaint;
	
	self.helpFileName 		:= HelpFile_Invoicing;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbLocalesBuild" id="17173c62-4934-4388-89e5-b5e78e852cd6">
        <source>doCmbLocalesBuild();
/*

Purpose:			Loads Locales into the combo box

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
31 August 2022	navpw1	Initial creation TFS: 54564 (54379)

*/

vars
	currentLocale : CM_Locale;
	
begin
	self.cmbLocale.clear();
	
	foreach currentLocale in app.myRoot.allLocales do
		self.cmbLocale.addItemObject(currentLocale.localeDescription, currentLocale);
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="3cf4da38-041a-457b-bdc6-54c0baee6482">
        <updating/>
        <source>doDelete(): Boolean updating;
/*

Purpose:			Deletes a Invoice Line Type Translation

Parameters:			NONE

Return Value:		Boolean	Representing whether the object was deleted or not

Date				Who		Reason
01 September 2022	navpw1	Initial creation TFS: 54564 (54379)

*/

vars
	theReturn : Integer;
	
begin 
	while true do
 	 	app.myTrxDA.trxDeleteInvoiceLineNarr(self.myCurrentObject.CM_InvoiceLineNarration, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			return true;
		else
			theReturn := app.showErrorWarningDialog("Invoice Line Translations", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
	endwhile;
	
	return false;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="3ffe931d-1674-425e-9e55-4831cf071e79">
        <updating/>
        <source>doSave(): Boolean updating;
/*

Purpose:			Saves a Invoice Line Type Translation

Parameters:			NONE

Return Value:		Boolean	Representing whether the object was saved or not

Date			Who		Reason
31 August 2022	navpw1	Initial creation TFS: 54564 (54379)

*/

vars
	pxyInvoiceLineNarration 	: CM_InvoiceLineNarration;
	table						: CM_EntryTable;
	theReturn 					: Integer;
	
begin
	table := self.tblEntDetail;
	
	if self.mode = Mode_Add then
		create pxyInvoiceLineNarration transient;
		pxyInvoiceLineNarration.setMyInvoiceLineType(self.myInvoiceLineDesc);
		
	elseif self.mode = Mode_Update then
		pxyInvoiceLineNarration := self.myProxyObject.CM_InvoiceLineNarration;
		
	else
		return false;
		
	endif;
	
	pxyInvoiceLineNarration.setProxy(self.cmbLocale.listObject.CM_Locale,
								table.getValueByName(ETRow_Narration).String,
								table.getValueByName(ETRow_UnitNarration).String);
	
	while true do
	 	if self.mode = Mode_Add then
			app.myTrxCA.trxCreateInvoiceLineNarr(pxyInvoiceLineNarration, self.myCurrentObject, app.myPassport);
			
		elseif self.mode = Mode_Update then
			app.myTrxUA.trxUpdateInvoiceLineNarr(pxyInvoiceLineNarration, app.myPassport);
			
		endif;
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			theReturn := app.showErrorWarningDialog("Invoice Type", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		break;
	endwhile;
	
	return true;
	
epilog
	if self.mode = Mode_Add then
		delete pxyInvoiceLineNarration;
	endif;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="41f73067-a08a-4231-beba-14517b5f9278">
