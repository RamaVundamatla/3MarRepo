    <JadeMethod name="cmbVoyageDetails_click" id="8afa55e8-537e-459f-b4e5-b93d0c6ed0ae">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbVoyageDetails_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
28 July 2022	navcs2	Bug 54316: MTN - Voyage Work Order - Unable to enter the text in the External Code field
02 Aug 2022 	navtnr20 Bug 54347: MTN - Voyage Work Orders - When selecting any task the voyage gets disappeared
03/08/2022		navcs2	Bug 54309: MTN - Voyage Work Orders - Unable to add a task for the Voyage Work Orders

*/

vars
	voyage 			: CM_Voyage;
	voyExtRef		: String;
	str 			: String;
begin
	if self.cmbVoyageDetails.listObject &lt;&gt; null then
		voyage :=  self.cmbVoyageDetails.listObject.CM_Voyage;
		self.myVoyage := voyage; //navtnr20 2-Aug-2022 54347 
		self.txtVoyageExtCode.text := voyage.voyageCodeExternal;
	endif;
	//start	04-08-2022 navtnr20  54347
	if voyage = null then
		self.handleActions();
	endif;
	if voyage &lt;&gt; null and voyage.myHMSVoyageData = null then
		self.btnTaskAdd.enabled := false;
		app.raiseCMException(Selected_voyage_movements,null, null);	
		return;
	endif;		
	//end	04-08-2022 navtnr20  54347

	// 03/08/2022 navcs2	Bug 54309
	if self.workOrderMode = self.MODE_ADD then
		self.canMaintainTasks(WO_STATUS_USERENTRY);
	else
		self.canMaintainTasks(myPxyWorkOrder.taskStatus);
	endif;
	
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
