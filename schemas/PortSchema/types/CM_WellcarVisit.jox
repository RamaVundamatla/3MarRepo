    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="wagonVisit"/>
    <ExplicitInverseRef name="allWagonWellsArray" id="eba5c192-161e-46b9-908e-106391ae9247">
        <kind>parent</kind>
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
