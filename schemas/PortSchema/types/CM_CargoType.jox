    <JadeMethod name="delete" id="5afa2c43-0db2-4e9e-8d4e-9e39b7c76049">
        <updating/>
        <source>delete() updating;
// -------------------------------------------
// Created 15 November 2005 by cnwdvb1
// -------------------------------------------
vars

	//15 Jul 2016	NDL	TFS 2329
	iter : Iterator;
	cmqfTT : CMQF_TerminalTIs;
	cmqfVS : CMQF_VoyageSummary;

begin

	//04 Apr 2019	NDL	TFS 44194
	if app.myAlternateDict &lt;&gt; null then
		app.myAlternateDict.setCargoTypeDictNeedsRefresh;
	endif;
	

	iter := CMQF_TerminalTIs.instances.createIterator;
	while iter.next(cmqfTT) do
		if cmqfTT.allCargoTypes.includes(self) then
			cmqfTT.allCargoTypes.remove(self);
		endif;
	endwhile; 
	delete iter;
	
	iter := CMQF_VoyageSummary.instances.createIterator;
	while iter.next(cmqfVS) do
		if cmqfVS.allCargoTypes.includes(self) then
			cmqfVS.allCargoTypes.remove(self);
		endif;
	endwhile; 
	delete iter;

	// Clean up proxies and persitents.
	if global.isValidObject(self.myDrawingAttribute) then
		delete self.myDrawingAttribute;
	endif;
	if global.isValidObject(self.mySystemProductType) then
		delete self.mySystemProductType;
	endif;

epilog
	delete iter;
end;</source>
    </JadeMethod>
