    <JadeMethod name="auditId" id="241fd309-8373-4949-a9d5-a5ed66de775e">
        <source>auditId(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2017	cnwma1	Initial creation

*/

vars

begin
	return self.getTranMapBreadCrumb;

epilog

end;</source>
