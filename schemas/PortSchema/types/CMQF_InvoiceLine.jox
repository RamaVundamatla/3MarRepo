    <JadeMethod name="getOIDAndDescForAttribute" id="9c24b084-422e-486d-bdfc-291e2cbf09fc">
        <source>getOIDAndDescForAttribute(_attrName: String; _getCalculatedDate: Boolean; _oid: String output): String;

vars
	str : String;
	company : CM_Bank;
	invoiceLineType	: CM_InvoiceLineDesc;
	shipLine : CM_ShippingLine;
begin
	if _attrName = ETRow_InvoiceType then
		if self.getMyInvoiceType &lt;&gt; null then
			_oid := self.getMyInvoiceType.getOidAsString();
			return self.getMyInvoiceType.getDescriptionWithTerminalStr();
		endif;
		
	elseif _attrName = ETRow_Company then
		if self.allCompanies.isNotEmpty then
			company := self.allCompanies.first;
			_oid := company.getOidAsString();
			return company.getNameWithTerminalString();
		endif;
		
	elseif _attrName = ETRow_Debtor then
		if self.getMyDebtor &lt;&gt; null then
			_oid := self.getMyDebtor.getOidAsString();
			return self.getMyDebtor.name;
		endif;
		
	elseif _attrName = ETRow_BillOfLading then
		return self.billOfLading;
	elseif _attrName = ETRow_CargoId then
		return self.cargoId;
	elseif _attrName = ETRow_SiteState then
		_oid := siteState.String;
		return app.siteEnumToString(siteState);
	elseif _attrName = ETRow_Voyage then
		if self.getMyVoyage &lt;&gt; null then
			_oid := self.getMyVoyage.getOidAsString(); 
			return self.getMyVoyage.code;
		endif;
	elseif _attrName = ETRow_InvLineType then
		if self.getMyInvoiceLineType &lt;&gt; null then
			_oid := self.getMyInvoiceLineType.getOidAsString();
			return self.getMyInvoiceLineType.getDescriptionWithTerminalStr();
		endif;
	 // ### TFS BUG 56660 23FEB2023 NAVAB1
	elseif _attrName = ETRow_ShippingLine then
		shipLine := self.getMyShippingLine();
		if shipLine &lt;&gt; null then
			_oid:=shipLine.getOidAsString;
			return shipLine.code;
		endif;
		return Any_String;
	endif;
	
	return inheritMethod(_attrName, _getCalculatedDate, _oid);

epilog
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <Parameter name="_oid" type="String" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="efd1231d-a45f-4b2f-8320-0e2c850fd611">
        <updating/>
        <source>includesObject(_line : CM_InvoiceLine; _passport: CM_Passport; _breakOut: Boolean output): Boolean updating, protected;
// Financial Reporting, invoice line filtering
vars
	ti	: CM_TrackedItem;
begin
	self.numSearched := self.numSearched + 1;

	// invoice line or invoice-level checks
	// 37009 missing criteria
	if self.startDate &lt;&gt; null and
	   _line.createdTime.date &lt; self.startDate then
		return false;
	endif;
	if self.endDate &lt;&gt; null and
	   _line.createdTime.date &gt; self.endDate then
		return false;
	endif;
	if self.getMyInvoiceType &lt;&gt; null and
	   _line.getInvoiceType() &lt;&gt; self.getMyInvoiceType then
		return false;
	endif;
	if self.getMyInvoiceLineType &lt;&gt; null and
	   _line.invoiceLineDesc &lt;&gt; self.getMyInvoiceLineType then
		return false;
	endif;
	if self.getMyDebtor &lt;&gt; null and
	   _line.debtor &lt;&gt; self.getMyDebtor then
		return false;
	endif;
	if self.getMyShippingLine() &lt;&gt; null and // ### TFS BUG 56660 23FEB2023 NAVAB1
	   _line.getMyShippingLine() &lt;&gt; self.getMyShippingLine() then // ### TFS BUG 56660 23FEB2023 NAVAB1
		return false; // ### TFS BUG 56660 23FEB2023 NAVAB1
	endif;
	
	// tracked item-level checks
	ti := _line.trackedItem;
	if ti &lt;&gt; null then
		if self.siteState &lt;&gt; TI_SITE_UNDEFINED and
		   ti.site &lt;&gt; self.siteState then
			return false;
		endif;
		if self.cargoId &lt;&gt; null and
		   ti.id &lt;&gt; self.cargoId then
			return false;
		endif;
		// 37009 missing criteria
		if self.getMyCargoType &lt;&gt; null and
		   ti.cargoType &lt;&gt; self.getMyCargoType.id then
			return false;
		endif;
		if self.billOfLading &lt;&gt; null and
		   ti.billOfLading &lt;&gt; self.billOfLading then
			return false;
		endif;
		if self.getMyConsignee &lt;&gt; null and 
		   ti.consignee &lt;&gt; getMyConsignee.code then
			return false;
		endif;
		if self.getMyVoyage &lt;&gt; null and
		   ti.myVoyage &lt;&gt; self.getMyVoyage then
			return false;
		endif;
	endif;
	
	self.numFound := self.numFound + 1;
	return true;

epilog
end;</source>
        <access>protected</access>
        <Parameter name="_line" type="CM_InvoiceLine"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromTemplate" id="2593be7f-dd88-4e29-8652-599ba24d2f33">
        <updating/>
        <source>setFromTemplate(_obj: CMQF_FilterReports; _runDate: Date; _allEventData: CM_EventDataByTypeDict) updating;
/*

Date		Who		Reason
10 September 2014	cnwer1	Initial creation PAR 34813

*/

vars
	eventData : CM_EventDataVoyage;
begin
	inheritMethod(_obj, _runDate, _allEventData);

		// This code sets the voyage for event driven schedules.
	// Have to do this for each appropriate class because they have different myVoyage references.
	eventData := _allEventData[EventDataVoyage].CM_EventDataVoyage;
	if eventData &lt;&gt; null and eventData.myVoyage &lt;&gt; null then
		self.setMyVoyage( eventData.myVoyage );
	endif;
epilog

end;</source>
        <Parameter name="_obj" type="CMQF_FilterReports"/>
        <Parameter name="_runDate" type="Date"/>
        <Parameter name="_allEventData" type="CM_EventDataByTypeDict"/>
    </JadeMethod>
