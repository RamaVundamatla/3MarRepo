	self.txtCode.setFocus();
	
	self.updateMode := false;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="2182156f-2847-4fad-ba84-7ff4778b143b">
        <updating/>
        <source>doDelete() updating;
/*
Purpose:	

Date		Who		Reason
09 July 2024	navab1	CR 64617 TASK 64638
22 Aug 2024	navnk30	Bug 65636: NSW - EDI Issues Configuration UI issues
*/

vars

	pxyIssue, realIssue : CM_EDIIssue;
	theReturn : Integer;
begin
	realIssue := self.myCurrentEDIIssue;
	
	if realIssue = null then
		app.msgBox(app.getErrorString(NO_Items_selected), app.getErrorString(Problem), MsgBox_OK_Only);
		return;
	endif;
	
	if app.msgBox("Confirm Deletion", 
							app.getErrorString(CONFIRM_REMOVAL), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;
	
	self.lblEmail.caption := "No email has been set";	//22.08.2024 navnk30 #65636
	while true do
		app.myTrxDA.trxDeleteEDIIssue(realIssue, app.myPassport);

		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			self.myCurrentEDIIssue := null;
			self.updateMode := false;
			self.clearFields();

			break;
		else
			theReturn := app.showErrorWarningDialog("EDI Issues", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;



epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDisplayEDIIssues" id="1223cc8a-2f78-4227-aec8-c3c6be44346a">
        <source>doDisplayEDIIssues();
/*
Purpose:	

Date		Who		Reason
10 July 2024	navab1	CR 64617 TASK 64638
*/

vars
	issue : CM_EDIIssue;
begin
	self.tblData.rows := self.tblData.fixedRows;
	self.allNotableObjects.clear();
	
	foreach issue in self.myTerminal.allEDIIssues discreteLock do
		self.addRowToTable(issue);
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doEDIDataTypesBuild" id="1e801a9f-cd9c-4462-a170-c63c1f53437c">
        <source>doEDIDataTypesBuild();
/*
Purpose:	

Date		Who		Reason
09 July 2024	navab1	CR 64617 TASK 64638
*/

vars

begin
	self.msgEDITypes.myAvailableListBox.sorted 	:= true;
	self.msgEDITypes.mySelectedListBox.sorted 	:= true;
	self.msgEDITypes.setupControl(null, self.myEDIFilTypeAgent.allEDIFileTypes,CMUI_EDIIssueMaint::getEDIFileTypeDisplay.name);
	self.msgEDITypes.availableHeading	:= app.getErrorString(Available);
	self.msgEDITypes.selectedHeading	:= app.getErrorString(Selected);
	self.msgEDITypes.myBaseForm	:= self;
	self.msgEDITypes.setSelected(null);
	self.msgEDITypes.multiSelect :=  ListBox.MultiSelect_Extended;
	self.msgEDITypes.caption := app.getErrorString(Data_types);


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doHandleNotification" id="9d600182-3fb8-4152-b001-6169bac089b2">
        <updating/>
        <source>doHandleNotification( eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any)updating;
/*
Purpose - 	
Who - NAVAB1
Date - 08JUL2024
ADO -  CR 64617 TASK 64638
*/


vars
	issue : CM_EDIIssue;
	event : Integer;
	idx : Integer;
	theDataLine : String;
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	event := self.myTerminal.getEventFromTerminalEvent(eventType);
	
	if userInfo.isKindOf(CM_EDIIssue) then
		issue := userInfo.CM_EDIIssue;
	elseif theObject.isKindOf(CM_EDIIssue) then
		issue := theObject.CM_EDIIssue;
	endif;
	
	if event = Event_EDIIssueCreate then
		if issue &lt;&gt; null then	
			self.addRowToTable(issue);
		endif;
	elseif event = Event_EDIIssueUpdate then
		if issue &lt;&gt; null then
			self.tblData.findObjectInRow(issue,idx);
			if idx &gt; self.tblData.fixedRows then
				theDataLine := issue.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
				self.tblData.accessCell(idx, 1).text := theDataLine;
			endif;
		endif;
	elseif event = Event_EDIIssueDelete then
		self.tblData.removeItemObject(issue);
		self.doNotableClear(issue);
		
	endif;
epilog
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
