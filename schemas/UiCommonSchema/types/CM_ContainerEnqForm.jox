    <JadeMethod name="cmbVoyage_displayEntry" id="bc88f1af-9539-4a3f-a0ad-6ff97ab78c95">
        <controlMethod name="ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbVoyage_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 19 November 2003
//
//********************************************************************
vars

begin
	if obj.CM_Voyage.myTerminal.hasDuplicateCodeVoyages (obj.CM_Voyage.code) then
		return obj.CM_Voyage.code &amp; " " &amp; obj.CM_Voyage.arrivedDT.reportDisplay;
	else
		return obj.CM_Voyage.code;
	endif;
end;</source>
