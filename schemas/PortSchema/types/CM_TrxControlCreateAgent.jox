    <JadeMethod name="trxCreateToDoInternalJob" id="8b1ece53-8a46-4261-8916-f3685bf6940e">
        <updating/>
        <source>trxCreateToDoInternalJob(	_wodToDo     : CM_WodToDo input;	
							_realToDoJob : CM_WOToDoTaskJob output;
							_passport 	 :  CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 Jul2009	cnwrd1	Initial creation
06 Jun 2018	NDL		TFS 38950 - rewrite
29 Sep 2021 navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
14/06/2022	navcs2	ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema (Changed _realToDoJob type to be new class)
17 Oct 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
18/01/2023	navcs2	ChangeRequest 56633:[56211] 54253.101 - Work order Transactions
15 Mar 2023 navhl20 ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
*/
vars

	terminal    : CM_Terminal;
	tiSet       : CM_TISet;
	todoParams  : CMIF_WorkOrderJobParams;
	ti 			: CM_TrackedItem;
	useYardJobs : Boolean;
	woTrans     : CM_WOTransaction;
	toDoTask	: CM_ToDoTaskDesc;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	terminal    := _wodToDo.getMyTerminal;
	useYardJobs := terminal.isUseYardJobsForCargoWo;  //29.09.2021 navma1 #51925
	
	create tiSet transient;
	create todoParams transient;
	
	todoParams.jobId 		  := _wodToDo.getJobId;
	//todoParams.myToDoTaskDesc := _wodToDo.myToDoTaskDesc;		//15.3.2023 navhl20	#56614[56615]
	todoParams.myWorkOrderDtl := _wodToDo;
	todoParams.numberToQueue  := _wodToDo.allSelectedTIs.size;
	todoParams.requiredByDT   := _wodToDo.requiredByDT;
	
	_wodToDo.allAvailableTIs.copy(tiSet);						//05.04.2023 navma1 #56614:[56615]
	
	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	
	
	// Perform the operation
	
	app.myUtilityCA.utlCreateToDosForWO( _wodToDo, _passport );
	
	if app.myPassport.noErrors then
		foreach ti in tiSet do
			todoParams.allTIs.add( ti);
			_wodToDo.setTIActioned(ti, true);
		endforeach;
	endif;
	
	//29.09.2021 navma1 #51925
	if useYardJobs then
		foreach toDoTask in _wodToDo.allToDoTasksDescs do			//15.3.2023 navhl20	#56614[56615]
			todoParams.myToDoTaskDesc := toDoTask;					//15.3.2023 navhl20	#56614[56615]
			app.myUtilityCA.utlCreateToDoInternalJob( todoParams, _realToDoJob, terminal, _passport );
		endforeach;													//15.3.2023 navhl20	#56614[56615]
	endif;
	
	
	woTrans := _wodToDo.createWOTransaction(_wodToDo.TRANS_UPDATED, null, null); // 17.10.2022 navcs2 #56633:[56211]

	
epilog
	delete tiSet;
	delete todoParams;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_wodToDo" type="CM_WodToDo" usage="input"/>
        <Parameter name="_realToDoJob" type="CM_WOToDoTaskJob" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
