    <JadeMethod name="displayCurrentRow" id="476fcd90-1f2d-4cdd-b457-0710d73d0507">
        <source>displayCurrentRow(_port : CM_Port; _row : Integer) : Integer protected;
// created by cnwvu1 25/08/2006
vars
	theRow	: Integer;
	strC,
	strDesc,
	str		: String;

begin

	if _port.myCountry &lt;&gt; null then
		strC		:= _port.myCountry.code;
		strDesc		:= _port.myCountry.description;
	endif;
		
	str := _port.code &amp; Tab &amp; _port.portCode &amp; Tab &amp; _port.description &amp; Tab &amp; strC &amp; Tab &amp; strDesc &amp; Tab &amp; _port.isActivePort.getYesNo();
	
	if _row = 0 then
		theRow := self.tblCurrent.addItemObject(_port, str);
	else
		theRow := _row;
		self.tblCurrent.accessCell(theRow, 1).text := str;
	endif;
	
	return theRow;

end;
</source>
        <access>protected</access>
        <Parameter name="_port" type="CM_Port"/>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="displayLocodesRow" id="eee1ec57-f38e-4922-a5bf-d29fbd7f8de7">
        <source>displayLocodesRow(_port : CM_Port; _row : Integer) : Integer protected;
// created by Vytenis &amp; Richard 25/08/2006
vars
	theRow	: Integer;
	str		: String;

begin

//	str := _port.code &amp; Tab &amp;  _port.description &amp; Tab &amp; _port.countryCode &amp; Tab &amp;  _port.isPort.getYesNo();	// cnwrl1 29/05/2009 PAR 19672 - what it was
	str := _port.code &amp; Tab &amp;  _port.description &amp; Tab &amp; _port.getCountryCodeForDisplay( Tab ) &amp; Tab &amp;  _port.isPort.getYesNo();
	
	if _row = 0 then
		theRow := self.tblLocodes.addItemObject(_port, str);
	else
		theRow := _row;
		self.tblLocodes.accessCell(theRow, 1).text := str;
	endif;
	
	if _port.isActiveDestination then
		self.tblLocodes.accessRow(theRow).backColor := self.lblActiveColor.backColor;
	else
		self.tblLocodes.accessRow(theRow).backColor := self.tblLocodes.backColor;
	endif;
	
	return theRow;

end;
</source>
        <access>protected</access>
        <Parameter name="_port" type="CM_Port"/>
        <Parameter name="_row" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doCountriesLoad" id="29b90452-e05b-4c0e-b821-3b5a839af4bd">
        <updating/>
        <source>doCountriesLoad() protected, updating;

vars
	agent		: CM_LocodePortLoader;
begin

	if app.msgBox('Do you wish to reload the UN locode countries file', 'Update Database', MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;
	
	create agent transient;
	

	if not agent.updateCountries and not app.myPassport.allErrors.isEmpty then
		app.showErrorWarningDialog('File Import Process', app.myPassport, ErrWarnMode_Update);
		return;
	endif;

	self.doRefresh();
	
epilog
	delete agent;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLocationEdit" id="efbc9fb1-01d5-4ac6-9a60-6147575a1573">
        <source>doLocationEdit( _tableP: CM_DataTable input ) protected;
// Created:     30/08/2006	cnwvu1

vars
 	thePort : CM_Port;
	subSystem : CMUI_SubSystem;
	table : CM_DataTable;

begin

	table := _tableP;
	if (not self.getCurrentLocation( table, thePort )) then
		return;
	endif;
	
	subSystem := app.myController.allSubSystems['SysOpsSchema'];
	self.myAssistant.showTableMaintForm(table.accessRow(table.row).itemObject.CM_Object, self.myMasterMenuAction, true, true);

end;
</source>
        <access>protected</access>
        <Parameter name="_tableP" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doLocodeLoad" id="fa666ee0-2f9d-4cef-a726-bd5c18c8fa6d">
        <updating/>
        <source>doLocodeLoad() protected, updating;

vars

	file		: File;
	country,
	locode,
	str,
	locodeDesc,
	locodeType	: String;
	array		: HugeStringArray;
	isPort		: Boolean;
	filePath	: String;
	count		: Integer;
	agent		: CM_LocodePortLoader;
	
begin

	if app.msgBox('Do you wish to reload the UN locode locations file', 'Update Database', MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;

	create agent transient;
	
	// TAKE THIS OUT !!!
	agent.isUpgradeProcess := false;
	
	if not agent.updatePorts() and not app.myPassport.allErrors.isEmpty then
		app.showErrorWarningDialog('File Import Process', app.myPassport, ErrWarnMode_Update);
		return;
	endif;
	
	self.doRefresh();
	
epilog
	delete agent;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLocodeSearch" id="953bbee7-bb36-43ed-97a8-eda9ac73aae7">
        <source>doLocodeSearch() protected;

// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/6/2006	RBarr		CM_Port::codeDisplay attribute obsolete
// 25/08/2006	Vytenis		Fixed error of searching by Location Code.
// 							Display all actives and inactive locations in different colors
// 26 May 2008	cnwkpd1		PAR #16810 - Increase in Jade table row limit
// 11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks
// ---------------------------------------------------------------------------

vars

	code,
	portDesc	 : String;
	countryObj	: CM_Country;
	iter		: Iterator;
	dict		: CM_PortByCodeDict;
	count,
	idx			: Integer;
	port		: CM_Port;
		
begin

	self.tblLocodes.rows := 1;
	
	code		:= self.txtPortCode.text.trimBlanks();
	portDesc	:= self.txtPortDescr.text.trimBlanks();
	
	countryObj 	:= self.cmbCounty.myObject.CM_Country;
	
	
	if self.chkPorts.value then
		dict := app.myRoot.allPortLocodes;
	else
		dict := app.myRoot.allPorts;
	endif;
	
	iter := dict.createIterator();
	
	if countryObj &lt;&gt; null then
		dict.startKeyGeq(countryObj.code, iter);
	endif;
	
	while iter.next(port) do
		
//		if port.isActiveDestination then
//			continue;
//		endif;
			
		if countryObj &lt;&gt; null and port.myCountry &lt;&gt; countryObj then
			continue;
		endif;
		
		if code &lt;&gt; null and (not port.code.toUpper().cnContains(code)) then
			continue;
		endif;
		
		if portDesc &lt;&gt; null and (not port.description.toUpper().cnContains(portDesc)) then
			continue;
		endif;
	
		count := count + 1;
		idx := self.displayLocodesRow(port, 0);
		if count &gt;= JadeTableRowLimit then		// PAR #16810
			app.msgBox('Unable to display more than ' &amp; JadeTableRowLimit.String &amp; ' rows', 'Maximum Rows Reached',  MsgBox_Exclamation_Mark_Icon);
			break;
		endif;
	endwhile;
	
	self.tblLocodes.sortColumn[1] := 1;
	self.tblLocodes.sortAscending := true;
	
	self.tblLocodes.resort();
	self.tblLocodes.deselectAll;
	self.tblLocodes.selectRow( self.tblLocodes.fixedRows + 1, true);
	self.lblResults.caption := 'UN Locode Search Results - ' &amp; count.String;

epilog
	delete iter;		// PAR #26678
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="058a39a7-945d-4a70-a7f0-da9b7b4b9000">
        <updating/>
        <source>doRefresh() updating, protected;

// Created by cnwdvb1 on 07 April 2006

vars

begin
	inheritMethod();
	self.loadCurrentPorts();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doShowContextMenu" id="8e27eb79-7569-494e-a053-3510da898265">
        <updating/>
        <source>doShowContextMenu(pMenu : MenuItem; tbl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer) : Boolean updating;
// Created:     30/08/2006	cnwvu1
vars
	x1 : Real;
	y1 : Real;

begin

	self.mnuLocationEdit.userObject := tbl;

	x1 := x;
	y1 := y;
	if (not mouse) then  // if keyboard, use current listIndex value
	    x1 := 20;
	    if tbl.row &lt; 0 then
	        y1 := 5;
	    else
	        y1 := tbl.positionTop();
	    endif;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form

	self.popupMenu(pMenu, x1.Integer, y1.Integer);

	return true;
	
end;</source>
        <Parameter name="pMenu" type="MenuItem"/>
        <Parameter name="tbl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doUNFileLoad" id="aa477ae6-8e9f-4614-b9f8-c6356010abf9">
        <updating/>
        <source>doUNFileLoad() updating, protected;
//-----------------------------------------------------------------------
//	Created:	18 April 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	agent		: CM_LocodePortLoader;
	cmifMonitor	: CMIF_Monitor;
begin

	cmifMonitor := app.myPassport.myCMIFMonitor;
	if cmifMonitor = null then
		create cmifMonitor transient;
		app.myPassport.setMyCMIFMonitor(cmifMonitor);
		cmifMonitor.myParent := self;
	endif;
	self.modalDialogShow('Loading UN Country/Port Codes', null, null, null, null, cmifMonitor.message);
   	self.pbProgressBar.visible := true;   	
	app.doWindowEvents(0);
	
	if app.msgBox('Do you wish to reload the UN locode countries file', 'Update Database', MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;
	
	create agent transient;
	

	if not agent.updateFromUNFile() and not app.myPassport.allErrors.isEmpty then
		app.showErrorWarningDialog('File Import Process', app.myPassport, ErrWarnMode_Update);
		return;
	endif;

	self.doRefresh();
	
epilog
	app.mousePointer := Idle;
	self.frmModalDialog.visible := false;
	delete cmifMonitor;
	delete agent;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getCurrentLocation" id="7a5ae544-b64e-482f-8bdd-16803ba24d43">
        <source>getCurrentLocation( _tableP: CM_DataTable input; _location: CM_Port output) : Boolean protected;
// Created:     30/08/2006  cnwvu1

vars
	selected	:	Boolean;
	table		:	CM_DataTable;
	
begin

	table := _tableP;
	if table.row &gt; 0 then
		_location:= table.accessRow(table.row).itemObject.CM_Port;
		selected := table.accessCell(table.row, 1).selected;
	endif;

	if _location = null or not selected then
		return false;
	endif;

	return true;

end;
</source>
        <access>protected</access>
        <Parameter name="_tableP" type="CM_DataTable" usage="input"/>
        <Parameter name="_location" type="CM_Port" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handle14051Error" id="b4da2589-a45d-4be3-bca3-ae9939d81c3f">
        <updating/>
        <source>handle14051Error(_exObj: Exception; _table : CM_BaseTable; _exOccurred : Boolean output ): Integer updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25/11/2014	cnwndl1	Initial creation Par 35248

*/

vars

begin

	if _exObj.errorCode = 14051 then
		_exOccurred := true;
		abortTransaction;
		abortTransientTransaction;
		if _exObj.resumable then
			return Ex_Resume_Next;
		else
			return Ex_Abort_Action;
		endif;
	endif;
	return Ex_Pass_Back;

epilog

end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_table" type="CM_BaseTable"/>
        <Parameter name="_exOccurred" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadCurrentPorts" id="05e642ee-efa7-445e-936d-826c3663cc05">
        <updating/>
        <source>loadCurrentPorts() protected, updating;

// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/6/2006	RBarr		CM_Port::codeDisplay attribute obsolete
// ---------------------------------------------------------------------------

vars

	port	: CM_Port;
	exOccurred : Boolean;	//25 Nov 2014	NDL	Par 35248
	index 		: Integer;	//25 Nov 2014	NDL	Par 35248
begin

	
	self.currentCount := 0;
	self.tblCurrent.rows := 1;
	
	on Exception do self.handle14051Error(exception,self.tblCurrent,exOccurred);	//25 Nov 2014	NDL	Par 35248
	foreach port in app.myRoot.allActiveDestinations do
	//	self.displayCurrentRow(port, 0);
		index := self.displayCurrentRow(port, 0);
		if index = 0 or exOccurred then	//25 Nov 2014	NDL	Par 35248
			break;
		endif;
		self.currentCount := 	self.currentCount + 1;
	endforeach;
	
	self.lblActive.caption := 'Currently Active Codes - ' &amp; self.currentCount.String;
	self.tblCurrent.sortColumn[1] := 1;
	self.tblCurrent.sortAscending := true;
	
	self.tblCurrent.resort();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="makeActive" id="bba08994-a998-4654-9d45-da28ddd44d06">
        <updating/>
        <source>makeActive() protected, updating;

// Created by cnwdvb1 on 07 April 2006

vars

	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815

begin

	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxPortCodeMakeActiveInactive(self.tblLocodes.allSelectedObjects, true, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Make Code Active', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
	self.tmpSet.clear();
	
	makeActiveSelected();	// cnwvu1 31/08/2006

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="makeActiveSelected" id="786cc92b-5cf8-4b60-bad9-c9515f9bbe73">
        <source>makeActiveSelected() protected;
// Created by cnwvu1 on 31/08/2006

vars
	thePort	: CM_Port;
	idx		: Integer;
	
begin

	if (not self.getCurrentLocation( tblLocodes, thePort )) then
		return;
	endif;

	if tblCurrent.findObjectInRow( thePort, idx) then
		self.tblCurrent.deselectAll;
		self.tblCurrent.selectRow(idx, true);
	endif;

end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="makeInactive" id="c3806ca6-f669-447d-8f18-111b2a041c35">
        <updating/>
        <source>makeInactive() protected, updating;

// Created by cnwdvb1 on 07 April 2006

vars

	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815

begin

	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxPortCodeMakeActiveInactive(self.tblCurrent.allSelectedObjects, false, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Make Code Inactive', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
	self.tmpSet.clear();

end;</source>
        <access>protected</access>
    </JadeMethod>
