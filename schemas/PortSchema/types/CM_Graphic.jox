    <JadeMethod name="doInsertNewPoint" id="16e49f93-ebfd-40a8-9c7c-af88a8fcc58a">
        <updating/>
        <source>doInsertNewPoint(_thePoint : Point; _insertBefore : Boolean) updating; 
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/

vars
	thePoint, theAdjoiningPoint, theNewPoint : Point;
	thePointIndex, theAdjoiningPointIndex : Integer;
	x1,x2,y1,y2,x3,y3, polySize : Integer;
begin
	thePointIndex := self.pointsPolygon.indexOf(_thePoint);
	polySize := self.pointsPolygon.size;// PAR 28920
	
	// PAR 28920
	if thePointIndex &lt; 1 then
		app.raiseCMException(Polyg_point_must_selec_canno_a, null, null);
		return;
	endif;
	
	
	
	
	// PAR 28920
//	if thePointIndex = 1 then
//		theAdjoiningPointIndex := self.pointsPolygon.size;
//	else
		if _insertBefore then
			if thePointIndex = 1 then
				theAdjoiningPointIndex := polySize - 1;
			else
				theAdjoiningPointIndex := thePointIndex - 1;
			endif;
		else
			theAdjoiningPointIndex := thePointIndex + 1;
		endif;
//	endif;
	
	theAdjoiningPoint := self.pointsPolygon[theAdjoiningPointIndex];
	thePoint := self.pointsPolygon[thePointIndex];


	if _insertBefore then
		x1 := theAdjoiningPoint.x;
		y1 := theAdjoiningPoint.y;
		x2 := thePoint.x;
		y2 := thePoint.y;
		
		x3 := (((x2 - x1) / 2) + x1).Integer;
		y3 := (((y2 - y1) / 2) + y1).Integer;
		theNewPoint.set(x3,y3);
		if thePointIndex = 1 then// PAR 28920
			self.pointsPolygon.insert(polySize,theNewPoint);// PAR 28920
		else
			self.pointsPolygon.insert(thePointIndex,theNewPoint);
		endif;
	else
		x1 := thePoint.x;
		y1 := thePoint.y;
		x2 := theAdjoiningPoint.x;
		y2 := theAdjoiningPoint.y;
		
		x3 := (((x2 - x1) / 2) + x1).Integer;
		y3 := (((y2 - y1) / 2) + y1).Integer;
		theNewPoint.set(x3,y3);
		self.pointsPolygon.insert(theAdjoiningPointIndex,theNewPoint);
	endif;

epilog
end;</source>
        <Parameter name="_thePoint" type="Point"/>
        <Parameter name="_insertBefore" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doRemovePoint" id="ab8b5258-92f8-4a55-a097-81f9bdf194a4">
        <updating/>
        <source>doRemovePoint(_thePoint : Point) updating;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
*/

vars

	thePoint, theAdjoiningPoint, theNewPoint : Point;
	thePointIndex, theAdjoiningPointIndex : Integer;
	x1,x2,y1,y2,x3,y3 : Integer;
begin
	thePointIndex := self.pointsPolygon.indexOf(_thePoint);
	
	if thePointIndex &gt; 0 and thePointIndex &lt;= self.pointsPolygon.size then
		self.pointsPolygon.removeAt(thePointIndex);
		
		// PAR 28920 The first point and the last point are the same, so if removing the first point join up the last point
		if thePointIndex = 1 then
			self.pointsPolygon[self.pointsPolygon.size] := self.pointsPolygon[1];
		endif;
	else
		app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " Point not found, cannot remove ");
		return;
	endif;

epilog
end;</source>
        <Parameter name="_thePoint" type="Point"/>
    </JadeMethod>
    <JadeMethod name="drawPolygons" id="d9a03b30-6e39-4a7c-9a38-0c9744991d29">
        <source>drawPolygons(_frame: Frame; _type: Integer; _scale: Real; _offsetX: Integer; _offsetY: Integer; 
				_flippedH: Boolean; _stretchOffset: Integer; _max : Integer; _fillColour : Integer);
// ---------------------------------------------------------------------------
// Created:		01 December 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theFrame : Frame;
	aGraphic : CM_Graphic;
	theCommands : CM_GraphicArray;
	aCommand : CM_GraphicCommand;
	thePoints : RealArray;
	theX, theY : Integer;
	tmp : Integer;  //cnwjo3
	stretchOffset,stretchX, stretchY : Integer;
	maxX : Integer;
begin
	theFrame := _frame;
	theCommands := self.getCommands(_type);
	self.getStretchXY(_type,stretchX, stretchY); // the point from which to stretch
	if stretchY &gt; 0 then
		stretchOffset := _stretchOffset;
	endif;
	maxX := _max;
	
	create thePoints transient;
	foreach aGraphic in theCommands do
		aCommand := aGraphic.CM_GraphicCommand;
		
		if aCommand.type = CM_GraphicCommand.TYPE_STOP then
			theFrame.drawPolygon(thePoints,aCommand.lineColour);
			thePoints.clear;
		elseif aCommand.type = CM_GraphicCommand.TYPE_STOP_FILL then
		//cnwjo3 ccms 1018. terrible hack.  If the label/description is 'NoChange'
		//then don't attempt to change the fillcolour (for example for
		//consignee's, iso types, voyages etc...)
			if _fillColour = NullColour or aCommand.label = app.getErrorString(Nochange) then
				theFrame.drawFillColor := aCommand.fillColour;
			else
				theFrame.drawFillColor := _fillColour;
			endif;
			
			theFrame.drawFilledPolygon(thePoints,aCommand.lineColour);
			thePoints.clear;
		elseif aCommand.type = CM_GraphicCommand.TYPE_DRAW then
			if _flippedH then
				theX := (_scale * aCommand.x1).Integer + 1;
				theY := (_scale * aCommand.y1).Integer + _offsetY;
			else
				theX := (_scale * aCommand.x1).Integer + _offsetX;
				theY := (_scale * aCommand.y1).Integer + _offsetY;
			endif;
			
			if _flippedH then
				theX := maxX - theX;
				theX := theX +  _offsetX;
				theX := theX - maxX;
			endif;
			if aCommand.y1 &gt; stretchY then
				theY := theY + stretchOffset;
			endif;

			thePoints.add(theX);
			thePoints.add(theY);
			
		endif;
	endforeach;
epilog
	delete thePoints;
end;</source>
        <Parameter name="_frame" type="Frame"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_scale" type="Real"/>
        <Parameter name="_offsetX" type="Integer"/>
        <Parameter name="_offsetY" type="Integer"/>
        <Parameter name="_flippedH" type="Boolean"/>
        <Parameter name="_stretchOffset" type="Integer"/>
        <Parameter name="_max" type="Integer"/>
        <Parameter name="_fillColour" type="Integer"/>
    </JadeMethod>
