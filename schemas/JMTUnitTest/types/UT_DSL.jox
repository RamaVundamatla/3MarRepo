    <JadeMethod name="deleteRTDevice" id="0c1a4775-48c7-4c20-86b7-a1ff02ccb722">
        <source>deleteRTDevice(_id: String);
//07 January 2009	cnwdw1	
//
vars
	rtDevice: CM_RadioTelemetryDevice;
	machine : CM_Machine;
begin
	rtDevice := self.getRTDevice(_id);
	if rtDevice &lt;&gt; null then
		// In unit tests, multiple machines can be using the same RT device
		// need to be able to delete a logged in device
		machine := rtDevice.getMachine;		//jlgzm1 12/07/2019
		if machine &lt;&gt; null and machine.loggedOn then
			self.machineLogOff(machine);
		endif;
		app.myTrxDA.trxDeleteRTDevice(rtDevice, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
epilog
end;</source>
