    <JadeMethod name="isOpsViewData" id="8a550d15-f636-408b-9bac-67fa92a91d97">
        <source>isOpsViewData(): Boolean;
/*
Purpose:			

Date		Who		Reason
26 August 2021	navab1	TFS 51853
*/

vars
	ti : CM_TrackedItem;
begin

	if self.allReceiveTrackedItems.isEmpty
	and self.allReleaseTrackedItems.isEmpty then
		return true;
	endif;

	foreach ti in self.allReceiveTrackedItems discreteLock do
		if ti.isOpsViewData() then
			return true;
		endif;
	endforeach;

	foreach ti in self.allReleaseTrackedItems discreteLock do
		if ti.isOpsViewData() then
			return true;
		endif;
	endforeach;


	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isRail" id="d4418af5-7a2d-4989-a54a-209b3f408908">
        <source>isRail(): Boolean;
// ---------------------------------------------------------------------------
