    <JadeMethod name="doExtract" id="7ce06f42-d78c-4875-b84a-4f9c773073c7">
        <source>doExtract();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2011	#cnwdz2	  27747

*/

vars
	fileObj         : File;

begin
    app.mousePointer    :=  Busy;

    create fileObj transient;
	fileObj.mode :=	File.Mode_Output;	// 1/3/16 cnwmp6 PAR 36286 unicode version

    self.tblDetails.cnEcExportToCSV(fileObj, false);
	
epilog
app.mousePointer    :=  Idle;
    delete fileObj;
  
end;</source>
