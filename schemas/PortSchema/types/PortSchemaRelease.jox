	isHazNotLimitedObj			: CM_YATypeIsHazNotLimited;						//cnwrd1 par 24881 6.7.2010
	isHazOrLimitedObj			: CM_YATypeIsHazOrLimited;
	loadPortObj					: CM_YATypeLoadPort;
