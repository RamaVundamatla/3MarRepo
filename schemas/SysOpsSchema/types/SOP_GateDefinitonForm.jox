    <JadeMethod name="doCmbTroubleIn_updateProxy" id="e9218591-326b-4d0b-bc30-4e31f44b5418">
        <updating/>
        <source>doCmbTroubleIn_updateProxy()updating, protected;
// ---------------------------------------------------------------------------
// Created:     04 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	combo	:CMUI_ComboBox;
begin
	combo	:= cmbTroubleIn;
	
	if combo.listIndex = -1 then
		return;	// nothing to do
	endif;
	
	if combo.text = app.getErrorString (XLAT_P_THEN_T) then
		// trouble last
		self.doMove (false);
	else
		// trouble first
		self.doMove (true);
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
