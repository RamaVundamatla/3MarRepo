	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_drTerm, false);
	endif;
	
epilog

end;</source>
        <Parameter name="_drTerm" type="CM_DebtorTerminal" usage="input"/>
        <Parameter name="_isCashOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
