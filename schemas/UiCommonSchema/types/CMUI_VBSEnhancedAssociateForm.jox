    <JadeMethod name="doUseBookingClick" id="8e2e99c6-079f-4797-8bbb-f73ae0e90277">
        <source>doUseBookingClick();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Apr 2025 navlc30 JIRA 34266 TPT | FR 33661.040 VBS - One Release Request and Multiple VBS - On Schedule

*/

vars
	vbsts : CM_VehicleBookingTimeSlot;
	proxy : CM_VehicleBookingTimeSlot;
	theReturn : Integer;
	loadState : Boolean;
	strArray : StringArray;
	deliveryIds, pickupIds : StringArray;	
begin
	if not self.doValidateSelection( vbsts ) then
		return;
	endif;
	if vbsts = null or vbsts.myVehicleVisitRecord &lt;&gt; null then
		return;
	endif;
	
	if self.myVehicleVisitRecord = null or self.myVehicleVisitRecord.myVehicleBookingTimeslot &lt;&gt; null then
		return;
	endif;
	
	app.cmsBeginLoad(loadState);
	proxy := vbsts.pxyCreateUpdateProxy().CM_VehicleBookingTimeSlot;
	app.cmsEndLoad(loadState);
	
	create strArray transient;
	create deliveryIds transient;									
	create pickupIds transient;										

	vbsts.getTiIdsFromBookedItemsOrVvr(deliveryIds, pickupIds);		
	deliveryIds.copy(strArray);	
	pickupIds.copy(strArray);
	
	proxy.setProxy(	vbsts.bookingTSstart,	//_scheduleTSstart : TimeStamp;
					vbsts.bookingTSend,	//_scheduleTSend : TimeStamp;
					vbsts.myVehicleBookingTerminal,	//_myVBTerminal : CM_VehicleBookingTerminal;
					vbsts.myCarrier,	//_myCarrier : CM_Carrier;
					null,				//_mySubCarrier : CM_Carrier;
					vbsts.myDriver,	//_myDriver : CM_DriverDetails;
					vbsts.myVehicle,	//_myVehicle : CM_Vehicle;
					vbsts.remarks,	//_remarks : String;
					vbsts.includesDelivery,	//_includesDelivery : Boolean;
					vbsts.includesPickUp,	//_includesPickUp : Boolean;
					strArray,	//_bookedTiIds : StringArray;
					self.myVehicleVisitRecord,	//_myVehicleVisitRecord : CM_VehicleVisitRecord
					vbsts.myVBTimeSlotType,	//_myVBTimeslotType : CM_VehicleBookingTimeSlotType
					vbsts.id,	//_id : String;
					vbsts.allBookingRefs,	//_allBookingRefs : CM_BookingRefSet;
					vbsts.allBulkReleases,	//_allBulkReleases : CM_BulkReleaseSet
					null,	//_allVBSTimeSlots : CM_VehicleBookingTSItemSet;
					vbsts.preGateInCheck,	//_preGateInCheck : Boolean; 
					vbsts.preGateOutCheck,	//_preGateOutChck : Boolean;
					null,	//_kioskCheck : Boolean;
					null,	//_externalReference : String
					null	//_myTILCType : CM_TILCType	// 08 Aug 2024 navcs2	ChangeRequest 63928
					);
					
	while true do

		app.myTrxUA.trxUpdateVehicleBooking(proxy, null, null, app.myPassport);	
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Vehicle_schedul_booking_slot), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;

epilog

	delete strArray;
	delete deliveryIds;	
	delete pickupIds;
	delete proxy;
	
	app.cmsEndLoad(loadState);

end;</source>
    </JadeMethod>
    <JadeMethod name="doValidateSelection" id="c47c5fe0-0a4f-4ec6-8a79-5f43339cb2a2">
        <source>doValidateSelection( _booking : CM_VehicleBookingTimeSlot output) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Apr 2025	navlc30	Initial creation
04 APR 2025 navlc30 JIRA 34266 TPT | FR 33661.040 VBS - One Release Request and Multiple VBS? On Schedule

*/

vars

begin
	if self.tblBookings.row &gt; self.tblBookings.fixedRows and self.tblBookings.row &lt;= self.tblBookings.rows then
		_booking := self.tblBookings.accessRow( self.tblBookings.row ).itemObject.CM_VehicleBookingTimeSlot;
	endif;

	return _booking &lt;&gt; null;
epilog

end;</source>
        <Parameter name="_booking" type="CM_VehicleBookingTimeSlot" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
