    <JadeMethod name="doBaseFormSave" id="9a7a2a88-11c3-417c-8b69-fa481bfab683">
        <updating/>
        <source>doBaseFormSave() updating, protected;
vars
	controller : CMIF_ShipOverstowController;
	tmpJS : CM_VoyageJobSheet;
	idx, rows : Integer;
	aJob : CM_VoyageJob;
begin
	if self.myCurrentVoyage = null then
		app.msgBox("Please select a voyage.", "Problem", MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	create controller;
	controller.init(self.myCurrentVoyage);
	
	rows := self.tblJobsJS1.rows;
	if rows &gt; 0 then
		create tmpJS transient;
		controller.addJobSheet(tmpJS);
		foreach idx in 1 to rows do
			aJob := self.tblJobsJS1.accessRow(idx).itemObject.CM_VoyageJob;
			tmpJS.addJob(aJob,0);
		endforeach;
	endif;
	rows := self.tblJobsJS2.rows;
	if rows &gt; 0 then
		create tmpJS transient;
		controller.addJobSheet(tmpJS);
		foreach idx in 1 to rows do
			aJob := self.tblJobsJS2.accessRow(idx).itemObject.CM_VoyageJob;
			tmpJS.addJob(aJob,0);
		endforeach;
	endif;
	rows := self.tblJobsJS3.rows;
	if rows &gt; 0 then
		create tmpJS transient;
		controller.addJobSheet(tmpJS);
		foreach idx in 1 to rows do
			aJob := self.tblJobsJS3.accessRow(idx).itemObject.CM_VoyageJob;
			tmpJS.addJob(aJob,0);
		endforeach;
	endif;
	
	controller.osMoveTotals.clear;
	controller.checkOSAbsolute();
	controller.checkOSAsWorked();
	controller.checkOSRealTimeActual();
	controller.checkOSRealTimeEstimated();
epilog
	delete controller;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doQuery" id="ecfb9bb1-27db-4b1e-ba96-3906ae6694b0">
        <source>doQuery();

vars

begin
	if self.myCurrentVoyage = null then
		app.msgBox("Please select a voyage.", "Problem", MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	self.displayAllJobs();
	
	self.displayJobSheets();
end;
</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="87aaebd4-9e1b-45e5-9838-2bff56547ead">
        <updating/>
        <source>setupForm() updating;

vars

begin
	inheritMethod();
	self.frmToolbar.alignContainer	:=	Frame.AlignContainer_Top; // this will make the dkcMain line up its top	
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;
	
	if self.myCurrentVoyage = null then
		app.msgBox("Please select a voyage.", "Problem", MsgBox_Exclamation_Mark_Icon);
		
	else
		self.caption := self.caption &amp; " " &amp; self.myCurrentVoyage.code;
		self.doQuery();

	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="2ef616fd-c83f-465a-b51a-ba62826b07ad">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006394, locale);
	btnJS1In.translateCaption(Xlat_0006395, locale);
	btnJS1Out.translateCaption(Xlat_0006396, locale);
	btnJS2In.translateCaption(Xlat_0006397, locale);
	btnJS2Out.translateCaption(Xlat_0006398, locale);
	btnJS3In.translateCaption(Xlat_0006399, locale);
	btnJS3Out.translateCaption(Xlat_0006400, locale);
	btnJobsOut.translateCaption(Xlat_0006401, locale);
	grpJS1.translateCaption(Xlat_0006402, locale);
	grpJS2.translateCaption(Xlat_0006403, locale);
	grpJS3.translateCaption(Xlat_0006404, locale);
	grpJobs.translateCaption(Xlat_0006405, locale);
	shtJobs.translateCaption(Xlat_0006406, locale);
	shtResults.translateCaption(Xlat_0006407, locale);
end;</source>
    </JadeMethod>
</GUIClass>
