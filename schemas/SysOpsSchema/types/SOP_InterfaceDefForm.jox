    <JadeMethod name="tblTranslations_dblClick" id="d5333179-53f7-4ba1-a5e8-f5bbded7afe0">
        <controlMethod name="Table::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblTranslations_dblClick(table: CM_BaseTable input) updating;
// --------------------------------------------------------------------------------
// Created:		23 September 2008 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if table.row &lt;= table.fixedRows then
		table.cnEcSetSortTypes(Table.SortType_Alpha, Table.SortType_Alpha, Table.SortType_Alpha);
		table.cnEcResort(table.column, true, true);
	endif;
end;</source>
        <Parameter name="table" type="CM_BaseTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="f8b517b1-fbaa-4cef-9734-fbcad39ee162">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0009662, locale);
	btnCancel.translateCaption(Xlat_0009663, locale);
	btnDelete.translateCaption(Xlat_0009664, locale);
	btnHookConAttr.translateCaption(Xlat_0009665, locale);
	btnHookConUniq.translateCaption(Xlat_0015842, locale);
	btnHookLocTran.translateCaption(Xlat_0009666, locale);
	btnNew.translateCaption(Xlat_0009667, locale);
	btnResetInterfac.translateCaption(Xlat_0013360, locale);
	btnSave.translateCaption(Xlat_0009668, locale);
	btnTAdd.translateCaption(Xlat_0009669, locale);
	btnTRemove.translateCaption(Xlat_0009670, locale);
	btnViewMessage.translateCaption(Xlat_0013361, locale);
	grpUserHooks.translateCaption(Xlat_0009671, locale);
	lblAppCopies.translateCaption(Xlat_0009672, locale);
	lblDefinition.translateCaption(Xlat_0009673, locale);
	lblHookConAttr.translateCaption(Xlat_0009674, locale);
	lblHookConUniq.translateCaption(Xlat_0015843, locale);
	lblHookLocTran.translateCaption(Xlat_0009675, locale);
	lblLocale.translateCaption(Xlat_0009676, locale);
	lblMaxQEntries.translateCaption(Xlat_0013362, locale);
	lblMessageACKTO.translateCaption(Xlat_0013363, locale);
	lblName.translateCaption(Xlat_0009677, locale);
	lblSessionTO.translateCaption(Xlat_0009678, locale);
	lblTcpAddress.translateCaption(Xlat_0009679, locale);
	lblTcpPort.translateCaption(Xlat_0009680, locale);
	lblTcpTimeout.translateCaption(Xlat_0009681, locale);
	lblType.translateCaption(Xlat_0013364, locale);
	shtDetails.translateCaption(Xlat_0009682, locale);
	shtTranslations.translateCaption(Xlat_0009683, locale);
end;</source>
    </JadeMethod>
