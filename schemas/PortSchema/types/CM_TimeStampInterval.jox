    <JadeMethod name="getName" id="b198e015-a4f0-4da9-84ae-7e5b2f91e7e3">
        <source>getName(): String;
/*
Date		Who		Reason
22 September 2011	cnwcs5	Initial creation - CCMS RIO 2041 / par 28220 Start/Stop Times
*/
vars

begin
	return self.startDT.asStringJMT &amp; ' - ' &amp; self.endDT.asStringJMT;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="a69bb199-012e-4f5f-b359-10ec247921ec">
        <updating/>
        <source>setForUpdate(_proxy :CM_TimeStampInterval)updating;
/*
Date		Who		Reason
21 September 2011	cnwcs5	Initial creation - CCMS RIO 2041 / par 28220 Start/Stop Times
*/
vars

begin
	self.startDT	:= _proxy.startDT;
	self.endDT		:= _proxy.endDT;
epilog

end;</source>
        <Parameter name="_proxy" type="CM_TimeStampInterval"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TimeStampInterval" id="9a8cc1d0-49f7-4184-be4e-4c2149d4bf3e">
