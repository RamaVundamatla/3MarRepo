        <updating/>
        <source>setCountryOfOrigin(_country : CM_Country) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin

*/

vars

begin
