    <JadeMethod name="isCMIFDataMatch" id="086f6705-c0b1-4436-81cf-c8361b90468f">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataObjects): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/08/2023	navkc1	CR 59603 Task 59604: UI - CustDocs More Stop Criteria

*/

vars

begin
	return _cmifAutoPlan.isCustomDocType_Match(_yaData);

epilog

