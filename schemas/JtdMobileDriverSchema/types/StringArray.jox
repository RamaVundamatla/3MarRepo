<CollClass name="StringArray">
    <JadeMethod name="jtdFind" id="0e149b29-287f-4d8b-8a52-48fa9a1b1dc6">
        <source>jtdFind(str : String) : Integer;

vars
	i 		: Integer;
	str2 	: String;
	str3	: String;
begin
	//  Case-insensitive find, returns array position of input string ///

	str2	:= str.toLower;

	foreach str3 in self do
		if str3.toLower = str2 then
			return self.indexOf(str3);
		endif;
	endforeach;

 	return 0;	
end;</source>
        <Parameter name="str" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</CollClass>
