    <JadeMethod name="getInstruction" id="dfb4d7da-d39d-41a3-a649-7c126e5fa052">
        <source>getInstruction():String;
/*

Purpose:
Returns instruction type description in the following priority
WorkOrder&gt;WorkOrderDetail&gt;bulkRelease/BOL/Booking &gt;	reserveDetail/BOLDetail/BookingItem &gt; trackedItem			

Parameters:			

Return Value:		

Date		Who		Reason
03 Dec 2024	navhl20 Bug MTN-33558: EUP | 53127 - Wrong Instructions shown in WO Ops Thin Client and Mobile Apps
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
08 Apr 2025	navbs1	Bug MTN-34396: EUP | Additional Operational Instructions - more issues (part 2)

*/
vars
	wod 		: CM_WorkOrderDtl;
	instruction : CM_InstructionsIssued;
	relReq		: CM_BulkRelease;
	resDtl		: CM_ReserveDetail;
	book		: CM_BookingRef;
	bookDtl		: CM_BookingRefItem;
	ins			: String;
	req			: CM_Request;
begin
	
	instruction := self.getFirstInstFromWODtl(wod);				//17.04.2025 navbs1 #34396
	if instruction &lt;&gt; null then
		return instruction.getInstructionDesc();
	endif;
	
	if wod &lt;&gt; null then
		if wod.isKindOf(CM_WodReceive) then
			book := wod.CM_WodReceive.myBookingRef;
			bookDtl	:= wod.CM_WodReceive.myBookingRefItem;
			if book &lt;&gt; null then
				instruction := book.getInstructions();
				if instruction &lt;&gt; null then
					//return instruction.internalInstructions; //10.03.2025 navah1 #34283
					return instruction.getInstructionDesc();   //10.03.2025 navah1 #34283
				endif;
			endif;
			if bookDtl &lt;&gt; null then
				instruction := bookDtl.getInstructions();
				if instruction &lt;&gt; null then
					//return instruction.internalInstructions; //10.03.2025 navah1 #34283
					return instruction.getInstructionDesc();   //10.03.2025 navah1 #34283
				endif;
			endif;
		else
			relReq := wod.CM_WodRelease.myReleaseRequest;
			if relReq &lt;&gt; null then
				instruction := relReq.getInstructions();
				if instruction &lt;&gt; null then
					//return instruction.internalInstructions; //10.03.2025 navah1 #34283
					return instruction.getInstructionDesc();   //10.03.2025 navah1 #34283
				endif;
			endif;
			foreach req in self.allRequests discreteLock do	//06.03.2025 navma1 #MTN-34179
				resDtl := req.myReserveDetail;
				if resDtl &lt;&gt; null then
					instruction := resDtl.myInstructions;
				endif;
				//if instruction &lt;&gt; null and not ins.cnContains(instruction.internalInstructions) then		//13.12.2024 navhl20 #33558 //10.03.2025 navah1 #34283
				if instruction &lt;&gt; null and not ins.cnContains(instruction.getInstructionDesc()) then		//10.03.2025 navah1 #34283
					if ins = null then
						// ins := ins &amp; instruction.internalInstructions;//10.03.2025 navah1 #34283
						ins := ins &amp; instruction.getInstructionDesc();   //10.03.2025 navah1 #34283
					else
						// ins := ins &amp; Comma &amp; instruction.internalInstructions;//10.03.2025 navah1 #34283
						ins := ins &amp; Comma &amp; instruction.getInstructionDesc();   //10.03.2025 navah1 #34283
					endif;
				endif;
			endforeach;
			if ins &lt;&gt; null then 					//08.04.2025 navbs1 #34396
				return ins;
			endif;
		endif;
	endif;
	
	instruction := self.getFirstInstFromTIs();		//17.04.2025 navbs1 #34396
	if instruction &lt;&gt; null then
		return instruction.getInstructionDesc();
	endif;

	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getJobActivity" id="3250debc-01b6-49aa-8364-f660a39096ae">
        <source>getJobActivity(): String;
/*

Purpose:			This method returns a string of Job Actions timestamp
					eg.
					
					Job Start		21/03/2024 15:10
					Job Stop		21/03/2024 15:13
					Job Resume		21/03/2024 15:19
					Job Complete	21/03/2024 15:24
					
					It returns					
					21/03/2024 15:10 to 15:13
					21/03/2024 15:19 to 15:24

Parameters:			

Return Value:		

Date		Who		Reason
20/03/2024	navkc1 CR 62694 Task 62901: UI - WO Ops Start Stop Details
28/03/2024	navkc1 CR63258  Task 63259: Jade - Start Stop API call TRX
29 Nov 2024	navhl20 Bug MTN-33553: EUP - WO Ops screen job activity populated with extra line
*/

vars
	vvr				: CM_VehicleVisitRecord;
	
	vvrDtl			: CM_VehicleVisitRecordDetail;
	
	retVal			: String;
	isStartResume	: Boolean;
	ts				: TimeStamp;
begin
	
	vvr := self.myVehicleVisit;
	
	if vvr = null then
		return null;
	endif;
	
	ts := null;
	
	foreach vvrDtl in vvr.allVehicleVisitRecordDetails discreteLock do
		
		if not vvrDtl.isTypeOfJobAction() then
			continue;
		endif;
		
		if vvrDtl.recordType = VisitRecord_JobStart or vvrDtl.recordType = VisitRecord_JobResume then
			
			ts := vvrDtl.timeStart;
			if isStartResume then
				retVal &amp;= " to ???, " &amp; ts.asStringJMT();
			else
				retVal &amp;= ts.asStringJMT();
			endif;
			
			isStartResume := true;
			continue;
		endif;
		
		if vvrDtl.recordType = VisitRecord_JobStop or vvrDtl.recordType = VisitRecord_JobComplete then
			ts := vvrDtl.timeStart;
			if isStartResume then
				if vvrDtl.recordType = VisitRecord_JobComplete then											//29.11.2024 navhl20 #33553
					retVal &amp;= " to " &amp; ts.asStringJMT();
				else
					retVal &amp;= " to " &amp; ts.asStringJMT() &amp; CrLf;
				endif;
			else
				retVal &amp;= "??? to " &amp; ts.asStringJMT() &amp; CrLf;
			endif;
			isStartResume := false;
			continue;
		endif;
	endforeach;
	
	return retVal;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getJobClassNiceString" id="ef847d9d-fa52-42eb-bb55-1004e5d7ad80">
