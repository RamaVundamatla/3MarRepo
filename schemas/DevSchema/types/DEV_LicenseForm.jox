    <JadeMethod name="terminalAdd" id="7dbd36bf-3c8f-4f07-8ed7-2ed5efde846d">
        <updating/>
        <source>terminalAdd() updating, protected;
// ---------------------------------------------------------------------------
// Created:     06 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	termName	: String;
	licTerm		: DEV_LicenseDtl;
	idx			: Integer;
	
begin

	if self.myCurrentClient = null then
		app.msgBox('You must select a client', 'Error', 0);
		return;
	endif;

	read termName;
	if termName = null then
		return;
	endif;
	
	termName := termName.trimBlanks;
	
	licTerm := self.myCurrentClient.addLicenseDtl(termName, DEV_LicenseEntity.LicenseType_Terminal);
	if licTerm = null then
		// must have been an error
		return;
	endif;
	
	self.initComboLicenseType(self.myCurrentClient);
	self.setCurrentLicenseDtl(licTerm, DEV_LicenseEntity.LicenseType_Terminal);	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
