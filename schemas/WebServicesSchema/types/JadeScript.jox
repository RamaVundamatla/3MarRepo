    <JadeMethod name="mATestQuickFind" id="0823ee44-57dd-4fcf-81a9-677be6eb3183">
        <source>mATestQuickFind();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2018	jlgma1	Initial creation

*/

vars
	tmpTerminal	: CM_Terminal;
	ti			: CM_TrackedItem;
	tmpVoy		: CM_Voyage;
	checkDT 	: TimeStamp;
	foundTIs	: CM_TISet;
	foundBookings : CM_BookingRefSet;
	foundBols     : CM_BOLSet;
	tmpDAC	: CM_DataAccessController;
	iter : Iterator;
	bookingRef : CM_BookingRef;
	bolIn	: CM_BOLIn;
	realBol : CM_BOL;
	qu : CMIF_QuickViewController;
begin
app.initialize;
		app.myPassport.setMyUserFromCode("CNWMC5A");
	app.myPassport.setMyTerminal(app.myRoot.allTerminals["JBL"]);
	create qu transient;
	create foundBols transient;

	tmpTerminal := app.myRoot.allTerminals["JBL"];
		//foreach tmpTerminal in self.allTerminals discreteLock do
			bolIn := tmpTerminal.getBOLInByNumber("BOL185181", BOLType_GeneralBillOfLading);
			if bolIn &lt;&gt; null then
				if qu.checkAccess and not bolIn.canUserAccessSelf(null, tmpDAC,app.myPassport) then
						//continue;
				endif;
				foundBols.add(bolIn);
			endif;
		//endforeach;
		
		foreach realBol in foundBols discreteLock do
			if realBol.isKindOf(CM_BOLIn) then
				foreach  ti in realBol.CM_BOLIn.allTrackedItems discreteLock do
					if ti = null then
						continue;
					endif;
					
					if qu.checkAccess and not ti.canUserAccessSelf(null, tmpDAC,app.myPassport) then
						continue;
					endif;
					/*if not self.allTIs.includes(ti) then
						self.allTIs.add(ti);
					endif;*/
				endforeach;
			endif;
		endforeach;
epilog
	delete qu;
	delete foundBols;
end;</source>
    </JadeMethod>
