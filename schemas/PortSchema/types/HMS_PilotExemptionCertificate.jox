    <JadeMethod name="validateMe" id="be8ca6c3-b7cb-4b69-9e23-9c864febe6a3">
        <source>validateMe(_passport: CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2012	cnwndl1	Initial creation	Par 29496

*/

vars

begin

	inheritMethod(_passport);
	
	if not self.certifiedDate.isValid then
	//	app.raiseCMException1( REQUIRED_FIELD, app.getErrorString(Date_certified), null, null );
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Date_certified), null, null ); // cnwdb2	PAR 35364
	endif;
	
	if not self.expiryDate.isValid then
	//	app.raiseCMException1( REQUIRED_FIELD, app.getErrorString(ExpiryDate), null, null );
		app.raiseCMException1( Input_required_field_Required, app.getErrorString(ExpiryDate), null, null ); // cnwdb2	PAR 35364
	else
		if self.expiryDate &lt;= self.certifiedDate then
			app.raiseCMException2( Not_earlier_than, app.getErrorString(ExpiryDate), app.getErrorString(Date_certified), null, null );
		endif;
	endif;
	
	
	if self.myVessel = null then
	//	app.raiseCMException1( REQUIRED_FIELD, app.getErrorString(CM_Vessel_GC), null, null );
		app.raiseCMException1( Input_required_field_Required, app.getErrorString(CM_Vessel_GC), null, null ); // cnwdb2	PAR 35364
	endif;
	
	if self.myHarbour = null then
//		app.raiseCMException1( REQUIRED_FIELD, app.getErrorString(Harbour), null, null );
		app.raiseCMException1( Input_required_field_Required, app.getErrorString(Harbour), null, null ); 
	endif;
	
	if self.myMaster = null then
	//	app.raiseCMException1( REQUIRED_FIELD, app.getErrorString(Master), null, null );
		app.raiseCMException1( Input_required_field_Required, app.getErrorString(Master), null, null ); // cnwdb2	PAR 35364
	endif;
	
	if not self.isTransient then
		if self.myMaster.allPilotExemptionCertificates.hasAnotherLikeMe(self) then
			app.raiseCMException( Pilot_exemp_with_this_crite_al, null, null );
		endif;
	endif;
	
	if self.revalidationDate.isValid then
		if self.revalidationDate &lt;= self.certifiedDate then
			app.raiseCMException2( Not_earlier_than, app.getErrorString(Revalidation_date), app.getErrorString(Date_certified), null, null );
		endif;
		if self.myValidatedBy = null then
//			app.raiseCMException1( REQUIRED_FIELD, app.getErrorString(Validat_pilot_require_revalid), null, null );
			app.raiseCMException1( Input_required_field_Required, app.getErrorString(Validat_pilot_require_revalid), null, null ); // cnwdb2	PAR 35364
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
