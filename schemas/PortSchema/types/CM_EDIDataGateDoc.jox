    <JadeMethod name="getEDIDataTypeChildren" id="753c4580-8501-4268-91b4-bf85726db436">
        <source>getEDIDataTypeChildren(_ediDataType: Integer; _childrenDataTypes: IntegerArray input);
//
// 27 Aug 2014	cnwrs1	Par 34702 - Add support for JMT XML 
//
// 13 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
//18 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
vars

begin
	if (_ediDataType = EDIDataType_GateDocument and
	   self.myTransportManifest &lt;&gt; null) or
	   _ediDataType = EDIDataType_JMTInternal then
		_childrenDataTypes.add(EDIDataType_BookingHeader);
		_childrenDataTypes.add(EDIDataType_Prenote);
		_childrenDataTypes.add(EDIDataType_RequestHeader);
	elseif _ediDataType = EDIDataType_BookingHeader then
		_childrenDataTypes.add(EDIDataType_BookingItem);
	elseif _ediDataType = EDIDataType_BookingItem then	//21 Nov 2016	NDL	TFS 2843 / 2604
		_childrenDataTypes.add(EDIDataType_TIHazDets);
		_childrenDataTypes.add(EDIDataType_ReqBookToDo);	//12 May 2017	NDL	TFS 4263
	elseif _ediDataType = EDIDataType_Prenote then
		_childrenDataTypes.add(EDIDataType_TIHazDets);
		_childrenDataTypes.add(EDIDataType_TISeal);
	elseif _ediDataType = EDIDataType_RequestHeader then
		_childrenDataTypes.add(EDIDataType_RequestDetail);
	elseif _ediDataType = EDIDataType_RequestDetail then
		_childrenDataTypes.add(EDIDataType_RequestCriteria);
		_childrenDataTypes.add(EDIDataType_ReqBookToDo);
	endif;
end;
</source>
        <Parameter name="_ediDataType" type="Integer"/>
        <Parameter name="_childrenDataTypes" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getEDIPartyCoparnRules" id="5068d0d6-21e0-4a13-b2ee-f7fcd3c8970d">
        <source>getEDIPartyCoparnRules(_sender : String) : CM_EDIPartyCoparnRules;
//
//11 Dec 2015	cnwrs1	Par 37402 TFS 1192 MultiLine Release Request
// 09 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
//
vars
	party : CM_EDIParty;
	rule : CM_EDIPartyRules;
begin
	if _sender = null then
		return null;
	endif;
	
	party := self.getMyTerminal().allEDIPartiesBySenderCode[_sender];
	
	if party &lt;&gt; null then
		return party.getRulesForFileType(EDIFileType_Coparn).CM_EDIPartyCoparnRules;
	endif;
epilog

end;</source>
        <Parameter name="_sender" type="String"/>
        <ReturnType type="CM_EDIPartyCoparnRules"/>
    </JadeMethod>
    <JadeMethod name="getEDITIType" id="964f6a03-4854-4da7-9beb-d3017e7d0a65">
        <source>getEDITIType(_ediDataType: Integer): Class;
//
// cnwrs1 sept 2009 CCMS Messina 1008 par21718
//
// 13 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
vars

begin
	if _ediDataType =  EDIDataType_BookingHeader then
		return CM_EDIBookingHeaderTI;
	elseif _ediDataType = EDIDataType_BookingItem then
		return CM_EDIBookingItemTI;
	elseif _ediDataType = EDIDataType_ReqBookToDo then	//06 Oct 2016 NDL TFS 2001 / 2792
		return CM_EDITaskRemarkRelBookTI;
	elseif _ediDataType = EDIDataType_TIHazDets then	//21 Nov 2016	NDL	TFS 2843 / 2604
		return CM_EDIHazDetailsTI;
	elseif _ediDataType =  EDIDataType_Prenote then
		return CM_EDIPrenoteTI;
	elseif _ediDataType =  EDIDataType_TIHazDets then
		return CM_EDIHazDetailsTI;
	elseif _ediDataType =  EDIDataType_TISeal then
		return CM_EDISealTI;
	elseif _ediDataType =  EDIDataType_RequestHeader then
		return CM_EDIRequestHeaderTI;
	elseif _ediDataType = EDIDataType_RequestDetail then
		return CM_EDIRequestDetailTI;
	elseif _ediDataType = EDIDataType_RequestCriteria then
		return CM_EDIRequestCriteriaTI;
	elseif _ediDataType = EDIDataType_ReqBookToDo then
		return CM_EDITaskRemarkRelBookTI;
	endif;
end;
</source>
        <Parameter name="_ediDataType" type="Integer"/>
        <ReturnType type="Class"/>
    </JadeMethod>
