    <JadeMethod name="unPlanMyTIs" id="fd0c39ce-9218-410d-9127-cfd814e7b4f4">
        <source>unPlanMyTIs(theTI : CM_TrackedItem;_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		if this is being erased and it has planned cargo then uplan teh cargo and unattach the cargo from the job.
//
// ---------------------------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state

vars
	theMoveController : CMIF_MoveController;
	ls : Boolean;
	aFutureMove : CM_FutureMove;
	fmIndex : Integer;
	lQEntry : CM_RTQueueEntry;
	aProxyJob : CM_VoyageJob;
begin
	if self.moveType &lt;&gt; NULL_MOVETYPE then
		return;
	endif;
	if theTI = null then
		return;
	endif;
	if theTI.myPrimaryPlannedLocation = null then
		return;
	endif;

	create theMoveController transient;
	theMoveController.setMyWorkListEntry(self.allWorkListEntries.first);

	theMoveController.mySlotRequest := self;
	theMoveController.setMoveMode(PLANNING_MODE);
	theMoveController.setMyTrackedItem(theTI);
	if self.myJob &lt;&gt; null and self.isLoad then
		app.cmsBeginLoad(ls);
		aProxyJob := self.myJob.CM_VoyageJob.pxyCreateUpdateProxy();
		app.cmsEndLoad(ls);

		app.myUtilityUA.utlUpdateWLEUnassignTI(theMoveController, _passport); // this sorts out the job as well
	endif;
	
	delete theMoveController;
	create theMoveController transient;
	theMoveController.setMoveMode(PLANNING_MODE);
	theMoveController.setMyTrackedItem(theTI);
	theMoveController.isFullyUnplan := true;
	theTI.setFMUnplanIndex(self.isLoad,theMoveController);
	
	lQEntry := theTI.getQueueEntry();
	if lQEntry &lt;&gt; null then
		app.myUtilityDA.utlDeleteQueueEntry(lQEntry, false, null, _passport);
	endif;

	app.myUtilityUA.utlUpdateMoveTIUndo(theMoveController, _passport);

epilog
	app.cmsEndLoad(ls);				// 08/04/2011 cnwmh5 #27347
end;</source>
        <Parameter name="theTI" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="unsetTwinLiftFromEraserPen" id="aeff4f44-99a7-43af-bb49-e43c4dd0676b">
        <updating/>
        <source>unsetTwinLiftFromEraserPen() updating;

/*

Purpose:		When using eraser pen on voyage planning need to unset twin lift
				if required.

Parameters:			

Return Value:		


Date		Who		Reason
09 August 2010	cnwmh5	Initial creation #25007

*/

vars

	slot			: CM_SlotRequest;

begin

	// get the appropriate slot request
	slot := self.getAftSlotRequest();
	if slot = null then
		slot := self.getForwardSlotRequest();
	endif;
	
	// don't have aft slot but have forward or have aft slot but not forward
	// then set twin lift attributes to false
	if slot &lt;&gt; null then
		slot.setTwinLift(false, true);
		slot.setTwinLift(false, false);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="update" id="037bb620-f170-42ca-9683-a8377faee317">
        <updating/>
        <source>update(_proxyRequest: CM_SlotRequest) updating;
// ---------------------------------------------------------------------------
// Created:     03 April 2002 by cnwdwq1 
//
// Purpose:     Converted from C++. A MASSIVE headache, this is horrible stuff. DQ 16/4/2002
//This is the old C++ method CM_SlotRequest::set
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 06/06/2002   cnwrs1		rename from setForUpdate in keeping with trx methods

//Comment from DWQ 19/2/03. I dont know if this is still needed, the regime should be that
//the job should look after itself, as should the tracked items at move time.
// ---------------------------------------------------------------------------

vars
	fortyFoot : Boolean;
	colourCodeType : Integer;
	isFirst : Boolean;
	ti : CM_TrackedItem;
	wle : CM_WorkListEntry;
	slotRequest: CM_Request;
begin
	_proxyRequest.raiseExceptionIfNotTransient(method);
	self.raiseExceptionIfTransient(method);

	exclusiveLock(self);
	
	fortyFoot := _proxyRequest.getAttrIs40();
	colourCodeType := self.colorCodeType;
	
	if self.myJob &lt;&gt;  null then
		sharedLock(self.myJob);
		if self.myJob.status = JOB_COMPLETE then
			// for discharge jobs allow updating of attribute fields automatically
			// even if a job is loaded, but do not allow the moveType to change
			if colourCodeType = DischargeColourCode then
				if self.moveType &lt;&gt; _proxyRequest.moveType then
					app.raiseCMException1(ERR_JOB_LOADED, self.myJob.jobId, null, null);
					return;
				endif;
			else
				app.raiseCMException1(ERR_JOB_LOADED, self.myJob.jobId, null, null);
				return;
			endif;
/* PAR 15567 this ELSEIF is the same as the IF above, so it will never be used. This is the only place where the FIXED attribute if read and it is never used.			
		elseif self.myJob.status = JOB_COMPLETE then
			if self.fixed and _proxyRequest.moveType = NULL_MOVETYPE then //redefining
				// if reworking a discharge slot then all ti in this cell are deemed to be
				// dischargeable at this point in time. Therefore clear their receivedDT and deliverdDT
				// fields as these indicate whetehr they have been worked or not. 
				if colourCodeType = DischargeColourCode then
					foreach ti in self.mySlotControllerDischarge.allTrackedItems do
						if self.myJob.jobType = VOYAGEJOB_TYPE_SOB or self.myJob.jobType = VOYAGEJOB_TYPE_LOAD then
							ti.setReceivedDT(null);
						endif;						
						if self.myJob.jobType = VOYAGEJOB_TYPE_SOB or self.myJob.jobType = VOYAGEJOB_TYPE_LOAD then
							ti.setReleasedDT(null);
						endif;
					endforeach;
				endif;
				if self.myJob.jobType = VOYAGEJOB_TYPE_SOB then
					self.myAssociatedJob := null;
				endif;

				//wle-request
				foreach wle in self.allWorkListEntries do
					wle.updateRequest(null);
				endforeach;
				foreach wle in self.associatedWLEs do
					wle.CM_VoyageWLE.setAssociatedRequest(null);
				endforeach;

				//and make definable again
				self.fixed := false;		//remove fixed
				//update job status
				self.myJob.changeStatus(JOB_COMPLETE);
				self.myJob := null;	//job link is now broken
			else
				app.raiseCMException1(ERR_JOB_COMPLETE, self.myJob.jobId, null, null);
				return;
			endif;
			*/
		endif;
	endif;
	/* PAR 15567 FIXED is not set anymore so do not need this
	if self.fixed  and _proxyRequest.moveType &lt;&gt; NULL_MOVETYPE then
		return;
	endif;
	*/

	if _proxyRequest.moveType &lt; DISCHARGE_MOVETYPE or _proxyRequest.moveType &gt; DLR_MOVETYPE then
		//If invalid value, set to null
//		_proxyRequest.moveType := NULL_MOVETYPE;
		app.raiseCMException(ERR_INVALID_MOVETYPE, null, null);
		return;
	endif;

	if colourCodeType &lt;&gt; DischargeColourCode and _proxyRequest.moveType = DISCHARGE_MOVETYPE then
		app.raiseCMException(ERR_INVALID_MOVETYPE, null, null);
		return;
	endif;
  // Clear the structure if the fields are not applicable
	if _proxyRequest.moveType = NULL_MOVETYPE then
		self.setForNullMoveType();
	else
		if colourCodeType = DischargeColourCode then //get the attributes from the ti at this position
			foreach ti in self.mySlotControllerDischarge.allTrackedItems do
				self.setToTrackedItemProperties(ti.CM_Container, isFirst);
			endforeach;
		endif;
	endif;

	if _proxyRequest.moveType = NULL_MOVETYPE and self.myJob &lt;&gt; null then
		slotRequest := self;
		self.myJob.removeRequest(slotRequest);
	endif;

	/* PAR 15567 FIXED is not set anymore so do not need this, plus NULL_MOVETYPE is not used on the slot req so this will never happen
	if _proxyRequest.moveType = NULL_MOVETYPE and self.fixed then	//and make definable again
		self.fixed := false;	 //remove fixed
	endif;
	*/
	self.setMoveType(_proxyRequest.moveType);
	//-----------------------
	//Complain for no reefer/power attributes if LOAD CC
	//-----------------------
	// waterCooled is only valid for integrals so we need power for this slot
	if self.getAttrPowerRequired() or self.getAttrWaterCooled() then
		if self.mySlotDefinition.power = false and colourCodeType = LoadColourCode then
			app.raiseCMException1(ERR_NON_POWER, stowageId, null, null);
			return;
		endif;
	endif;

// PAR7496 AKB2004FEB		if self.reefer then
// PAR7496 AKB2004FEB			if self.slotDefn.reefer = false and colourCodeType = LoadColourCode then
// PAR7496 AKB2004FEB				app.raiseCMException1(ERR_NON_REEFER, stowageId, null, null);
// PAR7496 AKB2004FEB				return;
// PAR7496 AKB2004FEB			endif;
// PAR7496 AKB2004FEB		endif;
	self.unavailable := _proxyRequest.unavailable;
	
	//fire a colour code event after we have done our updates
	if colourCodeType = DischargeColourCode then

		foreach ti in self.mySlotControllerDischarge.allTrackedItems do
			// Ignore worked TI
			if ti.isRehandle then
				if ti.receivedDT.isValid then
					continue;	 // worked
				endif;
			else
				if ti.releasedDT.isValid then
					continue;	 // worked
				endif;
			endif;
			// cnwrs2/cnwdad1 28/04/2010 - PAR #23996: ti.statusEvent signature changed.
			ti.statusEvent(DIS_CCODE_STATUS_EV, true, app.myPassport);
		endforeach;
	endif;
	// else load do nothing
//	self.myBayColourCode.updateEdition(); //cause an explicit update on the parent
end;</source>
        <Parameter name="_proxyRequest" type="CM_SlotRequest"/>
    </JadeMethod>
    <JadeMethod name="updateForCreate" id="5a5e60d5-2446-4673-b0c2-3af500088b22">
        <updating/>
        <source>updateForCreate(_ordinalDeck, _ordinalCell, _ordinalTier : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     14 March 2002 by cnwdwq1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
