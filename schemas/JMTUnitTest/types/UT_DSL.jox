    <JadeMethod name="splitTI" id="4cf91614-64d6-44a2-9ca0-f80be977d564">
        <source>splitTI( _mainTI : CM_TrackedItem ; _tisToCreate : CMIF_TISplitSet);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 April 2010	cnwrd1	Initial creation

*/

vars
	tiToSplit : CM_TrackedItem;
	expectedEdition : Integer;

	cloneTransactions : Boolean;
	reasonCode,
	recoveryCode, 
	comment	: String;
	passport : CM_Passport;
	splitee1, splitee2, splitee3 : CMIF_TISplit;
begin

	cloneTransactions := true;
	
	tiToSplit := _mainTI;		// MASTERPACK
	expectedEdition := tiToSplit.edition();

	passport := app.myPassport;
	
	app.myTrxUA.trxTISplt(tiToSplit, expectedEdition, _tisToCreate,
							cloneTransactions, reasonCode, recoveryCode, 
							comment, passport);
	self.assertNoTrxErrorsOrWarnings();
epilog
	
end;
</source>
        <Parameter name="_mainTI" type="CM_TrackedItem"/>
        <Parameter name="_tisToCreate" type="CMIF_TISplitSet"/>
    </JadeMethod>
    <JadeMethod name="startProfiler" id="6f53b227-2bf3-44dc-95ae-faa98df7cd4a">
        <source>startProfiler(_fileName : String; _prof : JadeProfiler output);
/*

Purpose:	For testing - In progress**		

Parameters:		
		_fileName    			: report file name

Note : Please call 'self.endProfiler(prof)' at the epilog.

Date		Who		Reason
29 November 2024	navsp1	Initial creation UT - Testing

*/

vars
	ts 			: TimeStamp;
begin
	_prof := process.profiler;
	_prof.fileName := app.getAppServerLogDir() &amp; '\tmpFiles\'&amp;_fileName &amp; "_" &amp; ts.formatAsYYYYMMDDHHmmSS &amp; ".log";
	_prof.methodCount := 200;
	//prof.reportCacheStatistics := false;
	_prof.clearMethodCache();
	_prof.reportActualTime := true;
	_prof.reportTotalTime := true;
	_prof.reportLoadTime := true;
	_prof.start;
epilog

end;</source>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_prof" type="JadeProfiler" usage="output"/>
    </JadeMethod>
    <JadeMethod name="sysOpsGetEntTableDef" id="34953a04-bb89-4c9c-baf4-10de147bdd04">
        <source>sysOpsGetEntTableDef(_methodName : String; _class : Class) : Any;

/*

Purpose:		

Date			Who		Reason
28/01/2015		cnwmh5	Initial creation

*/

vars

	sysOpsSchema 			: Schema;
	class 					: Class;
	sysOpsTestAgent 		: Object;
	
	returnValue				: Any;

begin

	sysOpsSchema := rootSchema.getSchema("SysOpsSchema");
	class := sysOpsSchema.getClass("SOP_UnitTestAgent");
	create sysOpsTestAgent as class transient;
	returnValue := sysOpsTestAgent.sendMsgWithParams(_methodName, _class);
	return returnValue;

epilog

	delete sysOpsTestAgent;

end;</source>
