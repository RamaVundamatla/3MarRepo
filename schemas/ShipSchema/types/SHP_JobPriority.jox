    <JadeMethod name="initListBoxAddPriority" id="8d58c918-2aec-43df-86b0-0bd4883079eb">
        <source>initListBoxAddPriority(_jp : CM_JobPriority);
// ---------------------------------------------------------------------------
// Created:		07 April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	list : CMUI_ListBox;
	test : Boolean;
	craneType, priority,jobType : Integer;
	aJP : CM_JobPriority;
	aJPG : CM_JobPriorityGroup;
begin

	list := self.lstJobPriority;
	priority := _jp.priority;
	craneType := _jp.craneType;
	jobType := _jp.jobType;
	
	list.addItem(self.getPriorityDesc(priority));
	list.itemLevel[list.newIndex] := self.LevelPriority;
	list.itemData[list.newIndex] := priority;
	
	create aJPG transient; // PAR 34655
	aJPG.setTypePriority(craneType, jobType, priority); // PAR 34655

	list.itemObject[list.newIndex] := aJPG; // PAR 34655

end;</source>
        <Parameter name="_jp" type="CM_JobPriority"/>
    </JadeMethod>
