    <JadeMethod name="saveUserEntry" id="e301602d-6a24-43d2-8aaf-eebf11c55807">
        <updating/>
        <source>saveUserEntry() updating;
/*
----------   ----------  --------------------------------------------------
Created:	30 April 2007 By cnwth2

Purpose:	called from tree click - self.mySelectedObject is still the prior selected object. 
			Re-implement and update self.mySelectedObject from the entry table(s).
			Make it robust - this is called before many different things happen.
			
			also N.B you may need to update the tree text and/or picture for the entity if
			the user has made input that would change this.

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin


end;


</source>
    </JadeMethod>
    <JadeMethod name="selectObject" id="07c61521-5ad1-413e-abd3-ed824d142aad">
        <updating/>
        <source>selectObject(_obj : CM_Object) updating;
/*
----------   ----------  --------------------------------------------------
Created:	10 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	lst				: CMUI_ListBox;
	listCount,
	foundIdx,
	idx 			: Integer;
begin
	if _obj = null or (not app.isValidObject(_obj)) then
		if self.mode = self.Mode_View then
			self.tblEntry.clearValues();
		endif;
		return;
	endif;
	
	lst := self.lstTree;
	listCount := lst.listCount;
	if listCount &lt; 1 then
		return;
	endif;
	
	foreach idx in 1 to listCount do
		if lst.itemObject[idx] = _obj then
			lst.itemSelected[idx] := true;
			foundIdx := idx;
		else
			lst.itemSelected[idx] := false;
		endif;
	endforeach;
	
	if foundIdx &gt; 0 then
		lst.listIndex := foundIdx;
	endif;
	self.mySelectedObject := _obj;
	self.doTreeClick();
	
end;


</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
