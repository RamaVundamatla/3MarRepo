    <JadeMethod name="doMnuPlanTI" id="18af3d48-1094-4622-bcf5-0de3436e44bb">
        <updating/>
        <source>doMnuPlanTI() updating;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		set self.myCurrentTrackedItem, self.myCurrentWLE and self.myCurrentLocation
//				and this will plan the TI to the location and update the status on the WLE
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	arbiter	: CM_RTQueueArbiter;
	lJob	: CM_Job;
	lWLE, proxyWLE	 : CM_WorkListEntry;
	idx : Integer;
	lTI	: CM_TrackedItem;
	aStr : String;
	lResult : Integer;
	lMoveControl : CMIF_MoveController;
	lTransferArea : CM_TerminalArea;
	rtnValue : Boolean;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
begin
	mousePointer := MousePointer_HourGlass;	

	if self.myCurrentTrackedItem = null or self.myCurrentWLE = null  or self.myCurrentLocation = null then
		app.msgBox("Please select a WLE in the table and then right click the wagon body","Planning", MsgBox_OK_Only);
		return;
	else
		create lMoveControl transient;
		lMoveControl.setMoveMode(PLANNING_MODE);
		lMoveControl.setJobForMove(self.myCurrentWLE.job);		
		lMoveControl.setMyTrackedItem(self.myCurrentWLE.myTrackedItem);
		lMoveControl.setMyToPrimaryLocation(self.myCurrentLocation);
		
		//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxUpdateWLEQueue(self.myCurrentWLE, lMoveControl, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog('Log Ops', app.myPassport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
		
	endif;
epilog 
	mousePointer := MousePointer_Default;	
	if lMoveControl &lt;&gt; null then
		delete lMoveControl;
	endif;
	if proxyWLE &lt;&gt; null then
		delete proxyWLE;
	endif;
end;</source>
    </JadeMethod>
