    <JadeMethod name="pxyCreateUpdateProxy" id="46023dcf-f531-4a4c-a0b1-35f459fc6c23">
        <source>pxyCreateUpdateProxy(): SelfType;
//-----------------------------------------------------------------------
//	Created:	17 October 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxyObj	: SelfType;
	completedOK		: Boolean;
	
begin
	proxyObj	:=	inheritMethod();
	
	proxyObj.code			:=	self.code;
	proxyObj.description	:=	self.description;
	proxyObj.myRoot			:=	self.myRoot;
	
	self.allHarbourRegions.copy(proxyObj.allHarbourRegions);
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyObj;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyObj;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="ceee46ba-4d03-42f8-8438-638dc5a1c102">
        <updating/>
        <source>setForUpdate(_pxyRouteTemplate: HMS_RouteTemplate; _passport: CM_Passport input) updating;
//-----------------------------------------------------------------------
//	Created:	17 October 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------

//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(_pxyRouteTemplate, _passport);
	
	self.code 			:= _pxyRouteTemplate.code.toUpper.trimBlanks;
	self.description 	:= _pxyRouteTemplate.description;
	
	self.allHarbourRegions.clear;
	
	_pxyRouteTemplate.allHarbourRegions.copy(self.allHarbourRegions);
	
	self.myRoot			:= _pxyRouteTemplate.myRoot;

end;</source>
        <Parameter name="_pxyRouteTemplate" type="HMS_RouteTemplate"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="7db68d5d-2843-444c-9993-bae0f3cec2f9">
        <updating/>
        <source>setProxy(_code, _description : String; _allRegions : HMS_HarbourRegionArray; _root : CM_Root)updating;
//-----------------------------------------------------------------------
//	Created:	17 October 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
//------------------------------------------------------
vars
	hr : HMS_HarbourRegion;
begin
	self.raiseExceptionIfNotTransient(method);
	
	self.code	:= _code;
	self.description	:= _description;
	
	self.allHarbourRegions.clear();
	
	if _allRegions &lt;&gt; null then
		foreach hr in _allRegions do
			if hr &lt;&gt; null then
				self.allHarbourRegions.add (hr);
			endif;
		endforeach;
	endif;
	
	
	self.myRoot := _root;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_allRegions" type="HMS_HarbourRegionArray"/>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="5d2d3aa1-0a2f-4b54-b189-7f8ddfe012f7">
        <source>validateMe(_passport: CM_Passport input);
//-----------------------------------------------------------------------
//	Created:	17 October 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------

/*

Date		Who		Reason
28 Mar 2008	cnwkpd1	PAR #16262 - Clarify error message to include name of the default harbour region

*/

vars
	seaHarbourRegion	: HMS_HarbourRegion;

begin
	inheritMethod(_passport);
	
	if self.code = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Code', ETRow_Code, null);
		app.raiseCMException(Input_required_field_code, ETRow_Code, null); // cnwdb2	PAR 35364
	endif;
	if self.description = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Description', ETRow_Description,  null);
		app.raiseCMException(Input_required_field_desc, ETRow_Description,  null); // cnwdb2	PAR 35364
	endif;

	if allHarbourRegions.size &lt; 2 then
		app.raiseCMException2(Must_select_at_least_n, 'two', 'waypoint', ETRow_Description,  null);
	endif;
	
	// par 13641 Must start and end at sea
	// PAR #16262 - Clarify the error message
	seaHarbourRegion := app.myRoot.getSeaHarbourRegion();
	if seaHarbourRegion &lt;&gt; null then
		if allHarbourRegions.first &lt;&gt; seaHarbourRegion or allHarbourRegions.last &lt;&gt; seaHarbourRegion then
			app.raiseCMException1(Must_startend_at_sea, seaHarbourRegion.getDisplayString, ETRow_Description,  null);
		endif;
	endif;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
