    <JadeMethod name="create" id="9762c98a-bc4d-44a7-af6b-41cb606f70a3">
        <updating/>
        <source>create() updating;

begin
	create self.jtdMySummary transient;
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="87228d6c-6abb-4ae9-b4da-3af22dca90b2">
        <updating/>
        <source>delete() updating;

begin
	if self.jtdMySummary &lt;&gt; null and global.isValidObject(self.jtdMySummary) then
		delete self.jtdMySummary;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="jtdClassAndMethodExist" id="609eee02-6bd6-4149-8002-8e56b7392a4e">
        <source>jtdClassAndMethodExist() : Boolean;

vars
	cls : Class;
	
begin
	cls := currentSchema.jtdGetClasses[self.jtdClassName];
	
	if cls = null then
		return false;
	endif;
	
	return cls.jtdGetMethods[self.jtdMethodName] &lt;&gt; null;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jtdDoTransaction" id="9e31e855-e9e8-4fdf-b4dc-d3ef4b84a5d0">
        <source>jtdDoTransaction(invoked : Boolean output; returnResult, exErrCode : Integer output);

vars
	errNo, startRunClock : Integer;
	gen : JtdTransactionGenerator;
	profiling : Boolean;
	jtd : JtdContext;
	runSecs : Real;
	mth : String;
	
begin
	invoked := false;
	returnResult := 0;
	exErrCode := 0;
	
	gen := self.jtdMyTrxGenerator;
	jtd := app.jtdMyContext;
	
	if gen = null or (not global.isValidObject(gen)) then
		return;
	endif;	

	mth := self.jtdMethodName;
		
	if gen.class.rootType.jtdGetMethods[mth] = null then
		return;
	endif;

	profiling := (self.jtdMethodName = jtd.jtdMethodNameToProfile and
		jtd.jtdProfilerOutputFileName &lt;&gt; null);
	
	if profiling then
		// reset the profiler before we start our clocks
		process.profilerReset;
	endif;

	startRunClock := jtd.jtdStartAllClocks;

	if profiling then
		process.profilerStart;
	endif;

	// arm an exception handler around the execution of the user's method
	on Exception do self.jtdInvokeTrxGenMethodExHandler(exception, exErrCode);

	// invoke the transaction
	invoked := true;
	app.controlLockAcquire;
	returnResult := gen.sendMsg(mth).Integer;
	app.controlLockRelease;

	// Disarm our handler on return from the user's method.
	// If an exception occurred, our handler will have resumed to here.
	on Exception do null;
	
	if profiling then
		process.profilerStop;
	endif;
	
	runSecs := (jtd.jtdEndAllRunningClocks - startRunClock) / 1000;
	
	if runSecs &gt; 0 then
		jtd.jtdSetTotalRunSecs(jtd.jtdTotalRunSecs + runSecs);
	endif;

	if profiling then
		errNo := 0;
		on Exception do self.jtdResumeNextExHandler(exception, errNo);
		
		process.profilerReport(jtd.jtdProfilerOutputFileName);
		
		// if an exception occurs saving the profiler info, our handler
		// armed above will resume to here
		on Exception do null;
		
		process.profilerReset;
		profiling := false;

		// tell any controllers that we've taken a profile
		system.causeEvent(jtd.jtdProfileMthResponseEventNo, true, errNo.String &amp;
			';' &amp; jtd.jtdMethodNameToProfile &amp; ';' &amp; jtd.jtdProfilerOutputFileName);
		
		// we only do one-shot method profiles; to profile a method again,
		// the user must request it again from the controller
		jtd.jtdSetMethodNameToProfile(null);
		jtd.jtdSetProfilerOutputFileName(null);
	endif;
			
epilog
	// ensure that in the event of an abnormal exit, profiling doesn't
	// remain enabled beyond the scope of this method
	if profiling then
		process.profilerStop;
		process.profilerReset;
	endif;
end;</source>
        <Parameter name="invoked" type="Boolean" usage="output"/>
        <Parameter name="returnResult" type="Integer" usage="output"/>
        <Parameter name="exErrCode" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="jtdGetPingResponseString" id="8532b393-c292-4364-8f42-57d67b48dbba">
        <source>jtdGetPingResponseString() : String;

begin
	return getOidStringForObject(process) &amp;
		   ';' &amp;
		   self.jtdMethodName &amp;
		   ';' &amp;
		   self.jtdIsUpdateTransaction.String &amp;
		   ';' &amp;
		   self.jtdMySummary.jtdAsString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdInvokeTrxGenMethodExHandler" id="c33918d3-1d2c-45bc-bbe4-ede38eef4559">
        <source>jtdInvokeTrxGenMethodExHandler(ex:Exception; errNo:Integer output):Integer protected;

vars
	dumpStack:JtdDumpStack;
begin
	create dumpStack transient;
	dumpStack.dumpStack(ex);
	errNo := ex.errorCode;
	abortTransaction;
	return Ex_Resume_Next;
epilog
	delete dumpStack;
end;</source>
        <access>protected</access>
        <Parameter name="ex" type="Exception"/>
        <Parameter name="errNo" type="Integer" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jtdUpdateForCreate" id="41e2048a-08fa-4bc7-a6eb-725fde00d096">
        <updating/>
        <source>jtdUpdateForCreate(_clsName, _mthName : String; _gen : JtdTransactionGenerator) updating;

// cannot use these to dispatch inherited methods or subschema copy class methods

vars
	trimmedClassName, trimmedMethodName : String;
	genRootCls : Class;
	
begin
	trimmedClassName := _clsName.trimBlanks;
	if trimmedClassName = null then
		app.jtdMyContext.jtdRaiseJtdException(JtdExNullClassName);
		return;
	endif;

	trimmedMethodName := _mthName.trimBlanks;
	if trimmedMethodName = null then
		app.jtdMyContext.jtdRaiseJtdException(JtdExNullMethodName);
		return;
	endif;
	
	if _gen = null then
		app.jtdMyContext.jtdRaiseJtdException(JtdExNullTrxGen);
		return;
	endif;

	genRootCls := _gen.class.rootType;
	if genRootCls.name &lt;&gt; trimmedClassName then
		app.jtdMyContext.jtdRaiseJtdException(JtdExTrxGenClassNameMismatch);
		return;
	endif;

	if genRootCls.jtdGetMethods[trimmedMethodName] = null then
		app.jtdMyContext.jtdRaiseJtdException(JtdExInvalidMethodForClass);
		return;
	endif;
	
	self.jtdClassName := trimmedClassName;
	self.jtdMethodName := trimmedMethodName;
	self.jtdIsUpdateTransaction := genRootCls.inheritsFrom(JtdUpdateTransactionGenerator);
	self.jtdMyTrxGenerator := _gen;
end;</source>
        <Parameter name="_clsName" type="String"/>
        <Parameter name="_mthName" type="String"/>
        <Parameter name="_gen" type="JtdTransactionGenerator"/>
    </JadeMethod>
    <JadeMethod name="logExceptionDetails" id="aa6c41d9-a229-4a28-9b6d-edf8c437978a">
        <source>logExceptionDetails( pLogFile : JadeLog input; pDetails : String ) protected;

vars

begin
	write pDetails ;
	pLogFile.info( pDetails );
end;</source>
        <access>protected</access>
        <Parameter name="pLogFile" type="JadeLog" usage="input"/>
        <Parameter name="pDetails" type="String"/>
    </JadeMethod>
</Class>
