    <JadeMethod name="tblData_dblClick" id="2d682bfc-f6e3-49a7-a8ab-fd05a94e8f63">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_dblClick(table: Table input) updating;
// -------------------------------------------
// Created 30 November 2005 by cnwdvb1
// -------------------------------------------
vars
theRow	: Integer;
begin

	// TFS 2101 CNWAB1
	if not app.myCurrentUserCan(null, self.permissionMaint) then
		return;
	endif;
	theRow := table.row;
	
	if theRow &lt;= 0 then
		return;
	endif;
	
	if theRow = 1 then
		self.zTblDataResort();
	else
		self.openTiLCTypeMaintForm(true);
	endif;


end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="7080e105-c867-45ed-a213-e7c5c362a5ed">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:44:13.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008192, locale);
	btnCloseSearcher.translateBubbleHelp(Xlat_0005338, locale);
	btnCloseSearcher.translateCaption(Xlat_0005339, locale);
	btnDelete.translateBubbleHelp(Xlat_0005340, locale);
	btnDelete.translateCaption(Xlat_0005341, locale);
	btnDoSearch.translateBubbleHelp(Xlat_0005342, locale);
	btnDoSearch.translateCaption(Xlat_0005343, locale);
	btnEdit.translateBubbleHelp(Xlat_0005344, locale);
	btnEdit.translateCaption(Xlat_0005345, locale);
	btnNew.translateBubbleHelp(Xlat_0005346, locale);
	btnNew.translateCaption(Xlat_0005347, locale);
	btnPrint.translateCaption(Xlat_0005348, locale);
	btnReportOptions.translateBubbleHelp(Xlat_0005349, locale);
	btnReportOptions.translateCaption(Xlat_0005350, locale);
//	btnSearcher.translateBubbleHelp(Xlat_0023324, locale);
//	btnSearcher.translateCaption(Xlat_0023325, locale);
	btnSelectAll.translateBubbleHelp(Xlat_0005351, locale);
	btnSelectAll.translateCaption(Xlat_0005352, locale);
//	btnView.translateBubbleHelp(Xlat_0023326, locale);
//	btnView.translateCaption(Xlat_0023327, locale);
//	lblSearcherCap.translateCaption(Xlat_0023328, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0008193, locale);
	mnuContextTbl.translateCaption(Xlat_0008194, locale);
	mnuInspectObj.translateCaption(Xlat_0008195, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="zTblDataResort" id="7409273b-3f4b-4ff6-ad28-95be6b8f2ab1">
        <updating/>
        <source>zTblDataResort() updating;

vars
	idx,
	startRow,
	endRow,
	sortColNo	: Integer;
	sortColName	: String;
	descending	: Boolean;
	obj			: Object;
begin

	
	sortColNo := tblData.column;
	
	if sortColNo &lt;= 0
	or sortColNo &gt; tblData.columns then
		return;
	endif;
	
	if self.tblData.allTblDataColPropertyNames.size &gt;= sortColNo then	

		sortColName := tblData.allTblDataColPropertyNames[sortColNo];
	endif;

	if sortColName = null then
		app.msgBox(app.getErrorString(Not_Able_To_Sort_By_Column), app.getErrorString(Info), MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
	self.tblData.resortTableByColumn(sortColNo);

	startRow := self.tblData.fixedRows + 1;
	endRow	:= self.tblData.rows;
	foreach idx in startRow to endRow do
		if (idx mod 2 = 0) then
			self.tblData.accessRow(idx).backColor := self.colorRow1;
		else
			self.tblData.accessRow(idx).backColor := self.colorRow2;
		endif;
	endforeach;

end;
</source>
    </JadeMethod>
</GUIClass>
