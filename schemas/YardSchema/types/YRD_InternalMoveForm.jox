    <JadeMethod name="selectISOSource" id="fe072255-f3d1-4ca7-8e5a-b9c07d00b518">
        <updating/>
        <source>selectISOSource()updating, protected;
// called from Advanced button to get CMUI_SelectISOSourceMulti form
vars
	sourceForm	: CMUI_SelectISOSourceMulti;
begin
	
	sourceForm := app.loadForm(CMUI_SelectISOSourceMulti, CMUI_Assistant, false, false, true, self.myTerminal, self.myMasterMenuAction).CMUI_SelectISOSourceMulti;
	sourceForm.centreWindow;
	sourceForm.setMyTerminal(self.myTerminal);
	// keep the sourceForm.allWLEs collection empty so that CMUI_SelectISOSourceMulti will not do the save, as it needs to be
	//  done from here
	sourceForm.myDeliveryRequest := null; //self.myDeliveryRequest;
	sourceForm.setSelectedValues(self.allSelectedTAs, self.allSelectedTAGridObjs, self.isFIFO, self.chkBestPick.getBoolean()); //last item = isBestpick

	sourceForm.showModal;

	if sourceForm.modalDialogReturnValue &lt;&gt; ModalDialogReturn_Default then		// Cancel button pressed
		return;
	endif;
	
	// save the result
	sourceForm.getAreasWithGridObjs( self.allSelectedTAs, self.allSelectedTAGridObjs);
	//sourceForm.mltTermAreas.getSelected(self.allSelectedTAs); 
	self.isFIFO := sourceForm.optFIFO.value;	
	self.chkBestPick.setValue(sourceForm.chkBestPick.value);

	self.txtYardSource.caption := self.getYardSourceText();

epilog
	delete sourceForm;	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setForCreateFromBulkRelease" id="1f979f89-fc00-4fc0-af23-435a139c8193">
