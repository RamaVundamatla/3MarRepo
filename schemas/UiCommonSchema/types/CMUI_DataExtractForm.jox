    <JadeMethod name="doBtnClearClick" id="453f32e9-7a47-4513-87b7-191d062489fb">
        <source>doBtnClearClick() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 April 2011	#cnwdz2	 

*/

vars
	index : Integer;
begin
	index := self.tblExtractClass.fixedRows + 1;
	while index &lt;= self.tblExtractClass.rows do
		self.tblExtractClass.setCellText(index, 1, "0");
		index := index + 1;
	endwhile;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnExtractClick" id="1027bfde-28d9-4957-88a5-4d0e8e093bf0">
        <updating/>
        <source>doBtnExtractClick() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 April 2011	#cnwdz2	 

*/

vars
	folderPath   : String;
	terminal     : CM_Terminal;
	classCol     : CM_DataExtractClassSet;
	index        : Integer;
	fileName,
	filePath     : String;
	date         : Date;
	time         : Time;
	cmifMonitor	 : CMIF_Monitor;
	breakOut 	 : Boolean;
begin
	app.mousePointer := Busy;
	
	folderPath := self.txtDirectory.text;
	if folderPath = null then
		app.msgBox("Please enter a output folder.",app.getErrorString(Error),MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	terminal := self.cmbTerminal.listObject.CM_Terminal;
	if terminal = null then
		app.msgBox("Please select a terminal.",app.getErrorString(Error),MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	create classCol transient;
	index := self.tblExtractClass.fixedRows + 1;
	while index &lt;= self.tblExtractClass.rows do
		if self.tblExtractClass.getCellText(index, 1) = "1" then
			classCol.add(self.tblExtractClass.accessRow(index).itemObject.CM_DataExtractClass);			
		endif;	
		index := index + 1;
	endwhile;	
	
	if classCol.size() = 0 then
		app.msgBox("Please select a data type to be extracted.",app.getErrorString(Error),MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	delete app.myPassport.myCMIFMonitor;
	create cmifMonitor transient;
	app.myPassport.setMyCMIFMonitor(cmifMonitor);
	cmifMonitor.myParent := self;
	self.frmModalDialog.zOrder(1);
	self.lblModalInfo.top := self.lblModalInfo.top - 15;
	self.btnModalOpt2.left	:= self.btnModalOpt1.left + 70;
	self.pbProgressBar.visible := false;
	self.modalDialogShow(null, null, null, app.getErrorString(Cancel), "Extracting Data", cmifMonitor.message);
	//self.lblModalInfo.caption :=  "Extracting...";
	
	delete app.myDataExtractAgent;
	create app.myDataExtractAgent transient;
	
	self.setDataEntryFields(false);
	
	app.myDataExtractAgent.initialise();
	app.myDataExtractAgent.doExtract(terminal, classCol, folderPath, date.formatAsYYYYMMDD(), time.formatAsHHMMSS(), breakOut);	
	app.myDataExtractAgent.finalise();	
	
	if breakOut then
		app.msgBox("Data extraction has been cancelled.", "Extraction Cancelled", MsgBox_Information_Icon);
	endif;
	
epilog
	app.mousePointer := Idle;
	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;
	self.modalDialogReturnValue := null;
	self.setDataEntryFields(true);
	
	delete classCol; 
	delete cmifMonitor;
	if app.myDataExtractAgent &lt;&gt; null and app.myDataExtractAgent.errorOccurred then
		app.msgBox("Error occurred and the extraction has been aborted. For more details, please refer to the log: " &amp; app.myDataExtractAgent.DataDumpLogName, app.getErrorString(Error),MsgBox_Exclamation_Mark_Icon);
	endif;
	delete app.myDataExtractAgent;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnFindClick" id="af47ceb1-6cf4-46d1-89e7-166f8da28de1">
        <source>doBtnFindClick() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 April 2011	#cnwdz2	 

*/

vars
	fileFolder : FileFolder;
	folderPath : String;
begin
	create fileFolder;
	folderPath := fileFolder.browseForFolder(app.getErrorString(BrowseBulkDataLoadFolderCap),null);
	self.txtDirectory.text := folderPath;	
epilog
	delete fileFolder;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initCmbTerminal" id="aa6fad2c-c6f4-44c6-b7ac-d85aadb44b51">
        <source>initCmbTerminal();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 April 2011	#cnwdz2	 

*/

vars
	terminal     : CM_Terminal;
	userTerminal : CM_UserTerminal;
	iter	     : Iterator;
	idx          : Integer;	
begin
	self.cmbTerminal.clear;

	iter := app.getMyUser().allUserTerminals.createIterator();
	while iter.next(userTerminal) do	
		if userTerminal.mySecurityRole.isKindOf(CM_SecurityRoleTerminalRoot) then
			terminal := userTerminal.getRealTerminal();
			idx := self.cmbTerminal.addItem(terminal.name);
			self.cmbTerminal.itemObject[idx] := terminal;
		endif;
	endwhile;
	
	if self.cmbTerminal.listCount &gt; 0 then
		self.cmbTerminal.listIndex := 1;
	endif;
epilog
	delete iter;		// PAR #27874

end;</source>
    </JadeMethod>
    <JadeMethod name="initTblExtractClasses" id="fd9a6df3-b230-40a7-9c7f-78b3610384dd">
        <source>initTblExtractClasses();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 April 2011	#cnwdz2	 

*/

vars
	entTableDef		: EntTableDef;
begin
	self.tblExtractClass.rows := self.tblExtractClass.fixedRows;
	self.tblExtractClass.fixedColumns := 0;
	self.tblExtractClass.leftColumn := 1;	
	
	entTableDef := app.myController.getEntTableDef(ETDef_DataExtractDef);
	self.tblExtractClass.setTblDataEntRowsFromDef(entTableDef);
	
	self.tblExtractClass.sortColumn[1] := 0;
	self.tblExtractClass.sortColumn[2] := 0;
	
	self.tblExtractClass.selectionType := CM_EntryTable.SelectionType_Row;
	self.tblExtractClass.multiSelect := CM_DataTable.MultiSelect_Simple;
	
	self.tblExtractClass.userInputEnabled := true;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="populateDataExtractClass" id="b4e0307a-4c39-4aba-81d3-e526693c800b">
        <source>populateDataExtractClass() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 April 2011	#cnwdz2	 

*/

vars
	classDict : CM_DataExtractClassDict;
	class     : CM_DataExtractClass;
	included  : Boolean;
	lineStr   : String;
	idx       : Integer;
	className : String;
begin
	self.tblExtractClass.allSelectedObjects.clear();
	self.tblExtractClass.rows := self.tblExtractClass.fixedRows;
	//classDict := app.myRoot.allDataExtractClasses;
	classDict := CM_DataExtractRoot.firstInstance.allDataExtractClasses;
	
	//foreach className in CM_DataExtractRoot.firstInstance.dataExtractOrder do
	foreach class in classDict do
		//class := classDict[className];
		included := false;
		
		lineStr := included.cnEcGetTableCheckBoxValue &amp; Tab &amp; 
					class.className;
			
		idx := self.tblExtractClass.addItem(lineStr);
		//self.tblExtractClass.accessCell(idx, 1).itemObject := class;
		//if included then
		self.tblExtractClass.accessRow(idx).itemObject := class;
		//endif;
		self.tblExtractClass.colourRows(self.colorRow1, self.colorRow2);			
	endforeach;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
