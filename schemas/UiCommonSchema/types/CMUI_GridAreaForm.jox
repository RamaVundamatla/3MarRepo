    <JadeMethod name="doUnqueueTI" id="93686165-d92b-463b-ad2e-00292055aa00">
        <updating/>
        <source>doUnqueueTI(_theTI : CM_TrackedItem input; _isOverstow : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		April  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	idx 					: Integer;
	lTI						: CM_TrackedItem;
	aStr					: String;
	lResult					: Integer;
	lMoveControl			: CMIF_MoveController;
	lTransferArea			: CM_TerminalArea;
	lQEntry					: CM_RTQueueEntry;
	wle						: CM_WorkListEntry;
	futureMove				: CM_FutureMove;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
	
begin
	mousePointer := MousePointer_HourGlass;	

	if _theTI = null then
		app.msgBox("Please select a Tracked Item.","Unplanning", MsgBox_OK_Only);
		return;
	else
		create lMoveControl transient;
		lMoveControl.setMoveMode(QUEUE_MODE);
		lMoveControl.setMyTrackedItem(_theTI);
		futureMove := _theTI.setFMUnqueueIndex(_isOverstow,lMoveControl);
		if futureMove &lt;&gt; null then
			lMoveControl.setMyWorkListEntry(futureMove.myWorkListEntry);
		endif;

		lMoveControl.isOverstowMove := _isOverstow;
		
		//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxUA.trxUpdateMoveTIUndo(lMoveControl, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog('Unplan', app.myPassport, ErrWarnMode_AddUpdate);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
			
		endwhile;
		
	endif;
	
epilog 
	if lMoveControl &lt;&gt; null then
		delete lMoveControl;
	endif;
	mousePointer := MousePointer_Default;	
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_isOverstow" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doZoom" id="dc63b565-b255-4379-82ac-c460c061d451">
        <updating/>
        <source>doZoom(pFactor : Real; _theSDF : CMUI_ScrollableDrawingFrame) updating;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     Implement in subclass
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
vars
	posH, posV : Real;
	theHValue, theVValue : Integer;	
	endTime,startTime : TimeStamp;
	thePoints : CMUI_GridPointSet;
	aPoint : CMUI_GridPoint;
	theSDF : CMUI_ScrollableDrawingFrame;
begin

	self.mousePointer := Window.MousePointer_HourGlass;
	theSDF := _theSDF;
	if theSDF = null then
		theSDF := self.sdf01;
	endif;
	
	create thePoints transient;
	theSDF.getAllSelectedPoints(thePoints);
	posH := (theSDF.myHScroll.value / theSDF.myHScroll.max).Real;
	posV := (theSDF.myVScroll.value / theSDF.myVScroll.max).Real;
	

	startTime := app.actualTimeServer;// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	theSDF.doZoom(pFactor);
	self.xmlZoomFactor := pFactor;
	endTime := app.actualTimeServer;// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.frmStatusLine.myFrameCaption.caption := (startTime.cnEcDiff(endTime) / 1000).Integer.String &amp; " Seconds to Zoom";

	aPoint := thePoints.first;
	if aPoint &lt;&gt; null then
		aPoint.getXYOnSDF(theHValue,theVValue);
	else
		theHValue := (theSDF.myHScroll.max * posH).Integer;
		theVValue := (theSDF.myVScroll.max * posV).Integer;
	endif;
	theSDF.myHScroll.value := theHValue;
	theSDF.myVScroll.value := theVValue;
	theSDF.repositionScrollBars();
	
epilog 
	delete thePoints;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="pFactor" type="Real"/>
        <Parameter name="_theSDF" type="CMUI_ScrollableDrawingFrame"/>
    </JadeMethod>
