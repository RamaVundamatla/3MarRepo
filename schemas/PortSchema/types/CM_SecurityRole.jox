    <JadeMethod name="getParentHeirarchyString" id="9a2dfe96-1589-470b-887a-839645e96365">
        <source>getParentHeirarchyString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2014	cnwndl1	Initial creation

*/

vars

	str : String;
	parentHeirarchyStr : String;

begin

	if self.myParentRole = null then
		return null;
	endif;
	
	parentHeirarchyStr := self.myParentRole.getParentHeirarchyString;
	if parentHeirarchyStr &lt;&gt; null then
		return parentHeirarchyStr &amp; "/" &amp; self.myParentRole.name;
	else
		return self.myParentRole.name;
	endif;

epilog

end;</source>
