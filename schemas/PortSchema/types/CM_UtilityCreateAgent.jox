    <JadeMethod name="utlCreateLogOutFile" id="e3aa337f-0fc6-422e-b152-de42bcb3830d">
        <updating/>
        <source>utlCreateLogOutFile(_logRowDownloadArray:CMIF_LogRowDownloadArray; 
			_logFileName : String; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: December 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	logFile	 	: File;
	now			: TimeStamp;
	intFaceRow 	: CMIF_LogRowDownload;
	download 	: CM_LogVoyageRowDownload;
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	if _logFileName = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Log File Name', null, null);
		app.raiseCMException(Input_required_field_logFleNme, null, null); // cnwdb2	PAR 35364
		return;
	endif;	
	
	if _logFileName &lt;&gt; null then
		create logFile transient;
		logFile.fileName := _logFileName;
		logFile.mode := File.Mode_Output;
		logFile.open;
		logFile.purge();
	endif;

	foreach intFaceRow in _logRowDownloadArray do
		download := intFaceRow.myRowDownload;
		exclusiveLock(download);		
		download.downloadLogOutFile(intFaceRow.changesOnly, logFile);
	endforeach;

epilog
	if logFile &lt;&gt; null then
		logFile.close;
		delete logFile;	
	endif;

end;</source>
        <Parameter name="_logRowDownloadArray" type="CMIF_LogRowDownloadArray"/>
        <Parameter name="_logFileName" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
