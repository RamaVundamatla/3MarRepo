    <ImplicitInverseRef name="btnCancel" id="18cd2904-dc81-4e20-9a83-17402818d80f">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="btnOK" id="e2d85d03-9d6f-4bf3-b377-ee04edd2833e">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <PrimAttribute name="integer" id="02a358e4-f576-4bb7-b431-4c38440939cc">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="lblPrompt" id="7a260cea-39c2-46a9-9fd6-4d3db441f7d2">
        <embedded/>
        <type name="Label"/>
    </ImplicitInverseRef>
    <PrimAttribute name="maxValue" id="56610a85-08ff-4d76-9470-8d850ebcdf42">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="minValue" id="99ec1248-ee85-4f62-9fda-a73cc150eceb">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="performRangeChecks" id="faed22ef-56bd-441e-808e-5e423db656b6">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <ImplicitInverseRef name="txbInt" id="51ecec6c-f8ae-422d-8351-f895ad9249c7">
        <embedded/>
        <type name="TextBox"/>
    </ImplicitInverseRef>
    <JadeMethod name="btnCancel_click" id="21af111e-0e14-46b7-aba1-a0726f381579">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;

begin
	self.modalResult := 1;
	self.unloadForm;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnOK_click" id="00eb9359-9140-41bb-b437-a971509f7da1">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOK_click(btn: Button input) updating;

begin
	self.integer := self.txbInt.text.trimBlanks.Integer;
	
	if self.performRangeChecks then
		if self.integer &lt; self.minValue or self.integer &gt; self.maxValue then
			app.errorMsg("Value must be between " &amp; self.minValue.String &amp; " and " &amp;
				self.maxValue.String &amp; " inclusive.", false);
			self.txbInt.setFocus;
			return;
		endif;
	endif;
	
	self.modalResult := 0;
	self.unloadForm;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="load" id="945da387-37bf-4b57-8413-cbd3f2497eba">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

begin
	if self.txbInt.text &lt;&gt; null then
		self.txbInt.selStart := 0;
		self.txbInt.selLength := self.txbInt.text.length;
	endif;
	
	self.centreWindow;
end;</source>
    </JadeMethod>
</GUIClass>
