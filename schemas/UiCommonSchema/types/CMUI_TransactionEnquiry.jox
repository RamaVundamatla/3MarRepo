begin
	// PAR 24016
	table := self.tblCharges;
	if table.row &gt; table.fixedRows then
		anObject := table.accessRow(table.row).itemObject;
		if anObject.isKindOf(CM_CashPayment) then
			receipt := anObject.CM_CashPayment.myCashReceipt;
		endif;
		if receipt &lt;&gt; null then
			//self.myAssistant.showInvoiceLineForm(invoice, self.myMasterMenuAction);
		endif;
	endif;


end;
/*
	receiptForm		: INV_CashReceiptMulti;
begin
	create receiptForm transient;
	receiptForm.myTerminal := self.myTerminal;
