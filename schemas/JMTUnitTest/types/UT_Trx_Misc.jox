    <JadeMethod name="tDebtorType" id="173df8be-06bf-4f53-bb7a-db3fa448aa82">
        <source>tDebtorType();
/*

Purpose:			

Date		Who		Reason
02 November 2015	cnwmk3	Initial creation

*/
constants
  DebtorCode                            : String = "UT_DEBTOR";
  DebtorDescription                     : String = "Created by Unit Test";
vars
    pxyDebtorType			: CM_DebtorType;
	debtorType				: CM_DebtorType;
begin
   // add a debtor type
   debtorType := self.addDebtorType(DebtorCode, DebtorDescription);
   self.assertNotNull(debtorType);
   
   // update a debtor type
   beginLoad;
   pxyDebtorType := debtorType.pxyCreateUpdateProxy();
   endLoad;
   pxyDebtorType.setPropertyValue("isNotAvailableForEntry", true);
   pxyDebtorType.setPropertyValue("description", "Updated by Unit Test");
   app.myTrxUA.trxUpdateDebtorType(pxyDebtorType, app.myPassport);
   self.assertNoTrxErrorsOrWarnings();
   self.assertEqual(debtorType.description, "Updated by Unit Test");
epilog
   delete pxyDebtorType;
end;</source>
    </JadeMethod>
    <JadeMethod name="tDoorDirectionRule" id="d1e436fd-3ffa-4f75-9220-1bbdbd8875f0">
        <source>tDoorDirectionRule();
/*

Purpose:			

Date		Who		Reason
21 October 2015	cnwmk3	Initial creation

*/
constants
   SSArea="SSA00";
   DoorDirectionWords                                                  : String = "UT_DOORDIR";
   Desc                                                                : String = "Door Direction Rule";
vars
   proxyDoorDirectionRule                                              : CM_DoorDirectionRule;
   newDoorDirectionRule                                                : CM_DoorDirectionRule;
   theLocations                                                        : CM_LCSet;
   isoType                                                             : CM_ISOTypeGroup;
   straddleArea                                                        : CM_StraddleStack;
   allObjs                                                             : ObjectArray;
   proxyUpdateDoorDirectionRule                                        : CM_DoorDirectionRule;
   terminalArea                                                        : CM_TerminalArea;
begin
    isoType := app.myRoot.allISOTypeGroups.first.CM_ISOTypeGroup;
	terminalArea := self.getTerminalArea(SSArea);
	if terminalArea &lt;&gt; null then
       newDoorDirectionRule := terminalArea.allDoorDirectionRules[isoType];
    endif;
    if newDoorDirectionRule &lt;&gt; null then
      app.myTrxDA.trxDeleteDoorDirectionRule(newDoorDirectionRule, app.myPassport);
	  self.assertNoTrxErrorsOrWarnings();
    endif;
   
    self.deleteTerminalArea(SSArea);
    // add Terminal Area
	straddleArea:= self.addStraddleStack(SSArea,11,6,2);
	self.assertNotNull(straddleArea);
   
   create theLocations transient;
   create allObjs transient;
   straddleArea.getAllLocationsControllers(allObjs);
   allObjs.copy(theLocations);
   
   create proxyDoorDirectionRule transient;
   proxyDoorDirectionRule.setForProxy(straddleArea, DoorDirectionWords, Desc, Red, isoType);
   app.myTrxCA.trxCreateDoorDirectionRule(proxyDoorDirectionRule, newDoorDirectionRule, theLocations, app.myPassport);
   self.assertNoTrxErrorsOrWarnings();
   
   beginLoad;
   proxyUpdateDoorDirectionRule := newDoorDirectionRule.pxyCreateUpdateProxy();
   endLoad;
   proxyUpdateDoorDirectionRule.setPropertyValue("colour", Green);
   proxyUpdateDoorDirectionRule.setPropertyValue("myISOTypeGroup", newDoorDirectionRule.myISOTypeGroup);
   proxyUpdateDoorDirectionRule.setPropertyValue("myTerminalArea",newDoorDirectionRule.myTerminalArea);
   app.myTrxUA.trxUpdateDoorDirectionRule(proxyUpdateDoorDirectionRule, newDoorDirectionRule, theLocations, app.myPassport);
   self.assertNoTrxErrorsOrWarnings();
epilog
   delete proxyDoorDirectionRule;
   delete theLocations;
   delete allObjs;
   delete proxyUpdateDoorDirectionRule;
end;</source>
    </JadeMethod>
    <JadeMethod name="tEventTypeGroup" id="158098c7-e573-4601-8303-d91e59f67570">
        <source>tEventTypeGroup();
/*

Purpose:			

Date		Who		Reason
09 October 2015	cnwmk3	Initial creation

*/

constants

	EventName               : String = "UT_ET5";
	EName                   : String = "TEST";
	EDescription            : String = "Testing to create Event Group";

vars

	eventType				: CM_EventType;
	pxyEventType			: CM_EventType;
	desc					: String;
	proxyEventGroup         : CM_EventTypeGroup;
	eventGroupName          : CM_EventTypeGroup;
	allEventType            : ObjectArray;

begin

    self.deleteEventType(CM_EventType.VOYAGE_EVENT,EventName);  
	self.assertNoTrxErrorsOrWarnings(); //This was missing and causing it to fail at addEventType when we couldn't even delete it
	
	eventGroupName := app.myRoot.allEventTypeGroups[EName];
	if eventGroupName &lt;&gt; null then
		app.myTrxDA.trxDeleteEventTypeGroup(eventGroupName, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
	// ADD EVENT
	eventType := self.addEventType(CM_EventType.VOYAGE_EVENT ,EventName,"Description: " &amp; EventName,Blue, null);
	self.assertNotNullMsg(eventType, "eventType");
	
	// UPDATE EVENT
	beginLoad;
	pxyEventType := eventType.pxyCreateUpdateProxy();
	endLoad;
 	
	pxyEventType.setPropertyValue("myRoot", eventType.myRoot);
	desc := eventType.description &amp; " - Chg";
	pxyEventType.setPropertyValue("description", desc);
	app.myTrxUA.trxUpdateEventType(pxyEventType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(eventType.description, desc);	
	
	create allEventType transient;
	allEventType.add(eventType);
	
	create proxyEventGroup transient;
	proxyEventGroup.setProxy(EName, EDescription, allEventType, app.myRoot);
	app.myTrxCA.trxCreateEventTypeGroup(proxyEventGroup, eventGroupName, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	delete proxyEventGroup;
	
	beginLoad;
	proxyEventGroup := eventGroupName.pxyCreateUpdateProxy();
	proxyEventGroup.setPropertyValue("myRoot", eventGroupName.myRoot);
	endLoad;
	
	desc := EDescription &amp; " - Chg";
	proxyEventGroup.setPropertyValue("description", desc);
	app.myTrxUA.trxUpdateEventTypeGroup(proxyEventGroup, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(eventGroupName.description, desc);	
	
epilog

	delete allEventType;
	delete pxyEventType;
	delete proxyEventGroup;

end;</source>
    </JadeMethod>
    <JadeMethod name="tExportVesselDetails" id="deed2995-5923-4d5a-a25b-e8950b3b475f">
        <source>tExportVesselDetails();

/*

Purpose:		Export Vessel Details

Date			Who		Reason
30/10/2015	`cnwmh5	Initial creation

*/

vars

	vessel						: CM_Vessel;
	xmlFile						: File;

begin

	vessel := app.myRoot.allVessels["MESDIAM"];
	self.assertNotNull(vessel);
	
	create xmlFile transient;
	xmlFile.fileName := "c:\temp\" &amp; vessel.code &amp; ".xml";
	if xmlFile.isAvailable() then
		xmlFile.purge();
	endif;
	app.myTrxUA.trxExportAsXMLDoc(vessel, xmlFile.fileName, app.myPassport);
	self.assertEqual(self.checkErrorWarningHasOccurred(), false);

epilog

	delete xmlFile;

end;</source>
    </JadeMethod>
    <JadeMethod name="tFPDateTime" id="7608c9db-b8e4-4144-861e-ba8e01c64425">
        <source>tFPDateTime();
/*

Purpose:			

Date		Who		Reason
05 November 2015	cnwmk3	Initial creation
02 Apr 2024	jlirs1	make it work
*/
constants
   FPRemarks                                        : String = "UT Created";
   Desc                                             : String = "UT Updated";
vars
   pxyFPDate, newFPDate, proxyUpdateFPDate          : CM_FinancialPeriodDateTime;
   dateTime                                         : TimeStamp;
   fpEnd, pxyFPEnd, aFPEnd, pxyUpdateFPType         : CM_FinancialPeriodEnd;
   debtors                                          : CM_DebtorNodeByNameDict;
begin
// delete financial period time/period 
	dateTime.setDateTime(2015, 11, 05, 14, 19, 0, 0);
	aFPEnd := app.myRoot.myRootCompany.allFinancialPeriods[FPRemarks];
	if aFPEnd &lt;&gt; null then
		app.myTrxDA.trxDeleteFPType(aFPEnd, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
	aFPEnd := app.myRoot.myRootCompany.allFinancialPeriods[Desc];
	if aFPEnd &lt;&gt; null then
		newFPDate := aFPEnd.allFinancialPeriodEndDates[dateTime];
	endif;
	if newFPDate &lt;&gt; null then
		app.myTrxDA.trxDeleteFPDateTime(newFPDate, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;

// delete financial period type
   aFPEnd := app.myRoot.myRootCompany.allFinancialPeriods[Desc];
   if aFPEnd &lt;&gt; null then
        app.myTrxDA.trxDeleteFPType(aFPEnd, app.myPassport);
   endif;

// create financial period type
   create pxyFPEnd transient;
   pxyFPEnd.setProxy(FPRemarks, false);
   app.myTrxCA.trxCreateFPType(pxyFPEnd, aFPEnd, app.myPassport);
   self.assertNoTrxErrorsOrWarnings();
   
// update financial period type
   beginLoad;
   pxyUpdateFPType := aFPEnd.pxyCreateUpdateProxy();
   endLoad;
   create debtors transient;
   pxyUpdateFPType.setPropertyValue("description", Desc);
   app.myTrxUA.trxUpdateFPType(pxyUpdateFPType,debtors, app.myPassport);
   self.assertNoTrxErrorsOrWarnings();
   
// create financial period date/time   
   create pxyFPDate transient;
   fpEnd := app.myRoot.myRootCompany.allFinancialPeriods[Desc];
   pxyFPDate.setProxy(dateTime, FPRemarks, fpEnd);
   app.myTrxCA.trxCreateFPDateTime(pxyFPDate,newFPDate,app.myPassport);
   self.assertNoTrxErrorsOrWarnings();
 
// update financial period date/time 
   beginLoad;
   proxyUpdateFPDate := newFPDate.pxyCreateUpdateProxy();
   endLoad;
   proxyUpdateFPDate.setPropertyValue("myFinancialPeriodEnd", newFPDate.myFinancialPeriodEnd);
   proxyUpdateFPDate.setPropertyValue("remarks", "Updated by UT");
   app.myTrxUA.trxUpdateFPDateTime(proxyUpdateFPDate, app.myPassport);
   self.assertNoTrxErrorsOrWarnings();
   
epilog
   delete pxyFPDate;
   delete proxyUpdateFPDate;
   delete pxyFPEnd;
   delete debtors;
   delete pxyUpdateFPType;
end;</source>
    </JadeMethod>
    <JadeMethod name="tFaultType" id="75620c2f-285a-420f-aec2-b75eb16c4986">
        <source>tFaultType();
/*

Purpose:			

Date		Who		Reason
15 October 2015	cnwmk3	Initial creation

*/
constants
   FaultCode                          : String = "Test01";
   FaultDescription                   : String = "Test Fault Type";
   EmailRecipint                      : String = "mkaur@jadeworld.com";
   EmailSubject                       : String = "Test Email";
   EmailBody                          : String = "This is an auto generated email";
   Desc                               : String = "Fault Type is Updated";
vars
   faultType                          : CM_FaultType;
   proxyFaultType                     : CM_FaultType;
   proxyUpdatefaultType               : CM_FaultType;
begin
    
	faultType := app.myRoot.allFaultTypes[FaultCode];
	if faultType &lt;&gt; null then
		app.myTrxDA.trxDeleteFaultType(faultType, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
	create proxyFaultType transient;
	proxyFaultType.setProxy(FaultCode, FaultDescription, EmailRecipint, null, null, EmailSubject, EmailBody);
	self.assertNotNull(proxyFaultType);
    app.myTrxCA.trxCreateFaultType(proxyFaultType, faultType, app.myPassport);
	
	beginLoad;
	proxyUpdatefaultType := faultType.pxyCreateUpdateProxy();
	endLoad;
	proxyUpdatefaultType.setPropertyValue("description", Desc);
	app.myTrxUA.trxUpdateFaultType(proxyUpdatefaultType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(faultType.description, Desc);
	
epilog
    delete proxyFaultType;
	delete proxyUpdatefaultType;
end;</source>
    </JadeMethod>
    <JadeMethod name="tFileTypeUser" id="5b13d8f9-8121-48e2-8eee-bf85e56361ad">
        <source>tFileTypeUser();
/*

Purpose:			

Date		Who		Reason
15 October 2015	cnwmk3	Initial creation

*/
constants
	FileTypeName                               : String = "UT_Type";
vars
    fileTypeUser                               : CM_EDIFileTypeUser;
	pxyFileTypeUser                            : CM_EDIFileTypeUser;
	pxyUpdateFileTypeUser                      : CM_EDIFileTypeUser;
	emailSearch                                : StringArray;
begin
    // delete FileType if already exists
    fileTypeUser := app.myRoot.allEDIFileTypes[EDIFileType_UserDefined, FileTypeName].CM_EDIFileTypeUser;
	if fileTypeUser &lt;&gt; null then
		// if it does exist then delete it.
		app.myTrxDA.trxDeleteEDIFileTypeUser(fileTypeUser, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
    
	// create FileType
	create emailSearch transient;
	emailSearch[1] := "SearchText";
    
	create pxyFileTypeUser transient;
	beginTransaction;
	pxyFileTypeUser.setProxy(FileTypeName,DelimiterType_Comma, ",", EDIDateFormat_YYYYMMDD, "/", BayPlan, 2, false, null, false, null, emailSearch, null, null);
	commitTransaction;
    
	app.myTrxCA.trxCreateEDIFileTypeUser(fileTypeUser, pxyFileTypeUser, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// Update FileType
	
	beginLoad;
	pxyUpdateFileTypeUser := fileTypeUser.pxyCreateUpdateProxy();
	endLoad;
	
	pxyUpdateFileTypeUser.setPropertyValue("dateDelimeter", ".");
	app.myTrxUA.trxUpdateEDIFileTypeUser(pxyUpdateFileTypeUser, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog
    delete pxyUpdateFileTypeUser;
	delete pxyFileTypeUser;
	delete emailSearch;
end;</source>
    </JadeMethod>
    <JadeMethod name="tHazardousFlag" id="95da0bce-3619-4ac8-96a6-4253edda9473">
        <source>tHazardousFlag();
/*

Purpose:			

Date		Who		Reason
08 December 2015	cnwmk3	Initial creation

*/

vars
	tiHazLmtd					: CM_TrackedItem;
	proxyTI						: CM_TrackedItem;
	hazard						: CM_TIHazard;
	hazColl						: CM_HazardByCodeDict;
begin
//	Set The Terminal config [Hazardous -Use Detailed Hazardous Entry Screen ] to true
	self.setTerminalConfig("UseDetailedHazEntry", true);
	
//	Add Container
	self.deleteContainer("TEST0000003");
	tiHazLmtd := self.addContainerOpts("TEST0000003", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	
//	Add hazardous child cargo to container
	addTIHazard(tiHazLmtd, "1.0", false);
	self.assertTrueMsg(tiHazLmtd.isHazardous, "tiHazLmtd is not hazardous");
	self.assertEqual(tiHazLmtd.isHazardous, true);
	
//	Add another hazardous child cargo to container
	addTIHazard(tiHazLmtd, "2.1", false);
	self.assertTrueMsg(tiHazLmtd.isHazardous, "tiHaz is not hazardous");
	
//	Remove the first child cargo
	beginTransaction;
	tiHazLmtd.allTIHazards.first.erase(NORMAL_ERASE);
	commitTransaction;
	hazColl := tiHazLmtd.allTIHazards;
	self.assertNotNull(hazColl.first);
	self.assertEqual(hazColl.size, 1);

//	isHazardous should be still true
	self.assertEqual(tiHazLmtd.isHazardous, true);
	
//	Remove the second child cargo
	beginTransaction;
	tiHazLmtd.allTIHazards.first.erase(NORMAL_ERASE);
	commitTransaction;
	hazColl := tiHazLmtd.allTIHazards;
	self.assertNull(hazColl.first);
	
//	It should now set the isHazardous to false
	self.assertEqual(tiHazLmtd.isHazardous, false);
	
epilog
	self.setTerminalConfig("UseDetailedHazEntry", false);
end;</source>
    </JadeMethod>
    <JadeMethod name="tITSInterfaceRequest" id="f54ebe93-a317-41d9-ab5d-69cde71a3b14">
        <source>tITSInterfaceRequest();
/*

Purpose:			

Date		Who		Reason
09 November 2015	cnwmk3	Initial creation

*/
constants
   DefName                               : String = "ITS Interface Server";
vars
   proxyRequest                          : CM_ITSInterfaceReqAddQEntry;
   realRequest                           : CM_ITSInterfaceRequest;
   queueEntry                            : CM_RTQueueEntry;
   forkLift                              : CM_Machine;
   tas                                   : StringArray;
   queue                                 : CM_RadioTelemetryQueue;
   
   moveRequest                           : CM_YardDeliveryRequest;
   sourceBays                            : CM_GridObjectArray;
   forkStack                             : CM_ForkLiftStack;
   blockStack                            : CM_BlockStack;
   operator                              : CM_Operator;
   configMTStrategy                      : Integer;
   ti1, ti2                              : CM_TrackedItem;
   interfaceDef                          : CM_TCPInterfaceDefinition;
   proxyInterfaceDef                     : CM_ITSInterfaceDefinition;
   proxyResponse                         : CM_ITSInterfaceResponse;
   realResponse                          : CM_ITSInterfaceResponse;
   task                                  : CM_RTQueueTask;
   taMaster                              : CM_TerminalAreaMaster;
begin
// delete interface definition if already exist
    interfaceDef := self.getTerminal().allInterfaceDefinitions[DefName].CM_TCPInterfaceDefinition;
	if interfaceDef &lt;&gt; null then 
        app.myTrxDA.trxDeleteInterfaceDefinition(interfaceDef, app.myPassport);
	    self.assertNoTrxErrorsOrWarnings();
	endif;
   
// add terminal areas and queue
    forkStack := self.addForkLiftStack("UTFKS", 4,5,2);
	blockStack := self.addBlockStack("UTBS1", 100, null);
	operator :=  self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	queue := self.addQueueToTA("UTFRKSQ", forkStack);
	
// add containers and move to the added terminal areas
	self.opts.purge();
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_STORAGE);
	ti1 := self.addContainerOpts("UTTEST0001", "2200", "MT", operator);	
	move(ti1, self.getGridLocation(forkStack, 1, 1));
	ti2 := self.addContainerOpts("UTTEST0002", "2201", "MT", operator);		
	move(ti2, self.getGridLocation(forkStack,1, 1));
	
// add a move job
	create sourceBays transient;  
	moveRequest := self.moveDirector("UTYJ17", 1, operator.code, "2200", forkStack, sourceBays, blockStack); 
	assertEqual(moveRequest.allWorkListEntries.first.allRTQueueEntries.first.allTasks.first.getSourceLocationId, "UTFKS");
	
// add a forklift machine, assign to queue
	create tas transient;
	tas.add("UTFKS");
	tas.add("UTBS1");
	tas.add("UTFKS1");
	tas.add("UTFKS2");

	self.addMachineRule (forkStack, blockStack, RTMoveMethod_24);  // Forklift
	forkLift := self.addForkLift("UTF1", 91, tas, "UTFRKSQ");
	self.machineAssignToQueue(forkLift, queue);
	self.machineLogon(forkLift);
	
	queueEntry := moveRequest.allWorkListEntries.first.allRTQueueEntries.first;
   
// add interface definition
   create proxyInterfaceDef transient;
   proxyInterfaceDef.setITSProxy(DefName,1,"11",11,11,11,app.myRoot.allLocales.first, self.getTerminal(),"","","", 2, 11);
   app.myTrxCA.trxCreateInterfaceDefinition(proxyInterfaceDef, interfaceDef, app.myPassport);
   self.assertNoTrxErrorsOrWarnings();
   
// send a request to interface
   create proxyRequest transient;
   proxyRequest.setProxy(queueEntry, interfaceDef.CM_ITSInterfaceDefinition);
   app.myTrxCA.trxCreateITSInterfaceRequest(proxyRequest, realRequest, app.myPassport);
   
// response to the request
   create proxyResponse transient;
   task := queueEntry.allTasks.first;
   self.assertNotNull(task);
   proxyResponse.setProxyForQueueEntry(task, true, null, forkLift, interfaceDef.CM_ITSInterfaceDefinition);
   app.myTrxCA.trxCreateITSInterfaceResponse(proxyResponse, realResponse, null, app.myPassport);
   self.assertNoTrxErrorsOrWarnings();
   
// acknowledge that the request is processed
   app.myTrxUA.trxITSInterfaceMessageComplete(realRequest, app.actualTimeServer(), app.myPassport);
   self.assertNoTrxErrorsOrWarnings();
epilog
   self.machineLogOff(forkLift);
   delete sourceBays;
   delete proxyInterfaceDef;
   delete proxyRequest;
   delete proxyResponse;
   delete tas;
end;</source>
    </JadeMethod>
    <JadeMethod name="tImportFile" id="863e7100-f197-4a36-b565-02cfd376442d">
        <source>tImportFile();

/*

Purpose:		trxImportISOTypeFromFile

Date			Who		Reason
03/07/2015		cnwmh5	Initial creation

*/

vars

	file						: File;
	consigneeNor				: CM_ConsigneeConsignor;
	debtor						: CM_Debtor;
		
	code						: String;
	debtorCode					: String;
	
begin
	
	debtorCode := "UT_MDHDebtorZ";
	self.deleteDebtor(debtorCode);
	
	file := self.xDebtorNodeImportFile(debtorCode);
	file.kind := File.Kind_Unknown_Text;

	app.myTrxCA.trxImportDebtorNodeFromFile(file, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	debtor := app.myRoot.myRootCompany.debtors[debtorCode];
	self.assertNotNull(debtor);
	
	delete file;
	
	app.writeLog("Importing Consignee / Consignor.  Please wait...", LogINFO);
	code := "UTMH1";
	self.deleteConsigneeConsignor(code);	
	file := self.xConsigneeNorImportFile(code, debtorCode);
	file.kind := File.Kind_Unknown_Text;
	
	app.myTrxCA.trxImportConsignoreeFromFile(file, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	consigneeNor := self.getConsignee(code);
	self.assertNotNull(consigneeNor);
	
epilog

	delete file;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tInvoiceStatusReason" id="11ab8d21-9560-429a-a1fc-67e12cff2390">
        <source>tInvoiceStatusReason();
/*

Purpose:			

Date		Who		Reason
21 October 2015	cnwmk3	Initial creation

*/
constants
    ReasonCode                                     : String = "UT_REASON";
	ReasonDescription                              : String = "Invoice status is pending";
vars
    proxyReason                                    : CM_InvoiceStatusReason;
	realReason                                     : CM_InvoiceStatusReason;
	terminal                                       : CM_Terminal;
	proxyUpdateReason                              : CM_InvoiceStatusReason;
	
	desc                                           : String;
begin
    terminal := self.getTerminal();
	realReason := terminal.allInvoiceStatusReasons[ReasonCode];
	if realReason = null then
      create proxyReason transient;
	  proxyReason.setProxy(ReasonCode, ReasonDescription, false, self.getTerminal());
      app.myTrxCA.trxCreateInvoiceStatusReason(proxyReason,realReason,app.myPassport);
	  self.assertNoTrxErrorsOrWarnings();
	endif;
	
	beginLoad;
	proxyUpdateReason := realReason.pxyCreateUpdateProxy();
	endLoad;
	desc := "Invoice status is updated";
	proxyUpdateReason.setPropertyValue("description", desc);
	app.myTrxUA.trxUpdateInvoiceStatusReason(proxyUpdateReason,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
epilog
    delete proxyReason;
	delete proxyUpdateReason;
end;</source>
    </JadeMethod>
    <JadeMethod name="tLocalUserLogin" id="3f1eab73-118b-44c4-8b74-67b217036017">
        <source>tLocalUserLogin();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 Dec 2025 navlc30 JIRA 36748 CUX - Enforce SSO Login

*/

constants
	MyPassword						: String = "u^1tTest1";
	MyPassword2						: String = "u^1tTest2";
vars

	securityRoleSystem				: CM_SecurityRoleSystem;
	securityRoleTerminal			: CM_SecurityRoleTerminal;
	user							: CM_User;
	passport						: CM_Passport;	
	result							: Integer;

begin
	// create security role
	securityRoleSystem := self.addSecurityRole(true, "UTMDHSYS").CM_SecurityRoleSystem;
	self.assertNotNull(securityRoleSystem);
	securityRoleTerminal := self.addSecurityRole(false, "UTMDHTER").CM_SecurityRoleTerminal;
	self.assertNotNull(securityRoleTerminal);

	// update security role
	app.myPassport.setWarningsIgnored(true);
	self.updateSecurityRole(securityRoleSystem);
	self.assertEqual(securityRoleSystem.mySecurityRoleVisibility.availableToShippingCompany, false);
	app.myPassport.setWarningsIgnored(false);
	
	// create user
	self.opts.purge();
	self.opts.addAssoc("SysSecurityRole", securityRoleSystem);
	self.opts.addAssoc("UserPassword", MyPassword);
	user := self.addUser("UTMDH2", "UTMDH2");
	self.assertNotNull(user);
	
	// Set Enforced SSO Login to True
	self.setSystemConfig(SsoEnforceSingleSignOn, true);
	
	// update the user password
	app.myTrxUA.trxUpdatePassword(false, user.code, MyPassword, MyPassword2, MyPassword2, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
		
	// log user on
	// Expect the system to throw an Error ERR_LOCAL_LOGIN_DISABLED on login
	passport := app.myPassport;
	result := app.myTrxUA.trxUpdateLogon(user.code, MyPassword2,null, passport);
	self.assertEqual(ERR_LOCAL_LOGIN_DISABLED,result); 

	// Set the Allow Local MTN Login Enabled for the user
	beginTransaction;
	user.setLocalMTNLoginAllowed(true);
	commitTransaction;
	
	// log user on
	// Expect the user to login successfully
	passport := app.myPassport;
	result := app.myTrxUA.trxUpdateLogon(user.code, MyPassword2,null, passport);
	self.assertNoTrxErrorsOrWarnings();

	
epilog
	beginTransaction;
	user.setLocalMTNLoginAllowed(false);
	commitTransaction;
	self.setSystemConfig(SsoEnforceSingleSignOn, false);
end;</source>
    </JadeMethod>
    <JadeMethod name="tMiscellaneousTrxs" id="0919f070-6995-4d42-957c-6d808e72adb3">
        <source>tMiscellaneousTrxs();

/*

Purpose:		Miscellaneous trx's

				trxUpdateCargoFreeStorageDays
				trxUpdateTrackedItemsBatch
				trxUpdateReeferConnectList
				

Date			Who		Reason
22/06/2015		cnwmh5	Initial creation
"
*/

vars

	obj								: Object;
	ti								: CM_Container;
	pxyTI							: CM_Container;
	bs								: CM_BlockStack;
	powerPoint						: CM_GapController;

	tiSet							: CM_TISet;
	tiSetLoc						: ObjectSet;
	tiArray							: CM_TIArray;
	
	connectTS						: TimeStamp;
	
begin

	
	app.myTrxUA.trxUpdateCargoFreeStorageDays(self.getTerminal(), null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	
	
	create tiArray transient;
	create tiSet transient;
	
	bs := self.addBlockStack("UTMHBSO", 20, null);
	self.assertNotNull(bs);
	self.opts.purge();
	self.opts.addAssoc("ReturnTIs", true);
	self.addQuickCargo(bs, null, (bs.maxCapacity / 2).Integer, tiArray);
	
	foreach obj in tiArray do
		ti := obj.CM_Container;
		pxyTI := app.createUpdateProxy(ti).CM_Container;
		pxyTI.setPxyFromNamedFields("NZLYT", CM_TrackedItem::destinationPort.name);
		pxyTI.setPxyFromNamedFields("NZNSN", CM_TrackedItem::dischargePort.name);
		tiSet.add(pxyTI);
	endforeach;
	
	app.myTrxUA.trxUpdateTrackedItemsBatch(tiSet, TI_UPDMODE_NORMAL, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	foreach obj in tiArray do
		ti := obj.CM_Container;
		self.assertEqual(ti.destinationPort, "NZLYT");
		self.assertEqual(ti.dischargePort, "NZNSN");
	endforeach;
	
	
	foreach obj in tiSet do
		delete obj;
	endforeach;
	delete tiSet;
	
	tiArray.clear();
	self.opts.purge();
	self.opts.addAssoc("ISOType", "2231");
	self.opts.addAssoc("Commodity", "FZBU");
	self.opts.addAssoc("ReturnTIs", true);
	self.addQuickCargo(bs, null, 5, tiArray);
	
	create tiSet transient;
	foreach obj in tiArray do
		ti := obj.CM_Container;
		if ti.isoType &lt;&gt; "2231" then
			continue;
		endif;
		connectTS := ti.receivedDT;
		self.updateTIConnection(ti, true, true, connectTS, powerPoint);
		tiSet.add(ti);
	endforeach;
	
	app.myTrxUA.trxUpdateReeferConnectList(tiSet, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(self.getTerminal().allReeferConnectTIs.size, 5);

epilog
	
	if tiSet &lt;&gt; null then
		tiSet.clear();
	endif;
	delete tiSet;
	delete tiSetLoc;
	tiArray.clear();
	delete tiArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="tMoveTI" id="0e01189d-cf2e-43bc-a9c2-5808d10ff039">
        <source>tMoveTI();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2015	cnwmk3	Initial creation

*/

constants
	STADArea="ST600";
	CNTR="UT19102015";
	
vars
	moveController                     : CMIF_MoveController;
	straddleArea                       : CM_StraddleStack;
	ti		                           : CM_TrackedItem;
	primLC, targetLC                   : CM_GridController;
	tis                                : CM_TISet;
begin

	// delete TerminalArea and Container if already exist
	self.deleteTerminalArea(STADArea);
	self.deleteContainer(CNTR);
	
	// add Terminal Area
	straddleArea:= self.addStraddleStack(STADArea,11,6,2);
	self.assertNotNull(straddleArea);
	
	// add container
	ti := self.addContainer(CNTR, self.getOperator("APL"),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.assertNotNull(ti);
	
	// move container to a known location
	//self.move(ti, straddleArea.allGridControllersByRowColumn[2, 1]);
	
	// move container to a new target location
	create moveController transient;
	targetLC := straddleArea.allGridControllersByRowColumn[2, 6];
	moveController.setMyToPrimaryLocation(targetLC);
	
	create tis transient;
	tis.add(ti);
	app.myTrxUA.trxMoveTrackedItems(tis, moveController,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(ti.myPrimaryActualLocation.ident,"020006");
	
	// container unplanned
	moveController.setMoveMode(PLANNING_MODE);
	app.myTrxUA.trxUpdateMoveTIsUndoForMode(tis, PLANNING_MODE, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
epilog
	delete moveController;
	delete tis;
end;</source>
    </JadeMethod>
    <JadeMethod name="tMoveTIDefer" id="e30745fd-6cd2-4f10-9cce-b637084ec585">
        <source>tMoveTIDefer();
/*

Purpose:to validate whether the CM_Move transactions are correctly added to the CM_Terminal::allTITransactions dict as the defer updates functionality is newly added to trxUpdateMoveTIsUndoForMode 			

Parameters:			

Return Value:		

Date		Who		Reason
24 Feb 2025	navbs1	Initial creation Bug MTN-28384: MTN - Un Plan Cargo items Doesn't use Deferred Updates 

*/

constants
	STADArea1="ST600";
	BSName="UTBS10";
	CNTR="UTCNTR28384";
	
vars
	moveController                     : CMIF_MoveController;
	straddleArea					   : CM_StraddleStack;
	bs 								   : CM_BlockStack;
	ti		                           : CM_TrackedItem;
	targetLC                   		   : CM_GridController;
	tis                                : CM_TISet;
	tiTrans,
	moveTrans						   : CM_TITransaction;
begin

	// delete TerminalArea and Container if already exist
	self.deleteTerminalArea(STADArea1);
	self.deleteTerminalArea(BSName);
	self.deleteContainer(CNTR);
	
	// add Terminal Area
	straddleArea:= self.addStraddleStack(STADArea1,11,6,2);
	self.assertNotNull(straddleArea);
	
	bs := self.addBlockStack( BSName, 32, null);	
	self.assertTrueMsg( bs &lt;&gt; null, BSName &amp; " block stack not created");
	
	// add container
	ti := self.addContainerAtLocation(CNTR, self.getOperator("APL"),"2200", "MT", TI_IMEX_STATUS_STORAGE,bs);
	self.assertNotNull(ti);
	tiTrans := ti.allTransactions.last;
	assertTrue(tiTrans.isKindOf(CM_Move));
	assertEqual(tiTrans.getMoveTargetLocn,"UTBS10");
	assertTrue(tiTrans.CM_Move.mode = REAL_MODE);
	
	// plan a  container to a new target location
	create moveController transient;
	targetLC := straddleArea.allGridControllersByRowColumn[2, 6];
	moveController.setMyToPrimaryLocation(targetLC);
	moveController.setMoveMode(PLANNING_MODE);
	
	create tis transient;
	tis.add(ti);
	app.myTrxUA.trxMoveTrackedItems(tis, moveController,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(ti.plannedLocnId,"ST600 020006 1");
	tiTrans := ti.allTransactions.last;
	assertTrue(tiTrans.isKindOf(CM_Move));
	assertEqual(tiTrans.getMoveTargetLocn,"ST600 020006 1");
	assertTrue(tiTrans.CM_Move.mode = PLANNING_MODE);
	
	// unplan the container 
	moveController.setMoveMode(PLANNING_MODE);
	app.myTrxUA.trxUpdateMoveTIsUndoForMode(tis, PLANNING_MODE, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	//check for CM_Move transactions 
	tiTrans := ti.allTransactions.last;
	
	assertTrueMsg(tiTrans.isKindOf(CM_Move),"CM_Move transaction is not generated for trackedIItem");
	assertTrue(tiTrans.CM_Move.unplan);
	
	//check for this transaction in CM_Terminal::allTITransactions
	moveTrans := self.getTerminal.allTITransactions[tiTrans.dateTime,tiTrans.type];
	assertNotNullMsg(moveTrans,"CM_Move transaction is not found in terminal TITransactions dictionary");
	assertTrueMsg(tiTrans = moveTrans ,"The CM_Move transaction is not the expected one");

epilog
	delete moveController;
	delete tis;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPackage" id="4b2b6334-be49-4520-b42c-3a95148ab487">
        <source>tPackage();

/*

Purpose:		

Date			Who		Reason
18/06/2015		cnwmh5	Initial creation

*/

vars

	package					: CM_PackageInvoice;
	
	oa 						: ObjectArray;
	
	description				: String;
	packageName				: String;

begin

	packageName := 'UT invoice package ' &amp; app.getUTAdminUserCode();
	
	package := app.myRoot.allPackages[PackageInvoicePost, packageName].CM_PackageInvoice;
	self.deletePackage(package);
	
	create oa transient;
	
	package := self.createPackage(PackageInvoicePost, packageName, packageName, 
		app.getBitbucketEmailAddress(), null, null, "Test Invoice", "Invoice attached", app.getMyUser(), oa).CM_PackageInvoice;
	self.assertNotNull(package);
	
	description := "Unit Test invoice package";
	self.opts.purge();
	self.opts.addAssoc("Description", description);
	self.updatePackage(package);
	self.assertEqual(package.description, description);
	
epilog

	delete oa;

end;</source>
    </JadeMethod>
    <JadeMethod name="tPreNoteDateTransaction" id="912c3130-7f56-4ee6-9a56-5ba201c36122">
        <source>tPreNoteDateTransaction();
/*

Purpose:			

Date		Who		Reason
19 November 2015	cnwmk3	Initial creation

*/
constants
	PrenoteId							: String = "UTPRENOTE01";
vars
	ti									: CM_TrackedItem;
	pxyPreNote							: CM_TrackedItem;
	ifArray								: CMIF_TIObjectArray;
	ifPreNote							: CMIF_PreNote;
	date								: Date;
	tiTrx								: CM_TITransaction;
begin
	// delete prenote if exists already
	ti := self.getTrackedItem(PrenoteId);
	if ti &lt;&gt; null then
		deleteTrackedItem(ti, false);
	endif;
	
	// add prenote
	ti := self.addPrenoted(PrenoteId);
	self.assertNotNull(ti);	
	
	// update expectedArrivalDate of Prenote
	beginLoad;
	pxyPreNote := ti.pxyCreateUpdateProxy();
	endLoad;
	date := date + 5;
	pxyPreNote.setPropertyValue("expectedArrivalDate", date);
	app.myTrxUA.trxUpdateTrackedItem (pxyPreNote, null, TI_UPDMODE_NORMAL, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// check that edit transaction is created for Date changed
	tiTrx := ti.allTransactions.last;
	self.assertTrue(tiTrx.isKindOf(CM_Edit));
	assertEqual(tiTrx.id, PrenoteId);
	assertEqual(tiTrx.typeString, "Edited");
epilog
	delete ifArray;
	delete ifPreNote;
	delete pxyPreNote;
end;</source>
    </JadeMethod>
    <JadeMethod name="tProductGroup" id="bcea9898-b079-4228-a8ec-f10089daa74d">
        <source>tProductGroup();
/*

Purpose:			

Date		Who		Reason
09 November 2015	cnwmk3	Initial creation

*/
constants
   ID                              : String = "UT01";
   Desc                            : String = "Created by UT";
vars
   productGroup                    : CM_ProductGroup;
   cargoType                       : CM_CargoType;
   proxyProductGroup               : CM_ProductGroup;
begin
   cargoType := app.myRoot.allCargoTypesById.first;
// delete product group if already exists   
   productGroup := cargoType.allProductGroups[ID];
   if productGroup &lt;&gt; null then
         self.deleteProductGroup(ID, cargoType);
   endif;
// add a product group   
   productGroup := self.addProductGroup(ID, Desc, cargoType);
   
// update a product group
   beginLoad;
   proxyProductGroup := productGroup.pxyCreateUpdateProxy();
   endLoad;
   proxyProductGroup.setPropertyValue("description", "Updated by UT");
   proxyProductGroup.setPropertyValue("colour", Red);
   app.myTrxUA.trxUpdateProductGroup(proxyProductGroup, app.myPassport);
   self.assertNoTrxErrorsOrWarnings();
epilog
   delete proxyProductGroup;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRailMisc" id="bb52d977-c99e-48a9-9f4d-47a44df63657">
        <updating/>
        <source>tRailMisc() updating;

/*

Purpose:	

				Client
				======
				trxUpdateWagonFromCMIF					Done
				trxUpdateWagonConfirm					Done
				trxUpdateWagonsConfirmOut				Done
				trxUpdateWagonController				Done
				trxMoveTrackedItemsNewRailJob			Done
				trxUpdateWagonRailAlloc					Done
				trxDeleteRailAllocsForWagons			Done
				trxUpdateWagonInTransit					Done
				trxDeleteWagons							Done
				
				Non Client
				==========
				trxCreateWagon							Done
				trxImportWagonClassFromFile				Done
				trxSwapWagonCargoPositions				Done
				trxUnAssignWleFromWagon					Done
				trxUpdateRailSettings					Done
				trxUpdateTrainsRemarks					Done
				trxUpdateWagonConfirmRailLine			Done
				trxUpdateWagonDeparture					Done			
				trxUpdateWagonRakePositionSwap			Done
				trxUpdateWagonRemarks					Done
				trxUpdateWagonTrackedItem				Done

Date			Who		Reason
10 April 2014	cnwmh5	Initial creation
17 Aug	 2022	jlika1	TFS 53741 - EUP- Max Wagon Payload
*/

constants
	
	TrainCode 						: String = "UTTRAINMH1";
	WagonCodeId						: String = "UTMH";
	WagonClassCode					: String = "UTMH";
	RailAreaId 						: String = "UTJMHA1";
	NoWagons						: Integer = 10;
	RailLineId						: String = "UTJMHRL";
	
vars
	
	train							: CM_Train;
	railArea 						: CM_Rail;
	wagon 							: CM_Wagon;
	wagonClass 						: CM_WagonClass;
	operator 						: CM_Operator;
	wagonMaster 					: CM_WagonMaster;
	wagonPosition 					: CMIF_TIWagonPosition;
	tmpController 					: CM_WagonController;
	moveControl						: CMIF_WagonMoveController;
	yaRailConfig					: CM_YARailConfig;
	pxyWagonClass					: CM_WagonClass;
	
	wagonArray						: CM_WagonArray;
	wagonSet						: CM_WagonSet;
	opCriteria 						: CM_YACriteriaTypeArray;
		
	index							: Integer;
	remarks							: String;
	confirmedInCount				: Integer;
	confirmedOutCount				: Integer;
	origRequiresImportOperatorPIN	: Boolean;
	
begin

	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	origRequiresImportOperatorPIN := operator.getConfig(RequiresImportOperatorPIN).Boolean;		// 30/04/2014 cnmwh5
	beginTransaction;
	operator.setConfig (RequiresImportOperatorPIN, false);
	commitTransaction;
	
	self.deleteRailArea(RailAreaId);
	
	wagonClass := app.myRoot.allWagonClasses[WagonClassCode];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
		foreach index in 1 to NoWagons step 1 do
			wagonMaster	:=	self.getRoot.allWagonMasters[WagonCodeId &amp; index.String.padLeadingZeros(2)];
			if wagonMaster &lt;&gt; null then
				self.deleteWagonMasterAndWagons(wagonMaster);
			endif;
		endforeach;
	endif;
	
	self.deleteTrain(TrainCode, null);
	train := self.addTrain(TrainCode,null);
	self.assertNotNull(train);
	
	remarks := "Updated train remarks: " &amp; app.cnGetServerTime().String;
	app.myTrxUA.trxUpdateTrainRemarks(train, remarks, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(train.remarks, remarks);
	
	railArea := self.addRailArea(RailAreaId, 4, 11);
	self.assertNotNull(railArea);
	self.assertNotEqual(railArea.allRailLines, 0);
	
	self.opts.purge();
	self.opts.addAssoc("RailLine", railArea.allRailLines.first);
	wagonClass := self.addWagonClass(WagonClassCode);
	foreach index in 1 to NoWagons - 1 step 1 do
		wagon := self.addWagonInRailArea(WagonCodeId &amp; index.String.padLeadingZeros(2), WagonClassCode, railArea, train);
		self.assertNotNull(wagon);
	endforeach;
	
	wagon := self.addWagon(WagonCodeId &amp; index.String.padLeadingZeros(2), WagonClassCode, train);
	
	remarks := "Updated Wagon Remarks: " &amp; app.cnGetServerTime().String;
	app.myTrxUA.trxUpdateWagonRemarks(wagon, remarks, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(wagon.remarks, remarks);
	
	// update the wagon using CMIF
	self.opts.purge();
	self.opts.addAssoc("WagonRemarks", "Remarks updated: " &amp; app.cnGetServerTime().String);
	self.xUpdateWagonFromCMIF(train);
	
	// trxUpdateWagonController
	index := 0;
	while index &lt;= 0 do
		index := wagon.allLocationsControllersArray.size - 4;
	endwhile;
	tmpController := wagon.allLocationsControllersArray[index].CM_WagonController;
	create wagonPosition transient;
//	wagonPosition.myTrackedItem := null;
	wagonPosition.available := true;
	wagonPosition.hasTwistLocks := true;
	wagonPosition.twistLocksAreUp := false; 
	wagonPosition.position := tmpController.myWagon.allLocationsControllersArray.indexOf(tmpController);
	app.myTrxUA.trxUpdateWagonController(tmpController.myWagon, wagonPosition, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(wagon.allLocationsControllersArray[index].CM_WagonController.isAvailable, true);
	self.assertEqual(wagon.allLocationsControllersArray[index].CM_WagonController.hasTwistlocks, true);
	
	// trxUpdateWagonRakePositionSwap
	self.xUpdateWagonRakePositionSwap(train);
	
	// trxUpdateWagonConfirm - in
	create wagonArray transient;
	create moveControl transient;
	
	index := 0;
	foreach wagon in train.allWagonsByIdInward do 
		index := index + 1;
		if index mod 2 = 0 and not wagon.confirmed then
			wagonArray.add(wagon);
		endif;	
	endforeach;
	self.assertEqual(wagonArray.size, 5);
	app.myTrxUA.trxUpdateWagonConfirm(wagonArray, true, moveControl, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	index := 0;
	foreach wagon in train.allWagonsByIdInward do 
		index := index + 1;
		if index mod 2 = 0 then
			self.assertEqual(wagon.confirmed, true);
		else
			self.assertEqual(wagon.confirmed, false);
		endif;	
	endforeach;
	
	// add cargo to wagons
	self.xAddCargoToWagons(train);	
	
	// rail configuration setup
	create opCriteria transient;
	self.xRailConfigSetup(opCriteria, yaRailConfig);
	
	// trxUpdateWagonRailAlloc
	self.xUpdateWagonRailAlloc(train);
	
	
	// trxUpdateWagonConfirm - in
	wagonArray.clear();
	train.allWagonsByIdInward.copy(wagonArray);
	app.myTrxUA.trxUpdateWagonConfirm(wagonArray, true, moveControl, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	foreach wagon in train.allWagonsByIdInward do
		self.assertEqual(wagon.confirmed, true);
	endforeach;
	
	// Jobs trx's
//	self.xWagonJobs(train); // Commented out NDL 26 Aug 2020 TFS 49950 - This was trying to unassign outward jobs that were alreday
	//complete and finding the inward ones and doing those because of bad data in the test. Two other tests do this properly so not needed here..

	// trxUpdateWagonTrackedItem
	self.xUpdateWagonTrackedItem(train);
	
	// trxUpdateWagonInTransit
	self.xUpdateWagonInTransit(train);
	
	// trxSwapWagonCargoPositions
	self.xSwapWagonCargoPositions(train);
	
	
	// trxUpdateWagonsConfirmOut
	wagonArray.clear();
	index := 0;
	foreach wagon in train.allWagonsByIdInward do 
		index := index + 1;
		if index mod 2 = 0 then
			wagonArray.add(wagon);
		endif;	
		if index &gt; 7 then
			break;
		endif;
	endforeach;
	self.assertEqual(wagonArray.size, 4);
	app.myTrxUA.trxUpdateWagonsConfirmOut(null, wagonArray, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	index := 0;
	confirmedInCount := 0;
	confirmedOutCount := 0;
	wagonArray.clear();
	foreach wagon in train.allWagonsByIdInward do 
		if wagon.confirmed then
			confirmedInCount := confirmedInCount + 1;
		endif;
		if wagon.confirmedOutwards then
			confirmedOutCount := confirmedOutCount + 1;
		endif;
		if not wagon.confirmed then
			wagonArray.add(wagon);
		endif;
	endforeach;
	self.assertEqual(confirmedInCount, 10);
	self.assertEqual(confirmedOutCount, 4);
	
	// trxUpdateWagonDeparture
	self.xUpdateWagonDeparture(train);	
	
	// trxUpdateRailSettings
	self.xUpdateRailSettings();
	
	// trxUpdateWagonConfirmRailLine
//27 Aug 2020	NDL	TFS 49950 - This call was pointless all the wagons are already confirmed inwards
//	app.myTrxUA.trxUpdateWagonConfirmRailLine(railArea.allRailLines.first, false, app.myPassport);
//	self.assertNoTrxErrorsOrWarnings();
//	foreach wagon in train.allWagonsByIdInward do
//		self.assertEqual(wagon.confirmed, true);
//	endforeach;
	
	// import wagon class from file
	self.xImportWagonClass();
	
	// 25/05/2015 cnwmh5 - trxUpdateWagonMaster
	wagonClass := app.myRoot.allWagonClasses[WagonClassCode];
	self.assertNotNull(wagonClass);
	pxyWagonClass := app.createUpdateProxy(wagonClass).CM_WagonClass;
	pxyWagonClass.setPropertyValue("tareWeight","1500.00".Decimal);
	app.myTrxUA.trxUpdateWagonClass(pxyWagonClass, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	/* jlika1 TFS 53741 This is no longer a valid test case as the Wagon Master is savings it's own maxCargoWeight and Tare Weight
	self.opts.purge();
	self.opts.addAssoc("PropogatesChanges", 1);
	wagonMaster	:=	self.getRoot.allWagonMasters[WagonCodeId &amp; 1.String.padLeadingZeros(2)];
	self.updateWagonMaster(wagonMaster);
	self.assertEqualMsg(wagonMaster.getTareWeight(), "1500.00".Decimal, "Wagon Master Tare Weight");
	*/
	
	// trxDeleteWagons
	create wagonSet transient;
	wagonArray.copy(wagonSet);
	app.myTrxDA.trxDeleteWagons(wagonSet, false, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(train.allWagonsByIdInward.size, 10);
	
	//finished clean up
	self.deleteRailArea(RailAreaId);
	wagonClass := app.myRoot.allWagonClasses[WagonClassCode];
	if wagonClass &lt;&gt; null then
		self.deleteWagonClassAndWagons(wagonClass);
		foreach index in 1 to NoWagons step 1 do
			wagonMaster	:=	self.getRoot.allWagonMasters[WagonCodeId &amp; index.String.padLeadingZeros(2)];
			if wagonMaster &lt;&gt; null then
				self.deleteWagonMasterAndWagons(wagonMaster);
			endif;
		endforeach;
	endif;
	
	
epilog

	// 30/04/2014 cnwmh5 - Reset to original value
	beginTransaction;
	operator.setConfig (RequiresImportOperatorPIN, origRequiresImportOperatorPIN);
	commitTransaction;

	self.opts.purge();
	self.opts.addAssoc("OpCriteria", opCriteria);
	self.updateYARailConfig(yaRailConfig);
	if opCriteria &lt;&gt; null then
		if not opCriteria.isEmpty() then
			opCriteria.clear();
		endif;
	endif;
	delete opCriteria;

	delete wagonSet;
	delete wagonPosition;
	delete wagonArray;
	delete moveControl;
	delete pxyWagonClass;
	self.deleteTrainAndAssociatedObjs(train);
end;</source>
    </JadeMethod>
    <JadeMethod name="tReceiveContainerWithToDoTask" id="b8628bbe-36d5-43a4-ba1d-bc9aa3d415b3">
        <updating/>
        <source>tReceiveContainerWithToDoTask()updating;
/*

Purpose:			

Date		Who		Reason
22 October 2015	cnwmk3	Initial creation

*/
constants
    ShortDesc                       : String = "UT_10101";
	ToDoTaskCode                    : String = "UT_10101";
	ChildDesc						: String = "UT_10102";
	ChildTaskCode					: String = "UT_10102";
vars
	booking                         : CM_BookingRef;
	ti                              : CM_TrackedItem;
	vvr                             : CM_VehicleVisitRecord;
	voyage1                         : CM_Voyage;
	vessel                          : CM_Vessel;
	tiSet                           : CM_TISet;
	toDoTaskDesc                    : CM_ToDoTaskDesc;
	child                           : CM_TrackedItem;
	childtoDoTaskDesc				: CM_ToDoTaskDesc;
	childTiSet						: CM_TISet;
begin
	deleteContainer("UUT00000001");
	self.deleteBooking("UT_BOOKING01");
	deleteVoyage("UTVOY01");
	deleteVessel("UT_VESSEL101");
	self.deleteVehicle("UT_MAT");
	
	
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[ToDoTaskCode];
	 if toDoTaskDesc &lt;&gt; null then
	    self.deleteToDoTaskDescription(toDoTaskDesc);
	 endif;
     
	 // create a ToDo task
	 toDoTaskDesc := self.createToDoTaskDesc(ToDoTaskCode);
	 self.assertNotNullMsg(toDoTaskDesc, "Add To Do Task failed");
	
	vessel := addVesselCellular("UT_VESSEL101", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNull(vessel);
	voyage1 := addVoyageWithContainerStructur("UTVOY01", "UT_VESSEL101", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	assertNotNull(voyage1);

	
	booking := self.addBookingForContainer("UT_BOOKING01", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage1, "NZAKL", "2200", "MT");
	assertNotNull(booking);
	
	ti := self.addPrenotedContainer(booking.allBookingRefItems.first,  "UUT00000001");
	
	// add child cargo with todo task
	childtoDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[ChildTaskCode];
	 if childtoDoTaskDesc &lt;&gt; null then
	    self.deleteToDoTaskDescription(childtoDoTaskDesc);
	 endif;
     
	 // create a ToDo task for child
	 childtoDoTaskDesc := self.createToDoTaskDesc(ChildTaskCode);
	 self.assertNotNullMsg(childtoDoTaskDesc, "Add To Do Task failed");
	
	child := self.addContainer("UT_CHILD01", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "GENL", TI_IMEX_STATUS_STORAGE);
	beginTransaction;
	ti.attachChild(child, app.myPassport);
	commitTransaction;
	
	// add ToDo task to child cargo
	 create childTiSet transient;
	 childTiSet.add(child);
	 childtoDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[ChildDesc];
	 assertNotNull(childtoDoTaskDesc);
	 self.addToDoTask(childtoDoTaskDesc, childTiSet);
	
	// add ToDo task to cargo
	 create tiSet transient;
	 tiSet.add(ti);
	 toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[ShortDesc];
	 assertNotNull(toDoTaskDesc);
	 self.addToDoTask(toDoTaskDesc, tiSet);

	 vvr := self.gateInContainer("UT_MAT", "UUT00000001", "2200", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code, "GENL", 
		self.getProfileSetting(UT_Profile.P_SGATE).asString);
	 self.assertNotNull(vvr);
	 
	ti := self.getTrackedItem("UUT00000001");
	self.assertEqual(ti.allToDoTasksToDo.size, 1);
	self.assertEqual(ti.allToDoTasksToDo.first.toDoTaskDesc, toDoTaskDesc);
	
	child := self.getTrackedItem("UT_CHILD01");
	self.assertEqual(child.allToDoTasksToDo.size, 1);
	self.assertEqual(child.allToDoTasksToDo.first.toDoTaskDesc, childtoDoTaskDesc);
	
epilog
   delete tiSet;
   delete childTiSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseWLE" id="7c6270d5-bad9-468c-aa51-0b030d09622f">
        <source>tReleaseWLE();

/*

Purpose:		trxUpdateReleaseWLEQty

Date			Who		Reason
26/06/2015		cnwmh5	Initial creation

*/

vars

	releaseRequest					: CM_BulkRelease;
	blockStack						: CM_BlockStack;
	vvr								: CM_VehicleVisitRecord;
	deliveryRequest					: CM_DeliveryRequest;
	
	tiArray							: CM_TIArray;
	
	totalRequested					: Integer;
	changeBy						: Integer;

begin
	
	create tiArray transient;

	// create the road release request
	self.deleteReleaseRequest("UTMHROADREL2");
	self.opts.purge();
	self.opts.addAssoc("Number", 3);
	self.opts.addAssoc("ISOType", "UT20");
	self.opts.addAssoc("CreateDeliveryRequest", true);
	releaseRequest := self.addReleaseByTypeRequestOpts("UTMHROADREL2", BR_TYPE_ROAD, TI_CargoType_Container);
	self.assertNotNull(releaseRequest);
	self.assertFalse(releaseRequest.requests.isEmpty);
	
	// create the block stack for the containers
	self.deleteTerminalArea("UTMHBSO");
	blockStack := self.addBlockStack("UTMHBSO", 10, null);
	self.assertNotNull(blockStack);
	self.opts.purge();
	self.opts.addAssoc("ReturnTIs", true);
	self.addQuickCargo(blockStack, null, 5, tiArray);
	
	self.deleteVehicle("UTMHT2");
	self.opts.purge();
	self.opts.addAssoc("release", releaseRequest);
	vvr := self.gateOutContainer("UTMHT2", "", "", tiArray[1].CM_Container, true, 
		self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString), null);
	self.assertNotNull(vvr);
	
	self.deleteStops(tiArray[1]);
	
	deliveryRequest := releaseRequest.requests.first.CM_DeliveryRequest;
	self.assertNotNull(deliveryRequest);
	beginTransaction;
	deliveryRequest.setJob(vvr.getMyJob());
	commitTransaction;
	changeBy := 1;
	totalRequested := deliveryRequest.totalRequested + changeBy;
	
	app.myTrxUA.trxUpdateReleaseWLEQty(deliveryRequest, changeBy, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(deliveryRequest.totalRequested, totalRequested);
	

epilog

	delete tiArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="tRoadJobMisc" id="69ddd101-6362-4fed-a35a-4102c506a080">
        <source>tRoadJobMisc();

/*

Purpose:		

				trxUpdateKPITruck						Done
				trxCreateRoadJob						Done

Date			Who		Reason
12/02/2014		cnwmh5	Initial creation

*/
constants

	TruckID					: String = "UTMH01";
	TruckID2				: String = "UTMH02";
	TiID					: String = "UTMDH010001";
	TiID2					: String = "UTMDH010002";
	
vars

	vehicle					: CM_Vehicle;
	roadJob					: CM_RoadJob;
	carrier					: CM_Carrier;
	controller				: CMIF_KPITruckTurnaround;
	terminal				: CM_Terminal;
	vvr						: CM_VehicleVisitRecord;
	ti						: CM_TrackedItem;
	
	pinEmailAddresses		: CM_EmailEntityByTypeNameDict;
		
begin

	// get terminal
	terminal := self.getTerminal();

	// create a carrier
	create pinEmailAddresses transient;
	carrier := self.addCarrier("UTMHCR1", "Michaels UT Carrier", pinEmailAddresses, true, false, true, null);
	self.assertNotNull(carrier);
	
	// gate in a container
	self.opts.purge();
	//self.opts.addAssoc("DoNotCreateRoadJob", true);
	self.deleteTrackedItem(self.getTrackedItem(TiID), false);
	self.deleteVehicle(TruckID);
	self.gateInContainer(TruckID, TiID, "2200", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, "GENL", 
		self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString));
	
	vehicle := self.getVehicle(TruckID);
	self.assertNotNull(vehicle);
	
	// create app.myKPIAgent
	app.createKPIAgent();
	self.assertNotNull(app.myKPIAgent);
	
	// create CMIF_KPITruckTurnaround
	create controller transient;
	controller.myTerminal := terminal;
	controller.setPropertyValue("myVehicleVisit", vehicle.getCurrentVisit());
	app.myKPIAgent.processController(controller);
	self.assertNoTrxErrorsOrWarnings();
	
	// create road job
	self.opts.purge();
	self.opts.addAssoc("DoNotCreateRoadJob", true);
	self.deleteTrackedItem(self.getTrackedItem(TiID2), false);
	self.deleteVehicle(TruckID2);
	self.gateInContainer(TruckID2, TiID2, "2200", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, "GENL", 
		self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString));
	
	vehicle := self.getVehicle(TruckID2);
	self.assertNotNull(vehicle);
	
	// create the road job
	roadJob := self.createRoadJob(vehicle);
	self.assertNotNull(roadJob);

epilog

	delete app.myKPIAgent;
	delete controller;
	delete pinEmailAddresses;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tShift" id="4d084e9e-e003-43ab-b0b0-7fcc3f36734d">
        <source>tShift();

/*

Purpose:		

Date			Who		Reason
17/06/2015		cnwmh5	Initial creation

*/

vars

	shiftStd			: CM_ShiftStd;
	terminal			: CM_Terminal;
	pxyShiftStd			: CM_ShiftStd;
	shiftEntity			: CM_ShiftEntity;
	
	startT				: Time;
	endT				: Time;
	code				: String;
	desc				: String;
	shiftDay 			: Integer;
		
begin

	terminal := self.getTerminal();
	self.assertNotNull(terminal);
	
	startT.setTime(07, 00, 00, 00);
	endT.setTime(15, 00, 00, 00);
	code := "AM";
	desc := "Morning Desc";
	shiftDay := 1;
	
	shiftStd := terminal.allShiftsStandard[shiftDay, startT];
	if shiftStd &lt;&gt; null then
		app.myTrxDA.trxDeleteShift(shiftStd, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
	create pxyShiftStd transient;
	pxyShiftStd.setProxy(shiftDay, startT,	endT, code, desc, terminal, false);
	
	app.myTrxCA.trxCreateShift(pxyShiftStd, app.myPassport, shiftEntity);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(shiftEntity.description, desc);
	
	// update the description
	delete pxyShiftStd;
	desc := "Morning";
	beginLoad;
	pxyShiftStd := shiftEntity.pxyCreateUpdateProxy().CM_ShiftStd;
	endLoad;
	pxyShiftStd.setPropertyValue("description", desc);
	pxyShiftStd.setPropertyValue("myTerminal", shiftEntity.CM_ShiftStd.myTerminal);
	app.myTrxUA.trxUpdateShift(pxyShiftStd, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(shiftEntity.CM_ShiftStd.description, desc);
	

epilog

	delete pxyShiftStd;

end;</source>
    </JadeMethod>
    <JadeMethod name="tStockOrder" id="ea866b10-1f0b-463f-b663-748dd12e4d2a">
        <source>tStockOrder();

/*

Purpose:		

Date			Who		Reason
19 June 2015	cnwmh5	Initial creation

*/
constants

	VesselId						: String = "UTMHMISC";
	VoyageId						: String = "UTMHMISC";
	ReleaseNo						: String = "UTMDHREL01";
	
vars

	pxyStockHeader					: CM_StockOrderHeaderGeneric;
	stockHeader						: CM_StockOrderHeader;
	operator						: CM_Operator;
	terminal						: CM_Terminal;
	terminal2						: CM_Terminal;
	voyage							: CM_Voyage;
	oldVessel						: CM_Vessel;
	vessel							: CM_Vessel;
	
	orderDate						: Date;
	
begin

	operator := app.myRoot.allOperators["UTOP"];
	self.assertNotNull(operator);

	terminal := self.getTerminal();
	
	terminal2 := app.myRoot.allTerminals["JBL"];
	self.assertNotNull(terminal2);
	
	// delete cloned vessel
	self.deleteVessel(VesselId);
	
	// clone vessel
	oldVessel := app.myRoot.getVesselByName("Jolly Diamante OFFICIAL");
	self.assertNotNull(oldVessel);
	
	// clone the vessel
	vessel := self.cloneVessel(VesselId, oldVessel);
	self.assertNotNull(vessel);
	
	self.deleteVoyage(VoyageId);	
	voyage := self.addVoyageWithContainerStructur(VoyageId, VesselId, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString());
	self.assertNotNull(voyage);
	
	
	stockHeader := terminal.allStockOrderHeaders[StockOrderHeaderType_Domestic, operator, ReleaseNo];
	if stockHeader &lt;&gt; null then
		self.deleteStockOrder(stockHeader);
	endif;	
	
	create pxyStockHeader transient;
	pxyStockHeader.setProxy(null, operator, terminal, voyage, app.cnGetServerTime().date, null, ReleaseNo, 0, null, StockOrderHeaderType_Domestic, 
		Process_Direct_Loadout, true, false, terminal2, app.getMyUserCode);
		
	app.myTrxCA.trxCreateStockOrder(pxyStockHeader, stockHeader, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	delete pxyStockHeader;
	
	beginLoad;
	pxyStockHeader := stockHeader.pxyCreateUpdateProxy().CM_StockOrderHeaderGeneric;
	endLoad;
	pxyStockHeader.setPropertyValue("isAudit", false);
	pxyStockHeader.setPropertyValue("isTransfer", true);
	
	app.myTrxUA.trxUpdateStockOrder(pxyStockHeader, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(stockHeader.isTransfer, true);
	self.assertEqual(stockHeader.isAudit, false);

epilog

	delete pxyStockHeader;

end;</source>
    </JadeMethod>
    <JadeMethod name="tTFS55381" id="cca2f7bd-e775-4c4d-b333-56570cd1a1aa">
        <source>tTFS55381();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Nov 2022	navma1	ChangeRequest 55381: MTN - Store format's decimal precision on Measurement Type

*/

vars
	mT : CM_MeasurementType;
begin

	self.deleteMeasurementType('UT'&amp;UT_DSL.TFS55381);
	mT := self.createMeasurementType(9,14.8,false,false,false,false,'UT'&amp;UT_DSL.TFS55381,Type_Weight,'UT'&amp;UT_DSL.TFS55381);
	self.assertNotNullMsg(mT, "Measurement type UTMWeight not created");
	self.assertTrueMsg(mT.formatPrecision = 8,"format Precision is not correct ");
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tTIItemsLCL" id="063d9afa-2756-4f83-b8a8-0afe227eba8c">
        <source>tTIItemsLCL();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 October 2015	cnwmk3	Initial creation

*/

vars

	parentCont					: CM_Container;
	location					: CM_BlockStack;
	ti                          : CM_TrackedItem;
	prenote                     : CMIF_PreNote;
	intFaceArray                : CMIF_TIObjectArray;
	loc                         : CM_LocationsController;
	cargoType					: CM_CargoType;
	
	hazard : CM_Hazard;
	newHazard : CM_Hazard;
	row : Integer;
	
begin

	// create a parent container
	
	location := self.addBlockStack("BS02", 50, null);
	self.assertNotNull(location);
	parentCont := self.addContainerAtLocation("MK0810A0001", app.myRoot.allOperators["UTOP"], "2200", "GENL", TI_IMEX_STATUS_IMPORT, location);
	self.assertNotNull(parentCont);
	
	// add cargo to parent container
	
	cargoType := self.getCargoType("CANNON");
	self.assertNotNull(cargoType);
		
	// delete a prenote if already exists
	
	ti := self.getTrackedItem("MK0810A0002");
	self.deleteTrackedItem(ti, false);
	ti := self.getTrackedItem("MK0810A0002");
	self.assertNull(ti);
	
	self.opts.purge();
	self.opts.addAssoc("CargoType", cargoType.id);
	
	// create prenote from TI
	
	ti := self.addPrenoted("MK0810A0002");
	self.assertNotNull(ti);
	
	create prenote transient;
	prenote.setFromTI(ti, self.getTerminal());
	
	
	create intFaceArray transient;
	intFaceArray.add(prenote);
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(WARN_BOOKING_REF);
	self.expectedTrxErrors.add(ERR_PRENOTE_ID_EXISTS);
	
	// call trxCreateTrackedItemsLCL
	
	app.myTrxCA.trxCreateTrackedItemsLCL(intFaceArray, null, parentCont, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog
	
	delete intFaceArray;
	delete prenote;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTIRequestForJob" id="024f3b41-7783-4dac-b626-eb3885885da2">
        <source>tTIRequestForJob();
/*

Purpose:			

Date		Who		Reason
06 November 2015	cnwmk3	Initial creation

*/
constants
	
	TruckID		            : String = "UT_001";
	TiID					: String = "UT010002";
	CarrierName             : String = "UT_01";
vars
    job                     : CM_Job;
	trackedItem             : CM_TrackedItem;
	vehicle					: CM_Vehicle;
	carrier                 : CM_Carrier;
	email                   : CM_EmailEntityByTypeNameDict;
begin
    self.deleteTrackedItem(self.getTrackedItem(TiID), false);
	self.deleteCarrier(CarrierName);
	self.deleteVehicle(TruckID);
	
	create email transient;
	carrier := self.addCarrier(CarrierName, CarrierName, email, false, true, true, null);
	self.assertNotNull(carrier);
	vehicle := self.addVehicle(TruckID, carrier, self.getTerminal());
	
	trackedItem := self.addContainer(TiID, self.getOperator("APL"),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.assertNotNull(trackedItem);
	trackedItem := self.getTrackedItem(TiID);
	vehicle := self.getVehicle(TruckID);
	self.assertNotNull(vehicle);
	
	// create the road job
	job := self.createRoadJob(vehicle);
	self.assertNotNull(job);
	
	// create TI request for job 
    app.myTrxCA.trxCreateTIRequestForJob(job, trackedItem,true,5,15.5, app.myPassport); 
	self.assertNoTrxErrorsOrWarnings();
epilog
    delete email;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTaxCode" id="68d134b4-e7e9-4ae7-884c-26e7b6210e5a">
        <source>tTaxCode();
/*

Purpose:			

Date		Who		Reason
12 October 2015	cnwmk3	Initial creation

*/
constants
    TaxRate                                     : Decimal[4,2] = 15.5;
	UpdatedTaxRate                              :Decimal[4,2] = 10.5;
vars
    pxyTaxRate                                  : CM_TaxRate;
    realTaxRate                                 : CM_TaxRate;
    pxyTaxCode		                            : CM_TaxCode;
	taxCode                                     : CM_TaxCode;
	desc			                            : String;
	glCode                                      : CM_GLCode;
	bank                                        : CM_Bank;
	time                                        : TimeStamp;
	proxyUpdateRate                             : CM_TaxRate;
	cmObj                                       : CM_Object;
	objArray                                    : CM_ObjectArray;
begin
// delete tax code
    bank := self.getTerminal().getDefaultCompanyBank();
	taxCode := bank.allTaxCodes["TAX11"];
	if taxCode &lt;&gt; null then 
	   cmObj := taxCode;
	   self.ignoreTrxWarnings(true);
       app.myTrxDA.trxDeleteCMObject(cmObj, app.myPassport);
	   self.assertNoTrxErrorsOrWarnings();
	endif;
	taxCode := bank.allTaxCodes["TAX11"];
	self.assertNull(taxCode);

// delete InvoiceGL code
    self.deleteInvoiceGLCode("TEST_GLCode");
	self.assertNull(glCode);
    glCode := self.createInvoiceGLCode("TEST_GLCode", "");

// add new Tax Code
	if taxCode = null then
       taxCode := self.addTaxCode("TAX11", "GST tax", glCode);
	endif;

// update Tax Code
	beginLoad;
	pxyTaxCode := taxCode.pxyCreateUpdateProxy();
	endLoad;
 	
	pxyTaxCode.setPropertyValue("myBank",taxCode.myBank);
	desc := "Tax Code is Updated ";
	pxyTaxCode.setPropertyValue("description", desc);
	app.myTrxUA.trxUpdateTaxCode(pxyTaxCode, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(pxyTaxCode.description, desc);	
	
// create Tax Rate	
	create pxyTaxRate transient;
    pxyTaxRate.setProxy(time, taxCode, TaxRate);
    app.myTrxCA.trxCreateTaxRate(pxyTaxRate, realTaxRate, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

// update Tax Rate
	beginLoad;
	proxyUpdateRate := realTaxRate.pxyCreateUpdateProxy();
	endLoad;
	proxyUpdateRate.setPropertyValue("myTaxCode", realTaxRate.myTaxCode);
	proxyUpdateRate.setPropertyValue("rate", UpdatedTaxRate);
	app.myTrxUA.trxUpdateTaxRate(proxyUpdateRate, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
epilog
	delete pxyTaxCode;
	delete pxyTaxRate;
	delete proxyUpdateRate;
	ignoreTrxWarnings(false);
end;
</source>
    </JadeMethod>
    <JadeMethod name="tTemperatureConversion" id="96d1f438-af39-4175-a65c-dcdfbcc475f5">
        <updating/>
        <source>tTemperatureConversion()updating;
/*

Purpose:			

Date		Who		Reason
08 December 2015	cnwmk3	Initial creation
// 10 Sep 2019	cnwrs1	TFS 46030
*/
constants
	Booking1					= "UT_BK_0001";
vars
	configCMIF					: CMIF_OpTerminalConfigDict;
	codeGroupsColl				: CM_CodeGroupsByTypeDict;	
	emailAddresses				: CM_EmailEntityByTypeNameDict;
	operator					: CM_Operator;
	booking						: CM_BookingRef;
	vvr							: CM_VehicleVisitRecord;
	ti							: CM_TrackedItem;
	voyage						: CM_Voyage;
	vessel						: CM_Vessel;
	gte							: CMGTE_Entity;
	child						: CM_TrackedItem;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
	self.deleteMasterTi("UTMAT00002");
	ti := self.getTrackedItem("UTMAT00002");
	if ti &lt;&gt; null then
		self.deleteTrackedItem(ti, false);
	endif;
	self.deleteBooking(Booking1);
	self.deleteVoyage("UTVBOOK1");
	
	create configCMIF transient;	
	create codeGroupsColl transient;
	create emailAddresses transient;
	
	operator := self.addOperator("UT01", "UT Operator", false, 0, 0, null, true, false, false,
		false, false, false, false, false, false, false, null, null, codeGroupsColl, false, false, false, configCMIF, 
		emailAddresses, 0, null, null, null); 
	self.assertNotNull(operator);
	
	deleteVessel("UTBOAT");
	self.deleteVehicle("UTMAT");
	
	vessel := addVesselCellular("UTBOAT", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	assertNotNull(vessel);
	voyage := addVoyageWithContainerStructur("UTVBOOK1", "UTBOAT", operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	assertNotNull(voyage);
	
	// Booking for an ISO Group created
	self.opts.purge();
	self.opts.addAssoc("Temp", -3.00.Real);
	self.opts.addAssoc("ISO Group", "20BX");
	booking := self.addBookingForContainer(Booking1, self.getOperator(operator.code), voyage, "NZAKL", "2231", "REEF");
	self.assertNotNull(booking);
	self.assertEqual(booking.allBookingRefItems.first.myReeferProperties.temperature, -3.00.Real);
	
	ti := self.addPrenotedContainer(booking.allBookingRefItems.first, "UTMAT00002");
	self.assertEqual(getTrackedItem("UTMAT00002").myReeferProperties.temperature, -3.00.Real);
	
	vvr := self.gateInContainer("UTMAT", ti.id, "2231", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code, "REEF", self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString).name);
	self.assertNotNull(vvr);
	self.assertEqual(getTrackedItem("UTMAT00002").myReeferProperties.temperature, -3.00.Real);
	
	self.workVehicle(vvr);
	self.roadExit(vvr);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
	delete configCMIF;
	delete codeGroupsColl;
	delete emailAddresses;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tTerminalSubArea" id="fef40671-b278-4fbb-a4ec-04ab19ce9595">
        <source>tTerminalSubArea();
/*

Purpose:			

Date		Who		Reason
03 November 2015	cnwmk3	Initial creation
// 10 Sep 2019	cnwrs1	TFS 46030
*/
constants
   TADescription                                             : String = "Terminal Area by UT";
   STADArea                                                  : String = "ST600";
vars
   proxyTermSubArea                                          : CM_TerminalSubArea;
   newTermSubArea                                            : CM_TerminalSubArea;
   straddleArea                                              : CM_TerminalArea;
   theLocations                                              : CM_YardControllerSet;
   proxyUpdateTermSubArea                                    : CM_TerminalSubArea;
	isDoClearanceCheck : Boolean;
begin
	isDoClearanceCheck := self.getMyTerminal.myHarbour.isDoClearanceCheck;
	self.setHarbourIsDoClearanceCheck(false);
    // delete Sub TerminalArea if already exist
	proxyTermSubArea := self.getTerminalArea(STADArea).allSubAreas.getAtKey(TADescription);
	if proxyTermSubArea &lt;&gt; null then
	   app.myTrxDA.trxDeleteTerminalSubArea(proxyTermSubArea, app.myPassport);
	endif;
	self.assertNoTrxErrorsOrWarnings();
	
   // delete TerminalArea if already exist
	self.deleteTerminalArea(STADArea);
	
	// add Terminal Area
	straddleArea:= self.addStraddleStack(STADArea,11,6,2);
	self.assertNotNull(straddleArea);
	
   create theLocations transient;
   theLocations.add(straddleArea.allLocationsControllers.first.CM_YardController);
   create proxyTermSubArea transient;
   proxyTermSubArea.setProxy(TADescription,
										Blue,
										straddleArea,
										theLocations);
	
	app.myTrxCA.trxCreateTerminalSubArea(proxyTermSubArea, newTermSubArea, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	
	beginTransaction;
	proxyUpdateTermSubArea := newTermSubArea.pxyCreateUpdateProxy();
	commitTransaction;
	proxyUpdateTermSubArea.setProxy(TADescription,
										Red,
										straddleArea,
										theLocations);
	app.myTrxUA.trxUpdateTerminalSubArea(proxyUpdateTermSubArea, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(proxyUpdateTermSubArea.colour, Red);
epilog
	self.setHarbourIsDoClearanceCheck(isDoClearanceCheck);
    delete proxyTermSubArea;
	delete theLocations;
	delete proxyUpdateTermSubArea;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tTerminologyDef" id="5a486c93-192d-47ef-a8dd-8b76649bc330">
        <source>tTerminologyDef();
/*

Purpose:			

Date		Who		Reason
05 November 2015	cnwmk3	Initial creation

*/
constants
    TermName                                         : String = "UT_Terminology";
vars
    pxyTermHdr, newTermHdr, pxyUpdateTermHdr         : CM_TerminologyDef;
	termType                                         : CM_TerminologyType;
	termTypeExp			                             : CM_TerminologyTypeExpression;
	pxyExp				                             : CM_TerminologyExpression;
	termTypeDtl			                             : CM_TerminologyTypeDtl;
	pxyTermDtl			                             : CM_TerminologyDtl;
	userExpression                                   : String;
begin
// delete terminology def
    termType := app.myRoot.allTerminologyTypes.first;
    newTermHdr := termType.allTerminologyDefs["UT_Updated"];
	if newTermHdr &lt;&gt; null then 
        app.myTrxDA.trxDeleteTerminologyDef(newTermHdr, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
    endif;
	
// create terminology def
    create pxyTermHdr transient;
	pxyTermHdr.setProxy(TermName, termType);
	
	foreach termTypeExp in termType.allTerminologyTypeExpressions do
		pxyExp := pxyTermHdr.allTerminologyExpressions[pxyTermHdr.name, termTypeExp.expressionType];
		if pxyExp = null then
			create pxyExp transient;
		endif;
	    userExpression := termTypeExp.expressionDescr.String;
		self.assertNotNull(userExpression);
		pxyExp.set(termTypeExp, pxyTermHdr, userExpression);
	endforeach;
	
	foreach termTypeDtl in termType.allTerminologyTypeDtls do
			create pxyTermDtl transient;
			pxyTermDtl.set(termTypeDtl, pxyTermHdr, "Heading","ShortHeading");
	endforeach;
	
	pxyTermHdr.processUserHeadings();
	
    app.myTrxCA.trxCreateTerminologyDef(pxyTermHdr, newTermHdr, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

// update terminology def
	beginLoad;
	pxyUpdateTermHdr := newTermHdr.pxyCreateUpdateProxy();
	endLoad;
	pxyUpdateTermHdr.setPropertyValue("name", "UT_Updated");
	pxyUpdateTermHdr.processUserHeadings();
	app.myTrxUA.trxUpdateTerminologyDef(pxyUpdateTermHdr, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
epilog
    delete pxyTermHdr;
	delete pxyUpdateTermHdr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTrackedItemDamageInstances1" id="25170f53-256d-43e7-97a0-2f7494758f10">
        <updating/>
        <source>tTrackedItemDamageInstances1() updating;
//
// 25 Jul 2018	jlgrs1	TFS 38804 SNO Changes to repaired transactions
// 24 June 2022 navhl20 TFS 53862 EUP - WMS - Damage Recording Extra Details
// 11 July 2022	navak20	TFS 53862 EUP - WMS - Damage Recording Extra Details
// NAVAB1 - 27OCT2022 CUT DAY - damage severity is now an object so create some for this test and then delete them so that no one else uses them
constants
	Fixed = "FIXED";
	CodeDS : String = "UT_";	// 14.10.2022 navak20 TFS 53862 // NAVAB1 - 27OCT2022 CUT DAY
	DescriptionDS : String = "Damage ";	// 14.10.2022 navak20 TFS 53862 // NAVAB1 - 27OCT2022 CUT DAY
	IsNotAvailableForEntryDS : Boolean = false;	// 14.10.2022 navak20 TFS 53862
	LevelDS1 : Integer = 9991;	// 14.10.2022 navak20 TFS 53862 // NAVAB1 - 27OCT2022 CUT DAY added 999
	LevelDS2 : Integer = 9992;	// 14.10.2022 navak20 TFS 53862 // NAVAB1 - 27OCT2022 CUT DAY added 999
	LevelDS3 : Integer = 9993;	// 14.10.2022 navak20 TFS 53862 // NAVAB1 - 27OCT2022 CUT DAY added 999
	LevelDS4 : Integer = 9994;	// 14.10.2022 navak20 TFS 53862 // NAVAB1 - 27OCT2022 CUT DAY added 999
vars
	terminal : CM_Terminal;
	pxyTI : CM_TrackedItem;
	updController : CMIF_TIUpdateController;
	moveController : CMIF_MoveController;
	ti : CM_TrackedItem;
	bs : CM_BlockStack;
	bs2	: CM_BlockStack;
	bs3 : CM_BlockStack;
	carrier : CM_Carrier;
	cargoType : CM_CargoType;
	tiSet : CM_TISet;
	pinEmailAddresses : CM_EmailEntityByTypeNameDict;
	destPortCode : String;
	index : Integer;
	tiId : String;
	totalQuantity : Integer;
	quantity : Integer;
    noImportStops : Boolean;
	pxyRepairReason, repairReason : CM_RepairReason;
	severity1,
	severity2,
	severity3,
	severity4 : CM_DamageSeverity;
begin
	terminal := self.getTerminal();
	
    noImportStops := self.getTerminalConfig(NoImportStops).Boolean;
    self.setTerminalConfig(NoImportStops, false);

	destPortCode := terminal.getConfig(PortDestCode).String;
	//Start 14.10.2022 navak20 TFS 53862
	//severity1 := terminal.allDamageSeverities[DamageSeverity_1.String];
	//severity2 := terminal.allDamageSeverities[DamageSeverity_2.String];
	//severity3 := terminal.allDamageSeverities[DamageSeverity_3.String];
	//severity4 := terminal.allDamageSeverities[DamageSeverity_4.String];
	severity1 := self.createDamageSeverity(CodeDS&amp;"1",DescriptionDS&amp;"1",IsNotAvailableForEntryDS,LevelDS1);	
	severity2 := self.createDamageSeverity(CodeDS&amp;"2",DescriptionDS&amp;"2",IsNotAvailableForEntryDS,LevelDS2);
	severity3 := self.createDamageSeverity(CodeDS&amp;"3",DescriptionDS&amp;"3",IsNotAvailableForEntryDS,LevelDS3);
	severity4 := self.createDamageSeverity(CodeDS&amp;"4",DescriptionDS&amp;"4",IsNotAvailableForEntryDS,LevelDS4);
	//End 14.10.2022 navak20 TFS 53862
	// create the blockstack(s)
	bs := self.addBlockStack("UTMDHM", 50, null);
	self.assertNotNull(bs);
	
	bs2 := self.addBlockStack("UTMDHMMT", 5, null);
	self.assertNotNull(bs);
	
	bs3 := self.addBlockStack("UTMDHMGEN", 5, null);
	self.assertNotNull(bs);
		
	// create / update a carrier
	create pinEmailAddresses transient;
	carrier := self.addCarrier("UTMDHCR", "Michaels Carrier", pinEmailAddresses, false, false, true, null);
	self.assertNotNull(carrier);
	
	self.opts.purge();
	self.opts.addAssoc("CarrierDescription", carrier.description &amp; " Upd");
	self.updateCarrier(carrier);
	self.assertEqual(carrier.description, self.opts.str("CarrierDescription"));
		
	create tiSet transient;
	foreach index in 1 to 2 step 1 do
		tiId := "UTMDHMISC" &amp; index.padLeadingWith("0", 2);
		self.deleteTrackedItem(self.getTrackedItem(tiId), false);
		
		create pxyTI as CM_Container transient;
		pxyTI.setPxyFromDefaultTI(terminal, TI_CargoType_Container, tiId, "EFEC" , null);
		pxyTI.CM_Container.zSetPxyISOType("2200");
		pxyTI.setReceiptTransportMode(TI_TRANSMODE_ROAD);
		pxyTI.CM_Container.setMyVoyage(terminal.getNullVoyage(), app.myPassport );
		pxyTI.setImExStatus(TI_IMEX_STATUS_IMPORT);
		pxyTI.setDischargePort(destPortCode);
		pxyTI.CM_Container.setReleaseCarrier(carrier.code);
		pxyTI.CM_Container.zSetPxyTotalWeight(5000);					// 05/03/2015 cnwmh5
		pxyTI.zSetPxyRemarks(self.createdByUnitTest(null));				// 10/09/2015 cnwmh5
		
		tiSet.add(pxyTI);
	endforeach;
	
	app.myPassport.clearErrorsWarnings();
	app.myPassport.setWarningsIgnored(true);
	updController := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.getMyUserCode, null);
	updController.setMyTransientTIs(tiSet);
	
	app.myTrxCA.trxCreateTrackedItems(updController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// move the tracked items
	create moveController transient;
	tiSet.purge();
	self.opts.purge;
	self.opts.addAssoc("CENum", "666");
	foreach ti in updController.allPersistentTIs do
		moveController.setMyTrackedItem(ti);
		moveController.setMyToPrimaryLocation(bs.allLocationsControllers.first);
		moveController.isSystemMove := true;
		app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		self.deleteStops(ti);
	endforeach;
	
	// 09/10/2015 cnwmh5 - Damage remarks
	app.myTrxUA.trxUpdateTIRemarksDamage(ti, ti.remarks &amp; CrLf &amp; "Damage Remarks", null, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	app.myTrxUA.trxUpdateTIRemarksDamage(ti, ti.remarks &amp; CrLf &amp; "More Damage Remarks", null, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	app.myTrxUA.trxUpdateTIRemarksDamage(ti, ti.remarks &amp; CrLf &amp; "Much More Damage Remarks", null, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// damage details
	ti := updController.allPersistentTIs.first;
	
	// damage details
	self.opts.purge();
	self.opts.addAssoc("ShowDamageCodes", true);
	self.opts.addAssoc("NotAvailableForEntry", true);
	cargoType := self.addCargoType("MDHCType", false);
	self.assertNotNull(cargoType);
	
	quantity := quantity + 1;
	self.opts.purge();
	self.opts.addAssoc("quantity", quantity);
	ti := updController.allPersistentTIs.first;
	self.updateTIDamage(ti, "BENT", "Top", severity1);		// 11.07.2022 navak20 TFS 53862
	self.assertEqual(ti.damaged, true);
	//self.assertEqual(ti.allDamageInstances.first.severity, 1);		//24 June 2022 navhl20 TFS 53862
	self.assertEqual(ti.allDamageInstances.first.myDamageSeverity.level, LevelDS1);		//24 June 2022 navhl20 TFS 53862 // NAVAB1 - 27OCT2022 CUT DAY use constant
//	totalQuantity := totalQuantity + quantity;
	self.updateTIDamage(ti, "BENT", "Top", severity2);				// 11.07.2022 navak20 TFS 53862
	//self.assertEqual(ti.allDamageInstances.last.severity, 2);		//24 June 2022 navhl20 TFS 53862
	self.assertEqual(ti.allDamageInstances.last.myDamageSeverity.level, LevelDS2);		//24 June 2022 navhl20 TFS 53862 // NAVAB1 - 27OCT2022 CUT DAY use constant
//	totalQuantity := totalQuantity + quantity;
	self.updateTIDamage(ti, "BENT", "Top", severity3);	
	//self.assertEqual(ti.allDamageInstances.last.severity, 3);		//24 June 2022 navhl20 TFS 53862
	self.assertEqual(ti.allDamageInstances.last.myDamageSeverity.level, LevelDS3);		//24 June 2022 navhl20 TFS 53862 // NAVAB1 - 27OCT2022 CUT DAY use constant
//	totalQuantity := totalQuantity + quantity;
	self.updateTIDamage(ti, "BENT", "Top", severity4);	
	//self.assertEqual(ti.allDamageInstances.last.severity, 4);		//24 June 2022 navhl20 TFS 53862
	self.assertEqual(ti.allDamageInstances.last.myDamageSeverity.level, LevelDS4);		//24 June 2022 navhl20 TFS 53862 // NAVAB1 - 27OCT2022 CUT DAY use constant
	totalQuantity := totalQuantity + quantity;
	self.assertEqual(ti.allDamageInstances.size, 4);
	
	quantity := quantity + 1;
	self.opts.purge();
	self.opts.addAssoc("quantity", quantity);
	ti := updController.allPersistentTIs.first;
	self.updateTIDamage(ti, "BENT", "Bottom", severity1);	
	self.assertEqual(ti.damaged, true);
	self.assertEqual(ti.allDamageInstances.last.quantity, 2);
	totalQuantity := totalQuantity + quantity;
	self.opts.addAssoc("quantity", quantity*2);
	self.updateTIDamage(ti, "BENT", "Bottom", severity1);	
	self.assertEqual(ti.allDamageInstances.last.quantity, 4);
	totalQuantity := totalQuantity + quantity;
	self.assertEqual(ti.allDamageInstances.size, 6);

	quantity := quantity + 1;
	self.opts.purge();
	self.opts.addAssoc("quantity", quantity);
	ti := updController.allPersistentTIs.first;
	self.updateTIDamage(ti, "BENT", "Front", severity1);	
	self.assertEqual(ti.damaged, true);
	totalQuantity := totalQuantity + quantity;

	quantity := quantity + 1;
	self.opts.purge();
	self.opts.addAssoc("quantity", quantity);
	ti := updController.allPersistentTIs.first;
	self.updateTIDamage(ti, "BENT", "Back", severity1);	
	self.assertEqual(ti.damaged, true);
	totalQuantity := totalQuantity + quantity;

	quantity := quantity + 1;
	self.opts.purge();
	self.opts.addAssoc("quantity", quantity);
	ti := updController.allPersistentTIs.first;
	self.updateTIDamage(ti, "RUST", "Top", severity1);	
	self.assertEqual(ti.damaged, true);
	totalQuantity := totalQuantity + quantity;
	
	quantity := quantity + 1;
	self.opts.purge();
	self.opts.addAssoc("quantity", quantity);
	ti := updController.allPersistentTIs.first;
	self.updateTIDamage(ti, "RUST", "Bottom", severity1);	
	self.assertEqual(ti.damaged, true);
	totalQuantity := totalQuantity + quantity;

	quantity := quantity + 1;
	self.opts.purge();
	self.opts.addAssoc("isRepaired", true);
	self.opts.addAssoc("quantity", quantity);
	ti := updController.allPersistentTIs.first;
	self.updateTIDamage(ti, "RUST", "Front", severity1);	
	self.assertEqual(ti.damaged, true);
	totalQuantity := totalQuantity + quantity;

	quantity := quantity + 1;
	self.opts.purge();
	self.opts.addAssoc("isNewDamage", true);
	ti := updController.allPersistentTIs.first;
	self.updateTIDamage(ti, "RUST", "Back", severity1);	
	self.assertEqual(ti.damaged, true);
	totalQuantity := totalQuantity + quantity;

	self.assertEqual(ti.allDamageInstances.size, 12);
	quantity := ti.getDamageQuantity();

	self.assertEqualMsg(ti.getDamageQuantity, 35, ti.id&amp;" wrong quantity of damage"); // NAVAB1 - 27OCT2022 CUT DAY made 35
	
	
	self.deleteAllDamage(ti); // NAVAB1 - 27OCT2022 CUT DAY
	
	self.deleteDamageSeverity(severity1); // NAVAB1 - 27OCT2022 CUT DAY
	self.deleteDamageSeverity(severity2); // NAVAB1 - 27OCT2022 CUT DAY
	self.deleteDamageSeverity(severity3); // NAVAB1 - 27OCT2022 CUT DAY
	self.deleteDamageSeverity(severity4); // NAVAB1 - 27OCT2022 CUT DAY
	
	
epilog
	self.setTerminalConfig(NoImportStops, noImportStops);
	delete tiSet;
	delete moveController;
	delete updController;
	delete pinEmailAddresses;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTrackedItemDamageInstances2" id="2015de88-a23e-4a66-a96e-f81b0e024ff8">
        <updating/>
        <source>tTrackedItemDamageInstances2() updating;
//
// 25 Jul 2018	jlgrs1	TFS 38804 SNO Changes to repaired transactions
// 24 June 2022 navhl20 TFS 53862 EUP - WMS - Damage Recording Extra Details
// 11 July 2022	navak20	TFS 53862 EUP - WMS - Damage Recording Extra Details
// NAVAB1 - 27OCT2022 CUT DAY - damage severity is now an object so create some for this test and then delete them so that no one else uses them
constants
	CargoId1 = "UTREBAR9999A";
	CodeDS : String = "UT_";	// 14.10.2022 navak20 TFS 53862 // NAVAB1 - 27OCT2022 CUT DAY
	DescriptionDS : String = "Damage ";	// 14.10.2022 navak20 TFS 53862 // NAVAB1 - 27OCT2022 CUT DAY
	IsNotAvailableForEntryDS : Boolean = false;	// 14.10.2022 navak20 TFS 53862
	LevelDS1 : Integer = 9991;	// 14.10.2022 navak20 TFS 53862 // NAVAB1 - 27OCT2022 CUT DAY added 999
	LevelDS2 : Integer = 9992;	// 14.10.2022 navak20 TFS 53862 // NAVAB1 - 27OCT2022 CUT DAY added 999
	LevelDS3 : Integer = 9993;	// 14.10.2022 navak20 TFS 53862 // NAVAB1 - 27OCT2022 CUT DAY added 999
	LevelDS4 : Integer = 9994;	// 14.10.2022 navak20 TFS 53862 // NAVAB1 - 27OCT2022 CUT DAY added 999
vars
	terminal : CM_Terminal;
//	pxyTI : CM_TrackedItem;
	updController : CMIF_TIUpdateController;
	moveController : CMIF_MoveController;
//	ti : CM_TrackedItem;
	bs1 : CM_BlockStack;
	bs2	: CM_BlockStack;
	bs3 : CM_BlockStack;
	bs4 : CM_BlockStack;
	bs5 : CM_BlockStack;
	carrier : CM_Carrier;
	cargoType : CM_CargoType;
//	tiSet : CM_TISet;
	pinEmailAddresses : CM_EmailEntityByTypeNameDict;
	destPortCode : String;
//	index : Integer;
//	tiId : String;
	totalQuantity : Integer;
	quantity : Integer;
    noImportStops : Boolean;
	breakBulkCargoType : CM_CargoType;
	cargo, cargo2 : CM_TrackedItem; 
	cargoOnSite : CM_TrackedItem;
	lc : CM_LocationsController;
	height : Integer;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	tiSet : CM_TISet;
	severity1, severity2, severity3, severity4 : CM_DamageSeverity;
begin
	terminal := self.getTerminal();

	vessel := self.addVesselWithHolds("UT_VHOLDS", 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("UT_VHOLDS", vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
    noImportStops := self.getTerminalConfig(NoImportStops).Boolean;
    self.setTerminalConfig(NoImportStops, false);

	destPortCode := terminal.getConfig(PortDestCode).String;
	//Start 14.10.2022 navak20 TFS 53862
	//severity1 := terminal.allDamageSeverities[DamageSeverity_1.String];
	//severity2 := terminal.allDamageSeverities[DamageSeverity_2.String];
	//severity3 := terminal.allDamageSeverities[DamageSeverity_3.String];
	//severity4 := terminal.allDamageSeverities[DamageSeverity_4.String];
	severity1 := self.createDamageSeverity(CodeDS&amp;"1",DescriptionDS&amp;"1",IsNotAvailableForEntryDS,LevelDS1);	
	severity2 := self.createDamageSeverity(CodeDS&amp;"2",DescriptionDS&amp;"2",IsNotAvailableForEntryDS,LevelDS2);
	severity3 := self.createDamageSeverity(CodeDS&amp;"3",DescriptionDS&amp;"3",IsNotAvailableForEntryDS,LevelDS3);
	severity4 := self.createDamageSeverity(CodeDS&amp;"4",DescriptionDS&amp;"4",IsNotAvailableForEntryDS,LevelDS4);
	//End 14.10.2022 navak20 TFS 53862

	// create the blockstack(s)
	bs1 := self.addBlockStack("UTMDHM", 50, null);
	self.assertNotNull(bs1);
	bs2 := self.addBlockStack("UTMDHMMT", 5, null);
	self.assertNotNull(bs2);
	bs3 := self.addBlockStack("UTMDHMGEN", 5, null);
	self.assertNotNull(bs3);
	bs4 := self.addBlockStack("UTMDHMBULK", 5, null);
	self.assertNotNull(bs4);
	bs5 := self.addBlockStack("UTMDHMBAG", 5, null);
	self.assertNotNull(bs5);
		
	// create / update a carrier
	create pinEmailAddresses transient;
	carrier := self.addCarrier("UTMDHCR", "Michaels Carrier", pinEmailAddresses, false, false, true, null);
	self.assertNotNull(carrier);
	
	self.opts.purge();
	self.opts.addAssoc("CarrierDescription", carrier.description &amp; " Upd");
	self.updateCarrier(carrier);
	self.assertEqual(carrier.description, self.opts.str("CarrierDescription"));
		
	// Move break bulk cargo in parts
	breakBulkCargoType := app.myRoot.getCargoTypeFromAbbrev("UTREBAR");
	self.getTerminal.findLocationFromString("UTMDHM", true, lc, height); 
	deleteCargo(CargoId1, breakBulkCargoType);
	cargo := self.addCargoBreakBulkAtLocation(CargoId1, breakBulkCargoType, 50, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
	self.opts.addAssoc("TotalWeight", 50);
	self.updateTI(cargo);
	assertEqual(cargo.totalQuantity, 50);
	self.opts.purge;
	moveBreakBulk(cargo, bs2, 20);
	moveBreakBulk(cargo, bs3, 10);
	
/*	create tiSet transient;
	foreach index in 1 to 2 step 1 do
		tiId := "UTMDHMISC" &amp; index.padLeadingWith("0", 2);
		self.deleteTrackedItem(self.getTrackedItem(tiId), false);
		
		create pxyTI as CM_Container transient;
		pxyTI.setPxyFromDefaultTI(terminal, TI_CargoType_Container, tiId, "EFEC" , null);
		pxyTI.CM_Container.zSetPxyISOType("2200");
		pxyTI.setReceiptTransportMode(TI_TRANSMODE_ROAD);
		pxyTI.CM_Container.setMyVoyage(terminal.getNullVoyage(), app.myPassport );
		pxyTI.setImExStatus(TI_IMEX_STATUS_IMPORT);
		pxyTI.setDischargePort(destPortCode);
		pxyTI.CM_Container.setReleaseCarrier(carrier.code);
		pxyTI.CM_Container.zSetPxyTotalWeight(5000);					// 05/03/2015 cnwmh5
		pxyTI.zSetPxyRemarks(self.createdByUnitTest(null));				// 10/09/2015 cnwmh5
		
		tiSet.add(pxyTI);
	endforeach;*/
	
/*	app.myPassport.clearErrorsWarnings();
	app.myPassport.setWarningsIgnored(true);
	updController := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.getMyUserCode, null);
	updController.setMyTransientTIs(tiSet);
	
	app.myTrxCA.trxCreateTrackedItems(updController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();*/
	
/*	// move the tracked items
	create moveController transient;
	tiSet.purge();
	self.opts.purge;
	self.opts.addAssoc("CENum", "666");
	foreach ti in updController.allPersistentTIs do
		moveController.setMyTrackedItem(ti);
		moveController.setMyToPrimaryLocation(bs1.allLocationsControllers.first);
		moveController.isSystemMove := true;
		app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		self.deleteStops(ti);
	endforeach;
*/	
	// 09/10/2015 cnwmh5 - Damage remarks
	app.myTrxUA.trxUpdateTIRemarksDamage(cargo, cargo.remarks &amp; CrLf &amp; "Damage Remarks", null, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	app.myTrxUA.trxUpdateTIRemarksDamage(cargo, cargo.remarks &amp; CrLf &amp; "More Damage Remarks", null, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	app.myTrxUA.trxUpdateTIRemarksDamage(cargo, cargo.remarks &amp; CrLf &amp; "Much More Damage Remarks", null, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// damage details
//	ti := updController.allPersistentTIs.first;
	
	// damage details
	self.opts.purge();
	self.opts.addAssoc("ShowDamageCodes", true);
	self.opts.addAssoc("NotAvailableForEntry", true);
	cargoType := self.addCargoType("MDHCType", false);
	self.assertNotNull(cargoType);
	
	quantity := quantity + 1;
	self.opts.purge();
	self.opts.addAssoc("quantity", quantity);
//	ti := updController.allPersistentTIs.first;
	self.updateTIDamage(cargo, "BENT", "Top", severity1);	
	self.assertEqual(cargo.damaged, true);
	//self.assertEqual(cargo.allDamageInstances.last.severity, 1);		//24 June 2022 navhl20 TFS 53862
	self.assertEqual(cargo.allDamageInstances.last.myDamageSeverity.level, LevelDS1);		//24 June 2022 navhl20 TFS 53862
	totalQuantity := totalQuantity + quantity;
	self.updateTIDamage(cargo, "BENT", "Top", severity2);	
	//self.assertEqual(cargo.allDamageInstances.last.severity, 2);		//24 June 2022 navhl20 TFS 53862
	self.assertEqual(cargo.allDamageInstances.last.myDamageSeverity.level, LevelDS2);		//24 June 2022 navhl20 TFS 53862
	totalQuantity := totalQuantity + quantity;
	self.updateTIDamage(cargo, "BENT", "Top", severity3);	
	//self.assertEqual(cargo.allDamageInstances.last.severity, 3);		//24 June 2022 navhl20 TFS 53862
	self.assertEqual(cargo.allDamageInstances.last.myDamageSeverity.level, LevelDS3);		//24 June 2022 navhl20 TFS 53862
	totalQuantity := totalQuantity + quantity;
	self.updateTIDamage(cargo, "BENT", "Top", severity4);	
	//self.assertEqual(cargo.allDamageInstances.last.severity, 4);		//24 June 2022 navhl20 TFS 53862
	self.assertEqual(cargo.allDamageInstances.last.myDamageSeverity.level, LevelDS4);		//24 June 2022 navhl20 TFS 53862
	totalQuantity := totalQuantity + quantity;
	self.assertEqual(cargo.allDamageInstances.size, 4);
	
	quantity := quantity + 1;
	self.opts.purge();
	self.opts.addAssoc("quantity", quantity);
//	ti := updController.allPersistentTIs.first;
	self.updateTIDamage(cargo, "BENT", "Bottom", severity1);	
	self.assertEqual(cargo.damaged, true);
	self.assertEqual(cargo.allDamageInstances.last.quantity, 2);
	totalQuantity := totalQuantity + quantity;
	self.opts.addAssoc("quantity", quantity*2);
	self.updateTIDamage(cargo, "BENT", "Bottom", severity1);	
	self.assertEqual(cargo.allDamageInstances.last.quantity, 4);
	totalQuantity := totalQuantity + quantity*2;
	self.assertEqual(cargo.allDamageInstances.size, 6);

	quantity := quantity + 1;
	self.opts.purge();
	self.opts.addAssoc("quantity", quantity);
//	ti := updController.allPersistentTIs.first;
	self.updateTIDamage(cargo, "BENT", "Front", severity1);	// 11.07.2022 navak20 TFS 53862
	self.assertEqual(cargo.damaged, true);
	totalQuantity := totalQuantity + quantity;

	quantity := quantity + 1;
	self.opts.purge();
	self.opts.addAssoc("quantity", quantity);
//	ti := updController.allPersistentTIs.first;
	self.updateTIDamage(cargo, "BENT", "Back", severity1);		// 11.07.2022 navak20 TFS 53862	
	self.assertEqual(cargo.damaged, true);
	totalQuantity := totalQuantity + quantity;

	quantity := quantity + 1;
	self.opts.purge();
	self.opts.addAssoc("quantity", quantity);
//	ti := updController.allPersistentTIs.first;
	self.updateTIDamage(cargo, "RUST", "Top", severity1);		// 11.07.2022 navak20 TFS 53862	
	self.assertEqual(cargo.damaged, true);
	totalQuantity := totalQuantity + quantity;
	
	quantity := quantity + 1;
	self.opts.purge();
	self.opts.addAssoc("quantity", quantity);
//	ti := updController.allPersistentTIs.first;
	self.updateTIDamage(cargo, "RUST", "Bottom", severity1);		// 11.07.2022 navak20 TFS 53862		
	self.assertEqual(cargo.damaged, true);
	totalQuantity := totalQuantity + quantity;

	quantity := quantity + 1;
	self.opts.purge();
	self.opts.addAssoc("quantity", quantity);
//	ti := updController.allPersistentTIs.first;
	self.updateTIDamage(cargo, "RUST", "Front", severity1);		// 11.07.2022 navak20 TFS 53862
	self.assertEqual(cargo.damaged, true);
	totalQuantity := totalQuantity + quantity;

	quantity := quantity + 1;
	self.opts.purge();
	self.opts.addAssoc("quantity", quantity);
//	ti := updController.allPersistentTIs.first;
	self.updateTIDamage(cargo, "RUST", "Back", severity1);		// 11.07.2022 navak20 TFS 53862	
	self.assertEqual(cargo.damaged, true);
	totalQuantity := totalQuantity + quantity;


	self.assertEqual(cargo.allDamageInstances.size, 12);	//??
	quantity := cargo.getDamageQuantity();

	self.assertEqualMsg(cargo.getDamageQuantity, 43, cargo.id&amp;" wrong quantity of damage");	//??
	moveBreakBulk(cargo, bs4, 6);
	moveBreakBulk(cargo, bs5, 4);
	create tiSet transient;
	cargo.findAllDuplicateTIs(tiSet);
	self.assertEqualMsg(tiSet.size, 4, cargo.id&amp;" wrong quantity of damage");	//??

	// NAVAB1 - 27OCT2022 CUT DAY - lot of splitting so get rid of damage on those
	foreach cargo2 in cargo.allSplitChildrenTis do
		self.deleteAllDamage(cargo2); // NAVAB1 - 27OCT2022 CUT DAY
	
	endforeach;
	self.deleteAllDamage(cargo); // NAVAB1 - 27OCT2022 CUT DAY
	
	self.deleteDamageSeverity(severity1); // NAVAB1 - 27OCT2022 CUT DAY
	self.deleteDamageSeverity(severity2); // NAVAB1 - 27OCT2022 CUT DAY
	self.deleteDamageSeverity(severity3); // NAVAB1 - 27OCT2022 CUT DAY
	self.deleteDamageSeverity(severity4); // NAVAB1 - 27OCT2022 CUT DAY

epilog
	self.setTerminalConfig(NoImportStops, noImportStops);
//	delete tiSet;
	delete moveController;
	delete updController;
	delete pinEmailAddresses;
	delete tiSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTrackedItemMisc" id="e916f56f-f5c5-4465-91cb-99d7a25ef537">
        <source>tTrackedItemMisc();

// cnwmh5
/*

Purpose:		Miscellaneous Tracked Item

				trxCreateTrackedItems						Done
				trxUpdateTIDamage							Done
				trxUpdateTIForChargeChecks					Done
				trxUpdateTIDimensionsToDo					Done
				trxUpdateTIWeightToDo						Done
				trxUPdateTITODoTaskAdd						Done
				trxUpdateTIREmarks							Done
				trxUpdateTITodoTaskRemove					Done
				trxDeleteYardAllocations					Done
				trxUpdateGeneratePin						Done
				trxUpdateCarrier							Done
				trxUpdateRemovePinReleaseImp				Done  01/05/2014 cnwma1
				trxUpdateTIRemarksDamage					Done  09/10/2015 cnwmh5
				
Date			Who		Reason
07/02/2014		cnwmh5	Initial creation
11/06/2014 		cnwmh5  Replace hardcoded ToDoTaskDesc with get by Short Desc
11 July 2022	navak20	TFS 53862 EUP - WMS - Damage Recording Extra Details
*/
constants
	CodeDS : String = "2UT";	// 25.10.2022 navak20 TFS 53862
	DescriptionDS : String = "Damage one";	// 25.10.2022 navak20 TFS 53862
	IsNotAvailableForEntryDS : Boolean = false;	// 25.10.2022 navak20 TFS 53862
	LevelDS : Integer = 11;	// 25.10.2022 navak20 TFS 53862
vars

	terminal						: CM_Terminal;
	pxyTI							: CM_TrackedItem;
	updController 					: CMIF_TIUpdateController;
	moveController 					: CMIF_MoveController;
	ti								: CM_TrackedItem;
	bs								: CM_BlockStack;
	bs2								: CM_BlockStack;
	bs3								: CM_BlockStack;
	termEmailDef					: CM_PINObjectDefaultEmail;
	carrier							: CM_Carrier;
	ya								: CM_YardAllocation;
	toDoTaskDesc					: CM_ToDoTaskDesc;
	damageDef						: CM_DamageDefinitionCode;
	damagePos						: CM_DamagePosition;
	cargoType						: CM_CargoType;
	
	tiSet							: CM_TISet;
	pinEmailAddresses				: CM_EmailEntityByTypeNameDict;
	yaSet 							: CM_YardAllocationSet;
	toDoTasksArray					: IntegerArray;
	addingToDoTasksArray			: BooleanArray;
	assignToCargoTypes				: CM_ObjectSet;
	machineTypes					: CM_ObjectSet;

	destPortCode					: String;
	index							: Integer;
	tiId							: String;
	tmpStr							: String;
	toDoTaskId						: Integer;
    noImportStops 					: Boolean;
	severity						: CM_DamageSeverity;
begin
	severity := self.getTerminal().allDamageSeverities[CodeDS];
	
	self.deleteDamageSeverity(severity);	// 25.10.2022 navak20 TFS 53862
    noImportStops := self.getTerminalConfig(NoImportStops).Boolean;
    self.setTerminalConfig(NoImportStops, false);

	terminal := self.getTerminal();
	destPortCode := terminal.getConfig(PortDestCode).String;
	termEmailDef := terminal.getEmailDefaultsSettings( PINEmail_CargoRelease );
	//severity := terminal.allDamageSeverities[DamageSeverity_1.String];		// 25.10.2022 navak20 TFS 53862
	severity := self.createDamageSeverity(CodeDS,DescriptionDS,IsNotAvailableForEntryDS,LevelDS);	// 25.10.2022 navak20 TFS 53862

	// create the blockstack(s)
	bs := self.addBlockStack("UTMDHM", 50, null);
	self.assertNotNull(bs);
	
	bs2 := self.addBlockStack("UTMDHMMT", 5, null);
	self.assertNotNull(bs);
	
	bs3 := self.addBlockStack("UTMDHMGEN", 5, null);
	self.assertNotNull(bs);
		
	// create / update a carrier
	create pinEmailAddresses transient;
	carrier := self.addCarrier("UTMDHCR", "Michaels Carrier", pinEmailAddresses, false, false, true, null);
	self.assertNotNull(carrier);
	
	self.opts.purge();
	self.opts.addAssoc("CarrierDescription", carrier.description &amp; " Upd");
	self.updateCarrier(carrier);
	self.assertEqual(carrier.description, self.opts.str("CarrierDescription"));
		
	create tiSet transient;
	foreach index in 1 to 2 step 1 do
		tiId := "UTMDHMISC" &amp; index.padLeadingWith("0", 2);
		self.deleteTrackedItem(self.getTrackedItem(tiId), false);
		
		create pxyTI as CM_Container transient;
		pxyTI.setPxyFromDefaultTI(terminal, TI_CargoType_Container, tiId, "EFEC" , null);
		pxyTI.CM_Container.zSetPxyISOType("2200");
		pxyTI.setReceiptTransportMode(TI_TRANSMODE_ROAD);
		pxyTI.CM_Container.setMyVoyage(terminal.getNullVoyage(), app.myPassport );
		pxyTI.setImExStatus(TI_IMEX_STATUS_IMPORT);
		pxyTI.setDischargePort(destPortCode);
		pxyTI.CM_Container.setReleaseCarrier(carrier.code);
		pxyTI.CM_Container.zSetPxyTotalWeight(5000);					// 05/03/2015 cnwmh5
		pxyTI.zSetPxyRemarks(self.createdByUnitTest(null));				// 10/09/2015 cnwmh5
		
		tiSet.add(pxyTI);
		
	endforeach;
	
	app.myPassport.clearErrorsWarnings();
	app.myPassport.setWarningsIgnored(true);
	updController := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.getMyUserCode, null);
	updController.setMyTransientTIs(tiSet);
	
	app.myTrxCA.trxCreateTrackedItems(updController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// move the tracked items
	create moveController transient;
	tiSet.purge();
	self.opts.purge;
	self.opts.addAssoc("CENum", "666");
	foreach ti in updController.allPersistentTIs do
		moveController.setMyTrackedItem(ti);
		moveController.setMyToPrimaryLocation(bs.allLocationsControllers.first);
		moveController.isSystemMove := true;
		app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		self.deleteStops(ti);
	endforeach;
	
	// test trx update generate pin
	//tiSet.copy(updController.allPersistentTIs);
	updController.allPersistentTIs.copy(tiSet);
	app.myTrxUA.trxUpdateGeneratePin(tiSet, termEmailDef, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// test trx remove Pin
	app.myTrxUA.trxUpdateRemovePinReleaseImp(tiSet, termEmailDef, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNull(tiSet.first.myPinNo);
	
	app.myTrxUA.trxUpdateGeneratePin(tiSet, termEmailDef, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(tiSet.first.myPinNo);
	
	// remarks
	tmpStr := "Remarks Changed";
	ti := tiSet.first;
	self.updateTIRemarks(ti, tmpStr);
	//self.assertEqual(ti.remarks, tmpStr);
	self.assertEqual(ti.remarks, self.createdByUnitTest(null) &amp; CrLf &amp; tmpStr);						// 10/09/2015 cnwmh5
	
	// 09/10/2015 cnwmh5 - Damage remarks
	app.myTrxUA.trxUpdateTIRemarksDamage(ti, ti.remarks &amp; CrLf &amp; "Damage Remarks", null, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// damage details
	ti := updController.allPersistentTIs.first;
	
	// damage details
	self.opts.purge();
	self.opts.addAssoc("ShowDamageCodes", true);
	self.opts.addAssoc("NotAvailableForEntry", true);
	cargoType := self.addCargoType("MDHCType", false);
	self.assertNotNull(cargoType);
	
	create assignToCargoTypes transient;
	assignToCargoTypes.add(cargoType);
	
	create machineTypes transient;
	
	damageDef := self.addDamageDefinition("MDHDAM", "Michael's Special Damage", assignToCargoTypes);
	self.assertNotNull(damageDef);
	
	damagePos := self.addDamagePosition("MDHTOP", "Michael's Special Top", assignToCargoTypes, machineTypes);
	self.assertNotNull(damagePos);	
	
	ti := updController.allPersistentTIs.first;
	self.updateTIDamage(ti, damageDef.code, damagePos.code, severity);		// 11.07.2022 navak20 TFS 53862
	self.assertEqual(ti.damaged, true);
	
	// update to do add
	create toDoTasksArray transient;
	create addingToDoTasksArray transient;
	
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc["Weight"];
	self.assertNotNull(toDoTaskDesc);
	toDoTasksArray.add(toDoTaskDesc.code);
	addingToDoTasksArray.add(true);
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc["Dimension"];
	self.assertNotNull(toDoTaskDesc);
	toDoTasksArray.add(toDoTaskDesc.code);
	addingToDoTasksArray.add(true);
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc["SEAL"];
	self.assertNotNull(toDoTaskDesc);
	toDoTasksArray.add(toDoTaskDesc.code);
	addingToDoTasksArray.add(true);
	self.updateTIForCargoChecks(ti, toDoTasksArray, addingToDoTasksArray);
	self.assertEqual(ti.allToDoTasksToDo.size, 3);
	
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc["Weight"];
	self.assertNotNull(toDoTaskDesc);
	toDoTasksArray.add(toDoTaskDesc.code);
	addingToDoTasksArray.add(false);
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc["Dimension"];
	self.assertNotNull(toDoTaskDesc);
	toDoTasksArray.add(toDoTaskDesc.code);
	addingToDoTasksArray.add(false);
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc["SEAL"];
	self.assertNotNull(toDoTaskDesc);
	toDoTasksArray.add(toDoTaskDesc.code);
	addingToDoTasksArray.add(false);
	self.updateTIForCargoChecks(ti, toDoTasksArray, addingToDoTasksArray);
	self.assertEqual(ti.allToDoTasksToDo.size, 0);
	
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc["Weight"];
	self.assertNotNull(toDoTaskDesc);
	toDoTasksArray.add(toDoTaskDesc.code);
	addingToDoTasksArray.add(true);
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc["Dimension"];
	self.assertNotNull(toDoTaskDesc);
	toDoTasksArray.add(toDoTaskDesc.code);
	addingToDoTasksArray.add(true);
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc["SEAL"];
	self.assertNotNull(toDoTaskDesc);
	toDoTasksArray.add(toDoTaskDesc.code);
	addingToDoTasksArray.add(true);
	self.updateTIForCargoChecks(ti, toDoTasksArray, addingToDoTasksArray);
	self.assertEqual(ti.allToDoTasksToDo.size, 3);
	
	// update weigh to do task
	self.updateTIWeightToDoTask(ti, 18, 2442.25, true, false);
	self.assertEqual(ti.allToDoTasksToDo.size, 2);
	self.assertEqual(ti.isWeightCertified, true);
	self.assertEqual(ti.totalWeight.asStringWeightJMT(), 2442.25.Decimal.asStringWeightJMT());
	
	// remove weigh to do task
	app.myTrxUA.trxUpdateTIToDoTaskRemove(tiSet.first.CM_TrackedItem, 18, app.myPassport);
	self.assertEqual(ti.allToDoTasksToDo.size, 2);
	
	// update ti's dimensions
	ti := updController.allPersistentTIs.last;
	tiSet.clear();
	tiSet.add(ti);
	toDoTaskId := 47;
	self.addToDoTask(app.myRoot.allToDoTaskDescriptions[toDoTaskId], tiSet);
	self.assertNoTrxErrorsOrWarnings();
	self.opts.purge();
	self.opts.addAssoc("Commodity", "GENL");
	self.opts.addAssoc("CENum", "666");
	self.updateTI(ti);
	self.assertNoTrxErrorsOrWarnings();
	self.deleteStops(ti);
	
	self.assertEqual(ti.isOverDimensions, false);
	self.updateTIDimensions(ti, 11.11, 12.12, 13.13, 14.14, 15.15, 47, false);
	self.assertEqual(ti.isOverDimensions, true);
	
	tiSet.clear();	
	
	/************************************************************************************
	 * For the following trx
	 *  trxDeleteYardAllocations
	 ************************************************************************************/
	 
	// delete Yard Allocations
	create yaSet transient;
	foreach index in 1 to 2 step 1 do
		ya := terminal.allYardAllocatonsByCode["NUTMDH" &amp; index.String];
		if ya &lt;&gt; null then
			yaSet.add(ya);
		endif;
	endforeach;
	app.myTrxDA.trxDeleteYardAllocations(yaSet, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	 
	// disable YA
	self.disableAllYA(true);
	
	// create YA(s)
	ya := self.addYA1("NUTMDH1", YACriteriaType_Commodity, "MT", bs2.myLocationsController);
	self.assertNoTrxErrorsOrWarnings();
	
	ya := self.addYA1("NUTMDH2", YACriteriaType_Commodity, "GENL", bs3.myLocationsController);
	self.assertNoTrxErrorsOrWarnings();
	
epilog
	self.setTerminalConfig(NoImportStops, noImportStops);

	// enable YA(s)
	self.disableAllYA(false);

	delete tiSet;
	
	delete moveController;
	delete updController;
	delete pinEmailAddresses;
	delete yaSet;
	delete toDoTasksArray;
	delete addingToDoTasksArray;
	delete machineTypes;
	delete assignToCargoTypes;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tTrxDischargeCargoAutoPlan" id="1853c7b9-9c75-4f52-b5a4-342d8d8e4227">
        <source>tTrxDischargeCargoAutoPlan();

/*

Purpose:		

Date			Who		Reason
08/10/2015		cnwmh5	Initial creation

*/

vars

	bs						: CM_BlockStack;
	ya						: CM_YardAllocation;
	wle						: CM_WorkListEntry;
	ti						: CM_TrackedItem;
	voyageJob				: CM_VoyageJob;
	voyage					: CM_Voyage;
	
	locations				: CM_LCArray;
	slots 					: CM_SlotControllerArray;
	
	weight 					: Decimal [16,4];

begin

	disableAllYA(true);

	bs := self.addBlockStack("MHTRXBS1", 999, null);
	self.assertNotNull(bs);
	
	create locations transient;
	bs.allLocationsControllers.copy(locations);
	ya := self.addYA("YATRXDISCH", YACriteriaType_ID, "UTMDH0810A1", YACriteriaType_CargoType, "CONT", null, null, locations, null);
	self.assertNotNull(ya);
	
	self.deleteVoyage("MDHDIAM001");
	voyage := self.addVoyageWithConRORO("MDHDIAM001", "MESDIAM", "UTOP", self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
		self.getProfileSetting(UT_Profile.P_TRADE).asString(), 0, false, true);
	self.assertNotNull(voyage);
	
	create slots transient;
	self.getJobSlotControllers(voyage.code, "01", DeckOnDeck, 1, 1, 1, slots);
	assertEqual(slots.size, 1);
	ti := self.addContainerAtLocnDisch("UTMDH0810A1" , "2200", "GENL", TI_IMEX_STATUS_IMPORT, slots[1], 
		app.myRoot.allPorts["NZPOE"], voyage);
	self.voyageDischargeColourCode(voyage);
	
	voyageJob := self.addVoyageJob(voyage, "CRN1", slots, true);
	assertTrueMsg(voyageJob &lt;&gt; null, "Voyage job 1 not created");
	self.loadAllJobsToOps(voyage, true);
	
	ti := self.getTrackedItem("UTMDH0810A1");
	self.assertNotNull(ti);
	weight := ti.totalWeight;
	
	app.myTrxUA.trxDischargeCargoAutoPlan(null, ti, 1, weight, voyageJob, wle, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog

	disableAllYA(false);

	delete slots;
	delete locations;

end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateMachineNextQueue" id="448c1a6c-2707-46ee-ba2a-288c52416380">
        <source>tUpdateMachineNextQueue();
/*

Purpose:			

Date		Who		Reason
04 November 2015	cnwmk3	Initial creation

*/
constants
	MachineName             = "UTZY";
	StraddleStack1 			= "UT_ST001";
	QueueForStraddleStack1 	= "UT_ST001_Q";
vars
	machine,
	proxy                     : CM_Machine;
	st1,pxyStraddleStack      : CM_StraddleStack;
	q1		                  : CM_RadioTelemetryQueue;
	type, proxyType           : CM_MachineType;
	ta                        : CM_StraddleStack;
	taMaster                  : CM_TerminalAreaMaster;
begin
	self.deleteQueue(QueueForStraddleStack1);
	self.deleteTerminalArea(StraddleStack1);
	
	// add straddle stack area
	create pxyStraddleStack transient;
	pxyStraddleStack.setProxy(StraddleStack1, 
					"",
					TA_TYPE_STRADDLE_STACK, 
					2, 
					2, 
					2,
					true, 
					self.getTerminal,
					false,
					false,
					false,
					0, false, false, false, false, false, null,null, false, true, 
					"West", "East", "North", "Sourth");
	
	app.myTrxCA.trxCreateTerminalArea(pxyStraddleStack, taMaster, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// add queue for straddle stack area
	q1 	:= self.addQueueToTA(QueueForStraddleStack1, StraddleStack1);
	assertNotNull(q1);
	
	// add straddle stack area to the machine
	machine := self.getMachine(MachineName);
    type := app.myRoot.allMachineTypes[machine.machineType];
    beginTransaction;
	machine.addTAMaster(taMaster);
	commitTransaction;
	
	// trxUpdateMachineNextQueue
	beginLoad;
	proxy:=machine.pxyCreateUpdateProxy;
	endLoad;
	app.myTrxUA.trxUpdateMachineNextQueue(proxy,q1,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
epilog
	endLoad;				
	delete proxy;
	delete pxyStraddleStack;
end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateToDoTask" id="8a5d5b41-ad49-4cdf-a75c-eccffa7369c8">
        <source>tUpdateToDoTask();

/*

Purpose:		trxUpdateToDoTaskDesc
				trxUpdateTaskRemarks
				Testlink 01-184		

Parameters:			

Return Value:		


Date		Who		Reason
20 Oct 2015	cnwmk3	Initial creation
23 Jan 2023	navma1	ChangeRequest 54349[54262]: EUP - Enable Is Mandatory for ToDo Task Resources
*/
constants
	ToDoTaskCode                         : String = "UT_10101";
	ShortDesc                            : String = "Paint Damaged";
	TaskRemarks                          : String = "UT Remarks";
vars
	ti                                   : CM_TrackedItem;
	operator	                         : CM_Operator;
	tiSet                                : CM_TISet;
	toDoTask                             : CM_ToDoTaskDesc;
	proxyToDoTask                        : CM_ToDoTaskDesc;
	tiUpdateCntrlr						 : CMIF_TIUpdateController;
begin
     
	toDoTask := app.myRoot.allToDoTaskDescsByShortDesc[ToDoTaskCode];
	if toDoTask &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTask);
	endif;
	 
	 // create a ToDo task
	self.opts.purge();
	self.opts.addAssoc("RequiresExtraInfo", "Weight");
	self.opts.addAssoc(ETRow_TransactionToCreate, TRANS_TYPE_WEIGH);
	toDoTask := self.createToDoTaskDesc(ToDoTaskCode);
	self.assertNotNullMsg(toDoTask, "Add To Do Task failed");
	 // update a ToDo task
	beginLoad;
	proxyToDoTask := toDoTask.pxyCreateUpdateProxy();
	proxyToDoTask.setPropertyValue("description", ShortDesc);
	endLoad;
	 
	app.myTrxUA.trxUpdateToDoTaskDesc(proxyToDoTask, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	 
	 // add container
	self.deleteContainer("UT_CNTNR");
	operator := app.myRoot.allOperators["MSL"];
	ti 		 := self.addContainer("UT_CNTNR", operator,"2200","MT",TI_IMEX_STATUS_STORAGE);
	 
	 // add ToDo task to cargo
	create tiSet transient;
	tiSet.add(ti);
	self.addToDoTask(toDoTask, tiSet);
	 
	  // complete the task																		07/04/2016	cnwmk3 Testlink 01-184
	if ti.allToDoTasksToDo.first.toDoTaskDesc.requiredExtraInfo = EXTRA_INFO_WEIGHT then
		create tiUpdateCntrlr transient;
		tiUpdateCntrlr.userCode := app.getMyUserCode();
		beginTransaction;
		ti.setTotalWeight(5000, tiUpdateCntrlr, app.myPassport);
		ti.setIsWeightCertified(true, tiUpdateCntrlr, app.myPassport);
		commitTransaction;		
		self.completeToDoTask(toDoTask, tiSet,null);					//23.01.2023 navma1 #54349[54262]
	endif;
	 
	// check the new weight, Is Certified and the weighed trxn is created
	self.assertEqual(ti.allTransactions.last.type, TRANS_TYPE_WEIGH);
	self.assertEqual(ti.totalWeight, 5000.Decimal);
	self.assertEqual(ti.isWeightCertified, true);
	 
	// update to do task remarks
	setTerminalConfig(UseTaskFormCount, true);
	app.myTrxUA.trxUpdateTaskRemarks(TaskRemarks, toDoTask.allToDoTasks.first, app.myPassport);
	 
epilog
    delete proxyToDoTask;
	delete tiSet;
	delete tiUpdateCntrlr;
end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateUserStatus" id="47be1731-d703-436f-a75c-539b296ef406">
        <source>tUpdateUserStatus();
/*
jlgmd1

Purpose:			

Date			Who		Reason
19 October 2015	cnwmk3	Initial creation
19 June 2020	jlgmd1	TFS 49615 - validation for 'in use' users

*/
constants
    UsrName                           : String = "TestUser";
	UsrCode                           : String = "TEST01";
	BGPName							  : String = "UT-UUS-001";
vars
    user                              : CM_User;
	config							  : CM_WebSiteConfig;
	oldConfUsr						  : String;
	isOk							  : Boolean;
	bgpManager						  : BGP_Manager;
	bgpGeneric						  : BGP_GenericController;
	pxyManChild						  : CMIF_BGPManagerChildren;
	report							  : CM_ReportTemplate;
	oldRptUsr						  : CM_User;
begin
    
	// Cleanup/Reset from last time
	user := app.myRoot.allUsers[UsrCode];
	if user &lt;&gt; null then
		self.deleteUser(UsrCode);
		user := app.myRoot.allUsers[UsrCode];
		self.assertNull(user);
	endif;
	self.deleteBGPManager(BGPName);
	
    self.addUser(UsrName, UsrCode);
	user := app.myRoot.allUsers[UsrCode];
	
	// Change from EnabledNormalUser -&gt; NewUser
    app.myTrxUA.trxUpdateUserStatus(user, 1, NewUser, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// Add user to a web config
	foreach config in self.getRoot.allWebSiteConfigs do
		if config.publicUser &lt;&gt; null then
			break;
		else
			config := null;
		endif;
	endforeach;
	self.assertNotNull(config);
	
	oldConfUsr := config.publicUser;
	beginTransaction;
	config.setPropertyValue(CM_WebSiteConfig::publicUser.name, user.code);
	commitTransaction;
	
	// Add user to a BGP
	bgpManager := self.addBGPManager(BGPName);
	self.assertNotNull(bgpManager);
	
	bgpGeneric := bgpManager.allBGPControllers.first.BGP_GenericController;
	create pxyManChild transient;
	pxyManChild.myUser := user;
	app.myTrxUA.trxUpdateBGPControllerSetup(bgpGeneric, pxyManChild, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// Add user to a report template
	report := CM_ReportTemplate.firstInstance;
	oldRptUsr := report.myUserToRunAs;
	beginTransaction;
	report.setPropertyValue(CM_ReportTemplate::myUserToRunAs.name, user);
	commitTransaction;
	
	// Suspend/Disable user
	// Change from NewUser -&gt; DisabledBySysAdminUser
	app.myTrxUA.trxUpdateUserStatus(user, 2, DisabledBySysAdminUser, app.myPassport);
	self.assertTrxWarningMsg(UserInUseByWebConf, "Expecting Web Config warning. Got " &amp; app.myPassport.getAllErrorsAndWarningsAsStr());
	self.assertTrxWarningMsg(UserInUseByBGP, "Expecting BGP warning. Got " &amp; app.myPassport.getAllErrorsAndWarningsAsStr());
	self.assertTrxWarningMsg(UserInUseByReports, "Expecting Scheduled Reports warning. Got " &amp; app.myPassport.getAllErrorsAndWarningsAsStr());
	
	// (Try to) Delete User
	self.clearExpectedTrxErrors();
	self.expectTrxError(UserInUseByWebConf);
	self.expectTrxError(User_assigned_bgp_controller);
	self.expectTrxError(UserRunReportsErr);
	
	app.myTrxDA.trxDeleteUser(user, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.clearExpectedTrxErrors();
	
	// Reset any of our changes
	beginTransaction;
	config.setPropertyValue(CM_WebSiteConfig::publicUser.name, oldConfUsr);
	report.setPropertyValue(CM_ReportTemplate::myUserToRunAs.name, oldRptUsr);
	commitTransaction;
	
	self.deleteBGPManager(BGPName);
	
	// (Actually) Delete User
	app.myTrxDA.trxDeleteUser(user, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	isOk := true;
epilog
	if not isOk then
	// While this isn't great to put in an epilog, try and undo any changes we might have made
		beginTransaction;
		if config &lt;&gt; null then
			config.setPropertyValue(CM_WebSiteConfig::publicUser.name, oldConfUsr);
		endif;
		if report &lt;&gt; null then
			report.setPropertyValue(CM_ReportTemplate::myUserToRunAs.name, oldRptUsr);
		endif;
		commitTransaction;
	endif;
	
	delete pxyManChild;
end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateVoyageAllocNum" id="93320eee-75f9-4106-8733-707e67db8890">
        <updating/>
        <source>tUpdateVoyageAllocNum()updating;
/*

Purpose:			

Date		Who		Reason
13 October 2015	cnwmk3	Initial creation

*/
constants
    VesselId						: String = "MESDIAM";
	VoyageId						: String = "UTVOY01";
vars
    vessel                              : CM_Vessel;
	voyage                              : CM_Voyage;
	allocs                              : CM_YardAllocationSet;
	proxyAllocs,realAlloc               : CM_VoyageAllocation;
begin
	
	//self.deleteVessel(VesselId);
	self.deleteVoyage(VoyageId);
	//self.assertNull(self.getVessel(VesselId));
	self.assertNull(self.getVoyage(VoyageId));
	
	//vessel := self.addVesselLOLOholdsRORO(VesselId, self.getOperator("ANL"));
	//self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	voyage := self.addVoyageWithConRORO(VoyageId, VesselId, "ANL", "ANZ", null, 0, false, true);
	self.assertNotNull(voyage);
	
	realAlloc := self.addVoyageAllocation(voyage, "NZAKL", "GEN2", null, TI_CargoType_Container, false, false);
	
	beginLoad;
	proxyAllocs := realAlloc.pxyCreateUpdateProxy();
	endLoad;
	
    proxyAllocs.setProxyProjectedValues(30,0,0,0,0,0);
	
	create allocs transient;
	allocs.add(proxyAllocs);
	
    app.myTrxUA.trxUpdateVoyageAllocNumbers(allocs, app.myPassport);
	
epilog
    delete proxyAllocs;
    delete allocs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tUserMisc" id="4cd06c3f-97d0-4925-9174-edf5fc4bcc52">
        <updating/>
        <source>tUserMisc() updating;

/*

Purpose:		

				trxUpdatePassword					Done
				trxCreateSecurityRole				Done
				trxUpdateSecurityRole				Done
				trxDeleteSecurityRole				Done
				trxUpdUserToobarShowCaptions		Done
					

Date			Who		Reason
10/02/2014		cnwmh5	Initial creation

*/
constants
	MyPassword						: String = "u^1tTest1";
	MyPassword2						: String = "u^1tTest2";
vars

	securityRoleSystem				: CM_SecurityRoleSystem;
	securityRoleTerminal			: CM_SecurityRoleTerminal;
	user							: CM_User;
	passport						: CM_Passport;
	cargoType						: CM_CargoType;
	
	result							: Integer;
	
	auditObject : CM_AuditObject;

begin

	// create security role
	securityRoleSystem := self.addSecurityRole(true, "UTMDHSYS").CM_SecurityRoleSystem;
	self.assertNotNull(securityRoleSystem);
	securityRoleTerminal := self.addSecurityRole(false, "UTMDHTER").CM_SecurityRoleTerminal;
	self.assertNotNull(securityRoleTerminal);

	// update security role
	app.myPassport.setWarningsIgnored(true);
	self.updateSecurityRole(securityRoleSystem);
	self.assertEqual(securityRoleSystem.mySecurityRoleVisibility.availableToShippingCompany, false);
	app.myPassport.setWarningsIgnored(false);
	
	// create user
	self.opts.purge();
	self.opts.addAssoc("SysSecurityRole", securityRoleSystem);
	self.opts.addAssoc("UserPassword", MyPassword);
	user := self.addUser("UTMDH1", "UTMDH1");
	self.assertNotNull(user);
	
	//12 Aug 2020	NDL	TFS 49857
	auditObject := user.allAuditObjectChangesToMe.first;
	self.assertTrueMsg( auditObject &lt;&gt; null, "No Audit Object created for User" );
	self.assertTrueMsg( auditObject.auditText.pos("System Security Role ^8^UTMDHSYS",1) &gt; 1 , "Audit does not include 'System Security Role'" );
	self.assertTrueMsg( auditObject.auditText.pos("Organisation ^16^UnitTestTerminal",1) &gt; 1 , "Audit does not include 'Organisation'" );
	
	// set user show captions
	app.myTrxUA.trxUpdUserToolbarShowCaptions(user, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(user.myMenuUserToolbarRoot.showCaption, true);
	app.myTrxUA.trxUpdUserToolbarShowCaptions(user, false, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(user.myMenuUserToolbarRoot.showCaption, false);
	
	// update the users password
	app.myTrxUA.trxUpdatePassword(false, user.code, MyPassword, MyPassword2, MyPassword2, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// 18/05/2015 cnwmh5
	cargoType := app.myRoot.getCargoTypeFromAbbrev("CONT");
	self.assertNotNull(cargoType);
	
	self.opts.purge();
	self.opts.addAssoc("UserPassword", MyPassword2);
	self.opts.addAssoc("RequestedUser", user.code);
	self.addUserTerminalToUser(cargoType);
	
	return;
	// log user on
	passport := app.myPassport;
	result := app.myTrxUA.trxUpdateLogon(user.code, MyPassword2,null, passport);
	//dsl.assertNoTrxErrorsOrWarnings();
	if app.myPassport.hasErrorsOrWarnings() or result &gt; 0 then
		app.writeLog('Has errors or warnings. Result=' &amp; result.String &amp; CrLf &amp; app.myPassport.getAllErrorsAndWarnsFullAsStr() &amp; Tab &amp; 
			'.  Exiting JadeScript...', LogINFO);
		return;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tVGMRTS" id="499f854c-8a99-443b-b3cc-67fb8612e5f0">
        <source>tVGMRTS();

/*

Purpose:		VGM RTS Allowed no VMG Details

Date			Who		Reason
07/07/2016		cnwmh5	Initial creation

*/

vars

	bs							: CM_BlockStack;
	cont						: CM_Container;
	operator					: CM_Operator;
	voyage						: CM_Voyage;
	
	tiArray						: CM_TIArray;

begin

	// get the operator
	operator := app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString()];
	self.assertNotNull(operator);

	// setup the block stack
	bs := self.addBlockStack("MHBSM1", 99, null);
	self.assertNotNull(bs);
	
	// setup the voyage
	voyage := self.getVoyage("UTMDHVGMRTS");
	if voyage &lt;&gt; null then
		self.deleteVoyage(voyage.code);
	endif;
	voyage := self.addVoyageNonPlannedNonWorked("UTMDHVGMRTS", "MESDIAM", operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString());
	self.assertNotNull(voyage);
	
	// setup the container
	cont := self.getTrackedItem("UTMHVGMVTS1").CM_Container;
	if cont &lt;&gt; null then
		self.deleteTrackedItem(cont, false);
	endif;
	cont := self.addContainerAtLocation("UTMHVGMVTS1", operator, "2200", "GENL", TI_IMEX_STATUS_IMPORT, bs.allLocationsControllers.first);
	self.assertNotNull(cont);
	
	// make the container ready to ship
	create tiArray transient;
	self.opts.purge();
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("CENum", "12345");
	self.updateTI(cont);
	self.deleteStops(cont);
	tiArray.add(cont);
	
	// with AllowRTSwithoutVGM turned off should get warning
	self.setTerminalConfig(AllowRTSwithoutVGM, false);
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Not_ready_ship_until_weigh_cer);
	app.myTrxUA.trxUpdateTIsReadyToShip(tiArray, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
		
	// with AllowRTSwithoutVGM turned on should get nothing
	self.setTerminalConfig(AllowRTSwithoutVGM, true);
	app.myTrxUA.trxUpdateTIsReadyToShip(tiArray, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

epilog

	delete tiArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="tVehicleTimeSlot" id="c3759f49-91c3-4f49-a1c3-2226b82cf8ca">
        <source>tVehicleTimeSlot();
/*

Purpose:			

Date		Who		Reason
06 November 2015	cnwmk3	Initial creation

*/

vars
   proxyTimeSlot                          : CM_TimeSlotStd;
   newTimeSlot                            : CM_TimeSlotEntity;
   pStartTime                             : Time;
begin
// create a time slot
   create proxyTimeSlot transient;
   proxyTimeSlot.setProxy(Day, pStartTime, 5, self.getTerminal());
   app.myTrxCA.trxCreateTimeSlot(proxyTimeSlot, app.myPassport, newTimeSlot, true);
   self.assertNoTrxErrorsOrWarnings();
   self.assertNotNull(newTimeSlot);
epilog
   delete proxyTimeSlot;
end;</source>
    </JadeMethod>
    <JadeMethod name="tVoyageMachineMisc" id="04420e91-9ba5-4b73-a6a0-6a67cb454c38">
        <source>tVoyageMachineMisc();

/*

Purpose:		Voyage and Machine miscellaneous

				trxCreateStowageConfirmation				Done
				trxTransferVoyageJobsToCrane				Done
				trxUpdateUnassignRelease					Done
				trxProcessStopsEDIOnShip					Done
				trxRunImportTasksOnShip						Done
				trxAutoPlanMutlpleTIs						Done
				
				trxSetMediatorState							Done
				trxPickupWithTask							Done
				trxEnqTrackedItem							Done
				trxUpdateQueueEntryPosition					Done
				trxMOveTI									Done
				trxUpdateRTResetMediator					Done
				trxUpdateGradeForTI							Done
				
				[Non client]
				trxAcceptTask								Called from trxPickupWithTask if accept set to true
				trxSetDown									Done
				trxPickup									Done
				trxRejectTask								Done
				trxChangeAllTasksStatus						Done
				trxChangeTaskStatus							Done
				trxManipulateOnHold							Done
				trxMarkSlotForDischarge						Done
				
				trxUpdateCraneMoveRates						Done
				trxUpdateCraneSeedJobNumber					Done
				trxUpdateDischargePorts						Done								
				trxUpdateRORODeckRemarks					Done
				trxUpdateRORODecksOrdinal					Done
				trxUpdateSlotControllerUnplan				Done
				trxUpdateVoyageJobSheetJobs					Done
				trxUpdateVoyageRemarks						Done
				
Date			Who		Reason
10/02/2014		cnwmh5	Initial creation

*/
constants

	VesselId					: String = "MESDIAM";
	VoyageId					: String = "UTMHVOY14";

vars

	voyage						: CM_Voyage;
	crane						: CM_Machine;
	cta							: CM_CraneTransferArea;
	pxyCraneMoveRate			: CM_CraneMoveRates;
	craneMoveRate				: CM_CraneMoveRates;
	deck						: CM_DeckVoyage;
	fk1							: CM_ForkLiftStack;
	forklift					: CM_Machine;
	blockStack					: CM_BlockStack;
	ti							: CM_TrackedItem;
	
	tas							: StringArray;
	slotsToFill					: StringArray;
	locations					: CM_LCArray;
	tiArray						: CM_TIArray;
	
	ts							: TimeStamp;
    noImportStops :Boolean;
begin
    noImportStops := self.getTerminalConfig(NoImportStops).Boolean;
    self.setTerminalConfig(NoImportStops, false);

	self.disableAllYA(true);
	
	// create blockstack
	blockStack := self.addBlockStack("UTMHBSH", 99, null);
	self.assertNotNull(blockStack);	
	
	// create yard allocation;
	self.deleteYA("UTMHBSH");
	create locations transient;
	locations.add(blockStack.allLocationsControllers.first.CM_YardController);
	self.addYA1("UTMHBSH", YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, locations);

	self.deleteVoyage(VoyageId);
	voyage := self.addVoyageWithConRORO(VoyageId, VesselId, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, 
		self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, self.getProfileSetting(UT_Profile.P_TRADE).asString, 
		0, false, true);
	self.assertNotNull(voyage);
	
	// update the voyage remarks
	ts := app.cnGetServerTime();
	app.myTrxUA.trxUpdateVoyageRemarks(voyage, "Updated voyage remarks at " &amp; ts.String, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(voyage.remarks, "Updated voyage remarks at " &amp; ts.String);
	
	// RORO Deck Remarks
	deck := voyage.myROROStructure.allDecksByCode.first;
	self.assertNotNull(deck);
	app.myTrxUA.trxUpdateRORODeckRemarks(deck, "Deck " &amp; deck.description &amp; " remarks Updated " &amp; ts.String, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(deck.remarks, "Deck " &amp; deck.description &amp; " remarks Updated " &amp; ts.String);

	// create the crane transfer area
	self.deleteMachine("CRMH");
	self.opts.purge();
	self.opts.addAssoc("SetCraneLaneCages", true);
	self.deleteTerminalArea("UTCRMH");
	cta := self.addCraneTransferArea("UTCRMH");
	self.assertNotNull(cta);
	
	// create crane CRMH
	create tas transient;
	tas.add(cta.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	self.opts.addAssoc("BaseJobNumber", 600);
	crane := self.addCrane("CRMH", null, tas, null);
	self.assertNotNull(crane);
	
	// create crane move rate
	create pxyCraneMoveRate transient;
	pxyCraneMoveRate.setProxy(10, 11, 12,13, 14);
	app.myTrxCA.trxCreateCraneMoveRates(pxyCraneMoveRate, craneMoveRate, crane.CM_Crane, voyage.myVessel, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(craneMoveRate);
	
	// create forklift to use
	fk1 := self.addForkLiftStack("UTFKUTUT", 5, 5, 5);
	self.deleteMachine("UTTU");
	self.deleteRTDevice("88");
	tas.clear();
	tas.add(fk1.id); 
	tas.add(blockStack.id);
	forklift := self.addForkLift("UTTU", 88, tas, crane.CM_Crane.getQueue().id);
	assertNotNull(forklift);

	// test Run Import Tasks On Ship
	self.xTestRunImportTasksOnShip(voyage);
	
	// auto plan tis
	self.xAutoPlanMoveTIs(voyage);
	
	// trxUpdateRORODecksOrdinal
	self.xRORODeckOrdinal(voyage);
	
	// plan stuff onto the voyage
	self.xLoadStuffBackToVoyage(voyage);
	
	
	// release request
	self.xReleaseRequests(voyage);
	
	if forklift.myMachineController &lt;&gt; null then
		create tiArray transient;
		forklift.myMachineController.allTrackedItems.copy(tiArray);
		foreach ti in tiArray do
			if ti.isPlanned(PLANNING_MODE) or ti.isQueued then
				self.moveIT(ti, REAL_MODE);
				self.assertNoTrxErrorsOrWarnings();		
			endif;
		endforeach;
	endif;
	
	// Update the forklifts machine type
	self.opts.purge();
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	self.updateMachine(forklift);
	self.assertEqual(forklift.machineLiftType, TWIN_LIFT);
	
epilog
	self.setTerminalConfig(NoImportStops, noImportStops);

	self.disableAllYA(false);

	delete slotsToFill;
	delete tas;
	delete pxyCraneMoveRate;
	delete locations;
	delete tiArray;
	
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;MDHFAILSTEST&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
