<Class name="CM_MenuRootForUser" id="f7a0df69-d801-4960-b217-d5131ac4813f">
    <superclass name="CM_MenuRoot"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmenu"/>
    <ExplicitInverseRef name="myUser" id="7228eb0a-dea0-45e9-8339-a14f7413e01f">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_User"/>
        <access>readonly</access>
        <Inverse name="CM_User::myMenuRootForSysEntities"/>
    </ExplicitInverseRef>
    <PrimAttribute name="position" id="48bc2554-418e-4b83-8b7a-84ecb9aaf0b0">
