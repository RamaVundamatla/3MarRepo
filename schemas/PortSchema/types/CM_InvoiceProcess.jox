    <JadeMethod name="validateForCreate" id="62751a66-c155-4f37-9579-94521a063504">
        <source>validateForCreate(_passport : CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Oct 2018	jlgsl4	TFS 39618 - LNX - Invoice Approved Status

*/

vars

begin
	if self.myRoot.allInvoiceProcesses[self.code] &lt;&gt; null then
		app.raiseCMException1(Duplicate_code_must_unique, self.code, null, null);
	endif;
	self.validateSelf();
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
