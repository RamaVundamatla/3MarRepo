    <JadeMethod name="trxCreateEDIData" id="49547d14-6abf-44b7-8f9b-2b6e92651120">
        <updating/>
        <source>trxCreateEDIData(_realEdiData	: CM_EDIData io;
				 _ediDataClass	: Class;
		//		 _singleDataFile: Boolean; // cnwrs1 Par 24207 ccms 1117 11 May 2010
				 _type			: Integer;
				 _fileTypeCode : Integer;
				 _ediConfig	: CM_EDIConfig input;
				 _realEdiFile 	: CM_EDIFile input;
				 _ediFileType : CM_EDIFileType;
				 _passport		: CM_Passport input) updating;

// cnwdvb1 29 January 2003 
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	app.myUtilityCA.utlCreateEDIData(_realEdiData, _ediDataClass, _type, _fileTypeCode, _ediConfig, _realEdiFile, _ediFileType, _passport); // cnwrs1 Par 24207 ccms 1117 11 May 2010
epilog
	self.finaliseActivityWithPassport(_passport);	
end;</source>
