    <JadeMethod name="recoverFromDisruptedState" id="9655fb59-4503-4dd4-a477-57952841cc06">
        <updating/>
        <source>recoverFromDisruptedState(_form: JMMobileClient_BaseForm input; _state: Integer output; _lastState: Integer output; _errorString: String output; _lastUpdateTs: TimeStamp output): Boolean updating;
// -------------------------------------------
// Created 20 January 2006 by cnwdvb1
// -------------------------------------------
vars

	recoverRequest 				: WebSrv_RecoverFromDisrupt;
	recoverResponse				: WebServ_RecoverFromDisResponse;
	dtoResponseIn,
	dtoResponseOut				: WebSrv_DTO_EnquiryGradingTasks;
	dtoStateOut					: WebSrv_DTO_StateInfo;
	rtnValue					: Boolean;

begin

	create recoverRequest transient;
	create dtoResponseIn transient;

	self.clearStateObject();

	recoverRequest.dto 			:= dtoResponseIn;
	recoverRequest.stateInfo	:= self.myStateObjIn;
	
	recoverResponse := self.myWebSrvProvider.recoverFromDisruptedState(recoverRequest);
	
	
	dtoResponseOut		:= recoverResponse.dto;
	dtoStateOut			:= recoverResponse.stateInfo;
	
	if dtoResponseOut = null then
		self.mbRaiseException($MB_INVALID_RESPONSE);
		return false;
	endif;
	
	if dtoStateOut = null then
		self.mbRaiseException($MB_INVALID_RESPONSE);
		return false;
	endif;
	
	rtnValue := recoverResponse.recoverFromDisruptedStateResul;

	_errorString	:= dtoStateOut.errorString;
	_state			:= dtoStateOut.guiState;
	
	if rtnValue then
		_form.loadFormFromWebSrvObj(dtoResponseOut);
	endif;
		
	return rtnValue;
	
epilog

	delete recoverRequest;
	delete recoverResponse;
	delete dtoResponseIn;
	delete dtoResponseOut;
	delete dtoStateOut;

end;</source>
