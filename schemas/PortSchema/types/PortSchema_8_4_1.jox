    <JadeMethod name="cCMS1405ConvertClass" id="0321465f-abd3-44f6-af92-cbdee5766537">
        <source>cCMS1405ConvertClass(_class : Class) protected;
/*

Date		Who		Reason
09 December 2014	cnwer1	Initial creation PAR

*/

vars
	toDelete,
	os : ObjectSet;
	o : Object;
	t			: CM_EventTransaction;
begin
	if _class = null then
		return;
	endif;
	
	app.writeLog( method.qualifiedName &amp; " Converting event type class " &amp; _class.name &amp; " for 8.4.1", LogINFO);
	create toDelete transient;
	create os transient;
	_class.instances.copy(os);
	if os.first &lt;&gt; null then
			beginTransaction;
			foreach o in os discreteLock do
				
				t:=o.sendMsg("convertForCCMS1405").CM_EventTransaction;	
				if t &lt;&gt; null then
					toDelete.add(o);
				endif;
			endforeach;
			if not toDelete.isEmpty then
				toDelete.purge;	
			endif;	
		commitTransaction;
	endif;
epilog
	delete os;
	delete toDelete;
end;</source>
        <access>protected</access>
        <Parameter name="_class" type="Class"/>
    </JadeMethod>
    <JadeMethod name="convertHMSDelays" id="dbc322c6-9e87-4ac8-818e-41fdcee1013d">
        <updating/>
        <source>convertHMSDelays() updating;
//
// Purpose:			Convert HMS_VoyageDelay objects in to CM_Delay objects
//					Convert HMS_Delay objects in to CM_DelayType objects
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 29/12/2014	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394 Voyage Rationalisation
//
vars
	hmsDelayType 			: HMS_Delay;
	hmsDelay 				: HMS_VoyageDelay;
	pxyDelay, delay, realDelay 		: CM_Delay;
	pxyDelayType, delayType : CM_DelayType;
	allDelayTypeGroups		: CM_DelayTypeGroupSet;
	failedHMSDelays			: HMS_DelayByCodeDict;
	code					: String;
	alreadyDone				: Boolean;

begin
	app.writeLog(" Converting HMS_Delay and HMS_VoyageDelay instances to CM_DelayType and CM_Delay instances", LogINFO);
	create allDelayTypeGroups transient;
	create failedHMSDelays transient;
	
	// read all HMS_Delay objects and create a CM_DelayType object for each
	foreach hmsDelayType in app.myRoot.allHMSDelays do
		if app.myRoot.allDelayTypes[hmsDelayType.description[1:30]] &lt;&gt; null then
			code := hmsDelayType.code &amp; Space &amp; hmsDelayType.description;
		else
			code := hmsDelayType.description;
		endif;
		if code.length &gt; 30 then
			code := code[1:30];
		endif;
		if app.myRoot.allDelayTypes[code] &lt;&gt; null then
			// already done
			continue;
		endif;
		create pxyDelayType transient;
		pxyDelayType.setProxy(app.myRoot, allDelayTypeGroups, null, code, false, false, true, false, true, true, null);
		app.myTrxCA.trxCreateDelayType(pxyDelayType, delayType, app.myPassport);
		delete pxyDelayType;
		if app.myPassport.hasErrorsOrWarnings then
			failedHMSDelays.add(hmsDelayType);
			app.writeLog(" Failed to convert HMS_Delay " &amp; hmsDelayType.code &amp; Space &amp; hmsDelayType.description, LogINFO);
			continue;
		endif;
	endforeach;
	if not failedHMSDelays.isEmpty then
		return;
	endif;
	
	// now read through all HMS delays and create a matching CM_Delay instance
	foreach hmsDelay in HMS_VoyageDelay.instances do
		if failedHMSDelays.includes(hmsDelay.myDelay) then
			app.writeLog(" skipped HMS_VoyageDelay " &amp; hmsDelay.getOidString &amp; ", delay type was not converted", LogINFO);
			continue;
		endif;
		// ignore archived delays
		if hmsDelay.isArchived then
			continue;
		endif;
		
		code := hmsDelay.myDelay.description;
		if app.myRoot.allDelayTypes[code] &lt;&gt; null then
			code := hmsDelay.myDelay.description;
		else
			code := hmsDelay.myDelay.code &amp; Space &amp; hmsDelay.myDelay.description;
		endif;
		if code.length &gt; 30 then
			code := code[1:30];
		endif;
		delayType := app.myRoot.allDelayTypes[code];
		if delayType = null then
			app.writeLog(" Failed to find a converted delay Type for " &amp; code &amp; " from HMS_VoyageDelay " &amp; hmsDelay.getOidString, LogINFO);
			continue;
		endif;
		alreadyDone := false;
		foreach delay in hmsDelay.myVoyageData.myVoyage.allDelays do
			if delay.startDT = hmsDelay.startTime and delay.myDelayType.description = code then
				alreadyDone := true;
				break;
			endif;
		endforeach;
		if alreadyDone then
			continue;
		endif;
		
		create pxyDelay transient;
		pxyDelay.setProxy(	hmsDelay.myVoyageData.getMyTerminal, 
							hmsDelay.myVoyageData.myVoyage, 
							delayType,
							hmsDelay.startTime,
							null,
							hmsDelay.stopTime,
							null,
							null,
							null,
							null	);
		app.myTrxCA.trxCreateDelay(pxyDelay, realDelay, app.myPassport);
		if app.myPassport.noErrors and not app.myPassport.noWarnings then
			app.myPassport.warningsAcknowledged := true;
			app.myTrxCA.trxCreateDelay(pxyDelay, realDelay, app.myPassport);
		endif;
		if app.myPassport.hasErrors or app.myPassport.allWarnings.size &gt; 1 or (app.myPassport.allWarnings.size = 1 and app.myPassport.allWarnings.first.errorCode &lt;&gt; 82849) then
			app.writeLog(" failed to create CM_Delay for HMS_VoyageDelay " &amp; hmsDelay.getOidString &amp; Space &amp; app.myPassport.getErrorsAndWarningsAsString, LogINFO);
		endif;
		delete pxyDelay;
	endforeach;
	
epilog
	delete allDelayTypeGroups;
	delete pxyDelayType;
	delete pxyDelay;
	delete failedHMSDelays;
end;</source>
    </JadeMethod>
    <JadeMethod name="convertTBAMatch" id="70d4b453-ed65-46eb-8103-fa1f71a0685e">
        <source>convertTBAMatch();
/*
Purpose:			convert yard TBA to use the new inversed reference
Date		Who		Reason
