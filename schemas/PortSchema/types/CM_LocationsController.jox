Date		Who		Reason
17 January 2019	jlgndl1	Initial creation	TFS 42292

*/

vars

	iter : Iterator;
	count : Integer;
	ti : CM_TrackedItem;

begin

	iter := self.allTrackedItems.createIterator;
	while iter.next( ti ) do
		if ti.myPrimaryQueuedLocation &lt;&gt; null then
			count := count + 1;
		endif;
	endwhile;
	
	return count;

epilog

	delete iter;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
