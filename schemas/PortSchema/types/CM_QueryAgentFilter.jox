    <JadeMethod name="createEnqControllerForMode" id="bb3d4c43-0edb-4761-9c12-21639bad07b6">
        <source>createEnqControllerForMode(_qDefMode : Integer; _qDefType : Integer;
							_enqController : CM_EnquiryController output);
// ---------------------------------------------------------------------------
// Created:     03 November 2003	cnwth2
//
// Purpose:     Called when setting up a selector query - return query controllers
//			 
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 23/05/2013	cnwdap1		PAR #31486 New User-Defined Cargo mode
// 23 Dec 2022  navhl20 	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
// 18 Feb 2023  navmv20     TFS 55649 Task 55689: UI - Selector Query Contracts
// 10 May 2023  navlw1 		ChangeRequest 53902: EUP - VBS MTN - [6] - Selector Query and JRW
vars

begin

	//14 May 2014	NDL	Par 34142
	if _qDefType = CM_QueryDefinition.Invoicing_Query_Type then
		if _qDefMode = CM_QueryDefinition.Invoice_Query_Mode then
			create _enqController as CM_EnqControllerInvoice transient;
		elseif _qDefMode = CM_QueryDefinition.InvoiceLine_Query_Mode then
			create _enqController as CM_EnqControllerInvoiceLine transient;
		elseif _qDefMode = CM_QueryDefinition.Contract_Query_Mode then //18/02/2023 navmv20 TFS 55649 TASK 55689
			create _enqController as CM_EnqControllerContract transient; //18/02/2023 navmv20 TFS 55649 TASK 55689
		endif;
	//14 May 2014	NDL	Par 34142	
	elseif _qDefType = CM_QueryDefinition.Cash_Query_Type then
		if _qDefMode = CM_QueryDefinition.CashPayment_Query_Mode then
			create _enqController as CM_EnqControllerCashPayment transient;
		elseif _qDefMode = CM_QueryDefinition.CashReceipt_Query_Mode then
			create _enqController as CM_EnqControllerCashReceipt transient;
		endif;
	elseif _qDefType = CM_QueryDefinition.Audit_Query_Type then
		if _qDefMode = CM_QueryDefinition.Audit_Query_Mode then
			create _enqController as CM_EnqControllerAuditObject transient;
		endif;
	elseif _qDefMode = null then
		create _enqController as CM_EnqControllerTI transient;
	//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
	elseif _qDefMode = CM_QueryDefinition.CargoTransaction_Query_Mode then
		create _enqController as CM_EnqControllerCargoTrans transient;
	elseif _qDefMode = CM_QueryDefinition.EventTransaction_Query_Mode then
		create _enqController as CM_EnqControllerEventTrans transient;
	elseif _qDefMode = CM_QueryDefinition.HMSTransaction_Query_Mode then
		create _enqController as CM_EnqControllerHMSTrans transient;
	elseif _qDefMode = CM_QueryDefinition.BOLTransaction_Query_Mode then	//04 Nov 2019	NDL	TFS 47100
		create _enqController as CM_EnqControllerBOLTrans transient;
	elseif _qDefMode = CM_QueryDefinition.WorkOrderTrans_Query_Mode then	//23.12.2022 navhl20 #54350[54269]
		create _enqController as CM_EnqControllerWOTrans transient;		//23.12.2022 navhl20 #54350[54269]
	elseif _qDefMode = CM_QueryDefinition.VehicleBookingSlot_Query_Mode then
		create _enqController as CM_EnqControllerVehicleBooking transient;	//10.05.2023 navlw1 #53902
	elseif _qDefMode = CM_QueryDefinition.Location_Activity_Query_Mode then	//13 Apr 2021	NDL	TF 50906
		create _enqController as CM_EnqControllerLocationAct transient;
	elseif (_qDefMode &gt; BOLType_Min) and (_qDefMode &lt; BOLType_Max) then
		create _enqController as CM_EnqControllerBOL transient;
	elseif _qDefMode = TI_CargoType_BreakBulk then 
		create _enqController as CM_EnqControllerBreakBulk transient;
	elseif _qDefMode = TI_CargoType_Car then 
		create _enqController as CM_EnqControllerCar transient;
	elseif _qDefMode = TI_CargoType_COU then 
		create _enqController as CM_EnqControllerCOU transient;
	elseif _qDefMode = TI_CargoType_Container then  
		create _enqController as CM_EnqControllerContainer transient;
	elseif _qDefMode = TI_CargoType_Generator then  
		create _enqController as CM_EnqControllerGenerator transient;	
	elseif _qDefMode = TI_CargoType_LCL then  
		create _enqController as CM_EnqControllerLCL transient;
	elseif _qDefMode = TI_CargoType_Log then  
		create _enqController as CM_EnqControllerLog transient;
	elseif _qDefMode = TI_CargoType_Timber then  
		create _enqController as CM_EnqControllerTimber transient;
	elseif _qDefMode = TI_CargoType_Tower then  
		create _enqController as CM_EnqControllerTower transient;
	elseif _qDefMode = TI_CargoType_Chassis then
		create _enqController as CM_EnqControllerTILC transient;								//+cnwml2 MSL CCMS 1027
	elseif _qDefMode &gt; BOLType_Max then //warehouse cargo type  
		create _enqController as CM_EnqControllerBreakBulkGen transient;
	
	elseif _qDefMode = CM_QueryDefinition.UserDefined_Query_Mode then							// PAR #31486
		create _enqController as CM_EnqControllerBreakBulkGen transient;						// PAR #31486
	endif;

end;</source>
        <Parameter name="_qDefMode" type="Integer"/>
        <Parameter name="_qDefType" type="Integer"/>
        <Parameter name="_enqController" type="CM_EnquiryController" usage="output"/>
    </JadeMethod>
    <JadeMethod name="createJRWTransient" id="4628a7a7-15c4-4b2e-87d9-ad06bf188ae5">
        <source>createJRWTransient(_classToCreate : Class) : CM_JRWTransient;
// ---------------------------------------------------------------------------
// Created:     05 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	jrwTransient	: CM_JRWTransient;

begin

	if _classToCreate = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'class to create', null, null);
		app.raiseCMException(Input_required_field_clsToCrte, null, null); // cnwdb2	PAR 35364


		return null;
	endif;
	
	self.allJRWTransients.purge;
	
	create jrwTransient as _classToCreate transient;
	self.allJRWTransients.add(jrwTransient);

	return jrwTransient;
	
end;</source>
        <Parameter name="_classToCreate" type="Class"/>
        <ReturnType type="CM_JRWTransient"/>
    </JadeMethod>
    <JadeMethod name="delete" id="413356fc-8dfb-4187-ba4b-0bdfbeb5cb2c">
        <updating/>
        <source>delete() updating;
// -----------------------------------------------------------------------------
// Created:		07 June 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	//this should be no overhead for a transient obj
	if global.isValidObject(self.myRWLogDocket) then
		delete self.myRWLogDocket;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="getReportsToRun" id="fd2bba00-23b2-40b5-900d-e4315d950af5">
        <updating/>
        <source>getReportsToRun(_qryReport : CM_QryReport; _filterReport: CMQF_FilterReports; _reportArray : StringArray input) updating;
// -------------------------------------------
// Created 22 September 2004 by cnwdvb1
// -------------------------------------------
vars

	jrwTransient	: CM_JRWTransient;
	emptyFilter		: CMQF_Empty;
begin

	if _reportArray = null then
		return;
	endif;
	
	_reportArray.clear();
	self.isNoDataReport := false;
	if _qryReport.reportType &lt;&gt; CM_QryReportUser.ReportType_External then
		if self.noOutputReturned() then
			_reportArray.add('CM_NoDataRpt');
			jrwTransient := self.allJRWTransients.first;
			if jrwTransient &lt;&gt; null then
				jrwTransient.reportName := _qryReport.heading;
			endif;
			self.isNoDataReport := true;
			return;
		endif;
	endif;

	_qryReport.jrwReportName.copy(_reportArray);

	//additional report designs to run
	if _filterReport &lt;&gt; null
	and CMQF_Empty.hasInstance(_filterReport) then
		emptyFilter := _filterReport.CMQF_Empty;
		if emptyFilter.printMTSummaryRep then
			_reportArray.add('CM_MTSummaryRep');
		endif;
	endif;

end;</source>
        <Parameter name="_qryReport" type="CM_QryReport"/>
        <Parameter name="_filterReport" type="CMQF_FilterReports"/>
        <Parameter name="_reportArray" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="noOutputReturned" id="de4b3012-d647-4495-ba33-c1e78a1488dc">
        <source>noOutputReturned() : Boolean;
// -------------------------------------------
// Created 22 September 2004 by cnwdvb1
// -------------------------------------------
vars

	jrwTransient	: CM_JRWTransient; 
	rtnValue		: Boolean;

begin

	foreach jrwTransient in self.allJRWTransients do
		if not jrwTransient.noOutputReturned() then
			rtnValue := true;
		endif;
	endforeach;

	return not rtnValue;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="qryAnyDataObject" id="527dee9f-8bab-4a19-bcad-b476fe9e1ca1">
        <updating/>
        <source>qryAnyDataObject(_filter : CMQF_AnyDataObject input; _passport : CM_Passport) : Integer updating;

// cnwdvb1 22 April 2003 

vars

	jrwTrans : CM_JRWAnyDataObject;
	jrwGateReceiptTrans : CM_JRWGateReceipt;
	jrwTITrans	: CM_JRWTrackedItems;
	visit : CM_VehicleVisitRecord;

begin

	// 18 Mar 2010 - NDL - Kludge to allow print of Road Gate Receipt report
	// via BGP from Hand Held, using CM_VehicleVisitRecord::printReceiptViaBGPforHandHelds
	// CCMS MES 1005
	if _filter.dataClass = CM_VehicleVisitRecord.name then
		jrwGateReceiptTrans := self.createJRWTransient(CM_JRWGateReceipt).CM_JRWGateReceipt;
		visit := _filter.getMyDataObject.CM_VehicleVisitRecord;
		//jrwGateReceiptTrans.allTerminals.add(visit.myTerminal);
		jrwGateReceiptTrans.setTerminal(visit.myTerminal);	//13 June 2013	NDL	Par 31562
		jrwGateReceiptTrans.myVehicleVisit := visit;
		jrwGateReceiptTrans.vehicleVisitOid := visit.getOidAsString();
		if _filter.allGroupingAttributes.isEmpty then	//16 Dec 2013	NDL	Par 2336
			visit.allReceivedTrackedItems.copy (jrwGateReceiptTrans.allTrackedItems);
			visit.allReleasedTrackedItems.copy (jrwGateReceiptTrans.allTrackedItems); 
		else
			_filter.getCollectionDataCopyTo( jrwGateReceiptTrans.allTrackedItems );	//16 Dec 2013	NDL	Par 2336
		endif;
		return (jrwGateReceiptTrans.myVehicleVisit &lt;&gt; null).Integer;
	endif;

	// Changed dataObject to be a CM_RoadJob because report writer having
	// trouble with two levels of inheritance.
	if _filter.dataClass = CM_RoadJob.name then
		jrwTrans := self.createJRWTransient(CM_JRWAnyDataObject).CM_JRWAnyDataObject;
		jrwTrans.myDataObject := _filter.getMyDataObject.CM_RoadJob;
	endif;
	// TFS 985 hand-held label printing
	if _filter.dataClass = CM_TrackedItem.name then
		jrwTITrans := self.createJRWTransient(CM_JRWTrackedItems).CM_JRWTrackedItems;
		jrwTITrans.allTrackedItems.add(_filter.getMyDataObject.CM_TrackedItem);
		return  (_filter.getMyDataObject &lt;&gt; null).Integer;
	endif;
	return  (jrwTrans.myDataObject &lt;&gt; null).Integer;

end;</source>
        <Parameter name="_filter" type="CMQF_AnyDataObject" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryAudit" id="d2a3e18a-7473-467d-9774-60e2df82f29a">
        <updating/>
        <source>qryAudit(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2018	jlgmp6	Initial creation	TFS37718

*/

vars
	numSelected			: Integer;
	jrwTrans			: CM_JRWAudit;
	auditFilter			: CMQF_Audit;
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	auditFilter := _filter.CMQF_Audit;
	jrwTrans := self.createJRWTransient(CM_JRWAudit).CM_JRWAudit;
	jrwTrans.allAudits.clear();
	auditFilter.filterObjects(jrwTrans.allAudits, _passport);

	numSelected := jrwTrans.allAudits.size;

epilog

	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryBOL" id="9c4fe604-3437-476c-a36d-9e701bebd5ed">
        <updating/>
        <source>qryBOL(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     15 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	numSelected			: Integer;
	jrwTrans			: CM_JRWBOL;
	bolFilter			: CMQF_BOL;
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	bolFilter := _filter.CMQF_BOL;
	jrwTrans := self.createJRWTransient(CM_JRWBOL).CM_JRWBOL;
	jrwTrans.allBOLs.clear();
	_filter.filterObjects(jrwTrans.allBOLs, _passport);
	
//	bolFilter.allTerminals.copy(jrwTrans.allTerminals);
	jrwTrans.setAllTerminals(bolFilter.allTerminals);
	jrwTrans.blockLength 	:= bolFilter.blockLength;
	jrwTrans.baseDate		:= bolFilter.baseDate;
	jrwTrans.ageType		:= bolFilter.ageType;
	jrwTrans.transportMode	:= bolFilter.transportMode;
	jrwTrans.voyageCode 	:= bolFilter.voyageCode;
	jrwTrans.myOperator 	:= bolFilter.myOperator;
	jrwTrans.qryStartDate 	:= bolFilter.startDate;
	jrwTrans.qryEndDate 	:= bolFilter.endDate;
	

	jrwTrans.numContainers 		:= bolFilter.numContainers;
	jrwTrans.num20ft			:= bolFilter.num20ft;
	jrwTrans.num40ft	 		:= bolFilter.num40ft;
	jrwTrans.totalPackingCharge := bolFilter.totalPackingCharge;
	
	jrwTrans.outwardsDockets 	:= bolFilter.outwardsDockets;
	jrwTrans.outwardsTIs 		:= bolFilter.outwardsTIs;
	jrwTrans.outwardsVolume 	:= bolFilter.outwardsVolume;
	jrwTrans.outwardsWeight 	:= bolFilter.outwardsWeight;
	
	jrwTrans.inwardsDockets 	:= bolFilter.outwardsDockets;
	jrwTrans.inwardsTIs 		:= bolFilter.outwardsTIs;
	jrwTrans.inwardsVolume 	:= bolFilter.outwardsVolume;
	jrwTrans.inwardsWeight 	:= bolFilter.outwardsWeight;

	numSelected := jrwTrans.allBOLs.size;
	
epilog
	
	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryBOLMonthlyStats" id="81983d4a-39b5-4fba-bae0-687571885968">
        <updating/>
        <source>qryBOLMonthlyStats(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     15 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	numSelected			: Integer;
	jrwTrans			: CM_JRWBOL;
	statFilter			: CMQF_BOLMonthlyStatistics;
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	statFilter := _filter.CMQF_BOLMonthlyStatistics;
	jrwTrans := self.createJRWTransient(CM_JRWBOL).CM_JRWBOL;
	jrwTrans.allBOLs.clear();
	_filter.filterObjects(jrwTrans.allBOLs, _passport);
	
//	statFilter.allTerminals.copy(jrwTrans.allTerminals);
	jrwTrans.setAllTerminals(statFilter.allTerminals);
	jrwTrans.blockLength 	:= _filter.blockLength;
	jrwTrans.baseDate		:= _filter.baseDate;
	jrwTrans.ageType		:= _filter.ageType;
	jrwTrans.myOperator 	:= statFilter.myOperator;
	jrwTrans.qryStartDate 	:= statFilter.startDate;
	jrwTrans.qryEndDate 	:= statFilter.endDate;
	
	jrwTrans.inwardsDockets:= statFilter.inwardsDockets;
	jrwTrans.inwardsTIs		:= statFilter.inwardsTIs;
	jrwTrans.inwardsVolume	:= statFilter.inwardsVolume;
	jrwTrans.inwardsWeight	:= statFilter.inwardsWeight;
	
	jrwTrans.outwardsDockets:= statFilter.outwardsDockets;
	jrwTrans.outwardsTIs	:= statFilter.outwardsTIs;
	jrwTrans.outwardsVolume	:= statFilter.outwardsVolume;
	jrwTrans.outwardsWeight	:= statFilter.outwardsWeight;
	
	jrwTrans.totalPackingCharge := statFilter.totalPackingCharge;
	jrwTrans.numContainers 	:= statFilter.numContainers;
	jrwTrans.num20ft 		:= statFilter.num20ft;
	jrwTrans.num40ft 		:= statFilter.num40ft;
	
	
	numSelected := jrwTrans.allBOLs.size; //which should always be 1, but whatever...
	
epilog
	
	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryBOLOld" id="cbc3ad87-5d02-4b2f-b251-f94b2eef273e">
        <updating/>
        <source>qryBOLOld(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     19 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	numSelected 	: Integer;
	jrwTrans		: CM_JRWOld;
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);

	self.myRWLogDocket := self.createJRWTransient(CM_JRWOld).CM_JRWOld;
	jrwTrans := self.myRWLogDocket.CM_JRWOld;
	jrwTrans.allBOLs.clear();
	_filter.filterObjects(jrwTrans.allBOLs, _passport);

	
	jrwTrans.blockLength 	:= _filter.blockLength;
	jrwTrans.baseDate		:= _filter.baseDate;
	jrwTrans.ageType		:= _filter.ageType;
	
	numSelected := jrwTrans.allBOLs.size;
epilog
	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryBOLTransaction" id="e09a64b9-fc7b-46c0-a925-5138df140fb5">
        <updating/>
        <source>qryBOLTransaction(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
// 2/5/2016 cnwjre1 TFS 980 Bill of lading multiple splits reporting

vars
	numSelected			: Integer;
	jrwTrans			: CM_JRWBOLTfrTransactions;
	bolFilter			: CMQF_BOLTransaction;
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	bolFilter := _filter.CMQF_BOLTransaction;
	jrwTrans := self.createJRWTransient(CM_JRWBOLTfrTransactions).CM_JRWBOLTfrTransactions;

	bolFilter.filterObjects2(jrwTrans, _passport);
	
	jrwTrans.setAllTerminals(bolFilter.allTerminals);

	numSelected := jrwTrans.allTfrsByCargoId.size;
	
epilog
	
	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryBookingRef" id="3eb36626-76ec-4a55-a0bc-82feb32317a8">
        <updating/>
        <source>qryBookingRef(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
/*
----------   ----------  --------------------------------------------------
Created:	23 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	numSelected				: Integer;
	jrwTrans				: CM_JRWBookingRef;
	bookingRefFilter		: CMQF_BookingRef;
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	bookingRefFilter := _filter.CMQF_BookingRef;
	jrwTrans := self.createJRWTransient(CM_JRWBookingRef).CM_JRWBookingRef;
	jrwTrans.allBookingRefs.clear();
	_filter.filterObjects(jrwTrans.allBookingRefs, _passport);
	
	jrwTrans.setAllTerminals(bookingRefFilter.allTerminals);
	jrwTrans.qryBookingRef		:= bookingRefFilter.bookingRef;
	jrwTrans.myCargoType		:= bookingRefFilter.getMyCargoType.CM_CargoType;
	jrwTrans.myCommodity		:= bookingRefFilter.getMyCommodity;
	jrwTrans.consignee			:= bookingRefFilter.consignee;
	jrwTrans.consignor			:= bookingRefFilter.consignor;
	jrwTrans.myOperator			:= bookingRefFilter.myOperator;
	jrwTrans.myVoyage			:= bookingRefFilter.getMyVoyage;
	jrwTrans.totalQuantityExpected := bookingRefFilter.totalExpectedQuantity;
	jrwTrans.totalWeightExpected := bookingRefFilter.totalExpectedWeight;
	jrwTrans.voyageArrivalDateFrom	:= bookingRefFilter.voyageArrivalDateFrom;	//Par 17601. July 2008
	jrwTrans.voyageArrivalDateTo	:= bookingRefFilter.voyageArrivalDateTo;	//Par 17601. July 2008
	
	numSelected := jrwTrans.allBookingRefs.size;
	
epilog
	
	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryBookingRefDiscrepancies" id="910ab399-02b7-4e34-985d-801489462dea">
        <updating/>
        <source>qryBookingRefDiscrepancies(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 September 2009	cnwndl1	Initial creation	CCMS 1609	Par 20521

*/

vars
	numSelected			: Integer;
	jrwTrans			: CM_JRWBookingRefDiscrep;
	eventFilter			: CMQF_BookingRefDiscrepancy;
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	eventFilter := _filter.CMQF_BookingRefDiscrepancy;
	jrwTrans := self.createJRWTransient(CM_JRWBookingRefDiscrep).CM_JRWBookingRefDiscrep;
	jrwTrans.allEventsByDateTime.purge();
	eventFilter.filterObjects(jrwTrans.allEventsByDateTime, _passport);

	eventFilter.allTerminals.copy(jrwTrans.allTerminals);
	
	eventFilter.allEventTypes.copy(jrwTrans.allEventTypes);
	jrwTrans.fromDT.setDate(eventFilter.startDate);
	jrwTrans.fromDT.setTime(eventFilter.startTime);
	jrwTrans.toDT.setDate(eventFilter.endDate);
	jrwTrans.toDT.setTime(eventFilter.endTime);
	
	jrwTrans.includeNoTerminal 	:= eventFilter.includeNoTerminal;
	jrwTrans.includeNoUser		:= eventFilter.includeNoUser;
	jrwTrans.needFilterEventTypes := eventFilter.needFilterEventTypes;
	jrwTrans.needFilterUsers	:= eventFilter.needFilterUsers;
	
	eventFilter.allUsers.copy(jrwTrans.allUsers);
	
	jrwTrans.myOperator	:= eventFilter.myOperator;
	jrwTrans.bookingRef	:= eventFilter.bookingRef;
	jrwTrans.cargoId	:= eventFilter.cargoId;
	jrwTrans.myCargoType	:= eventFilter.getMyCargoType.CM_CargoType;
	jrwTrans.myVoyage	:= eventFilter.getMyVoyage;
	jrwTrans.stateString	:= app.stateEnumToString(eventFilter.state);
	
	numSelected := jrwTrans.allEventsByDateTime.size;

epilog
	
	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryBulkRelease" id="2edf74c0-d929-46d5-807d-c4ae34f54ee3">
        <updating/>
        <source>qryBulkRelease(_filter : CMQF_FilterReports input; _passport : CM_Passport input) : Integer updating;
//----------------------------------------------------------------
//	Created:	30 May 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	numSelected			: Integer;
	jrwTrans			: CM_JRWBulkRelease;
	tiFilter			: CMQF_BulkRelease;
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	tiFilter := _filter.CMQF_BulkRelease;
	
	jrwTrans := self.createJRWTransient(CM_JRWBulkRelease).CM_JRWBulkRelease;
	jrwTrans.allBulkReleases.clear();
	
	tiFilter.filterObjects(jrwTrans.allBulkReleases, _passport);

	jrwTrans.setAllTerminals(tiFilter.allTerminals);

	jrwTrans.myOperator 		:= tiFilter.myOperator;
	jrwTrans.myOperatorGroup	:= tiFilter.getMyOperatorGroup;
	jrwTrans.myISOGroup 		:= tiFilter.getMyISOTypeGroup;
	jrwTrans.releaseType		:= tiFilter.releaseType;

	
	jrwTrans.allAvaGrades.clear();
	tiFilter.allQryAvaGrades.copy(jrwTrans.allAvaGrades);

	numSelected := jrwTrans.allBulkReleases.size();
	
epilog

	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryCargo" id="de58ff03-4f59-407a-a52b-fab1c508b985">
        <updating/>
        <source>qryCargo(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
//----------------------------------------------------------------
//	Created:	15 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars
	numSelected			: Integer;
	jrwTrans			: CM_JRWTrackedItems;
	tiFilter			: CMQF_TrackedItem;
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	tiFilter := _filter.CMQF_TrackedItem;
	jrwTrans := self.createJRWTransient(CM_JRWTrackedItems).CM_JRWTrackedItems;
	jrwTrans.allTrackedItems.clear();
	tiFilter.filterObjects(jrwTrans.allTrackedItems, _passport);

//	tiFilter.allTerminals.copy(jrwTrans.allTerminals);
	jrwTrans.setAllTerminals(tiFilter.allTerminals);

	jrwTrans.myPort 		:= tiFilter.getMyPort;
	jrwTrans.myLoadPort 	:= tiFilter.getMyLoadPort;
	jrwTrans.qryDischargePort := tiFilter.dischargePort;
	jrwTrans.myVoyage 		:= tiFilter.getMyVoyage;
	jrwTrans.myTerminalArea := tiFilter.getMyTerminalArea;
	jrwTrans.myOperator 	:= tiFilter.myOperator;
	
	jrwTrans.qrySiteStateString := tiFilter.getSiteString();
	jrwTrans.qryId := tiFilter.id;
	
	numSelected := jrwTrans.allTrackedItems.size;

epilog

	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryCargoExtraHandling" id="dbd25f70-5b60-463c-ac58-753f75b97b2f">
        <updating/>
        <source>qryCargoExtraHandling(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
// ---------------------------------------------------------------------------
// Created by 	cnwsh3 - 21 September 2011
//
// Implemented version: JMT 7.9.2
// Date  		User  		Change
// 21/09/2011	cnwsh3		Initial creation - MES CCMS 1024 PAR28223 - Extra Cargo Handling report
//							Used for the Cargo Extra Hanlding system report.
// ----------   ----------  --------------------------------------------------
vars
	numSelected			: Integer;
	jrwTrans			: CM_JRWTransaction;
	tiFilter			: CMQF_CargoExtraHandling;
begin
	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	tiFilter := _filter.CMQF_CargoExtraHandling;
	jrwTrans := self.createJRWTransient(CM_JRWTransaction).CM_JRWTransaction;
	
	jrwTrans.allTransactions.clear();
	_filter.filterObjects(jrwTrans.allTransactions, _passport);
//	tiFilter.allTerminals.copy(jrwTrans.allTerminals);
	jrwTrans.setAllTerminals(tiFilter.allTerminals);
	//jrwTrans.baseDate		:= _filter.baseDate;
	//jrwTrans.ageType		:= _filter.ageType;
	jrwTrans.myOperator 	:= tiFilter.myOperator;
	jrwTrans.myVoyage		:= tiFilter.getMyVoyage;
	jrwTrans.startDate 	:= tiFilter.startDate;
	jrwTrans.endDate	:= tiFilter.endDate;
	jrwTrans.transType 	:= tiFilter.transType;
	jrwTrans.transTypeStr 	:= tiFilter.transTypeStr;
	//jrwTrans.includeChildTransactions := tiFilter.includeChildTransactions;	// 03 Aug 2010	NDL	Par 23056
	
	numSelected := jrwTrans.allTransactions.size; //which should always be 1, but whatever...

epilog
	
	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
