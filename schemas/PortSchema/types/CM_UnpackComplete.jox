    <JadeMethod name="getDisplayStringForAttribute" id="0b096336-6ce9-4264-9afd-0def23221c18">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// Jan 2012 CCMS 1262 Transaction Enquiry
vars

begin
	if _attrName = ETRow_UnpackComplete then
		return self.location;
	else
		return inheritMethod(_attrName, _short);
	endif;
end;
</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
