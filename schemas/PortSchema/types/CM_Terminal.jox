    <JadeMethod name="lookupVoyage" id="0326689f-e442-47b5-b992-fbc11ea881fa">
        <source>lookupVoyage(_value : String; arrivalDT : TimeStamp; _isCheckArchived : Boolean) : CM_Voyage;
// -----------------------------------------------------------------------------
// Created:		08 June 2001 by cnwdwq1
//
// Purpose:		Searches for a Voyage with the specified voyage code.
//
// Parameters:	_value - The voyage code to look for.
//				arrivalDT - The arrival date/time of the Voyage.
//				_isCheckArchived - True if archived voyages should also be searched.
//
// Returns:		A reference to a voyage with a matching code, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 30/08/2006	cnwdad1			Added the "_isCheckArchived" parameter.
// -----------------------------------------------------------------------------
vars
	voyCode	: String;
	voy		: CM_Voyage;
	
begin
	voyCode := _value.toUpper.trimBlanks();
	if voyCode = null then //cnwrs1 16 dec 2009 par 21817
		return null;
	endif;
	if  _isCheckArchived then
		/*
		   Date		      Who		Reason
		30 July 2008	cnwdz2	    Par15231 - if _isCheckArchived then should check duplication in the allVoyagesArchived dict as well.
		*/
		voy := self.allVoyagesArchived [voyCode, arrivalDT];
		
		if voy = null then
			voy := self.allVoyagesArchived.getAtKeyGeq (voyCode, null);			
			if voy = null // AKB2008AUG added
			or (voy &lt;&gt; null and voy.code &lt;&gt; voyCode and voy.inwardCode &lt;&gt; voyCode) then 								
				// allVoyagesNew should contain everything so we only need to look here.
				voy := self.allVoyagesNew [voyCode, arrivalDT];
				
				if voy = null then
					voy := self.allVoyagesNew.getAtKeyGeq (voyCode, null);
					//if voy &lt;&gt; null and voy.code &lt;&gt; voyCode and voy.inwardCode &lt;&gt; voyCode then //par cnwrs1 nov 2007
					if voy &lt;&gt; null
					and voy.code &lt;&gt; voyCode
					and voy.inwardCode &lt;&gt; voyCode
					then //par cnwrs1 nov 2007
						voy := null; 
					endif;
				endif;
			endif;
		endif;				

	else // not _isCheckArchived
		voy := self.allVoyagesByCode [voyCode, arrivalDT];
		
		if voy = null then
			voy := self.allVoyagesByCode.getAtKeyGeq (voyCode, null);
			
			if voy &lt;&gt; null and voy.code &lt;&gt; voyCode then
				voy := null;
			endif;
		endif;
		
		if voy = null then
			voy := self.allVoyagesByInwardCode[voyCode];			
		endif;
    endif;
	
    return voy;
end;</source>
        <Parameter name="_value" type="String"/>
        <Parameter name="arrivalDT" type="TimeStamp"/>
        <Parameter name="_isCheckArchived" type="Boolean"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="lookupVoyageAuto" id="fcaa79c1-c07f-4315-b4a5-09a49d845d81">
        <source>lookupVoyageAuto(_code, _vessel : String; _arrivalDT : TimeStamp; _checkArchived : Boolean) : CM_Voyage;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
16 July 2024	navlw1	ChangeRequest 63839: NSW | OnePort - Uniqueness of Inward and External Code
26 Nov 2024		navdap1	MTN-33516 NSW | OnePort - Voyage Already Exists With External Code Error
*/

vars
	voyCode	: String;
	voy		: CM_Voyage;
begin
	voyCode := _code.toUpper.trimBlanks();
	if voyCode = null then
		return null;
	endif;
	
	if _checkArchived then
		voy := self.allVoyagesArchived [voyCode, _arrivalDT];
		if voy = null then
			voy := self.allVoyagesArchived.getAtKeyGeq (voyCode, null);
			if voy = null or (voy &lt;&gt; null and voy.code &lt;&gt; voyCode and voy.inwardCodeAuto &lt;&gt; voyCode) then 
				voy := self.allVoyagesByInwardCodeAuto[voyCode, _vessel];
				// MTN-33516 take this out, it's incorrect
				//if voy = null then
				//	voy := self.allVoyagesByInwardCodeAuto.getAtKeyGeq (voyCode, _vessel);
				//	if voy &lt;&gt; null and voy.code &lt;&gt; voyCode and voy.inwardCodeAuto &lt;&gt; voyCode then
				//		voy := null; 
				//	endif;
				//endif;
			endif;
		endif;
	else // not _isCheckArchived
		voy := self.allVoyagesByCode [voyCode, _arrivalDT];
		if voy = null then
			voy := self.allVoyagesByCode.getAtKeyGeq (voyCode, null);
			
			if voy &lt;&gt; null and voy.code &lt;&gt; voyCode then
				voy := null;
			endif;
		endif;
		
		if voy = null then
			voy := self.allVoyagesByInwardCodeAuto[voyCode, _vessel];
		endif;
	endif;
	
	return voy;
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_vessel" type="String"/>
        <Parameter name="_arrivalDT" type="TimeStamp"/>
        <Parameter name="_checkArchived" type="Boolean"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="noMessageException" id="f883cae8-298b-41d1-b4fd-dafc0e5a161f">
        <source>noMessageException(exObj: Exception): Integer;
vars
begin
	abortTransaction;
	return Ex_Abort_Action;
end;</source>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="noOnsiteDuplicate" id="fac46e00-05ff-4b07-a35f-272682599e6f">
        <source>noOnsiteDuplicate(_ti : Object; _cargoType : Integer; _operator : String; _bookingRef : String;
					_searchReversed, _containerEnqSearch : Boolean
					): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14/12/2023	navcs2	ChangeRequest 57539: CUX | Multiple Prenotes Unique by Booking Reference
17/05/2024	naviv1	Bug 64119 - CUX | POST/cargo API - Error Description
21/05/2024	navdap1	TFS 63619 CUX | FR - POST and PUT /Cargo not saving Customs References for Onboard Cargo
10/06/2025	navdap1	TFS 64431 DB Loading status when loading the replace Rail manifest file 
*/
vars
	myEnqController : CM_EnqControllerTI;
	criteriaHolder 	: CM_QueryCriteriaLineHolder;
	qDef 			: CM_QueryDefinition;
	criteriaLine 	: CM_SelectorCriteriaLine;
	cargoType 		: CM_CargoType;
	foundTIs 		: CM_TISet;
	operator		: CM_Operator;
	states			: IntegerArray;
	id				: String;
	isPrenote		: Boolean;
begin	
	isPrenote := false;
	
	if _ti.isKindOf(CM_TrackedItem) then
		id := _ti.CM_TrackedItem.id;
		isPrenote := _ti.CM_TrackedItem.isNotified;		// TFS 63619
	elseif _ti.isKindOf(CMIF_PreNote) then
		id := _ti.CMIF_PreNote.id;
		isPrenote := true;
	else
		return false;
	endif;
	
	create myEnqController;
	create foundTIs transient;
	myEnqController.allObjects := foundTIs;
	create criteriaHolder transient;
	myEnqController.myTerminal := self;
	myEnqController.myCriteriaLineHolder := criteriaHolder;
	myEnqController.searchReversed := _searchReversed;
	
	create states transient;
	states.add(TI_STATE_NORMAL);
	states.add(TI_STATE_NOTIFIED);
	
	cargoType := self.myRoot.allCargoTypesById[_cargoType];
	operator  := self.myRoot.allOperators[_operator];

	qDef := self.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,null];
	
	criteriaLine := qDef.createCriteriaLine(CM_TrackedItem::myTerminal.name, CM_QueryOperator.Operator_Equal, self);
	criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	
	if cargoType &lt;&gt; null then 
		criteriaLine := qDef.createCriteriaLine(CM_TrackedItem::cargoType.name, CM_QueryOperator.Operator_Equal, cargoType);
		criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	endif;
	
	if id &lt;&gt; null then 
		criteriaLine := qDef.createCriteriaLine(CM_TrackedItem::id.name, CM_QueryOperator.Operator_Equal, id);
		criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	endif;
	
	if _operator &lt;&gt; null then
		criteriaLine:=qDef.createCriteriaLine( CM_TrackedItem::operatorCode.name, CM_QueryOperator.Operator_Equal, operator);
		if criteriaLine &lt;&gt; null then
			criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
		endif;
	endif;
	
	if _bookingRef &lt;&gt; null then
		criteriaLine:=qDef.createCriteriaLine( CM_TrackedItem::bookingReference.name, CM_QueryOperator.Operator_Equal, _bookingRef.toUpper);  //17-May-2024 naviv1 #64119
		if criteriaLine &lt;&gt; null then
			criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
		endif;
	endif;
	
	criteriaLine := qDef.createCriteriaLine(CM_TrackedItem::state.name, CM_QueryOperator.Operator_IsOneOf, states);
	criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	
	criteriaLine.setMyCriteriaLineHolder(criteriaHolder);
	
	myEnqController.doQuery(qDef);
	
	if isPrenote then
		if foundTIs.isEmpty then
			return true;
		elseif foundTIs.size = 1 and _ti.isKindOf(CM_TrackedItem) and foundTIs.first = _ti.CM_TrackedItem then	// TFS 63619
			return true;																						// TFS 63619
		elseif foundTIs.size = 1 and _ti.isKindOf(CM_TrackedItem) 												// TFS 63619
		and _ti.isTransient and app.myProxyManager.getRealObject(_ti.CM_TrackedItem) = foundTIs.first then		// TFS 63619
			return true;																						// TFS 63619
		elseif foundTIs.size = 1 and _ti.isKindOf(CMIF_PreNote) and foundTIs.first = _ti.CMIF_PreNote.myPersistentTrackedItem then	// TFS 64431
			return true;																											// TFS 64431
		else
			return false;
		endif;
	else
		if foundTIs.isEmpty then
			return true;
		elseif foundTIs.size = 1 and foundTIs.first = _ti.CM_TrackedItem then
			return true;
		else
			return false;
		endif;
	endif;
epilog
	if myEnqController &lt;&gt; null then
		if myEnqController.myCriteriaLineHolder &lt;&gt; null then
			delete myEnqController.myCriteriaLineHolder;
		endif;
		myEnqController.allObjects:=null;
	endif;
	delete myEnqController;
	delete foundTIs;
	delete states;
end;</source>
        <Parameter name="_ti" type="Object"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_operator" type="String"/>
        <Parameter name="_bookingRef" type="String"/>
        <Parameter name="_searchReversed" type="Boolean"/>
        <Parameter name="_containerEnqSearch" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="outputConfig" id="4695ad7a-471c-4b33-8799-9407c6e699b1">
        <source>outputConfig(_file: File; _objArray: ObjectArray io; _exportReferences: Boolean; _exportCollections, _outputEndTag : Boolean);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 April 2009	cnwjk3	Initial creation

*/

vars
	ifConfig 	: CMIF_ConfigTerminal;
begin
	
	// output &lt;CM_Terminal&gt; and subfields
	inheritMethod(_file, _objArray, false, false, false);

	// output &lt;CMIF_ConfigTerminal&gt; for this terminal
	create ifConfig transient;
	ifConfig.setFromPersistentData(self);
	ifConfig.myObject := self;
	ifConfig.outputConfig(_file, _objArray, true, false, true);
	
	// &lt;/CM_Terminal&gt;
	_file.writeLine("&lt;/"&amp;self.class.name&amp;"&gt;");	
epilog
	delete ifConfig;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
        <Parameter name="_exportReferences" type="Boolean"/>
        <Parameter name="_exportCollections" type="Boolean"/>
        <Parameter name="_outputEndTag" type="Boolean"/>
    </JadeMethod>
