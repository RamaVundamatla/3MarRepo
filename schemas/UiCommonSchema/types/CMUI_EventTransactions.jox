    <JadeMethod name="setupCmbCharge" id="69a8db05-c96e-4aac-821f-fce023d63ea6">
        <source>setupCmbCharge( _value : Boolean );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars
	index : Integer;
begin
	self.cmbCharge.clear();
	
	index := cmbCharge.addItem(app.getErrorString(No));
	cmbCharge.itemData[index] := 0;
	
	index := cmbCharge.addItem(app.getErrorString(Yes));
	cmbCharge.itemData[index] := 1;
	
	//set the value...
	foreach index in 1 to cmbCharge.listCount do
		if cmbCharge.itemData[index] = _value.Integer then
			cmbCharge.listIndex := index;
			break;
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupCmbDebtor" id="2dfe6106-27c3-4e36-a2f9-aec9c4bc4988">
        <updating/>
        <source>setupCmbDebtor(_currentEventDebtor: CM_Debtor)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Jun 2020 cnwma1 ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
*/

vars
	debtor, 
	defaultDebtor   : CM_Debtor;
	voyage          : CM_Voyage;
	train           : CM_Train;
	vehicle         : CM_Vehicle;
	carrier         : CM_Carrier;
	vvr             : CM_VehicleVisitRecord;
begin

	if self.myParent &lt;&gt; null then
		if self.myParent.isKindOf(CM_Voyage) then
			voyage 		  := self.myParent.CM_Voyage;
			defaultDebtor := voyage.myDebtor.CM_Debtor;
		elseif self.myParent.isKindOf(CM_Train) then
			train 	:= self.myParent.CM_Train;
			carrier := self.myParent.CM_Train.myCarrier;
		elseif self.myParent.isKindOf(CM_VehicleVisitRecord) then
			vehicle     := self.myParent.CM_VehicleVisitRecord.vehicle;
			if vehicle &lt;&gt; null then
				carrier := vehicle.carrier;
			endif;
		endif;
		if carrier &lt;&gt; null then
			defaultDebtor := carrier.myDebtor;
		endif;
	endif;
	self.cmbDebtor.clear;
	self.cmbDebtor.sorted := true;

	foreach debtor in app.myRoot.myRootCompany.debtors where not debtor.isSuspended do
		if debtor.isRDT then
			continue;
		endif;
		self.cmbDebtor.addItem(debtor.name);
		self.cmbDebtor.itemObject[self.cmbDebtor.newIndex] := debtor;
	endforeach;

	if _currentEventDebtor &lt;&gt; null then
		self.cmbDebtor.listIndex := self.cmbDebtor.findObject( _currentEventDebtor );
	elseif  defaultDebtor &lt;&gt; null then
		self.cmbDebtor.listIndex := self.cmbDebtor.findObject( defaultDebtor );
	endif;
end;</source>
        <Parameter name="_currentEventDebtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="a5615084-44ab-425a-acaa-7e987a07ea66">
        <updating/>
        <source>setupForm() updating;
/*

Date		Who		Reason
09/12/2014	cnwer1	Initial creation PAR
16/02/2017	cnwdap1	TFS 3466 Set minimum width and height
23/07/2019 	JLGNS1	ChangeRequest 45575: ASPA - Train Events
29/07/2022	jlizm1	TFS 54165 EDI Voyage Events
20/02/2023	jlizm1	TFS 56675 Truck Events remarks field
*/

vars
	isVoyageTrainEvent : Boolean;
	isTruckEvent 		: Boolean;
begin
	isVoyageTrainEvent 	:= self.eventCategory = CM_EventType.VOYAGE_EVENT or self.eventCategory = CM_EventType.TRAIN_EVENT;//nds TFS 3047 13/01/17	ChangeRequest 45575
	isTruckEvent 		:= self.eventCategory = CM_EventType.TRUCK_EVENT;
	
	self.txtAmount.visible := isVoyageTrainEvent; // PAR 35478																						ChangeRequest 45575
	self.lblAmount.visible :=  isVoyageTrainEvent; // PAR 35478																						ChangeRequest 45575
	self.lblRemarks.visible := isVoyageTrainEvent or isTruckEvent;//nds TFS 3047 13/01/17															ChangeRequest 45575
	self.txtRemarks.visible := isVoyageTrainEvent or isTruckEvent;//nds TFS 3047 13/01/17															ChangeRequest 45575
	self.doShowEndDateControls( false);			//25/01/17 cnwns1 TFS3214 LNX - Voyage Operations Enhancements 										ChangeRequest 45575
	
	self.tblWeight.visible := false;	// TFS 54165
	self.lblWeight.visible := false;	// TFS 54165
	
	self.grpEventDetail.borderStyle := 0;
	self.handleMenusForModalDisplay();
	self.showToolbar := true;
	self.refreshToolbar();
	self.btnInvoiceLine.enabled := false;//cnwas3
	inheritMethod();
	
	//self.myAssistant.comboBoxEventTypeUser(self.cmbEventType,self.eventCategory);
	self.cmbEventType.clear();	//09 Mar 2020	NDL	TFS 48784
	self.myAssistant.comboBoxEventTypeUser(self.cmbEventType,self.eventCategory,self.myTerminal); //03 May 2017	NDL	TFS 4248
	self.clearEditControls();
	self.initTables();
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnNewEvent.enabled:= false;
	endif;
	
	self.setFormTitle(); // TFS 3548
	
	self.minimumWidth := 770;			// TFS 3466
	self.minimumHeight := 500;			// TFS 3466
	self.doResize();					// TFS 3466
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showColumnOrganiser" id="f894d733-55be-4b90-b187-491977010683">
        <updating/>
        <source>showColumnOrganiser(_dataTable : CM_DataTable input)updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 November 2009	cnwndl1	Initial creation	Par 21519

*/

vars
	defBefore, defAfter, typeTag : String;
begin

	if _dataTable = null then
		return;
	endif;
	
	defBefore := _dataTable.getXmlStrForColumns(true);
	_dataTable.showColumnOrganiserFrm(self.myTerminal, null);
	defAfter := _dataTable.getXmlStrForColumns(true);

	if defBefore &lt;&gt; defAfter then //Update the array if columns have changed via the column organiser.  The array is saved when form is closed
		self.xmlStrTblEvents := defAfter;
		return;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_dataTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showDebtorCombo" id="9ebb5965-3a6f-428e-95a9-11ca371bff32">
        <updating/>
        <source>showDebtorCombo(_currentDebtor : CM_Debtor)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Jun 2020 cnwma1 ChangeRequest 49400: ASPA - Invoice Enhancements for Barges

*/

vars
	bank 		: CM_Bank;
	eventTM 	: CM_TranMapEvent;
	eventType   : CM_EventType;
begin
	
	self.lblDebtor.visible := false;
	self.cmbDebtor.visible := false;
	bank := self.getBank();
	
	if bank &lt;&gt; null then
		eventTM :=bank.myCurrentTranMapEvent;
	endif;
	
	if eventTM &lt;&gt; null then
		eventType := cmbEventType.listObject.CM_EventType;
		
		if eventType &lt;&gt; null then
			if eventTM.allEventServiceBrokers[eventType]  &lt;&gt; null then
				self.lblDebtor.visible := true;
				self.cmbDebtor.visible := true;
				self.setupCmbDebtor(_currentDebtor);
			endif;
		endif;
	
	endif;
epilog

end;</source>
        <Parameter name="_currentDebtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="tblCharges_click" id="fe0e9c62-7a42-4188-b28c-396a620708d6">
