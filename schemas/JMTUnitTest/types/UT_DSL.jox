    <JadeMethod name="createManualInvoiceLine" id="f6e97792-8274-4c49-8cd3-4c01e601666f">
        <source>createManualInvoiceLine(_invLineDesc : CM_InvoiceLineDesc; _invoice: CM_Invoice; _quantity: Real; _narration : String; _date : Date) : CM_InvoiceLine;
//10 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type
vars
	manController	: CMIF_InvoiceLineManual;
	realInvLine		: CM_InvoiceLine;
	
begin
	create manController transient;
	manController.quantity := _quantity;
	manController.remarks := _narration;// ### JIRA 33007 10DEC2024 NAVAB1
	manController.chargeTime.setDate(_date);
	manController.myInvoice := _invoice;
	//manController.myInvoiceLineType := _invLineDesc; //10 March 2023  navmv20 TFS 56128 Task 56129
	manController.allInvoiceLineTypes.add(_invLineDesc); //10 March 2023  navmv20 TFS 56128 Task 56129
	
	//08/10/2025	navkc1 JIRA 36145
	if self.opts.includesKey('useCalculationType') then
		manController.useCalcTypeForQuantity := self.opts.bool('useCalculationType');
	endif;
	
	//19/05/2025	navkc1 JIRA EPIC-34131 STORY-34818
	if self.opts.includesKey("allTrackedItems") then
		self.opts.obj("allTrackedItems").CM_TISet.copy(manController.allTrackedItems);
	endif;

	//08/12/2025	navkc1 JIRA 36262
	if self.opts.includesKey("isOverridden") then
		manController.isOverridden := self.opts.bool("isOverridden").Boolean;
	endif;
	
	//08/12/2025	navkc1 JIRA 36262
	if self.opts.includesKey("rate") then
		manController.rate := self.opts.dec("rate").Decimal;
	endif;
	//08/12/2025	navkc1 JIRA 36262
	if self.opts.includesKey("total") then
		manController.totalAmount := self.opts.dec("total").Decimal;
	endif;
	
	
	app.myTrxCA.trxCreateInvoiceLineManual(manController, realInvLine, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	return realInvLine;
epilog
	delete manController;
end;
</source>
        <Parameter name="_invLineDesc" type="CM_InvoiceLineDesc"/>
        <Parameter name="_invoice" type="CM_Invoice"/>
        <Parameter name="_quantity" type="Real"/>
        <Parameter name="_narration" type="String"/>
        <Parameter name="_date" type="Date"/>
        <ReturnType type="CM_InvoiceLine"/>
    </JadeMethod>
    <JadeMethod name="createManualInvoiceLineWithTI" id="600c719c-d075-4c09-9fdb-8afc77365c11">
        <source>createManualInvoiceLineWithTI(_invLineDesc : CM_InvoiceLineDesc; _invoice: CM_Invoice; _quantity: Real; _narration : String; _date : Date; _ti : CM_TrackedItem) : CM_InvoiceLine;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 February 2024	navrv30	Initial creation for CR 61911/ Task 61393

*/

vars
	manController	: CMIF_InvoiceLineManual;
	realInvLine		: CM_InvoiceLine;
	
begin
	create manController transient;
	manController.quantity := _quantity;
	manController.remarks := _narration;// ### JIRA 33007 10DEC2024 NAVAB1
	manController.chargeTime.setDate(_date);
	manController.myInvoice := _invoice;
	manController.allInvoiceLineTypes.add(_invLineDesc);
	if _ti &lt;&gt; null then
		manController.allTrackedItems.add(_ti);
	endif;
	app.myTrxCA.trxCreateInvoiceLineManual(manController, realInvLine, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	return realInvLine;
epilog
	delete manController;
end;
</source>
