    <JadeMethod name="getAuditText" id="0b77ad5b-084f-476d-9ad5-3ebacc9a9ba8">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 January 2019	jlger1	Initial creation 43546

*/

vars
	auditText : String;
	cargoDetails : CM_WodCargoRequest;
	marineDetail : CM_WodMarineServiceDetail;
begin
	auditText:= inheritMethod();
	
	foreach cargoDetails in self.allCargoDetails discreteLock do
		auditText:= auditText &amp; cargoDetails.getAuditText;	
	endforeach;
	
	foreach marineDetail in self.allMarineServiceDetails discreteLock do
		auditText:= auditText &amp; marineDetail.getAuditText;	
	endforeach;
	
	return auditText;
epilog

end;</source>
