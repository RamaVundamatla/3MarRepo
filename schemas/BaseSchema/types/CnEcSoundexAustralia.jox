<Class name="CnEcSoundexAustralia" id="8ff14b06-3b8b-4bab-ba1a-6e19a7b77486">
    <superclass name="CnEcSoundexIndigenous"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
