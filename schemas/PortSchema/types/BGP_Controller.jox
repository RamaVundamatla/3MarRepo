    <JadeMethod name="isRunning" id="c47d4640-5646-437a-900d-121090a04c08">
        <source>isRunning() : Boolean;

// cnwdvb1 25 October 2002 
/*

Date		Who		Reason
19 Feb 2010	cnwkpd1	PAR #22434 - Background Application performance - use exception handler
					to deal with invalid Process
07/03/2011	cnwmh5	PAR #27142 - Change to use local variable for exception handler
*/

vars
	tmpProcess		: Process;
	invalidProcess,
	match			: Boolean;
	str : String;
begin
	if app.isSDSSecondaryDB then	// 11 July 2011	cmwrs1		CCMS1150 - backup sds notification
		tmpProcess := self.mySDSSecondaryProcess;	// CCMS1150 cnwrs1 04 July 2011
	else
		tmpProcess := self.myProcess;				// 07/03/2011 cnwmh5 #27142
	endif;
	if tmpProcess = null then
		return false;
	endif;
	
	on Exception do app.handleDeletedObject(exception, tmpProcess, invalidProcess);			// 07/03/2011 cnwmh5 #27142
	if app.isSDSSecondaryDB then	// 11 July 2011	cmwrs1		CCMS1150 - backup sds notification
		match := true;
		str := tmpProcess.signOnTime.String;	// to test the handle deleted object
	else
		match := (tmpProcess.signOnTime = self.dateTimeLastStarted);				// 07/03/2011 cnwmh5 #27142
	endif;

	return match and not invalidProcess;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
