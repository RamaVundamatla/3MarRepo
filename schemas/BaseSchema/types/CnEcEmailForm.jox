    <JadeMethod name="updateEmailAddressInBook" id="ac4c7d3f-4b45-4174-b79d-02fe060c7458">
        <source>updateEmailAddressInBook() protected;

vars
	formObj			: CnEcEmailAddressMaintForm;
	emailAddressObj	: CnEcEmailAddress;
	
begin
	emailAddressObj	:=	lstAddressPerson.listObject.CnEcEmailAddress;
	
	create formObj;
	formObj.aMyEmailAddress		:=	emailAddressObj;
	formObj.aMyEmailSendForm	:=	self;
	formObj.showModal();
	
	self.populateAddressPersonList();
epilog
	if app.isValidObject(emailAddressObj) then
		lstAddressPerson.listIndex	:=	lstAddressPerson.findObject(emailAddressObj);
		
		if lstAddressPerson.listIndex &gt; 0 then
			btnAddressBook.enabled := true;
		else
			btnAddressBook.enabled := false;
		endif;
	else
		btnAddressBook.enabled := false;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="userNotify" id="fb061a1f-bfe3-41a5-a905-a365e11d856a">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;

vars
	smtpObj		:	CnSmtpConnection;
	errorMsg	: String;

begin
	smtpObj	:=	theObject.CnSmtpConnection;

	self.aIsWaiting := false;
	
	if smtpObj.result.bitAnd(CnSmtpConnection.Error_Occurred) &lt;&gt; null then
		self.populateWithLastEmail();
		app.msgBox(smtpObj.extendedErrorText,  "SMTP Error " &amp; smtpObj.errorCode.String,	MsgBox_OK_Only);
	else
		self.deleteMyLastEmail();
		self.setStatusLine(null);			    
	endif;
	
	btnSend.enabled	:=	true;
epilog
	delete smtpObj;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="xHandlerEmail" id="826e8064-3ff4-48e1-9f7f-63c910cff945">
        <updating/>
        <source>xHandlerEmail(pExceptionObj: Exception):Integer updating; 

constants
	UNAVAILABLE1		: Integer = 450;
	UNAVAILABLE2		: Integer = 550;
	NOT_LOCAL			: Integer = 551;
	NAME_NOT_ALLOWED	: Integer = 553;
	OBJECT_NOT_CREATED	: Integer = 100000;
	NO_MAIL_SERVER		: Integer = 100001;
	MESSAGE_OR_FILE		: Integer = 100002;
	NO_MESSAGE_OR_FILE	: Integer = 100003;
	NO_SEND_FROM		: Integer = 100004;
	NO_SEND_TO			: Integer = 100005;
	NO_SUBJECT			: Integer = 100006;
	MORE_THAN_1000		: Integer = 100007;
	NON_ASCII			: Integer = 100008;
	INVALID_TYPE		: Integer = 100009;
	NO_MESSAGE_FILE		: Integer = 100010;
	SEND_FROM_OVER_64	: Integer = 100011;
	SEND_TO_OVER_64		: Integer = 100012;
	MORE_THAN_100_TO	: Integer = 100013;
	REPLY_OVER_64		: Integer = 100014;
	SENDER_OVER_64		: Integer = 100016;
	NO_ATTACHMENT		: Integer = 100017;
	INVALID_ATTACHMENT	: Integer = 100018;

vars
	returnvalue	: Integer;
	errorCode	: Integer;

begin
	returnvalue	:=	0;
	errorCode	:=	pExceptionObj.errorCode;

	if errorCode = UNAVAILABLE1 or errorCode = UNAVAILABLE2 then
		app.msgBox ("Mailbox Unavailable:", "Error", 0);
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = NOT_LOCAL  then
		app.msgBox ("User not local", "Error", 0);
		returnvalue :=  Ex_Abort_Action;
	endif;
	if errorCode = NAME_NOT_ALLOWED  then
		app.msgBox ("Mail Box name not allowed", "Error", 0);
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = OBJECT_NOT_CREATED  then
		app.msgBox ("The CnCntrl object has not been created", "Error", 0);
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = NO_MAIL_SERVER  then
		app.msgBox ("No mail server has been entered", "Error", 0);
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = MESSAGE_OR_FILE  then
		app.msgBox ("Specify a message OR a message file, not both", "Error", 0);
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = NO_MESSAGE_OR_FILE  then
		app.msgBox ("You have not specified a message or a message file", "Error", 0);
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = NO_SEND_FROM  then
		app.msgBox ("No sender has been specified", "Error", 0);
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = NO_SEND_TO  then
		app.msgBox ("The send to address has not been entered", "Error", 0);
		returnvalue :=  Ex_Abort_Action;
	endif;	
	
	if errorCode = NO_SUBJECT  then
		app.msgBox ("No subject has been entered", "Error", 0);
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = NO_MAIL_SERVER  then
		app.msgBox ("One line can not contain more than 1000 characters", "Error", 0);
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = NON_ASCII  then
		app.msgBox ("Your message contains Non ASCII characters", "Error", 0);
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = INVALID_TYPE  then
		app.msgBox ("No valid content type was provided", "Error", 0);
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = NO_MESSAGE_FILE  then
		app.msgBox ("No message file was provided", "Error", 0);
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = SEND_FROM_OVER_64  then
		app.msgBox ("The from address was greater than 64 characters", "Error", 0);
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = SEND_TO_OVER_64  then
		app.msgBox ("The to address was greater than 64 characters", "Error", 0);
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = MORE_THAN_100_TO  then
		app.msgBox ("Can not send to more than 100 addresses", "Error", 0);
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = REPLY_OVER_64  then
		app.msgBox ("The reply address was greater than 64 characters", "Error", 0);
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = SENDER_OVER_64  then
		app.msgBox ("The sender address was greater than 64 characters", "Error", 0);
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = NO_ATTACHMENT  then
		app.msgBox ("Can't find the attachment file", "Error", 0);
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = INVALID_ATTACHMENT  then
		app.msgBox ("You have not provided a valid attachment encoding type", "Error", 0);
		returnvalue :=  Ex_Abort_Action;
	endif;
	
	if errorCode = MORE_THAN_1000  then
		app.msgBox ("More than 1000 characters on a line in the message", "Error", 0);
		returnvalue :=  Ex_Abort_Action;
	endif;

	if returnvalue = 0 then
		returnvalue := Ex_Pass_Back;	 //default dialog
	endif;
	
	if errorCode &lt;&gt; null then
		app.msgBox( "Email error condition - " &amp; errorCode.String, "Email Error" , MsgBox_OK_Only );
	endif;		

	return returnvalue;
epilog
	self.deleteMyLastEmail();
	btnSend.enabled := true;		
	self.aIsWaiting := false;
	self.setStatusLine("Error occurred, please correct and resend.");
end;</source>
        <Parameter name="pExceptionObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</GUIClass>
