    <JadeMethod name="refreshArrDepartTimeTable" id="0c4ad904-86b5-4d0d-aa31-10e2febf111f">
        <source>refreshArrDepartTimeTable();

vars
	arrivedLocal,
	departedLocal:	TimeStamp;
begin
	if myCurrentWorkingVoyage = null then
		return;
	endif;
 	// This method is called when the arrival or departure dates/times change
	arrivedLocal := self.systemToLocalTime(myCurrentWorkingVoyage.arrivedDT);	// 31/5/16 cnwmp6 TFS 488 - Multi timezone support
 	txtDateArrival.setDate(arrivedLocal.Date);
	txtTimeArrival.setTime(arrivedLocal.Time);
	departedLocal := self.systemToLocalTime(myCurrentWorkingVoyage.departedDT);	// 31/5/16 cnwmp6 TFS 488 - Multi timezone support
	txtDateDepart.setDate(departedLocal.Date);
	txtTimeDepart.setTime(departedLocal.Time);
end;</source>
    </JadeMethod>
