end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStackHeightOfTIsColour" id="5d0d8a28-7b70-498d-9420-f8262b6b84da">
        <source>getStackHeightOfTIsColour() : Integer;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
/* note these are the meanings of the colours
  strs(1) = "Unavailable"
  strs(2) = "SubBlock"
  strs(3) = "Light"
  strs(4) = "Building"
  strs(5) = "Empty"
  strs(6) = "˝"
  strs(7) = "1"
  strs(8) = "1 ˝"
  strs(9) = "2"
  strs(10) = "2 ˝"
  strs(11) = "3"
  strs(12) = "3 ˝"
  strs(13) = "4"
  strs(14) = "4 ˝"
  strs(15) = "5"
  strs(16) = "5 ˝"
  strs(17) = "6"
  strs(18) = "6 ˝"
  strs(19) = "7"
  strs(20) = "7 ˝"
  strs(21) = "8"

*/
// ---------------------------------------------------------------------------
vars
	totalHeight	:	Integer;
	idx, colur : Integer;
	ti : CM_TrackedItem;
begin

	if self.mySubBlockStack &lt;&gt; null then
		return 2;
	elseif self.usage = BUILDING_USE then
		return 4;
	elseif self.usage = LIGHT_TOWER_USE then
		return 3;
	elseif self.usage = UNAVAILABLE_USE or self.availability = PAD_USER_UNAVAILABLE or self.availability = PAD_UNAVAILABLE then 
		return 1;
	else

		foreach ti in self.allTrackedItems do
			totalHeight := totalHeight + ti.getHeightOfTI();
		endforeach;
		idx := totalHeight;
		idx := idx + 5;
		if idx &gt; 21 then
			idx := 21;
		endif;
		
		return idx;
	endif;
	
	return -1;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
