end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateMoveTo" id="3c17b5e1-5354-4a17-b653-e78725c9030a">
        <source>validateMoveTo(control: CMIF_MoveController input);
/*
 ------------------------------------------------------------------------
Created:			26 November 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	tAutoPlanMove : CMIF_AutoMovePlan;
begin
	if control.isForcedMove then
		return;
	endif;

	if control.myTrackedItem.myCargoType.id &lt;&gt; TI_CargoType_Tower then	
		app.raiseCMException(ERR_ONLY_TOWERS, null, null);
		return;
	endif;
		
	inheritMethod(control);
	//------------------
	//Validate for Labour Restriction in the area we are moving TO
	//------------------
	//self.validateMoveLabourRestriction(control); // already done in inherithMethod();
	//------------------------
	//This is the standard stuff to validate any move here	
	//------------------------
	if self.includesTI(control.myTrackedItem, control.moveMode) then
		//-----------------
		//If the TI is already here, then simply return. They must be shifting it?
		//-----------------
		return;
	endif;
	//---------------------------
	//  Creat a transient automoveplan from our moveController so we can share
	//  same code as the autoPlan tests.
	//---------------------------
	tAutoPlanMove := control.createAsAutoMovePlan();
	tAutoPlanMove.setOriginatingController(self);
	//---------------------------
	//  TEST : Vertically full
	//---------------------------
	self.isStackFull(tAutoPlanMove);
	if tAutoPlanMove.getController() = null then
		return;
	endif;
	//---------------------------
	//Check location restriction
	//---------------------------
	self.testIsControllerLocnRestricted(tAutoPlanMove );
epilog
	delete tAutoPlanMove;
end;</source>
        <Parameter name="control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
</Class>
