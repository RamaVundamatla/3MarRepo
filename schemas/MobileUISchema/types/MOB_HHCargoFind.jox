        <source>unload() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2016	cnwndl1	Initial creation

*/

vars

begin

	if self.mySearchEntTableView &lt;&gt; null 
	and self.mySearchEntTableView.isTransient
	then
		delete self.mySearchEntTableView;
	endif;

epilog

