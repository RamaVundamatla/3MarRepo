        <updating/>
        <source>btnOk_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		03 June 2008 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	
	if self.doSave() then
		self.modalResult	:=	self.MB_MODAL_UPDATE;
		self.unloadForm();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
