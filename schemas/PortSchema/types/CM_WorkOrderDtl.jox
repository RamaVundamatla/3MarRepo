    <JadeMethod name="doVoidInvoiceLines" id="9e2edd85-c529-40bf-b712-333a579b98db">
        <source>doVoidInvoiceLines();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/11/2024	navkc1 JIRA Story MTN-33012: EUP | WO Transaction Billing Change of Debtor

*/

vars
	woTrans				: CM_WOTransaction;
	pxyInvLine,
	invLine				: CM_InvoiceLine;
	invStatus			: CMIF_InvoiceStatus;
	transientToDelete 	: ObjectArray;
	reason				: String;
	voidStatus			: Integer;
begin
	
	if not self.getNoCharge() then
		return;
	endif;
	
	// Void the invoice lines when no charge is true;
	
	voidStatus 	:= CM_InvoiceLine.STATUS_VOIDED;
	reason 		:= "Completed Work Order No Charge changed to true.";
	create transientToDelete transient;
	
	foreach woTrans in self.allWODtlTransactions discreteLock do
		foreach invLine in woTrans.allInvoiceLines discreteLock where invLine.status &lt;&gt; voidStatus do
			create invStatus transient;
			transientToDelete.add(invStatus);
			
			pxyInvLine := app.createUpdateProxy(invLine).CM_InvoiceLine;
			transientToDelete.add(pxyInvLine);
			
			invStatus.allInvoiceLines.add(pxyInvLine);
			invStatus.voidReason := reason;
			invStatus.newStatus := voidStatus;
			
			app.myUtilityUA.utlUpdateInvoiceLineStatus(pxyInvLine, invStatus, app.myPassport);
		endforeach;
	endforeach;	
	
epilog
	if transientToDelete &lt;&gt; null then
		transientToDelete.purge();
	endif;
	delete transientToDelete;
end;</source>
    </JadeMethod>
    <JadeMethod name="erase" id="06337d70-7511-4069-8bca-fe6503111764">
