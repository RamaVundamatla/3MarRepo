    <JadeMethod name="getChildNiceName" id="e65f69a1-c900-4e39-9cfa-1a57ca14aa1e">
        <source>getChildNiceName(_obj : CM_Object): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	if _obj = null then
		return null ;
	endif;
	return _obj.CM_VesselSection.code;

epilog

end;</source>
