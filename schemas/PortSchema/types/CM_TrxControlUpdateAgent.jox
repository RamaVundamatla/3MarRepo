        <updating/>
        <source>trxUpdateWLEStatusDirectWLE(_wle: CM_WorkListEntry input; _status : Integer; _passport : CM_Passport input) updating;
/*
Purpose:			
Date				Who			Reason
AUGUST 2014		CNWAB1		Initial creation
*/
vars
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);

	beginTransaction;

	app.myUtilityUA.utlUpdateWLEStatusDirectWLE(_wle, _status, _passport);

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateWLEsAutoplan" id="8056ab28-3c6d-45cf-bd59-7209e9af0863">
        <updating/>
        <source>trxUpdateWLEsAutoplan(_wleArray : CM_WLEArray; _wlesWithWarnings : CM_WLEArray input; _moveMode : Integer; _passport : CM_Passport input) updating;
//-----------------------------------------
//Created: June 2004 By: cnwgd1
//-----------------------------------------
vars
	tmpTI : CM_TrackedItem;
	wle : CM_WorkListEntry;
	toLocn : CM_LocationsController;
	autoPlan,
	alertCreated : Boolean;
	hadException	: Boolean;
	id		: String;
	moveController : CMIF_MoveController;
	errorSet	: CM_ErrorSet;	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// DVB added 30/05/2005
	app.initialiseForStartAutoPlan(_passport);
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	app.myEventManager.setMultiTransactionTrx();
	
	create errorSet transient;
	// 36290 handle deleted WLEs in the input
	on Exception do app.handleDeletedObject (exception, wle, hadException);
	
	foreach wle in _wleArray do
		// 36290 check for invalid WLE and skip if any
		hadException := false;
		id := wle.id;
		if hadException then
			continue;
		endif;

		beginTransaction;
		if wle.status = WLE_COMPLETED then
			app.raiseCMException3(ERR_QUEUE_WLE_STAT, wle.getTreeDescription(), 'complete', 'auto-planned', null, null);
		endif;
		
		if _passport.noErrors() then
			app.myUtilityUA.utlUpdateWLEAutoplan(wle, _moveMode, _passport);
		endif;
		
		if _passport.isOkToCommit(false) then
			app.cmsCommitTransaction(_passport);
		else
			app.cmsAbortTransaction;
			if _passport.hasErrors then
				app.convertErrorsWarningsToAlert('Entry ' &amp; wle.getFullDescription() 
												&amp; ' could not be auto-planned', _passport.allErrorWarnings);				
				alertCreated := true;
			elseif _passport.hasWarnings then
				_wlesWithWarnings.add(wle);
			endif;
			_passport.moveErrorsToSet(errorSet);
			_passport.initialiseTransaction();				
		endif;
	endforeach;

	if _passport.noErrors and (not process.isInTransactionState) then
		// Done so that finaliseActivityWithPassport will commit correctly
		beginTransaction;
	endif;
	_passport.addErrorsFromSet(errorSet);
	if alertCreated then
		app.raiseCMException1(SystemAlertCreated, 'work list entries', null, self);
	endif;	
	
epilog
	self.finaliseActivityWithPassport(_passport);
	delete errorSet;
	delete moveController;	
end;</source>
        <Parameter name="_wleArray" type="CM_WLEArray"/>
        <Parameter name="_wlesWithWarnings" type="CM_WLEArray" usage="input"/>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateWLEsAutoplanRailArea" id="f01ecc74-f4e8-4a9a-925b-8080416b4046">
        <updating/>
        <source>trxUpdateWLEsAutoplanRailArea(_wleArray 		: CM_WLEArray; 
							_wlesWithWarnings 	: CM_WLEArray input; 
							_rail				: CM_Rail;
							_moveMode			: Integer; 
							_effectiveTS : TimeStamp;	//25 Feb 2021	NDL	TFS 50837
							_passport 			: CM_Passport input) updating;
//-----------------------------------------
//Created: June 2004 By: cnwgd1
//-----------------------------------------
vars
	tmpTI : CM_TrackedItem;
	wle : CM_WorkListEntry;
	toLocn : CM_LocationsController;
	autoPlan,
	alertCreated : Boolean;
	hadException	: Boolean;
	id		: String;
	errorSet	: CM_ErrorSet;	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// DVB added 30/05/2005
	app.initialiseForStartAutoPlan(_passport);
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	app.myEventManager.setMultiTransactionTrx();
	
	create errorSet transient;
	// 36290 handle deleted WLEs in the input
	on Exception do app.handleDeletedObject (exception, wle, hadException);

	foreach wle in _wleArray do
		// 36290 check for invalid WLE and skip if any
		hadException := false;
		id := wle.id;
		if hadException then
			continue;
		endif;

		beginTransaction;
		if wle.status = WLE_COMPLETED then
			continue;
		endif;
		
		if not _passport.noErrors() then
			return;
		endif;
		
		app.myUtilityUA.utlUpdateWLEAutoplanToRailArea(wle, _rail, _moveMode, _effectiveTS, _passport);
			
		if _passport.isOkToCommit(false) then
			app.cmsCommitTransaction(_passport);
		else
			app.cmsAbortTransaction;
			if _passport.hasErrors then
				app.convertErrorsWarningsToAlert('Entry ' &amp; wle.getFullDescription() 
												&amp; ' could not be auto-planned', _passport.allErrorWarnings);				
				alertCreated := true;
			elseif _passport.hasWarnings then
				_wlesWithWarnings.add(wle);
			endif;
			_passport.moveErrorsToSet(errorSet);
			_passport.initialiseTransaction();				
		endif;
	endforeach;

	if _passport.noErrors and (not process.isInTransactionState) then
		// Done so that finaliseActivityWithPassport will commit correctly
		beginTransaction;
	endif;
	_passport.addErrorsFromSet(errorSet);
	if alertCreated then
		app.raiseCMException1(SystemAlertCreated, 'work list entries', null, self);
	endif;	
	
epilog
	self.finaliseActivityWithPassport(_passport);
	delete errorSet;
	
end;</source>
        <Parameter name="_wleArray" type="CM_WLEArray"/>
        <Parameter name="_wlesWithWarnings" type="CM_WLEArray" usage="input"/>
        <Parameter name="_rail" type="CM_Rail"/>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_effectiveTS" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateWLEsAutoplanTwin" id="a6a0be5e-9415-45c4-b37c-792a7db4f10d">
        <updating/>
        <source>trxUpdateWLEsAutoplanTwin(_wleArray : CM_WLEArray; _wlesWithWarnings : CM_WLEArray input; _moveMode : Integer; _passport : CM_Passport input) updating;
//-----------------------------------------
//Created: June 2004 By: cnwgd1
//-----------------------------------------
vars
	tmpTI, previousTI : CM_TrackedItem;
	wle : CM_WorkListEntry;
	voyageWLE,previousWLE 	: CM_VoyageWLE;
	toLocn : CM_LocationsController;
	autoPlan,
	alertCreated : Boolean;
	moveController : CMIF_MoveController;
	errorSet	: CM_ErrorSet;	
	iter : Iterator;
	hadException	: Boolean;
	id		: String;
	isTwinWLE : Boolean;
	previousSeq,
	seq : Integer;
	foundLC,
	foundLCTwin : CM_LocationsController;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// DVB added 30/05/2005
	app.initialiseForStartAutoPlan(_passport);
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	//app.myEventManager.setMultiTransactionTrx();

	create errorSet transient;
	// 36290 handle deleted WLEs in the input
	on Exception do app.handleDeletedObject (exception, wle, hadException);

	iter := _wleArray.createIterator;
	while iter.next(voyageWLE) do
		// 36290 check for invalid WLE and skip if any
		hadException := false;
		id := wle.id;
		if hadException then
			continue;
		endif;

		if wle.isKindOf(CM_VoyageWLE) then
			voyageWLE:=wle.CM_VoyageWLE;
		endif;
		if voyageWLE &lt;&gt; null then
			
			// does the previous wle have the same sequence number
			if previousWLE &lt;&gt; null and  previousWLE &lt;&gt; voyageWLE then
			
			
				beginTransaction;
				if previousWLE.status = WLE_COMPLETED or voyageWLE.status = WLE_COMPLETED then
					app.raiseCMException3(ERR_QUEUE_WLE_STAT, wle.getTreeDescription(), 'complete', 'auto-planned', null, null);
				endif;
				if _passport.noErrors() then
					app.myUtilityUA.utlUpdateAutoplanTwin(previousWLE.myTrackedItem,
														  voyageWLE.myTrackedItem,
														  previousWLE.job,
														  voyageWLE.job,
														  null,
														  null,
														  _moveMode,
														  _passport);
				endif;
				
				if _moveMode = QUEUE_MODE and (previousWLE.myTrackedItem.myPrimaryQueuedLocation = null or  voyageWLE.myTrackedItem.myPrimaryQueuedLocation = null) then
					app.raiseCMException2(Failed_twin_carry_auto_plan, previousWLE.myTrackedItem.id, voyageWLE.myTrackedItem.id, null, previousWLE.myTrackedItem);
				elseif _moveMode = PLANNING_MODE and (previousWLE.myTrackedItem.myPrimaryPlannedLocation = null or  voyageWLE.myTrackedItem.myPrimaryPlannedLocation = null) then
					app.raiseCMException2(Failed_twin_carry_auto_plan, previousWLE.myTrackedItem.id, voyageWLE.myTrackedItem.id,  null, previousWLE.myTrackedItem);
				endif;
				
				if _passport.isOkToCommit(false) then
					app.cmsCommitTransaction(_passport);
				else
					app.cmsAbortTransaction;
					if _passport.hasErrors then
						app.convertErrorsWarningsToAlert('Entry ' &amp; previousWLE.getFullDescription() 
														&amp; ' and '  &amp; voyageWLE.getFullDescription() &amp; ' could not be twin auto-planned', _passport.allErrorWarnings);				
						alertCreated := true;
					elseif _passport.hasWarnings then
						_wlesWithWarnings.add(previousWLE);
					endif;
					_passport.moveErrorsToSet(errorSet);
					_passport.initialiseTransaction();				
				endif;
				
			endif;
			previousWLE:=voyageWLE;
		else
			previousWLE:=null;
		endif;
		
	endwhile;


	if _passport.noErrors and (not process.isInTransactionState) then
		// Done so that finaliseActivityWithPassport will commit correctly
		beginTransaction;
	endif;
	_passport.addErrorsFromSet(errorSet);
	if alertCreated then
		app.raiseCMException1(SystemAlertCreated, 'work list entries', null, self);
	endif;	
	
epilog
	self.finaliseActivityWithPassport(_passport);
	delete iter;
	delete errorSet;
	delete moveController;	

end;</source>
        <Parameter name="_wleArray" type="CM_WLEArray"/>
        <Parameter name="_wlesWithWarnings" type="CM_WLEArray" usage="input"/>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateWLEsDoMove" id="bf159e7e-a262-4a83-9dba-35e460f57a85">
        <updating/>
        <source>trxUpdateWLEsDoMove(_wleArray 		    : CM_WLEArray;  
					_wlesWithWarnings   : CM_WLEArray input; 
					_moveMode	        : Integer;
					_queueInOrder 	    : Boolean;
					_effectiveTimeStamp : TimeStamp; 
					_passport 			: CM_Passport input) updating;
//-----------------------------------------
//Created: 01 May 2003 By: cnwgd1
//-----------------------------------------
// ### _queueInOrder PAR 8947. If we are queueing voyage WLEs they have to 
//		be queued in order. But we allow this to be overridden.
//		This is because they are in a sequence order and they must be in that same order in the RTQ
//		Without this param Voyage WLEs with errors where not planned and so got out of order on the RTQ
//		If REAL MODE then always move what you can
//
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------------------------------
// 25/10/2011	cnwdap1		PAR #28524 CCMS POL 2096 Coparn bookings
// 31/01/2011	cnwdap1		PAR #29071 Avoid 1090 on a booking with no voyage
// 15/10/2021	navdap1		TFS 51935 SAL Direct Loading Partial Prenoted Cargo from Truck to Vessel
// 01/12/2021	navdap1		TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
// 06/12/2021	navdap1		TFS 52293 SAL Direct Laoding - Marking Job as Direct Delivery
// 29/10/2024   navma1		MTN-33231 - Enable Deferred Updates For Train and Wagon Events 
// 17/03/2025	navma1 		MTN-34120 MTN | Dead Lock (1081) on CM_OfflineFutureActorParentDct
vars
	tmpTI 				 : CM_TrackedItem;
	wle 				 : CM_WorkListEntry;
	toLocn 				 : CM_LocationsController;
	hadException	 	 : Boolean;
	id					 : String;
	modeStr				 : String;
	autoPlan,
	alertCreated, 
	allHasErrorsWarnings : Boolean;
	moveController 		 : CMIF_MoveController;
	errorSet			 : CM_ErrorSet;	
	queueInOrder 		 : Boolean;
	bookingRef 			 : CM_BookingRef;		// PAR #28524
	voyageCode 			 : String;				// PAR #29071
	schema 				 : Schema;				// TFS 51935
	assistantClass 		 : Class;				// TFS 51935
	assistant 			 : Object;				// TFS 51935
	result 				 : Boolean;				// TFS 51935
	localMoveMode 		 : Integer;				// TFS 51935
	fmWle 				 : CM_WorkListEntry;	// TFS 51935
	directMove 			 : Boolean;				// TFS 51935
	isGateInAutoComplete : Boolean;
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	
	// DVB added 30/05/2005
	app.initialiseForStartAutoPlan(_passport);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	queueInOrder := _queueInOrder;
	if _moveMode = REAL_MODE then
		queueInOrder := false;
	endif;	

	// 36290 handle deleted WLEs in the input
	on Exception do app.handleDeletedObject (exception, wle, hadException);
	
	if _moveMode = PLANNING_MODE then
		app.raiseCMException1( Invalid_move_mode_passed, method.qualifiedName, null, null );	//13 Apr 2021	NDL	TFS 50906
	endif;
		
	if _moveMode = QUEUE_MODE then
		modeStr := 'Queued';
	else
		modeStr := 'Moved';
	endif;		

	// so only 1 note sent from the move controller
	app.myEventManager.setMultiTransactionTrx();
	
	isGateInAutoComplete := _passport.myTerminal.getConfig(GateInAutoComplete).Boolean;		//17.03.2025 navma1 #MTN-34120
	
	create errorSet transient;		
	create moveController transient;
	moveController.setMoveMode(_moveMode);
	moveController.setEffectiveTimeStampOverride(_effectiveTimeStamp);

	foreach wle in _wleArray do
		// Set every time as they are reset.
		_passport.useTITransactionDeferUpdate	:= true;
		_passport.useTIDictDeferUpdate 			:= true;
		_passport.useEventDeferUpdate			:= true;		//25.10.2024 navma1 #MTN-33231
		_passport.useOfflineFutureActorDeferDel := true;		//17.03.2025 navma1 #MTN-34120
		_passport.useOfflineFutureActorDeferUpd := true;		//17.03.2025 navma1 #MTN-34120
		
		// 36290 check for invalid WLE and skip if any
		hadException := false;
		id := wle.id;
		if hadException then
			continue;
		endif;
		
		// PAR #28524 If the operator's bookings are unique by number, and we're real-moving to a ship, display a warning
		// if the TI has a booking and the booking's voyage differs from the one we're moving to
		if _moveMode = REAL_MODE 
		and wle.myTrackedItem &lt;&gt; null 
		and wle.myTrackedItem.myOperator.bookingsUniqueByNumber 
		and CM_VoyageJob.hasInstance(wle.job) then
			tmpTI := wle.myTrackedItem;
			
			if tmpTI.myBookingRef &lt;&gt; null then
				bookingRef := tmpTI.myBookingRef;
			elseif tmpTI.bookingReference &lt;&gt; null then
				bookingRef := tmpTI.myTerminal.getBookingReference(tmpTI.myOperator.code, tmpTI.bookingReference, null);
			endif;
			if bookingRef &lt;&gt; null and bookingRef.myVoyage &lt;&gt; wle.job.CM_VoyageJob.myVoyage then
				if bookingRef.myVoyage &lt;&gt; null then				// PAR #29071
					voyageCode := bookingRef.myVoyage.code;		// PAR #29071
				else											// PAR #29071
					voyageCode := null;							// PAR #29071
				endif;											// PAR #29071
				app.raiseCMWarning2(BookingVoyageMatch, voyageCode, wle.job.CM_VoyageJob.myVoyage.code, "bookingReference", null, tmpTI);	// PAR #29071
			endif;
		endif;
		// PAR #28524 
		
		//07 Feb 2013	NDL	Par 31102
		if _moveMode = QUEUE_MODE and wle.myTrackedItem &lt;&gt; null and wle.myTrackedItem.directDelivery then
			app.raiseCMException1(Direct_delive_cargo_not_queued, wle.myTrackedItem.id, app.getErrorString(Direct_delivery), tmpTI);		// PAR #29071
		endif;
		
		// TFS 51935 If doing direct move from truck to voyage, the first future location on the TI 
		// will be used as the target location. Need to set DD WLE on the move controller as well,
		// and get the quantity / amount we're moving
		if _moveMode = REAL_MODE and not (wle.myFutureMove = null and wle.isCompleteForJob) then		//17.03.2025 navma1 #MTN-34120
			tmpTI := wle.myTrackedItem;
			if tmpTI &lt;&gt; null then
				directMove := wle.job.isDirectDeliveryJob;										// TFS 52293
				if toLocn = null and directMove then
					toLocn := wle.getLocationForDDMove(tmpTI, fmWle);
					if toLocn &lt;&gt; null then
						if fmWle &lt;&gt; null then								// TFS 52360
							moveController.myDDWorkListEntry := fmWle;
							moveController.myDDJob := fmWle.job;
						endif;												// TFS 52360
						moveController.setMyToPrimaryLocation(toLocn);
					endif;
					if tmpTI.canSplitTotalQuantity then
						localMoveMode := _moveMode;
						moveController.setMyTrackedItem(tmpTI);
						schema := rootSchema.getSchema(UiCommonSchemaName);
						assistantClass := schema.getClass("CMUI_Assistant");
						create assistant as assistantClass transient;
						assistant.sendMsgWithIOParams("showMoveAmountFormForRoadOps", moveController, localMoveMode, result);
						if not result then
							continue;
						endif;
					endif;
				endif;
			endif;
		endif;
		// TFS 51935 end of this bit
		
		beginTransaction;
		
		//epr par 25573 7/2/2011
		if wle.myFutureMove = null and wle.isCompleteForJob then 		//17.03.2025 navma1 #MTN-34120
			app.raiseCMException3(ERR_QUEUE_WLE_STAT, wle.getTreeDescription(), 'complete', modeStr, null, null);
		endif;
		
		if _passport.noErrors() then
			if wle.myTrackedItem = null and not wle.myRequest.isKindOf(CM_ReceivalRequest) then		// cnwjk3 ccms 1071 22/02/10
				//Cargo on Dockets may not have been created yet e.g. Log Dockets
				wle.setTIsForAutoComplete();
				if wle.myBOL &lt;&gt; null and (wle.myBOL.bolType = BOLType_Log and not isGateInAutoComplete ) then				//17.03.2025 navma1 #MTN-34120
					app.raiseCMWarning1(Movin_docke_will_resul_creat_u, wle.myBOL.number.String, null, null,wle.myBOL);	
				endif;
			endif;
			tmpTI := wle.myTrackedItem;
			if tmpTI &lt;&gt; null then		
				exclusiveLock(tmpTI);				
			endif;
			toLocn := wle.getLocationForMode(PLANNING_MODE);
			if toLocn = null then
				toLocn := wle.getLocationForMode(QUEUE_MODE);		
			endif;
			if toLocn = null then											// TFS 51935
				toLocn := wle.getLocationForDDMove(tmpTI, fmWle);			// TFS 51935
			endif;															// TFS 51935

			if toLocn = null 
			and _moveMode = QUEUE_MODE
			and tmpTI &lt;&gt; null 
			and (not wle.isReceipt) then
				toLocn := wle.getReleaseTransferAreaLocation();
				if _passport.warningsAcknowledged then
					//They want to queue it to the release transfer area
				elseif toLocn &lt;&gt; null then
					//Ask if they want to queue the release to the release transfer area
					app.raiseCMWarning3(QueueToTransferArea, wle.getTreeDescription(), tmpTI.id, toLocn.getID(), null, null, tmpTI);
				else
					app.raiseCMException3(ERR_QUEUE_WLE_STAT, wle.getTreeDescription(), 'not planned', 'queued', null, null);									
				endif;
			endif;		

			if toLocn = null and _passport.noErrors() then
				if not wle.myRequest.isKindOf(CM_ReceivalRequest) then	// cnwjk3 ccms 1071 22/02/10
					if _passport.warningsAcknowledged then
						//They want to try auto-planning
						autoPlan := true;
					else
						app.autoPlanAlertOverride(_passport.myTerminal);
						autoPlan := true;
					endif;
				endif;
			endif;

			if _passport.noErrors() then													
				if toLocn &lt;&gt; null then
					if tmpTI &lt;&gt; null then
						// this needs to be set set that the setMyToPrimaryLocation can handle 40 footers going to the voyage
						moveController.setMyTrackedItem(tmpTI);
					endif;
					if wle.isBulkRelease() and ( not toLocn.isVoyageController and not _moveMode = REAL_MODE ) then // dont autoplan if we are going to a ship cnwrd1 par 30222
						// Just queue it
						app.myUtilityUA.utlUpdateWLEAutoplan(wle, QUEUE_MODE, _passport);
					else	
						//we only create the moveController once, 
						//WLE updates the controller as required,
						//validation is done in the move
						//epr par 17/11/08 18493 make sure we update the to primary location string by setting to null then setting 
						moveController.setMyToPrimaryLocation(null);
						moveController.setMyToPrimaryLocation(toLocn);
						
						// jlgzm1 tfs42863 17/09/2019
						if wle.isDRLinkedByFM  then
							//want to always be using the receipt wle for consistency
							if wle.myFutureMove &lt;&gt; null then
								wle := wle.getDRLinkedWLE();
							endif;
						endif;
						
						// TFS 51935 if we're a direct move from truck to voyage, we've already set the 
						// wle weight and/or quantity
						if not directMove then
							moveController.setQuantity(wle.quantity);	//epr par 31875 25/6/13
							moveController.setWeight(wle.weight); //epr CCMS 1366 13/3/14
						endif;
						// TFS 51935 end of this bit
						
						wle.doMoveToLocn(moveController, _passport);

					endif;
				elseif autoPlan then
					app.myUtilityUA.utlUpdateWLEAutoplan(wle, QUEUE_MODE, _passport);
				elseif wle.myRequest.isKindOf(CM_ReceivalRequest) and  _moveMode = REAL_MODE  then			//epr par 36277 21/5/15			
					app.myUtilityUA.utlUpdateWLEStatusDirectWLE(wle.CM_YardWLE, WLE_COMPLETED, _passport);		// cnwjk3 ccms 1071 22/02/10
				endif;
			endif;
		endif; 
		
		// Do those deferred updates.
		if _passport.noErrors() then
			_passport.doDeferredUpdates();
		endif;
		
		if _passport.isOkToCommit(false) and not allHasErrorsWarnings then
			// PAR 9401. This 'dispatchAllEvents' was making the move 4 times slower. This whole move method is fast, but this dispatch here made 
			//			the notes get sent out 1 every 3 seconds. taking it out you get 3 notes per  second.
			//app.myEventManager.dispatchAllEvents; 
			app.cmsCommitTransaction(_passport);
		else
			app.cmsAbortTransaction;
			if queueInOrder then
				allHasErrorsWarnings := true;
			endif;
			if _passport.hasErrors then
				app.convertErrorsWarningsToAlert('Entry ' &amp; wle.getFullDescription() 
												&amp; ' could not be ' &amp; modeStr &amp;' to location', _passport.allErrorWarnings);				
				alertCreated := true;
			elseif _passport.hasWarnings
			or queueInOrder then //add wle so it gets re-processed in order
				_wlesWithWarnings.add(wle);
			endif;
			_passport.moveErrorsToSet(errorSet);
			_passport.initialiseTransaction();				

		endif;
	endforeach;

	if _passport.noErrors and (not process.isInTransactionState) then
		// Done so that finaliseActivityWithPassport will commit correctly
		beginTransaction;
	endif;
	_passport.addErrorsFromSet(errorSet);
	if alertCreated then
		app.raiseCMException1(SystemAlertCreated, 'work list entries', null, self);
	endif;	
	
epilog
	self.finaliseActivityWithPassport(_passport);
	delete errorSet;
	delete moveController;	
end;</source>
        <Parameter name="_wleArray" type="CM_WLEArray"/>
        <Parameter name="_wlesWithWarnings" type="CM_WLEArray" usage="input"/>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_queueInOrder" type="Boolean"/>
        <Parameter name="_effectiveTimeStamp" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateWLEsQueueRequest" id="7ee4887b-5b5e-484b-bd35-c5337d8d1835">
        <updating/>
        <source>trxUpdateWLEsQueueRequest(_wles : CM_WLEArray input; _termAreas : CM_TerminalAreaArray; _termGridObjs : CM_GridObjectArray;_bestPick : Boolean; _fifo : Boolean; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 June 2010	cnwrd1	Initial creation

*/

vars

begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	beginTransaction;

	app.myUtilityUA.utlUpdateWLEsQueueRequest(_wles, _termAreas, _termGridObjs, _bestPick, _fifo , false, _passport);

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
