    <JadeMethod name="isNSWInvoiceAPIDef" id="643058f2-4dde-4bd6-a03e-edc11e76be46">
        <source>isNSWInvoiceAPIDef() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2024	jlier1	Initial creation

*/

vars

begin
	return self.allEndpoints[ETRow_NswCreateInvHeader] &lt;&gt; null;
