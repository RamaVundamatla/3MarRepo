    <JadeMethod name="showRestrictionsForm" id="6fdff0a4-964b-42ca-a9a9-7ddfd6579845">
        <source>showRestrictionsForm(_theTerminalArea : CM_TerminalArea;_areaMode : Integer; _initObject : CM_Object);
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

	theTerminalArea : CM_TerminalArea;
	aForm 	: Form;
	menuAction 		: CMUI_MenuAction;
begin
	if _theTerminalArea = null then
		return;
	endif;
	
	theTerminalArea := _theTerminalArea;
	menuAction := app.myController.createMenuAction(PmAdmPadeditView, null, self.myMasterMenuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;
	
	aForm := menuAction.goToObject(null, null, false, null); 
	if aForm = null then
		return;
	endif;
	
	aForm.sendMsgWithParams("setInitializeWithObject", theTerminalArea, _areaMode, _initObject, false, false);
	aForm.show;	


end;</source>
        <Parameter name="_theTerminalArea" type="CM_TerminalArea"/>
        <Parameter name="_areaMode" type="Integer"/>
        <Parameter name="_initObject" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="showSelectorForm" id="e1e59b9a-f7bd-452c-ad46-ba5390dd327b">
        <updating/>
        <source>showSelectorForm() updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

	theSelector				: CMUI_Selector;
	cargoType				: CM_CargoType;
	
begin
	
	theSelector := app.getSelectorForm(self, self.myMasterMenuAction);
	if theSelector = null then
		return;
	endif;
	
	self.setSelector(theSelector);//this will set the default mode
	theSelector.show;

end;</source>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="2f2dabd0-0bed-44e8-af64-e3834314e3c3">
