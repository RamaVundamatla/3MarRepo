    <JadeMethod name="setLblTotals" id="a676d9a9-9bc1-47a3-94e4-3701459c30e2">
        <updating/>
        <source>setLblTotals() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2014	cnwndl1	Initial creation
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars

	size : Integer;
	ti : CM_TrackedItem;
	obj : Object;
	reserveDetail : CM_ReserveDetail;
	futureMove : CM_FutureMove;
	tiSet : CM_TISet;
	reason : String;

begin

	self.lblTotals.caption := null;
	
	if self.myBulkRelease = null then
		return;
	endif;
	if self.myTargetLocation = null then
		return;
	endif;
	
	if self.fldCargo.topSheet = self.shtSelectable then
		if self.cmbRelItems.listIndex &gt; 0 then
			obj := self.cmbRelItems.itemObject[self.cmbRelItems.listIndex];
			if obj &lt;&gt; null then
				reserveDetail := obj.CM_ReserveDetail;
			endif;
		endif;
		if reserveDetail = null then
			reserveDetail := self.myBulkRelease.allReserveDetails.first;
		endif;
		create tiSet transient;
		if reserveDetail &lt;&gt; null then
			if reserveDetail.isKindOf(CM_ReserveTI) then
				if moveMode = QUEUE_MODE then
					foreach futureMove in self.myTargetLocation.allQueuedFutureMoves do
						ti := futureMove.getTrackedItem;
						if ti &lt;&gt; null then
							//if reserveDetail.allTrackedItems.includes(ti) then
							if reserveDetail.includeTrackedItem(ti, false) then //23/06/2023	navkc1	CR 58406 Task 58408
								tiSet.addNoDuplicates( ti, false );
							endif;
						endif;
					endforeach;
				endif;
				foreach ti in self.myTargetLocation.allTrackedItems do
					//if reserveDetail.allTrackedItems.includes(ti) then
					if reserveDetail.includeTrackedItem(ti, false) then //23/06/2023	navkc1	CR 58406 Task 58408
						tiSet.addNoDuplicates( ti, false );
					endif;
				endforeach;
				
			elseif reserveDetail.isKindOf(CM_ReserveSelection) then
				if moveMode = QUEUE_MODE then
					foreach futureMove in self.myTargetLocation.allQueuedFutureMoves do
						ti := futureMove.getTrackedItem;
						if ti &lt;&gt; null then
							if ti.testAgainstReserveSelection( reserveDetail.CM_ReserveSelection, reason, true, null ) then
								tiSet.addNoDuplicates( ti, false );
							endif;
						endif;
					endforeach;
				endif;
				foreach ti in self.myTargetLocation.allTrackedItems do	
					if ti.testAgainstReserveSelection( reserveDetail.CM_ReserveSelection, reason, true, null ) then
						tiSet.addNoDuplicates( ti, false );
					endif;
				endforeach;
				
			endif;
			size := 0;			// 36334
			foreach ti in tiSet do
				size := size + ti.totalQuantity.max(1);
			endforeach;
			self.lblTotals.caption := size.String &amp; " item(s) in Staging area";
		endif;
	elseif self.fldCargo.topSheet = self.shtChosen then
		size := 0; // 36334
		foreach ti in self.myTargetLocation.allTrackedItems do
			size := size + ti.totalQuantity.max(1);
		endforeach;
		if moveMode = QUEUE_MODE then
			foreach futureMove in self.myTargetLocation.allQueuedFutureMoves do    // 36334
				size := size + futureMove.getTrackedItem.totalQuantity.max(1);
			endforeach;
		endif;
		self.lblTotals.caption := size.String &amp; " item(s) in Staging area";
	endif;
	
	self.txtCargoId.text := null;
	self.convertedAltId := null;	//08 Jul 2016	NDL	TFS 2275 / 2216
	self.convertedCargoId := null;	//08 Jul 2016	NDL	TFS 2275 / 2216					
	self.txtCargoId.setFocus();	//19 Apr 2016	NDL	TFS 1868

epilog

	delete tiSet;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setSelectableOrder" id="9514516a-d2ea-4561-a45f-99ce0b9fa83c">
        <source>setSelectableOrder( _tiSet : CM_TISet input; _tiArray : CM_TIArray input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2014	cnwndl1	Initial creation

*/

vars

	dynaDict : DynaDictionary;

begin

	if _tiSet.isEmpty then
		return;
	endif;

	create dynaDict transient;
	dynaDict.setMembership( CM_TrackedItem );
	
	if self.isById then
		dynaDict.addMemberKey( "id", false, true );
	elseif self.isFIFO then
		dynaDict.addMemberKey( "earliestReceivalTS", false, false );
	endif;
	dynaDict.endKeys(true);
	
	_tiSet.copy( dynaDict );
	
	dynaDict.copy( _tiArray );

epilog

	delete dynaDict;

end;</source>
        <access>protected</access>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
        <Parameter name="_tiArray" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupChosen" id="5de294f4-810f-43cf-8d39-75043a8678c6">
        <updating/>
        <source>setupChosen()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2014	cnwndl1	Initial creation

*/

constants

	TAB_INDEX_START = 1000;
	
vars

	menuButton : MOB_Button;
	buttonOffset : Integer;
	buttonNumber : Integer;
	buttonWidth : Real;
	tiArray : CM_TIArray;
	ti : CM_TrackedItem;
	size : Integer;
	buttonCaption : String;
	futureMove : CM_FutureMove;
	queuedSet : CM_TISet;
	location : String;
	buttonHeight : Integer;
	reserveDetail : CM_ReserveDetail;
	docActions : CM_DocumentActions;
	da : CM_DocumentActions;
	taskAndStopStr : String;
	reason : String;
	
begin

	self.docActsToDisplay.clear();

	if self.chosenCount &gt; 0 then
		foreach buttonNumber in 1 to self.chosenCount do
			menuButton := self.btnChosenTemp.getControl( buttonNumber ).MOB_Button;
			if menuButton &lt;&gt; null then
				menuButton.visible := false;
				delete menuButton;
			endif;
		endforeach;
		self.chosenCount := 0;
		buttonNumber := 0;
	endif;

	create queuedSet transient;
	create tiArray transient;
	self.myTargetLocation.allTrackedItemsById.copy( tiArray ); 
	
	if moveMode = QUEUE_MODE then
		foreach futureMove in self.myTargetLocation.allQueuedFutureMoves do
			ti := futureMove.getTrackedItem;
			if ti &lt;&gt; null then
				tiArray.addExclusive( ti );
				queuedSet.addNoDuplicates( ti, false );
			endif;
		endforeach;
	endif;
	
	size := tiArray.size;	

	buttonHeight := self.getScrollingButtonHeight();
	self.btnChosenTemp.height := buttonHeight;
	buttonWidth := self.getButtonWidthSetScrollBar( size, self.frmChosen, self.btnChosenTemp.height, self.scrChosen );

	foreach ti in tiArray do
	
		docActions := null;
		if not ti.allReserveDetails.isEmpty then
			docActions := ti.allReserveDetails.first.myReserveDetailActions;
		endif;
		if docActions = null then
			foreach reserveDetail in self.myBulkRelease.allReserveDetails do
				da := reserveDetail.myReserveDetailActions;
				if da &lt;&gt; null and da.includesTi( ti ) then
					docActions := da;
					break;
				endif;
			endforeach;
		endif;
		
		buttonNumber := buttonNumber + 1;
		menuButton := self.btnChosenTemp.loadControl( buttonNumber ).MOB_Button;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
		
		menuButton.userObject := ti;
		location := CrLf &amp; ti.myPrimaryActualLocation.getFullId;
		if queuedSet.includes( ti ) then
			location := location &amp; " - Q'd to " &amp; self.myTargetLocation.getFullId;
		endif;
		
		if ti.canSplitTotalQuantity and ti.isBulkByQuantity then
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.totalQuantity.String &amp; ")" 
										&amp; location;
		elseif ti.isBulkByWeight and ti.isBulkByVolume then
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.CM_Bulk.getBulkTrackByDisplayForWeight(true) &amp; ")" 
										&amp; location;
		else
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; location;
		endif;
		
		if docActions &lt;&gt; null then
			taskAndStopStr := docActions.getTaskAndStopStrForTi(ti,true);
			if taskAndStopStr &lt;&gt; null then
				menuButton.caption := menuButton.caption &amp; " " &amp; taskAndStopStr;
				self.docActsToDisplay.addExclusive( docActions );
			endif;
		endif;
		
		self.addHazDetailsToButton( menuButton, ti, null ); //30 May 2017	NDL	TFS 4587
		
		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
		
	endforeach;
	
	self.chosenCount := buttonNumber;
	
	self.btnChosenTemp.visible := false;
	self.frmChosen.caption := null;
	
	self.lblNoChose.visible := self.chosenCount &lt; 1;
	
	
epilog

	delete tiArray;
	delete queuedSet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupControls" id="9be894fc-3b00-4d59-aa44-5d2f53152f3b">
        <updating/>
        <source>setupControls() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2014	cnwndl1	Initial creation

*/

vars

	sheetName: String;

begin

	//21 Sep 2016	NDL	TFS 2647
	sheetName := self.myMobileGenericAgent.stringField1;
	if sheetName = self.shtChosen.name then
		self.isById := self.myMobileGenericAgent.inward;
		self.isFIFO := self.myMobileGenericAgent.forward;
	endif;
	
	self.setupSelectable( self.myBulkRelease.allReserveDetails.first );
	self.setupChosen();
	
	self.doResizeControls(true);
	
	if sheetName = self.shtChosen.name then
		self.fldCargo.querySheetChg(self.fldCargo,self.shtChosen);
		self.fldCargo.topSheet := self.shtChosen;
	endif;
	
	self.setLblTotals();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="cd4266a8-6c81-445a-8203-34d6523edc3d">
        <updating/>
        <source>setupForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2014	cnwndl1	Initial creation

*/

vars

begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	self.moveMode := self.myMobileGenericAgent.checksState; // will be QUEUE_MODE or REAL_MODE, i.e. 2 or 0
	self.myTargetLocation := self.myMobileGenericAgent.myYardLocation;
	self.myBulkRelease := self.myMobileGenericAgent.myBulkRelease;
	if self.myMobileGenericAgent.stringField1 = MOB_HHReleaseStaging::optById.name then
		self.isById := true;
		self.isFIFO := false;
	elseif self.myMobileGenericAgent.stringField1 = MOB_HHReleaseStaging::optFIFO.name then
		self.isById := false;
		self.isFIFO := true;
	endif;
	
	self.lblTotals.caption := null;
	
	inheritMethod();
	
	self.setupCmdButtons( 1, app.getErrorString(Back), null, null, null, null );
	
	self.setupControls();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupSelectable" id="7e1ac89e-f8b7-45f1-8550-41f2f0df460a">
        <updating/>
        <source>setupSelectable( _reserveDetail : CM_ReserveDetail ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2014	cnwndl1	Initial creation
// 11 Jan 2017	cnwrs1	TFS 3144 dont rebuild the release req details combo every ti move
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

constants

	TAB_INDEX_START = 1000;
	
vars

	reserveDetail : CM_ReserveDetail;
	index : Integer;
	iter : Iterator;
	cargoType : CM_CargoType;
	startTi : CM_TrackedItem;

	menuButton : MOB_Button;
	buttonOffset : Integer;
	buttonNumber : Integer;
	buttonWidth : Real;
	tiSet : CM_TISet;
	tiArray : CM_TIArray;
	ti : CM_TrackedItem;
	size : Integer;
	buttonCaption : String;
	visibleButtons : Boolean;
	reason : String;
	buttonHeight : Integer;
	
	ta : CM_TerminalArea;	//21 Jul 2016	NDL	TFS 2408
	
	startTime,finTime: TimeStamp;
	i,j: Integer;
	allTis	: CM_TISet;
begin
	startTime := app.actualTimeServer;
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	if self.selectedCount &gt; 0 then
		foreach buttonNumber in 1 to self.selectedCount do
			menuButton := self.btnSelectTemp.getControl( buttonNumber ).MOB_Button;
			if menuButton &lt;&gt; null then
				menuButton.visible := false;
				delete menuButton;
			endif;
		endforeach;
		self.selectedCount := 0;
		buttonNumber := 0;
	endif;

	if self.cmbRelItems.listCount &lt; 1 then
		if self.myBulkRelease = null then
			//nothing to do but clear the fileds etc.
		else
			self.cmbRelItems.clear();
			if self.myBulkRelease.allReserveDetails.size &gt; 1 then
				foreach reserveDetail in self.myBulkRelease.allReserveDetails do
					index := self.cmbRelItems.addItem( reserveDetail.getDescription );
					self.cmbRelItems.itemObject[index] := reserveDetail;
				endforeach;
			endif;
			if _reserveDetail &lt;&gt; null then
				self.cmbRelItems.listIndex := self.cmbRelItems.findObject( _reserveDetail );
			endif;
		endif;
	endif;
	
	create tiSet transient;
	
	if _reserveDetail &lt;&gt; null then
		_reserveDetail.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
		if _reserveDetail.isKindOf(CM_ReserveTI) then
			//foreach ti in _reserveDetail.allTrackedItems do
			foreach ti in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
			//	if ti.myPrimaryActualLocation = self.myTargetLocation then
				ta := ti.myPrimaryActualLocation.myTerminalArea;	//21 Jul 2016	NDL	TFS 2408
				if ta &lt;&gt; null and ta.isInterchangeArea then	//21 Jul 2016	NDL	TFS 2408
					continue;
				elseif moveMode = QUEUE_MODE then
					if ti.isAlreadyQueuedTo( self.myTargetLocation ) then
						continue;
					endif;
				endif;
				if ti.myPrimaryActualLocation.isVehicle then	//20 Apr 2016	NDL	TFS 1876
					//its aready loaded on the truck
					continue;
				endif;
				tiSet.addNoDuplicates( ti, false );
			endforeach;
		elseif _reserveDetail.isKindOf(CM_ReserveSelection) then
			//foreach ti in _reserveDetail.allTrackedItems do
			foreach ti in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
				//if ti.myPrimaryActualLocation = self.myTargetLocation then
				ta := ti.myPrimaryActualLocation.myTerminalArea;	//21 Jul 2016	NDL	TFS 2408
				if ta &lt;&gt; null and ta.isInterchangeArea then	//21 Jul 2016	NDL	TFS 2408
					continue;
				elseif moveMode = QUEUE_MODE then
					if ti.isAlreadyQueuedTo( self.myTargetLocation ) then
						continue;
					endif;
				endif;
				if ti.myPrimaryActualLocation.isVehicle then	//20 Apr 2016	NDL	TFS 1876
					//its aready loaded on the truck
					continue;
				endif;
				tiSet.addNoDuplicates( ti, false );
			endforeach;
			if tiSet.isEmpty then
				//none actually assigned that aren't already in the staging area
				//so search the rest of the onsite cargo
				cargoType := _reserveDetail.getCargoType;
				if cargoType &lt;&gt; null then
					iter := self.myTerminal.allOnsiteTIsByCargoTypeId.createIterator;
					startTi := self.myTerminal.allOnsiteTIsByCargoTypeId.getAtKeyGeq( cargoType.id, null );
					if startTi &lt;&gt; null and startTi.myCargoType = cargoType then
						iter.startAtObject( startTi );
						while iter.next(ti) do
							if ti.myCargoType &lt;&gt; cargoType then
								break;
							endif;
							if not ti.isOnSite then
								// protect against crap data in DMAST
								continue;
							endif;
							if not ti.testAgainstReserveSelection( _reserveDetail.CM_ReserveSelection, reason, true, null ) then
								continue;
							endif;
							//if ti.myPrimaryActualLocation = self.myTargetLocation then
							ta := ti.myPrimaryActualLocation.myTerminalArea;	//21 Jul 2016	NDL	TFS 2408
							if ta &lt;&gt; null and ta.isInterchangeArea then	//21 Jul 2016	NDL	TFS 2408
								continue;
							elseif moveMode = QUEUE_MODE then
								if ti.isAlreadyQueuedTo( self.myTargetLocation ) then
									continue;
								endif;
							endif;
							if ti.myPrimaryActualLocation.isVehicle then	//20 Apr 2016	NDL	TFS 1876
								if not ti.allBulkReleasesAssigned.isEmpty then
									//apparently assigned and already loaded...
									continue;
								endif;
							endif;
							tiSet.addNoDuplicates( ti, false );
						endwhile;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	
	size := tiSet.size;	
	create tiArray transient;
	self.setSelectableOrder( tiSet, tiArray );
	
	buttonHeight := self.getScrollingButtonHeight();
	self.btnSelectTemp.height := buttonHeight;
	buttonWidth := self.getButtonWidthSetScrollBar( size, self.frmSelectable, self.btnSelectTemp.height, self.scrSelect );

	foreach ti in tiArray do
		
		buttonNumber := buttonNumber + 1;
		menuButton := self.btnSelectTemp.getControl( buttonNumber ).MOB_Button;
		if menuButton = null then
			menuButton := self.btnSelectTemp.loadControl( buttonNumber ).MOB_Button;
		endif;
		menuButton.move(0, buttonOffset, buttonWidth, buttonHeight-4 );
		
		menuButton.userObject := ti;
		if ti.canSplitTotalQuantity and ti.isBulkByQuantity then
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.totalQuantity.String &amp; ")" 
										&amp; CrLf &amp; ti.myPrimaryActualLocation.getFullId;
		elseif ti.isBulkByWeight and ti.isBulkByVolume then
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; "(" &amp; ti.CM_Bulk.getBulkTrackByDisplayForWeight(true) &amp; ")" 
										&amp; CrLf &amp; ti.myPrimaryActualLocation.getFullId;
		else
			menuButton.caption := ti.cargoTypeDescr &amp; " - " &amp; ti.id &amp; CrLf &amp; ti.myPrimaryActualLocation.getFullId;
		endif;
		
		self.addHazDetailsToButton( menuButton, ti, null ); //30 May 2017	NDL	TFS 4587
		
		buttonOffset := buttonOffset + buttonHeight-2;
		menuButton.tabIndex := TAB_INDEX_START + buttonNumber;
		
		visibleButtons := true;
		
	endforeach;
	
	
	self.selectedCount := buttonNumber;
	
	self.btnSelectTemp.visible := false;
	self.frmSelectable.caption := null;
	
	self.lblNoCargoSel.visible := not visibleButtons;

epilog

	delete tiArray;
	delete tiSet;
	delete iter;
	finTime := app.actualTimeServer;
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' finish. '&amp;finTime.differenceAsTime(startTime,i,j).formatAsHHMMSSmmm, LogINFO); 
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="dcbd9b34-db8a-4ac8-990b-f3b9ac381035">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 27 October 2016 09:09:14.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019982, locale);
	btnChosenTemp.translateCaption(Xlat_0019983, locale);
	btnDocActions.translateCaption(Xlat_0021436, locale);
	btnSelectTemp.translateCaption(Xlat_0019984, locale);
	frmChosen.translateCaption(Xlat_0019985, locale);
	frmSelectable.translateCaption(Xlat_0019986, locale);
	lblNoCargoSel.translateCaption(Xlat_0019987, locale);
	lblNoChose.translateCaption(Xlat_0019988, locale);
	lblTotals.translateCaption(Xlat_0019989, locale);
	shtChosen.translateCaption(Xlat_0019990, locale);
	shtSelectable.translateCaption(Xlat_0019991, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtCargoId_change" id="b166334b-eaa5-4d65-bd49-7637b6259fd7">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtCargoId_change(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2014	cnwndl1	Initial creation

*/

vars

begin

	self.convertCargoIdForSearch(	self.txtCargoId.text.toUpper,	//_rawId: String;
									0,	//_cargoType : Integer;
									0,	//_imex : Integer;
									null,	//_voyage : CM_Voyage;
									self.convertedCargoId,	//_convertedCargoId: String output;
									self.convertedAltId	//_convertedAltId: String output
									);
//	self.txtCargoId.text := self.convertedCargoId;
	self.txtCargoId.text := self.convertedAltId;	//08 Aug 2016	NDL	TFS 2567 - Is used for both cargo id and alternate id, don't truncate to 20
	
	self.findCargoInList();

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
</GUIClass>
