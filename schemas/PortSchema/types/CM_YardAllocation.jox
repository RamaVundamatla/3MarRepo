    <JadeMethod name="getCargoSubtype" id="b6d948cf-1ba9-4615-8c3c-e219572d5520">
        <source>getCargoSubtype(): CM_Product;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 March 2021	navndl1	Initial creation	TFS 49912

*/

vars

	criteria : CM_YACriteria;
	
begin

	criteria := self.getCriteriaOfTypeValue(YACriteriaType_Product);
	if criteria &lt;&gt; null then
		return criteria.myYAData.CM_YADataObjects.allObjects.first().CM_Product;			
	endif;

epilog

end;</source>
