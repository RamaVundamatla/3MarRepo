    <JadeMethod name="setupForm" id="833c6d41-32ea-4999-920f-5b2e474261e5">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.doCmbBankBuild();

	inheritMethod();
	///self.setCurrentBank();
	self.myCurrentBank := self.myTerminal.getDefaultCompanyBank();
//	TFS 2682	self.caption := self.myCurrentBank.code &amp; " Invoice Types";
