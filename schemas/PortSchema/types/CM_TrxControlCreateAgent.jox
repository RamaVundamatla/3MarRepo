    <JadeMethod name="trxCreateSnapShotUser" id="649d8037-3979-4144-a039-fbc952be501b">
        <updating/>
        <source>trxCreateSnapShotUser(_pxySnapShot: CM_TISnapShot; _newSnapShot: CM_TISnapShot output; _chgReason: CM_MessageUser; _passport: CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	11 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	// Perform the operation
	
	_newSnapShot := app.myUtilityCA.utlCreateTISnapShot(_pxySnapShot, _passport);
	
	if _newSnapShot &lt;&gt; null then
		app.myUtilityCA.utlCreateUserTISnapShot(_newSnapShot, _chgReason, _passport);
	else
		return;
	endif;
	
	if _passport.noErrors
	and _newSnapShot.myVoyage &lt;&gt; null then
		_newSnapShot.myVoyage.causeEvent(Event_HatchSummary_Update, false, _newSnapShot);
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxySnapShot" type="CM_TISnapShot"/>
        <Parameter name="_newSnapShot" type="CM_TISnapShot" usage="output"/>
        <Parameter name="_chgReason" type="CM_MessageUser"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
