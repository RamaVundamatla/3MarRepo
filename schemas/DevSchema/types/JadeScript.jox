	bol : CM_BOLIn;
	
	log4Count, 
	logNullCount, 
	logNullVoyageCount, 
	logNullVoyageObjectCount, 
	ediLogOutCount, 
	ediBolOutCount, 
	vvrPre2014Count, 
	vvrPre2014DetailCount,
