        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsQueryCargoIdConv" id="e31b3356-aa90-4022-8e22-c76110a09b83">
        <source>wsQueryCargoIdConv():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2016	cnwndl1	Initial creation		TFS 2275 / 2216

*/

vars
	ref : String;
	queryRequest : WS_TrackedItemQueryRequest;
	queryReqService : JMTUserInterfaceService;
	queryResponse : WS_TrackedItemQueryResponse;
	totalFound : Integer;
	
	rawScannedIdArray : StringArray;
	expectdIdArray : StringArray;
	
	rawScannedId : String;
	expectdId : String;
	id : String;
	index : Integer;
	
begin
	
	if app.name &lt;&gt; "JMTUnitTest" and app.name &lt;&gt; "JMTUnitTestRunner" then
		return "Pre-test check: App.name = '" &amp; app.name &amp; "' test will fail...";
	endif;

	create rawScannedIdArray transient;
	create expectdIdArray transient;
	
	rawScannedIdArray.add( "*MMEMC71XXGH031214*" );  //wrapped in asterix(s)
	expectdIdArray.add( "MMEMC71XXGH031214" );
	
	rawScannedIdArray.add( "JTJHY00W6G421386011" );	// added suffix
	expectdIdArray.add( "JTJHY00W6G4213860" );
	
	rawScannedIdArray.add( "I1C3CCCABXGN177954" );	// 'I' prefix
	expectdIdArray.add( "1C3CCCABXGN177954" );
	
	foreach index in 1 to rawScannedIdArray.size do
	
		rawScannedId := rawScannedIdArray[index];
		expectdId := expectdIdArray[index];
	
		//Query trackeditems
		create queryRequest transient;
		queryRequest.setPropertyValue("filterId",rawScannedId);
		queryRequest.maxReturnedItems := 10;
		queryRequest.startFrom := 0;	
		
		create queryReqService transient;
		queryResponse := queryReqService.findCargo(queryRequest);
		if queryResponse = null then
			return "Step 1 test " &amp; index.String &amp; ", queryResponse not returned.";
		endif;
		if queryResponse.hasErrors then
			return "Step 2 test " &amp; index.String &amp; ", " &amp; queryResponse.getErrorsAsStringForTesting;
		endif;
		totalFound := queryResponse.allTrackedItems.size;
		if totalFound &lt; 1 then
			return "Step 3 test " &amp; index.String &amp; ", queryResponse found no items, probably wrong.";
		endif;
		id := queryResponse.allTrackedItems.last.idTextBox;
		if id &lt;&gt; expectdId then
			return "Step 4 test " &amp; index.String &amp; ", queryResponse scanned input was '" &amp; rawScannedId &amp; "', expected to find '" &amp; expectdId &amp; "', but found '" &amp; id &amp; "' probably wrong.";
		endif;
		
		delete queryResponse;
		delete queryRequest;
		delete queryReqService;	
	
	endforeach;
	
	
	
	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsQueryCargoIdConv.name; 

epilog

	delete queryResponse;
	delete queryRequest;
	delete queryReqService;
	
	delete rawScannedIdArray;
	delete expectdIdArray;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsQueryPreNotes" id="6ab25825-154c-41ad-8152-ab1faa1b33de">
        <source>wsQueryPreNotes(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2013	cnwndl1	Initial creation	Par 31506

*/

vars
	ref : String;
	queryRequest : WS_TrackedItemQueryRequest;
	queryReqService : JMTUserInterfaceService;
	queryResponse : WS_TrackedItemQueryResponse;
	totalFound : Integer;
	id : String;

begin

	if app.name &lt;&gt; "JMTUnitTest" and app.name &lt;&gt; "JMTUnitTestRunner" then
		return "Pre-test check: App.name = '" &amp; app.name &amp; "' test will fail...";
	endif;

	//Query trackeditems
	create queryRequest transient;
	queryRequest.setPropertyValue("filterId","UT");
	// just looking for any prenotes that starts with 'UT' anywhere related to terminal 'UT'
	

	queryRequest.maxReturnedItems := 0;
	queryRequest.startFrom := 0;
	
	
	create queryReqService transient;
	queryResponse := queryReqService.findPreNoteCargo(queryRequest);
	if queryResponse = null then
		return "test 1, queryResponse not returned.";
	endif;
	if queryResponse.hasErrors then
		return "test 2, " &amp; queryResponse.getErrorsAsStringForTesting;
	endif;
	if queryResponse.allTrackedItems.isEmpty then
		return "test 3, queryResponse no pre-notes found, probably wrong.";
	endif;
	delete queryResponse;
	
	
	queryRequest.maxReturnedItems := 2;
	queryRequest.startFrom := 0;
	queryResponse := queryReqService.findPreNoteCargo(queryRequest);
	if queryResponse = null then
		return "test 4, queryResponse not returned.";
	endif;
	if queryResponse.hasErrors then
		return "test 5, " &amp; queryResponse.getErrorsAsStringForTesting;
	endif;
	if queryResponse.allTrackedItems.size &lt;&gt; 2 then
		return "test 6, queryResponse requested 2 items, returned " &amp; queryResponse.allTrackedItems.size.String;
	endif;
	id := queryResponse.allTrackedItems.last.idTextBox;
	delete queryResponse;
	
	
	queryRequest.maxReturnedItems := 2;
	queryRequest.startFrom := 2;	// should be the same as the last one of the previous list
	queryResponse := queryReqService.findPreNoteCargo(queryRequest);
	if queryResponse = null then
		return "test 7, queryResponse not returned.";
	endif;
	if queryResponse.hasErrors then
		return "test 8, " &amp; queryResponse.getErrorsAsStringForTesting;
	endif;
	if queryResponse.allTrackedItems.first.idTextBox &lt;&gt; id then
		return "test 9, queryResponse requested 10 items, starting at 2. returned incorrect first object";
	endif;
	delete queryResponse;
	
	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsQueryPreNotes.name; 

epilog

	delete queryResponse;
	delete queryRequest;
	delete queryReqService;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsQueryTrackedItems" id="432982a5-9123-4df8-90db-8e838ce91e9c">
        <source>wsQueryTrackedItems(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2013	cnwndl1	Initial creation	Par 31506

*/

vars
	ref : String;
	queryRequest : WS_TrackedItemQueryRequest;
	queryReqService : JMTUserInterfaceService;
	queryResponse : WS_TrackedItemQueryResponse;
	totalFound : Integer;
	id : String;
	
begin
	
	if app.name &lt;&gt; "JMTUnitTest" and app.name &lt;&gt; "JMTUnitTestRunner" then
		return "Pre-test check: App.name = '" &amp; app.name &amp; "' test will fail...";
	endif;

	//Query trackeditems
	create queryRequest transient;
	queryRequest.setPropertyValue("filterId","UT");
	// just looking for any cargo that starts with 'UT' anywhere related to terminal 'UT'
	
	queryRequest.maxReturnedItems := 50;
	queryRequest.startFrom := 0;	
	
	create queryReqService transient;
	queryResponse := queryReqService.findCargo(queryRequest);
	if queryResponse = null then
		return "test 1, queryResponse not returned.";
	endif;
	if queryResponse.hasErrors then
		return "test 2, " &amp; queryResponse.getErrorsAsStringForTesting;
	endif;
	totalFound := queryResponse.allTrackedItems.size;
	if totalFound &lt; 100 then
	//	return "test 3, queryResponse found less than 100 items, probably wrong.";
	endif;
	delete queryResponse;	
	
	queryRequest.maxReturnedItems := 10;
	queryRequest.startFrom := 0;
	queryResponse := queryReqService.findCargo(queryRequest);
	if queryResponse = null then
		return "test 4, queryResponse not returned.";
	endif;
	if queryResponse.hasErrors then
		return "test 5, " &amp; queryResponse.getErrorsAsStringForTesting;
	endif;
	if queryResponse.allTrackedItems.size &lt;&gt; 10 then
		return "test 6, queryResponse requested 10 items, returned " &amp; queryResponse.allTrackedItems.size.String;
	endif;
	id := queryResponse.allTrackedItems.last.idTextBox;
	delete queryResponse;
	
	
	queryRequest.maxReturnedItems := 10;
	queryRequest.startFrom := 10;	// should be the same as the last one of the previous list
	queryResponse := queryReqService.findCargo(queryRequest);
	if queryResponse = null then
		return "test 7, queryResponse not returned.";
	endif;
	if queryResponse.hasErrors then
		return "test 8, " &amp; queryResponse.getErrorsAsStringForTesting;
	endif;
	if queryResponse.allTrackedItems.first.idTextBox &lt;&gt; id then
		return "test 9, queryResponse requested 10 items, starting at 10. returned incorrect first object";
	endif;
	delete queryResponse;
	
	//26 Feb 2020	TFS 48700 - 1035 error when no items found in teh first multi item search.
	queryRequest.maxReturnedItems := 10;
	queryRequest.startFrom := 0;
	queryRequest.setPropertyValue("filterId","ABCDEFGH,IJKLMNOP,QRSTUVWX,YZABCDEF,GHIJKLMN,OPQRSTUV,WXYZABCD");
	queryResponse := queryReqService.findCargo(queryRequest);
	if queryResponse = null then
		return "test 10, queryResponse not returned.";
	endif;
	if queryResponse.hasErrors then
		return "test 11, " &amp; queryResponse.getErrorsAsStringForTesting;
	endif;
	if not queryResponse.allTrackedItems.isEmpty then
		return "test 12, queryResponse should not have found items, returned " &amp; queryResponse.allTrackedItems.size.String;
	endif;
	delete queryResponse;
	
	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsQueryTrackedItems.name; 

epilog

	delete queryResponse;
	delete queryRequest;
	delete queryReqService;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsQueryTrackedItemsQuickView" id="5b5082ef-da53-48ba-b231-f68a03838929">
        <source>wsQueryTrackedItemsQuickView(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2013	cnwndl1	Initial creation	Par 31506

*/

vars
	ref : String;
	ti : CM_TrackedItem;
	id : String;
	cargoTypeInt : Integer;
	queryRequest : WS_TrackedItemQueryRequest;
	queryReqService : JMTUserInterfaceService;
	queryResponse : WS_TrackedItemQueryResponse;
	totalFound : Integer;
	wsTrackedItem : WS_TrackedItem;
	foundAltId : Boolean;
	iter : Iterator;
	allTIs : CM_TIByTimeStampDict;
	
begin

	if app.name &lt;&gt; "JMTUnitTest" and app.name &lt;&gt; "JMTUnitTestRunner" then
		return "Pre-test check: App.name = '" &amp; app.name &amp; "' test will fail...";
	endif;
	
	// cnwmc5 - Find the first OnSite container that matches the default Cargo Quick Find criteria.
	create allTIs transient;
	iter := self.myTerminal.allOnsiteTIsByIdCargoType.createIterator;
	while iter.next(ti) do
		self.myTerminal.allOnsiteTIsByIdCargoType.lookupByIDExactMatch(ti.id, TI_CargoType_Container, app.myPassport, false, false, allTIs);
		if not allTIs.isEmpty then
			break;
		endif;
	endwhile;
	//ti :=  self.myTerminal.allOnsiteTIsByIdCargoType.last;
	
	if ti &lt;&gt; null then
		id := ti.id;
	else
		return "test 1, No onsite cargo found,..";
	endif;
	
	cargoTypeInt := ti.cargoType;

	//Query trackeditems
	create queryRequest transient;
	queryRequest.setPropertyValue("filterId",id);	 //Quick view looks for an exact match only...
	queryRequest.setPropertyValue("filterSite",TI_SITE_ONSITE.String);
	queryRequest.setPropertyValue("filterTiType",cargoTypeInt.String);
	// anywhere onsite in terminal 'UT'
	
	
	queryRequest.maxReturnedItems := 0;
	queryRequest.startFrom := 0;

	
	create queryReqService transient;
	queryResponse := queryReqService.findCargoQuickView(queryRequest);
	if queryResponse = null then
		return "test 2, queryResponse not returned.";
	endif;
	if queryResponse.hasErrors then
		return "test 3, " &amp; queryResponse.getErrorsAsStringForTesting;
	endif;
	totalFound := queryResponse.allTrackedItems.size;
	if totalFound &gt; 5 then
		return "test 4, queryResponse found more than 5 items, probably wrong.";
	endif;
	delete queryResponse;
	
	
	queryRequest.maxReturnedItems := 2;
	queryRequest.startFrom := 0;
	queryResponse := queryReqService.findCargoQuickView(queryRequest);
	if queryResponse = null then
		return "test 5, queryResponse not returned.";
	endif;
	if queryResponse.allTrackedItems.size &gt; 2 then
		return "test 6, queryResponse requested max 2 items, returned " &amp; queryResponse.allTrackedItems.size.String;
	endif;
	if queryResponse.hasErrors then
		return "test 7, " &amp; queryResponse.getErrorsAsStringForTesting;
	endif;
//	if queryResponse.allTrackedItems.first.idTextBox &lt;&gt; id then
	if not queryResponse.allTrackedItems.includesId( ti.id ) then
		return "test 8, queryResponse failed to return the correct cargo item. Wanted '" &amp; id &amp; "', found '" &amp; queryResponse.allTrackedItems.first.idTextBox &amp; "'";
	endif;
	delete queryResponse;
	
	
	ti :=  self.myTerminal.allOnsiteTIsByAlternativeId.last;
	if ti = null then
		return "test 9, queryResponse unable to check alternative id, alt id collection empty.";
	else
		id := ti.alternativeId;
		cargoTypeInt := ti.cargoType;
		queryRequest.setPropertyValue("filterId",id);
		queryRequest.setPropertyValue("filterTiType",cargoTypeInt.String);
		
		queryRequest.maxReturnedItems := 0;
		queryRequest.startFrom := 0;
		
		queryResponse := queryReqService.findCargoQuickView(queryRequest);
		if queryResponse = null then
			return "test 10, queryResponse not returned.";
		endif;
		if queryResponse.hasErrors then
			return "test 11, " &amp; queryResponse.getErrorsAsStringForTesting;
		endif;
		if queryResponse.allTrackedItems.isEmpty then
			return "test 12, queryResponse quick search by alternative id search failed to find anything";
		endif;
		
		foreach wsTrackedItem in queryResponse.allTrackedItems do
			foundAltId := ( wsTrackedItem.alternativeId = id );
			if foundAltId then
				break;
			endif;
		endforeach;
		if not foundAltId then
			return "test 13, queryResponse quick search by alternative id search failed to find matching altid";
		endif;
		delete queryResponse;
	endif;
	
	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsQueryTrackedItemsQuickView.name; 

epilog

	delete queryResponse;
	delete queryRequest;
	delete queryReqService;
	delete iter;
	delete allTIs;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsQueryVehicleBookings" id="60814968-b600-4262-97f4-c3e6a9e88f54">
        <source>wsQueryVehicleBookings(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2013	cnwndl1	Initial creation	Par 31393
07 Jun 2020 cnwma1  ChangeRequest 49570: Web Portal - VBS - Add / Search / Edit Vehicle Bookings UI changes
*/
constants

	// These are teh same as are used in JMTUnitTest UT_VehicleScheduling::tBaseSetup
	CarrierId : String = "UTVSS";
	VehicleId : String = "UTVSS";
	DriverID : String = "UTVS";
	
vars
	ref : String;
	queryRequest : WS_VehicleBookingTimesRequest;
	queryReqService : JMTUserInterfaceService;
	queryResponse : WS_VehicleBookingTimesResponse;
	carrier : CM_Carrier;
	driver : CM_DriverDetails;
	vehicle : CM_Vehicle;
	
	queryCount : Integer;
	
	firstWSTimeslot : WS_VehicleBookingTimeslot;
	realVBTimeslot : CM_VehicleBookingTimeSlot;
	errString : String;

begin

	if app.name &lt;&gt; "JMTUnitTest" and app.name &lt;&gt; "JMTUnitTestRunner" then
		return "Pre-test check: App.name = '" &amp; app.name &amp; "' test will fail...";
	endif;

	beginTransaction;
	app.setPropertyValue("isVehicleBookingEnabled",true);
	myTerminal.setConfig(VsUseVehicleScheduling,true);
	commitTransaction;
	
	carrier := app.myRoot.allCarriers[CarrierId];
	if carrier = null then
		return "Set up, carrier not found. [" &amp; CarrierId &amp; "]";
	endif;
	driver := myTerminal.allDriversByCode[DriverID];
	if driver = null then
		return "Set up, driver not found. [" &amp; DriverID &amp; "]";
	endif;
	vehicle := myTerminal.vehicles[VehicleId, ""];
	if vehicle = null then
		return "Set up, vehicle not found. [" &amp; VehicleId &amp; "]";
	endif;

	//Query Booked and unbooked time slots available for carrier
	create queryRequest transient;
	queryRequest.setPropertyValue( "carrierFilter", carrier.getOidAsString );
	queryRequest.setPropertyValue( "includeUnBooked", true );
	
	
	queryRequest.maxReturnedItems := 0;
	//queryRequest.startFrom := 0;        //01.07.2020 cnwma1 #49570
	
	
	create queryReqService transient;
	queryResponse := queryReqService.findVehicleBookingTimeSlots(queryRequest);
	if queryResponse = null then
		return "test 1, queryResponse not returned.";
	endif;
	if queryResponse.hasErrors then
		return "test 2, " &amp; queryResponse.getErrorsAsStringForTesting;
	endif;
	if queryResponse.allVehicleBookingTimeSlots.isEmpty then
		return "test 3, queryResponse no booking times found, probably wrong.";
	endif;
	delete queryResponse;
	
	
	queryRequest.maxReturnedItems := 10;
	//queryRequest.startFrom := 0;        //01.07.2020 cnwma1 #49570
	queryResponse := queryReqService.findVehicleBookingTimeSlots(queryRequest);
	if queryResponse = null then
		return "test 4, queryResponse not returned.";
	endif;
	if queryResponse.hasErrors then
		return "test 5, " &amp; queryResponse.getErrorsAsStringForTesting;
	endif;
	if queryResponse.allVehicleBookingTimeSlots.size &lt;&gt; 10 then
		return "test 6, queryResponse requested 10 items, returned " &amp; queryResponse.allVehicleBookingTimeSlots.size.String;
	endif;
	delete queryResponse;
	
		
	queryRequest.setPropertyValue( "driverFilter", driver.getOidAsString );
	queryRequest.setPropertyValue( "vehicleFilter", vehicle.getOidAsString );
	queryRequest.setPropertyValue( "includeUnBooked", false );
	
	queryRequest.maxReturnedItems := 0;
	//queryRequest.startFrom := 0;        //01.07.2020 cnwma1 #49570
	queryResponse := queryReqService.findVehicleBookingTimeSlots(queryRequest);
	if queryResponse = null then
		return "test 7, queryResponse not returned.";
	endif;
	if queryResponse.hasErrors then
		return "test 8, " &amp; queryResponse.getErrorsAsStringForTesting;
	endif;
	if queryResponse.allVehicleBookingTimeSlots.isEmpty then
		return "test 9, queryResponse found no items matching Carrier, Driver &amp; Vehicle possibly wrong or may need to run 'UT_VehicleScheduling.tBaseSetup'";
	endif;
	firstWSTimeslot := queryResponse.allVehicleBookingTimeSlots.first;
	realVBTimeslot := firstWSTimeslot.cmObjectId.asOid.CM_VehicleBookingTimeSlot;
	queryCount := queryResponse.allVehicleBookingTimeSlots.size;
	delete queryResponse;
	
	//now clear the carrier by updating the booking
	errString := self.clearVehicleBooking( realVBTimeslot );
	if errString &lt;&gt; null then
		return "test 10, " &amp; errString;
	endif;
	
	//now call the exact same query and check the booking is no longer returned
	queryResponse := queryReqService.findVehicleBookingTimeSlots(queryRequest);
	if queryResponse = null then
		return "test 11, queryResponse not returned.";
	endif;
	if queryResponse.hasErrors then
		return "test 12, " &amp; queryResponse.getErrorsAsStringForTesting;
	endif;
	if queryResponse.allVehicleBookingTimeSlots.size = queryCount then
		return "test 13, queryResponse found same number of items! Should not be returning the updated (now unbooked) timeslot'";
	endif;
	delete queryResponse;
	
	return null;
	
	// Not used,just to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsQueryVehicleBookings.name;

epilog

	myTerminal.setConfig(VsUseVehicleScheduling,true);

	delete queryResponse;
	delete queryRequest;
	delete queryReqService;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsRESTAuthLogin" id="6632525a-9faa-4600-a3b1-ffefdbffba1d">
        <source>wsRESTAuthLogin(_jsonPayload: String; _expectFailure: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
13 April 2022	navmd1	Initial creation TFS 53378 REST Refactor

*/

vars
	ref 				: String;
	webService			: MasterTerminalAPIService;
	request				: WS_RESTLoginAuthRequest;
	parser				: JadeJson;
	transientJSONObjs	: ObjectArray;
	response			: WS_InterfaceObject;
	
	terminal			: CM_Terminal;
	accessTokenSecret	: String;
	refreshTokenSecret	: String;
	jwtErrors			: String;
begin
	create webService transient;
	
	create parser transient;
	create transientJSONObjs transient;
	request := parser.parse(_jsonPayload, WS_RESTLoginAuthRequest, transientJSONObjs).WS_RESTLoginAuthRequest;
	
	// Is it worth asserting the JSON reuqest object here ?
	// All we'd really be doing is checking JADEs json parsing works - so probably not.
	
	// call POST /login
	webService.setPropertyValue(WS_RestWebServiceProvider::requestPath.name, "/login");
	response := webService.postLogin(request);
	
	// If we're expecting to fail, then return early
	if _expectFailure then
		if webService.httpStatusCode = HttpResponseOK then
			return "Failure expected, got 200 OK";
		endif;
		
		return response.WS_Response.allErrors.first.text;
	endif;
	
	if webService.httpStatusCode &lt;&gt; HttpResponseOK then
		return method.qualifiedName &amp; " Bad Response Code, expecting 200 OK, got " &amp; webService.httpStatusCode.String &amp; ". Check UnitTest runner logs for more details";
	endif;
	
	// Make sure the tokens returned are valid
	terminal := app.myRoot.allTerminals[request.scope.facilityId];
	accessTokenSecret := terminal.getConfig(JWTAccessKey).String;
	if not JadeJWTValidator@validateSymmetricToken(response.WS_NAuthTokenResponse.accessToken, accessTokenSecret, jwtErrors) then
		return method.qualifiedName &amp; " Invalid Access Token. " &amp; jwtErrors;
	endif;
	
	refreshTokenSecret := terminal.getConfig(JWTRefreshKey).String;
	if not JadeJWTValidator@validateSymmetricToken(response.WS_NAuthTokenResponse.refreshToken, refreshTokenSecret, jwtErrors) then
		return method.qualifiedName &amp; " Invalid Refresh Token. " &amp; jwtErrors;
	endif;
	
	if response.WS_NAuthTokenResponse.expiresIn &lt;&gt; 15 * 60 then
		return method.qualifiedName &amp; " Invalid Refresh Time. Expected 15 minutes, got " &amp; (response.WS_NAuthTokenResponse.expiresIn / 60).Integer.String;
	endif;
	
	return null;
	
	// Not used,just here to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsRESTAuthLogin.name; 

epilog
	delete webService;
	delete request;
	delete parser;
	
	transientJSONObjs.purge();
	delete transientJSONObjs;
	
	delete response;
end;</source>
        <Parameter name="_jsonPayload" type="String"/>
        <Parameter name="_expectFailure" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsRESTAuthLogout" id="cf4b6f09-a569-458c-acd5-c44c17ce3eb0">
        <source>wsRESTAuthLogout(_accessToken: String; _expectFailure: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
13 April 2022	navmd1	Initial creation TFS 53378 REST Refactor

*/

vars
	ref 				: String;
	webService			: MasterTerminalAPIService;
	response			: WS_InterfaceObject;
	
	terminal			: CM_Terminal;
	accessTokenSecret	: String;
	refreshTokenSecret	: String;
	jwtErrors			: String;
begin
	create webService transient;
	
	// call GET /logout
	webService.setPropertyValue(WS_RestWebServiceProvider::requestPath.name, "/logout");
	if _accessToken &lt;&gt; null then
		webService.unitTestData.addAssoc("HTTP_AUTHORIZATION", "Bearer " &amp; _accessToken.String);
	endif;
	response := webService.getLogout();
	
	// If we're expecting to fail, then return early
	if _expectFailure then
		if webService.httpStatusCode = HttpResponseOK then
			return "Failure expected, got 200 OK";
		endif;
		
		return response.WS_Response.allErrors.first.text;
	endif;
	
	if webService.httpStatusCode &lt;&gt; HttpResponseOK then
		return method.qualifiedName &amp; " Bad Response Code, expecting 200 OK, got " &amp; webService.httpStatusCode.String &amp; ". Check UnitTest runner logs for more details";
	endif;
	
	return null;
	
	// Not used,just here to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsRESTAuthRefresh.name; 

epilog
	delete webService;	
	delete response;
end;</source>
        <Parameter name="_accessToken" type="String"/>
        <Parameter name="_expectFailure" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsRESTAuthRefresh" id="060a84d6-b6dd-4998-b56d-ba4687fcab6c">
        <source>wsRESTAuthRefresh(_refreshToken: String; _terminalCode: String; _expectFailure: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
13 April 2022	navmd1	Initial creation TFS 53378 REST Refactor

*/

vars
	ref 				: String;
	webService			: MasterTerminalAPIService;
	response			: WS_InterfaceObject;
	
	terminal			: CM_Terminal;
	accessTokenSecret	: String;
	refreshTokenSecret	: String;
	jwtErrors			: String;
begin
	create webService transient;
	
	// call GET /refresh
	webService.setPropertyValue(WS_RestWebServiceProvider::requestPath.name, "/refresh");
	if _refreshToken &lt;&gt; null then
		webService.unitTestData.addAssoc("HTTP_AUTHORIZATION", "Bearer " &amp; _refreshToken.String);
	endif;
	response := webService.getRefresh();
	
	// If we're expecting to fail, then return early
	if _expectFailure then
		if webService.httpStatusCode = HttpResponseOK then
			return "Failure expected, got 200 OK";
		endif;
		
		return response.WS_Response.allErrors.first.text;
	endif;
	
	if webService.httpStatusCode &lt;&gt; HttpResponseOK then
		return method.qualifiedName &amp; " Bad Response Code, expecting 200 OK, got " &amp; webService.httpStatusCode.String &amp; ". Check UnitTest runner logs for more details";
	endif;
	
	// Make sure the tokens returned are valid
	terminal := app.myRoot.allTerminals[_terminalCode];
	accessTokenSecret := terminal.getConfig(JWTAccessKey).String;
	if not JadeJWTValidator@validateSymmetricToken(response.WS_NAuthTokenResponse.accessToken, accessTokenSecret, jwtErrors) then
		return method.qualifiedName &amp; " Invalid Access Token. " &amp; jwtErrors;
	endif;
	
	refreshTokenSecret := terminal.getConfig(JWTRefreshKey).String;
	if not JadeJWTValidator@validateSymmetricToken(response.WS_NAuthTokenResponse.refreshToken, refreshTokenSecret, jwtErrors) then
		return method.qualifiedName &amp; " Invalid Refresh Token. " &amp; jwtErrors;
	endif;
	
	if response.WS_NAuthTokenResponse.expiresIn &lt;&gt; 15 * 60 then
		return method.qualifiedName &amp; " Invalid Refresh Time. Expected 15 minutes, got " &amp; (response.WS_NAuthTokenResponse.expiresIn / 60).Integer.String;
	endif;
	
	return null;
	
	// Not used,just here to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsRESTAuthRefresh.name; 

epilog
	delete webService;	
	delete response;
end;</source>
        <Parameter name="_refreshToken" type="String"/>
        <Parameter name="_terminalCode" type="String"/>
        <Parameter name="_expectFailure" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsRESTDeleteCargo" id="930b64f7-9d68-4756-884d-4cb3979690dc">
        <source>wsRESTDeleteCargo(_loginString: String; _pathParamString: String; _queryParamString: String; _expectFailure: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 April 2024	navhn30	Initial creation

*/

vars
	request 			: WS_RestCargoParentObject;
	requestLogin		: WS_RESTLoginAuthRequest;
	webService			: MasterTerminalAPIService;
	parser				: JadeJson;
	transientJSONObjs	: ObjectArray;
	response 			: WS_Response;
	ref 				: String;
	cargoType,
	cargoId,
	state				: String;
	pos					: Integer;
	dict 				: WS_QueryStringParamDict;
	jsonHelper 			: JMTJadeJson;
begin
	create webService transient;
	create transientJSONObjs transient;
	create parser transient;
	
	// Login Request
	self.loginREST(webService);
	webService.qsData.parseNameValuePair(_queryParamString);

	// set up the WS_Request object
	webService.setPropertyValue(WS_RestWebServiceProvider::requestPath.name, "/cargo");
	pos := 2;											
	_pathParamString.scanUntil('/', pos);				
	pos += 1;											
	cargoId := _pathParamString.scanUntil('/', pos);	
	pos += 1;											
	cargoType := _pathParamString.scanUntil('/', pos);	
	pos += 1;	
	state := _pathParamString.scanUntil('?', pos);

	response := webService.deleteCargo(cargoId, cargoType, state.Integer);
	
	// If we're expecting to fail, then return early
	if _expectFailure then
		if webService.httpStatusCode = HttpResponseOK then
			return "Failure expected, got 200 OK";
		endif;
		return response.WS_Response.allErrors.first.text;
	endif;
	
	if webService.httpStatusCode &lt;&gt; HttpResponseOK then
		if response.allErrors.size &gt; 0 then
			app.writeLog(response.allErrors.first.text, LogERROR);
		endif;
		return method.qualifiedName &amp; " Bad Response Code, expecting 200 OK, got " &amp; webService.httpStatusCode.String &amp; ". Check UnitTest runner logs for more details" &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	endif;
	
	return null;
	
	// Not used,just here to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsRESTDeleteCargo.name;

epilog
	if webService.objectsToBeDeleted.isNotEmpty then
		webService.objectsToBeDeleted.purge;
	endif;
	dict := webService.qsData;
	dict.purge();
	delete webService;
	delete parser;
	delete requestLogin;
	delete request;
	transientJSONObjs.purge();
	delete transientJSONObjs;
end;</source>
