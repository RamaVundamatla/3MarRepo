    <JadeMethod name="utlDeleteYardActivity" id="f5659aa5-3c1d-4f1f-8719-7941be842452">
        <source>utlDeleteYardActivity( pYardActivity : CM_YardActivity io; _passport : CM_Passport input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	information : StringArray512;
	info : CM_Information;
	invalid : Boolean;

begin

	self.initialiseActivity();

	app.setContinueCMExceptions(false);

	if pYardActivity.myTrackedItem &lt;&gt; null then
	
		on Exception do app.handleDeletedObject( exception, pYardActivity.myTrackedItem, invalid );
		
		create information transient;
		information.addTruncated(pYardActivity.getTypeString &amp; " - Deleted Manually");
		information.addTruncated("Reefer = " &amp; pYardActivity.myTrackedItem.id);
		
		info := pYardActivity.myTrackedItem.createInfomationTransaction( "Reefer Job - Deleted Manually", information, null, app.myPassport );
		
	endif;

	if _passport.noErrors then
		pYardActivity.erase(NORMAL_ERASE);
	endif;

epilog
	
	delete information;

end;</source>
        <Parameter name="pYardActivity" type="CM_YardActivity" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteYardAllocation" id="311b6bb6-1dd6-48db-b104-d9583a70e676">
        <source>utlDeleteYardAllocation(pYardAllocationObj:CM_YardAllocation io; _passport : CM_Passport input);
// --------------------------------------------------------------------------------
// Created:		27 April 2005 by cnwdad1
//
// Purpose:		Deletes a Yard Allocation.
//
// Parameters:	pYardAllocationObj - A reference to the Yard Allocation to delete.
//				_passport - A reference to the user's "passport" object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 10/03/2012	navdap1		TFS 50889 PRP Yard Allcoation Performance Improvement
// --------------------------------------------------------------------------------
vars
	aTA : CM_TerminalArea;
	tmpTerm : CM_Terminal;
	crit : CM_YACriteria;				// TFS 50889
	markValue : CM_YADataString;		// TFS 50889
	marks : StringArray512;				// TFS 50889
	mark : String;						// TFS 50889
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	app.myValDA.valYardAllocation(pYardAllocationObj);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		if not pYardAllocationObj.isYATemplate() then
			self.myDeleteAuditAgent.audDeleteGeneric(pYardAllocationObj);
			// ### NOTES
			tmpTerm := pYardAllocationObj.myTerminal;
			if tmpTerm &lt;&gt; null then
				tmpTerm.causeEvent(tmpTerm.getTerminalEvent(Event_YardAllocationDelete),false,pYardAllocationObj);
				
				foreach aTA in pYardAllocationObj.allTerminalAreas do
					aTA.causeEvent(tmpTerm.getTerminalEvent(EVENT_REFRESH_GRID_AREA),false,null);
				endforeach;
				
				// TFS 50889 remove this yard alloction from the Mark collection if required
				foreach crit in pYardAllocationObj.allCriteria where crit.code = pYardAllocationObj.CRITERIA_MARK do
					markValue := crit.myYAData.CM_YADataString;
					create marks transient;
					markValue.value.getTokensForDelimiter(Comma, marks);
					foreach mark in marks do
						mark := mark.trimBlanks[1:100];
						if tmpTerm.allYAsByMark[mark, pYardAllocationObj.code] &lt;&gt; null then
							tmpTerm.allYAsByMark.removeKeyEntry(mark, pYardAllocationObj.code, pYardAllocationObj);
						endif;
					endforeach;
					break;
				endforeach;
				// TFS 50889 end
			else
				// Must be for a group. Tell all terminals.
				foreach tmpTerm in CM_Terminal.instances do
					tmpTerm.causeEvent(tmpTerm.getTerminalEvent(Event_YardAllocationDelete),false,pYardAllocationObj);
				endforeach;
			endif;
		endif;
		pYardAllocationObj.erase(NORMAL_ERASE);
	endif;
epilog
	delete marks;			// TFS 50889
end;</source>
        <Parameter name="pYardAllocationObj" type="CM_YardAllocation" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
