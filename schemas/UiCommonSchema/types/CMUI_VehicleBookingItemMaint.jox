    <JadeMethod name="setProxyVBSItem" id="12c24474-5e6a-4968-a781-bf70f3e17b60">
        <updating/>
        <source>setProxyVBSItem(_proxy : CM_VehicleBookingTimeSlotItem) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 July 2022	navcs2	Initial creation

*/

vars

begin
	myPxyVehicleBookTimeSlotItem := _proxy;
epilog

end;</source>
        <Parameter name="_proxy" type="CM_VehicleBookingTimeSlotItem"/>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="7e07a77d-9113-4b60-be1e-6f1dc13edc3f">
        <updating/>
        <source>setTableDataFromOrganiser(table: CM_DataTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
04 May 2023 navhl20	ChangeRequest 57402:[57471] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 03]

*/

vars
	bulkRelease 	: CM_BulkRelease;
	bookingRef		: CM_BookingRef;
	ti				: CM_TrackedItem;
	currentObject 	: Object;
begin
	self.saveXMLStrForTblColumns(table);
	
	if self.optBtnRR.value then
		currentObject := self.cmbReleaseReq.getCurrentItemObject;
	elseif self.optBtnBooking.value then
		currentObject := self.cmbBooking.getCurrentItemObject;
	elseif self.optBtnCargo.value then
		currentObject := self.myTrackedItem;
	endif;
	
	if currentObject = null then
		return;
	endif;
	
	if currentObject.isKindOf(CM_BulkRelease) then
		bulkRelease := currentObject.CM_BulkRelease;
	elseif currentObject.isKindOf(CM_BookingRef) then
		bookingRef := currentObject.CM_BookingRef;
	else
		ti := currentObject.CM_TrackedItem;
	endif;
	
	if self.cmbReleaseReq.listObject &lt;&gt; null then																				//03.5.2023 navhl20 #57402[57471]
		self.loadItemTable(bulkRelease);
	elseif bookingRef &lt;&gt; null then
		self.loadItemTable(bookingRef);
	else
		self.loadItemTable(ti);
	endif;
epilog

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTblMaxWeight" id="2891eaeb-e171-48e5-9a13-e92893dbfc31">
        <source>setTblMaxWeight(_reserveDetail : CM_ReserveDetail) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
11 July 2024	navpw1	Initial creation TFS: 61525 (61527)

*/

vars
	bookingTimeSlotItem	: CM_VehicleBookingTimeSlotItem;
	
begin
	bookingTimeSlotItem := self.myPxyVehicleBookTimeSlotItem;
	
	self.tblMaxWeight.visible := false;
	self.tblMaxWeight.setup(Type_Weight, self.backColor);
	
	if _reserveDetail = null or _reserveDetail.myReserveHeader = null then
		return;
	endif;
	
	if not _reserveDetail.isReserveSelection then
		return;
	endif;
	
	if not _reserveDetail.myReserveHeader.releaseByType then
		return;
	endif;
	
	if bookingTimeSlotItem &lt;&gt; null and 
		bookingTimeSlotItem.maxWeight &lt;&gt; null and
		_reserveDetail = bookingTimeSlotItem.myReserveDetails and
		_reserveDetail.isReserveSelection and _reserveDetail.myReserveHeader.releaseByType
	then
		self.tblMaxWeight.visible := true;
		self.lblMaxWeight.visible := true;
		self.tblMaxWeight.setValue(bookingTimeSlotItem.maxWeight);
		return;
		
	endif;
	
	//New item defaults
	self.tblMaxWeight.visible := true;
	self.lblMaxWeight.visible := true;
	self.tblMaxWeight.setValueDefault("0");
	
end;</source>
        <access>protected</access>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="setTblWeight" id="6ff96111-cb62-45a2-b66a-9783b35a0354">
        <source>setTblWeight();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
01 September 2022	navcs2	53899 EUP - SD - VBS MTN - [3] - Maintaining VBS Slot
23 Dec 2022			navak20 Task 55979: EUP - VBS MTN - [3] - Maintaining VBS Slot - Review Changes
24 Apr 2023			navhl20	ChangeRequest 57716:[57718] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 01]
03 May 2023			navhl20	ChangeRequest 57402:[57471] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 03]
16 May 2023			navhl20	Defect 58027:[58028] MTN - Quantity field is missing on the Edit mode of the booking slot item.
02 June 2023		navpw1	TFS: 58256 - Added volume to vehicle booking time slot item

*/

vars
	trackedItem			: CM_TrackedItem;
	bookingTimeSlotItem	: CM_VehicleBookingTimeSlotItem;		// 23.12.2022 navak20 TFS 55979
	ti					: CM_TrackedItem;
	
begin
	bookingTimeSlotItem := self.myPxyVehicleBookTimeSlotItem;	// 23.12.2022 navak20 TFS 55979
	
	self.tblWeight.visible := false;
	self.txtQuantity.visible := false;
	self.lblQuantity.visible := false;
	self.lblWeight.visible := false;
	self.lblVolume.visible := false;	// ### TFS 58256 02Jun2023 NAVPW1
	self.tblVolume.visible := false;	// ### TFS 58256 02Jun2023 NAVPW1

	if self.cmbReserveDetail.listObject &lt;&gt; null then					 		//04.5.2023 navhl20 #57402[57471]
		self.setupQuantity(self.cmbReserveDetail.listObject);
	elseif self.cmbCargo.listObject &lt;&gt; null then
		self.setupQuantity(self.cmbCargo.listObject);
	elseif self.cmbCargo.text &lt;&gt; null and bookingTimeSlotItem.myBookingItem &lt;&gt; null then										//16.5.2023 navhl20	#58027[58028]
		foreach ti in bookingTimeSlotItem.myBookingItem.allTIs do
			if ti.id = self.cmbCargo.text then
				self.setupQuantity(ti);
			endif;
		endforeach;
	elseif self.myTrackedItem &lt;&gt; null and self.optBtnCargo.value then
		self.setupQuantity(self.myTrackedItem);
	endif;
	
	//if self.myPxyVehicleBookTimeSlotItem &lt;&gt; null and self.myPxyVehicleBookTimeSlotItem.weight &lt;&gt; null then	// 23.12.2022 navak20 TFS 55979
	if bookingTimeSlotItem &lt;&gt; null and bookingTimeSlotItem.weight &lt;&gt; null and	// 23.12.2022 navak20 TFS 55979
		self.cmbReserveDetail.listObject.CM_ReserveDetail = bookingTimeSlotItem.myReserveDetails and									//04.5.2023 navhl20 #57402[57471]
		self.myTrackedItem = bookingTimeSlotItem.myTrackedItem and																		//04.5.2023 navhl20 #57402[57471]
		self.cmbCargo.listObject.CM_TrackedItem = bookingTimeSlotItem.myTrackedItem	then												//04.5.2023 navhl20 #57402[57471]
		self.tblWeight.setValue(bookingTimeSlotItem.weight);
	endif;
	
	// ### TFS 58256 02Jun2023 NAVPW1
	if bookingTimeSlotItem &lt;&gt; null and 
		bookingTimeSlotItem.volume &lt;&gt; null and
		self.cmbReserveDetail.listObject.CM_ReserveDetail = bookingTimeSlotItem.myReserveDetails and
		self.myTrackedItem = bookingTimeSlotItem.myTrackedItem and
		self.cmbCargo.listObject.CM_TrackedItem = bookingTimeSlotItem.myTrackedItem	
	then
		if bookingTimeSlotItem.myTrackedItem &lt;&gt; null then
			self.tblVolume.setupFromCargoType(bookingTimeSlotItem.myTrackedItem.myCargoType, bookingTimeSlotItem.myTrackedItem.myProduct, self.backColor);
		endif;
		self.tblVolume.setValue(bookingTimeSlotItem.volume);
	endif;
	// ### TFS 58256 02Jun2023 NAVPW1
	
	//if self.myPxyVehicleBookTimeSlotItem &lt;&gt; null and self.myPxyVehicleBookTimeSlotItem.quantity &lt;&gt; null then	// 23.12.2022 navak20 TFS 55979
	if bookingTimeSlotItem &lt;&gt; null and bookingTimeSlotItem.quantity &lt;&gt; null and 	// 23.12.2022 navak20 TFS 55979
		self.cmbReserveDetail.listObject.CM_ReserveDetail = bookingTimeSlotItem.myReserveDetails and									//04.5.2023 navhl20 #57402[57471]
		self.myTrackedItem = bookingTimeSlotItem.myTrackedItem and																		//04.5.2023 navhl20 #57402[57471]
		self.cmbCargo.listObject.CM_TrackedItem = bookingTimeSlotItem.myTrackedItem	then												//04.5.2023 navhl20 #57402[57471]
		//self.txtQuantity.text := self.myPxyVehicleBookTimeSlotItem.quantity.String;		// 23.12.2022 navak20 TFS 55979
		self.txtQuantity.text := bookingTimeSlotItem.quantity.String;	// 23.12.2022 navak20 TFS 55979
	endif;
	
epilog
	self.tblWeight.setup(Type_Weight, self.backColor);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="355bf984-c8f5-4091-8318-2376b5cd6ef8">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
11 Jul 2022		navcs2	ChangeRequest 53899: EUP - VBS MTN - [3] - Maintaining VBS Slot
26 Dec 2022		navak20 Task 55979: EUP - VBS MTN - [3] - Maintaining VBS Slot - Review Changes
24 Apr 2023		navhl20	ChangeRequest 57716:[57718] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 01]
03 May 2023		navhl20	ChangeRequest 57402:[57471] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 03]
02 June 2023	navpw1	TFS: 58256 - Added volume to vehicle booking time slot item
11 July 2024	navpw1	TFS: 61525 (61527) - Added Max Weight Field

*/

begin
	inheritMethod();
	
	if self.mode = self.MODE_UPDATE or self.mode = self.MODE_BULK_UPDATE  then							//04.5.2023 navhl20 #57402[57471]
		self.btnNext.enabled := false;
	endif;
	
	if self.mode = self.MODE_BULK_ADD or self.mode = self.MODE_BULK_UPDATE then
		self.optBtnCargo.enabled := false;
		self.cmbCargo.enabled     := false;
	endif;
	
	self.txtQuantity.visible 	:= false;										//27.04.2023 navma1 #57716:[57718]
	self.cmbReleaseReq.visible 	:= false;										//26.12.2022 navak20 #55979
	self.lblQuantity.visible	:= false;										//27.04.2023 navma1 #57716:[57718]
	self.tblWeight.visible	 	:= false;										//27.04.2023 navma1 #57716:[57718]
	self.lblVolume.visible	 	:= false;										// ### TFS 58256 02Jun2023 NAVPW1
	self.tblVolume.visible	 	:= false;										// ### TFS 58256 02Jun2023 NAVPW1
	self.cmbReleaseReq.visible  := false;										//27.04.2023 navma1 #57716:[57718]
	self.tblMaxWeight.visible	:= false;										// ### TFS 61525 (61527) 11Jul2024 NAVPW1
	self.lblMaxWeight.visible	:= false;										// ### TFS 61525 (61527) 11Jul2024 NAVPW1
	
	if self.mode = self.MODE_ADD or self.mode = self.MODE_BULK_ADD then			//04.5.2023 navhl20 #57402[57471]
		self.optBtnPickUp.value 	:= true;
		self.optBtnPickUp_click(self.optBtnPickUp);
		self.optBtnRR.value 		:= true;
	endif;
	
	self.setCargoMode(true);
	self.tblWeight.setup(Type_Weight, self.backColor);
	self.tblVolume.setup(Type_Volume, self.backColor);							// ### TFS 58256 02Jun2023 NAVPW1
	self.tblMaxWeight.setup(Type_Weight, self.backColor);						// ### TFS 61525 (61527) 11Jul2024 NAVPW1
	
	if self.myParentForm &lt;&gt; null then
		self.myPxyVehicleBookingSlot := self.myParentForm.CMUI_VehicleBookingAdvMaint.myProxyVehicleBookingTimeSlot;
	endif;
	
	if self.myPxyVehicleBookTimeSlotItem = null then
		self.createProxyVBItem();
	else
		self.myTrackedItem := self.myPxyVehicleBookTimeSlotItem.myTrackedItem;	//24.4.2023 navhl20 #57716[57718]
	endif;
	
	// Setup Combo Boxes
	self.populateCombos();
	
	// Setup the measurement input field
	self.tblWeight.selectMode := Table.SelectMode_None;
	self.tblVolume.selectMode := Table.SelectMode_None;							// ### TFS 58256 02Jun2023 NAVPW1
	
	//self.alignTable();														//03.5.2023 navhl20 #57402[57471]
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupQuantity" id="23f85f87-f949-4f46-9c6a-ee4cd7303561">
        <source>setupQuantity(_obj : Object);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 May 2023		navhl20	ChangeRequest 57402:[57471] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 03]
24 May 2023		navhl20 Defect 58137: EUP - VBS MTN - [9] - Cannot add a bulk item on Vehicle Booking Slot Item screen
02 June 2023	navpw1	TFS: 58256 - Added volume to vehicle booking time slot item
05 Jan 2024 	navlc30 Bug 61929: FR | 54329 - VBS - Release Qty of 1 is not populated correctly in VBS Slot creation screen
24 July 2024	navpw1	TFS: 61525 (61527) - Show quantity even if it is 0 when using max weight

*/

vars
	bulkCargo	: CM_Bulk;
	cargoType	: CM_CargoType;
	quantity	: Integer;
	
begin
	if _obj.isKindOf(CM_Bulk) then
		bulkCargo := _obj.CM_Bulk;
		if bulkCargo.myCargoType.isKindOf(CM_CargoType) then
			cargoType := bulkCargo.myCargoType.CM_CargoType;
		endif;
		
		if cargoType &lt;&gt; null and cargoType.isBulkByWeight then
			self.tblWeight.visible		:= true;
			self.txtQuantity.visible	:= false;
			self.lblQuantity.visible	:= false;
			self.lblWeight.visible		:= true;
			self.tblWeight.setValueDefault(bulkCargo.totalWeight.asStringJMT);	//24.5.2023 navhl20	#58137
			self.lblVolume.visible		:= false;
			self.tblVolume.visible		:= false;
			
		elseif cargoType &lt;&gt; null and cargoType.isBulkByVolume then
			self.tblWeight.visible		:= false;
			self.txtQuantity.visible	:= false;
			self.lblQuantity.visible	:= false;
			self.lblWeight.visible		:= false;
			self.tblWeight.visible		:= false;
			self.lblVolume.visible		:= true;
			self.tblVolume.visible		:= true;
			self.tblVolume.setupFromCargoType(cargoType, null, self.backColor);
			self.tblVolume.setValue(bulkCargo.totalVolume);
		endif;
		
	elseif _obj.isKindOf(CM_Container) then
		self.tblWeight.visible		:= false;
		self.txtQuantity.visible	:= false;
		self.lblQuantity.visible	:= false;
		self.lblWeight.visible		:= false;
		self.lblVolume.visible		:= false;
		self.tblVolume.visible		:= false;
	else
		self.tblWeight.visible		:= false;
		self.lblWeight.visible		:= false;
		self.lblVolume.visible		:= false;
		self.tblVolume.visible		:= false;
		if _obj.isKindOf(CM_TrackedItem) then
			quantity	:= _obj.CM_TrackedItem.totalQuantity;
		elseif _obj.isKindOf(CM_ReserveSelection) then
			if _obj.CM_ReserveSelection.totalRequested &gt; 0 then
				if self.mode = self.MODE_UPDATE and self.myPxyVehicleBookTimeSlotItem.quantity &lt; 1 then
					quantity := self.myPxyVehicleBookTimeSlotItem.quantity;
					self.txtQuantity.visible := true;
					self.lblQuantity.visible := true;
					self.txtQuantity.text := quantity.asStringJMT;
				else
					quantity	:= _obj.CM_ReserveSelection.totalRequested;
				endif;
			else
				self.tblWeight.visible 	 := true;
				self.lblWeight.visible	 := true;
				self.tblWeight.setValueDefault(_obj.CM_ReserveSelection.weightRequested.asStringJMT);		//24.5.2023 navhl20	#58137
			endif;
		endif;
		if quantity &gt; 0 then																				//05.01.2023 navlc30 #61929
			self.txtQuantity.visible := true;
			self.lblQuantity.visible := true;
			self.txtQuantity.text := quantity.asStringJMT;
		endif;
	endif;
	
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
