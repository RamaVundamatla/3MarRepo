    <JadeMethod name="optionChange" id="1a4c537d-05dd-47b3-a724-ca2bcb691c94">
        <source>optionChange();
//--------------------------------------------------------------
//Created: 24 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	obj : Object;

begin
	if self.fldTreeView.topSheet = self.shtListPorts then
		obj := self.lstPorts.listObject;
	elseif self.fldTreeView.topSheet = self.shtListSuppliers then
		obj := self.lstSuppliers.listObject;	
	endif;
	if obj = null then
		return;
	endif;
	
	if obj.isKindOf(CM_VoyageGlobal) then
		self.loadAllOrdersByVoyageGlobal(obj.CM_VoyageGlobal);
	elseif obj.isKindOf(CM_VoyageOperator) then
		self.loadAllOrdersByVoyageOperator(obj.CM_VoyageOperator);
	elseif obj.isKindOf(CM_Voyage) then
		self.loadAllOrdersByVoyageTerminal(obj.CM_Voyage, null);		
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="removeDeletedObject" id="e236d8c1-5d39-4c15-9623-25e6fee81bf0">
        <updating/>
        <source>removeDeletedObject(_object : Object)updating;
//--------------------------------------------------------------
//Created: 05 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	idx : Integer;
begin

	if CM_Operator.hasInstance(_object) and
	   self.myCurrentOperator = _object then
		self.myCurrentOperator			:= null;
	endif;
	if CM_StockOrderObject.hasInstance(_object) and
	   self.myCurrentStockOrderObject = _object then
		self.myCurrentStockOrderObject	:= null;
	endif;
	if CM_Voyage.hasInstance(_object) and
	   self.myCurrentVoyage = _object then
		self.myCurrentVoyage	 		:= null;
	endif;
	if CM_VoyageGlobal.hasInstance(_object) and
	   self.myCurrentVoyageGlobal = _object then
		self.myCurrentVoyageGlobal 		:= null;
	endif;
	if CM_VoyageOperator.hasInstance(_object) and
	   self.myCurrentVoyageOperator = _object then
		self.myCurrentVoyageOperator := null;
	endif;
	
	idx := self.lstPorts.findObject(_object);
	
	if idx &gt; 1 then
		self.lstPorts.clearBelowLevel(idx);
		self.lstPorts.removeItem(idx);
	endif;
	
	idx := self.lstSuppliers.findObject(_object);
	
	if idx &gt; 1 then
		self.lstSuppliers.clearBelowLevel(idx);	
		self.lstSuppliers.removeItem(idx);
		if CM_VoyageOperator.hasInstance(_object) then
			self.listSupplierRemoveOperator(idx);
		endif;		
	endif;

end;</source>
        <Parameter name="_object" type="Object"/>
    </JadeMethod>
    <JadeMethod name="resortTblOrderData" id="d538836e-28e3-4da4-b045-7c0ca105a22e">
        <updating/>
        <source>resortTblOrderData()updating;
//--------------------------------------------------------------
//Created: 05 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	idx, backColour : Integer;
begin
	if self.optBoth.value then
		return;
	endif;

	tblOrderData.resortTableByColumn(tblOrderData.column);
	foreach idx in 2 to tblOrderData.rows do
		if idx mod 2 = 0 then
			backColour := self.colorRow1;
		else
			backColour := self.colorRow2;
		endif;		
		tblOrderData.accessRow(idx).backColor := backColour;
	endforeach;	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="savePxyLogVoyages" id="b294fa1e-443a-4ecb-a827-d78d7dc0bae6">
        <updating/>
        <source>savePxyLogVoyages(_pxyVoyGlobal : CM_VoyageGlobal) updating;
//--------------------------------------------------------------
//Created: 09 July 2002 By: cnwgd1
//
// Changed On	By			Reason
// ----------	--------	------------------------------------
// 09/03/2015	cnwdap1		PAR #35826 CCMS SFW 1410 Added expected arrival/departure date/time
// 15/03/2018	jlgdap1		TFS 37427 PEL1 Voyage Status Enhancements
//13/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
//--------------------------------------------------------------
vars
	voy					: CM_Voyage;
	terminal 			: CM_Terminal;
	starboardBerthed	: Boolean;
	berth,
	sideTo				: String;
	arrivalDate, sailDate,
	startDate, endDate	: Date;
	arrivalTime, sailTime,
	startTime, endTime	: Time;
	sailDT,
	startDT, endDT,
	arriveDT, departDT	: TimeStamp;
	loadRate			: Decimal[13,3];
	row, col, statusInt : Integer;
	hmsBerth			: HMS_Berth;
	realVoy,
	pxyLogVoyage,
	existingVoyage 		: CM_Voyage;
	pxyLogStructure 		: CM_LogVoyageStructure;
	status, voyCode,
	vesselCode, vesselName 	: String;
	nullCurrentVoyage		: Boolean;
	nullCurrentVoyageIndx	: Integer;
	startLocal,
	endLocal,
	arriveLocal,
	sailLocal				: TimeStamp;
	
	voyageProcess 		: CM_VoyageProcess;		// TFS 37427
	voyageStatus		: CM_VoyageStatus;		// TFS 37427
begin

	voyCode := self.tblVoyageAdmin.getValueByName(ETRow_VoyageCode).String;
	vesselCode	:= self.tblVoyageAdmin.getValueByName(ETRow_IMO).String[1:7];
	row := (tblVoyTermDtl.rows);
	
	nullCurrentVoyage:=self.myCurrentVoyage &lt;&gt; null;
	
	while row &gt; tblVoyTermDtl.fixedRows do

		existingVoyage := tblVoyTermDtl.accessRow(row).itemObject.CM_Voyage;

		if existingVoyage &lt;&gt; null then
			if (not existingVoyage.isTransient) then
				app.raiseUnexpectedProgramError(class.name, method.name, 'voyage object is not a transient');
			else
				pxyLogVoyage := existingVoyage;
			endif;
			// epr par 12021
			if nullCurrentVoyage and
				existingVoyage = self.myCurrentVoyage then
				nullCurrentVoyage:=false;
			endif;
		else
			create pxyLogVoyage transient;
		endif;
		
		terminal := tblVoyTermDtl.accessCell(row, 1).itemObject.CM_Terminal;
		// CCMS 1124 berth, side to, arrival date/time
		col := tblVoyTermDtl.getColumnByRowName(ETRow_Berth);
		berth := tblVoyTermDtl.accessCell(row, col).text;
		hmsBerth := self.findBerth(terminal, berth);
		col := tblVoyTermDtl.getColumnByRowName(ETRow_Side);
		sideTo := tblVoyTermDtl.accessCell(row, col).text;
		if sideTo = "Starboard" then
			starboardBerthed := true;
		else
			starboardBerthed := false;
		endif;

		col := tblVoyTermDtl.getColumnByRowName(ETRow_ArriveDT);
		arrivalDate := tblVoyTermDtl.getValueForCellAsDate(row, col);
		col := tblVoyTermDtl.getColumnByRowName(ETRow_LoadStartDate);
		startDate := tblVoyTermDtl.getValueForCellAsDate(row, col);
		col := tblVoyTermDtl.getColumnByRowName(ETRow_LoadEndDate);
		endDate := tblVoyTermDtl.getValueForCellAsDate(row, col);

		col := tblVoyTermDtl.getColumnByRowName(ETRow_ArrivalTime);
		arrivalTime := tblVoyTermDtl.getValueForCellAsTime(row, col);						
		col := tblVoyTermDtl.getColumnByRowName(ETRow_LoadStartTime);
		startTime := tblVoyTermDtl.getValueForCellAsTime(row, col);						
		col := tblVoyTermDtl.getColumnByRowName(ETRow_LoadEndTime);
		endTime := tblVoyTermDtl.getValueForCellAsTime(row, col);
		col := tblVoyTermDtl.getColumnByRowName(ETRow_DepartTM);
		sailTime := tblVoyTermDtl.getValueForCellAsTime(row, col);						
		col := tblVoyTermDtl.getColumnByRowName(ETRow_DepartDT);
		sailDate := tblVoyTermDtl.getValueForCellAsDate(row, col);
		col := tblVoyTermDtl.getColumnByRowName(ETRow_LoadRate);
		loadRate := tblVoyTermDtl.accessCell(row, col).text.asDecimalJMT;
		col := tblVoyTermDtl.getColumnByRowName(ETRow_Status);
		status := tblVoyTermDtl.accessCell(row, col).text;
		
		if status = app.voyageStatusEnumToString(Voyage_Status_Archived, true) and
		   (not app.getMyUser().canDo(self.myTerminal, PmVoyageArchive)) then
			app.raiseCMException1(VB_SECMOVE, 'Voyage Ops - Change status to Archived', null, null);
			return;
		endif;
		
		if existingVoyage = null and terminal &lt;&gt; null then 
			
			// we need to do the correct lookup here - by arrival date if necessary
			// H
			// there is a bug here when they delete a terminal and re-add in the same
			// transaction.  Need to consider if this lookup here is required at all.
			
			// Mohammad 19/2/2007 par13442
			voy := _pxyVoyGlobal.getVoyageForArrivingDTTerminal(null, terminal);
			if voy &lt;&gt; null then
				// have deleted and re-added the terminal so have lost
				// link from original proxy to real object so need to
				// try and re-connect (or have added the same terminal twice, which
				// gui prevents.  Will need to review as part of Comalco changes
				if voy.archived then
					app.raiseCMException1(ERR_IS_ARCHIVED_VOY, voy.code, null, null);
				else
					//app.raiseCMException2(DuplicateItem, 'Voyage', voy.code, null, null); //13.06.2022 navds20 53760
					// Voyage already exists for %1: Voyage_already_exists
					app.raiseCMException1(Voyage_already_exists, voy.code, null, null); //13.06.2022 navds20 53760
				endif;
				return;		   
			endif;		
		endif;		
		
		if (not arrivalDate.isValid) then
			arrivalDate := null;
		endif;
		if (not arrivalTime.isValid) then
			arrivalTime := null;
		endif;
		if (not startDate.isValid) then
			startDate := null;
		endif;
		if (not startTime.isValid) then
			startTime := null;
		endif;
		if (not endDate.isValid) then
			endDate := null;
		endif;
		if (not endTime.isValid) then
			endTime := null;
		endif;
		if not sailDate.isValid then
			sailDate := null;
		endif;
		if not sailTime.isValid then
			sailTime := null;
		endif;
								
		startLocal.cnEcSetDateAndTime(startDate, startTime);	// 22/4/16 cnwmp6 TFS 488 - Multi timezone support
		endLocal.cnEcSetDateAndTime(endDate, endTime);
		sailLocal.cnEcSetDateAndTime(sailDate, sailTime);
		arriveLocal.cnEcSetDateAndTime(arrivalDate, arrivalTime);
		//statusInt := app.voyageStatusStringToEnum(status.trimBlanks);		// TFS 37427
		voyageProcess := terminal.getDefaultVoyageProcess;					// TFS 37427
		if voyageProcess &lt;&gt; null then	//23 Jul 2018	NDL	TFS 39882
			foreach voyageStatus in voyageProcess.allStatuses do				// TFS 37427
				if voyageStatus.description = status.trimBlanks then			// TFS 37427
					statusInt := voyageStatus.id;								// TFS 37427
					break;														// TFS 37427
				endif;															// TFS 37427
			endforeach;															// TFS 37427
		endif;
		
		startDT := self.localToSystemTime(startLocal);	// 22/4/16 cnwmp6 TFS 488 - Multi timezone support
		endDT := self.localToSystemTime(endLocal);
		sailDT := self.localToSystemTime(sailLocal);
		arriveDT := self.localToSystemTime(arriveLocal);

		realVoy := pxyLogVoyage.pxyGetRealObject();
		if realVoy &lt;&gt; null then
			//arriveDT := realVoy.arrivedDT;
			departDT := realVoy.departedDT;
		else
			//arriveDT := null;
			departDT := null;
		endif;
		
		if pxyLogVoyage.myLogVoyageStructure = null then
			// then is new voyage so needs log voyage structure
			create pxyLogStructure transient;
			pxyLogVoyage.setProxyVoyageLogStructure(pxyLogStructure);
		endif;	

		pxyLogVoyage.setProxyLogVoyage(voyCode, terminal, startDT, endDT, arriveDT, departDT, sailDT, loadRate,
									//statusInt, _pxyVoyGlobal, vesselCode, _pxyVoyGlobal.vesselName);					// PAR #35826
									statusInt, _pxyVoyGlobal, vesselCode, _pxyVoyGlobal.vesselName, null, null);		// PAR #35826
		
		// CCMS 1124 new properties saved
		pxyLogVoyage.setPropertyValue("starboardBerthed", starboardBerthed);
		pxyLogVoyage.setMyBerth(hmsBerth);
		
		row := row - 1;	
	endwhile;

	//its been deleted par 12021
	if nullCurrentVoyage  then
		nullCurrentVoyageIndx:=self.lstPorts.findObject(self.myCurrentVoyage);
		if nullCurrentVoyageIndx &lt;&gt; -1 then
			self.lstPorts.removeItem(nullCurrentVoyageIndx);
		endif;
		self.myCurrentVoyage:=null;
	endif;

epilog
	//Deliberatly did not delete pxyLogVoyage here
	//they will be deleted when the _pxyVoyGlobal is deleted
end;</source>
        <Parameter name="_pxyVoyGlobal" type="CM_VoyageGlobal"/>
    </JadeMethod>
    <JadeMethod name="selectUnselectAll" id="be705359-91f3-4a5f-88f9-eba5e9752e3d">
        <source>selectUnselectAll(_all : Boolean) ;
//--------------------------------------------------------------
//Created: June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	cell 	: JadeTableCell;
	row		: Integer;		
begin

	foreach row in 2 to self.tblAllocatedRows.rows do
		cell := self.tblAllocatedRows.accessCell(row, tblAllocatedRows.getColumnByRowName(ETRow_Opt));
		cell.text := _all.Integer.String;
	endforeach;

end;</source>
        <Parameter name="_all" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="3930fc23-ea38-4e0e-8943-284f5315af80">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     29 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpBackColor	: Integer;

begin
	inheritMethod(_colorControl);
	
	tmpBackColor	:= self.backColor;
	
	self.fldInfo.backColor			:= tmpBackColor;
	self.fldSSSLoadOut.backColor	:= tmpBackColor;
	self.fldTreeView.backColor		:= tmpBackColor;
	
	self.frmData.backColor		:= tmpBackColor;
	self.frmMessage.backColor	:= tmpBackColor;

	self.shtAdditInfo.backColor		:= tmpBackColor;
	self.shtAllocateRows.backColor	:= tmpBackColor;
	self.shtAllocToDetail.backColor	:= tmpBackColor;
	self.shtDetails.backColor		:= tmpBackColor;
	self.shtSSScan.backColor		:= tmpBackColor;
	self.shtListPorts.backColor		:= tmpBackColor;
	self.shtListSuppliers.backColor	:= tmpBackColor;
	self.shtSSSBOL.backColor		:= tmpBackColor;
	self.shtSSSEDIData.backColor	:= tmpBackColor;
	self.shtSuppliers.backColor		:= tmpBackColor;
	self.shtVoyage.backColor		:= tmpBackColor;
	self.shtVoyageAdmin.backColor	:= tmpBackColor;
	
	self.splAllocateRows.backColor	:= tmpBackColor;
	self.splMain.backColor			:= tmpBackColor;
	self.splOperations.backColor	:= tmpBackColor;
	
	self.setColorsForEntryTable(self.tblAlloSearch);
	self.setColorsForEntryTable(self.tblArchiveSearch);
	self.setColorsForEntryTable(self.tblHatchPlaceEnt);
	self.setColorsForEntryTable(self.tblLotDetails);
	self.setColorsForEntryTable(self.tblSupplierEnt);
	self.setColorsForEntryTable(self.tblVoyage);
	self.setColorsForEntryTable(self.tblVoyageAdmin);

	self.setColorsForTable(self.tblAdditInfo);
	self.setColorsForTable(self.tblAllocDetail);
	self.setColorsForTable(self.tblAllocatedRows);
	self.setColorsForTable(self.tblDownloadInfo);
	self.setColorsForTable(self.tblHatchPlaceDtl);
	self.setColorsForTable(self.tblOrderData);
	self.setColorsForTable(self.tblSSSDockets);
	self.setColorsForTable(self.tblSSSEDIData);
	self.setColorsForTable(self.tblSrchResults);
	self.setColorsForTable(self.tblSupplierDtl);
	self.setColorsForTable(self.tblVoyTermDtl);
	
	self.lblAllocated.backColor		:= tmpBackColor;
	self.lblAllocateReq.backColor	:= tmpBackColor;
	self.lblDwnLogFile.backColor	:= tmpBackColor;
	self.lblDwnShipFile.backColor	:= tmpBackColor;
	self.lblImportFile.backColor	:= tmpBackColor;					
	self.lblsssLine.backColor		:= tmpBackColor;
		
end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setControlFocusForTopSheet" id="a0837c59-e06b-4e20-8ee0-d4a192755a8d">
        <source>setControlFocusForTopSheet();
//--------------------------------------------------
// Created:	12 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	topSheet	: Sheet;
begin

	// set focus separatly to prevent LVO form getting focus when notifications processed for other forms
	
	topSheet := fldInfo.topSheet;
	
	if topSheet = self.shtVoyageAdmin then
		self.btnAdminNew.setFocus();
	elseif topSheet = self.shtVoyage then
		self.btnVoyageEdit.setFocus();
	elseif topSheet = self.shtSuppliers then
		self.btnSupNew.setFocus();
	elseif topSheet = self.shtDetails then
		self.btnDetailsNew.setFocus();
	elseif topSheet = self.shtAllocToDetail then
		self.tblAllocDetail.setFocus();
	elseif topSheet = self.shtSSScan then
		self.btnSelectChanges.setFocus();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForSheet" id="05ba6859-85bf-4494-9ce9-fbd39d34fa87">
        <source>setControlsForSheet(_sheet : Sheet; _enabled : Boolean);
// ---------------------------------------------------------------------------
// Created:     31 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if _sheet = shtAllocToDetail then

	elseif _sheet = shtAllocateRows then
		btnClearAlloRows.enabled	:= _enabled;
		btnSaveAllocate.enabled		:= _enabled;
		btnSearch.enabled			:= _enabled;
		tblAlloSearch.enabled		:= _enabled;
		tblSrchResults.enabled		:= _enabled;

	elseif _sheet = shtDetails then

	elseif _sheet = shtSSScan then
		btnSSSExportFile.enabled:= _enabled;
		tblDownloadInfo.enabled	:= _enabled;
		txtDwnLogFile.enabled	:= _enabled;
		
	elseif _sheet = shtSuppliers then

	elseif _sheet = shtVoyage then

	endif;

	// TFS 2734 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		btnClearAlloRows.enabled	:= false;
		btnSaveAllocate.enabled		:= false;

	endif;

end;</source>
        <Parameter name="_sheet" type="Sheet"/>
        <Parameter name="_enabled" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setEnableObjects" id="cf2de105-1d81-4cf9-9267-92a1bdca9011">
        <updating/>
        <source>setEnableObjects()updating;
//--------------------------------------------------
// Created:	30 June 2004 By: cnwgd1
//--------------------------------------------------
vars
	topSheet	: Sheet;
begin

	topSheet := fldInfo.topSheet;
	
	if topSheet = self.shtVoyageAdmin then
		self.setEnableObjectsVoyageAdmin();
	elseif topSheet = self.shtVoyage then
		self.setEnableObjectsVoyage();
	elseif topSheet = self.shtSuppliers then
		self.setEnableObjectsSuppliers();		
	elseif topSheet = self.shtDetails then
		self.setEnableObjectsDetails();	
	elseif topSheet = self.shtAllocateRows then
		self.setEnableObjectsAllocRows();
	elseif topSheet = self.shtAllocToDetail then
		self.setEnableObjectsAllocDetail();
	elseif topSheet = self.shtAdditInfo then
		//nothing to do for this sheet
	elseif topSheet = self.shtSSScan then
		self.setEnableObjectsSSS();
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableObjectsAllocDetail" id="3e4b381d-2546-4fbf-a94b-562fe449681d">
        <source>setEnableObjectsAllocDetail();
//--------------------------------------------------------------
//Created: 08 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if self.modeView = Mode_ArchiveView or self.mode = self.Mode_View_Only or
	   self.modeView = Mode_LimitedEdit then
		btnClearAllocDtl.enabled	:= false;
		btnSaveAllocDtl.enabled		:= false;
		btnShowHide.enabled			:= false;
		tblAllocDetail.enabled		:= false;
	else		
		btnClearAllocDtl.enabled	:= true;
		btnSaveAllocDtl.enabled		:= true;
		btnShowHide.enabled			:= true;
		tblAllocDetail.enabled		:= true;		
	endif;

	if self.myCurrentStockOrderSummary = null then
		self.showCannotAccessSheetMsg(shtAllocToDetail, 'You must select a stock order summary in the table above before you can allocate rows to orders.');
		return;
	else
		self.hideCannotAccessSheetMsg(shtAllocToDetail);	
	endif;
	self.showAllocToDetail();	
		
end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableObjectsAllocRows" id="ad41c386-cea1-4a55-ab30-398f5f70b97b">
        <source>setEnableObjectsAllocRows();
//--------------------------------------------------------------
//Created: 08 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if self.modeView = Mode_ArchiveView or self.mode = self.Mode_View_Only or
	   self.modeView = Mode_LimitedEdit then
		btnClearAlloRows.enabled	:= false;
		btnSaveAllocate.enabled		:= false;
		btnSearch.enabled			:= false;
		btnAllocSelect.enabled		:= false;
		tblAllocatedRows.userInputEnabled := false;		
	else		
		btnClearAlloRows.enabled	:= true;
		btnSaveAllocate.enabled		:= true;
		btnSearch.enabled			:= true;
		btnAllocSelect.enabled		:= true;
		tblAllocatedRows.userInputEnabled := true;				
	endif;

	if self.myCurrentStockOrderObject = null then
		self.showCannotAccessSheetMsg(shtAllocateRows, 'You must select a stock order line in the table above before you can allocate rows');
	else
		self.hideCannotAccessSheetMsg(shtAllocateRows);
	endif;

	self.setupSearchCriteria();
		
end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableObjectsDetails" id="9f8fd5e6-1b8e-4435-b7aa-8bef1e763fd5">
        <source>setEnableObjectsDetails();
//--------------------------------------------------------------
//Created: 08 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if self.mode = Mode_Add or self.mode = Mode_Update then
		tblHatchPlaceEnt.enabled := false;		// 33265 not wanted by C3
		tblLotDetails.userInputEnabled := true;		
		shtAdditInfo.enabled := false;
		shtAllocToDetail.enabled := false;
		shtAllocateRows.enabled := false;
		shtVoyage.enabled := false;
		shtSuppliers.enabled := false;
		shtListPorts.enabled := false;
		shtListSuppliers.enabled := false;
		shtSSScan.enabled := false;						
		tblOrderData.enabled := false;
		btnDetailsHPAdd.enabled := false;		// 33265 not wanted by C3
		btnDetailsHPRem.enabled := false;		// 33265 not wanted by C3
		btnDetailsEdit.enabled := false;																
		btnDetailsDelete.enabled := false;
		btnDetailsNew.enabled := false;
		btnDetailsSave.enabled := true;
		btnDetailsCancel.enabled := true;				
	elseif self.mode = Mode_View or self.mode = self.Mode_View_Only or
	   self.mode = Mode_LimitedEdit then
		tblHatchPlaceEnt.enabled := false;
		btnDetailsHPAdd.enabled := false;
		btnDetailsHPRem.enabled := false;				
		tblLotDetails.userInputEnabled := false;		
		shtAdditInfo.enabled := true;
		shtAllocToDetail.enabled := true;
		shtAllocateRows.enabled := true;
		shtVoyage .enabled := true;
		shtSuppliers.enabled := true;
		shtListPorts.enabled := true;
		shtListSuppliers.enabled := true;
		shtSSScan.enabled := true;						
		tblOrderData.enabled := true;
		btnDetailsEdit.enabled := true;																
		btnDetailsDelete.enabled := true;																		
		btnDetailsNew.enabled := true;
		btnDetailsSave.enabled := false;
		btnDetailsCancel.enabled := false;
	endif;
	
	if self.modeView = Mode_ArchiveView or self.mode = self.Mode_View_Only or
	   self.modeView = Mode_LimitedEdit then
		btnDetailsHPAdd.enabled := false;
		btnDetailsHPRem.enabled := false;						
		btnDetailsEdit.enabled := false;																
		btnDetailsDelete.enabled := false;
		btnDetailsNew.enabled := false;
		btnDetailsSave.enabled := false;
		btnDetailsCancel.enabled := false;
	endif;
	
	if self.myCurrentVoyage = null then
		self.showCannotAccessSheetMsg(shtDetails, 'You must select a Terminal from the list before updating details.');
		return;
	else
		self.hideCannotAccessSheetMsg(shtDetails);
	endif;
	self.myAssistant.LOG_Assistant.comboBoxHatch(tblHatchPlaceEnt, ETRow_Hatch, self.myCurrentVoyage.myLogVoyageStructure.numHatches);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableObjectsSSS" id="f58952f1-0aca-4c8c-8ab9-2fdf92c80d5f">
        <updating/>
        <source>setEnableObjectsSSS()updating;
//--------------------------------------------------------------
//Created: 08 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	if self.modeView = Mode_ArchiveView or self.mode = self.Mode_View_Only or
	   self.modeView = Mode_LimitedEdit then
		btnSSSExportFile.enabled			:= false;
		btnDwnBrowseLog.enabled		:= false;
		btnDwnBrowseShip.enabled	:= false;
		btnImportBrowse.enabled		:= false;
		btnImportLogOut.enabled		:= false;
		btnSelectAll.enabled		:= false;		
		btnSelectChanges.enabled	:= false;				
		btnSSSExportTEST.enabled		:= false;				
		btnSSSLoad.enabled			:= false;				
		btnSSSSelect.enabled	    := false;
		tblSSSDockets.userInputEnabled := false;
		tblSSSEDIData.userInputEnabled := false;
		tblDownloadInfo.userInputEnabled := false;				
	else
		btnSSSExportFile.enabled			:= true;			
		btnDwnBrowseLog.enabled		:= true;
		btnDwnBrowseShip.enabled	:= true;
		btnImportBrowse.enabled		:= true;
		btnImportLogOut.enabled		:= true;
		btnSelectAll.enabled		:= true;
		btnSelectChanges.enabled	:= true;
		btnSSSExportTEST.enabled		:= true;				
		btnSSSLoad.enabled			:= true;				
		btnSSSSelect.enabled	    := true;
		tblSSSDockets.userInputEnabled := true;
		tblSSSEDIData.userInputEnabled := true;
		tblDownloadInfo.userInputEnabled := true;																		
	endif;

	tblDownloadInfo.rows := tblDownloadInfo.fixedRows;
	tblSSSEDIData.rows := tblSSSEDIData.fixedRows;
	tblSSSDockets.rows := tblSSSDockets.fixedRows;		
		
	if self.myCurrentVoyage = null then
		self.showCannotAccessSheetMsg(shtSSScan, 'You must select a terminal in the list box before you can do a download');
		return;
	else
		self.hideCannotAccessSheetMsg(shtSSScan);
	endif;

//	if (not self.myCurrentVoyage.isKindOf(CM_LogVoyage)) then
	if (self.myCurrentVoyage.myLogVoyageStructure = null) then
		app.msgBox('Current voyage is not a log voyage.  Cannot continue', 'Error', MsgBox_OK_Only);
		return;
	endif;
	
	self.mySSSLogVoyage := self.myCurrentVoyage.CM_Voyage;
	self.sssShowLogRowsForDownload();
	self.sssShowEDIData();
	self.sssShowDocketsToBeLoaded();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableObjectsSuppliers" id="00a92dd2-7d2a-46a8-a22f-6f1d6404fd74">
        <updating/>
        <source>setEnableObjectsSuppliers() updating;
//--------------------------------------------------------------
//Created: 08 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	
	if self.mode = Mode_Add or self.mode = Mode_Update then
		tblSupplierEnt.enableRowByName(ETRow_MyOperator);
		tblSupplierEnt.enableRowByName(ETRow_Agent);
		tblSupplierEnt.enableRowByName(ETRow_Stevedore1);
		tblSupplierEnt.enableRowByName(ETRow_Stevedore2);
		tblSupplierEnt.enableRowByName(ETRow_Port);
		tblSupplierEnt.enableRowByName(ETRow_LotPlanVersion);
		
		tblSupplierDtl.enabled := false;
		
		btnSupSave.enabled := true;
		btnSupCancel.enabled := true;
		btnSupImport.enabled := false;
		btnSupNew.enabled := false;
		btnSupDelete.enabled := false;
		btnSupEdit.enabled := false;
		btnSSSExportTEST.enabled := false;		
		
		shtAdditInfo.enabled := false;
		shtAllocToDetail.enabled := false;
		shtAllocateRows.enabled := false;
		shtDetails.enabled := false;
		shtVoyage.enabled := false;
		shtListPorts.enabled := false;
		shtListSuppliers.enabled := false;
		shtSSScan.enabled := false;						
		tblOrderData.userInputEnabled := false;
	elseif self.mode = Mode_View or self.mode = self.Mode_View_Only or
	   self.mode = Mode_LimitedEdit then
		tblSupplierEnt.disableRowByName(ETRow_MyOperator);
		tblSupplierEnt.disableRowByName(ETRow_Agent);
		tblSupplierEnt.disableRowByName(ETRow_Stevedore1);
		tblSupplierEnt.disableRowByName(ETRow_Stevedore2);
		tblSupplierEnt.disableRowByName(ETRow_Port);
		tblSupplierEnt.disableRowByName(ETRow_LotPlanVersion);
		
		tblSupplierDtl.enabled := true;				
		
		btnSupSave.enabled := false;
		btnSupCancel.enabled := false;
		btnSupImport.enabled := true;
		btnSupNew.enabled := true;
		btnSupDelete.enabled := true;
		btnSupEdit.enabled := true;
		btnSSSExportTEST.enabled := true;				
		
		shtAdditInfo.enabled := true;
		shtAllocToDetail.enabled := true;
		shtAllocateRows.enabled := true;
		shtDetails.enabled := true;
		shtVoyage.enabled := true;
		shtListPorts.enabled := true;
		shtListSuppliers.enabled := true;
		shtSSScan.enabled := true;						
		tblOrderData.userInputEnabled := true;
	endif;
	
	if self.modeView = Mode_ArchiveView or self.mode = self.Mode_View_Only or
	   self.modeView = Mode_LimitedEdit then
		btnSupSave.enabled := false;
		btnSupCancel.enabled := false;
		btnSupImport.enabled := false;
		btnSupNew.enabled := false;
		btnSupDelete.enabled := false;
		btnSupEdit.enabled := false;
		btnSSSExportTEST.enabled := false;
	endif;

	if self.myCurrentVoyage = null and self.myCurrentVoyageGlobal = null then
		self.showCannotAccessSheetMsg(shtSuppliers, 'You must select a Voyage or Terminal from the list before you can update suppliers.');
		return;
	else
		self.hideCannotAccessSheetMsg(shtSuppliers);	
		self.showSupplierDetails();
	endif;
		
end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableObjectsVoyage" id="d1a90465-c7eb-4fc6-bda8-6da5cc692435">
        <updating/>
        <source>setEnableObjectsVoyage() updating;
//--------------------------------------------------------------
//Created: 08 July 2002 By: cnwgd1	enable Voyage tab
//--------------------------------------------------------------
vars

begin
	tblVoyage.disableRowByName(ETRow_IMO);
	tblVoyage.disableRowByName(ETRow_VoyageCode);
	tblVoyage.disableRowByName(ETRow_VesselName);
	tblVoyage.disableRowByName(ETRow_NumHatches);
	
	if self.mode = Mode_Add or self.mode = Mode_Update then
		btnVoyageEdit.enabled := false;
		btnVoyageCancel.enabled := true;
		btnVoyageSave.enabled := true;			
		shtAdditInfo.enabled := false;
		shtAllocToDetail.enabled := false;
		shtAllocateRows.enabled := false;
		shtDetails.enabled := false;
		shtSuppliers.enabled := false;
		shtListPorts.enabled := false;
		shtListSuppliers.enabled := false;
		shtSSScan.enabled := false;
		shtVoyageAdmin.enabled := false;
		tblOrderData.userInputEnabled := false;
		optCurrentView.enabled := false;
		optArchiveView.enabled := false;
		tblArchiveSearch.enabled := false;
		btnArchiveSearch.enabled := false;																						
	elseif self.mode = Mode_View or self.mode = self.Mode_View_Only or
	   self.mode = Mode_LimitedEdit then
		btnVoyageEdit.enabled := true;
		btnVoyageCancel.enabled := false;
		btnVoyageSave.enabled := false;		
		shtAdditInfo.enabled := true;
		shtAllocToDetail.enabled := true;
		shtAllocateRows.enabled := true;
		shtDetails.enabled := true;
		shtSuppliers.enabled := true;
		shtListPorts.enabled := true;
		shtListSuppliers.enabled := true;
		shtSSScan.enabled := true;
		shtVoyageAdmin.enabled := true;
		tblOrderData.userInputEnabled := true;
		optCurrentView.enabled := true;
		optArchiveView.enabled := true;
		tblArchiveSearch.enabled := false;
		btnArchiveSearch.enabled := false;
	endif;
										
	if self.modeView = Mode_ArchiveView or self.mode = self.Mode_View_Only or
	   self.modeView = Mode_LimitedEdit then
		btnVoyDeSelPort.enabled := false;
		btnVoySelectPort.enabled := false;
		tblArchiveSearch.enabled := true;
		btnArchiveSearch.enabled := true;
		if self.tblVoyTermDtl.rows &gt; self.tblVoyTermDtl.fixedRows then
			if self.mode = Mode_View or self.mode = Mode_LimitedEdit then
				btnVoyageEdit.enabled := true;
			else
				btnVoyageEdit.enabled := false;									
			endif;
		else
			btnVoyageEdit.enabled := false;				
		endif;
		if (not app.getMyUser().canDo(self.myTerminal, PmVoyageArchive)) then
			btnVoyageEdit.enabled := false;								
		endif;			
	endif;

	if self.mode &lt;&gt; self.Mode_Add then
		if self.myCurrentVoyageGlobal = null and self.myCurrentVoyage = null then
			self.showCannotAccessSheetMsg(shtAllocToDetail, 'You must select a Voyage from the list first.');
			return;
		else
			self.hideCannotAccessSheetMsg(shtAllocToDetail);	
		endif;
		
		self.showVoyageDetails();
	endif;
		
end;</source>
    </JadeMethod>
    <JadeMethod name="setEnableObjectsVoyageAdmin" id="b447a64c-7257-4f15-b132-5ce514f30a3a">
        <updating/>
        <source>setEnableObjectsVoyageAdmin() updating;
// CCMS 1124 Voyage Admin tab
vars

begin
	if self.mode = Mode_Add or self.mode = Mode_Update then
		tblVoyageAdmin.enableRowByName(ETRow_IMO);
		tblVoyageAdmin.enableRowByName(ETRow_VoyageCode);
		// can enter vessel name here for add, must do it via the Edit Name button -&gt; separate form for update
		if self.mode = Mode_Add then
			tblVoyageAdmin.enableRowByName(ETRow_VesselName);
		else
			tblVoyageAdmin.disableRowByName(ETRow_VesselName);
		endif;
		tblVoyageAdmin.enableRowByName(ETRow_NumHatches);
		btnVoyDeSelPort.enabled := true;
		btnVoySelectPort.enabled := true;
		btnAdminCancel.enabled := true;
		btnAdminSave.enabled := true;			
		shtAdditInfo.enabled := false;
		shtAllocToDetail.enabled := false;
		shtAllocateRows.enabled := false;
		shtDetails.enabled := false;
		shtSuppliers.enabled := false;
		shtListPorts.enabled := false;
		shtListSuppliers.enabled := false;
		shtSSScan.enabled := false;	
		shtVoyage.enabled := false;
		tblOrderData.userInputEnabled := false;
		btnAdminDelete.enabled := false;
		btnAdminEdit.enabled := false;
		btnAdminNew.enabled := false;
		btnEditName.enabled := (self.mode = Mode_Update);
	elseif self.mode = Mode_View or self.mode = self.Mode_View_Only or
	   self.mode = Mode_LimitedEdit then
		tblVoyageAdmin.disableRowByName(ETRow_IMO);
		tblVoyageAdmin.disableRowByName(ETRow_VoyageCode);
		tblVoyageAdmin.disableRowByName(ETRow_VesselName);
		tblVoyageAdmin.disableRowByName(ETRow_NumHatches);
		// 33265 this method is called from voyage save as well
		btnVoyageEdit.enabled := true;
		btnVoyageCancel.enabled := false;
		btnVoyageSave.enabled := false;
		shtVoyageAdmin.enabled := true;
		btnVoyDeSelPort.enabled := false;
		btnVoySelectPort.enabled := false;
		btnAdminCancel.enabled := false;
		btnAdminSave.enabled := false;		
		shtAdditInfo.enabled := true;
		shtAllocToDetail.enabled := true;
		shtAllocateRows.enabled := true;
		shtDetails.enabled := true;
		shtSuppliers.enabled := true;
		shtListPorts.enabled := true;
		shtListSuppliers.enabled := true;
		shtSSScan.enabled := true;
		shtVoyage.enabled := true;
		tblOrderData.userInputEnabled := true;
		btnAdminDelete.enabled := true;
		btnAdminEdit.enabled := true;
		btnAdminNew.enabled := true;
		btnEditName.enabled := false;
	endif;
										
	if self.modeView = Mode_ArchiveView or self.mode = self.Mode_View_Only or
	   self.modeView = Mode_LimitedEdit then
		btnVoyDeSelPort.enabled := false;
		btnVoySelectPort.enabled := false;
		btnAdminDelete.enabled := false;
		btnAdminNew.enabled := false;				
		if self.tblVoyTermDtl.rows &gt; self.tblVoyTermDtl.fixedRows then
			if self.mode = Mode_View or self.mode = Mode_LimitedEdit then
				btnAdminEdit.enabled := true;
			else
				btnAdminEdit.enabled := false;									
			endif;
		else
			btnAdminEdit.enabled := false;				
		endif;
		if (not app.getMyUser().canDo(self.myTerminal, PmVoyageArchive)) then
			btnAdminEdit.enabled := false;								
		endif;			
	endif;

	if self.mode &lt;&gt; self.Mode_Add then
		if self.myCurrentVoyageGlobal = null and self.myCurrentVoyage = null then
			self.showCannotAccessSheetMsg(shtAllocToDetail, 'You must select a Voyage from the list first.');
			return;
		else
			self.hideCannotAccessSheetMsg(shtAllocToDetail);	
		endif;
		
		self.showVoyageDetails();
	endif;
		
end;</source>
    </JadeMethod>
    <JadeMethod name="setLoadEndDateTime" id="141b4f25-ee91-494f-bfe4-fa36a1dc1c95">
        <updating/>
        <source>setLoadEndDateTime() updating;
//--------------------------------------------------------------
//Created: 25 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	now		: TimeStamp;
	row,
	col	 	: Integer;
begin
return;
	if tblVoyTermDtl.row &lt;= 1 then
		return;
	endif;
	
	row := (tblVoyTermDtl.row);	
	
	col := tblVoyTermDtl.getColumnByRowName(ETRow_Status);
	if tblVoyTermDtl.accessCell(row, col).text = self.origStatus then
		//No Change so do nothing
		return;
	endif;
	
	now := self.systemToLocalTime(app.actualTimeServer());	// 23/6/16 cnwmp6 TFS 488 - Multi timezone support
	
	col := tblVoyTermDtl.getColumnByRowName(ETRow_LoadEndDate);
	tblVoyTermDtl.accessCell(row, col).text := now.date.shortFormatJMT();
	col := tblVoyTermDtl.getColumnByRowName(ETRow_LoadEndTime);
	tblVoyTermDtl.accessCell(row, col).text := now.time.currentLocaleFormatJMT();
	
	col := tblVoyTermDtl.getColumnByRowName(ETRow_Status);
	self.origStatus := tblVoyTermDtl.accessCell(row, col).text;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setMode" id="b8240335-f884-4aec-aab3-f67fe81290ef">
        <updating/>
        <source>setMode(_newMode : Integer) updating;
//--------------------------------------------------
// Created:	01 September 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.mode = self.Mode_View_Only then
		// user only has view permissions, do not reset the mode.
		return;
	endif;
	
	if _newMode &gt; self.Mode_View_Only then
		self.mode := self.Mode_View_Only;
		return;
	endif;
	
	self.mode := _newMode;
end;</source>
        <Parameter name="_newMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setProxyObject" id="4c13237c-962c-41a6-b48e-f8ce62727725">
        <updating/>
        <source>setProxyObject(_realObj : CM_Object) updating;
//--------------------------------------------------------------
//Created: 11 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	self.clearProxies();

	if _realObj &lt;&gt; null then
		self.myProxyObject := app.createUpdateProxy(_realObj);
		if self.myProxyObject &lt;&gt; null then
			self.allProxies.add(self.myProxyObject);
		endif;
	endif;
	
end;</source>
        <Parameter name="_realObj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setSelectedTblOrderData" id="65f7e2bb-115d-4ea0-9443-b0dcff80b6ee">
        <updating/>
        <source>setSelectedTblOrderData(_orderObject : CM_StockOrderObject; _topRow : Integer)updating;
//--------------------------------------------------------------
//Created: 07 July 2004 By: cnwgd1
//--------------------------------------------------------------
vars
	rowIdx : Integer;
begin
	if _orderObject = null then
		return;
	endif;
	
	if (not global.isValidObject(_orderObject)) then
		return;
	endif;
	
	if self.tblOrderData.findObjectInRow(_orderObject, rowIdx) then
		self.tblOrderData.accessRow(rowIdx).selected := true;
		self.tblOrderData.row := rowIdx;
	endif;		

	if _topRow &gt; self.tblOrderData.fixedRows
	and _topRow &lt;= self.tblOrderData.rows then
		if _topRow &lt;&gt; self.tblOrderData.topRow then
			self.tblOrderData.topRow := _topRow;
		endif;
	elseif rowIdx &gt; self.tblOrderData.fixedRows
	and rowIdx &lt;= self.tblOrderData.rows then
		if rowIdx &lt;&gt; self.tblOrderData.topRow then
			self.tblOrderData.topRow := rowIdx;
		endif; 
	endif;

	self.tblOrderDataSelectRow(self.tblOrderData);

	self.showRequiredAllocatedQtys();	
end;</source>
        <Parameter name="_orderObject" type="CM_StockOrderObject"/>
        <Parameter name="_topRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupBerth" id="ee71ae62-3140-4a1a-856c-e7b5fa55b7aa">
        <updating/>
        <source>setupBerth(_terminal : CM_Terminal; _row : Integer; _value : String) updating, protected;
// Berth combo
vars
	harbour		: HMS_Harbour;
	wharf		: HMS_Wharf;
	berth		: HMS_Berth;
	str			: String;
	
begin
	
	self.tblVoyTermDtl.accessCell(_row, 2).inputType := Table.InputType_ComboBox;

	harbour := _terminal.myHarbour;
	if harbour &lt;&gt; null then
		wharf := harbour.allWharves.first;
		if wharf &lt;&gt; null then
			foreach berth in wharf.allBerths do
				if str = null then
					str := Tab &amp; berth.code;	// 33265 add a null berth so can clear berth as well as set it
				else
					str := str &amp; Tab &amp; berth.code;
				endif;
			endforeach;
		endif;
	endif;
	self.tblVoyTermDtl.accessCell(_row, 2).comboList := str;
	
	if _value &lt;&gt; null then
		self.tblVoyTermDtl.accessCell(_row, 2).text := _value;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupDynaDict" id="35327f12-36e1-4ee9-a918-49390225e2df">
        <updating/>
        <source>setupDynaDict(_table : CM_DataTable; _clearFirst : Boolean) updating;
//--------------------------------------------------------------
//Created: 12 July 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

end;</source>
        <Parameter name="_table" type="CM_DataTable"/>
        <Parameter name="_clearFirst" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="aa10cb42-fead-4b45-9d7b-d0aea5ace8df">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     04 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();

	if (not app.myCurrentUserCan(self.myTerminal, self.permissionMaint)) then
		self.setMode(Mode_View_Only);
	endif;
		
	self.initTblOrderData();
	self.initTblsShipsideScan();
	self.initTblAdditionalInfo();
	self.initTblsAllocateRows();
	self.initTblsVoyage();
	self.initTblsVoyageAdmin();
	self.initTblsSuppliers();
	self.initTblsDetails();
	self.initTblAllocToDetail();
	self.initFldTreeView();

	self.beginClassNotification(Global, false, LogVoyageOps_Create_Event, Response_Continuous, null);
	self.beginClassNotification(Global, false, LogVoyageOps_Update_Event, Response_Continuous, null);
	self.beginClassNotification(Global, false, LogVoyageOps_Delete_Event, Response_Continuous, null);


	self.lstPorts.setFocus();
	self.setNavigatorHeading('Voyages');

	self.mnuLVOOptions.visible := false;
	
	// Par 10009
	self.shtSuppliers.caption := app.getTerminologyAlternate(app.myRoot.allCargoTypesById[TI_CargoType_Log], self.myTerminal,
																CM_TerminologyOperator, CM_TermExpressionPlural, 'Suppliers');
	self.shtListSuppliers.caption := self.shtSuppliers.caption;
	
	//Disabled at Alans request 24/9/02, till users more familiar with operation
	self.optSummary.enabled := false;
	self.setEnableObjects();	
	
	self.fldInfo.useSheetBackColors := true;
	self.fldInfo.setDefaultSheetBackColors();
	self.fldInfo.initSheetBackColors();
	self.fldSSSLoadOut.useSheetBackColors := true;
	self.fldSSSLoadOut.setDefaultSheetBackColors();
	self.fldSSSLoadOut.initSheetBackColors();
	self.fldTreeView.useSheetBackColors := true;
	self.fldTreeView.setDefaultSheetBackColors();
	self.fldTreeView.initSheetBackColors();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupSearchCriteria" id="6bda09bd-19b9-4d2d-a3c2-c16b26ce2fab">
        <source>setupSearchCriteria();
//--------------------------------------------------------------
//Created: 04 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	summary 			: CM_StockOrderSummary;
	productLog 			: CM_ProductLog;
	assist 				: LOG_Assistant;
	tmpCodeGroup		: CM_CodesByCodeDict;
	codeGrpLogType 		: CM_LogTypeByCodeDict;
	codeGrpTreatment	: CM_LogTreatmentsByCodeDict;
	codeGrpLength		: CM_LogLengthsByCode;	
begin
	if self.fldInfo.topSheet &lt;&gt; self.shtAllocateRows then
		return;
	endif;
	
	if self.myCurrentStockOrderSummary &lt;&gt; null then
		summary := self.myCurrentStockOrderSummary;
	elseif self.myCurrentStockOrderLine &lt;&gt; null then
		summary := self.myCurrentStockOrderLine.myStockOrderSummary;
	endif;
	
	if summary = null then
		return;
	else
		productLog := summary.myProduct.CM_ProductLog;
	endif;
	
	if productLog = null then
		return;
	endif;
	
	assist := self.myAssistant.LOG_Assistant;
//	assist.comboBoxOperator(self.cmbFilterOper, summary.myOperator, null);
	self.cmbFilterOper.setObject(summary.myOperator);
	cmbFilterOper.lostFocus(cmbFilterOper);

//	tmpCodeGroup := summary.myOperator.getAllLogSpecies();
//	cmbFilterSpecies.gotFocus(cmbFilterSpecies);
//	assist.comboBoxCodes(self.cmbFilterSpecies, productLog.myLogSpecies, tmpCodeGroup, false);
	self.cmbFilterSpecies.setObjectAndOperator(productLog.myLogSpecies, summary.myOperator);
	cmbFilterSpecies.lostFocus(cmbFilterSpecies);
	
//	tmpCodeGroup := productLog.myLogSpecies.allLogGrades;
//	cmbFilterGrade.gotFocus(cmbFilterGrade);		
//	assist.comboBoxCodes(self.cmbFilterGrade, productLog.myLogGrade, tmpCodeGroup, false);
	self.cmbFilterGrade.setObjectAndSpecies(productLog.myLogGrade,productLog.myLogSpecies);
	cmbFilterGrade.lostFocus(cmbFilterGrade);
	
//	codeGrpLogType := productLog.myLogGrade.allLogTypes;
//	assist.comboBoxLogType(self.cmbFilterType, productLog.myLogType, codeGrpLogType, false);
	self.cmbFilterType.setObjectAndGrade(productLog.myLogType, productLog.myLogGrade);
	cmbFilterType.lostFocus(cmbFilterType);
	
//	codeGrpTreatment := productLog.myLogGrade.allLogTreatments;
//	assist.comboBoxLogTreatment(self.cmbFilterTreat, productLog.myLogTreatment, codeGrpTreatment, false);
	self.cmbFilterTreat.setObjectAndGrade(productLog.myLogTreatment, productLog.myLogGrade);
	cmbFilterTreat.lostFocus(cmbFilterTreat);
	
//	codeGrpLength := productLog.myLogGrade.allLogLengths;
//	assist.comboBoxLogLength(self.cmbFilterLength, productLog.myLogLength, codeGrpLength, false);
	self.cmbFilterLength.setObjectAndGrade(productLog.myLogLength, productLog.myLogGrade);
	cmbFilterLength.lostFocus(cmbFilterLength);					
		
end;</source>
    </JadeMethod>
