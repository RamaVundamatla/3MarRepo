    <JadeMethod name="translateForm" id="31933bc2-6a40-472a-bd6b-6a80ba0b59e7">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017577, locale);
	btnPrint.translateCaption(Xlat_0005920, locale);
	btnReportOptions.translateBubbleHelp(Xlat_0005921, locale);
	btnReportOptions.translateCaption(Xlat_0005922, locale);
	frmReport.translateCaption(Xlat_0005923, locale);
	lblReport.translateCaption(Xlat_0005924, locale);
	mnuColOrganiser.translateCaption(Xlat_0005925, locale);
	mnuContext.translateCaption(Xlat_0005926, locale);
end;</source>
    </JadeMethod>
</GUIClass>
