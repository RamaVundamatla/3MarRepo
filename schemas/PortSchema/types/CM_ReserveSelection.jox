    <JadeMethod name="getStwHHCmbDetails37200" id="43706c7b-4ab3-457f-8b83-c84f6772ea0c">
        <source>getStwHHCmbDetails37200( _defColour : Integer; _colour : Integer output ): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2018	jlgndl1	Initial creation	TFS 38083 / 37200
19 Dec 2018	NDL	TFS 38083
*/

vars

	cargoGroupId : String;
	cargoId : String;
	retStr : String;
	workStr : String;
	lc : CM_LocationsController;
	isForBulk : Boolean;
	weightRequested : Decimal [16,4];
	weightReleased : Decimal [16,4];
	weightUnit : String;
	volumeUnit : String;
	unit : String;
	density : Decimal [16,4];
	qtyRequested : Integer;
	qtyReleased : Integer;
	cargoType : CM_CargoType;
	weightPacked : Decimal [16,4];
	qtyPacked : Integer;
	
	delReq : CM_Request;
	qtyActioned : Integer;
	weightActioned : Decimal [16,4];
	volumeActioned : Decimal [16,4];
	weightActionedString : String;

	qtyOutstanding : Integer;
	weightOutstanding : Decimal [16,4];
	weightOutstandingString : String;
	
begin

	cargoType := self.myCargoType;
	if cargoType = null then
		return null;
	endif;
	
	if cargoType &lt;&gt; null then
		isForBulk := cargoType.isBulkMulti;
		workStr := cargoType.abbreviation;
		if self.getProductCode &lt;&gt; null then
			workStr := workStr &amp; " / " &amp; self.getProductCode;
		endif;
		if workStr &lt;&gt; null then
			retStr := workStr;
			workStr := null;
		endif;
	endif;
	
	retStr := self.getTotalRequestedDisplay &amp; " x " &amp; retStr;	//	20 Feb 2017	NDL	TFS 3476
	
	cargoGroupId := self.getMyCargoGroupId;
	if cargoGroupId = null then
		cargoId := self.getMyCriteriaCargoId;
	endif;
	
	if cargoGroupId &lt;&gt; null then
		retStr := retStr &amp; ", " &amp; cargoGroupId;
	elseif cargoId &lt;&gt; null then
		retStr := retStr &amp; ", " &amp; cargoId;
	endif;

	//Quotes from TFS 38083 from Tomek in the Discussion section
	//- By 'No. of items actioned', we mean how many items of a Release Item are currently being actioned
	// at the Terminal = being requested to load or loaded on a Truck, or packed in a Container.
	foreach delReq in self.myReserveHeader.allRequestsBeingActioned do
		if delReq.isKindOf(CM_DeliveryRequest) then
			if delReq.myReserveDetail = self then
				if isForBulk then
					weightActioned := weightActioned + delReq.CM_DeliveryRequest.weightRequested;
				else
					qtyActioned := qtyActioned + delReq.CM_DeliveryRequest.totalRequested;
				endif;
			endif;
		endif;
	endforeach;
	
	//- By 'No. of items outstanding', we mean the number of Total Requested for a specific Release Item
	// minus (-) no. of items actioned or released.
	
	if isForBulk then
		weightReleased := self.getWeightReleased();
		weightRequested := self.weightSelection;
		weightOutstanding := weightRequested - ( weightReleased + weightActioned );
		
		if cargoType.isBulkByVolume then
			if cargoType &lt;&gt; null and cargoType.myVolumeMeasurementType &lt;&gt; null then
				volumeUnit := cargoType.myVolumeMeasurementType.shortName;
				unit := volumeUnit;
			endif;
			density := self.getDensity;
			volumeActioned := weightActioned / density;
			if volumeActioned = 0 then
				weightActionedString := "0";
			elseif volumeUnit &lt;&gt; null then
				weightActionedString := app.convertMeasurementForDisplay( volumeUnit, volumeActioned );
			else
				weightActionedString := weightActioned.Integer.String &amp; " " &amp; volumeUnit;
			endif;
		else
			if cargoType &lt;&gt; null and cargoType.myWeightMeasurementType &lt;&gt; null then
				weightUnit := cargoType.myWeightMeasurementType.shortName;
				unit := weightUnit;
			endif;
			if weightActioned = 0 then
				weightActionedString := "0";
			elseif weightUnit &lt;&gt; null then
				weightActionedString := app.convertMeasurementForDisplay( weightUnit, weightActioned );
			else
				weightActionedString := weightActioned.Integer.String &amp; " " &amp; weightUnit;
			endif;
		endif;
		
		retStr := retStr &amp; ", (" &amp; weightActionedString &amp; " " &amp; unit &amp; " " &amp; app.getErrorString(Actioned) &amp; ")";
		
	else
		qtyRequested := self.getTotalRequested;
		qtyReleased := self.getTotalReleased;
		qtyOutstanding := qtyRequested - ( qtyReleased + qtyActioned );
		
		retStr := retStr &amp; ", (" &amp; qtyActioned.String &amp; " " &amp; app.getErrorString(Actioned)&amp; ")";
		
	endif;
	
	if self.isPackingChild then
		weightPacked := self.getWeightPacked();
		if isForBulk then
			weightOutstanding := weightRequested - ( weightPacked + weightActioned );
			weightOutstandingString := cargoType.getBulkTrackByDisplayForWeight(weightPacked,self.getDensity,true);
			retStr := retStr &amp; " (" &amp; weightOutstandingString &amp; " " &amp; app.getErrorString(Outstanding)&amp; ")";
		else
			qtyPacked := self.getTotalPacked;
			qtyOutstanding := qtyRequested - ( qtyPacked + qtyActioned );
			retStr := retStr &amp; " (" &amp; qtyOutstanding.String &amp; " " &amp; app.getErrorString(Outstanding)&amp; ")";
		endif;
	elseif self.myReserveHeader.isPackingType and self.isPackingParent then
		//??
	else
		if isForBulk then
			if cargoType &lt;&gt; null and cargoType.isBulkMulti then
				weightOutstandingString := cargoType.getBulkTrackByDisplayForWeight(weightOutstanding,self.getDensity,true); 
			else
				weightOutstandingString :=  weightOutstanding.asStringJMT;
			endif;	
			retStr := retStr &amp; " (" &amp; weightOutstandingString &amp; " " &amp; app.getErrorString(Outstanding)&amp; ")";
		else
			retStr := retStr &amp; " (" &amp; qtyOutstanding.String &amp; " " &amp; app.getErrorString(Outstanding)&amp; ")";
		endif;
	endif;
	
	
	//15 Jan 2019	NDL	TFS 42906
	//count of released
	if not self.myReserveHeader.isPackingType then
		retStr := retStr &amp; " (" &amp; self.getTotalReleasedDisplay() &amp; " "&amp; app.getErrorString(ReleasedStr) &amp; ")";
	endif;
	
	
	//- For the colour rules I would suggest to adjust them a little bit.
	//We should keep the Red marking for a Release Item fully Released (Qty requested = Qty released),
	//but change the Grey one or introduce a new colour (like Blue) for Release Item that is Actioned (Qty actioned &lt;= Qty requested)."
	
	_colour := _defColour; // default colour for background
	if isForBulk then
		if self.isPackingChild then
			if weightRequested = weightPacked then
				_colour := Red;
			elseif weightActioned &gt; 0 and weightActioned &lt;= weightRequested then
				_colour := LightBlue;	
			endif;
		elseif self.myReserveHeader.isPackingType and self.isPackingParent then
			//??
		else
			if weightRequested = weightReleased then
				_colour := Red;
			elseif weightActioned &gt; 0 and weightActioned &lt;= weightRequested then
				_colour := LightBlue;	
			endif;
		endif;
	else
		if self.isPackingChild then
			if qtyRequested = qtyPacked then
				_colour := Red;
			elseif qtyActioned &gt; 0 and qtyActioned &lt;= qtyRequested then
				_colour := LightBlue;	
			endif;
		elseif self.myReserveHeader.isPackingType and self.isPackingParent then
			//??
		else
			if qtyRequested = qtyReleased then
				_colour := Red;
			elseif qtyActioned &gt; 0 and qtyActioned &lt;= qtyRequested then
				_colour := LightBlue;	
			endif;
		endif;
	endif;
	
	return retStr;

epilog

end;</source>
        <Parameter name="_defColour" type="Integer"/>
        <Parameter name="_colour" type="Integer" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStwHHHDetailsView2" id="3a6a61cb-9a6e-49ff-b289-75fa800ed973">
        <source>getStwHHHDetailsView2( _vehicle : CM_Vehicle; _cont : CM_Container ): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2018	jlgndl1	Initial creation

*/

vars

	cargoGroupId : String;
	cargoId : String;
	retStr : String;
	workStr : String;
	lc : CM_LocationsController;
	isForBulk : Boolean;
	cargoType : CM_CargoType;
	term : CM_Terminal;
	allTis : CM_TISet;
	allCgs : CM_TISet;
	allLoadedOrPackedTis : CM_TISet;
	allCountedTis : CM_TISet;
	startObj : CM_TrackedItem;
	iter : Iterator;
	ti : CM_TrackedItem;
	key : String;
	totalQty : Integer;
	totalWeight : Decimal [16,4];
	roadJob : CM_Job;
	wle : CM_WorkListEntry;
	req : CM_Request;
	reqQty : Integer;
	reqWeight : Decimal [16,4];
	localType : String;

begin

	term := self.myReserveHeader.myTerminal;

	//Cargo Type
	cargoType := self.myCargoType;
	if cargoType = null then
		return null;
	endif;
	
	if cargoType &lt;&gt; null then
		isForBulk := cargoType.isBulkMulti;
		workStr := cargoType.abbreviation;
		if self.getProductCode &lt;&gt; null then
			workStr := workStr &amp; " / " &amp; self.getProductCode;
		endif;
		if workStr &lt;&gt; null then
			retStr := workStr;
			workStr := null;
		endif;
	endif;
	
	//Extra criteria - either cargo id or cargo group id from extra criteria
	cargoGroupId := self.getMyCargoGroupId;
	if cargoGroupId = null then
		cargoId := self.getMyCriteriaCargoId;
	endif;
	
	if cargoGroupId &lt;&gt; null then
		retStr := retStr &amp; ", " &amp; cargoGroupId &amp; ", ";
		key := cargoGroupId;
		startObj := term.allCargoGroupsByIdCargoType.getAtKeyGeq( key, null);
		if startObj &lt;&gt; null then
			iter := term.allCargoGroupsByIdCargoType.createIterator;
			iter.startAtObject( startObj );
		endif;
	elseif cargoId &lt;&gt; null then
		retStr := retStr &amp; ", " &amp; cargoId &amp; ", ";
		key := cargoId;
		startObj := term.allOnsiteTIsByIdCargoType.getAtKeyGeq( key, null);
		if startObj &lt;&gt; null then
			iter := term.allOnsiteTIsByIdCargoType.createIterator;
			iter.startAtObject( startObj );
		endif;
	endif;
	
	//matching location(s) and quantities in each
	
	create allTis transient;
	create allCgs transient;
	
	if iter &lt;&gt; null then
		while iter.next( ti ) do
			if ti.id &lt;&gt; key then
				break;
			endif;
			if ti.isCargoGroupItem then
				if ti.CM_CargoGroup.getCargoGroupCargoType = cargoType then
					//collection of matching cargo groups with items on them
					allCgs.add( ti );
				endif;
				
			elseif cargoType = ti.myCargoType then
				//collection of matching tis
				allTis.add( ti );
			endif;
		endwhile;
		
		if not allCgs.isEmpty then
			// we have a collection of cargo groups, but only want the on-site ti's assigned to these. 
			foreach ti in allCgs do
				ti.CM_CargoGroup.getOnsiteAssignedCargo( allTis, false );
			endforeach;
		endif;
		
	endif;
	
	//separate any that are already packed or already on a truck
	create allCountedTis transient;
	create allLoadedOrPackedTis transient;
	foreach ti in allTis do
		if ti.isChild then
			allLoadedOrPackedTis.add( ti );
		elseif ti.myPrimaryActualLocation &lt;&gt; null and ( ti.myPrimaryActualLocation.isVehicle or ti.myPrimaryActualLocation.isTILCController )then
			allLoadedOrPackedTis.add( ti );
		endif;
	endforeach;
	foreach ti in allLoadedOrPackedTis do
		//remove them from the master collection
		allTis.remove( ti );
	endforeach;
	
	if not allTis.isEmpty then
		while not allTis.isEmpty do
			delete iter;
			iter := allTis.createIterator;
			while iter.next( ti ) do
				if ti.myPrimaryActualLocation = null then
					allCountedTis.add( ti );
				endif;
				if lc = null then
					lc := ti.myPrimaryActualLocation;
				endif;
				if ti.myPrimaryActualLocation = lc then
					allCountedTis.add( ti );
					totalQty := totalQty + ti.totalQuantity.max(1);
					totalWeight := totalWeight + ti.totalWeight;
				endif;
			endwhile;
			if lc &lt;&gt; null then
				workStr := lc.getFullId;
				if isForBulk then
					workStr := workStr &amp; "(" &amp; cargoType.getBulkTrackByDisplayForWeight(totalWeight,self.getDensity,true) &amp; ") ";
				else
					workStr := workStr &amp; "(" &amp; totalQty.String &amp; ") ";
				endif;
				retStr := retStr &amp; workStr;
				lc := null;
			endif;
			if not allCountedTis.isEmpty then
				foreach ti in allCountedTis do
					//remove them from the master collection
					allTis.remove( ti );
				endforeach;
				allCountedTis.clear();
			endif;
			if allTis.isEmpty then
				break;
			endif;
		endwhile;
		if workStr &lt;&gt; null then
			retStr := retStr &amp; ",";
		endif;
	endif;
	
	
	//count of loaded or packed.
	totalQty := 0;
	totalWeight := 0;
	if _vehicle &lt;&gt; null then
	
		roadJob := _vehicle.allRoadJobs.first;	
		if roadJob &lt;&gt; null then
			foreach wle in roadJob.workListEntries do
				if wle.myRequest &lt;&gt; null and wle.myRequest.myReserveDetail = self then
					reqQty := reqQty + wle.quantity.max(1);	//20 May 2015	NDL	Par 36127
					reqWeight := reqWeight + wle.weight;
				endif;
			endforeach;
		endif;
	
		foreach ti in allLoadedOrPackedTis do
			if _cont &lt;&gt; null and ti.myParent = _cont then
				totalQty := totalQty + ti.totalQuantity.max(1);
				totalWeight := totalWeight + ti.totalWeight;
				continue;
			endif;
			if ti.myPrimaryActualLocation = null then
				continue;
			endif;
			if ti.myPrimaryActualLocation.isVehicle and ti.myPrimaryActualLocation.CM_VehicleController.vehicle = _vehicle then
				totalQty := totalQty + ti.totalQuantity.max(1);
				totalWeight := totalWeight + ti.totalWeight;
				continue;
			elseif ti.myPrimaryActualLocation.isTILCController and ti.myPrimaryActualLocation.CM_TILCController.getVehicle = _vehicle then
				totalQty := totalQty + ti.totalQuantity.max(1);
				totalWeight := totalWeight + ti.totalWeight;
				continue;
			endif;
		endforeach;
	elseif _cont &lt;&gt; null then
		foreach ti in allLoadedOrPackedTis do
			if ti.myParent &lt;&gt; null
			and ti.myParent = _cont
			then
				totalQty := totalQty + ti.totalQuantity.max(1);
				totalWeight := totalWeight + ti.totalWeight;
				continue;
			endif;
		endforeach;
	endif;
	
	if self.isPackingChild then
		if isForBulk then
			reqWeight := self.weightRequested;	//12 Nov 2018	NDL	TFS 38083
			retStr := retStr &amp; " (" &amp;  cargoType.getBulkTrackByDisplayForWeight(totalWeight,self.getDensity,true)
			&amp; "/" &amp;  cargoType.getBulkTrackByDisplayForWeight(reqWeight,self.getDensity,true)
			&amp; " " &amp; app.getErrorString(Packed)&amp; ")";
		else
			reqQty := self.totalRequested;	//12 Nov 2018	NDL	TFS 38083
			retStr := retStr &amp; " (" &amp; totalQty.String
			&amp; "/" &amp; reqQty.String
			&amp; " " &amp; app.getErrorString(Packed)&amp; ")";
		endif;
	elseif self.myReserveHeader.isPackingType and self.isPackingParent then
		//??
	else
		localType :=  app.getErrorString(Loaded);
		if _cont &lt;&gt; null then
			localType :=  app.getErrorString(Packed);
		endif;
		if isForBulk then
			retStr := retStr &amp; " (" &amp; cargoType.getBulkTrackByDisplayForWeight(totalWeight,self.getDensity,true)
			&amp; "/" &amp;  cargoType.getBulkTrackByDisplayForWeight(reqWeight,self.getDensity,true)
			&amp; " " &amp; localType &amp; ")";
		else
			retStr := retStr &amp; " (" &amp; totalQty.String
			&amp; "/" &amp; reqQty.String
			&amp; " " &amp;localType &amp; ")";
		endif;
		
	endif;
	
	return retStr;

epilog

	delete allTis;
	delete allCgs;
	delete allCountedTis;
	delete allLoadedOrPackedTis;
	delete iter;

end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
        <Parameter name="_cont" type="CM_Container"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStwHandHeldCmbDetails" id="5ab7bf09-c28f-4678-9af0-cad5d5eb488a">
        <source>getStwHandHeldCmbDetails( _changeColour : Boolean output ): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2016	cnwndl1	Initial creation	3037/2369

*/

vars

	cargoGroupId : String;
	cargoId : String;
	retStr : String;
	workStr : String;
	lc : CM_LocationsController;
	isForBulk : Boolean;
	weightRequested : Decimal [16,4];
	weightReleased : Decimal [16,4];
	weightStaged : Decimal [16,4];
	volumeStaged : Decimal [16,4];
	weightUnit : String;
	volumeUnit : String;
	unit : String;
	weightStagedString : String;
	density : Decimal [16,4];
	qtyRequested : Integer;
	qtyReleased : Integer;
	qtyStaged : Integer;
	cargoType : CM_CargoType;
	weightPacked : Decimal [16,4];
	qtyPacked : Integer;
	packedStr: String;

begin

	cargoType := self.myCargoType;
	if cargoType = null then
		return null;
	endif;
	
	if cargoType &lt;&gt; null then
		isForBulk := cargoType.isBulkMulti;
		workStr := cargoType.abbreviation;
		if self.getProductCode &lt;&gt; null then
			workStr := workStr &amp; " / " &amp; self.getProductCode;
		endif;
		if workStr &lt;&gt; null then
			retStr := workStr;
			workStr := null;
		endif;
	endif;
	
	retStr := self.getTotalRequestedDisplay &amp; " x " &amp; retStr;	//	20 Feb 2017	NDL	TFS 3476
	
	cargoGroupId := self.getMyCargoGroupId;
	if cargoGroupId = null then
		cargoId := self.getMyCriteriaCargoId;
	endif;
	
	if cargoGroupId &lt;&gt; null then
		retStr := retStr &amp; ", " &amp; cargoGroupId;
	elseif cargoId &lt;&gt; null then
		retStr := retStr &amp; ", " &amp; cargoId;
	endif;
/*	
	if self.isPackingChild then
		weightPacked := self.getWeightPacked();
		if isForBulk then
			packedStr := cargoType.getBulkTrackByDisplayForWeight(weightPacked,self.getDensity,true);
			retStr := retStr &amp; ", (" &amp; packedStr &amp; " " &amp; app.getErrorString(Packed)&amp; ")";
		else
			qtyPacked := self.getTotalPacked;
			retStr := retStr &amp; ", (" &amp; qtyPacked.String &amp; " " &amp; app.getErrorString(Packed)&amp; ")";
		endif;
	elseif self.myReserveHeader.isPackingType and self.isPackingParent then
		//??
	else
		retStr := retStr &amp; ", (" &amp; self.getTotalLoadedDisplay &amp; " " &amp; app.getErrorString(Loaded)&amp; ")";	//06 Mar 2017	NDL	TFS 3477
		retStr := retStr &amp; " (" &amp; self.getTotalReleasedDisplay &amp; " " &amp; app.getErrorString(ReleasedStr)&amp; ")";
	endif;
*/	
	if isForBulk then
		weightReleased := self.getWeightReleased();
		weightRequested := self.weightSelection;
		weightStaged := self.getWeightStaged;
		
		if cargoType.isBulkByVolume then
			if cargoType &lt;&gt; null and cargoType.myVolumeMeasurementType &lt;&gt; null then
				volumeUnit := cargoType.myVolumeMeasurementType.shortName;
				unit := volumeUnit;
			endif;
			density := self.getDensity;
			volumeStaged := weightStaged / density;
			if volumeStaged = 0 then
				weightStagedString := "0";
			elseif volumeUnit &lt;&gt; null then
				weightStagedString := app.convertMeasurementForDisplay( volumeUnit, volumeStaged );
			else
				weightStagedString := weightStaged.Integer.String &amp; " " &amp; volumeUnit;
			endif;
		else
			if cargoType &lt;&gt; null and cargoType.myWeightMeasurementType &lt;&gt; null then
				weightUnit := cargoType.myWeightMeasurementType.shortName;
				unit := weightUnit;
			endif;
			if weightStaged = 0 then
				weightStagedString := "0";
			elseif weightUnit &lt;&gt; null then
				weightStagedString := app.convertMeasurementForDisplay( weightUnit, weightStaged );
			else
				weightStagedString := weightStaged.Integer.String &amp; " " &amp; weightUnit;
			endif;
		endif;
		
		retStr := retStr &amp; ", (" &amp; weightStagedString &amp; " " &amp; unit &amp; " " &amp; app.getErrorString(CM_Staged) &amp; ")";
		
		if self.isPackingChild then
			_changeColour := ( weightPacked + weightStaged &gt;= weightRequested );
		else
			_changeColour := ( weightReleased + weightStaged &gt;= weightRequested );
		endif;
		
	else
		qtyRequested := self.getTotalRequested;
		qtyReleased := self.getTotalReleased;
		qtyStaged := self.getTotalStaged(null,lc,null);
		
		retStr := retStr &amp; ", (" &amp; qtyStaged.String &amp; " " &amp; app.getErrorString(CM_Staged)&amp; ")";
		
		if self.isPackingChild then
			_changeColour := ( qtyPacked + qtyStaged &gt;= qtyRequested );
		else
			_changeColour := ( qtyReleased + qtyStaged &gt;= qtyRequested );
		endif;
		
	endif;
	
	if self.isPackingChild then
		weightPacked := self.getWeightPacked();
		if isForBulk then
			packedStr := cargoType.getBulkTrackByDisplayForWeight(weightPacked,self.getDensity,true);
			retStr := retStr &amp; " (" &amp; packedStr &amp; " " &amp; app.getErrorString(Packed)&amp; ")";
		else
			qtyPacked := self.getTotalPacked;
			retStr := retStr &amp; " (" &amp; qtyPacked.String &amp; " " &amp; app.getErrorString(Packed)&amp; ")";
		endif;
	elseif self.myReserveHeader.isPackingType and self.isPackingParent then
		//??
	else
		retStr := retStr &amp; " (" &amp; self.getTotalLoadedDisplay &amp; " " &amp; app.getErrorString(Loaded)&amp; ")";	//06 Mar 2017	NDL	TFS 3477
		retStr := retStr &amp; " (" &amp; self.getTotalReleasedDisplay &amp; " " &amp; app.getErrorString(ReleasedStr)&amp; ")";
	endif;
	
	
	return retStr;

epilog

end;</source>
        <Parameter name="_changeColour" type="Boolean" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStwHandHeldDetails" id="c140ba92-157b-4454-941f-4b95da250783">
        <source>getStwHandHeldDetails(  _isSTWComplete : Boolean output ): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 October 2015	cnwndl1	Initial creation	Par 37033

*/

vars

	cargoGroupId : String;
	retStr : String;
	workStr : String;
	lc : CM_LocationsController;
	isForBulk : Boolean;
	weightStaged : Decimal [16,4];
	volumeStaged : Decimal [16,4];
	weightUnit : String;
	volumeUnit : String;
	weightStagedString : String;
	density : Decimal [16,4];
	weightRequested : Decimal [16,4];
	weightReleased : Decimal [16,4];
	qtyRequested : Integer;
	qtyReleased : Integer;
	qtyStaged : Integer;
	cargoId : String;

begin
	
	if self.myCargoType &lt;&gt; null then
		isForBulk := self.myCargoType.isBulkMulti;
		workStr := self.myCargoType.abbreviation;
		if self.getProductCode &lt;&gt; null then
			workStr := workStr &amp; " / " &amp; self.getProductCode;
		endif;
		if workStr &lt;&gt; null then
			retStr := workStr;
			workStr := null;
		endif;
	endif;
	
	cargoGroupId := self.getMyCargoGroupId;
	if cargoGroupId = null then
		cargoId := self.getMyCriteriaCargoId;
	endif;
	
	if cargoGroupId &lt;&gt; null then
		retStr := retStr &amp; ", " &amp; cargoGroupId;
	elseif cargoId &lt;&gt; null then
		retStr := retStr &amp; ", " &amp; cargoId;
	endif;
	
	if self.isPackingChild then
		if self.isFullyPacked then
			retStr := retStr &amp; " - ";
			return app.getErrorString1(Fully_packed, retStr);
		endif;
	elseif self.myReserveHeader.isPackingType and self.isPackingParent then
		//??
	else
		if self.isFullyLoaded then
			retStr := retStr &amp; " - ";
			return app.getErrorString1(Fully_loaded, retStr);
		endif;
	endif;
	
	if isForBulk then	//10 Dec 2015	NDL	Par 37288
		
		weightReleased := self.getWeightReleased();
		weightRequested := self.weightSelection;
		weightStaged := self.getWeightStaged;
		
		if self.myCargoType.isBulkByVolume then
			if self.myCargoType &lt;&gt; null and self.myCargoType.myVolumeMeasurementType &lt;&gt; null then
				volumeUnit := self.myCargoType.myVolumeMeasurementType.shortName;
			endif;
			density := self.getDensity;
			volumeStaged := weightStaged / self.getDensity;
			if volumeStaged = 0 then
				weightStagedString := "0";
			elseif volumeUnit &lt;&gt; null then
				weightStagedString := app.convertMeasurementForDisplay( volumeUnit, volumeStaged );
			else
				weightStagedString := weightStaged.Integer.String;
			endif;
			retStr := retStr &amp; ", " &amp; weightStagedString &amp; "/" &amp; self.getTotalOutstandingDisplay;
		else
			if self.myCargoType &lt;&gt; null and self.myCargoType.myWeightMeasurementType &lt;&gt; null then
				weightUnit := self.myCargoType.myWeightMeasurementType.shortName;
			endif;
			weightStaged := self.getWeightStaged;
			if weightStaged = 0 then
				weightStagedString := "0";
			elseif weightUnit &lt;&gt; null then
				weightStagedString := app.convertMeasurementForDisplay( weightUnit, weightStaged );
			else
				weightStagedString := weightStaged.Integer.String;
			endif;
			retStr := retStr &amp; ", " &amp; weightStagedString &amp; "/" &amp; self.getTotalOutstandingDisplay;
		endif;
		
		_isSTWComplete := ( weightReleased + weightStaged &gt;= weightRequested );
		
	else
		qtyRequested := self.getTotalRequested;
		qtyReleased := self.getTotalReleased;
		qtyStaged := self.getTotalStaged(null,lc,null);
		
		retStr := retStr &amp; ", " &amp; app.getErrorString1(RackItems,  qtyStaged.String &amp; "/" &amp; self.getTotalOutstanding.String );
		
		_isSTWComplete := ( qtyReleased + qtyStaged &gt;= qtyRequested );
		
	endif;
	
	retStr := retStr &amp; " " &amp; app.getErrorString(Staged);
	
	if self.myReserveDetailActions &lt;&gt; null then
		if self.myReserveDetailActions.hasActions then
			retStr := retStr &amp; " " &amp; self.myReserveDetailActions.getActionsSummary(true);
		endif;
	endif;
	
	return retStr;

epilog

end;</source>
        <Parameter name="_isSTWComplete" type="Boolean" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTerminalArea" id="f2ca26fc-d242-418a-a134-fc8da419de4e">
        <source>getTerminalArea() :CM_TAByIdDict ;
//getTerminalArea() : CM_TerminalArea;
// 17/03/2010	cnwjre1	CCMS 1101 + 22634
//01/07/2015	cnwma1	PAR #36555 CCMS 2509 TFS - Multi-location selection for MTs for vessel release
vars
	//ta	: CM_TerminalArea;
	tas		: CM_TAByIdDict;  // 01/07/2015 cnwma1 PAR #36555
begin
	
	if self.allTerminalAreas &lt;&gt; null and  // 01/07/2015 cnwma1 PAR #36555
	   self.allTerminalAreas.size &gt; 0 then
		tas := self.allTerminalAreas;
	endif;
	return tas;
	
	/*if self.allTerminalAreas &lt;&gt; null and
	   self.allTerminalAreas.size &gt; 0 then
		ta := self.allTerminalAreas.first;
	endif;
	return ta;*/
end;
</source>
        <ReturnType type="CM_TAByIdDict"/>
    </JadeMethod>
    <JadeMethod name="getTerminalAreaId" id="51e848ad-9c3e-43ab-8fc1-303c33134ad2">
        <source>getTerminalAreaId() : String;
// 15/02/2010	cnwjre1	CCMS 1101 
vars
	id	: String;
	ta	: CM_TerminalArea;
begin
	if self.allTerminalAreas &lt;&gt; null and
	   self.allTerminalAreas.size &gt; 0 then
		ta := self.allTerminalAreas.first;
		id := ta.id;
	endif;
	return id;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTerminalAreas" id="97f6ddee-3965-428a-acba-95500591d4f9">
        <source>getTerminalAreas() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 January 2017	cnwrh7	Initial creation TFS2929

*/

vars
	strId			:  String;
	termArea : CM_TerminalArea;
begin
	if self.allTerminalAreas = null then
		return null;
	endif;
	foreach termArea in self.allTerminalAreas discreteLock where app.isValidObject(termArea) do
		if strId = "" then
			strId := termArea.id;
		else
			strId := strId &amp; "," &amp; termArea.id ;
		endif;
	endforeach;
	return strId;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTi" id="510bb877-a526-4956-9f1d-a82005ff5154">
        <source>getTi():CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 July 2022	navtnr20	ChangeRequest 54279: EUP - Extra Fields in the Road Gate Picker Screen
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars
	ti			: CM_TrackedItem;
begin
	
	//ti := self.allTrackedItems.first;
	ti := self.getFirstTI(false); //23/06/2023	navkc1	CR 58406 Task 58408
	if ti = null then
		ti := self.allTrackedItemsReleased.first;
	endif;
	
	return ti;

end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getTotalAssignedInLocation" id="911b7378-801b-4e96-bc4b-6725e15698ad">
        <source>getTotalAssignedInLocation( _lc : CM_LocationsController ):Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Dec 2015	cnwndl1	Initial creation	Par 37288
23 Jun 2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
25 Mar 2024 navma1	ChangeRequest 63141: MTN - Code Refactor to improve finding matching cargo items using reserve details
*/

vars

	ti      : CM_TrackedItem;
	count   : Integer;
	wagon   : CM_Wagon;
	allTis	: CM_TISet; 
	lc		: CM_LocationsController;
begin
	if _lc = null then
		return 0;
	endif;
	
	create allTis transient;							 //23/06/2023	navkc1	CR 58406 Task 58408
	self.getAllTrackedItems(allTis, false);
	if _lc.isWagon then									//19 Jan 2017	NDL	TFS 3198/2877
		wagon := _lc.CM_WagonController.myWagon;
		if wagon &lt;&gt; null then
			
			foreach ti in allTis do 					//23/06/2023	navkc1	CR 58406 Task 58408
				
				lc := ti.myPrimaryActualLocation;		//25.03.2024 navma1 #63141
				if lc = null or not lc.isWagon then
					continue;
				endif;
				if lc.CM_WagonController.myWagon &lt;&gt; wagon then
					continue;
				endif;
				count := count + ti.totalQuantity.max(1);
			endforeach;
		endif;
	
	else

		foreach ti in allTis do 							//23/06/2023	navkc1	CR 58406 Task 58408
			
			if ti.myPrimaryActualLocation &lt;&gt; _lc then
				continue;
			endif;
			count := count + ti.totalQuantity.max(1);
		endforeach;
	
	endif;
	
	return count;

epilog
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalLoaded" id="86670aaa-1e61-4f7a-a028-cede3c9ea833">
        <source>getTotalLoaded(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
06 March 2017	cnwndl1	Initial creation	TFS 3477
01 Mar 2018		NDL		TFS 37377 - Performance
14 Nov 2022		jlizm1	TFS 54118 Assigning Releases to Wagons
23/06/2023		navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
25 Mar 2024 	navma1	ChangeRequest 63141: MTN - Code Refactor to improve finding matching cargo items using reserve details
*/

vars

	ti 			: CM_TrackedItem;
	lc 			: CM_LocationsController;
	loadedCount : Integer;
	iter 		: Iterator;
	allTis		: CM_TISet; 
	bulkRelease : CM_BulkRelease;
begin
	create allTis transient; 							//23/06/2023	navkc1	CR 58406 Task 58408
	//	if self.myReserveHeader &lt;&gt; null then
	//	iter := self.myReserveHeader.allTrackedItemsAssigned.createIterator;
	self.getAllTrackedItems(allTis, false); 			//23/06/2023	navkc1	CR 58406 Task 58408
	//iter := self.allTrackedItems.createIterator;		//01 Mar 2018	NDL	TFS 37377
	iter := allTis.createIterator(); 					//23/06/2023	navkc1	CR 58406 Task 58408
	
	bulkRelease := self.myReserveHeader;				//25.03.2024 navma1 #63141
	
	while iter.next( ti ) do
		if not ti.isOnSite then
			continue;
		endif;
		if ti.isChild then
			continue;
		endif;
		if bulkRelease &lt;&gt; null and not bulkRelease.allTrackedItemsAssigned.includes( ti ) then		//25.03.2024 navma1 #63141
			continue;
		endif;
		
		lc := ti.myPrimaryActualLocation;															//25.03.2024 navma1 #63141
		
		if lc &lt;&gt; null then
			
			if lc.isVehicle or lc.isTILCController or lc.isWagon then
				loadedCount := loadedCount + ti.totalQuantity.max(1);
			endif;
		endif;
		
	endwhile;
//	endif;
	
	return loadedCount;

epilog
	
	delete iter;
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalStaged" id="f6fe09ca-8527-482e-9b4a-3568d74a59d9">
        <source>getTotalStaged( _tiSet : CM_TISet input; _firstStagingLC : CM_LocationsController output; _allStagingAreas : CM_LCSet input): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 October 2015	cnwndl1	Initial creation	Par 37033
01 Mar 2018	NDL		TFS 37377 - Performance
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items

*/

vars

	ti : CM_TrackedItem;
	ta : CM_TerminalArea;
	stagedCount : Integer;
	iter : Iterator;
	reason : String;
	lc : CM_LocationsController;
	allTis	: CM_TISet;
	
begin
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	//if self.myReserveHeader &lt;&gt; null then
	//	iter := self.myReserveHeader.allTrackedItemsAssigned.createIterator;
		self.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
		//iter := self.allTrackedItems.createIterator;	//01 Mar 2018	NDL	TFS 37377
		iter := allTis.createIterator;	//23/06/2023	navkc1	CR 58406 Task 58408
		while iter.next( ti ) do
			if not ti.isOnSite then
				continue;
			endif;
			if ti.isChild then
				continue;
			endif;
			//if not self.allTrackedItems.includes( ti ) then
			if self.myReserveHeader &lt;&gt; null and not self.myReserveHeader.allTrackedItemsAssigned.includes( ti ) then	//01 Mar 2018	NDL	TFS 37377
				continue;
			endif;
			lc := ti.myPrimaryActualLocation;	//05 May 2017	NDL	TFS 4016
			if lc &lt;&gt; null then
				ta := lc.myTerminalArea;
				if ta &lt;&gt; null then
					if ta.type = TA_TYPE_YARD_INTERCHANGE then
						// Its actually already staged
						if _firstStagingLC = null then
							_firstStagingLC := lc;
						endif;
						if _allStagingAreas &lt;&gt; null and not _allStagingAreas.includes( lc ) then	//05 May 2017	NDL	TFS 4016
							_allStagingAreas.add( lc );
						endif;
						if _tiSet &lt;&gt; null then
							if _tiSet &lt;&gt; null then
								if _tiSet.addNoDuplicates(ti,false) then
									stagedCount := stagedCount + ti.totalQuantity.max(1);
									continue;
								else
									continue;
								endif;
							endif;
							return 1;
						endif;
						stagedCount := stagedCount + ti.totalQuantity.max(1);
						continue;
					endif;
				endif;
			endif;
			
		endwhile;
	//endif;
	
	return stagedCount;

epilog
	
	delete iter;
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
        <Parameter name="_firstStagingLC" type="CM_LocationsController" usage="output"/>
        <Parameter name="_allStagingAreas" type="CM_LCSet" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalStagedOrSelected" id="07f23247-3b0c-4141-b1d6-55eb35ec8708">
        <source>getTotalStagedOrSelected(_totalCount: Integer output; _totalWeight: Decimal output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2021	jlier1	Initial creation 52626
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars
	ti : CM_TrackedItem;
	ta : CM_TerminalArea;
	stagedCount : Integer;
	iter : Iterator;
	reason : String;
	lc : CM_LocationsController;
	allTis : CM_TISet; 
begin
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	self.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
	//iter := self.allTrackedItems.createIterator;	//01 Mar 2018	NDL	TFS 37377
	iter := allTis.createIterator(); //23/06/2023	navkc1	CR 58406 Task 58408
	
	while iter.next( ti ) do
		if not ti.isOnSite then
			continue;
		endif;
		if ti.isChild then
			continue;
		endif;
		//if not self.allTrackedItems.includes( ti ) then
		if self.myReserveHeader &lt;&gt; null and not self.myReserveHeader.allTrackedItemsAssigned.includes( ti ) then	//01 Mar 2018	NDL	TFS 37377
			continue;
		endif;
		lc := ti.myPrimaryActualLocation;	//05 May 2017	NDL	TFS 4016
		if lc &lt;&gt; null then
			ta := lc.myTerminalArea;
			if ta &lt;&gt; null then
				if ta.type = TA_TYPE_YARD_INTERCHANGE then
					// Its actually already staged	
					_totalCount := _totalCount + ti.totalQuantity.max(1);
					_totalWeight := _totalWeight + ti.totalWeight;
					continue;
				endif;
			else
				if lc.isMachineController then
					_totalCount := _totalCount + ti.totalQuantity.max(1);
					_totalWeight := _totalWeight + ti.totalWeight;
				endif;
			endif;
		endif;
		
	endwhile;

epilog
	delete iter;
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <Parameter name="_totalCount" type="Integer" usage="output"/>
        <Parameter name="_totalWeight" type="Decimal" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getTrackedItems" id="19ae8fb9-671e-4144-91a1-c6dfacfafb5d">
        <source>getTrackedItems() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 January 2017	cnwrh7	Initial creation TFS2929
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars
	strId	:  String;
	ti			:  CM_TrackedItem;
	allTis	: CM_TISet; 
begin
	
	if self.allTrackedItems = null then
		return null;
	endif;
	
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	
	self.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
	
	//foreach ti in self.allTrackedItems  discreteLock do
	foreach ti in allTis discreteLock do //23/06/2023	navkc1	CR 58406 Task 58408
		if strId = "" then
			strId := ti.id ;
		else
			strId := strId &amp; "," &amp; ti.id ;
		endif;
	endforeach;
	return strId;
epilog
	delete allTis; 
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTrackedItemsReleased" id="76a06365-6010-43a3-ac28-0884688d922c">
        <source>getTrackedItemsReleased() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 January 2017	cnwrh7	Initial creation TFS2929

*/

vars
	strId	:  String;
	ti			:  CM_TrackedItem;
begin
		if self.allTrackedItemsReleased = null then
			return null;
		endif;
		foreach ti in self.allTrackedItemsReleased  discreteLock do 
			if strId = "" then
				strId := ti.id ;
			else
				strId := strId &amp; "," &amp; ti.id ;
			endif;
		endforeach;
		return strId;
epilog
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
