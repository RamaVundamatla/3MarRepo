    <JadeMethod name="getPlainManifestTitle" id="faa592a7-2b53-446e-94ce-769c7968e378">
        <source>getPlainManifestTitle() : String;
// --------------------------------------------------------------------------------
// Created:		5 November 2009 by cnwjo3
//
// Purpose:		Get a title for the Plain Manifest.  Use 'config' setting
//				MES 1013.  Note:  I don't like it here!
//
vars
	train : String;
	originPort : String;
	destinationPort : String;
	scheduleCode : String;
	
begin
	//PlainManifestTitleConstant
	train := self.code;
	
	if self.myOriginPort &lt;&gt; null then
		originPort := self.myOriginPort.code;
	else
		originPort := app.getErrorString(Unknown);
	endif;
	
	if self.myDestinationPort &lt;&gt; null then
		destinationPort := self.myDestinationPort.code;
	else
		destinationPort := app.getErrorString(Unknown);
	endif;
	
	if self.scheduleCode &lt;&gt; null then
		scheduleCode := self.scheduleCode;
	endif;
	
	return app.getErrorString3(PlainManifestTitleConstant,train,originPort,destinationPort);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPopulateListRakes" id="245d902c-a260-4148-8cee-afa3535d08b7">
        <source>getPopulateListRakes(inward : Boolean; allConfirmedTIs : CM_TIArray input; mtmConfirmedCargo : StringArray) : StringArray;
/*

Purpose:			
Retrieve summary detail for populating Rake List views (refactored to move
method MOB_HHRailAllRakesList.populateListRakes from MobileUISchema to this
schema to allow visiblity in the MTM apps)

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2017	cnwsc8	Initial creation

*/

vars
	allWagonsOnTrain : CM_WagonByIdDict;
	allUsedRailLines : CM_RailLineArray;
	wagonIter : Iterator;
	wagon : CM_Wagon;
	railLine : CM_RailLine;
	lineIter : Iterator;
	pos : Integer;
	wagonCount : Integer;
	itemCount : Integer;
	wagonCountChecked : Integer;
	itemCountChecked : Integer;
	wagonTis : CM_TIArray;
	ti : CM_TrackedItem;
	tiIter : Iterator;
	index : Integer;
	str : String;
	
	wagons : String;
	items : String;
	confirmed : Boolean;
	
	detail : String;
	response : StringArray;
	
begin
	create allUsedRailLines transient;
	if inward then
		allWagonsOnTrain := allWagonsByIdInward;
	else
		allWagonsOnTrain := allWagonsByIdOutward;
	endif;
	wagonIter := allWagonsOnTrain.createIterator;
	
	while wagonIter.next( wagon ) do
		railLine := wagon.myRailLine;
		if railLine &lt;&gt; null then
			if not allUsedRailLines.includes(railLine) then
				allUsedRailLines.add(railLine);
			endif;
		endif;
	endwhile;
	
	if allUsedRailLines.isEmpty then
		return null;
	endif;
	
	wagons := " " &amp; app.getErrorString(Wagons) &amp; ", ";
	items := " " &amp; app.getErrorString(Items);
	
	create response transient;
	create wagonTis transient;
	lineIter := allUsedRailLines.createIterator;
	while lineIter.next(railLine) do
		
		foreach pos in 1 to railLine.maximumWagons do
			wagon := railLine.getWagonAtPosition(pos);
			if wagon &lt;&gt; null then
		
				if inward then
					confirmed := wagon.confirmed;
				else
					confirmed := wagon.confirmedOutwards;
				endif;
			
				wagonCount := wagonCount + 1;
				wagonTis.clear;
				wagon.getAllTrackedItems(inward, wagonTis, false);
				if not wagonTis.isEmpty then
					itemCount := itemCount + wagonTis.size;
					tiIter := wagonTis.createIterator;
					while tiIter.next(ti) do
						if confirmed or (allConfirmedTIs &lt;&gt; null and allConfirmedTIs.includes(ti)) or (mtmConfirmedCargo &lt;&gt; null and mtmConfirmedCargo.includes(ti.getOidAsString()) )then
							itemCountChecked := itemCountChecked + 1;
						endif;
					endwhile;
					delete tiIter;
				endif;
				
				if confirmed then
					wagonCountChecked := wagonCountChecked + 1;
				endif;
				
			endif;
		endforeach;

		detail := railLine.getOidAsString() &amp; ";" &amp; wagonCount.String &amp; ";" &amp; itemCount.String &amp; ";" &amp; wagonCountChecked.String &amp; ";" &amp; itemCountChecked.String;
		response.add(detail);
		
		
		itemCount := 0;
		itemCountChecked := 0;
		wagonCount := 0;
		wagonCountChecked := 0;
		
	endwhile;
	
	return response;
epilog
	
	delete allUsedRailLines;
	delete wagonIter;
	delete lineIter;
	delete wagonTis;
	delete tiIter;

end;</source>
        <Parameter name="inward" type="Boolean"/>
        <Parameter name="allConfirmedTIs" type="CM_TIArray" usage="input"/>
        <Parameter name="mtmConfirmedCargo" type="StringArray"/>
        <ReturnType type="StringArray"/>
    </JadeMethod>
