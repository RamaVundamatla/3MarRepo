    </JadeMethod>
    <JadeMethod name="erase" id="2349280e-26fa-4144-9aab-8c38fdf8383a">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     20 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2010	cnwcs5		par 23859 - stop printer being deleted if it is in use at a gate lane
// ---------------------------------------------------------------------------
vars

begin
	if not self.allLaneDevices.isEmpty then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Printer is in use so cannot be deleted');
	endif;
	
	inheritMethod(_eraseLevel);

epilog

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="476cf299-d2bd-47f7-9db9-4f173b2020af">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     7 June 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------

vars
	txt		: String;
	tmpStr	: String;
	bgp    	: BGP_ReportController;
begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();
	return txt;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="48370027-2290-4f5d-9a68-59efd3ed47d2">
        <updating/>
        <source>setForCreate(_proxyPrinterDef : CM_PrinterDef) updating;

// cnwdvb1 22 April 2003 

vars

begin

	self.setForUpdate(_proxyPrinterDef);
	self.myRoot	:= _proxyPrinterDef.myRoot;

end;</source>
        <Parameter name="_proxyPrinterDef" type="CM_PrinterDef"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="7976d054-5e11-41d4-a95e-1ed4a4f10163">
        <updating/>
        <source>setForUpdate(_proxyPrinterDef : CM_PrinterDef) updating;

// cnwdvb1 22 April 2003 

vars

begin

	self.description			:= _proxyPrinterDef.description;
	self.logicalPrinterName		:= _proxyPrinterDef.logicalPrinterName;
	self.physicalPrinterName	:= _proxyPrinterDef.physicalPrinterName;
	self.printerIsPDF			:= _proxyPrinterDef.printerIsPDF;

end;</source>
        <Parameter name="_proxyPrinterDef" type="CM_PrinterDef"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="7f88e0c8-238e-4597-b52f-981044eb1933">
        <updating/>
        <source>setProxy(_description, _logicalPrinterName, _physicalPrinterName : String; _isPDFPrinter : Boolean) updating;

// cnwdvb1 22 April 2003 

vars

begin

	self.description 			:= _description;
	self.logicalPrinterName		:= _logicalPrinterName;
	self.physicalPrinterName	:= _physicalPrinterName;
	self.printerIsPDF			:= _isPDFPrinter;
	self.myRoot					:= app.myRoot;

end;</source>
        <Parameter name="_description" type="String"/>
        <Parameter name="_logicalPrinterName" type="String"/>
        <Parameter name="_physicalPrinterName" type="String"/>
        <Parameter name="_isPDFPrinter" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="08c76556-a291-4b35-9922-b25c27126829">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;

vars
	propName	: String;

begin

	propName := _property.name;
	if propName = CM_PrinterDef::myGateLaneController.name then
		return false;
	endif;
	
	return inheritMethod(_rootClass, _property);
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validate" id="b22331d7-c060-412b-a70c-322e9afa048c">
        <source>validate();

// cnwdvb1 23 April 2003 

vars

	local : Boolean;
	server : Boolean;

begin

	if self.logicalPrinterName = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'LogicalPrinterName', null, null);
		app.raiseCMException(Input_required_field_logPrntNm, null, null); // cnwdb2	PAR 35364

	// What about Win2PDF?
//	elseif self.logicalPrinterName.hasInvalidChars()then 
	//		app.raiseCMException1(ERR_INVALID_CHARACTERS, 'LogicalPrinterName ('&amp; self.logicalPrinterName &amp; ') ', null, null);
	endif;
	
	local := app.validatePrinterName( self.physicalPrinterName, false, true );
	server := app.validatePrinterName( self.physicalPrinterName, true, false );
	
	if not local and not server then
		app.raiseCMWarning1(Printer_not_known_anywhere, self.physicalPrinterName, "Physical Printer Name", null, null);
	elseif not server then
		app.raiseCMWarning1(Printer_local_NOT_server, self.physicalPrinterName, "Physical Printer Name", null, null);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateDelete" id="d941dc7d-2600-4700-8788-f8fad4ded4be">
        <source>validateDelete(_passport: CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     20 April 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if not self.allLaneDevices.isEmpty then
		app.raiseCMException2 (Lane_Device_Delete_Error, self.description, self.allLaneDevices.first.getLaneDescription, null, null);
	endif;
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="e49e2f9f-a6ad-499e-8d70-51cf94491ca9">
        <source>validateForCreate();

// cnwdvb1 24 April 2003 

vars

begin

	if self.myRoot.allPrinterDefsByLogicalName[self.logicalPrinterName] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.logicalPrinterName, null, null);
	endif;
	self.validate();

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="1ab0730e-9c4f-4a45-b688-f3d77f715cea">
        <source>validateForUpdate();

// cnwdvb1 24 April 2003 

vars

begin

	self.validate();

end;</source>
    </JadeMethod>
