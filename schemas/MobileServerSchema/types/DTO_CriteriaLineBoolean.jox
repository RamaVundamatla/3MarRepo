        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="putSearchingValue" id="0275360d-3404-49f9-8e1b-d1e731d4ab85">
        <source>putSearchingValue(_criteriaLine: CM_SelectorCriteriaLine input; _value: Any);
// -------------------------------------------------------------------------
// Created 08 may 2008 by cnwvu1
// -------------------------------------------------------------------------

vars

begin
	
	inheritMethod( _criteriaLine, _value );
	
end;
</source>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine" usage="input"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="putSearchingValuesFromRT" id="3f974f50-5137-4d64-a30c-2ce98c88342e">
        <source>putSearchingValuesFromRT( _criteriaLine : CM_SelectorCriteriaLine input );
// ----------------------------------------------------------------------
// Created 08 may 2008 by cnwvu1
//
// Purpose:	Puts searching values from DTO criteriaLine (RT screen)
//			 into criteriaLineLine for running a query
// ----------------------------------------------------------------------

vars

begin

	inheritMethod(_criteriaLine);
	self.putSearchingValue( _criteriaLine, self.searchValueBoolean );
	
end;
</source>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="e23a0ed8-dd2e-4c16-ba7a-03109b8a74a6">
        <updating/>
        <source>setForCreate( 	_labelCriteria, 
				_searchValueA, _searchValueB : String; _searchValueBoolean : Boolean;
				_myQueryCriteriaLineHolderRT : DTO_QueryCriteriaLineHolderRT;
				_propClassName, _propName, _queryOperatorOid : String ) updating;
// ----------------------------------------------------------------------------------
// Created 06 may 2008 by cnwvu1
// ----------------------------------------------------------------------------------

vars

begin
	
	inheritMethod(_labelCriteria, _searchValueA, _searchValueB, _searchValueBoolean, _myQueryCriteriaLineHolderRT, _propClassName, _propName, _queryOperatorOid);
	self.searchValueBoolean := _searchValueBoolean;
	
end;
</source>
        <Parameter name="_labelCriteria" type="String"/>
        <Parameter name="_searchValueA" type="String"/>
        <Parameter name="_searchValueB" type="String"/>
        <Parameter name="_searchValueBoolean" type="Boolean"/>
        <Parameter name="_myQueryCriteriaLineHolderRT" type="DTO_QueryCriteriaLineHolderRT"/>
        <Parameter name="_propClassName" type="String"/>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_queryOperatorOid" type="String"/>
    </JadeMethod>
