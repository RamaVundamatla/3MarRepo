    <JadeMethod name="btnCnEcCancel_click" id="4d054a18-a422-4a1b-9e3c-8653e1c468aa">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCnEcCancel_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		14 January 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.modalResult	:=	self.CNEC_MODAL_CANCEL;
	unloadForm();
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnCnEcOk_click" id="8a1ac55c-f3da-4439-9cd4-8a1ca1a07424">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCnEcOk_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		14 January 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.doFormUpdate(false) then
		unloadForm();
	endif;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnSetToday_click" id="8b468cda-450e-4443-b83f-254fdd57fa08">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSetToday_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// TFS2304 cnwns1	15/7/16	Multi-timezone issue - Date Picker defaults to System Date
// --------------------------------------------------------------------------------
vars
	dateToday	: Date;
	
begin
	dateToday := self.getToday(); // TFS2304 cnwns1	
	self.doResetDate(dateToday);
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="calSelect_click" id="fc8ddbc6-5116-4c66-a527-b0d31d3d5da1">
        <controlMethod name="BaseControl::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>calSelect_click(cntrl: CnEcCalendarControl input) updating;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 19/06/2003	cnwdad1		We want the user to be able to key in a new year, and
//							then click on another control and still have that year
//							recognized on the lostFocus event of the year control.
//							Because this click event occurs before the lostFocus
//							event, we need to pick up the year from that control
//							in this event.
// --------------------------------------------------------------------------------
vars
	selectedDate	: Date;
	
begin
	selectedDate	:=	cntrl.getSelectedDate();
	selectedDate.setDate(selectedDate.day, cmbMonth.itemData[cmbMonth.listIndex], txtYear.cnEcInteger());
	
//	self.doResetDate(cntrl.getSelectedDate());
	self.doResetDate(selectedDate);
	cntrl.setFocus();
end;</source>
        <Parameter name="cntrl" type="CnEcCalendarControl" usage="input"/>
    </JadeMethod>
    <JadeMethod name="calSelect_dblClick" id="4fb021a1-8326-4049-bd6e-3a9ec852c48c">
        <controlMethod name="BaseControl::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>calSelect_dblClick(cntrl: BaseControl input) updating;
// --------------------------------------------------------------------------------
// Created:		08 November 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.doFormUpdate(false) then
		unloadForm();
	endif;
end;</source>
        <Parameter name="cntrl" type="BaseControl" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbMonth_scrolled" id="4be02278-a28a-4ccc-99d3-d204cfb280aa">
        <controlMethod name="ComboBox::scrolled"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbMonth_scrolled(combobox: ComboBox input; scrollBar: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	oldDate	: Date;
	newDate	: Date;
	
begin
	oldDate	:=	calSelect.getSelectedDate();
	
	// Subtract the old month from the new month (yielding a +ve or -ve value)
	// and adjust the date accordingly.
	
	newDate	:=	oldDate.cnEcAddMonths(combobox.itemData[combobox.listIndex] - oldDate.month);
	self.doResetDate(newDate);
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="scrollBar" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="create" id="e95e1626-24e6-452d-976b-33ace7aa4bbf">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// TFS2304 cnwns1	15/7/16	Multi-timezone issue - Date Picker defaults to System Date
// --------------------------------------------------------------------------------
vars
	dateToday	: Date;
	
begin
	dateToday	:= app.actualTimeServer().date();	// TFS2304 cnwns1	
	self.setStartDate(dateToday);
end;</source>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="b6a58d08-b208-4d00-94c3-2d92d0214da2">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	allKeysArray	: CnEcKeyCodeArray;
	
begin
	inheritMethod();

	if self.aPositionLeft = 0 and self.aPositionTop = 0 then
		centreWindow();
	else
		self.move(self.aPositionLeft, self.aPositionTop, self.width, self.height);
	endif;		
	
	txtYear.setMinValue(1);
	txtYear.setMaxValue(9999);
	self.doInitializeDateInfo();
	
	create allKeysArray transient;
//	self.registerFormKeys(allKeysArray);
epilog
	delete allKeysArray;
	self.modalResult	:=	self.CNEC_MODAL_CANCEL;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormUpdate" id="eb059022-b5a4-46ec-a2cb-6b39b36dbb23">
        <updating/>
        <source>doFormUpdate(pIsDelete: Boolean): Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		08 November 2000 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aSelectedDate	:=	calSelect.getSelectedDate();
	self.modalResult	:=	self.CNEC_MODAL_SELECT;
epilog
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="pIsDelete" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doInitializeDateInfo" id="ce600f61-2144-4167-9c8c-359e525de5fc">
        <updating/>
        <source>doInitializeDateInfo() updating, protected;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Initialize the currently selected date details.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 19/06/2003	cnwdad1		The month combobox will now be populated in reverse
//							order so that when it's scrolled, it does so in the
//							same direction as the year scrollbox.
// --------------------------------------------------------------------------------
vars
	startDate		: Date;
	newEntryIndex	: Integer;
	monthIndex		: Integer;
	calendarObj		: CnEcCalendarControl;

begin
	startDate		:=	self.aStartDate;
	calendarObj		:=	calSelect;
	
	cmbMonth.clear;
	
//	foreach monthIndex in 1 to 12 do
	foreach monthIndex in 12 to 1 step -1 do
		newEntryIndex	:=	cmbMonth.addItem(("1/" &amp; monthIndex.String &amp; "/" &amp; startDate.year.String).Date.monthName);
		cmbMonth.itemData[newEntryIndex]	:=	monthIndex;
	endforeach;
	
	txtYear.setValue(startDate.year);
	cmbMonth.listIndex	:=	cmbMonth.findStringExact(1, startDate.monthName);
	calendarObj.setSelectedDate(startDate, true);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResetDate" id="1d8ebe0c-1e80-44de-ae9d-a82cd119843a">
        <updating/>
        <source>doResetDate(pDate:Date) updating, protected;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		This method will reset the calendar to the requested date.  Note
//				that if the newly requested date is outside of the date range that
//				was originally specified (i.e. for the Start Date and years either
//				side), then the Start Date will be reset to this specified date and
//				the calendar will be reinitialized based upon that new Start Date.
//
// Parameters:	pDate (Date) - The date to which the calendar will be set.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	cmbMonth.listIndex	:=	cmbMonth.findStringExact(1, pDate.monthName);
	txtYear.setValue(pDate.year);
	
	if cmbMonth.listIndex = CNEC_NULL_INDEX or txtYear.cnEcInteger() = 0 then
		self.setStartDate(pDate);
		self.doInitializeDateInfo();
		return;
	endif;
	
	calSelect.doClearHighlightedDays();
	calSelect.setSelectedDate(pDate, true);
	self.setStartDate(pDate);
end;</source>
        <access>protected</access>
        <Parameter name="pDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="getDate" id="32840bc5-54d7-441f-ab1f-b03092dcdb0e">
        <source>getDate():Date;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		Returns the date that was selected by the User.
//
// Parameters:	None
//
// Returns:		Date
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.aSelectedDate;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="getToday" id="a224514d-9fc7-4f1b-8f22-85c34ff8147d">
        <source>getToday():Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 July 2016	cnwns1	Initial creation
// TFS2304 cnwns1	15/7/16	Multi-timezone issue - Date Picker defaults to System Date

*/

vars

begin
	return app.actualTimeServer().date();
epilog

end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="setPosition" id="73596bb1-e29c-4a26-a58e-0e552ecd2cf6">
        <updating/>
        <source>setPosition(pPositionLeft:Integer; pPositionTop:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		08 November 2000 by cnwdad1
//
// Purpose:		Sets the (screen) position at which to display this form.  This is
//				intended for use by the CnEcDateBox control to display this form
//				next to the control when the User double-clicks it to pick a date.
//
//				NOTE: These attributes are only used by the form's "load" event.
//
// Parameters:	pPositionLeft (Integer) - The Left position on the screen.
//				pPositionTop (Integer) - The Teft position on the screen.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.aPositionLeft &lt;&gt; pPositionLeft then
		self.aPositionLeft	:=	pPositionLeft;
	endif;

	if self.aPositionTop &lt;&gt; pPositionTop then
		self.aPositionTop	:=	pPositionTop;
	endif;
end;</source>
        <Parameter name="pPositionLeft" type="Integer"/>
        <Parameter name="pPositionTop" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setStartDate" id="502eeb9e-adff-4f90-9d24-ad42df1105bf">
        <updating/>
        <source>setStartDate(pDate:Date) updating;
// --------------------------------------------------------------------------------
// Created:		07 November 2000 by cnwdad1
//
// Purpose:		This methods sets the default starting date for the select calendar.
//
// Parameters:	pDate - The new start date.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.aStartDate &lt;&gt; pDate then
		self.aStartDate	:=	pDate;
	endif;
end;</source>
        <Parameter name="pDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="txtYear_keyUp" id="d40d477a-9674-47af-90a8-83dd9d73640b">
        <controlMethod name="TextBox::keyUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtYear_keyUp(textbox: TextBox input; keyCode: Integer io; shift: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		19 June 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	enteredDate	: Date;
	
begin
	if keyCode = J_key_Return then
		enteredDate	:=	calSelect.getSelectedDate();
		
		enteredDate.setDate(enteredDate.day, enteredDate.month, textbox.cnEcInteger());
		self.doResetDate(enteredDate);
	endif;
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="txtYear_lostFocus" id="91856642-9ec7-4277-83c2-0b1f618153ea">
        <controlMethod name="CnEcTextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtYear_lostFocus(textbox: TextBox input) updating;
// --------------------------------------------------------------------------------
// Created:		19 June 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	enteredDate	: Date;
	
begin
	enteredDate	:=	calSelect.getSelectedDate();
	
	enteredDate.setDate(enteredDate.day, enteredDate.month, textbox.cnEcInteger());
	self.doResetDate(enteredDate);
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtYear_scrolled" id="f9de9054-d327-4e03-8632-8cf9eca5784d">
        <controlMethod name="CnEcScrollBox::scrolled"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtYear_scrolled(textbox: CnEcScrollBox input; scrollBar: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		04 December 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	oldDate	: Date;
	newDate	: Date;
	
begin
	oldDate	:=	calSelect.getSelectedDate();

	// Subtract the old year from the new year (yielding a +ve or -ve value)
	// and adjust the date accordingly.
	
	newDate	:=	oldDate.cnEcAddYears(textbox.cnEcInteger() - oldDate.year);
	self.doResetDate(newDate);
end;</source>
        <Parameter name="textbox" type="CnEcScrollBox" usage="input"/>
        <Parameter name="scrollBar" type="Integer"/>
    </JadeMethod>
</GUIClass>
