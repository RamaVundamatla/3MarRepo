    <JadeMethod name="getExportFileName" id="2fb817cb-46f2-4663-9b1b-25b182dbdbfa">
        <source>getExportFileName(_deck : CM_Deck) : String protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

	fileXML : CMDFileSave; 
	theFileName : String;
begin

	on FileException do app.fileExceptionHandler(exception);

	create fileXML;
	fileXML.filter:="XML (*.xml)|*.xml";
	
	fileXML.fileName := self.getROROStructureParentCode;
	if _deck &lt;&gt; null then
		fileXML.fileName:=fileXML.fileName	&amp; _deck.code &amp; ".xml";
	else
		fileXML.fileName:=fileXML.fileName	&amp; ".xml";
	endif;
	//open the file browser
	// 0 means user clicked the OK button
	if fileXML.open &lt;&gt; 0 then
		return null;
	endif;
	
	theFileName:= fileXML.fileName;
	
	if theFileName.length &lt; 4 or theFileName[(theFileName.length - 3):theFileName.length] &lt;&gt; ".xml" then
		theFileName:=theFileName &amp; ".xml";
	endif;
	
	
	return theFileName;

epilog
	delete fileXML;
end;</source>
        <access>protected</access>
        <Parameter name="_deck" type="CM_Deck"/>
        <ReturnType type="String"/>
    </JadeMethod>
