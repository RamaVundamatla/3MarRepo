    <JadeMethod name="utlCreateTITransaction" id="c52c5b68-5f40-446d-8dd5-1b9bf09576a6">
        <source>utlCreateTITransaction(_tiTransactionController:CMIF_TITransactionController input; 
				_newTITransaction:CM_TITransaction output; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theCloned : CM_TITransaction;
	theTI : CM_TrackedItem;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valTITransaction(_tiTransactionController);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	app.setContinueCMExceptions(false);

	theTI := _tiTransactionController.myTrackedItem;
	_newTITransaction := theTI.createTransaction(_tiTransactionController, _passport);
	
end;</source>
        <Parameter name="_tiTransactionController" type="CMIF_TITransactionController" usage="input"/>
