    <JadeMethod name="addWharfDrawControl" id="f6ee2b83-b5ed-4fe2-a48a-a57a56b9e78b">
        <updating/>
        <source>addWharfDrawControl(_wharfDrawControl : HMS_WharfDrawControl input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     29 October 2004 by cnwrs2
//
// Purpose:     Done this way as the Visible collection is an array so
//				need control order from this end.
// ---------------------------------------------------------------------------
vars

begin
	self.allWharfDrawControls.add(_wharfDrawControl);
	// At this stage hiding of wharf controls is not permitted so
	// no need to check visible status.
	// NOTE - use "insert" here as we are going through the dict in calling
	// method in reverse order =&gt; want to always insert at beginning of
	// the array
	self.allWharfDrawControlsVisible.insert(1, _wharfDrawControl);
end;</source>
        <access>protected</access>
        <Parameter name="_wharfDrawControl" type="HMS_WharfDrawControl" usage="input"/>
    </JadeMethod>
    <JadeMethod name="applyMovementChange" id="da7d6403-9bbe-4e43-84c6-da628fcad1b6">
        <updating/>
        <source>applyMovementChange(oldMovement : CMIF_HMS_WorkingMovement; newMovement : CMIF_HMS_WorkingMovement) updating;
//
// Changed On	By			Reason
// ----------	--------	------------------------------------------------------
// 10/02/2014	cnwdap1		PAR #33337 CCMS PTR 2214 HMS Enhancements
vars

begin

 	// part of the refresh call that is sent by the view controller	
	//self.setMyCurrentWorkingMovement(null);
	self.rebuildShips();

	if self.mySeaViewForm &lt;&gt; null then
		self.mySeaViewForm.applyMovementChange(oldMovement, newMovement);
	endif;

	if self.myVoyageList &lt;&gt; null then
		self.myVoyageList.applyMovementChange(oldMovement, newMovement);
	endif;

	if self.myMovementsTableForm &lt;&gt; null then
		self.myMovementsTableForm.applyMovementChange(oldMovement, newMovement);
	endif;			

	if self.myTidalSummaryForm &lt;&gt; null then
		self.myTidalSummaryForm.applyMovementChange(newMovement);
	endif;				
	
	if self.myTidalModelForm &lt;&gt; null then														// PAR #33337
		self.myTidalModelForm.handleNotificationRefreshView(null, newMovement, null, null);		// PAR #33337
	endif;																						// PAR #33337

end;</source>
        <Parameter name="oldMovement" type="CMIF_HMS_WorkingMovement"/>
        <Parameter name="newMovement" type="CMIF_HMS_WorkingMovement"/>
    </JadeMethod>
    <JadeMethod name="autoPositionOnBerth" id="ccfc4178-f007-4cf4-af53-20ac5988df7b">
        <updating/>
        <source>autoPositionOnBerth(berth : HMS_Berth):Boolean updating;

vars
	newCurrent,
	newNext,
	origCurrent,
	origNext			: CMIF_HMS_WorkingMovement;
	editMovementChange	: CMIF_HMS_MovementEdit;
	wp					: CMIF_HMS_WharfPosnCheckParams;
	cntrl				: Control;
	changeOK			: Boolean;
begin
	// check that the ship can be dropped onto the requested berth - provide the correct berth marks if ok, otherwise
	// don't allow the shift
	changeOK := false;

	cntrl := self.myCurrentDragPicture;
	origCurrent 	:= cntrl.DragPicture.myMovement;
	origNext		:= cntrl.DragPicture.myNextMovement;

	if origCurrent &lt;&gt; null then
		newCurrent := origCurrent.cloneSelf(true);
		newCurrent.myPersistentMovement	:=origCurrent.myPersistentMovement;
		newCurrent.myBerth				:=origCurrent.myBerth;
		newCurrent.myWorkingVoyage		:=origCurrent.myWorkingVoyage;
		newCurrent.myHarbour			:=origCurrent.myHarbour;
		newCurrent.notYetSaved			:=true;

		create wp transient;
		wp.berth:= berth;
		wp.myWorkingMovementToCheck:=newCurrent;
		wp.bowMark:=newCurrent.bowMarkTo;
		wp.sternMark:=newCurrent.sternMarkTo;
		wp.foreClearance:=newCurrent.foreClearanceTo;
		wp.aftClearance:=newCurrent.aftClearanceTo;
		wp.controller:=myViewController;
		wp.orientation:=newCurrent.sideTo;
		//wp.ship:=newCurrent.myWorkingVoyage.getMyVessel;
		wp.myHMSVoyageData:=newCurrent.myWorkingVoyage.myHMSVoyageData;		
		
		if newCurrent.berthing_AutoPositionOnBerth(wp) then
			changeOK := true;			
			newCurrent.myBerth 			:= wp.berth;
			newCurrent.bowMarkTo 		:= wp.bowMark;
			newCurrent.sternMarkTo		:= wp.sternMark;
			newCurrent.foreClearanceTo	:= wp.foreClearance;
			newCurrent.aftClearanceTo	:= wp.aftClearance;
			newCurrent.sideTo			:= wp.orientation; 
		endif;

		if changeOK then
			newCurrent.myViewController		:= self.myViewController;
			if newNext &lt;&gt; null then
				newNext.myViewController	:= self.myViewController;
			endif;			
			create editMovementChange;
			editMovementChange.versionPrevious	:=origCurrent;
			editMovementChange.appliesToMovement:=newCurrent;
			editMovementChange.ofViewController	:=self.myViewController;
			self.myViewController.changeApply(editMovementChange, false, true);
		else
			return false;
		endif;
	endif;
	return true;

epilog
	delete wp;	
end;</source>
        <Parameter name="berth" type="HMS_Berth"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
