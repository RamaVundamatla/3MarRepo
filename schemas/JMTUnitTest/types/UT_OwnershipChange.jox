					'Cargo,' &amp; _mapName &amp; ',(Default),(Default),(Default),(Default),(Default),(Default),' &amp; 'Curtain Attached' &amp; ',,(Default),(Default) ›,(Default),,,**Any**,All,' &amp; _invLineDesc  &amp; CrLf;
					
