    <JadeMethod name="setTblDataXML" id="b6e0d369-2838-40bc-b455-80c2bcbecf61">
        <source>setTblDataXML(): String protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 July 2009	cnwmd1	Initial creation

*/

vars
	str : String;
	tagStr,typeTag	: String;
	inwardXML, outwardXML : String;
begin
	tagStr := self.tblCargo.XMLTag_Table &amp; self.tblCargo.name;

	str := self.tblCargo.getXmlStrForColumns(true);

	if self.tableDefIn &lt;&gt; null then
		inwardXML := global.formatAsXMLPrefix(ETView_WagonIn2) &amp; self.tableDefIn &amp; global.formatAsXMLSuffix(ETView_WagonIn2);
	endif;
	if self.tableDefOut &lt;&gt; null then
		outwardXML := global.formatAsXMLPrefix(ETView_WagonOut2) &amp; self.tableDefOut &amp; global.formatAsXMLSuffix(ETView_WagonOut2);
	endif;

	
	typeTag := self.getTypeMode();
	if typeTag = ETView_WagonOut2 then //Over-ride the current option
		outwardXML := global.formatAsXMLPrefix(ETView_WagonOut2) &amp; str &amp; global.formatAsXMLSuffix(ETView_WagonOut2);
	elseif typeTag = ETView_TrainInward then
		inwardXML := global.formatAsXMLPrefix(ETView_WagonIn2) &amp; str &amp; global.formatAsXMLSuffix(ETView_WagonIn2);
	endif;

	str := inwardXML &amp; outwardXML;

	return str;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setWagonPxy" id="274cbfa4-4c7e-48ad-b697-8f7b425f03f5">
        <updating/>
        <source>setWagonPxy(_pxyWagon : CM_Wagon input; wagonUpdateCtrl : CMIF_WagonUpdateController input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 Jun 2009	cnwmd1	Initial creation
04 Nov 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores
25 Jul 2022	jlika1	TFS 53741 - EUP- Max Wagon Payload
31 July 2023 navmv20 Defect 59322: MTN - 1090 exception when confirming the wagon outwards
*/

vars

	trainIn, 
	trainOut     		: CM_Train;
	remark 		 		: String;
	carrier	     		: CM_Carrier;
	wagon 	     		: CM_Wagon;
	wagonClass   		: CM_WagonClass;
	wagonPos     		: Integer;
	confirmIn    		: Boolean;
	confirmOut  		: Boolean;
	destTerm    		: CM_Terminal;
	recStevedore 		: CM_Stevedore;
	relStevedore 		: CM_Stevedore;
	allowWagonWeights 	: Boolean;
	maxCargoWeight		: Decimal[12,2];
	tareWeight			: Decimal[12,2];
begin

	if self.myTerminal &lt;&gt; null then
		allowWagonWeights := self.myTerminal.getConfig(AllowWagonWeightsToBeUpd).Boolean;
	endif;	
	
	trainIn  := self.cmbTrainIncoming.listObject.CM_Train;
	trainOut := self.cmbTrainOutgoing.listObject.CM_Train;
	wagon 	 := self.myCurrentWagon; //real wagon
	remark   := self.txtRemaks.text;

	if self.cmbCarrier.listIndex &lt;&gt; -1 then
		carrier := self.cmbCarrier.listObject.CM_Carrier;
	endif;
	if self.cmbWagonClass.listIndex &lt;&gt; -1 then
		wagonClass := self.cmbWagonClass.listObject.CM_WagonClass;
	endif;
	if self.cmbDestTerm.listIndex &lt;&gt; -1 then	// TFS 2533
		destTerm := self.cmbDestTerm.listObject.CM_Terminal;
	endif;
	confirmIn    := self.chkConfirmIn.value;
	confirmOut   := self.chkConfirmOut.value;
	recStevedore := self.cmbStevedoreRec.listObject.CM_Stevedore;                    //02.10.2020 cnwma1 TFS #50112
	relStevedore := self.cmbStevedoreRel.listObject.CM_Stevedore;                    //02.10.2020 cnwma1 TFS #50112
	
	maxCargoWeight	:= 0;
	tareWeight		:= 0;
	if allowWagonWeights then
		maxCargoWeight	:= self.tblMaxCWeight.getConvertedValue();
		tareWeight	:= self.tblTare.getConvertedValue();
	else
		maxCargoWeight	:= self.txtMaxWeight.text.Decimal;
		tareWeight	:= self.txtTareWeight.text.Decimal;
	endif;
	
	
	//update prxy wagon
	_pxyWagon.setProxy(	self.myTerminal,
						self.cmbWagonPrenote.text,
						wagonClass,
						trainIn,
						trainOut,
						remark,
						0,
						maxCargoWeight,
						tareWeight,
						carrier,
						recStevedore,
						relStevedore);  
 	_pxyWagon.setMyDestinationTerminal(destTerm);
	_pxyWagon.setPxyConfirmed(confirmIn,confirmOut); //31/07/2023 navmv20 Defect 59322
						
	//update wagonUpdateCtrl
	if self.cmbRake.listIndex &gt; 0 then
		wagonPos := self.cmbRake.itemData[self.cmbRake.listIndex];
	endif;
	
	wagonUpdateCtrl.setBasicDetails(	self.mode,	//_mode : Integer;
										self.cmbRake.listObject.CM_RailLine,	//_rake : CM_RailLine;
										trainIn,	//_train : CM_Train;
										wagonPos,	//_wagonPosition : Integer;
										true//_trainMode : Boolean  01 Feb 2011	NDL	Par 25181       //(self.myRailArea = null).Boolean	//_trainMode : Boolean
										);
										
	wagonUpdateCtrl.myProxyWagon := _pxyWagon;
	
	if wagon &lt;&gt; null then
		wagonUpdateCtrl.confirmWagonInwards    := wagon.confirmed = false and confirmIn = true;
		wagonUpdateCtrl.confirmWagonOutwards   := wagon.confirmedOutwards = false and confirmOut = true;
		wagonUpdateCtrl.unconfirmWagonInwards  := wagon.confirmed = true and confirmIn = false;
		wagonUpdateCtrl.unconfirmWagonOutwards := wagon.confirmedOutwards = true and confirmOut = false;
		wagonUpdateCtrl.expectedEditionWagon   := wagon.edition;
	else
		wagonUpdateCtrl.confirmWagonInwards  := confirmIn;
		wagonUpdateCtrl.confirmWagonOutwards := confirmOut;
	endif;
	
	if wagon &lt;&gt; null then
		wagonUpdateCtrl.populateFromExistingWagonAddTi( wagon, null, 0 );
	endif;

	if wagonUpdateCtrl.confirmWagonInwards then
		if (not wagonUpdateCtrl.allTrackedItems.isEmpty) then
			endLoad;	//19 May 2011	NDL	Par 27459 - must be unconditional here, we will be in load state, and must end it
			wagonUpdateCtrl.doAutoPlan := (app.msgBox(app.getErrorString(Want_autop_cargo_into_yard), app.getErrorString(DO_AUTOPLAN_YA) &amp; '?',MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes);
			beginLoad;	//19 May 2011	NDL	Par 27459 - must be unconditional here, must restart it.
		endif;
	endif;
epilog
	
end;</source>
        <Parameter name="_pxyWagon" type="CM_Wagon" usage="input"/>
        <Parameter name="wagonUpdateCtrl" type="CMIF_WagonUpdateController" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="02f27dcc-eaa9-4cf0-9675-72224ffec9d1">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 Jun 2009	cnwmd1	Initial creation
17 Aug 2022 navhl20 ChangeRequest 54281: EUP - Wagon Track Planning
01 Aug 2023	jlizm1	TFS 59215 Wagon maintenance notifications
*/

vars

begin
	
	self.beginClassNotification( CM_Wagon, false, self.myTerminal.getTerminalEvent(Wagon_Create_Event), Response_Continuous, null);
	self.beginClassNotification( CM_Wagon, false, self.myTerminal.getTerminalEvent(Wagon_Update_Event), Response_Continuous, null);
	self.beginClassNotification( CM_Wagon, false, self.myTerminal.getTerminalEvent(Wagon_Delete_Event), Response_Continuous, null);
	
	self.buildCombos();
	self.buildComboAreas();
	self.initTblCargo();
	
	if self.mode = self.Mode_View then //default
		self.doWagonDisplay(true);
		self.loadCargo(optDirInTB.value);
	elseif self.mode = self.Mode_Update then
		self.doWagonDisplay(true);
		self.doWagonEdit();
		self.loadCargo(optDirInTB.value);
	elseif self.mode = self.Mode_Add then
		if self.myRailArea &lt;&gt; null then
			self.chkAdvanced.value := true;
		endif;
		self.doWagonAdd();
	endif;

	
	if self.myRailArea &lt;&gt; null then
		self.cmbRailArea.listObject := self.myRailArea;
		self.buildComboPosition(self.myRailArea);
	endif;
	self.addToolbarControls();

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnIntransit.enabled:= false;
		self.btnIntransitNO.enabled:= false;
		self.btnNewWagon.enabled:= false;
		self.btnEditWagon.enabled:= false;
		self.btnDeleteWagon.enabled:= false;
		self.btnCCWagon.enabled:= false;
		self.btnAddCargo.enabled:= false;
		self.btnWagonClass.enabled:= false;
		self.btnWagonMove.enabled := false;		//17 Aug 2022 navhl20 TFS 54281
		self.btnWagonUnplan.enabled := false;	//17 Aug 2022 navhl20 TFS 54281
	endif;
	
	//Start 17 Aug 2022 navhl20 TFS 54281
	if self.myCurrentWagon &lt;&gt; null and self.myCurrentWagon.allPlannedFutureMoves.isNotEmpty then
		self.lblPlanLocation.visible := true;
		self.lblPlanLocation.caption := self.lblPlanLocation.caption &amp; Space &amp; self.myCurrentWagon.getPlannedLocation();
	endif;
	//End 17 Aug 2022 navhl20 TFS 54281
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showColumnOrganiser" id="cbf8a508-0b2b-4f8d-975b-52e2e3eaaa82">
        <updating/>
        <source>showColumnOrganiser(_dataTable : CM_DataTable input)updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 July 2009	cnwmd1	Initial creation

*/

vars
	defBefore, defAfter, typeTag : String;
begin
	if _dataTable = null then
		return;
	endif;
	
	defBefore := _dataTable.getXmlStrForColumns(true);
	_dataTable.showColumnOrganiserFrm(self.myTerminal, null);
	defAfter := _dataTable.getXmlStrForColumns(true);
	
	if defBefore &lt;&gt; defAfter then //Update the array if columns have changed via the column organiser.  The array is saved when form is closed
		typeTag := self.getTypeMode();
		if typeTag = ETView_WagonOut2 then //Over-ride the current option
			self.tableDefOut := defAfter;
		elseif typeTag = ETView_WagonIn2 then
			self.tableDefIn := defAfter;
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_dataTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showTransactions" id="4e4c294d-9fe1-4d8d-bbe8-6a8824c2b87c">
        <source>showTransactions();
// ---------------------------------------------------------------------------
// Created:     21 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	wagon	 : CM_Wagon;
	wagonForm : YRD_WagonTransactionForm;
begin
	wagon := self.myCurrentWagon;
	
	if wagon = null then
		return;
	endif;


	wagonForm := app.loadForm(YRD_WagonTransactionForm, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_WagonTransactionForm;
	wagonForm.myCurrentWagon := wagon;
	wagonForm.show();
epilog

end;</source>
    </JadeMethod>
