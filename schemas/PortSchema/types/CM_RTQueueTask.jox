    <JadeMethod name="isCraneTask" id="9563e8fc-0263-4e91-92b6-14ea76ee6fb5">
        <source>isCraneTask()	: Boolean;
//Returns TRUE if this Task is a crane task (not a machine task)
vars

begin
	if ti = null then
		return false;
	endif;
	if taskType = TASK_PICKUP or 
		taskType = TASK_SETDOWN then
		if self.sourceLocation.isKindOf(CM_SlotController) and 
			self.targetLocation.getParent.isKindOf(CM_CraneTransferArea) then
				return true;
		endif;
		if self.sourceLocation.isKindOf(CM_CraneTransferArea) and 
			self.targetLocation.getParent.isKindOf(CM_SlotController) then
			return true;
		endif;
	endif;
	return false;	

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isDirectorWithAssignedTI" id="4028fcff-5fa0-4098-812e-6319adf7fe2d">
        <source>isDirectorWithAssignedTI() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 November 2011	cnwrd1	Initial creation

*/

vars
	rtEntry : CM_RTQueueEntry;
	firstTask : CM_RTQueueTask;
begin

	// have to determine if we were a director task and (through best pick) we have automatically assigned a TI when the first machine has accepted the task.
	
	if self.status = TASK_ACCEPTED and self.ti &lt;&gt; null and self.taskType = TASK_PICKUP then //we are an accepted pickup task
		rtEntry := self.myEntry;
		firstTask := rtEntry.allTasks.first;
		
		if firstTask &lt;&gt; null and firstTask.taskType = TASK_DIRECTOR and firstTask.status = TASK_COMPLETE then //the first task for our entry is a completed director task		
			if rtEntry.getPreviousRelatedEntry() = null then //we are the first and only or the first in a mmm chain //epr par 35702 CCMS 2457 17/2/15
				return true;
			endif;			
		endif;
	
	endif;	
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
