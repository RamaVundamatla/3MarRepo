    <JadeMethod name="setupForm" id="1e8f42fa-1691-4064-91b3-40b478ddf114">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		11 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.berthageNoShift := app.myPassport.myTerminal.getConfig(InvoiceHMSNoShiftCharge).Boolean;
	self.usesQueryFrame := true;
	self.useTableInfo := false;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.useTableSorting := false;
	inheritMethod();
	self.tblData.disallowColumnSorter := true;
	
	self.initTableData(ETDef_HMSResourceUsed);
	self.tblData.sortColumn[1] := 0;
	self.tblData.fixedColumns := 0;
	self.fldQuery.topSheet := self.shtQuery1;
	self.cmbQueryVoyage.listCollection(self.myTerminal.allVoyagesByCode,false,0);
	
	if  self.myCurrentVoyage &lt;&gt; null then

		self.doQuery();
	endif;
	
	self.mnuContextHide.visible := false;
	self.mnuContextLocate.visible := true;
	self.mnuContextLocate.caption := "Invoice...";

	self.mnuContextTIEdit.visible := true;
	self.mnuContextTIEdit.caption := "Movement Maintenance...";
	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnVoyInvStatus.enabled:= false;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showColourLegend" id="bdf88aa6-b504-4639-b64f-4202d41d4e53">
        <source>showColourLegend();
// ---------------------------------------------------------------------------
// Created:		11 August 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	colLegend	: CMUI_ColourLegend;
	
begin

	create colLegend;
	colLegend.centreWindow;
	colLegend.caption := "Resource Used Colour Legend";
	colLegend.height := 150;
	colLegend.addLegendItem("Not Charged, requires no data input", Black, self.ColourLightGreen, null, false);
	colLegend.addLegendItem("Not Charged, requires data input", Black, self.ColourLightRed, null, false);
	colLegend.addLegendItem("Charged", Black, self.ColourLightLightGray, null, false);
	
	colLegend.showModal;


epilog
	delete colLegend;


end;</source>
    </JadeMethod>
