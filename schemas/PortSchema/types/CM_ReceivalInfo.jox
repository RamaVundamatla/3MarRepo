    <JadeMethod name="getQuantity" id="03940cb8-4960-48fb-bf64-3857deb77403">
        <source>getQuantity() : Integer;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		16 March 2010
//
// Implemented version: JMT 7.8.1
// Date  		User  		Change
//----------------------------------------------------------------------
vars

begin
	if self.myBookingItem &lt;&gt; null then
		return self.myBookingItem.quantity;
	endif;
	
	return self.quantity;
epilog
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotQtyLeft" id="ba710d97-4b56-4702-bb26-2c30cd476d1a">
        <source>getTotQtyLeft():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 March 2014	cnwndl1	Initial creation	Par 33596

*/

vars

	totQuantity : Integer;
	qtyLeft : Integer;
	ti : CM_TrackedItem;

begin

	if self.quantity = 0 then
		return 0;
	endif;

	foreach ti in self.allTrackedItems do
		totQuantity := totQuantity + ti.totalQuantity;
	endforeach;
	
	qtyLeft := self.quantity - totQuantity;
	
	if qtyLeft &lt; 1 then
		// in case its negative
		qtyLeft := 0;
	endif;
	
	return qtyLeft;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hasReceivedTIs" id="7dbcac71-44f8-46d5-96a4-c9549dee18f8">
