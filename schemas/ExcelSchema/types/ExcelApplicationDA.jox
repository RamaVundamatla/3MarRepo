    <JadeMethod name="getWorksheet" id="adbabdcc-7bda-4d37-881c-0541d2482a2d">
        <source>getWorksheet(pWorkSheetName:String):I_Worksheet;

vars
	sht	:	I_Worksheet;
	int	:	Integer;
begin
	foreach int in 1 to myExcelApplication.worksheets.count do
		sht := myExcelApplication.sheets.item(int).I_Worksheet;
		if sht.name = pWorkSheetName then
			return sht;
			break;
		endif;
	endforeach;

end;</source>
        <Parameter name="pWorkSheetName" type="String"/>
        <ReturnType type="I_Worksheet"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="75f39519-9b2d-4d4e-aa47-c1f8d9c05e95">
        <updating/>
        <source>initialise() updating;

/*****************************************************
	Written by	:	cnwpra1		04 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
	4/11/2004	cnwrh3	Added ability to specify the filename before initialisation.
******************************************************/

vars
	workbook		: I_Workbook;
	first			: Boolean;
	strWorkbookName	: String;
	oidStr			: String;
	t				: TimeStamp;
	
	folderName, fileTitle : String;
	splitIndex : Integer;

begin
	if myExcelApplication = null then
		create myExcelApplication;
		myExcelApplication.createAutomationObject;
		//myExcelApplication.attachAutomationObject(true);
		
		first := true;
		excelCreatedOK := true;
	endif;
	
	if myFileManagementDA = null then
		create myFileManagementDA;
		myFileManagementDA.setUseLocalDirectory(true);
	endif;
	
	oidStr := self.String;
	oidStr.replaceChar('/', '_');
	strWorkbookName := myWorkbookDefinition.workbookName &amp; oidStr &amp; t.yyyymmddhhmmss &amp; '.xls';
	workbookName := strWorkbookName;
	
	if self.fileName = null then
		self.fileName := app.getJadeInstallDir &amp; '\ExcelPackage\' &amp; strWorkbookName;
		folderName := app.getJadeInstallDir() &amp; '\ExcelPackage\';
		fileTitle := strWorkbookName;
		self.shouldWorkbooksBeDeleted := true;
	else
		splitIndex := self.fileName.reversePos("\");
		folderName := self.fileName[1:splitIndex];
		fileTitle := self.fileName[(splitIndex+1):end];
		self.shouldWorkbooksBeDeleted := false;
	endif;
	
	myFileManagementDA.copyBlobToFile(myWorkbookDefinition.workbook, folderName, fileTitle);
	myExcelApplication.workbooks.open(fileName, null, false, null,null,null,true,null,null,true,null,null,null);
	
	if first then
		myExcelApplication.beginNotifyAutomationEvent(self, 'myAEvents');
		//myExcelApplication.beginNotifyAutomationEvent(self, 'myWBE');
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="makeVisible" id="0a553aa5-eb30-4e03-89dd-e1594b6a8c3a">
        <source>makeVisible(pVisible : Boolean);

vars

begin
	if myExcelApplication &lt;&gt; null then
		myExcelApplication.visible	:= pVisible;
	endif;

end;</source>
        <Parameter name="pVisible" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="makeWorksheetVisible" id="2fb2a590-c16b-4a55-a57d-3d8900f2e7ef">
        <source>makeWorksheetVisible(pWorkSheetName: String; pVisible : Boolean);

vars
	int	:	Integer;
	sht	:	I_Worksheet;
begin
	foreach int in 1 to myExcelApplication.worksheets.count do
		sht := myExcelApplication.sheets.item(int).I_Worksheet;
		if sht.name = pWorkSheetName then
			if pVisible then
				sht.I_Worksheet.visible := -1;
			else
				sht.I_Worksheet.visible := 0;
			endif;
			break;
		endif;
	endforeach; 

end;</source>
        <Parameter name="pWorkSheetName" type="String"/>
        <Parameter name="pVisible" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="myAEvents_workbookBeforeClose" id="e0440029-78a1-49ff-9f5f-46f5b4d8eaf7">
        <controlMethod name="AppEvents::workbookBeforeClose"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>myAEvents_workbookBeforeClose(wb: I_Workbook; cancel: Boolean) updating;

/*****************************************************
	Written by	:	cnwpra1		24 May 2004
	Description	:	Excel is closing, don't save the workbook, do all the cleaning up

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	work		: I_Workbook;
	awb			: Any;
	aCancel		: Any;

begin
	on Exception do app.defaultExceptionHandler(exception);
	
	if doingClose then
		return;
	endif;
/*
	aCancel := cancel;	
	if aCancel.isKindOf(I_Workbook) then
		work := aCancel.I_Workbook;
		awb := wb;
		cancel := awb.Boolean;
		wb := work;
		write cancel;
		write wb;
	endif;
	
	if doingClose then	// we are automatically closing something they are trying to open
		doingClose := false;
		write 'closing';
		return;
	endif;
*/
	// some temporary code to try to get round what is supposed to be a windows problem where
	// windows occasionally supply method parameters in reverse sequence
	
	
	aCancel := cancel;	
	if aCancel.isKindOf(I_Workbook) then
		work := aCancel.I_Workbook;
	else
		work := wb;
	endif;
	
	if work.name = workbookName then
		
		work.saved := true;
		
		doCleanupProcessing;
	endif;
	
epilog

end;</source>
        <Parameter name="wb" type="I_Workbook"/>
        <Parameter name="cancel" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="myAEvents_workbookBeforeSave" id="ad7a95da-d5a2-4f3f-87fe-c5880146c70d">
        <controlMethod name="AppEvents::workbookBeforeSave"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>myAEvents_workbookBeforeSave(wb : Any io; saveAsUI: Boolean io; cancel: Any io) updating;

/*****************************************************
	Written by	:	cnwpra1		26 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	awb		: Any;
	aCancel	: Any;

begin
/*		we will allow saving to local drives
	awb := cancel;
	if not awb.isKindOf(I_Workbook) then
		awb := wb;
	endif;
	
	awb.I_Workbook.saved := true;
	
	wb := true;
	saveAsUI := false;
		
	doCleanupProcessing;
*/
	
epilog

end;</source>
        <Parameter name="wb" type="Any" usage="io"/>
        <Parameter name="saveAsUI" type="Boolean" usage="io"/>
        <Parameter name="cancel" type="Any" usage="io"/>
    </JadeMethod>
    <JadeMethod name="myAEvents_workbookOpen" id="a2dd304d-b060-4f69-97e2-3e5ca4ba5465">
        <controlMethod name="AppEvents::workbookOpen"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>myAEvents_workbookOpen(wb: I_Workbook) updating;

/*****************************************************
	Written by	:	cnwpra1		24 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars
	work		: I_Workbook;

begin
	return;			// requires 6.0.19 for events to work correctly
	app.msgBox('Please do not open another workbook during this process.' &amp; CrLf &amp; CrLf &amp;
							'The new Workbook is being closed. Use another copy of Excel to work on an outside Workbook', 
									'Workbook Processing', MsgBox_OK_Only);
	work := wb;
	work.saved := true;	
	doingClose := true;
	work.close(null, null, null);	
	
epilog

end;</source>
        <Parameter name="wb" type="I_Workbook"/>
    </JadeMethod>
    <JadeMethod name="pasteArrayInDatasheet" id="61a00aa7-118a-4527-ab3f-89cad7599dd3">
        <updating/>
        <source>pasteArrayInDatasheet(array		: ExcelHugeStringArray) updating;

/*****************************************************
	Written by	:	cnwpra1		14 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
	4/11/2004	cnwrh3	Removed the line that automatically makes Excel visible
******************************************************/

vars
	str			: String;
	row			: Integer;
	range		: Range;
	str2		: String;

begin
	foreach str in array do
		row := row + 1;
		myDataWorksheet.activate;
		myDataWorksheet.range('A' &amp; row.String, 'A' &amp; row.String).select;
		
		app.copyStringToClipboard(str);
		myDataWorksheet.paste(null,false);
			
	endforeach;
	
	if myChartTopsheet &lt;&gt; null then
		myChartTopsheet.activate;
	elseif myWorksheetTopsheet &lt;&gt; null then 
		myWorksheetTopsheet.activate;
	endif;
	
	if myWorkbookDefinition.hideDataWorksheet then
		myDataWorksheet.visible := 0;
	endif;
	
	myExcelApplication.beginNotifyAutomationEvent(self, 'myAEvents');
	
	// myExcelApplication.activeWorkbook.saved := true;
	myExcelApplication.activeWorkbook.save();
	
	// myExcelApplication.visible := true;
	
epilog

end;</source>
        <Parameter name="array" type="ExcelHugeStringArray"/>
    </JadeMethod>
