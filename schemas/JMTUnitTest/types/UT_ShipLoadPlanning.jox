    <JadeMethod name="removeAllStopsForAssoc" id="8d0b83a4-63ce-4f0c-95b4-1cee19621f36">
        <source>removeAllStopsForAssoc(_allAssocs : ObjectArray input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2009	cnwer1	Initial creation

*/

vars
	obj : Object;
	assoc : CM_AssociationDict;
	id : String;
	ti : CM_TrackedItem;
begin
	foreach obj in _allAssocs do
		assoc:=obj.CM_AssociationDict;
		id:=assoc.str("ID");
		assoc.addAssociation("CENum","ABC123");
	
		ti := self.getTerminal.lookupTrackedItem(id, TI_CargoType_Container, TI_STATE_NORMAL, null, false);
		if ti = null then
			
			continue;
		endif;
		write id;
		self.assertTrue(ti &lt;&gt; null);
		
		self.deleteStops(ti);
		//OLD CODE
		//self.deleteStops(ti, assoc);
	endforeach;
epilog

end;</source>
        <Parameter name="_allAssocs" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setStraddleStackTwinLiftPoints" id="4c74339b-ef2f-4382-90b1-05add9a080b8">
        <source>setStraddleStackTwinLiftPoints(_straddleStack : CM_StraddleStack input; _allAssocDicts : ObjectArray);
/*

Purpose:		passed in should be a array of CM_AssociationDicts

				each CM_AssociationDict should have CM_Associations with
					gridRow1
					gridCol1
					gridRow2
					gridCol2
					
					row1 and col1 will get the grid point and set the grid controllers canTwinLiftWithNextController = true 
					row2 and col2 will get the grid point and set the grid controllers canTwinLiftWithPrevController = true

Parameters:			

Return Value:		


Date			Who		Reason
16 January 2009	cnwer1	Initial creation
08/04/2011		cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
*/

vars
	pxyStraddleStack 	: CM_StraddleStack;
	allAssocs		 	: CM_AssociationDict;
	obj					: Object;
	assoc				: CM_Association;
	gridController		: CM_GridController;
	row1,
	col1,
	row2,
	col2 				: Integer;
begin
	beginLoad;
	pxyStraddleStack:=_straddleStack.pxyCreateUpdateProxy();	
	endLoad;
	
	foreach obj in _allAssocDicts do
		allAssocs:=obj.CM_AssociationDict;
		foreach assoc in allAssocs do
			
		//	pxyStraddleStack.allGridControllersByRowColumn
		
		endforeach;	
	endforeach;

epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
end;</source>
        <Parameter name="_straddleStack" type="CM_StraddleStack" usage="input"/>
        <Parameter name="_allAssocDicts" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="tNoCargoSelectionNoParams" id="e7a45f72-5e28-4362-acc5-6bf090683e1a">
        <updating/>
        <source>tNoCargoSelectionNoParams() updating;
// cnwer1
/* cnwer1

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 December 2008	cnwer1	Initial creation

*/

vars

tmpOptionsUsed 	: IntegerArray;
	allJobs 		: CM_JobArray;
	jobSheet		: CM_VoyageJobSheet;
	job				: CM_VoyageJob;
	allJobSet				: CM_VoyageJobSet;
	controller		: CMIF_ShipPlanningController;
	mode 			: Integer;
	voyage 			: CM_Voyage;
	planIfStops,
	planFromRowEnds,
	useWeights,
	planAccrossTermArea,
	planAccrossTermAreaCol,
	ignoreWarnings,
	planTwinLift	: Boolean;
	
	height,
	numRowSep,
	weightAve,
	weightPC	: Integer;
	cmifMonitor : CMIF_Monitor;
	reqs : CM_SlotRequestArray;
	slotRequest : CM_SlotRequest;
	futureMovePlanned : CM_FutureMovePlanned;
	stradStack : CM_StraddleStack;
	gridControler : CM_GridController;
	trackedItem 	: CM_TrackedItem;
begin
	//need to delete all containers and recreate
	
	self.uCreateContainers();
	self.uRemoveAllStops();
	
	create tmpOptionsUsed transient;
	create allJobs transient;
	create cmifMonitor transient;
	create controller transient;
	mode:=3; //this is job mode voyage is 1 crane is 2
	voyage := self.getVoyage(self.getVoyageName);
	jobSheet:=voyage.allJobSheets[self.getCraneID];
	//there's only one job
	assertNotNull(jobSheet);
	
	job:=self.getJob();
	assertNotNull(job);
	allJobs.add(job);

	/* the options that could be included
		VoyageFullPlanThirdHeight
		VoyageFullPlanGroundHeight
		VoyageFullPlanOSVoyage
		VoyageFullPlanOSDischPort
	*/
	//not sure why this sets the config when the chk box changes value?
	app.myTrxUA.trxUpdateTerminalConfig(self.getTerminal, AutoLoadPlanAt3Height,false, app.myPassport );
	
	//self.setYardAreaFlipped();
	controller.init(self.getTerminal,
					mode, 
					allJobs, 
					jobSheet,
					voyage,
					planIfStops,
					tmpOptionsUsed, 
					height, 
					planFromRowEnds,
					numRowSep,
					null,
					useWeights,
					weightAve,
					weightPC,
					planAccrossTermArea,
					planAccrossTermAreaCol,
					ignoreWarnings,
					planTwinLift);
					
	controller.initQuery();
	controller.doQuery(null);

//	self.writeTransientsNow(CM_TISet);
	
	// the results should be 
	//get the slot requests in order 20 requests
	create reqs transient;
	job.doSortReqsInToSeqOrder(reqs);
	
	//1st voyage slot request  
	stradStack:=self.getTerminal.allTerminalAreas["UTSTRDA"].CM_StraddleStack;
	self.checkSlotRequest(reqs[1],stradStack,1,1,3);
		
	//2nd voyage slot request  
	self.checkSlotRequest(reqs[2],stradStack,1,1,2);
		
	//3rd voyage slot request  
	self.checkSlotRequest(reqs[3],stradStack,1,1,1);
	
	//4th voyage slot request  
	self.checkSlotRequest(reqs[4],stradStack,1,2,3);
	//5th voyage slot request  
	self.checkSlotRequest(reqs[5],stradStack,1,2,2);
	//6th voyage slot request  
	self.checkSlotRequest(reqs[6],stradStack,1,2,1);
	//7th voyage slot request  
	self.checkSlotRequest(reqs[7],stradStack,1,3,3);
	//8th voyage slot request  
	self.checkSlotRequest(reqs[8],stradStack,1,3,2);
	//9th voyage slot request  
	self.checkSlotRequest(reqs[9],stradStack,1,3,1);
	//10th voyage slot request  
	self.checkSlotRequest(reqs[10],stradStack,1,4,3);
	//11th voyage slot request  
	self.checkSlotRequest(reqs[11],stradStack,1,4,2);
	//12th voyage slot request  
	self.checkSlotRequest(reqs[12],stradStack,1,4,1);
	//13th voyage slot request  
	self.checkSlotRequest(reqs[13],stradStack,1,5,3);	
	//14th voyage slot request  
	self.checkSlotRequest(reqs[14],stradStack,1,5,2);
	//15th voyage slot request  
	self.checkSlotRequest(reqs[15],stradStack,1,5,1);
	//16th voyage slot request  
	self.checkSlotRequest(reqs[16],stradStack,2,1,3);
	//17th voyage slot request  
	self.checkSlotRequest(reqs[17],stradStack,2,1,2);
	//18th voyage slot request  
	self.checkSlotRequest(reqs[18],stradStack,2,1,1);
	//19th voyage slot request  
	self.checkSlotRequest(reqs[19],stradStack,2,2,3);
	//20th voyage slot request  
	self.checkSlotRequest(reqs[20],stradStack,2,2,2);
	
	
	create allJobSet transient;
	allJobs.copy(allJobSet);
	self.unplanVoyageJobs(allJobSet);
epilog
	delete allJobs;
	delete tmpOptionsUsed;
	delete cmifMonitor;
	delete controller;
	delete reqs;
	delete allJobSet;
	self.uDeleteContainers();
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="false"&gt;SCHEDULE_Weekly&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tPlanAccrossTA" id="e5b59d82-4ae4-49af-866b-d8290316ae07">
        <updating/>
        <source>tPlanAccrossTA() updating;
// cnwer1
/* 

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 December 2008	cnwer1	Initial creation

*/

vars
tmpOptionsUsed 	: IntegerArray;
	allJobs 		: CM_JobArray;
	jobSheet		: CM_VoyageJobSheet;
	job				: CM_VoyageJob;
	allJobSet				: CM_VoyageJobSet;
	controller		: CMIF_ShipPlanningController;
	mode 			: Integer;
	voyage 			: CM_Voyage;
	planIfStops,
	planFromRowEnds,
	useWeights,
	planAccrossTermArea,
	planAccrossTermAreaCol,
	ignoreWarnings,
	planTwinLift	: Boolean;
	
	height,
	numRowSep,
	weightAve,
	weightPC	: Integer;
	reqs : CM_SlotRequestArray;
	slotRequest : CM_SlotRequest;
	futureMovePlanned : CM_FutureMovePlanned;
	stradStackA,
	stradStackB,
	stradStackC: CM_StraddleStack;
	gridControler : CM_GridController;
	trackedItem 	: CM_TrackedItem;
begin
	
	//need to delete all containers and recreate
	
	self.uCreateContainers();
	self.uRemoveAllStops();

	create tmpOptionsUsed transient;
	create allJobs transient;
	create controller transient;
	mode:=3; //this is job mode voyage is 1 crane is 2
	voyage := self.getVoyage(self.getVoyageName);
	jobSheet:=voyage.allJobSheets[self.getCraneID];
	
	/*
		//result of trying to rerun this test
		//really should create the voyage and jobs before hand
		won't work if that one job has been completed need to create the job and delete it everytime
		job was marked up as 20 tl for discharge port BNE
	
	*/
	//there's only one job
	job:=self.getJob();
	allJobs.add(job);

	/* the options that could be included
		VoyageFullPlanThirdHeight
		VoyageFullPlanGroundHeight
		VoyageFullPlanOSVoyage
		VoyageFullPlanOSDischPort
	*/
	
	//not sure why this sets the config when the chk box changes value?
	app.myTrxUA.trxUpdateTerminalConfig(self.getTerminal, AutoLoadPlanAt3Height,false, app.myPassport );
	planAccrossTermArea:=true;
	
	//self.setYardAreaFlipped();
	controller.init(self.getTerminal,
					mode, 
					allJobs, 
					jobSheet,
					voyage,
					planIfStops,
					tmpOptionsUsed, 
					height, 
					planFromRowEnds,
					numRowSep,
					null,
					useWeights,
					weightAve,
					weightPC,
					planAccrossTermArea,
					planAccrossTermAreaCol,
					ignoreWarnings,
					planTwinLift);
					
	controller.initQuery();
	controller.doQuery(null);

	// the results should be 
	//get the slot requests in order 20 requests
	create reqs transient;
	job.doSortReqsInToSeqOrder(reqs);
	
	//1st voyage slot request  
	stradStackA:=self.getTerminal.allTerminalAreas["UTSTRDA"].CM_StraddleStack;
	stradStackB:=self.getTerminal.allTerminalAreas["UTSTRDB"].CM_StraddleStack;
	stradStackC:=self.getTerminal.allTerminalAreas["UTSTRDC"].CM_StraddleStack;
	// params are slot request, row, col , height
	self.checkSlotRequest(reqs[1],stradStackA,1,1,3);
		
	//2nd voyage slot request  
	self.checkSlotRequest(reqs[2],stradStackB,1,1,3);
		
	//3rd voyage slot request  
	self.checkSlotRequest(reqs[3],stradStackC,1,1,3);
	
	//4th voyage slot request  
	self.checkSlotRequest(reqs[4],stradStackA,1,1,2);
	//5th voyage slot request  
	self.checkSlotRequest(reqs[5],stradStackB,1,1,2);
	
	//6th voyage slot request  
	self.checkSlotRequest(reqs[6],stradStackC,1,1,2);
	//7th voyage slot request  
	self.checkSlotRequest(reqs[7],stradStackA,1,1,1);
	//8th voyage slot request  
	self.checkSlotRequest(reqs[8],stradStackB,1,1,1);
	//9th voyage slot request  
	self.checkSlotRequest(reqs[9],stradStackC,1,1,1);
	//10th voyage slot request  
	self.checkSlotRequest(reqs[10],stradStackA,1,2,3);
	//11th voyage slot request  
	self.checkSlotRequest(reqs[11],stradStackB,1,2,3);
	//12th voyage slot request  
	self.checkSlotRequest(reqs[12],stradStackC,1,2,3);
	//13th voyage slot request  
	self.checkSlotRequest(reqs[13],stradStackA,1,2,2);	
	//14th voyage slot request  
	self.checkSlotRequest(reqs[14],stradStackB,1,2,2);
	//15th voyage slot request  
	self.checkSlotRequest(reqs[15],stradStackC,1,2,2);
	//16th voyage slot request  
	self.checkSlotRequest(reqs[16],stradStackA,1,2,1);
	//17th voyage slot request  
	self.checkSlotRequest(reqs[17],stradStackB,1,2,1);
	//18th voyage slot request  
	self.checkSlotRequest(reqs[18],stradStackC,1,2,1);
	//19th voyage slot request  
	self.checkSlotRequest(reqs[19],stradStackA,1,3,3);
	//20th voyage slot request  
	self.checkSlotRequest(reqs[20],stradStackB,1,3,3);
	
	
	create allJobSet transient;
	allJobs.copy(allJobSet);
	self.unplanVoyageJobs(allJobSet);
	
	
epilog
	delete allJobs;
	delete tmpOptionsUsed;
	delete controller;
	delete reqs;
	delete allJobSet;
	self.uDeleteContainers();
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="false"&gt;SCHEDULE_Weekly&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
