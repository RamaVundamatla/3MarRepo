        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="displayEntry" id="a76a816b-30ce-4e38-9170-a332178ab7af">
        <controlMethod name="ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>displayEntry(combobox: ComboBox input; con: CM_ConsigneeConsignor; lstIndex: Integer): String updating, clientExecution;
//17 February 2010	cnwml2
//16 June 2022		navdap1	TFS 53362 EUP Master Data interface customers between TOS and ERP

vars

	 failedDAC  :CM_DataAccessController;

begin
	if con = null then
		return null;
	endif;
	
	if (not con.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		return null;
	endif;
	
	if con.isNotAvailableForEntry then
		if self.myObject &lt;&gt; con then
			return null;
		else
			self.hasDirtyObject := true;
		endif;
	endif;
	
	//if app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean then	// TFS 53362
	if self.isDisplayByName then	//18 Oct 2013	NDL	Par 32594			// TFS 53362
		return con.getDescriptionTabCode;
	else
		return con.code &amp; Tab &amp; con.description;
	endif;

epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="con" type="CM_ConsigneeConsignor"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="e53e7f7b-8dca-42d4-9582-72cdff76d0ca">
        <source>getCollectionJMT(): Collection protected;
//17 February 2010	cnwml2
//+cnwml2 PAR22371

vars
	con : CM_ConsigneeConsignor;
begin
	self.allConsignees.clear();
	foreach con in app.myRoot.allConsigneeConsignors do
		if con.isConsignee then
			self.allConsignees.add(con);
		endif;
	endforeach;
	return self.allConsignees;
	

epilog

end;	</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="getListUpdateStatus" id="9e0f183a-66c9-4815-b6c0-03d9836d30e1">
        <source>getListUpdateStatus(): Boolean;
//18 February 2010	cnwml2
//+cnwml2 PAR22371

vars

begin
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="init" id="debb0a37-e6e8-4d8a-8be0-bcd34e57451a">
        <updating/>
        <source>init() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/06/2022	navdap1		Initial creation TFS 53362 EUP Master Data interface customers between TOS and ERP
//
vars

begin
	inheritMethod();
	self.isDisplayByName := app.myRoot.getConfig(ConsigneeConsignorCmbOrdDescr).Boolean;
	if self.isDisplayByName then
		self.sorted := true;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setObject" id="938f58d9-6890-41c8-b0c8-983c8b8af7c5">
        <updating/>
        <source>setObject(_value: Object) updating;
//17 February 2010	cnwml2
//+cnwml2 PAR22371

vars
	value : Object;
begin
	value := _value;
	if value &lt;&gt; null then
		if not self.getCollectionJMT.includes(_value) then
			app.msgBox(app.getErrorString2(InvalidSettings, app.getString(Consignee), _value.CM_ConsigneeConsignor.code), app.getString(Error), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			value := null;
		endif;
	endif;
	
	inheritMethod(value);

epilog

end;</source>
        <Parameter name="_value" type="Object"/>
    </JadeMethod>
