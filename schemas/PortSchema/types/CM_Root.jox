    <JadeMethod name="getPasswordDescription" id="d9bde87b-d2e9-41e3-aa60-d32d563c6b60">
        <source>getPasswordDescription() : String;
// ---------------------------------------------------------------------------
// Created:     05 April 2007 by cnwrs2
//
// Purpose:     Returns string of requirements for a valid password e.g.
//			A minimum length of 6 characters
//			A minimum length 
// ---------------------------------------------------------------------------
vars
	msg	: String;
begin

	if self.passwordMinUpper &lt;&gt; 0 then
		msg := msg &amp; app.getErrorString1(PswdMinUpperCase, app.myRoot.passwordMinUpper.String);
	endif;
	
	if self.passwordMinLower &lt;&gt; 0 then
		msg := msg &amp; app.getErrorString1(PswdMinLowerCase, app.myRoot.passwordMinLower.String);
	endif;
	
	if self.passwordMinNumeric &lt;&gt; 0 then
		msg := msg &amp; app.getErrorString1(PswdMinNumeric, app.myRoot.passwordMinNumeric.String);
	endif;
	
	if self.passwordMinSpecial &lt;&gt; 0 then
		msg := msg &amp; app.getErrorString1(PswdMinSpecial, app.myRoot.passwordMinSpecial.String);
		if self.passwordSpecialChars &lt;&gt; null then 
			msg := msg &amp; app.getErrorString1(PswdSpecialChars, app.myRoot.passwordSpecialChars.String);
		else
			app.raiseCMException(ERR_SPECIAL_CHARS_MISSING, null, null);
		endif;//special characters are required but non have been required.Contact system administrator.
	endif;
	
	return msg;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPathSegment" id="116721ad-440e-4cd1-9718-9b9c70cfb11e">
        <source>getPathSegment(_from : HMS_HarbourRegion; _to : HMS_HarbourRegion) : HMS_PathSegment;
//-----------------------------------------------------------------------
//	Created:	17 October 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	pathSegment : HMS_PathSegment;
	
begin
	app.writeLog("Executing " &amp; class.name &amp; "::" &amp; method.name, LogDEBUG);
	
	foreach pathSegment in self.allPathSegments discreteLock do
		if pathSegment.myRegionFrom = _from and pathSegment.myRegionTo = _to then
			app.writeLog("Path Segment is " &amp; pathSegment.getDisplayString() &amp; "]", LogDEBUG);
			return pathSegment;
		endif;
	endforeach;
	
	app.writeLog("Path Segment is [null", LogDEBUG);
	
	return null;
epilog
	app.writeLog("Exiting " &amp; class.name &amp; "::" &amp; method.name, LogDEBUG);
end;</source>
        <Parameter name="_from" type="HMS_HarbourRegion"/>
        <Parameter name="_to" type="HMS_HarbourRegion"/>
        <ReturnType type="HMS_PathSegment"/>
    </JadeMethod>
    <JadeMethod name="getPeriodForPleindo" id="b3e864e7-63f7-4d34-9475-fd67abf48579">
        <source>getPeriodForPleindo(_checkDT : TimeStamp input  ;_startDT ,_endDT : Date output);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 December 2018	jlgma1	ChangeRequest 42036: PEL1 - SAP TPP Report

*/

vars
	strStart,
	strEnd,
	strYear  : String;
	year     : Integer;
begin
	
	strYear := _checkDT.Date.formatAsYYYYMMDD[1:4].String;
	year    :=  strYear.Integer;
	
	if _checkDT.date.format("MM") ="01" then
		strStart  := "29/12/"&amp; (year-1).String;
		strEnd    := "28/01/"&amp; strYear;	
		_startDT  := (strStart).Date;
		_endDT    := (strEnd).Date;
	elseif _checkDT.date.format("MM") ="02" then
		strStart  := "29/01/"&amp; strYear;
		_startDT  := (strStart).Date;
		_endDT    := _checkDT.Date.cnEcGetLastDayOfMonth();
	elseif _checkDT.date.format("MM") ="03" then
		strStart  := "01/03/"&amp; strYear;
		strEnd    := "28/03/"&amp; strYear;
		_startDT  := (strStart).Date;
		_endDT    := (strEnd).Date;
	elseif _checkDT.date.format("MM") ="04" then
		strStart  := "29/03/"&amp; strYear;
		strEnd    := "28/04/"&amp; strYear;	
		_startDT  := (strStart).Date;
		_endDT    := (strEnd).Date;
	elseif _checkDT.date.format("MM") ="05" then
		strStart  := "29/04/"&amp; strYear;
		strEnd    := "28/05/"&amp; strYear;
		_startDT  := (strStart).Date;
		_endDT   := (strEnd).Date;
	elseif _checkDT.date.format("MM") ="06" then
		strStart  := "29/05/" &amp; strYear;
		strEnd    := "28/06/" &amp; strYear;
		_startDT  := (strStart).Date;
		_endDT    := (strEnd).Date;
	elseif _checkDT.date.format("MM") ="07" then
		strStart  := "29/06/" &amp; strYear;
		strEnd    := "28/07/" &amp; strYear;
		_startDT  := (strStart).Date;
		_endDT    := (strEnd).Date;
	elseif _checkDT.date.format("MM") ="08" then
		strStart  := "29/07/" &amp; strYear;
		strEnd    := "28/08/" &amp; strYear;
		_startDT  := (strStart).Date;
		_endDT    := (strEnd).Date;
	elseif _checkDT.date.format("MM") ="09" then
		strStart  := "29/08/" &amp; strYear;
		strEnd    := "28/09/" &amp; strYear;
		_startDT  := (strStart).Date;
		_endDT    := (strEnd).Date;
	elseif _checkDT.date.format("MM") ="10" then
		strStart  := "29/09/" &amp; strYear;
		strEnd    := "28/10/" &amp; strYear;
		_startDT  := (strStart).Date;
		_endDT    := (strEnd).Date;
	elseif _checkDT.date.format("MM") ="11" then
		strStart  := "29/10/" &amp; strYear;
		strEnd    := "28/11/" &amp; strYear;
		_startDT  := (strStart).Date;
		_endDT    := (strEnd).Date;
	elseif _checkDT.date.format("MM") ="12" then
		strStart  := "29/11/" &amp; strYear;
		strEnd    := "28/12/" &amp; strYear;
		_startDT  := (strStart).Date;
		_endDT    := (strEnd).Date;
	endif;
epilog

end;</source>
        <Parameter name="_checkDT" type="TimeStamp" usage="input"/>
        <Parameter name="_startDT" type="Date" usage="output"/>
        <Parameter name="_endDT" type="Date" usage="output"/>
    </JadeMethod>
