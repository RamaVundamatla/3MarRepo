    <JadeMethod name="btnExecute_click" id="d1b6ea37-7f45-4429-8cf3-dbebfaf67d90">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnExecute_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     02 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.executeQuery();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
