    <JadeMethod name="doBuildComboAreas" id="cc917ec1-6699-43fc-a2e8-ab1c8a798f0b">
        <updating/>
        <source>doBuildComboAreas() updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	idx 			: Integer;
	aTermArea 		: CM_TerminalAreaMaster;
	theDataLine 	: String;
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	self.cmbArea1.clear();
	self.cmbArea2.clear();

	self.cmbArea1.addItem(null);
	self.cmbArea2.addItem(null);
	self.cmbArea1.sorted := true;
	self.cmbArea2.sorted := true;
	
	foreach aTermArea in self.myTerminal.allTerminalAreas do
		idx := self.cmbArea1.addItem(aTermArea.id);
		self.cmbArea1.itemObject[idx] := aTermArea;
		idx := self.cmbArea2.addItem(aTermArea.id);
		self.cmbArea2.itemObject[idx] := aTermArea;
	endforeach;

epilog
	self.mousePointer := Window.MousePointer_Default;



end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboDirectional" id="afded4a9-5432-42d5-9a51-7600ef0fa6da">
        <source>doBuildComboDirectional(_theArea1,_theArea2 : CM_TerminalArea);
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.cmbDirectional.clear;
	self.cmbDirectional.sorted := false;
	self.cmbDirectional.addItem("BiDirectional Between To and From Areas");
	self.cmbDirectional.addItem("UniDirectional");
		
end;</source>
        <Parameter name="_theArea1" type="CM_TerminalArea"/>
        <Parameter name="_theArea2" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="doBuildComboParent" id="fb7658ac-0843-444e-801f-ff6b6f4be0b1">
        <source>doBuildComboParent(_theType : Integer);
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aVoyage : CM_Voyage;
	idx : Integer;
	aQueue : CM_RadioTelemetryQueue;
begin
	self.cmbParent.clear;
	self.cmbParent.sorted := false;
	self.cmbParent.text := null;
	if _theType =  QTYPE_SUBQUEUE or _theType = QTYPE_VOYAGE or _theType = QTYPE_RTG or _theType = QTYPE_RMG  or _theType = QTYPE_VOYAGEYARD then
		self.cmbParent.addItem(self.myTerminal.radioTelemetry.masterQueue.id);
		self.cmbParent.itemObject[1] := self.myTerminal.radioTelemetry.masterQueue;
	endif;
	if _theType &lt;&gt;  QTYPE_RTG or _theType &lt;&gt;  QTYPE_RMG  then
		foreach aQueue in self.myTerminal.radioTelemetry.masterQueue.allSubQueuesById do
			
			if aQueue.queueType = QTYPE_RTG then
				if _theType = QTYPE_RTGSUBQUEUE then
					idx := self.cmbParent.addItem(aQueue.id );
					self.cmbParent.itemObject[idx] := aQueue;
				endif;
				continue;
			endif;
			if aQueue.isKindOf(CM_SubQueue) and (_theType = QTYPE_SUBQUEUE or _theType = QTYPE_VOYAGE or _theType = QTYPE_VOYAGEYARD ) then
			elseif aQueue.isKindOf(CM_VoyageQueue) and _theType = QTYPE_CRANE  then
			elseif aQueue.isKindOf(CM_VoyageQueue) and _theType = QTYPE_WORKPOINT then
			else
				continue;
			endif;
			idx := self.cmbParent.addItem(aQueue.id );
			self.cmbParent.itemObject[idx] := aQueue;
		endforeach;
	endif;
	self.tblMain.setValueByControlName(self.cmbParent.name, null);

end;</source>
        <Parameter name="_theType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doBuildComboType" id="215301c1-8774-412b-b1e6-0742f037fa51">
        <source>doBuildComboType();
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 21 July 2011	Cnwer1		CCMS 1033 RORO Operations added Work Point Queue also made all queue type names translatable
// ---------------------------------------------------------------------------

vars

begin
	self.cmbType.clear;
	self.cmbType.sorted := false;
	self.cmbType.addItemWithData(app.getErrorString(Sub_Queue), QTYPE_SUBQUEUE);
	self.cmbType.addItemWithData(app.getErrorString(Voyage_Queue),QTYPE_VOYAGE);
	self.cmbType.addItemWithData(app.getErrorString(Voyage_Crane_Queue),QTYPE_CRANE);
	self.cmbType.addItemWithData(app.getErrorString(Voyage_yard_queue),QTYPE_VOYAGEYARD);
	self.cmbType.addItemWithData(app.getErrorString(RTG_Sub_Queue),QTYPE_RTGSUBQUEUE);
	self.cmbType.addItemWithData(app.getErrorString(RTG_Queue),QTYPE_RTG);
	self.cmbType.addItemWithData(app.getErrorString(RMG_Queue),QTYPE_RMG);
	self.cmbType.addItemWithData(app.getErrorString(Work_Point_Queue),QTYPE_WORKPOINT);
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboVoyage" id="c5ed8699-e9db-4550-b1e3-8dac2255adc4">
        <source>doBuildComboVoyage();
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	aVoyage : CM_Voyage;
	idx : Integer;
	theVoyages : CM_VoyageSet;
begin
	
	self.cmbVoyage.clear;
	create theVoyages transient;
	self.myTerminal.getAllCurrentCellularVoyages(theVoyages, true, false);  // PAR 34743 changed to true

	foreach aVoyage in theVoyages do

		if aVoyage.vesselName &lt;&gt; null then
			idx := self.cmbVoyage.addItem(aVoyage.code &amp; " "  &amp; aVoyage.vesselName);
		else
			idx := self.cmbVoyage.addItem(aVoyage.code );
		endif;
		self.cmbVoyage.itemObject[idx] := aVoyage;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildComboWorkArea" id="25a7abb0-0e39-4c21-80ea-dbd464ec6a64">
        <source>doBuildComboWorkArea();
