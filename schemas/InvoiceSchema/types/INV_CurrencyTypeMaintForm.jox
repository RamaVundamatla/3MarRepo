    <JadeMethod name="loadCurrencyTypes" id="ac9d6f27-4beb-4da4-822f-83034ad8e4d3">
        <source>loadCurrencyTypes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2018	jlgndl1	Initial creation	TFS 37550

*/

vars

	idx : Integer;
	theLevel : Integer;
	tmpCurrencyTypeList : ListBox;
	tmpCurrencyType : CM_CurrencyType;
	
begin
	
	tmpCurrencyTypeList := self.lstData;
	tmpCurrencyTypeList.enabled := true;
	tmpCurrencyTypeList.backColor := White;
	tmpCurrencyTypeList.clear;
	tmpCurrencyTypeList.hasTreeLines := true;
	tmpCurrencyTypeList.hasPlusMinus := true;
	tmpCurrencyTypeList.defaultLineHeight := 13;
	
	theLevel := 1;
	idx := tmpCurrencyTypeList.addItem("Currency Types");
	tmpCurrencyTypeList.itemLevel[idx] := theLevel;
//	tmpCurrencyTypeList.itemPicture[idx] := self.picBU.picture;
	tmpCurrencyTypeList.itemExpanded[idx] := true;
	
	foreach tmpCurrencyType in app.myRoot.allCurrencyTypes do
		self.loadCurrencyType(tmpCurrencyType, idx);
	endforeach;
	
	tmpCurrencyTypeList.itemExpanded[1] := true;
	
end;</source>
    </JadeMethod>
