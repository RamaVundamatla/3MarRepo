    <JadeMethod name="isNumItemsSameForMatch" id="e2531083-3d44-4f6a-b5f7-f07ff04248e6">
        <source>isNumItemsSameForMatch(_numScalingDtls : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:     23 June 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	
begin

	if self.percentScaled &lt; 100 then
		if _numScalingDtls &gt;= self.numberTicketed and
		   _numScalingDtls &lt;= self.myBOL.numItems then
			return true;
		endif;
	elseif _numScalingDtls = self.numberTicketed then
		return true;
	endif;
	
	return false;

end;</source>
        <Parameter name="_numScalingDtls" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTicketIdInSequence" id="7e06306b-bda2-44f1-94a9-fe39298a4a33">
        <source>isTicketIdInSequence(_ticketId : String) : Boolean;
// -----------------------------------------------------------------------------
// Created:		10 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	ticketSequence : CM_TicketSequence;
begin
	foreach ticketSequence in self.allTicketSequences do
		if not ticketSequence.isTicketIdNotInSequence(_ticketId) then
			return false;
		endif;
	endforeach;
	return true;
end;</source>
        <Parameter name="_ticketId" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="434eff9b-c3ce-4b5e-a4f8-4bb714aa7a05">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     24 June 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	pxyExt	: CM_BOLExtLogIn;
	iter	: Iterator;
	ticketSeq, 
	pxyTicketSeq : CM_TicketSequence;
	completedOK		: Boolean;
	
begin

	pxyExt := inheritMethod();
	
	pxyExt.myTerminalIfUnmatched	:= self.myTerminalIfUnmatched;

	iter := self.allTicketSequences.createIterator();
	while iter.next(ticketSeq) do
		pxyTicketSeq := ticketSeq.pxyCreateUpdateProxy();
		pxyExt.allTicketSequences.add(pxyTicketSeq);
	endwhile;

	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyExt;

epilog
	
	delete iter;
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyExt;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="sendNoteOnMoveCompletion" id="dad99b02-c563-4fa4-ae87-cd90458f4baf">
        <source>sendNoteOnMoveCompletion(_passport : CM_Passport);
// -------------------------------------------
// Created 19 March 2004 by cnwdvb1
// -------------------------------------------
vars
	terminal : CM_Terminal;

begin

	// We don't use the isMatchedAndMoved method yet because at this stage
	// the bol has not had its myTerminalIfUnmatched set yet.
	terminal := _passport.myTerminal;
	if self.isMatched and _passport.noErrors() then
		terminal.causeEvent(terminal.getTerminalEvent(BOLRecon_Matched_Event), false, self.myBOL);	
	endif;
	

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
