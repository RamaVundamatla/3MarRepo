    <JadeMethod name="activate" id="a106ff0e-be7d-43a3-8f6b-1061913189e0">
        <controlMethod name="Form::activate"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>activate() updating;
// ---------------------------------------------------------------------------
// Created:     28 May 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
27 May 2014	cnwkpd1	PAR #34210 - CCMS SFW 1350 - Online Documentation
	
*/

begin
// cnwdad1 01/05/2006 - If this event was fired more than once during startup,
// any forms that were being restored from the previous session were duplicated
// each time this event was triggered - we only want this to process once.
	if self.aIsFirstActivateStarted then
		return;
	else
		self.aIsFirstActivateStarted	:=	true;
	endif;
	
	if (not self.isFirstActivateComplete) then
		self.handlePostShow();
	endif;

	app.currentHelpKeyword := self.helpKeyword.truncatedAt(30);		// PAR #34210
	
	// Do not inheritMethod() as this does stuff
	// we do not want to do for this main form
	//inheritMethod();
	
	if (not self.isFirstActivateComplete) then
		self.loadDataForFirstTime();
	endif;
	
	// suspect this is not required here
	//self.positionNavigator();
	
	// Should not need to resize on each activate
	//self.resize();
epilog
	if (not self.isFirstActivateComplete) then
		// set the flag here because we don't want to repeat the load
		// on the next activate if the load has an exception
		self.isFirstActivateComplete	:=	true;
	endif;
	
	self.aIsFirstActivateStarted	:=	false;
end;</source>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="1e247a2c-28ab-4bb0-8604-5f812c54ab45">
        <source>addToolbarControls() protected;
// ---------------------------------------------------------------------------
// Created:     01 August 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

	user : CM_User;
	pic			: CMUI_ToolbarPicture;
begin
	if app.isSDSSecondaryDB() then	//cnwrs1 nov 2005 make JMTTerminal work on SDSsecondary
		return;
	endif;
	
	user := app.getMyUser();
	
	if user = null or user.myMenuUserToolbarRoot = null then
		return;
	endif;
	
	self.frmToolbar.loadToolbarFromMenuRoot(user.myMenuUserToolbarRoot, self.picSeperatorBase.picture);
	
	if not user.allEventTypes.isEmpty then
		self.frmToolbar.addButton(self.btnEventAlarm, CMUI_Toolbar.Control_Alignment_Right);
		pic := self.btnEventAlarm.myToolbarButton.getMyPicture();
		pic.picture := self.picEventOff.picture;
		self.btnEventAlarm.visible := false;
		self.btnEventAlarm.caption := app.getErrorString(Event_alarm_quick_search);
		self.btnEventAlarm.bubbleHelp := app.getErrorString(Event_alarm_bubblehelp);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="btnEventAlarm_click" id="d0e2648b-070b-4a97-b68c-a4c8ccf5be54">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnEventAlarm_click(btn: Button input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	18 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	assistant		: CMUI_Assistant;
begin
	create assistant transient;
	assistant.showEventEnquiryQuickSearch(-10, self.myMasterMenuAction);
epilog
	delete assistant;
end;


</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
