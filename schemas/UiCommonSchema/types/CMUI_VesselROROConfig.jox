    <JadeMethod name="doSave" id="2bec082d-1367-46a9-89f1-b28cd7af544c">
        <updating/>
        <source>doSave() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 April 2011	cnwer1	Initial creation

*/

vars
	proxyStateData  : CM_StateData;
	result : Integer;
begin
	
	self.doSaveAllProxyStateData();	

	while true do
		app.myTrxUA.trxUpdateConfigAllStateData(self.allProxyStateData,app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			self.unloadForm();
			break;
		else
			result := app.showErrorWarningDialog('RORO Vessel Config', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
			endif;
		endif;
		
		break;
	endwhile;
	
	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSaveAllProxyStateData" id="2a1795ec-c790-4d83-ab51-c69cf0fcfc6a">
        <source>doSaveAllProxyStateData() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 April 2011	cnwer1	Initial creation

*/

vars
	stateData : CM_StateData;
	allStateData : CM_StateDataDict;
begin

	if self.myVessel  &lt;&gt; null then
	
		allStateData:= self.myVessel.allStateData;
	else
		allStateData:= app.myRoot.getStateObject(ConfigGrp_System).allStateData;
	endif;

	if self.allProxyStateData &lt;&gt; null then
		self.allProxyStateData.purge;
	endif;
	
	//	RoRoAutoGenerateStartEnd
	self.doSaveProxyStateData(allStateData,RoRoDeckLabelPrefix ,self.txtDeckPre.text);
	self.doSaveProxyStateData(allStateData, RoRoLaneCodeIsZeroFilled,self.chklLaneCodeZero.value.asStringJMT());
	self.doSaveProxyStateData(allStateData, RoRoLaneLabelPrefix, self.txtLanePre.text);
	self.doSaveProxyStateData(allStateData, RoRoLaneNumberLength,self.txtlLaneNumLen.text.Integer);
	self.doSaveProxyStateData(allStateData, RoRoLocationCodeIsZeroFilled,self.chklLocCodeZero.value.asStringJMT());
	self.doSaveProxyStateData(allStateData, RoRoLocationNumberLength,self.txtlLocNumLen.text.Integer);
	self.doSaveProxyStateData(allStateData, RoRoRotatedLabel,self.txtRotatedLabel.text);
	self.doSaveProxyStateData(allStateData, RoRoSubDeckLabelPrefix,self.txtSubDeckPre.text);
	self.doSaveProxyStateData(allStateData, RoRoOutOfTwistLockSuffix,self.txtOOTLS.text);
	self.doSaveProxyStateData(allStateData, RoRoGeneralCargoSuffix,self.txtGCS.text);
	
	self.doSaveProxyStateData(allStateData, RoRoLaneWidth,self.txtLaneWidth.text.asDecimalJMT());
	self.doSaveProxyStateData(allStateData, RoRoLaneLength,self.txtLaneLength.text.asDecimalJMT());
	self.doSaveProxyStateData(allStateData, RoRoLaneGap,self.txtLaneGap.text.asDecimalJMT());
	self.doSaveProxyStateData(allStateData, RoRoLocationWidth,self.txtContPosWidth.text.asDecimalJMT());
	self.doSaveProxyStateData(allStateData, RoRoLocationLength,self.txtContPosLength.text.asDecimalJMT());
	self.doSaveProxyStateData(allStateData, RoRoLocationGap,self.txtContPosGap.text.asDecimalJMT());
	//self.doSaveProxyStateData(allStateData, RoRoLinearMeteringWidth,self.txtLinMeterWidth.text.asDecimalJMT());

	
	if  self.cmbAutoGen.listIndex &gt;= 0 then
		self.doSaveProxyStateData(allStateData,RoRoAutoGenerateStartEnd,self.cmbAutoGen.listIndex.Integer);
	endif;

	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSaveProxyStateData" id="9709c8bc-9ad5-41f2-9584-74b7da3ea7e3">
        <source>doSaveProxyStateData(_realAllStateData : CM_StateDataDict;_key : String; _value : Any) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 April 2011	cnwer1	Initial creation

*/

vars
	stateData, proxyStateData : CM_StateData;
	class	: Class;
	parent 	: Object;
begin
	stateData := _realAllStateData[_key];

	if stateData &lt;&gt; null then
		beginLoad;
		proxyStateData:=stateData.pxyCreateUpdateProxy();
		endLoad;
	else
		//no value and not created don't know what class to create as
		if _value = null  then
			return;
		endif;
		class:=global.getDataClass(_value);
		create proxyStateData as class transient;	
		
	endif;
	
	if self.myVessel &lt;&gt; null then
		parent:=self.myVessel;
	else
		parent:=app.myRoot;
	endif;
	
	proxyStateData.set(_key,_value,parent);
	
	
	self.allProxyStateData.add(proxyStateData);
epilog
	endLoad;
end;</source>
        <access>protected</access>
        <Parameter name="_realAllStateData" type="CM_StateDataDict"/>
        <Parameter name="_key" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="initDetails" id="3378e2db-0352-4f45-95c8-e4dfead5f553">
