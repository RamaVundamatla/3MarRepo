        <executionLocation>client</executionLocation>
        <source>mouseUp(pict: HMS_GraphicalDragPicture input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
//--------------------------------------------------
// Created:	04 August 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.isPicHeightUnderZero then
		self.setPicHeight (2);
	endif;
	
	self.myCurrentWharfDrawControl.dragPictureMouseUpEvent(pict, button, shift, x, y);
end;</source>
        <Parameter name="pict" type="HMS_GraphicalDragPicture" usage="input"/>
        <Parameter name="button" type="Integer"/>
