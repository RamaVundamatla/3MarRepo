    <JadeMethod name="getDisplayStringForAttribute" id="44bf8048-d9d4-4cd8-914f-8269f20b86ac">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 August 2009	cnwer1	Initial creation

*/

vars

begin
	if _attrName = ETRow_NumberOfWagonPositions then
		return self.numberOfWagonPositions.asStringJMT;
	elseif _attrName =  ETRow_NumberOfRailLines then
		return self.numberOfRailLines.asStringJMT;
	elseif _attrName = ETRow_ConfirmFromFarEnd then
		return self.confirmFromFarEnd.asStringJMT;
	elseif _attrName = ETRow_DefaultToOppositeView then
		return self.defaultToOppositeView.asStringJMT;

	elseif _attrName = ETRow_WorkFromFarEnd then
		return self.workFromFarEnd.asStringJMT;
	
	elseif _attrName = ETRow_RailTransferArea then
		if self.myTransferArea &lt;&gt; null then
			//return self.myTransferArea.id.trimBlanks &amp; " - " &amp; self.myTransferArea.typeString.trimBlanks;
			return self.myTransferArea.id;
		else
			return null;
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocationLabel" id="1a033451-ffd7-4251-80ab-0776b9be7926">
