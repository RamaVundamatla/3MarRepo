    <JadeMethod name="getDisplay" id="e4806a71-9e1e-4dc5-b1bd-1e6810a51dc1">
        <source>getDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 November 2016	cnwma1	Initial creation

*/
vars
	str	,detail: String;
	cargoSubtype : String;
	invalidTI : Boolean;
begin
	str := inheritMethod();
	
	//epr TFS 4474 1/6/17
	on Exception do app.handleDeletedObject(exception,self.myTrackedItem,invalidTI);
	
	if self.myTrackedItem.myProduct &lt;&gt; null then
		cargoSubtype := self.myTrackedItem.myProduct.description;
	endif;
	
	detail := "Free Storage Expiry Stop Create";
	detail :=  detail &amp;Tab &amp; 
			   self.actionTimeStamp.date.asStringJMT &amp;Tab&amp;
			   self.myTrackedItem.myTerminal.code &amp; Tab&amp;
			   self.myTrackedItem.id &amp; Tab&amp;
			   self.myTrackedItem.myCargoType.description &amp; Tab&amp;
			   cargoSubtype &amp; Tab&amp;
			   self.myTrackedItem.locationId &amp; Tab&amp;
			   self.myTrackedItem.totalQuantity.asStringJMT &amp; Tab&amp;
 // ### TFS 60548 06NOV2023 NAVAB1			   self.myTrackedItem.plannedDT.date.asStringJMT &amp; Tab;
			   self.myTrackedItem.getFutureStorageAnniversary().asStringJMT &amp; Tab;
			   
	if invalidTI then
		return null;
	endif;
	return detail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
