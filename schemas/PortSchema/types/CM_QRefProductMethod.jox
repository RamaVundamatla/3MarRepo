    <JadeMethod name="create" id="d2a041fb-aa61-4018-8459-3e3fdcc50e5a">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 January 2023	navhl20	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query

*/

vars
	oper : CM_QueryOperator;
begin
	if self.isTransient then 
		return;
	endif;

	create oper as CM_QReferenceIsOneOf persistent;
	self.allAllowedOperators.add(oper);
epilog

end;</source>
    </JadeMethod>
