    <JadeMethod name="createCharge" id="c9b9a7d1-3e7d-4fbd-a281-edb3a25d37ff">
        <source>createCharge();
/*
Purpose:		TFS 39237	
Date			Who			Reason
JUNE 2018		CNWAB1		Initial creation
31 Jan 2025		navlw1 		JIRA-33865: MTN | Logging only displays that financials aren't enabled in logging level is TRACE
*/

vars
	businessUnit		: CM_Bank;
	term	: CM_Terminal;
	
begin
	term := self.myWorkOrder.getMyTerminal();

	if term = null then
		app.raiseUnexpectedProgramError(class.name, method.name, CM_TITransaction::myTerminal.name &amp; " is null.");
		return;
	endif;

	// Start navlw1 #JIRA-33865 31/01/2025
	if self.noCharge then
		app.invLog("Transaction is not chargeable",LogINFO.String); // navlw1 #JIRA-33692
		return;
	endif;
	
	if not term.getConfig(FinancialsEnabled).Boolean then
		app.invLog("Financials Are Not Enabled, No Charging Will Occur",LogTRACE.String); // navlw1 #JIRA-33692  // ### JIRA 35228 11JUL2025 NAVAB1
		return;
	endif;
	if not app.myRoot.canDo(Mod_Invoicing) then
		app.invLog("Invoice Module is not licensed",LogINFO.String); // navlw1 #JIRA-33692
		return;
	endif;
	// End navlw1 #JIRA-33865 31/01/2025
	
	// ### TFS BUG 58790 23JUN2023 NAVAB1 businessUnit := self.myWorkOrder.getMyBank();
	businessUnit := self.getMyBank(); // ### TFS BUG 58790 23JUN2023 NAVAB1
	
	if businessUnit = null 
	or app.isUnitTestGarbageCollect then
		return;
	endif;

	businessUnit.createChargeWorkOrder(self);
end;</source>
    </JadeMethod>
    <JadeMethod name="doCreateCharge" id="d4fba272-9663-4f80-bb83-9b8f396124a9">
        <updating/>
        <source>doCreateCharge(_passport: CM_Passport): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2021	navndl1	Initial creation	TFS 51443

*/

vars

begin
	
	self.createCharge();
	
	return not _passport.hasErrorsOrWarnings();

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doResyncInvoiceLines" id="d2196f72-609f-498a-b96a-53407e83a0fb">
        <source>doResyncInvoiceLines(_sbController : CMIF_ServiceBroker input);
/*
Purpose:		TFS 39237	
Date			Who			Reason
JUNE 2018		CNWAB1		Initial creation
05 Oct 2022	   	navma1		Bug 52967: STWO - Cargo Delivery Process &amp; System Lock Details
23 Oct 2024 	navlw1 		JIRA-33107: Invoice Logging Use Levels
31 Jan 2025		navlw1 		JIRA-33865: MTN | Logging only displays that financials aren't enabled in logging level is TRACE
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	invLine 	 : CM_InvoiceLine;
	invLineTypes : CM_InvoiceLineDescArray;
	invLineDesc  : CM_InvoiceLineDesc;
	reject 	     : Boolean;
	bu 			 : CM_Bank;
	canLogExtra	 : Boolean;
	tmpDebtor	 : CM_Debtor;
	term 		 : CM_Terminal;
begin
	
	canLogExtra := app.canLogExtraDetail();			//05.10.2022 navma1 #52967
	bu 		    := _sbController.myBank;

	// ### TFS DEFECT 59153 17JUL2023 NAVAB1
	if self.noCharge then
		if canLogExtra then
			app.invLog("Transaction " &amp; self.getDescription() &amp; " has NOCHARGE set to TRUE", LogINFO.String);
		endif;
		return;
	endif;
	
	create invLineTypes transient;
	
	// Start navlw1 #JIRA-33865 31/01/2025
	term := self.myTerminal;
	if term = null then
		app.raiseUnexpectedProgramError(class.name, method.name, CM_TITransaction::myTerminal.name &amp; " is null.");
		return;
	endif;
	if not term.getConfig(FinancialsEnabled).Boolean then
		if canLogExtra then											//26.02.2025 navah1	#34141
			app.invLog("Financials Are Not Enabled, No Charging Will Occur",LogTRACE.String); // navlw1 #JIRA-33692  // ### JIRA 35228 11JUL2025 NAVAB1
		endif;
		return;
	endif;
	if not app.myRoot.canDo(Mod_Invoicing) then
		if canLogExtra then												 //26.02.2025 navah1 #34141
			app.invLog("Invoice Module is not licensed",LogINFO.String); // navlw1 #JIRA-33692
		endif;
		return;
	endif;
	// End navlw1 #JIRA-33865 31/01/2025
	
	//20/11/2024	navkc1 JIRA Story MTN-33012
	tmpDebtor := self.getMyDebtor();
	
	foreach invLine in self.allInvoiceLines discreteLock where invLine.status &lt;&gt; CM_InvoiceLine.STATUS_VOIDED do
		
		reject := true;
		
		//20/11/2024	navkc1 JIRA Story MTN-33012 - reevaluate so it gets charged to the correct debtor
		if tmpDebtor &lt;&gt; invLine.debtor then
			invLine.reevaluate();
		endif;
		
		invLineTypes.clear;
		_sbController.allInvoiceLineTypes.copy(invLineTypes);
		foreach invLineDesc in invLineTypes discreteLock do
			if invLine.invoiceLineDesc = invLineDesc then
				// take out any invoiceline type that we have already charged correctly for
				_sbController.allInvoiceLineTypes.remove(invLineDesc);
				reject := false;
				invLine.setFromQuantityRangeMap(_sbController.getQRMFromLineType(invLineDesc));
				if canLogExtra then							// 05.10.2022 navmd1 #52967
					app.invLog(invLine.invoiceLineDesc.narration.removeCrLfs &amp; " - existing invoice line " &amp; invLine.sequenceNum.String &amp; " of invoice " &amp; invLine.invoice.sequenceNum.String, LogTRACE.String);
				endif;
			endif;
		endforeach;
		
		if reject then
			// should not have been charged so void it
			if canLogExtra then								//05.10.2022 navma1 #52967
				app.invLog("Invoice line " &amp; invLine.sequenceNum.String &amp; " of invoice " &amp; invLine.invoice.sequenceNum.String &amp; " voided", LogTRACE.String);
			endif;
			invLine.changeStatus(CM_InvoiceLine.STATUS_VOIDED);
		endif;
	endforeach;

epilog 

	delete invLineTypes;
	
end;</source>
        <Parameter name="_sbController" type="CMIF_ServiceBroker" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getBerthFromWOForPaymentType" id="b8d77db4-f647-4238-a855-7123e366062d">
        <source>getBerthFromWOForPaymentType():HMS_Berth;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 October 2018	jlgndl1	Initial creation	TFS 41281

*/

vars

begin

	if self.myWorkOrder &lt;&gt; null then
		return self.myWorkOrder.getBerthForPaymentType();
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="getCargoBOLs" id="20476d91-6f1d-461b-a6e4-1ddaa14e6c6a">
        <source>getCargoBOLs():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Jan 2023	navhl20	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
08 Feb 2023 navma1  ChangeRequest 56457:[56458] EUP - Allowing different sets of cargo items per work order task [Refactor]
04 Aug 2023	navlw1	ChangeRequest 59284:[59660] EUP | FR - VAS Work Order Transactions - Fixing Duplicate Values 

*/

vars

begin
	
	if not self.hasCargoWorkOrderDetails  then
		return null;
	endif;

	return self.myWorkOrderDetail.CM_WorkOrderTIDtl.allSelectedTIs.listStringNoDuplicate(Comma,CM_TrackedItem::billOfLading.name);
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCargoColours" id="53bc31b2-4cb9-4407-a3f6-0c4ac060ff78">
        <source>getCargoColours():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Jan 2023	navhl20	ChangeRequest 54350:[54269] EUP - VAS Work Orders Selector Query
08 Feb 2023 navma1  ChangeRequest 56457:[56458] EUP - Allowing different sets of cargo items per work order task [Refactor]
04 Aug 2023	navlw1	ChangeRequest 59284:[59660] EUP | FR - VAS Work Order Transactions - Fixing Duplicate Values 
*/


vars
	ti  	: CM_TrackedItem;
	str,
	attrStr	: String;
begin
	
	if not self.hasCargoWorkOrderDetails  then
		return null;
	endif;
	
	
	foreach ti in self.myWorkOrderDetail.CM_WorkOrderTIDtl.allSelectedTIs do	//08.02.2023 navma1 #56457:[56458]
		// 04.08.2023 navlw1 tfs #59284:#59660
		attrStr :=  ti.getColour;
		
		if not str.cnContains(attrStr)then
			if str &lt;&gt; null then
				str :=  str &amp; Comma &amp; attrStr ;
			
			else
				str := attrStr;
			endif;
		endif;
	endforeach;
	
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCargoCommodity" id="efdee874-fc66-42d8-be44-ddf8c7aa27eb">
