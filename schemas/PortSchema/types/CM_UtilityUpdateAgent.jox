        <source>utlUpdateBGPEmailRequests(_bgpEmailDict : BGP_EmailReqByUserAddressDict input; _passport : CM_Passport input);
//-----------------------------------------
// Created: 20 May 2005 By: cnwgd1
//-----------------------------------------
vars
	tmpBGPEmail : BGP_EmailSendRequest;
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(false);
//	self.raiseExceptionIfNull(_bgpEmailDict, '_bgpEmailDict');
	
	foreach tmpBGPEmail in _bgpEmailDict do
