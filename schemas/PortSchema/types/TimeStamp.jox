    <JadeMethod name="getDifferenceInMinsFromTo" id="b5fb2160-1a61-4d43-8f61-820f469685f4">
        <source>getDifferenceInMinsFromTo(_timeStamp:TimeStamp) : Integer;
// ---------------------------------------------------------------------------
// Created:     17 February 2008 by cnwrs2
//
// Purpose:     Returns the difference in minutes from self to the passed in
//				timestamp.  Will return -ve value if _timeStamp &lt; self
// ---------------------------------------------------------------------------
vars
	diff	: Integer;
begin
	if self.isValid() and _timeStamp.isValid() and self &lt;&gt; _timeStamp then
		diff := (self.getDifference(_timeStamp) / MillisecondsPerMinute).Integer; 
		if _timeStamp &lt; self then
			return -diff;
		endif;
		return diff;
	endif;
	
	return 0;
end;</source>
        <Parameter name="_timeStamp" type="TimeStamp"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDifferenceInMinutes" id="934158f0-8b30-44bd-9c3d-68b1428397c5">
        <source>getDifferenceInMinutes(_timeStamp:TimeStamp) : Integer;
//-----------------------------------------------------------------------
//	Created:	26 October 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
begin
	if self.isValid() and _timeStamp.isValid() then
		if self.getDifference(_timeStamp) &gt; 0.0 then
			return (self.getDifference(_timeStamp) / MillisecondsPerMinute).Integer; 
		endif;
	endif;
	
	return 0;
end;</source>
        <Parameter name="_timeStamp" type="TimeStamp"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
