    <JadeMethod name="validateForProcess" id="85b240d7-4f93-4665-8505-bb6b22dbe39e">
        <updating/>
        <source>validateForProcess(_passport : CM_Passport input): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     Jan 2010 par 21329
//
// Purpose:     Standard validating when the receiver is processed.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	// 21/02/2014 cnwar2 #33202
	if not (self.action.isBlank() or
			self.action = CM_EDITrackedItem.EDI_ACTION_ADD or
			self.action = CM_EDITrackedItem.EDI_ACTION_UPDATE or
			self.action = CM_EDITrackedItem.EDI_ACTION_DELETE) then
		app.raiseCMException(InvalidEDIAction, null, self.myUserObject);
		return false;
	endif;

	if self.action = CM_EDITrackedItem.EDI_ACTION_ADD then
		return self.validateForCreate(_passport);
	elseif self.action = CM_EDITrackedItem.EDI_ACTION_UPDATE then
		return self.validateForUpdate(_passport);
	elseif self.action = CM_EDITrackedItem.EDI_ACTION_DELETE then
		return self.validateForDelete(_passport);
	endif;
	return true;
end;
</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="0f623647-9dcf-4637-a3e4-6ea2d8a4e690">
