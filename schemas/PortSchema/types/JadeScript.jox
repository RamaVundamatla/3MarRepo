    <JadeMethod name="rel792_par28940" id="a75009cf-b6de-408f-b296-49bec0aae86d">
        <source>rel792_par28940();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 February 2012	cnwrd1	Initial creation

*/

vars
	roroLane 	: CM_RoRoController;
	aTI 		: CM_TrackedItem;
begin
	app.initialize();
	
	beginTransaction;
	foreach roroLane in CM_RoRoController.instances do	
		foreach  aTI in roroLane.allTrackedItems do
			aTI.refreshLocationId(REAL_MODE);
		endforeach;
	endforeach;
	
	commitTransaction;
epilog

end;</source>
    </JadeMethod>
