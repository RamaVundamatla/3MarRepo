    </JadeMethod>
    <JadeMethod name="getSpecialStowStr" id="618a8b2c-cd30-429f-9c36-de4024fd46fa">
        <source>getSpecialStowStr(): String;
//----------------------------------------------------------------
//	Created:	30 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	invalid 		: Boolean;
	commGrp			: CM_CommodityGroup;
	
begin

	if self.getAttrHazardous() then
		return app.getErrorString(HazardousAbbrev);
	////elseif self.overDimension then //+ Par 22101
	elseif self.getAttrOverDimensioned() then								// 15/10/2010 cnwmh5 #25626
		return "ODIM"; //+ Par 22101
	else
		commGrp := self.getAttrCommodityGroup();
		if commGrp &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, commGrp, invalid);
			if commGrp.isSpecialStow then
				return commGrp.code;
			endif;
		endif;
	endif;
	
	return null;
	
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTIofMode" id="a3e3c96e-6c55-4c00-905e-3c55a9b0f03f">
        <source>getTIofMode(_theMode : Integer) : CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:		August 2010 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	aOK : Boolean;
	aWLE : CM_WorkListEntry;
begin
	
	foreach aWLE in self.allWorkListEntries do
		if aWLE.myTrackedItem &lt;&gt; null then
			if _theMode = PLANNING_MODE then
				if aWLE.myTrackedItem.myPrimaryPlannedLocation &lt;&gt; null then
					return aWLE.myTrackedItem;
					break;
				endif;
			elseif _theMode = REAL_MODE then
				if aWLE.myTrackedItem.myPrimaryActualLocation &lt;&gt; null then
					return aWLE.myTrackedItem;
					break;
				endif;
			elseif _theMode = QUEUE_MODE then
				if aWLE.myTrackedItem.myPrimaryQueuedLocation &lt;&gt; null then
					return aWLE.myTrackedItem;
					break;
				endif;
			endif;
		endif;
	endforeach;
	
	return null;
end;</source>
        <Parameter name="_theMode" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getTargetLocationID" id="533e7f86-33a5-4061-990e-9d75540cdaad">
        <source>getTargetLocationID(): String;
// ---------------------------------------------------------------------------
// Created:     11 December 2014 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lc :CM_LocationsController;
	id : String;
	invalidObj : Boolean;
begin
	on Exception do app.handleDeletedObject(exception,lc,invalidObj);
	
	lc:= self.mySlotController;
	if lc &lt;&gt; null then
		id := lc.getFullId;
	endif;
	
	if invalidObj then
		return null;
	endif;
	
	return id;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
