    <JadeMethod name="getMaxRowColString" id="6775ed79-3a16-4710-aa0b-4a93f141d17a">
        <source>getMaxRowColString( _maxRowCol : String output ): Boolean;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/01/2009	cnwjk3	SFW1030
17/11/2011	cnwdap1	PAR #28514 Return row/col or col/row, depending on whether we're a "location id is column then row" location
*/
vars

begin

	if self.numberOfColumns &gt; 0 and self.numberOfRows &gt; 0 then
		if self.areLocationIdsColThenRow then																								// PAR #28514
			_maxRowCol := self.getMinColLabel() &amp; "-" &amp; self.getMaxColLabel() &amp; " " &amp; self.getMinRowLabel() &amp; "-" &amp; self.getMaxRowLabel();	// PAR #28514
		else																																// PAR #28514
			_maxRowCol := self.getMinRowLabel() &amp; "-" &amp; self.getMaxRowLabel() &amp; " " &amp; self.getMinColLabel() &amp; "-" &amp; self.getMaxColLabel();
		endif;																																// PAR #28514
		return true;
	endif;
	return false;
epilog

end;</source>
        <Parameter name="_maxRowCol" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
