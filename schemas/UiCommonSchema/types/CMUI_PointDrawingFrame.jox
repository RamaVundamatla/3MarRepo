    <JadeMethod name="setCurrentPoint" id="b7ec3cc1-1f96-48ba-979d-07ad619e2e7f">
        <updating/>
        <source>setCurrentPoint(_point : Point) : Boolean updating;
/*
Purpose:	PAR 28008 highlight the current point that is being edited in th dimension table		
Date		Who		Reason
15 August 2011	cnwab1	Initial creation
*/

vars

begin
	if _point = self.dragLastPoint then
		return false;
	endif;
	
	self.dragLastPoint := _point;
	
	return true;
epilog

end;</source>
        <Parameter name="_point" type="Point"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDefaultFont" id="395fcaae-54c6-4b33-a944-69592b2f677a">
        <source>setDefaultFont(_frame : Frame input);
// ---------------------------------------------------------------------------
// Created:     27 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if _frame = null then 
		return;
	endif;
	
	_frame.drawFontName := Font_MicrosoftSansSerif;
	_frame.drawFontSize := 8;
end;</source>
