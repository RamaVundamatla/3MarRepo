        <updating/>
        <source>txtDescription_lostFocus(textbox: TextBox input) updating;
// ---------------------------------------------------------------------------
// Created:     24 November 2009 by cnwcs5
// Purpose:     CCMS 1028 - summary mappings
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	proxy	:CM_XTABMapping;
	value	:String;
begin
	proxy 	:= self.myProxyObject.CM_XTABMapping;
	value	:= textbox.text.trimBlanks;
	
	if proxy.description &lt;&gt; value then
		proxy.setDescription (value);
	endif;
epilog

end;</source>
