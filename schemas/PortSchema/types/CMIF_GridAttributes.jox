<Class name="CMIF_GridAttributes" id="c17bce3d-8183-49ab-88c0-8fedaad53e3b">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <CompAttribute name="allDisplayCodes" id="55d77f78-c082-4bd5-8f78-36a80349ced1">
        <type name="StringArray"/>
    </CompAttribute>
    <CompAttribute name="allDisplayColors" id="76d51cbb-f3e5-49fb-a440-7c24d040fa34">
        <type name="IntegerArray"/>
    </CompAttribute>
    <CompAttribute name="allDisplayIcons" id="ac527ba7-1bf4-4449-9d40-294c91ba3e0a">
        <type name="StringArray"/>
    </CompAttribute>
    <ImplicitInverseRef name="allDisplayObjects" id="d2277e94-12fc-4960-852a-436e2d240ee3">
        <memberTypeInverse/>
        <type name="ObjectArray"/>
        <text>These are used purely for notifications. If the user changes a colours or code the point is updated.</text>
    </ImplicitInverseRef>
    <PrimAttribute name="height" id="9465ff14-4b74-4ac5-9023-22d84e2ef3fb">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="id" id="9697edd3-168d-4c59-92a7-d64b9e3cfccc">
        <length>21</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="weight" id="651d7018-e885-4529-bfd9-9d00d5079fcc">
        <precision>14</precision>
        <scaleFactor>4</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
    </PrimAttribute>
    <PrimAttribute name="width" id="2bdbad7b-072a-40a6-b148-cb15a2166c28">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="nullMe" id="e8615a48-3744-4ac7-a178-24d452d05de6">
        <updating/>
        <source>nullMe() updating;
// ---------------------------------------------------------------------------
// Created:     26 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.height := null;
	self.id 	:= null;
	self.weight := null;
	self.width 	:= null;
	
	self.allDisplayColors.clear;
	self.allDisplayIcons.clear;
	self.allDisplayObjects.clear;
//	self.allDisplayCodes.clear;	// check with AB if this should be happening

end;</source>
    </JadeMethod>
</Class>
