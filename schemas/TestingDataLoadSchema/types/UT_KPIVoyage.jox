    <JadeMethod name="createExchangeDates" id="01d7f676-a947-4145-90db-ceb6bc8b69bc">
        <source>createExchangeDates(_voy : CM_Voyage input);
// ---------------------------------------------------------------------------
// Created:     24 August 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 15/03/2018		jlgdap1			TFS 37427 PEL1 Voyage Status Enhancements
// ---------------------------------------------------------------------------

vars
	_pilotOnBoardDT,
	_labourOB,
	_labourOS:TimeStamp;
	_shipExchangeDT,
	_shipExchangeCompleteDT,
	_departTargetDT	: TimeStamp;
	_pilotReturnDT : TimeStamp;
	_anchorDownDT : TimeStamp;
	
	dte : Date;
	tme : Time;
	
begin
	dte := _voy.arrivedDT.date;
	tme := _voy.arrivedDT.time;
	
	

	tme := tme - 3600000;
	_pilotOnBoardDT.setDate(dte);
	_pilotOnBoardDT.setTime(tme);

	tme := _voy.arrivedDT.time;
	tme := tme + 3600000;
	_anchorDownDT.setDate(dte);
	_anchorDownDT.setTime(tme);
	tme := tme + 3600000;
	_labourOB.setDate(dte);
	_labourOB.setTime(tme);
	tme := tme + 3600000;
	_shipExchangeDT.setDate(dte);
	_shipExchangeDT.setTime(tme);
	tme := tme + 3600000;
	_shipExchangeCompleteDT.setDate(null);
	_shipExchangeCompleteDT.setTime(null);
	tme := tme + 3600000;
	_labourOS.setDate(dte);
	_labourOS.setTime(tme);
	tme := tme + 3600000;
	_departTargetDT.setDate(dte);
	_departTargetDT.setTime(tme);
	tme := tme + 3600000;
	_pilotReturnDT.setDate(dte);
	_pilotReturnDT.setTime(tme);

	_voy.setProxyExchangeData(_voy.starboardBerthed, 
											_pilotOnBoardDT, 
											_labourOB,
											_labourOS,
											_voy.dateFirstAvailable,
											_shipExchangeDT,
											_shipExchangeCompleteDT,
											_departTargetDT,
											_voy.totalTimeInPort,
											_voy.nonChargeTime,
											_voy.stopChargingAt,
											_voy.loadRate,
											_voy.dischargeRate,
											_voy.status,
											_pilotReturnDT,
											_anchorDownDT,
											false,
											_voy.myVoyageProcess				// TFS 37427
											);
	
epilog

end;</source>
        <Parameter name="_voy" type="CM_Voyage" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createExtraMovesDetails" id="e4e3da35-7d65-4db8-af11-2d0349998b72">
        <source>createExtraMovesDetails(_voy : CM_Voyage input);
// ---------------------------------------------------------------------------
// Created:     24 August 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	controller : CMIF_VoyageExtraMoveDtl;
begin
	
	write "Create extra move details";
	app.writeLog("Create extra move details", LogINFO);
	
	create controller transient;
	controller.setFromVoyage(_voy);
	controller.numCageMoves := 100;
	controller.numExtraMoves := 200;
	controller.numLashingBinMoves := 300;
	controller.numLashings := 400;
	controller.numUnlashings := 500;
	
	app.myTrxUA.trxSetVoyageExtraMoveDtls(controller, app.myPassport);		
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), "Extra Move Problems &gt;&gt;&gt; " &amp; app.myPassport.getAllErrorsWarningsAsString());

//	beginTransaction;
//	_voy.setExtraMoveDtls(controller,app.myPassport);
//	commitTransaction;
epilog
	delete controller;
end;</source>
        <Parameter name="_voy" type="CM_Voyage" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createLidJobs" id="f7ea71fc-5d49-4d8c-8193-4033548acb4b">
        <updating/>
        <source>createLidJobs() updating;
// ---------------------------------------------------------------------------
// Created:     04 June 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	bay : CM_Bay;
	req : CM_SlotRequest;
	voy : CM_Voyage;
begin
	
	write "Create lid jobs";
	app.writeLog("Create lid jobs", LogINFO);
	
	
	//voy := self.getVoyage("OPSVIEW001");
	foreach bay in voyage.myCellularVoyageStructure.allBayVoyagesById discreteLock do
		// create a hatchlid job if we have under deck colour coding
		foreach req in bay.CM_BayVoyage.allSlotRequestByMoveType  discreteLock do
			if req.mySlotController.ordinalDeck = DeckUnderDeck then
				self.createHatchLidJobs(bay, "COV1");
				break;
			endif;
		endforeach;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createOpsViewCrane" id="e3c96e96-4dde-4ea1-b1c5-b3715ccc982b">
        <source>createOpsViewCrane(craneId : String) : CM_Crane;

vars

	crane					: CM_Crane;
	ctaArea					: CM_TerminalArea;
	cta						: CM_CraneTransferArea;
	
	tas						: StringArray;
	
	ctaAreaName				: String;

begin
	
	write "Creating crane: " &amp; craneId;
	app.writeLog("Creating crane: " &amp; craneId, LogINFO);
	
	// delete the crane
	self.deleteMachine(craneId);
		
	// setup the CTA Area
	ctaAreaName := craneId &amp; "1";
	self.deleteTerminalArea(ctaAreaName);
	cta := self.addCraneTransferArea(ctaAreaName);
	self.assertNotNull(cta);
	
	create tas transient;
	tas.add(cta.id);
		
	self.opts.addAssoc("CraneTransferArea", cta);
		
	crane := self.addCrane(craneId, null, tas, null).CM_Crane;
	self.assertNotNull(crane);
	
	return crane;

epilog

	delete tas;
	
end;
</source>
        <Parameter name="craneId" type="String"/>
        <ReturnType type="CM_Crane"/>
    </JadeMethod>
    <JadeMethod name="createVesselVoyage" id="3304a8c0-0f9a-4d1d-ae29-5b049e424af2">
        <updating/>
        <source>createVesselVoyage(_voyage : String; _vessel : String; _operator :CM_Operator) : CM_Voyage updating;
// ---------------------------------------------------------------------------
// Created:     28 May 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	locations : CM_LCArray;
	ya: CM_YardAllocation;
	ti1, ti2: CM_TrackedItem;
	location: CM_LocationsController;
	voyage1: CM_Voyage;
	voyage2: CM_Voyage;
	vessel: CM_Vessel; 
	
begin
	voyage1 := self.getVoyage(_voyage);
	if voyage1 &lt;&gt; null then
		self.loadAllJobsToOps(voyage1, false);
	endif;
	deleteVoyage(_voyage);
	deleteVessel("UTBISHOP");
	
	vessel := self.addVesselLOLOholdsRORO("UTBISHOP", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	
	
	
	
	
	self.addVesselDefnReefer40(vessel);

	voyage1:=self.addVoyageWithConRORO(_voyage, "UTBISHOP", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString, null, 0, false, true);
	
	
	
	
	return voyage1;
epilog

end;</source>
        <Parameter name="_voyage" type="String"/>
        <Parameter name="_vessel" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="createVoyage" id="e9f6f930-80f3-4240-ab9c-984df93c3f8f">
        <updating/>
        <source>createVoyage(_voyage : String) : CM_Voyage updating;
// ---------------------------------------------------------------------------
// Created:     28 May 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	voyage				: CM_Voyage;
	terminal			: CM_Terminal;
	dsl					: UT_DSL;
	oldVessel, vessel	: CM_Vessel;
begin
	
	write "Deleting voyage: " &amp; _voyage;
	app.writeLog("Creating voyage: " &amp; _voyage, LogINFO);
		
	// clone vessel
	oldVessel := app.myRoot.getVesselByName("OPSVIEW 1");
	self.assertNotNull(oldVessel);
	
	// clone the vessel
	vessel := self.cloneVessel(VesselId, oldVessel);
	self.assertNotNull(vessel);
	
	// Edit vessel name
	self.opts.purge();
	self.opts.addAssoc("VesselName", VesselId);
	self.updateVessel(vessel);
	self.assertNoTrxErrorsOrWarnings();
	
	self.addVesselHolds(VesselId);
	
	voyage := self.getVoyage(OldVoyage);
	if voyage &lt;&gt; null then
		self.loadAllJobsToOps(voyage, false);
	endif;
	deleteVoyage(OldVoyage);
	
	//voyage:=self.addVoyageWithConRORO(_voyage, "OPSVIEW", "MSL", "MSL", "New Zealand East Coast", 0, false, true);
	create dsl transient;
	//dsl.setActiveProfileMDHONLY();
	dsl.opts.purge();
	dsl.opts.addAssoc("Trade", "New Zealand East Coast");
	dsl.opts.addAssoc("UseAllocations", true);
	write "Creating voyage: " &amp; _voyage;
	voyage := self.addVoyageWithContainerStructurOpsview(_voyage, VesselId, "MSL", "NZEC");
	write "voyage created: " &amp; _voyage;
	return voyage;
	
epilog

end;</source>
        <Parameter name="_voyage" type="String"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="createVoyageDischargeJobs" id="75a044f9-98b1-4573-8059-679bdc850524">
        <source>createVoyageDischargeJobs();
// ---------------------------------------------------------------------------
// Created:     02 June 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	//voyage : CM_Voyage;
	voyageJob : CM_VoyageJob;
	slots : CM_SlotControllerArray;
	roroLCs : CM_LCArray; //CM_VoyageROROControllerArray;
	tmpLoadCC	: CMIF_LoadColorCode;
	theDeck : CM_DeckVoyage;
	cellIdx : Integer;
begin
	
	write "Create voyage discharge jobs";
	app.writeLog("Create voyage discharge jobs", LogINFO);
	
	// ### LOLO DISCHARGE JOB
	create slots transient;
	//voyage := self.getVoyage(voyage.code);
	self.getJobSlotControllers(voyage.code,"01",DeckOnDeck,1,1,24,slots);
	voyageJob:=self.addVoyageJob(voyage, "COV1",slots, true);
	assertTrue(voyageJob &lt;&gt; null);
	
	
	foreach cellIdx in 1 to 6 do
		slots.clear;
		self.getJobSlotControllers(voyage.code,"09",DeckOnDeck,cellIdx,2,3,slots);
		voyageJob:=self.addVoyageJob(voyage, "COV2",slots, true);
		assertTrue(voyageJob &lt;&gt; null);
	endforeach;
	
	/*
	// ### RORO SLOT DISCHARGES
	create roroLCs transient;
	theDeck := voyage.myROROStructure.allDecksByCode[DECK1];
	self.getJobROROSlotController(voyage.code, DECK1, roroLCs, false,104);
	self.getJobROROControllerByID(voyage.code,DECK1, null, "DD1071O1", roroLCs, false, 1); 
	self.getJobROROControllerByID(voyage.code,DECK1, null, "DD1073O1", roroLCs, false, 1); 
	self.getJobROROControllerByID(voyage.code,DECK1, null, "DD1074O1", roroLCs, false, 1); 
	self.getJobROROControllerByID(voyage.code,DECK1, null, "DD1074O2", roroLCs, false, 1); 
	self.getJobROROControllerByID(voyage.code,DECK1, null, "DD1076O1", roroLCs, false, 1); 
	self.getJobROROControllerByID(voyage.code,DECK1, null, "DD1076O2", roroLCs, false, 1); 

	voyageJob:=self.addVoyageROROJob(voyage,theDeck, "UT_KPI",roroLCs, true);
	assertTrue(voyageJob &lt;&gt; null);
	
	
	roroLCs.clear();
	self.getJobROROControllerByID(voyage.code,DECK1, null, "AUTOLOCN421", roroLCs, false, 1); 
	self.getJobROROControllerByID(voyage.code,DECK1, null, "AUTOLOCN422", roroLCs, false, 1); 
	self.getJobROROControllerByID(voyage.code,DECK1, null, "AUTOLOCN423", roroLCs, false, 1); 
	self.getJobROROControllerByID(voyage.code,DECK1, null, "AUTOLOCN491", roroLCs, false, 1); 
	self.getJobROROControllerByID(voyage.code,DECK1, null, "AUTOLOCN492", roroLCs, false, 1); 
	self.getJobROROControllerByID(voyage.code,DECK1, null, "AUTOLOCN493", roroLCs, false, 1); 
	self.getJobROROControllerByID(voyage.code,DECK1, null, "AUTOLOCN561", roroLCs, false, 1); 
	self.getJobROROControllerByID(voyage.code,DECK1, null, "AUTOLOCN562", roroLCs, false, 1); 
	self.getJobROROControllerByID(voyage.code,DECK1, null, "AUTOLOCN563", roroLCs, false, 1); 
	
	
	voyageJob:=self.addVoyageROROJob(voyage,theDeck, "UT_KP2",roroLCs, true);
	assertTrue(voyageJob &lt;&gt; null);
	
	
	
	// ### RORO GC DISCHARGES
	roroLCs.clear();
	theDeck := voyage.myROROStructure.allDecksByCode[DECK1];
	self.getJobROROGCController(voyage.code, DECK1, roroLCs, false);

	voyageJob:=self.addVoyageROROJob(voyage,theDeck, "UT_KPI",roroLCs, true);
	assertTrue(voyageJob &lt;&gt; null);
	*/

epilog
	delete slots;
	delete roroLCs;
end;</source>
    </JadeMethod>
    <JadeMethod name="createVoyageLoadJobs" id="5783a943-d604-4d82-8c05-fc9ed9828c5e">
        <source>createVoyageLoadJobs();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 December 2008	cnwer1	Initial creation

*/

vars
	//voyage : CM_Voyage;
	voyageJob : CM_VoyageJob;
	slots : CM_SlotControllerArray;
	tmpLoadCC	: CMIF_LoadColorCode;
begin
	
	write "Create voyage load jobs";
	app.writeLog("Create voyage load jobs", LogINFO);
	
	//create a voyage job for bay 
	
	//voyage := self.getVoyage("OPSVIEW001");
	create slots transient;
	create tmpLoadCC transient;
	tmpLoadCC.overrideMoveType :=true;
	tmpLoadCC.myDischargePort:=app.myRoot.allPorts["NZAKL"];

	
	// ### GET SLOTS NOTE - tier ordinals start at bottom left, cell tiers start at top left.
	// 40 GENL
	self.getJobSlotControllers(VoyageId,"01",DeckOnDeck,1,1,6,slots);
	tmpLoadCC.myCommodityGroup := null;
	self.markSlotsAsLoadJob(slots,tmpLoadCC);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Forty);
	slots.clear;
	// 20 GENL
	self.getJobSlotControllers(VoyageId,"01",DeckOnDeck,2,3,6,slots);
	tmpLoadCC.myCommodityGroup := null;
	self.markSlotsAsLoadJob(slots,tmpLoadCC);
	slots.clear;

	// 40 REEFER
	self.getJobSlotControllers(VoyageId,"01",DeckOnDeck,4,1,6,slots);
	self.markSlotsAsLoadJob(slots,tmpLoadCC);
	tmpLoadCC.myCommodityGroup := app.myRoot.allCommodityGroups["FROZ"];
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Forty);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Power);
	slots.clear;

	// 20 REEFER
	self.getJobSlotControllers(VoyageId,"01",DeckOnDeck,5,3,6,slots);
	tmpLoadCC.myCommodityGroup := app.myRoot.allCommodityGroups["FROZ"];
	self.markSlotsAsLoadJob(slots,tmpLoadCC);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Power);
	slots.clear;

	// 40 EMPTY
	self.getJobSlotControllers(VoyageId,"01",DeckUnderDeck,1,1,5,slots);
	tmpLoadCC.myCommodityGroup := null;
	self.markSlotsAsLoadJob(slots,tmpLoadCC);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Forty);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Empty);
	slots.clear;


	// 40 GENL OD
	self.getJobSlotControllers(VoyageId,"01",DeckUnderDeck,2,3,5, slots);
	tmpLoadCC.myCommodityGroup := null;
	self.markSlotsAsLoadJob(slots,tmpLoadCC);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Forty);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_OD);
	slots.clear;
	
	
	/// ## MAKE JOB
	self.getJobSlotControllers(VoyageId,"01",DeckOnDeck,1,1,24,slots);
	self.getJobSlotControllers(VoyageId,"01",DeckUnderDeck,1,1,10,slots);
	voyageJob:=self.addVoyageJob(voyage, "COV1",slots, false);
	assertTrue(voyageJob &lt;&gt; null);

epilog
	delete slots;
	delete tmpLoadCC;

end;</source>
    </JadeMethod>
    <JadeMethod name="createVoyageLoadJobsHighC" id="2b0e4504-c92e-4af4-b083-5dcfafdd031a">
        <source>createVoyageLoadJobsHighC();
//24 September 2010	cnwas3	  

vars
	//voyage : CM_Voyage;
	voyageJob : CM_VoyageJob;
	slots : CM_SlotControllerArray;
	tmpLoadCC	: CMIF_LoadColorCode;
begin
	//create a voyage job for bay 
	
	//voyage := self.getVoyage("OPSVIEW001");
	create slots transient;
	create tmpLoadCC transient;
	tmpLoadCC.overrideMoveType :=true;
	tmpLoadCC.myDischargePort:=app.myRoot.allPorts["NZAKL"];

	
	// ### GET SLOTS NOTE - tier ordinals start at bottom left, cell tiers start at top left.
	// 40 GENL
	self.getJobSlotControllers(voyage.code,"01",DeckOnDeck,1,1,6,slots);
	self.markSlotsAsLoadJob(slots,tmpLoadCC);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Hicubed);
	
	voyageJob:=self.addVoyageJob(voyage,"COV1",slots, false);
	assertTrue(voyageJob &lt;&gt; null);

epilog
	delete slots;
	delete tmpLoadCC;

end;</source>
    </JadeMethod>
    <JadeMethod name="createVoyageLoadJobsVA" id="9e792581-8e6c-4c04-90de-f5d685f916a2">
        <updating/>
        <source>createVoyageLoadJobsVA() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 December 2008	cnwer1	Initial creation

*/

vars
	altRoroLCs, roroLCs : CM_LCArray;
	realAlloc 				: CM_VoyageAllocation;
	//voyage : CM_Voyage;
	voyageJob : CM_VoyageJob;
	altSlots, slots : CM_SlotControllerArray;
	tmpLoadCC	: CMIF_LoadColorCode;
	voyageDeck : CM_DeckVoyage;
	gcDefn : CM_ROROGCDefnVoyage;
	theLCs: CM_LCArray;
	ct : CM_CargoType;
	product: CM_Product;
	theEditions : CM_ObjectByOidEditionDict;
	lc : CM_LocationsController;
	theTI : CM_TrackedItem;
	
	slotsFrom						: CM_SlotControllerArray;
	slotsTo							: CM_SlotControllerArray;
	allObjectEditions				: CM_ObjectByOidEditionDict;	
	slot							: CM_SlotController;
begin
	
	write "Create voyage load jobs (VA)";
	app.writeLog("Create voyage load jobs (VA)", LogINFO);
	
	ct	:= self.getTerminal.getFirstNonSystemCargoType().CM_CargoType;
	product := ct.allProducts.first;

	//create a voyage job for bay 
	
	//voyage := self.getVoyage("OPSVIEW001");
	create theLCs transient;
	create slots transient;
	create altSlots transient;
	create theEditions transient;
	create roroLCs transient;
	create altRoroLCs transient;

	// ### GET SLOTS. NOTE - tier ordinals start at bottom left, cell tiers start at top left.
	// 20 GENL PRENOTES
	self.getJobSlotControllers(voyage.code,"05",DeckOnDeck,1,1,4,slots);
	realAlloc := self.addVoyageAllocation2(voyage, "NZAKL", "GEN2", null, TI_CargoType_Container, false, false);
	self.addLCsToLOLOAllocation(true, realAlloc, slots, altSlots);
	slots.clear;
	
	// 40 GENL
	self.getJobSlotControllers(voyage.code,"01",DeckOnDeck,1,1,6,slots);
	realAlloc := self.addVoyageAllocation2(voyage, "NZAKL", "40BX", null, TI_CargoType_Container, false, false);
	self.addLCsToLOLOAllocation(true, realAlloc, slots, altSlots);
	slots.clear;

	// 20 GENL
	self.getJobSlotControllers(voyage.code,"01",DeckOnDeck,2,3,6,slots);
	realAlloc := self.addVoyageAllocation2(voyage, "NZAKL", "GEN2", null, TI_CargoType_Container, false, false);
	self.addLCsToLOLOAllocation(true, realAlloc, slots, altSlots);
	slots.clear;

	// 40 REEFER
	self.getJobSlotControllers(voyage.code,"01",DeckOnDeck,4,1,6,slots);
	self.opts.purge();
	self.opts.addAssoc("CommodityGroupOnly", true);
	realAlloc := self.addVoyageAllocation2(voyage, "NZAKL", "REF4", "REEF", TI_CargoType_Container, true, false);
	self.addLCsToLOLOAllocation(true, realAlloc, slots, altSlots);
	slots.clear;
	
	// 20 REEFER
	self.getJobSlotControllers(voyage.code,"01",DeckOnDeck,5,3,6,slots);
	self.opts.purge();
	self.opts.addAssoc("CommodityGroupOnly", true);
	realAlloc := self.addVoyageAllocation2(voyage, "NZAKL", "REF2", "REEF", TI_CargoType_Container, true, false);
	self.addLCsToLOLOAllocation(true, realAlloc, slots, altSlots);
	slots.clear;
	
	// 40 EMPTY
	self.getJobSlotControllers(voyage.code,"01",DeckUnderDeck,1,1,5,slots);
	self.opts.purge();
	self.opts.addAssoc("CommodityGroupOnly", true);
	realAlloc := self.addVoyageAllocation2(voyage, "NZAKL", "GEN4", "MT", TI_CargoType_Container, false, false);
	self.addLCsToLOLOAllocation(true, realAlloc, slots, altSlots);
	slots.clear;

	// 40 GENL OD
	self.getJobSlotControllers(voyage.code,"01",DeckUnderDeck,2,3,5, slots);
	realAlloc := self.addVoyageAllocation2(voyage, "NZAKL", "GEN4", "", TI_CargoType_Container, false, true);
	self.addLCsToLOLOAllocation(true, realAlloc, slots, altSlots);
	slots.clear;
	
	/// ## MAKE SLOT JOB
	self.getJobSlotControllers(voyage.code,"01",DeckOnDeck,1,1,24,slots);
	self.getJobSlotControllers(voyage.code,"01",DeckUnderDeck,1,1,10,slots);
	voyageJob:=self.addVoyageJob(voyage,"COV1",slots, false);
	assertTrue(voyageJob &lt;&gt; null);

	// 30 EMPTY
	slots.clear;
	self.getJobSlotControllers(voyage.code,"09",DeckOnDeck,1,4,1,slots);
	self.getJobSlotControllers(voyage.code,"09",DeckOnDeck,2,4,1,slots);
	self.getJobSlotControllers(voyage.code,"09",DeckOnDeck,3,4,1,slots);
	self.opts.purge();
	self.opts.addAssoc("CommodityGroupOnly", true);
	realAlloc := self.addVoyageAllocation2(voyage, "NZAKL", "30BX", "MT", TI_CargoType_Container, false, false);
	self.addLCsToLOLOAllocation(true, realAlloc, slots, altSlots);

	// 45 EMPTY
	slots.clear;
	self.getJobSlotControllers(voyage.code,"09",DeckOnDeck,1,3,1,slots);
	self.getJobSlotControllers(voyage.code,"09",DeckOnDeck,2,3,1,slots);
	self.getJobSlotControllers(voyage.code,"09",DeckOnDeck,3,3,1,slots);
	self.opts.purge();
	self.opts.addAssoc("CommodityGroupOnly", true);
	realAlloc := self.addVoyageAllocation2(voyage, "NZAKL", "45BX", "MT", TI_CargoType_Container, false, false);
	self.addLCsToLOLOAllocation(true, realAlloc, slots, altSlots);

	// 53 EMPTY
	slots.clear;
	self.getJobSlotControllers(voyage.code,"09",DeckOnDeck,1,2,1,slots);
	self.getJobSlotControllers(voyage.code,"09",DeckOnDeck,2,2,1,slots);
	self.getJobSlotControllers(voyage.code,"09",DeckOnDeck,3,2,1,slots);
	self.opts.purge();
	self.opts.addAssoc("CommodityGroupOnly", true);
	realAlloc := self.addVoyageAllocation2(voyage, "NZAKL", "53FT", "MT", TI_CargoType_Container, false, false);
	self.addLCsToLOLOAllocation(true, realAlloc, slots, altSlots);
	
	// PAR 28522 ADD LOAD CC for PRENOTES to a JOB
	/*slots.clear;
	self.getJobSlotControllers(voyage.code,"05",DeckOnDeck,1,1,4,slots);
	voyageJob:=self.addVoyageJob(voyage,"COV1",slots, false);
	assertTrue(voyageJob &lt;&gt; null);
	self.pnJobNum := voyageJob.id;
*/

	/*
	// PAR 28968 DLR from LOL to RORO linked
	theEditions.clear();
	slots.clear;
	altRoroLCs.clear();
	roroLCs.clear();
	// GET LOLO DLR
	self.getJobSlotControllers(voyage.code,"09",DeckOnDeck,3,1,1,slots); 
	// GET RORO DLR
	self.getJobROROControllerByID("OPSVIEW001",DECK1, null, "AUTOLOCN351", altRoroLCs, true, 1);
	slots.copyNoDuplicates(theEditions);
	altRoroLCs.copyNoDuplicates(theEditions);
	slots.copyNoDuplicates(roroLCs);
	app.myTrxUA.doRORORequestDLRSoB(roroLCs, altRoroLCs, false,DLR_MOVETYPE, theEditions, app.myPassport);	
	self.assertNoTrxErrorsOrWarnings();
	theTI := roroLCs.last.allTrackedItems.first;
	self.assertTrueMsg(theTI.isRehandle, theTI.id &amp; " should be a DLR Rehandle");
	voyageJob:=self.addVoyageJob(voyage,"COV2",slots, true);
	assertTrue(voyageJob &lt;&gt; null);

	// PAR 28968 SoB from LOLO to RORO linked
	theEditions.clear();
	slots.clear;
	altRoroLCs.clear();
	roroLCs.clear();
	// GET LOLO SOB
	self.getJobSlotControllers(voyage.code,"09",DeckOnDeck,2,1,1,slots); 
	// GET RORO SOB
	self.getJobROROControllerByID("OPSVIEW001",DECK1, null, "AUTOLOCN302", altRoroLCs, true, 1);
	slots.copyNoDuplicates(theEditions);
	altRoroLCs.copyNoDuplicates(theEditions);
	slots.copyNoDuplicates(roroLCs);
	app.myTrxUA.doRORORequestDLRSoB(roroLCs, altRoroLCs, false,SOB_MOVETYPE, theEditions, app.myPassport);	
	self.assertNoTrxErrorsOrWarnings();
	theTI := roroLCs.last.allTrackedItems.first;
	self.assertTrueMsg(theTI.isSOB, theTI.id &amp; " should be a SOB Shift on Board");
	voyageJob:=self.addVoyageJob(voyage,"COV2",slots, true);
	assertTrue(voyageJob &lt;&gt; null);
	*/
	
	// PAR 28522 ADD COLOUR CODING for DLR
	/*
	// ### DISCHARGE
	slots.clear;
	theEditions.clear();
	self.getJobSlotControllers(voyage.code,"05",DeckOnDeck,3,1,4,slots);
	self.getJobSlotControllers(voyage.code,"07",DeckOnDeck,3,1,4,slots);
	slots.copyNoDuplicates(theEditions);
	app.myTrxUA.trxUpdateSlotRequestAttribute(slots, altSlots, false, theEditions, CM_SlotRequest.Attribute_SOB, null, app.myPassport);	

	self.assertNoTrxErrorsOrWarnings();
	voyageJob:=self.addVoyageJob(voyage,"COV2",slots, true);
	assertTrue(voyageJob &lt;&gt; null);

	// ### LOAD
	slots.clear;
	theEditions.clear();
	
	self.getJobSlotControllers(voyage.code,"05",DeckOnDeck,3,1,4,slots);
	self.getJobSlotControllers(voyage.code,"07",DeckOnDeck,3,1,4,slots);
	realAlloc := self.addVoyageAllocation2(voyage, "NZAKL", "U20G", null, TI_CargoType_Container, false, false);
	self.addLCsToLOLOAllocation(true, realAlloc, slots, altSlots);
	slots.copyNoDuplicates(theEditions);
	app.myTrxUA.trxUpdateSlotRequestAttribute(slots, altSlots, true, theEditions, CM_SlotRequest.Attribute_DLR, null, app.myPassport);	
	self.assertNoTrxErrorsOrWarnings();
	voyageJob:=self.addVoyageJob(voyage,"COV2",slots, false);
	assertTrue(voyageJob &lt;&gt; null);
*/
	
	// colour code the load slots
	create slotsTo transient;
	self.getJobSlotControllers(voyage.code, "05", DeckOnDeck, 5, 1, 4, slotsTo);
	self.markSlotsAsLoadJob(slotsTo, tmpLoadCC);
	self.markSlotsAsLoadCC(slotsTo, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	self.markSlotsAsLoadCC(slotsTo, tmpLoadCC, CM_SlotRequest.Attribute_SOB);
	
	// colour code the discharge slots
	create slotsFrom transient;
	self.getJobSlotControllers(voyage.code, "05", DeckOnDeck, 3, 1, 4, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_SOB);
	voyageJob := self.addVoyageJob(voyage, "COV1", slotsFrom, true);
	assertTrue(voyageJob &lt;&gt; null);
	
		// link the slots
	create allObjectEditions transient;
	foreach slot in slotsFrom do
		allObjectEditions.add(slot);
	endforeach;
	foreach slot in slotsTo do
		allObjectEditions.add(slot);
	endforeach;
	app.myTrxUA.trxUpdateSlotReqLinkSOBDLR2(slotsFrom, slotsTo, allObjectEditions, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	/*
	if voyage.myROROStructure &lt;&gt; null then
		voyageDeck:=voyage.myROROStructure.allDecksByCode[DECK1];
		if voyageDeck &lt;&gt; null then
		
		
		
			// ADD IN 30/45/53 DLRs
			theEditions.clear();
			altRoroLCs.clear();
			roroLCs.clear();
			// GET DISCH DLR
			self.getJobROROControllerByID("OPSVIEW001",DECK1, null, "AUTOLOCN681", roroLCs, true, 1);
			self.getJobROROControllerByID("OPSVIEW001",DECK1, null, "AUTOLOCN682", roroLCs, true, 1);
			self.getJobROROControllerByID("OPSVIEW001",DECK1, null, "AUTOLOCN683", roroLCs, true, 1);
			self.getJobROROControllerByID("OPSVIEW001",DECK1, null, "AUTOLOCN611", roroLCs, true, 1);
			self.getJobROROControllerByID("OPSVIEW001",DECK1, null, "AUTOLOCN612", roroLCs, true, 1);
			self.getJobROROControllerByID("OPSVIEW001",DECK1, null, "AUTOLOCN613", roroLCs, true, 1);
			self.getJobROROControllerByID("OPSVIEW001",DECK1, null, "AUTOLOCN541", roroLCs, true, 1);
			self.getJobROROControllerByID("OPSVIEW001",DECK1, null, "AUTOLOCN542", roroLCs, true, 1);
			self.getJobROROControllerByID("OPSVIEW001",DECK1, null, "AUTOLOCN543", roroLCs, true, 1);
			// GET LOAD DLR
			self.getJobROROControllerByID("OPSVIEW001",DECK1, null, "AUTOLOCN681", altRoroLCs, true, 1);
			self.getJobROROControllerByID("OPSVIEW001",DECK1, null, "AUTOLOCN682", altRoroLCs, true, 1);
			self.getJobROROControllerByID("OPSVIEW001",DECK1, null, "AUTOLOCN683", altRoroLCs, true, 1);
			self.getJobROROControllerByID("OPSVIEW001",DECK1, null, "AUTOLOCN611", altRoroLCs, true, 1);
			self.getJobROROControllerByID("OPSVIEW001",DECK1, null, "AUTOLOCN612", altRoroLCs, true, 1);
			self.getJobROROControllerByID("OPSVIEW001",DECK1, null, "AUTOLOCN613", altRoroLCs, true, 1);
			self.getJobROROControllerByID("OPSVIEW001",DECK1, null, "AUTOLOCN541", altRoroLCs, true, 1);
			self.getJobROROControllerByID("OPSVIEW001",DECK1, null, "AUTOLOCN542", altRoroLCs, true, 1);
			self.getJobROROControllerByID("OPSVIEW001",DECK1, null, "AUTOLOCN543", altRoroLCs, true, 1);
			
			roroLCs.copyNoDuplicates(theEditions);
			altRoroLCs.copyNoDuplicates(theEditions);
		
			app.myTrxUA.doRORORequestDLRSoB(roroLCs, altRoroLCs, false,DLR_MOVETYPE, theEditions, app.myPassport);	
			self.assertNoTrxErrorsOrWarnings();
			theTI := roroLCs.last.allTrackedItems.first;
			self.assertTrueMsg(theTI.isRehandle, theTI.id &amp; " should be a DLR Rehandle");
			voyageJob:=self.addVoyageROROJob(voyage,voyageDeck, "UT_KP2",roroLCs, true);
			assertTrue(voyageJob &lt;&gt; null);
			
			
			
		
		
		
		
		
			// ### CONTAINER POSITIONS including OOTL
			roroLCs.clear();
			altRoroLCs.clear();
			self.getJobROROSlotController("OPSVIEW001",DECK1, roroLCs, true, 75);
			
			realAlloc := self.addVoyageAllocation2(voyage, "NZWLG", "GEN2", "", TI_CargoType_Container, false, false);
			self.addLCsToROROAllocation(true, realAlloc, roroLCs, altRoroLCs,1);
		

			voyageJob:=self.addVoyageROROJob(voyage,voyageDeck, "UT_KPI",roroLCs, false);
			assertTrue(voyageJob &lt;&gt; null);
	
	
	
			// ### 30 Exports
			roroLCs.clear();
			altRoroLCs.clear();
			self.getJobROROControllerByID("OPSVIEW001",DECK1, null, "AUTOLOCN421", roroLCs, true, 1); 
			self.getJobROROControllerByID("OPSVIEW001",DECK1, null, "AUTOLOCN422", roroLCs, true, 1); 
			self.getJobROROControllerByID("OPSVIEW001",DECK1, null, "AUTOLOCN423", roroLCs, true, 1); 
			
			realAlloc := self.addVoyageAllocation2(voyage, "NZAKL", "30BX", "", TI_CargoType_Container, false, false);
			self.addLCsToROROAllocation(true, realAlloc, roroLCs, altRoroLCs,1);
			voyageJob:=self.addVoyageROROJob(voyage,voyageDeck, "UT_KP2",roroLCs, false);
			assertTrue(voyageJob &lt;&gt; null);
	
			// ### 45 Exports
			roroLCs.clear();
			altRoroLCs.clear();
			self.getJobROROControllerByID("OPSVIEW001",DECK1, null, "AUTOLOCN491", roroLCs, true, 1); 
			self.getJobROROControllerByID("OPSVIEW001",DECK1, null, "AUTOLOCN492", roroLCs, true, 1); 
			self.getJobROROControllerByID("OPSVIEW001",DECK1, null, "AUTOLOCN493", roroLCs, true, 1); 
			
			realAlloc := self.addVoyageAllocation2(voyage, "NZAKL", "45BX", "", TI_CargoType_Container, false, false);
			self.addLCsToROROAllocation(true, realAlloc, roroLCs, altRoroLCs,1);
			voyageJob:=self.addVoyageROROJob(voyage,voyageDeck, "UT_KP2",roroLCs, false);
			assertTrue(voyageJob &lt;&gt; null);
	
			// ### 53 Exports
			roroLCs.clear();
			altRoroLCs.clear();
			self.getJobROROControllerByID("OPSVIEW001",DECK1, null, "AUTOLOCN561", roroLCs, true, 1); 
			self.getJobROROControllerByID("OPSVIEW001",DECK1, null, "AUTOLOCN562", roroLCs, true, 1); 
			self.getJobROROControllerByID("OPSVIEW001",DECK1, null, "AUTOLOCN563", roroLCs, true, 1); 
			
			realAlloc := self.addVoyageAllocation2(voyage, "NZAKL", "53FT", "", TI_CargoType_Container, false, false);
			self.addLCsToROROAllocation(true, realAlloc, roroLCs, altRoroLCs,1);
			voyageJob:=self.addVoyageROROJob(voyage,voyageDeck, "UT_KP2",roroLCs, false);
			assertTrue(voyageJob &lt;&gt; null);
	
	
	
	
	
			// PAR 28968
			roroLCs.clear();
			self.getJobROROControllerByID("OPSVIEW001",DECK1, null, "AUTOLOCN351", roroLCs, true, 1); // DLR
			voyageJob:=self.addVoyageROROJob(voyage,voyageDeck, "UT_KPI",roroLCs, false);
			assertTrue(voyageJob &lt;&gt; null);
			roroLCs.clear();
			self.getJobROROControllerByID("OPSVIEW001",DECK1, null, "AUTOLOCN302", roroLCs, true, 1); // SOB
			voyageJob:=self.addVoyageROROJob(voyage,voyageDeck, "UT_KPI",roroLCs, false);
			assertTrue(voyageJob &lt;&gt; null);
			
			
			
			self.planLoadItemDLR_RORO("DLRR2022452","AUTOLOCN351",  "DLR");
// ALREADY PLANNED			self.planLoadItemDLR_RORO("SOBB2022452","AUTOLOCN302",  "SOB");

			// ### GC ALLOCATION
			realAlloc := self.addVoyageAllocation2(voyage, "AUSYD", "", "", ct.id, false, false); // Cannon Balls
 			// ### GC POSITIONS
			roroLCs.clear();
			gcDefn := app.myTrxCA.trxCreateROROGCCargo(true, null, null,null, 25, -20, voyageDeck, app.myPassport);
			roroLCs.add(gcDefn.myGCController);

			gcDefn := app.myTrxCA.trxCreateROROGCCargo(true, null, null,null, 50, -20, voyageDeck, app.myPassport);
			roroLCs.add(gcDefn.myGCController);

			gcDefn := app.myTrxCA.trxCreateROROGCCargo(true, null, null,null, 75, -20, voyageDeck, app.myPassport);
			roroLCs.add(gcDefn.myGCController);

			self.addLCsToROROAllocation(true, realAlloc, roroLCs, altRoroLCs,1);

		
			// ### GC JOB
			voyageJob:=self.addVoyageROROJob(voyage,voyageDeck, "UT_KPI",roroLCs, false);
			assertTrue(voyageJob &lt;&gt; null);
			
			// Plan the GC Items to the GC Positions
			roroLCs.copy(theLCs);
			self.planTIsRORO(self.allTIs,theLCs, realAlloc.allRequests.first.CM_RORORequest);
			

			
			
			
			// ### GC ALLOCATION
			realAlloc := self.addVoyageAllocation2(voyage, "AUMEL", "", "", ct.id, false, false); // Cannon Balls
 			// ### GC POSITIONS
			roroLCs.clear();
			gcDefn := app.myTrxCA.trxCreateROROGCCargo(true, null, null,null, 50, 10, voyageDeck, app.myPassport);
			roroLCs.add(gcDefn.myGCController);

			gcDefn := app.myTrxCA.trxCreateROROGCCargo(true, null,null, null, 50, -5, voyageDeck, app.myPassport);
			roroLCs.add(gcDefn.myGCController);

			gcDefn := app.myTrxCA.trxCreateROROGCCargo(true, null, null,null, 75, -5, voyageDeck, app.myPassport);
			roroLCs.add(gcDefn.myGCController);

			self.addLCsToROROAllocation(true, realAlloc, roroLCs, altRoroLCs,1);

		
			// ### GC JOB
			voyageJob:=self.addVoyageROROJob(voyage,voyageDeck, "UT_KP2",roroLCs, false);
			assertTrue(voyageJob &lt;&gt; null);
			
			// Plan the GC Items to the GC Positions
			self.allTIs.clear();
			self.allTIs.add(voyage.allOnsiteTIsByCargoTypeId[ct.id, "CNON8899091"]);
			self.allTIs.add(voyage.allOnsiteTIsByCargoTypeId[ct.id, "CNON8899092"]);
			self.allTIs.add(voyage.allOnsiteTIsByCargoTypeId[ct.id, "CNON8899093"]);
			theLCs.clear();
			roroLCs.copy(theLCs);

			self.planTIsRORO(self.allTIs,theLCs, realAlloc.allRequests.first.CM_RORORequest);
		endif;
		voyageDeck:=voyage.myROROStructure.allDecksByCode[DECK2];
		if voyageDeck &lt;&gt; null then
		
			// ### GC ALLOCATION
			realAlloc := self.addVoyageAllocation2(voyage, "AUSYD", "", "", ct.id, false, false); // Cannon Balls
 			// ### GC POSITIONS
			roroLCs.clear();
			gcDefn := app.myTrxCA.trxCreateROROGCCargo(true, null, null,null, 25, -20, voyageDeck, app.myPassport);
			roroLCs.add(gcDefn.myGCController);

			gcDefn := app.myTrxCA.trxCreateROROGCCargo(true, null, null,null, 50, -20, voyageDeck, app.myPassport);
			roroLCs.add(gcDefn.myGCController);

			self.addLCsToROROAllocation(true, realAlloc, roroLCs, altRoroLCs,1);

		
			// ### GC JOB
			voyageJob:=self.addVoyageROROJob(voyage,voyageDeck, "UT_KP2",roroLCs, false);
			assertTrue(voyageJob &lt;&gt; null);
			
			// Plan the GC Items to the GC Positions
			theLCs.clear();
			roroLCs.copy(theLCs);
			self.allTIs.clear();
			self.allTIs.add(voyage.allOnsiteTIsByCargoTypeId[ct.id, "CNON8899004"]);
			self.allTIs.add(voyage.allOnsiteTIsByCargoTypeId[ct.id, "CNON8899005"]);
			self.allTIs.add(voyage.allOnsiteTIsByCargoTypeId[ct.id, "CNON8899006"]);
			self.planTIsRORO(self.allTIs,theLCs, realAlloc.allRequests.first.CM_RORORequest);
			

			
			
			
			// ### GC ALLOCATION
			realAlloc := self.addVoyageAllocation2(voyage, "AUMEL", "", "", ct.id, false, false); // Cannon Balls
 			// ### GC POSITIONS
			roroLCs.clear();

			gcDefn := app.myTrxCA.trxCreateROROGCCargo(true, null, null, null,50, -5, voyageDeck, app.myPassport);
			roroLCs.add(gcDefn.myGCController);

			gcDefn := app.myTrxCA.trxCreateROROGCCargo(true, null, null, null,75, -5, voyageDeck, app.myPassport);
			roroLCs.add(gcDefn.myGCController);

			self.addLCsToROROAllocation(true, realAlloc, roroLCs, altRoroLCs,1);

		
			// ### GC JOB
			voyageJob:=self.addVoyageROROJob(voyage,voyageDeck, "UT_KP2",roroLCs, false);
			assertTrue(voyageJob &lt;&gt; null);
			
			// Plan the GC Items to the GC Positions
			theLCs.clear();
			roroLCs.copy(theLCs);
			self.allTIs.clear();
			self.allTIs.add(voyage.allOnsiteTIsByCargoTypeId[ct.id, "CNON8899094"]);
			self.allTIs.add(voyage.allOnsiteTIsByCargoTypeId[ct.id, "CNON8899095"]);
			self.allTIs.add(voyage.allOnsiteTIsByCargoTypeId[ct.id, "CNON8899096"]);

			self.planTIsRORO(self.allTIs,theLCs, realAlloc.allRequests.first.CM_RORORequest);
		endif;
	endif;
	*/
	
epilog
	delete slots;
	delete theLCs;
	delete altRoroLCs;
	delete roroLCs;
	delete tmpLoadCC;
	delete altSlots;
	delete theEditions;

end;</source>
    </JadeMethod>
    <JadeMethod name="createVoyageSlotsLoadCC" id="78d546d4-ebc2-407d-9b43-a21167a2ae57">
        <source>createVoyageSlotsLoadCC();
/*23 September 2010	cnwas3	  */

vars
	//voyage : CM_Voyage;
	voyageJob : CM_VoyageJob;
	slots : CM_SlotControllerArray;
	tmpLoadCC	: CMIF_LoadColorCode;
begin
	//create a voyage job for bay 
	
	//voyage := self.getVoyage("OPSVIEW001");
	create slots transient;
	create tmpLoadCC transient;
	tmpLoadCC.overrideMoveType :=true;
	tmpLoadCC.myDischargePort:=app.myRoot.allPorts["NZAKL"];

	
	// ### GET SLOTS NOTE - tier ordinals start at bottom left, cell tiers start at top left.
	// 40 GENL
	self.getJobSlotControllers(voyage.code,"01",DeckOnDeck,1,1,6,slots);
	//self.markSlotsAsLoadJob(slots,tmpLoadCC);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Forty);
	slots.clear;
	// 20 GENL
	self.getJobSlotControllers(voyage.code,"01",DeckOnDeck,2,3,6,slots);
	//self.markSlotsAsLoadJob(slots,tmpLoadCC);
	slots.clear;

	// 40 REEFER
	self.getJobSlotControllers(voyage.code,"01",DeckOnDeck,4,1,6,slots);
	//self.markSlotsAsLoadJob(slots,tmpLoadCC);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Forty);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Power);
	slots.clear;

	// 20 REEFER
	self.getJobSlotControllers(voyage.code,"01",DeckOnDeck,5,3,6,slots);
	//self.markSlotsAsLoadJob(slots,tmpLoadCC);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Power);
	slots.clear;

	// 40 EMPTY
	self.getJobSlotControllers(voyage.code,"01",DeckUnderDeck,1,1,5,slots);
	//self.markSlotsAsLoadJob(slots,tmpLoadCC);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Forty);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Empty);
	slots.clear;


	// 40 GENL OD
	self.getJobSlotControllers(voyage.code,"01",DeckUnderDeck,2,3,5, slots);
	//self.markSlotsAsLoadJob(slots,tmpLoadCC);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Forty);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_OD);
	slots.clear;
	
	
	/// ## MAKE JOB
	/*self.getJobSlotControllers(voyage.code,"01",DeckOnDeck,1,1,24,slots);
	self.getJobSlotControllers(voyage.code,"01",DeckUnderDeck,1,1,10,slots);
	voyageJob:=self.addVoyageLoadJob(voyage,"COV1",slots, false);
	assertTrue(voyageJob &lt;&gt; null);*/

epilog
	delete slots;
	delete tmpLoadCC;

end;</source>
    </JadeMethod>
    <JadeMethod name="deleteVoyageSlotsLoadCC" id="d70b1948-7c3d-40db-8d6b-51a36074c404">
        <source>deleteVoyageSlotsLoadCC();
/*23 September 2010	cnwas3	  Initial creation*/


vars
	//voyage : CM_Voyage;
	voyageJob : CM_VoyageJob;
	slots : CM_SlotControllerArray;
	tmpLoadCC	: CMIF_LoadColorCode;
begin
	//create a voyage job for bay 
	
	//voyage := self.getVoyage("OPSVIEW001");
	create slots transient;
	create tmpLoadCC transient;
	tmpLoadCC.overrideMoveType :=true;
	tmpLoadCC.myDischargePort:=app.myRoot.allPorts["NZAKL"];

	
	// ### GET SLOTS NOTE - tier ordinals start at bottom left, cell tiers start at top left.
	// 40 GENL
	self.getJobSlotControllers(voyage.code,"01",DeckOnDeck,1,1,6,slots);
	
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Erase);
	slots.clear;
	// 20 GENL
	self.getJobSlotControllers(voyage.code,"01",DeckOnDeck,2,3,6,slots);
	
	slots.clear;

	// 40 REEFER
	self.getJobSlotControllers(voyage.code,"01",DeckOnDeck,4,1,6,slots);
	self.markSlotsAsLoadJob(slots,tmpLoadCC);
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Erase);
	
	slots.clear;

	// 20 REEFER
	self.getJobSlotControllers(voyage.code,"01",DeckOnDeck,5,3,6,slots);
	
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Erase);
	slots.clear;

	// 40 EMPTY
	self.getJobSlotControllers(voyage.code,"01",DeckUnderDeck,1,1,5,slots);
	
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Erase);
	
	slots.clear;


	// 40 GENL OD
	self.getJobSlotControllers(voyage.code,"01",DeckUnderDeck,2,3,5, slots);
	
	self.markSlotsAsLoadCC(slots,tmpLoadCC,CM_SlotRequest.Attribute_Erase);
	
	slots.clear;
	
	/*
	/// ## MAKE JOB
	self.getJobSlotControllers(voyage.code,"01",DeckOnDeck,1,1,24,slots);
	self.getJobSlotControllers(voyage.code,"01",DeckUnderDeck,1,1,10,slots);
	voyageJob:=self.addVoyageLoadJob(voyage,"COV1",slots, false);
	assertTrue(voyageJob &lt;&gt; null);*/

epilog
	delete slots;
	delete tmpLoadCC;

end;</source>
