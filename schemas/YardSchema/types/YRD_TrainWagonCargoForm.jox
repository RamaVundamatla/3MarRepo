    <JadeMethod name="doAutoFindCargo" id="b75cd039-67bf-473e-bcea-0836a5502595">
        <source>doAutoFindCargo( combobox: ComboBox input );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 August 2009	cnwndl1	Initial creation
07 Apr    2017	cnwma1 TFS #3640:1090 error while adding cargo to a wagon
*/

vars
	searchText : String;
	cargoType : CM_CargoType;
	ti		: CM_TrackedItem;
	searchTIs : CM_TISet;
	obj : Object;
	
begin
	
	searchText := combobox.text.toUpper;
	cargoType := cmbCargoType.listObject.CM_CargoType;
	
	combobox.clear();

	create searchTIs transient;
	//In case they keyed the exact id and it was a pre note but not pre-note by rail.
	// 07 Oct 2009	NDL	Par 20839
	if searchText.trimBlanks &lt;&gt; null then
		if cargoType &lt;&gt; null then  // cnwma1 TFS #3640 07/04/2017
			ti := app.getMyTerminalDO_NOT_USE.allNotifiedTIsByCargoTypeId.getAtKey(cargoType.id,searchText);
		endif;
	endif;
	if ti &lt;&gt; null then
		searchTIs.add(ti);
	elseif cargoType &lt;&gt; null then
		doAutoFindGetMatchingCargo(searchText, cargoType.id, searchTIs);
	endif;
			
	if searchTIs.size &lt;&gt; 0 then
		foreach ti in searchTIs do
			combobox.addItem(ti.id);
			combobox.itemObject[combobox.newIndex] := ti;
		endforeach;
	endif;

	combobox.text := searchText;
	combobox.selStart := combobox.text.length;
	if searchText &lt;&gt; null and combobox.listCount &gt; 1 then
		combobox.showDropDown();
		return;
	elseif searchText &lt;&gt; null and combobox.listCount = 1 then			//cnwmc5 - 10 Jan 2013 - PAR 32349
		combobox.listIndex := 1;
		return; // if only one is found then display the data for it
	elseif combobox.listCount = 0 then
		//combobox.listIndex := -1;
		return; // if none are found then clear the data
	endif;
	
epilog

	delete searchTIs;
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doAutoFindGetMatchingCargo" id="9383fb02-9fbd-429c-984c-a8de263a70b7">
        <source>doAutoFindGetMatchingCargo(_itemID: String ; pType : Integer ; _objSet : ObjectSet input) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 Aug 2009	cnwndl1	Initial creation CCMS 1094
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	lTI	: CM_TrackedItem;
	lIter01	: Iterator;
	idStr	: String;
	lType	: Integer;
	lTIId	: String;
	transitAndPrenoteTIs : CM_TIByCargoTypeIdDict;
begin
	create transitAndPrenoteTIs transient;
	
	self.myTerminal.allNotifiedTIsByCargoTypeId.copy(transitAndPrenoteTIs);
	self.myTerminal.allInTransitTIsToByFromTypeId.copy(transitAndPrenoteTIs);
	lIter01 := transitAndPrenoteTIs.createIterator();
	
	transitAndPrenoteTIs.startKeyGeq(pType, null, lIter01);
		
	while lIter01.next(lTI) do
		if lTI.isChild() then
			continue;
		endif;
		if lTI.cargoType &lt;&gt; pType then
			break;
		endif;
		if lTI.myPrimaryActualLocation &lt;&gt; null then
			continue;
		endif;
		if lTI.receiptTransportMode &lt;&gt; TI_TRANSMODE_RAIL then// 07 Oct 2009	NDL	Par 20839
			continue;
		endif;
		if _itemID = null then
			_objSet.add(lTI);
		else
			lTIId := lTI.id;
			if lTIId[1:_itemID.length] = _itemID then
				//front nn chars match.
				_objSet.add(lTI);
			elseif lTIId.length &gt; _itemID.length then
				if lTIId[ ( lTIId.length - _itemID.length )+ 1 : end]  = _itemID then
					//back nn chars match.
					_objSet.add(lTI);
				endif;
			endif;
		endif;
	endwhile;
epilog
	delete transitAndPrenoteTIs;
	delete lIter01;		// PAR #26678
end;</source>
        <access>protected</access>
        <Parameter name="_itemID" type="String"/>
        <Parameter name="pType" type="Integer"/>
        <Parameter name="_objSet" type="ObjectSet" usage="input"/>
    </JadeMethod>
