    <JadeMethod name="validateForUpdate" id="a38338ec-4761-4ed4-9629-c9a2361d7c77">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Dec 2022 navtnr20	TFS CR 55622 Task 55690: Jade - Shipping Terms TRX
30 Jan 2022 navtnr20	Bug 56309: EUP - Invoice Shipping Terms - Can add the same debtor type multiple times for same code
*/

vars
	realInvoiceShipTermMapping,realinvoice,shipTermMap   : CM_InvoiceShipTermMapping;
	invLineDesc: 			CM_InvoiceLineDesc;
begin
	if self.priority = null then
		app.raiseCMException(Input_require_field_priorit, null ,self);
	endif;
	
	if self.myShippingTerm = null then
		app.raiseCMException(Input_required_field_shipping, null ,self);
	endif;
	
	if self.myDebtorType = null then
		app.raiseCMException(Input_required_field_debtor, null ,self);
	endif;
	
	realinvoice := app.myProxyManager.getRealObject(self).CM_InvoiceShipTermMapping;
	
	foreach invLineDesc in self.allInvoiceLineTypes do
        realInvoiceShipTermMapping := self.myShippingTerm.allShipTermMappingsByInvLnType[invLineDesc];
        if realInvoiceShipTermMapping &lt;&gt; null 
		and realInvoiceShipTermMapping &lt;&gt; realinvoice then
            app.raiseCMException2(Invoice_linetyp_already_exists, invLineDesc.narration, realInvoiceShipTermMapping.myDebtorType.description, null,null); 
        endif;
	endforeach;
		
	foreach shipTermMap in self.myShippingTerm.allShipTermMappings do
		if shipTermMap &lt;&gt; realinvoice and shipTermMap.myDebtorType = self.myDebtorType then
			app.raiseCMException2(Debto_type_alrea_invoi_line_ma,self.myDebtorType.description,self.myShippingTerm.code,null,null); 
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
</Class>
