    <JadeMethod name="doUpdateVoyageDetails" id="e1bb31ee-5c2d-45cf-8fd6-4576b11300d2">
        <updating/>
        <source>doUpdateVoyageDetails() updating;
// ---------------------------------------------------------------------------
// Created:		02 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars
	ls : Boolean;
	aJS : CM_JobSheet;
	aCrane : Object;
	controller : CMIF_OOWVoyageUpdate;
	theTable : Table;
	aTS : TimeStamp;
	aDate : Date;
	aTime : Time;
	theRow : Integer;
	theReturn : Integer;
begin
	
	app.mousePointer := Window.MousePointer_HourGlass;
	aDate := self.dteStart.getDate();
	aTime := self.timeStart.getTime();
	
	create controller;
	app.cmsBeginLoad(ls);
	controller.myVoyage := app.createUpdateProxy(self.myCurrentVoyage).CM_Voyage;
	app.cmsEndLoad(ls);
	
	controller.shipExhangeTS.setDate(aDate);
	controller.shipExhangeTS.setTime(aTime);
	controller.starboardBerthed := (self.cmbBerthage.listIndex =  2);
	controller.myVoyageStructure := self.myCurrentVoyage.myCellularVoyageStructure;
	
	while true do
		app.myTrxUA.trxUpdateVoyageOOWVoyage(controller, app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("OOW Voyage Details Update", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;
	
epilog
	app.cmsEndLoad(ls);		// 08/04/2011 cnwmh5 #27347
	delete controller.myVoyage;
	delete controller;
	app.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="drawDraggedCell" id="729faf80-6937-44f0-bad6-26a4939e036e">
        <source>drawDraggedCell(_offsetX, _offsetY : Integer);
// ---------------------------------------------------------------------------
// Created:		05 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theTable : Table;
	tmpPoints :RealArray;
	inx, ide, st, en : Integer;
begin
	create tmpPoints transient;
	
	en := self.thePoints.size;
	foreach inx in 1 to en do
		if inx mod 2 = 0 then
			tmpPoints.add(self.thePoints[inx] + _offsetY);
		else
			tmpPoints.add(self.thePoints[inx] + _offsetX);
		endif;
	endforeach;
	
	theTable := self.tblData;
	theTable.drawFillColor := self.origColor;
	theTable.drawWidth := 1;
	theTable.drawFilledPolygon(tmpPoints,Black);

epilog
	delete tmpPoints;
end;</source>
        <Parameter name="_offsetX" type="Integer"/>
        <Parameter name="_offsetY" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getCellDescription" id="dbdaeb88-286e-41c6-9603-63dd586e6f92">
        <source>getCellDescription(_table : Table input; _column : Integer) : String;
// ---------------------------------------------------------------------------
// Created:		05 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	desc : String;
	entTableRow : EntTableRow;
	entRowName : String;
begin
	if _column &gt; _table.CM_DataTable.allTblDataEntRows.size then
		return null;
	endif;
	entTableRow:=_table.CM_DataTable.allTblDataEntRows[_column].EntTableRow;
	entRowName:=entTableRow.name;
	
	if entRowName = ETRow_DeckTotal then
		desc := "Bay Total";
	elseif  entRowName = ETRow_Discharge20 then
		desc := "Discharge 20";
	elseif entRowName = ETRow_Discharge40 then
		desc := "Discharge 40";
	elseif  entRowName = ETRow_DischDLR20 then
		desc := "Discharge DLR 20";
	elseif entRowName = ETRow_DischDLR40 then
		desc := "Discharge DLR 40";
	elseif  entRowName = ETRow_Load20 then
		desc := "Load 20";
	elseif  entRowName = ETRow_Load40 then
		desc := "Load 40";
	elseif  entRowName = ETRow_LoadDLR20 then
		desc := "Load DLR 20";
	elseif  entRowName = ETRow_LoadDLR40 then
		desc := "Load DLR 40";
	elseif  entRowName = ETRow_Refeer20 then
		desc := "Reefer 20";
	elseif  entRowName = ETRow_Reefer40 then
		desc := "Reefer 40";
	elseif entRowName = ETRow_Sob20 then
		desc := "SOB 20";
	elseif entRowName = ETRow_Sob40 then
		desc := "SOB 40";
	elseif entRowName = ETRow_Deck then
		desc := "Bay";
	endif;
	return desc;
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_column" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="bd00859c-19c1-48ac-97b5-ab76828a75c5">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	xmlStr	: String;
	entRow	: EntTableRow;	
begin
	xmlStr := inheritMethod();

	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagColourBay, self.xmlColourBay.String);
	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagColourCell, self.xmlColourCell.String);
	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagColourRow, self.xmlColourRow.String);
	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagSplit, self.xmlSplit.Integer.String);
	xmlStr := xmlStr &amp; global.formatAsXML(XML_TagShowLiftColumn, self.xmlShowLiftColumn.Integer.String);
	
	
	return xmlStr;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initCranesTable" id="db188e4a-873b-40ef-ba1e-6f1b579059b6">
        <source>initCranesTable();
// ---------------------------------------------------------------------------
// Created:		24 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theTable : CM_DataTable;
begin
	//10 Aug 2009	NDL  reworked for CCMS1031
	theTable := self.tblCranes;
	theTable.selectMode := Table.SelectMode_CurrentRow;
	theTable.columns := 6;
	theTable.borderColorSingle:=Grey;
	// 1 Sep 2011 epr changed for CCMS 1033
	theTable.addItem(app.getErrorString(Work_point) &amp; Tab  &amp; app.getErrorString(Exchange_date) &amp; Tab &amp;app.getErrorString(TimeStr) &amp; Tab &amp; app.getErrorString(Move_rate) &amp; Tab &amp; app.getErrorString(Order) &amp; Tab &amp; app.getErrorString(Start_number));
	theTable.fixedRows := 1;	


end;</source>
    </JadeMethod>
    <JadeMethod name="initDataTable" id="8d74c590-75a1-4fc1-ad2d-55cb7f2e745b">
        <source>initDataTable() protected;
// ---------------------------------------------------------------------------
// Created:		21 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	ColHead1 = 1;
	ColHead2 = 2;
vars
	theTable		: CM_DataTable;
	entTableDef : EntTableDef;
	mergeColumn : Integer;
begin


	theTable := self.tblData;
	theTable.disallowColumnSorter := true;
	theTable.allowDragSelect := true;
	theTable.userInputEnabled := false;
	theTable.selectMode := CM_EntryTable.SelectMode_None; 
	theTable.selectionType := CM_EntryTable.SelectionType_None;
	theTable.rows := 0;
	theTable.cnEcResizeContents();
	
	theTable.show3D := Table.Show3D_Not3D;
	theTable.readOnly := false;	
	theTable.fixedColumns := 0;
	theTable.fixedRows:=3;

	entTableDef := app.myController.getEntTableDef(ETDef_OowCreationBay);
	theTable.setTblDataEntRowsFromDef(entTableDef);
	theTable.alignment := Table.Alignment_Center_Middle;
	self.setColorsForTable(theTable);
	
	theTable.accessCell(ColHead1,1).text:="Bay" &amp; Tab &amp; "UD" &amp; Tab &amp; "Jobs" &amp; Tab &amp;  "Discharge" &amp; Tab &amp; Tab &amp; "Load" &amp; Tab &amp; Tab &amp;  "DLR" &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp;  "SOB" &amp; Tab &amp; Tab &amp;  "Bay" &amp; Tab &amp; "Running Totals" &amp; Tab&amp; Tab &amp; Tab &amp; Tab &amp; "Reefer";
	theTable.accessCell(ColHead2,1).text:=Tab &amp; "OD" &amp; Tab&amp; Tab &amp; Tab &amp; Tab &amp;  Tab  &amp; Tab &amp;  "Discharge"&amp; Tab &amp; Tab &amp; "Load"&amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp;   "Total" &amp; Tab &amp; "FWD" &amp; Tab &amp; "AFT" &amp; Tab &amp; "Crane" &amp; Tab &amp; "Lifts" &amp; Tab &amp; Tab;

	

	// DISCHARGE
	theTable.getEntRowColumnByRowName(ETRow_Discharge20, mergeColumn); //self.Column_Bay_Disc20
	theTable.accessCell(ColHead1,mergeColumn).mergeCells := Table.MergeCells_Merge;
	theTable.accessCell(ColHead1,mergeColumn).alignment := Table.Alignment_Center_Middle;

	// LOADING
	theTable.getEntRowColumnByRowName(ETRow_Load20, mergeColumn);//self.Column_Bay_Load20);/
	theTable.accessCell(ColHead1,mergeColumn).mergeCells := Table.MergeCells_Merge;
	theTable.accessCell(ColHead1,mergeColumn).alignment := Table.Alignment_Center_Middle;
	// DLR  	//self.Column_Bay_DiscDLR20
	theTable.getEntRowColumnByRowName(ETRow_DischDLR20, mergeColumn);
	theTable.accessCell(ColHead1,mergeColumn).mergeCells := Table.MergeCells_Merge;
	theTable.accessCell(ColHead1,mergeColumn).alignment := Table.Alignment_Center_Middle;
	
	// LINE 2
	theTable.accessCell(ColHead2,mergeColumn).mergeCells := Table.MergeCells_Merge;
	theTable.accessCell(ColHead2,mergeColumn).alignment := Table.Alignment_Center_Middle;
	
	//load DLR
	theTable.getEntRowColumnByRowName(ETRow_LoadDLR20, mergeColumn);

	theTable.accessCell(ColHead2,mergeColumn).mergeCells := Table.MergeCells_Merge;
	theTable.accessCell(ColHead2,mergeColumn).alignment := Table.Alignment_Center_Middle;
	
	// SOB 		
	theTable.getEntRowColumnByRowName(ETRow_Sob20, mergeColumn);
	theTable.accessCell(ColHead1,mergeColumn).mergeCells := Table.MergeCells_Merge;
	theTable.accessCell(ColHead1,mergeColumn).alignment := Table.Alignment_Center_Middle;
	theTable.accessCell(ColHead1,mergeColumn + 2).mergeCells := Table.MergeCells_NotAvailable;
	
	//self.Column_Bay_SOB20
	theTable.accessCell(ColHead2,mergeColumn).mergeCells := Table.MergeCells_NotAvailable;
	
	// RUNNING TOTALS
	theTable.getEntRowColumnByRowName(ETRow_FwdAft, mergeColumn);//,self.Column_Bay_RunTotFwdAft
	theTable.accessCell(ColHead1,mergeColumn).mergeCells := Table.MergeCells_Merge;
	theTable.accessCell(ColHead1,mergeColumn).alignment := Table.Alignment_Center_Middle;
	
	// REEFER TOTALS //self.Column_Bay_Reef20
	theTable.getEntRowColumnByRowName(ETRow_Refeer20, mergeColumn);
	theTable.accessCell(ColHead1,mergeColumn).mergeCells := Table.MergeCells_Merge;
	theTable.accessCell(ColHead1,mergeColumn).alignment := Table.Alignment_Center_Middle;

	//hide or show the lift column
	theTable.getEntRowColumnByRowName(ETRow_Lifts, mergeColumn);
	theTable.accessColumn(mergeColumn).visible := self.btnShowLift.value;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="ca1f51d5-e1fe-4748-9f05-668000a73287">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
// ---------------------------------------------------------------------------
// Created:		May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if _userWindow = null then
		return;
	endif;

	inheritMethod(_userWindow);

	self.xmlColourBay := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_TagColourBay).Integer;
	self.xmlColourCell := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_TagColourCell).Integer;
	self.xmlColourRow := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_TagColourRow).Integer;
	self.xmlSplit := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_TagSplit).Integer.Boolean;
	self.chkSplit.value := self.xmlSplit;
	self.xmlShowLiftColumn := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_TagShowLiftColumn).Integer.Boolean;
	
	self.btnShowLift.value := self.xmlShowLiftColumn;

	self.setColours();
end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initROROTable" id="67963df1-e449-4e75-a3e7-3b3237c4b03e">
        <source>initROROTable() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

constants
	ColHead1 = 1;
	ColHead2 = 2;
vars
	theTable		: CM_DataTable;
	entTableDef : EntTableDef;
	mergeColumn : Integer;
begin

	theTable := self.tblRORO;
	theTable.disallowColumnSorter := true;
	theTable.allowDragSelect := true;
	theTable.userInputEnabled := false;
	theTable.selectMode := CM_EntryTable.SelectMode_None;
	theTable.selectionType := CM_EntryTable.SelectionType_None;
	theTable.rows := 0;
	theTable.cnEcResizeContents();

	theTable.readOnly := false;	
	theTable.fixedColumns := 0;
	theTable.fixedRows:=3;
	theTable.show3D := Table.Show3D_Not3D;
	theTable.alignment := Table.Alignment_Center_Middle;
	entTableDef := app.myController.getEntTableDef(ETDef_OowCreation);
	theTable.setTblDataEntRowsFromDef(entTableDef);
	self.setColorsForTable(theTable);
	
	theTable.accessCell(ColHead1,1).text:="Deck" &amp; Tab &amp;  "Jobs" &amp;  Tab &amp; "Discharge"  &amp; Tab &amp; Tab &amp; Tab &amp; "Load"  &amp; Tab &amp; Tab &amp; Tab &amp; "DLR" &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp; Tab &amp;  "SOB" &amp;  Tab &amp; Tab &amp; Tab  &amp; "Deck" &amp; Tab &amp; "Running Totals"  &amp; Tab &amp; "Reefer" ;
	theTable.accessCell(ColHead2,1).text:=Tab &amp;  Tab &amp; Tab &amp;  Tab &amp; Tab  &amp; Tab &amp; Tab &amp; Tab&amp;  "Discharge"&amp; Tab &amp; Tab &amp; Tab &amp; "Load" &amp; Tab &amp;  Tab &amp; Tab &amp; Tab &amp; Tab &amp; Tab&amp;  "Total" &amp; Tab &amp;  "Work Point" &amp; Tab &amp;   Tab;
	
	// DISCHARGE  
	theTable.getEntRowColumnByRowName(ETRow_Discharge20, mergeColumn);
	theTable.accessCell(ColHead1,mergeColumn).mergeCells := Table.MergeCells_Merge;
	theTable.accessCell(ColHead1,mergeColumn ).alignment := Table.Alignment_Center_Middle;

	// LOADING //self.Column_Bay_Load20
	theTable.getEntRowColumnByRowName(ETRow_Load20, mergeColumn);
	theTable.accessCell(ColHead1,mergeColumn).mergeCells := Table.MergeCells_Merge;
	theTable.accessCell(ColHead1,mergeColumn).alignment := Table.Alignment_Center_Middle;
	// DLR  	//self.Column_Bay_DiscDLR20
	theTable.getEntRowColumnByRowName(ETRow_DischDLR20, mergeColumn);
	theTable.accessCell(ColHead1,mergeColumn).mergeCells := Table.MergeCells_Merge;
	theTable.accessCell(ColHead1,mergeColumn).alignment := Table.Alignment_Center_Middle;
	
	// LINE 2
	theTable.accessCell(ColHead2,mergeColumn).mergeCells := Table.MergeCells_Merge;
	theTable.accessCell(ColHead2,mergeColumn).alignment := Table.Alignment_Center_Middle;
	
	//load DLR
	theTable.getEntRowColumnByRowName(ETRow_LoadDLR20, mergeColumn);

	theTable.accessCell(ColHead2,mergeColumn).mergeCells := Table.MergeCells_Merge;
	theTable.accessCell(ColHead2,mergeColumn).alignment := Table.Alignment_Center_Middle;
	
	// SOB 		
	theTable.getEntRowColumnByRowName(ETRow_Sob20, mergeColumn);
	theTable.accessCell(ColHead1,mergeColumn).mergeCells := Table.MergeCells_Merge;
	theTable.accessCell(ColHead1,mergeColumn).alignment := Table.Alignment_Center_Middle;
	theTable.accessCell(ColHead1,mergeColumn + 3).mergeCells := Table.MergeCells_NotAvailable;
	
	//self.Column_Bay_SOB20
	theTable.accessCell(ColHead2,mergeColumn).mergeCells := Table.MergeCells_NotAvailable;
	
	// REEFER TOTALS //self.Column_Bay_Reef20
	theTable.getEntRowColumnByRowName(ETRow_Refeer20, mergeColumn);
	theTable.accessCell(ColHead1,mergeColumn).mergeCells := Table.MergeCells_Merge;
	theTable.accessCell(ColHead1,mergeColumn).alignment := Table.Alignment_Center_Middle;



epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initThePoints" id="f20b28a3-3afb-4e18-ac99-05be706a2e74">
        <source>initThePoints();
// ---------------------------------------------------------------------------
// Created:		05 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.thePoints.add(6);self.thePoints.add(1);
