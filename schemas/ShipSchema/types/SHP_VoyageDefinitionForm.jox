    </JadeMethod>
    <JadeMethod name="doDelete" id="3da906de-3cee-4c94-884b-d3399a3c78c6">
        <updating/>
        <source>doDelete(): Boolean updating;
//--------------------------------------------------
// Created:	25 March 2004 By: cnwgd1
// 11/11/2015  cnwma1 PAR #36753 Colour Coding Criteria not getting deleted when voyage deleted
//--------------------------------------------------
vars
	msgStr : String;
	result : Integer;
	voyAllocations  : CM_YardAllocationSet;
begin
	
	if self.myCurrentVoyage = null then
		return false;
	endif;

	msgStr := app.getErrorString2(ConfirmDelete, 'the selected', 'voyage ' &amp; self.myCurrentVoyage.code);
	if app.msgBox(msgStr, self.caption, MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second) = MsgBox_Return_No then
		return false;
	endif;	

	app.mousePointer := Window.MousePointer_HourGlass;

	create voyAllocations transient;                                     // 11/11/2015 cnwma1 PAR #36753
	
	if not self.myCurrentVoyage.allVoyageAllocations.isEmpty then
			self.myCurrentVoyage.allVoyageAllocations.copy(voyAllocations);
	endif;
		
	if not voyAllocations.isEmpty then										// 11/11/2015 cnwma1 PAR #36753
		while true do
			app.myTrxDA.trxDeleteVoyageAllocations(voyAllocations, app.myPassport);
			if app.myPassport.trxCompletedOK then
				self.clearErrorWarnings();
				break;
			else
				result := app.showErrorWarningDialog(app.getErrorString(Voyage_load_colour_coding), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			endif;			
			break;
		endwhile;	
	endif;
	
	while true do
		app.myTrxDA.trxDeleteVoyage(self.myCurrentVoyage, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Voyage_Definition), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		
		endif;
		return false;
	endwhile;	
				
	self.cmbVoyage.setObject(null);			
	self.cmbVoyage.setFocus();	
	global.beep;
	return true;

epilog
	app.mousePointer := Window.MousePointer_Default;
	delete voyAllocations;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDeleteDelay" id="aebab222-1fb2-407b-add7-4e92db476b22">
        <updating/>
        <source>doDeleteDelay() : Boolean updating;
//--------------------------------------------------
// Created:	10 August 2005 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------
// 31/12/2014	cnwdap1		PAR #35397 CCMS SFW 1394 HMS_VoyageDelay objects are now CM_Delay objects
// 20 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	//deleteObj : HMS_Object;						// PAR #35397
	//voyageDelay : HMS_VoyageDelay;				// PAR #35397
	deleteObj : CM_Delay;							// PAR #35397
	voyageDelay : CM_Delay;							// PAR #35397
	result,
	msgBoxType : Integer;
	voyageDelayLocalTS : TimeStamp;
begin 
	if not checkSecurity(PmHMSVoyageMaint,"HMS Voyage") then
		return false;
	endif;	

	// voyage delay object associated with selected row
	//voyageDelay := self.tblDelays.accessRow(self.tblDelays.row).itemObject.HMS_VoyageDelay;	// PAR #35397
	voyageDelay := self.tblDelays.accessRow(self.tblDelays.row).itemObject.CM_Delay;			// PAR #35397
	if voyageDelay = null then
		app.msgBox(app.getErrorString(Please_Select_An_Item_Fiirst), app.getErrorString(Select_Item), MsgBox_Stop_Icon + MsgBox_OK_Only);
		return false;
	endif;
	// Confirm deletion
	msgBoxType := MsgBox_Yes_No+MsgBox_Question_Mark_Icon+MsgBox_Default_Second;
		voyageDelayLocalTS := self.systemToLocalTime(voyageDelay.startDT);						// 20 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	//if (not app.msgBox("Delete '" &amp; voyageDelay.myDelay.description &amp; ' occuring on ' &amp; voyageDelay.startTime.date.shortFormatJMT() &amp; ' : ' &amp; voyageDelay.startTime.time.currentLocaleFormatJMT(), app.getErrorString(ConfirmDeletion), msgBoxType)=MsgBox_Return_Yes) then		// PAR #35397
	//	if (not app.msgBox("Delete '" &amp; voyageDelay.myDelayType.description &amp; "' occuring on " &amp; voyageDelay.startDT.date.shortFormatJMT() &amp; ' : ' &amp; voyageDelay.startDT.time.currentLocaleFormatJMT(), app.getErrorString(ConfirmDeletion), msgBoxType)=MsgBox_Return_Yes) then	// PAR #35397
	if (not app.msgBox("Delete '" &amp; voyageDelay.myDelayType.description &amp; "' occuring on " &amp; voyageDelayLocalTS.date.shortFormatJMT() &amp; ' : ' &amp; voyageDelayLocalTS.time.currentLocaleFormatJMT(), app.getErrorString(ConfirmDeletion), msgBoxType)=MsgBox_Return_Yes) then	// PAR #35397
		return false;
	endif;

	app.mousePointer := Window.MousePointer_HourGlass;
	deleteObj := voyageDelay;

	while true do
		//app.myTrxDA.trxDeleteHMSObject(deleteObj, app.myPassport);							// PAR #35397
		app.myTrxDA.trxDeleteDelay(deleteObj, app.myPassport);									// PAR #35397
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog('Voyage Delay', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return false;
	endwhile;	
	
	self.displayHMSDelay();

epilog
	app.mousePointer := Window.MousePointer_Default;	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDeleteMovement" id="c48ed6d2-e835-49d0-b2d4-04c7745a5683">
        <updating/>
        <source>doDeleteMovement() updating;
//--------------------------------------------------
// Created:	29 July 2005 By: cnwgd1
//--------------------------------------------------
vars
	result : Integer;
begin
	if (not self.checkSecurity(PmHMSMovementsMaint, 'Movement Maintenance')) then
		return;
	endif;
	if (not HMS_Object.hasInstance(self.tblHMSMovements.userObject)) then
		app.msgBox(app.getErrorString(Please_Select_An_Item_Fiirst), app.getErrorString(Select_Item), MsgBox_Stop_Icon + MsgBox_OK_Only);
		return;
	endif;
	
	while true do
		app.myTrxDA.trxDeleteHMSObject(self.tblHMSMovements.userObject.HMS_Object, app.myPassport);
		
		if (not app.myPassport.trxCompletedOK) then
			result:=app.showErrorWarningDialog('Delete Movement', app.myPassport, ErrWarnMode_Delete);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			
			return;
		endif;
		self.displayHMSMovements();	//01 May 2018	NDL	TFS 38353
		return;
	endwhile;
end;</source>
    </JadeMethod>
    <JadeMethod name="doOpenEventScheduleSelector" id="c0b0232c-2865-481a-acfb-cb97b258148b">
        <source>doOpenEventScheduleSelector() protected;
//--------------------------------------------------
// Created:	11 August 2005 By: cnwgd1
//--------------------------------------------------
vars

	attachFrm 		: CMUI_EventScheduleSelector;
	sender			: String;
	allSchedules	: CM_AutoSchedulesByStartTsDict;
	schedule		: CM_AutoSchedule;
	strArray		: StringArray;
	
begin

	app.mousePointer := MousePointer_Default;
				
	attachFrm := app.loadForm(CMUI_EventScheduleSelector, self.myAssistant.class, false, false, false, self.myTerminal, null).CMUI_EventScheduleSelector;

	if attachFrm = null then
		return;
	endif;
	
	create allSchedules transient;
	if self.myCurrentVoyage = null then
		app.msgBox(app.getErrorString(PleaseSelectAVoyage) ,app.getErrorString(PleaseSelectAVoyage), MsgBox_OK_Only + MsgBox_Information_Icon);
		return;
	endif;
	
	create strArray transient;
	attachFrm.setupSelector(EventDataVoyage, allSchedules,app.getErrorString2(EventScheduleCaption, app.getErrorString(Voyage), self.myCurrentVoyage.code),self.myCurrentVoyage, strArray);
	
	attachFrm.showModal;

	app.mousePointer := MousePointer_HourGlass;
	foreach schedule in allSchedules do
		app.runEventScheduleVoyage(schedule, self.myCurrentVoyage,  strArray.first);
	endforeach;
	return;
	
epilog
	if attachFrm &lt;&gt; null then
		delete attachFrm;
	endif;
	delete strArray;
	delete allSchedules;
	app.mousePointer := MousePointer_Default;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doPortOfCallAdd" id="4af32800-1d31-467e-a4cf-95fac780e33e">
        <source>doPortOfCallAdd();
/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
27 April 2009	cnwer1	Initial creation
03 Jun 2009		concms1	par 19013 - mulit select option
22 Jun 2009 	cnwrl1	PAR 19980 - current number of ports
*/

vars
	form : CMUI_PortCodeSelector;
	
begin
	create form transient;
	
	form.isPort 			:= false;
	form.isForTranshipPorts	:= false;
	form.myInterfaceObject	:= self;
	form.multiSelect		:= true;	// par 19013
	
	form.setCurrentTotalOfPorts(self.lstPortsOfCall.listCount);		// cnwrl1 22/06/2009 PAR 19880
	
	form.showModal();
	
epilog
	
end;</source>
