    <JadeMethod name="create" id="7c0ba89d-34c7-4271-a81b-56547cab39ce">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2014	cnwjre1	Initial creation 34364 invoice line type in combo

*/

vars
	oper : CM_QueryOperator;

begin

	if self.isTransient then 
		return;
	endif;

	create oper as CM_QReferenceIsOneOf persistent;
	self.allAllowedOperators.add(oper);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getKeyLengthForXTABDictionary" id="395f289a-e9dd-44c3-9554-004f305fb95a">
        <source>getKeyLengthForXTABDictionary(): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2014	cnwjre1	Initial creation

*/

vars

begin
	return CM_InvoiceLineDesc::narration.length + CM_Bank::code.length  + CM_Terminal::code.length + 5;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
