    <JadeMethod name="getValueSpecial" id="212552d0-be36-4668-800c-c0f1ce244bcd">
        <source>getValueSpecial(_propName: String; _xlationOperator: CM_Operator): String;
//
// 16 Jan 2012	MSL CCMS 1009 PAR 29024
//
//02 Feb 2012	cnwrs1	Par 29076 Fix up Hazard Processing in EDI
//05 Apr 2012	cnwrs1		Par 29391 - EDI RORO Stowage Advice hazard codes
//05 Jul 2012	cnwrs1	Par 29894 - write negative numbers out as negative not zero
//07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
//30 Jun 2016	cnwrs1	Par 38000 extract VGM
// 05 Jul 2017	jlgrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
//19 Jul 2023	jlirs1	TFS 59187 (59019) EUP - Manifest Processing - Container Reference Field
//07 Aug 2023	jlirs1	TFS 59148 Port of Origin BOP
vars
	str, result : String;
	foundMatch	: Boolean;
begin

	if _propName =  ETRow_Commodity then //Par 13379 cnwrs1 feb 2007
		if _xlationOperator &lt;&gt; null then
			return _xlationOperator.getXlationForeignCode(self.commodity[1:30], XLATION_TYPE_COMMODITY_BYOP, foundMatch);
		else
			return self.commodity;
		endif;
		
	elseif _propName = ETRow_Humidity then//non-multiplied
		if self.getHumidity = NULL_HUMIDITY then//i.e. null STRING - NULL_Humidity - other wise '0' is a valid humidity
			return null;
		else
			return self.getHumidity.asStringJMT();
		endif;
		
	elseif _propName = ETRow_ImCodes or _propName = ETRow_Hazardous then
		
		foreach str in self.imCodes do
			if result = null then
				result := str;
			else
				result := result &amp; ' '&amp; str;
			endif;
		endforeach;
		
		return result;
		
	elseif _propName = ETRow_Ventilation or _propName = ETRow_Vent then//non-multiplied
		if self.vent = NULL_VENTILATION then//i.e. null STRING - NULL_VENTILATION - other wise '0' is a valid vent
			return null;
		else
			return vent.asStringJMT();
		endif;
	elseif _propName = ETRow_CarbonDioxide then
		if self.getCarbonDioxide = NULL_CARBON_DIOXIDE then
			return null;
		else
			return self.getCarbonDioxide.asStringJMT();
		endif;
		
	elseif _propName = ETRow_Oxygen then
		if self.getOxygen = NULL_OXYGEN then
			return null;
		else
			return self.getOxygen.asStringJMT();
		endif;
		
	elseif _propName = ETRow_Temperature then
		if self.temperature = NULL_TEMPERATURE then
			return null;
		else
			return self.temperature.asStringJMT();
		endif;
		
	elseif _propName = ETRow_TotalWeight then
		return weight.asCSVFormatString();	//05 Jul 2012	cnwrs1	Par 29894 - write negative numbers out as negative not zero
	//cnwmc5 - 23 Jan 2014 - PAR 33001
	elseif _propName = ETRow_OverHeight then
		if self.overHeight = NULL_INTEGER then
			return null;
		else
			return self.overHeight.asStringJMT();
		endif;
	//cnwmc5 - 23 Jan 2014 - PAR 33001
	elseif _propName = ETRow_OverLengthBack then
		if self.overLengthBack = NULL_INTEGER then
			return null;
		else
			return self.overLengthBack.asStringJMT();
		endif;
	//cnwmc5 - 23 Jan 2014 - PAR 33001
	elseif _propName = ETRow_OverLengthFront then
		if self.overLengthFront = NULL_INTEGER then
			return null;
		else
			return self.overLengthFront.asStringJMT();
		endif;
	//cnwmc5 - 23 Jan 2014 - PAR 33001
	elseif _propName = ETRow_OverWidthLeft then
		if self.overWidthLeft = NULL_INTEGER then
			return null;
		else
			return self.overWidthLeft.asStringJMT();
		endif;
	//cnwmc5 - 23 Jan 2014 - PAR 33001
	elseif _propName = ETRow_OverWidthRight then
		if self.overWidthRight = NULL_INTEGER then
			return null;
		else
			return self.overWidthRight.asStringJMT();
		endif;
	elseif _propName = ETRow_IsCertifiedWeight then
		return self.isWeightCertified.asStringJMT();
	elseif _propName = ETRow_SealShipper then
		if self.sealShipper &lt;&gt; null then
			return '"'&amp;self.sealShipper&amp;'"';
		else
			return null;
		endif;
	elseif _propName = ETRow_ContainerNumberText then		//19 Jul 2023	jlirs1	TFS 59187 (59019) EUP
		return self.getContainerNumberText();
	elseif _propName = ETRow_PortOfOrigin then				//07 Aug 2023	jlirs1	TFS 59148 Port of Origin BOP
		return self.getPortOfOrigin();
	else
		return inheritMethod(_propName, _xlationOperator);
	endif;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="String"/>
    </JadeMethod>
