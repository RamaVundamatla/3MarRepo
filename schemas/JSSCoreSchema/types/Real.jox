        <Parameter name="pTheFullLocale" type="LocaleFullInfo"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssGetWordForTeen" id="3fe8b08e-af2c-4617-971a-d024534ee8bf">
        <source>jssGetWordForTeen():String protected;
// --------------------------------------------------------------------------------
// Created:		21 August 2001 by cnwdad1
//
// Purpose:		Converts the receiver into it's equivalent word.  This method only
//				handles values between 11 and 19.
//
// Parameters:	None
//
// Returns:		The worded receiver.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	value	: Real;
	
begin
	value	:=	self;
	
	if value = 10 then
		return $JSS_NUM_TEN;
	elseif value = 11 then
		return $JSS_NUM_ELEVEN;
	elseif value = 12 then
		return $JSS_NUM_TWELVE;
	elseif value = 13 then
		return $JSS_NUM_THIRTEEN;
	elseif value = 14 then
		return $JSS_NUM_FOURTEEN;
	elseif value = 15 then
		return $JSS_NUM_FIFTEEN;
	elseif value = 16 then
		return $JSS_NUM_SIXTEEN;
	elseif value = 17 then
		return $JSS_NUM_SEVENTEEN;
	elseif value = 18 then
		return $JSS_NUM_EIGHTEEN;
	elseif value = 19 then
		return $JSS_NUM_NINETEEN;
	endif;
end;</source>
        <access>protected</access>
        <text>___________________________________________________________________________

              P R O P R I E T A R Y   N O T I C E

This software, in whole and in every part, is proprietary to Jade Software
Corporation Limited at Christchurch, New Zealand and is not to be
