    <JadeMethod name="isIgnoredUnitTestMethod" id="17e0f183-4ec1-479a-82c6-402bad293035">
        <source>isIgnoredUnitTestMethod(_method : Method) : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2024	navpw1	Initial creation

*/

constants
	Capitals		: String = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";

vars
	testIsIgnored	: Boolean;
	methodName		: String;
	
begin
	testIsIgnored := false;
	
	methodName := _method.name;
	
	if methodName[1:1] = "i" and Capitals.pos(methodName[2:1], 1) &gt; 0 then
		testIsIgnored := true;
	endif;

	return testIsIgnored;
	
end;</source>
        <access>protected</access>
        <Parameter name="_method" type="Method"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isRunnableUnitTestMethod" id="3cce724f-ce33-4f3d-8500-7860969c9051">
        <source>isRunnableUnitTestMethod(_method : Method) : Boolean protected;
/*

Purpose:			Return if is a method that the unit test framework can run

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
11 October 2024	navpw1	Initial creation

*/

constants
	Capitals		: String = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";

vars
	testIsRunnable	: Boolean;
	methodName		: String;
	
begin
	testIsRunnable := false;
	
	methodName := _method.name;
	
	if methodName[1:1] = "t" and Capitals.pos(methodName[2:1], 1) &gt; 0 then
		testIsRunnable := true;
	endif;

	return testIsRunnable;
	
end;</source>
        <access>protected</access>
        <Parameter name="_method" type="Method"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
