    <JadeMethod name="cmbTrain_click" id="2b23b758-fc96-4e76-9532-66b6d14a989d">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTrain_click(combobox: ComboBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 July 2009	cnwmd1	Initial creation

*/

vars
	
begin
	self.myCurrentTrain := combobox.listObject.CM_Train;
	self.buildComboWagon();
epilog

