    <JadeMethod name="setVoyage" id="e324a703-853a-4bec-9983-e8789d980d4f">
        <updating/>
        <source>setVoyage(_voyage: CM_Voyage) updating;
//----------------------------------------------------------------
//	Created:	11 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if self.myTransaction &lt;&gt; null then
		app.raiseUnexpectedProgramError(class.name, method.name, "the transaction should be null if setting the voyage");
		return;
	endif;
	
	self.myVoyage := _voyage;
	
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setupDefault" id="0d840635-882e-4eeb-a3ce-ee7073f5fa15">
        <updating/>
        <source>setupDefault(_terminal: CM_Terminal; _passport: CM_Passport) updating;
//----------------------------------------------------------------
//	Created:	11 May 2006	by Jason Chapman  (cnwjc2)
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 07.07.2018 cnwma1  Bug 39418: POL - [Fwd: ##RE-8120## : Issues adding Container and Hatch Summary]
//	13 May 2022	navgm20	53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema
//	14 Sep 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin
//----------------------------------------------------------------
vars
	terminal		: CM_Terminal;
begin

	terminal := _terminal;
	
	self.availabilityGrade	:= 0;
	self.cargoType			:= TI_CargoType_Container;
	self.consignee			:= null;
	self.consignor			:= null;
	self.shippingLineCode	:= null;			//13 may 2022 navgm20 tfs 53195
	self.myCountryOfOrigin 	:= null;			//14.09.2022 navtnr20 54441
	self.contentsStatus		:= TI_CONTENTS_STATUS_EMPTY;
	self.height				:= null;
	self.id					:= "TBA";
	self.imExStatus			:= TI_IMEX_STATUS_IMPORT;
	self.is40				:= false;
	self.isClean			:= true;
	self.isoTypeGroup		:= null;
	self.isToBeInspected	:= false;
	self.isTransship		:= false;
	self.length				:= 0;
	self.locationId			:= null;
	self.site				:= 1;
	self.sizeAttributes		:= 1;
	self.snapShotCreatedBy	:= _passport.myUser;
	self.snapShotDateTime	:= app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	self.snapShotOf			:= null;
	self.temperature		:= NULL_TEMPERATURE;
	self.transitStatus		:= 0;
	self.typeAttributes.bitOr(ISO_GENERAL);
	self.width				:= 0;
	
	if terminal &lt;&gt; null then
		self.weight				:= terminal.getConfig(MinTIWeight).Integer;
		if terminal.getConfig(DefISOType).CM_ISOType &lt;&gt; null then // 07.07.2018 cnwma1  Bug 39418
			self.isoType			:= terminal.getConfig(DefISOType).CM_ISOType.code;
		endif;
		self.dischargePort		:= terminal.getConfig(PortDestCode).String;
		self.commodity			:= terminal.getConfig(DefCommodity).String;
		self.loadPort			:= terminal.getConfig(PortDestCode).String;
	endif;
		
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="takeSnapShot" id="369718bf-8f99-4e0c-a636-b445b1043af1">
        <updating/>
        <source>takeSnapShot() updating;
// ---------------------------------------------------------------------------
// Created:     19 July 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
//  3 Sep 2018	jlgsl4	TFS 39801 - SNO - Codeco needs 'at Receive' details
//	13 May 2022	navgm20	53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema
//	14 Sep 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin
vars
	ti			: CM_TrackedItem;
	container	: CM_Container;
	invalid 	: Boolean;
	edition	    : Integer;
	country		: CM_Country;
	shipLine	: CM_ShippingLine;
begin
	inheritMethod();
	
	on Exception do app.handleDeletedObject(exception, self.snapShotOf, invalid); 	//28.05.2024 navma1 #64224
	
	if self.snapShotOf &lt;&gt; null then
		edition  := self.snapShotOf.edition;
	endif;
	
	if invalid then
		return;
	endif;
	
	/*
	28.05.2024 navma1 #64224
	if (not CM_TrackedItem.hasInstance(self.snapShotOf)) then
		return;
	endif;
	*/

	
	ti := self.snapShotOf.CM_TrackedItem;
	
	if (not ti.snapShots.includes(self)) then
		ti.snapShots.add(self);
	endif;
	
	self.id				:= ti.id;
	self.cargoType 		:= ti.cargoType;
	self.commodity 		:= ti.commodity;
	self.consignee		:= ti.consignee;
	self.consignor		:= ti.consignor;
	
	shipLine := ti.myShippingLine;
	if shipLine &lt;&gt; null then						
		self.shippingLineCode := shipLine.code;
	endif;	
	
	country := ti.myCountryOfOrigin;
	if country &lt;&gt; null then
		self.myCountryOfOrigin := country;		
	endif;
	
	self.loadPort		:= ti.loadPort;
	self.locationId		:= ti.locationId;
	self.dischargePort	:= ti.dischargePort;
	self.operatorCode 	:= ti.operatorCode;
	self.site			:= ti.site;
	self.sizeAttributes := ti.sizeAttributes;
	self.isTransship	:= ti.isTranshipItem;
	
	ti.getStopsAsIntegerArray(self.stops);
	
	self.transitStatus 				:= ti.getTransitStatus();
	self.imExStatus					:= ti.getImExStatus();
	self.height						:= ti.height;
	self.length						:= ti.length;
	self.width						:= ti.width;
	self.weight 					:= ti.totalWeight;					//+cnwml2 MSL CCMS 1017
	self.typeAttributes 			:= ti.typeAttributes;	//late addition can't use this until 2006? - the release after 733
	
	// TFS 40336
	self.billOfLading 				:= ti.billOfLading;
	self.cargoGroupId 				:= ti.getMyCargoGroupId();
	self.cargoSubtypeCode 		    := ti.getCargoSubTypeCode();
	self.cargoSubtypeDescription    := ti.getCargoSubTypeDescr();
	self.cargoTypeCode 				:= ti.cargoTypeCode();
	self.cargoTypeDescription 		:= ti.cargoTypeDescr;
	self.colour	 				    := ti.getColour();
	self.customsAgentCode 			:= ti.getMyCustomsAgentDesc(false);
	self.description 				:= ti.description;
	self.destinationPortCode		:= ti.destinationPort;
	self.destinationPortDescription := ti.getDestinationPortDescription();
	self.dischargePortDescription   := ti.dischargePortDescription;
	self.hazard 					:= ti.getHazardCodesCSV();
	self.isotypeDescription			:= ti.getISOTypeDesc();
	self.loadPortDescription 		:= ti.loadPortDescription;
	self.mark 						:= ti.mark;
	self.markNumber					:= ti.markNumber;
	self.orderNumber 				:= ti.orderNumber;
	self.remarks 					:= ti.remarks;
	self.totalQuantity 				:= ti.totalQuantity;
	self.totalVolume 				:= ti.totalVolume;
	self.totalWeight 				:= ti.totalWeight;
	self.voyageCode 				:= ti.voyageCode;
	self.deliveryRelease 			:= ti.deliveryRelease; // TFS 39801
	
	self.takeSnapShotHaz(ti);
	
	
	/*
	28.05.2024 navma1 #64224
	if (not CM_Container.hasInstance(self.snapShotOf)) then
		return;
	endif;
	*/
	if not ti.isContainer then		//28.05.2024 navma1 #64224
		return;
	endif;
	
	container 			 := self.snapShotOf.CM_Container;
	self.contentsStatus	 := container.getContentsStatus();
	self.isToBeInspected := container.isToBeInspected;
	self.isoType		 := container.isoType;
	self.isoTypeGroup	 := container.isoTypeGroup;
	self.temperature	 := container.getTemperature;
	self.is40			 := container.is40;

end;</source>
    </JadeMethod>
    <JadeMethod name="takeSnapShotHaz" id="a01013e0-acc5-41d2-b096-697d63336e41">
        <updating/>
        <source>takeSnapShotHaz(_ti : CM_TrackedItem) updating;
/*

Purpose:		TFS 40336	

Parameters:			

Return Value:		

Date		Who		Reason
13 September 2018	jlgab1	Initial creation

*/

vars
	tihaz : CM_TIHazard;
	haz : CM_Hazard;
	hazsnap : CM_HazardSnapShot;
	snapshot : CM_SnapShot;
begin
	if _ti.allTIHazards.isEmpty() then
		return;
	endif;
	
	foreach haz in _ti.allTIHazards	discreteLock do
		tihaz := haz.CM_TIHazard;
		
		create hazsnap;
		hazsnap.setFromTIHax(tihaz, self);
	endforeach;
	
	foreach snapshot in self.allHazSnapShots	discreteLock do
		hazsnap := snapshot.CM_HazardSnapShot;
		
		if self.hazard = "" then
			self.hazard := hazsnap.code;
		else
			self.hazard := self.hazard &amp;"&lt; " &amp; hazsnap.code;
		endif;
	endforeach;
	
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
