    <JadeMethod name="doBtnSubRemove" id="d1e9746c-d192-49e2-8be3-465bc952fc66">
        <updating/>
        <source>doBtnSubRemove() updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theLCS : CM_LCArray;
	rtnValue : Boolean;
	theReturn,theIndex : Integer;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	self.frmGridArea.enabled := false;
	self.modalDialogShow(null, 'Cancel', null, null, "Sub Block Stack","Removing...");
	
	if self.myCurrentSubBlockStack = null then
		app.msgBox("Please select a Sub Block Stack to Remove","Remove Sub Block Stack",MsgBox_OK_Only);
		return;
	endif;
	self.tblOther.clearValues();
	create theLCS transient;
	self.myCurrentSubBlockStack.allByPassedControllers.copy(theLCS);
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteTerminalArea(self.myCurrentSubBlockStack, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Sub Block Stack', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
	self.myCurrentSubBlockStack := null;

epilog
	self.frmModalDialog.visible := false;
	delete theLCS;
	self.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnSubSave" id="b8ad3b53-2460-4e39-9c8b-2e1bcc0bfd16">
        <updating/>
        <source>doBtnSubSave() updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theIndex,idx,result : Integer;
	theRegion : CMIF_GridTARegion;
	aPoint : CMUI_GridPoint;
	rtnValue, hideFOV : Boolean;
	aController : CM_LocationsController;
	theRealSubBlock : CM_SubBlockStack;
	theDefaultID : String;
	theLCS : CM_LCArray;
begin

	self.mousePointer := Window.MousePointer_HourGlass;
	create theLCS transient;
	self.modalDialogShow(null, 'Cancel', null, null, "Sub Block Stack","Saving...");
	
	// ################################
	// ### SET UP PROXY
	if self.myCurrentSubBlockStack &lt;&gt; null then
		theIndex := self.lstRestrictions.findObject(self.myCurrentSubBlockStack);
		self.myCurrentSubBlockStack.allByPassedControllers.copy(theLCS);
	else
		theIndex := self.getListIndexForAdd();
	endif;
	create theRegion transient;
	theRegion.colour := self.tblOther.getValueByName(ETRow_Colour).Integer;
	theRegion.myGridArea := self.myCurrentTerminalArea.CM_GridArea;
	theRegion.autoRestrictionsEnabled := self.tblOther.getValueByName(ETRow_AutoRestrictionsEnabled).Boolean;
	theDefaultID := self.tblOther.getValueByName(ETRow_Id).String.toUpper;
	theRegion.hideFromOverView := self.tblOther.getValueByName(ETRow_HideFromOverView).Boolean;
	theRegion.isStockControlled := self.tblOther.getValueByName(ETRow_StockControlled).Boolean;
	theRegion.maxCapacity := self.tblOther.getValueByName(ETRow_MaxCapacity).Integer; //par18840 cnwjo3
	
	
	foreach aPoint in self.frmGridArea.myGridArea.allSelectedPoints do
		aController := aPoint.myLocationsController;
		if aController &lt;&gt; null then
			theRegion.allLocationControllers.add(aController);
			if theDefaultID = null then
				theDefaultID := aController.getID();
			endif;
		endif;
	endforeach;
	if theDefaultID.trimBlanks.length &gt; 12 then
		theRegion.id := theDefaultID.trimBlanks[1:12];
	else
		theRegion.id := theDefaultID.trimBlanks;
	endif;

	// ################################
	// ### TRX IT
	while true do
		if self.mode = self.Mode_Update then
			theRegion.idOriginal := self.myCurrentSubBlockStack.id;
			app.myTrxUA.trxUpdateSubBlockStack(theRegion,theRealSubBlock, app.myPassport);
		else
			theRegion.idOriginal := theRegion.id;
			app.myTrxCA.trxCreateSubBlockStack(theRegion,theRealSubBlock, app.myPassport);
		endif;
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Sub Block Stack', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;

	// ################################
	// ### CLEAN UP GUI
	self.myCurrentSubBlockStack := theRealSubBlock;
	self.doEnableControls(false);
	
//	foreach aController in theRealSubBlock.allByPassedControllers do
//		if not theLCS.includes(aController) then
//			 theLCS.add(aController);
//		endif;
//	endforeach;
//	self.doUpdateGridArea(theLCS);

//	self.displayListBoxRemoveAdd(theRealSubBlock.id,theIndex,theRealSubBlock,YRD_PadArea.AreaMode_SubBlock,3);
	self.frmGridArea.enabled := false;

epilog
	self.frmModalDialog.visible := false;
	delete theRegion;
	delete theLCS;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnTermSubAreaAdd" id="3a1db0ba-5481-417a-aeca-3a87e5f72302">
