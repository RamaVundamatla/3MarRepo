    </JadeMethod>
    <JadeMethod name="getNextQuickCargoIDGC" id="73a6607b-749c-4a6a-9b33-c9ec503258ed">
        <source>getNextQuickCargoIDGC(_cargoType : Integer; _comm : String) : String;
/*
Purpose:			
Date		Who		Reason
03 October 2014	cnwab1	Initial creation
*/

vars

	aTI : CM_TrackedItem;
	nextID, numId : String;
	nextNum : Integer;
	now : Date;
	comm : String;
	ct : CM_CargoType;
begin
	now := app.actualTimeServer().date();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	nextNum := (now.formatAsYYMMDD() &amp; "01").asIntegerJMT;
	ct := app.myRoot.allCargoTypesById[_cargoType];
	if ct &lt;&gt; null then
		comm := ct.abbreviation[1:4];
	endif;
	
	while true do
		nextID := comm &amp; nextNum.String;
		if  ct.isCargoGroup() then
			if self.myTerminal.allCargoGroupsByIdCargoType[nextID,_cargoType] = null then
				return nextID;
			endif;
		else
			if self.myTerminal.allOnsiteTIsByIdCargoType[nextID,_cargoType] = null then
				return nextID;
			endif;
		endif;
		nextNum := nextNum + 1;
	endwhile;
	
	return nextID;
epilog


end;</source>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_comm" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNumTIs" id="3ec390bc-85a1-413f-8ba8-5dd4055dfa32">
        <source>getNumTIs(mode: Integer) : Integer;
//Given a mode, returns the # of TI's in the stack
// NOTE: this is slow for a gridarea stack as it has to check each ti
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars

begin
	if self.myLocationsController = null then
		return 0;
	endif;
	
	if mode = REAL_MODE then
		return self.myLocationsController.numTIs;
	elseif mode = PLANNING_MODE then
		return self.myLocationsController.numPlannedTIs;
	else
		return self.myLocationsController.numQueuedTIs;
	endif;
end;</source>
        <Parameter name="mode" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
