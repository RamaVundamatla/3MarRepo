<Class name="CM_StateBinary" id="38ec8d0d-7b33-4e50-a585-3f3e142fc5b1">
    <superclass name="CM_StateData"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmstate"/>
    <PrimAttribute name="value" id="a9d9236e-4bc6-449e-90d9-0c86aa8557fa">
        <type name="Binary"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getValue" id="f4136fa4-0cd7-449e-8dae-467e99e36a38">
        <source>getValue(): Any;

vars

begin
	return self.value;
end;</source>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="setValue" id="bdea67ed-475d-4397-b0b4-62c63a34d1a7">
        <updating/>
        <source>setValue(pValue: Any) updating;

vars
	tmpValue	: Binary;
	
begin

	tmpValue := pValue.Binary;
	if self.value &lt;&gt; tmpValue then
		self.value := tmpValue;
	endif;
	
end;</source>
        <Parameter name="pValue" type="Any"/>
    </JadeMethod>
</Class>
