    <JadeMethod name="isSnapShotDataMatch" id="1ec0a922-02a6-46b2-836b-494e71279f3c">
        <source>isSnapShotDataMatch(_criteria : CM_YACriteria; _yaType : Integer; _propertyValue : String) : Boolean;
// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
// default implementation
vars

begin
	if _yaType &lt;&gt; self.type then
		return false;
	endif;
	//epr TFS 37176 21/2/18 was reimplementing this same code on all boolean type criteria
	if _criteria = null or _criteria.myYAData = null then
		return false;
	endif;
	
	if _criteria.myYAData.isKindOf(CM_YADataBoolean) then
		//epr TFS 37176 21/2/18
		return _criteria.myYAData.CM_YADataBoolean.doesValueMatch( _propertyValue.Boolean);
	endif;
	
	return false;
	
end;
</source>
        <Parameter name="_criteria" type="CM_YACriteria"/>
        <Parameter name="_yaType" type="Integer"/>
        <Parameter name="_propertyValue" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
