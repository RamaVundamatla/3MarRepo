    <JadeMethod name="couTypeStringToEnum" id="74da462e-6591-4559-90b2-6322e5e06a25">
        <source>couTypeStringToEnum(pName : String) : Integer;
// ---------------------------------------------------------------------------
// Created:     09 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpVal	: String;

begin

	tmpVal := pName.toUpper;

	if tmpVal = COU_SHORT_NAME.toUpper() then
		return COU_TYPE_SHORT;
	elseif tmpVal = COU_LONG_NAME.toUpper() then
		return COU_TYPE_LONG;
	elseif tmpVal = COU_MARINE_NAME.toUpper() then
		return COU_TYPE_MARINE;
	elseif tmpVal = COU_LAND_NAME.toUpper() then
		return COU_TYPE_LAND;
	endif;
	
	return COU_TYPE_UNDEFINED;

end;</source>
        <Parameter name="pName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
