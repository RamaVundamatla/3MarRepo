<Class name="CM_AutoTaskPackage" id="2a7f62c2-9675-4d9a-8abc-9c5383451012">
    <superclass name="CM_AutoTask"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Packages&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <ExplicitInverseRef name="myPackage" id="4b1c0f7e-33dd-4c20-bb7f-2d93d8ca8468">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Package"/>
        <access>readonly</access>
        <Inverse name="CM_Package::allTasks"/>
    </ExplicitInverseRef>
    <JadeMethod name="getEntryTableViewName" id="67cf3464-cff4-49ea-8c58-4da8a91064f6">
        <source>getEntryTableViewName(): String;

// Created by cnwdvb1 on 27 June 2006

vars

begin
	return 'bgpAutoViewPackage';

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValueForRow" id="cfcfc723-a780-4dbb-aee6-a8c76c97aa6f">
        <source>getValueForRow(_rowName: String; _obj : Object output): Any;

// Created by cnwdvb1 on 27 June 2006

vars

begin

	if _rowName = ETRow_BgpAutoPackages then
		if self.myPackage &lt;&gt; null then
			return self.myPackage.code;
		endif;
	else
		return inheritMethod(_rowName, _obj);
	endif;

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_obj" type="Object" usage="output"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="34d821b0-5d5d-4d01-acc3-7280725fa38d">
        <source>pxyCreateUpdateProxy(): SelfType;

// Created by cnwdvb1 on 27 June 2006
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars

	task : SelfType;
	completedOK		: Boolean;
	
begin
	
	task := inheritMethod();
	task.myPackage := self.myPackage;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return task;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete task;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="5090d5af-199a-4511-9866-87a4c11fe785">
        <updating/>
        <source>setForCreate(_pxyAutoTask: CM_AutoTaskPackage) updating;

// Created by cnwdvb1 on 27 June 2006

vars

begin
	inheritMethod(_pxyAutoTask);
	self.requestClassName	:= BGP_ReportRequestPackageRunner.name;
	self.myPackage			:= _pxyAutoTask.myPackage;

end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskPackage"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="02c2048a-40e3-4e74-bb56-1bc44b2c2787">
        <updating/>
        <source>setForUpdate(_pxyAutoTask: CM_AutoTaskPackage) updating;

// Created by cnwdvb1 on 27 June 2006

vars

begin
	inheritMethod(_pxyAutoTask);
	self.myPackage			:= _pxyAutoTask.myPackage;

end;</source>
        <Parameter name="_pxyAutoTask" type="CM_AutoTaskPackage"/>
    </JadeMethod>
    <JadeMethod name="setValueForRow" id="43991511-1f95-42e5-a932-d0cc25339eb7">
        <updating/>
        <source>setValueForRow(_rowName: String; _value: Any) updating;

// Created by cnwdvb1 on 27 June 2006

vars

begin

	if _rowName = ETRow_BgpAutoPackages then
		self.myPackage := _value.CM_Package;
	else
		inheritMethod(_rowName, _value);
	endif;

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="taskForInvoicePackage" id="586bf1e8-1fad-4b75-977d-a21ea12e68f6">
        <source>taskForInvoicePackage(): Boolean;

vars

begin
	if self.myPackage.isKindOf(CM_PackageInvoice) then
		return true;
	else
		return false;
	endif;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validate" id="31b99d07-f49f-439f-b749-3c8f31cbc345">
        <source>validate();

// Created by cnwdvb1 on 27 June 2006
// 15/12/2014  cnwdb2	PAR 35364

vars

begin
	inheritMethod();

	if self.myPackage = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Package', null, null);
		app.raiseCMException(Input_required_field_package, null, null); // cnwdb2	PAR 35364

	endif;

end;</source>
    </JadeMethod>
</Class>
