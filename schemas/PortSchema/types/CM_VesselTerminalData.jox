        <source>defaultDraftDeparture(set : Boolean; _value : Decimal io) mapping;
// --------------------------------------------------------------------------------
// Created:		07 June 2007 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isUseTerminalDefaults and (not set) then
		_value	:=	self.myTerminal.getConfig(VesselDraftDeparture).Decimal;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getGrossDischargeTimeMinutes" id="01d50a01-928c-43ca-bc9b-71ccb258909b">
        <source>getGrossDischargeTimeMinutes() : Integer;
/*
----------   ----------  --------------------------------------------------
Created:	07 August 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	return (self.grossDischargeTime * 60).Integer;
end;


</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getGrossLoadingTimeMinutes" id="903eb015-c751-43e7-a908-80f53062acb0">
        <source>getGrossLoadingTimeMinutes() : Integer;
/*
----------   ----------  --------------------------------------------------
Created:	07 August 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	return (self.grossLoadingTime * 60).Integer;

end;


</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTerminalCode" id="daf07aa6-8ff1-4e3b-a706-440b0c3d78a2">
        <source>getTerminalCode():String protected;
// --------------------------------------------------------------------------------
// Created:		25 February 2008 by cnwdad1
//
// Purpose:		Returns the receiver's Terminal Code.
//
// Parameters:	None
//
// Returns:		The receiver's Terminal code, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myTerminal &lt;&gt; null then
		return self.myTerminal.code;
	else
		return app.getString(Unknown);
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
