    <JadeMethod name="doBuildActionString" id="aae6afcb-7b99-455b-ab13-25a584980ea2">
        <source>doBuildActionString();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/06/2025	navkc1 JIRA MTN 34779 MTN | Cash Status Change for Special Users.

*/

vars
	
	newStatus 	: Integer;
	str			: String;
	cmb			: CMUI_ComboBox;
begin
	self.lblAction.caption := null;
	
	cmb := self.cmbNewStatus;
	
	if cmb.listIndex &lt;= null then
		return;
	endif;
	
	newStatus := cmb.itemData[cmb.listIndex];
	
	if newStatus = null then
		return;
	endif;
	
	if newStatus = CM_CashReceipt.API_RECEIPT_DRAFT then
		str := app.getErrorString(CR_ActionStrDraft);
	elseif newStatus = CM_CashReceipt.API_RECEIPT_CANCELLED then
		str := app.getErrorString(CR_ActionStrCancelled);
	elseif newStatus = CM_CashReceipt.API_RECEIPT_FINAL then
		str := app.getErrorString(CR_ActionStrFinal);
	endif;
	
	self.lblAction.caption := str;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildStatusCmb" id="f5de9bc0-5722-4d75-bfc7-ddd4f7a71fc9">
        <source>doBuildStatusCmb();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/06/2025	navkc1 JIRA MTN 34779 MTN | Cash Status Change for Special Users.

*/

vars
	fromStatus,
	toStatus,
	newStatus 	: Integer;
	errorMsg	: String;
begin
	self.cmbNewStatus.clear();
	
	fromStatus 	:= CM_CashReceipt.API_RECEIPT_DRAFT;
	toStatus	:= CM_CashReceipt.API_RECEIPT_FINAL;
	
	foreach newStatus in fromStatus to toStatus do
		if not self.myCashReceipt.isNextProformaStatusValid(newStatus, errorMsg, true) then
			continue;
		endif;
		
		self.cmbNewStatus.addItemWithData(app.paymentStatusCashEnumToString(newStatus), newStatus);
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDisplayCurrentReceiptStatus" id="fb63d083-eb9f-4f2d-b5d0-37712da9eae4">
        <source>doDisplayCurrentReceiptStatus();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/06/2025	navkc1 JIRA MTN 34779 MTN | Cash Status Change for Special Users.

*/

vars

begin
	self.lblCurrentStatusData.caption := app.paymentStatusCashEnumToString(self.myCashReceipt.paymentStatus);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="ee41ab81-bda4-4404-b496-381380452930">
        <updating/>
        <source>doSave() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/06/2025	navkc1 JIRA MTN 34779 MTN | Cash Status Change for Special Users.

*/

vars
	realCashReceipt,
	pxyCashReceipt 	: CM_CashReceipt;
	result,
	newStatus		: Integer;
	
begin
	
	realCashReceipt := self.myCashReceipt;
	
	if realCashReceipt = null then
		return;
	endif;
	
	beginLoad;
		pxyCashReceipt := realCashReceipt.pxyCreateUpdateProxy();
	endLoad;
	
	if self.cmbNewStatus.listIndex &lt;= null then
		return;
	endif;
	
	newStatus := self.cmbNewStatus.itemData[self.cmbNewStatus.listIndex];
	
	if newStatus = null then
		return;
	endif;
	
	while true do
		app.myTrxUA.trxCashReceiptJMTUpdateStatus(pxyCashReceipt, newStatus, app.myPassport);
		
		if app.myPassport.trxCompletedOK() then
			app.beep();
			break;
		else
			result := app.showErrorWarningDialog("Change Change Receipt Status", app.myPassport, ErrWarnMode_Update);
			
			if app.myPassport.noErrors() and result = IDOK then
				app.myPassport.warningsAcknowledged := true;
				continue;
			endif;
			
		endif;
		
		return;
		
	endwhile;
	
	self.unloadForm();
	
epilog
	delete pxyCashReceipt;
end;</source>
    </JadeMethod>
