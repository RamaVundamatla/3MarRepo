    <JadeMethod name="getProformaDebtorForInvLine" id="80997a31-8c82-41d5-935f-c0118d2cb745">
        <source>getProformaDebtorForInvLine(_invLine : CM_InvoiceLine) : String;
 
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 March 2018	jlgab1	Initial creation

*/

vars


	proformaPayment : CM_CashPayment;

begin
	foreach proformaPayment in self.allCashPaymentProformaPrints discreteLock do
		if proformaPayment.proformaDesc = _invLine.invoiceLineDesc.narration then
			if proformaPayment.cashValue.roundedTo(2) = _invLine.lineTotal.roundedTo(2)
			or _invLine.overriddenChargeCount &gt; 0 then
				return proformaPayment.myDebtorTerminal.myDebtor.name;
			endif;
		endif;
	endforeach;
	
	return _invLine.debtor.name;

epilog

end;</source>
        <Parameter name="_invLine" type="CM_InvoiceLine"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRealBerthDT" id="725b47db-f5c4-4045-88b8-ba684ba08cbe">
        <source>getRealBerthDT() : TimeStamp;

/*

Purpose:			Get the time of the arrival at the first real Berth


Return Value:		TimeStamp of the first real movement, or null if there isn't one


Date		Who		Reason
17 Apr 2008	cnwkpd1	PAR #16521 - Short Term Movements report

*/

vars
	movement		: HMS_VoyageMovement;
	
begin
	movement := self.getMovementFirstRealBerth();
	if movement = null then
		return null;
	endif;
	
	return movement.arrivalTimeAtToRegion;
	
	
epilog

end;</source>
