<Class name="CnEcHtmlPage" id="624f00af-6cfd-4c1c-9c08-36e9c0f21978">
    <superclass name="CnEcHtmlTagObject"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
