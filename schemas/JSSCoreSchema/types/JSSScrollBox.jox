    <JadeMethod name="moveField" id="ed1453d5-b81a-4dcc-a994-8f5bd5b78d49">
        <updating/>
        <source>moveField(pIsRight:Boolean) updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 February 2001 by cnwdad1
//
// Purpose:		This is an abstraction of a method to move from editing one selected
//				field to another.
//
// Parameters:	pIsRight - If true, move to the right of the current field, otherwise
//					move to the left.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
end;</source>
        <access>protected</access>
        <Parameter name="pIsRight" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processArrowKey" id="2e36b55b-d98a-4e82-96c1-c1c3b313330b">
        <updating/>
        <source>processArrowKey(pKeyCode:Integer io) updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 February 2001 by cnwdad1
//
// Purpose:		Handles which field, and which part of it, is now being edited after
//				the cursor is moved by an arrow key.
//
// Parameters:	pKeyCode - The keycode of the key that was pressed.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Up and down arrow keys are handled using scrolling.
	
	// Left arrow...
	if (pKeyCode = JSS_KEY_ARROWLEFT) then
		self.moveField(false);
		pKeyCode	:=	0;
	endif;
	
	// Right arrow...
	if (pKeyCode = JSS_KEY_ARROWRIGHT) then
		self.moveField(true);
		pKeyCode	:=	0;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pKeyCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="processNumberKey" id="07201f0a-1677-4015-86b3-b87c41f47958">
        <updating/>
        <source>processNumberKey(pKeyCode:Integer io) updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 February 2001 by cnwdad1
//
// Purpose:		Updates the current field value based upon the number key that was
//				pressed.
//
// Parameters:	pKeyCode - The keycode of the numeric key that was pressed.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	fieldValue		: Integer;
	newStringValue	: String;
	newIntegerValue	: Integer;
	keyPressed		: Integer;
	
begin
	if (pKeyCode &gt;= J_key_0 and pKeyCode &lt;= J_key_9) then
		keyPressed	:=	pKeyCode - J_key_0;
		
	elseif (pKeyCode &gt;= JSS_KEY_PAD0 and pKeyCode &lt;= JSS_KEY_PAD9) then
		keyPressed	:=	pKeyCode - JSS_KEY_PAD0;
		
	endif;
	
	fieldValue := self.getValue();
	
	// was it previously selected?
	if selLength = (text.length - 4) then
		newIntegerValue	:=	keyPressed;			// Replace the whole lot.
	else
		// Add onto the end of the current text.
		newStringValue	:=	fieldValue.String &amp; keyPressed.String;
		newIntegerValue	:=	newStringValue.Integer;
	endif;
	
	// Validate the new value within the allowed range.
	if (newIntegerValue &gt;= self.minValue) and (newIntegerValue &lt;= self.maxValue)
	or (self.minValue = 0 and self.maxValue = 0)
	then
		self.setScrollValue(newIntegerValue);
 	endif;
 	
	//self.selectFieldNumber(self.getCurrentFieldNumber);
end;</source>
        <access>protected</access>
        <Parameter name="pKeyCode" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="scrolled" id="22366431-1096-49c2-8638-c668d64c7344">
        <updating/>
        <source>scrolled(textbox: JSSScrollBox input; scrollBar: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 27/11/2002	cnwdad1		If the control is read-only, then do not allow scrolling.
// 23/01/2003	cnwdad1		Added a check of the isChanged flag to determine whether
//							to invoke the firstChange event method.
// --------------------------------------------------------------------------------
begin
	if (not self.isMouseDown)
	and (not self.readOnly)
	then
		// Don't scroll (change the number) if dragging across the control.
		
		if self.scrollVertPos = 0 then
			self.incrementField();
		else
			self.decrementField();
		endif;
	endif;
	
	self.scrollVertPos	:=	1;
	inheritMethod(textbox, scrollBar);
	
	if (not self.isChanged) then
		self.isChanged	:=	true;
		self.firstChange(self);
	endif;
end;</source>
        <Parameter name="textbox" type="JSSScrollBox" usage="input"/>
        <Parameter name="scrollBar" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="selectFieldNumber" id="7f5cb7f4-8093-4a5e-b4fd-c03ea9329bb2">
        <updating/>
        <source>selectFieldNumber(pFieldNo:Integer) updating, protected;
// --------------------------------------------------------------------------------
// Created:		05 February 2001 by cnwdad1
//
// Purpose:		Makes the specified field number the currently selected field.
//
// Parameters:	pFieldNo - The number of the field.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	textValue		: String;
	allValuesArray	: StringArray;
	
begin
	// Highlight the desired field (hour, minute, second) in the edit control.
	create allValuesArray transient;
	
	textValue		:=	self.text;
	textValue.replaceChar(Cr, ' ');
	textValue.replaceChar(Lf, ' ');
	allValuesArray	:=	textValue.trimBlanks().getTokens;
	
	if pFieldNo = 1 then
		self.selStart	:=	2;
	elseif pFieldNo = 2 then
		selStart		:=	2 + allValuesArray[1].length + 1;
	elseif pFieldNo = 3 then
		self.selStart	:=	2 + allValuesArray[1].length + 1  + allValuesArray[2].length + 1;
	endif;
	
//	self.selLength	:=	allValuesArray[pFieldNo].length;
epilog
	delete allValuesArray;
end;</source>
        <access>protected</access>
        <Parameter name="pFieldNo" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setIsMinimumZero" id="dda2981b-b3cc-4f2e-a187-93cd0e993012">
        <updating/>
        <source>setIsMinimumZero(pIsMinimumZero:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		25 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isMinimumZero &lt;&gt; pIsMinimumZero then
		self.isMinimumZero	:=	pIsMinimumZero;
	endif;
end;</source>
        <Parameter name="pIsMinimumZero" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMaxValue" id="98eec42b-9471-4cb6-a5ca-7e98584104a4">
        <updating/>
        <source>setMaxValue(pValue:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2001 by cnwdad1
//
// Purpose:		Sets the maximum value that the field can display.
//
// Parameters:	pValue - The maximum value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.maxValue &lt;&gt; pValue then
		self.maxValue	:=	pValue;
		
		if self.getValue() &gt; self.maxValue then 
			self.setValue(self.maxValue);
		endif;
	endif;
end;</source>
        <Parameter name="pValue" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMinValue" id="56bc94de-c0f1-443f-875b-736c1f3e994d">
        <updating/>
        <source>setMinValue(pValue:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2001 by cnwdad1
//
// Purpose:		Sets the minimum value that the field can display.
//
// Parameters:	pValue - The minimum value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 04/12/2001	cnwdad1		Changed to default the maximum value if it is less than
//							new minimum value.
// --------------------------------------------------------------------------------
begin
	if self.minValue &lt;&gt; pValue then
		self.minValue	:=	pValue;
		
		if self.maxValue &lt; pValue then
			self.setMaxValue(pValue);
		endif;
		
		if self.getValue() &lt; self.minValue then 
			self.setValue(self.minValue);		
		endif;
	endif;
end;</source>
        <Parameter name="pValue" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setScrollValue" id="6127d262-07b3-409e-856e-9165f6892e72">
        <updating/>
        <source>setScrollValue(pValue:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2001 by cnwdad1
//
// Purpose:		Sets the current value of the field.
//
// Parameters:	pValue - The new field value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 25/02/2003	cnwdad1		Added a check of the "is minimum value zero" flag.
// --------------------------------------------------------------------------------
begin
	if (self.minValue = 0 and self.maxValue = 0) 
	or (pValue &gt;= self.minValue and pValue &lt;= self.maxValue)
	then
		if self.isMinimumZero and pValue &lt; 0 then
			return;
		else
			// Adding the CrLf's effectively enables the scrollbars.
			self.text			:=	CrLf &amp; pValue.String &amp; CrLf;
			self.scrollVertPos	:=	1;
		endif;
	endif;
end;</source>
        <Parameter name="pValue" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setValue" id="5d7f6e25-40cb-4d57-81cf-814811e7d57d">
        <updating/>
        <source>setValue(pValue:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2001 by cnwdad1
//
// Purpose:		Sets the current value of the field.
//
// Parameters:	pValue - The new field value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 23/01/2003	cnwdad1		Reset the isChanged flag which is used to determine whether
//							to invoke the firstChange event method.
// --------------------------------------------------------------------------------
begin
	self.setScrollValue(pValue);
	self.isChanged		:=	false;
end;</source>
        <Parameter name="pValue" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="bc78e13d-334e-46b9-8d41-a82ca31ae3f3">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.scrollBars		:=	Window.ScrollBars_Vertical;
	self.scrollVertical	:=	true;
	self.alignment		:=	TextBox.Alignment_Center;
	self.setValue(0);
	
	inheritMethod(cntrl, persistCntrl);
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
