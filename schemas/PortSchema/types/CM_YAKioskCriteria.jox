    <JadeMethod name="pxyCreateUpdateProxy" id="5ff94898-4ecd-405f-9843-1bf5a9efdd3e">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
30 August 2023		jlizm1	Initial creation TFS 59551 Kiosk Additional Question

*/

vars
	proxyObj		: SelfType;
	completedOK		: Boolean;
	
begin

	proxyObj := inheritMethod();
	proxyObj.myAdditionalQuestion := self.myAdditionalQuestion;

	completedOK := true;
	return proxyObj;

epilog
	if not completedOK then
		delete proxyObj;
	endif;
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="4e6c1194-446f-446b-8c0b-9c4d1a477e2e">
        <updating/>
        <source>setForCreate(pProxyObj: SelfType) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
25 August 2023		jlizm1	Initial creation TFS 59551 Kiosk Additional Question

*/

vars

begin
	self.setForUpdate(pProxyObj);
	
	self.myAdditionalQuestion := pProxyObj.myAdditionalQuestion;

epilog

end;</source>
        <Parameter name="pProxyObj" type="SelfType"/>
    </JadeMethod>
