    <JadeMethod name="select40BackEnd" id="eaf3bb13-c89c-42f4-a86a-50ea37a61144">
        <updating/>
        <source>select40BackEnd(y : Real; _lc : CM_LocationsController) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	cellHeight, y1,y2,tiIndex : Integer;
	theTI : CM_TrackedItem;
begin
	if self.displayMode = DISPLAY_MODE_ACTUAL then
		theTI := self.get40FooterFromBackEnd(y,_lc,REAL_MODE);
	elseif self.displayMode = DISPLAY_MODE_QUEUE then
		theTI := self.get40FooterFromBackEnd(y,_lc,QUEUE_MODE);
	elseif self.displayMode = DISPLAY_MODE_PLAN then
		theTI := self.get40FooterFromBackEnd(y,_lc,PLANNING_MODE);
	endif;


	if theTI &lt;&gt; null and self.myYardGridAreaForm &lt;&gt; null then
		self.myDrawingFrame.selectObject(theTI, self.myDrawingFrame.myStartObject, false);
		self.myYardGridAreaForm.showExtraInfo(theTI);
		self.myYardGridAreaForm.picCargo.picture := self.myYardGridAreaForm.showCargoPicture(theTI);
		return true;
	endif;
	
	return false;
end;</source>
        <Parameter name="y" type="Real"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="selectBlockOfObjectsFromXYs" id="4866c618-cfd8-4641-a5d5-1920373d6ee7">
        <updating/>
        <source>selectBlockOfObjectsFromXYs( _class : Class; _x1,_y1,_x2,_y2 : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		07 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	objs : ObjectArray ;
	startObj, anObj : Object;
	selectTI : Boolean;
	cdc : SelfType;
	realX1,realX2,realY1,realY2 : Integer;
	frmX1,frmX2,frmY1,frmY2 : Integer;
	objX1,objX2,objY1,objY2 : Integer;

	tmpFrame : YRD_ContainerDrawingFrame;
begin
	create objs transient;

	cdc := self;

	realX1 := _x1;
	realY1 := _y1;
	realX2 := _x2;
	realY2 := _y2;

	if _x1 &gt; _x2 then
		realX1 := _x2;
		realX2 := _x1;
	endif;
	
	if _y1 &gt; _y2 then
		realY1 := _y2;
		realY2 := _y1;
	endif;
	
	tmpFrame := self.myDrawingFrame;
	
/*
	frmX1 := tmpFrame.left.Integer;
	frmX2 := tmpFrame.clientWidth + tmpFrame.left.Integer;
	frmY1 := tmpFrame.top.Integer;
	frmY2 := tmpFrame.clientHeight + tmpFrame.top.Integer;
	
	
	objX1 := realX1 - frmX1;
	objX2 := realX2 - frmX1;
	objY1 := realY1 - frmY1;
	objY2 := realY2 - frmY1;
	self.allGridObjects.findObjectsInDict(objX1,objY1,objX2,objY2, objs, _class,true);
*/
	objs.clear;
	self.allGridObjects.findObjectsInDict(realX1,realY1,realX2,realY2, objs, _class,true,false);
	foreach anObj in objs do
		self.selectObject(anObj,tmpFrame,true);	
	endforeach;
epilog
	delete objs;


end;</source>
        <Parameter name="_class" type="Class"/>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="selectionBoundsObjectsPutAtKey" id="90aba458-b1f5-415b-a8cb-79f5ab135f2a">
        <source>selectionBoundsObjectsPutAtKey( _x1, _y1, _x2, _y2 : Integer; _obj : Object );

vars

begin
	if self.myDrawingFrame.swapXY then
		self.allSelectionBoundsObjects.putAtKey( 	_y1 + self.myDrawingFrame.swapYadjustment, _x1 + self.myDrawingFrame.swapXadjustment, 
										_y2 + self.myDrawingFrame.swapYadjustment, _x2 + self.myDrawingFrame.swapXadjustment, _obj );
	else
		self.allSelectionBoundsObjects.putAtKey( _x1, _y1, _x2, _y2, _obj );
	endif;

epilog

end;</source>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
