    <JadeMethod name="userNotification" id="c785319c-4405-4efb-8ff7-4c7c65ac1edd">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
/*
----------   ----------  --------------------------------------------------
Created:	13 June 2006 By cnwth2

Purpose:	Note: the userInfo is a delimited string of params to set rather than the 'master' CM_Activity_Capture object
			passed through to straight copy from. This is because it is a transient potentially from a different cache
			so self would be looking at an out of date copy that cannot be resunc.

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars	
	
begin

	if eventType = EVENT_ACTCAP_START then
		if self.currentlyCapturing then
			return;
		endif;
		
		self.setParamsDelimited(userInfo.String);			
		self.setEnabled(true);
		
	elseif eventType = EVENT_ACTCAP_STOP then
		self.setEnabled(false);
	endif;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</Class>
