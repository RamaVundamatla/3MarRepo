    <ImplicitInverseRef name="allRequests" id="dcbf5915-220c-4a22-b8c7-3ea3731b8024">
        <memberTypeInverse/>
        <type name="WS_RestIntJobRequestArray"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="allTodoJobs" id="80de89a7-6c80-4c93-b842-338ec6f914a7">
        <memberTypeInverse/>
        <type name="WS_RestIntJobArray"/>
    </ImplicitInverseRef>
