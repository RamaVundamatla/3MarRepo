<Class name="CM_QStringMethod" id="fa376c2f-cd31-4fd6-92a3-709d545cea2a">
    <superclass name="CM_QueryMethod"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="9c89a4e0-5aa5-4764-a0c2-25c707cf5f42">
        <updating/>
        <source>create() updating;
/*
----------   ----------  --------------------------------------------------
Created:	06 June 2006 By cnwth2
Purpose:	

Changed On   Changed By  Reason
----------   ----------  --------------------------------------------------
18/10/2010	cnwcs5		par25608 - make string method support same operators as string property
*/
vars
	oper : CM_QueryOperator;

begin
	if self.isTransient then 
		return;
	endif;
		
	create oper as CM_QStringStartsWith persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QStringEndsWith persistent;
	self.allAllowedOperators.add(oper);
	
	//15 May 2013	NDL	Par 31506
	create oper as CM_QStringStartsOrEndsWith persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QStringContains persistent;
	self.allAllowedOperators.add(oper);

	create oper as CM_QStringNotEqual persistent;
	self.allAllowedOperators.add(oper);

	create oper as CM_QStringEquals persistent;
	self.allAllowedOperators.add(oper);
	
	//+cnwcs5 par25608 - make string method suuport same operators as string property
	create oper as CM_QStringRange persistent;
	self.allAllowedOperators.add(oper);
end;</source>
    </JadeMethod>
    <JadeMethod name="getDefaultOperator" id="234331ad-43c7-4362-82d2-30300d3f46da">
        <source>getDefaultOperator(): CM_QueryOperator;
/*
----------   ----------  --------------------------------------------------
Created:	06 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	return self.allAllowedOperators[CM_QueryOperator.Operator_StartsWith];

end;</source>
        <ReturnType type="CM_QueryOperator"/>
    </JadeMethod>
    <JadeMethod name="getQueryOperatorForYADataConv" id="55b673c7-03e3-4484-8d16-a7fe1aa6e3cb">
        <source>getQueryOperatorForYADataConv(): Class;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 June 2015	cnwndl1	Initial creation	Par 36338

*/

vars

begin
	return CM_QStringEquals;

epilog

end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="getValueForObject" id="4f16459f-bdeb-409e-b3b1-9c20914d7a24">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;
/*
----------   ----------  --------------------------------------------------
Created:	06 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	propValue : String; 

begin
	propValue := _obj.sendMsg(self.propertyName).String;

	if self.needToUpperCase then
		propValue := propValue.String.toUpper;
	endif;

	return propValue;

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="propertyAvailableInCombo" id="f12bbb90-402d-4917-841a-84f54740e97c">
        <source>propertyAvailableInCombo(): Boolean;
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
// Hide the "Details" transaction property from the selector combo as it's only needed in the result table
vars

begin
	if (self.propertyClassName = CM_TITransaction.name and self.propertyName = CM_TITransaction::getDetails.name)
		or (self.propertyClassName = CM_AuditObject.name and self.propertyName = CM_AuditObject::getDetails.name) then
		return false;
	else
		return inheritMethod();
	endif;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTextValues" id="e379f0f1-5c15-4f01-9b4c-fb1c00573d60">
        <source>setTextValues(_txt: TextBox input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*
----------   ----------  --------------------------------------------------
Created:	06 June 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if _txt = null or (not CM_QueryStringOperators.hasInstance(_operator)) then
		return;
	endif;
	
	_txt.text := _operator.CM_QueryStringOperators.searchValue.String;

end;</source>
        <Parameter name="_txt" type="TextBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
