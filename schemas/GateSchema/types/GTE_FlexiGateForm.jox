    <JadeMethod name="isDriverAllowed" id="433d57cb-5190-4fb1-aea2-be9b0083bda7">
        <source>isDriverAllowed() : Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
12 March 2010		cnwjk3	PAR 22778
10 June 2024		jlizm1	TFS 63908 Allow duplicate driver names

*/

vars
	key,
	driverCode,
	driverName 	: String;
	driver		: CM_DriverDetails; 
begin

	driverCode := self.txtDriverCode.text.trimBlanks();
	if driverCode = null and self.cmbDriverCode.itemObject &lt;&gt; null and self.cmbDriverCode.itemObject.isKindOf(CM_DriverDetails) then
		driverCode := self.cmbDriverCode.listObject.CM_DriverDetails.code;
	endif;
	driverName := self.txtDriverName.text.trimBlanks();
	
	if driverCode = null and driverName = null then
		return true;
	endif;
	
	if driverCode &lt;&gt; null then
		key := driverCode;
	else
		key := driverName;
	endif;
	
	driver := self.myTerminal.findDriver(key);
	if driver = null then
		return true;
	else	
		return driver.isDriverOK() = null;
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOKToProceed" id="91fb0dc6-f0b7-4bd8-8cac-080e1ee50326">
        <updating/>
        <source>isOKToProceed() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     07 August 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 16/02/2011		cnwdap1			PAR #27031 Changes to setting of self.detailsChangedVehicle meant this method
//									always returned true when nothing had been entered on the screen. This meant the
//									Receive/Release forms could be shown without a vehicle visit record
// 11/05/2023		navpw1			TFS: 54049 (55840) - Updates the vehicle visit record for the slot type validation vbs process
// ---------------------------------------------------------------------------

vars
	vbsProcess : CM_VBSProcess;					// ### TFS 54049 (55840) 05May2023 NAVPW1
	
begin
	if not self.isDriverAllowed() then			// cnwjk3 PAR 22778 12/03/2010
		self.lblDriverCode.enabled := true;		// cnwjk3 PAR 22778 12/03/2010
		self.lblDriverName.enabled := true;		// cnwjk3 PAR 22778 12/03/2010
		self.txtDriverCode.enabled := true;		// cnwjk3 PAR 22778 12/03/2010
		self.txtDriverName.enabled := true;		// cnwjk3 PAR 22778 12/03/2010
	endif;										// cnwjk3 PAR 22778 12/03/2010
	
	vbsProcess := self.myVBSProcess;					// ### TFS 54049 (55840) 05May2023 NAVPW1
	
	//if self.detailsChangedVehicle then								// PAR #27031
	if self.detailsChangedVehicle or self.myRealVVR = null then			// PAR #27031
		return self.doUpdateVVRec();
	elseif vbsProcess &lt;&gt; null and vbsProcess.isVbsSlotValidation then	// ### TFS 54049 (55840) 05May2023 NAVPW1
		return self.doUpdateVVRec();									// ### TFS 54049 (55840) 05May2023 NAVPW1
	endif;
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isVVRUpdatable" id="9bcc11a1-2835-4dbd-961c-e6a062fc573a">
        <source>isVVRUpdatable() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 August 2009	cnwjk3	Initial creation

*/

vars

begin
	if self.myRealVVR = null  then
		return false;
	elseif
		self.myRealVVR.isUpdatable = false then
		return false;
	else 
		return app.myPassport.myUser.canDo(self.myTerminal, self.permissionMaint);
	endif;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
