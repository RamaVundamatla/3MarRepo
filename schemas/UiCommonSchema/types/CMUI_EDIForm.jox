	table.selectMode 	:= CM_BaseTable.SelectMode_Row;
	table.selectionType := CM_BaseTable.SelectionType_Row;
	table.scrollBars 	:= CM_EntryTable.ScrollBars_Both;
	table.fixedRows 	:= 1;
	table.rows 			:= 1;
	table.fixedColumns 	:= 0;
	table.columns 		:= 4;
	table.tag			:= null;
	table.autoSize 						:= table.AutoSize_BothColumnMinimum;	 
	table.accessColumn(4).wordWrap 		:= true;		 
	table.accessedColumn.widthPercent 	:= 70;	 
	
	table.accessCell(1, 1).text := 'ID'&amp;Tab&amp;'Type'&amp;Tab&amp;'Property'&amp;Tab&amp;'Error Message';

end;</source>
