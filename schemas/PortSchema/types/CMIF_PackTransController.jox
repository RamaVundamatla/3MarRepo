<Class name="CMIF_PackTransController" id="8640b79c-d996-40da-ba41-5355031c0e4a">
    <superclass name="CMIF_TITransactionController"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transact"/>
    <PrimAttribute name="action" id="c41b4a54-bbe2-41ef-b61d-c21f522e65e2">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="setFromTransaction" id="b8faca14-8a8c-4bcc-b56f-483cbc7ac086">
        <updating/>
        <source>setFromTransaction(_txn: CM_TITransaction) updating;   //transaction could be a CM_Pack or a CM_Unpack
//setFromTransaction(_txn: CM_Pack) updating;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 21 January 2004
//
//********************************************************************
vars

begin
	inheritMethod(_txn);

	if CM_Pack.hasInstance(_txn) then
		self.action := _txn.CM_Pack.action;
	elseif CM_Unpack.hasInstance(_txn) then
		self.action := _txn.CM_Unpack.action;
	else
		//no action
	endif;
	

end;</source>
        <Parameter name="_txn" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="setTransactionDetails" id="f2ad1c27-f9a3-46d1-b145-499176866586">
        <updating/>
        <source>setTransactionDetails(pTrx: CM_Pack input) updating, protected;
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 21 January 2004
//
//********************************************************************
vars

begin
	inheritMethod(pTrx);
	pTrx.setAction(self.action);
end;</source>
        <access>protected</access>
        <Parameter name="pTrx" type="CM_Pack" usage="input"/>
    </JadeMethod>
</Class>
