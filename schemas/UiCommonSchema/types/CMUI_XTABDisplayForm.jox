    <JadeMethod name="sendToScreen" id="faabe637-d571-449a-9c38-90bdf83303fd">
        <updating/>
        <source>sendToScreen()protected, updating;
// ---------------------------------------------------------------------------
// Created:     15 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/12/2009	cnwcs5		ccms 1023 - snapshot summaries
// 09/08/2010	CNWCS5		PAR 23706 - small optimisation
// ---------------------------------------------------------------------------
vars
	coll	: Collection;
	mode	: Integer;
begin
	// Use self.myCollectionForDrillDown as we know it was populated during 
	// the contextMenu event
	//coll := self.getCollectionForDrillDown;
	coll := self.myCollectionForDrillDown;		// 09/08/2010 cnwcs5 par 23706 
	
	if self.myProxyOutputFormat.isSnapshotMode then					// cnwcs5 16/12/2009
		self.getSnapshotObjectsFromColl (coll);						// cnwcs5 16/12/2009
							
		coll := self.mySnapshotDrillDownColl;						// cnwcs5 16/12/2009
		mode := self.myProxyOutputFormat.myOutputFormat_SS.mode;	// cnwcs5 16/12/2009
	else															// cnwcs5 16/12/2009
		mode := self.myProxyOutputFormat.mode;
	endif;															// cnwcs5 16/12/2009
	
	self.doSendToScreen_Send( self.tblScreens, coll, mode );
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setCollection" id="89c394ed-91c2-4c54-869e-b51cfca40366">
        <source>setCollection(_coll :Collection);
// ---------------------------------------------------------------------------
// Created:     02 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.myCollection.clear;
	
	_coll.copy (self.myCollection);
	
epilog

end;</source>
        <Parameter name="_coll" type="Collection"/>
    </JadeMethod>
    <JadeMethod name="setHideRepeatedRowValues" id="6c5d2d1f-bf05-41ba-bcbb-a2ec51a63e51">
        <updating/>
        <source>setHideRepeatedRowValues(_value :Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     26 July 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 							ccms 1156/ par23706
// ---------------------------------------------------------------------------
vars
	agent	:CMIF_OutputFormatAgent_XTAB;
	proxy	:CM_OutputFormat_XTAB;
begin
	self.hideRepeatedRowValues	:= _value;
	
	agent := self.myOutputFormatAgent;
	
	if agent &lt;&gt; null then
		agent.setHideRepeatedRowValues (_value);
	endif;
	
	proxy := self.myProxyOutputFormat;
	
	if proxy &lt;&gt; null then
		proxy.setShowRepeatedRowValues (not _value);
	endif;
epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMenuEnquiryCaption" id="703b6d9e-a7c9-478b-9b8d-78702ece718d">
        <source>setMenuEnquiryCaption();

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
30 November 2009	cnwndl1	Initial creation
16/12/2009			cnwcs5	ccms 1023 - snapshot summaries
*/

vars
	firstObject : Object;
begin
	firstObject := self.myCollection.first.Object;

	if self.myProxyOutputFormat.isSnapshotMode then								// cnwcs5 16/12/2009
		firstObject := firstObject.CM_DynamicObject_Snapshot.allObjects.first;	// cnwcs5 16/12/2009
	endif;																		// cnwcs5 16/12/2009
	
	if firstObject &lt;&gt; null then
		if firstObject.isKindOf(CM_TrackedItem) then
			mnuPopupCargoEnquiry.caption := app.getErrorString(Cargo_Enquiry) &amp; "...";
		elseif firstObject.isKindOf(CM_BookingRef) then
			mnuPopupCargoEnquiry.caption := app.getErrorString(Booking_enquiry);
		elseif firstObject.isKindOf(CM_BookingRefItem) then
			mnuPopupCargoEnquiry.caption := app.getErrorString(Booking_item_enquiry);
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyOutputFormat" id="e08b0365-7b0b-4547-8ac4-f100544a23c5">
        <updating/>
        <source>setMyOutputFormat( _proxyFormat, _realFormat : CM_OutputFormat_XTAB; _expectedEdition : Integer ) updating, protected;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
28 January 2009		cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	
begin
	self.myProxyOutputFormat		:= _proxyFormat;
	self.myRealOutputFormat			:= _realFormat;
	setRealFormatExpectedEdition( _expectedEdition );
	
epilog
	
end;
</source>
        <access>protected</access>
        <Parameter name="_proxyFormat" type="CM_OutputFormat_XTAB"/>
        <Parameter name="_realFormat" type="CM_OutputFormat_XTAB"/>
        <Parameter name="_expectedEdition" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setRealFormatExpectedEdition" id="b40232e7-2fa2-46f1-9536-2818434a4010">
        <updating/>
        <source>setRealFormatExpectedEdition( _value : Integer ) updating;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
12 February 2009	cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)

*/
	
vars
	
begin
	if realFormatExpectedEdition &lt;&gt; _value then
		realFormatExpectedEdition	:= _value;
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="b03d4251-13ee-4ba1-87ab-480ea2c93c05">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     26 November 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/02/2010	cnwcs5		par 22435 - release summary changes
// ---------------------------------------------------------------------------
vars

begin
	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;
	self.showToolbar	:= true;
	
	inheritMethod();
	
	// set the minimum values but allow the users previous larger settings to take precedence.
	// also make sure the form is not too large for screen resolution of 1024 * 768.
	self.minimumHeight	:= 250;
	self.minimumWidth	:= 300;
	
	frmMain.top		:= self.frmToolbar.height;
	frmMain.width	:= self.clientWidth;
	frmMain.height 	:= self.clientHeight - frmToolbar.height;
	
	// par 22435 22/02/2010 cnwcs5 - start
	// hide cargo enquiry/send to menus if we are not in tracked item mode
	if self.myProxyOutputFormat &lt;&gt; null then
		if self.myProxyOutputFormat.type &lt;&gt; CM_QueryDefinition.BOL_Query_Type and
			self.myProxyOutputFormat.type &lt;&gt; CM_QueryDefinition.TrackedItem_Query_Type and
			self.myProxyOutputFormat.type &lt;&gt; CM_QueryDefinition.Snapshot_Query_Type then
			self.mnuPopupCargoEnquiry.visible 	:= false;
			self.mnuPopupSendTo.visible			:= false;
		endif;
	endif;
	// par 22435 22/02/2010 cnwcs5 - end
	
	//self.doGenerateXTAB;		// move to loadDataForFirstTime
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showHideFrame" id="ee1d8913-08bb-47ea-b75d-b002799234a5">
        <source>showHideFrame(_frm: CMUI_Frame input; _show: Boolean; _modal: Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     15 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 19 Jun 2013	cnwcs5		par 31678 - centre frame over window
// ---------------------------------------------------------------------------
vars
	obj 			: Object;
	
begin
	if _frm = null then
		return;
	endif;
	
	if _show then
		//disables everything else and brings the frame front and centre
		if _modal then
			self.frmMain.enabled := false;
			self.frmToolbar.enabled := false;
		endif;
		
		_frm.parent 	:= self;
		_frm.zOrder(1);
		_frm.enabled	:= true;

		_frm.centreWindow;
		
		_frm.visible := true;
		
		if _frm = self.frmSendToScreen then
			self.btnSend.default := true;
			self.tblScreens.setFocus();
		endif;	
	else
		_frm.visible 			:= false;
		self.frmMain.enabled 	:= true;
		self.frmToolbar.enabled := true;
		self.btnSend.default 	:= false;
		
		// CCMS Tranship: unload the unused forms that were created in self.showScreensToSendTo();
		foreach obj in self.allDefaultForms do
			if app.isValidObject(obj) then 
				if (not obj.Form.visible) then
					obj.Form.unload();
					self.allDefaultForms.remove(obj);	// PAR #17642 - Need to actually delete forms to stop transient leaks
					delete obj;
				endif;
			endif;
		endforeach;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_frm" type="CMUI_Frame" usage="input"/>
        <Parameter name="_show" type="Boolean"/>
        <Parameter name="_modal" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblMain_contextMenu" id="72569820-4965-4b99-8b68-2d12eaa31807">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMain_contextMenu(
	_table	: Table input;
	_conwin	: Window input;
	_mouse	: Boolean;
	_x		: Integer;
	_y		: Integer ) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     02 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26/07/2010	cnwcs5		ccms 1156 / par 23706 - hide/show repeated row values
// ---------------------------------------------------------------------------
vars
	coll	: Collection;
	ti 		: CM_TrackedItem;
	voy : CM_Voyage;
	bookRefItem : CM_BookingRefItem;
begin
	coll := self.getCollectionForDrillDown;
	
	if coll = null or coll.isEmpty then
		//return false;
		self.mnuPopupCargoEnquiry.visible	:= false;	// ccms 1156 / par 23706 
		self.mnuPopupSendTo.visible			:= false;	// ccms 1156 / par 23706 
		self.mnuPopupSummarise.visible		:= false;	// ccms 1156 / par 23706 
		self.mnuSaveAsVoyAlloc.visible 		:= false;	// ccms 1156 / par 23706 
		self.mnuSaveAsVoyAllocALL.visible 	:= false;	// ccms 1156 / par 23706 
		self.mnuSep1.visible				:= false;	// ccms 1156 / par 23706 
		self.mnuInspectObject.visible		:= false;	// ccms 1156 / par 23706 
	else												// ccms 1156 / par 23706 
		self.mnuPopupCargoEnquiry.visible	:= true;	// ccms 1156 / par 23706 
		self.mnuPopupSendTo.visible			:= true;	// ccms 1156 / par 23706 
		self.mnuPopupSummarise.visible		:= true;	// ccms 1156 / par 23706 
		self.mnuSep1.visible				:= true;	// ccms 1156 / par 23706 
		self.mnuInspectObject.visible 		:= app.isAllowedToInspect();
		
		// PAR 21746
		if coll.first().isKindOf(CM_TrackedItem) then
			ti := coll.first().CM_TrackedItem;
			voy := ti.myVoyage;
		elseif coll.first().isKindOf(CM_BookingRefItem) then
			bookRefItem := coll.first().CM_BookingRefItem;
			voy := bookRefItem.myBookingReference.myVoyage;
		endif;
		if self.isVoyageCCMode and voy &lt;&gt; null then
			self.mnuSaveAsVoyAlloc.visible := true;
			self.mnuSaveAsVoyAllocALL.visible := true;
			if ti &lt;&gt; null then
				self.mnuSaveAsVoyAlloc.caption := app.getErrorString1(Creat_load_colou_codin_voyag_b,  voy.code);
				self.mnuSaveAsVoyAllocALL.caption := app.getErrorString1(Creat_load_colou_codin_vo8989,  voy.code);
			else
				self.mnuSaveAsVoyAlloc.caption := app.getErrorString1(Creat_load_colou_codin_voyBOOK,  voy.code);
				self.mnuSaveAsVoyAllocALL.caption := app.getErrorString1(Creat_load_colou_codin_BOOK76,  voy.code);
			endif;
			
		else
			self.mnuSaveAsVoyAlloc.visible := false;		
			self.mnuSaveAsVoyAllocALL.visible := false;
		endif;
		
		self.setMenuEnquiryCaption();	//30 Nov 2009	NDL	CCMS 1028
	endif;	// ccms 1156 / par 23706 
	
	// ccms 1156 / par 23706 - start
	if self.hideRepeatedRowValues then
		self.mnuHideShowRepeatedRow.caption := app.getErrorString (Show_repeated_values);
	else
		self.mnuHideShowRepeatedRow.caption := app.getErrorString (Hide_repeated_values);
	endif;
	// ccms 1156 / par 23706 - end
	
	// now show the menu and terminate further processing
	return self.showContextMenu( self.mnuPopup1, _table, _conwin, _mouse, _x, _y );
	
epilog
	
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_conwin" type="Window" usage="input"/>
        <Parameter name="_mouse" type="Boolean"/>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="323fd4b5-bc05-4588-a398-9a5b5578220e">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0009236, locale);
	btnCancelSend.translateCaption(Xlat_0009237, locale);
	btnExtract.translateBubbleHelp(Xlat_0009333, locale);
	btnExtract.translateCaption(Xlat_0009240, locale);
	btnPrintTV.translateBubbleHelp(Xlat_0009242, locale);
	btnPrintTV.translateCaption(Xlat_0009243, locale);
	btnSend.translateCaption(Xlat_0009244, locale);
	btnShowDefn.translateBubbleHelp(Xlat_0009322, locale);
	btnShowDefn.translateCaption(Xlat_0009323, locale);
	lblScreens.translateCaption(Xlat_0009245, locale);
	mnuHideShowRepeatedRow.translateCaption(Xlat_0016261, locale);
	mnuInspectObject.translateCaption(Xlat_0014286, locale);
	mnuPopup1.translateCaption(Xlat_0009246, locale);
	mnuPopupCargoEnquiry.translateCaption(Xlat_0014629, locale);
	mnuPopupSendTo.translateCaption(Xlat_0014630, locale);
	mnuPopupSummarise.translateCaption(Xlat_0009249, locale);
	mnuSaveAsVoyAlloc.translateCaption(Xlat_0013554, locale);
	mnuSaveAsVoyAllocALL.translateCaption(Xlat_0014287, locale);
end;</source>
    </JadeMethod>
