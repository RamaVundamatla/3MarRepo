    <JadeWebServicesMethod name="getCommodityGroups" id="e8a405c5-64f0-4744-8138-b2aa0170a3e5">
        <source>getCommodityGroups() : WS_CodeResponse webService;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 28/08/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	response : WS_CodeResponse;
	completedOK : Boolean;
	commodityGroup : CM_CommodityGroup;
	iter : Iterator;
	wsCode : WS_Code;
begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	create response transient;
	
	iter := app.myRoot.allCommodityGroups.createIterator;
	while iter.next(commodityGroup) do
		create wsCode transient;
		wsCode.setProxyDetails(commodityGroup, commodityGroup.code, commodityGroup.description);
		response.allCodes.add(wsCode);
	endwhile;
	
	completedOK := true;
	return response;
	
epilog
	delete iter;
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <ReturnType type="WS_CodeResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getCompanies" id="98930f88-cfa4-41d0-9ee6-9cf1686e274b">
        <source>getCompanies() : WS_CompaniesResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2018	jlger1	Initial creation 37654

*/

vars
	response		: WS_CompaniesResponse;
	completedOK		: Boolean;
	proxyCompany	: WS_Company;
	company			: CM_Bank;

	failedDAC  		: CM_DataAccessController;
	obj				: Object;
begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passDelayType for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	if app.myPassport.myTerminal = null then
		completedOK:=true;
		return response;
	endif;
	
	// Populate the response
	foreach company in app.myPassport.myTerminal.companies where company.isBusinessUnit do
		
		create proxyCompany transient;
		proxyCompany.setProxyFromObject(company);
		response.allCompanies.add(proxyCompany);
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up transients
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
