    <JadeMethod name="makeCOMSegment" id="4a2887bf-760e-4f30-97f5-7f37cfd9112c">
        <source>makeCOMSegment(_protocol : CM_CamProtocol; _group : HugeStringArray input; _vgmDetails : CM_VGMDetails) : String protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 20/07/2017	jlgdap1		Initial creation TFS 4492 SNO VERMAS Changes
// 20/10/2017   cnwma1	    TFS #7143 POL - ##6038## Missing Export VGM - PORT CHALMERS
// 09.11.2017   cnwma1		TFS # 7737 POL - 1090 exception flood from CAMS
// 21 Dec 2017	jlgrh7 		TFS #36348 POL - [Fwd: ##RE-6710## : FW: Problems with VERMAS for Hamburg Süd -- I-170137303]
//21/03/2018 	jlgrh7			TFS37723 problems with VERMAS for Hamburg Süd 
//
constants
	MESSAGE = "COM";
vars
	msg	: String;
	plus : Character; 
	colon : Character; 
	singleQuote : Character;
	weightAuth : CM_WeighAuthority;
	mPhone, ediTransmission, email, fax, mail, phone : String;
	
begin
	if _vgmDetails = null then  //09.11.2017  cnwma1 TFS #7737
		return null;
	endif;
	if _vgmDetails.myWeighAuthTerminal &lt;&gt;  null then   //20.10.2017 cnwma1 TFS #7423
		weightAuth := _vgmDetails.myWeighAuthTerminal.myWeighAuthority;
		if _vgmDetails.vgmEDITransmission = null and _vgmDetails.vgmElectronicMail = null 
		and _vgmDetails.vgmMail = null and _vgmDetails.vgmPhone = null and _vgmDetails.vgmTelefax = null
		and _vgmDetails.vgmTelephone = null then
			if weightAuth.address1 = null and weightAuth.address2 = null and weightAuth.address3 = null 
			and weightAuth.email1 = null and weightAuth.email2 = null and weightAuth.phone1 = null 
			and weightAuth.phone2 = null then
				return msg;
			endif;
		endif;
	endif;
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	// Mobile Phone Number
	mPhone := _vgmDetails.vgmPhone;
	if mPhone = null and weightAuth &lt;&gt; null then   //20.10.2017 cnwma1 TFS #7423
		mPhone := weightAuth.phone2;
	endif;
	if mPhone &lt;&gt; null then
		msg := MESSAGE &amp; plus &amp; 
				mPhone &amp; colon &amp; "AM";						//-TFS36348			//+TFS37723
				//mPhone &amp; plus &amp; "AM";							//+TFS36348		//-TFS37723
		msg := msg &amp; singleQuote;
		if _group &lt;&gt; null then
			_group.add (msg);
		endif;
	endif;
			
	// EDI Transmission
	if _vgmDetails.vgmEDITransmission &lt;&gt; null then
		msg := MESSAGE &amp; plus &amp; 
				_vgmDetails.vgmEDITransmission &amp; colon &amp; "EI";							//-TFS36348					//+TFS37723
				//_vgmDetails.vgmEDITransmission &amp; plus &amp; "EI";								//+TFS36348			//-TFS37723
		msg := msg &amp; singleQuote;
		if _group &lt;&gt; null then
			_group.add (msg);
		endif;
	endif;
			
	// Email
	email := _vgmDetails.vgmElectronicMail;
	if email = null and weightAuth &lt;&gt; null then  //20.10.2017 cnwma1 TFS #7423
		email := weightAuth.email1;
	endif;
	if email &lt;&gt; null then
		msg := MESSAGE &amp; plus &amp; 
				email &amp; colon &amp; "EM";							//-TFS36348				//+TFS37723
				//email &amp; plus &amp; "EM";							//+TFS36348			//-TFS37723
		msg := msg &amp; singleQuote;
		if _group &lt;&gt; null then
			_group.add (msg);
		endif;
	endif;
			
	// Fax
	if _vgmDetails.vgmTelefax &lt;&gt; null then      //20.10.2017 cnwma1 TFS #7423
		msg := MESSAGE &amp; plus &amp; 
				_vgmDetails.vgmTelefax &amp; colon &amp; "FX";								//-TFS36348		//+TFS37723
				//_vgmDetails.vgmTelefax &amp; plus&amp; "FX";								//+TFS36348	//-TFS37723
		msg := msg &amp; singleQuote;
		if _group &lt;&gt; null then
			_group.add (msg);
		endif;
	endif;
			
	// Mail
	mail := _vgmDetails.vgmMail; 
	//mail:=mail.replaceString(Colon,Comma); 								//+TFS36348			//-TFS37723
	//mail := mail.replaceString(SemiColon,Comma); 					//+TFS36348			//-TFS37723
	if mail = null and weightAuth &lt;&gt; null then   //20.10.2017 cnwma1 TFS #7423
		//mail := weightAuth.address1 &amp; Colon &amp; weightAuth.address2 &amp; Colon &amp; weightAuth.address3;					//-TFS36348
		mail := weightAuth.address1;																																						//+TFS36348 To elimiated last Comma
		if weightAuth.address2 &lt;&gt; null then
			mail := weightAuth.address1 &amp; Comma &amp; weightAuth.address2;
			if weightAuth.address3 &lt;&gt; null then
				mail := mail &amp; Comma &amp; weightAuth.address3;
			endif;
		else
			if weightAuth.address3 &lt;&gt; null then
				mail := mail &amp; Comma &amp; Comma &amp;weightAuth.address3;
			endif;
		endif;
	endif;
	mail:=mail.replaceString(Colon,Comma); 								//+TFS37723
	mail := mail.replaceString(SemiColon,Comma); 					//+TFS37723
	mail.trimBlanks();
	if mail &lt;&gt; null then
		msg := MESSAGE &amp; plus &amp; 
				mail &amp; colon &amp; "MA";														//-TFS36348		//+TFS37723
				//mail &amp; plus &amp; "MA";														//+TFS36348	//-TFS37723
		msg := msg &amp; singleQuote;
		if _group &lt;&gt; null then
			_group.add (msg);
		endif;
	endif;
			
	// Telephone
	phone := _vgmDetails.vgmTelephone;
	if phone = null and weightAuth &lt;&gt; null then   //20.10.2017 cnwma1 TFS #7423
		phone := weightAuth.phone1;
	endif;
	if phone &lt;&gt; null then
		msg := MESSAGE &amp; plus &amp; 
				phone &amp; colon &amp; "TE";												//-TFS36348								//+TFS37723
				//phone &amp; plus &amp; "TE";												//+TFS36348							//-TFS37723
		msg := msg &amp; singleQuote;
		if _group &lt;&gt; null then
			_group.add (msg);
		endif;
	endif;
	
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_vgmDetails" type="CM_VGMDetails"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeCTASegment" id="2fba69d3-91e6-4a92-90ff-35f5985bee13">
        <source>makeCTASegment(_protocol :CM_CamProtocol; _group :HugeStringArray input;_type, _code :String; _qual1, _qual2 :String):String protected;
/*
Purpose:	Make a UNZ segment

Date		Who		Reason
22/06/2016	cnwma1	TFS #2157 POL - Changes to VERMAS from Ship Operators
*/
constants
	MESSAGE	= "CTA";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	msg := MESSAGE &amp; plus &amp; 
			_type &amp; plus &amp; colon&amp;
			_code.String;
			
	msg := msg &amp; singleQuote;
	
	if _group &lt;&gt; null then
		_group.add (msg);
	endif;
			
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_code" type="String"/>
        <Parameter name="_qual1" type="String"/>
        <Parameter name="_qual2" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeDOCSegment" id="d98d9947-358e-41e1-aa02-1797d1c47914">
        <source>makeDOCSegment(_protocol: CM_CamProtocol; _group: HugeStringArray input;_theTi : CM_TrackedItem): String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/06/2016	cnwma1	TFS #2157 POL - Changes to VERMAS from Ship Operators
15/07/2016  cnwma1 	2351:PNL - Change to VERMAS for DOC segment
05 Oct 2016	cnwma1	TFS #2712 CPL - Container Number in VERMAS DOC segment
18/07/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
28/08/2017	jlgdap1	TFS 6563 Make sure DOC segment is always correct
*/

constants
	MESSAGE	= "DOC";
vars
	msg	: String;
	plus : Character; 
	colon : Character; 
	singleQuote : Character;
	containerId : String;
	vgmCommsType : String;
begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	if _protocol.getVermasDOC then  // 05/10/2016 cnwma1 TFS #2712
		containerId := plus &amp;_theTi.id;
		vgmCommsType := "SHP";					// TFS 6563
	else
		if _theTi.isKindOf(CM_Container) and _theTi.CM_Container.myVGMDetails &lt;&gt; null then
			if _theTi.CM_Container.myVGMDetails.vgmDocumentDetails &lt;&gt; null then	// TFS 4492
				containerId := plus &amp; _theTi.CM_Container.myVGMDetails.vgmDocumentDetails;			// TFS 4492
			else
				containerId := plus &amp; _theTi.id;
			endif;
			
			//17.08.2017 CNWMA1 TFS #6563
			if _theTi.CM_Container.myVGMDetails.vgmCommsType &lt;&gt; null then 
				vgmCommsType := _theTi.CM_Container.myVGMDetails.vgmCommsType;
			else
				vgmCommsType :="SHP"; //17.08.2017 CNWMA1 TFS #6563
			endif;
		else																					// TFS 4492
		
			//containerId := null; 			 17.08.2017 CNWMA1 TFS #6563
			containerId := plus &amp; _theTi.id; //17.08.2017 CNWMA1 TFS #6563
			vgmCommsType :="SHP";			 //17.08.2017 CNWMA1 TFS #6563	
		endif;																					// TFS 4492
	endif;
	
	msg := MESSAGE &amp; 
		plus  &amp;
		//"SM1"&amp;   // 23/06/2016 cnwma1 TFS #2157
		//"SHP"&amp;			//15/07/2016   //17.08.2017 CNWMA1 TFS #6563
		vgmCommsType &amp;
		colon &amp;
		"VGM" &amp;
		colon &amp;
		"306" &amp;
		containerId &amp;  // 05/10/2016 cnwma1 TFS #2712
		singleQuote   ; 
	if _group &lt;&gt; null then
		_group.add (msg);
	endif;
	
	msg := msg &amp; singleQuote;
			
	return msg;
end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_theTi" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMEASegmentForTotalWeight" id="ff73d286-422e-4dbe-bded-3b44b4d70ab2">
        <source>makeMEASegmentForTotalWeight(_protocol :CM_CamProtocol;
							_group :HugeStringArray input;
							_ti : CM_TrackedItem;
							_tiTransaction : CM_TITransaction )  protected;
//
//05 Apr 2016	cnwrs1	TFS 1600 VERMAS Cams
//
vars
	measurementQualifier : String;
	measurementDetail : String;
	measurementUnit : String;
	totalWeight : Decimal [14,4];
begin
		
	measurementQualifier := self.getMeasurementQualifier();
	measurementDetail:= "G";
	totalWeight := _ti.totalWeight;
	if _ti.isWeightCertified and
	   not _ti.isEmpty then
		measurementDetail := "VGM";
	endif;
	measurementUnit := "KGM";
	
	self.makeMEASegment(_protocol, _group, measurementQualifier, measurementDetail, measurementUnit, totalWeight);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiTransaction" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="makeMessageHeader" id="78486584-6c31-4229-986c-a95b7843a55b">
        <updating/>
        <source>makeMessageHeader(_camFile: CM_CamFile input; _camTaskHistory: CM_CamTaskHistory input; _unhSeqNumber: Integer io; _type: String; _fileType: String; _coll: HugeStringArray input): String updating;
//
//05 Apr 2016	cnwrs1	TFS 1600 VERMAS Cams
//23 May 2016	cnwrs1	TFS 2008 - Vermas file changes
//
vars
	protocol	:CM_CamProtocol;
	strLine : String;
begin
	_unhSeqNumber 	:= _unhSeqNumber + 1;
	protocol 		:= _camTaskHistory.camProtocol;
	// UNH
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeUNHSegment(protocol, _unhSeqNumber, _fileType, "D", "16A", "UN", "SMDG04", null, _camTaskHistory.runDateTime), _coll);			//cnwmc5 - 15 Oct 2014 - CCMS 2380

	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeBGMSegment(protocol, _type, _unhSeqNumber, 9, null), _coll);
	
	_camFile.incrementMessageCount();
	return strLine;
end;</source>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_fileType" type="String"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageLOC" id="a86b94e3-763d-4857-a575-302262c7c224">
        <source>makeMessageLOC(_protocol :CM_CamProtocol; _group :HugeStringArray input; _activity :Integer; _ti :CM_TrackedItem) protected;
//
//05 Apr 2016	cnwrs1	TFS 1600 VERMAS Cams
//
vars
	terminal : CM_Terminal;
	code : String;
	fCode : String;
	pCode	:String;
	location : CM_LocationsController;
begin
	terminal := _protocol.terminal;
	
	// LOC+9 - load port
	code := _ti.loadPort.trimRight;
	fCode := self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, terminal);
	
	if fCode = null then
		fCode := code.trimRight;
	endif;
	
	self.makeLOCSegment(_protocol, _group, '9', fCode, '139', '6', null, null, null);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="makeMessageRFF_BN" id="aac12863-5d7c-435b-bcc7-b76ad9b6d1fb">
        <source>makeMessageRFF_BN(_protocol :CM_CamProtocol; _group :HugeStringArray input; _ti :CM_TrackedItem):String protected;
//
//05 Apr 2016	cnwrs1	TFS 1600 VERMAS Cams
//
vars
	msg : String;
	booking : String;
begin
	if _protocol.isUseCarrierRefForBooking then
		booking := _ti.getCarrierReference;
	else
		booking := _ti.bookingReference.trimRight;
	endif;
	
	if booking &lt;&gt; null then
		msg := self.makeRFFSegment(_protocol, _group, "BN", booking);
	endif;
	
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageSealsData" id="cba430f2-8d3b-4b6a-b99a-3872aa42fd20">
        <source>makeMessageSealsData(_ti: CM_TrackedItem; _camMessage: CM_CamMessage input; _group: HugeStringArray input; _camProtocol: CM_CamProtocol; _contentsStatus : String );
/* Changes

Date		Name	TFS#		Description
============================================================================
25 May 2017	cnwrs1	TFS 4465
25 May 2017	cnwrs1	TFS 4466 SNO SEL for MTs
11 Oct 2017	jlgrs1	TFS 7355 SNO muliple seal numbers
31 Oct 2017	jlgrs1	TFS 7701 SNO Terminal Operator seals extractings as TO
29 Mar 2019 jlgka1	TFS 44020	Change StringArray to HugeStringArray.
============================================================================*/
vars
	strSeal		: String;
	plus 		: Character;
	singleQuote	: Character;	
	seals 		: HugeStringArray; // jlgka1 TFS 44020
	sealParty 	: String;
	ventSeal 	: String;
	seal 		: String;
	sealTI 		: CM_SealTI;
begin
//	if _contentsStatus = '4' then
//		//Empty Containers should never include seals data...
//		return;
//	endif;
	
	create seals transient;
	plus := _camProtocol.elementSeparator;	
	singleQuote	:= _camProtocol.segmentTerminator;	
	_ti.getSealNumStringArray(seals, SealType_Operator);
	foreach strSeal in seals do
		if strSeal.trimRight &lt;&gt; "" then	
			_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(strSeal) &amp; plus &amp; "CA" &amp; singleQuote);	
		endif;
	endforeach;
	seals.clear();
	_ti.getSealNumCustomsStringArray(seals);
	foreach strSeal in seals do
		if strSeal.trimRight &lt;&gt; "" then		// 12/09/2014 cnwar2 #34897
			_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(strSeal) &amp; plus &amp; "CU" &amp; singleQuote);	// 10/05/2011 cnwcs5 par 27460
		endif;
	endforeach;
	seals.clear();
	_ti.getSealNumStringArray(seals, SealType_Shipper);
	foreach strSeal in seals do
		if strSeal.trimRight &lt;&gt; "" then	
			_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(strSeal) &amp; plus &amp; "SH" &amp; singleQuote);
		endif;
	endforeach;
	seals.clear();
	_ti.getSealNumStringArray(seals, SealType_TerminalOperator);
	foreach strSeal in seals do
		if strSeal.trimRight &lt;&gt; "" then	
			_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(strSeal) &amp; plus &amp; "TO" &amp; singleQuote);
		endif;
	endforeach;
	
	if _ti.isKindOf (CM_Container) then
		seals.clear();
		_ti.getSealNumStringArray(seals, SealType_Vent);
		foreach strSeal in seals do
			if strSeal.trimRight &lt;&gt; "" then
				_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(strSeal) &amp; plus &amp; "AB" &amp; singleQuote);
			endif;
		endforeach;
	endif;
	foreach sealTI in _ti.allSeals do
		if sealTI.sealType = SealType_Customs or
		   sealTI.sealType = SealType_Operator or
		   sealTI.sealType = SealType_Shipper or
		   sealTI.sealType = SealType_TerminalOperator or
		   sealTI.sealType = SealType_Vent then
			continue;
		endif;	
		foreach seal in sealTI.allSealNums do
			//27 Aug 2020	NDL	TFS 49974 - Don't report 'unknown' type seals with no 'current' value.
			if _camProtocol.formatSeal(seal).trimBlanks = null then
				continue;
			endif;
			_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(seal) &amp; plus &amp; "AB" &amp; singleQuote);
		endforeach;
	endforeach;
epilog
	delete seals;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_contentsStatus" type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessage_TDT" id="8a21f8e9-000a-4d22-87ab-213373244972">
        <source>makeMessage_TDT(_protocol :CM_CamProtocol; _group :HugeStringArray input; _ti :CM_TrackedItem):String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22/06/2016	cnwma1	TFS #2157 POL - Changes to VERMAS from Ship Operators
12 Jul 2016 cnwrs1	Par 34046- Cams Problems in 090
02/10/2017	jlgdap1	TFS 7143 SNO TDT Header should show vessel name, not translated vessel code
*/
vars
	voyage : CM_Voyage;
	voyCode : String;
	oprCode : String ;
	xlatedOprCode :String;
	xlatedVoyCode : String;
	vessCode : String;
	xlatedVessCode : String;
	strLine : String;
	foundMatch : Boolean;
	vessel : CM_Vessel;						// TFS 7143
begin
	voyage := _ti.myVoyage;
	if voyage &lt;&gt; null then
	
		oprCode := _ti.CM_Container.operatorCode;
		if oprCode &lt;&gt; null then
			xlatedOprCode :=  app.myRoot.getXlationForeignOperatorCode( null, oprCode.trimBlanks, foundMatch).trimRight;
		endif;
	endif;
	if voyage.code = NULL_VOYAGE_CODE then
		xlatedVoyCode := null;
		strLine := self.makeTDT20Segment(_protocol, null, '1', null, null, null, null, null, null, null, null, null, null);
	else
		voyCode := voyage.code;
		xlatedVoyCode	:= self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks, voyCode, XLATION_TYPE_VOYAGETERMINAL, _protocol.terminal).trimRight;
		if voyage.vesselCode &lt;&gt; null then
            //xlatedVessCode := self.getXlatedVesselCode(_protocol.operatorXlationCode.trimBlanks, voyage.vesselCode);	// TFS 7143
			vessel := voyage.myVessel;																					// TFS 7143
			if vessel &lt;&gt; null then																						// TFS 7143
				xlatedVessCode := vessel.name;																			// TFS 7143
			endif;																										// TFS 7143
		endif;
	
		if _protocol.camGroup.useCallSign then
			strLine := self.makeTDT20Segment(_protocol, xlatedVoyCode, '1',xlatedOprCode, '', null, null, null, null, voyage.callSign.trimRight, '103', null, xlatedVessCode.toUpper);
		else
			strLine := self.makeTDT20Segment(_protocol, xlatedVoyCode, '1', xlatedOprCode, '', null, null, null, null, voyage.lloydsNumber, '146', null, xlatedVessCode.toUpper);
		endif;
	endif;
	
	if _group &lt;&gt; null then
		_group.add (strLine);
	endif;

	return strLine;
end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessage_TDT20" id="c175e744-9e1c-4b33-8b6a-d0db4598dfad">
        <source>makeMessage_TDT20(_protocol :CM_CamProtocol; _group :HugeStringArray input; _activity :Integer; _transaction :CM_TITransaction; _ti :CM_TrackedItem) : String protected;
//
//05 Apr 2016	cnwrs1	TFS 1600 VERMAS Cams
//02/10/2017	jlgdap1	TFS 7143 SNO TDT Header should show vessel name, not translated vessel code
//
vars
	voyage : CM_Voyage;
	voyCode : String;
	xlatedVoyCode : String;
	vessCode : String;
	xlatedVessCode : String;
	strLine : String;
	vessel : CM_Vessel;					// TFS 7143
begin
	voyage := _ti.myVoyage;
	if voyage.code = NULL_VOYAGE_CODE then
		xlatedVoyCode := null;
		strLine := self.makeTDT20Segment(_protocol, null, '1', null, null, null, null, null, null, null, null, null, null);
	else
		voyCode := voyage.code;
		xlatedVoyCode	:= self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks, voyCode, XLATION_TYPE_VOYAGETERMINAL, _protocol.terminal).trimRight;
		if voyage.vesselCode &lt;&gt; null then
            //vessCode := self.getXlatedVesselCode(_protocol.operatorXlationCode.trimBlanks, voyage.vesselCode);		// TFS 7143
			vessel := voyage.myVessel;																					// TFS 7143
			if vessel &lt;&gt; null then																						// TFS 7143
				vessCode := vessel.name;																				// TFS 7143
			endif;																										// TFS 7143
		endif;
	
		if _protocol.camGroup.useCallSign then
			strLine := self.makeTDT20Segment(_protocol, xlatedVoyCode, '1', null, null, null, null, null, null, voyage.callSign.trimRight, '103', null, xlatedVessCode.toUpper);
		else
			strLine := self.makeTDT20Segment(_protocol, xlatedVoyCode, '1', null, null, null, null, null, null, voyage.lloydsNumber, '146', null, xlatedVessCode.toUpper);
		endif;
	endif;

	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessages" id="ebd04945-976b-4a3d-960c-0d277234511c">
        <source>makeMessages(_trackedItem:CM_TrackedItem; _transaction: CM_TITransaction; _camProtocol: CM_CamProtocol; _camMessage: CM_CamMessage input; _xlVoyageId: String; _terminal: CM_Terminal; _secondTrx : CM_TITransaction);
//
//05 Apr 2016	cnwrs1	TFS 1600 VERMAS Cams
//09/05/2016    cnwma1	TFS 1964 CPL - Missing EDI CAMS Report transaction line on VERMAS messages
//23 May 2016	cnwrs1	TFS 2008 - Vermas file changes
//22/06/2016	cnwma1	TFS #2157 POL - Changes to VERMAS from Ship Operators
//28 Jun 2016  cnwma1  TFS #2226 POL - Update to VERMAS structure from Ship Operators
// 05 Oct 2016	cnwma1	TFS #2712 CPL - Container Number in VERMAS DOC segment
//20/07/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
//23/08/2017	cnwma1  TFS #5834-PNL - EDI Translation - ISO Code foreign out
//20/10/2017    cnwma1	TFS# 7423 : POL - ##6038## Missing Export VGM - PORT CHALMERS
//18 Dec 2017    jlgrh7 TFS 7781 SNO - VERMAS with EDIFACT codes required
//21 Jun 2022	jlizm1	TFS 53754 LNX Different local and server time zones causing incorrect edi outputs
//
vars
	theTI : CM_TrackedItem;
	contentsStatus : String;
	dateTime : TimeStamp;						// TFS 4492
	isoCode,fIsoCode : String;
	useVERMASVer10 : Boolean;			//TFS 7781

begin
// UN
	app.writeStatement(method.qualifiedName &amp; Tab &amp;  ' is &gt;&gt;R&gt;&gt; ' );
	theTI := _transaction.myTrackedItem;
	contentsStatus := self.contentsStatusToString(_transaction.contentsStatus,_camMessage.activity, _transaction.type);
	// EQD segment
	if  theTI.isKindOf(CM_Container) then
		isoCode := theTI.CM_Container.isoType;
		fIsoCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode, isoCode, XLATION_TYPE_ISOTYPE_BYOP, _terminal);
		self.makeEQDSegment(_camProtocol, _camMessage.group3, "CN", theTI.id.trimRight, fIsoCode, '102', '5', null, self.imExStatusToString(theTI), contentsStatus); //23/08/2017 cnwma1 TFS #5834
	else
		self.makeEQDSegment(_camProtocol, _camMessage.group3, "CN", theTI.id.trimRight, theTI.getISOType(), '102', '5', null, self.imExStatusToString(theTI), contentsStatus);  //23/08/2017 cnwma1 TFS #5834
	endif;
	_camMessage.eqdCount := _camMessage.eqdCount + 1;
//	self.makeDTMSegment(_camProtocol, _camMessage.group3, "137", _camProtocol.lastRunDateTime.date.longYearEDI() &amp; _transaction.dateTime.time.shortFormatEDI() , "203");
	// RFF+BN
	self.makeMessageRFF_BN(_camProtocol, _camMessage.group3,  theTI);
//	self.makeNADSegment(_camProtocol, _camMessage.group3, "WPA", "NZPOE", null, null);
	// LOC segments
	self.makeMessageLOC(_camProtocol, _camMessage.group3, _camMessage.activity, theTI);
	//the SEL for the seal number
	self.makeMessageSealsData(theTI, _camMessage, _camMessage.group3, _camProtocol, contentsStatus);
	// MEA - weight
	self.makeMEASegmentForTotalWeight(_camProtocol, _camMessage.group3, theTI, null); //TFS7781
	//self.makeDTMSegment(_camProtocol, _camMessage.group3, "WAT", _transaction.dateTime.date.longYearEDI() &amp; _transaction.dateTime.time.shortFormatEDI() , "203"); //20.10.10 cnwma1 TFS #7423  //-TFS7781
	useVERMASVer10 := _camProtocol.getVermasVer10();
	
	if useVERMASVer10 then
		self.makeDTMSegment(_camProtocol, _camMessage.group3, "798", _transaction.dateTime, "203"); // +TFS7781 Vermas Version 1.0 // TFS 53754
	else
		self.makeDTMSegment(_camProtocol, _camMessage.group3, "WAT", _transaction.dateTime, "203"); // +TFS7781 Vermas Version 0.4 (Default) // TFS 53754
	endif;
	//if theTI.isKindOf(CM_Container) and theTI.CM_Container.myVGMDetails &lt;&gt; null then														// TFS 4492
	//	if theTI.CM_Container.myVGMDetails.vgmDeterminationDT &lt;&gt; null then																	// TFS 4492
	//		dateTime := theTI.CM_Container.myVGMDetails.vgmDeterminationDT;																	// TFS 4492
	//		self.makeDTMSegment(_camProtocol, _camMessage.group3, "798", dateTime.date.longYearEDI &amp; dateTime.time.shortFormatEDI, "203");	// TFS 4492
	//	endif;																																// TFS 4492
	//	self.makeCOMSegment(_camProtocol, _camMessage.group3, theTI.CM_Container.myVGMDetails);												// TFS 4492 Moved to below (COM can only be in a CTA segment group)
	//endif;																																	// TFS 4492
//	self.makeMessageTDT20Segment(_camProtocol, _camVoyage, _camMessage.activity)
	//self.makeTDTSegment(_camProtocol, _camMessage.group3);  // 22/06/2016	cnwma1	TFS #2157
	self.makeMessage_TDT(_camProtocol, _camMessage.group3,  theTI);  // 22/06/2016	cnwma1	TFS #2157
	self.makeRFFSegment(_camProtocol, _camMessage.group3, "VON", theTI.voyageCode);
	self.makeDOCSegment(_camProtocol, _camMessage.group3,theTI);  // 05/10/2016 cnwma1 TFS #2712

	if _camProtocol.getVermasNAD then
		self.makeNADSegment(_camProtocol, _camMessage.group3, "SPC++", theTI.weightCertifiedReference.trimBlanks.toUpper[1:35], '', ''); // 28/06/2016	cnwma1	TFS #2226 //31/08/2016 cnwma1 TFS #2612
	else
		self.makeNADSegment(_camProtocol, _camMessage.group3, "WPA++", theTI.weightCertifiedReference.trimBlanks.toUpper[1:35], '', '');   //09/05/2016 cnwma1 TFS #1964 //31/08/2016 cnwma1 TFS #2612
	endif;
	
	//self.makeNADSegment(_camProtocol, _camMessage.group3, "SPC++", theTI.weightCertifiedReference.trimBlanks.toUpper, '', '');	//09/05/2016 cnwma1 TFS #1964   // 22/06/2016	cnwma1	TFS #2157
	self.makeCTASegment(_camProtocol, _camMessage.group3, "RP", theTI.weightCertifiedName.trimBlanks.toUpper[1:35], '', '');	//09/05/2016 cnwma1 TFS #1964   // 22/06/2016	cnwma1	TFS #2157 //31/08/2016 cnwma1 TFS #2612
	self.makeCOMSegment(_camProtocol, _camMessage.group3, theTI.CM_Container.myVGMDetails);												// TFS 7423 Moved from above
	self.makeNADSegment(_camProtocol, _camMessage.group3, "AM++", theTI.weightCertifiedName.trimBlanks.toUpper[1:35], '', '');		//09/05/2016 cnwma1 TFS #1964 //31/08/2016 cnwma1 TFS #2612
//	self.makeMessageCTA_COM);
end;
</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
