    <JadeMethod name="tFlexiWeightPattern" id="ef7a3ff0-9b08-45f2-848a-f158f2ed8d08">
        <source>tFlexiWeightPattern();
// cnwndl1
// cnwml2 13 May 2010
//
vars
	yaPattern: CMIF_YAPattern;
	patterns: StringArray;
	pattern: String;
begin
	create patterns transient;
	patterns.add("50t");
	patterns.add("50t-60t");
	patterns.add("70T");
	patterns.add("97T-42T");
	
	foreach pattern in patterns do
		create yaPattern transient;
		yaPattern.setPattern(pattern, CMIF_YAPattern.YAPattern_WeightRange);
		self.assertTrueMsg(yaPattern.validate(yaPattern.pattern,null), "validate failed " &amp; pattern);
		delete yaPattern;
	endforeach;
	
epilog
	delete patterns;
	delete yaPattern;
end;</source>
    </JadeMethod>
    <JadeMethod name="tFlexiWeightPatternWithErrors" id="6b2bcbb8-46e2-409a-826c-a3063c2b931c">
        <source>tFlexiWeightPatternWithErrors();
// cnwndl1
// cnwml2 13 May 2010	
//
vars
	yaPattern: CMIF_YAPattern;
	patterns: StringArray;
	pattern: String;
begin
	create patterns transient;
	patterns.add("5T0");
	patterns.add("5T-6T0");
	patterns.add("500t-7t0");
	patterns.add("t23-72T");
	patterns.add("u23-72t");
	patterns.add("*");
	patterns.add("!");	
	patterns.add("2000tT");
	patterns.add("t2000");

	
	
	foreach pattern in patterns do
		create yaPattern transient;
		yaPattern.setPattern(pattern, CMIF_YAPattern.YAPattern_WeightRange);
		self.assertTrueMsg(not yaPattern.validate(yaPattern.pattern,null), "validate succeded " &amp; pattern);
		delete yaPattern;
	endforeach;
	
epilog
	delete patterns;
	delete yaPattern;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRangePattern" id="f2f93a61-f8b7-448f-b0ec-41a5332dfa88">
        <source>tRangePattern();
// cnwndl1
//17 July 2008	cnwdw1	
//
vars
	yaPattern: CMIF_YAPattern;
	patterns: StringArray;
	pattern: String;
begin
	create patterns transient;
	patterns.add("1000");
	patterns.add("1000-2000");
	patterns.add("1000,2000,3000");
	patterns.add("1000-1999,2000-2999,3000");
	patterns.add("!ABC");
	patterns.add("*ABC");
	patterns.add("ABC*");
	patterns.add("ABC*,!ABC");
	patterns.add("*_*");
	
	foreach pattern in patterns do
		create yaPattern transient;
		yaPattern.setPattern(pattern, CMIF_YAPattern.YAPattern_Range);
		self.assertTrueMsg(yaPattern.validate(yaPattern.pattern,null), "validate failed " &amp; pattern);
		delete yaPattern;
	endforeach;
	
epilog
	delete patterns;
	delete yaPattern;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRangePatternWithErrors" id="0323cab5-7803-4818-88b1-96a89079f726">
        <source>tRangePatternWithErrors();
// cnwndl1
//17 July 2008	cnwdw1	
//
vars
	yaPattern: CMIF_YAPattern;
	patterns: StringArray;
	pattern: String;
begin
	create patterns transient;
	patterns.add("1000--2000");
	patterns.add("&lt;");
	patterns.add("&gt;");
	patterns.add("&gt;=");
	patterns.add("2000-");
	patterns.add("ABC-");
	patterns.add("2000&lt;&lt;, 5000&gt;&gt;");
	patterns.add("2000 - 3000 - 4000");
	patterns.add("2&gt;000");
	patterns.add("*");
	patterns.add("!");
	patterns.add("&gt;2000&gt;");
	patterns.add("&lt;=2000-2303&gt;");
	
	//26 Jan 2011	NDL Par 26771
	patterns.add("&lt;5000");
	patterns.add("&gt;5000");
	patterns.add("&lt;2000, &gt;5000");
	patterns.add("&lt;=2000, &gt;=5000");
	patterns.add("&gt;=3000,1000-1999,2000-2999");
	patterns.add("&lt;=ABC, &gt;=ABC"); 
	patterns.add("1000-1999,&gt;=3000");
		
	foreach pattern in patterns do
		create yaPattern transient;
		yaPattern.setPattern(pattern, CMIF_YAPattern.YAPattern_Range);
		self.assertTrueMsg(not yaPattern.validate(yaPattern.pattern,null), "validate succeeded " &amp; pattern);
		delete yaPattern;
	endforeach;
	
epilog
	delete patterns;
	delete yaPattern;
end;</source>
    </JadeMethod>
    <JadeMethod name="tWildcardPattern" id="2329d4ce-2b1f-48ba-83a9-e7e1856a3769">
        <source>tWildcardPattern();
// cnwndl1
//17 July 2008	cnwdw1	
//
vars
	yaPattern: CMIF_YAPattern;
	patterns: StringArray;
	pattern: String;
begin
	create patterns transient;
	patterns.add("DOUG*");
	patterns.add("!DOUG");
	patterns.add("DOUG*,!DOUG");
	patterns.add("!DOUG,!DOUG");
	patterns.add("1*");
	patterns.add("!1");
	patterns.add("!DOUG*, !DOUG");
	patterns.add("*DOUG");
	patterns.add("*DOUG*");
	patterns.add("*DOUG,*doug");
	patterns.add("!DOUG*");
	patterns.add("DOUG_MATT");
	patterns.add("DOUG-MATT");

	//cnwjo3 testing for par 23437
	patterns.add(self.getTerminal.getNullOperator().code);
	patterns.add(self.getTerminal.getNullTrain().getYADisplay);
	patterns.add(self.getTerminal.getNullVoyage().code);
	
	foreach pattern in patterns do
		create yaPattern transient;
		yaPattern.setPattern(pattern, CMIF_YAPattern.YAPattern_Wildcard);
		self.assertTrueMsg((yaPattern.isValidAlpha(yaPattern.pattern) or yaPattern.hasWildcard), "hasWildcard is false");
		self.assertTrueMsg(yaPattern.validate(yaPattern.pattern,self.getTerminal), "validate failed");
		delete yaPattern;
	endforeach;
	
epilog
	delete patterns;
	delete yaPattern;
end;</source>
    </JadeMethod>
    <JadeMethod name="tWildcardPatternWithErrors" id="68eecf5e-ecab-4801-ba90-2415ddaf0f73">
        <source>tWildcardPatternWithErrors();
// cnwndl1
//17 July 2008	cnwdw1	
//
vars
	yaPattern: CMIF_YAPattern;
	patterns: StringArray;
	pattern: String;
begin
	create patterns transient;
	patterns.add("DO*UG");
	patterns.add("DO*UG*");
	patterns.add("DO!UG");
	patterns.add("DOUG!");
	patterns.add("!DOUG!");
	patterns.add("!DO!UG");
	patterns.add("!*DOUG");
	patterns.add("1!");
	patterns.add("*");
	patterns.add("!");
	
	
	
	foreach pattern in patterns do
		create yaPattern transient;
		yaPattern.setPattern(pattern, CMIF_YAPattern.YAPattern_Wildcard);
		self.assertTrueMsg(yaPattern.hasWildcard, "hasWildcard is false");
		self.assertTrueMsg(not yaPattern.validate(yaPattern.pattern,null), "validate succeded " &amp; pattern);
		delete yaPattern;
	endforeach;
	
epilog
	delete patterns;
	delete yaPattern;
end;</source>
    </JadeMethod>
</Class>
