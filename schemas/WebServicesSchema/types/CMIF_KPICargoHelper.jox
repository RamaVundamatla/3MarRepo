/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2025	navhn30	Initial creation

*/

vars

begin
	return inheritMethod(timestamp);

epilog

end;</source>
        <Parameter name="timestamp" type="TimeStamp"/>
        <ReturnType type="String"/>
    </JadeMethod>
