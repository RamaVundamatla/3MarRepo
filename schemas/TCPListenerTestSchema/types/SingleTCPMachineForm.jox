    <JadeMethod name="doSendFaultResponses" id="666f8ad9-a9d7-4e21-8ae1-7b1a3d6f8b2a">
        <updating/>
        <source>doSendFaultResponses() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 February 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift

*/

vars
	message			: TCPMessagePayload;
	tcpMessage		: String;
	i,
	count			: Integer;
	
begin
	count := self.txtNumFaults.text.Integer;
	
	create message transient;
	message.operationName := Operation_SendFaultResponse;
	
	foreach i in 1 to count do
		message.message := self.txtMachine.text &amp; ',' &amp; i.String &amp; ",yes";
		self.sendTCPMessage(message);
	endforeach;
	
	
epilog
	delete message;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSendGetDestination" id="76f83b4b-f4d9-4c73-9ea6-01cab589e3e3">
        <updating/>
        <source>doSendGetDestination() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 February 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift

*/

vars
	message			: TCPMessagePayload;
	tcpMessage		: String;
	
begin
	create message transient;
	message.operationName := Operation_GetDestination;
	message.message := self.txtMachine.text &amp; "," &amp; self.txtContainer1.text &amp; "," &amp; self.txtContainer2.text;
	write message ;
	self.sendTCPMessage(message);
	
	
epilog
	delete message;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
