    <JadeMethod name="setVoyageCode" id="3f2ed685-5ba5-4a80-90b7-9a15d0172319">
        <updating/>
        <source>setVoyageCode( _value : String ) updating;
/*
Date			Who		Reason
09 June 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
11 April 2013	cnwcs5	Make use of local variables
// 20 Nov 2018	jlgrs1	TFS 41659 STWR Make EDI MultiThreaded Stage 6
*/
vars
	config			:CM_EDIConfig;
	coll			:CM_EDITIsByVoyageCodeDict;
	code, codeUpper	:String;
begin
	// need to make sure the manual collection on CM_EDIConfig gets maintained correctly, this collection
	// keeps track of all EDITrackedITems that have some connection to a voyageCode of some kind.
	config := self.myEDIConfig;
	
	if config &lt;&gt; null then
		coll := config.allEDITrackedItemsByVoyageCode;
	endif;
	
	code := self.voyageCode;
	
	// remove the previous non-null value from this collection
	if code &lt;&gt; null and coll &lt;&gt; null then
		codeUpper := code.toUpper;
		
		if coll.includesKey( codeUpper, self ) then
			coll.removeKeyEntry( codeUpper, self, self );
		endif;
	endif;

	// now change it and add this new value to the manual collection (if not null).
	code			:= _value[ 1 : self.voyageCode.maxLength ];
	self.voyageCode	:= code;
	
	if not self.isTransient and
	   code &lt;&gt; null and coll &lt;&gt; null then
		codeUpper := code.toUpper;
		
		if not coll.includesKey( codeUpper, self ) then
			coll.putAtKey( codeUpper, self, self );
		endif;
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
</Class>
