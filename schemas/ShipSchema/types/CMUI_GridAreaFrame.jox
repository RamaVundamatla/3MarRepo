    <JadeMethod name="setAttributeForSelected" id="1b9f19c3-c84f-419d-a48d-a81124671df7">
        <source>setAttributeForSelected(_shipBayArea : SHP_BayArea; _attribute : String);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 May 2009	cnwer1	Initial creation

*/

vars

	aPoint : CMUI_GridPoint;
	bayPoint : SHP_BayPoint;
	pxySD : CM_SlotDefn;
	pxySR : CM_SlotRequest;
	trxUpdateOK,isVesselDefn, colLoadForty  : Boolean;
	shpGridAreaFrame : CMUI_GridAreaFrame;
begin

	shpGridAreaFrame:=	_shipBayArea.myGridAreaFrame;
	if _shipBayArea.allSelectedPoints.size = 0 then
		return;
	endif;

	foreach aPoint in _shipBayArea.allSelectedPoints do
		if aPoint.isKindOf(SHP_BayPoint) then
			bayPoint := aPoint.SHP_BayPoint;
			// ##################################
			// BAY DEFINITION
			if bayPoint.mySlotDefn &lt;&gt; null then
		
					pxySD := bayPoint.mySlotDefn;
					pxySD.setAnAttributeFromController(_attribute);
					bayPoint.setAnAttributeFromController(_attribute);
			endif;
			bayPoint.drawSelf(shpGridAreaFrame);
		endif;
	endforeach;


	
epilog

end;</source>
        <Parameter name="_shipBayArea" type="SHP_BayArea"/>
        <Parameter name="_attribute" type="String"/>
    </JadeMethod>
    <JadeMethod name="setBayLayoutSelected" id="e980a9ef-d85c-487c-88a8-eaf5fe6b00f2">
        <source>setBayLayoutSelected(_attribute : String);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 May 2009	cnwer1	Initial creation

*/
vars

	bayFrame : CMUI_GridAreaFrame;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	bayFrame := self.getControl(ONDECK);
	if bayFrame &lt;&gt; null then
		//bayFrame.myGridArea.SHP_BayAreaAboveDeck.setAttributeForSelected(_attribute); // PAR 18682 CCMS SFW 1055
		
		self.setAttributeForSelected(bayFrame.myGridArea.SHP_BayArea,_attribute);
	endif;

	bayFrame := self.getControl(UNDERDECK);
	if bayFrame &lt;&gt; null then
		//bayFrame.myGridArea.SHP_BayAreaBelowDeck.setAttributeForSelected(_attribute); // PAR 18682 CCMS SFW 1055
		//couldn't use the above because it updated the persistent selected slot data ???
		self.setAttributeForSelected(bayFrame.myGridArea.SHP_BayArea,_attribute);
	endif;
epilog

end;</source>
        <Parameter name="_attribute" type="String"/>
    </JadeMethod>
</GUIClass>
