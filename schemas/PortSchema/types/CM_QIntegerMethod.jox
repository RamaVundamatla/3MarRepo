    <JadeMethod name="propertyAvailableInCombo" id="afa30f5a-4c58-4b92-bb81-8b7df0430138">
        <source>propertyAvailableInCombo(): Boolean;
//  29810 add availabilityGrade as integer value
// Hide the "AG" property from the selector combo as it's only needed in the result table
vars

begin
	if self.propertyClassName = CM_Container.name and
	   self.propertyName = CM_Container::getAvailabilityGrade.name then
		return false;
	else
		return inheritMethod();
	endif;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTextValues" id="b4d92c9c-be17-45e1-92f3-b69e491edd08">
        <source>setTextValues(_txt: TextBox input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
// ---------------------------------------------------------------------------
// Created:     11 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _txt = null or (not CM_QueryIntegerOperators.hasInstance(_operator)) then
		return;
	endif;
	
	_txt.text := _operator.CM_QueryIntegerOperators.searchValue.String;


end;</source>
        <Parameter name="_txt" type="TextBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="1528d9be-48f4-49a9-a6f4-ef2bc84da34d">
