    <JadeMethod name="setControlsForAddEdit" id="c21e4a63-dc87-4886-83b1-e57358f53e52">
        <updating/>
        <source>setControlsForAddEdit(_new : Boolean) updating;
/*
----------   ----------  --------------------------------------------------
Created:	20 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
23/09/2009	cnwcs5		par 20320 - toggle name/file def controls
30/05/2013	cnwcs5		par 31618
07/04/2014	cnwah9		CCMS 1380 
21/11/2015  cnwma1		PAR #36842	Unable to define control column value when defining a User-Defined EDI Format
//16 Dec 2015	cnwrs1	Par 37402 TFS 1192 MultiLine Release Request
27/06/2023	jlizm1		TFS 53901 EUP VBS EDI
20 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
28 jan 2025 jlier1 	TFS 33694
12 Nov 2025 navlc30 JIRA 36357 - LINX - Enable importing debtor addresses via EDI
*/
vars
	fileType	: CM_EDIFileTypeUser;
	int			: Integer;
	sheet		: CMUI_Sheet;
	format : Integer; 	//cnwrs1 ccms 2044 28 Apr 2011
begin
	self.cmbEDIDataType.enabled := true;
	self.showSettings();

	if _new then
		self.clearForNew();
		self.mode := self.MODE_ADD;
		
		self.cmbEDIDataType.enabled	:= true;	// cnwcs5 23/09/2009
	else
		self.mode 	:= self.MODE_UPDATE;
		fileType 	:= self.cmbFileDef.listObject.CM_EDIFileTypeUser;
		if fileType&lt;&gt; null then											//20/11/2015 cnwma1 PAR #36842
			if fileType.dataType &lt;&gt; null then
				// can't change it once it has been set
				self.cmbEDIDataType.enabled := false;
			else
				self.cmbEDIDataType.enabled := true;	// cnwcs5 23/09/2009
			endif;
		endif;
	endif;

	self.lblDataType.enabled	:= true;	// cnwcs5 23/09/2009
	self.lblFileDef.visible		:= false;	// cnwcs5 23/09/2009
	self.cmbFileDef.visible 	:= false;	// cnwcs5 23/09/2009
	self.lblName.visible		:= true;	// cnwcs5 23/09/2009
	self.txtName.visible		:= true;	// cnwcs5 23/09/2009
	self.btnNew.enabled := false;
	self.btnEdit.enabled := false;
	self.btnSaveBase.enabled := true;
	self.btnSettings.enabled := true;
	self.btnDelete.enabled := false;
	self.btnExportDef.enabled := false;
	self.btnImportDef.enabled := false;
	
	self.grpFileDetails.enabled := true;
	self.grpAutoEmail.enabled 	:= true;
	self.grpSampleData.enabled 	:= true;
	self.grpXlate.enabled		:= true;	// cnwcs5 23/09/2009

	format := self.cmbFormatType.itemData[self.cmbFormatType.listIndex];	//cnwrs1 ccms 2044 28 apr 2011
	self.setControlsForFormatType(format);	//cnwrs1 ccms 2044 28 Apr 2011
		
	
// par 20320 - start	
	while true do
		sheet := self.shtFieldMapping.getControl (int);
		
		if sheet = null then
			break;
		endif;
		
		self.tblFieldMap.getControl(int).userInputEnabled 		:= true;
		self.tblUserFieldCode.getControl(int).userInputEnabled 	:= true;
		self.txtControlColVal.getControl(int).enabled 			:= true;	// cnwcs5 23/09/2009
		self.txtNumFields.getControl(int).enabled				:= true;	// cnwcs5 23/09/2009	
		
		self.setTblUserCodeView(false, int);
		
		self.tblFieldMap.getControl(int).allowDrag := Table.AllowDrag_Rows;
		
		int := int + 1;
	endwhile;
// par 20320 - end	

	
	
	//CCMS1380 cnwah9 07/04/2014
//	if not (self.cmbEDIDataType.text = "BOL" or 
	if format &lt;&gt; CM_EDIFileType.FORMAT_XML and  not (self.cmbEDIDataType.text = "BOL" or //23 Aug 2018	NDL	TFS 40316
			self.cmbEDIDataType.text = "Booking Reference Multi Line" or						
			self.cmbEDIDataType.text = app.getErrorString(Cargo_group_assignment) or
			self.cmbEDIDataType.text = "RORO Deck Plan" or							
			self.cmbEDIDataType.text = "RORO Deck Stowage Advice" or	
			self.cmbEDIDataType.text = app.getErrorString(Request_multiline) or
			self.cmbEDIDataType.text ="Ship Manifest" or							
			self.cmbEDIDataType.text ="Train Consist" or
			self.cmbEDIDataType.text = app.getErrorString(Prenote) or //17 Nov 2016	NDL TFS 2843 / 2604
			self.cmbEDIDataType.text = app.getErrorString(Cargo_OnShip) or //18 Nov 2016	NDL TFS 2843 / 2604
			self.cmbEDIDataType.text = app.getErrorString(Cargo_OnSite) or //18 Nov 2016	NDL TFS 2843 / 2604
			self.cmbEDIDataType.text ="Load/Discharge List" or	// 08 Nov 2017	NDL	TFS 7727
			self.cmbEDIDataType.text = app.getErrorString(Vehicle_booking_slot) or // TFS 53901
			self.cmbEDIDataType.text = "CallOff" or					//20 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
			self.cmbEDIDataType.text = "Transport Manifest" or		//20 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
			self.cmbEDIDataType.text ="Voyage" or
			self.cmbEDIDataType.text = app.getUntranslatedErrorString(Delivery_party) or
			self.cmbEDIDataType.text = app.getErrorString(INV_Debtor)) then				//12.11.2025 navlc30 #36357
		self.lblControlCol.enabled := false;
		self.txtControlCol.enabled := false;
		
		int:=0;
		while true do
			sheet := self.shtFieldMapping.getControl (int);
		
			if sheet = null then
				break;
			endif;
		
			self.lblControlColVal.getControl(int).enabled:= false;
			self.txtControlColVal.getControl(int).enabled:= false;
		
			int := int + 1;
		endwhile;
		
	else
		self.lblControlCol.enabled:=true;
		self.txtControlCol.enabled:=true;
		
		int:=0;
		while true do
			sheet := self.shtFieldMapping.getControl (int);
		
			if sheet = null then
				break;
			endif;
		
			self.lblControlColVal.getControl(int).enabled:= true;
			self.txtControlColVal.getControl(int).enabled:= true;
		
			int := int + 1;
		endwhile;
				
	endif;
	
	
	if self.chkActive.value=true then	
		self.lblSearch.enabled:=true;
		self.txtNumSearch.enabled:=true;
		self.lblLines3.enabled:=true;
		self.lblKeywords.enabled:=true;
		self.txtSearchWords.enabled:=true;
	else
		self.lblSearch.enabled:=false;
		self.txtNumSearch.enabled:=false;
		self.lblLines3.enabled:=false;
		self.lblKeywords.enabled:=false;
		self.txtSearchWords.enabled:=false;
	endif;
	
	if self.chkXlations.value=true then	
		self.lblXlatOperator.enabled:=true;
		self.cmbXlationOp.enabled:=true;
	else
		self.lblXlatOperator.enabled:=false;
		self.cmbXlationOp.enabled:=false;
	endif;
		
	if not (self.txtLoadLines.text="0") then
		self.lblFileName.enabled:=true;
		self.txtFileName.enabled:=true;
		self.btnBrowse.enabled:=true;
		self.lblCharPos.enabled:=true;
		self.btnLoad.enabled:=true;
		self.tblSampleData.enabled:=true;
	else
		self.lblFileName.enabled:=false;
		self.txtFileName.enabled:=false;
		self.btnBrowse.enabled:=false;
		self.lblCharPos.enabled:=false;
		self.btnLoad.enabled:=false;
		self.tblSampleData.enabled:=false;
	endif;	
	
	self.btnCancelBase.enabled:=true;
	//CCMS1380 End

	self.setLineHookCtrls();

	self.txtName.setFocus();	
end;</source>
        <Parameter name="_new" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setControlsForFormatType" id="fa6d7f64-a49a-4001-8f45-7c22b738ac0f">
        <source>setControlsForFormatType(_format :Integer) protected;
// ---------------------------------------------------------------------------
// Created:     24 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/11/2015   cnwma1		PAR #36842 Unable to define control column value when defining a User-Defined EDI Format
// ---------------------------------------------------------------------------
vars
	table 	:CM_DataTable;
	index	:Integer;
	col : Integer;
begin	
	if _format = CM_EDIFileType.FORMAT_DELIMITED then
		self.txtDelim.visible 		:= true;
		self.lblFieldDelim.visible 	:= true;
	elseif _format = CM_EDIFileType.FORMAT_FIXEDLENGTH then
		self.txtDelim.visible 		:= false;
		self.lblFieldDelim.visible 	:= false;
	elseif _format = CM_EDIFileType.FORMAT_XML then		//cnwrs1 ccms 2044 21 Apr 2011
		self.txtDelim.visible 		:= false;
		self.lblFieldDelim.visible 	:= false;
	endif;
	if _format = CM_EDIFileType.FORMAT_XML then	//cnwrs1 ccms 2044 28 Apr 2011
		self.txtIgnore.enabled := false;
		self.txtControlCol.enabled := false;
		self.txtControlCol.text:= "0";    			//20/11/2015 cnwma1 PAR #36842
		self.txtLoadLines.enabled := false;
		self.lblIgnoreFirst.enabled := false;
		self.lblLines.enabled := false;
		self.lblControlCol.enabled := false;
		self.lblLoadLines.enabled := false;
		self.lblLines2.enabled := false;
		self.lblCharPos.visible := false;
		col := self.tblFieldMap.getColumnByRowName(ETRow_FieldDescription);
		self.tblFieldMap.setCellText(1, col, app.getErrorString(TagName));
		self.txtControlColVal.enabled := true;	//23 Aug 2018	NDL	TFS 40316
		self.lblControlColVal.enabled := true;	//23 Aug 2018	NDL	TFS 40316
	else	
		self.txtIgnore.enabled := true;
		self.txtControlCol.enabled := true;
		self.txtLoadLines.enabled := true;
		self.lblIgnoreFirst.enabled := true;
		self.lblLines.enabled := true;
		self.lblControlCol.enabled := true;
		self.lblLoadLines.enabled := true;
		self.lblLines2.enabled := true;
		self.lblCharPos.visible := true;
		col := self.tblFieldMap.getColumnByRowName(ETRow_FieldDescription);
		self.tblFieldMap.setCellText(1, col, self.tblFieldMap.getHeadingByName(ETRow_FieldDescription));
	endif;
	
	while true do
		table	:= self.tblFieldMap.getControl (index);
		
		if table = null then
			break;
		endif;
		
		self.setTableColumnsForFormatType (_format, table);
		
		index := index + 1;
	endwhile;	
	
end;</source>
        <access>protected</access>
        <Parameter name="_format" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setControlsForView" id="1e9c2b0c-e3f2-45a9-a21c-01f2b790ec97">
        <updating/>
        <source>setControlsForView() updating;
/*
----------   ----------  --------------------------------------------------
Created:	20 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
23/09/2009	cnwcs5		par 20320 - toggle name/file definition controls
30/05/2013	cnwcs5		par 31618
08/04/2014	cmwah9		CCMS1380
*/
vars
	storeFileDef	: CM_EDIFileTypeUser;
	int				:Integer;
	sheet			:CMUI_Sheet;
begin
	self.mode 					:= self.MODE_VIEW;
	self.btnNew.enabled 		:= true;
	self.btnEdit.enabled 		:= true;
	self.btnSaveBase.enabled 	:= false;
	self.btnSettings.enabled 	:= false;
	self.btnDelete.enabled 		:= true;
	self.btnExportDef.enabled 	:= true;
	self.btnImportDef.enabled 	:= true;
	
	self.showSettings();
	
	self.lblFileDef.visible			:= true;	// cnwcs5 23/09/2009
	self.cmbFileDef.visible 		:= true;	// cnwcs5 23/09/2009
	self.lblName.visible			:= false;	// cnwcs5 23/09/2009
	self.txtName.visible			:= false;	// cnwcs5 23/09/2009
	self.lblDataType.enabled		:= false;	// cnwcs5 23/09/2009
	self.cmbEDIDataType.enabled		:= false;	// cnwcs5 23/09/2009
	self.grpFileDetails.enabled 	:= false;
	self.grpAutoEmail.enabled 		:= false;
	self.grpSampleData.enabled 		:= false;
	self.grpXlate.enabled			:= false;	// cnwcs5 23/09/2009
	self.txtControlColVal.enabled	:= false;	// cnwcs5 23/09/2009	
	self.txtNumFields.enabled		:= false;	// cnwcs5 23/09/2009	
	self.tblFieldMap.userInputEnabled 		:= false;
	self.tblUserFieldCode.userInputEnabled 	:= false;
	storeFileDef := self.cmbFileDef.listObject.CM_EDIFileTypeUser;
	self.loadCmbFileTypes();
	
	if storeFileDef &lt;&gt; null then
		self.cmbFileDef.listIndex := self.cmbFileDef.findObject(storeFileDef);
	endif;

	// par 20320 - start	
	while true do
		sheet := self.shtFieldMapping.getControl (int);
		
		if sheet = null then
			break;
		endif;
		
		self.tblFieldMap.getControl(int).userInputEnabled 		:= false;
		self.tblUserFieldCode.getControl(int).userInputEnabled 	:= false;
		self.txtControlColVal.getControl(int).enabled			:= false;	// cnwcs5 23/09/2009
		self.lblControlColVal.getControl(int).enabled			:= false;   // 08/04/2014	cmwah9	CCMS1380 
		self.txtNumFields.getControl(int).enabled				:= false;	// cnwcs5 23/09/2009	
				self.setTblUserCodeView(true, int);
		
		self.tblFieldMap.getControl(int).allowDrag := Table.AllowDrag_None;

	
		int := int + 1;
	endwhile;
	
	self.btnCancelBase.enabled:=false;
// par 20320 - end	
	self.setLineHookCtrls();
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnEdit.enabled := false;
		self.btnNew.enabled := false;
		self.btnDelete.enabled := false;
		self.btnImportDef.enabled := false;
	endif;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="setInputTypesForFieldMapping" id="d5840d04-14a5-497d-a603-93d12649b9b4">
        <source>setInputTypesForFieldMapping( _table : CM_DataTable input; _row :Integer) protected;
// ---------------------------------------------------------------------------
// Created:     22 September 2009 by cnwcs5:1
// Purpose:     par 20320 - multiple user defined record types  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	col	:Integer;
begin
	col := _table.getColumnByRowName (ETRow_FieldNo);
	_table.accessCell(_row, col).inputType 	:= Table.InputType_TextNumeric;
	
	col := _table.getColumnByRowName (ETRow_FieldType);
	_table.accessCell(_row, col).inputType 	:= Table.InputType_TextBox;
	_table.accessedCell.cellControl 		:= self.cmbFieldType.getControl (_table.index);	
	
	col := _table.getColumnByRowName (ETRow_PropName);
	_table.accessCell(_row, col).inputType 	:= Table.InputType_None;
	
	col := _table.getColumnByRowName (ETRow_FieldDescription);
	_table.accessCell(_row, col).inputType 	:= Table.InputType_TextBox;
	
	col := _table.getColumnByRowName (ETRow_FieldStripChars);			// 06/11/2009 cnwar2 #21554
	_table.accessCell(_row, col).inputType 	:= Table.InputType_TextBox;
	
	col := _table.getColumnByRowName (ETRow_Length);
	_table.accessCell(_row, col).inputType 	:= Table.InputType_TextNumeric;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setLineHookCtrls" id="f78197fe-f259-4fc1-b86c-0a37d81450c9">
        <source>setLineHookCtrls();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 September 2008	cnwrd1	Initial creation

*/
vars
	add 		: Boolean;
	
begin
//par 18402, switch controlls purely on myFileLineHookCode 
//	fileType := self.cmbFileDef.listObject.CM_EDIFileTypeUser;
	add := true;

	if self.myFileLineHookCode &lt;&gt; null then
		add := false;
	endif;
		
	self.btnLineHookAdd.visible 	:= add;
	self.btnLineHookDel.visible 	:= not self.btnLineHookAdd.visible;
	self.btnLineHookView.visible 	:= not self.btnLineHookAdd.visible;

	if self.mode = MODE_VIEW then
		self.btnLineHookAdd.enabled 	:= false;
		self.btnLineHookDel.enabled 	:=  false;
		self.btnLineHookView.enabled 	:=  true;
		self.btnLineHookView.caption 	:=  'View';
	else
		self.btnLineHookAdd.enabled 	:= true;
		self.btnLineHookDel.enabled 	:=  true;
		self.btnLineHookView.enabled 	:=  true;
		self.btnLineHookView.caption 	:=  'Edit';
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setSheetCaption" id="0acf66ab-c4e2-423e-b54f-2bf14cadacc1">
        <source>setSheetCaption(_sheet :CMUI_Sheet input; _value :String) protected;
// ---------------------------------------------------------------------------
// Created:     23 September 2009 by cnwcs5:1
// Purpose:     Par 20320 - multiple user record types  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	int	:Integer;
begin
	int := _sheet.index;
	
	if _value &lt;&gt; null then
		_sheet.caption := _value;
	else
		shtFieldMapping.translateCaption(Xlat_0009865, app.myCurrentLocale);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_sheet" type="CMUI_Sheet" usage="input"/>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setTableColumnsForFormatType" id="f0423b0f-4409-4bb7-a3ef-84ed170e8e17">
        <source>setTableColumnsForFormatType(_format :Integer; _table :CM_DataTable input) protected;
// ---------------------------------------------------------------------------
// Created:     24 September 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
	endif;
	//th2 temp hide this column
	_table.hideColumnByColName(ETRow_UsePrevValIfNull);
	self.lblControlColVal.translateCaption(Xlat_0013436, locale);
	
	if _format = CM_EDIFileType.FORMAT_DELIMITED then
		_table.hideColumnByColName(ETRow_Length);
		_table.hideColumnByColName(ETRow_PropName);			
	elseif _format = CM_EDIFileType.FORMAT_FIXEDLENGTH then
		_table.showColumnByColName(ETRow_Length);
		_table.hideColumnByColName(ETRow_PropName);
	elseif _format = CM_EDIFileType.FORMAT_XML then	//cnwrs1 ccms 2044 21 Apr 2011
		_table.hideColumnByColName(ETRow_Length);
		_table.hideColumnByColName(ETRow_PropName);
		self.lblControlColVal.caption := "Control Tag Name:";
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_format" type="Integer"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTblUserCodeView" id="62f53d8f-08c3-4dee-b130-6472731889c2">
        <source>setTblUserCodeView( _view : Boolean; _index :Integer);
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
08 September 2008	cnwrd1	Initial creation

*/

vars
	table			: CM_DataTable;
	row,numRows		: Integer;
	fieldHookCode 	: CM_EDIFieldHookCode;
	displayVal		: String;
begin
	table	:= self.tblUserFieldCode.getControl (_index);
	numRows := table.rows;
	
	foreach row in table.fixedRows + 1 to numRows do
		displayVal 		:= null;
		fieldHookCode 	:= table.accessRow(row).itemObject.CM_EDIFieldHookCode;		
		
		if _view then
			if fieldHookCode &lt;&gt;  null then
				displayVal := app.getErrorString (XLAT_DBLCLICK_VIEW);	// PAR 21300
			endif;
		else
			if fieldHookCode &lt;&gt;  null then
				displayVal := app.getErrorString (XLAT_DBLCLICK_EDIT);	// PAR 21300
			else
				displayVal := app.getErrorString (XLAT_DBLCLICK_CREATE);	// PAR 21300;
			endif;
		endif;
		
		table.accessCell(row, 4).text := displayVal; 
	endforeach;
	
epilog

end;</source>
        <Parameter name="_view" type="Boolean"/>
        <Parameter name="_index" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setValuesForFieldMapping" id="1f46fb77-3f4e-44eb-8cf5-125e541318d6">
        <source>setValuesForFieldMapping(_fieldMapping :CM_EDIFieldMapping; _table :CM_DataTable input; _row :Integer)protected;
// ---------------------------------------------------------------------------
// Created:     22 September 2009 by cnwcs5:1
// Purpose:     par 20320 
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17/05/2010	cnwcs5		par 23326 - if propName is not valid then
// ---------------------------------------------------------------------------
vars
	strFieldDesc, strPropName 	:String;								// par 23326
	combo						:ComboBox;								// par 23326
	index						:Integer;								// par 23326
	entRow						:EntTableRow;							// par 23326
	translatedIndex : Integer;	//02 Feb 2018	NDL	TFS 36809
	translatedEntRow : EntTableRow;	//02 Feb 2018	NDL	TFS 36809
begin
	// display mapping details in table
	_table.accessRow(_row).itemObject := _fieldMapping;

	if 	_fieldMapping &lt;&gt; null then
		strFieldDesc 	:= _fieldMapping.fieldDescr;					// par 23326
		strPropName		:= _fieldMapping.propName;						// par 23326
		combo			:= self.cmbFieldType.getControl (_table.index);	// par 23326
			
		if combo.listCount &gt; 0  then									// par 23326
			index := combo.findStringExact (1, strFieldDesc);			// par 23326
			
			//02 Feb 2018	NDL	TFS 36809 - Handle where fileds may have been translated.
			if index &lt; 1 then
				//We may not have found it because it had previously been translated, so try again
				//using the property name i.e. the name on the entRow
				foreach translatedIndex in 1 to combo.listCount do
					translatedEntRow := combo.itemObject[translatedIndex].EntTableRow;
					if translatedEntRow &lt;&gt; null and translatedEntRow.name = strPropName then
						index := translatedIndex;  // the index of the row we want
						strFieldDesc := combo.itemText[translatedIndex]; // the text on that row that we should use from now on.
						break;
					endif;
				endforeach;	
			endif; 
		
			if index &gt; 0 then
				entRow := combo.itemObject[index].EntTableRow;			// par 23326
			endif;
		endif;
		
		if entRow &lt;&gt; null and
			entRow.name = strPropName then								// par 23326
			// field type is valid and has matching property name		// par 23326			
			_table.setCellValueByName (ETRow_FieldType, _row, strFieldDesc);
			_table.setCellValueByName (ETRow_PropName, _row, strPropName);
		else
			if entRow = null or 										// par 23326
				entRow.name &lt;&gt; strPropName then							// par 23326
				// the field type must have been removed or property name changed
				// this is an old file type definition Set the field type and property name to Ignore
				entRow 	:=	app.myController.getEntTableGroup(ETGrp_EdiMaint).allEntTableRowsByName[ETRow_Ignore];	// par 23326
				
				_table.setCellValueByName (ETRow_FieldType, _row, entRow.getHeading(null, self.myTerminal, null));	// par 23326
				_table.setCellValueByName (ETRow_PropName, _row, ETRow_Ignore);										// par 23326
			endif;														// par 23326
		endif;															// par 23326
	
		_table.setCellValueByName (ETRow_FieldDescription, _row, _fieldMapping.userDesc);
		_table.setCellValueByName (ETRow_FieldStripChars, _row, _fieldMapping.getStripCharsAsString());
		_table.setCellValueByName (ETRow_Length, _row, _fieldMapping.length.String);
	endif;
	
	_table.setCellValueByName (ETRow_FieldNo, _row, (_row - _table.fixedRows).String);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_fieldMapping" type="CM_EDIFieldMapping"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="8163eced-c2de-4857-9402-726cf1dd82c9">
        <updating/>
        <source>setupForm() updating;
/*
----------   ----------  --------------------------------------------------
Created:	20 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
23/09/2009	cnwcs5		par 20320 - multiple file types
*/
vars
	
begin	

	self.addToolbarControls();
	self.initTblFieldMap(self.tblFieldMap);
	self.initTblFieldUserCode(self.tblUserFieldCode);
	self.loadCmbFileTypes();
	self.loadEDITDataType;	//cnwcs5 23/09/2009	self.loadFieldMappingTypes();
	self.loadFormatTypes();
	self.initTblSampleData();
	self.loadDateFormats();
	self.loadDateDelimeter();
	self.myAssistant.comboBoxEDITypeCategories(self.cmbEDIDataType, true, null);


	inheritMethod();
	
	self.cmbFieldType.automaticCellControl := true;
	self.cmbFieldType.filterIgnore := true; // ### TFS 55105 28DEC2022 NAVAB1
	self.cmbFieldType.style := ComboBox.Style_DropDownList; // ### TFS 55105 28DEC2022 NAVAB1
	self.setControlsForView();
	

	// move the name label.textbox to the same place as the file definition label/textbox
	lblName.left	:= lblFileDef.left;	// cnwcs5 23/09/2009
	txtName.left	:= cmbFileDef.left;	// cnwcs5 23/09/2009
	
	self.doMnuShowCaptions(null);		// cnwmh5 #21651
	
	//08/04/2014	cnwah9		CCMS 1380	START 
	self.cmbFileDef.setIndex(1);
	self.loadFileTypeDetails();
	//CCMS 1380	END
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showHookCodeMaintForm" id="d415f366-4020-4fa9-b0a2-06d11e8d9198">
        <source>showHookCodeMaintForm(_mode : Boolean; _table :CM_DataTable input);
/*
Purpose:			
Parameters:			
Return Value:		

Date				Who		Reason
05 September 2008	cnwrd1	Initial creation
12/10/2009			cnwcs5	par 21300 - exception editing hook code from cloned sheet
							Change all code that used tblUserFieldCode to use _table instead
09/03/2018			jlgmd1	TFS #37520 JMT - EDI User Defined File Type Import Bugs
*/
vars
	ediHookCode			: CM_HookCode;
	ediFieldHookCode 	: CM_EDIFieldHookCode;
	tmpHookType 		: CM_HookType;
	jadeCode 			: String;
	code, userDesc 		: String ;
begin
	ediFieldHookCode 	:= _table.accessRow(_table.row).itemObject.CM_EDIFieldHookCode;	// par 21300
	ediHookCode 		:= ediFieldHookCode.myHookCode;
	
	if ediHookCode = null and _mode then
		return;
	endif;
	
	tmpHookType := app.myRoot.allHookTypes[HookType_EDIFileFieldHook];
	userDesc 	:= _table.accessCell(tblUserFieldCode.row, 3).text[1:30].trimBlanks();	// par 21300
	
	// If there is no user description entered, then just use the field name (like the import already does)
	if userDesc = null then
		userDesc := _table.accessCell(tblUserFieldCode.row, 1).text;	// This is truncated to 10 later		//TFS 37520
	endif;
	
	if ediHookCode = null and  not _mode then
		create ediHookCode transient;
		//ediHookCode := self.createEDIFieldHookCode();
		_table.accessRow(_table.row).itemObject := ediHookCode; 					// par 21300
		code := _table.accessCell(tblUserFieldCode.row, 2).text[1:30].trimBlanks(); // par 21300
	else
		jadeCode 	:= ediHookCode.getCurrentJadeCode();
		code 		:= ediHookCode.code;
	endif;

	if app.showHookCodeMaintForm(tmpHookType, jadeCode, _mode) and not _mode then 	//editmode
	
		ediHookCode.setForProxy (code,tmpHookType);	
		ediHookCode.setJadeCodeForProxy (jadeCode, userDesc);
	
		//validate at time of edit... // cnwrd1 30.10.08 par #18402
		ediHookCode.allHookCodeHistory.first.validate();
	endif;
	
	self.setTblUserCodeView( _mode, _table.index); // par 21300
epilog

end;</source>
        <Parameter name="_mode" type="Boolean"/>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showSettings" id="7f61b3fc-5b9a-469d-8dfd-de7015263db4">
        <source>showSettings();

vars
	blnSettings : Boolean;
begin
	if canHaveSettings then 
		btnSettings.visible := true;
	else
		btnSettings.visible := false;
	endif;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="tblFieldMap_contextMenu" id="115115dc-610d-42b4-96ab-6786282d8a79">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblFieldMap_contextMenu(_table: Table input; _conwin: Window input; _mouse: Boolean; _x, _y: Integer):Boolean updating;
/*
Date		Who		Reason
28 May 2013	cnwcs5	Initial Creation - par 31618
*/
vars
	row	:Integer;
begin
	if self.cmbEDIDataType.listIndex &lt; 1 then
		// nothing selected
		return false;
	endif;
	
	if mode = MODE_VIEW then
		// not editing
		return false;
	endif;
	
	row := _table.row;
	
	if not _table.accessRow (row).selected then
		// need to click on fixed column to select row
		return false;
	endif;
	
	if row &gt; _table.fixedRows then
		self.mnuDeleteMapping.enabled		:= true;
		self.mnuDeleteMapping.userObject 	:= _table;	
	else
		self.mnuDeleteMapping.enabled 		:= false;
		self.mnuDeleteMapping.userObject 	:= null;	
	endif;
	
	self.mnuInsertMapping.userObject 	:= _table;	
	
	return self.showContextMenu(self.mnuContextMapping, _table, _conwin, _mouse, _x, _y);
epilog
	
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_conwin" type="Window" usage="input"/>
        <Parameter name="_mouse" type="Boolean"/>
        <Parameter name="_x" type="Integer"/>
