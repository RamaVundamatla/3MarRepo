    <JadeMethod name="tReleaseThruTheFence" id="d8ad1ae5-f09c-44f3-ab1c-2f4189507ea3">
        <source>tReleaseThruTheFence();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 July 2017	jlgndl1	Initial creation	TFS 5327
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

constants

	ReleaseCode : String = "UTFENCE";
	TiId1 : String = "UTFENCECAR1";
	TiId2 : String = "UTFENCECAR2";
	RelArea : String = "UTCARREL";

vars

	br : CM_BulkRelease;
	oper : CM_Operator;
	cargoType : CM_CargoType;
	dra : CM_BlockStack;
	ti1 : CM_TrackedItem;
	ti2 : CM_TrackedItem;
	reserveDetail : CM_ReserveDetail;
	tiSet : CM_TISet;
	consignee : CM_ConsigneeConsignor;
	delNum : String;
	delReason : CM_DeliveryReleaseReason;
	remaining : Integer;

begin

	oper := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	self.assertTrueMsg( oper &lt;&gt; null , " Operator not found pre-test");
	cargoType := app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("UT_CAR01");
	self.assertTrueMsg( cargoType &lt;&gt; null , "Cargo Type UT_CAR01 not found pre-test");
	consignee := app.myRoot.allConsigneeConsignors.getAtKey("UTCE1");
	self.assertTrueMsg( consignee &lt;&gt; null , "Consignee UTCE1 not found pre-test");
	delReason := app.myRoot.allDeliveryReasonselReasons.first;
	self.assertTrueMsg( delReason &lt;&gt; null , "Delivery Reason not found pre-test");
	
	self.deleteCargo( TiId1, cargoType );
	self.deleteCargo( TiId2, cargoType );
	
	self.deleteTerminalArea( RelArea );
	dra := self.addReleaseTransArea( RelArea, 100, null );
	self.assertTrueMsg( dra &lt;&gt; null , " Direct Release Area not created pre-test");
	
	ti1 := self.addCargoAtLocation(TiId1, cargoType, oper, dra.allLocationsControllers.first);
	self.assertTrueMsg( ti1 &lt;&gt; null , " Cargo '" &amp; TiId1 &amp; "' not created pre-test");
	ti2 := self.addCargoAtLocation(TiId2, cargoType, oper, dra.allLocationsControllers.first);
	self.assertTrueMsg( ti2 &lt;&gt; null , " Cargo '" &amp; TiId2 &amp; "' not created pre-test");
	
	self.deleteReleaseRequest(ReleaseCode);
	self.opts.purge();
	self.opts.addAssoc("Number", 2.Integer );
	self.opts.addAssoc("Operator", oper );
	br := self.addReleaseByTypeRequestOpts(ReleaseCode, BR_TYPE_ROAD, cargoType.id);
	self.assertTrueMsg( br &lt;&gt; null , " Bulk Release not created pre-test");
	self.assertTrueMsg( br.status = BR_ACTIVE , " Bulk Release not active pre-test");
	
	reserveDetail := br.allReserveDetails.first;
	self.assertTrueMsg(reserveDetail &lt;&gt; null , " Reserve detail not created pre-test");
	
	app.myTrxUA.trxAddToReserveDetail( reserveDetail, ti1, app.myPassport );
	//self.assertTrueMsg( reserveDetail.allTrackedItems.includes( ti1 ), " Reserve detail doesn't include " &amp; ti1.id &amp; " pre-test");
	self.assertTrueMsg( reserveDetail.includeTrackedItem( ti1 , false), " Reserve detail doesn't include " &amp; ti1.id &amp; " pre-test");//23/06/2023	navkc1	CR 58406 Task 58408
	app.myTrxUA.trxAddToReserveDetail( reserveDetail, ti2, app.myPassport );
	//self.assertTrueMsg( reserveDetail.allTrackedItems.includes( ti2 ), " Reserve detail doesn't include " &amp; ti2.id &amp; " pre-test");
	self.assertTrueMsg( reserveDetail.includeTrackedItem( ti2 , false), " Reserve detail doesn't include " &amp; ti2.id &amp; " pre-test");
	
	remaining := reserveDetail.getQuantityRemaining;
	self.assertTrueMsg( remaining = 2, " Reserve detail remaining doesn't = 2 pre test");
	
	//AAT - Release thru a hole in teh fence...
	create tiSet transient;
	tiSet.add( ti1 );
	delNum := "UnitTest";
	app.myTrxDA.trxReleaseFromTransArea(tiSet, 0, consignee.code, delNum, delReason.id, app.myPassport);
	self.assertTrueMsg( app.myPassport.allErrors.isEmpty, "Gate Out failed - " &amp; app.myPassport.getAllErrorsWarningsAsString);
	
	
	remaining := reserveDetail.getQuantityRemaining;
	self.assertTrueMsg( remaining = 1, " Reserve detail remaining doesn't = 1 post gate out");
	self.assertTrueMsg( ti1.getTransRelease &lt;&gt; null, " No Release transacyion for " &amp; ti1.id &amp; " post gate out");
	
	self.deleteCargo( TiId1, cargoType );
	self.deleteCargo( TiId2, cargoType );
	self.deleteTerminalArea( RelArea );
	self.deleteReleaseRequest(ReleaseCode);

epilog

	delete tiSet;

end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseWithAssignedCargo" id="06d07efb-9694-45be-8106-a0ffbfa0aaf9">
        <source>tReleaseWithAssignedCargo();
// cnwndl1
//04 November 2009	cnwdw1
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
//
vars
	releaseRequest : CM_BulkRelease;
	ti, ti1 : CM_TrackedItem;
	bs : CM_BlockStack;
begin
	
	self.deleteReleaseRequest("UTRRRoad");
	self.deleteContainer("UUT00000001");
	self.deleteContainer("UUT00000002");
	self.deleteTerminalArea("UTBS1");
	
	bs := self.addBlockStack("UTBS1", 100, null);
	
	releaseRequest := addReleaseByTypeRequest("UTRRRoad", BR_TYPE_ROAD, TI_CargoType_Container, "2200");
	assertEqual(releaseRequest.status, BR_ACTIVE);
	
	ti := self.addContainer("UUT00000001", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti, bs);
	
	self.releaseAssignCargo(releaseRequest,null, ti);
	assertEqual(releaseRequest.allTrackedItemsAssigned.size, 1);
	assertEqual(releaseRequest.allReserveDetails.size, 1);
	//assertEqual(releaseRequest.allReserveDetails.first.CM_ReserveSelection.allTrackedItems.size, 1);
	assertEqual(releaseRequest.allReserveDetails.first.CM_ReserveSelection.getAllTrackedItemsSize(false), 1); //23/06/2023	navkc1	CR 58406 Task 58408
		
	ti1 := self.addContainer("UUT00000002", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200","MT",TI_IMEX_STATUS_STORAGE);
	self.move(ti1, bs);
	self.releaseAssignCargo(releaseRequest,null, ti1);
	assertEqual(releaseRequest.allTrackedItemsAssigned.size, 2);
	assertEqual(releaseRequest.allReserveDetails.size, 1);
	//assertEqual(releaseRequest.allReserveDetails.first.CM_ReserveSelection.allTrackedItems.size, 2);
	assertEqual(releaseRequest.allReserveDetails.first.CM_ReserveSelection.getAllTrackedItemsSize(false), 2); //23/06/2023	navkc1	CR 58406 Task 58408
	assertEqual(releaseRequest.status, BR_ACTIVE);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tSTW12PackRelRulesTest" id="a0229924-bd11-48a6-b3b2-aaf1155965d9">
        <source>tSTW12PackRelRulesTest();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2017	cnwndl1	Initial creation	TFS 4016
08 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
*/

constants

	ReleaseCode : String = "UT12PACK";
	BaseTiId : String = "UTRL12PACK";
	BlockStack : String = "PK_BS";
	ICArea : String = "PK_IC";
	
vars

	br : CM_BulkRelease;
	oper : CM_Operator;
	agent : CMIF_MobileGenericAgent;
	selectedResDetail : CM_ReserveDetail;
	autoSelectedStageArea : CM_LocationsController;
	targetLocation : CM_LocationsController;
	stwRuleNum : Integer;
	tiArray : CM_TIArray;
	bs : CM_BlockStack;
	index : Integer;
	ti : CM_TrackedItem;
	ic1 : CM_YardInterchangeArea;
	ic2 : CM_YardInterchangeArea;
	childCargoType1 : CM_CargoType;
	childCargoType2 : CM_CargoType;
	reserveDetail1 : CM_ReserveDetail;
	cont : CM_TrackedItem;
	packTIs : CM_TIArray ;
	term : CM_Terminal;
	
begin
	
	create agent transient;
	agent.setDoNotShowMsgBox(true);
	
	// ### Make sure the agent has the same terminal as  this unit test
	term := self.getTerminal();
	if agent.myTerminal &lt;&gt; term then
		agent.setMyTerminal(term);
	endif;

	create tiArray transient;
	oper := app.myRoot.allOperators.getAtKey("260");
	self.assertTrueMsg( oper &lt;&gt; null , " Operator not found pre-test");
	
	childCargoType1 := app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("UTREBAR");
	self.assertTrueMsg( childCargoType1 &lt;&gt; null , " UTREBAR not found pre-test");
	childCargoType2 := app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation("UT_WIDGET");
	self.assertTrueMsg( childCargoType2 &lt;&gt; null , " UT_WIDGET not found pre-test");

	self.setTerminalConfig(UseAltSelectRulesTL, true);
	
	self.assertTrueMsg(self.getMyTerminal().getConfig(UseAltSelectRulesTL).Boolean = true, "UseAltSelectRulesTL Should be TRUE");
	
	foreach index in 1 to 9 do
		self.deleteCargo( BaseTiId &amp; index.String,  childCargoType1 );
		self.deleteCargo( BaseTiId &amp; index.String,  childCargoType2 );
	endforeach;
	self.deleteContainer( BaseTiId &amp; "A" );
	
	self.deleteTerminalArea(BlockStack);
	bs := self.addBlockStack(BlockStack, 100, null);
	self.assertTrueMsg( bs &lt;&gt; null , " Block Stack not found pre-test");
	
	self.deleteTerminalArea(ICArea &amp; "1");
	self.deleteTerminalArea(ICArea &amp; "2");
	ic1 := self.addInterchangeArea(ICArea &amp; "1",null);
	ic2 := self.addInterchangeArea(ICArea &amp; "2",null);
	self.assertTrueMsg( ic1 &lt;&gt; null , " Inter change 1 not found pre-test");
	self.assertTrueMsg( ic2 &lt;&gt; null , " Inter change 2 not found pre-test");
	
	self.deleteReleaseRequest(ReleaseCode);
	
	self.opts.purge();
	self.opts.addAssoc("ISOType", "2200");
	self.opts.addAssoc("Number", 1.Integer );
	self.opts.addAssoc("Operator", oper );
	br := self.addReleaseByTypeRequestOpts(ReleaseCode, BR_TYPE_PACKING, TI_CargoType_Container);
	self.assertTrueMsg( br &lt;&gt; null , " Bulk Release not created pre-test");
	self.assertTrueMsg( br.status = BR_ACTIVE , " Bulk Release not active pre-test");

	self.assertTrueMsg(self.getMyTerminal().getConfig(UseAltSelectRulesTL).Boolean = true, "UseAltSelectRulesTL Should be TRUE");
	
	self.opts.purge;
	self.opts.addAssoc("Operator", oper);
	self.opts.addAssoc("Number", 3.Integer );
	self.addReserveSelectionOpts( br, CM_ReserveDetail.PackType_Child, childCargoType1.id);
	self.assertTrueMsg( br.allReservePackingChildren.size = 1, ReleaseCode &amp; " Bulk Releaser 1st child reserve details not created - setup phase - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	reserveDetail1 := br.allReservePackingChildren.first;
	self.assertTrueMsg( reserveDetail1 &lt;&gt; null , " Child Reserve Detail not created pre-test");
		
	
	//add 9 Rebar tracked items
	foreach index in 1 to 9 do
		ti := self.addCargoAtLocation(BaseTiId &amp; index.String, childCargoType1, oper, bs.allLocationsControllers.first);
		self.assertTrueMsg( ti &lt;&gt; null , " Cargo '" &amp; BaseTiId &amp; index.String &amp; "' not created pre-test");
	endforeach;
	
	self.assertTrueMsg(self.getMyTerminal().getConfig(UseAltSelectRulesTL).Boolean = true, "UseAltSelectRulesTL Should be TRUE");

	//Nothing assigned or staged - a single reserveDetail Should use rule 4.	
	agent.getCargoStagingDispRuleSTW( 	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
										autoSelectedStageArea,	//autoSelectedStageArea : CM_LocationsController output;
										stwRuleNum	//_stwRuleNum : Integer output
										);
	self.assertTrueMsg( stwRuleNum = 4, " Agent method 'getCargoStagingDispRuleSTW' &amp; should have returned Rule = 4.");
	self.assertTrueMsg( autoSelectedStageArea = null, " Agent method 'getCargoStagingDispRuleSTW' should NOT have selected an area for Rule 4.");
	self.assertTrueMsg(self.getMyTerminal().getConfig(UseAltSelectRulesTL).Boolean, "UseAltSelectRulesTL Should be TRUE");
	
	agent.getCargoBasedOnSTW12Rules(	br,	//_bulkRelease : CM_BulkRelease;
										selectedResDetail,	//_selectedResDetail : CM_ReserveDetail;
