    <JadeMethod name="timerEvent" id="ac65e160-904c-4970-ad8e-b74ab248346d">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
//----------------------------------------------------------------
//	Created:	29 September 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------
// 08/11/2010	cnwdap1		PAR #23794 CCMS MES 1102 WLE updates
vars

begin
	app.mousePointer	:=	Busy;
	if eventTag = 1 then
//		app.myPassport.myActivityCapture.startCaptureDebugMisc(method.name);
		beginLoad;
		self.doCentralisedTINoteUpdate();
		if self.myTerminal.getConfig(ShowRelReqOnRailLoadList).Boolean then//07 Dec 2011	NDL	Par 28797
			self.doCentralisedWLENoteUpdate();		// PAR #23794
			self.doCentralisedBulkRelNoteUpdate();	// PAR #23794
			self.doCentralisedRailJobNoteUpdate();	// PAR #23794
		endif;
		endLoad;
//		app.myPassport.myActivityCapture.stopCaptureDebugMisc();
		self.startedTimer := false;	//11 June 2013	NDL	Par 31692 - only reset it once in case we get another sysNotify  between methods above.
	endif;
	
epilog
	endLoad; // PAR 15648, just in case of a CRASH!!!!
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="ce984bcc-7e61-4795-9c5e-eab028c0d0c3">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0012300, locale);
	btnAssignApply.translateCaption(Xlat_0012301, locale);
	btnAssignCancel.translateCaption(Xlat_0012302, locale);
	btnCancelPref.translateCaption(Xlat_0012303, locale);
