    <JadeMethod name="doResize" id="450f7929-2bd9-4ba5-89cc-99109e008666">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17/04/2009	cnwrl1		PAR 19479 - Make sure the View/Comparison combos stay visible.
// ---------------------------------------------------------------------------
vars

	comboContainer : Window;
	rh : Real;
	
begin
	
	/* TFS 50421 moved this to the painter definition with minimum width and height. Also the toolbar frame for the view combo was really really wide, made this smaller so that it does not disappear when the width is smaller.
	// cnwrl1 17/04/2009 PAR 19479 - start of coding, needs to be before the inheritMethod.
	// Make sure the View/Comparison combos stay visible, especially when captions are being shown.
	self.minimumHeight	:= 250; //was 150 cnwrs1 ccms 1137 July 2010
	if self.frmToolbar.showCaptions then
		self.minimumWidth			:= 1020;
		self.frmLoadListView.width	:= 320;
		self.cmbView.width			:= 100;
		//self.cmbComparison.width	:= 80;
		//self.lblComparison.left		:= self.cmbView.left + self.cmbView.width + 5;
		//self.cmbComparison.left		:= self.lblComparison.left + self.lblComparison.width + 5;
	else
		self.minimumWidth			:= 800;
		self.frmLoadListView.width	:= 500;
		self.cmbView.width			:= 185;
		//self.cmbComparison.width	:= 160;
		//self.lblComparison.left		:= self.cmbView.left + self.cmbView.width + 10;
		//self.cmbComparison.left		:= self.lblComparison.left + self.lblComparison.width + 10;
	endif;
	// cnwrl1 17/04/2009 PAR 19479 - end of coding.
	*/
	inheritMethod();
	
	comboContainer := self.cmbVoyage.parent;
	
	self.cmbVoyage.width := comboContainer.width - 100;
	self.cmbLoadList.width := comboContainer.width - 100;
	self.chkAutoUpdateRTS.width := comboContainer.width - 30;
	self.chkCurrentVoys.width := comboContainer.width - 30;	//23 Feb 2021	NDL	TFS 50836
	
	//19 May 2010	NDL	Par 24243
	self.grpXtraOps.left := 2;
	self.grpXtraOps.width := self.shtQuery1.width - 10;
//	self.grpXtraOps.height := 200; //cnwrs1 CCMS 1137 15 June 2010
	self.grpExclude.left := 2;
	self.grpExclude.width := self.grpXtraOps.width - 4;
//	self.grpExclude.height := 80; //cnwrs1 CCMS 1137 15 June 2010
	rh := self.chkAutoUpdateRTS.left + self.chkAutoUpdateRTS.width;
	self.chkInclOtherVoy.left := ( rh - self.grpXtraOps.left ) - self.chkInclOtherVoy.width;
	self.chkExclImport.left := (( rh - self.grpXtraOps.left ) - self.grpExclude.left ) - self.chkExclImport.width;
	self.chkExclEmpty.left := (( rh - self.grpXtraOps.left ) - self.grpExclude.left ) - self.chkExclEmpty.width;
	self.lblInclOtherVoy.left := 2;
	self.lblInclOtherVoy.width := (( self.chkInclOtherVoy.left - self.lblInclOtherVoy.left ) - 3 );
	
	if not self.tblInfo.visible then
		self.tblData.height := self.tblData.height - self.staStatusBar.height;
	endif;
	self.lblSelectIgnore.top := self.frmIgnoreFields.top + 20;	//cnwrs1 CCMS 1137 15 June 2010
	self.lblSelectIgnore.left := self.frmIgnoreFields.left + 10;
	self.mulSelectIgnore.top := self.frmIgnoreFields.top + 40;
	self.mulSelectIgnore.left := self.frmIgnoreFields.left + 10;
	self.mulSelectIgnore.height := self.frmIgnoreFields.height - 60;
	self.mulSelectIgnore.width := self.frmIgnoreFields.width - 30;

	self.lblSelectUpdate.top := self.frmUpdateField.top;	//cnwrs1 CCMS 1137 15 June 2010
	self.lblSelectUpdate.left := self.frmUpdateField.left + 10;
	self.mulSelectUpdate.top := self.frmUpdateField.top + 30;
	self.mulSelectUpdate.left := self.frmUpdateField.left + 10;
	self.mulSelectUpdate.height := self.frmUpdateField.height - 215;//cnwns1 TFS 1766 06/04/2016
	self.mulSelectUpdate.width := self.frmUpdateField.width - 30;

	self.chkTranshipAdd.top := self.mulSelectUpdate.top + self.mulSelectUpdate.height + 10;	//cnwrs1 CCMS 1137 15 June 2010
	self.chkTranshipAdd	.left := self.frmUpdateField.left + 10;
	self.chkTranshipAdd.width := self.frmUpdateField.width - 30;
	self.mulSelTranship.top := self.mulSelectUpdate.top + self.mulSelectUpdate.height + 30;
	self.mulSelTranship.left := self.frmUpdateField.left + 10;
	self.mulSelTranship.height :=  145;//cnwns1 TFS 1766 06/04/2016
	self.mulSelTranship.width := self.frmUpdateField.width - 30;
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doRunComparisonClick" id="164dae28-803f-4e5e-a3a7-45ae685eed29">
        <updating/>
        <source>doRunComparisonClick(_isRefresh : Boolean) updating;
//----------------------------------------------------------------
//	Created:	22 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars
begin
	app.mousePointer := MousePointer_HourGlass;
	
	if self.myCurrentVoyage = null then
		app.raiseCMException1(ERR_INVALID_VOYAGE, "null" , 'voyage', null);
		return;
	endif;
	
	self.frmQuery.visible := false;
	self.doWindowEvents(0);
	
	if self.comparisonMode &lt;&gt; VOYAGE_DETAILS_COMPARISON then
		self.initiateCompare(_isRefresh);
	else
		self.initiateCompareVoyDet(false);
	endif;
	
epilog

	app.mousePointer := MousePointer_Default;
	
end;</source>
        <Parameter name="_isRefresh" type="Boolean"/>
    </JadeMethod>
