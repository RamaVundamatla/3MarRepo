    <JadeMethod name="isEntRowNameVisible" id="1f7f9602-3326-4e6d-906e-b1eec7c2ed73">
        <source>isEntRowNameVisible(_rowName : String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2010	cnwer1	Initial creation

*/

vars
	row : Integer;
begin
	row:=self.findRowWithEntRowName(_rowName);
	
	if row &lt;= 0 then
		return false;
	endif;
	
	return self.myTable.accessRow(row).visible;
epilog

end;</source>
        <Parameter name="_rowName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
