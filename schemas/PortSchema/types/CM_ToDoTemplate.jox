end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="ba7a7d7d-74c7-4ee4-9921-f99df9fb61c6">
        <updating/>
        <source>setForCreate(_proxyToDoTemplate:CM_ToDoTemplate) updating;
// ---------------------------------------------------------------------------
// Created:     11 September 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	_proxyToDoTemplate.raiseExceptionIfNotTransient(method);	
	self.setForUpdate(_proxyToDoTemplate);
	self.setMyTerminal(_proxyToDoTemplate.myTerminal);
end;</source>
        <Parameter name="_proxyToDoTemplate" type="CM_ToDoTemplate"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="2342021e-4136-4df6-ad6d-e926ec46f74b">
        <updating/>
        <source>setForUpdate(_proxyToDoTemplate : CM_ToDoTemplate) updating;
// ---------------------------------------------------------------------------
// Created:     11 September 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
begin
	self.id := _proxyToDoTemplate.id;
	self.empties := _proxyToDoTemplate.empties;
	self.exports := _proxyToDoTemplate.exports;
	self.imports := _proxyToDoTemplate.imports;
	self.full := _proxyToDoTemplate.full;
	self.storage := _proxyToDoTemplate.storage;
	self.tranships := _proxyToDoTemplate.tranships;			// 21/09/2010 cnwmh5 #25602
	self.availabilityGradeToApply := _proxyToDoTemplate.availabilityGradeToApply;
	self.myTerminal := _proxyToDoTemplate.myTerminal;

	self.availabilityGrades.clear;
	self.isoGroups.clear;
	self.isoTypes.clear;
	self.operators.clear;
	self.toDoTasks.clear;
	
	_proxyToDoTemplate.availabilityGrades.copy(self.availabilityGrades);	
	_proxyToDoTemplate.isoGroups.copy(self.isoGroups);
	_proxyToDoTemplate.isoTypes.copy(self.isoTypes);	
	_proxyToDoTemplate.operators.copy(self.operators);
	_proxyToDoTemplate.toDoTasks.copy(self.toDoTasks);

end;</source>
        <Parameter name="_proxyToDoTemplate" type="CM_ToDoTemplate"/>
    </JadeMethod>
