    <JadeMethod name="getXMLSettingsForSave" id="a9674ba7-56e0-4df8-97ab-b43dd91ed725">
        <updating/>
        <source>getXMLSettingsForSave() : String updating;

/*
Date			Who		Reason
13 October 2010	cnwrl1	Initial creation as part of PAR 23899/25674 - Pack/Unpack form column organiser.
*/
	
vars
	
begin
	return	inheritMethod() &amp;
			self.tblPacked.getXmlStrForColumns( true ) &amp;
			self.tblUnpacked.getXmlStrForColumns( true ) &amp;
			global.formatAsXML("Filter", self.chbFilter.value.String);		// 37288 save Filter option value
	
epilog
	
end;</source>
        <ReturnType type="String"/>
