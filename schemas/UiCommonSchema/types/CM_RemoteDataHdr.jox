<Class name="CM_RemoteDataHdr">
    <JadeMethod name="isProcessAllowedInSystemAllert" id="feccd78a-81f0-495b-a94c-489e0d4115f9">
        <source>isProcessAllowedInSystemAllert() : Boolean;
/* ---------------------------------------------------------------------------
Created:	23 February 2010	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	return true;	// it enables btnProcessT for CMUI_RemoteDataEditForm, that is called from CMUI_SystemAllerts


end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadRemoteTable" id="b7995f96-b3e8-4bb4-8bb5-f6cbc7686377">
        <updating/>
        <source>loadRemoteTable(_table: CM_EntryTable io) updating;

vars

begin

	inheritMethod(_table);
	_table.setColumnHeadings('Item', 'Value');
	self.addRemoteRow(_table, 'Terminal', self.terminal, null);
	
	
end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="io"/>
    </JadeMethod>
</Class>
