    </JadeMethod>
    <JadeMethod name="setProxyForNewStructure" id="f00d624f-7400-4366-9640-7881f7b562b0">
        <updating/>
        <source>setProxyForNewStructure(pCode, pColour: Integer; pDescription, pAbbr: String) updating;
/*
------------------------------------------------------------------------
Created:			06 June 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars

begin

	self.raiseExceptionIfNotTransient(method);

	self.code := pCode;
	self.colour := pColour;
	self.abbreviation := pAbbr[1:4];
	self.description := pDescription[1:40];
	self.myRoot := app.myRoot;
end;</source>
        <Parameter name="pCode" type="Integer"/>
        <Parameter name="pColour" type="Integer"/>
        <Parameter name="pDescription" type="String"/>
        <Parameter name="pAbbr" type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyForUpdate" id="226e2677-787a-4c65-ba85-84154ae5de51">
        <updating/>
        <source>setProxyForUpdate(_abbr, _descr : String; _colour : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     11 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.abbreviation := _abbr;
	self.description := _descr;
	self.colour := _colour;

end;</source>
        <Parameter name="_abbr" type="String"/>
        <Parameter name="_descr" type="String"/>
        <Parameter name="_colour" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="9f82aaa4-3a70-4d02-8af1-6e74d6373685">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     11 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	if self.abbreviation = null then
		app.raiseCMException(Input_required_field_statsAbbr, null, null);
	endif;
	
	if self.description = null then
		app.raiseCMException(Input_required_field_statsDesc, null, null);
	endif;

end;</source>
    </JadeMethod>
