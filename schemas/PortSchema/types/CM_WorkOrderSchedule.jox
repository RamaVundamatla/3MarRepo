<Class name="CM_WorkOrderSchedule" id="404aad4b-5113-4c21-b897-eee39ee61b41">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Holds the planned work schedule information</text>
    <DbClassMap file="workorder"/>
    <ExplicitInverseRef name="myParent" id="945186cc-6574-4f35-a274-2c670613a61f">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
