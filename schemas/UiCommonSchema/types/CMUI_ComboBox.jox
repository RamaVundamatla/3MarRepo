    <JadeMethod name="click" id="2d189b62-2289-4c53-b4fc-fd2ae3e0f559">
        <controlMethod name="ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>click(combobox: ComboBox input) updating, clientExecution;
 // ### TFS 55105 07NOV2022 NAVAB1
vars
	
begin

	if not self.filterIgnore then // ### TFS BUG 64462 04JUNE024 NAVAB1 - Doing Filtering

		// they have selected an item, put everything back in the list. This is incase the UI has a reset option and is setting the list index to -1 or 1 etc.
		self.filterReshowAllItems();
	
	endif;
	
	inheritMethod(combobox);
end;
</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
