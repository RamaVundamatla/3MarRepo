    <JadeMethod name="repositionButton" id="c4247b76-eb84-47f7-9533-982d4f199556">
        <source>repositionButton(	_button : Button input;
					_lastButton : Button io;
					_leftAligned : Boolean) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2012	cnwer1	Initial creation SFW 1295

*/
constants
	Margin = 5;
vars

begin
	if _button.visible then
		if _leftAligned then
			_button.left := _lastButton.left + _lastButton.clientWidth + Margin;
		else
			_button.left:=_lastButton.left - _button.clientWidth - Margin;
		endif;
		_lastButton:=_button;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_button" type="Button" usage="input"/>
        <Parameter name="_lastButton" type="Button" usage="io"/>
        <Parameter name="_leftAligned" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="repositionButtons" id="0536829e-cc80-4701-a675-fc3624547d6f">
        <source>repositionButtons();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 June 2010	cnwer1	Initial creation

*/

begin

	//cnwjo3 par 26026
	if app.myVMAgent.getMyRTVehicleConfig.displayAcceptOnLeftHandSide then
		self.repositionLeftHand();
	else
		self.repositionRightHand();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="repositionLeftHand" id="c2dc9ed9-4926-43c6-ab0c-5d2c90753c3a">
        <source>repositionLeftHand();
// --------------------------------------------------------------------------------
// Created:		08 November 2010 by cnwjo3
//
// Purpose:		par 26026.  Position Reject and Pickup on LEFT hand side for left-handed people
//
constants
	Margin = 5;
vars
	lastMenuButton : Button;
begin
	//setting control properties...
	self.btnAccept.parentAspect := Control.ParentAspect_CenterVert;
	self.btnReject.parentAspect := Control.ParentAspect_CenterVert;
	self.btnMenu.parentAspect := Control.ParentAspect_CenterVert + Control.ParentAspect_AnchorRight;
	self.btnGraphic.parentAspect := Control.ParentAspect_CenterVert + Control.ParentAspect_AnchorRight;
	self.btnGraphicView.parentAspect := Control.ParentAspect_CenterVert + Control.ParentAspect_AnchorRight;
	self.btnVoyDischarge.parentAspect := Control.ParentAspect_CenterVert + Control.ParentAspect_AnchorRight;
	self.btnTaskMode.parentAspect :=Control.ParentAspect_CenterVert + Control.ParentAspect_AnchorRight; 
		
	//positioning...
	self.btnAccept.left := Margin;
	self.btnReject.left := self.btnAccept.left + self.btnAccept.clientWidth + Margin;
	self.btnMenu.left := self.clientWidth - Margin - self.btnMenu.clientWidth;
	
	lastMenuButton:=self.btnMenu;
	self.repositionButton(self.btnGraphic,lastMenuButton,false);
	self.repositionButton(self.btnGraphicView,lastMenuButton,false);
	self.repositionButton(self.btnVoyDischarge,lastMenuButton,false);
	self.repositionButton(self.btnTaskMode,lastMenuButton,false);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="repositionRightHand" id="97525541-4a93-426d-a0aa-33927b925466">
        <source>repositionRightHand();
// --------------------------------------------------------------------------------
// Created:		08 November 2010 by cnwjo3
//
// Purpose:		par 26026.  Position Reject and Pickup on right hand side for right-handed people
//				place menu and graphic on left
// 03/11/2016 		cnwrh7	TFS	2501
constants
	Margin = 5;
vars
	lastMenuButton : Button;
begin
	//setting control properties...
	self.btnAccept.parentAspect := Control.ParentAspect_CenterVert + Control.ParentAspect_AnchorRight;
	self.btnReject.parentAspect := Control.ParentAspect_CenterVert + Control.ParentAspect_AnchorRight;
	self.btnGetWeight.parentAspect := Control.ParentAspect_CenterVert + Control.ParentAspect_AnchorRight;						//+TFS2501
	self.btnSaveWeight.parentAspect := Control.ParentAspect_CenterVert + Control.ParentAspect_AnchorRight;					//+TFS2501
	
	self.btnMenu.parentAspect := Control.ParentAspect_CenterVert;
	self.btnGraphic.parentAspect := Control.ParentAspect_CenterVert;
	self.btnGraphicView.parentAspect := Control.ParentAspect_CenterVert;
	self.btnVoyDischarge.parentAspect := Control.ParentAspect_CenterVert;
	self.btnTaskMode.parentAspect := Control.ParentAspect_CenterVert;
	
	
	//positioning...
	self.btnAccept.left := self.clientWidth - Margin - self.btnAccept.clientWidth;
	self.btnReject.left := self.clientWidth  - Margin - self.btnAccept.clientWidth - Margin - self.btnReject.clientWidth;
	self.btnSaveWeight.left := self.clientWidth  - Margin - self.btnAccept.clientWidth - Margin - self.btnReject.clientWidth - self.btnSaveWeight.clientWidth - Margin ;	//+TFS2501
	self.btnGetWeight.left := self.clientWidth  - Margin - self.btnAccept.clientWidth - Margin - self.btnReject.clientWidth - self.btnSaveWeight.clientWidth-Margin-self.btnGetWeight.clientWidth - Margin ;	//+TFS2501
	
	self.btnMenu.left := Margin;
	lastMenuButton:=self.btnMenu;
	self.repositionButton(self.btnGraphic,lastMenuButton,true);
	self.repositionButton(self.btnGraphicView,lastMenuButton,true);
	self.repositionButton(self.btnVoyDischarge,lastMenuButton,true);
	self.repositionButton(self.btnTaskMode,lastMenuButton,true);
	

end;</source>
    </JadeMethod>
    <JadeMethod name="reselectRTQueueEntries" id="6156a1ef-abef-426d-8951-70ea4985813c">
        <source>reselectRTQueueEntries(_allSelectedEntries : CM_RTQueueEntrySet ) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 June 2010	cnwer1	Initial creation

*/

vars
	row : Integer;
	theRow: JadeTableRow;
	selectedEntry : CM_RTQueueEntry;
	theObject	: Object;
	invalidObject : Boolean;
begin

	self.tblTasks.tag:=null;
	if _allSelectedEntries = null or
		_allSelectedEntries.size = 0 then
		
		self.tblTasks.row := 1;	//26 Mar 2013	NDL	Par 31278
		self.tblTasks.click(self.tblTasks);	
		self.tblTasks.tag:=null; //epr 11/7/11 par 25048
		return;
	endif;
	
	//epr par 28458 14/10/11
	on Exception do app.handleDeletedObject(exception,theObject, invalidObject);
	//select fist visible row
	row:=self.tblTasks.fixedRows + 1;
	while row &lt;= self.tblTasks.rows do
		theRow:=self.tblTasks.accessRow(row);
		if theRow.visible and
			theRow.itemObject &lt;&gt; null then
			theObject:=theRow.itemObject;
			if not theObject.isKindOf(DTO_RTQueueEntry) then
				continue;
			endif;
			if _allSelectedEntries.includes(theObject.DTO_RTQueueEntry.myRealQueueEntry.CM_RTQueueEntry) then
				self.tblTasks.row:=row;
				self.tblTasks.click(self.tblTasks);
				//epr par 26069 18/10/10
				self.tblTasks.setFocus();
				selectedEntry:=theObject.DTO_RTQueueEntry.myRealQueueEntry.CM_RTQueueEntry;

			endif;
		
		endif;
		row:=row+1;
	endwhile;

	//18/01/2011 cnwdz2 26647
	row := 2;
	if selectedEntry = null and row &lt;= self.tblTasks.rows then
		
		self.tblTasks.row := row;
		self.tblTasks.click(self.tblTasks);	
		self.tblTasks.setFocus();				
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_allSelectedEntries" type="CM_RTQueueEntrySet"/>
    </JadeMethod>
    <JadeMethod name="reselectTI" id="fa6b3149-39a7-4e89-8d4a-473c9e78d96e">
        <source>reselectTI(_selectedTI : CM_TrackedItem) : Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 June 2010	cnwer1	Initial creation

*/

vars
	row : Integer;
	theRow : JadeTableRow;
begin

	//select fist visible row
	row:=self.tblTasks.fixedRows + 1;
	while row &lt;= self.tblTasks.rows do
		theRow:=self.tblTasks.accessRow(row);
		if theRow.visible and
			theRow.itemObject &lt;&gt; null and
			theRow.itemObject = _selectedTI then
			self.tblTasks.row:=row;
			self.tblTasks.click(self.tblTasks);
			return row;
		endif;
		row:=row+1;
	endwhile;
	
	return 0;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_selectedTI" type="CM_TrackedItem"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
