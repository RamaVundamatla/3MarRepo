    <JadeMethod name="queryDisplayResult" id="964228d9-d376-4ea3-97cb-3e798423c92f">
        <updating/>
        <source>queryDisplayResult( _dtoQueryResult : DTO_QueryResult ) updating, protected;
// -------------------------------------------
// Created 05 May 2008 by cnwvu1
// -------------------------------------------

vars
	strRow		: String;
	i			: Integer;
	
begin

	self.queryResultTableReInitialize();
	
	self.lblQueryName.caption := _dtoQueryResult.queryName;

	//number of columns
	if _dtoQueryResult.columns &gt; 0 and _dtoQueryResult.columnHeadings &lt;&gt; null then
		self.tblResults.columns := _dtoQueryResult.columns;
	else
		self.tblResults.columns := 1;
	endif;
	 
	self.tblResults.accessCell(1,1).text := _dtoQueryResult.columnHeadings;
	
	// setting all sortTypes for all column
	foreach i in 1 to _dtoQueryResult.columns do
		self.aQuerySortTypes[i] := _dtoQueryResult.sortTypes[i];
	endforeach;

	foreach strRow in _dtoQueryResult.allData do
		self.tblResults.addItem( strRow );
	endforeach;
	
	self.queryResultTableColours();
	
end;
</source>
        <access>protected</access>
        <Parameter name="_dtoQueryResult" type="MobileServerRTThin::DTO_QueryResult"/>
    </JadeMethod>
    <JadeMethod name="queryGetDefinition" id="56c9bd6b-e5f1-45d8-9a1a-d4ae9bda416d">
        <updating/>
        <source>queryGetDefinition( _queryOid : String ) updating, protected;
// -------------------------------------------
// Created 02 may 2008 by cnwvu1
// -------------------------------------------

vars
	errorStr	: String;
	
begin

	if app.myRTGuiAgent.getQueryDefinition( self, _queryOid, errorStr ) then
		self.aQuerySelectorOid := _queryOid;	
		self.setModeQuery( self.Mode_QueryRun );
	else
		self.aWarnings := false;
		self.showMessage( errorStr, true );
	endif;

end;
</source>
        <access>protected</access>
