    <JadeMethod name="tNormalTimeOvertime" id="03ea27fb-ce69-4749-b61d-834c3eed5e29">
        <source>tNormalTimeOvertime();
//
// 07 May 2019	jlgrs1	TFS44650 STWO Invoice line incorrectly charged as NORMAL hours where OVERTIME is expected
//02/10/2025	navkc1 JIRA 36149 AAT | RotaBox ISO Type and New Attributes - Calculation Type
//
constants
	UTCalculationType = "UTCTOT";
	UTCalendarCode1 = "UTOI";
	UTCalendarCode2 = "UTOE";
	UTDayType1 = "UTDTOTIN";
	UTDayType2 = "UTDTOTEX";
vars
	calcType : CM_CalculationType;
	calendar1 : CM_Calendar;
	calendar2 : CM_Calendar;
	dayType : CM_DayType;
	startDate : Date;
	calendarDay : CM_CalendarDate;
	actionTS1 : TimeStamp;
	actionTS2 : TimeStamp;
	actionTS3 : TimeStamp;
	result : Boolean;
begin
	self.deleteCalendar(UTCalendarCode1, UTDayType1);
	calendar1 := self.createCalendar(UTCalendarCode1, "Unit test OverTime", false, false, UTDayType1);
	calendarDay := self.addSingleCalendarDate(startDate, "ToDay", calendar1);
	beginTransaction;
	calendarDay.setStartEndTime('07:30'.Time, '17:30'.Time);
	commitTransaction;
	self.deleteCalendar(UTCalendarCode2, UTDayType2);
	calendar2 := self.createCalendar(UTCalendarCode2, "Unit test OverTime", false, false, UTDayType2);
	self.addSingleCalendarDate(startDate.addDays(-1), "ToDay", calendar2);
	self.deleteCalculationType(UTCalculationType, NORMAL_ERASE);
	calcType := self.addCalculationTypeFull(INV_CALC_TYPE_BUSHRSCARGOVALUE, UTCalculationType, "Unit test OverTime", null, null, null, 0, 0, 0, 0, true, false, false, false, INV_CALC_TYPE_DAYS_SINCE_RECVL, null, calendar1, calendar2, null);
	self.assertNotNull(calcType);
	actionTS1.setTime("12:30".Time);
	actionTS2.setTime("20:00".Time);
	actionTS3 := actionTS3.addDays(-1);
	// straight run thru
	result := calcType.isTimeNormalTime(actionTS1, self.getTerminal);
	write actionTS1.String&amp;' Normal time='&amp;result.String;
	self.assertEqual(result, true);
	result := calcType.isTimeNormalTime(actionTS2, self.getTerminal);
	write actionTS2.String&amp;' Normal time='&amp;result.String;
	self.assertEqual(result, false);
	result := calcType.isTimeNormalTime(actionTS3, self.getTerminal);
	write actionTS3.String&amp;' Normal time='&amp;result.String;
	self.assertEqual(result, false);
	result := calcType.isTimeOverTime(actionTS1, self.getTerminal);
	write actionTS1.String&amp;' Over time='&amp;result.String;
	self.assertEqual(result, false);
	result := calcType.isTimeOverTime(actionTS2, self.getTerminal);
	write actionTS2.String&amp;' Over time='&amp;result.String;
	self.assertEqual(result, true);
	result := calcType.isTimeOverTime(actionTS3, self.getTerminal);
	write actionTS3.String&amp;' Over time='&amp;result.String;
	self.assertEqual(result, false);
	result := calcType.isTimeExcludedTime(actionTS1, self.getTerminal);
	write actionTS1.String&amp;' Excluded time='&amp;result.String;
	self.assertEqual(result, false);
	result := calcType.isTimeExcludedTime(actionTS2, self.getTerminal);
	write actionTS2.String&amp;' Excluded time='&amp;result.String;
	self.assertEqual(result, false);
	result := calcType.isTimeExcludedTime(actionTS3, self.getTerminal);
	write actionTS3.String&amp;' Excluded time='&amp;result.String;
	self.assertEqual(result, true);
	// now the exclusion calendar has been disconnected
	beginTransaction;
	calendar2.allTerminals.clear();
	commitTransaction;
	result := calcType.isTimeNormalTime(actionTS1, self.getTerminal);
	write actionTS1.String&amp;' Normal time='&amp;result.String;
	self.assertEqual(result, true);
	result := calcType.isTimeNormalTime(actionTS2, self.getTerminal);
	write actionTS2.String&amp;' Normal time='&amp;result.String;
	self.assertEqual(result, false);
	result := calcType.isTimeNormalTime(actionTS3, self.getTerminal);
	write actionTS3.String&amp;' Normal time='&amp;result.String;
	self.assertEqual(result, false);
	result := calcType.isTimeOverTime(actionTS1, self.getTerminal);
	write actionTS1.String&amp;' Over time='&amp;result.String;
	self.assertEqual(result, false);
	result := calcType.isTimeOverTime(actionTS2, self.getTerminal);
	write actionTS2.String&amp;' Over time='&amp;result.String;
	self.assertEqual(result, true);
	result := calcType.isTimeOverTime(actionTS3, self.getTerminal);
	write actionTS3.String&amp;' Over time='&amp;result.String;
	self.assertEqual(result, false);
	result := calcType.isTimeExcludedTime(actionTS1, self.getTerminal);
	write actionTS1.String&amp;' Excluded time='&amp;result.String;
	self.assertEqual(result, false);
	result := calcType.isTimeExcludedTime(actionTS2, self.getTerminal);
	write actionTS2.String&amp;' Excluded time='&amp;result.String;
	self.assertEqual(result, false);
	result := calcType.isTimeExcludedTime(actionTS3, self.getTerminal);
	write actionTS3.String&amp;' Excluded time='&amp;result.String;
	self.assertEqual(result, false);
	// now the inclusion calendar has been disconnect and the exclusion calcendar reconnected
	beginTransaction;
	calendar1.allTerminals.clear();
	calendar2.allTerminals.add(self.getTerminal);
	commitTransaction;
	result := calcType.isTimeNormalTime(actionTS1, self.getTerminal);
	write actionTS1.String&amp;' Normal time='&amp;result.String;
	self.assertEqual(result, false);
	result := calcType.isTimeNormalTime(actionTS2, self.getTerminal);
	write actionTS2.String&amp;' Normal time='&amp;result.String;
	self.assertEqual(result, false);
	result := calcType.isTimeNormalTime(actionTS3, self.getTerminal);
	write actionTS3.String&amp;' Normal time='&amp;result.String;
	self.assertEqual(result, false);
	result := calcType.isTimeOverTime(actionTS1, self.getTerminal);
	write actionTS1.String&amp;' Over time='&amp;result.String;
	self.assertEqual(result, false);
	result := calcType.isTimeOverTime(actionTS2, self.getTerminal);
	write actionTS2.String&amp;' Over time='&amp;result.String;
	self.assertEqual(result, false);
	result := calcType.isTimeOverTime(actionTS3, self.getTerminal);
	write actionTS3.String&amp;' Over time='&amp;result.String;
	self.assertEqual(result, false);
	result := calcType.isTimeExcludedTime(actionTS1, self.getTerminal);
	write actionTS1.String&amp;' Excluded time='&amp;result.String;
	self.assertEqual(result, false);
	result := calcType.isTimeExcludedTime(actionTS2, self.getTerminal);
	write actionTS2.String&amp;' Excluded time='&amp;result.String;
	self.assertEqual(result, false);
	result := calcType.isTimeExcludedTime(actionTS3, self.getTerminal);
	write actionTS3.String&amp;' Excluded time='&amp;result.String;
	self.assertEqual(result, true);
	// now both calendars have been disconnected
	beginTransaction;
	calendar1.allTerminals.clear();
	calendar2.allTerminals.clear();
	commitTransaction;
	result := calcType.isTimeNormalTime(actionTS1, self.getTerminal);
	write actionTS1.String&amp;' Normal time='&amp;result.String;
	self.assertEqual(result, false);
	result := calcType.isTimeNormalTime(actionTS2, self.getTerminal);
	write actionTS2.String&amp;' Normal time='&amp;result.String;
	self.assertEqual(result, false);
	result := calcType.isTimeNormalTime(actionTS3, self.getTerminal);
	write actionTS3.String&amp;' Normal time='&amp;result.String;
	self.assertEqual(result, false);
	result := calcType.isTimeOverTime(actionTS1, self.getTerminal);
	write actionTS1.String&amp;' Over time='&amp;result.String;
	self.assertEqual(result, false);
	result := calcType.isTimeOverTime(actionTS2, self.getTerminal);
	write actionTS2.String&amp;' Over time='&amp;result.String;
	self.assertEqual(result, false);
	result := calcType.isTimeOverTime(actionTS3, self.getTerminal);
	write actionTS3.String&amp;' Over time='&amp;result.String;
	self.assertEqual(result, false);
	result := calcType.isTimeExcludedTime(actionTS1, self.getTerminal);
	write actionTS1.String&amp;' Excluded time='&amp;result.String;
	self.assertEqual(result, false);
	result := calcType.isTimeExcludedTime(actionTS2, self.getTerminal);
	write actionTS2.String&amp;' Excluded time='&amp;result.String;
	self.assertEqual(result, false);
	result := calcType.isTimeExcludedTime(actionTS3, self.getTerminal);
	write actionTS3.String&amp;' Excluded time='&amp;result.String;
	self.assertEqual(result, false);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tOracleFinancialExport" id="9917f2e3-885d-4361-9e7f-fa6afeaa9e97">
        <source>tOracleFinancialExport();
// cnwma1
// cnwjre1 Doha invoice export test CCMS 1271 and 2283
//  (re)create customers, GL codes, services, invoice line types, invoice types and invoices (debit and credit values)
// 		based on the original sample data provided by Doha.
// 14/12/2021	navdap1	Unit test fixups after DMAST -&gt; WMAST code overwrite
vars
	tempDir	: String;
	currentFinClass	: CM_ExtFinanceIO;
	now		: Date;
	bank 		: CM_Bank;
	services : CM_ServiceByNameDict;
	debtors		: CM_DebtorSet;
	invType		: CM_InvoiceDesc;
	invoices	: CM_InvoiceSet;
	roundType 	: Integer;

begin

	tempDir := self.getTempDirectory();
	currentFinClass := getInvoiceFinancialClass();

	roundType := self.setTerminalConfig(InvoiceRoundLineTotal, CMIF_ConfigTerminal.InvLineRound_Value_NoRound).Integer;
	
	bank := app.myRoot.myRootCompany;
	create debtors transient;
	create services transient;

	// recreate the debtors
	self.zOracleFinExportCreateDebtors(debtors);

	// recreate the GL codes and services
	self.zOracleFinExportCreateServices(services);

	// create invoice type
	self.deleteInvoiceType("UT_IT1");
	invType := self.createInvoiceTypeFull(CM_InvoiceDesc.Accrue_Until_Manually_Closed,
											null,
											"UT_IT1",
											CM_InvoiceDesc.Key_None,
											InvoiceTypeGeneral,
											bank.allFinancialPeriods.first(),
											bank.allInvoiceTermsOfTrade.first(),
											true,
											InvTypeTrigger_Release,
											now,
											now,
											0,
											"");

	// create invoice line types
	self.zOracleFinExportCreateILTs(invType, services );
	
	// set up rates for these debtors and services
	self.zOracleFinExportCreateRates(debtors, services);
	
	// create invoices
	invoices := self.zOracleFinExportCreateInvoices(debtors, invType);
	
	// set export financial class to test
	self.setInvoiceFinancialClass(CM_OracleFinancials, tempDir);
	//self.setInvoiceFinancialClass(CM_OracleFinancials, "%MISCDIR%\invoices");
	// post and export invoices
	self.zOracleFinExportPostInvoices(invoices);
	
	// test the extracted files against the invoices
	self.zOracleFinExportTestInvoices(invoices);
epilog
	if currentFinClass &lt;&gt; null then
		self.setInvoiceFinancialClass(currentFinClass.class, null);
	endif;
	self.setTerminalConfig(InvoiceRoundLineTotal, roundType);
	delete debtors;
	delete services;
	delete invoices;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPackageEmailPlaceholders" id="1b40f617-ecd0-450a-90df-e3d133a03434">
        <source>tPackageEmailPlaceholders();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Oct 2025	navah1	Initial creation
23 Oct 2025 navah1	Story 36250: LINX | Unit Test for Invoice Subject Placeholder Replacement
*/
constants 
	DebtorName  = "UT_Debtor_36249";
	VOYAGEID	= "UT_VOY_36249";
	VESSELID	= "UT_VES_36249";
vars  
	date		: Date; 
	bank 		: CM_Bank; 
	debtorRate  : CM_DebtorRate; 
	debtorNode	: CM_DebtorNode;
	proxyDebtor,
	debtor		: CM_Debtor;
	invType		: CM_InvoiceDesc;
	invLineType	: CM_InvoiceLineDesc;
	debtorNodeController	: CMIF_DebtorNode;
	invoice		: CM_Invoice;
	invoiceLine	: CM_InvoiceLine; 
	user 		: CM_User;
	emailRequest : BGP_EmailSendRequest;
	vessel		: CM_Vessel;
	voyage		: CM_Voyage;
	subjectWithValues : String;
	count		: Integer;
	invoiceNumber,
	invoiceStatus,
	voyageExternal,
	voyageCode,
	vesselName,
	terminalCode,
	debtorCode, 
	shippingLine: String; 
	operator : CM_Operator;
begin
	bank := app.myRoot.myRootCompany;
	user := app.getMyUser(); 
	operator := self.getOperator((self.getProfileSetting(UT_Profile.P_OPERATOR).asString()));
	shippingLine := self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(); 
	
	// deleteing and creating voyage and vessel
	self.deleteVoyage(VOYAGEID); 
	self.deleteVessel(VESSELID);
	vessel := self.addVesselCellular(VESSELID, operator); 
	voyage := self.addVoyageWithContainerStructur(VOYAGEID, VESSELID, operator.code, shippingLine); 
	voyage := self.getVoyage(VOYAGEID);
	self.assertNotNull(voyage);	  
	
	// delete debtor
	debtorNode := app.myRoot.myRootCompany.debtors[DebtorName];
	if debtorNode &lt;&gt; null then
		self.deleteDebtor(debtorNode);
	endif;
	
	// create debtor
	create debtorNodeController transient;
	create proxyDebtor transient;
	debtorNodeController.code := DebtorName;
	self.setDebtorNodeController1(DebtorName, debtorNodeController, proxyDebtor);
	self.setInvLinePlaceholders(proxyDebtor);  
	app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport); 
	self.assertNoTrxErrorsOrWarnings(); 
	
	if debtorNode &lt;&gt; null then
		debtor := debtorNode.CM_Debtor;
	endif; 
	self.assertNotNullMsg(debtor, "Debtor not created.");
	
	// create invoice
	invType := self.getInvoiceType("UT_InvType");
	invoice := self.createManualInvoice(self.myBank, debtor, null, invType, null); 
	invLineType := self.getInvoiceLineType("UT_ILD01");
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 10, "Line 1", date);
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 5, "Line 2", date); 
	beginTransaction; 
	voyage.setPropertyValue("voyageCodeExternal", "EXT_36249");
	invoice.setVoyage(voyage); 
	commitTransaction;
	
	// post invoice, run invoice package
	self.postInvoice(invoice, false, false);
	
	invoiceNumber     := invoice.getExternalInvoiceNumber();
	invoiceStatus     := invoice.getStatusDescription(invoice.status);
	voyageExternal    := voyage.voyageCodeExternal;
	voyageCode   	  := voyage.code;
	vesselName   	  := voyage.getMyVessel().name;
	terminalCode      := invoice.myTerminal.code;
	debtorCode        := invoice.debtor.code;
	subjectWithValues := "INV=" &amp; invoiceNumber &amp;
							" STA="&amp; invoiceStatus &amp;
							" VOE=" &amp; voyageExternal &amp;
							" VOY=" &amp; voyageCode &amp;
							" VES=" &amp; vesselName &amp;
							" TER=" &amp; terminalCode &amp;
							" DEBTCODE=" &amp; debtorCode;
							
	foreach emailRequest in BGP_EmailSendRequest.instances do
		if emailRequest.myUser = user and
			  emailRequest.sendSubject &lt;&gt; null and
			  emailRequest.sendSubject.pos(subjectWithValues, 1) &gt; 0 then 
				count += 1;
		endif;
	endforeach;  
	
	self.assertTrueMsg(count &gt; 0, "Email subject placeholders are not replaced correctly.");
epilog
	delete proxyDebtor; 
	delete debtorNodeController; 
	delete debtorRate; 
	self.deleteInvoice(invoice);
end;</source>
    </JadeMethod>
    <JadeMethod name="tPostInvConsByNarrAndRate" id="3276c171-1ac9-4bb5-adbd-2b16bb9fb3d9">
        <source>tPostInvConsByNarrAndRate();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
05 February 2024	navrv30	Initial creation for CR 61911/ Task 61391
28 February 2025 	navsck1 MTN-34224 Unit test UT_Invoicing::tPostInvConsByNarrAndRate needs to be fixed

*/

constants
	DebtorName	= "UT_Debtor1";
	InvoiceType = "UT_INV";
	VoyageId	= "UT_VOY1";
	ExtWebServiceDefName : String = "UT_InvoiceOracleIntf";	
	
vars
	bank		: CM_Bank;
	terminal	: CM_Terminal;
	debtor		: CM_Debtor;
	invType		: CM_InvoiceDesc;
	voyage		: CM_Voyage;
	invoice	: CM_Invoice;

	activeWebServiceDef : CM_ExternalWebServiceDef;
	pxyExtWebServiceDef : CM_InvoiceAPIServiceDef;
	bgpInvoiceAPIWSReq	: BGP_InvoiceAPIWSRequest;
	calcType : CM_CalculationType;
	service100 : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType		: CM_InvoiceLineDesc;
	invoiceLine, invoiceLine2,
	invoiceLine3, invoiceLine4		: CM_InvoiceLine;
	now             : TimeStamp;
	realProcess     : CM_InvoiceProcess;
	pxyCharge			   : CM_Charge;
	aCharge			       : CM_Charge;
	theController		   : CMIF_ChargesController;
	ewsActivity		: CM_ExternalWebServiceActivity;
	transientObjs : ObjectArray;
begin
	self.deleteExternalWebService(ExtWebServiceDefName);
	self.deleteInvoiceService("UT_ServiceCopy-1",0);
	self.deleteInvoiceType("UT_InvTypeCopy");
	self.deleteInvoiceLineType("UT_LineTypeCopy",0);
	now := app.actualTime();
	create transientObjs transient;
	beginTransaction;
	create pxyExtWebServiceDef as CM_InvoiceAPIServiceDef transient;
	
	pxyExtWebServiceDef.setProxy(	true,	//_active : Boolean;
									ExtWebServiceDefName,	//_name : String;  
									"http://143.96.24.26:80/",	//_baseEndpoint : String;  
									null,//app.pwEnCode( "test" ),	//_password : String;
									"MTN1",	//_userCode : String; 
									3,	//_maxRetries : Integer;  
									1,	//_timeBetweenRetries : Integer; 
									10,	//_timeoutSeconds : Integer; 
									null,	//_restAPIAuthEndpoint : String; 
									null,	//_restAPIBaseEndpoint : String;
									null,	//_authProviderUrl : String;
									"MTN1",	//_clientId : String;
									null,	//_clientSecret : String;
									null,	//_runAsKey : String;
									null	//_callBackUrl : String
									);	
	
	pxyExtWebServiceDef.setInvoiceLinesPerBatch(3500);
	app.myUtilityCA.utlCreateExtWebService(pxyExtWebServiceDef, activeWebServiceDef, app.myPassport);	
	commitTransaction;
	
	terminal := self.getTerminal();
	self.assertNotNull(terminal);
	
	bank := terminal.getDefaultCompanyBank();
	self.assertNotNull(bank);
	
	debtor := self.getDebtor(DebtorName);
	self.assertNotNull(debtor);
	
	invType := self.getInvoiceType(InvoiceType);
	self.assertNotNull(invType);
	
	voyage := self.getVoyage(VoyageId);
	self.assertNotNull(voyage);	
	
	bank := terminal.getDefaultCompanyBank();
	self.assertNotNull(bank);
	//bank.myInvoiceProcess
	
	debtor := self.getDebtor(DebtorName);
	self.assertNotNull(debtor);
	
	calcType := app.myRoot.allCalculationTypesByCode["CCT00"];
	service100 := self.createInvoiceService("UT_ServiceCopy-1","1- Unit test for Task 61635", calcType, null);
	self.assertNotNullMsg(service100, "UT_ServiceCopy-1 not created");
	
	create services transient;
 	services.add(service100);
	
	invType := self.createInvoiceType("UT_InvTypeCopy", InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeCopy not created");
	
	invLineType := self.createInvoiceLineType("UT_LineTypeCopy", calcType, invType, services,"SDT6");
	self.assertNotNullMsg(invLineType, "UT_LineTypeCopy not created");
	
	invoice := self.createManualInvoice(bank, debtor, voyage, invType, null);
	self.assertNotNull(invoice);
	self.assertEqual(invoice.category, InvoiceCategory_Invoice);	
	
	beginTransaction;
	invoice.sequenceNum := 999;
	
	create theController transient;
	realProcess := app.myRoot.allInvoiceProcesses[InvoiceProcessInvoiceAPI];
	invoice.setMyInvoiceProcess(realProcess);
	commitTransaction;
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 2, "UT-Copy-Inv1", now.date());
	foreach aCharge in invoiceLine.charges do 
		pxyCharge := app.createUpdateProxy(aCharge).CM_Charge;
		pxyCharge.setProxyRateNew(50);
		pxyCharge.setOverriden();
		theController.allCharges.add(pxyCharge);
		transientObjs.add(pxyCharge);
	endforeach;
	
	beginTransaction;						// 28.02.2025 navsck1 #MTN-34224
	invoiceLine.setTaxCodes("GST");
	commitTransaction;						// 28.02.2025 navsck1 #MTN-34224		
	
	app.myTrxUA.trxUpdateChargesManual(theController,app.myPassport);
	theController.allCharges.clear();
	
	invoiceLine2 := self.createManualInvoiceLine(invLineType, invoice, 5, "UT-Copy-Inv1", now.date());
	foreach aCharge in invoiceLine2.charges do 
		pxyCharge := app.createUpdateProxy(aCharge).CM_Charge;
		pxyCharge.setProxyRateNew(50);
		pxyCharge.setOverriden();
		theController.allCharges.add(pxyCharge);
		transientObjs.add(pxyCharge);
	endforeach;	
	
	beginTransaction;												// 28.02.2025 navsck1 #MTN-34224
	invoiceLine2.setTaxCodes("GST");	
	commitTransaction;												// 28.02.2025 navsck1 #MTN-34224
	
	app.myTrxUA.trxUpdateChargesManual(theController,app.myPassport);
	theController.allCharges.clear();
	
	invoiceLine3 := self.createManualInvoiceLine(invLineType, invoice, 5, "UT-Copy-Inv2", now.date());
	foreach aCharge in invoiceLine3.charges do 
		pxyCharge := app.createUpdateProxy(aCharge).CM_Charge;
		pxyCharge.setProxyRateNew(100);
		pxyCharge.setOverriden();
		theController.allCharges.add(pxyCharge);
		transientObjs.add(pxyCharge);
	endforeach;	
	
	beginTransaction;												// 28.02.2025 navsck1 #MTN-34224
	invoiceLine3.setTaxCodes("GST");
	commitTransaction;												// 28.02.2025 navsck1 #MTN-34224
	
	app.myTrxUA.trxUpdateChargesManual(theController,app.myPassport);
	theController.allCharges.clear();
	
	invoiceLine4 := self.createManualInvoiceLine(invLineType, invoice, 5, "UT-Copy-Inv2", now.date());
	foreach aCharge in invoiceLine4.charges do 
		pxyCharge := app.createUpdateProxy(aCharge).CM_Charge;
		pxyCharge.setProxyRateNew(100);
		pxyCharge.setOverriden();
		theController.allCharges.add(pxyCharge);
		transientObjs.add(pxyCharge);
	endforeach;	
	
	beginTransaction;												// 28.02.2025 navsck1 #MTN-34224
	invoiceLine4.setTaxCodes("GST");
	commitTransaction;												// 28.02.2025 navsck1 #MTN-34224
	
	app.myTrxUA.trxUpdateChargesManual(theController,app.myPassport);
	theController.allCharges.clear();	
	
	create bgpInvoiceAPIWSReq transient;	
	bgpInvoiceAPIWSReq.setDetails(invoice, invoice.myTerminal,  CM_InvoiceAPI.CONSMODE_INV_LINE_AND_RATE, null, null,null);
	bgpInvoiceAPIWSReq.createAndSendInvoiceJSON( activeWebServiceDef.CM_InvoiceAPIServiceDef,  3);
	
	foreach ewsActivity in activeWebServiceDef.CM_InvoiceAPIServiceDef.allEWSActivities do
		if ewsActivity.isKindOf(CM_EWSActivityInvoiceAPIParts) then
			self.valConsolidatedMessage(ewsActivity);
		endif;
	endforeach;	
	
epilog	
	
	delete bgpInvoiceAPIWSReq;
	delete pxyExtWebServiceDef;
	if services &lt;&gt; null then
		beginTransaction;
		services.purge();
		delete services;
		commitTransaction;
	endif;	
	delete theController;	
	if transientObjs &lt;&gt; null then
		transientObjs.purge();
	endif;
	delete transientObjs;
	beginTransaction;		
		delete invoice;
	commitTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="tPostInvConsByServiceAndRate" id="a8fd686d-9cbb-4bf3-90ee-c641dee4d665">
        <source>tPostInvConsByServiceAndRate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 February 2024	navrv30	Initial creation

*/


constants
	DebtorName	= "UT_Debtor1";
	InvoiceType = "UT_INV";
	VoyageId	= "UT_VOY1";
	ExtWebServiceDefName : String = "UT_InvoiceOracleIntf";	
	
vars
	bank		: CM_Bank;
	terminal	: CM_Terminal;
	debtor		: CM_Debtor;
	invType		: CM_InvoiceDesc;
	voyage		: CM_Voyage;
	invoice	: CM_Invoice;

	activeWebServiceDef : CM_ExternalWebServiceDef;
	pxyExtWebServiceDef : CM_InvoiceAPIServiceDef;
	bgpInvoiceAPIWSReq	: BGP_InvoiceAPIWSRequest;
	calcType : CM_CalculationType;
	service100 : CM_Service;
	service101 : CM_Service;
	service102 : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType		: CM_InvoiceLineDesc;
	invoiceLine, invoiceLine2,
	invoiceLine3, invoiceLine4		: CM_InvoiceLine;
	now             : TimeStamp;
	realProcess     : CM_InvoiceProcess;
	pxyCharge			   : CM_Charge;
	aCharge			       : CM_Charge;
	theController		   : CMIF_ChargesController;
	ewsActivity		: CM_ExternalWebServiceActivity;
	transientObjs : ObjectArray;
begin
	self.deleteExternalWebService(ExtWebServiceDefName);
	self.deleteInvoiceService("UT_ServiceCopy-1",0);
	self.deleteInvoiceService("UT_ServiceCopy-2",0);
	self.deleteInvoiceService("UT_ServiceCopy-3",0);
	self.deleteInvoiceType("UT_InvTypeCopy");
	self.deleteInvoiceLineType("UT_LineTypeCopy",0);
	self.deleteInvoiceLineType("UT_LineTypeCopy1",0);
	self.deleteInvoiceLineType("UT_LineTypeCopy2",0);
	self.deleteInvoiceLineType("UT_LineTypeCopy3",0);
	now := app.actualTime();
	create transientObjs transient;
	beginTransaction;
	create pxyExtWebServiceDef as CM_InvoiceAPIServiceDef transient;
	
	pxyExtWebServiceDef.setProxy(	true,	//_active : Boolean;
									ExtWebServiceDefName,	//_name : String;  
									"http://143.96.24.26:80/",	//_baseEndpoint : String;  
									null,//app.pwEnCode( "test" ),	//_password : String;
									"MTN2",	//_userCode : String; 
									3,	//_maxRetries : Integer;  
									1,	//_timeBetweenRetries : Integer; 
									10,	//_timeoutSeconds : Integer; 
									null,	//_restAPIAuthEndpoint : String; 
									null,	//_restAPIBaseEndpoint : String;
									null,	//_authProviderUrl : String;
									"MTN2",	//_clientId : String;
									null,	//_clientSecret : String;
									null,	//_runAsKey : String;
									null	//_callBackUrl : String
									);	
	
	pxyExtWebServiceDef.setInvoiceLinesPerBatch(3500);
	app.myUtilityCA.utlCreateExtWebService(pxyExtWebServiceDef, activeWebServiceDef, app.myPassport);	
	commitTransaction;
	
	terminal := self.getTerminal();
	self.assertNotNull(terminal);
	
	bank := terminal.getDefaultCompanyBank();
	self.assertNotNull(bank);
	
	debtor := self.getDebtor(DebtorName);
	self.assertNotNull(debtor);
	
	invType := self.getInvoiceType(InvoiceType);
	self.assertNotNull(invType);
	
	voyage := self.getVoyage(VoyageId);
	self.assertNotNull(voyage);	
	
	bank := terminal.getDefaultCompanyBank();
	self.assertNotNull(bank);
	//bank.myInvoiceProcess
	
	debtor := self.getDebtor(DebtorName);
	self.assertNotNull(debtor);
	
	calcType := app.myRoot.allCalculationTypesByCode["CCT00"];
	service100 := self.createInvoiceService("UT_ServiceCopy-1","1- Unit test for Task 61392", calcType, null);
	self.assertNotNullMsg(service100, "UT_ServiceCopy-1 not created");
	
	service101 := self.createInvoiceService("UT_ServiceCopy-2","1- Unit test for Task 61392", calcType, null);
	self.assertNotNullMsg(service100, "UT_ServiceCopy-2 not created");
	
	service102 := self.createInvoiceService("UT_ServiceCopy-3","1- Unit test for Task 61392", calcType, null);
	self.assertNotNullMsg(service100, "UT_ServiceCopy-3 not created");
	
	create services transient;
 	services.add(service100);
	//services.add(service101);
	//services.add(service102);
	
	invType := self.createInvoiceType("UT_InvTypeCopy", InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeCopy not created");
	
	invLineType := self.createInvoiceLineType("UT_LineTypeCopy", calcType, invType, services,"SDT6");
	self.assertNotNullMsg(invLineType, "UT_LineTypeCopy not created");
	
	invoice := self.createManualInvoice(bank, debtor, voyage, invType, null);
	self.assertNotNull(invoice);
	self.assertEqual(invoice.category, InvoiceCategory_Invoice);	
	
	beginTransaction;
	invoice.sequenceNum := 999;
	
	create theController transient;
	realProcess := app.myRoot.allInvoiceProcesses[InvoiceProcessInvoiceAPI];
	invoice.setMyInvoiceProcess(realProcess);
	commitTransaction;	
	
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 2, "UT-Copy-Inv1", now.date());
	foreach aCharge in invoiceLine.charges do 
		pxyCharge := app.createUpdateProxy(aCharge).CM_Charge;
		pxyCharge.setProxyRateNew(50);
		pxyCharge.setOverriden();
		theController.allCharges.add(pxyCharge);
		transientObjs.add(pxyCharge);
	endforeach;
	
	app.myTrxUA.trxUpdateChargesManual(theController,app.myPassport);
	theController.allCharges.clear();
	
	services.remove(service100);
	services.add(service101);
	invLineType := self.createInvoiceLineType("UT_LineTypeCopy1", calcType, invType, services,"SDT6");
	self.assertNotNullMsg(invLineType, "UT_LineTypeCopy not created");
	
	invoiceLine2 := self.createManualInvoiceLine(invLineType, invoice, 5, "UT-Copy-Inv1", now.date());
	foreach aCharge in invoiceLine2.charges do 
		pxyCharge := app.createUpdateProxy(aCharge).CM_Charge;
		pxyCharge.setProxyRateNew(60);
		pxyCharge.setOverriden();
		theController.allCharges.add(pxyCharge);
		transientObjs.add(pxyCharge);
	endforeach;	
	app.myTrxUA.trxUpdateChargesManual(theController,app.myPassport);
	theController.allCharges.clear();
	
	services.remove(service101);
	services.add(service102);
	invLineType := self.createInvoiceLineType("UT_LineTypeCopy2", calcType, invType, services,"SDT6");
	self.assertNotNullMsg(invLineType, "UT_LineTypeCopy not created");
	invoiceLine3 := self.createManualInvoiceLine(invLineType, invoice, 5, "UT-Copy-Inv2", now.date());
	foreach aCharge in invoiceLine3.charges do 
		pxyCharge := app.createUpdateProxy(aCharge).CM_Charge;
		pxyCharge.setProxyRateNew(70);
		pxyCharge.setOverriden();
		theController.allCharges.add(pxyCharge);
		transientObjs.add(pxyCharge);
	endforeach;	
	app.myTrxUA.trxUpdateChargesManual(theController,app.myPassport);
	theController.allCharges.clear();
	
	services.remove(service102);
	services.add(service100);
	//invLineType := self.createInvoiceLineType("UT_LineTypeCopy", calcType, invType, services,"SDT6");
	//self.assertNotNullMsg(invLineType, "UT_LineTypeCopy not created");
	invoiceLine4 := self.createManualInvoiceLine(invLineType, invoice, 5, "UT-Copy-Inv2", now.date());
	foreach aCharge in invoiceLine4.charges do 
		pxyCharge := app.createUpdateProxy(aCharge).CM_Charge;
		pxyCharge.setProxyRateNew(70);
		pxyCharge.setOverriden();
		theController.allCharges.add(pxyCharge);
		transientObjs.add(pxyCharge);
	endforeach;	
	app.myTrxUA.trxUpdateChargesManual(theController,app.myPassport);
	theController.allCharges.clear();	
	
	create bgpInvoiceAPIWSReq transient;
	bgpInvoiceAPIWSReq.setDetails(invoice, invoice.myTerminal,  CM_InvoiceAPI.CONSMODE_CHARGE_AND_RATE, null, null,null);
	bgpInvoiceAPIWSReq.createAndSendInvoiceJSON( activeWebServiceDef.CM_InvoiceAPIServiceDef,  4);
	
	foreach ewsActivity in activeWebServiceDef.CM_InvoiceAPIServiceDef.allEWSActivities do
		if ewsActivity.isKindOf(CM_EWSActivityInvoiceAPIParts) then
			self.valConsMsgByServiceRate(ewsActivity);
		endif;
	endforeach;	
	
epilog	
	
	delete bgpInvoiceAPIWSReq;
	delete pxyExtWebServiceDef;
	if services &lt;&gt; null then
		beginTransaction;
		services.purge();
		delete services;
		commitTransaction;
	endif;	
	delete theController;	
	if transientObjs &lt;&gt; null then
		transientObjs.purge();
	endif;
	delete transientObjs;
	beginTransaction;		
		delete invoice;
	commitTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="tQtyRateHook" id="1f52b46e-3e72-4fb1-8e3c-7594e860db65">
        <source>tQtyRateHook();
// cnwma1
// cnwjre1	test par 24024 CCMS 1151
//02/10/2025	navkc1 JIRA 36149 AAT | RotaBox ISO Type and New Attributes - Calculation Type
vars
	qtySource,
	rateSource,
	remarksSource: String;
	chargeCount,
	lineCount,
	lineCount2	: Integer;
	calcType	: CM_CalculationType;
	service		: CM_Service;
	ild			: CM_InvoiceLineDesc;
	invType		: CM_InvoiceDesc;
	invLine		: CM_InvoiceLine;
	charge		: CM_Charge;
	services : CM_ServiceByNameDict;
	start,
	expiry : TimeStamp;
	proxyDebtorRate	: Boolean;
	ignoreEntry : Boolean;
	costs : DecimalArray;
	debtor : CM_DebtorNode;
	debtorRate : CM_DebtorRate;
	rateEntry : CM_RateEntry;
	ti: CM_TrackedItem;
	selectedTypes: CM_CargoBOLTypeSet;
	stopsTable: CM_StopsTable;
	processAreas: IntegerArray;
	invoice	: CM_Invoice;
	opts : CM_AssociationDict;
	auditObject : CM_AuditObject;
	auditStr : String;
	dummyStr : String;

begin
	// delete any old objects
	self.deleteContainer("TEST0000001");
	self.deleteStopsTable(99);
	self.deleteInvoiceLineType("UT_UserHook", FORCED_ERASE);
	self.deleteInvoiceService("UTADDSTOP", FORCED_ERASE);
	self.deleteInvoiceCalcType("UTHOOK");
	self.deleteInvoiceCalcType("UTHMSHOOK");

	// create new instances
	create services transient;
	// hook code doubles the quantity and halves the rate
	qtySource := 'amendQuantity(_cmif : CMIF_CalcTypeQuantityHook) : Real;
vars
	newQty  : Real;
begin
	newQty := 2 * _cmif.origQty;
	return newQty;
	//UT_Invoicing::tQtyRateHook-qtySource
end;';
	rateSource := 'amendRate(_cmif : CMIF_CalcTypeRateHook) : Real;
vars
	newRate : Real;
begin
	newRate := 0.5 * _cmif.origRate;
	return newRate;
	//UT_Invoicing::tQtyRateHook-rateSource
end;';

	remarksSource := 'amendRemarks (_cmif : CMIF_CalcTypeRemarksHook) : String;
vars
	newRemarks : String;
begin
	newRemarks := _cmif.origRemarks;

	return newRemarks;
	//UT_Invoicing::tQtyRateHook-remarksSource
end;';


	invType := self.getInvoiceType("UT_InvType");
	self.assertNotNullMsg(invType, "Invoice type UT_InvType not created");

	calcType := self.addCalculationType(INV_CALC_TYPE_UNITY, "UTHOOK", "Has qty rate hook code", qtySource, rateSource, remarksSource, 0,0,0,0, true, false, false, false,0, null, null);
	self.assertNoTrxErrorsOrWarnings();

	service := self.createInvoiceService("UTADDSTOP", "Add stop", calcType, null);
	self.assertNoTrxErrorsOrWarnings();
	
	services.add(service);
	ild := self.createInvoiceLineType("UT_UserHook", calcType, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	self.tranMapLoadHook();

	// set a rate of $20.00
	create costs transient;
	debtor := self.getRootDebtor();
	costs.add(20.00);
	start.setDate("31/01/2010".Date);
	start.setTime("00:00".Time);
	expiry := null;
	debtorRate := debtor.serviceRates[service];
	if debtorRate = null then
		create debtorRate transient;
		debtorRate.setProxy(service, debtor);
		proxyDebtorRate := true;
		rateEntry := self.addInvoiceRateEntry(debtorRate, start, expiry, ignoreEntry, costs, 0, 0, null, null);
	else
		rateEntry := debtorRate.rateEntries.first;
		self.updateInvoiceRateEntry(debtorRate, rateEntry, start, expiry, ignoreEntry, costs, 0, 0, null,null);
	endif;
	self.assertNoTrxErrorsOrWarnings();

	// create a container and add a stop, to trigger invoice creation
	ti := self.addContainerOpts("TEST0000001", "2200", "APPL", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));	
	create selectedTypes transient;
	selectedTypes.add(app.myRoot.allCargoTypesById[TI_CargoType_Container]);
	create processAreas transient;
	processAreas.add(StopProcessCopyToChild);
	create opts transient;
	opts.addAssoc(ETRow_ProcessStopAreas, processAreas);
	stopsTable := addStopsTable(99, "UT", "Unit Test", selectedTypes, opts);

	addStop(ti, stopsTable);
	
	// in the weekend runs, extra invoice lines are created from CM_StopAdds.  This test is only interested in UT_UserHook lines.
	foreach invLine in ti.invoiceLines do
		if invLine.invoiceLineDesc.narration = "UT_UserHook" then
			lineCount := lineCount + 1;
			// the quantity hook code doubles the quantity from 1 to 2
			self.assertEqualMsg(invLine.quantity, 2.Real, "Invoice line " &amp; lineCount.String &amp; " quantity");
			chargeCount := 0;
			foreach charge in invLine.charges do
				// the rate hook code halves the rate from $20 to $10
				self.assertEqualMsg(charge.getRate, 10.00.Real, "Charge for invoice line " &amp; lineCount.String &amp; " rate");
				chargeCount := chargeCount + 1;
			endforeach;
			self.assertTrueMsg(chargeCount &gt; 0, "At least one charge for invoice line " &amp; lineCount.String);
		elseif invLine.invoiceLineDesc.narration = "UT_ILD02" then
			// TFS 2500 Aug 2016 the hook code doubles the quantity from 1 to 2 for the quantity range calculation as well - it gets UT_ILD01 without this code
			lineCount2 := lineCount2 + 1;
		endif;
	endforeach;
	self.assertTrueMsg(lineCount &gt; 0, "At least one hook code invoice line");
	self.assertTrueMsg(lineCount2 &gt; 0, "At least one invoice line from quantity range");
	
	//04 May 2020	NDL	TFS 49001
	auditObject := calcType.allAuditObjectsForClass.first();
	self.assertTrueMsg( auditObject &lt;&gt; null, "No audit found" );
	auditStr := null;
	auditObject.getOldNewValueForTag( app.getErrorString(Quantity_hook_code), auditStr, dummyStr );
	self.assertTrueMsg( auditStr &lt;&gt; null and auditStr.pos("qtySource",1) &gt; 1, "Hook code for Quantity not found or incomplete in audit text" );
	auditStr := null;
	auditObject.getOldNewValueForTag( app.getErrorString(Rate_hook_code), auditStr, dummyStr );
	self.assertTrueMsg( auditStr &lt;&gt; null and auditStr.pos("rateSource",1) &gt; 1, "Hook code for Rate not found or incomplete in audit text" );
	auditStr := null;
	auditObject.getOldNewValueForTag( app.getErrorString(Remarks_hook_code), auditStr, dummyStr );
	self.assertTrueMsg( auditStr &lt;&gt; null and auditStr.pos("remarksSource",1) &gt; 1, "Hook code for Remarks not found or incomplete in audit text" );
	
	calcType := self.addCalculationType(INV_CALC_TYPE_QUOTED_RATE, "UTHMSHOOK", "Has HMS qty rate hook code", qtySource, rateSource, remarksSource, 0,0,0,0, false, true, false, false,0, null, null);
	
	auditObject := calcType.allAuditObjectsForClass.first();
	self.assertTrueMsg( auditObject &lt;&gt; null, "No audit found" );
	auditStr := null;
	auditObject.getOldNewValueForTag( app.getErrorString(Quantity_hook_code), auditStr, dummyStr );
	self.assertTrueMsg( auditStr &lt;&gt; null and auditStr.pos("qtySource",1) &gt; 1, "Hook code for Quantity not found or incomplete in audit text" );
	auditStr := null;
	auditObject.getOldNewValueForTag( app.getErrorString(Rate_hook_code), auditStr, dummyStr );
	self.assertTrueMsg( auditStr &lt;&gt; null and auditStr.pos("rateSource",1) &gt; 1, "Hook code for Rate not found or incomplete in audit text" );
	auditStr := null;
	auditObject.getOldNewValueForTag( app.getErrorString(Remarks_hook_code), auditStr, dummyStr );
	self.assertTrueMsg( auditStr &lt;&gt; null and auditStr.pos("remarksSource",1) &gt; 1, "Hook code for Remarks not found or incomplete in audit text" );

epilog
	self.resetDefaultTranMap();

	delete services;
	delete costs;
	if proxyDebtorRate then
		delete debtorRate;
	endif;
	delete selectedTypes;
	delete processAreas;
	delete opts;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRateChange" id="a6e6614e-6b8a-42b6-8992-63a8ee5123ab">
        <source>tRateChange();
// cnwma1
// cnwjre1 SFW 1264 Invoice non-virtual fields, test rate change now propogates automatically to invoice lines
//  add rate, update, add second rate and delete again - check after each
// Also set a rate value manually and check that this is NOT changed by the subsequent rate activity
vars
	start,
	expiry : TimeStamp;
	costs : DecimalArray;
	date		: Date;
	debtorName	: String;
	bank 		: CM_Bank;
	service 	: CM_Service;
	debtorRate,
	pxyDebtorRate	: CM_DebtorRate;
	rateEntry98,
 	rateEntry99	: CM_RateEntry;
	debtorNode	: CM_DebtorNode;
	proxyDebtor,
	debtor		: CM_Debtor;
	invType		: CM_InvoiceDesc;
	invLineType	: CM_InvoiceLineDesc;
	debtorNodeController	: CMIF_DebtorNode;
	invoice		: CM_Invoice;
	invoiceLine	: CM_InvoiceLine;
	invoice2	: CM_Invoice;
	controller	: CMIF_InvoiceLineMove;

begin
	bank := app.myRoot.myRootCompany;

	debtorName := "UT_DebtorY1";
	// delete debtor first
	debtorNode := app.myRoot.myRootCompany.debtors[debtorName];
	if debtorNode &lt;&gt; null then
		self.deleteDebtor(debtorNode);
	endif;
	
	// new debtor
	create debtorNodeController transient;
	create proxyDebtor transient;
	self.setDebtorNodeController(debtorName, "600555", "", "", debtorNodeController, proxyDebtor);
	
	app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	debtor := debtorNode.CM_Debtor;
	
	// set up rates for this debtor and UT_Service98 and UT_Service99
	create costs transient;
	create pxyDebtorRate transient;
	service := self.myBank.services['UT_Service98'];
	pxyDebtorRate.setProxy(service, debtor);
	costs.add(12.00);
	start.setDate("01/01/2010".Date);
	start.setTime("00:00".Time);
	expiry := null;
	rateEntry98 := self.addInvoiceRateEntry(pxyDebtorRate, start, expiry, false, costs, 0, 0, null, null);
	
	delete pxyDebtorRate;
	create pxyDebtorRate transient;
	service := self.myBank.services['UT_Service99'];
	pxyDebtorRate.setProxy(service, debtor);
	costs.clear();
	costs.add(6.00);
	start.setDate("01/01/2010".Date);
	start.setTime("00:00".Time);
	expiry := null;
	rateEntry99 := self.addInvoiceRateEntry(pxyDebtorRate, start, expiry, false, costs, 0, 0, null, null);

	// create invoice
	invType := self.getInvoiceType("UT_InvType");
	invoice := self.createManualInvoice(self.myBank, debtor, null, invType, null);
	invLineType := self.getInvoiceLineType("UT_ILD01");
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 10, "Line 1", date);
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 5, "Line 2", date);
	invLineType := self.getInvoiceLineType("UT_ILD02");
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 10, "Line 3", date);
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 5, "Line 4", date);
	invLineType := self.getInvoiceLineType("UT_LineTypeLastLoad");
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 10, "Line 5", date);
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 5, "Line 6", date);
	
	// check the invoice line amounts
	self.validateRateInitial(invoice);
	
	// set the charges on the fourth invoice line to manual values
	self.updateManualRate(invoice);
		
	// change the rates - service98 12.00 to 18.00, service99 6.00 to 9.00
	debtorRate := rateEntry98.rate.CM_DebtorRate;
	costs.clear();
	costs.add(18.00);
	self.updateInvoiceRateEntry(debtorRate, rateEntry98, start, expiry, false, costs, 0, 0, null,null);
	debtorRate := rateEntry99.rate.CM_DebtorRate;
	costs.clear();
	costs.add(9.00);
	self.updateInvoiceRateEntry(debtorRate, rateEntry99, start, expiry, false, costs, 0, 0, null,null);
	
	// check the new invoice line amounts
	self.validateRateChanged1(invoice, 1);
	
	// add a more recent rate - service98 20
	debtorRate := rateEntry98.rate.CM_DebtorRate;
	costs.clear();
	costs.add(20.00);
	start.setDate("01/10/2010".Date);
	start.setTime("00:00".Time);
	expiry := null;
	rateEntry98 := self.addInvoiceRateEntry(debtorRate, start, expiry, false, costs, 0, 0, null, null);
	
	// check the new invoice line amounts
	self.validateRateChanged2(invoice);
	
	// delete the latest rate, revert to the prior rate
	self.deleteInvoiceRateEntry(rateEntry98);
	
	// check the new invoice line amounts
	self.validateRateChanged1(invoice, 3);
	
	// 26/05/2015 cnwmh5 - trxUpdateInvoiceLineMove  - Start
	invoice2 := self.createManualInvoice(self.myBank, debtor, null, invType, null);
	self.assertEqual(invoice2.invoiceLines.size, 0);
	
	create controller transient;
	controller.allInvoiceLines.add(invoice.invoiceLines.first);
	controller.allInvoiceLines.add(invoice.invoiceLines.last);
	controller.myInvoice := invoice2;
	app.myTrxUA.trxUpdateInvoiceLineMove(controller, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(invoice.invoiceLines.size, 4);
	self.assertEqual(invoice2.invoiceLines.size, 2);	
	
	foreach invoiceLine in invoice2.invoiceLines do
		if not invoiceLine.remarks &lt;&gt; "Line 1" and not invoiceLine.remarks &lt;&gt; "Line 3" then
			self.assertEqual(true, true);		
		endif;
	endforeach;	
	// 26/05/2015 cnwmh5 - trxUpdateInvoiceLineMove  - End
	
epilog
	delete proxyDebtor;
	delete debtorNodeController;
	delete costs;
	delete pxyDebtorRate;
	delete controller;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRateEntry" id="6c36a621-716c-44b4-abb5-11d37241e88c">
        <source>tRateEntry();
// cnwma1
// CNWJRE1 
// rate entry create and access
// test 23582
vars
	start,
	expiry : TimeStamp;
	ignoreEntry : Boolean;
	costs : DecimalArray;
	debtorName : String;
	debtor : CM_DebtorNode;
	serviceName : String;
	service : CM_Service;
	debtorRate : CM_DebtorRate;
	rateEntry : CM_RateEntry;
begin
	create costs transient;
	debtorName := "ABCONE";
	debtor := app.myRoot.myRootCompany.debtors[debtorName];
	serviceName := "UT_Service98";
	service := self.myBank.services[serviceName];

	// create a range of rate entries some with expiry and ignore set
	create debtorRate transient;
	debtorRate.setProxy(service, debtor);
	costs.add(120.00);
	start.setDate("01/05/2010".Date);
	start.setTime("00:00".Time);
	expiry := null;
	rateEntry := self.addInvoiceRateEntry(debtorRate, start, expiry, ignoreEntry, costs, 0, 0, null, null);
	delete debtorRate;

	// for the second and subsequent entries, use the persistent rate from the rateEntry created above
	debtorRate := rateEntry.rate.CM_DebtorRate;
	costs.clear;
	costs.add(121.00);
	start.setDate("02/05/2010".Date);
	expiry.setDate("05/05/2010".Date);
	expiry.setTime("23:59".Time);
	rateEntry := self.addInvoiceRateEntry(debtorRate, start, expiry, ignoreEntry, costs, 0, 0, null, null);

	costs.clear;
	costs.add(122.00);
	start.setDate("10/05/2010".Date);
	expiry := null;
	ignoreEntry := true;
	rateEntry := self.addInvoiceRateEntry(debtorRate, start, expiry, ignoreEntry, costs, 0, 0, null, null);

	costs.clear;
	costs.add(123.00);
	start.setDate("12/05/2010".Date);
	expiry := null;
	ignoreEntry := false;
	rateEntry := self.addInvoiceRateEntry(debtorRate, start, expiry, ignoreEntry, costs, 0, 0, null, null);

	start.setDate("15/05/2010".Date);
	rateEntry := debtor.getServiceTimeRate(service, start);
	self.assertEqualMsg(rateEntry.getRawCostPerUnit, 123.Decimal, "15 May rate");	// latest entry
	
	start.setDate("10/05/2010".Date);
	rateEntry := debtor.getServiceTimeRate(service, start);
	self.assertEqualMsg(rateEntry.getRawCostPerUnit, 120.Decimal, "10 May rate");	// skips both the ignore and expired entries
	
	start.setDate("04/05/2010".Date);
	rateEntry := debtor.getServiceTimeRate(service, start);
	self.assertEqualMsg(rateEntry.getRawCostPerUnit, 121.Decimal, "04 May rate");	// within expiry
	
	start.setDate("01/05/2010".Date);
	rateEntry := debtor.getServiceTimeRate(service, start);
	self.assertEqualMsg(rateEntry.getRawCostPerUnit, 120.Decimal, "01 May rate");	// first entry
	
epilog
	delete costs;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tRateEntryAdjustPercent" id="ce5fec59-332d-44e5-89c2-da96aa1838f6">
        <source>tRateEntryAdjustPercent();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2012	cnwndl1	Initial creation	Par 30375

*/

vars
	start,
	expiry : TimeStamp;
	costs : DecimalArray;
	date		: Date;
	debtorName	: String;
	bank 		: CM_Bank;
	
	debtorRate,
	pxyDebtorRate	: CM_DebtorRate;
	
	debtorNode	: CM_DebtorNode;
	proxyDebtor,
	debtor		: CM_Debtor;
	invType		: CM_InvoiceDesc;
	invLineType	: CM_InvoiceLineDesc;
	debtorNodeController	: CMIF_DebtorNode;
	invoice		: CM_Invoice;
	invoiceLine	: CM_InvoiceLine;
	adjust : Decimal[8,4];
	percent : Decimal[8,4];
	parentRate98 : CM_Rate;
	parentRate99 : CM_Rate;
	baseRateEntry : CM_RateEntry;
	rootDebtorGroup : CM_RootDebtorGroup;
	rateEntry : CM_RateEntry;
	baseRateEntry98	: CM_RateEntry;
 	baseRateEntry99	: CM_RateEntry;
	derivedRates : CM_RateEntrySet;
	now : TimeStamp;
	service98 : CM_Service;
	service99 : CM_Service;
	add98 : Boolean;
	upd98 : Boolean;
	add99 : Boolean;
	upd99 : Boolean;
	pxyDebtorRate98 : CM_DebtorRate;
	rate98 : CM_Rate;
	rateEntry98_1 : CM_RateEntry;
	rateEntry98_2 : CM_RateEntry;
	rateEntry98_3 : CM_RateEntry;
	pxyDebtorRate99 : CM_DebtorRate;
	rate99 : CM_Rate;
 	rateEntry99_1 : CM_RateEntry;
 	rateEntry99_2 : CM_RateEntry;
 	rateEntry99_3 : CM_RateEntry;
	invCount : Integer;
	invLine	: CM_InvoiceLine;
	charge : CM_Charge;

begin
	bank := app.myRoot.myRootCompany;
	
	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
		
	debtorName := "UT_DebtorZ1";
	// delete debtor first
	debtorNode := app.myRoot.myRootCompany.debtors[debtorName];
	if debtorNode &lt;&gt; null then
		self.deleteDebtor(debtorNode);
	endif;
	
	// new debtor
	create debtorNodeController transient;
	create proxyDebtor transient;
	self.setDebtorNodeController(debtorName, "555600", "", "", debtorNodeController, proxyDebtor);
	
	app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	debtor := debtorNode.CM_Debtor;
	
	// set up default rates for the Root and UT_Service98 and UT_Service99
	rootDebtorGroup := bank.getRootDebtorGroup;
	create derivedRates transient;
	create costs transient;
	
	create pxyDebtorRate transient;
	service98 := self.myBank.services['UT_Service98'];
	pxyDebtorRate.setProxy(service98, rootDebtorGroup);
	costs.add(10.00);
	start.setDate("01/01/2010".Date);
	start.setTime("00:00".Time);
	expiry := null;
	baseRateEntry98 := rootDebtorGroup.getServiceTimeRate(service98,now);
	if baseRateEntry98 = null then
		add98 := true;
		baseRateEntry98 := self.addInvoiceRateEntry(pxyDebtorRate, start, expiry, false, costs, 0, 0, null, null);
		self.assertTrueMsg( baseRateEntry98 &lt;&gt; null, "Base Rate Entry 98 not created");
	else
		upd98 := true;
		self.updateInvoiceRateEntry(baseRateEntry98.rate, baseRateEntry98, start, expiry, false, costs, 0, 0, null,null);
		self.assertTrueMsg( baseRateEntry98.getRawCostPerUnit = 10.00, "Base Rate Entry 98 not updated");
	endif;
	
	delete pxyDebtorRate;
	create pxyDebtorRate transient;
	service99 := self.myBank.services['UT_Service99'];
	pxyDebtorRate.setProxy(service99, rootDebtorGroup);
	costs.clear();
	costs.add(20.00);
	start.setDate("01/01/2010".Date);
	start.setTime("00:00".Time);
	expiry := null;
	baseRateEntry99 := rootDebtorGroup.getServiceTimeRate(service99,now);
	if baseRateEntry99 = null then
		baseRateEntry99 := self.addInvoiceRateEntry(pxyDebtorRate, start, expiry, false, costs, 0, 0, null, null);
		self.assertTrueMsg( baseRateEntry99 &lt;&gt; null, "Base Rate Entry 99 not created");
		add99 := true;
	else
		self.updateInvoiceRateEntry(baseRateEntry99.rate, baseRateEntry99, start, expiry, false, costs, 0, 0, null,null);
		self.assertTrueMsg( baseRateEntry99.getRawCostPerUnit = 20.00, "Base Rate Entry 99 not updated");
		upd99 := true;
	endif;
	

	// set up derived rates for debtor UT_DebtorZ1 and UT_Service98
	costs.clear();
	costs.add(0.00);
	baseRateEntry := rootDebtorGroup.getServiceTimeRate(service98,start);
	self.assertTrueMsg( baseRateEntry &lt;&gt; null, "Base Rate Entry 98 not found");
	self.assertTrueMsg( baseRateEntry = baseRateEntry98, "Base Rate Entry 98 not the right one");
	parentRate98 := baseRateEntry.rate;
	create pxyDebtorRate98 transient;
	pxyDebtorRate98.setProxy(service98, debtor);
	
	start.setDate("01/03/2010".Date);
	start.setTime("00:00".Time);
	expiry := null;
	adjust := 5.00;
	percent	:= 0.00;
	rateEntry98_1 := self.addInvoiceRateEntry(pxyDebtorRate98, start, expiry, false, costs, adjust, percent, parentRate98, null);
	self.assertTrueMsg( rateEntry98_1 &lt;&gt; null, "Adjustment Rate Entry 98_1 not created");
	derivedRates.add( rateEntry98_1 );
	rate98 := rateEntry98_1.rate;

	start.setDate("01/03/2011".Date);
	start.setTime("00:00".Time);
	expiry.setDate("01/06/2011".Date);
	expiry.setTime("00:00".Time);
	adjust := 10.00;
	percent	:= 0.00;
	rateEntry98_2 := self.addInvoiceRateEntry(rate98, start, expiry, false, costs, adjust, percent, parentRate98, null);
	self.assertTrueMsg( rateEntry98_2 &lt;&gt; null, "Adjustment Rate Entry 98_2 not created");
	derivedRates.add( rateEntry98_2 );
	
	start.setDate("01/03/2012".Date);
	start.setTime("00:00".Time);
	expiry := null;
	adjust := -5.00;
	percent	:= 0.00;
	rateEntry98_3 := self.addInvoiceRateEntry(rate98, start, expiry, false, costs, adjust, percent, parentRate98, null);
	self.assertTrueMsg( rateEntry98_3 &lt;&gt; null, "Adjustment Rate Entry 98_3 not created");
	derivedRates.add( rateEntry98_3 );
	
	
	
	// set up derived rates for debtor UT_DebtorZ1 and  UT_Service99
	costs.clear();
	costs.add(0.00);
	baseRateEntry := rootDebtorGroup.getServiceTimeRate(service99,start);
	self.assertTrueMsg( baseRateEntry &lt;&gt; null, "Base Rate Entry 99 not found");
	self.assertTrueMsg( baseRateEntry = baseRateEntry99, "Base Rate Entry 99 not the right one");
	parentRate99 := baseRateEntry.rate;
	create pxyDebtorRate99 transient;
	pxyDebtorRate99.setProxy(service99, debtor);
	
	start.setDate("01/03/2010".Date);
	start.setTime("00:00".Time);
	expiry := null;
	adjust := 0.00;
	percent	:= 80.00;
	rateEntry99_1 := self.addInvoiceRateEntry(pxyDebtorRate99, start, expiry, false, costs, adjust, percent, parentRate99, null);
	self.assertTrueMsg( rateEntry99_1 &lt;&gt; null, "Percent Rate Entry 99_1 not created");
	derivedRates.add( rateEntry99_1 );
	rate99 := rateEntry99_1.rate;
	
	start.setDate("01/03/2011".Date);
	start.setTime("00:00".Time);
	expiry.setDate("01/06/2011".Date);
	expiry.setTime("00:00".Time);
	adjust := 0.00;
	percent	:= 120.00;
	rateEntry99_2 := self.addInvoiceRateEntry(rate99, start, expiry, false, costs, adjust, percent, parentRate99, null);
	self.assertTrueMsg( rateEntry99_2 &lt;&gt; null, "Percent Rate Entry 99_2 not created");
	derivedRates.add( rateEntry99_2 );
	
	start.setDate("01/03/2012".Date);
	start.setTime("00:00".Time);
	expiry := null;
	adjust := 0.00;
	percent	:= 200.00;
	rateEntry99_3 := self.addInvoiceRateEntry(rate99, start, expiry, false, costs, adjust, percent, parentRate99, null);
	self.assertTrueMsg( rateEntry99_3 &lt;&gt; null, "Percent Rate Entry 99_3 not created");
	derivedRates.add( rateEntry99_3 );


	// create invoice
	invType := self.getInvoiceType("UT_InvType");
	invoice := self.createManualInvoice(self.myBank, debtor, null, invType, null);
	invLineType := self.getInvoiceLineType("UT_ILD01");
	date := "01/02/2010".Date;	// should use base rate
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 1, "Line 1", date);
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 10, "Line 2", date);
	date := "01/04/2010".Date;	// should use Rate Entry 98_1 &amp; Rate Entry 99_1
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 1, "Line 3", date);
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 10, "Line 4", date);
	date := "01/04/2011".Date;	// should use Rate Entry 98_2 &amp; Rate Entry 99_2
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 1, "Line 5", date);
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 10, "Line 6", date);
	date := "01/08/2011".Date;	// should use Rate Entry 98_1 &amp; Rate Entry 99_1
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 1, "Line 7", date);
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 10, "Line 8", date);
	date := "01/04/2012".Date;	// should use Rate Entry 98_3 &amp; Rate Entry 99_3
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 1, "Line 9", date);
	invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 10, "Line 10", date);
	
	
	
	foreach invLine in invoice.invoiceLines do
		invCount := invCount + 1;
		self.assertTrueMsg(invLine.charges.size = 2, "Number of charges on Invoice line " &amp; invCount.String &amp; " incorrect");
		if invCount = 1 or invCount = 2 then
			// should be base rates, date was before the derived rates started
			if invCount = 1 then
				self.assertTrueMsg(invLine.lineTotal = 30, "Expected value of Invoice line " &amp; invCount.String &amp; " incorrect");
			else
				self.assertTrueMsg(invLine.lineTotal = 300, "Expected value of Invoice line " &amp; invCount.String &amp; " incorrect");
			endif;
			self.assertTrueMsg(invLine.charges.first.getRate = 10, "UT_Service98 rate on Invoice line " &amp; invCount.String &amp; " incorrect");
			self.assertTrueMsg(invLine.charges.last.getRate = 20, "UT_Service99 rate on Invoice line " &amp; invCount.String &amp; " incorrect");
		
		elseif invCount = 3 or invCount = 4 or invCount = 7 or invCount = 8 then
			// 3 &amp; 4 should be base rates adjusted ( +5 or 80%) date matches Rate Entry 98_1 &amp; Rate Entry 99_1
			// 7 &amp; 8 because date is after  ( Rate Entry 98_2 &amp; Rate Entry 99_2 ) but before ( Rate Entry 98_3 &amp; Rate Entry 99_3 )
			//       and ( Rate Entry 98_1 &amp; Rate Entry 99_1 ) dont expire, so are still valid.
			if invCount = 3 or invCount = 7 then
				self.assertTrueMsg(invLine.lineTotal = 31, "Expected value of Invoice line " &amp; invCount.String &amp; " incorrect");
			else
				self.assertTrueMsg(invLine.lineTotal = 310, "Expected value of Invoice line " &amp; invCount.String &amp; " incorrect");
			endif;
			self.assertTrueMsg(invLine.charges.first.getRate = 15, "UT_Service98 rate on Invoice line " &amp; invCount.String &amp; " incorrect");
			self.assertTrueMsg(invLine.charges.last.getRate = 16, "UT_Service99 rate on Invoice line " &amp; invCount.String &amp; " incorrect");
		
		elseif invCount = 5 or invCount = 6 then
			// should be base rates, ( +10 or 120%) date matches Rate Entry 98_2 &amp; Rate Entry 99_2
			if invCount = 5 then
				self.assertTrueMsg(invLine.lineTotal = 44, "Expected value of Invoice line " &amp; invCount.String &amp; " incorrect");
			else
				self.assertTrueMsg(invLine.lineTotal = 440, "Expected value of Invoice line " &amp; invCount.String &amp; " incorrect");
			endif;
			self.assertTrueMsg(invLine.charges.first.getRate = 20, "UT_Service98 rate on Invoice line " &amp; invCount.String &amp; " incorrect");
			self.assertTrueMsg(invLine.charges.last.getRate = 24, "UT_Service99 rate on Invoice line " &amp; invCount.String &amp; " incorrect");
		
		elseif invCount = 9 or invCount = 10 then
			// should be base rates, ( -5 or 200%) date matches Rate Entry 98_2 &amp; Rate Entry 99_2
			if invCount = 9 then
				self.assertTrueMsg(invLine.lineTotal = 45, "Expected value of Invoice line " &amp; invCount.String &amp; " incorrect");
			else
				self.assertTrueMsg(invLine.lineTotal = 450, "Expected value of Invoice line " &amp; invCount.String &amp; " incorrect");
			endif;
			self.assertTrueMsg(invLine.charges.first.getRate = 5, "UT_Service98 rate on Invoice line " &amp; invCount.String &amp; " incorrect");
			self.assertTrueMsg(invLine.charges.last.getRate = 40, "UT_Service99 rate on Invoice line " &amp; invCount.String &amp; " incorrect");

		endif;
	
	endforeach;
	
	// change the rates and check again.
	start.setDate("01/03/2011".Date);
	start.setTime("00:00".Time);
	expiry := null;
	adjust := 10.00;
	percent	:= 0.00;
	self.updateInvoiceRateEntry(rate98, rateEntry98_2, start, expiry, false, costs, adjust, percent, parentRate98,null);
	self.assertTrueMsg( rateEntry98_2.expiryTimestamp = null, "Adjustment Rate Entry 98_2 expiry not updated");
	
	adjust := 0.00;
	percent	:= 120.00;
	self.updateInvoiceRateEntry(rate99, rateEntry99_2, start, expiry, false, costs, adjust, percent, parentRate99,null);
	self.assertTrueMsg( rateEntry99_2.expiryTimestamp = null, "Percent Rate Entry 99_2 expiry not updated");
	
	start.setDate("01/03/2012".Date);
	start.setTime("00:00".Time);
	adjust := 0.00;
	percent	:= 150.00;
	self.updateInvoiceRateEntry(rate99, rateEntry99_3, start, expiry, false, costs, adjust, percent, parentRate99,null);
	self.assertTrueMsg( rateEntry99_3.percentageOfBase = 150, "Percent Rate Entry 99_3 not updated");
	
	
	foreach invLine in invoice.invoiceLines do
		invCount := invCount + 1;
		self.assertTrueMsg(invLine.charges.size = 2, "Number of charges on Invoice line " &amp; invCount.String &amp; " incorrect");
		if invCount = 1 or invCount = 2 then
			// should be base rates, date was before the derived rates started
			if invCount = 1 then
				self.assertTrueMsg(invLine.lineTotal = 30, "Expected value of Invoice line " &amp; invCount.String &amp; " incorrect");
			else
				self.assertTrueMsg(invLine.lineTotal = 300, "Expected value of Invoice line " &amp; invCount.String &amp; " incorrect");
			endif;
			self.assertTrueMsg(invLine.charges.first.getRate = 10, "UT_Service98 rate on Invoice line " &amp; invCount.String &amp; " incorrect");
			self.assertTrueMsg(invLine.charges.last.getRate = 20, "UT_Service99 rate on Invoice line " &amp; invCount.String &amp; " incorrect");
		
		elseif invCount = 3 or invCount = 4 then
			// 3 &amp; 4 should be base rates adjusted ( +5 or 80%) date matches Rate Entry 98_1 &amp; Rate Entry 99_1
			if invCount = 3 then
				self.assertTrueMsg(invLine.lineTotal = 31, "Expected value of Invoice line " &amp; invCount.String &amp; " incorrect");
			else
				self.assertTrueMsg(invLine.lineTotal = 310, "Expected value of Invoice line " &amp; invCount.String &amp; " incorrect");
			endif;
			self.assertTrueMsg(invLine.charges.first.getRate = 15, "UT_Service98 rate on Invoice line " &amp; invCount.String &amp; " incorrect");
			self.assertTrueMsg(invLine.charges.last.getRate = 16, "UT_Service99 rate on Invoice line " &amp; invCount.String &amp; " incorrect");
		
		elseif invCount = 5 or invCount = 6 or invCount = 7 or invCount = 8 then
			// should be base rates, ( +10 or 120%) date matches Rate Entry 98_2 &amp; Rate Entry 99_2  ( they no longer expire so are still valid for this one.)
			if invCount = 5 or invCount = 7 then
				self.assertTrueMsg(invLine.lineTotal = 44, "Expected value of Invoice line " &amp; invCount.String &amp; " incorrect");
			else
				self.assertTrueMsg(invLine.lineTotal = 440, "Expected value of Invoice line " &amp; invCount.String &amp; " incorrect");
			endif;
			self.assertTrueMsg(invLine.charges.first.getRate = 20, "UT_Service98 rate on Invoice line " &amp; invCount.String &amp; " incorrect");
			self.assertTrueMsg(invLine.charges.last.getRate = 24, "UT_Service99 rate on Invoice line " &amp; invCount.String &amp; " incorrect");
		
		elseif invCount = 9 or invCount = 10 then
			// should be base rates, ( -5 or 150%) date matches Rate Entry 98_2 &amp; Rate Entry 99_2
			if invCount = 9 then
				self.assertTrueMsg(invLine.lineTotal = 35, "Expected value of Invoice line " &amp; invCount.String &amp; " incorrect");
			else
				self.assertTrueMsg(invLine.lineTotal = 350, "Expected value of Invoice line " &amp; invCount.String &amp; " incorrect");
			endif;
			self.assertTrueMsg(invLine.charges.first.getRate = 5, "UT_Service98 rate on Invoice line " &amp; invCount.String &amp; " incorrect");
			self.assertTrueMsg(invLine.charges.last.getRate = 30, "UT_Service99 rate on Invoice line " &amp; invCount.String &amp; " incorrect");

		endif;
	
	endforeach;

epilog

	if derivedRates &lt;&gt; null then
		foreach rateEntry in derivedRates do
			self.deleteInvoiceRateEntry( rateEntry );
		endforeach;
		delete derivedRates;
	endif;
	if add98 then
		self.deleteInvoiceRateEntry( baseRateEntry98 );
	elseif upd98 then
		costs.clear();
		costs.add(0.00);
		self.updateInvoiceRateEntry(baseRateEntry98.rate, baseRateEntry98, now, null, false, costs, 0, 0, null,null);
	endif;
	if add99 then
		self.deleteInvoiceRateEntry( baseRateEntry99 );
	elseif upd99 then
		costs.clear();
		costs.add(0.00);
		self.updateInvoiceRateEntry(baseRateEntry99.rate, baseRateEntry99, now, null, false, costs, 0, 0, null,null);
	endif;
	delete proxyDebtor;
	delete debtorNodeController;
	delete costs;
	delete pxyDebtorRate;
	delete pxyDebtorRate98;
	delete pxyDebtorRate99;
end;</source>
    </JadeMethod>
    <JadeMethod name="tReeferDaily" id="5276a792-f286-45d9-ac95-f36130b13dcb">
        <updating/>
        <source>tReeferDaily() updating;
// cnwma1
// cnwjre1
/* ---------------------------------------------------------------------------
Created:     Mar 2011

Purpose:     Check contact 27000, reefer daily monitoring using days since ship start calculation type
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	date	: Date;
	ts		: TimeStamp;
	cargoMap	: CM_TranMap;
	theService : CM_Service;
	calType1		: CM_CalculationType;
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2,
	invLineType3,
	invLineType4  	: CM_InvoiceLineDesc;
	services : CM_ServiceByNameDict;
	bs: CM_BlockStack;
	termArea	: CM_TerminalArea;
	loc		: CM_LocationsController;
	grid : CM_GridController;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
begin

	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

	self.deleteTransactionMaps();

	// reefer area
	self.deleteTerminalArea("CTEST1");
	termArea := self.addRTGArea("CTEST1",2,2,2);
	foreach loc in termArea.allLocationsControllers where loc.isKindOf(CM_GridController) do
		grid := loc.CM_GridController;
	endforeach;

	// block stack
	bs:= self.getTerminalArea("UTSTORE").CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	termArea:= self.getTerminalArea("CTEST1").CM_RTGArea;
	if termArea &lt;&gt; null then
		foreach loc in termArea.allLocationsControllers do
			self.deleteInvoiceLines(loc);
		endforeach;
	endif;
	self.deleteInvoiceTransactionMap(1, 'UT_Reefer');
	self.deleteInvoiceType("UT_InvTypeStore");
	self.deleteInvoiceService("UT_ServiceStore1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore3", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore4", FORCED_ERASE);

	create services transient;

	////////////////////////////////////////////////////////////////////
	// Create Invoice Type, Services and Invoice Line Type
	////////////////////////////////////////////////////////////////////
	invType := self.createInvoiceType("UT_InvTypeStore", InvoiceTypeStorage);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeStore not created");

	calType1 := app.myRoot.allCalculationTypesByCode['CCT02'];	// INV_CALC_TYPE_TRANSQUANTITY
	self.assertNotNullMsg(calType1, "Calculation type INV_CALC_TYPE_TRANSQUANTITY not found");
	
	
	theService := self.createInvoiceService("UT_ServiceStore1","UT Store1", calType1, null);
	self.assertNotNullMsg(theService, "UT_ServiceStore1 not created");
 	services.add(theService);
	
	invLineType1 := self.createInvoiceLineType("UT_LineTypeStore1", calType1, invType, services,"SDT1");
	invLineType2 := self.createInvoiceLineType("UT_LineTypeStore2", calType1, invType, services,"SDT1");
	invLineType3 := self.createInvoiceLineType("UT_LineTypeStore3", calType1, invType, services,"SDT1");
	invLineType4 := self.createInvoiceLineType("UT_LineTypeStore4", calType1, invType, services,"SDT1");
	
	self.assertNotNullMsg(invLineType1, "UT_LineTypeStore1 not created");
	self.assertNotNullMsg(invLineType2, "UT_LineTypeStore2 not created");
	self.assertNotNullMsg(invLineType3, "UT_LineTypeStore3 not created");
	self.assertNotNullMsg(invLineType4, "UT_LineTypeStore4 not created");

	// Need to map to above invoice line types, using quantity ranges
	self.tranMapLoadReefer();
	
	// create a container with retrospective transactions (refer example on PAR 24160)
	voy:=self.createVesselVoyage3();
	aPort := app.myRoot.allPorts["NZAKL"];


	// Create Reefer Daily Transaction
	cargo := self.createReefer("UACU7894561", grid);
	beginTransaction;
	cargo.setMyVoyage(voy, app.myPassport);
	commitTransaction;

	// base date 24/01/2011, reefer monitor 24/03/2011 but ship start date 04/01/2011 so 80 days not 60
	date.setDate(4,1,2011);
	ts.setDate(date);
	beginTransaction;
	voy.setPropertyValue("shipExchangeDate", ts);
	commitTransaction;

	self.createReeferTransactions(cargo);
	self.validateReeferTransactions(cargo, false);

	
epilog
	delete services;
	termArea:= self.getTerminalArea("CTEST1").CM_RTGArea;
	if termArea &lt;&gt; null then
		foreach loc in termArea.allLocationsControllers do
			self.deleteInvoiceLines(loc);
		endforeach;
	endif;
	// delete this tran map so following tests can delete the invoice line descs etc
	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);
	self.deleteInvoiceTransactionMap(1, 'UT_Reefer');
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tReeferDailyFromRelease" id="c21bc1dd-1bb9-4759-9282-ab2f60d6a9e3">
        <updating/>
        <source>tReeferDailyFromRelease() updating;
// cnwma1
// cnwjre1
/* ---------------------------------------------------------------------------
Created:     Sep 2013

Purpose:     From contact 32416, checking the charging of reefer connect/disconnect and automatic reefer daily from release.
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	date	: Date;
	ts		: TimeStamp;
	cargoMap	: CM_TranMap;
	theService : CM_Service;
	debtorType	: CM_DebtorType;
	calType1		: CM_CalculationType;
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2,
	invLineType3,
	invLineType4  	: CM_InvoiceLineDesc;
	services : CM_ServiceByNameDict;
	bs: CM_BlockStack;
	termArea	: CM_TerminalArea;
	loc		: CM_LocationsController;
	grid : CM_GridController;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
    noImportStops :Boolean;
begin
    noImportStops := self.getTerminalConfig(NoImportStops).Boolean;
    self.setTerminalConfig(NoImportStops, false);

	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

	invType := self.getInvoiceType("UT_InvType");
	self.addIfNewServiceILD("UT_ServReeferPlugUnplug", "CCT01", "UT_ILTReeferPlugUnplug", null, invType);
	self.addIfNewServiceILD("UT_ServReeferPower", "CCT09", "UT_ILTReeferPower", null, invType);
	invLineType1 := self.myBank.invoiceLineDescriptors["UT_ILTReeferPlugUnplug"];
	invLineType2 := self.myBank.invoiceLineDescriptors["UT_ILTReeferPower"];
	debtorType := app.myRoot.allDebtorTypes["SDT6"];	// customs agent
	beginTransaction;
	invLineType1.setPropertyValue("myDebtorType", debtorType);
	invLineType2.setPropertyValue("myDebtorType", debtorType);
	commitTransaction;
	
	self.tranMapLoadReefer2();
	
	self.createImportCargo(false);
epilog
	self.setTerminalConfig(NoImportStops, noImportStops);
	// delete this tran map so following tests can delete the invoice line descs etc
	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);
	self.deleteInvoiceTransactionMap(1, 'UT_Reefer');
	self.resetDefaultTranMap();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tResyncQuantity" id="45302a36-689f-4f3c-8026-6218700321d2">
        <updating/>
        <source>tResyncQuantity() updating;
// cnwma1
// cnwjre1
/* ---------------------------------------------------------------------------
Created:     Mar 2011

Purpose:     test 27193 update invoice line quantity on resync after changing quantity ranges in transaction map
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	cargoMap	: CM_TranMap;
	theService  : CM_Service;
	calType1		: CM_CalculationType;
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2,
	invLineType3,
	invLineType4  	: CM_InvoiceLineDesc;
	services : CM_ServiceByNameDict;
	bs: CM_BlockStack;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
begin

	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

	bs:= self.getTerminalArea("UTSTORE").CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	self.deleteTerminalArea("UTSTORE");
	self.deleteInvoiceTransactionMap(1, 'UT_Storage');
	self.deleteInvoiceType("UT_InvTypeStore");
	self.deleteInvoiceService("UT_ServiceStore1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore3", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore4", FORCED_ERASE);

	create services transient;

	////////////////////////////////////////////////////////////////////
	// Create Invoice Type, Services and Invoice Line Type
	////////////////////////////////////////////////////////////////////
	invType := self.createInvoiceType("UT_InvTypeStore", InvoiceTypeStorage);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeStore not created");

	calType1 := app.myRoot.allCalculationTypesByCode['CCT06'];	// INV_CALC_TYPE_DAYS_SINCE_RECVL;
	self.assertNotNullMsg(calType1, "Calculation type INV_CALC_TYPE_DAYS_SINCE_RECVL not found");
	
	
	theService := self.createInvoiceService("UT_ServiceStore1","UT Store1", calType1, null);
	self.assertNotNullMsg(theService, "UT_ServiceStore1 not created");
 	services.add(theService);
	
	invLineType1 := self.createInvoiceLineType("UT_LineTypeStore1", calType1, invType, services,"SDT1");
	invLineType2 := self.createInvoiceLineType("UT_LineTypeStore2", calType1, invType, services,"SDT1");
	invLineType3 := self.createInvoiceLineType("UT_LineTypeStore3", calType1, invType, services,"SDT1");
	invLineType4 := self.createInvoiceLineType("UT_LineTypeStore4", calType1, invType, services,"SDT1");
	
	self.assertNotNullMsg(invLineType1, "UT_LineTypeStore1 not created");
	self.assertNotNullMsg(invLineType2, "UT_LineTypeStore2 not created");
	self.assertNotNullMsg(invLineType3, "UT_LineTypeStore3 not created");
	self.assertNotNullMsg(invLineType4, "UT_LineTypeStore4 not created");

	// Need to map to above invoice line types, using quantity ranges
	self.tranMapLoadStorage();
	
	// create a container with retrospective transactions (refer example on PAR 24160)
	voy:=self.createVesselVoyage3();
	aPort := app.myRoot.allPorts["NZAKL"];
	bs:= addBlockStack("UTSTORE", 100, null);


	// Create Storage Transactions
	cargo := self.addContainerAtLocnDisch("STOR2077441", "2200", "MT", TI_IMEX_STATUS_IMPORT, bs.myLocationsController, aPort, voy);
	self.createStorageTransactions13(cargo);
	self.tranMapReloadStorage();
	self.reevalStorageTrans(cargo);
	self.validateStorageTransactions13(cargo);

	
epilog
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
	delete services;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tResyncQuantity02" id="0e0bda8c-dfef-43e0-9ec0-ed0dfe436cc3">
        <updating/>
        <source>tResyncQuantity02() updating;
 // ### JIRA 35228 11JUL2025 NAVAB1
vars
	cargoMap	: CM_TranMap;
	theService  : CM_Service;
	calType1		: CM_CalculationType;
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2,
	invLineType3,
	invLineType4  	: CM_InvoiceLineDesc;
	services : CM_ServiceByNameDict;
	bs: CM_BlockStack;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
	trans : CM_TITransaction;
begin
	self.setTerminalConfig(FinancialsEnabled, false);

	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

	bs:= self.getTerminalArea("UTSTORE").CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	self.deleteTerminalArea("UTSTORE");
	self.deleteInvoiceTransactionMap(1, 'UT_Storage');
	self.deleteInvoiceType("UT_InvTypeStore");
	self.deleteInvoiceService("UT_ServiceStore1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore3", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore4", FORCED_ERASE);

	create services transient;

	////////////////////////////////////////////////////////////////////
	// Create Invoice Type, Services and Invoice Line Type
	////////////////////////////////////////////////////////////////////
	invType := self.createInvoiceType("UT_InvTypeStore", InvoiceTypeStorage);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeStore not created");

	calType1 := app.myRoot.allCalculationTypesByCode['CCT06'];	// INV_CALC_TYPE_DAYS_SINCE_RECVL;
	self.assertNotNullMsg(calType1, "Calculation type INV_CALC_TYPE_DAYS_SINCE_RECVL not found");
	
	
	theService := self.createInvoiceService("UT_ServiceStore1","UT Store1", calType1, null);
	self.assertNotNullMsg(theService, "UT_ServiceStore1 not created");
 	services.add(theService);
	
	invLineType1 := self.createInvoiceLineType("UT_LineTypeStore1", calType1, invType, services,"SDT1");
	invLineType2 := self.createInvoiceLineType("UT_LineTypeStore2", calType1, invType, services,"SDT1");
	invLineType3 := self.createInvoiceLineType("UT_LineTypeStore3", calType1, invType, services,"SDT1");
	invLineType4 := self.createInvoiceLineType("UT_LineTypeStore4", calType1, invType, services,"SDT1");
	
	self.assertNotNullMsg(invLineType1, "UT_LineTypeStore1 not created");
	self.assertNotNullMsg(invLineType2, "UT_LineTypeStore2 not created");
	self.assertNotNullMsg(invLineType3, "UT_LineTypeStore3 not created");
	self.assertNotNullMsg(invLineType4, "UT_LineTypeStore4 not created");

	// Need to map to above invoice line types, using quantity ranges
	self.tranMapLoadStorage();
	
	// create a container with retrospective transactions (refer example on PAR 24160)
	voy:=self.createVesselVoyage3();
	aPort := app.myRoot.allPorts["NZAKL"];
	bs:= addBlockStack("UTSTORE", 100, null);


	// Create Storage Transactions
	cargo := self.addContainerAtLocnDisch("STOR2077441", "2200", "MT", TI_IMEX_STATUS_IMPORT, bs.myLocationsController, aPort, voy);
	trans := self.createStorageTransactions13(cargo);
	self.assertTrueMsg(trans.allInvoiceLines.isEmpty, "Transaction Should Not Have an Invoice Line");
	

	
epilog
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
	delete services;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tSAL52163Invoice" id="aebc2d8c-6d35-4d1c-8c4e-7488ddde73dc">
        <source>tSAL52163Invoice();
/*

Purpose:			
		1- Create invoice Line Description with 200 narration
		2- Convert Invoice line type
Parameters:			

Return Value:		

Date		Who		Reason
28 Oct 2021 navma1 ChangeRequest 52163: SAL - Unicode Arabic Support Business Requirements

*/
constants
	BS1					: String = "UT_SAL521631";
	BS2					: String = "UT_SAL521632";
	TI1					: String = "UT_521631";
	TI2					: String = "UT_521632";
	InvoiceType		    : String = "UT_SAL521631";
	DebtorName			: String = "UT_SAL521631";
	InvoiceServiceId	: String = "UT_SAL521631";
	Narration1 			: String = "Invoice Line1 - Will be used to Test change Request 52163 SAL - Unicode Arabic Support Business Requirements,52001 SAL - SD Unicode Database Requirements - Arabic Support v_0.2,52001 SAL - SD-Unicode";
	Narration2 			: String = "Invoice Line2 - Will be used to Test change Request 52163 SAL - Unicode Arabic Support Business Requirements,52001 SAL - SD Unicode Database Requirements - Arabic Support v_0.2,52001 SAL - SD-Unicode";
vars
	invLineDesc1		: CM_InvoiceLineDesc;
	invLineDesc2		: CM_InvoiceLineDesc;
	invType				: CM_InvoiceDesc;
	debtor				: CM_Debtor;		
	service				: CM_Service;
	calcType			: CM_CalculationType;
	services			: CM_ServiceByNameDict;
	bs1					: CM_BlockStack;
	ti1,ti2				: CM_TrackedItem;
	operator			: CM_Operator;
	invLine1,
	invLine2			: CM_InvoiceLine;
	invoice				: CM_Invoice;
	terminal			: CM_Terminal;
begin
	
	/*
	0 -  Preparing 
	*/
	terminal := self.getTerminal();
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	calcType := app.myRoot.allCalculationTypesByCode["CCT00"];
	self.assertNotNull(calcType);
	
	self.deleteTerminalArea(BS1);
	bs1 := self.addBlockStack(BS1,999,null);
	self.assertNotNull(bs1);
	
	ti1 := self.addContainerAtLocation( TI1, operator, "2200", "GENL", TI_IMEX_STATUS_STORAGE, bs1.myLocationsController);
	ti2 := self.addContainerAtLocation( TI2, operator, "2200", "GENL", TI_IMEX_STATUS_STORAGE, bs1.myLocationsController);
	/*
	1 - Add Debtor
	*/
	debtor := operator.debtor;
	self.assertNotNull(debtor);
	
	
	/*
	2- Add Invoice Type
	*/
	self.deleteInvoiceTypeOnly(InvoiceType);
	invType := self.createInvoiceType(InvoiceType, InvoiceTypeGeneral);
	self.assertNotNull(debtor);
	
	/*
	3- Add SERVICE
	*/
	create services transient;
	self.deleteService(InvoiceServiceId);
	service := self.createInvoiceService(InvoiceServiceId,null, calcType, null);
	self.setServiceRate(service, debtor, "01/01/2021".Date, 300.00);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(service);
	services.add(service);
	
	
	/*
	4- Add Invoice Line Desc
	*/
	self.deleteInvoiceLineType(Narration1,FORCED_ERASE);
	invLineDesc1 := self.createInvoiceLineType(Narration1,calcType,invType,services,"SDT11");
	self.assertNotNull(invLineDesc1);
	self.deleteInvoiceLineType(Narration2,FORCED_ERASE);
	invLineDesc2 := self.createInvoiceLineType(Narration2,calcType,invType,services,"SDT11");
	self.assertNotNull(invLineDesc2);
	
	
	/*
	5 - Add Manual invoice Line 
	*/
	invoice  := self.createManualInvoice(self.myBank, debtor, null, invType, null);
	invLine1 := self.createManualInvoiceLine(invLineDesc1, invoice, 10,Narration1 , app.cnGetServerTime().date);
	invLine2 := self.createManualInvoiceLine(invLineDesc2, invoice, 5, Narration2, app.cnGetServerTime().date);
	self.assertEqual(invoice.invoiceLines.size, 2);
	
	/*
	6- Convert Invoice Line Desc 
	*/
	
	self.xTrxUpdateInvoiceLineConvert(invoice, invLineDesc2);
	self.assertEqual(invoice.invoiceLines.first.invoiceLineDesc, invLineDesc2);
	
	
epilog
	self.setDebtorCashOnly(debtor, terminal, false);
	delete services;
end;</source>
    </JadeMethod>
    <JadeMethod name="tSTWO50821" id="5d579759-cb6c-41a4-a12a-42ce39a614ea">
        <updating/>
        <source>tSTWO50821()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2021	navma1	Bug 50821: STWO - 1- Calculate storage/ demurrage charges for all cargo discharged from a vessel either Import or Transshipment.
10 September 2023 navmv20 CR 58250 Task 58252: Jade - New mapping methods

*/
constants
 VesselCodeString1 = "508212UT_ZGC1";
 VesselCodeString2 = "50821UT_ZGC2";
 VOYAGE1 		   = "VOY-50821-1";
 VOYAGE2 		   = "VOY-50821-2";
 CARGO1  		   = "CARGO50821-1";
 CARGO2            = "CARGO50821-2";
 CARGO3            = "CARGO50821-3";
 CARGO4  		   = "CARGO50821-4";

vars
	vessel1,
	vessel2     : CM_Vessel;
	voyage1,
	voyage2		: CM_Voyage;
	ts,
	glDate1,
	glDate2,
	ata,
	atd         : TimeStamp;
	bs1         : CM_BlockStack;
	cargoType   : CM_CargoType;
	lc			: CM_LocationsController;
	height      : Integer;
	ti1,         
	ti2,
	ti3,
	ti4         	: CM_TrackedItem;
	controller		: CMIF_TranshipTIController;
	storageConfig   : CM_StorageConfig;
	shipRecvType    : Integer;
	storageExpDetail : CM_StorageExpiryDetail; ///14/09/2023 navmv20 CR 58250 Task 58252
begin
	vessel1 	:= self.addVesselWithHolds(VesselCodeString1, 2, 2);
	vessel2 	:= self.addVesselWithHolds(VesselCodeString2, 2, 2);
	bs1     	:= self.addBlockStack("UTBS50821", 9999, null);
	ata 		:= app.actualTimeServer;
	atd 		:= app.actualTimeServer;
	cargoType 	:= app.myRoot.getCargoTypeFromAbbrev("UTREBAR");
	
	
	//Create Voyage1
	voyage1 := self.addVoyageWithGeneralCargoStruc(VOYAGE1, vessel1.name, vessel1.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);	
	beginTransaction;
		ata.setDate (ata.date+1);
		voyage1.setArrivalDT(ata);
		atd.setDate (atd.date+4);		
		voyage1.setDepartureDT(atd);
		glDate1.setDate(ata.date+2);
		voyage1.setGeneralLandingDate(glDate1.Date);
	commitTransaction;
	self.assertTrueMsg( voyage1.getGeneralLandingDate(true)= glDate1.Date,"GL Date Voyage1 is not correct");
	
	
	
	//Create Voyage1
	voyage2 := self.addVoyageWithGeneralCargoStruc(VOYAGE2, vessel2.name, vessel2.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);	
	beginTransaction;
		ata.setDate (ata.date+4);
		voyage2.setArrivalDT(ata);
		atd.setDate (atd.date+8);		
		voyage2.setDepartureDT(atd);
		glDate2.setDate(ata.date+6);
		voyage2.setGeneralLandingDate(glDate2.Date);
	commitTransaction;
	self.assertTrueMsg( voyage2.getGeneralLandingDate(true)= glDate2.Date,"GL Date Voyage2 is not correct");
	
	
	// Check Import GL Date 
	self.getTerminal.findLocationFromString(VOYAGE1&amp;" 0101", true, lc, height); 
	deleteCargo(CARGO1, cargoType);
	ti1 := self.addCargoBreakBulkAtLocation(CARGO1, cargoType, 50, lc, null, TI_IMEX_STATUS_IMPORT, voyage1, vessel1.myOperator);
	self.assertTrueMsg( ti1.generalLandingDate = glDate1.Date,"Cargo1 GL Date is not correct");
	
	// Check Export GL Date 
	deleteCargo(CARGO2, cargoType);
	ti2 := self.addCargoBreakBulkAtLocation(CARGO2, cargoType, 50, lc, null, TI_IMEX_STATUS_EXPORT, voyage2, vessel2.myOperator);
	self.assertTrueMsg( ti2.generalLandingDate = null,"Cargo2 GL Date is not correct");
	
	
	//Check Tranship GL Date
	deleteCargo(CARGO3, cargoType);
	ti3 := self.addCargoBreakBulkAtLocation(CARGO3, cargoType, 50, lc, null, TI_IMEX_STATUS_IMPORT, voyage1, vessel1.myOperator);
	self.assertTrueMsg( ti1.generalLandingDate = glDate1.Date,"Cargo1 GL Date is not correct");

	moveBulk(ti3, bs1, 50);
	self.assertTrueMsg( ti3.locationId = "UTBS50821","Cargo3 is not at yard");
	
	//Make Cargo3 Tranship on Voyage2
	delete controller;
	create controller transient;
	controller.allTrackedItems.add(ti3);
	controller.myExportDestPort 	:= app.myRoot.allPorts['NZAKA'];
	controller.myExportDisPort 		:= app.myRoot.allPorts['NZAKL'];
	controller.myExportVoyage 		:= voyage2;
	controller.remarks 				:= "UT Tranship";
	self.makeTrackedItemTranship(controller);
	self.assertTrueMsg( ti3.myVoyage = voyage2,"Cargo3 is not a Tranship");
	self.assertTrueMsg( ti3.generalLandingDate = glDate1.Date,"Cargo3 GL Date is not correct");
	
	storageExpDetail := ti3.getStorageExpiryDetail();
	if storageExpDetail &lt;&gt; null then
		ts := storageExpDetail.freeStorageExpiry;
	endif;
	
	self.assertTrueMsg( ts.Date = app.actualTimeServer.Date,"getLastFreeStorage is not correct");
	
	storageConfig := self.getMyTerminal.myStorageConfig;
	if storageConfig &lt;&gt; null then
		shipRecvType := storageConfig.shipReceivalType;
		beginTransaction;
			storageConfig.setPropertyValue("shipReceivalType",Voyage_General_Landing);
		commitTransaction;
		self.assertTrueMsg( storageConfig.shipReceivalType = Voyage_General_Landing,"Storage Config setting is not correct");
		ts := ti3.deriveFreeStorageDateTime(); // ### TFS BUG 60548 09OCT2023 NAVAB1 getLastFreeStorageDateTime();
	endif;
	self.assertTrueMsg( ts.Date = glDate1.Date,"getLastFreeStorage using GL Setting is not correct");
	
epilog
	delete controller;
	
	if storageConfig &lt;&gt; null  then
		beginTransaction;
		storageConfig.setPropertyValue("shipReceivalType",shipRecvType);
		commitTransaction;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="tSTWO51218" id="c6a46a12-6692-42aa-8f20-2b136a504d59">
        <source>tSTWO51218();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 May 2021 cnwma1  	Bug 51218:  STWO - Cargo data missing in invoice export
26 Apr 2023 navnmk20	Bug 57663: EUP - Incorrect Statuses Available when copying an invoice
23 May 2023 navtnr20 	Bug 58089: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 070.b
*/
constants
	CONTID  	= "APZU255201"; 
	CARGOID 	= "UT55201-01";
	BS      	= "UTBS51218";
	BOL1    	= "UTBOL51218-1";
	BOL2    	= "UTBOL51218-2";
	VESSEL  	= "UTVSL51218";
	VOYAGE  	= "UTVOY51218";
	DEBTORNAME  = "UTDEB51218";
vars
	bs1 			: CM_BlockStack;
	cargoType   	: CM_CargoType;
	cont,
	cargo1			: CM_TrackedItem;
	operator    	: CM_Operator;
	terminal        : CM_Terminal;
	vessel          : CM_Vessel;
	voyage          : CM_Voyage;
	bol1,
	bol2			: CM_BOL;
	aPort		    : CM_Port;
	lc              : CM_LocationsController;
	product         : CM_Product;
	cargoMap	    : CM_TranMap;
	calType1        : CM_CalculationType;
	invType         : CM_InvoiceDesc;
	ild			    : CM_InvoiceLineDesc;
	services 		: CM_ServiceByNameDict;
	service 		: CM_Service;
	bu              : CM_Bank;
	realInvoice,
	pxyInvoice      : CM_Invoice;
	pxyInvLine,
	invLine1,
	invLine2        : CM_InvoiceLine;
	ioClassActual 	: CM_ExtFinanceIO;
	ioClassForTest  : CM_STWRInterface;
	origPath        : String;
	debtorNode      : CM_DebtorNode;
	debtor          : CM_Debtor;
begin
	
	ioClassActual := self.getTerminalConfig(FinancialIOClass).CM_ExtFinanceIO;
	
	ioClassForTest := CM_STWRInterface.firstInstance().CM_STWRInterface;
	if ioClassForTest = null then	
		ioClassForTest := app.myTrxCA.trxCreateExternalFinanceClass(CM_STWRInterface).CM_STWRInterface;
	endif;
	if ioClassForTest &lt;&gt; null then	
		self.setTerminalConfig(FinancialIOClass,ioClassForTest);
		origPath := ioClassForTest.exportPath;
		beginTransaction;
		ioClassForTest.exportPath := "..\c_misc\";
		commitTransaction;
	endif;
	
	bs1     		:= self.addBlockStack(BS, 9999, null);
	cargoType 		:= app.myRoot.getCargoTypeFromAbbrev("UTNSCT");
	product         := cargoType.allProducts.first;
	operator 		:= self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	terminal		:= self.getTerminal();
	vessel 			:= self.addVesselWithHolds(VESSEL, 2, 2);
	voyage 			:= self.addVoyageWithGeneralCargoStruc(VOYAGE, vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	aPort 			:= app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	calType1 		:= app.myRoot.allCalculationTypesByCode['CCT00'];
	
	beginTransaction;
	voyage.setGeneralLandingDate(voyage.arrivedDT.Date.addDays(1));
	commitTransaction;
	
	self.deleteContainer(CONTID);
	self.deleteCargo(CARGOID, cargoType);

	
	cont := self.addContainerOnShip( CONTID , operator, "2200", "GENL", null, voyage, aPort.code, voyage.code);
	self.assertNotNull(cont);
	self.opts.addAssoc("Description", "CargoDesc1");
	self.opts.addAssoc("ClientRef",  "ClientRef21");
	self.opts.addAssoc("Consignee",  "UTDDC");
	self.opts.addAssoc("Consignor",  "UTMO1");
	self.updateTI(cont);
	
	self.deleteBOL(BOL1, null);

	bol1 := self.addBOL(BOL1, voyage, operator, null, terminal );
	
	lc := voyage.myShipBlockStack;
	//create cargo on ship
	self.opts.addAssoc("Product", product);
	self.opts.addAssoc("TotalQuantity",50); 
	cargo1 := lc.createNewCargoForLCDetailed(cargoType,product, CARGOID, aPort.code, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator, 50, null).CM_Cargo;
	self.assertNotNull(cargo1);
	self.opts.addAssoc("TotalWeight", 5000);
	self.opts.addAssoc("Commodity", "COM1");
	self.opts.addAssoc("TotalVolume", 7000);
	self.opts.addAssoc("CargoLength", 111.0);
	self.opts.addAssoc("CargoWidth", 222.0);
	self.opts.addAssoc("CargoHeight", 333.0);
	self.opts.addAssoc("Description", "CargoDesc2");
	self.opts.addAssoc("ClientRef", "ClientRef2");
	self.opts.addAssoc("Consignee", "UTDDC");
	self.opts.addAssoc("Consignor", "UTMO1");
	self.updateTI(cargo1);
	assertEqual(cargo1.totalQuantity, 50);
	
	self.deleteBOL(BOL2, null);
	bol2 := self.addBOL(BOL2, voyage, operator, null, terminal );
	
	beginTransaction;
	cont.setMyVoyage(voyage, app.myPassport);
	cargo1.setMyVoyage(voyage, app.myPassport);
	cont.setBOL(bol1.number);
	cargo1.setBOL(bol2.number);
	commitTransaction;
	self.assertEqualMsg(BOL1, cont.myReceivalBOL.number, "Container receival BOL");
	self.assertEqualMsg(BOL2, cargo1.myReceivalBOL.number, "Cargo receival BOL");
	

	//Invoicing 
	self.deleteDebtor(DEBTORNAME);
	debtorNode := self.addDebtor(DEBTORNAME, PaymentType_None);
	assertNotNull(debtorNode);
	debtor := debtorNode.CM_Debtor;
	beginTransaction;
	debtor.setPropertyValue("decfinName",DEBTORNAME&amp;'C');
	debtor.setPropertyValue("longName",DEBTORNAME&amp;'LONG');
	commitTransaction;
	
	self.deleteInvoiceService("UT_STWO51218" , FORCED_ERASE);
	self.deleteInvoiceLineType("UT_STWO51218", FORCED_ERASE);
	self.deleteInvoiceType("UT_STWO51218");
	
	create services transient;
	invType := self.createInvoiceType("UT_STWO51218", InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type UT_InvRounding not created");

	service := self.createInvoiceService("UT_STWO51218", "MANUAL", calType1, null);
	self.assertNoTrxErrorsOrWarnings();
	
	services.add(service);
	ild := self.createInvoiceLineType("UT_STWO51218", calType1, invType, services, "SDT1");
	self.assertNoTrxErrorsOrWarnings();
	
	bu := self.getTerminal().getDefaultCompanyBank();
	// ### MANUAL INVOICE
	create pxyInvoice transient;
	pxyInvoice.setProxyForCreate(bu,
								debtor, 
								null, 
								null,
								invType,
								//false,	// 26.4.2023 navmk20 TFS 57663
								CM_Invoice.INVOICE_PENDING, // 26.4.2023 navmk20 TFS 57663		
								true,	
								null,
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								null,	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
								0,
								null,  // ### BUG 56925 07MAR2023 NAVAB1
								bu.myInvoiceProcess,		 // 26.4.2023 navmk20 TFS 57663	
								null,		//navtnr20 23-05-2023 BUG 58089
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null, //14/08/2023	navkc1	Bug 59803
								null //14/08/2023	navkc1	Bug 59803
								);
	app.myTrxCA.trxCreateInvoiceManual(pxyInvoice,realInvoice, app.myPassport);
	
	beginTransaction;
	realInvoice.setPropertyValue("status",0); // OPEN
	commitTransaction;
	//First Cargo
	self.createManualInvoiceLineRate(realInvoice, ild, 55.000000,null);
	//Update first invoiceLine With Cargo
	invLine1 := realInvoice.invoiceLines.first;
	self.assertNotNull(invLine1);
	
	if invLine1 &lt;&gt; null then
		pxyInvLine := app.createUpdateProxy(invLine1).CM_InvoiceLine;
	endif;
	pxyInvLine.setRemarks("Updated with cargo1");
	pxyInvLine.setTrackedItem(cargo1);
	app.myTrxUA.trxUpdateInvoiceLineRemarks(pxyInvLine, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.createManualInvoiceLineRate(realInvoice, ild, 55.000000,cargo1);
	
	//Update first invoiceLine With Cargo
	//Second Cargo
	self.createManualInvoiceLineRate(realInvoice, ild, 66.000000,null);
	invLine2 := realInvoice.invoiceLines.last;
	
	self.assertNotNull(invLine2);
	delete pxyInvLine;
	if invLine2 &lt;&gt; null then
		pxyInvLine := app.createUpdateProxy(invLine2).CM_InvoiceLine;
	endif;
	
	pxyInvLine.setRemarks("Updated with Cont");
	pxyInvLine.setTrackedItem(cont);
	app.myTrxUA.trxUpdateInvoiceLineRemarks(pxyInvLine, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.createManualInvoiceLineRate(realInvoice, ild, 66.000000,cont);
	self.assertEqual(realInvoice.invoiceLines.size,4);
	
	self.postInvoice(realInvoice,true,false);
	
	self.validateSTWOInvoiceFiles(realInvoice);
epilog
	self.resetDefaultTranMap();	
	delete services;
	delete pxyInvoice;
	delete pxyInvLine;
	if ioClassForTest &lt;&gt; null then	
		beginTransaction;
		ioClassActual.exportPath := origPath;
		commitTransaction;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="tSepByVoyCargoGrpBOL" id="4e224806-8ce2-43e6-b850-15b06d321687">
        <source>tSepByVoyCargoGrpBOL();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2023 navmv20 TFS 56995 Task 57223: Jade - Invoice Debtor Separation Unit Tests

*/

constants
	Ref					: String = "56995";
	UT_Debtor1 			: String = "UT_" &amp; Ref &amp; "_Debtor2";
	UT_InvoiceDesc 		: String = "UT_" &amp; Ref &amp; "_InvoiceDesc";
	UT_BlockStackId 			: String = Ref &amp; "2B1";
	UT_VesselId					: String = "UT_" &amp; Ref &amp; "_VESS00008";
	UT_VoyageId					: String = "UT_" &amp; Ref &amp; "_VOY00008";
	UT_CalculationTypeCode		: String = "UT_" &amp; Ref;
	UT_GlCode					: String = "UT_" &amp; Ref &amp; "_GLCode";
	UT_GlRemarks				: String = "UT_" &amp; Ref &amp; " GL Code";
	UT_ServiceRemarks			: String = "UT_" &amp; Ref;
	UT_InvoiceLineDesc			: String = "UT_" &amp; Ref &amp; "_InvoiceLnDescSur";
	NullMSG						: String = " Expected: 'not null' | Actual: 'null'";
	UT_TransactionMapId			: String = "UT_" &amp; Ref;
	UT_CargoCommodity			: String = "FCL";
	UT_OperatorCode				: String = "UTSU";
	UT_CargoTypeCont			: String = "CONT";
	UT_IsoType					: String = "2200";
	UT_TrackedItem1				: String = "UT" &amp; Ref &amp; "011";
	UT_TrackedItem2				: String = "UT" &amp; Ref &amp; "012";
	UT_TrackedItem3				: String = "UT" &amp; Ref &amp; "021";
	UT_TrackedItem4				: String = "UT" &amp; Ref &amp; "022";
	UT_VesselDischLocn 			: String = "090488";
	
vars
	pxyInvTypeDebtorSeparation,
	realInvTypeDebtorSeparation 			: CM_InvTypeDebtorSeparation;
	invoiceType								: CM_InvoiceDesc;
	debtor1									: CM_Debtor;
	surchargesAndExemptions					: CM_InvoiceTypeSurchargeExempt;
	title,
	fileContent								: String;
	cargoMap								: CM_TranMap;
	error									: CM_Error;
	calcType 								: CM_CalculationType;
	glCode 						: CM_GLCode;
	service						: CM_Service;
	services                    : CM_ServiceByNameDict;
	invoiceLnType               : CM_InvoiceLineDesc;
	terminal                    : CM_Terminal;
	bank                        : CM_Bank;
	rootDebtor                  : CM_Debtor;
	ti1,
	ti2,
	ti3,
	ti4							: CM_TrackedItem;
	operator                    : CM_Operator;
	invoice1,
	invoice2					: CM_Invoice;
	vesselLocations				: StringArray;
	tiSet						: CM_TISet;
	voyage						: CM_Voyage;
	theSlot                     : CM_LocationsController;
	foundheight					: Integer;
	aPort                       : CM_Port;
	cargoType                   : CM_CargoType;
	blockStack                  : CM_BlockStack;
	vessel                      : CM_Vessel;
	cgId1,
	cgId2						: String;
	cg1,
	cg2							: CM_CargoGroup;
	allCargoToAssign			: CM_TISet;
	now							: TimeStamp;
	selectedTypes				: CM_CargoBOLTypeSet;
	line						: CM_InvoiceLine;
	invoice						: CM_Invoice;
	tiSet1                      : CM_TISet;
	ti                          : CM_TrackedItem;
	bol1,
	bol2                        : CM_BOL;
	
begin
	/*
	** Cleanup
	*/
	now := app.actualTimeServer;
	
	self.deleteCleanup(); // ### NAVAB1 04MAR2024 - fixing UTs, delete everything.
	/*
	debtor1 := app.myRoot.myRootCompany.debtors[UT_Debtor1];
	self.deleteDebtor(debtor1);
	
	self.deleteInvoiceType(UT_InvoiceDesc);
	self.deleteOperator(UT_OperatorCode);
	
	self.deleteContainer(UT_TrackedItem1);
	self.deleteContainer(UT_TrackedItem2);
	self.deleteContainer(UT_TrackedItem3);
	self.deleteContainer(UT_TrackedItem4);

	// delete voyage
	self.deleteVoyage(UT_VoyageId);
	
	//Delete Vessel
	self.deleteVessel(UT_VesselId);
	
	//Terminal
	self.deleteTerminalArea(UT_BlockStackId);
	
	self.deleteCalculationType(UT_CalculationTypeCode,FORCED_ERASE);
	self.deleteService(UT_InvoiceLineDesc);
	self.deleteInvoiceGLCode(UT_GlCode);
	self.deleteInvoiceLineType(UT_InvoiceLineDesc, FORCED_ERASE);
	*/
	
	
	
	/*
	** Global Setup
	*/
	debtor1 := self.addDebtor(UT_Debtor1, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtor1, "Debtor1");
	
	terminal := self.getTerminal();
	self.assertTrueMsg(terminal &lt;&gt; null, title &amp; "terminal" &amp; NullMSG);
	
	bank := terminal.companies["DFBU"];
	self.assertTrueMsg(bank &lt;&gt; null, title &amp; "bank" &amp; NullMSG);
	
	rootDebtor := bank.rootDebtor;
	self.assertTrueMsg(rootDebtor &lt;&gt; null, title &amp; "rootDebtor" &amp; NullMSG);
	
	invoiceType	:= self.createInvoiceType(UT_InvoiceDesc, InvoiceTypeGeneral);
	self.assertNotNullMsg(invoiceType, "Invoice Type");
	
	self.addInvTypeSurchargeExempt(invoiceType, 0, null, null);
	
	surchargesAndExemptions	:= invoiceType.mySurchargeAndExemptions;
	self.assertNotNullMsg(surchargesAndExemptions, "Surcharges and Exemptions");
	
	
	calcType := self.createInvoiceCalcType(null, 0, UT_CalculationTypeCode, UT_CalculationTypeCode, 0, 0,0,0,null, false, null, null, 0, 0, INV_CALC_TYPE_UNITY,
											null, null, null, "UNITTEST", true, false, false, null, null, null, null);	
	self.assertTrueMsg(calcType &lt;&gt; null, title &amp; "calcType" &amp; NullMSG);
	
	glCode := self.createInvoiceGLCode(UT_GlCode, UT_GlRemarks);
	service := self.createInvoiceService(UT_InvoiceLineDesc, UT_ServiceRemarks, calcType, glCode);
	self.assertTrueMsg(glCode &lt;&gt; null, title &amp; "glCode" &amp; NullMSG);
	self.assertTrueMsg(service &lt;&gt; null, title &amp; "service" &amp; NullMSG);
	
	create services transient;
	services.add(service);
	
	invoiceLnType := self.createInvoiceLineType(UT_InvoiceLineDesc, calcType, invoiceType, services, "SDT1");
	self.assertTrueMsg(invoiceLnType &lt;&gt; null, title &amp; "invoiceLnType" &amp; NullMSG);
	
	beginTransaction;
	bank.getRootDebtorGroup().serviceRates[service].rateEntries.first.setCostPerUnit(50);
	commitTransaction;
	
	operator := self.addOperator(UT_OperatorCode, "UT_" &amp; Ref &amp; " Desc", false, null, null, debtor1, false, false, false, false, false, false, false, false, false, false, null, null, null, null, false, false, null, null, null, null, false, false);
	self.assertTrueMsg(operator &lt;&gt; null, title &amp; "operator" &amp; NullMSG);
	
	cargoType := app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation(UT_CargoTypeCont);
	self.assertTrueMsg(cargoType &lt;&gt; null, title &amp; "cargoType" &amp; NullMSG);
	
	create vesselLocations transient;
	create tiSet transient;
	
	//Create Vessel
	vessel := self.addVesselCellular(UT_VesselId, operator);
	self.assertTrueMsg(vessel &lt;&gt; null, title &amp; "vessel" &amp; NullMSG);
	
	//Create voyage
	voyage := self.addVoyageWithContainerStructur(UT_VoyageId, UT_VesselId, operator.code,  self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertTrueMsg(voyage &lt;&gt; null, title &amp; "voyage" &amp; NullMSG);
	
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	self.assertTrueMsg(aPort &lt;&gt; null, title &amp; "aPort" &amp; NullMSG);
	
	blockStack := self.addBlockStack(UT_BlockStackId, 999, null);
	self.assertTrueMsg(blockStack &lt;&gt; null, title &amp; "blockStack" &amp; NullMSG);
	
	vesselLocations.add(UT_VesselDischLocn);
	voyage.findLocation(vesselLocations, false, theSlot, foundheight);
	
	title := "Debtor Separation by voyage, cargo group id, BOL";
	create pxyInvTypeDebtorSeparation transient;
	pxyInvTypeDebtorSeparation.setProxy(debtor1, null, true, false, false, true, true, false, false, false, surchargesAndExemptions);
	app.myTrxCA.trxCreateInvTypeDtrSeparation(pxyInvTypeDebtorSeparation, realInvTypeDebtorSeparation, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	self.verifyDebtorSepAttributes(realInvTypeDebtorSeparation,pxyInvTypeDebtorSeparation,title);
	
	fileContent := "TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Transfer Type,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?,Is Work Order Requested?" &amp; CrLf &amp;
	"Cargo," &amp; UT_TransactionMapId &amp; ",(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),,,**Any**,All," &amp; UT_InvoiceLineDesc;
	
	self.deleteTransactionMapByName(UT_TransactionMapId);
	self.transactionMapLoad(fileContent, UT_TransactionMapId);
	self.assertNoTrxErrorsOrWarnings();
	
	cargoMap := bank.myCurrentTranMapCargo[UT_TransactionMapId];
	self.assertTrueMsg(cargoMap &lt;&gt; null, title &amp; "cargoMap" &amp; NullMSG);
	
	app.myTrxUA.trxUpdateBankTMActive(cargoMap, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	//Debtor Separation by voyage, cargo group id, BOL
	//positive case : voyage, cargo group and BOL are same on cargos
	
	ti1 := self.setUpTrackedItem(UT_TrackedItem1,"ti1",TI_IMEX_STATUS_EXPORT,voyage,operator,cargoType,theSlot,aPort);
	ti2 := self.setUpTrackedItem(UT_TrackedItem2,"ti2",TI_IMEX_STATUS_EXPORT,voyage,operator,cargoType,theSlot,aPort);
	
	tiSet.clear();
	tiSet.add(ti1);
	tiSet.add(ti2);

	self.setUpCargoGroup("04",operator,tiSet);
	
	vesselLocations.clear;
	self.deleteBOL("UTBOL001", null);
	bol1 := self.addBOL("UTBOL001", voyage,operator, null, self.getTerminal );
	self.deleteBOL("UTBOL002", null);
	bol2 := self.addBOL("UTBOL002", voyage,operator, null, self.getTerminal );
	beginTransaction;
	ti1.setBOL(bol1.number);
	ti2.setBOL(bol1.number);
	commitTransaction;
	
	//edit transaction
	addDamage(ti1, "BENT", "All", null, 1, "XXX");
	addDamage(ti2, "BENT", "All", null, 2, "XXX");
	if ti1.invoiceLines.isNotEmpty then
		invoice1 := ti1.invoiceLines.last.invoice;
	endif;
	
	if ti2.invoiceLines.isNotEmpty then
		invoice2 := ti2.invoiceLines.last.invoice;
	endif;

	self.assertTrueMsg(invoice1 = invoice2, title &amp; "invoices are different");
	self.assertTrueMsg(invoice1.myVoyage = ti1.myVoyage, title &amp; "Voyage is incorrect on invoice1 ");
	self.assertTrueMsg(invoice1.myCargoGroup = ti1.myCargoGroup, title &amp; "Cargo group is different on invoice1");
	self.assertTrueMsg(invoice1.myBOL.number = ti1.billOfLading, title &amp; "BOL is different on invoice1");
	self.assertTrueMsg(invoice2.myVoyage = ti2.myVoyage, title &amp; "Voyage is incorrect on invoice2 ");
	self.assertTrueMsg(invoice2.myCargoGroup = ti2.myCargoGroup, title &amp; "Cargo group is different on invoice2");
	self.assertTrueMsg(invoice2.myBOL.number = ti2.billOfLading, title &amp; "BOL is different on invoice2");
	
	// Negative Case : BOL is different on cargos
	ti3 := self.setUpTrackedItem(UT_TrackedItem3,"ti3",TI_IMEX_STATUS_EXPORT,voyage,operator,cargoType,theSlot,aPort);
	ti4 := self.setUpTrackedItem(UT_TrackedItem4,"ti4",TI_IMEX_STATUS_EXPORT,voyage,operator,cargoType,theSlot,aPort);
	
	tiSet.clear();
	tiSet.add(ti3);
	tiSet.add(ti4);

	self.setUpCargoGroup("41",operator,tiSet);
	
	vesselLocations.clear;
	
	beginTransaction;
	ti3.setBOL(bol1.number);
	ti4.setBOL(bol2.number);
	commitTransaction;
	
	//edit transaction
	addDamage(ti3, "BENT", "All", null, 1, "XXX");
	addDamage(ti4, "BENT", "All", null, 2, "XXX");
	if ti3.invoiceLines.isNotEmpty then
		invoice1 := ti3.invoiceLines.last.invoice;
	endif;
	
	if ti4.invoiceLines.isNotEmpty then
		invoice2 := ti4.invoiceLines.last.invoice;
	endif;

	self.assertTrueMsg(invoice1 &lt;&gt; invoice2, title &amp; "invoices are same");
	self.assertTrueMsg(invoice1.myVoyage = ti3.myVoyage, title &amp; "Voyage is incorrect on invoice1 ");
	self.assertTrueMsg(invoice1.myCargoGroup = ti3.myCargoGroup, title &amp; "Cargo group is different on invoice1");
	self.assertTrueMsg(invoice1.myBOL.number = ti3.billOfLading, title &amp; "BOL is different on invoice1");
	self.assertTrueMsg(invoice2.myVoyage = ti4.myVoyage, title &amp; "Voyage is incorrect on invoice2 ");
	self.assertTrueMsg(invoice2.myCargoGroup = ti4.myCargoGroup, title &amp; "Cargo group is different on invoice2");
	self.assertTrueMsg(invoice2.myBOL.number = ti4.billOfLading, title &amp; "BOL is different on invoice2");
	
	
	self.deleteCleanup(); // ### NAVAB1 04MAR2024 - fixing UTs, delete everything.

epilog
	self.resetDefaultTranMap();
	delete pxyInvTypeDebtorSeparation;
	delete services;
	delete tiSet;
	delete vesselLocations;
end;</source>
    </JadeMethod>
    <JadeMethod name="tSepByVoyCargoGrpBooking" id="ea8fc548-aa49-43bf-aa07-d7b84c215cce">
        <source>tSepByVoyCargoGrpBooking();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2023 navmv20 TFS 56995 Task 57223: Jade - Invoice Debtor Separation Unit Tests

*/

constants
	Ref					: String = "56995";
	UT_Debtor1 			: String = "UT_" &amp; Ref &amp; "_Debtor2";
	UT_InvoiceDesc 		: String = "UT_" &amp; Ref &amp; "_InvoiceDesc";
	UT_BlockStackId 			: String = Ref &amp; "2B1";
	UT_VesselId					: String = "UT_" &amp; Ref &amp; "_VESS00008";
	UT_VoyageId					: String = "UT_" &amp; Ref &amp; "_VOY00008";
	UT_CalculationTypeCode		: String = "UT_" &amp; Ref;
	UT_GlCode					: String = "UT_" &amp; Ref &amp; "_GLCode";
	UT_ServiceRemarks			: String = "UT_" &amp; Ref;
	UT_InvoiceLineDesc			: String = "UT_" &amp; Ref &amp; "_InvoiceLnDescSur";
	NullMSG						: String = " Expected: 'not null' | Actual: 'null'";
	UT_TransactionMapId			: String = "UT_" &amp; Ref;
	UT_CargoCommodity			: String = "FCL";
	UT_OperatorCode				: String = "UTSU";
	UT_CargoTypeCont			: String = "CONT";
	UT_IsoType					: String = "2200";
	UT_TrackedItem1			: String = "UT" &amp; Ref &amp; "011";
	UT_TrackedItem2			: String = "UT" &amp; Ref &amp; "012";
	UT_TrackedItem3			: String = "UT" &amp; Ref &amp; "021";
	UT_TrackedItem4			: String = "UT" &amp; Ref &amp; "022";
	UT_VesselDischLocn 			: String = "090488";
	
vars
	pxyInvTypeDebtorSeparation,
	realInvTypeDebtorSeparation 			: CM_InvTypeDebtorSeparation;
	invoiceType								: CM_InvoiceDesc;
	debtor1									: CM_Debtor;
	surchargesAndExemptions					: CM_InvoiceTypeSurchargeExempt;
	title,
	fileContent								: String;
	cargoMap								: CM_TranMap;
	error									: CM_Error;
	calcType 								: CM_CalculationType;
	glCode 						: CM_GLCode;
	service						: CM_Service;
	services                    : CM_ServiceByNameDict;
	invoiceLnType               : CM_InvoiceLineDesc;
	terminal                    : CM_Terminal;
	bank                        : CM_Bank;
	rootDebtor                  : CM_Debtor;
	ti1,
	ti2,
	ti3,
	ti4							: CM_TrackedItem;
	operator                    : CM_Operator;
	invoice1,
	invoice2					: CM_Invoice;
	vesselLocations				: StringArray;
	tiSet						: CM_TISet;
	voyage						: CM_Voyage;
	theSlot                     : CM_LocationsController;
	foundheight					: Integer;
	aPort                       : CM_Port;
	cargoType                   : CM_CargoType;
	blockStack                  : CM_BlockStack;
	vessel                      : CM_Vessel;
	cgId1						: String;
	cg1							: CM_CargoGroup;
	allCargoToAssign			: CM_TISet;
	now							: TimeStamp;
	booking						: CM_BookingRef;
	selectedTypes				: CM_CargoBOLTypeSet;
	line						: CM_InvoiceLine;
	invoice						: CM_Invoice;
	tiSet1                      : CM_TISet;
	ti                          : CM_TrackedItem;
	
begin
	/*
	** Cleanup
	*/
	now := app.actualTimeServer;
	
	
	self.deleteCleanup(); // ### NAVAB1 04MAR2024 - fixing UTs, delete everything.

	/*
	** Global Setup
	*/
	debtor1 := self.addDebtor(UT_Debtor1, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtor1, "Debtor1");
	
	terminal := self.getTerminal();
	self.assertTrueMsg(terminal &lt;&gt; null, title &amp; "terminal" &amp; NullMSG);
	
	bank := terminal.companies["DFBU"];
	self.assertTrueMsg(bank &lt;&gt; null, title &amp; "bank" &amp; NullMSG);
	
	rootDebtor := bank.rootDebtor;
	self.assertTrueMsg(rootDebtor &lt;&gt; null, title &amp; "rootDebtor" &amp; NullMSG);
	
	invoiceType	:= self.createInvoiceType(UT_InvoiceDesc, InvoiceTypeGeneral);
	self.assertNotNullMsg(invoiceType, "Invoice Type");
	
	self.addInvTypeSurchargeExempt(invoiceType, 0, null, null);
	
	surchargesAndExemptions	:= invoiceType.mySurchargeAndExemptions;
	self.assertNotNullMsg(surchargesAndExemptions, "Surcharges and Exemptions");
	
	
	calcType := self.createInvoiceCalcType(null, 0, UT_CalculationTypeCode, UT_CalculationTypeCode, 0, 0,0,0,null, false, null, null, 0, 0, INV_CALC_TYPE_UNITY,
											null, null, null, "UNITTEST", true, false, false, null, null, null, null);	
	self.assertTrueMsg(calcType &lt;&gt; null, title &amp; "calcType" &amp; NullMSG);
	
	glCode := self.createInvoiceGLCode(UT_GlCode, UT_GlCode);
	service := self.createInvoiceService(UT_InvoiceLineDesc, UT_ServiceRemarks, calcType, glCode);
	self.assertTrueMsg(glCode &lt;&gt; null, title &amp; "glCode" &amp; NullMSG);
	self.assertTrueMsg(service &lt;&gt; null, title &amp; "service" &amp; NullMSG);
	
	create services transient;
	services.add(service);
	
	invoiceLnType := self.createInvoiceLineType(UT_InvoiceLineDesc, calcType, invoiceType, services, "SDT1");
	self.assertTrueMsg(invoiceLnType &lt;&gt; null, title &amp; "invoiceLnType" &amp; NullMSG);
	
	beginTransaction;
	bank.getRootDebtorGroup().serviceRates[service].rateEntries.first.setCostPerUnit(50);
	commitTransaction;
	
	operator := self.addOperator(UT_OperatorCode, "UT_" &amp; Ref &amp; " Desc", false, null, null, debtor1, false, false, false, false, false, false, false, false, false, false, null, null, null, null, false, false, null, null, null, null, false, false);
	self.assertTrueMsg(operator &lt;&gt; null, title &amp; "operator" &amp; NullMSG);
	
	cargoType := app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation(UT_CargoTypeCont);
	self.assertTrueMsg(cargoType &lt;&gt; null, title &amp; "cargoType" &amp; NullMSG);
	
	create vesselLocations transient;
	create tiSet transient;
	
	//Create Vessel
	vessel := self.addVesselCellular(UT_VesselId, operator);
	self.assertTrueMsg(vessel &lt;&gt; null, title &amp; "vessel" &amp; NullMSG);
	
	//Create voyage
	voyage := self.addVoyageWithContainerStructur(UT_VoyageId, UT_VesselId, operator.code,  self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertTrueMsg(voyage &lt;&gt; null, title &amp; "voyage" &amp; NullMSG);
	
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	self.assertTrueMsg(aPort &lt;&gt; null, title &amp; "aPort" &amp; NullMSG);
	
	blockStack := self.addBlockStack(UT_BlockStackId, 999, null);
	self.assertTrueMsg(blockStack &lt;&gt; null, title &amp; "blockStack" &amp; NullMSG);
	
	vesselLocations.add(UT_VesselDischLocn);
	voyage.findLocation(vesselLocations, false, theSlot, foundheight);
	
	title := "Debtor Separation by Voyage, Cargo group id, Booking reference";
	
	create pxyInvTypeDebtorSeparation transient;
	pxyInvTypeDebtorSeparation.setProxy(debtor1, null, true, false, false, true, false, true, false, false, surchargesAndExemptions);
	app.myTrxCA.trxCreateInvTypeDtrSeparation(pxyInvTypeDebtorSeparation, realInvTypeDebtorSeparation, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	self.verifyDebtorSepAttributes(realInvTypeDebtorSeparation,pxyInvTypeDebtorSeparation,title);
	
	fileContent := "TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Transfer Type,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?,Is Work Order Requested?" &amp; CrLf &amp;
	"Cargo," &amp; UT_TransactionMapId &amp; ",(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),,,**Any**,All," &amp; UT_InvoiceLineDesc;
	
	self.deleteTransactionMapByName(UT_TransactionMapId);
	self.transactionMapLoad(fileContent, UT_TransactionMapId);
	self.assertNoTrxErrorsOrWarnings();
	
	cargoMap := bank.myCurrentTranMapCargo[UT_TransactionMapId];
	self.assertTrueMsg(cargoMap &lt;&gt; null, title &amp; "cargoMap" &amp; NullMSG);
	
	app.myTrxUA.trxUpdateBankTMActive(cargoMap, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	//Debtor Separation by Voyage, Cargo group id, Booking reference
	//positive case - voyage, cargo group and bboking are same on cargos
	
	ti1 := self.setUpTrackedItem(UT_TrackedItem1,"ti1",TI_IMEX_STATUS_EXPORT,voyage,operator,cargoType,theSlot,aPort);
	ti2 := self.setUpTrackedItem(UT_TrackedItem2,"ti2",TI_IMEX_STATUS_EXPORT,voyage,operator,cargoType,theSlot,aPort);
	
	tiSet.clear();
	tiSet.add(ti2);
	tiSet.add(ti1);

	self.setUpCargoGroup("20",operator,tiSet);
	vesselLocations.clear;
	
	
	self.deleteBooking("UT_DocCon");
	self.deleteBooking("UT_DocCon1");
	self.opts.purge();
	self.opts.addAssoc("ISOType", "2200"); 
	self.opts.addAssoc("ISOGroupType", "GEN2");
	booking := self.addBookingForGeneralCargo("UT_DocCon", operator, voyage, "NZAKL",ti1.cargoType, 1);
	self.assertNotNull(booking);
	beginTransaction;
	ti1.setMyBooking(booking,booking.allBookingRefItems.first);
	ti2.setMyBooking(booking,booking.allBookingRefItems.first);
	commitTransaction;
	
	//edit transaction
	addDamage(ti1, "BENT", "All", null, 1, "XXX");
	addDamage(ti2, "BENT", "All", null, 2, "XXX");
	
	if ti1.invoiceLines.isNotEmpty then
		invoice1 := ti1.invoiceLines.last.invoice;
	endif;
	
	if ti2.invoiceLines.isNotEmpty then
		invoice2 := ti2.invoiceLines.last.invoice;
	endif;

	self.assertTrueMsg(invoice1 = invoice2, title &amp; "invoices are different");
	self.assertTrueMsg(invoice1.myVoyage = ti1.myVoyage, title &amp; "Voyage is incorrect on invoice1 ");
	self.assertTrueMsg(invoice1.myCargoGroup = ti1.myCargoGroup, title &amp; "Cargo group is different on invoice1");
	self.assertTrueMsg(invoice1.myBookingRef = ti1.myBookingRef, title &amp; "Booking is different on invoice1");
	self.assertTrueMsg(invoice2.myVoyage = ti2.myVoyage, title &amp; "Voyage is incorrect on invoice2 ");
	self.assertTrueMsg(invoice2.myCargoGroup = ti2.myCargoGroup, title &amp; "Cargo group is different on invoice2");
	self.assertTrueMsg(invoice1.myBookingRef = ti1.myBookingRef, title &amp; "Booking is different on invoice1");
	
	//negative case - booking is different for the cargos
	ti3 := self.setUpTrackedItem(UT_TrackedItem3,"ti3",TI_IMEX_STATUS_EXPORT,voyage,operator,cargoType,theSlot,aPort);
	ti4 := self.setUpTrackedItem(UT_TrackedItem4,"ti4",TI_IMEX_STATUS_EXPORT,voyage,operator,cargoType,theSlot,aPort);
	
	tiSet.clear();
	tiSet.add(ti3);
	tiSet.add(ti4);

	self.setUpCargoGroup("21",operator,tiSet);
	vesselLocations.clear;
	
	self.opts.addAssoc("ISOType", "2200"); 
	self.opts.addAssoc("ISOGroupType", "GEN2");
	
	beginTransaction;
	ti3.setMyBooking(booking,booking.allBookingRefItems.first);
	commitTransaction;
	
	booking := self.addBookingForGeneralCargo("UT_DocCon1", operator, voyage, "NZAKL",ti4.cargoType, 1);
	self.assertNotNull(booking);
	beginTransaction;
	ti4.setMyBooking(booking,booking.allBookingRefItems.first);
	commitTransaction;
	
	//edit transaction
	addDamage(ti3, "BENT", "All", null, 1, "XXX");
	addDamage(ti4, "BENT", "All", null, 2, "XXX");
	
	if ti3.invoiceLines.isNotEmpty then
		invoice1 := ti3.invoiceLines.last.invoice;
	endif;
	
	if ti4.invoiceLines.isNotEmpty then
		invoice2 := ti4.invoiceLines.last.invoice;
	endif;

	self.assertTrueMsg(invoice1 &lt;&gt; invoice2, title &amp; "invoices are same");
	self.assertTrueMsg(invoice1.myVoyage = ti3.myVoyage, title &amp; "Voyage is incorrect on invoice1 ");
	self.assertTrueMsg(invoice1.myCargoGroup = ti3.myCargoGroup, title &amp; "Cargo group is different on invoice1");
	self.assertTrueMsg(invoice1.myBookingRef = ti3.myBookingRef, title &amp; "Booking is different on invoice1");
	self.assertTrueMsg(invoice2.myVoyage = ti4.myVoyage, title &amp; "Voyage is incorrect on invoice2 ");
	self.assertTrueMsg(invoice2.myCargoGroup = ti4.myCargoGroup, title &amp; "Cargo group is different on invoice2");
	self.assertTrueMsg(invoice1.myBookingRef = ti3.myBookingRef, title &amp; "Booking is different on invoice1");
	
	self.deleteCleanup(); // ### NAVAB1 04MAR2024 - fixing UTs, delete everything.
	
epilog
	self.resetDefaultTranMap();
	delete pxyInvTypeDebtorSeparation;
	delete services;
	delete tiSet;
	delete vesselLocations;
end;</source>
    </JadeMethod>
    <JadeMethod name="tSepByVoyCargoGrpRelease" id="845ee665-2bd7-4ac9-ac74-ad6bfe410941">
        <source>tSepByVoyCargoGrpRelease();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2023 navmv20 TFS 56995 Task 57223: Jade - Invoice Debtor Separation Unit Tests

*/

constants
	Ref					: String = "56995";
	UT_Debtor1 			: String = "UT_" &amp; Ref &amp; "_Debtor2";
	UT_InvoiceDesc 		: String = "UT_" &amp; Ref &amp; "_InvoiceDesc";
	UT_BlockStackId 			: String = Ref &amp; "2B1";
	UT_VesselId					: String = "UT_" &amp; Ref &amp; "_VESS00008";
	UT_VoyageId					: String = "UT_" &amp; Ref &amp; "_VOY00008";
	UT_CalculationTypeCode		: String = "UT_" &amp; Ref;
	UT_GlCode					: String = "UT_" &amp; Ref &amp; "_GLCode";
	UT_GlRemarks				: String = "UT_" &amp; Ref &amp; " GL Code";
	UT_ServiceRemarks			: String = "UT_" &amp; Ref;
	UT_InvoiceLineDesc			: String = "UT_" &amp; Ref &amp; "_InvoiceLnDescSur";
	NullMSG						: String = " Expected: 'not null' | Actual: 'null'";
	UT_TransactionMapId			: String = "UT_" &amp; Ref;
	UT_CargoCommodity			: String = "FCL";
	UT_OperatorCode				: String = "UTSU";
	UT_CargoTypeCont			: String = "CONT";
	UT_IsoType					: String = "2200";
	UT_TrackedItem1				: String = "UT" &amp; Ref &amp; "011";
	UT_TrackedItem2				: String = "UT" &amp; Ref &amp; "012";
	UT_TrackedItem3				: String = "UT" &amp; Ref &amp; "021";
	UT_TrackedItem4				: String = "UT" &amp; Ref &amp; "022";
	UT_VesselDischLocn 			: String = "090488";
	
vars
	pxyInvTypeDebtorSeparation,
	realInvTypeDebtorSeparation 			: CM_InvTypeDebtorSeparation;
	invoiceType								: CM_InvoiceDesc;
	debtor1									: CM_Debtor;
	surchargesAndExemptions					: CM_InvoiceTypeSurchargeExempt;
	title,
	fileContent								: String;
	cargoMap								: CM_TranMap;
	error									: CM_Error;
	calcType 								: CM_CalculationType;
	glCode 						: CM_GLCode;
	service						: CM_Service;
	services                    : CM_ServiceByNameDict;
	invoiceLnType               : CM_InvoiceLineDesc;
	terminal                    : CM_Terminal;
	bank                        : CM_Bank;
	rootDebtor                  : CM_Debtor;
	ti1,
	ti2,
	ti3,
	ti4							: CM_TrackedItem;
	operator                    : CM_Operator;
	invoice1,
	invoice2					: CM_Invoice;
	vesselLocations				: StringArray;
	tiSet						: CM_TISet;
	voyage						: CM_Voyage;
	theSlot                     : CM_LocationsController;
	foundheight					: Integer;
	aPort                       : CM_Port;
	cargoType                   : CM_CargoType;
	blockStack                  : CM_BlockStack;
	vessel                      : CM_Vessel;
	cgId1						: String;
	cg1							: CM_CargoGroup;
	allCargoToAssign			: CM_TISet;
	now							: TimeStamp;
	selectedTypes				: CM_CargoBOLTypeSet;
	line						: CM_InvoiceLine;
	invoice						: CM_Invoice;
	tiSet1                      : CM_TISet;
	ti                          : CM_TrackedItem;
	
begin
	/*
	** Cleanup
	*/
	now := app.actualTimeServer;
	
	
	self.deleteCleanup(); // ### NAVAB1 04MAR2024 - fixing UTs, delete everything.

	/*
	** Global Setup
	*/
	debtor1 := self.addDebtor(UT_Debtor1, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtor1, "Debtor1");
	
	terminal := self.getTerminal();
	self.assertTrueMsg(terminal &lt;&gt; null, title &amp; "terminal" &amp; NullMSG);
	
	bank := terminal.companies["DFBU"];
	self.assertTrueMsg(bank &lt;&gt; null, title &amp; "bank" &amp; NullMSG);
	
	rootDebtor := bank.rootDebtor;
	self.assertTrueMsg(rootDebtor &lt;&gt; null, title &amp; "rootDebtor" &amp; NullMSG);
	
	invoiceType	:= self.createInvoiceType(UT_InvoiceDesc, InvoiceTypeGeneral);
	self.assertNotNullMsg(invoiceType, "Invoice Type");
	
	self.addInvTypeSurchargeExempt(invoiceType, 0, null, null);
	
	surchargesAndExemptions	:= invoiceType.mySurchargeAndExemptions;
	self.assertNotNullMsg(surchargesAndExemptions, "Surcharges and Exemptions");
	
	
	calcType := self.createInvoiceCalcType(null, 0, UT_CalculationTypeCode, UT_CalculationTypeCode, 0, 0,0,0,null, false, null, null, 0, 0, INV_CALC_TYPE_UNITY,
											null, null, null, "UNITTEST", true, false, false, null, null, null, null);	
	self.assertTrueMsg(calcType &lt;&gt; null, title &amp; "calcType" &amp; NullMSG);
	
	glCode := self.createInvoiceGLCode(UT_GlCode, UT_GlRemarks);
	service := self.createInvoiceService(UT_InvoiceLineDesc, UT_ServiceRemarks, calcType, glCode);
	self.assertTrueMsg(glCode &lt;&gt; null, title &amp; "glCode" &amp; NullMSG);
	self.assertTrueMsg(service &lt;&gt; null, title &amp; "service" &amp; NullMSG);
	
	create services transient;
	services.add(service);
	
	invoiceLnType := self.createInvoiceLineType(UT_InvoiceLineDesc, calcType, invoiceType, services, "SDT1");
	self.assertTrueMsg(invoiceLnType &lt;&gt; null, title &amp; "invoiceLnType" &amp; NullMSG);
	
	beginTransaction;
	bank.getRootDebtorGroup().serviceRates[service].rateEntries.first.setCostPerUnit(50);
	commitTransaction;
	
	operator := self.addOperator(UT_OperatorCode, "UT_" &amp; Ref &amp; " Desc", false, null, null, debtor1, false, false, false, false, false, false, false, false, false, false, null, null, null, null, false, false, null, null, null, null, false, false);
	self.assertTrueMsg(operator &lt;&gt; null, title &amp; "operator" &amp; NullMSG);
	
	cargoType := app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation(UT_CargoTypeCont);
	self.assertTrueMsg(cargoType &lt;&gt; null, title &amp; "cargoType" &amp; NullMSG);
	
	create vesselLocations transient;
	create tiSet transient;
	
	//Create Vessel
	vessel := self.addVesselCellular(UT_VesselId, operator);
	self.assertTrueMsg(vessel &lt;&gt; null, title &amp; "vessel" &amp; NullMSG);
	
	//Create voyage
	voyage := self.addVoyageWithContainerStructur(UT_VoyageId, UT_VesselId, operator.code,  self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertTrueMsg(voyage &lt;&gt; null, title &amp; "voyage" &amp; NullMSG);
	
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	self.assertTrueMsg(aPort &lt;&gt; null, title &amp; "aPort" &amp; NullMSG);
	
	blockStack := self.addBlockStack(UT_BlockStackId, 999, null);
	self.assertTrueMsg(blockStack &lt;&gt; null, title &amp; "blockStack" &amp; NullMSG);
	
	vesselLocations.add(UT_VesselDischLocn);
	voyage.findLocation(vesselLocations, false, theSlot, foundheight);
	
	title := "Debtor Separation by voyage, cargo group id, Release request";
	create pxyInvTypeDebtorSeparation transient;
	pxyInvTypeDebtorSeparation.setProxy(debtor1, null, true, false, false, true, false, false, true, false, surchargesAndExemptions);
	app.myTrxCA.trxCreateInvTypeDtrSeparation(pxyInvTypeDebtorSeparation, realInvTypeDebtorSeparation, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	self.verifyDebtorSepAttributes(realInvTypeDebtorSeparation,pxyInvTypeDebtorSeparation,title);
	
	fileContent := "TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Transfer Type,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?,Is Work Order Requested?" &amp; CrLf &amp;
	"Cargo," &amp; UT_TransactionMapId &amp; ",(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),,,**Any**,All," &amp; UT_InvoiceLineDesc;
	
	self.deleteTransactionMapByName(UT_TransactionMapId);
	self.transactionMapLoad(fileContent, UT_TransactionMapId);
	self.assertNoTrxErrorsOrWarnings();
	
	cargoMap := bank.myCurrentTranMapCargo[UT_TransactionMapId];
	self.assertTrueMsg(cargoMap &lt;&gt; null, title &amp; "cargoMap" &amp; NullMSG);
	
	app.myTrxUA.trxUpdateBankTMActive(cargoMap, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	//Debtor Separation by voyage, cargo group id, Release request
	//positive case : voyage, cargo group and release request are same on cargos

	ti1 := self.setUpTrackedItem(UT_TrackedItem1,"ti1",TI_IMEX_STATUS_EXPORT,voyage,operator,cargoType,theSlot,aPort);
	ti2 := self.setUpTrackedItem(UT_TrackedItem2,"ti2",TI_IMEX_STATUS_EXPORT,voyage,operator,cargoType,theSlot,aPort);
	
	tiSet.clear();
	tiSet.add(ti1);
	tiSet.add(ti2);

	self.setUpCargoGroup("30",operator,tiSet);
	vesselLocations.clear;

	self.opts.addAssoc("operator",operator.code);
	addReleaseById("abc",BR_TYPE_ROAD,tiSet);
	
	//edit transaction
	addDamage(ti1, "BENT", "All", null, 1, "XXX");
	addDamage(ti2, "BENT", "All", null, 2, "XXX");
	
	if ti1.invoiceLines.isNotEmpty then
		invoice1 := ti1.invoiceLines.last.invoice;
	endif;
	
	if ti2.invoiceLines.isNotEmpty then
		invoice2 := ti2.invoiceLines.last.invoice;
	endif;

	self.assertTrueMsg(invoice1 = invoice2, title &amp; "invoices are different");
	self.assertTrueMsg(invoice1.myVoyage = ti1.myVoyage, title &amp; "Voyage is incorrect on invoice1 ");
	self.assertTrueMsg(invoice1.myCargoGroup = ti1.myCargoGroup, title &amp; "Cargo group is different on invoice1");
	self.assertTrueMsg(invoice1.myReleaseRequest = ti1.allBulkReleasesAssigned.first, title &amp; "Release Request is incorrect on invoice1 ");
	self.assertTrueMsg(invoice2.myVoyage = ti2.myVoyage, title &amp; "Voyage is incorrect on invoice2 ");
	self.assertTrueMsg(invoice2.myCargoGroup = ti2.myCargoGroup, title &amp; "Cargo group is different on invoice2");
	self.assertTrueMsg(invoice2.myReleaseRequest = ti2.allBulkReleasesAssigned.first, title &amp; "Release Request is incorrect on invoice2 ");
	
	//negative case : release request is different on cargos
	ti3 := self.setUpTrackedItem(UT_TrackedItem3,"ti3",TI_IMEX_STATUS_EXPORT,voyage,operator,cargoType,theSlot,aPort);
	ti4 := self.setUpTrackedItem(UT_TrackedItem4,"ti4",TI_IMEX_STATUS_EXPORT,voyage,operator,cargoType,theSlot,aPort);
	
	tiSet.clear();
	tiSet.add(ti3);
	tiSet.add(ti4);

	self.setUpCargoGroup("31",operator,tiSet);
	vesselLocations.clear;
	
	tiSet.clear();
	tiSet.add(ti3);
	self.opts.addAssoc("operator",operator.code);
	addReleaseById("REL1",BR_TYPE_ROAD,tiSet);
	
	tiSet.clear();
	tiSet.add(ti4);
	addReleaseById("REL2",BR_TYPE_ROAD,tiSet);
	
	//edit transaction
	addDamage(ti3, "BENT", "All", null, 1, "XXX");
	addDamage(ti4, "BENT", "All", null, 2, "XXX");
	
	if ti3.invoiceLines.isNotEmpty then
		invoice1 := ti3.invoiceLines.last.invoice;
	endif;
	
	if ti4.invoiceLines.isNotEmpty then
		invoice2 := ti4.invoiceLines.last.invoice;
	endif;

	self.assertTrueMsg(invoice1 &lt;&gt; invoice2, title &amp; "invoices are same");
	self.assertTrueMsg(invoice1.myVoyage = ti3.myVoyage, title &amp; "Voyage is incorrect on invoice1 ");
	self.assertTrueMsg(invoice1.myReleaseRequest = ti3.allBulkReleasesAssigned.first, title &amp; "Release Request is incorrect on invoice1 ");
	self.assertTrueMsg(invoice1.myCargoGroup = ti3.myCargoGroup, title &amp; "Cargo group is different on invoice1");
	self.assertTrueMsg(invoice2.myVoyage = ti4.myVoyage, title &amp; "Voyage is incorrect on invoice2 ");
	self.assertTrueMsg(invoice2.myReleaseRequest = ti4.allBulkReleasesAssigned.first, title &amp; "Release Request is different on invoice2");
	
	self.deleteCleanup(); // ### NAVAB1 04MAR2024 - fixing UTs, delete everything.

epilog
	self.resetDefaultTranMap();
	delete pxyInvTypeDebtorSeparation;
	delete services;
	delete tiSet;
	delete vesselLocations;
end;</source>
    </JadeMethod>
    <JadeMethod name="tSeparationByVoyCargoGrp" id="e16bff85-08af-4437-aa51-9c8c195aca65">
        <source>tSeparationByVoyCargoGrp();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 April 2023 navmv20 TFS 56995 Task 57223: Jade - Invoice Debtor Separation Unit Tests

*/

constants
	Ref					: String = "56995";
	UT_Debtor1 			: String = "UT_" &amp; Ref &amp; "_Debtor2";
	UT_InvoiceDesc 		: String = "UT_" &amp; Ref &amp; "_InvoiceDesc";
	UT_BlockStackId 			: String = Ref &amp; "2B1";
	UT_VesselId					: String = "UT_" &amp; Ref &amp; "_VESS00008";
	UT_VoyageId					: String = "UT_" &amp; Ref &amp; "_VOY00008";
	UT_CalculationTypeCode		: String = "UT_" &amp; Ref;
	UT_GlCode					: String = "UT_" &amp; Ref &amp; "_GLCode";
	UT_GlRemarks				: String = "UT_" &amp; Ref &amp; " GL Code";
	UT_ServiceRemarks			: String = "UT_" &amp; Ref;
	UT_InvoiceLineDesc			: String = "UT_" &amp; Ref &amp; "_InvoiceLnDescSur";
	NullMSG						: String = " Expected: 'not null' | Actual: 'null'";
	UT_TransactionMapId			: String = "UT_" &amp; Ref;
	UT_CargoCommodity			: String = "FCL";
	UT_OperatorCode				: String = "UTSU";
	UT_CargoTypeCont			: String = "CONT";
	UT_IsoType					: String = "2200";
	UT_TrackedItem1			: String = "UT" &amp; Ref &amp; "011";
	UT_TrackedItem2			: String = "UT" &amp; Ref &amp; "012";
	UT_TrackedItem3			: String = "UT" &amp; Ref &amp; "021";
	UT_TrackedItem4			: String = "UT" &amp; Ref &amp; "022";
	UT_VesselDischLocn 			: String = "090488";
	UT_VesselDischLocn2 		: String = "090486";
	UT_VesselDischLocn3 		: String = "090484";
	
vars
	pxyInvTypeDebtorSeparation,
	realInvTypeDebtorSeparation 			: CM_InvTypeDebtorSeparation;
	invoiceType								: CM_InvoiceDesc;
	debtor1									: CM_Debtor;
	surchargesAndExemptions					: CM_InvoiceTypeSurchargeExempt;
	title,
	fileContent								: String;
	cargoMap								: CM_TranMap;
	error									: CM_Error;
	calcType 								: CM_CalculationType;
	glCode 						: CM_GLCode;
	service						: CM_Service;
	services                    : CM_ServiceByNameDict;
	invoiceLnType               : CM_InvoiceLineDesc;
	terminal                    : CM_Terminal;
	bank                        : CM_Bank;
	rootDebtor                  : CM_Debtor;
	ti1,
	ti2,
	ti3,
	ti4							: CM_TrackedItem;
	operator                    : CM_Operator;
	invoice1,
	invoice2					: CM_Invoice;
	vesselLocations				: StringArray;
	tiSet						: CM_TISet;
	voyage						: CM_Voyage;
	theSlot                     : CM_LocationsController;
	foundheight					: Integer;
	aPort                       : CM_Port;
	cargoType                   : CM_CargoType;
	blockStack                  : CM_BlockStack;
	vessel                      : CM_Vessel;
	cgId1,
	cgId2						: String;
	cg1,
	cg2							: CM_CargoGroup;
	allCargoToAssign			: CM_TISet;
	now							: TimeStamp;
	line						: CM_InvoiceLine;
	invoice						: CM_Invoice;
	tiSet1                      : CM_TISet;
	ti                          : CM_TrackedItem;
	
begin
	/*
	** Cleanup
	*/
	now := app.actualTimeServer;
	
	debtor1 := app.myRoot.myRootCompany.debtors[UT_Debtor1];
	self.deleteDebtor(debtor1);
	
	self.deleteInvoiceType(UT_InvoiceDesc);
	self.deleteOperator(UT_OperatorCode);
	
	self.deleteContainer(UT_TrackedItem1);
	self.deleteContainer(UT_TrackedItem2);
	self.deleteContainer(UT_TrackedItem3);
	self.deleteContainer(UT_TrackedItem4);
	
	// delete voyage
	self.deleteVoyage(UT_VoyageId);
	
	//Delete Vessel
	self.deleteVessel(UT_VesselId);
	
	//Terminal
	self.deleteTerminalArea(UT_BlockStackId);
	
	self.deleteCalculationType(UT_CalculationTypeCode,FORCED_ERASE);
	self.deleteService(UT_InvoiceLineDesc);
	self.deleteInvoiceGLCode(UT_GlCode);
	self.deleteInvoiceLineType(UT_InvoiceLineDesc, FORCED_ERASE);
	/*
	** Global Setup
	*/
	debtor1 := self.addDebtor(UT_Debtor1, PaymentType_None).CM_Debtor;
	self.assertNotNullMsg(debtor1, "Debtor1");
	
	terminal := self.getTerminal();
	self.assertTrueMsg(terminal &lt;&gt; null, title &amp; "terminal" &amp; NullMSG);
	
	bank := terminal.companies["DFBU"];
	self.assertTrueMsg(bank &lt;&gt; null, title &amp; "bank" &amp; NullMSG);
	
	rootDebtor := bank.rootDebtor;
	self.assertTrueMsg(rootDebtor &lt;&gt; null, title &amp; "rootDebtor" &amp; NullMSG);
	
	invoiceType	:= self.createInvoiceType(UT_InvoiceDesc, InvoiceTypeGeneral);
	self.assertNotNullMsg(invoiceType, "Invoice Type");
	
	self.addInvTypeSurchargeExempt(invoiceType, 0, null, null);
	
	surchargesAndExemptions	:= invoiceType.mySurchargeAndExemptions;
	self.assertNotNullMsg(surchargesAndExemptions, "Surcharges and Exemptions");
	
	
	calcType := self.createInvoiceCalcType(null, 0, UT_CalculationTypeCode, UT_CalculationTypeCode, 0, 0,0,0,null, false, null, null, 0, 0, INV_CALC_TYPE_UNITY,
											null, null, null, "UNITTEST", true, false, false, null, null, null, null);	
	self.assertTrueMsg(calcType &lt;&gt; null, title &amp; "calcType" &amp; NullMSG);
	
	glCode := self.createInvoiceGLCode(UT_GlCode, UT_GlRemarks);
	service := self.createInvoiceService(UT_InvoiceLineDesc, UT_ServiceRemarks, calcType, glCode);
	self.assertTrueMsg(glCode &lt;&gt; null, title &amp; "glCode" &amp; NullMSG);
	self.assertTrueMsg(service &lt;&gt; null, title &amp; "service" &amp; NullMSG);
	
	create services transient;
	services.add(service);
	
	invoiceLnType := self.createInvoiceLineType(UT_InvoiceLineDesc, calcType, invoiceType, services, "SDT1");
	self.assertTrueMsg(invoiceLnType &lt;&gt; null, title &amp; "invoiceLnType" &amp; NullMSG);
	
	beginTransaction;
	bank.getRootDebtorGroup().serviceRates[service].rateEntries.first.setCostPerUnit(50);
	commitTransaction;
	
	operator := self.addOperator(UT_OperatorCode, "UT_" &amp; Ref &amp; " Desc", false, null, null, debtor1, false, false, false, false, false, false, false, false, false, false, null, null, null, null, false, false, null, null, null, null, false, false);
	self.assertTrueMsg(operator &lt;&gt; null, title &amp; "operator" &amp; NullMSG);
	
	cargoType := app.myRoot.allCargoTypesById.getCargoTypeByAbbreviation(UT_CargoTypeCont);
	self.assertTrueMsg(cargoType &lt;&gt; null, title &amp; "cargoType" &amp; NullMSG);
	
	create vesselLocations transient;
	create tiSet transient;
	
	//Create Vessel
	vessel := self.addVesselCellular(UT_VesselId, operator);
	self.assertTrueMsg(vessel &lt;&gt; null, title &amp; "vessel" &amp; NullMSG);
	
	//Create voyage
	voyage := self.addVoyageWithContainerStructur(UT_VoyageId, UT_VesselId, operator.code,  self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertTrueMsg(voyage &lt;&gt; null, title &amp; "voyage" &amp; NullMSG);
	
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	self.assertTrueMsg(aPort &lt;&gt; null, title &amp; "aPort" &amp; NullMSG);
	
	blockStack := self.addBlockStack(UT_BlockStackId, 999, null);
	self.assertTrueMsg(blockStack &lt;&gt; null, title &amp; "blockStack" &amp; NullMSG);
	
	vesselLocations.add(UT_VesselDischLocn);
	voyage.findLocation(vesselLocations, false, theSlot, foundheight);
	
	title := "Separation By Voyage, Cargo Group Id";
	create pxyInvTypeDebtorSeparation transient;
	pxyInvTypeDebtorSeparation.setProxy(debtor1, null, true, false, false, true, false, false, false, false, surchargesAndExemptions);
	app.myTrxCA.trxCreateInvTypeDtrSeparation(pxyInvTypeDebtorSeparation, realInvTypeDebtorSeparation, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	self.verifyDebtorSepAttributes(realInvTypeDebtorSeparation,pxyInvTypeDebtorSeparation,title);
	
	fileContent := "TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Quantity Sub Type,Quantity Sub Range,Transfer Type,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?,Is Work Order Requested?" &amp; CrLf &amp;
	"Cargo," &amp; UT_TransactionMapId &amp; ",(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),,,**Any**,All," &amp; UT_InvoiceLineDesc;
	
	self.deleteTransactionMapByName(UT_TransactionMapId);
	self.transactionMapLoad(fileContent, UT_TransactionMapId);
	self.assertNoTrxErrorsOrWarnings();
	
	cargoMap := bank.myCurrentTranMapCargo[UT_TransactionMapId];
	self.assertTrueMsg(cargoMap &lt;&gt; null, title &amp; "cargoMap" &amp; NullMSG);
	
	app.myTrxUA.trxUpdateBankTMActive(cargoMap, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// testing Separation By Voyage, Cargo Group Id
	//positive scenario - voyage, cargo group id are same on cargos
	
	ti1:= self.setUpTrackedItem(UT_TrackedItem1,"ti1",TI_IMEX_STATUS_IMPORT,voyage,operator,cargoType,theSlot,aPort);
	ti2 := self.setUpTrackedItem(UT_TrackedItem2,"ti2",TI_IMEX_STATUS_IMPORT,voyage,operator,cargoType,theSlot,aPort);
	
	tiSet.clear();
	tiSet.add(ti2);
	tiSet.add(ti1);

	self.setUpCargoGroup("10",operator,tiSet);
	vesselLocations.clear;
	
	//move transaction
	self.moveCargo(ti1, null, blockStack.myLocationsController, app.myPassport);
	self.moveCargo(ti2, null, blockStack.myLocationsController, app.myPassport);
	
	if ti1.invoiceLines.isNotEmpty then
		invoice1 := ti1.invoiceLines.last.invoice;
	endif;
	
	if ti2.invoiceLines.isNotEmpty then
		invoice2 := ti2.invoiceLines.last.invoice;
	endif;

	self.assertTrueMsg(invoice1 = invoice2, title &amp; "invoices are not equal");
	self.assertTrueMsg(invoice1.myVoyage = ti1.myVoyage, title &amp; "Voyage is incorrect on invoice1 ");
	self.assertTrueMsg(invoice1.myCargoGroup = ti1.myCargoGroup, title &amp; "Cargo group is different on invoice1");
	self.assertTrueMsg(invoice2.myVoyage = ti2.myVoyage, title &amp; "Voyage is incorrect on invoice2 ");
	self.assertTrueMsg(invoice2.myCargoGroup = ti2.myCargoGroup, title &amp; "Cargo group is different on invoice2");

	//negative scenario - cargo groups are different on the cargos
	ti3 := self.setUpTrackedItem(UT_TrackedItem3,"ti3",TI_IMEX_STATUS_IMPORT,voyage,operator,cargoType,theSlot,aPort);
	ti4 := self.setUpTrackedItem(UT_TrackedItem4,"ti4",TI_IMEX_STATUS_IMPORT,voyage,operator,cargoType,theSlot,aPort);
	
	tiSet.clear();
	tiSet.add(ti3);

	self.setUpCargoGroup("11",operator,tiSet);
	
	tiSet.clear();
	tiSet.add(ti4);
	self.setUpCargoGroup("12",operator,tiSet);
	vesselLocations.clear;
	
	//move transaction
	self.moveCargo(ti3, null, blockStack.myLocationsController, app.myPassport);
	self.moveCargo(ti4, null, blockStack.myLocationsController, app.myPassport);
	
	if ti3.invoiceLines.isNotEmpty then
		invoice1 := ti3.invoiceLines.last.invoice;
	endif;
	
	if ti4.invoiceLines.isNotEmpty then
		invoice2 := ti4.invoiceLines.last.invoice;
	endif;

	self.assertTrueMsg(invoice1 &lt;&gt; invoice2, title &amp; "invoices are same");
	self.assertTrueMsg(invoice1.myVoyage = ti3.myVoyage, title &amp; "Voyage is incorrect on invoice1 ");
	self.assertTrueMsg(invoice1.myCargoGroup = ti3.myCargoGroup, title &amp; "Cargo group is different on invoice1");
	self.assertTrueMsg(invoice2.myVoyage = ti4.myVoyage, title &amp; "Voyage is incorrect on invoice2 ");
	self.assertTrueMsg(invoice2.myCargoGroup = ti4.myCargoGroup, title &amp; "Cargo group is different on invoice2");
epilog
	self.resetDefaultTranMap();
	delete pxyInvTypeDebtorSeparation;
	delete services;
	delete tiSet;
	delete vesselLocations;
end;</source>
    </JadeMethod>
    <JadeMethod name="tSetInvStatusWhenCancelRcvRoad" id="3b86b7db-a1b4-4c5a-8c62-cc6be428174e">
        <source>tSetInvStatusWhenCancelRcvRoad();
/* Test the status of an invoice after deleting a Road Job (WLE) according to terminal configuration
   as well as next action after the deletion relating to Release Road transaction creation (also depend on the terminal configuration)

   Teh terminal configuration that I am refering to is the 'Road Operations Delete Current Entry Option'

Purpose: Test the following
		 1. System behaviour after the deletion/cancellation of Road Job (WLE)
			Action will be based on terminal configuration.
		    Configuration options are :
			i. Road Receive Deleted, Road Release Created, Invoice Line REMAINS (Option No 1)
			ii. Road Receive Deleted, Road Release Created, Invoice Line VOIDED (Option No 2)
			iii. Road Receive Deleted, Road Release NOT Created, Invoice Line REMAINS (Option No 3)
			iv. Road Receive Deleted, Road Release NOT Created, Invoice Line VOIDED (Option No 4)
			
		 2. Creation of Receive Road Cancelled transaction

Date		Who		TFS		Reason
11 Nov 2019	jlgdi1	46578	Initial creation
*/

constants
	InvType_Receive = "UT_RCVROAD";
	CalType_Code_RcvRoad = "UT_CALTYPE_RR";
	CalType_Desc_RcvRoad = "UT_CalType_RR_Desc";
	Srvc_ReceiveCargo = "UT_SRVC_RCVROAD";
	InvLineType_Code = "UT_RCVROAD";
	Debtor_Type = "SDT1";
	TruckID1 = "UTT121";
	TruckID2 = "UTT122";
	TruckID3 = "UTT123";
	TruckID4 = "UTT124";
	DriverID1 = "UTD121";
	DriverID2 = "UTD122";
	DriverID3 = "UTD123";
	DriverID4 = "UTD124";
	State_UT = "UT";
	ISO_22G0 = "22G0";
	Commodity_MT = "MT";
	ContainerID1 = "ZZZZ1911112";
	ContainerID2 = "ZZZZ1911113";
	ContainerID3 = "ZZZZ1911114";
	ContainerID4 = "ZZZZ1911115";
	TransType_ReceivedRoad = "Received - Road";
	TransMap_UT = "UtTransMap";
	
vars
	transactionMapping : CM_TranMap;
	invType	: CM_InvoiceDesc;
	calType : CM_CalculationType;
	service : CM_Service;
	services : CM_ServiceByNameDict;
	invLineType : CM_InvoiceLineDesc;
	operator : CM_Operator;
	debtor : CM_Debtor;
	container1 : CM_TrackedItem;
	terminal : CM_Terminal;	
	gate : CM_Gate;
	singleGate : CM_Gate;
	vvr : CM_VehicleVisitRecord;
	transaction : CM_TITransaction;
	yardWLE : CM_YardWLE;
	invoiceLine : CM_InvoiceLine;
	prevRoadOpsDelCurEntry : Integer;
	container2 : CM_TrackedItem;
	container3 : CM_TrackedItem;
	container4 : CM_TrackedItem;
	rcvRoadTrans : CM_ReceiveRoad;
	rcvRoadCancelTrans : CM_ReceiveRoadCancelled;
	releaseRoadTrans : CM_ReleaseRoad;
	
begin
	/*
	I. Arrange Transaction Map - Invoice Type, Services, Invoice Line Type
	*/
	transactionMapping := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(transactionMapping,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(transactionMapping, app.myPassport);
	
	self.deleteService(Srvc_ReceiveCargo);
	self.deleteTransactionMapByName(TransMap_UT);
	
	self.deleteInvoiceType(InvType_Receive);
	invType := self.createInvoiceType(InvType_Receive, InvoiceTypeGeneral);
	self.assertNotNullMsg(invType, "Invoice type " &amp; InvType_Receive &amp; " not created");
	
	self.deleteCalculationType(CalType_Code_RcvRoad, FORCED_ERASE);
	calType := self.createInvoiceCalcType(null, INV_CALC_TYPE_WEIGHT, CalType_Code_RcvRoad,
										   CalType_Desc_RcvRoad, 0, 0, 0, 0,
										   null, false, null, null, 0, 0,
										   0, null, null, null,
										   null, true, null, null, 
										   null, null, null, null);
	self.assertNotNullMsg(calType, "Calculation type " &amp;  CalType_Desc_RcvRoad &amp; " not created");
	
	create services transient;
		
	service := self.createInvoiceService(Srvc_ReceiveCargo, Srvc_ReceiveCargo, calType, null);
	self.assertNotNullMsg(service, "Service " &amp; Srvc_ReceiveCargo &amp; " not created");
	services.add(service);
	
	self.deleteInvoiceLineType(InvLineType_Code, FORCED_ERASE);
	invLineType := self.createInvoiceLineType(InvLineType_Code, calType, invType, services, Debtor_Type);
	self.assertNotNullMsg(invLineType, "Invoice Line type " &amp; InvLineType_Code &amp; " not created");
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;
	
	self.loadTransMapReceiveRoad(TransMap_UT, TransType_ReceivedRoad, invLineType.narration);
	
	terminal := CM_Root.firstInstance.allTerminals[self.getProfileSetting(UT_Profile.P_TERMINAL).asString];
	
	prevRoadOpsDelCurEntry := terminal.getConfig(RoadOpsDelCurEntryOption).Integer;
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	gate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);
	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
		
	//  ###########  CONTAINER # 1 ########### 	
	/*  Case : terminal config set to OPTION 1 - Road Receive Deleted, Road Release Created, Invoice Line REMAINS
		Test the following 
		- Road Receive Deleted
		- Receive Road Cancel transaction CREATED
		- Road Release Created 
		- Invoice Line REMAINS
	*/
	self.setTerminalConfig(RoadOpsDelCurEntryOption, DEL_CUR_ENTRY_OPTION_1);
	
	self.deleteContainer(ContainerID1);
	self.deleteVehicle(TruckID1);
	
	vvr := self.gateInContainer(TruckID1,
								ContainerID1, 
								ISO_22G0, 
								operator.code,
								Commodity_MT,
								singleGate);
	self.assertNotNull(vvr);
	
	container1 := self.getTrackedItem(ContainerID1);	
	assertNotNull(container1);
	assertEqual(vvr.vehicle.allRoadJobs.size, 1);
	assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
	
	rcvRoadTrans := null;
	rcvRoadTrans := container1.getTransactionOfType(TRANS_TYPE_REC_ROAD).CM_ReceiveRoad;
	
	// Invoice Line still active (not void)
	self.assertNotNullMsg(rcvRoadTrans, "Container # 1 - Failed to create Receive Road transaction for ");
	self.assertFalseMsg(rcvRoadTrans.deleted, "Container # 1 - Road Receive transaction expected to be active");
	self.assertTrueMsg(rcvRoadTrans.allInvoiceLines.size &gt; 0, "Container # 1 - Failed to create Invoice Line for Receive Road transaction");
	
	self.deleteJobEntry(vvr.myRoadJob.workListEntries.first);
	
	// Assert (Road Receive Deleted, Release Road Created, Invoice Line REMAINS) &amp; Receive Road Cancel transaction CREATED
	self.assertTrueMsg(rcvRoadTrans.deleted, "Container # 1 - Road Receive transaction must be logically deleted");
	
	rcvRoadCancelTrans := container1.getTransactionOfType(TRANS_TYPE_RCVROADCANCELLED).CM_ReceiveRoadCancelled;
	self.assertNotNullMsg(rcvRoadCancelTrans, "Container#1 - Failed to create Receive Road Cancel transaction");
	
	releaseRoadTrans := container1.getTransactionOfType(TRANS_TYPE_REL_ROAD).CM_ReleaseRoad;
	self.assertNotNullMsg(releaseRoadTrans, "Container#1 - Failed to create Release Road transaction");
	
	foreach invoiceLine in rcvRoadTrans.allInvoiceLines do 
		self.assertFalseMsg(invoiceLine.voided, "Container # 1 - Invoice Line status should remain active");
	endforeach;
	
	self.deleteVVR(vvr);
	
	//  ###########  CONTAINER # 2 ########### 
	/*  Case : terminal config set to OPTION 2 - Road Receive Deleted, Road Release CREATED, Invoice Line VOIDED
		Test the following 
		- Road Receive Deleted
		- Receive Road Cancel transaction CREATED
		- Road Release CREATED
		- Invoice Line VOIDED
	*/
	self.setTerminalConfig(RoadOpsDelCurEntryOption, DEL_CUR_ENTRY_OPTION_2);
	self.deleteContainer(ContainerID2);
	self.deleteVehicle(TruckID2);		
	
	vvr := self.gateInContainer(TruckID2,
								ContainerID2, 
								ISO_22G0, 
								operator.code,
								Commodity_MT,
								singleGate);
	self.assertNotNull(vvr);
	
	container2 := self.getTrackedItem(ContainerID2);
	assertNotNull(container2);
	assertEqual(vvr.vehicle.allRoadJobs.size, 1);
	assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
	
	rcvRoadTrans := null;
	rcvRoadTrans := container2.getTransactionOfType(TRANS_TYPE_REC_ROAD).CM_ReceiveRoad;
	
	// Invoice Line still active (not void)
	self.assertNotNullMsg(rcvRoadTrans, "Container # 2 - Failed to create Receive Road transaction");
	self.assertFalseMsg(rcvRoadTrans.deleted, "Container # 2 - Initial status of Road Receive transaction must be active");
	self.assertTrueMsg(rcvRoadTrans.allInvoiceLines.size &gt; 0, "Container # 2 - Failed to create Invoice Line for Receive Road transaction");	
	
	self.deleteJobEntry(vvr.myRoadJob.workListEntries.first);
		
	// Assert (Road Receive DELETED, Release Road CREATED, Invoice Line VOIDED) &amp; Receive Road Cancel transaction CREATED
	self.assertTrueMsg(rcvRoadTrans.deleted, "Container # 2 - Road Receive transaction must be logically deleted");

	rcvRoadCancelTrans := null;
	rcvRoadCancelTrans := container2.getTransactionOfType(TRANS_TYPE_RCVROADCANCELLED).CM_ReceiveRoadCancelled;
	self.assertNotNullMsg(rcvRoadCancelTrans, "Container#2 - Failed to create Receive Road Cancel transaction");

	releaseRoadTrans := null;
	releaseRoadTrans := container2.getTransactionOfType(TRANS_TYPE_REL_ROAD).CM_ReleaseRoad;
	self.assertNotNullMsg(releaseRoadTrans, "Container#2 - Failed to create Release Road transaction");
	
	foreach invoiceLine in rcvRoadTrans.allInvoiceLines do 
		self.assertTrueMsg(invoiceLine.voided, "Container # 2 - Invoice Line status must be set to VOID");
	endforeach;
	
	self.deleteVVR(vvr);
	
	//  ###########  CONTAINER # 3 ########### 
	/*  Case : terminal config set to OPTION 3 - Road Receive Deleted, Road Release NOT CREATED, Invoice Line REMAINS
		Test the following 
		- Road Receive Deleted
		- Receive Road Cancel transaction CREATED
		- Road Release NOT CREATED
		- Invoice Line REMAINS
	*/
	self.setTerminalConfig(RoadOpsDelCurEntryOption, DEL_CUR_ENTRY_OPTION_3);	
	self.deleteContainer(ContainerID3);
	self.deleteVehicle(TruckID3);
	
	vvr := self.gateInContainer(TruckID3,
								 ContainerID3,
								 ISO_22G0, 
								 operator.code,
								 Commodity_MT,
								 singleGate);
	self.assertNotNull(vvr);
	
	container3 := self.getTrackedItem(ContainerID3);
	assertNotNull(container3);
	assertEqual(vvr.vehicle.allRoadJobs.size, 1);
	assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
	
	rcvRoadTrans := null;
	rcvRoadTrans := container3.getTransactionOfType(TRANS_TYPE_REC_ROAD).CM_ReceiveRoad;
	
	// Invoice Line still active (not void)
	self.assertNotNullMsg(rcvRoadTrans, "Container # 3 - Failed to create Receive Road transaction");
	self.assertFalseMsg(rcvRoadTrans.deleted, "Container # 3- Road Receive transaction expected to be active");
	self.assertTrueMsg(rcvRoadTrans.allInvoiceLines.size &gt; 0, "Container # 3 - Failed to create Invoice Line for Receive Road transaction");
	
	self.deleteJobEntry(vvr.myRoadJob.workListEntries.first);
	
	// Assert (Road Receive DELETED, Road Release NOT CREATED, Invoice Line REMAINS)  &amp; Receive Road Cancel transaction CREATED
	self.assertTrueMsg(rcvRoadTrans.deleted, "Container # 3 - Road Receive transaction must be logically deleted");
	
	rcvRoadCancelTrans := null;
	rcvRoadCancelTrans := container3.getTransactionOfType(TRANS_TYPE_RCVROADCANCELLED).CM_ReceiveRoadCancelled;
	self.assertNotNullMsg(rcvRoadCancelTrans, "Container#3 - Failed to create Receive Road Cancel transaction");	
	
	releaseRoadTrans := null;
	releaseRoadTrans := container3.getTransactionOfType(TRANS_TYPE_REL_ROAD).CM_ReleaseRoad;
	self.assertNullMsg(releaseRoadTrans, "Container#3 - Release Road transaction must not be created based on configuration");
	
	foreach invoiceLine in rcvRoadTrans.allInvoiceLines do 
		self.assertFalseMsg(invoiceLine.voided, "Container # 3 - Invoice Line status should remain active");
	endforeach;
	
	self.deleteVVR(vvr);
	
	//  ###########  CONTAINER # 4 ###########
	/*  Case : terminal config set to OPTION 4 - Road Receive Deleted, Road Release NOT CREATED, Invoice Line VOIDED
		Test the following 		
		- Road Receive Deleted
		- Receive Road Cancel transaction CREATED
		- Road Release NOT CREATED
		- Invoice Line VOIDED
	*/	
	self.setTerminalConfig(RoadOpsDelCurEntryOption, DEL_CUR_ENTRY_OPTION_4);
	
	self.deleteContainer(ContainerID4);
	self.deleteVehicle(TruckID4);
	
	vvr := self.gateInContainer(TruckID4,
								ContainerID4, 
								ISO_22G0, 
								operator.code,
								Commodity_MT,
								singleGate);
	self.assertNotNull(vvr);
	
	container4 := self.getTrackedItem(ContainerID4);
	assertNotNull(container4);
	assertEqual(vvr.vehicle.allRoadJobs.size, 1);
	assertEqual(vvr.vehicle.allRoadJobs.first.workListEntries.size, 1);
	
	rcvRoadTrans := null;
	rcvRoadTrans := container4.getTransactionOfType(TRANS_TYPE_REC_ROAD).CM_ReceiveRoad;
	
	// Invoice Line still active (not void)
	self.assertNotNullMsg(rcvRoadTrans, "Container # 4 - Failed to create Receive Road transaction");
	self.assertFalseMsg(rcvRoadTrans.deleted, "Container # 4 - Initial status of Road Receive transaction must be active");
	self.assertTrueMsg(rcvRoadTrans.allInvoiceLines.size &gt; 0, "Container # 4 - Failed to create Invoice Line for Receive Road transaction");	
	
	self.deleteJobEntry(vvr.myRoadJob.workListEntries.first);
	
	// Assert (Road Receive DELETED, Road Release NOT CREATED, Invoice Line VOIDED) &amp; Receive Road Cancel transaction CREATED
	self.assertTrueMsg(rcvRoadTrans.deleted, "Container # 4 - Road Receive transaction must be logically deleted");
	
	rcvRoadCancelTrans := null;
	rcvRoadCancelTrans := container4.getTransactionOfType(TRANS_TYPE_RCVROADCANCELLED).CM_ReceiveRoadCancelled;
	self.assertNotNullMsg(rcvRoadCancelTrans, "Container#4 - Failed to create Receive Road Cancel transaction");
	
	releaseRoadTrans := null;
	releaseRoadTrans := container4.getTransactionOfType(TRANS_TYPE_REL_ROAD).CM_ReleaseRoad;
	self.assertNullMsg(releaseRoadTrans, "Container#4 - Release Road transaction must not be created based on configuration");
	
	foreach invoiceLine in rcvRoadTrans.allInvoiceLines do 
		self.assertTrueMsg(invoiceLine.voided, "Container # 4 - Invoice Line status must be set to VOID");
	endforeach;
	
	self.deleteVVR(vvr);
	
epilog
	self.setTerminalConfig(RoadOpsDelCurEntryOption, prevRoadOpsDelCurEntry);
	self.resetDefaultTranMap();
	
	self.deleteInvoiceType(InvType_Receive);
	self.deleteCalculationType(CalType_Code_RcvRoad, FORCED_ERASE);
	self.deleteInvoiceLineType(InvLineType_Code, FORCED_ERASE);
	self.deleteTransactionMapByName(TransMap_UT);
	delete services;
	
	container1 := self.getTrackedItem(ContainerID1);
	if container1 &lt;&gt; null then 
		self.deleteContainer(ContainerID1);
	endif;
	container2 := self.getTrackedItem(ContainerID2);
	if container2 &lt;&gt; null then 
		self.deleteContainer(ContainerID2);
	endif;
	container3 := self.getTrackedItem(ContainerID3);
	if container3 &lt;&gt; null then 
		self.deleteContainer(ContainerID3);
	endif;
	container4 := self.getTrackedItem(ContainerID4);
	if container4 &lt;&gt; null then 
		self.deleteContainer(ContainerID4);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="tShipStartEscalatingStorage" id="b31d6c91-3fba-4933-9550-7f1d2f93531e">
        <updating/>
        <source>tShipStartEscalatingStorage() updating;
// cnwma1
// cnwjre1
/* ---------------------------------------------------------------------------
Created:     Feb 2010

Purpose:     test 26895 escalating storage when no linked storage transactions present
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	tranTS : TimeStamp;
	tranDate : Date;
	cargoMap	: CM_TranMap;
	theService : CM_Service;
	calType1		: CM_CalculationType;
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2,
	invLineType3,
	invLineType4  	: CM_InvoiceLineDesc;
	invoice	: CM_Invoice;
	services : CM_ServiceByNameDict;
	bs: CM_BlockStack;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
begin

	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

	bs:= self.getTerminalArea("UTSTORE").CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	self.deleteTerminalArea("UTSTORE");
	self.deleteInvoiceTransactionMap(1, 'UT_Storage');
	self.deleteInvoiceType("UT_InvTypeStore");
	self.deleteInvoiceService("UT_ServiceStore1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore3", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore4", FORCED_ERASE);

	create services transient;

	////////////////////////////////////////////////////////////////////
	// Create Invoice Type, Services and Invoice Line Type
	////////////////////////////////////////////////////////////////////
	invType := self.createInvoiceType("UT_InvTypeStore", InvoiceTypeStorage);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeStore not created");

	calType1 := app.myRoot.allCalculationTypesByCode['CCT06'];	// INV_CALC_TYPE_DAYS_SINCE_RECVL;
	self.assertNotNullMsg(calType1, "Calculation type INV_CALC_TYPE_DAYS_SINCE_RECVL not found");
	
	
	theService := self.createInvoiceService("UT_ServiceStore1","UT Store1", calType1, null);
	self.assertNotNullMsg(theService, "UT_ServiceStore1 not created");
 	services.add(theService);
	
	invLineType1 := self.createInvoiceLineType("UT_LineTypeStore1", calType1, invType, services,"SDT1");
	invLineType2 := self.createInvoiceLineType("UT_LineTypeStore2", calType1, invType, services,"SDT1");
	invLineType3 := self.createInvoiceLineType("UT_LineTypeStore3", calType1, invType, services,"SDT1");
	invLineType4 := self.createInvoiceLineType("UT_LineTypeStore4", calType1, invType, services,"SDT1");
	
	self.assertNotNullMsg(invLineType1, "UT_LineTypeStore1 not created");
	self.assertNotNullMsg(invLineType2, "UT_LineTypeStore2 not created");
	self.assertNotNullMsg(invLineType3, "UT_LineTypeStore3 not created");
	self.assertNotNullMsg(invLineType4, "UT_LineTypeStore4 not created");

	// Need to map to above invoice line types, using quantity ranges
	self.tranMapLoadShipStart();
	
	// create a container with retrospective transactions (refer example on PAR 24160)
	voy:=self.createVesselVoyage3();
	aPort := app.myRoot.allPorts["NZAKL"];
	bs:= addBlockStack("UTSTORE", 100, null);
	tranDate.setDate(1,5,2010);
	tranTS.setDate(tranDate);
	beginTransaction;
	voy.setPropertyValue("shipExchangeDate", tranTS);
	commitTransaction;

	// Create Storage Transactions
	cargo := self.addContainerAtLocnDisch("STOR2077441", "2200", "MT", TI_IMEX_STATUS_IMPORT, bs.myLocationsController, aPort, voy);
	self.createStorageTransactions13(cargo);
	self.reevalStorageTrans(cargo);
	self.validateStorageTransactions12(cargo);

	
epilog
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
	delete services;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tSimpleEscalatingStorage" id="1289b873-7f99-4e99-a67a-d16ed60b533b">
        <updating/>
        <source>tSimpleEscalatingStorage() updating;
// cnwma1
// cnwjre1
/* ---------------------------------------------------------------------------
Created:     Feb 2010

Purpose:     test 26895 escalating storage when no linked storage transactions present
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	cargoMap	: CM_TranMap;
	theService : CM_Service;
	calType1		: CM_CalculationType;
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2,
	invLineType3,
	invLineType4  	: CM_InvoiceLineDesc;
	invoice	: CM_Invoice;
	services : CM_ServiceByNameDict;
	bs: CM_BlockStack;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
begin

	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

	bs:= self.getTerminalArea("UTSTORE").CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	self.deleteTerminalArea("UTSTORE");
	self.deleteInvoiceTransactionMap(1, 'UT_Storage');
	self.deleteInvoiceType("UT_InvTypeStore");
	self.deleteInvoiceService("UT_ServiceStore1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore3", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore4", FORCED_ERASE);

	create services transient;

	////////////////////////////////////////////////////////////////////
	// Create Invoice Type, Services and Invoice Line Type
	////////////////////////////////////////////////////////////////////
	invType := self.createInvoiceType("UT_InvTypeStore", InvoiceTypeStorage);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeStore not created");

	calType1 := app.myRoot.allCalculationTypesByCode['CCT06'];	// INV_CALC_TYPE_DAYS_SINCE_RECVL;
	self.assertNotNullMsg(calType1, "Calculation type INV_CALC_TYPE_DAYS_SINCE_RECVL not found");
	
	
	theService := self.createInvoiceService("UT_ServiceStore1","UT Store1", calType1, null);
	self.assertNotNullMsg(theService, "UT_ServiceStore1 not created");
 	services.add(theService);
	
	invLineType1 := self.createInvoiceLineType("UT_LineTypeStore1", calType1, invType, services,"SDT1");
	invLineType2 := self.createInvoiceLineType("UT_LineTypeStore2", calType1, invType, services,"SDT1");
	invLineType3 := self.createInvoiceLineType("UT_LineTypeStore3", calType1, invType, services,"SDT1");
	invLineType4 := self.createInvoiceLineType("UT_LineTypeStore4", calType1, invType, services,"SDT1");
	
	self.assertNotNullMsg(invLineType1, "UT_LineTypeStore1 not created");
	self.assertNotNullMsg(invLineType2, "UT_LineTypeStore2 not created");
	self.assertNotNullMsg(invLineType3, "UT_LineTypeStore3 not created");
	self.assertNotNullMsg(invLineType4, "UT_LineTypeStore4 not created");

	// Need to map to above invoice line types, using quantity ranges
	self.tranMapLoadStorage();
	
	// create a container with retrospective transactions (refer example on PAR 24160)
	voy:=self.createVesselVoyage3();
	aPort := app.myRoot.allPorts["NZAKL"];
	bs:= addBlockStack("UTSTORE", 100, null);


	// Create Storage Transactions
	cargo := self.addContainerAtLocnDisch("STOR2077441", "2200", "MT", TI_IMEX_STATUS_IMPORT, bs.myLocationsController, aPort, voy);
	self.createStorageTransactions13(cargo);
	self.reevalStorageTrans(cargo);
	self.validateStorageTransactions12(cargo);

	
epilog
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
	delete services;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tSimpleFSEscalatingStorage1" id="40068767-31ac-4132-aeca-0ae7adeb914a">
        <updating/>
        <source>tSimpleFSEscalatingStorage1() updating;
// cnwma1
// cnwjre1
/* ---------------------------------------------------------------------------
Created:     Sep 2012

Purpose:     test 26895 escalating storage when no linked storage transactions present
			modified for CCMS 1295 free storage days, working days charged (not calendar)
			
			NOTE: This script is very hacky, is not really using MTN correctly, lots of assumptions and hard coded changing of data
			Basically having setup the storage config with weekends and holidays, it receives a piece of cargo and then has a hard coded create storage transaction. 
			This shoudl create a 2nd storage transaction, which represents the free storage period.
			This script tests that hte 2nd storage transaction is created correctly and thathe correct number of days are charged, taking into account the weekends and hoildays.
			
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	storageConfig	: CM_StorageConfig;
	storageDetail, storageDetailTI	: CM_StorageDetail;
	criteriaTypes : CM_YACriteriaTypeArray;
	triggers		: CM_StorageTriggerByType;
	calendar		: CM_Calendar;
	startDate		: Date;
	deriveDebtorFrom	: CM_DebtorType;
	firstDayTimeCutoff	: Time;
	includeFirstDay	: Boolean;
	includeLastDay	: Boolean;
	lastDayTimeCutoff	: Time;
	shipReceivalType	: Integer;
	shipReleaseType		: Integer;
	nullTime		: Time;
	criteria	: IntegerArray;

	cargoMap	: CM_TranMap;
	theService : CM_Service;
	calType1		: CM_CalculationType;
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2,
	invLineType3,
	invLineType4  	: CM_InvoiceLineDesc;
	services : CM_ServiceByNameDict;
	bs: CM_BlockStack;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
	allStoDtlCriterias 	: IntegerArray;
	allStoDtlCritValues	: ObjectArray;
begin
	self.deleteStorageConfig( false );
	self.deleteCalendar("UTSC", "UTDAY");
	
	
	// set up the storage calendar for 2012 with weekends (Saturday and Sunday) and at least one holiday in the period covered in cargo storage
	//  which is June/July/August
	calendar := self.createCalendar("UTSC", "Unit test storage calendar", false, false, "UTDAY");
	startDate := "07/01/2012".Date;	// first Saturday
	self.addBulkCalendarDates(calendar, startDate, 51, "Saturday");
	startDate := "01/01/2012".Date;	// first Sunday
	self.addBulkCalendarDates(calendar, startDate, 52, "Sunday");
	startDate := "22/06/2012".Date;		// a Friday
	self.addSingleCalendarDate(startDate, "Holiday1", calendar);
	startDate := "09/07/2012".Date;		// a Monday
	self.addSingleCalendarDate(startDate, "Holiday2", calendar);
	startDate := "07/08/2012".Date;		// a Tuesday
	self.addSingleCalendarDate(startDate, "Holiday3", calendar);
	
	// set up the storage config
	deriveDebtorFrom := app.myRoot.allDebtorTypes["SDT1"];		// cargo operator
	nullTime := "00:00".Time;
	firstDayTimeCutoff := nullTime;
	lastDayTimeCutoff := nullTime;
	includeLastDay := true;		// this corresponds to the non-storage config case
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_Commodity]);
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_ContainerLength]);
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_ContentsStatus]);
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_ImexStatus]);
	create triggers transient;

	storageConfig := self.createStorageConfig(criteriaTypes, triggers, deriveDebtorFrom, firstDayTimeCutoff, includeFirstDay, includeLastDay, lastDayTimeCutoff, shipReceivalType, shipReleaseType, calendar, null,null, -1, -1, -1);
	
	create allStoDtlCriterias transient;
	create allStoDtlCritValues transient;
	storageDetail := self.addStorageDetail(storageConfig, method.name, allStoDtlCriterias, allStoDtlCritValues, 5, 0, true, true, 0, 0, false, null); // NAVAB1 26OCT2023
	
	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

	bs:= self.getTerminalArea("UTSTORE").CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	self.deleteTerminalArea("UTSTORE");
	self.deleteInvoiceTransactionMap(1, 'UT_Storage');
	self.deleteInvoiceType("UT_InvTypeStore");
	self.deleteInvoiceService("UT_ServiceStore1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore3", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStore4", FORCED_ERASE);

	create services transient;

	////////////////////////////////////////////////////////////////////
	// Create Invoice Type, Services and Invoice Line Type
	////////////////////////////////////////////////////////////////////
	invType := self.createInvoiceType("UT_InvTypeStore", InvoiceTypeStorage);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeStore not created");

	calType1 := app.myRoot.allCalculationTypesByCode['CCT06'];	// INV_CALC_TYPE_DAYS_SINCE_RECVL;
	self.assertNotNullMsg(calType1, "Calculation type INV_CALC_TYPE_DAYS_SINCE_RECVL not found");
	
	
	theService := self.createInvoiceService("UT_ServiceStore1","UT Store1", calType1, null);
	self.assertNotNullMsg(theService, "UT_ServiceStore1 not created");
 	services.add(theService);
	
	invLineType1 := self.createInvoiceLineType("UT_LineTypeStore1", calType1, invType, services,"SDT1");
	invLineType2 := self.createInvoiceLineType("UT_LineTypeStore2", calType1, invType, services,"SDT1");
	invLineType3 := self.createInvoiceLineType("UT_LineTypeStore3", calType1, invType, services,"SDT1");
	invLineType4 := self.createInvoiceLineType("UT_LineTypeStore4", calType1, invType, services,"SDT1");
	
	self.assertNotNullMsg(invLineType1, "UT_LineTypeStore1 not created");
	self.assertNotNullMsg(invLineType2, "UT_LineTypeStore2 not created");
	self.assertNotNullMsg(invLineType3, "UT_LineTypeStore3 not created");
	self.assertNotNullMsg(invLineType4, "UT_LineTypeStore4 not created");

	// Need to map to above invoice line types, using quantity ranges
	self.tranMapLoadStorage();
	
	// create a container with retrospective transactions (refer example on PAR 24160)
	voy:=self.createVesselVoyage3();
	aPort := app.myRoot.allPorts["NZAKL"];
	bs:= addBlockStack("UTSTORE", 100, null);


	// Create Storage Transactions
	cargo := self.addContainerAtLocnDisch("STOR2077441", "2200", "MT", TI_IMEX_STATUS_IMPORT, bs.myLocationsController, aPort, voy);
	
	storageDetailTI := cargo.getMatchingFreeStorageDetail(null);
	self.assertTrueMsg(storageDetailTI = storageDetail, "DIfferent storageDetail object");
	
	// the 5 working days becomes 8 calendar days so the first no-charge storage transaction is dated 28/06/2012
	// transactions are back-dated to 20/06/2012 and storage created at 13/7/2012 which is 23 calendar days later but only 10 working days,
	//	with weekends and holidays as created above.  The 5 free days are handled by the no-charge storage transaction dated 28/06/2012
	//  and the 10 days going through the transaction map becomes invoice line quantities of 5, 4 and 1.
	self.createStorageTransactions15(cargo);
	
	self.reevalStorageTrans(cargo);
	self.validateStorageTransactions14(cargo);

	
epilog
	
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
	delete services;
	delete criteriaTypes;
	delete criteria;
	delete triggers;
	// DON'T leave the config around to affect subsequent storage tests
		self.deleteStorageConfig( true );
	self.deleteCalendar("UTSC", null);
	delete allStoDtlCriterias;
	delete allStoDtlCritValues;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tSnapshotBasic" id="02069c5a-c4aa-4a23-86a3-59aeb7c4aed1">
        <source>tSnapshotBasic();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 September 2017	jlgndl1	Initial creation	TFS 6759

*/

vars

	menuRoot : CM_MenuRootQuery;
	iter : Iterator;
	menuEntity : CM_MenuEntity;
	selectorQuery : CM_MenuUserQuery;
	snapshotDef : CM_OutputFormat_SS;
	service : CM_Service;
	invType : CM_InvoiceDesc;
	ssInvLineType : CM_InvoiceLineDesc;
	bank : CM_Bank;
	calcType : CM_CalculationType;
	services : CM_ServiceByNameDict;
	operator : CM_Operator;
	debtor : CM_Debtor;
	pxyDebtorRate : CM_DebtorRate;
	debtorRate : CM_DebtorRate;
	rateEntry : CM_RateEntry;
	pxyRateEntry : CM_RateEntry;
	costs : DecimalArray;
	start : TimeStamp;
	fileContent : String;
	fileName : String;
	mapName : String;
	ssMap : CM_TranMapSSSummary;
	agent : CM_OnsiteCargoAgent;
	term : CM_Terminal;
	snapshotData : CM_SnapshotData;
	ssb	: CM_SnapShotServiceBroker;
	invoice : CM_Invoice;
	invAlloc : CM_YardAllocation;
	qRMap : CM_QuantityRangeMap;
	invLineDesc : CM_InvoiceLineDesc;
	minChgInvLineType : CM_InvoiceLineDesc; 
	minChgInvLine : CM_InvoiceLine; 
	load : Boolean;
	defaultBank : CM_Bank;
	lineCount : Integer;
	
	ya	: CM_YardAllocation;
	ia	: CM_InvoiceAllocation;
	firstInvLine : CM_InvoiceLine;

begin
	term := self.getTerminal;
	defaultBank := term.getDefaultCompanyBank();
	bank := term.companies.getAtKey("DFBU");
	self.assertTrueMsg( defaultBank = bank, "Banks different in setup !!");
	menuRoot := app.myRoot.myQueryMenuRoot;
	iter := menuRoot.allChildren.createIterator;
	while iter.next( menuEntity ) do
		if not menuEntity.isKindOf( CM_MenuUserQuery ) then
			continue;
		endif;
		if menuEntity.CM_MenuUserQuery.heading = "UT_Empty" then
			selectorQuery := menuEntity.CM_MenuUserQuery;
			break;
		endif;
	endwhile;
	delete iter;
	if selectorQuery = null then
		self.assertTrueMsg( selectorQuery &lt;&gt; null, "Selector Query 'UT_Empty' not found, please re-create, see " &amp; method.qualifiedName);
		/*In selector query form, create the following query and 'save as' "UT_Empty"
		Cargo Type equal to ISO Container
		Site equal to On Site
		Terminal equal to UT
		Contents Status equal to Emptyish
		Id starts with UTG */
		return;
	endif;
	
	snapshotDef := app.myRoot.allOutputFormats_SS.getAtKey("UT_TFS6759");
	if snapshotDef = null then
		self.assertTrueMsg( snapshotDef &lt;&gt; null, "Snap shot definition 'UT_TFS6759' not found, please re-create, see " &amp; method.qualifiedName);
		/*
		Name = "UT_TFS6759"
		Description = "Invoice Onsite Container Count"
		Mode = "ISO Container"
		Selector = "UT_Empty"
		Business Unit = "Default Business Unit"
		Selected Items = "Id"   and   "Operator"
		Dat items:
		"Id","COUNT","COUNT(Id)"
		"Operator","COUNT","COUNT(Operator)"
		*/
		return;
	endif;
	
	service := self.myBank.services["USnapService"];
	if service &lt;&gt; null then
		self.deleteInvoicesUsingService(service);
	endif;
	self.deleteInvoiceService("USnapService", FORCED_ERASE);
	calcType := app.myRoot.allCalculationTypesByCode["CCT00"];	//Calculation Type = "Value of 1"
	self.assertTrueMsg( calcType &lt;&gt; null, "Failed to find calcType for 'USnapService' set up" );
	service := self.createInvoiceService("USnapService","TFS 6759", calcType, null);
	self.assertTrueMsg( service &lt;&gt; null, "Failed to create 'USnapService' during set up" );
	
	
	self.deleteInvoiceLineType("UT_Snapshot", FORCED_ERASE);
	self.deleteInvoiceLineType("UTSSMinChg", FORCED_ERASE);	
	create services transient;
 	services.add(service);
	invType := bank.findInvoiceType("Cargo");
	self.assertTrueMsg( invType &lt;&gt; null, "Failed to find invType for 'UT_Snapshot' set up" );
	ssInvLineType := self.createInvoiceLineType("UT_Snapshot", calcType, invType, services, null);
	self.assertTrueMsg( ssInvLineType &lt;&gt; null, "Failed to create invLineType 'UT_Snapshot' during set up" );
	
	//01 May 2019	NDL	TFS 44534
	minChgInvLineType := self.createInvoiceLineType("UTSSMinChg", calcType, invType, services, "SDT1");
	self.assertTrueMsg( minChgInvLineType &lt;&gt; null, "Minimum charge Line Type Not Created" );
	beginTransaction;
	minChgInvLineType.zSetInvoiceType( invType );
	ssInvLineType.setPropertyValue("minimumChargeAmount",1000.Real);
	ssInvLineType.setPropertyValue("minimumChargeGroupBy",CM_InvoiceLineDesc.GROUP_BY_INVOICE.Integer);
	ssInvLineType.setPropertyValue("minimumChargeInvoiceLineType",minChgInvLineType);
	commitTransaction;
	
	//Update the rate entry for the default dr
	create costs transient;
	costs.add(12.50);
	start.setDate("01/05/2010".Date);
	start.setTime("00:00".Time);
	rateEntry := service.debtorNodeRates.first.rateEntries.first;
	app.cmsBeginLoad(load);
	pxyRateEntry := rateEntry.pxyCreateUpdateProxy();
	app.cmsEndLoad(load);
	pxyRateEntry.setProxy(	costs,	//_cpus : DecimalArray;
							costs.first,	//_cpu : Decimal;
							service.debtorNodeRates.first,	//_rate : CM_Rate;
							null,	//_user : String;
							start,	//_start : TimeStamp;
							null,	//_expiry : TimeStamp;
							false,	//_ignoreEntry : Boolean;
							pxyRateEntry.adjustmentToBase,	//_adjustToBase : Decimal;
							pxyRateEntry.percentageOfBase,	//_percentOfBase : Decimal;
							pxyRateEntry.myRateDerived	//_parentRate : CM_Rate
							);
	app.myTrxUA.trxUpdateRateEntry(pxyRateEntry, app.myPassport);
	self.assertTrueMsg( rateEntry.getRawCostPerUnit = 12.5, "Default debtor rate not updated to 12.50 - " &amp; app.myPassport.getAllErrorsWarningsAsString );
	delete pxyRateEntry;
	
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);	
	debtor := operator.debtor;
	create pxyDebtorRate transient;
	pxyDebtorRate.setProxy(service, debtor);	
	rateEntry := self.addInvoiceRateEntry(pxyDebtorRate, start, null, false, costs, 0, 0, null, null);
	self.assertTrueMsg( rateEntry &lt;&gt; null, "No rate for Debtor " &amp; debtor.getOidString &amp; " - " &amp; app.myPassport.getAllErrorsWarningsAsString );
	
	// Create the new transaction map for snap shots
	
	fileName := "TFS6759";
	mapName := "UT_TFS6759";
	
	ssMap := bank.allSnapShotTranMaps[mapName];
	if ssMap &lt;&gt; null then
		ssb := ssMap.allSnapShotServiceBrokers.first();
		if ssb &lt;&gt; null then
			foreach invAlloc in ssb.allInvoiceAllocations do
				app.myTrxDA.trxDeleteInvoiceAllocation(invAlloc.CM_InvoiceAllocation, qRMap, invLineDesc, app.myPassport);
			endforeach;
		endif;
		if self.myBank.myCurrentTranMapSnapShot &lt;&gt; ssMap then
			app.myTrxDA.trxDeleteInvoiceTranMapSS(ssMap, app.myPassport);
		endif;
	endif;
		
fileContent := 
'TranMap Type,TranMap Name,Invoice Map,Id,Operator,Debtor Type,Quantity Attribute,Default,Range,Invoice Line' &amp; CrLf &amp;
'Snapshot Summary,'&amp;mapName&amp;','&amp;mapName&amp;',"(Default)","(Default)",SDT1 (Cargo Operator),COUNT (Id),true,0 to 99999999,VOID' &amp; CrLf &amp;
'Snapshot Summary,'&amp;mapName&amp;','&amp;mapName&amp;',"(Default)","UTOP, UTM2, UTM3",SDT1 (Cargo Operator),COUNT (Operator),false,1 to 99999999,UT_Snapshot' &amp; CrLf;
	 	
	//load up the snapshot transaction map
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	ssMap := bank.allSnapShotTranMaps[mapName];
	self.assertTrueMsg( ssMap &lt;&gt; null, "Snapshot Map not found" );
	
	//make the map active
	app.myTrxUA.trxUpdateBankTMSActive(ssMap,app.myPassport);
	self.assertTrueMsg( app.myPassport.trxCompletedOK, "Snapshot Map not made active - " &amp; app.myPassport.getAllErrorsWarningsAsString );

	//create daily snapshot using "snapshotDef" found earlier
	start := app.actualTimeAppServer;
	create agent transient;
	agent.createSnapshotSummaryData( term, snapshotDef, start.Date, start.Date );
	snapshotData := snapshotDef.allSnapshotDatas.last;
	self.assertTrueMsg( snapshotData &lt;&gt; null, "No Snapshot Data found" );
	self.assertTrueMsg( snapshotData.runDateTime.Date = start.Date, "The Snapshot Data we found isn't the one we generated" );
	self.assertTrueMsg( snapshotData.numberOfItems &gt; 0, "Snapshot Data found no cargo" );
	
	//generate invoices against the snapshot data using the new transaction map.
	ssb := ssMap.allSnapShotServiceBrokers[snapshotData.myOutputFormat_SS];
	app.myTrxUA.trxUpdateSnapshotCharge(ssb, snapshotData, app.myPassport);
	lineCount := snapshotData.getInvoiceLineCount;
	self.assertTrueMsg( lineCount &gt; 0, "No invoice lines generated from Snapshot data" );
	invoice := snapshotData.getFirstInvoice();
	self.assertTrueMsg( invoice &lt;&gt; null, "No Associated invoice found" );
	
	lineCount :=invoice.invoiceLines.size;
	
	// Post the invoice, then return it.
	self.postInvoice(invoice, false, false);

	self.assertTrueMsg(invoice.isPosted, "Snaphot based invoice did not post.");
	self.assertTrueMsg( invoice.invoiceLines.size &gt; lineCount, "Posting Invoice failed to add a minimium charge line" );

	//01 May 2019	NDL	TFS 44534
	minChgInvLine := invoice.invoiceLines.last;
	self.assertTrueMsg( minChgInvLine &lt;&gt; null, "Minimum Charge Line not found" );

	self.assertTrueMsg( invoice.getTotalAmount &gt;= 1000, "Invoice total should be 1000 was " &amp; invoice.getTotalAmount.String &amp; ", Operator = " &amp; operator.code &amp; " - " &amp; operator.getOidString );

	self.returnInvoice( invoice, true );
	self.assertTrueMsg(invoice.isReversed, "Snaphot based invoice did not post return.");
	self.assertTrueMsg(invoice.myReversedCreditInvoice &lt;&gt; null, "Snaphot based invoice 'Reverse Credit' invoice not found.");
	self.assertTrueMsg(invoice.myReversedCreditInvoice.isReverseCredit, "Snaphot based invoice 'Reverse Credit' invoice status incorrect.");
	self.assertTrueMsg(invoice.myReversedPendingInvoice &lt;&gt; null, "Snaphot based invoice 'Reverse Pending' invoice not found.");
	self.assertTrueMsg(invoice.myReversedPendingInvoice.isPending, "Snaphot based invoice 'Reverse Pending' invoice status incorrect.");
	
epilog

	self.resetDefaultTranMap();
	
	delete iter;
	delete services;
	delete costs;
	delete pxyDebtorRate;
	delete pxyRateEntry;
	delete agent;
	app.cmsEndLoad(load);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tStorageConstants" id="ea003800-c7a8-4a39-b35c-b0b34d3a1b5b">
        <source>tStorageConstants();
/*

Purpose:			

Parameters:			

dateTypeIntArray.add(Value:		

Date		Who		Reason
14 December 2016	cnwndl1	Initial creation	TFS 3119/3038
06 Jan 2017 - migrated up to UT_Invoicing so the data is created at the right time in teh overnight run.

*/

vars

	recDateTypeStrArray : StringArray;
	recDateTypeIntArray : IntegerArray;
	relDateTypeStrArray : StringArray;
	relDateTypeIntArray : IntegerArray;
	
	pos : Integer;
	str : String;
	int : Integer;
	
	voyage : CM_Voyage;
	ti : CM_TrackedItem;
	storage : CM_Storage;
	ts1 : TimeStamp;
	ts2 : TimeStamp;
	now : TimeStamp;
	firstAvailDate : Date;
	
	config : CM_StorageConfig;

begin

	//Voyage and Ti created by unit test UT_Invoicing::tReeferDailyFromRelease
	ti := self.getTerminal.allOffsiteTIsByIdCargoType.getAtKeyGeq("MRKU0910440",1,null);
	self.assertTrueMsg( ti &lt;&gt; null, "Container MRKU0910440 not found. Should have been set up by UT_Invoicing::tReeferDailyFromRelease");
	voyage := ti.myVoyage;
	self.assertTrueMsg( voyage &lt;&gt; null, "Voyage UTVOYROR2 not found. Should have been set up by UT_Invoicing::tReeferDailyFromRelease");
	storage := ti.allTransactions.getLastTransOfType(TRANS_TYPE_STORAGE,null).CM_Storage;
	self.assertTrueMsg( storage &lt;&gt; null, "No Storage Transaction found. Should have been set up by UT_Invoicing::tReeferDailyFromRelease");
	
	firstAvailDate := now.Date - 1;
	
	beginTransaction;
		voyage.setPropertyValue( CM_Voyage::dateFirstAvailable.name, firstAvailDate );
	commitTransaction;
	
	//build arrays of the respectibe options. (Same values as INV_StorageConfig::populateDateCombos)
	//Receival based First
	create recDateTypeStrArray transient;
	create recDateTypeIntArray transient;
	recDateTypeStrArray.add(Voyage_Actual_Discharge_Str);		recDateTypeIntArray.add(Voyage_Actual_Discharge);
	recDateTypeStrArray.add(Voyage_Anchor_Down_Str);			recDateTypeIntArray.add(Voyage_Anchor_Down);
	recDateTypeStrArray.add(Voyage_Arrival_Str);				recDateTypeIntArray.add(Voyage_Arrival);
	recDateTypeStrArray.add(Voyage_General_Landing_Str);		recDateTypeIntArray.add(Voyage_General_Landing);
	recDateTypeStrArray.add(Voyage_Labour_On_Board_Str);		recDateTypeIntArray.add(Voyage_Labour_On_Board);
	recDateTypeStrArray.add(Voyage_Pilot_On_Board_Str);			recDateTypeIntArray.add(Voyage_Pilot_On_Board);
	recDateTypeStrArray.add(Voyage_Rec_First_Day_Avail_Str);	recDateTypeIntArray.add(Voyage_Rec_First_Day_Avail);
	recDateTypeStrArray.add(Voyage_Rec_Labour_Ashore_Str);		recDateTypeIntArray.add(Voyage_Rec_Labour_Ashore);//7
	recDateTypeStrArray.add(Voyage_Rec_Ship_Exch_End_Str);		recDateTypeIntArray.add(Voyage_Rec_Ship_Exch_End);
	recDateTypeStrArray.add(Voyage_Ship_Exchange_Start_Str);	recDateTypeIntArray.add(Voyage_Ship_Exchange_Start);
	
	foreach pos in 1 to recDateTypeIntArray.size do
		int := recDateTypeIntArray[pos];
		ts1 := storage.getCargoStartTimeFSD( int, now );
		if int = Voyage_Rec_First_Day_Avail then
			self.assertTrueMsg( ts1.date = firstAvailDate, "Receival date for 'First Date Available' from trx incorrect(test 1)" );
		endif;
		ts2 := ti.getStartTimeFSD( int, now );
		if int = Voyage_Rec_First_Day_Avail then
			self.assertTrueMsg( ts2.date = firstAvailDate, "Receival date for 'First Date Available' from ti incorrect(test 2)" );
		endif;
		self.assertTrueMsg( ts1 = ts2, "Receival TimeStamps differ for '" &amp; recDateTypeStrArray[pos] &amp; "' between form rex and from ti(test 3)" );
	endforeach;
	

	//build arrays of the respective options. (Same values as INV_StorageConfig::populateDateCombos)
	//Release based
	create relDateTypeStrArray transient;
	create relDateTypeIntArray transient;
	relDateTypeStrArray.add(Voyage_Actual_Load_Str);			relDateTypeIntArray.add(Voyage_Actual_Load);
	relDateTypeStrArray.add(Voyage_Departed_Str);				relDateTypeIntArray.add(Voyage_Departed);	
	relDateTypeStrArray.add(Voyage_First_Day_Avail_Str);		relDateTypeIntArray.add(Voyage_First_Day_Avail);
	relDateTypeStrArray.add(Voyage_General_Landing_Str);		relDateTypeIntArray.add(Voyage_General_Landing);
	relDateTypeStrArray.add(Voyage_Labour_Ashore_Str);			relDateTypeIntArray.add(Voyage_Labour_Ashore);	//3
	relDateTypeStrArray.add(Voyage_Pilot_Return_Str);			relDateTypeIntArray.add(Voyage_Pilot_Return);
	relDateTypeStrArray.add(Voyage_Ship_Exchange_End_Str);		relDateTypeIntArray.add(Voyage_Ship_Exchange_End);
	relDateTypeStrArray.add(Voyage_Rel_Ship_Exch_Start_Str);	relDateTypeIntArray.add(Voyage_Rel_Ship_Exch_Start);
	relDateTypeStrArray.add(Voyage_Rel_Labour_Onboard_Str);		relDateTypeIntArray.add(Voyage_Rel_Labour_Onboard);
	
	create config transient;
	
	foreach pos in 1 to relDateTypeIntArray.size do
		int := relDateTypeIntArray[pos];
		config.setPropertyValue("shipReleaseType", int);
		ts1 := storage.getEndDateTimeFSD( int, config );
		if int = Voyage_First_Day_Avail then
			self.assertTrueMsg( ts1.date = firstAvailDate, "Release date for 'First Date Available' from trx incorrect(test 4)" );
		endif;
	endforeach;
	
epilog

	delete recDateTypeStrArray;
	delete recDateTypeIntArray;
	delete relDateTypeStrArray;
	delete relDateTypeIntArray;
	delete config;

end;</source>
    </JadeMethod>
    <JadeMethod name="tStorageDaysCalc1EOPRecFirst" id="c066f169-8c92-4a8c-91b9-c7ca4c0eeb03">
        <updating/>
        <source>tStorageDaysCalc1EOPRecFirst() updating;
//
//30 Mar 2016	cnwrs1	TFS 1479 create storage for inclusive dates over EOP
// The EOP is run on the same night as the container was received, check that if include first day then a 1 day storage is created by EOP, they are allowed to be one day over but not 1 day under
//
constants
	USE_INVLINE = false;
vars
	cargo : CM_TrackedItem;
	tran : CM_Transaction;
	idx : Integer;
	days : Integer;
begin
// Changes for TFS 45574 24 Jul 2019


	cargo := self.storageDaysCalculation(false, false, true, -4, 1, -4, 0, 0, 0, USE_INVLINE);
	idx := 0;
	foreach tran in cargo.allTransactions do
		if tran.getType = TRANS_TYPE_STORAGE then
			days := tran.CM_TITransaction.getDetails.extractInteger;
			if days = 0 then
				continue;
			endif;
			idx := idx + 1;
			if idx = 1 then
				self.assertIsOneOf(days, "Incorrect Storage Days Test A", 3, 4);
			else
				self.assertEqualMsg(true, false, " more Storage transactions then expected Test A.");
			endif;
		endif;
	endforeach;

	cargo := self.storageDaysCalculation(false, true, true, -4, 1, -4, 0, 0, 0, USE_INVLINE);
	idx := 0;
	foreach tran in cargo.allTransactions do
		if tran.getType = TRANS_TYPE_STORAGE then
			days := tran.CM_TITransaction.getDetails.extractInteger;
			if days = 0 then
				continue;
			endif;
			idx := idx + 1;
			if idx = 1 then
				self.assertIsOneOf(days, "Incorrect Storage Days Test B", 4, 5);
			else
				self.assertEqualMsg(true, false, " more Storage transactions then expected. Test B");
			endif;
		endif;
	endforeach;
//	write("true false true");
	cargo := self.storageDaysCalculation(true, false, true, -4, 1, -4, 0, 0, 0, USE_INVLINE);
	idx := 0;
	foreach tran in cargo.allTransactions do
		if tran.getType = TRANS_TYPE_STORAGE then
			days := tran.CM_TITransaction.getDetails.extractInteger;
			if days = 0 then
				continue;
			endif;
			idx := idx + 1;
			if idx = 1 then
				self.assertIsOneOf(days, "Incorrect Storage Days Test C", 1, 2);
			elseif idx = 2 then
				self.assertIsOneOf(days, "Incorrect Storage Days Test D", 3, 4);
			else
				self.assertEqualMsg(true, false, " more Storage transactions then expected. Test CD");
			endif;
		endif;
	endforeach;

	cargo := self.storageDaysCalculation(true, true, true, -4, 1, -4, 0, 0, 0, USE_INVLINE);
	idx := 0;
	foreach tran in cargo.allTransactions do
		if tran.getType = TRANS_TYPE_STORAGE then
			days := tran.CM_TITransaction.getDetails.extractInteger;
			if days = 0 then
				continue;
			endif;
			idx := idx + 1;
			if idx = 1 then
				self.assertIsOneOf(days, "Incorrect Storage Days Test E", 1, 2);
			elseif idx = 2 then
				self.assertIsOneOf(days, "Incorrect Storage Days Test F", 4, 5);
			else
				self.assertEqualMsg(true, false, " more Storage transactions then expected. Test EF");
			endif;
		endif;
	endforeach;
	
epilog

	self.deleteStorageConfig( true );
end;
</source>
    </JadeMethod>
    <JadeMethod name="tStorageDaysCalc1EOPRelLast" id="7bf82810-ef88-4ae1-910a-b7e42ddf2cf9">
        <updating/>
        <source>tStorageDaysCalc1EOPRelLast() updating;
//
//30 Mar 2016	cnwrs1	TFS 1479 create storage for inclusive dates over EOP
// The EOP is run on the same night as the container was released, check that if include last day then a 1 day storage is created for the relase tran, they are allowed to be one day over but not 1 day under
//
constants
	USE_INVLINE = false;
vars
	cargo : CM_TrackedItem;
	tran : CM_Transaction;
	idx : Integer;
	days : Integer;
begin
// Changes for TFS 45574 24 Jul 2019

	cargo := self.storageDaysCalculation(false, false, true, -4, 1, 0, 0, 0, 0, USE_INVLINE);
	idx := 0;
	foreach tran in cargo.allTransactions do
		if tran.getType = TRANS_TYPE_STORAGE then
			days := tran.CM_TITransaction.getDetails.extractInteger;
			if days = 0 then
				continue;
			endif;
			idx := idx + 1;
			if idx = 1 then
				self.assertIsOneOf(days, "Incorrect Storage Days", 3, 4);
			else
				self.assertEqualMsg(true, false, " more Storage transactions then expected.");
			endif;
		endif;
	endforeach;

	cargo := self.storageDaysCalculation(false, true, true, -4, 1, 0, 0, 0, 0, USE_INVLINE);
	idx := 0;
	foreach tran in cargo.allTransactions do
		if tran.getType = TRANS_TYPE_STORAGE then
			days := tran.CM_TITransaction.getDetails.extractInteger;
			if days = 0 then
				continue;
			endif;
			idx := idx + 1;
			if idx = 1 then
				self.assertIsOneOf(days, "Incorrect Storage Days", 4, 5);
			else
				self.assertEqualMsg(true, false, " more Storage transactions then expected.");
			endif;
		endif;
	endforeach;
	cargo := self.storageDaysCalculation(true, false, true, -4, 1, 0, 0, 0, 0, USE_INVLINE);
	idx := 0;
	foreach tran in cargo.allTransactions do
		if tran.getType = TRANS_TYPE_STORAGE then
			days := tran.CM_TITransaction.getDetails.extractInteger;
			if days = 0 then
				continue;
			endif;
			idx := idx + 1;
			if idx = 1 then
				self.assertIsOneOf(days, "Incorrect Storage Days", 5, 6);
			elseif idx = 2 then
				self.assertIsOneOf(days, "Incorrect Storage Days", 1, 2);
			else
				self.assertEqualMsg(true, false, " more Storage transactions then expected.");
			endif;
		endif;
	endforeach;
	cargo := self.storageDaysCalculation(true, true, true, -4, 1, 0, 0, 0, 0, USE_INVLINE);
	idx := 0;
	foreach tran in cargo.allTransactions do
		if tran.getType = TRANS_TYPE_STORAGE then
			days := tran.CM_TITransaction.getDetails.extractInteger;
			if days = 0 then
				continue;
			endif;
			idx := idx + 1;
			if idx = 1 then
				self.assertIsOneOf(days, "Incorrect Storage Days", 4, 5);
			elseif idx = 2 then
				self.assertIsOneOf(days, "Incorrect Storage Days", 1, 2);
			else
				self.assertEqualMsg(true, false, " more Storage transactions then expected.");
			endif;
		endif;
	endforeach;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tStorageDaysCalculation1EOP" id="c8c04b6a-6617-4ffb-9fbd-4cab3eb4aa95">
        <updating/>
        <source>tStorageDaysCalculation1EOP() updating;
//
//08 Mar 2016	cnwrs1	TFS 1479 create storage for inclusive dates over EOP
// The EOP is run between the container being recived and released the 2 storage transactions should be correct, they are allowed to be one day over but not 1 day under
//
constants
	USE_INVLINE = false;
vars
	cargo : CM_TrackedItem;
	tran : CM_Transaction;
	idx : Integer;
	days : Integer;
begin
	cargo := self.storageDaysCalculation(false, false, true, -8, 1, -4, 0, 0, 0, USE_INVLINE);
	idx := 0;
	foreach tran in cargo.allTransactions do
		if tran.getType = TRANS_TYPE_STORAGE then
			days := tran.CM_TITransaction.getDetails.extractInteger;
			if days = 0 then
				continue;
			endif;
			idx := idx + 1;
			if idx = 1 then
				self.assertIsOneOf(days, "Incorrect Storage Days", 4, 5);
			elseif idx = 2 then
				self.assertIsOneOf(days, "Incorrect Storage Days", 3, 4);
			else
				self.assertEqualMsg(true, false, " more Storage transactions then expected.");
			endif;
		endif;
	endforeach;
	
	cargo := self.storageDaysCalculation(false, true, true, -8, 1, -4, 0, 0, 0, USE_INVLINE);
	idx := 0;
	foreach tran in cargo.allTransactions do
		if tran.getType = TRANS_TYPE_STORAGE then
			days := tran.CM_TITransaction.getDetails.extractInteger;
			if days = 0 then
				continue;
			endif;
			idx := idx + 1;
			if idx = 1 then
				self.assertIsOneOf(days, "Incorrect Storage Days", 4, 5);
			elseif idx = 2 then
				self.assertIsOneOf(days, "Incorrect Storage Days", 4, 5);
			else
				self.assertEqualMsg(true, false, " more Storage transactions then expected.");
			endif;
		endif;
	endforeach;
	
	cargo := self.storageDaysCalculation(true, false, true, -8, 1, -4, 0, 0, 0, USE_INVLINE);
	idx := 0;
	foreach tran in cargo.allTransactions do
		if tran.getType = TRANS_TYPE_STORAGE then
			days := tran.CM_TITransaction.getDetails.extractInteger;
			if days = 0 then
				continue;
			endif;
			idx := idx + 1;
			if idx = 1 then
				self.assertIsOneOf(days, "Incorrect Storage Days", 5, 6);
			elseif idx = 2 then
				self.assertIsOneOf(days, "Incorrect Storage Days", 3, 4);
			else
				self.assertEqualMsg(true, false, " more Storage transactions then expected.");
			endif;
		endif;
	endforeach;
	
	cargo := self.storageDaysCalculation(true, true, true, -8, 1, -4, 0, 0, 0, USE_INVLINE);
	idx := 0;
	foreach tran in cargo.allTransactions do
		if tran.getType = TRANS_TYPE_STORAGE then
			days := tran.CM_TITransaction.getDetails.extractInteger;
			if days = 0 then
				continue;
			endif;
			idx := idx + 1;
			if idx = 1 then
				self.assertIsOneOf(days, "Incorrect Storage Days", 5, 6);
			elseif idx = 2 then
				self.assertIsOneOf(days, "Incorrect Storage Days", 3, 4);
			else
				self.assertEqualMsg(true, false, " more Storage transactions then expected.");
			endif;
		endif;
	endforeach;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tStorageDaysCalculation2EOP" id="4e3f0c3e-973b-4d55-a8f8-85f29f3b3e06">
        <updating/>
        <source>tStorageDaysCalculation2EOP() updating;
//
//08 Mar 2016	cnwrs1	TFS 1479 create storage for inclusive dates over EOP
// two EOPs are run between the container being recived and released the 3 storage transactions should be correct, they are allowed to be one day over but not 1 day under
//
constants
	USE_INVLINE = false;
vars
	cargo : CM_TrackedItem;
	tran : CM_Transaction;
	idx : Integer;
	days : Integer;
begin

	cargo := self.storageDaysCalculation(false, false, true, -10, 2, -6, -3, 0, 0, USE_INVLINE);
	idx := 0;
	foreach tran in cargo.allTransactions do
		if tran.getType = TRANS_TYPE_STORAGE then
			days := tran.CM_TITransaction.getDetails.extractInteger;
			if days = 0 then
				continue;
			endif;
			idx := idx + 1;
			if idx = 1 then
				days := tran.CM_TITransaction.getDetails.extractInteger;
				self.assertIsOneOf(days, "Incorrect Storage Days", 4, 5);
			elseif idx = 2 then
				days := tran.CM_TITransaction.getDetails.extractInteger;
				self.assertIsOneOf(days, "Incorrect Storage Days", 3, 4);
			elseif idx = 3 then
				days := tran.CM_TITransaction.getDetails.extractInteger;
				self.assertIsOneOf(days, "Incorrect Storage Days", 2, 3);
			else
				self.assertEqualMsg(true, false, " more Storage transactions then expected.");
			endif;
		endif;
	endforeach;
	
	cargo := self.storageDaysCalculation(false, true, true, -10, 2, -6, -3, 0, 0, USE_INVLINE);
	idx := 0;
	foreach tran in cargo.allTransactions do
		if tran.getType = TRANS_TYPE_STORAGE then
			days := tran.CM_TITransaction.getDetails.extractInteger;
			if days = 0 then
				continue;
			endif;
			idx := idx + 1;
			if idx = 1 then
				self.assertIsOneOf(days, "Incorrect Storage Days", 4, 5);
			elseif idx = 2 then
				self.assertIsOneOf(days, "Incorrect Storage Days", 3, 4);
			elseif idx = 3 then
				self.assertIsOneOf(days, "Incorrect Storage Days", 3, 4);
			else
				self.assertEqualMsg(true, false, " more Storage transactions then expected.");
			endif;
		endif;
	endforeach;
	
	cargo := self.storageDaysCalculation(true, false, true, -10, 2, -6, -3, 0, 0, USE_INVLINE);
	idx := 0;
	foreach tran in cargo.allTransactions do
		if tran.getType = TRANS_TYPE_STORAGE then
			days := tran.CM_TITransaction.getDetails.extractInteger;
			if days = 0 then
				continue;
			endif;
			idx := idx + 1;
			if idx = 1 then
				self.assertIsOneOf(days, "Incorrect Storage Days", 5, 6);
			elseif idx = 2 then
				self.assertIsOneOf(days, "Incorrect Storage Days", 3, 4);
			elseif idx = 3 then
				self.assertIsOneOf(days, "Incorrect Storage Days", 2, 3);
			else
				self.assertEqualMsg(true, false, " more Storage transactions then expected.");
			endif;
		endif;
	endforeach;
	
	cargo := self.storageDaysCalculation(true, true, true, -10, 2, -6, -3, 0, 0, USE_INVLINE);
	idx := 0;
	foreach tran in cargo.allTransactions do
		if tran.getType = TRANS_TYPE_STORAGE then
			days := tran.CM_TITransaction.getDetails.extractInteger;
			if days = 0 then
				continue;
			endif;
			idx := idx + 1;
			if idx = 1 then
				self.assertIsOneOf(days, "Incorrect Storage Days", 5, 6);
			elseif idx = 2 then
				self.assertIsOneOf(days, "Incorrect Storage Days", 3, 4);
			elseif idx = 3 then
				self.assertIsOneOf(days, "Incorrect Storage Days", 3, 4);
			else
				self.assertEqualMsg(true, false, " more Storage transactions then expected.");
			endif;
		endif;
	endforeach;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tStorageDaysCalculationNoEOP" id="fc4fae82-987d-49fb-8d14-79ed0a86ed14">
        <updating/>
        <source>tStorageDaysCalculationNoEOP() updating;
//
//08 Mar 2016	cnwrs1	TFS 1479 create storage for inclusive dates over EOP
// No EOP is run between the container being recived and released the storage transactions should be correct, it is allowed to be one day over but not 1 day under
//
constants
	USE_INVLINE = false;
vars
	cargo : CM_TrackedItem;
	tran : CM_Transaction;
	idx : Integer;
	days : Integer;
begin

	cargo := self.storageDaysCalculation(false, false, true, -8, 0, 0, 0, 0, 0, USE_INVLINE);
	idx := 0;
	foreach tran in cargo.allTransactions do
		if tran.getType = TRANS_TYPE_STORAGE then
			days := tran.CM_TITransaction.getDetails.extractInteger;
			if days = 0 then
				continue;
			endif;
			idx := idx + 1;
			if idx = 1 then
				self.assertIsOneOf(days, "Incorrect Storage Days", 7, 8);
			else
				self.assertEqualMsg(true, false, " more Storage transactions then expected.");
			endif;
		endif;
	endforeach;
	
	cargo := self.storageDaysCalculation(false, true, true, -8, 0, 0, 0, 0, 0, USE_INVLINE);
	idx := 0;
	foreach tran in cargo.allTransactions do
		if tran.getType = TRANS_TYPE_STORAGE then
			days := tran.CM_TITransaction.getDetails.extractInteger;
			if days = 0 then
				continue;
			endif;
			idx := idx + 1;
			if idx = 1 then
				self.assertIsOneOf(days, "Incorrect Storage Days", 8, 9);
			else
				self.assertEqualMsg(true, false, " more Storage transactions then expected.");
			endif;
		endif;
	endforeach;
	
	cargo := self.storageDaysCalculation(true, false, true, -8, 0, 0, 0, 0, 0, USE_INVLINE);
	idx := 0;
	foreach tran in cargo.allTransactions do
		if tran.getType = TRANS_TYPE_STORAGE then
			days := tran.CM_TITransaction.getDetails.extractInteger;
			if days = 0 then
				continue;
			endif;
			idx := idx + 1;
			if idx = 1 then
				self.assertIsOneOf(days, "Incorrect Storage Days", 8, 9);
			else
				self.assertEqualMsg(true, false, " more Storage transactions then expected.");
			endif;
		endif;
	endforeach;
	
	cargo := self.storageDaysCalculation(true, true, true, -8, 0, 0, 0, 0, 0, USE_INVLINE);
	idx := 0;
	foreach tran in cargo.allTransactions do
		if tran.getType = TRANS_TYPE_STORAGE then
			days := tran.CM_TITransaction.getDetails.extractInteger;
			if days = 0 then
				continue;
			endif;
			idx := idx + 1;
			if idx = 1 then
				self.assertIsOneOf(days, "Incorrect Storage Days", 9, 10);
			else
				self.assertEqualMsg(true, false, " more Storage transactions then expected.");
			endif;
		endif;
	endforeach;
end;
</source>
    </JadeMethod>
