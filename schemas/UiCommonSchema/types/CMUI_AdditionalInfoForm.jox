    <JadeMethod name="showWithObjectMode" id="7ffe7fc4-227e-4d91-bcdf-02fe088ea9c1">
        <updating/>
        <source>showWithObjectMode(_object: Object; _doMode: Boolean) updating;
//--------------------------------------------------
// Created:	16 December 2005 By: cnwgd1
//--------------------------------------------------
