    <JadeMethod name="loadCurrentTime" id="8a7d75ac-25a9-4c5a-aacf-f0cb9eeeaf00">
        <source>loadCurrentTime( _startTime : TimeStamp; _action : String ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 March 2021	navndl1	Initial creation	TFS 

*/

vars

	endTime : TimeStamp;
	tsi : TimeStampInterval;
	milliSeconds : Integer64;
	returnStr : String;

begin

	endTime := app.actualTimeAppServer;
	tsi := endTime - _startTime;
	milliSeconds := tsi.getMilliseconds();
	returnStr := _action &amp; " " &amp; milliSeconds.String;
	
	return returnStr;

epilog

end;</source>
        <Parameter name="_startTime" type="TimeStamp"/>
        <Parameter name="_action" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="loadCurrentVoyage" id="aa69af75-3319-4515-8d0a-318154f77ad5">
        <updating/>
        <source>loadCurrentVoyage()updating;
//--------------------------------------------------
// Created:	17 October 2003 By: cnwgd1
//--------------------------------------------------
// Changed On	Changed By	Reason
// ----------	----------	------------------------------------
// 18/07/2022	navdap1		TFS 53889 EUP Collapsed view not kept when moving or updating cargo
// 08/11/2022	navmd1		TFS 55379 Refactor VoyageOpsCG Form
// 28/11/2022	navkc1		ChangeRequest 55408: MTN - Cargo Group Ops Form - Only show cargo groups by default
// 08/12/2022	navkc1		ChangeRequest 55409: MTN - Voyage Ops Form - Pagination of tables
// 24/02/2024 	navcs2 		MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
vars
	startTime 	: TimeStamp;
	passport 	: CM_Passport;
	cmifMonitor : CMIF_Monitor;
	totalParts,
	currentPart	: Integer;
begin
	on Exception do self.handleInterruptExceptions(exception);
	
	passport := app.myPassport;
	
	self.doNotableClear();
	
	//15 Mar 2021	NDL	TFS 50935
	if listeningForTiNotes then
		self.listeningForTiNotes := false;
		//clear notes and table collections.
		self.endClassNotification( CM_TrackedItem, false,  self.myTerminal.getTerminalEvent(EVENT_TI_Voyage_Chg) );
	endif;
	
	if self.myCurrentVoyage = null then
		self.tblOffsite.rows := self.tblOffsite.fixedRows;
		self.tblOnsite.rows := self.tblOffsite.fixedRows;
		self.tblOnship.rows := self.tblOffsite.fixedRows;
		self.tblPreNote.rows := self.tblPreNote.fixedRows;
		self.lblOffsiteCount.caption := null;
		self.lblOnshipCount.caption := null;
		self.lblOnsiteCount.caption := null;
		self.lblPreNoteCount.caption := null;
		return;
	endif;
	/* //30/07/2025	navkc1 JIRA MTN 35478
	if self.performRefresh = self.RefreshCurrentViewOnly then	//15 Mar 2021	NDL	TFS 50935
		//individual notes are armed in "loadCargoForTable" for this mode
		self.listeningForTiNotes := true; // listening at TI level
		self.beginClassNotification( CM_TrackedItem, false, self.myTerminal.getTerminalEvent(EVENT_TI_Voyage_Chg), Response_Continuous, self.myTerminal.getTerminalEvent(EVENT_TI_Voyage_Chg) );
	else*/if not self.listeningForClassNotes then
		self.listeningForClassNotes := true;	// listening at Class level
		self.beginClassNotification( CM_TrackedItem, false, Any_System_Event, Response_Continuous, 1);
	endif;
	
	app.mousePointer := self.MousePointer_HourGlass;	
	
	if passport.myCMIFMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		passport.setMyCMIFMonitor(cmifMonitor);
	endif;
	
	self.modalDialogReturnValue := self.ModalDialogReturn_Null;	
	self.modalDialogShow(null, 'Cancel' , null, null, app.getErrorString1(Loading_voyage, self.myCurrentVoyage.code),  'Please Wait....');
	self.pbProgressBar.visible := true;
	self.btnModalDefault.visible := true;
	
	totalParts := 10;
	currentPart := 1;
	
// ##### Off-Site Cargo	 #####
	
	cmifMonitor.updateProgress(app.getErrorString(Loading_offsite_cargo), totalParts, currentPart);
	startTime := app.actualTimeAppServer;
	
	self.loadOffsiteTable(null, true); // 08/12/2022	navkc1	#55409
	currentPart += 1;
	
	app.writeLog(self.loadCurrentTime( startTime, "Off Site Tables load took"), LogTRACE);

// ##### On-Ship Cargo #####
	
	if not cmifMonitor.updateProgress(app.getErrorString(Loading_onship_cargo), totalParts, currentPart) then
		return;	// User Cancelled the load
	endif;
	startTime := app.actualTimeAppServer;
	
	self.loadOnShipTable(null, true); // 08/12/2022	navkc1	#55409
	currentPart += 1;
	
	app.writeLog(self.loadCurrentTime( startTime, "On Ship Tables load took"), LogTRACE);
	
// ##### On-Site Cargo #####
	
	if not cmifMonitor.updateProgress(app.getErrorString(Loading_onsite_cargo), totalParts, currentPart) then
		return;	// User Cancelled the load
	endif;
	startTime := app.actualTimeAppServer;
	
	self.loadOnsiteTable(null, true); // 08/12/2022	navkc1	#55409
	currentPart += 1;
	
	app.writeLog(self.loadCurrentTime( startTime, "On Site Tables load took"), LogTRACE);

// ##### Pre-Noted Cargo #####
	
	if not cmifMonitor.updateProgress(app.getErrorString(Loading_prenotified_cargo), totalParts, currentPart) then
		return;	// User Cancelled the load
	endif;
	startTime := app.actualTimeAppServer;
	
	self.loadPreNoteTable(null, true); // 08/12/2022	navkc1	#55409
	currentPart += 1;
	
	app.writeLog(self.loadCurrentTime( startTime, "Pre Note Tables load took"), LogTRACE);

// ##### Filters #####
	
	if not cmifMonitor.updateProgress('Loading Filters', totalParts, currentPart) then
		return;	// User Cancelled the load
	endif;
	startTime := app.actualTimeAppServer;
		
	//epr par 36244 3/9/15
	if not self.isCargoGroupForm() then			// TFS 53889
		self.tblOffsite.doShowFilter(self.tblOffsite.showingFilters);
		currentPart += 1;
		if not cmifMonitor.updateProgress('Loading Filters', totalParts, currentPart) then
			return;	// User Cancelled the load
		endif;
		self.tblPreNote.doShowFilter(self.tblPreNote.showingFilters);
		currentPart += 1;
		if not cmifMonitor.updateProgress('Loading Filters', totalParts, currentPart) then
			return;	// User Cancelled the load
		endif;
		self.tblOnsite.doShowFilter(self.tblOnsite.showingFilters);
		currentPart += 1;
		if not cmifMonitor.updateProgress('Loading Filters', totalParts, currentPart) then
			return;	// User Cancelled the load
		endif;
		self.tblOnship.doShowFilter(self.tblOnship.showingFilters);
		currentPart += 1;
	else
		currentPart += 4;
	endif;										// TFS 53889
	
	app.writeLog(self.loadCurrentTime( startTime, "Table Filters Load"), LogTRACE);

// ##### Status Bar Totals #####
	
	if not cmifMonitor.updateProgress('Updating Table Status Bar Information', totalParts, currentPart) then
		return;	// User Cancelled the load
	endif;
	startTime := app.actualTimeAppServer;
	
	//updateStatusBarCounts();
	updateStatusBarCounts(true, null);  // 28/10/2022	navkc1	#55408
	
	currentPart += 1;

	app.writeLog(self.loadCurrentTime( startTime, "Status Line Count"), LogTRACE);

// ##### Quick stuff ;)
	
	cmifMonitor.updateProgress(null, totalParts, currentPart);
	startTime := app.actualTimeAppServer;
	
	self.buildDischargeCombo();
	
	self.enableVoyageButtons();
	
	app.writeLog(self.loadCurrentTime( startTime, "Discharge Combo and buttons"), LogTRACE);
	cmifMonitor.updateProgress(null, totalParts, totalParts);
	
epilog
	delete cmifMonitor;
	app.myPassport.setMyCMIFMonitor(null);
	self.frmModalDialog.visible := false;
	app.mousePointer := self.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="00936ab0-e926-49a5-a1a2-56cf465de16e">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//--------------------------------------------------
// Created:	17 October 2003 By: cnwgd1
// 16/11/2022		navkc1	Bug 54927: MTN - Loading a cargo on ship edi file freeze the system if the New version of the voyage operation screen is opened
//--------------------------------------------------
begin
	inheritMethod();
	self.setColours();
	self.doRefresh(); // Gets the voyages and sets the current voyage
	
	if self.cmbVoyage.findObject(self.myCurrentVoyage) &gt; 0 then // PAR 11898
		self.cmbVoyage.listObject := self.myCurrentVoyage;
	endif;
	
	self.doResizeDisplayFrames();	//19 Nov 2009	NDL	CCMS 1031
	
	/* //30/07/2025	navkc1 JIRA MTN 35478 - using standard notification framework, no longer needed
	// navkc1	16/11/2022	#54927 - Start timer after finish loading the tables.
	if self.performHybrid and self.performRefresh &gt; 0 then
		self.startRefreshTimer();
	endif;
	// navkc1	16/11/2022	#54927 ends
	*/
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadOffsiteTable" id="920a00fe-b7a8-4053-96d9-a2c044db788d">
        <updating/>
        <source>loadOffsiteTable(_startingTI : CM_TrackedItem;	// 08/12/2022	navkc1	#55409
				 _next : Boolean				// 08/12/2022	navkc1	#55409
				 )updating;
//--------------------------------------------------
// Created:	17 October 2003 By: cnwgd1
//--------------------------------------------------
//
// 01/12/2022	navmd1	TFS 55379 Refactor VoyageOpsCG Form
// 08/12/2022	navkc1	ChangeRequest 55409: MTN - Voyage Ops Form - Pagination of tables
// 24/02/2024 	navcs2 	MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
// 14 Jan 2026 	navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)

vars
	rowIdx, maxRow		: Integer;
	ti 					: CM_TrackedItem;
	isHidden			: Boolean;
	currentVoyage		: CM_Voyage;
	currentTable		: CM_FilterTable;
	cmifMonitor 		: CMIF_Monitor;
	noMonitor 			: Boolean;
	idx, totalParts,
	currentPart			: Integer;
	maxStr				: String;
	progressStr			: String;
	iter				: Iterator;
	tis					: CM_TIByIdCargoTypeRelseDict;
begin
	on Exception do self.handleExceptionVoyage(exception, currentVoyage);
	currentVoyage := self.myCurrentVoyage;
	if currentVoyage &lt;&gt; null then
		currentVoyage.fetchLatest();
	endif;

	// Exception handler sets voyage to null if its been deleted
	if currentVoyage = null then
		return;
	endif;
	
	currentTable := self.tblOffsite;
	currentTable.rows := tblOffsite.fixedRows;
	currentTable.clearAllViewObjects( Any_System_Event );	//15 Mar 2021	NDL	TFS 50935
	
	isHidden := not self.dkcOffSite.visible;	//22 Mar 2021	NDL	TFS 50935

	cmifMonitor := app.myPassport.myCMIFMonitor;
	if cmifMonitor = null then
		// This should never be a thing, but instead of breaking because we can't show progress, lets just create a dummy one and not link it anywhere
		noMonitor := true;
		create cmifMonitor transient;
	endif;
	totalParts := cmifMonitor.partsInJob;
	currentPart := cmifMonitor.partsDone;
	
	maxStr := currentVoyage.allOffsiteTIsByIdCargoType.size.String;
	progressStr := app.getErrorString(Loading_offsite_cargo);
	
	maxRow := self.numOfRowsPerTable;	// 08/12/2022	navkc1	#55409
	currentTable.doShowNext(false); 	// 08/12/2022	navkc1	#55409 - Hide "&gt;" button
	currentTable.doShowPrev(false); 	// 08/12/2022	navkc1	#55409 - Hide "&lt;" button
	
	tis := currentVoyage.allOffsiteTIsByIdCargoType;
	
	iter := tis.createIterator();
	
	// We have a starting item, go through the collection and start from it.
	if _startingTI &lt;&gt; null then
		if _next then
			currentTable.doShowPrev(true); // Processing next # of items, display "&lt;" button to go to previous page
		else
			currentTable.doShowNext(true); // Processing prev # of items, display "&gt;" button to go to next page
		endif;
		tis.startKeyGeq(_startingTI.id, null, null, iter);
		iter.next(ti);
	endif;
	
	if _next then
		maxStr := (tis.size() - tis.indexOf(ti)).String;
	else
		maxStr := (tis.indexOf(ti)).String;
	endif;
	
	if self.performLimitNumOfRow then
		maxStr := maxRow.min(maxStr.Integer).String;
	endif;
	
	// Before we load to table, make sure we have ID column if we are limiting number of rows
	if self.performLimitNumOfRow then
		if currentTable.getColumnByRowName(ETRow_Id) = null then
			self.doAddSortIdColumn(currentTable);
		endif;
	endif;
	
	if _next then
		while iter.next(ti) do
			idx += 1;
			
			cmifMonitor.updateProgress(progressStr &amp; ' [' &amp; idx.String &amp; '/' &amp; maxStr &amp; ']', totalParts, currentPart);
			
			self.loadCargoForTable(ti, rowIdx, currentTable, isHidden, false);
			
			if idx = maxRow then
				if not ti = tis.last() then
					currentTable.doShowNext(true);
				endif;
				break;
			endif;
		endwhile;
	else
		while iter.back(ti) do
			idx += 1;
			
			cmifMonitor.updateProgress(progressStr &amp; ' [' &amp; idx.String &amp; '/' &amp; maxStr &amp; ']', totalParts, currentPart);
			
			self.loadCargoForTable(ti, rowIdx, currentTable, isHidden, false);
			
			if idx = maxRow then
				if not ti = tis.first() then
					currentTable.doShowPrev(true);
				endif;
				break;
			endif;
		endwhile;
	endif;
	
	if self.performAllowFilter then	//09 Mar 2021	NDL	TFS 50796
		currentTable.columnFilterApplyFilters(); //15 Jan 2015	NDL
	endif;
	self.colourTableRows(currentTable);
	
	/* //30/07/2025	navkc1 JIRA MTN 35478
	//12 Mar 2021	NDL	TFS 50935
	if self.performRefresh = RefreshCurrentViewOnly then
		self.tblOffsite.setCurrentViewObjects();
	endif;
	*/
	
epilog
	if noMonitor then
		delete cmifMonitor;
	endif;
	
	delete iter;
end;</source>
        <Parameter name="_startingTI" type="CM_TrackedItem"/>
        <Parameter name="_next" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadOnShipHoldCargoTable" id="6090de24-3a1c-4155-a1ee-88469cc74657">
        <updating/>
        <source>loadOnShipHoldCargoTable(_mode : Integer;
						 _tis : CM_TIByIdCargoTypeDict io // 08/12/2022	navkc1	#55409 
						) protected, updating;
/*

Date		Who		Reason
28 May 2014	cnwer1	Initial creation PAR
08/12/2022	navkc1	ChangeRequest 55409: MTN - Voyage Ops Form - Pagination of tables
*/

vars
	plannedTIs 	: CM_TIArray;
	ti 			: CM_TrackedItem;
	holdLC 		: CM_GeneralCargoController;
	rowIdx 		: Integer;
	table		: CM_FilterTable;
	
begin
	
	//epr par 33948 28/5/14 for break bulk cargo the cargo's voyage will not neccessary be for this voyage so have to look through lcs
	create plannedTIs transient;
		
	// 08/12/2022	navkc1	#55409
	table := self.tblOnship;
	
	if self.myCurrentVoyage.myShipBlockStack &lt;&gt; null then
		self.myCurrentVoyage.myShipBlockStack.getTIs(plannedTIs, _mode, true);
		plannedTIs.tryCopy__(_tis);
	endif;
	
	if self.myCurrentVoyage.myGeneralCargoVoyage &lt;&gt; null then
		foreach holdLC in self.myCurrentVoyage.myGeneralCargoVoyage.allLocationsByHatchPlace do
			holdLC.getTIs(plannedTIs, _mode, true);
			plannedTIs.tryCopy__(_tis);
		endforeach;
	endif;
	// 08/12/2022	navkc1	#55409
epilog
	delete plannedTIs;
end;</source>
        <access>protected</access>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_tis" type="CM_TIByIdCargoTypeDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="loadOnShipTable" id="d0ce0990-339a-4e15-8a77-45e468ecc7b6">
        <updating/>
        <source>loadOnShipTable(_startingTI : CM_TrackedItem; 	// 08/12/2022	navkc1	#55409
				_next : Boolean					// 08/12/2022	navkc1	#55409
				)updating;
//--------------------------------------------------
// Created:	17 October 2003 By: cnwgd1
//--------------------------------------------------
// 17/08/2011	cnwmh5 	#27707 - Change to include General Cargo and remove duplicated where tests
// 08/11/2022	navmd1	TFS 55379 Refactor VoyageOpsCG Form
// 08/12/2022	navkc1	ChangeRequest 55409: MTN - Voyage Ops Form - Pagination of tables
// 24/02/2024 	navcs2  MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
// 14 Jan 2026 	navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
vars
	rowIdx, maxRow		: Integer;
	ti 					: CM_TrackedItem;
	currentVoyage		: CM_Voyage;
	currentTable		: CM_FilterTable;
	cmifMonitor 		: CMIF_Monitor;
	noMonitor 			: Boolean;
	idx, totalParts,
	currentPart			: Integer;
	maxStr				: String;
	progressStr			: String;
	iter				: Iterator;
	tis					: CM_TIByIdCargoTypeDict;
begin
	on Exception do self.handleExceptionVoyage(exception, currentVoyage);
	currentVoyage := self.myCurrentVoyage;
	if currentVoyage &lt;&gt; null then
		currentVoyage.fetchLatest();
	endif;
	
	// Exception handler sets voyage to null if its been deleted
	if currentVoyage = null then
		return;
	endif;
	
	currentTable := self.tblOnship;
	currentTable.rows := currentTable.fixedRows;
	currentTable.clearAllViewObjects( Any_System_Event );	//15 Mar 2021	NDL	TFS 50935
	
	cmifMonitor := app.myPassport.myCMIFMonitor;
	if cmifMonitor = null then
		// This should never be a thing, but instead of breaking because we can't show progress, lets just create a dummy one and not link it anywhere
		noMonitor := true;
		create cmifMonitor transient;
	endif;
	totalParts := cmifMonitor.partsInJob;
	currentPart := cmifMonitor.partsDone;
	progressStr := app.getErrorString(Loading_onship_cargo);
	
	maxRow := self.numOfRowsPerTable;	// 08/12/2022	navkc1	#55409
	currentTable.doShowNext(false); 	// 08/12/2022	navkc1	#55409 - Hide "&gt;" button
	currentTable.doShowPrev(false); 	// 08/12/2022	navkc1	#55409 - Hide "&lt;" button
	
	// Add TIs to collection
	if self.displayModeOnShip = DISPLAY_MODE_ACTUAL then	// Actual
		// 08/12/2022	navkc1	#55409
		tis 	:= currentVoyage.allOnshipTIsByIdCargoType;
	elseif self.displayModeOnShip = DISPLAY_MODE_QUEUE then	// Queued
		// 08/12/2022	navkc1	#55409
		create tis transient;
		
		foreach ti in currentVoyage.allOnsiteTIsByIdCargoType discreteLock where self.isQueued(ti) do
			tis.addNoDuplicates(ti, false);
		endforeach;
		
		self.loadOnShipHoldCargoTable(QUEUE_MODE, tis);
	elseif self.displayModeOnShip = DISPLAY_MODE_PLAN then	// Planned
		// 08/12/2022	navkc1	#55409
		create tis transient;
		
		foreach ti in currentVoyage.allOnsiteTIsByIdCargoType discreteLock where self.isPlanned(ti) do
			tis.addNoDuplicates(ti, false);
		endforeach;
		
		foreach ti in currentVoyage.allTranshipTIsExport discreteLock where self.isPlanned(ti) do	
			tis.addNoDuplicates(ti, false);
		endforeach;
		
		self.loadOnShipHoldCargoTable(PLANNING_MODE, tis);
	endif;
	
	iter := tis.createIterator();
		
	// We have a starting item, go through the collection and start from it.
	if _startingTI &lt;&gt; null then
		if _next then
			currentTable.doShowPrev(true);	// Processing next # of items, display "&lt;" button to go to previous page
		else
			currentTable.doShowNext(true);	// Processing prev # of items, display "&gt;" button to go to next page
		endif;
		tis.startKeyGeq(_startingTI.id, null, iter);
		iter.next(ti);
	endif;
	
	if _next then
		maxStr := (tis.size() -  tis.indexOf(ti)).String;
	else
		maxStr := (tis.indexOf(ti)).String;
	endif;
	
	if self.performLimitNumOfRow then
		maxStr := maxRow.min(maxStr.Integer).String;
	endif;
	
	// Before we load to table, make sure we have ID column if we are limiting number of rows
	if self.performLimitNumOfRow then
		if currentTable.getColumnByRowName(ETRow_Id) = null then
			self.doAddSortIdColumn(currentTable);
		endif;
	endif;
	
	// Now load TIs to table
	if _next then
		while iter.next(ti) do
			idx += 1;
			
			cmifMonitor.updateProgress(progressStr &amp; ' [' &amp; idx.String &amp; '/' &amp; maxStr &amp; ']', totalParts, currentPart);
			self.loadCargoForTable(ti, rowIdx, currentTable, false, false);
			
			if idx = maxRow then
				if not ti = tis.last() then
					currentTable.doShowNext(true);
				endif;
				break;
			endif;
		endwhile;
	else
		while iter.back(ti) do
			idx += 1;
			
			cmifMonitor.updateProgress(progressStr &amp; ' [' &amp; idx.String &amp; '/' &amp; maxStr &amp; ']', totalParts, currentPart);
			self.loadCargoForTable(ti, rowIdx, currentTable, false, false);
			
			if idx = maxRow then
				if not ti = tis.first() then
					currentTable.doShowPrev(true);
				endif;
				break;
			endif;
		endwhile;
	endif;
	
	if self.performAllowFilter then	//09 Mar 2021	NDL	TFS 50796
		currentTable.columnFilterApplyFilters(); //15 Jan 2015	NDL
	endif;
	self.colourTableRows(currentTable);
	
	/* //30/07/2025	navkc1 JIRA MTN 35478
	//12 Mar 2021	NDL	TFS 50935
	if self.performRefresh = RefreshCurrentViewOnly then
		currentTable.setCurrentViewObjects();
	endif;
	*/
	
epilog
	if noMonitor then
		delete cmifMonitor;
	endif;
	
	delete iter;
	if not self.displayModeOnShip = DISPLAY_MODE_ACTUAL then
		delete tis;
	endif;
end;</source>
        <Parameter name="_startingTI" type="CM_TrackedItem"/>
        <Parameter name="_next" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadOnsiteTable" id="bc429562-2171-4ccc-a0f4-e2e99b10f48c">
        <updating/>
        <source>loadOnsiteTable(_startingTI : CM_TrackedItem;	// 08/12/2022	navkc1	#55409
				_next 		: Boolean			// 08/12/2022	navkc1	#55409
				)updating;
//--------------------------------------------------
// Created:	17 October 2003 By: cnwgd1
//--------------------------------------------------
// 08/11/2022	navmd1	TFS 55379 Refactor VoyageOpsCG Form
// 08/12/2022	navkc1	ChangeRequest 55409: MTN - Voyage Ops Form - Pagination of tables
// 24/02/2024 	navcs2 	MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
// 24/10/2025	jlizm1	MTN 36255 Rotabox Assign Release To Vessel
// 14 Jan 2026	navhl20 Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
vars
	rowIdx, maxRow		: Integer;
	ti 					: CM_TrackedItem;
	currentVoyage		: CM_Voyage;
	currentTable		: CM_FilterTable;
	cmifMonitor 		: CMIF_Monitor;
	noMonitor 			: Boolean;
	idx, totalParts,
	currentPart			: Integer;
	maxStr				: String;
	progressStr			: String;
	iter				: Iterator;
	tis					: CM_TIByIdCargoTypeDict;
begin
	on Exception do self.handleExceptionVoyage(exception, currentVoyage);
	currentVoyage := self.myCurrentVoyage;
	if currentVoyage &lt;&gt; null then
		currentVoyage.fetchLatest();
	endif;

	// Exception handler sets voyage to null if its been deleted
	if currentVoyage = null then
		return;
	endif;
	
	currentTable := self.tblOnsite;
	currentTable.rows := currentTable.fixedRows;
	currentTable.clearAllViewObjects( Any_System_Event );	//15 Mar 2021	NDL	TFS 50935
	
	cmifMonitor := app.myPassport.myCMIFMonitor;
	if cmifMonitor = null then
		// This should never be a thing, but instead of breaking because we can't show progress, lets just create a dummy one and not link it anywhere
		noMonitor := true;
		create cmifMonitor transient;
	endif;
	totalParts := cmifMonitor.partsInJob;
	currentPart := cmifMonitor.partsDone;
	progressStr := app.getErrorString(Loading_onsite_cargo);
	
	maxRow := self.numOfRowsPerTable;	// 08/12/2022	navkc1	#55409
	currentTable.doShowNext(false); 	// 08/12/2022	navkc1	#55409 - Hide "&gt;" button
	currentTable.doShowPrev(false); 	// 08/12/2022	navkc1	#55409 - Hide "&lt;" button
	
	create tis transient;
	
	// First add TIs to collection
	
	//20 Nov 2009	NDL CCMS 1031
	if self.displayModeOnSite = DISPLAY_MODE_ACTUAL then	// Actual
		// 08/12/2022	navkc1	#55409
		foreach ti in currentVoyage.allOnsiteTIsByIdCargoType discreteLock where self.includeOnSite(ti) do
			tis.addNoDuplicates(ti, false);
		endforeach;
		
		foreach ti in currentVoyage.allRRPTIsByIdCargoType discreteLock do
			tis.addNoDuplicates(ti, false);
		endforeach;

	elseif self.displayModeOnSite = DISPLAY_MODE_QUEUE then	// Queued to a yard location
		// 08/12/2022	navkc1	#55409
		foreach ti in currentVoyage.allOnsiteTIsByIdCargoType discreteLock where ti.isQueuedToYard() and self.includeOnSite(ti) do
			tis.addNoDuplicates(ti, false);
		endforeach;
		
		foreach ti in currentVoyage.allOffsiteTIsByIdCargoType discreteLock where ti.isQueuedToYard do
			tis.addNoDuplicates(ti, false);
		endforeach;
		
		foreach ti in currentVoyage.allOnshipTIsByIdCargoType discreteLock where ti.isQueuedToYard do
			tis.addNoDuplicates(ti, false);
		endforeach;
		
	elseif self.displayModeOnSite = DISPLAY_MODE_PLAN then	// Planned to a yard location
		// 08/12/2022	navkc1	#55409
		foreach ti in currentVoyage.allOnsiteTIsByIdCargoType discreteLock where ti.isPlannedToYard() and self.includeOnSite(ti) do
			tis.addNoDuplicates(ti, false);
		endforeach;
		
		foreach ti in currentVoyage.allOffsiteTIsByIdCargoType discreteLock where ti.isPlannedToYard do
			tis.addNoDuplicates(ti, false);
		endforeach;
		
		foreach ti in currentVoyage.allOnshipTIsByIdCargoType discreteLock where ti.isPlannedToYard do
			tis.addNoDuplicates(ti, false);
		endforeach;
		
	endif;
	
	iter := tis.createIterator();
		
	// We have a starting item, go through the collection and start from it.
	if _startingTI &lt;&gt; null then
		if _next then
			currentTable.doShowPrev(true); // Processing next # of items, display "&lt;" button to go to previous page
		else
			currentTable.doShowNext(true); // Processing prev # of items, display "&gt;" button to go to next page
		endif;
		tis.startKeyGeq(_startingTI.id, null, iter);
		iter.next(ti);
	endif;
	
	if _next then
		maxStr := (tis.size() - tis.indexOf(ti)).String;
	else
		maxStr := (tis.indexOf(ti)).String;
	endif;
	
	if self.performLimitNumOfRow then
		maxStr := maxRow.min(maxStr.Integer).String;
	endif;
	
	// Before we load to table, make sure we have ID column if we are limiting number of rows
	if self.performLimitNumOfRow then
		if currentTable.getColumnByRowName(ETRow_Id) = null then
			self.doAddSortIdColumn(currentTable);
		endif;
	endif;
	
	// Now load TIs to table
	if _next then
		while iter.next(ti) do
			
			idx += 1;
			
			cmifMonitor.updateProgress(progressStr &amp; ' [' &amp; idx.String &amp; '/' &amp; maxStr &amp; ']', totalParts, currentPart);
			self.loadCargoForTable(ti, rowIdx, currentTable, false, false);
			
			if idx = maxRow then
				if not ti = tis.last() then
					currentTable.doShowNext(true);
				endif;
				break;
			endif;
		endwhile;
	else
		while iter.back(ti) do
			
			idx += 1;
			
			cmifMonitor.updateProgress(progressStr &amp; ' [' &amp; idx.String &amp; '/' &amp; maxStr &amp; ']', totalParts, currentPart);
			self.loadCargoForTable(ti, rowIdx, currentTable, false, false);
			
			if idx = maxRow then
				if not ti = tis.first() then
					currentTable.doShowPrev(true);
				endif;
				break;
			endif;
		endwhile;
	endif;
	
	if self.performAllowFilter then	//09 Mar 2021	NDL	TFS 50796
		currentTable.columnFilterApplyFilters(); //15 Jan 2015	NDL
	endif;
	self.colourTableRows(currentTable);
	
	/* //30/07/2025	navkc1 JIRA MTN 35478
	//12 Mar 2021	NDL	TFS 50935
	if self.performRefresh = RefreshCurrentViewOnly then
		currentTable.setCurrentViewObjects();
	endif;
	*/
	
epilog
	if noMonitor then
		delete cmifMonitor;
	endif;
	
	delete iter;
	delete tis;
end;</source>
        <Parameter name="_startingTI" type="CM_TrackedItem"/>
        <Parameter name="_next" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadPreNoteTable" id="4d6cad31-888e-4a76-a5a4-49bb93820079">
        <updating/>
        <source>loadPreNoteTable(_startingTI : CM_TrackedItem;	// 08/12/2022	navkc1	#55409
				 _next : Boolean) 				// 08/12/2022	navkc1	#55409
				 updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 11/12/2014	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394
// 01/12/2022	navmd1		TFS 55379 Refactor VoyageOpsCG Form
// 08/12/2022	navkc1		ChangeRequest 55409: MTN - Voyage Ops Form - Pagination of tables
// 24/02/2024 	navcs2 		MTN-29368 EUP | Transaction Instrumentation - Voyage Discharge
// 14 Jan 2026 	navhl20 	Bug MTN-35897: PEN - System Locking Errors (1000010 - Unknown message)
vars
	rowIdx, maxRow		: Integer;
	ti 					: CM_TrackedItem;
	isHidden 			: Boolean;
	currentVoyage		: CM_Voyage;
	currentTable		: CM_FilterTable;
	cmifMonitor 		: CMIF_Monitor;
	noMonitor 			: Boolean;
	idx, totalParts,
	currentPart			: Integer;
	maxStr				: String;
	progressStr			: String;
	iter				: Iterator;
	tis					: CM_TIByIdCargoTypeDict;
begin
	on Exception do self.handleExceptionVoyage(exception, self.myCurrentVoyage);
	currentVoyage := self.myCurrentVoyage;
	if currentVoyage &lt;&gt; null then
		currentVoyage.fetchLatest();
	endif;
	
	// Exception handler sets voyage to null if its been deleted
	if currentVoyage = null then
		return;
	endif;
	
	currentTable := self.tblPreNote;
	currentTable.rows := currentTable.fixedRows;
	currentTable.clearAllViewObjects( Any_System_Event );	//15 Mar 2021	NDL	TFS 50935
	
	isHidden := not self.dkcPreNotes.visible;	//15 Mar 2021	NDL	TFS 50935
	
	cmifMonitor := app.myPassport.myCMIFMonitor;
	if cmifMonitor = null then
		// This should never be a thing, but instead of breaking because we can't show progress, lets just create a dummy one and not link it anywhere
		noMonitor := true;
		create cmifMonitor transient;
	endif;
	totalParts := cmifMonitor.partsInJob;
	currentPart := cmifMonitor.partsDone;
	progressStr := app.getErrorString(Loading_prenotified_cargo);
	
	maxRow := self.numOfRowsPerTable;	// 08/12/2022	navkc1	#55409
	currentTable.doShowNext(false); 	// 08/12/2022	navkc1	#55409 - Hide "&gt;" button
	currentTable.doShowPrev(false); 	// 08/12/2022	navkc1	#55409 - Hide "&lt;" button

	tis := currentVoyage.allNotifiedTIsByIdCargoType;
	
	iter := tis.createIterator();
	
	// We have a starting item, go through the collection and start from it.
	if _startingTI &lt;&gt; null then
		if _next then
			currentTable.doShowPrev(true); // Processing next # of items, display "&lt;" button to go to previous page
		else
			currentTable.doShowNext(true); // Processing prev # of items, display "&gt;" button to go to next page
		endif;
		tis.startKeyGeq(_startingTI.id, null, iter);
		iter.next(ti);
	endif;
	
	if _next then
		maxStr := (tis.size() - tis.indexOf(ti)).String;
	else
		maxStr := (tis.indexOf(ti)).String;
	endif;
	
	if self.performLimitNumOfRow then
		maxStr := maxRow.min(maxStr.Integer).String;
	endif;
	
	// Before we load to table, make sure we have ID column if we are limiting number of rows
	if self.performLimitNumOfRow then
		if currentTable.getColumnByRowName(ETRow_Id) = null then
			self.doAddSortIdColumn(currentTable);
		endif;
	endif;
	
	if _next then
		while iter.next(ti) do
			if self.displayModePreNote = DISPLAY_MODE_PLAN and ti.myPrimaryPlannedLocation = null then
				continue;
			endif;
			
			idx += 1;
			
			cmifMonitor.updateProgress(progressStr &amp; ' [' &amp; idx.String &amp; '/' &amp; maxStr &amp; ']', totalParts, currentPart);
			self.loadCargoForTable(ti, rowIdx, currentTable, isHidden, false);
			
			if idx = maxRow then
				if not ti = tis.last() then
					currentTable.doShowNext(true);
				endif;
				break;
			endif;
		endwhile;
	else
		while iter.back(ti) do
			if self.displayModePreNote = DISPLAY_MODE_PLAN and ti.myPrimaryPlannedLocation = null then
				continue;
			endif;
			
			idx += 1;
			
			cmifMonitor.updateProgress(progressStr &amp; ' [' &amp; idx.String &amp; '/' &amp; maxStr &amp; ']', totalParts, currentPart);
			self.loadCargoForTable(ti, rowIdx, currentTable, isHidden, false);
			
			if idx = maxRow then
				if not ti = tis.first() then
					currentTable.doShowPrev(true);
				endif;
				break;
			endif;
		endwhile;
	endif;
	
	if self.performAllowFilter then	//09 Mar 2021	NDL	TFS 50796
		currentTable.columnFilterApplyFilters(); //15 Jan 2015	NDL
	endif;
	self.colourTableRows(currentTable);
	
	/* //30/07/2025	navkc1 JIRA MTN 35478
	//12 Mar 2021	NDL	TFS 50935
	if self.performRefresh = RefreshCurrentViewOnly then
		currentTable.setCurrentViewObjects();
	endif;
	*/
	
epilog
	if noMonitor then
		delete cmifMonitor;
	endif;
	delete iter;
end;</source>
        <Parameter name="_startingTI" type="CM_TrackedItem"/>
        <Parameter name="_next" type="Boolean"/>
    </JadeMethod>
