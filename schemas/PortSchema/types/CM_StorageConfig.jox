    <JadeMethod name="delete" id="ba99e2b1-6740-4ed1-95d5-20ea72dd3afd">
        <updating/>
        <source>delete() updating;
// 10 Oct 2017    jlgrh7 TFS #7228 ADP - Storage Configuration Validation and Auditing
vars
	
begin
	
	self.resetAuditsDuringDelete();	//25 Jan 2021	NDL	TFS 50152 
	
	if self.allExtraData &lt;&gt; null then
		self.allExtraData.purge();
	endif;

end;
</source>
    </JadeMethod>
    <JadeMethod name="doesCalendarIncludeDate" id="66fe35a7-ed23-4140-bcfe-eb9a7a9c84a0">
        <source>doesCalendarIncludeDate(_freeDaysType: Integer; _date : Date) : Boolean;
/*
Purpose:			

Date		Who		Reason
18MAY2023	NAVAB1	BUG 57961 
*/

vars
	calendar : CM_Calendar;
begin
	if _freeDaysType = CM_StorageDetail.Working_Days then
		calendar := self.myWorkingDaysCalendar;
		if calendar &lt;&gt; null then
			return calendar.doesCalendarIncludeDate(_date);
		endif;
	elseif _freeDaysType = CM_StorageDetail.Working_Compulsory_Days then
		calendar := self.myWorkingDaysCalendar;
		if calendar &lt;&gt; null then
			if calendar.doesCalendarIncludeDate(_date) then
				return true;
			else
				calendar := self.myCompulsoryCalendar;
				if calendar &lt;&gt; null then
					if calendar.doesCalendarIncludeDate(_date) then
						return true;
					endif;
				endif;
			endif;
		else
			calendar := self.myCompulsoryCalendar;
			if calendar &lt;&gt; null then
				if calendar.doesCalendarIncludeDate(_date) then
					return true;
				endif;
			endif;
		endif;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_freeDaysType" type="Integer"/>
        <Parameter name="_date" type="Date"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="72d47dc1-52b8-4b6a-84cf-71078c2713e0">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
// 10 Oct 2017    jlgrh7 TFS #7228 ADP - Storage Configuration Validation and Auditing
//14/06/2023	navkc1	CR 58007 Defect 58623: Audit option not working on Storage Config Screen for "Cargo Types for Extra Days Storage" tab
*/

vars
	auditText,tmpStr			: String;
	yaCriteriaType				: CM_YACriteriaType;
	storageTrigger				: CM_StorageTrigger;
	storageConfigType			: CM_StorageConfigType;
	storageConfigTypeSSL		: CM_StorageConfigTypeSSL;
	root						: CM_Root;
begin
	auditText:= inheritMethod();
	tmpStr:=null;
	foreach yaCriteriaType in self.allYACriteriaTypes do
		if tmpStr = null then
			tmpStr := yaCriteriaType.description;
		else
			tmpStr := tmpStr &amp; ', ' &amp; yaCriteriaType.description;
		endif;
	endforeach;
	auditText := auditText &amp; "Selected Free Days Attributes" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;	
	
	
	tmpStr:=null;
	foreach storageTrigger in self.allStorageTriggers do
		if tmpStr = null then
			tmpStr := storageTrigger.getTriggerDescription();
		else
			tmpStr := tmpStr &amp; ', ' &amp; storageTrigger.getTriggerDescription();
		endif;
	endforeach;
	auditText := auditText &amp; "Selected Storage Triggers Attributes" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;	
	
	tmpStr := null;
	tmpStr := self.includeFirstDay.Boolean.String;
	auditText := auditText &amp; "Include First Day" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;	
	
	tmpStr := null;
	tmpStr := self.includeLastDay.Boolean.String;
	auditText := auditText &amp; "Include Last Day" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;	
	
	tmpStr := null;
	tmpStr := self.firstDayTimeCutoff.String;
	auditText := auditText &amp; "Storage Time Cutoff" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;	
	
	tmpStr := null;
	tmpStr := self.getShipReceDescption();
	auditText := auditText &amp; "Ship Receival Based on" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;	
	
	tmpStr := null;
	tmpStr := self.getShipReleDescption();
	auditText := auditText &amp; "Ship Release Based on" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;	
	
	//14/06/2023	navkc1	CR 58007 Defect 58623
	storageConfigType := self.myTerminal.getMyStorageConfigType();
	
	if storageConfigType &lt;&gt; null and storageConfigType.isSSLtype() then
		
		storageConfigTypeSSL := storageConfigType.CM_StorageConfigTypeSSL;
		
		root := app.myRoot;
		
		if root = null then
			return auditText;
		endif;
		
		tmpStr := storageConfigTypeSSL.getExtraDayCargoTypeSummary(CrLf);
		
		auditText := auditText &amp; "Cargo Types for Extra Days Storage" &amp; AuditStringSeparator &amp; tmpStr.length().String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		
	endif;
	
	return auditText;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAuditTextForProperty" id="0c77ff54-e36c-4e9b-8025-139e4b88e06f">
        <source>getAuditTextForProperty(_property: Property): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//08/06/2023	navkc1	CR 58007 Task 58008: JADE - Storage Config - Audits

*/

vars

begin

	if _property.name = CM_StorageConfig::unpackReceivalType.name then
		return self.formatAuditText(_property.name, self.getReceivalDateOptionStr(self.unpackReceivalType));
	elseif _property.name = CM_StorageConfig::roadReceivalType.name then
		return self.formatAuditText(_property.name, self.getReceivalDateOptionStr(self.roadReceivalType));
	elseif _property.name = CM_StorageConfig::railReceivalType.name then
		return self.formatAuditText(_property.name, self.getReceivalDateOptionStr(self.railReceivalType));
	endif;
	
	return inheritMethod(_property);

epilog

end;</source>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDescForError" id="f502ea71-88c7-4104-808d-df13d0ce285f">
        <source>getDescForError():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2017	jlgndl1	Initial creation	TFS 7032

