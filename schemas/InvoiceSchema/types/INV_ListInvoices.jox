    <JadeMethod name="getInvoiceLines" id="2cb6a58d-892d-42fc-bab5-80667e7be972">
        <source>getInvoiceLines(_theInvLines : CM_InvoiceLineBySeqNumDict input) ;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anObject : Object;
begin
	foreach anObject in self.tblData.allSelectedObjects do
		if CM_Invoice.hasInstance(anObject) and global.isValidObject(anObject) then
			anObject.CM_Invoice.invoiceLines.copy(_theInvLines);
		endif;
	endforeach;
end;</source>
