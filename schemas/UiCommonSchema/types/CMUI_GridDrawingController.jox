    <JadeMethod name="doZoom" id="943e98e2-b8a1-45cc-a429-3b7d3387ac12">
        <updating/>
        <source>doZoom(pFactor : Real) updating;
// ---------------------------------------------------------------------------
// Created:     05 February 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theFactor : Real;
	posH, posV : Real;
	theHValue, theVValue : Integer;	
	tmpPoint : Point;

begin

	app.mousePointer := Window.MousePointer_HourGlass;

	theFactor := pFactor;
	
	if theFactor &lt;= 0 then
		theFactor := ScaleFactor_1;
	endif;

	self.setScale(theFactor, true, true);
	self.drawSelf(false);	

epilog 
	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="pFactor" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawAttribute" id="9a5f5df7-e0c4-4f20-aa22-92d185e940e9">
        <updating/>
        <source>drawAttribute(_ti : CM_TrackedItem; _frame: CMUI_Frame input;_x1,_y1 :Real; _theAttColour: Integer; _theAttribute: String; _theAttributePosition: Integer io) protected, updating;
// ---------------------------------------------------------------------------
// Created:     02 September 2004 by cnwrs2
//
// Purpose:     
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 13/05/2015	cnwdap1		PAR #36206 TFS 324/334 Graphical Representation of Hazard Class and Special Stow
// ---------------------------------------------------------------------------
vars
	theDrawingAttribute : CM_DrawingAttribute;
	tmpX, tmpY: Real;
	theAttributePosition, 
	theColour : Integer;
	theCharacter : Character;
	theFrame: CMUI_Frame;
	lDisplayMode	: Integer;
	fntSze, offset45X, offset45Y : Integer;
	tmJN : String;
	hazard : CM_TIHazard;											// PAR #36206
	hazClass : CM_HazardClass;										// PAR #36206
	specialStow : CM_SpecialStow;									// PAR #36206
	theCharWidth : Real;	
begin
	theFrame := _frame;

	lDisplayMode := self.displayMode;
	if _theAttribute = PicTIBreakBulk then
		theDrawingAttribute := _ti.myCargoType.myDrawingAttribute;
	elseif _theAttribute = PicTIHazard then							// PAR #36206
		/* WAS PAR 37527
		hazard := _ti.getHazardFirst;								// PAR #36206
		if hazard &lt;&gt; null then										// PAR #36206
			hazClass := hazard.getClassObject;						// PAR #36206
			if hazClass &lt;&gt; null then								// PAR #36206
				theDrawingAttribute := hazClass.myDrawingAttribute;	// PAR #36206
			endif;													// PAR #36206
		endif;			// PAR #36206
		NOW */
		hazClass := self.getHazardClass(_ti);
		if hazClass &lt;&gt; null then								// PAR #36206
			theDrawingAttribute := hazClass.myDrawingAttribute;	// PAR #36206
		endif;													// PAR #36206
		
		
	elseif _theAttribute = PicSpecialStow then						// PAR #36206
		/* WAS PAR 37527
		specialStow := _ti.getSpecialStow();						// PAR #36206
		if specialStow &lt;&gt; null then									// PAR #36206
			theDrawingAttribute := specialStow.myDrawingAttribute;	// PAR #36206
		endif;														// PAR #36206
		NOW */
		specialStow := self.getSpecialStow(_ti);						// PAR #36206
		if specialStow &lt;&gt; null then									// PAR #36206
			theDrawingAttribute := specialStow.myDrawingAttribute;	// PAR #36206
		endif;														// PAR #36206

	endif;
	if theDrawingAttribute = null then
		theDrawingAttribute := self.allDrawingAttributes[_theAttribute];
	endif;

	if theDrawingAttribute = null then
		return;
	endif;
	
	// ################################
	// LEGEND LEGEND
	if self.amPrinting and
	   (not self.allAttributeCodes.includes(_theAttribute.trimBlanks)) then
		self.allAttributeCodes.add(_theAttribute.trimBlanks);
	endif;
	// #######################
	
	// increment the attribute counter and check if
	// we still have room for this attibute
	_theAttributePosition := _theAttributePosition + 1;

	if _theAttributePosition &gt; self.attrMaxNum then
		return;
	endif;

	

	theFrame.drawFontName := theDrawingAttribute.fontName;
	
	// #######################
	// DRAW THE CHARACTER
	
	theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
	theCharacter := theDrawingAttribute.fontCharacter.Character;
	
	
	if _theAttColour &lt; 0 then
		theColour := theDrawingAttribute.colour;
	else	
		theColour := _theAttColour;
	endif;
	
	//self.getAttrXYforPosition(_theAttributePosition, tmpX, tmpY);
	
	//epr par 37386 20/1/16 better drawing of icons so we can fit more in
	if _theAttributePosition = 1 then
		tmpX:=2;
	else
		tmpX :=self.attrX1 ;
	endif;
	tmpY:=self.attrY1;
	
	theFrame.drawTextAt(theCharacter,_x1+ tmpX,_y1 + tmpY, theColour);
	theCharWidth:=theFrame.drawTextWidth(theCharacter.Character.String);
	
	//epr par 37386 20/1/16 better drawing of icons so we can fit more in	
	self.attrX1:=tmpX + theCharWidth;
	if self.scaleFactor &gt;= ScaleFactor_6 then
		self.attrX1:=self.attrX1 + 5;

	elseif self.scaleFactor &gt; ScaleFactor_1 then
		self.attrX1:=self.attrX1 + self.scaleFactor;
	endif;
	
	if _ti &lt;&gt; null then
		if self.isBayDrawingController() then
			if _theAttribute = PicTI40Footer and _ti.isOverSizedContainer() then
				fntSze := theFrame.drawFontSize.Integer;
				
				if self.scaleFactor &lt;= 2 then
					offset45X := 6;
					offset45Y := 0;
					theFrame.drawFontSize := 6;
				elseif self.scaleFactor = 3 then
					offset45X := 9;
					offset45Y := 0;
					theFrame.drawFontSize := 6;
				elseif self.scaleFactor = 4 then
					offset45X := 12;
					offset45Y := 0;
					theFrame.drawFontSize := 8;
				elseif self.scaleFactor = 6 then
					offset45X := 14;
					offset45Y := 4;
					theFrame.drawFontSize := 12;
				elseif self.scaleFactor = 9 then
					offset45X := 16;
					offset45Y := 3;
					theFrame.drawFontSize := 16;
				endif;
				theFrame.drawTextAt("5",_x1 + tmpX + offset45X, _y1 + tmpY + offset45Y, theColour);
				theFrame.drawFontSize := fntSze;
			endif;
		elseif self.isGridDrawingController() then
			// DQ and RICHARD WANTED THIS
			if _theAttribute = PicTIPlanned 
//			and self.scaleFactor &gt;= 2 then	// SFW1030 - for factor &gt; than 2 now handling in drawTI method of CMUI_GridDrawingController.
			and self.scaleFactor = 2 then
					fntSze := theFrame.drawFontSize.Integer;
					
					if self.scaleFactor = 2 then
						offset45X := 2;
						offset45Y := 10;
						theFrame.drawFontSize := 7;
					elseif self.scaleFactor = 3 then
						offset45X := 2;
						offset45Y := 18;
						theFrame.drawFontSize := 7;
					elseif self.scaleFactor = 4 then
						offset45X :=  2;
						offset45Y := 25;
						theFrame.drawFontSize := 8;
					elseif self.scaleFactor = 6 then
						offset45X := 10;
						offset45Y := 20;
						theFrame.drawFontSize := 12;
					elseif self.scaleFactor = 9 then
						offset45X := 16;
						offset45Y := 3;
						theFrame.drawFontSize := 16;
					endif;
					
					// PAR 33336	tmJN := _ti.loadJobNum.String;
					tmJN := self.getTILoadJobNumber(_ti); // PAR 33336
					
				// PAR 30320	tmJN := tmJN[tmJN.reversePos(",") + 1: end];
					
					theFrame.drawTextAt(tmJN &amp; " " &amp; _ti.loadSeqNumber, _x1 +  tmpX  + offset45X , _y1 + tmpY + offset45Y, theColour);
					theFrame.drawFontSize := fntSze;
			endif;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_frame" type="CMUI_Frame" usage="input"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_theAttColour" type="Integer"/>
        <Parameter name="_theAttribute" type="String"/>
        <Parameter name="_theAttributePosition" type="Integer" usage="io"/>
    </JadeMethod>
