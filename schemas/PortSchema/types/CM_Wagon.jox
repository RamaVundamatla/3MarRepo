    <JadeMethod name="getNextFreeWagonContForRequest" id="f7cfa74b-0afd-4055-8c68-ec4ea26d94c8">
        <source>getNextFreeWagonContForRequest(req : CM_DeliveryRequest):CM_WagonController;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2009	cnwndl1	Initial creation CCMS 1094

*/

vars

	isoTypeCode : String;
	isoType : CM_ISOType;
	isoTypeGroupCode : String;
	isoTypeGroup : CM_ISOTypeGroup;
	
begin

	if req = null then
		return null;
	endif;
	
	isoTypeCode := req.isoType;
	isoTypeGroupCode := req.isoGroup;	//10 May 2010	NDL Par 24064
	if isoTypeCode &lt;&gt; null then
		isoType	:=	app.myRoot.allISOTypes[isoTypeCode];
	elseif isoTypeGroupCode &lt;&gt; null then	//10 May 2010	NDL Par 24064
		isoTypeGroup	:=	app.myRoot.allISOTypeGroups[isoTypeGroupCode];
	endif;
	
	if isoType = null and isoTypeGroup = null then	//10 May 2010	NDL Par 24064
		return null;
	endif;
	
	//return self.getNextFreeWagonController( null, REAL_MODE, isoType, true );
	return self.getNextFreeWagonController( null, REAL_MODE, isoType, isoTypeGroup, true );//10 May 2010	NDL Par 24064
		
epilog

end;</source>
        <Parameter name="req" type="CM_DeliveryRequest"/>
        <ReturnType type="CM_WagonController"/>
    </JadeMethod>
    <JadeMethod name="getNextFreeWagonContForWLE" id="3486e946-50e4-4aa9-9c76-0d1e1063662b">
        <source>getNextFreeWagonContForWLE(intendedTI : CM_TrackedItem;  _wle : CM_WorkListEntry input) : CM_WagonController;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2019	jlger1	Initial creation

*/

vars
	location : CM_LocationsController;
	 freeLocation : CM_WagonController;
begin
	if _wle &lt;&gt; null then
		location := _wle.getTargetLocation;
		if location &lt;&gt; null and location.isWagon then
			freeLocation:=location.CM_WagonController;
		endif;
		if freeLocation = null and _wle.isYardReleaseAssigned then
			freeLocation := _wle.CM_YardWLE.allLocationControllers.first;
		endif;
		
		if freeLocation &lt;&gt; null and freeLocation.isKindOf(CM_WagonController) then
			if freeLocation.CM_WagonController.myWagon &lt;&gt; self then
				freeLocation:=null;
			endif;
		endif;
	endif;
	
	if freeLocation = null then
		if self.allLocationsControllersArray.size = 0 then
			return null;
		endif;
		
		//find first available space on this wagon
		freeLocation := self.getNextFreeWagonController( intendedTI, REAL_MODE, null, null, true );
	
	endif;
	
	return freeLocation;

epilog

end;</source>
        <Parameter name="intendedTI" type="CM_TrackedItem"/>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="input"/>
        <ReturnType type="CM_WagonController"/>
    </JadeMethod>
    <JadeMethod name="getNextFreeWagonController" id="54a94501-dbec-4be5-9d56-b94f22fc135d">
        <source>getNextFreeWagonController(intendedTI : CM_TrackedItem; mode : Integer; _intendedIsoType : CM_ISOType; _intendedIsoTypeGroup : CM_ISOTypeGroup; _doValidations : Boolean) : CM_WagonController;
/*
 ------------------------------------------------------------------------
Created:		24 July 2001 by cnwdwq1
Purpose:		Returns the first free wagonController that this TI will fit on, else NULL
Parameters:		None
Returns:		CM_WagonController
Changed On		Changed By		Reason
21 Aug 2009		NDL				Added parameter for isotype CCMS 1094
--------------	--------------	-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	nextFreePos	: Real;
	lc			: CM_WagonController;
begin

	//nextFreePos  := self.getNextFreeWagonPosition(intendedTI,_intendedIsoType, mode, _doValidations);	// 06 Oct 2009	NDL	Par 20842 Param chg
	nextFreePos  := self.getNextFreeWagonPosition(intendedTI,_intendedIsoType, _intendedIsoTypeGroup, mode, _doValidations);	//10 May 2010	NDL Par 24064

	if nextFreePos &lt; 1 then
		return null;
	endif;
	if nextFreePos &gt; self.allLocationsControllersArray.size then
		return null;	//!!!! Huh?? Belts n Braces
	endif;
	lc := self.allLocationsControllersArray[nextFreePos.Integer];
	
	return lc;
end;</source>
        <Parameter name="intendedTI" type="CM_TrackedItem"/>
        <Parameter name="mode" type="Integer"/>
        <Parameter name="_intendedIsoType" type="CM_ISOType"/>
        <Parameter name="_intendedIsoTypeGroup" type="CM_ISOTypeGroup"/>
        <Parameter name="_doValidations" type="Boolean"/>
        <ReturnType type="CM_WagonController"/>
    </JadeMethod>
    <JadeMethod name="getNextFreeWagonControllerPN" id="dc9745ab-4a80-474a-881c-68438d74749a">
        <source>getNextFreeWagonControllerPN(intendedTI : CM_TrackedItem; mode : Integer) : CM_WagonController;
// ---------------------------------------------------------------------------
// Created:     JUNE 2009 ANDREW BISHOP
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 02/07/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// 07/07/2009	consw1		PAR 20213 - Unable to plan outward rail while inward cargo still on wagon
// ---------------------------------------------------------------------------

vars
	nextFreePos : Real;
	numCurrently : Integer;
	numUnitsRequired : Integer;
	posInStack : Integer;
	maxNumInStack : Integer;
	lc : CM_WagonController;
begin

	maxNumInStack := self.myWagonClass.maxNumInStack;
	
	foreach posInStack in 1 to maxNumInStack do
		nextFreePos  := self.getNextFreeWagonPosIgnorePN(intendedTI, posInStack, mode);
		if nextFreePos &gt; 0 then
			break;
		endif;
	endforeach;

	if nextFreePos &lt; 1 then
		return null;
	endif;
	if nextFreePos &gt; self.allLocationsControllersArray.size then
		return null;	//!!!! Huh?? Belts n Braces
	endif;
	lc := self.allLocationsControllersArray[nextFreePos.Integer];
	
	return lc;
	
end;</source>
        <Parameter name="intendedTI" type="CM_TrackedItem"/>
        <Parameter name="mode" type="Integer"/>
        <ReturnType type="CM_WagonController"/>
    </JadeMethod>
    <JadeMethod name="getNextFreeWagonPos" id="4bcf77c3-a365-467b-903d-e16f0ed1eeea">
        <source>getNextFreeWagonPos(_intendedTI : CM_TrackedItem; _posInStack : Integer; _intendedIsoType : CM_ISOType; _intendedIsoTypeGroup : CM_ISOTypeGroup; _mode : Integer; _doValidations : Boolean) : Integer;

/*
Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 February 2010	cnwndl1	Initial creation	Par 22343	-New version
*/

vars


	numLcs : Integer;
	numUnitsRequired : Integer;
	pos, pos2, freePos, totalToBeUsed : Integer;
	lc : CM_WagonController;
	lc2 : CM_WagonController;
	cmifControl : CMIF_MoveController;
	rulesMet : CM_WagonPositionalRuleSet;
	errorPosition : Integer;
	trackClearance : CM_TrackClearance;
	clearanceError : String;
	firstLoc : CM_WagonController;
	
begin

	if _intendedIsoType &lt;&gt; null then
		numUnitsRequired := self.getLengthInUnitsForWagon(_intendedIsoType).Integer - 1; // minus 1 because we are inclusive
	elseif _intendedIsoTypeGroup &lt;&gt; null then	//10 May 2010	NDL Par 24064
		numUnitsRequired := self.getLengthInUnitsForWagon(_intendedIsoTypeGroup).Integer - 1; //10 May 2010	NDL Par 24064
	else
		numUnitsRequired := self.getLengthInUnitsForWagon(_intendedTI).Integer - 1; // minus 1 because we are inclusive
	endif;
	// ### how big is the wagon?
	numLcs := self.myWagonClass.getLenInUnits;
	freePos := 0;//init to unavailable pos
	
	// ### go through each controller. Is it avail, empty, and the locations after it empty, for the required length?
	foreach pos in 1 to numLcs do : loop1
		lc := self.allLocationsControllersArray[pos];
		if not lc.isReallyAvailable( _intendedTI, null, _posInStack, _intendedIsoType, _intendedIsoTypeGroup) then//10 May 2010	NDL Par 24064
			continue;
		endif;
		// have found one empty slot
		
		firstLoc := lc;	//09 Dec 2014	NDL	Par 35345

		freePos := pos;	// first free position
		totalToBeUsed := (pos + numUnitsRequired);	// number of positions required for the ti
		if totalToBeUsed &gt; numLcs then // Too big from this start position, would hang over the back of teh wagon.
			freePos := 0;
			break;
		endif;

		// now check the following positions are also MT and Available
		// i.e. that our TI will fit (we probably need more than one position)
		foreach pos2 in pos to totalToBeUsed do : loop2
			lc2 := self.allLocationsControllersArray[pos2];
			if not lc2.isReallyAvailable( _intendedTI, firstLoc, _posInStack, _intendedIsoType, _intendedIsoTypeGroup) then//10 May 2010	NDL Par 24064
				freePos := 0;
				break loop2;//unavailable
			endif;
		
		endforeach;
		
		// ### we found a position with enough empty / available following positions to fit out ti or isotype!!!
		if freePos &gt; 0 then
		
			// 06 Oct 2009	NDL	Par 20842 
			if _doValidations and _intendedTI &lt;&gt; null then	//14 Dec 2009	NDL	Par 21656
				create cmifControl transient;
				cmifControl.setMyToPrimaryLocation( self.allLocationsControllersArray[freePos] );
				cmifControl.setMyTrackedItem( _intendedTI );
				if self.myWagonMaster &lt;&gt; null then
					if self.myWagonMaster.myWagonClass &lt;&gt; null then
						if not self.myWagonMaster.myWagonClass.allWagonPositionalRules.loadMeetsWagonPositionalRule( cmifControl, self, errorPosition, rulesMet ) then
							//write _intendedTI.id &amp; " is outside of Positional rules on " &amp; self.id &amp; " @ " &amp; freePos.String &amp; " with current/planned load";
							// not right for this position on the wagon
							delete cmifControl;
							continue;
						endif;
					endif;
				endif;
				if self.myTrainOutwards &lt;&gt; null then
					trackClearance := self.myTrainOutwards.myTrackClearance;
					if trackClearance &lt;&gt; null then
						clearanceError := self.validateUsingTrackClearance(cmifControl, trackClearance, _mode, false, false);
						if clearanceError &lt;&gt; null then
							//write _intendedTI.id &amp; " would give track clearance error on " &amp; self.id &amp; " @ " &amp; freePos.String &amp; " [" &amp; clearanceError &amp; "]";
							//exceeds track clearance settings in this pos.
							delete cmifControl;
							continue;
						endif;
					endif;
				endif; 
			endif;
		
			return freePos;
		endif;
	
	endforeach;
	
	return freePos;
	
epilog

	delete cmifControl;
	
end;</source>
        <Parameter name="_intendedTI" type="CM_TrackedItem"/>
        <Parameter name="_posInStack" type="Integer"/>
        <Parameter name="_intendedIsoType" type="CM_ISOType"/>
        <Parameter name="_intendedIsoTypeGroup" type="CM_ISOTypeGroup"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_doValidations" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNextFreeWagonPosIgnorePN" id="b53a952d-78e0-4733-a420-c0c69fb6e7f3">
        <source>getNextFreeWagonPosIgnorePN(_intendedTI : CM_TrackedItem; _posInStack : Integer; mode : Integer) : Integer;
// ---------------------------------------------------------------------------
// Created:		June 2009 By Andrew Bishop cnwab1
//
// Purpose:		Need to ignore prenote TIs
//
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// 07/07/2009	consw1		PAR 20213 - Unable to plan outward rail while inward cargo still on wagon
// ---------------------------------------------------------------------------
vars
	numberOfTis : Integer;
	numCurrently, numLcs : Integer;
	numUnitsRequired, pos, pos2, freePos, totalToBeUsed : Integer;
	lc : CM_WagonController;
	ti, tiActual, tiPlanning, tiQueue, tiNextActual : CM_TrackedItem;
begin

	numUnitsRequired := _intendedTI.getLengthInUnits().Integer - 1; // minus 1 because we are inclusive
	// ### how big is the wagon?
	numLcs := self.myWagonClass.getLenInUnits;
	freePos := 0;//init to unavailable pos

	// ### go through each controller. Is it avail, empty, and the locations after it empty, for the required length?
	foreach pos in 1 to numLcs do : loop1
		lc := self.allLocationsControllersArray[pos];
		
		tiActual := null;
		tiPlanning := null;
		tiQueue := null;
		tiNextActual := null;
		
		numberOfTis := lc.numQueuedTIs;
		if mode = PLANNING_MODE then
			numberOfTis := numberOfTis + lc.numPlannedTIs;
		endif;

		if numberOfTis &gt;= _posInStack then
			continue;
		endif;

		// Allow for actual cargo that is not prenoted.
		foreach ti in lc.allTrackedItems do
			if mode &lt;&gt; PLANNING_MODE or self.isTIOutward(ti) then
				if not ti.isPreNote() // its prenoted so don't take into account.
				or self.isInTransit() then // hold on it's in transit so allow for this.
					numberOfTis := numberOfTis + 1;
					tiActual := ti;
				endif;
			endif;
		endforeach;

		if numberOfTis &gt;= _posInStack then
			continue;
		endif;

		// Check overstow is ok

		//if tiActual &lt;&gt; null and not tiActual.isOverStowable(_intendedTI,null) then
		if tiActual &lt;&gt; null and not tiActual.isOverStowableOnWagon(self,_intendedTI,null,null) then//10 May 2010	NDL Par 24064
			continue;
		endif;

		if lc.numPlannedTIs &gt; 0 then
			tiPlanning := lc.getTIAtIndex(PLANNING_MODE, lc.allPlannedFutureMoves.size);
			//if tiPlanning &lt;&gt; null and not tiPlanning.isOverStowable(_intendedTI,null) then
			if tiPlanning &lt;&gt; null and not tiPlanning.isOverStowableOnWagon(self,_intendedTI,null,null) then//10 May 2010	NDL Par 24064
				continue;
			endif;
		endif;
	
		if lc.numQueuedTIs &gt; 0 then
			tiQueue := lc.getTIAtIndex(QUEUE_MODE, lc.allQueuedFutureMoves.size);
			//if tiQueue &lt;&gt; null and not tiQueue.isOverStowable(_intendedTI,null) then
			if tiQueue &lt;&gt; null and not tiQueue.isOverStowableOnWagon(self,_intendedTI,null,null) then//10 May 2010	NDL Par 24064
				continue;
			endif;
		endif;

		// have found an empty place

		freePos := pos;
		totalToBeUsed := (pos + numUnitsRequired);
		if totalToBeUsed &gt; numLcs then // Too big
			freePos := 0;
			break;
		endif;

		// check that our TI will fit i.e. that the LCs that the TI will cover are also MT and Avail

		foreach pos2 in pos to totalToBeUsed do : loop2
			lc := self.allLocationsControllersArray[pos2];
			
			foreach ti in lc.allTrackedItems reversed do
				if mode &lt;&gt; PLANNING_MODE or self.isTIOutward(ti) then
					if not ti.isPreNote() // its prenoted so don't take into account.
					or self.isInTransit() then // hold on it's in transit so allow for this.
						tiNextActual := ti;
						break;
					endif;
				endif;
			endforeach;

			if tiNextActual &lt;&gt; tiActual then
				freePos := 0;
				break loop2;//unavailable or cannot overstow - continue outside loop
			endif;

			if lc.numQueuedTIs &gt; 0 or tiQueue &lt;&gt; null then
				if lc.numQueuedTIs = 0
				or tiQueue &lt;&gt; lc.getTIAtIndex(QUEUE_MODE, lc.allQueuedFutureMoves.size) then
					freePos := 0;
					break loop2;//unavailable or cannot overstow - continue outside loop
				endif;
			endif;
			
			if lc.numPlannedTIs &gt; 0 or tiPlanning &lt;&gt; null then
				if lc.numPlannedTIs = 0
				or tiPlanning &lt;&gt; lc.getTIAtIndex(PLANNING_MODE, lc.allPlannedFutureMoves.size) then
					freePos := 0;
					break loop2;//unavailable or cannot overstow - continue outside loop
				endif;
			endif;

		endforeach;
		
		// ### we found one!!!
		if freePos &gt; 0 then
			return freePos;
		endif;
	
	endforeach;
	
	return freePos;
end;</source>
        <Parameter name="_intendedTI" type="CM_TrackedItem"/>
        <Parameter name="_posInStack" type="Integer"/>
        <Parameter name="mode" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNextFreeWagonPosition" id="29fbe0fe-1aa8-4d78-9d87-2175911138f2">
        <source>getNextFreeWagonPosition(_intendedTI : CM_TrackedItem; _intendedIsoType : CM_ISOType; _intendedIsoTypeGroup : CM_ISOTypeGroup; _mode : Integer; _doValidations : Boolean) : Integer;
// ---------------------------------------------------------------------------
// Created:		October 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// 21 Aug 2009 NDL Added parameter for isotype CCMS 1094
// 06 Oct 2009	NDL	Par 20842 Param chg
// ---------------------------------------------------------------------------
vars
	nextFreePos : Integer;
	posInStack : Integer;
	maxNumInStack : Integer;
begin

	maxNumInStack := self.myWagonClass.maxNumInStack;
	
	foreach posInStack in 1 to maxNumInStack do
		//nextFreePos  := self.getNextFreeWagonPos(_intendedTI, posInStack, _intendedIsoType, _mode, _doValidations);
		nextFreePos  := self.getNextFreeWagonPos(_intendedTI, posInStack, _intendedIsoType, _intendedIsoTypeGroup, _mode, _doValidations);//10 May 2010	NDL Par 24064
		if nextFreePos &gt; 0 then
//write self.id &amp; "  " &amp; posInStack.String &amp; ", " &amp; nextFreePos.String;
			break;
		endif;
	endforeach;

	return nextFreePos;
	
epilog

end;</source>
        <Parameter name="_intendedTI" type="CM_TrackedItem"/>
        <Parameter name="_intendedIsoType" type="CM_ISOType"/>
        <Parameter name="_intendedIsoTypeGroup" type="CM_ISOTypeGroup"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_doValidations" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNextWagon" id="0e11e335-cbdf-4949-ac2c-15b6b7cc5d40">
        <source>getNextWagon()	:	CM_Wagon;
//Finds the next wagon in the rail line
vars
	currentPos : Integer;
begin
	if self.confirmed = false then
		//-------------
		//We are NOT a confirmed wagon - not on a rake!
		//-------------
		return null;
	endif;
	currentPos := self.myRailLine.allWagons.indexOf(self);
	if currentPos = self.myRailLine.allWagons.size then
		return null;	//End of rake
	endif;
	return self.myRailLine.allWagons[currentPos +1];	
end;</source>
        <ReturnType type="CM_Wagon"/>
    </JadeMethod>
