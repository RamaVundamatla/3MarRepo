    <JadeMethod name="setupFormLoadPhotos" id="0c412646-ba50-42a9-b322-50499394b5df">
        <updating/>
        <source>setupFormLoadPhotos() updating;
/*
Purpose:			

Date		Who		Reason
04 January 2024	navab1	CR 58499 TASK 61458
*/

vars
	photo : CM_Photo;
	attachment : CM_Attachment;
	iter: Iterator;
	
	frame: Frame;
	frmLeft,
	lastThumbnailWidth	: Real;
	thumbnailContainer  : Control;

begin
	frmLeft := CMUI_CargoPhotosForm.Thumbnail_Left;	
	lastThumbnailWidth := 0;
	thumbnailContainer := self.frmPhotoThumb.getThumbnailContainer();
	
	iter:=self.myTerminalArea.allAttachments.createIterator();
	self.myTerminalArea.allAttachments.startKeyGeq(CM_Attachment.Type_Photo,iter);

	while iter.next(attachment) do
		if attachment.type &lt;&gt; CM_Attachment.Type_Photo then
			continue;
		endif;	
		photo := attachment.CM_Photo;
		if not self.allPhotos.includes(photo) then
			self.allPhotos.add(photo);
		endif;
		
		if (frmLeft + lastThumbnailWidth + CMUI_CargoPhotosForm.Thumbnail_Space) &gt; thumbnailContainer.width then
			self.frmPhotoThumb.increaseSize(thumbnailContainer.width *2, thumbnailContainer.height);
		endif;
		frame := self.createPhotoThumbnail(photo.getThumbnailContent(),CMUI_CargoPhotosForm.Thumbnail_Top,frmLeft,CMUI_CargoPhotosForm.Thumbnail_Width, CMUI_CargoPhotosForm.Thumbnail_Height);	
		frame.parent := thumbnailContainer;		
		frmLeft := frame.left + frame.width + CMUI_CargoPhotosForm.Thumbnail_Space;	
		lastThumbnailWidth := frame.width;
		
		break;
	endwhile;
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="7e2c6c56-ebaf-4814-bb88-bfd6550407f9">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 03 January 2024 15:02:34.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0026581, locale);
end;</source>
    </JadeMethod>
</GUIClass>
