    <JadeMethod name="setComboValues" id="d8e6e9dd-6761-4280-8da2-6bad8e4e0996">
        <source>setComboValues(_combo : ComboBox input; _params : CM_QueryCriteriaLineHolder; _queryOperator : CM_QueryOperator; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     18 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	crit			: CM_SelectorCriteriaLine;
	idx				: Integer;
	os				: ObjectSet;
	value			: Any;
	obj				: Object;
	cargoType		: CM_CargoType;
	product			: CM_Product;
	qrl				: CM_QReferenceLookup;
	terminal : CM_Terminal;
begin

	_combo.clear;
	
	if _params = null then // SUMMARIES DO NOT HAVE PARAMS WITH CRITERIA
		 // TFS 7528 
		// Build full list of sub cargo types
		 terminal := app.myPassport.myTerminal;
		foreach cargoType in app.myRoot.allCargoTypesById do
		
			if terminal &lt;&gt; null then
				if not terminal.allCargoBOLTypes.includes(cargoType) then
					continue;
				endif;
			endif;
			
			foreach product in cargoType.allProducts do
				idx := _combo.addItem(cargoType.abbreviation &amp; " - " &amp; product.code);
				_combo.itemObject[idx] := product;
			endforeach;
		endforeach;
		
		
		// Select the chosen one
		if CM_QReferenceLookup.hasInstance(_queryOperator) then
			qrl := _queryOperator.CM_QReferenceLookup;
			if global.isValidObject(qrl.mySelectionValue) then
				_combo.listObject := qrl.mySelectionValue;
			endif;
		endif;
	
		
		return;
	endif;
	
	//07/10/2025	navkc1 JIRA 36147 Do Content Cargo Type if there is one
	crit := _params.allCriteriaByPropertyName[CM_TrackedItem::getCargoTypeIdForContents.name, CM_TrackedItem.name]; // 19/10/2025	navkc1 MTN JIRA 36352
	
	//07/10/2025	navkc1 JIRA 36147
	if crit = null then
		crit := _params.allCriteriaByPropertyName[CM_TrackedItem::cargoType.name, CM_TrackedItem.name];  // 19/10/2025	navkc1 MTN JIRA 36352
	endif;
	
	create os transient;
	
	if crit &lt;&gt; null then
		if CM_QReferenceIsOneOf.hasInstance(crit.myQueryOperator) then
			crit.myQueryOperator.getSearchValueAsObjectSet(os);
		elseif	CM_QIntegerLookupNotEqual.hasInstance(crit.myQueryOperator) or 
				CM_QIntegerLookupEqual.hasInstance(crit.myQueryOperator) then
			cargoType := app.myRoot.allCargoTypesById[crit.myQueryOperator.getSearchValue().Integer];	
			if cargoType = null then
				app.msgBox(app.getString(CouldNotFindCargoType), 'Warning', 0);
				return;
			endif;
			os.add(cargoType);
		endif;
		
	else
		app.msgBox(app.getString(SpecifyCargoType), 'Warning', 0);				//+cnwml2 PAR24397
		return;
	endif;
	
	foreach obj in os do
		cargoType := obj.CM_CargoType;
		foreach product  in cargoType.allProducts do
			idx := _combo.addItem(product.code);
			_combo.itemObject[idx] := product;
		endforeach;
	endforeach;
	
	if CM_QReferenceLookup.hasInstance(_queryOperator) then
		qrl := _queryOperator.CM_QReferenceLookup;
		
		obj := qrl.mySelectionValue; // 19/10/2025	navkc1 MTN JIRA 36352
		
		if global.isValidObject(obj) then
			idx := _combo.findObject(obj);  // 19/10/2025	navkc1 MTN JIRA 36352
			
			// 19/10/2025	navkc1 MTN JIRA 36352
			if idx &gt; null then
				//_combo.listObject := qrl.mySelectionValue;
				_combo.listIndex := idx; // 19/10/2025	navkc1 MTN JIRA 36352
			endif;
		endif;
	endif;
	
epilog
	delete os;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="cacf661d-813b-48f3-a9a8-097bc34c0426">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QReferenceIsOneOf ; _passport: CM_Passport);
//15 June 2010	cnwml2
//+cnwml2 PAR24397

vars
	subCargo : CM_Product;
	criteriaLine : CM_SelectorCriteriaLine;
	cargoType : CM_CargoType;
	selectionValue : Integer;
	idx : Integer;
	terminal : CM_Terminal;
begin
	_tbl.clear();
	_tbl.rows := 0;
	_tbl.sortColumn[1] := 2; // TFS 7821

	
	foreach criteriaLine in _params.allCriteriaLines do
		if criteriaLine.propName = "cargoType" then
			cargoType := app.myRoot.allCargoTypesById[criteriaLine.myQueryOperator.getSearchValue().Integer];	
			break;
		endif;
	endforeach;
	
	if cargoType &lt;&gt; null then // TFS 7528
		foreach subCargo in cargoType.allProducts do
			selectionValue := 0;
			if _operator &lt;&gt; null then
				if _operator.allSelectionValues.includes(subCargo) then
					selectionValue := 1;
				endif;
			endif;
			idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; subCargo.code &amp; " - " &amp; subCargo.description);
			_tbl.accessRow(idx).itemObject := subCargo.CM_Product;
			_tbl.row := idx;
			_tbl.change(_tbl); 
		endforeach;
	else
	 // TFS 7528
	 terminal := app.myPassport.myTerminal;
		foreach cargoType in app.myRoot.allCargoTypesById do
		
			if terminal &lt;&gt; null then
				if not terminal.allCargoBOLTypes.includes(cargoType) then
					continue;
				endif;
			endif;
			
			foreach subCargo in cargoType.allProducts do
				selectionValue := 0;
				if _operator &lt;&gt; null then
					if _operator.allSelectionValues.includes(subCargo) then
						selectionValue := 1;
					endif;
				endif;
				idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; cargoType.abbreviation &amp; " - " &amp; subCargo.code &amp; " - " &amp; subCargo.description);
				_tbl.accessRow(idx).itemObject := subCargo.CM_Product;
				_tbl.row := idx;
				_tbl.change(_tbl); 
			endforeach;
		endforeach;
	endif;
	
	
	_tbl.sortColumn[1] := 2;
	_tbl.sortAsc[1] := true;
	_tbl.resort();
	
epilog

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QReferenceIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="51d7734d-c39d-4ee4-8456-39d18eed8e54">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
//15 June 2010	cnwml2
//+cnwml2 PAR24397


vars
	cargoSubType	: CM_Product;
	str			: String;
	numRows,
	idx			: Integer;
	ia			: ObjectSet;

begin

	create ia transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			cargoSubType := _tbl.accessRow(idx).itemObject.CM_Product;
			ia.add(cargoSubType);
		endif;
	endforeach;
	
	_op.setSearchValue(ia);

epilog
	delete ia;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showCriteria" id="467015f4-389e-4158-919c-698fba75f4cc">
        <source>showCriteria(lineHolder: CM_QueryCriteriaLineHolder input): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Nov 2019	jlger1	Initial creation  47132

*/

vars
	os : ObjectSet;
	obj : Object;
begin
	
	create os transient;
	lineHolder.getCargoTypes(os);
	
	foreach obj in os discreteLock do
		if obj.CM_CargoType.isSubCargoTypeRequired then
			return true;
		endif;
	endforeach;
	
	return false;

epilog
	delete os;
end;</source>
        <Parameter name="lineHolder" type="CM_QueryCriteriaLineHolder" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="02797271-e80c-4f1e-a8fc-08ae4e2aeb9b">
        <source>translateStringToSearchValue( _value: Any; _criteriaLine : CM_SelectorCriteriaLine ): Any;
// ----------------------------------------------------------------------
// Created 12 May 2008 by cnwvu1
//
// Purpose:	Gets value as String from RT screen and returns value
//			 into criteriaLineLine for running a query
// ----------------------------------------------------------------------

vars
	prod		: CM_Product;
	critHolder	: CM_QueryCriteriaLineHolder;
	critLine	: CM_SelectorCriteriaLine;
	cargoType	: CM_CargoType;
	dict		: CM_ProductByOpCodeProCodeDict;
	tmpValue	: String;
	
begin

	if _value.isKindOf( CM_Product ) then
		return _value;
	endif;

	tmpValue := _value.String.toUpper();
	
	critHolder	:= _criteriaLine.myCriteriaLineHolder;
	critLine	:= critHolder.allCriteriaByPropertyName['cargoType', CM_TrackedItem.name];
	cargoType := app.myRoot.allCargoTypesById[ critLine.myQueryOperator.getSearchValue().Integer ];
	
	dict	:= cargoType.allProducts;
	
	foreach prod in dict discreteLock do
		if prod.code.toUpper() = tmpValue then
			return prod;
		endif;
	endforeach;

	// when not found. Par 17092	cnwvu1, June 2008
	inheritMethod( _value, _criteriaLine );

end;
</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="107a00fd-fa3b-44aa-8311-a1a65d0c6295">
        <source>translateToDisplayValue(_value: Any): String;
// ---------------------------------------------------------------------------
// Created:     18 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
22 Oct 2008	cnwkpd1	PAR #18099 - Handle null objects in selector queries

*/

vars

begin
	if _value &lt;&gt; null then
		return _value.CM_Product.code;
	endif;
	
	return null;


end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="a5000e0f-df99-4ddd-8e38-1dd17010a163">
        <source>translateToSearchValue(_value: Any): Any;
// ---------------------------------------------------------------------------
// Created:     18 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
06 Oct 2008	cnwkpd1	PAR #18099 - Correct Selector query processing
22 Oct 2008	cnwkpd1	PAR #18348 - Prevent 1002 exceptions in Selector query processing with isOneOf

*/

vars
	returnVal		: CM_Product;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			// PAR #18348
			return _value;
		endif;

		if _value.isKindOf(CM_Product) then
			returnVal := _value.CM_Product;
		endif;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
