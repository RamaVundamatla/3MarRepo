    <JadeMethod name="setMessageAsRead" id="edefa3d9-5b05-45b4-86bd-00194a602ada">
        <source>setMessageAsRead(_msg : CM_Message);
// ---------------------------------------------------------------------------
// Created:     15 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if _msg = null then
		return;
	endif;

	if self.allMessagesToRead.includes(_msg) then
		self.allMessagesToRead.remove(_msg);
	endif;

	if (not self.allMessagesRead.includes(_msg)) then
		self.allMessagesRead.add(_msg);
	endif;
	
end;</source>
        <Parameter name="_msg" type="CM_Message"/>
    </JadeMethod>
