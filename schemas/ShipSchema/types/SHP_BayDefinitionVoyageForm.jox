    <JadeMethod name="showShipGraphicForm" id="e63070b7-ab4d-4971-9def-de0845716a00">
        <source>showShipGraphicForm();
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		This form stores the polygons, used for drawing the side profile of a Voyage, into a graphic on the NULL voyage.
//
// ---------------------------------------------------------------------------

vars
/*
	theForm : Form;
	theLeftRequests: CM_SlotRequestArray;
	thePoints : CMUI_GridPointSet;
	aPoint : CMUI_GridPoint;
	aRequest : CM_SlotRequest;
	aBayPoint : SHP_BayPoint;
*/
begin
	if not app.isDevelopmentSystem then
		if not app.isSpecial() then
			return;
		endif;
	endif;
	
	app.mousePointer := Window.MousePointer_HourGlass;
	self.myAssistant.showGraphicCommandForm(self.myMasterMenuAction,0);

/*	// Now create the form
	theForm := app.getForm(SHP_ShipGraphicForm.name);
	if theForm = null then
		create theForm as SHP_ShipGraphicForm;
	endif;

	theForm.SHP_ShipGraphicForm.myTerminal := self.myTerminal;
	theForm.show();
*/
epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="showWithObjectMode" id="09249eb8-9662-48da-9398-ae45b03a35cc">
        <updating/>
        <source>showWithObjectMode(_voyage : CM_Voyage; _doMode: Boolean) updating;
//--------------------------------------------------
// Created:	15 December 2005 By: cnwgd1
//--------------------------------------------------
vars

	failedDAC  :CM_DataAccessController;

begin
	inheritMethod(_voyage, _doMode);
	if _voyage &lt;&gt; null
	and (not _voyage.isNullVoyage)
	and _voyage.myCellularVoyageStructure &lt;&gt; null	
	and _voyage.canUserAccessSelf(null, failedDAC, app.myPassport) then
		self.myCurrentVoyage := _voyage;
	endif;

	if self.myCurrentVoyage &lt;&gt; null then
		if _doMode then
			// set to update mode. self.loadDataForFirstTime() will init form in update mode for the selected vessel
			self.mode := self.Mode_Update;
		endif;
	elseif _doMode then
		// set to add mode. self.loadDataForFirstTime() will init form in add mode
		self.mode := self.Mode_Add;			
	endif;
	
	self.show();
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_doMode" type="Boolean"/>
    </JadeMethod>
