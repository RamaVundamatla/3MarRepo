    <JadeMethod name="doSave" id="3c07a5e8-e997-4b9d-b75a-31e3d70a6a81">
        <source>doSave(): Boolean;
// ---------------------------------------------------------------------------
// Created:     11 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	pxyCargoStatus			: CM_CargoStatus;
	tbl						: CM_EntryTable;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	tbl := self.myForm.tblInput1;
	pxyCargoStatus := self.myForm.myProxyObject.CM_CargoStatus;
	
	if pxyCargoStatus = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy cargo status is null');
		return false;
	endif;
	
	pxyCargoStatus.setProxyForUpdate(tbl.getValueByName(ETRow_Abbreviation).String,
							tbl.getValueByName(ETRow_Description).String,
							tbl.getValueByName(ETRow_Colour).Integer);
							
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateCargoStatus(pxyCargoStatus, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Update Cargo Status', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
