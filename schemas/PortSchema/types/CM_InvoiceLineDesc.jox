    <JadeMethod name="createInvoiceLineInventory" id="d645b0a3-b6bf-433f-88b1-ccefa6334408">
        <updating/>
        <source>createInvoiceLineInventory(debtor : CM_Debtor; tran : CMEVT_LocationActivity) : CM_InvoiceLine updating;
/*
Purpose:			

Date		Who		Reason
31MAY2021	NAVAB1	TFS 51219
*/

vars
	invLine:   CM_InvoiceLine;
	invoice:   CM_Invoice;
	now:       TimeStamp;
	seqNum : Integer;
	invType : CM_InvoiceDesc;
	calcType: CM_CalculationType;
	cmifHook: CMIF_CalcTypeRemarksHook;
	valueOut,
	origRemarks: String;
begin

	invType := self.getInvoiceType(debtor);

	invoice := self.bank.getAutoInvoiceEvent(invType, self, tran, debtor);

	create invLine persistent;
	seqNum := app.getNextInvoiceSeqNumOnRootBank(SN_INVOICELINE); 

	if tran.dateTime.isValid then
		now := tran.dateTime;
	else
		now := app.serverTimestampAtTrxStart;
	endif;
	invLine.setForCreate(seqNum, false, null, self, invoice, debtor, bank, 0, now); 
	invLine.setMyTransactionEvent(tran);
	invLine.setTrackedItem(tran.myTrackedItem);
	invLine.createCharges();

	invLine.doHookCodeForRemarks();

	
	app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(invLine);	

	return invLine;

epilog
	delete cmifHook;
end;</source>
        <Parameter name="debtor" type="CM_Debtor"/>
