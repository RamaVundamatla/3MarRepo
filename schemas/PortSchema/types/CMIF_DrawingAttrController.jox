    <JadeMethod name="handleShippingLineObj" id="e250230c-5249-4b33-8778-66ceabb32941">
        <source>handleShippingLineObj(_code : String; _codesArray : StringArray input; _colorArray :IntegerArray input;_objArray : ObjectArray input);
// ---------------------------------------------------------------------------
// Created:  06-06-2022 navtnr20  ChangeRequest 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	iter		: Iterator;
	trimCode,
	theCode,
	codeKey		: String;
	theColor,
	colorKey	: Integer;
	tmpShippingLine	: CM_ShippingLine;

begin

	trimCode := _code.trimBlanks;

	iter := self.myIterShippingLine;
	self.allShippingLines.startKeyGeq(trimCode, 0, iter);
	self.allShippingLines.getIteratorKeys(codeKey, colorKey, iter);
	
	if codeKey = trimCode then
		// found the right one
		theCode		:= _code;
		theColor	:= colorKey;
	else
		tmpShippingLine := self.myRoot.allShippingLines[trimCode];
		if tmpShippingLine &lt;&gt; null then
			self.allShippingLines.add(tmpShippingLine);
			theCode		:= trimCode;
			theColor	:= tmpShippingLine.colour;
		else
			theCode		:= null;
			theColor	:= NullColour;
		endif;
	endif;

	_codesArray.atPut(TI_ColourMode_ShippingLine, theCode);
	_colorArray.atPut(TI_ColourMode_ShippingLine, theColor);
	_objArray.atPut(TI_ColourMode_ShippingLine, tmpShippingLine);

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_codesArray" type="StringArray" usage="input"/>
        <Parameter name="_colorArray" type="IntegerArray" usage="input"/>
        <Parameter name="_objArray" type="ObjectArray" usage="input"/>
