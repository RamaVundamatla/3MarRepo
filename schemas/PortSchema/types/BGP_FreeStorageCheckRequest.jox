<Class name="BGP_FreeStorageCheckRequest" id="e774ad39-ec23-4a4a-81a6-19744baa07a1">
    <superclass name="BGP_Request"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <access>protected</access>
    <text>&lt;display&gt;Check Free Storage Days Expiry&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <JadeMethod name="action" id="6d3f8960-690d-4a1b-9b35-0fffa10e02ea">
        <updating/>
        <source>action(): Boolean updating;
// --------------------------------------------------------------------------------
// Created:		02 May 2006 by cnwdad1
//
// Purpose:		Standard implementation method to action a request.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errCode	: Integer;
	errTxt	: String;
	
begin
	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), errCode, errTxt, true, true);
	on LockException do app.alertLockExceptionHandler(exception);
	
	self.processCheckRequest();
epilog
	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errTxt, app.myPassport);
	else
		app.createActivityHistory(ActivityHistoryGeneral, self.myTerminal, null, app.getErrorString(Successfully_CheckedFreeStores), false, false);
	endif;
	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="b0016c27-b07d-4e2a-8466-23a04404f390">
        <source>getDisplay(): String;
// --------------------------------------------------------------------------------
// Created:		02 May 2006 by cnwdad1
//
// Purpose:		Returns a display string for the receiver.
//
// Parameters:	None
//
// Returns:		The display string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return inheritMethod() &amp; " Check Free Storage Days Expiry Request";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
