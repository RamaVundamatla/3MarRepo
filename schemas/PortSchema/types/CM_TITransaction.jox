/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
25 November 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars
	
	code : CM_HarmonizedSystem;
	
begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	if self.hsCode = null then
		return;
	endif;
		
	code := app.myRoot.allHSCodesActive[self.hsCode];
		
	if code = null then
		return;
	endif;
		
	_value := code;

epilog

end;</source>
