    <JadeMethod name="handleShowModal" id="e25365bf-847c-4319-92a6-3414c7a94f32">
        <updating/>
        <source>handleShowModal():Integer updating;

vars
	sa:StringArray;
	meth:String;
	atcgModalCount:Integer;
begin
	create sa transient;
	app.atcgModalCount:=app.atcgModalCount+1;
	atcgModalCount:=app.atcgModalCount;

	if atcgModalCount = 1 then
		myMB_MsgBoxForm_1:=app.getForm('MB_MsgBoxForm').MB_MsgBoxForm;
		myMB_MsgBoxForm_1.show;
		myMB_MsgBoxForm_1.activate;
		sa.add('sll008m_MMBF_btnDialog1_click');
	endif;

	foreach meth in sa do
		if meth[7:3] &lt;&gt; "mv_" then
			app.doWindowEvents(longPause);
		endif;
		userPreTransaction(meth);
		retCode:=self.sendMsg(meth).Integer;
		userPostTransaction(meth);
		if retCode = 0 then
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" succeeded");
		else
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" failed with error code "&amp;retCode.String);
			app.atcgReplayFailure:=true;
			break;
		endif;
	endforeach;

	if atcgModalCount = 1 then
		if app.isValidObject(myMB_MsgBoxForm_1) then
			myMB_MsgBoxForm_1.unloadForm;  // 14:18:47
		endif;
		myMB_MsgBoxForm_1:=null;
		return 6;
	endif;
epilog
	delete sa;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="runTest" id="c92647c4-60f7-47ee-a79a-2699db59d552">
        <updating/>
        <source>runTest():Integer updating;

vars
	sa:StringArray;
	meth:String;
begin
	create sa transient;
	sa.add('sll002_HHLF_btnAppShipLaclick');
	sa.add('sll004_HHSLF_btnLogOff_click');
	sa.add('sll006_HHLF_btnExit_click');
	sa.add('sll999_tidyUp');
	app.atcgSetMsgBoxReturn('Exiting will close this application. Are you sure you wish to exit?', 'Are you sure?', 4, 6);

	foreach meth in sa do
		if meth[7:2] &lt;&gt; "v_" then
			app.doWindowEvents(longPause);
		endif;
		userPreTransaction(meth);
		retCode:=self.sendMsg(meth).Integer;
		userPostTransaction(meth);
		if app.atcgReplayFailure then
			app.atcgReplayFailure:=false;
			break;
		elseif retCode = 0 then
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" succeeded");
		else
			app.logMessage("Test "&amp;self.class.name&amp;"::"&amp;meth&amp;" failed with error code "&amp;retCode.String);
			break;
		endif;
	endforeach;
	app.atcgDetectMissedMsgBoxes;
	app.logMessage("Finished");
	return 0;
epilog
	delete sa;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
