    <JadeMethod name="addToolbarControls" id="b31f324b-41de-4ad1-b230-61a33dd51897">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
//25/01/17 cnwns1 TFS3214 LNX - Voyage Operations Enhancements 
vars
	toolbar		: CMUI_Toolbar;
	showCaptions	: Boolean;
	
begin
	inheritMethod();

	toolbar := self.frmToolbar;
	showCaptions := toolbar.showCaptions;

	toolbar.addButton(self.btnNew, CMUI_Toolbar.Control_Alignment_Left);			
	toolbar.addButton(self.btnEdit, CMUI_Toolbar.Control_Alignment_Left);				
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnDelete, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);			

	toolbar.addButton(self.btnCopy, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnImport, CMUI_Toolbar.Control_Alignment_Left);					
	toolbar.addButton(self.btnExport, CMUI_Toolbar.Control_Alignment_Left);	

	//if app.myCurrentUserCan(self.myTerminal, PmShipPlanning) then
// ### JIRA 33505 30DEC2024 NAVAB1 (Mod_CargoShip in part of base now)	if app.myCurrentUserCan(self.myTerminal, Mod_CargoShip) then//07 Oct 2019	NDL	TFS 46169
		toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnBayDefinition, CMUI_Toolbar.Control_Alignment_Left);	
	//	toolbar.addButton(self.btnShipGraphics, CMUI_Toolbar.Control_Alignment_Left);
//	endif;
	
	if app.myCurrentUserCan(self.myTerminal, Mod_VesselRORO) then
		toolbar.addButton(self.btnRoRoDeckDef, CMUI_Toolbar.Control_Alignment_Left);	
	endif;
	
	//09 Jul 2013	NDL	Par 31965
	toolbar.addButton(self.btnHoldDef, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnEventAlloc, CMUI_Toolbar.Control_Alignment_Left); //25/01/17 cnwns1 TFS3214 LNX - Voyage Operations Enhancements 
	
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);	
	
end;</source>
