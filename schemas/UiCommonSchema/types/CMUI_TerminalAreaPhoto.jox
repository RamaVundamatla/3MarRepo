    <JadeMethod name="addToolbarControls" id="83c301f9-a6d2-4be8-9538-2eb73b658cf9">
        <updating/>
        <source>addToolbarControls() updating, protected;

/*
Purpose - 	
Who - NAVAB1
Date - 03JAN2024
ADO -  CR 58499 TASK 61458
*/

vars
	toolbarObj	: CMUI_Toolbar;
	
begin
	inheritMethod();

	self.frmALL.visible := false;
	self.btnPrintAll.visible := false;
	self.btnExportAll.visible := false;
	self.btnDeleteAll.visible := false;
	toolbarObj	:=	self.frmToolbar;
	toolbarObj.hideSeperator(8);

	
epilog

end;</source>
        <access>protected</access>
