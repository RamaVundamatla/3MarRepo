    </JadeMethod>
    <JadeMethod name="delete" id="e3cb747d-30b2-4bb3-866f-8061decafe59">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 April 2009	cnwer1	Initial creation PAR 19566 moved from erase was not being called when a collection of these objects
								were purged
//13/11/17 jlgns1 TFS 6960 QNS - Disk space issues and house keeping inside JMT
10/10/2018 	JLGNS1	Bug 40801: STWO - Issue 37878 occuring again in PROD
*/

vars

	job : CM_Job;

begin

	//TFS 6960
//	if self.myTrackedItem = null and app.isUnitTestGarbageCollect then
//		return;
//	endif;
	
	if 	app.isGarbageCollectionProcess then
		return;
	endif;
	
	if self.myTrackedItem = null then	//Bug 40801
		return;							//Bug 40801
	endif;								//Bug 40801
	
	//TFS 6960
	
	//29 Jan 2015	NDL	Par 35577 - and out with Par 35643
/*	if self.myWorkListEntry &lt;&gt; null then
		if self.myWorkListEntry.job &lt;&gt; null and self.myWorkListEntry.job.isKindOf(CM_VoyageROROJob) then
			job := self.myWorkListEntry.job;
			delete self.myWorkListEntry;
			if job.workListEntries.isEmpty then
				delete job;
			endif;
		endif;
	endif; */
		
	self.causeUpdateDisplayEvents(self.myTrackedItem, self.allLocationsControllers);	
	
	// DVB added.
	
	self.myTrackedItem.refreshMyFutureLocations(PLANNING_MODE,self); // PAR 9747	
	self.myTrackedItem.setHazardLocationsForMode(PLANNING_MODE, true); // PAR 16097

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAllLocationsString" id="6d907238-8d15-4b9e-a0b0-cbf58ae778b6">
        <source>getAllLocationsString(): String;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 06/11/2024	navdap1		MTN-18897 EUP | FR 53485 EUP - Warehouse Yard Allocation
// ---------------------------------------------------------------------------
vars
	lc	: CM_LocationsController;
	theString, tmpString : String;
	
	gcGroup : CM_GeneralCargoAllocGroup;	//22 Jul 2021	NDL	TFS 51429
	allGroups : CM_LCSet;	//22 Jul 2021	NDL	TFS 51429
	isAutoPlanFullGC : Boolean;
begin

	isAutoPlanFullGC := self.myTerminal.getAutoPlanAllowFullGCArea; //17Feb2023 navsp1 TFS 56543
	foreach	lc in self.allLocationsControllers do
		//22 Jul 2021	NDL	TFS 51429
		if lc.isGCAllocCont then
			gcGroup := lc.CM_GeneralCargoAllocController.myGroup;
			if gcGroup &lt;&gt; null then
				if allGroups = null then
					create allGroups transient;
					allGroups.add( gcGroup );
					//and let it fall through and have teh name added
				elseif allGroups.includes( gcGroup ) then
					continue;
					//same group, no need to add it again.
				else
					//add it
					allGroups.add( gcGroup );
					//and let it fall through and have this name added
				endif;
			endif;
		endif;
		
		tmpString := lc.getFullIdForTI(true);
		if self.isMoveToFullGCArea then				// MTN-18897
			tmpString := lc.myTerminalArea.id;
		endif;
		
		if theString = null then	
			theString := tmpString;
		else
			theString :=  theString &amp; ", " &amp; tmpString;
		endif;
		
	endforeach;
	
	return theString[1:30];			// 13/01/2010 cnwmh5 #22132
	
epilog

	delete allGroups;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
