    <JadeMethod name="getEmailBaseData" id="c06bb8d5-a1d3-4bdf-8a46-ca0c96d82383">
        <source>getEmailBaseData(pComputerName : String):CnEcEmailBaseData;

vars
	retValue : CnEcEmailBaseData;
	
begin
	retValue := self.allCnEcEmailBaseDatas.getAtKey(pComputerName);

	if retValue = null then
		retValue := self.myDefaultBaseData;
	endif;
	
	return retValue;
end;</source>
        <Parameter name="pComputerName" type="String"/>
        <ReturnType type="CnEcEmailBaseData"/>
    </JadeMethod>
