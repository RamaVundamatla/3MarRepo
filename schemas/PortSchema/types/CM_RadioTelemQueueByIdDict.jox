<CollClass name="CM_RadioTelemQueueByIdDict" id="20d2214e-2947-4ea1-9f4c-f4a1bba2bf10">
    <memberType name="CM_RadioTelemetryQueue"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="planning"/>
    <MemberKey>
        <property name="CM_RadioTelemetryQueue::id"/>
    </MemberKey>
    <JadeMethod name="addQueue" id="bf84d495-2a20-487d-98e3-0b38a20d7b0f">
        <lockReceiver/>
        <updating/>
        <source>addQueue(_queue : CM_RadioTelemetryQueue) updating;

vars

	parent : CM_RadioTelemetryQueue;

begin

	if not self.includes(_queue) then
		self.add(_queue);
		parent := _queue;
		while true do
			parent := parent.myParentQueue;
			if parent = null then
				break;
			endif;
		
			if not self.includes(parent) then
				self.add(parent);
			endif;
		endwhile;
	endif;

end;
</source>
        <Parameter name="_queue" type="CM_RadioTelemetryQueue"/>
    </JadeMethod>
</CollClass>
