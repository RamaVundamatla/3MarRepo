    <JadeMethod name="setupContextMenuItems" id="f8f2e537-a602-404e-ac6a-3befc7d47d25">
        <updating/>
        <source>setupContextMenuItems(table : CM_DataTable input) updating;
//-----------------------------------------
//
// Created : by cnwaer1 01 September 2008
//-----------------------------------------
vars
	realObj,
	pxyBookingItem : CM_BookingRefItem;
	resDtl : CM_ReserveDetail;
	ti		: CM_TrackedItem;
	obj : Object;
begin
	if self.tblItems.allSelectedObjects.size &gt; 0 then
		foreach obj in self.tblItems.allSelectedObjects do
			if obj.CM_BOLDtl.allTrackedItems.size &gt; 0 then
				self.mnuReceived.visible := true;
				self.mnuSeperator.visible := true;
			else
				self.mnuReceived.visible := false;
				self.mnuSeperator.visible := false;
			endif;
		endforeach;
	else
		self.mnuReceived.visible := false;
		self.mnuSeperator.visible := false;
	endif;
	
	self.mnuColumnOrganiser.visible := true;
end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="441f0c72-5f09-4e87-b62c-a86afb58e539">
        <updating/>
        <source>setupForm() updating;
//06 January 2010	cnwml2
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------
// 27/11/2013	cnwdap1		PAR #33019 CCMS DPH 2285 New BOL Fields
//19 July 2022	navmv20	ChangeRequest 54095: EUP - Outturn Remarks on BOL
//09 May 2023 navmv20  Bug 57659: CAL - Voyage BOL maintenance screen does not update properly.
vars

begin
	inheritMethod();
	
	self.portCmbOrderDescrFirst := app.myRoot.getConfig(PortCmbOrderDescrFirst).Boolean; //cnwas3 par23827
	
	//09/05/2023 navmv20 Bug 57659 - START
	//self.loadCombos();
	self.loadNotifyPartyCombo();
	self.loadVoyageCombo(true);
	//09/05/2023 navmv20 Bug 57659 - END
	
	if self.myCurrentBOL &lt;&gt; null then
		self.txtBOL.text := self.myCurrentBOL.number;
		if self.myCurrentBOL.isKindOf(CM_BOLIn) then
			self.cmbVoyage.setIndexFromObject(self.myCurrentBOL.CM_BOLIn.myVoyage);
		else
			self.cmbVoyage.setIndexFromObject(self.myCurrentBOL.CM_BOLOut.myVoyage);
		endif;
		
		self.loadOperatorCombo(); //09/05/2023 navmv20 Bug 57659
		self.loadDischargePortCombo(); //09/05/2023 navmv20 Bug 57659
		self.cmbOperator.setIndexFromObject(self.myCurrentBOL.myOperator);
		self.cmbDestination.myAssistant := self.myAssistant;
		self.cmbDestination.setObject(app.myRoot.allPorts[self.myCurrentBOL.destinationPort]);
		//self.cmbDischargePort.myAssistant := self.myAssistant;
		self.cmbDischargePort.setIndexFromObject(app.myRoot.allPorts[self.myCurrentBOL.dischargePort]);
		self.cmbLoadPort.myAssistant := self.myAssistant;
		self.cmbLoadPort.setObject(app.myRoot.allPorts[self.myCurrentBOL.loadPortCode]);
		self.cmbNofiyParty.setIndexFromObject(self.myCurrentBOL.myNotifyParty);
		self.chkDirDel.value := self.myCurrentBOL.directDelivery;
		
		self.txtServiceOrder.text := self.myCurrentBOL.clientRef1;				// PAR #33019
		self.txtPONbr.text := self.myCurrentBOL.clientRef2;						// PAR #33019
		
		self.dateGenLanding.setDate(self.myCurrentBOL.generalLandingDate); // TFS 4274

	else
		if self.myVoyage &lt;&gt; null then		// set from General Cargo Onship form
			self.cmbVoyage.setIndexFromObject(self.myVoyage);
			self.loadOperatorCombo(); //09/05/2023 navmv20 Bug 57659
			self.loadDischargePortCombo(); //09/05/2023 navmv20 Bug 57659
			self.cmbOperator.setIndexFromObject(self.myVoyage.myOperator);
		endif;
	endif;

	self.dateGenLanding.readOnly := not app.myCurrentUserCan(self.myTerminal, PmShpGLDateBOLMaint); // TFS 4274

	self.initTblItems(ETDef_BOLItems);
	self.loadItemTable();
	self.btnEdit.enabled := false;
	self.btnDelete.enabled := false;
	
	self.height := 420;
	
	if mode = Mode_View then
		//everything is read only
		self.txtBOL.enabled := false;
		self.cmbVoyage.enabled := false;
		self.cmbOperator.enabled := false;
		self.cmbDestination.enabled := false;
		self.cmbDischargePort.enabled := false;
		self.cmbLoadPort.enabled := false;
		self.cmbNofiyParty.enabled := false;
		self.chkDirDel.enabled := false;
		self.txtServiceOrder.enabled := false;									// PAR #33019
		self.txtPONbr.enabled := false;											// PAR #33019
	else
		self.txtBOL.enabled := true;
		self.cmbVoyage.enabled := true;
		self.cmbOperator.enabled := true;
		self.cmbDestination.enabled := true;
		self.cmbDischargePort.enabled := true;
		self.cmbLoadPort.enabled := true;
		self.cmbNofiyParty.enabled := true;
		self.chkDirDel.enabled := true;
		self.txtServiceOrder.enabled := true;									// PAR #33019
		self.txtPONbr.enabled := true;											// PAR #33019
	endif;	
	
	// 26/04/2010 cnwmh5 PAR23821 - Start
	// set buttons and controls for view based on maint permission
	// TFS 2198 self.btnEdit.enabled	:=  app.myPassport.myUser.canDo(self.myTerminal, self.permissionMaint);
		// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnAdd.enabled := false;
		self.btnDelete.enabled := false;
		self.tblItems.userInputEnabled := false; // TFS 2198
		self.btnSave.enabled := false;
		self.btnClear.enabled := false;
		self.setControlsForView();

	endif;

	self.setupOutturnTable(); //19/07/2022 navmv20 54095	
// TFS 2198 	if not btnEdit.enabled then
// TFS 2198 		self.setControlsForView();
// TFS 2198 	endif;

	// 26/04/2010 cnwmh5 PAR23821 - End
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupOutturnTable" id="a4bfcd34-5bbb-4c43-9a68-2e120ee44bcd">
        <updating/>
        <source>setupOutturnTable() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2022	navmv20	ChangeRequest 54095: EUP - Outturn Remarks on BOL

*/

vars
	outturnRemarksArray : HugeStringArray;
	str:String;
begin
	self.tblOutturn.tabKey := J_key_Tab;
	self.tblOutturn.rows := self.tblOutturn.fixedRows;
	self.tblOutturn.accessCell(1,1).text := app.getErrorString(Outturn_Remarks);
	self.tblOutturn.accessCell(1,1).alignment:= Table.Alignment_Center_Middle;
	create outturnRemarksArray transient;
	    if self.myCurrentBOL &lt;&gt; null then
			self.myCurrentBOL.getOutturnRemarksArray(outturnRemarksArray);
			foreach str in outturnRemarksArray do
				self.addRowToOutturnRemarks(str);
			endforeach;
		endif;
epilog
	delete outturnRemarksArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="tblItems_click" id="22da9ba1-e657-46ef-adf0-d73eb33caa9d">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblItems_click(table: Table input) updating;
//12 January 2010	cnwml2


vars

begin
/* TFS 2198
	if not self.btnEdit.enabled then		// 26/04/2010 cnwmh5 par 23821
		return;								// 26/04/2010 cnwmh5 par 23821
	endif;
	*/
	
	
	if self.tblItems.allSelectedObjects.size &gt; 0 then
		self.btnEdit.enabled := true;
		self.btnDelete.enabled := true;
	else
		self.btnEdit.enabled := false;
		self.btnDelete.enabled := false;
	endif;
	
		// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnDelete.enabled := false;
		self.btnAdd.enabled:= false;
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblItems_contextMenu" id="42c5d084-2551-47f4-ad4f-3af9c5600f75">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblItems_contextMenu(table: CM_DataTable input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
//22 January 2010	cnwml2


vars
	
begin
	return self.doMnuFormContextMenu(table, mouse, x, y);
epilog

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
