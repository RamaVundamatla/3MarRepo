end;</source>
        <Parameter name="_boundaryType" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasNoKeyboardPressed" id="38a3041e-c066-4541-8ce4-cfd7c04adb95">
        <source>hasNoKeyboardPressed() : Boolean;
// ---------------------------------------------------------------------------
// Created:		05 April 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if not self.isAltKeyPressed
	and not self.isControlKeyPressed
	and not self.isShiftKeyPressed then
		return true;
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
