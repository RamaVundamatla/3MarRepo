    <JadeMethod name="setObjectsPerTrx" id="90af06b2-6d90-4846-a677-44e243dccf34">
        <updating/>
        <source>setObjectsPerTrx(pValue : Integer) updating;

begin
	if self.objectsPerTrx &lt;&gt; pValue then
		if pValue &lt; 1 then
			self.objectsPerTrx := 1;
		else
			self.objectsPerTrx := pValue;
		endif;
	endif;
end;</source>
        <Parameter name="pValue" type="Integer"/>
    </JadeMethod>
