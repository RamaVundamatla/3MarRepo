    <JadeMethod name="doMovementAndGenInvNow" id="485a20ed-8d22-4d9e-bb96-c6728333f70f">
        <source>doMovementAndGenInvNow( _movment : HMS_VoyageMovement input;
						_pilot : HMS_Pilot;
						_pilotLaunch : HMS_PilotLaunch
						);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 June 2019	jlgndl1	Initial creation	TFS 44773

*/

vars

	load : Boolean;
	pxyMovement : HMS_VoyageMovement;
	pxyResourceUsed : HMS_ResourceUsed;

	resType : HMS_ResourceType;
	resource : HMS_Resource;
	unitsUsed : Real;
	fromDateTime : TimeStamp;
	toDateTime : TimeStamp;
	actionDateTime : TimeStamp;
	createCharge : Boolean;
	poc : Boolean;
	pxyVTMISTrans : HMS_VTMISTransaction;
	cM : HMS_VoyageMovement;
	pxyMovementPilotDetails : HMS_MovementPilotDetails;
	pxyTrxs : ObjectSet;

begin

	app.cmsBeginLoad( load );
	pxyMovement := _movment.pxyCreateUpdateProxy();
	app.cmsEndLoad( load );
	
	create pxyTrxs transient;
	
	foreach pxyResourceUsed in pxyMovement.allResourceUsed where pxyResourceUsed.myVTMISTransaction = null do
	
		create pxyVTMISTrans transient;
		pxyTrxs.add( pxyVTMISTrans );
		pxyResourceUsed.setProxy(	_movment.myHarbour,	//_harbour : HMS_Harbour;
									pxyResourceUsed.myResourceType,	//_resourceType : HMS_ResourceType;
									pxyResourceUsed.myResource,	//_rescource : HMS_Resource;
									pxyVTMISTrans,	//_pxyVTMISTrans : HMS_VTMISTransaction;
									pxyResourceUsed.fromDateTime,	//_fromDateTime : TimeStamp;
									pxyResourceUsed.toDateTime,	//_toDateTime : TimeStamp;
									unitsUsed.max(1),	//_unitsUsed : Real;
									false,	//_poc : Boolean;
									pxyResourceUsed.myWorkOrderVoyageDtl,	//_wodOrderVoyageDtl : CM_WorkOrderVoyageDtl;
									pxyResourceUsed.myDebtor	//_debtor : CM_Debtor
									);

	
	endforeach;
	
	pxyMovement.setProxyForMoveConfirmation(_movment.occursOnDTNEW, MovementStatus_Actual, _movment.draftAft, _movment.draftFwd );

	if _pilot &lt;&gt; null or _pilotLaunch &lt;&gt; null then
		create pxyMovementPilotDetails transient;
		pxyMovementPilotDetails.setProxy(	_pilot,	//_pilot : HMS_Pilot;
											_pilotLaunch,	//_pilotLaunch : HMS_PilotLaunch;
											pxyMovement,	//_movement : HMS_VoyageMovement;
											null	//_workingMovement : CMIF_HMS_WorkingMovement
											);
	endif;
	
	app.myTrxUA.trxUpdateHMSMovement( pxyMovement, app.myPassport );
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());

	
epilog

	delete pxyMovement;
	if pxyTrxs &lt;&gt; null and not pxyTrxs.isEmpty then
		pxyTrxs.purge();
	endif;
	delete pxyTrxs;
	

end;</source>
        <Parameter name="_movment" type="HMS_VoyageMovement" usage="input"/>
        <Parameter name="_pilot" type="HMS_Pilot"/>
        <Parameter name="_pilotLaunch" type="HMS_PilotLaunch"/>
    </JadeMethod>
    <JadeMethod name="doQueueUnplannedUnworkedCargo" id="ad3ab498-8fd2-42d1-80af-e893920a53fa">
        <source>doQueueUnplannedUnworkedCargo(  _ti : CM_TrackedItem; _job : CM_VoyageJob output; _wle : CM_WorkListEntry output );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 May 2010	cnwndl1	Initial creation	Par 23603

*/

vars

	targetLocn : CM_LocationsController;
	moveController : CMIF_MoveController;
	tiArray	: CM_TIArray;
	params : CMIF_AutoplanParams;
	
begin

	//establish our target location
	if _ti.myPrimaryQueuedLocation &lt;&gt; null then
		targetLocn := _ti.myPrimaryQueuedLocation;
	elseif _ti.myPrimaryPlannedLocation &lt;&gt; null then
		targetLocn := _ti.myPrimaryPlannedLocation;
	else
		// no target known, do an autoplan
		create tiArray transient;
		create params transient;
		params.allTrackedItems.add(_ti);
		params.moveMode := PLANNING_MODE;
		params.myTerminalArea := null;
		params.showWarningWhenNoPlan := false;
		app.myTrxUA.trxUpdateAutoplanTrackedItems(params, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
		if _ti.myPrimaryPlannedLocation &lt;&gt; null then
			targetLocn := _ti.myPrimaryPlannedLocation;
		endif;
	endif;

	// set up the move controller for a queued move
	create moveController transient;
	moveController.setMyTrackedItem(_ti);
	moveController.setMyOriginatingLocation(_ti.myPrimaryActualLocation);
	moveController.setMoveMode(QUEUE_MODE);	
	moveController.setMyToPrimaryLocation(targetLocn);
	moveController.transferType := VESSEL_TYPE_RORO; // NAVAB1 MAY17 1; // 0 = LOLO 1 = RORO  TFS 4435
	moveController.isNonCraneVoyageMove := true; 

	// update the cargo item with the queued move
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	//return the job that was created.
	if moveController.myWorkListEntry &lt;&gt; null then
		_wle := moveController.myWorkListEntry;
		_job := _wle.job.CM_VoyageJob;
	endif;

epilog

	delete moveController;
	delete tiArray;
	delete params;
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_job" type="CM_VoyageJob" usage="output"/>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="output"/>
    </JadeMethod>
    <JadeMethod name="doSimulateWebTruckLoad" id="fe96c40f-d281-418c-8511-446949f13c57">
        <source>doSimulateWebTruckLoad( _truck : CM_Vehicle; _wle : CM_WorkListEntry; _ti : CM_TrackedItem; _complete : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 March 2021	navndl1	Initial creation	TFS 
14 Feb 2024 navhl20 ChangeRequest 62418: EUP | Retrospective Operations - [54177.040] - Road Release
*/

vars

	truckUnLoaderController: CMIF_MobileTruckLoaderUnloader;
	term : CM_Terminal;
	quantity : Integer;
	weight : Decimal [14,4];

begin

	term := self.getTerminal;
	
	if _ti &lt;&gt; null then
		if _ti.isBulkByWeight or _ti.isBulkByVolume then
			weight := _ti.totalWeight;
		else
			quantity := _ti.totalQuantity.max(1);
		endif;
	endif;
	
	if self.opts.includesKey("quantity") then
		quantity := self.opts.int("quantity");
	elseif self.opts.includesKey("weight") then
		weight := self.opts.dec("weight");
	endif;

	create truckUnLoaderController transient;
	truckUnLoaderController.setMyTerminal( term );
	truckUnLoaderController.setTruck( _truck);
	truckUnLoaderController.setMyWle( _wle );
	truckUnLoaderController.setDoNotShowMsgBox(true);// ### TFS CR 60922 TASK 60980 02NOV2023 NAVAB1
	
	if _complete then
		truckUnLoaderController.doTruckComplete( false, true, false ); // shutting down the last "Any Id Any Amount" wle
	else
		truckUnLoaderController.saveChangesLoad( _ti, quantity, weight, null);			//14.02.2024 navhl20 #62418
	endif;

epilog

	delete truckUnLoaderController;

end;</source>
        <Parameter name="_truck" type="CM_Vehicle"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_complete" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSimulateWebTruckUnload" id="e3de43fd-a6db-46bd-bc50-95f43a870cc1">
        <source>doSimulateWebTruckUnload( _truck : CM_Vehicle; _wle : CM_WorkListEntry; _ti : CM_TrackedItem; _location : CM_LocationsController;  _complete : Boolean );
/*
Purpose - 	
Who - NAVAB1
Date - 07NOV2023
ADO - 60922 TASK 60980
14 Feb 2023 navhl20 ChangeRequest 62093: EUP | Retrospective Operations - [54177.030] - Road Receive
*/

vars

	truckUnLoaderController: CMIF_MobileTruckLoaderUnloader;
	term : CM_Terminal;
	quantity : Integer;
	weight : Decimal [14,4];

begin

	term := self.getTerminal;
	
	if _ti &lt;&gt; null then
		if _ti.isBulkByWeight or _ti.isBulkByVolume then
			weight := _ti.totalWeight;
		else
			quantity := _ti.totalQuantity.max(1);
		endif;
	endif;
	
	if self.opts.includesKey("quantity") then
		quantity := self.opts.int("quantity");
	elseif self.opts.includesKey("weight") then
		weight := self.opts.dec("weight");
	endif;

	create truckUnLoaderController transient;
	truckUnLoaderController.setMyTerminal( term );
	truckUnLoaderController.setTruck( _truck);
	truckUnLoaderController.setMyWle( _wle );
	truckUnLoaderController.setDoNotShowMsgBox(true);
	
	if _complete then
		truckUnLoaderController.doTruckComplete( false, true, false ); // shutting down the last "Any Id Any Amount" wle
	else
		truckUnLoaderController.saveChangesUnload( _ti, _location, quantity, weight, null);							//14.02.2023 navhl20 #62093
	endif;

epilog

	delete truckUnLoaderController;

end;</source>
        <Parameter name="_truck" type="CM_Vehicle"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_location" type="CM_LocationsController"/>
        <Parameter name="_complete" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doStwStageCargo" id="cb87353e-e799-4c1d-9724-c31e5ad44e1b">
        <source>doStwStageCargo(	_ti : CM_TrackedItem;
					_reserveDetail : CM_ReserveDetail input;
					_targetLocation : CM_LocationsController );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2017	cnwndl1	Initial creation	TFS 4016

*/

vars

	moveController : CMIF_MoveController;
	quantity : Integer;
	weight : Decimal [16,4];

begin

	create moveController transient;
	moveController.setMyTrackedItem( _ti );
	moveController.setMoveMode( REAL_MODE );
	if _ti.isBulkByQuantity then	
		if quantity &lt;&gt; 0 then
			moveController.setQuantity(quantity);
		elseif _ti.totalQuantity &lt;&gt; 0 then
			moveController.setQuantity(_ti.totalQuantity);
		endif;
	elseif _ti.isBulkByWeight or _ti.isBulkByVolume then
		if weight &lt;&gt; 0 then
			moveController.setWeight(weight);
		elseif _ti.totalWeight &lt;&gt; 0 then
			moveController.setWeight(_ti.totalWeight);
		endif;
	endif;
		
	moveController.setMyToPrimaryLocation( _targetLocation );
		
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxStageCargoForRelease(moveController, _reserveDetail, false, app.myPassport);

epilog

	delete moveController;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail" usage="input"/>
        <Parameter name="_targetLocation" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="doWorkOrderAction" id="f3d82b2b-52b8-41ed-84f8-f4a9d331be91">
        <source>doWorkOrderAction( _woDtl : CM_WorkOrderDtl input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2019	jlgndl1	Initial creation	TFS 44774

*/

vars

	woActionIF : CMIF_WorkOrderAction;

begin

	if _woDtl.isKindOf( CM_WodMove )
	or _woDtl.isKindOf( CM_WodToDo )
	then
		_woDtl.performInstantAction();
	
	else
		create woActionIF transient;		
		woActionIF.myWorkOrderDtl := _woDtl;
		app.myTrxCA.trxCreateWorkOrderAction(woActionIF, app.myPassport);
		
	endif;

epilog

	delete woActionIF;

end;</source>
        <Parameter name="_woDtl" type="CM_WorkOrderDtl" usage="input"/>
    </JadeMethod>
    <JadeMethod name="ediDBLoad" id="fd443699-3229-49c3-98d3-b203c887dc0a">
        <source>ediDBLoad(_ediFile: CM_EDIFile);
//17 December 2008	cnwdw1	
//
vars
	ediAgent: CM_EDIControllerAgent;
	ediData: CM_EDIData;
	ediTi	: CM_EDITrackedItem;
	remarks : String;
	setRemarks	: Boolean;
	createdBy   : String;
	ediFile		: CM_EDIFile;
begin
	create ediAgent transient;
	ediAgent.setTerminal(self.getTerminal());
	
	ediData := _ediFile.ediData;

	ediAgent.verifyEdiData(ediData);

	ediFile := _ediFile;
	
	setRemarks := true;
	if self.opts.includesKey("SetRemarks") then
		setRemarks := self.opts.bool("SetRemarks");
	endif;
	if setRemarks then
		self.updateEDITIRemarks(ediFile);
	endif;
		
	ediAgent.loadEdiDb(null, ediData, false);

	/////self.assertNoTrxErrorsOrWarnings();								// 08/04/2013 cnwmh5
	
epilog
	delete ediAgent;
end;</source>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
    </JadeMethod>
    <JadeMethod name="ediDeleteUserDefinedDefinition" id="0ae5510f-8ff0-4eb6-b03c-fd662e2e3d04">
        <source>ediDeleteUserDefinedDefinition(_userDefinedName: String; _fileType: Integer);
//22 December 2008	cnwdw1	
//
vars
	fileType: CM_EDIFileTypeUser;
begin
	fileType := app.myRoot.allEDIFileTypes[_fileType, _userDefinedName].CM_EDIFileTypeUser;
	if fileType &lt;&gt; null then
		app.myTrxDA.trxDeleteEDIFileTypeUser(fileType, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
end;</source>
        <Parameter name="_userDefinedName" type="String"/>
        <Parameter name="_fileType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="ediImportUserDefinedDefinition" id="a742d6d8-330e-4339-a664-645d0e3383bd">
        <source>ediImportUserDefinedDefinition(_xml: String; _name: String):CM_EDIFileTypeUser;
//22 December 2008	cnwdw1	
//
vars
	fileType, pxyFileType: CM_EDIFileTypeUser;
begin
	ediDeleteUserDefinedDefinition(_name, EDIFileType_UserDefined);
	create pxyFileType transient;
	pxyFileType.importMeXML(_xml);
	app.myTrxCA.trxCreateEDIFileTypeUser(fileType, pxyFileType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return fileType;	// cnwcs5 18/05/2010
epilog	
	delete pxyFileType;
end;</source>
        <Parameter name="_xml" type="String"/>
        <Parameter name="_name" type="String"/>
        <ReturnType type="CM_EDIFileTypeUser"/>
    </JadeMethod>
    <JadeMethod name="ediLoad" id="8688ebd5-1c31-4af2-9803-62a4f59a993b">
        <source>ediLoad(_text: String; _fileType: Integer; _userDefinedName: String): CM_EDIFile;
//17 December 2008	cnwdw1	
//
/*

Date		Who		Reason
25 Feb 2009	cnwkpd1	7.7.1 release - reworked to remove reference to CardSchema method
22 Mar 2012	cnwrs1	Par 29295 allow CSV and XML files to come thru un defined
09 Oct 2014	cnwkpd1	Tidy up temporary files from bin directory

*/

vars
	loadFile: File;
	fileName: String;
	fileType : Integer;
	ediFile	: CM_EDIFile;
begin
	fileType := _fileType;
	if fileType = EDIFileType_Unknown then
		fileName := "EDI_LOAD " &amp; _userDefinedName &amp; ".edi";
	elseif _fileType = EDIFileType_CSV then
		fileName := "EDI_LOAD " &amp; _userDefinedName &amp; ".csv";
		fileType := EDIFileType_Unknown;
	elseif _fileType = EDIFileType_XML then
		fileName := "EDI_LOAD " &amp; _userDefinedName &amp; ".xml";
		fileType := EDIFileType_Unknown;
	else
		fileName := "EDI_LOAD " &amp; _userDefinedName &amp; ".csv";
	endif;
	
	fileName.replaceChar(' ', '_');
	create loadFile transient;
	loadFile.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
	loadFile.openOutput(fileName);
	loadFile.writeString(_text);
	loadFile.close;
	//return self.ediLoadFile(loadFile.fileName, fileType, _userDefinedName);
	ediFile := self.ediLoadFile(loadFile.fileName, fileType, _userDefinedName);				// 08/04/2013 cnwmh5
	/////self.assertNoTrxErrorsOrWarnings();
	
	// Physically delete the temporary file
	on FileException do xHandleFileException(exception, fileName);
	loadFile.purge();
	
	return ediFile;
	
epilog
	delete loadFile;

end;</source>
        <Parameter name="_text" type="String"/>
        <Parameter name="_fileType" type="Integer"/>
        <Parameter name="_userDefinedName" type="String"/>
        <ReturnType type="CM_EDIFile"/>
    </JadeMethod>
    <JadeMethod name="ediLoadFile" id="203922ff-a18d-43f8-8c20-99f58a22f4da">
        <source>ediLoadFile(_fileName: String; _fileType: Integer; _userDefinedName: String): CM_EDIFile protected;
//17 December 2008	cnwdw1	
//
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
//25 Sep 2023	navmd1	TFS 60588 Allow the agent to look up the file type later
vars
	ediAgent: CM_EDIControllerAgent;
	ediFile: CM_EDIFile;
	ediFileType : CM_EDIFileType;
	loadFile: File;
	expectErrors : Boolean;
	lookupFileType : Boolean;
begin

	expectErrors := self.opts.bool("ExpectErrors");
	lookupFileType := self.opts.bool("LookupFileType");
	
	create ediAgent transient;
	ediAgent.setTerminal(self.getTerminal());
	ediAgent.transformFor := self.opts.str("TransformAsCustomer");
	
	create loadFile transient;
	loadFile.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
	loadFile.fileName := _fileName;

	ediFileType := app.myRoot.allEDIFileTypes[_fileType, _userDefinedName];
	if not lookupFileType and ediFileType = null then
		ediFileType := app.myRoot.allEDIFileTypeUsersByName[_userDefinedName];
	endif;
	ediFile := ediAgent.loadAndProcessFileForTerminal(loadFile,  ediFileType, app.myPassport);
	if not expectErrors then
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
	return ediFile;
epilog
	delete ediAgent;
	delete loadFile;
end;</source>
        <access>protected</access>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_fileType" type="Integer"/>
        <Parameter name="_userDefinedName" type="String"/>
        <ReturnType type="CM_EDIFile"/>
    </JadeMethod>
    <JadeMethod name="ediLoadFileName" id="22f24796-e26b-42c7-ab39-8fb2b5720032">
        <source>ediLoadFileName(_text: String; _fileType: Integer; _userDefinedName, _fileName: String): CM_EDIFile;
//17 December 2008	cnwdw1	
//
/*

Date		Who		Reason
25 Feb 2009	cnwkpd1	7.7.1 release - reworked to remove reference to CardSchema method
22 Mar 2012	cnwrs1	Par 29295 allow CSV and XML files to come thru un defined
09 Oct 2014	cnwkpd1	Tidy up temporary files from bin directory
25 Sep 2023 navmd1	TFS 60588 Allow the agent to look up the file type later
04 Dec 2024	navcs2	MTN-33047 EUP - NTO-1000 - EUP - Additional Data Fields in EDI Operations

*/

vars
	loadFile: File;
	fileName: String;
	fileType : Integer;
	ediFile	: CM_EDIFile;
	lookupFileType : Boolean;
begin
	lookupFileType := self.opts.bool("LookupFileType");
	fileType := _fileType;
	
	if lookupFileType then
		fileName := _fileName;
	else
		if fileType = EDIFileType_Unknown then
			fileName := "EDI_LOAD " &amp; _fileName &amp; ".edi";
		elseif _fileType = EDIFileType_CSV then
			fileName := "EDI_LOAD " &amp; _fileName &amp; ".csv";
			fileType := EDIFileType_Unknown;
		elseif _fileType = EDIFileType_XML then
			fileName := "EDI_LOAD " &amp; _fileName &amp; ".xml";
			fileType := EDIFileType_Unknown;
		elseif _fileType = EDIFileType_CallOff then				//04 Dec 2024	navcs2	MTN-33047
			fileName := "EDI_LOAD " &amp; _fileName &amp; ".json";		//04 Dec 2024	navcs2	MTN-33047
			fileType := EDIFileType_CallOff;					//04 Dec 2024	navcs2	MTN-33047
		else
			fileName := "EDI_LOAD " &amp; _fileName &amp; ".csv";
		endif;
	endif;
	
	fileName.replaceChar(' ', '_');
	create loadFile transient;
	loadFile.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version
	loadFile.openOutput(fileName);
	loadFile.writeString(_text);
	loadFile.close;
	//return self.ediLoadFile(loadFile.fileName, fileType, _userDefinedName);
	ediFile := self.ediLoadFile(loadFile.fileName, fileType, _userDefinedName);				// 08/04/2013 cnwmh5
	/////self.assertNoTrxErrorsOrWarnings();
	
	// Physically delete the temporary file
	on FileException do xHandleFileException(exception, fileName);
	loadFile.purge();
	
	return ediFile;
	
epilog
	delete loadFile;

end;</source>
        <Parameter name="_text" type="String"/>
        <Parameter name="_fileType" type="Integer"/>
        <Parameter name="_userDefinedName" type="String"/>
        <Parameter name="_fileName" type="String"/>
        <ReturnType type="CM_EDIFile"/>
    </JadeMethod>
    <JadeMethod name="ediLoadVerifyDBLoadActualBasic" id="8c046785-868a-4771-9e43-238eed424a9e">
        <source>ediLoadVerifyDBLoadActualBasic(_ediText, _userDefinedName, _fileName: String; _ediFileType: Integer; _verify: Boolean; _dbLoad: Boolean; _makeActual: Boolean; _makeActualWithMerge: Boolean; _ediFile: CM_EDIFile): CM_EDIFile protected;
/*

Purpose:		Load edi file, verify it, db load it and or make actual	
				Currently doesn't handle assertIsOneOf

Date			Who		Reason
13/02/2013		cnwmh5	Initial creation

*/

vars
	
	ediFile 			: CM_EDIFile;
	ediControllerAgent 	: CM_EDIControllerAgent;
	
	tempStr				: String;
	
begin

	//  now load the extracted details into voyage3
	//create ediControllerAgent transient;
	//ediControllerAgent.setTerminal( self.getTerminal );	// cnwrl1 24/05/2010 PAR 24276

	// maybe doing these things one a time and don't need to load the edi file again
	if _ediFile &lt;&gt; null then
		ediFile := _ediFile;
	endif;	
	
	if ediFile = null then
		ediFile := self.ediLoadFileName(_ediText, _ediFileType, _userDefinedName, _fileName);		
		self.assertNotNull(ediFile);
	endif;
	
	if _verify then
		self.ediVerify(ediFile);
		tempStr	:= 'Verify failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
		self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, tempStr);
	endif;
	
	if _dbLoad then
		self.ediDBLoad(ediFile);
		tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
		self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, tempStr);
	endif;

	if _makeActual then
		self.ediMakeActual(ediFile);
		tempStr	:= 'Make Actual failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
		self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_MADE_ACTUAL, tempStr);
	endif;
	
	if _makeActualWithMerge then
		self.ediMakeActualWithMerge(ediFile);
		tempStr	:= 'Make Actual failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
		self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_MADE_ACTUAL, tempStr);
	endif;
	
	/////self.assertNoTrxErrorsOrWarnings();					// 08/04/2013 cnwmh5	
	
	return ediFile;

epilog

	//delete ediControllerAgent;

end;</source>
        <access>protected</access>
        <Parameter name="_ediText" type="String"/>
        <Parameter name="_userDefinedName" type="String"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_ediFileType" type="Integer"/>
        <Parameter name="_verify" type="Boolean"/>
        <Parameter name="_dbLoad" type="Boolean"/>
        <Parameter name="_makeActual" type="Boolean"/>
        <Parameter name="_makeActualWithMerge" type="Boolean"/>
        <Parameter name="_ediFile" type="CM_EDIFile"/>
        <ReturnType type="CM_EDIFile"/>
