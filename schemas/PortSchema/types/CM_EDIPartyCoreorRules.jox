<Class name="CM_EDIPartyCoreorRules" id="db5b61a3-6228-4200-8608-906a7141f8ce">
    <superclass name="CM_EDIPartyRules"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <PrimAttribute name="ignoreExpiryDates" id="28c18069-aa4e-45b1-b5a1-836533a56ec5">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="create" id="7ae65915-9496-4496-a3ef-ba89576c9361">
        <updating/>
        <source>create() updating;
//
// 21 Aug 2017	jlgrs1	TFS 6564 add Coparn and Coreor RFF and NAD translation
//
vars
	type	:CM_EDIFileType;
begin
	// set file type
	type := app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileType_Coreor, null);
	
	if type = null or 
	   type.type &lt;&gt; EDIFileType_Coreor then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Coreor file type missing');
	endif;
	
	self.myEDIFileType	:= type;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="47d14012-44fe-46e0-b3d6-bd57018f134c">
        <updating/>
        <source>setForUpdate(_proxy: CM_EDIPartyCoreorRules) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 August 2018	jlggb1	Initial creation TFS 39344

*/

vars

begin
	inheritMethod(_proxy);
	self.ignoreExpiryDates := _proxy.ignoreExpiryDates;

epilog

end;</source>
        <Parameter name="_proxy" type="CM_EDIPartyCoreorRules"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="1e1de09a-ec29-471b-9c60-ee95eabd14dc">
        <updating/>
        <source>setProxy(_ignoreExpiryDates: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 August 2018	jlggb1	Initial creation TFS 39344

*/

vars

begin
	self.ignoreExpiryDates := _ignoreExpiryDates;

epilog

end;</source>
        <Parameter name="_ignoreExpiryDates" type="Boolean"/>
    </JadeMethod>
</Class>
