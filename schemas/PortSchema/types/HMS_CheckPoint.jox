    <JadeMethod name="setProxy" id="5deba2ac-0f0e-4535-b2a3-df56da16933d">
        <updating/>
        <source>setProxy(_root 		: CM_Root; 
		_harbour 	: HMS_Harbour;
		_checkpointType : Integer;
		_tidalModel : HMS_TidalModelDefinition;
		_hiLoTideReference : String;
		_hiLoRelativeTimeTo : Integer;
		_hiLoRelativeTimeFrom : Integer;
		_hiLoTideReference2 : String;
		_hiLoRelativeTimeTo2 : Integer;
		_hiLoRelativeTimeFrom2 : Integer;
		_tideRangeReference : String;
		_tideRangeAmount : Integer;
		_tideRangeReference2 : String;
		_tideRangeAmount2 : Integer;
		_gapTimeDifference : Integer;
		_shipsDepartTimings : String;
		_timeGapCheckArrivals : Boolean;
		_timeGapCheckDepartures : Boolean;
		_timeGapToCheckRegion : HMS_HarbourRegion;
		_tideState : Integer;
		_jadeCode, _userCode : String) updating;
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.raiseExceptionIfNotTransient(method);
	
	self.myRoot			:=	_root;
	self.myHarbour		:=	_harbour;
	self.checkPointType :=	_checkpointType;
	self.myTidalModel	:=	_tidalModel;
	self.myTimeGapToCheckRegion := _timeGapToCheckRegion;

	//th2 see HMS_HarbourRegion.myTidalModel references - now superseeds this attribute
	//self.rvTideLocation := _rvTideLocn;
	
	self.hiLoTideReference		:=	_hiLoTideReference;
	self.hiLoRelativeTimeTo		:=	_hiLoRelativeTimeTo;
	self.hiLoRelativeTimeFrom	:=	_hiLoRelativeTimeFrom;
	self.hiLoTideReference2		:=	_hiLoTideReference2;
	self.hiLoRelativeTimeTo2	:=	_hiLoRelativeTimeTo2;
	self.hiLoRelativeTimeFrom2	:=	_hiLoRelativeTimeFrom2;
	self.tideRangeReference		:=	_tideRangeReference;
	self.tideRangeAmount		:=	_tideRangeAmount;
	self.tideRangeReference2	:=	_tideRangeReference2;
	self.tideRangeAmount2		:=	_tideRangeAmount2;
	self.gapTimeDifference		:=	_gapTimeDifference;	
	self.gapCheckArrivals 		:= _timeGapCheckArrivals; //epr par 16514 16/4/08
	self.gapCheckDepartures 	:= _timeGapCheckDepartures;//epr par 16514 16/4/08
	self.shipDepartTimings		:=	_shipsDepartTimings;
	self.tideState				:= _tideState; //epr par 16884 5/6/08
	if self.myHookCode &lt;&gt; null then
		self.myHookCode.setForProxy(self.code, app.myRoot.allHookTypes[HookType_HMS_CheckPoint]);
		self.myHookCode.setJadeCodeForProxy(_jadeCode, _userCode);
	else
		create self.myHookCode transient;
		self.myHookCode.setForProxy(self.code, app.myRoot.allHookTypes[HookType_HMS_CheckPoint]);
		self.myHookCode.createProxyHookLinkForParent(HookType_HMS_CheckPoint, self);
		self.myHookCode.setJadeCodeForProxy(_jadeCode, _userCode);
	endif;
end;</source>
        <Parameter name="_root" type="CM_Root"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_checkpointType" type="Integer"/>
        <Parameter name="_tidalModel" type="HMS_TidalModelDefinition"/>
        <Parameter name="_hiLoTideReference" type="String"/>
        <Parameter name="_hiLoRelativeTimeTo" type="Integer"/>
        <Parameter name="_hiLoRelativeTimeFrom" type="Integer"/>
        <Parameter name="_hiLoTideReference2" type="String"/>
        <Parameter name="_hiLoRelativeTimeTo2" type="Integer"/>
        <Parameter name="_hiLoRelativeTimeFrom2" type="Integer"/>
        <Parameter name="_tideRangeReference" type="String"/>
        <Parameter name="_tideRangeAmount" type="Integer"/>
        <Parameter name="_tideRangeReference2" type="String"/>
        <Parameter name="_tideRangeAmount2" type="Integer"/>
        <Parameter name="_gapTimeDifference" type="Integer"/>
        <Parameter name="_shipsDepartTimings" type="String"/>
        <Parameter name="_timeGapCheckArrivals" type="Boolean"/>
        <Parameter name="_timeGapCheckDepartures" type="Boolean"/>
        <Parameter name="_timeGapToCheckRegion" type="HMS_HarbourRegion"/>
        <Parameter name="_tideState" type="Integer"/>
        <Parameter name="_jadeCode" type="String"/>
        <Parameter name="_userCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="f047e7bc-1b58-44c3-a6f2-0c78557b186d">
        <source>validateMe(_passport: CM_Passport input);
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
/* Changes

Date		Name	TFS#		Description
============================================================================
22/07/2019	jlgka1 	TFS 45620	JMT - Refactor remove remaining  Voyage Commodity  Planning
14/06/2022  navds20     TFS 53760 DuplicateItem not Translatable
============================================================================*/
vars
	checkPointObj	: HMS_CheckPoint;
	leavingArray	: IntegerArray;
	
begin
	inheritMethod(_passport);
	
	if self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Code', ETRow_Code, null);
		app.raiseCMException(Input_required_field_code, ETRow_Code, null); // cnwdb2	PAR 35364
	endif;
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Description', ETRow_Description,  null);
		app.raiseCMException(Input_required_field_desc, ETRow_Description,  null); // cnwdb2	PAR 35364
	endif;

	/*Lorcan no validation on harbour now
	if self.myHarbour = null then
		app.raiseCMException1(REQUIRED_FIELD, 'Harbour', ETRow_MyHarbour,  null);
	endif;
	if self.myHarbour &lt;&gt; null and self.myHarbour.tidalModelType = app.getErrorString(HMSTidalModelType_Otago) then
		if self.rvTideLocation &lt; 1 then
			app.raiseCMException1(REQUIRED_FIELD, 'Tide Model ID', ETRow_RvTideLocation, null);
		endif;
	endif;
	*/
	if self.checkPointType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Tidal Type', ETRow_CheckPointType,  null);
		app.raiseCMException(Input_required_field_tidalType, ETRow_CheckPointType,  null); // cnwdb2	PAR 35364
	endif;	
	
	//jlgka1 TFS 45620 --&gt;
	/*if self.checkPointType &lt;&gt; HMS_ChkPointType_TideRange and  
	   //self.checkPointType &lt;&gt; HMS_ChkPointType_ShipsDepart and // jlgka1 TFS 45620
	   self.checkPointType &lt;&gt; HMS_ChkPointType_TimeGap and
	   self.checkPointType &lt;&gt; HMS_ChkPointType_UserHookCode and
	   self.checkPointType &lt;&gt; HMS_ChkPointType_TideState then
		if self.myTidalModel = null then
			//app.raiseCMWarning1(Full_Replacement_Message, 'Warning: You have not selected a tidal model for this tidal type.', ETRow_TidalModel, null, self); //- cnwmd1, Par 20524
			app.raiseCMWarning(Warni_have_selec_tidal_model_t, ETRow_TidalModel, null, self);
		elseif self.checkPointType &lt;&gt; self.myTidalModel.dataType then
			//app.raiseCMException1(Full_Replacement_Message, 'Error: The tidal type and the tidal model type selected do not match.', ETRow_TidalModel, null);	//- cnwmd1, Par 20524
			app.raiseCMException(Error_tidal_type_tidal_model_t, ETRow_TidalModel, null);	
		endif;	
	endif;*/
	//jlgka1 TFS 45620 &lt;--
	
	if _passport.hasErrors then
		return;
	endif;

	checkPointObj	:=	self.myRoot.allHMSCheckpoints.getAtKey(self.code);
	
	if checkPointObj &lt;&gt; null then
		if self.isTransient and checkPointObj &lt;&gt; self.pxyGetRealObject() then
			//app.raiseCMException2(DuplicateItem, 'CheckPoint', self.code, ETRow_Code, null); //14.06.2022 navds20 53760
			// CheckPoint already exists for %1 : Checkpoint_already_exists
			app.raiseCMException1(Checkpoint_already_exists, self.code, ETRow_Code, null); //14.06.2022 navds20 53760
		endif;
	endif;
	
	if self.checkPointType = HMS_ChkPointType_HiLo then
		if self.hiLoTideReference = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Relative To Which Tide', ETRow_RelativeToTide,  null);
			app.raiseCMException(Input_required_field_relToTide, ETRow_RelativeToTide,  null); // cnwdb2	PAR 35364
		endif;
		
		if self.hiLoRelativeTimeFrom &gt;= self.hiLoRelativeTimeTo then
			app.raiseCMException1(ERR_RESTRIC_TIME_MISMATCH, 'Relative Times', ETRow_RelativeToTide, null);	
		endif;
		
		if self.hiLoTideReference2 &lt;&gt; null then
			if self.hiLoRelativeTimeFrom2 &gt;= self.hiLoRelativeTimeTo2 then
				app.raiseCMException1(ERR_RESTRIC_TIME_MISMATCH, '2nd Relative Times', ETRow_RelativeToTide2, null);	
			endif;
		endif;
	endif;
	//jlgka1 TFS 45620 --&gt;
	/*if self.checkPointType = HMS_ChkPointType_TideRange then
		if self.tideRangeReference = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Tide Range', ETRow_TideRangeReference,  null);
			app.raiseCMException(Input_required_field_tideRange, ETRow_TideRangeReference,  null); // cnwdb2	PAR 35364
		else
			if self.tideRangeAmount = 0 then
//				app.raiseCMException1(REQUIRED_FIELD, 'Tide Range Amount', ETRow_TideRangeAmount,  null);
				app.raiseCMException(Input_required_field_tdeRngAmt, ETRow_TideRangeAmount,  null); // cnwdb2	PAR 35364
			endif;
		endif;
		
		if self.tideRangeReference2 &lt;&gt; null then
			if self.tideRangeAmount2 = 0 then
			//	app.raiseCMException1(REQUIRED_FIELD, '2nd Tide Range Amount', ETRow_TideRangeAmount2,  null);
				app.raiseCMException(Input_required_field_2ndTdeRng, ETRow_TideRangeAmount2,  null); // cnwdb2	PAR 35364
			endif;
		endif;
	endif;
	
	if self.checkPointType = HMS_ChkPointType_ShipsDepart then
		if self.hiLoTideReference = null then
//			app.raiseCMException1(REQUIRED_FIELD, 'Relative To Which Tide', ETRow_RelativeToTide,  null);
			app.raiseCMException(Input_required_field_relToWTde, ETRow_RelativeToTide,  null); // cnwdb2	PAR 35364
		endif;
		create leavingArray transient;
		if not self.getShipsDepartTime (2, leavingArray) then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Ships Depart Timings string invalid', ETRow_ShipsDepartTimings,  null);
			app.raiseCMException(Input_required_field_shpDepTim, ETRow_ShipsDepartTimings,  null); // cnwdb2	PAR 35364
		endif;
	endif;*/
	//jlgka1 TFS 45620 --&gt;
	if self.checkPointType = HMS_ChkPointType_TimeGap then
		if self.myTimeGapToCheckRegion = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Region to check time gap at', ETRow_MyTimeGapToCheckRegion,  null);
			app.raiseCMException(Input_required_field_regCTG, ETRow_MyTimeGapToCheckRegion,  null); // cnwdb2	PAR 35364
		endif;
		if self.gapTimeDifference &lt; 0 then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Time Between Movements', ETRow_GapBetweenMovements,  null);
			app.raiseCMException(Input_required_field_timBetMov, ETRow_GapBetweenMovements,  null); // cnwdb2	PAR 35364
		endif;
	endif;
	
epilog
	delete leavingArray;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
