    <JadeMethod name="displayData_ContainerAttribute" id="025fad3a-981d-4d4e-8594-850f9b41e119">
        <source>displayData_ContainerAttribute(_table :Table input; _keyRow :Integer; _displayGrandTotals :Boolean; _attribute :Attribute; _heading, _totalHeading :String) protected;
/*
Date		Who		Reason
03 Sep 2012	cnwcs5	Initial creation - par 30290
03/09/2012	cnwcs5	par 30290
*/
constants
	NotIncluded	 	= 0;
	Included		= 1;
	IncludeOther 	= 2;
vars
	row, start, totalRow	:Integer;
	colCargoType, colTotal, 
	colRow1, colRow2		:Integer;
	include30, include45, 
	include53, int			:Integer;		// par 30290
	includeOther			:Boolean;		// par 30290
begin
	// store property values in local variables - small optimization
	colCargoType	:= self.colour_CargoType;
	colTotal		:= self.colour_Total;
	colRow1			:= self.colour_Row1;
	colRow2			:= self.colour_Row2;
	include30		:= self.is30Included;										// par 30290
	include45		:= self.is45Included;										// par 30290
	include53		:= self.is53Included;										// par 30290
	includeOther	:= (include30 = IncludeOther) or (include45 = IncludeOther) or (include53 = IncludeOther);	// par 30290
	
	start 	:= _table.rows;
	row 	:= _table.addItem (_heading);		_table.accessRow(row).backColor	:= colCargoType;	_table.accessCell (row,1).fontBold := true;
	row 	:= _table.addItem (app.getErrorString(TwentyFoot));		_table.accessRow(row).backColor	:= colRow1;			_table.accessCell (row,1).alignment := Table.Alignment_Right;
	row 	:= _table.addItem (app.getErrorString(FortyFoot));		_table.accessRow(row).backColor	:= colRow2;			_table.accessCell (row,1).alignment := Table.Alignment_Right;
	
	if include30 = Included then	// par 30290
		row := _table.addItem (app.getErrorString(ThirtyFoot));		_table.accessRow(row).backColor	:= colRow1;			_table.accessCell (row,1).alignment := Table.Alignment_Right;
	endif;
	
	if include45 = Included then	// par 30290
		row := _table.addItem (app.getErrorString(FortyFiveFoot));	_table.accessRow(row).backColor	:= colRow2;			_table.accessCell (row,1).alignment := Table.Alignment_Right;
	endif;
	
	if include53 = Included then	// par 30290
		row := _table.addItem (app.getErrorString(FiftyThreeFoot));	_table.accessRow(row).backColor	:= colRow1;			_table.accessCell (row,1).alignment := Table.Alignment_Right;
	endif;
	
	if includeOther then	// par 30290
		row := _table.addItem (app.getErrorString(Other));			_table.accessRow(row).backColor	:= colRow1;			_table.accessCell (row,1).alignment := Table.Alignment_Right;
	endif;
	
	totalRow := _table.addItem (_totalHeading);						_table.accessRow(totalRow).backColor := colTotal; 	_table.accessCell (totalRow, 1).fontBold := true;
			
	self.displayRow_Container (_table, start+2, totalRow, 20, _attribute, _keyRow,  _displayGrandTotals);
	self.displayRow_Container (_table, start+3, totalRow, 40, _attribute, _keyRow,  _displayGrandTotals);
	
	int := 3;				// par 30290
	
	if include30 = Included then	// par 30290
		int := int + 1;
		
		self.displayRow_Container (_table, start+int, totalRow, 30, _attribute, _keyRow,  _displayGrandTotals);
	endif;
	
	if include45 = Included then	// par 30290
		int := int + 1;
		
		self.displayRow_Container (_table, start+int, totalRow, 45, _attribute, _keyRow,  _displayGrandTotals);
	endif;
	
	if include53 = Included then	// par 30290
		int := int + 1;
		
		self.displayRow_Container (_table, start+int, totalRow, 53, _attribute, _keyRow,  _displayGrandTotals);
	endif;
	
	if includeOther then	// par 30290
		int := int + 1;
		
		self.displayRow_Container (_table, start+int, totalRow, Max_Integer, _attribute, _keyRow,  _displayGrandTotals);
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_keyRow" type="Integer"/>
        <Parameter name="_displayGrandTotals" type="Boolean"/>
        <Parameter name="_attribute" type="Attribute"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_totalHeading" type="String"/>
    </JadeMethod>
    <JadeMethod name="displayData_Containers" id="4a6cd00f-aa65-49c6-84a4-8ea7b6231588">
        <source>displayData_Containers(_table :Table input; _keyRow :Integer; _contCount, _contTEU, _displayGrandTotals :Boolean) protected;
/*
Date		Who		Reason
08 Aug 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
03/09/2012	cnwcs5	par 30290 - 
*/
vars
	
begin
	if _contTEU then
		// do container TEU first
		self.displayData_ContainerAttribute (_table, _keyRow, _displayGrandTotals, CM_KPIVoyageMoveDtl_Container::numTEU, app.getErrorString (CONT_TEU), app.getErrorString (CONT_TEU_TOTAL) );
	endif;
		
	if _contCount then
		// do container counts
		self.displayData_ContainerAttribute (_table, _keyRow, _displayGrandTotals, CM_KPIVoyageMoveDtl_Container::numTIs, app.getErrorString (CONT_COUNT), app.getErrorString (CONT_COUNT_TOTAL) );
	endif;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_keyRow" type="Integer"/>
        <Parameter name="_contCount" type="Boolean"/>
        <Parameter name="_contTEU" type="Boolean"/>
        <Parameter name="_displayGrandTotals" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayData_GC" id="0d60f45d-1b28-4137-a723-876436bfe750">
        <source>displayData_GC(_table :Table input; _keyRow :Integer; _gcCount, _gcArea, _gcLM, _gcQty, _gcVolume, _gcWeight, _displayGrandTotals :Boolean;
				_cargoTypes :Collection) protected;
/*
Date		Who		Reason
08 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	row, start, totalRow	:Integer;
	coll					:CM_CargoTypeSet;
	cargoType				:CM_CargoType;
	colCargoType, colTotal, 
	colRow1, colRow2		:Integer;
	kpi						:CM_KPIVoyageTotals;
begin
	// store property values in local variables - small optimization
	colCargoType	:= self.colour_CargoType;
	colTotal		:= self.colour_Total;
	colRow1			:= self.colour_Row1;
	colRow2			:= self.colour_Row2;
	
	create coll transient;
	
	if _cargoTypes &lt;&gt; null then
		_cargoTypes.copy (coll);
	else
		kpi := self.myVoyage.getKPI.CM_KPIVoyageTotals;
		
		if kpi &lt;&gt; null then
			kpi.getAllCargoTypes (coll);
		endif;
	endif;
	// do General Cargo counts
	if _gcCount then
		self.displayData_GCAttribute (_table, coll, CM_KPIVoyageMoveDtl::numTIs, CargoType_Count, _keyRow, _displayGrandTotals, app.getErrorString (GC_COUNT), app.getErrorString (GC_COUNT_TOTAL),
									colCargoType, colTotal, colRow1, colRow2);
	endif;

	// do General Cargo Linear Metres
	if _gcLM then
		self.displayData_GCAttribute (_table, coll, CM_KPIVoyageMoveDtl_GC::linearMetres, CargoType_LM, _keyRow, _displayGrandTotals, app.getErrorString (GC_LM), app.getErrorString (GC_LM_TOTAL),
									colCargoType, colTotal, colRow1, colRow2);
	endif;
	
	// do General Cargo Qty
	if _gcQty then
		self.displayData_GCAttribute (_table, coll, CM_KPIVoyageMoveDtl_GC::quantity, CargoType_Quantity, _keyRow, _displayGrandTotals, app.getErrorString (GC_QTY), app.getErrorString (GC_QTY_TOTAL),
									colCargoType, colTotal, colRow1, colRow2);
	endif;
	
	// do General Cargo Weight
	if _gcWeight then
		self.displayData_GCAttribute (_table, coll, CM_KPIVoyageMoveDtl_GC::totalWeight, CargoType_Weight, _keyRow, _displayGrandTotals, app.getErrorString (GC_WEIGHT), app.getErrorString (GC_WEIGHT_TOTAL),
									colCargoType, colTotal, colRow1, colRow2);
	endif;

	// do General Cargo Area
	if _gcArea then
		self.displayData_GCAttribute (_table, coll, CM_KPIVoyageMoveDtl_GC::area, CargoType_Area, _keyRow, _displayGrandTotals, app.getErrorString (GC_AREA), app.getErrorString (GC_AREA_TOTAL),
									colCargoType, colTotal, colRow1, colRow2);
	endif;
	
	// do General Cargo Volume
	if _gcVolume then
		self.displayData_GCAttribute (_table, coll, CM_KPIVoyageMoveDtl_GC::volume, CargoType_Volume, _keyRow, _displayGrandTotals, app.getErrorString (GC_VOLUME), app.getErrorString (GC_VOLUME_TOTAL),
									colCargoType, colTotal, colRow1, colRow2);
	endif;
epilog
	delete coll;
end;</source>
        <access>protected</access>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_keyRow" type="Integer"/>
        <Parameter name="_gcCount" type="Boolean"/>
        <Parameter name="_gcArea" type="Boolean"/>
        <Parameter name="_gcLM" type="Boolean"/>
        <Parameter name="_gcQty" type="Boolean"/>
        <Parameter name="_gcVolume" type="Boolean"/>
        <Parameter name="_gcWeight" type="Boolean"/>
        <Parameter name="_displayGrandTotals" type="Boolean"/>
        <Parameter name="_cargoTypes" type="Collection"/>
    </JadeMethod>
    <JadeMethod name="displayData_GCAttribute" id="406d8496-836f-4ad9-89f5-d5d771ecc3bc">
        <source>displayData_GCAttribute(_table :Table input; _coll :CM_CargoTypeSet; _attribute :Attribute; _errorNum :Integer;
						_keyRow :Integer;_displayGrandTotals :Boolean;
						_heading, _totalHeading :String; 
						_colCargoType, _colTotal, _colRow1, _colRow2 :Integer) protected;
/*
Date		Who		Reason
24/08/2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
29/01/2015	cnwdap1	PAR #35397 CCM SSFW 1394 Voyage Rationalisation - include a "Containers Total" line in the Total Count section
*/
vars
	start, totalRow	:Integer;
	cargoType		:CM_CargoType;
	containerTotals	:StringArray;			// PAR #35397
	totalString		:String;				// PAR #35397
	str				:String;				// PAR #35397
	column, total	:Integer;				// PAR #35397
	showCont		: Boolean;				// PAR #35397
	contType		: CM_CargoType;			// PAR #35397
begin
	// do General Cargo counts
	start 		:= _table.addItem (_heading);			_table.accessRow(start).backColor		:= _colCargoType;	_table.accessCell (start, 1).fontBold := true;
	totalRow 	:= _table.addItem (_totalHeading);		_table.accessRow(totalRow).backColor	:= _colTotal;	_table.accessCell (totalRow, 1).fontBold := true;
	
	contType := app.myRoot.allCargoTypesById[TI_CargoType_Container];						// PAR #35397
	showCont := _coll.includes(contType);													// PAR #35397
	if _attribute = CM_KPIVoyageMoveDtl::numTIs and showCont then							// PAR #35397
		create containerTotals transient;													// PAR #35397
		self.getContainerTotals(_table, start-1, containerTotals);							// PAR #35397
		totalString := app.getErrorString(CONT_COUNT);										// PAR #35397
		foreach str in containerTotals do													// PAR #35397
			totalString := totalString &amp; str &amp; Tab;											// PAR #35397
		endforeach;																			// PAR #35397
		_table.addItemAt(totalString, start+1);												// PAR #35397
		_table.accessRow(start+1).backColor := _colRow1;									// PAR #35397
		_table.accessCell(start+1, 1).alignment := Table.Alignment_Right;					// PAR #35397
		totalRow := totalRow + 1;															// PAR #35397
	endif;																					// PAR #35397

	//foreach cargoType in _coll do															// PAR #35397
	foreach cargoType in _coll where cargoType &lt;&gt; contType do								// PAR #35397
		// insert line for cargo type 
		_table.addItemAt (app.getErrorString1 (_errorNum, cargoType.description), totalRow);
		_table.accessCell (totalRow,1).alignment 	:= Table.Alignment_Right;
		_table.accessRow (totalRow).itemObject	:= cargoType;
		
		if totalRow.isOdd then
			_table.accessRow (totalRow).backColor	:= _colRow1;
		else
			_table.accessRow (totalRow).backColor	:= _colRow2;
		endif;
		
		// total row has moved now !
		totalRow	:= totalRow + 1;
		// display the counts for this cargo type
		self.displayRow_GC (_table, totalRow-1, totalRow, cargoType, _attribute, _keyRow, _displayGrandTotals);
	endforeach;

	// now include container counts in totals row											// PAR #35397
	if _attribute = CM_KPIVoyageMoveDtl::numTIs and showCont then							// PAR #35397
		foreach column in _table.fixedColumns+1 to _table.columns do						// PAR #35397
			str := containerTotals[column];													// PAR #35397
			if str &lt;&gt; null and str.isInteger then											// PAR #35397
				total := _table.accessCell(totalRow, column).text.Integer + str.Integer;	// PAR #35397
				_table.accessCell(totalRow, column).text := total.asStringJMT;				// PAR #35397
			endif;																			// PAR #35397
		endforeach;																			// PAR #35397
	endif;																					// PAR #35397
epilog
	delete containerTotals;																	// PAR #35397
end;</source>
        <access>protected</access>
