    <JadeMethod name="createBOLEntry" id="085b977f-6416-44e8-bd3e-a31e92f13cea">
        <source>createBOLEntry(_bolEntryHdr : CM_RemoteBOLEntryHdr input; _bolEntryObj:CnEcXmlStructureInstance);

// Created by cnwdvb1 on 02 August 2007

vars
	detailObj	: CM_RemoteBOLEntryDtl;
	strArray	: StringArray;
	sequenceObj	: CnEcXmlStructureInstance;
	ticketObj	: CnEcXmlStructureInstance;
	
begin
	create detailObj transient;
	
	sequenceObj	:=	_bolEntryObj.findStructure(XML_TICKETSEQUENCE);
	
	if sequenceObj &lt;&gt; null and sequenceObj.isKindOf(CnEcXmlGroupInstance) then
		create strArray transient;
		
		foreach ticketObj in sequenceObj.CnEcXmlGroupInstance.allFields do
			strArray.add(ticketObj.tagData);
		endforeach;
	endif;
	
	detailObj.setProxyForBOLEntry(	self.getTagDataFromXML(XML_ACTIVITY, _bolEntryObj),
									self.getTagDataFromXML(XML_AUTOMATCH, _bolEntryObj),
									self.getTagDataFromXML(XML_BACKLOAD, _bolEntryObj),
									self.getTagDataFromXML(XML_CARRIERID, _bolEntryObj),
									self.getTagDataFromXML(XML_CHHSUPPLIER, _bolEntryObj),
									self.getTagDataFromXML(XML_COMPARTMENT, _bolEntryObj),
									self.getTagDataFromXML(XML_EXPORTER, _bolEntryObj),
									self.getTagDataFromXML(XML_CUSTOMER, _bolEntryObj),
									self.getTagDataFromXML(XML_DRIVERID, _bolEntryObj),
									self.getTagDataFromXML(XML_FELLINGDATE, _bolEntryObj),
									self.getTagDataFromXML(XML_FOREST, _bolEntryObj),
									self.getTagDataFromXML(XML_GANG, _bolEntryObj),
									self.getTagDataFromXML(XML_GRADE, _bolEntryObj),
									self.getTagDataFromXML(XML_GROSSWEIGHT, _bolEntryObj),
									self.getTagDataFromXML(XML_NIGHTSHIFT, _bolEntryObj),
									self.getTagDataFromXML(XML_JASSCALED, _bolEntryObj),
									self.getTagDataFromXML(XML_LENGTH, _bolEntryObj),
									self.getTagDataFromXML(XML_LOADERNO, _bolEntryObj),
									self.getTagDataFromXML(XML_LOADINGCONT, _bolEntryObj),
									self.getTagDataFromXML(XML_LOGTYPE, _bolEntryObj),
									self.getTagDataFromXML(XML_LOGGINGCONT, _bolEntryObj),
									self.getTagDataFromXML(XML_LOGGINGOP, _bolEntryObj),
									self.getTagDataFromXML(XML_LOGGINGORG, _bolEntryObj),
									self.getTagDataFromXML(XML_NETWEIGHT, _bolEntryObj),
									self.getTagDataFromXML(XML_NOITEMS, _bolEntryObj),
									self.getTagDataFromXML(XML_BOLNO, _bolEntryObj),
									self.getTagDataFromXML(XML_NOLIFTS, _bolEntryObj),
									self.getTagDataFromXML(XML_SUPPLIER, _bolEntryObj),
									self.getTagDataFromXML(XML_OPID, _bolEntryObj),
									self.getTagDataFromXML(XML_PERCENTAGESCALED, _bolEntryObj),
									self.getTagDataFromXML(XML_PICKUPPOINT, _bolEntryObj),
									self.getTagDataFromXML(XML_REMARKS, _bolEntryObj),
									self.getTagDataFromXML(XML_SCALERINITIALS, _bolEntryObj),
									self.getTagDataFromXML(XML_SPECIES, _bolEntryObj),
									self.getTagDataFromXML(XML_STAND, _bolEntryObj),
									self.getTagDataFromXML(XML_FSC, _bolEntryObj),		// CCSM XML 1105, PAR 21535 Nov 2009
									self.getTagDataFromXML(XML_TAREWEIGHT, _bolEntryObj),
									self.getTagDataFromXML(XML_HUNDREDTICKETED, _bolEntryObj),
									self.getTagDataFromXML(XML_TRAILERNO, _bolEntryObj),
									self.getTagDataFromXML(XML_TREATMENT, _bolEntryObj),
									self.getTagDataFromXML(XML_TRUCKNO, _bolEntryObj),
									self.getTagDataFromXML(XML_UNLOADPOINT, _bolEntryObj),
									self.getTagDataFromXML(XML_VEHICLEID, _bolEntryObj),
									self.getTagDataFromXML(XML_WEIGHBRIDGE, _bolEntryObj),
									self.getTagDataFromXML(XML_YARDLOCATION, _bolEntryObj),
									strArray,
									_bolEntryHdr);
epilog
	delete strArray;
end;</source>
        <Parameter name="_bolEntryHdr" type="CM_RemoteBOLEntryHdr" usage="input"/>
        <Parameter name="_bolEntryObj" type="CnEcXmlStructureInstance"/>
    </JadeMethod>
    <JadeMethod name="createBOLEntryDetail" id="71aea5cc-61be-4373-9d0c-800c4712494f">
        <updating/>
        <source>createBOLEntryDetail(_bolEntryHdr: CM_RemoteBOLEntryHdr input): Boolean updating;

// Created by cnwdvb1 on 02 August 2007

vars
	bolEntry		: CnEcXmlStructureInstance;
	allBolsObj		: CnEcXmlStructureInstanceSet;
	canContinue		: Boolean;
	className		: String;
	typeName		: String;
	
begin
	on SystemException do self.handleException(exception, canContinue);
	
	create allBolsObj transient;
	
	canContinue	:=	true;
	self.xmlStruct.findAllStructures(XML_BOLENTRYGRP, allBolsObj);
	
	//cnwrd1 par 30235 22.8.2012		  
	if allBolsObj.isEmpty then
		app.raiseCMException1(ERR_Parsing_XML, "No Body segments identified",null, null );
		return false;
	endif;
	
	foreach bolEntry in allBolsObj do
		_bolEntryHdr.getAttributes(bolEntry.tagAttribute, className, typeName);
		
		if className &lt;&gt; CM_RemoteDataObject.Class_Log then
			continue;
		endif;
		
		self.createBOLEntry(_bolEntryHdr, bolEntry);
	endforeach;
	
	return canContinue;
epilog
	delete allBolsObj;
end;
/*
	canContinue	:=	true;
	bolEntryGrp	:=	self.xmlStruct.findStructure(XML_BOLENTRYGRP).CnEcXmlGroupInstance;
	
	_bolEntryHdr.getAttributes(bolEntryGrp.tagAttribute, className, typeName);
	
	if className &lt;&gt; CM_RemoteDataObject.Class_Log then
		return false;
	endif;
	
	self.createBOLEntry(_bolEntryHdr);
	
	return canContinue;
end;
*/</source>
        <Parameter name="_bolEntryHdr" type="CM_RemoteBOLEntryHdr" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createBOLMaint" id="04d1275d-4ab3-48a3-8e57-21d8f1c4965e">
        <source>createBOLMaint(_bolMaintHdr : CM_RemoteBOLMaintHdr input; _bolMaintObj:CnEcXmlStructureInstance);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 June 2012	cnwrd1	Initial creation

*/

vars
	detailObj	: CM_RemoteBOLMaintDtl;
	strArray	: StringArray;
	sequenceObj	: CnEcXmlStructureInstance;
	ticketObj	: CnEcXmlStructureInstance;
	
begin
	create detailObj transient;
	
	detailObj.setProxyForBOLMaint(	self.getTagDataFromXML(XML_ACTIVITY, _bolMaintObj),
									self.getTagDataFromXML(XML_BACKLOAD, _bolMaintObj),
									self.getTagDataFromXML(XML_BOLNOLOOKUP, _bolMaintObj),
									self.getTagDataFromXML(XML_CARRIERID, _bolMaintObj),
									self.getTagDataFromXML(XML_CHHSUPPLIER, _bolMaintObj),
									self.getTagDataFromXML(XML_COMPARTMENT, _bolMaintObj),
									self.getTagDataFromXML(XML_CUSTOMER, _bolMaintObj),
									self.getTagDataFromXML(XML_DOCKETERROR, _bolMaintObj),
									self.getTagDataFromXML(XML_DRIVERID, _bolMaintObj),
									self.getTagDataFromXML(XML_PIECECOUNTERROR, _bolMaintObj),
									self.getTagDataFromXML(XML_DRIVERSPIECECOUNT, _bolMaintObj),
									self.getTagDataFromXML(XML_FELLINGDATE, _bolMaintObj),
									self.getTagDataFromXML(XML_FOREST, _bolMaintObj),
									self.getTagDataFromXML(XML_GANG, _bolMaintObj),
									self.getTagDataFromXML(XML_GROSSWEIGHT, _bolMaintObj),
									self.getTagDataFromXML(XML_FSC, _bolMaintObj),		
									self.getTagDataFromXML(XML_NIGHTSHIFT, _bolMaintObj),
									self.getTagDataFromXML(XML_LOADERNO, _bolMaintObj),
									self.getTagDataFromXML(XML_LOADINGCONT, _bolMaintObj),
									self.getTagDataFromXML(XML_LOGGINGCONT, _bolMaintObj),
									self.getTagDataFromXML(XML_LOGGINGOP, _bolMaintObj),
									self.getTagDataFromXML(XML_LOGGINGORG, _bolMaintObj),
									self.getTagDataFromXML(XML_NETWEIGHT, _bolMaintObj),
									self.getTagDataFromXML(XML_BOLNO, _bolMaintObj),									
									self.getTagDataFromXML(XML_SUPPLIERLOOKUP, _bolMaintObj),
									self.getTagDataFromXML(XML_OPID, _bolMaintObj),
									self.getTagDataFromXML(XML_PICKUPPOINT, _bolMaintObj),
									self.getTagDataFromXML(XML_REMARKS, _bolMaintObj),
									self.getTagDataFromXML(XML_STAND, _bolMaintObj),
									self.getTagDataFromXML(XML_SUBSUPPLIER, _bolMaintObj),
									self.getTagDataFromXML(XML_TAREWEIGHT, _bolMaintObj),
									self.getTagDataFromXML(XML_TRAILERNO, _bolMaintObj),
									self.getTagDataFromXML(XML_TRUCKNO, _bolMaintObj),
									self.getTagDataFromXML(XML_UNLOADPOINT, _bolMaintObj),
									self.getTagDataFromXML(XML_VEHICLEID, _bolMaintObj),
									self.getTagDataFromXML(XML_WEIGHBRIDGE, _bolMaintObj),
									_bolMaintObj.asXMLMessage,
									_bolMaintHdr);
									
epilog
	delete strArray;
end;</source>
        <Parameter name="_bolMaintHdr" type="CM_RemoteBOLMaintHdr" usage="input"/>
        <Parameter name="_bolMaintObj" type="CnEcXmlStructureInstance"/>
    </JadeMethod>
    <JadeMethod name="createBOLMaintDetail" id="81e35eef-7ae0-4f79-9acf-dc2e9e8f74b2">
        <updating/>
        <source>createBOLMaintDetail(_bolMaintHdr: CM_RemoteBOLMaintHdr input): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 June 2012	cnwrd1	Initial creation

*/

vars
	bolMaint		: CnEcXmlStructureInstance;
	allBolsObj		: CnEcXmlStructureInstanceSet;
	canContinue		: Boolean;
	className		: String;
	typeName		: String;
	
begin
	on SystemException do self.handleException(exception, canContinue);
	
	create allBolsObj transient;
	
	canContinue	:=	true;
	self.xmlStruct.findAllStructures(XML_BOLMAINTGRP, allBolsObj);
	
	//cnwrd1 par 30235 22.8.2012		  
	if allBolsObj.isEmpty then
		app.raiseCMException1(ERR_Parsing_XML, "No Body segments identified",null, null );
		return false;
	endif;
	
	foreach bolMaint in allBolsObj do
		_bolMaintHdr.getAttributes(bolMaint.tagAttribute, className, typeName);
		
		if className &lt;&gt; CM_RemoteDataObject.Class_Log then
			continue;
		endif;
		
		self.createBOLMaint(_bolMaintHdr, bolMaint);
	endforeach;
	
	return canContinue;
epilog
	delete allBolsObj;
end;</source>
        <Parameter name="_bolMaintHdr" type="CM_RemoteBOLMaintHdr" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createBOLQueryDetail" id="8ed002df-c413-491c-a62e-04b82219052a">
        <updating/>
        <source>createBOLQueryDetail(_bolQueryHdr : CM_RemoteBolQueryHdr input) : Boolean updating;

vars


	 bolqryrq			: CnEcXmlGroupInstance;
	 bol				: CnEcXmlStructureInstance;
	 allTis				: StringArray;
	 tagAttributes		: String;
	 canContinue		: Boolean;

begin

	on SystemException do self.handleException(exception, canContinue);
	
	canContinue := true;	
	create allTis transient;
	bolqryrq :=	self.xmlStruct.findStructure(XML_BOLQRYRQ).CnEcXmlGroupInstance;
	tagAttributes := bolqryrq.tagAttribute;
	foreach bol in bolqryrq.allFields do
		allTis.add(bol.tagData);
	endforeach;
	_bolQueryHdr.setProxyForBolQueryHdr(tagAttributes, allTis);

epilog

	delete allTis;
	return canContinue;
end;</source>
        <Parameter name="_bolQueryHdr" type="CM_RemoteBolQueryHdr" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createCheckScalingDetail" id="e6eedffd-d412-4576-ae82-9510adb48915">
        <updating/>
        <source>createCheckScalingDetail(_checkScalingHdr: CM_RemoteCheckScalingHdr): Boolean updating;

// cnwdvb1 04 April 2003 

vars
	batchrq				: CnEcXmlGroupInstance;
	tibatch				: CnEcXmlStructureInstance;
	tidtls				: CnEcXmlGroupInstance;
	ti					: CnEcXmlStructureInstance;
	canContinue			: Boolean;
	class,
	type,
	batchHdr,
	tiString			: String;
	remoteDetail		: CM_RemoteDataDtl;
	 

begin

	on SystemException do self.handleException(exception, canContinue);
	
	canContinue 	:= true;	
	batchrq 		:=	self.xmlStruct.findStructure(XML_BATCHRQ).CnEcXmlGroupInstance;
	foreach tibatch in batchrq.allFields do
		_checkScalingHdr.getAttributes(tibatch.tagAttribute, class, type);
		batchHdr	:= tibatch.findStructure(XML_BATCHHDR).tagData; 
		
		if type &lt;&gt; CM_RemoteDataObject.Type_Check then
			canContinue := false;
			return canContinue;
		endif;

		remoteDetail	:= self.parseBatchHdr(batchHdr, _checkScalingHdr, class, type);
		tidtls		:= tibatch.findStructure(XML_TIDTLS).CnEcXmlGroupInstance;	
		_checkScalingHdr.getAttributes(tidtls.tagAttribute, class, type);
		
		if type &lt;&gt; CM_RemoteDataObject.Type_Check then
			canContinue := false;
			return canContinue;
		endif;

		foreach ti in tidtls.allFields do
			tiString := ti.tagData;
			self.parseTiToExtraDetail(tiString, remoteDetail, class, type);
		endforeach;
	endforeach;

epilog

	return canContinue;

end;


/*	&lt;msg&gt;
	&lt;hdr&gt;
	&lt;msgtype&gt;SclCheckRq&lt;/msgtype&gt;
	&lt;msgid&gt;1234&lt;/msgid&gt;
	&lt;deviceid&gt;1111&lt;/deviceid&gt;
	&lt;userid&gt;JSS&lt;/userid&gt;
	&lt;pswd&gt;312312&lt;/pswd&gt;
	&lt;terminal&gt;1&lt;/terminal&gt;
	&lt;version&gt;1&lt;/version&gt;
	&lt;time&gt;20020612232434&lt;/time&gt;
	&lt;/hdr&gt;
	&lt;bdy&gt;
	&lt;batchrq&gt;
	&lt;tibatch class = "LOG"  type="CHECK"&gt;
	&lt;batchhdr&gt;1234567, AA,ALAN,20020612232434&lt;/batchhdr&gt;
	&lt;tidtls class="LOG" type="SCALE"&gt;
	&lt;ti&gt; 1, OK, 34, 36&lt;/ti&gt;
	&lt;/tidtls&gt;
	&lt;/tibatch&gt;
	&lt;/batchrq&gt;
	&lt;/bdy&gt;
	&lt;/msg&gt;*/</source>
        <Parameter name="_checkScalingHdr" type="CM_RemoteCheckScalingHdr"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
