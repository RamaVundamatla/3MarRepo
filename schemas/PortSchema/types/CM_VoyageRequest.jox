    <JadeMethod name="getOOWDesc" id="fe7eb846-61b6-454a-995e-d790181c4182">
        <source>getOOWDesc(): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	returnVal	: String;
	invalid 	: Boolean;
	commGrp		: CM_CommodityGroup;
	port		: CM_Port;
	ct : CM_CargoType;
begin
// PAR 16415 CCMS 1029
	if self.getAttrIs53() then
		returnVal := "53";
	elseif self.getAttrIs30() then
		returnVal := "30";
	elseif self.getAttrIs45() then
		returnVal := "45";
	elseif self.getAttrIs40() then
		returnVal	:=	"40'";
	elseif self.getAttrIs20() then
		returnVal	:=	"20'";
	else
		ct := self.getAttrCargoType();
		if ct &lt;&gt; null then
			returnVal	:=	ct.abbreviation;
		endif;
	endif;
	
	if self.myTerminal.getConfig(OOWUseSimpleNonPlanned).Boolean then
		if ct = null then // Container
		returnVal	:=	returnVal &amp; self.getSimpleLabel();
		endif;
	else
		if ct = null then // Container
			commGrp := self.getAttrCommodityGroup();
			if commGrp &lt;&gt; null then
				on Exception do app.handleDeletedObject(exception, commGrp, invalid);
				returnVal := returnVal &amp; commGrp.code;
				on Exception do null;
			endif;
		endif;
	endif;
	
	port := self.getAttrDischargePort();
	if port &lt;&gt; null then
		returnVal	:=	returnVal &amp; ' ' &amp; port.code.padBlanks(5);
	endif;
	
	return returnVal;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
