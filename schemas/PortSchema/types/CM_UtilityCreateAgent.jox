        <source>utlCreateGLCode(pProxyGLCode : CM_GLCode; 
				pNewGLCode : CM_GLCode output;
				_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
// 09 Jan 2017	cnwma1	TFS #2643 :JMT - Audit of Invoice Maintenance Set-up
