    <JadeMethod name="uCreateTerminalNULLObjs" id="9c28781b-cbf6-4a23-8df1-cbbebeed5c3a">
        <updating/>
        <source>uCreateTerminalNULLObjs() updating;

/*

Purpose:		Create a terminals null train and voyage if they don't exist

Date			Who		Reason
22/04/2015		cnwmh5	Initial creation

*/

vars

	terminal					: CM_Terminal;
	nullTrain 					: CM_NullTrain;

	terminalName 				: String;

begin

	terminalName := "Enter Terminal Name to Create NULL train / voyage for";
	read terminalName;
	
	if terminalName = null then
		return;
	endif;
	
	terminal := app.myRoot.allTerminals[terminalName];	
	self.assertNotNull(terminal);
	
	beginTransaction;
	if terminal.getNullTrain() = null then
		create nullTrain persistent;
		nullTrain.init(terminal);
	endif;
	
	if terminal.getNullVoyage() = null then
		terminal.sendMsg("createNullVoyage");	
	endif;
	commitTransaction;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="uDeleteAllCargoOfType" id="be307789-94f9-434c-b29d-a3f3ff09e8fc">
        <source>uDeleteAllCargoOfType();
//18 September 2008	cnwdw1	
//
vars
	cargoTypeAbbrev: String;
	ti: CM_TrackedItem;
	iter: Iterator;
	terminal: CM_Terminal;
	cargoType: CM_CargoType;
	mergeIter: MergeIterator;
	voyage: CM_Voyage;
	count: Integer;
	deleteFromSingleTerminal: Boolean;
begin


	cargoTypeAbbrev := "abbrev";
	read cargoTypeAbbrev;
	cargoType := self.getRoot.getCargoTypeFromAbbrev(cargoTypeAbbrev);
	if cargoType = null then
		return;
	endif;
	
	if app.msgBox("Delete from ALL terminals?", "Delete Cargo", MsgBox_Yes_No) = MsgBox_Return_Yes then
		deleteFromSingleTerminal := false;
		if app.msgBox("This will delete all cargo of type "&amp;cargoTypeAbbrev&amp;" in ALL Terminals", "Delete All Cargo Type Cargo", MsgBox_OK_Cancel) = MsgBox_Return_Cancel then
			return;
		endif;
	else
		deleteFromSingleTerminal := true;
		if app.msgBox("This will delete all cargo of type "&amp;cargoTypeAbbrev&amp;" in " &amp; self.getTerminal.code, "Delete All Cargo Type Cargo", MsgBox_OK_Cancel) = MsgBox_Return_Cancel then
			return;
		endif;
	endif;
	
	foreach terminal in self.getRoot.allTerminals do
		
		if deleteFromSingleTerminal and terminal &lt;&gt; self.getTerminal then
			continue;
		endif;
		
		count := 0;
		create mergeIter transient;
		mergeIter.addCollection(terminal.allNotifiedTIsByCargoTypeId);
		mergeIter.addCollection(terminal.allOnsiteTIsByCargoTypeId);

		mergeIter.startKeyGeq(cargoType.id, null);
		while mergeIter.next(ti) do
			if ti.myCargoType &lt;&gt; cargoType then
				break;
			endif;
			deleteTrackedItem(ti, false); 
			count := count + 1;
		endwhile;
		delete mergeIter;
		
		create mergeIter transient;
		mergeIter.addCollection(terminal.allOffsiteTIsByCargoTypeId);

		mergeIter.startKeyGeq(cargoType.id, null, null);
		while mergeIter.next(ti) do
			if ti.myCargoType &lt;&gt; cargoType then
				break;
			endif;
			deleteTrackedItem(ti, false); 
			count := count + 1;
		endwhile;
		delete mergeIter;

		foreach voyage in terminal.allVoyagesByCode do
			iter := voyage.allOnshipTIsByCargoTypeId.createIterator;
			voyage.allOnshipTIsByCargoTypeId.startKeyGeq(cargoType.id, null, iter);
			while iter.next(ti) do
				if ti.myCargoType &lt;&gt; cargoType then
					break;
				endif;
				deleteTrackedItem(ti, false); 
				count := count + 1;
			endwhile;
			delete iter;
		endforeach;
		self.logMessage("Terminal: " &amp; terminal.code &amp; " Count: " &amp; count.String);
	endforeach;
	
epilog
	delete mergeIter;	
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="uDeleteAllHMSTransactions" id="a57c11bd-7e0a-4e65-8843-895ee0ff773e">
