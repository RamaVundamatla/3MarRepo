    <JadeMethod name="setupForm" id="bd3aaced-9d9c-4ff8-ba4d-7161ba67d246">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     04 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 18/03/2022	navcs2	ChangeRequest 52945: MTN - RTQueue Refresh Issue
// ---------------------------------------------------------------------------
vars
	lGray	: Integer;
begin
	inheritMethod();
//	on Exception do self.xInvalidObject(exception) global;
	self.isShowInherited := false;
	self.mnuShowInherited.checked := false;
	self.mnuHideOffMachines.checked := false; //16/08/2011 cnwdz2 27747
	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;
	self.showToolbar	:= true;
	
	self.splitter1.setLeftToRightRatioAndResize(35);
	self.splitter2.splitType := self.splitter1.SPLITTYPE_LOCKRIGHT;
	self.splitter2.setLeftToRightRatioAndResize(60);

	self.setCaption(app.getErrorString(Radio_Telemetry_Queue));
	lGray := tblQEntries.accessCell(1,1).backColor;
//	self.centreWindow; DO NOT Centre window as the users last size and position is used instead.

	self.initTblQEntries();
	self.setMasterQueue();
//	self.doQueueCleanup(false);

	if not app.isUsingSkin() then
		lstQueues.hasTreeLines := true;
	endif;
	lstQueues.hasPlusMinus := true;
	
	lstQueues.hasPictures := false; // this will put the windows pictures, folder etc. onto the tree

	self.tblQEntries.selectMode := Table.SelectMode_Row;
	self.tblQEntries.accessMode := Table.AccessMode_Row;
	self.tblQEntries.multiSelect := CM_BaseTable.MultiSelect_Simple;
	self.tblQEntries.selectionType := CM_BaseTable.SelectionType_Row;
	
	if app.myPassport.myUser.canDo(self.myTerminal, PmRTPeekAtScreen) then
		self.mnuMachinePeek.visible := true;
	else
		self.mnuMachinePeek.visible := false;
	endif;
	
	self.lstQueues.enableEvent('mouseMove', true); //false
	//17/08/2011 cnwdz2 27747
	
	 // ### JIRA 36102 23SEP2025 NAVAB1 change row heights for bigger icons
	self.tblMachines.defaultRowHeight :=  32; //16;
	self.lstQueues.defaultLineHeight :=  32; //16;
	self.tblQEntries.defaultRowHeight :=  26;
	self.tblQEntries.stretch := Table.Stretch_None_Picture_First;
	
	self.lstQueues.multiSelect:= ListBox.MultiSelect_Extended; //epr CCMS 1391 multi select
	
	self.canMaintainRTQueue := app.myCurrentUserCan(self.myTerminal, self.permissionMaint); // 19/03/2022 navcs2 52945
	
	// TFS 2198 CNWAB1
	// 19/03/2022 navcs2 52945
	if not self.canMaintainRTQueue then
		self.btnNewQueue.enabled:= false;
		self.tblQEntries.userInputEnabled := false;
		self.tblMachines.userInputEnabled := false;
		self.btnSuspend.enabled:= false;
		self.btnPin.enabled:= false;
	endif;

end;</source>
    </JadeMethod>
