    <JadeMethod name="jssAge" id="0d67cac5-e955-4bea-b1a4-43bffbfd4e3a">
        <source>jssAge():Decimal;
// Determines the age - i.e. the time between the TimeStamp and now.
// Returns the age in milliseconds.
vars
	now	: TimeStamp;
	age	: Decimal[23,1];

begin
	if now &gt;= self then
		age := now.jssDiff(self);
	else
		age := self.jssDiff(now);
	endif;

	return age;
end;</source>
        <text>___________________________________________________________________________

