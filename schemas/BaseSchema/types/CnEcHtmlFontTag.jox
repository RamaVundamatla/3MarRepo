Applies the font size and / or color and / or typeface specified to
the enclosed characters.</text>
    <DbClassMap file="basehtml"/>
    <PrimAttribute name="fontColor" id="db95eb51-2ff8-455c-8385-725c7546199f">
        <length>41</length>
        <embedded/>
        <type name="String"/>
        <text>Applies the color specified to the enclosed characters.

Refer to the Html_Colors category of global constants.</text>
    </PrimAttribute>
    <PrimAttribute name="fontFace" id="171f9dcd-8236-407c-93a4-ffc30511214e">
        <type name="String"/>
        <text>Applies the typeface specified to the enclosed characters.</text>
    </PrimAttribute>
    <PrimAttribute name="fontIsSizeProportional" id="eef6c180-2b68-491f-b543-a31e6ff96791">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
        <text>If true, the size will be set as a proportional value rather than as an absolute
value, i.e. '+' or '-' a certain number, such as '+1'.  These numbers can be
between 1 and 7.</text>
    </PrimAttribute>
    <PrimAttribute name="fontSize" id="f8d68459-6000-4289-a15e-ecc4601de2aa">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
        <text>Applies the font size specified to the enclosed characters.</text>
    </PrimAttribute>
    <PrimAttribute name="fontValue" id="a7da634e-d2ef-4512-891b-a8c6de097fbb">
        <type name="String"/>
        <text>The text value to display with the specified font.  Note that this may
include other HTML tags.</text>
    </PrimAttribute>
    <JadeMethod name="buildTagBody" id="cb9e16f7-dfc1-4418-8abb-f52f4d437623">
        <source>buildTagBody(): String protected;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	htmlString	: String;

begin
	if self.fontSize &lt;&gt; 0 then
		if self.fontIsSizeProportional then
			// The '+' specifies that the font size is absolute.
			htmlString	:=	'SIZE="+' &amp; self.fontSize.String &amp; '"';
		else
			htmlString	:=	'SIZE="' &amp; self.fontSize.String &amp; '"';
		endif;
	endif;

	if self.fontColor &lt;&gt; null then
		htmlString	:=	htmlString &amp; ' COLOR="' &amp; self.fontColor &amp; '"';
	endif;

	if self.fontFace &lt;&gt; null then
		htmlString	:=	htmlString &amp; ' FACE="' &amp; self.fontFace &amp; '"';
	endif;

	htmlString	:=	htmlString &amp; inheritMethod();
	htmlString	:=	htmlString &amp; '&gt;' &amp; self.fontValue;

	return htmlString;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHtml" id="48198004-ccab-4d35-937c-fa51a8d05989">
        <source>getHtml(): String;
// --------------------------------------------------------------------------------
// Created:		01 May 2000 by cnwdad2
//
// Purpose:		Refer to the CnEcHtmlTagObject implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return '&lt;FONT ' &amp; self.buildTagBody() &amp; '&lt;/FONT&gt;' &amp; CrLf;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isValidFontSize" id="aac87e74-34ad-415b-a5f3-29f8085b97c8">
        <source>isValidFontSize(pSize:Integer; pIsProportional:Boolean):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		02 May 2000 by cnwdad2
//
// Purpose:		Validates the receiver's font size setting.
//
// Parameters:	pSize - The receiver's font size setting.
//				pIsProportional - If true, the font size will be proportional to
//					the base font size, which is normally "3".
//
// Returns:		True if the alignment font size is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pIsProportional then
		// Proportional font sizes must be between 1 and 6.
		if pSize &lt; 1 or pSize &gt; 6 then
			CnEcBaseHtmlException.raise_(CNEC_X_22001, '"' &amp; pSize.String &amp; '" is not a valid proportional font size');
			return false;
		endif;
	endif;

	return true;
end;</source>
        <access>protected</access>
        <Parameter name="pSize" type="Integer"/>
        <Parameter name="pIsProportional" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFontSize" id="d66faffd-02a3-4603-89f9-a77db04ab824">
        <updating/>
        <source>setFontSize(pSize:Integer; pIsSizeProportional:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		02 May 2000 by cnwdad2
//
// Purpose:		Sets the receiver's font size.
//
// Parameters:	pSize - The font size.
//				pIsSizeProportional - If true, the font size will be proportional to
//					the base font size, which is normally "3".
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isValidFontSize(pSize, pIsSizeProportional) then
		self.fontSize				:=	pSize;
		self.fontIsSizeProportional	:=	pIsSizeProportional;
	endif;
end;</source>
        <Parameter name="pSize" type="Integer"/>
        <Parameter name="pIsSizeProportional" type="Boolean"/>
    </JadeMethod>
</Class>
