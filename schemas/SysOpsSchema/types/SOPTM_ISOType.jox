    <JadeMethod name="doSave" id="78229d98-ced6-4172-a059-500d4747fc28">
        <updating/>
        <source>doSave(): Boolean updating;

vars
	isNotTwinLiftCapable	: Boolean;
	proxyISOType:CM_ISOType;
	lCode, lDescription : String; 
	tareKilos,
	lColour : Integer;
	lCargoType : CM_CargoType;
	lISOTypeGroup:CM_ISOTypeGroup;
	lIS20ftLong, lIS40ftLong, lIS45ftLong, lIS30ftLong, lIS53ftLong, lIS4ft3High, lIS4ftHigh, 
	lIS8ft6High, lIS8ftHigh, lISHalfHeight, lIS9ft6High,
	lISCrib, lISFantainer, lISFlat, lISGeneral,
	lISIntegral, lISMachinery, lISOpenTop, lISPorthole,
	lISPowered, lISReefer, lISTank, lISFrame, lISRotatalbe, 
	isNotAvailableForEntry : Boolean;
	theForm : SOP_TableMaintForm;
	maxTareWeight,
	maxTotalWeight : Integer;
	
begin
	theForm := self.myForm; 
	
	lCode := theForm.tblInput1.getValueByName(ETRow_Code).String;
	lDescription := theForm.tblInput1.getValueByName(ETRow_Description).String;
    lColour := theForm.tblInput1.getValueByName(ETRow_Colour).Integer;
    lCargoType := theForm.cmbCargoType.listObject.CM_CargoType;
    lISOTypeGroup := theForm.cmbISOTypeGroup.listObject.CM_ISOTypeGroup;
 	lIS20ftLong := theForm.tblInput1.getValueByName(ETRow_Twenty).Boolean;
 	lIS30ftLong := theForm.tblInput1.getValueByName(ETRow_Thirty).Boolean;
 	lIS40ftLong := theForm.tblInput1.getValueByName(ETRow_Forty).Boolean;
 	lIS45ftLong := theForm.tblInput1.getValueByName(ETRow_FortyFive).Boolean;
 	lIS53ftLong := theForm.tblInput1.getValueByName(ETRow_FiftyThree).Boolean;
 	lIS4ft3High := theForm.tblInput1.getValueByName(ETRow_Height43).Boolean;
 	lIS4ftHigh := theForm.tblInput1.getValueByName(ETRow_Height4).Boolean;
	lIS8ft6High := theForm.tblInput1.getValueByName(ETRow_Height86).Boolean;
	lIS8ftHigh := theForm.tblInput1.getValueByName(ETRow_Height8).Boolean;
//	lISHalfHeight :=theForm.tblInput1.getValueByName(ETRow_Half
	lIS9ft6High := theForm.tblInput1.getValueByName(ETRow_Height96).Boolean;
	lISCrib := theForm.tblInput1.getValueByName(ETRow_Crib).Boolean;
	lISFantainer :=theForm.tblInput1.getValueByName(ETRow_Fan).Boolean;
	lISFlat := theForm.tblInput1.getValueByName(ETRow_Flat).Boolean;
	lISGeneral := theForm.tblInput1.getValueByName(ETRow_General).Boolean;
	lISIntegral := theForm.tblInput1.getValueByName(ETRow_Integral).Boolean;
//	tareKilos := theForm.tblInput1.getValueByName(ETRow_TareWeight).Integer;
	//18 Mar 2014	NDL	Par 33268
	tareKilos := self.getConvertedDisplayValue( ETRow_TareWeight, weightType ).Integer;
	lISRotatalbe := theForm.tblInput1.getValueByName(ETRow_IsRotatable).Boolean; //02/10/2025	navkc1 JIRA 36151
	
	
	//lISMachinery 
	lISOpenTop := theForm.tblInput1.getValueByName(ETRow_OpenTop).Boolean;
	lISPorthole := theForm.tblInput1.getValueByName(ETRow_Porthole).Boolean;
	lISPowered := theForm.tblInput1.getValueByName(ETRow_Powered).Boolean;
	lISReefer := theForm.tblInput1.getValueByName(ETRow_Reefer).Boolean;
	lISTank := theForm.tblInput1.getValueByName(ETRow_Tank).Boolean;
	lISFrame := theForm.tblInput1.getValueByName(ETRow_Frame).Boolean;	//02 Feb 2018	NDL	TFS 36752
	isNotAvailableForEntry := theForm.tblInput1.getValueByName(ETRow_NotAvailableForEntry).Boolean;
//	isNotTwinLiftCapable := not theForm.tblInput1.getValueByName(ETRow_MachineLiftType).Boolean;
	isNotTwinLiftCapable := not theForm.tblInput1.getValueByName(ETRow_CanTwinLift).Boolean; // PAR 17390, another thing broken by YI
	
//	maxTotalWeight := theForm.tblInput1.getValueByName(ETRow_MaxTotalWeight).Integer;
//	maxTareWeight := theForm.tblInput1.getValueByName(ETRow_MaxTareWeight).Integer;
	
	//18 Mar 2014	NDL	Par 33268
	maxTotalWeight := self.getConvertedDisplayValue( ETRow_MaxTotalWeight, weightType ).Integer;
	maxTareWeight := self.getConvertedDisplayValue( ETRow_MaxTareWeight, weightType ).Integer;
	
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_ISOType transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyISOType := theForm.myProxyObject.CM_ISOType;
	proxyISOType.setProxy(lCode, lDescription, tareKilos, lColour,lCargoType,lISOTypeGroup,
		 lIS20ftLong, lIS30ftLong, lIS40ftLong,lIS45ftLong,lIS53ftLong, lIS4ft3High, lIS4ftHigh, 
		 lIS8ft6High, lIS8ftHigh, lISHalfHeight, lIS9ft6High,
		 lISCrib, lISFantainer, lISFlat, lISGeneral,
		 lISIntegral, lISMachinery, lISOpenTop, lISPorthole,
		 lISPowered, lISReefer, lISTank, lISFrame, lISRotatalbe, isNotAvailableForEntry, isNotTwinLiftCapable, maxTotalWeight, maxTareWeight);

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateISOType(proxyISOType, theForm.myCurrentObject,app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateISOType(proxyISOType, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
