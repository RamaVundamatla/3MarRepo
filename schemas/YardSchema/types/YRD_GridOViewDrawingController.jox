    <JadeMethod name="getStatsFrameForTA" id="40cd3e8f-54d0-4476-ae57-d43847404421">
        <source>getStatsFrameForTA(_ta : CM_TerminalArea;_createIfNull : Boolean) : CMUI_Frame protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 August 2009	cnwer1	Initial creation

*/

vars
	classID,instanceID,
	newIdx: Integer;
	satViewForm : YRD_SatelliteViewForm;
	newFrame : CMUI_Frame;
begin
	if _ta = null then
		return null;
	endif;
	
	if not _ta.isKindOf(CM_RTGArea) then
		return null;
	endif;
	
	
	if self.myGridOverviewForm = null or not self.myGridOverviewForm.isKindOf(YRD_SatelliteViewForm)  then
		return null;
	endif;
	
	satViewForm:=self.myGridOverviewForm.YRD_SatelliteViewForm;
	
	//epr par 31523 4/7/13
	newIdx:=getNewFrameIndex(_ta,self.STATS_FRAME_ID);
	newFrame:= satViewForm.frmTAQInOut.getControl(newIdx);
	if newFrame = null and _createIfNull then
		newFrame:=satViewForm.frmTAQInOut.loadControl(newIdx).CMUI_Frame;
	endif;
	return newFrame;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_createIfNull" type="Boolean"/>
        <ReturnType type="CMUI_Frame"/>
    </JadeMethod>
    <JadeMethod name="getTAOriginForTA" id="61ddaa08-b9ea-4dad-9c1c-b171cd31d2fa">
        <source>getTAOriginForTA(_ta : CM_TerminalArea; _x, _y : Real output)  : CM_TerminalAreaViewPosition protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 January 2010	cnwjk3 ccms 1018

*/

vars
	taViewPostion : CM_TerminalAreaViewPosition;
begin

	taViewPostion:=self.myTerminalAreaView.findViewPositionForTA(_ta);
	if taViewPostion = null then
		return null;
	endif;
	
	self.getTAViewPositionXYs(taViewPostion,  _x, _y);
	//in clude the area heading and the row label
	_x := _x + 15 + self.getSpaceForDifferentFonts(1) * 1.5;
	_y := _y + 12;
	
	return taViewPostion;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_x" type="Real" usage="output"/>
        <Parameter name="_y" type="Real" usage="output"/>
        <ReturnType type="CM_TerminalAreaViewPosition"/>
