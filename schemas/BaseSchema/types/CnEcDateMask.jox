    <JadeMethod name="cnEcDate" id="f76f5dfb-09f8-4c4d-a6c4-2365a69b90b5">
        <source>cnEcDate(): Date;
// -----------------------------------------------------------------------------
// Created:		21 November 2001 by cnwdad1
//
// Purpose:		Returns the receiver's current date setting, provided that the
//				date is valid, otherwise a null value is returned.
//
// Parameters:	None
//
// Returns:		The current date setting.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
// 21/06/2007	cnwdad1		Added an exception handler in case the getTextAsDate
//							method throws an exception.
// -----------------------------------------------------------------------------
vars
	currentDate		: Date;
	errorMsg		: String;
	
begin
	errorMsg	:=	null;
	on Exception do self.xHandlerDate(exception, errorMsg);
	
	if self.isValid() then
		currentDate	:=	self.getTextAsDate();
	else
		currentDate	:=	null;
	endif;
	
	if currentDate.isValid() then
		return currentDate;
	else
		return null;
	endif;
epilog
	if errorMsg &lt;&gt; null then
		app.msgBox(errorMsg, $CNEC_ERROR, MsgBox_Information_Icon + MsgBox_OK_Only);
	endif;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="cnEcDecimal" id="97d222b3-2a98-4a9a-883f-64fef2e04d0d">
        <source>cnEcDecimal(): Decimal;
// -----------------------------------------------------------------------------
// Created:		21 November 2001 by cnwdad1
//
// Purpose:		Returns the receiver's current date setting as a Decimal Julian
//				day number.
//
// Parameters:	None
//
// Returns:		The Julian day number.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	if self.text.Date.isValid() then
		return self.text.Date.Decimal;
	else
		return 0;
	endif;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
