epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getExternalRefIdFromVBSId" id="58e12c2b-6033-487f-9125-8114ce6a6a8b">
        <source>getExternalRefIdFromVBSId(_vbsId : String) : String;
/*

Purpose:			Generates External Reference from a Vehicle Booking Timeslot Id

Parameters:			_vbsId	String	Vehicle Booking Slot Id to grab the sequence number from

Return Value:		String	A new external reference id based off of the sequence number on the vbsId passed in

Date		Who		Reason
01 May 2023	navpw1	Initial creation TFS: 57783 (57784)

*/

vars
	serverDate		: Date;
	prefix,
	year,
	month,
	newId,
	sequenceNumber	: String;
	seqNum,
	nextSeqNum		: Real;
	failSafeCount,
	prefixPos		: Integer;
	
begin
	//Strip Prefix
	prefixPos := 1;
	prefixPos := _vbsId.pos(self.idPrefix, prefixPos);
	
	if prefixPos &lt;&gt; null then
		prefixPos += self.idPrefix.length; //get prefix start
		if self.idStyle = AutoIdStyle_P_MM_YY_SSS then
			
			prefixPos += 2;
		endif;
		
		if self.idStyle = AutoIdStyle_P_YY_SSS
		or self.idStyle = AutoIdStyle_YY_SSS
		or self.idStyle = AutoIdStyle_P_MM_YY_SSS
		or self.idStyle = AutoIdStyle_P_YY_MM_SSS
		or self.idStyle = AutoIdStyle_P_YY_MM_DD_SSS
		then
			prefixPos += 2;
		endif;
		
		if self.idStyle = AutoIdStyle_P_YY_MM_SSS or self.idStyle = AutoIdStyle_P_YY_MM_DD_SSS then
			prefixPos += 2;
		endif;
		
		if self.idStyle = AutoIdStyle_P_YY_MM_DD_SSS then  
			prefixPos += 2;
		endif;
		
		sequenceNumber := _vbsId[prefixPos:end];
	else
		sequenceNumber := _vbsId;
	endif;
	
	// get the value set up last time thru, or by the last user edit.
	seqNum := sequenceNumber.Integer;
	year := serverDate.format("yy");
	month := serverDate.format("MM");
	
	if self.idStyle = AutoIdStyle_P_YY_SSS
	or self.idStyle = AutoIdStyle_P_SSS
	or self.idStyle = AutoIdStyle_P_MM_YY_SSS
	or self.idStyle = AutoIdStyle_P_YY_MM_SSS // TFS 39976
	or self.idStyle = AutoIdStyle_P_YY_MM_DD_SSS //01/09/2022 navmv20 TFS 54610
	then
		prefix := self.externalRefPrefix;
	endif;
	
	if self.idStyle = AutoIdStyle_P_MM_YY_SSS then
		
		prefix := prefix &amp; month;
	endif;
	
	if self.idStyle = AutoIdStyle_P_YY_SSS
	or self.idStyle = AutoIdStyle_YY_SSS
	or self.idStyle = AutoIdStyle_P_MM_YY_SSS
	or self.idStyle = AutoIdStyle_P_YY_MM_SSS
	or self.idStyle = AutoIdStyle_P_YY_MM_DD_SSS
	then
		prefix := prefix &amp; year;
	endif;
	
	if self.idStyle = AutoIdStyle_P_YY_MM_SSS or self.idStyle = AutoIdStyle_P_YY_MM_DD_SSS then
		month := app.actualTimeServer.Date.format("MM");
		prefix := prefix &amp; month;
	endif;
	
	if self.idStyle = AutoIdStyle_P_YY_MM_DD_SSS then  
		prefix := prefix &amp; app.actualTimeServer.Date.format("dd");
	endif;
	
	//23 Jan 2019	NDL	TFS 43018
	if self.resetOnDateChange( serverDate ) then
		// new year, new,month or new Day, may be time to reset the counter.
		seqNum := 1;
	endif;
	
	while true do
		if seqNum.String.length &gt; self.idSeqNumLength then
			// just in case the user has made the seq num length shorter since last time thru,
			// or we have naturally reached the end of the series and need to reset.
			seqNum := 1;
		endif;
		
		//newId := prefix &amp; year &amp; seqNum.String.padLeadingZeros(self.idSeqNumLength) &amp; self.generateCheckDigit(seqNum.Integer64).asStringJMT().String.padLeadingZeros(self.externalRefLength);	// 27.02.2023 navak20 TFS 56769
		newId := prefix &amp; seqNum.String.padLeadingZeros(self.idSeqNumLength) &amp; self.generateCheckDigit(seqNum.Integer64).asStringJMT().String.padLeadingZeros(self.externalRefLength);	// 27.02.2023 navak20 TFS 56769
		
		if self.newExternalRefIdNotAlreadyUsed( newId ) then
			// no object of this type already uses this id.
			break;
		endif;
		
		seqNum := seqNum + 1;
		
		failSafeCount := failSafeCount + 1;
		if failSafeCount &gt; 9 then
			return null;
		endif;
		
	endwhile;
	
	nextSeqNum := seqNum + 1;
	if nextSeqNum.String.length &gt; self.externalRefLength then
		nextSeqNum := 1;
	endif;
	
	return newId;

end;</source>
        <Parameter name="_vbsId" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNextExternalRefId" id="187183ae-6630-4ce5-9e34-31a14285c522">
        <updating/>
        <source>getNextExternalRefId() : String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Jan 2023	navpw1	Initial creation TFS: 53898 (53961)
27 Feb 2023	navak20 Defect 56769: In Vehicle Booking- External Reference Column showing duplicate year
16 Nov 2023 navma1	ChangeRequest 61252: EUP | FR | 54329 | VBS - Pending issues - Issue 2
*/

vars
	serverDate 	  		: Date;
	prefix 		  		: String;
	year 		  		: String;
	month 		  		: String;
	seqNum 		  		: Real;
	newId 		  		: String;
	nextSeqNum    		: Real;
	failSafeCount 		: Integer;
	seqWitoutPrefix 	: String;
	dd     		  		: String;
begin
	// get the value set up last time thru, or by the last user edit.
	seqNum := self.nextSequenceNum -1;
	year := serverDate.format("yy");
	month := serverDate.format("MM");
	
	if self.idStyle = AutoIdStyle_P_YY_SSS
	or self.idStyle = AutoIdStyle_P_SSS
	or self.idStyle = AutoIdStyle_P_MM_YY_SSS
	or self.idStyle = AutoIdStyle_P_YY_MM_SSS // TFS 39976
	or self.idStyle = AutoIdStyle_P_YY_MM_DD_SSS //01/09/2022 navmv20 TFS 54610
	then
		prefix := self.externalRefPrefix;
	endif;
	
	if self.idStyle = AutoIdStyle_P_MM_YY_SSS then
		
		prefix 			:= prefix &amp; month;
		seqWitoutPrefix := month;								//16.11.2023 navma1 #61252
	endif;
	
	if self.idStyle = AutoIdStyle_P_YY_SSS
	or self.idStyle = AutoIdStyle_YY_SSS
	or self.idStyle = AutoIdStyle_P_MM_YY_SSS
	or self.idStyle = AutoIdStyle_P_YY_MM_SSS
	or self.idStyle = AutoIdStyle_P_YY_MM_DD_SSS
	then
		prefix 			:= prefix &amp; year;
		seqWitoutPrefix := seqWitoutPrefix &amp; year;				//16.11.2023 navma1 #61252
	endif;
	
	if self.idStyle = AutoIdStyle_P_YY_MM_SSS or self.idStyle = AutoIdStyle_P_YY_MM_DD_SSS then
		month 			:= app.actualTimeServer.Date.format("MM");
		prefix 			:= prefix &amp; month;
		seqWitoutPrefix := seqWitoutPrefix &amp; month;				//16.11.2023 navma1 #61252
	endif;
	
	if self.idStyle = AutoIdStyle_P_YY_MM_DD_SSS then  
		dd	   			:= app.actualTimeServer.Date.format("dd");
		prefix 			:= prefix &amp; dd;
		seqWitoutPrefix := seqWitoutPrefix &amp; dd;				//16.11.2023 navma1 #61252
	endif;
	
	//23 Jan 2019	NDL	TFS 43018
	if self.resetOnDateChange( serverDate ) then
		// new year, new,month or new Day, may be time to reset the counter.
		seqNum := 1;
	endif;
	
	while true do
		if seqNum.String.length &gt; self.idSeqNumLength then
			// just in case the user has made the seq num length shorter since last time thru,
			// or we have naturally reached the end of the series and need to reset.
			seqNum := 1;
		endif;
		
		seqWitoutPrefix := seqWitoutPrefix &amp; seqNum.String;		//16.11.2023 navma1 #61252
		
		newId := prefix &amp;
				seqNum.String.padLeadingZeros(self.idSeqNumLength) &amp; 
				self.generateCheckDigit(seqWitoutPrefix.Integer64).asStringJMT().String.padLeadingZeros(self.externalRefLength);	// 27.02.2023 navak20 TFS 56769
		
		if self.newExternalRefIdNotAlreadyUsed( newId ) then
			// no object of this type already uses this id.
			break;
		endif;
		
		seqNum := seqNum + 1;
		
		failSafeCount := failSafeCount + 1;
		if failSafeCount &gt; 9 then
			return null;
		endif;
		
	endwhile;
	
	nextSeqNum := seqNum + 1;
	if nextSeqNum.String.length &gt; self.externalRefLength then
		nextSeqNum := 1;
	endif;
	
	return newId;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
