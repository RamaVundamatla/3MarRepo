		write CrLf &amp; CrLf &amp; "output of UC 3 " &amp; CrLf;		
		write (camTaskHistory.getRawDataString().replace(Cr,'').replace(Lf,'').replace(CrLf,'').replace(' ','')&amp; CrLf);
	else
		//we know only one message would be there in the history
