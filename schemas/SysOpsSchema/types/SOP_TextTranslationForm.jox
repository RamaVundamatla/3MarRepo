    <JadeMethod name="setTranslationTableInputType" id="e5d49dd1-2fc1-453c-97e6-3104b740c11c">
        <updating/>
        <source>setTranslationTableInputType(inputType : Integer) updating, protected;

// set table input type (TextBox or None) depending on mode. Note default (NZ English) text can only be updated by developers

vars
	row 	: Integer;
	locale	: CM_Locale;
begin
	if self.myTranslatableText &lt;&gt; null then
		foreach row in tblTranslations.fixedRows + 1 to tblTranslations.rows do
			locale := tblTranslations.accessRow(row).itemObject.CM_Locale;
			
			if locale.localeId &lt;&gt; StandardTextLocaleStr or self.isDeveloperMode then
				tblTranslations.accessRow(row).itemObject := locale;
	
				if self.myTranslatableText.usesShortText then
					tblTranslations.accessCell(row, Col_ShortText).inputType := inputType;
				endif;
				
				tblTranslations.accessCell(row, Col_Text).inputType := inputType;
			endif;
		endforeach;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="inputType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setupDataTables" id="6c22bf17-95be-4f1c-8cd0-cfa9b94ec70d">
        <source>setupDataTables() protected;

// initialisation: set table relationships
// Each sheet &amp; table corresponds to a constant category and collection of translations
// navkc1	11/07/2022	TFS #53916, new ETROW for Table Entities
vars
	table : CM_TextTranslationTable;
	
begin
	tblMessages.initialise(XLAT_Exceptions, shtMessages, self.isDeveloperMode);
	tblFormCaptions.initialise(XLAT_FormCaptions, shtFormCaptions, self.isDeveloperMode);
	tblMenuEntities.initialise(XLAT_Menus, shtMenuEntities, self.isDeveloperMode);
	tblPermissions.initialise(XLAT_Permissions, shtPermissions, self.isDeveloperMode);
	tblReportNames.initialise(XLAT_ReportNames, shtReportNames, self.isDeveloperMode);
	tblTableEnts.initialise(EntTableRows, shtTableEntitys, self.isDeveloperMode);
	
	tblMessages.hideColumnByColName(ETRow_AllTableEntDefs); //#53916, navkc1, "Text messages" and "Table Entities" use the same EntTableDefs. Hide the new ETROW in "Text messages".
	
	// put tables in a collection for easy maintenance
	self.allDataTables.add(tblMessages);
	self.allDataTables.add(tblFormCaptions);
	self.allDataTables.add(tblMenuEntities);
	self.allDataTables.add(tblPermissions);
	self.allDataTables.add(tblReportNames);
	self.allDataTables.add(tblTableEnts);
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="511dfb01-7e1f-441c-ad3c-39ae0206f493">
        <updating/>
        <source>setupForm() updating;
//--------------------------------------------------
// Created:	13 April 2005 By: RBarr
//--------------------------------------------------
/*

Date		Who		Reason
06 Apr 2009	cnwkpd1	PAR #19397 - Enable Add only for main development environment
*/

begin
	self.addRegisteredKey(J_key_E);	// edit
	self.addRegisteredKey(J_key_S);	// save
	self.addRegisteredKey(J_key_X);	// cancel (edit mode) or close (view mode)

	inheritMethod();
	
	self.isDeveloperMode := app.isDevelopmentSystemMain() and app.isSpecial();
	
	self.myRoot := app.myRoot;
	
	create self.myAgent transient;
	self.setupDataTables();

	frmToolbar.alignContainer := Frame.AlignContainer_Top; // this will make the dkcMain line up its top	
	toolbarStyle := ToolbarStyle_ShowNoHide;	
	showToolbar := true;

	mnuClearAllToBeReviewd.visible := false; // this achieves the same as "Set As Reviewed ... All Translations"
	
	self.setFilterDefaults();
	self.setNavigatorHeading(caption);

	beginClassNotification(XLAT_Translation, false, Any_System_Event, Response_Continuous, 0);
	beginClassNotification(XLAT_TranslatableText, false, Any_System_Event, Response_Continuous, 0);
	beginClassNotification(CM_Locale, false, Any_System_Event, Response_Continuous, 0);
	
	self.mode := self.Mode_View;
	
	self.setButtonsEnabled();
	self.displayTranslations();	// init headings
	self.showHideSearcher();
	self.loadWithEntTableDef();
	
	//10 Feb 2015	NDL	Par 33263
	if app.getMyUser.canDo(null,PmAdmTranslationMaint) then
		if self.dkbDetails.height &lt; 100 and self.dkcMain.clientHeight &gt; 200 then
			self.dkbDetails.height := 100;
		endif;
	endif;
	
	if process.isNDLref 
	or global.cnwer1
	then
		self.chkInsensitive.value := true;
	endif;
	
	self.beginNotification(global, EVENT_SPECIAL_USER, Response_Continuous , null); //	JLGAB1 JUN19

end;</source>
    </JadeMethod>
    <JadeMethod name="showAddTranslatableTextForm" id="25e4e57f-c2be-4087-b8af-fef669ae28a6">
        <updating/>
        <source>showAddTranslatableTextForm():Boolean updating, protected;

// not currently supported

vars
	form 	: SOP_NewTextTranslationForm;
	result	: Integer;
	table	: CM_TextTranslationTable;
	
begin
	table := self.zGetTopTable();
	
	create form transient;
	form.myCategory := table.myTranslationCategory;
	form.canChangeCategory := false;
	result := form.showModal();

	self.myTranslatableText := form.myTranslatableText;
	self.mode := self.Mode_View;
	
	
	return result  = IDOK;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
