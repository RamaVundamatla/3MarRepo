    <JadeMethod name="doHighlights" id="2a8ebdfd-472f-4d9e-a1b3-6561f97bcdf4">
        <source>doHighlights() protected;
/*
------------------------------------------------------------------------
Created:			04 August 2004 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	numRows, 	idx : Integer;
	tbl : CM_DataTable;
begin
	tbl := self.tblUpgrades;
	numRows := tbl.rows;
	foreach idx in tbl.fixedRows to numRows do
		if idx mod 2 = 0 then
			tbl.accessRow(idx).backColor := self.colorRow1;
		else
			tbl.accessRow(idx).backColor := self.colorRow2;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadJMT" id="b8d7bb4e-2392-4bea-87ed-a01c8c87f082">
        <updating/>
        <source>doLoadJMT() protected, updating;
/*
------------------------------------------------------------------------
Created:			02 June 2004 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
	tmpTable : CM_DataTable;
	str, detStr, tStr : String;
	array : HugeStringArray;
	detailArray : HugeStringArray;
	section : String;
begin
	app.mousePointer := MousePointer_HourGlass;
	staMain.caption := null;
	self.caption := app.getErrorString(RelView_Terminal_Upgrade);
	tmpTable := self.tblUpgrades;
	tmpTable.rows := 0;	//Clear
	tmpTable.clearSort;
	tmpTable.setColumnHeadingsFromDef(ETDef_JMTTermRelTblData, false);
	
	create array transient;
	create detailArray transient;
	str := currentSchema.getUserAppliedPatches;
	//Now iterate through the string grabbing out the CRLF's
	str.getHugeTokensForDelimiter(Lf, array);
	foreach str in array do
		detailArray.clear;
		//build up an array of the details we get out
		str.replaceChar(',', Tab);
		str.getHugeTokensForDelimiter(Tab, detailArray);
		if detailArray.size = 1 then
			section := detailArray[1];
			section := section[1:section.length-1];	//There is an "unknown char on the end of this, its NOT a tab/cr/or lf!
			continue;
		else
			tStr := null;
			foreach detStr in detailArray do
				if tStr =  null then
					tStr := section &amp; " - " &amp; detStr;
					tStr.removeTabCrLfs();
				else
					tStr := tStr &amp; Tab &amp; detStr.fileBaseName;
				endif;
			endforeach;
		endif;		
		//Load the table
		tmpTable.addItem(tStr);
	endforeach;
	self.doHighlights();
epilog
	delete array;
	delete detailArray;
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadJMTSys" id="ce20c0f7-8100-458e-a1c7-a98c28eb56b3">
        <updating/>
        <source>doLoadJMTSys() protected, updating;
/*
------------------------------------------------------------------------
Created:			02 June 2004 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars

	tmpTable : CM_DataTable;
	str : String;
	array : HugeStringArray;
begin
	app.mousePointer := MousePointer_HourGlass;
	staMain.caption := null;
	self.caption := app.getErrorString(RelView_Terminal_JADE_Up);
	tmpTable := self.tblUpgrades;
	tmpTable.rows := 0;	//Clear
	tmpTable.clearSort;
	tmpTable.setColumnHeadingsFromDef(ETDef_JMTSysRelTblData, false);
	
	create array transient;
	str := currentSchema.getAppliedPatches;
	//Now iterate through the string grabbing out the CRLF's
	str.getHugeTokensForDelimiter(Lf, array);
	foreach str in array do
		str.replaceChar(',', Tab);
		//Load the table
		tmpTable.addItem(str);
	endforeach;
	self.doHighlights();

epilog
	delete array;
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadLogs" id="f53de814-c347-4065-afe5-963d6e26b062">
        <updating/>
        <source>doLoadLogs(_log : CnEcReleaseHistoryMaster) protected, updating;
/*
------------------------------------------------------------------------
Created:			02 June 2004 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
	theHistoryDetail	: CnEcReleaseHistoryDetail;
	tmpTable : CM_DataTable;
	str : String;
begin
	app.mousePointer := MousePointer_HourGlass;
	tmpTable := self.tblUpgrades;
	tmpTable.rows := 0;	//Clear
	tmpTable.clearSort;
	tmpTable.columns := 2;	//Clear
	staMain.caption := null;
	tmpTable.addItem('Date/Time' &amp; Tab &amp; 'Details');
	tmpTable.fixedRows := 1;
	//tmpTable.setColumnHeadingsFromDef(ETDef_JMTReleaseTblData, false);
	self.caption := app.getErrorString(RelView_Terminal_PatchLog);

	if _log = null then
		return;
	endif;		
	//--------------------
	//Get the goodies and load to the table.
	//--------------------
	foreach theHistoryDetail in _log.allDetails do
		str := theHistoryDetail.itemTime.String &amp; Tab &amp; theHistoryDetail.itemText.removeTabCrLfs;
		if str.length &gt; 500 then
			str := str[1:500];
		endif;
		tmpTable.addItem(str);
	endforeach;
 	self.doHighlights();

	staMain.caption := app.getErrorString4(CMUI_SysUpgrades, _log.fullReleasePatchNumber, _log.processStartTime.String,
			_log.processFinishTime.String, app.getYesNo(_log.isCompletedOK));

epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
        <Parameter name="_log" type="CnEcReleaseHistoryMaster"/>
    </JadeMethod>
