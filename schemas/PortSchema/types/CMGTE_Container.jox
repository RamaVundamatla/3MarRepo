    <JadeMethod name="createRequest" id="45784f4c-1de0-4b30-8b97-63dd6bebaf00">
        <updating/>
        <source>createRequest(_passport : CM_Passport input) : Boolean updating ;
// ---------------------------------------------------------------------------
// Created:     25 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpConsignorVoyageCode, tmpEirNumber, tmpConsignee : String;
	theTI : CM_TrackedItem;
	roadJob : CM_RoadJob;
	proxyTIRequest : CM_TIRequest;
begin

	roadJob := self.getVehicleVisitRecord.myRoadJob;

	theTI := self.myTrackedItem;
	
	create proxyTIRequest transient;

	tmpConsignorVoyageCode := theTI.consignorVoyageCode;
	tmpEirNumber := theTI.eirNumber;
	tmpConsignee := theTI.consignee;
	
	proxyTIRequest.setProxy(false, tmpConsignorVoyageCode, tmpEirNumber, // lClean, lconsignorVoyageCode, leirNumber
							tmpConsignee, self.doorsDirection, 
							null, self.freightForwarderCode, null, true, 			//pDeliveryNumber,lFreightForwarderCode, lFreightPayer, lisReceipt
							null,null, 0,null, false, null, false, 				// lISOType, lOperator, lNumRequested, lreasonCode, lHeavy, lMask, lneedCOU,
							false, null, null, false, null, null, null,				// lneedGenerator, lDate, lvoyageCode, lCheckISO, pJob, pinNo, pAVG
							false, null, self.remarks, self.myTrackedItem, // pRemoveStops, pReasonCodeDescr,pRemarks,pTI
							_passport.userCode, null);
								
	if _passport.noErrors() then	
		//Validate the request (TI is already validated)
		proxyTIRequest.validate(_passport.myUser);
	endif;
	
	if _passport.hasErrors() then
		return false;
	endif;

	//Add the request to the job	
	self.myYardRequest := roadJob.addRequest(proxyTIRequest, _passport).CM_YardRequest;
	if _passport.hasErrors() then
		return false;
	endif;
	

	//Add the TI to the job
	roadJob.addTI(self.myTrackedItem, proxyTIRequest);

	return true;
epilog
	delete proxyTIRequest;   // Leak found in unit test
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
