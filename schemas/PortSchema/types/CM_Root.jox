    <JadeMethod name="generateRandomPassword" id="eb1b731b-5317-43d8-b742-b7482ad2593a">
        <source>generateRandomPassword() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Oct 2017	jlger1	Initial creation tfs 7177
22 May 2018	jlgkpd1	TFS 38768 - Remove "confusing" characters from list of valid ones
22 Oct 2025	navlw1	JIRA-36269: Added delete invalidCharPos to epilog as it was missing
*/

vars
	specialChars,
	upperChars,
	lowerChars,
	numChars,
	validChars : String;
	passwordLength : Integer;
	stringSeed		: String;
	seed,
	randomCharPos : Integer;
	randomSeed		: Integer;
	password :String;
	i : Integer;
	minNumeric,
	minUpper,
	minLower,
	minSpecialCharacters: Integer;
	invalidCharPos,
	numPos,upperPos,lowerPos,specialPos : IntegerArray;
begin
	passwordLength:=self.passwordMinLength.max(8);
	upperChars:='ABCDEFGHJKLMNPQRSTUVWXYZ';
	lowerChars:='abcdefghijkmnopqrstuvwxyz';
	numChars:='23456789';
	validChars:=upperChars &amp; lowerChars &amp; numChars;

	minSpecialCharacters:=self.getConfig(MinSpecialChars).Integer;
	minNumeric:=self.getConfig(MinNumberChars).Integer;
	minLower:=self.getConfig(MinLowerChars).Integer;
	minUpper:=self.getConfig(MinUpperChars).Integer;
	if minSpecialCharacters &gt; 0 then
		specialChars:=self.getConfig(SpecialCharacter).String;
	endif;
	create numPos transient;
	create upperPos transient;
	create lowerPos transient;
	create specialPos transient;
	create invalidCharPos transient;
	/// Get a new seed using the last 9 digits of the current machine time (in microseconds)
	stringSeed := app.relativeMachineMicros().String.padZeros(20);
	seed := stringSeed[12:9].Integer;
	i:=1;
	while i &lt;=passwordLength do
		randomCharPos:=app.random31(seed,validChars.length-1) + 1;
		password[i]:=validChars[randomCharPos];
		if minLower &gt; 0 and lowerChars.pos(password[i],1) &gt; 0 then
			lowerPos.add(i);
		elseif minUpper &gt; 0 and upperChars.pos(password[i],1) &gt; 0 then
			upperPos.add(i);
		elseif minNumeric &gt; 0 and numChars.pos(password[i],1) &gt; 0 then
			numPos.add(i);
		elseif minSpecialCharacters &gt; 0 and specialChars.pos(password[i],1) &gt; 0 then
			specialPos.add(i);
		endif;
		i:=i+1;
	endwhile;
	
	if minLower &gt; 0 and  lowerPos.size &lt; minLower   then
		invalidCharPos.joinNonZero(upperPos);
		invalidCharPos.joinNonZero(numPos);
		invalidCharPos.joinNonZero(specialPos);
		app.myRoot.generateRandomPasswordMinChars(minLower,lowerPos,invalidCharPos,lowerChars,password,seed);
	endif;
	
	if minUpper &gt; 0 and upperPos.size &lt;  minLower  then
		invalidCharPos.clear;
		invalidCharPos.joinNonZero(lowerPos);
		invalidCharPos.joinNonZero(numPos);
		invalidCharPos.joinNonZero(specialPos);
		app.myRoot.generateRandomPasswordMinChars(minUpper,upperPos,invalidCharPos,upperChars,password,seed);
		
	endif;
		
	if minNumeric &gt; 0 and numPos.size &lt; minNumeric   then
		invalidCharPos.clear;
		invalidCharPos.joinNonZero(lowerPos);
		invalidCharPos.joinNonZero(upperPos);
		invalidCharPos.joinNonZero(specialPos);
		app.myRoot.generateRandomPasswordMinChars(minNumeric,numPos,invalidCharPos,numChars,password,seed);
	endif;
	
	if minSpecialCharacters &gt; 0 and specialPos.size &lt; minSpecialCharacters  then
		invalidCharPos.clear;
		invalidCharPos.joinNonZero(lowerPos);
		invalidCharPos.joinNonZero(upperPos);
		invalidCharPos.joinNonZero(numPos);
		app.myRoot.generateRandomPasswordMinChars(minSpecialCharacters,specialPos,invalidCharPos,specialChars,password,seed);
	endif;
	
	return password;
epilog
	delete numPos;
	delete upperPos;
	delete lowerPos;
	delete specialPos;
	delete invalidCharPos;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="generateRandomPasswordMinChars" id="dbb381a0-b171-407a-b175-e0f65f255f5f">
        <source>generateRandomPasswordMinChars(	_minChars : Integer;
								_charPos : IntegerArray input;
								_invalidCharPos : IntegerArray;
								_validChars : String;
								_password : String input;
								_randomSeed : Integer  io) ;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 April 2018	jlger1	Initial creation 37829

*/

vars
	randomCharPos,
	i : Integer;
begin
	if _minChars = 0 then
		return;
	endif;
	
	if _charPos.size &gt;= _minChars then
		return;
	endif;
	
	i:=1;
	while i &lt;= _password.length do
		if _invalidCharPos.includes(i)  then
			i:=i+1;
			continue;
		endif;
		
		randomCharPos:=app.random31(_randomSeed,_validChars.length-1) + 1;
		_password[i]:=_validChars[randomCharPos];
		_charPos.add(i);
		if _charPos.size = _minChars then
			break;
		endif;
		i:=i+1;
	endwhile;
epilog

end;</source>
        <Parameter name="_minChars" type="Integer"/>
        <Parameter name="_charPos" type="IntegerArray" usage="input"/>
        <Parameter name="_invalidCharPos" type="IntegerArray"/>
        <Parameter name="_validChars" type="String"/>
        <Parameter name="_password" type="String" usage="input"/>
        <Parameter name="_randomSeed" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAPrinterDefByPhysicalName" id="e40a338c-ff93-4aba-a21a-a8424f773335">
        <source>getAPrinterDefByPhysicalName( _physicalPrinterName : String ) : CM_PrinterDef;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 June 2013	cnwndl1	Initial creation	Par 31598 - Kludgey because there can be multiples...

*/

vars

	printerDef : CM_PrinterDef;
	physicalPrinterName : String;

begin

	physicalPrinterName := _physicalPrinterName;

	foreach printerDef in self.allPrinterDefsByLogicalName do
		if printerDef.physicalPrinterName = physicalPrinterName then
			return printerDef;
		endif;
	endforeach;
	
	return null;
	
epilog

end;</source>
        <Parameter name="_physicalPrinterName" type="String"/>
        <ReturnType type="CM_PrinterDef"/>
    </JadeMethod>
    <JadeMethod name="getActiveWebServiceDef" id="4d0823e5-5bab-4a8d-be13-83e16d1c5b2b">
        <source>getActiveWebServiceDef(_type : String; _terminal : CM_Terminal) : CM_ExternalWebServiceDef;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/12/2022	navdap1		Initial creation TFS 55159 MTN - Export CAMS to JSON API Endpoint
//
vars
	webDef : CM_ExternalWebServiceDef;

begin
	foreach webDef in self.allExternalWebServices discreteLock do
		if not webDef.active then
			continue;
		endif;
		if webDef.getExternalWebServiceType() = _type and webDef.isForTerminal(_terminal) then
			return webDef;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_type" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_ExternalWebServiceDef"/>
    </JadeMethod>
    <JadeMethod name="getAllMatchingStopTables" id="ed678611-f09a-46e9-92e8-69548eb20644">
        <source>getAllMatchingStopTables(
	_requiresInfoType	: Integer;
	_trackedItem		: CM_TrackedItem;		// cnwrl1 13/08/2009 PAR 20466
	_stopTables			: IntegerArray io );

/*

Purpose:	This method will return an IntegerArray of all StopsTable instances
			that have the supplied requiresInfoType and is relevant for the tracked item.

Date				Who		Reason
11 May 2009			cnwrl1	Initial creation as part of PAR 19574 - CCMS 1791
13/08/2009			cnwrl1	PAR 20466 - Changed to make sure the stop is relevant for the tracked item.
*/
	
vars
	stopTable	: CM_StopsTable;
	
begin
	foreach stopTable in self.allAvailableStopsTables discreteLock do : stopTable_loop
		if stopTable.requiresInfoType = _requiresInfoType and
		   stopTable.isStopRelevant( _trackedItem ) then
			_stopTables.add( stopTable.id );
		endif;
	endforeach stopTable_loop;
	
epilog
	
end;
</source>
        <Parameter name="_requiresInfoType" type="Integer"/>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_stopTables" type="IntegerArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllQryReports" id="109d5a15-59c7-40a3-b0b3-5645cf6682a6">
        <source>getAllQryReports(_rptDict : CM_QryReportDict input);
// ---------------------------------------------------------------------------
// Created:     21 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	iter		: Iterator;
	menuItem	: CM_MenuItem;

begin

	_rptDict.clear;
	iter := self.myReportMenuRoot.allMenuItems.createIterator();
	self.myReportMenuRoot.allMenuItems.startKeyGeq(MenuType_DetailSystem, null, iter);
	
	while iter.next(menuItem) do
		if menuItem.type &gt; MenuType_DetailUser then
			break;
		endif;
		if menuItem.isKindOf(CM_QryReport) then
			_rptDict.add(menuItem.CM_QryReport);
		endif;
	endwhile;

epilog
	delete iter;

end;</source>
        <Parameter name="_rptDict" type="CM_QryReportDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllVoyagesInPort" id="6b728b39-1196-4eb4-8ad3-f6f1f712312c">
        <source>getAllVoyagesInPort(_startTS:TimeStamp; _endTS:TimeStamp; _allTerminalsObj:CM_TerminalArray; _allVoyagesObj:CM_VoyageArray input);
// --------------------------------------------------------------------------------
// Created:		27 November 2006 by cnwdad1
//
// Purpose:		Populates an array with all Voyages that are in port at any point in
//				time within the specified date/time range.
//
// Parameters:	_startTS - The start of the date/time range.
//				_endTS - The end of the date/time range.
//				_allTerminalsObj - A reference to an array of Terminals to search.
//					If this array is empty, then all Terminals on the receiver will
//					be searched.
//				_allVoyagesObj - A reference to an array of Voyages to populate.
//
// Returns:		The populated array of Voyages.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 23 Dec 2010	cnwkpd1	PAR #26678 - Tidy up transient leaks
// --------------------------------------------------------------------------------
vars
	terminalObj		: CM_Terminal;
	voyageObj		: CM_Voyage;
	termIteratorObj	: Iterator;
	iteratorObj		: Iterator;
	failedDAC  :CM_DataAccessController;
	
begin
	_allVoyagesObj.clear();
	
	if _allTerminalsObj.isEmpty() then
		termIteratorObj	:=	_allTerminalsObj.createIterator();
	else
		termIteratorObj	:=	self.allTerminals.createIterator();
	endif;
	
	while termIteratorObj.next(terminalObj) do
		if not terminalObj.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then
			continue;
		endif;
		
		iteratorObj	:=	terminalObj.allVoyagesByArrivalDTCode.createIterator();
		
		while iteratorObj.next(voyageObj) do
			if voyageObj.archived or voyageObj.myHMSVoyageData = null then
				continue;
			endif;
			
			if voyageObj.isCancelled then  //jlier1 TFS51963 5/10/21
				continue;
			endif;
		
			if voyageObj.myHMSVoyageData.allVoyageMovements.isEmpty() then
				// Something wrong with this voyage.
				continue;
			endif;
			
			// Voyage arrives after the start date and before the end date.
			if (voyageObj.arrivedDT &gt;= _startTS and voyageObj.arrivedDT &lt;= _endTS)
			
			// Voyage departs after the start date and before the end date.
			or (voyageObj.departedDT &gt;= _startTS and voyageObj.departedDT &lt;= _endTS)
			
			// Voyage arrives before the start date and departs after the end date
			or (voyageObj.arrivedDT &lt;= _startTS and voyageObj.departedDT &gt;= _endTS)
			
			then
				_allVoyagesObj.add(voyageObj);
			endif; 
		endwhile;
		
		delete iteratorObj;
	endwhile;
epilog
	delete termIteratorObj;
	delete iteratorObj;			// PAR #26678
end;</source>
        <Parameter name="_startTS" type="TimeStamp"/>
        <Parameter name="_endTS" type="TimeStamp"/>
        <Parameter name="_allTerminalsObj" type="CM_TerminalArray"/>
        <Parameter name="_allVoyagesObj" type="CM_VoyageArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllVoyagesShippingSchedule" id="fae07b28-1394-43e2-bb36-cf7cdb8ac407">
        <source>getAllVoyagesShippingSchedule(_departedTS:TimeStamp; _scheduledTS:TimeStamp; _allTerminalsObj:CM_TerminalArray; _allVoyagesObj:CM_VoyageArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
15 September 2017	jlgam15	Display all the vessel/voyage info that departed in the last 48 hours, schedules in the next 30 days

*/

vars
	terminalObj		: CM_Terminal;
	voyageObj		: CM_Voyage;
	termIteratorObj	: Iterator;
	iteratorObj		: Iterator;
	failedDAC  		: CM_DataAccessController;
begin
	_allVoyagesObj.clear();
	
	if _allTerminalsObj.isEmpty() then
		termIteratorObj	:=	_allTerminalsObj.createIterator();
	else
		termIteratorObj	:=	self.allTerminals.createIterator();
	endif;
	
	while termIteratorObj.next(terminalObj) do
		if not terminalObj.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then
			continue;
		endif;
		
		iteratorObj	:=	terminalObj.allVoyagesByArrivalDTCode.createIterator();
		
		while iteratorObj.next(voyageObj) do
			if voyageObj.archived or voyageObj.myHMSVoyageData = null then
				continue;
			endif;
							
			// Voyage departed in the last 48 hours
			if (voyageObj.departedDT &lt;= _departedTS)
			
			// Voyage scheduled in the next 30 days
			or (voyageObj.departedDT &lt;= _scheduledTS)
					
			then
				_allVoyagesObj.add(voyageObj);
			endif; 
		endwhile;
		
		delete iteratorObj;
	endwhile;
epilog
	delete termIteratorObj;
	delete iteratorObj;			// PAR #26678
end;</source>
        <Parameter name="_departedTS" type="TimeStamp"/>
        <Parameter name="_scheduledTS" type="TimeStamp"/>
        <Parameter name="_allTerminalsObj" type="CM_TerminalArray"/>
        <Parameter name="_allVoyagesObj" type="CM_VoyageArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getBailOutTime" id="dd099279-2856-42b8-85e4-766b6f45e913">
        <source>getBailOutTime(_startTime : TimeStamp) : TimeStamp;
// ---------------------------------------------------------------------------
// Created:     09 January 2008 by cnwrs2
//
// Purpose:     In Voyage Commodity Planning when iterating to try and
//				find a time the vessel can get through we need a time to stop
//				at.  This is that time.
// ---------------------------------------------------------------------------
vars

begin

	return _startTime.cnEcAddMonths(6);

end;</source>
        <Parameter name="_startTime" type="TimeStamp"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getCalcTypeByNumber" id="4dddb509-a963-4333-b038-6f98f034bb23">
        <source>getCalcTypeByNumber(_calcType : Integer) : CM_CalculationType;
// ---------------------------------------------------------------------------
