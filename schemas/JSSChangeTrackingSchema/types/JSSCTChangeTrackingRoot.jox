    <PrimAttribute name="initiatedTimeStamp" id="a225e92e-e638-4a6a-a1c8-1d567b62f6cb">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="addClassObject" id="1e3b0306-004f-4815-80bd-cf1df8a12cff">
        <lockReceiver/>
        <updating/>
        <source>addClassObject(_classObject: JSSCTChangeTrackingClass; _isDelete: Boolean) lockReceiver, updating;
/*
		Add the object to this collection 
*/
begin
//	on Exception do handleException(exception, _classObject);

	if _isDelete then
		if not self.allDeleteClasses.includes(_classObject) then
			self.allDeleteClasses.add(_classObject);
		endif;
	else
		if not self.allChangeClasses.includes(_classObject) then
			self.allChangeClasses.add(_classObject);
		endif;
	endif;
end;</source>
        <Parameter name="_classObject" type="JSSCTChangeTrackingClass"/>
        <Parameter name="_isDelete" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createEntity" id="e315047f-5798-417d-94a0-865f25a44a1e">
        <updating/>
        <source>createEntity(pChangeTrackingRootTA: JSSChangeTrackingRootTA) updating;
/*
Date		Who		Reason
03 Feb 2011	cnwrs1	PAR #25828 - using up too many licences
*/
constants
	DEFAULT_DAYS_TO_KEEP: Integer = 5;
begin
	self.initiatedTimeStamp := app.actualTimeServer();
//	if pChangeTrackingRootTA.daysToKeepTrackingChanges &gt; 0 then	//par 25828 cnwrs1 3 feb 2011
//		self.daysToKeepTrackingChanges := pChangeTrackingRootTA.daysToKeepTrackingChanges;
//	else
//		self.daysToKeepTrackingChanges := DEFAULT_DAYS_TO_KEEP;
//	endif;
//	self.allChangesByTimeDicts.instantiate();
//	self.allDeletesByTimeDicts.instantiate();
	self.allUpdatesByTransactionIdDict.instantiate();
end;</source>
        <Parameter name="pChangeTrackingRootTA" type="JSSChangeTrackingRootTA"/>
    </JadeMethod>
    <JadeMethod name="delete" id="3d2aa4c6-a1d2-4fb6-9ccf-54815036b6c4">
        <updating/>
        <source>delete() updating;
//
//24 Sept 2013	cnwrs1	CCMS2238 C3 Change Tracker
//
begin
//	self.allChangesByTimeDicts.purge;
//	self.allDeletesByTimeDicts.purge;
	self.allChangeClasses.purge;
	self.allDeleteClasses.purge;
	self.allUsersByIndex.purge;
end;</source>
    </JadeMethod>
    <JadeMethod name="removeClassObject" id="bdfd99e2-f713-4ef4-8896-5caabe3855cc">
        <lockReceiver/>
        <updating/>
        <source>removeClassObject(_classObject: JSSCTChangeTrackingClass; _isDelete: Boolean) lockReceiver, updating;
/*
		Remove the object from this collection AND the collection by oid
*/
begin

	if _isDelete then
		if self.allDeleteClasses.includes(_classObject) then
			self.allDeleteClasses.remove(_classObject);
		endif;
	else
		if self.allChangeClasses.includes(_classObject) then
			self.allChangeClasses.remove(_classObject);
		endif;
	endif;
end;</source>
        <Parameter name="_classObject" type="JSSCTChangeTrackingClass"/>
        <Parameter name="_isDelete" type="Boolean"/>
    </JadeMethod>
