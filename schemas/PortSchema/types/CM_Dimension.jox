    <JadeMethod name="getDisplayStringForAttribute" id="af5b9f48-5e2c-4235-9aac-fce77d15808d">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	lDetail : String;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			if self.myTrackedItem.myCargoType.id = TI_CargoType_Container then
				lDetail := app.getString(Left) &amp; ': ' &amp; self.overLeft.cnEcStripDecimalZeros.asStringJMT() &amp; ' ' &amp; app.getString(Right) &amp; ': ' &amp; self.overRight.cnEcStripDecimalZeros.asStringJMT() &amp; ' ' &amp; app.getString(Front) &amp; ': ' &amp; self.overFront.cnEcStripDecimalZeros.asStringJMT() &amp; ' ' &amp; app.getString(Back) &amp; ': ' &amp; self.overBack.cnEcStripDecimalZeros.asStringJMT() &amp; ' ' &amp; app.getString(Height) &amp; ': ' &amp; self.overHeight.cnEcStripDecimalZeros.asStringJMT();
			else
				lDetail := app.getString(CM_Length) &amp; ': ' &amp; self.length.cnEcStripDecimalZeros.asStringJMT() &amp; ' ' &amp; app.getString(Width) &amp; ': ' &amp; self.width.cnEcStripDecimalZeros.asStringJMT() &amp; ' ' &amp; app.getString(Height) &amp; ': ' &amp;  self.height.cnEcStripDecimalZeros.asStringJMT() &amp; ' ' &amp; app.getString(CM_Volume) &amp; ': ' &amp; self.volume.cnEcStripDecimalZeros.asStringJMT();
			endif;
			
			//04 Nov 2014	NDL	Par 35160
			self.appendReferenceString( lDetail );
			
			return lDetail;
			
		endif;
							
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="dabe4baf-0896-4594-bd66-8b355131b600">
        <source>getEnquiryRow(): String;
//17 December 2009	cnwml2


vars
	str : String;
begin
	str := inheritMethod();
	
	if self.myTrackedItem.myCargoType.id = TI_CargoType_Container then
		str := str &amp; app.getString(Left) &amp; ': ' &amp; self.overLeft.cnEcStripDecimalZeros.asStringJMT() &amp; ' ' &amp; app.getString(Right) &amp; ': ' &amp; self.overRight.cnEcStripDecimalZeros.asStringJMT() &amp; ' ' &amp; app.getString(Front) &amp; ': ' &amp; self.overFront.cnEcStripDecimalZeros.asStringJMT() &amp; ' ' &amp; app.getString(Back) &amp; ': ' &amp; self.overBack.cnEcStripDecimalZeros.asStringJMT() &amp; ' ' &amp; app.getString(Height) &amp; ': ' &amp; self.overHeight.cnEcStripDecimalZeros.asStringJMT();
	else
		str := str &amp; app.getString(CM_Length) &amp; ': ' &amp; self.length.cnEcStripDecimalZeros.asStringJMT() &amp; ' ' &amp; app.getString(Width) &amp; ': ' &amp; self.width.cnEcStripDecimalZeros.asStringJMT() &amp; ' ' &amp; app.getString(Height) &amp; ': ' &amp;  self.height.cnEcStripDecimalZeros.asStringJMT() &amp; ' ' &amp; app.getString(CM_Volume) &amp; ': ' &amp; self.volume.cnEcStripDecimalZeros.asStringJMT();
	endif;
	
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TITransactionCntrl" id="869f8727-5180-429b-823e-201834484ae6">
        <updating/>
        <source>setFromCMIF_TITransactionCntrl(_tiTransCntrl: CMIF_TITransactionController; _passport: CM_Passport input) updating;
//18 December 2009	cnwml2


vars

begin

	if _tiTransCntrl = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _tiTransCntrl. Contact Developer.');
		return;
	endif;
	
	if _tiTransCntrl.myTrackedItem.myCargoType.id = TI_CargoType_Container then
		self.overBack := _tiTransCntrl.myTrackedItem.CM_Container.overLengthRear;
		self.overFront := _tiTransCntrl.myTrackedItem.CM_Container.overLengthFront;
		self.overLeft := _tiTransCntrl.myTrackedItem.CM_Container.overWidthLeft;
		self.overRight := _tiTransCntrl.myTrackedItem.CM_Container.overWidthRight;
		self.overHeight := _tiTransCntrl.myTrackedItem.CM_Container.overHeight;
	else
		self.height := _tiTransCntrl.myTrackedItem.height;
		self.length := _tiTransCntrl.myTrackedItem.length;
		self.width := _tiTransCntrl.myTrackedItem.width;
		self.volume := _tiTransCntrl.myTrackedItem.getMyTotalVolume;
	endif;
	inheritMethod(_tiTransCntrl, _passport);

epilog

end;</source>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
