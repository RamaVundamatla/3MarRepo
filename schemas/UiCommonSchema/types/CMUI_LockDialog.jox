    <JadeMethod name="btnCancel_click" id="6617e7be-bbce-4301-8b91-3574a01ad31a">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;

vars
	
begin
	self.cancelled := true;	
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="checkProgress" id="82f1e3a3-e837-4a7f-9b3d-582d190d5bc8">
        <source>checkProgress() : Boolean;
// ---------------------------------------------------------------------------
// Created:     21 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.refreshNow();
	self.btnCancel.doWindowEvents(0);
	return self.cancelled;

end;</source>
        <ReturnType type="Boolean"/>
