    <JadeMethod name="updateCriteriaValue" id="4134a42f-6a7a-48c4-9f56-3a08f7bbe046">
        <updating/>
        <source>updateCriteriaValue()updating;
/*
Date		Who		Reason
28 February 2012	cnwcs5	Initial creation - par 29158 EDI Booking Cutoff
*/
vars
	obj 	: Object;
	value 	: String;
	oids	: String;
begin
	foreach obj in self.tblAvailable.allSelectedObjects do
		if value &lt;&gt; null then
			value	:= value &amp; ", ";
		endif;
		value	:= value &amp; self.getValue(obj);
	endforeach;
	
	self.criteriaValue := value;
epilog

end;</source>
    </JadeMethod>
