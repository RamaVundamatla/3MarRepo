    </JadeMethod>
    <JadeMethod name="setToDoTaskComplete" id="f7d3a3d5-6b36-4342-9479-adc1fb54a733">
        <updating/>
        <source>setToDoTaskComplete( _toDoTask : CM_TiToDoTask) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
//24/05/2023  navmv20 CR 57925 Task 57921
*/

vars
	nextTask 	: CM_WorkOrderDtl;
	parent	 	: CM_WorkOrderTI;
	doComplete  : Boolean;
	job			: CM_Job;
	wle			: CM_WorkListEntry;
	toDoTask : CM_TiToDoTask;
begin
	
	if _toDoTask = null then
		return;
	endif;
	
	parent := self.myParent.CM_WorkOrderTI;
	
	// remove from available
	if self.allToDoTasks.includes( _toDoTask) then
		toDoTask := _toDoTask;
		toDoTask.setMyWodToDo(null);
		//self.allToDoTasks.remove( _toDoTask);
	endif;		
	
	if self.isFirstTask and parent.taskStatus = WO_STATUS_APPROVED then
		parent.setTaskStatus(WO_STATUS_PARTCOMPLETE);
	endif;

	if self.allToDoTasks.isEmpty then
		self.setStatus(WO_STATUS_COMPLETE);
		if self.isLastTask  then
			self.completeMe();
		endif;
	else
		self.setStatus(WO_STATUS_PARTCOMPLETE);
	endif;

epilog

end;</source>
        <Parameter name="_toDoTask" type="CM_TiToDoTask"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="45b46686-c59e-42f6-9484-fd69aa17ac14">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Mar 2023 navma1	ChangeRequest 57301: EUP - [Framework] - Improve Audits on Work orders

*/

vars
	propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if propName  = CM_WodToDo::autoQueueTask.name
	or propName  = CM_WodToDo::myWorkOrderDetail.name
	or propName  = CM_WodToDo::myToDoTaskDesc.name
	or propName  = CM_WodToDo::priority.name
	or propName  = CM_WodToDo::overrideCalcType.name
	then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
