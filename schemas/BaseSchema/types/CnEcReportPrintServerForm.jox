    <JadeMethod name="btnCancel_click" id="38c6b16c-3641-47c0-af06-4922ab416aa1">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		10 August 2000 by cnwdad1
//
// Changed On Changed By Reason
// ---------- ---------- ----------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	self.doCancelReportQueueEntry(tblQueue);
	self.doCheckErrorStatus(btnStatus, tblQueue);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
