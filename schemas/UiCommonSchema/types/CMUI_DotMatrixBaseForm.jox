    <JadeMethod name="addMultiplePrintLines" id="0f4046ec-26bc-4e2c-b8c4-0bbe44ce4b6d">
        <source>addMultiplePrintLines( tempStrings : CM_StringDict input ) protected;
/*

Purpose:			

Parameters:			Adds a set of test lines for a multi line list.
					should only be called after we have done a test to check that the lines will fit

Return Value:		

Date		Who		Reason
13 November 2012	cnwndl1	Initial creation	Par 30683

*/

vars

	obj : Object;
	strObj : CM_StringWithString;

begin

	foreach obj in tempStrings do
		strObj := obj.CM_StringWithString;
		self.allPrintStrings.add(strObj);
	endforeach;
	
	tempStrings.clear();

epilog

end;</source>
        <access>protected</access>
        <Parameter name="tempStrings" type="CM_StringDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="3b61bd8a-7c1a-4159-be87-1fc229a89ec8">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2012	cnwndl1	Initial creation	Par 30682

*/

vars

	obj : Object;
	label : CMUI_Label;

begin

	self.pixelsPerMM := 756 / 200;

//	self.allLabelsArray.clear();  //belt and braces.
//	self.makeLabelsAvailable();	// select the labels that we are dealing with in the subclassed report

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createAndAddPrintLineDetail" id="8bc34acf-a2bd-4e54-92c9-a396f37e5f97">
        <source>createAndAddPrintLineDetail( _subText : String; _top : Integer; _left : Integer; _attrib : Integer ) protected;
/*

Purpose:			

Parameters:			Adds the one line of text that we are printing to a dictionary in the right order so that all
					'lines' of text can be printed in order. (Don't have to back the printer up)

Return Value:		

Date		Who		Reason
09 November 2012	cnwndl1	Initial creation	Par 30682

*/

vars

	strObj : CM_StringWithString;
	keyString : String;

begin

	//keyString := _top.padLeadingWith("0",4) &amp; _left.padLeadingWith("0",4) &amp; _attrib.padLeadingWith("0",3); //31 Jan 2014	NDL	Par 33181
	keyString := self.getKeyString( _top, _left, _attrib );	//21 July 2014	NDL Par 34611
	create strObj transient;
	strObj.set( keyString, _subText );
	self.allPrintStrings.add(strObj);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_subText" type="String"/>
        <Parameter name="_top" type="Integer"/>
        <Parameter name="_left" type="Integer"/>
        <Parameter name="_attrib" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createOneLineItemLabelText" id="13782a8d-5cee-44c4-8ede-daa8e5d0f206">
        <source>createOneLineItemLabelText(	_label : CMUI_Label; 
							_text : String;
							_top : Integer
							)protected;
/*

Purpose:	Printa as much as possible, but just have one line, and we tell you the top position...		

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2012	cnwndl1	Initial creation	Par 30901

*/

vars

	text : String;
	printWidth : Integer;
	left : Integer;
	subText : String;
	endPos : Integer;
	tmpLeft : Integer;
	printAttrib : Integer;

begin

	text := _text.trimBlanks;
	
	left := ( _label.left ).Integer;
	//31 Jan 2014	NDL	Par 33181
	printAttrib := 0;	
	if _label.fontBold then	
		printAttrib := self.BOLD_Attribute;
	endif;
	endPos := 1;
	while true do
		subText := text[1:endPos];
		if ( subText = text ) or (  _label.getTextExtent( text[1:endPos + 1] ) &gt;= _label.width ) then
			//either we have all of the text selected, or one more character is too much for a line
			///////////////////////////////////////////////
			//get up left alignment
			if _label.alignment.isOneOf( _label.Alignment_Left_Bottom, _label.Alignment_Left_Middle, _label.Alignment_Left_Top ) then
				// Left Align the text
				tmpLeft :=  left;
			elseif _label.alignment.isOneOf( _label.Alignment_Right_Bottom, _label.Alignment_Right_Middle, _label.Alignment_Right_Top ) then
				// Right Align the text
				printWidth := _label.getTextExtent( subText );
				tmpLeft :=  ( ( _label.left.Integer + _label.width.Integer ) - printWidth ).Integer;
			else
				// Centre the text
				printWidth := _label.getTextExtent( subText );
				tmpLeft := ( _label.left + ( (_label.width - printWidth) / 2 ) ).Integer;
			endif;
			///////////////////////////////////////////////
			// create the string object
			self.createAndAddPrintLineDetail( subText, _top, tmpLeft, printAttrib );
			break;
			
		else
			// there is enough width and at least one more character available to print
			endPos := endPos + 1;
		endif;
	endwhile;
		

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_label" type="CMUI_Label"/>
        <Parameter name="_text" type="String"/>
        <Parameter name="_top" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="createTempSubLabelText" id="5c5210e9-3750-4470-b52d-3b7697690d7c">
        <source>createTempSubLabelText(	_label : CMUI_Label input; 
						_text : String;
						_top : Integer io;
						_tempStrings : CM_StringDict input;
						_printAttrib : Integer
						)protected;
/*

Purpose:			

Parameters:		This method creates dummy print data to see if its going to fit when we are doing lists
				such as multi invoice lines in a single label area.	

Return Value:		

Date		Who		Reason
13 November 2012	cnwndl1	Initial creation	Par 30683

*/

vars

	text : String;
	printWidth : Integer;
	printHeight : Integer;
	left : Integer;
	subText : String;
	endPos : Integer;
	
	strObj : CM_StringWithString;
	keyString : String;
	tmpLeft : Integer;
	printAttrib : Integer;
	prevLabelBool : Boolean;

begin

	text := _text;
	printHeight := _label.getTextHeight( "X" );
	//31 Jan 2014	NDL	Par 33181
	printAttrib := 0;
	if _printAttrib &lt;&gt; 0 then
		prevLabelBool := _label.fontBold;
		printAttrib := _printAttrib;
	elseif _label.fontBold then
		printAttrib := self.BOLD_Attribute;
	endif;
	
	left := ( _label.left ).Integer;
	endPos := 1;
	while true do
		subText := text[1:endPos];
		if ( subText = text ) or (  _label.getTextExtent( text[1:endPos + 1] ) &gt;= _label.width ) then
			//either we have all of the text selected, or one more character is too much for a line
			///////////////////////////////////////////////
			//get up left alignment
			if _label.alignment.isOneOf( _label.Alignment_Left_Bottom, _label.Alignment_Left_Middle, _label.Alignment_Left_Top ) then
				// Left Align the text
				tmpLeft :=  left;
			elseif _label.alignment.isOneOf( _label.Alignment_Right_Bottom, _label.Alignment_Right_Middle, _label.Alignment_Right_Top ) then
				// Right Align the text
				printWidth := _label.getTextExtent( subText );
				tmpLeft :=  ( ( _label.left.Integer + _label.width.Integer ) - printWidth ).Integer;
			else
				// Centre the text
				printWidth := _label.getTextExtent( subText );
				tmpLeft := ( _label.left + ( (_label.width - printWidth) / 2 ) ).Integer;
			endif;
			///////////////////////////////////////////////
			// create the dummy string object
			//keyString := _top.padLeadingWith("0",3) &amp; tmpLeft.padLeadingWith("0",3) &amp; _printAttrib.padLeadingWith("0",3);
			//keyString := _top.padLeadingWith("0",4) &amp; tmpLeft.padLeadingWith("0",4) &amp; _printAttrib.padLeadingWith("0",3); process.isNDL;
			keyString := self.getKeyString( _top, tmpLeft, _printAttrib );	//21 July 2014	NDL Par 34611
			create strObj transient;
			strObj.set( keyString, subText );
			_tempStrings.add(strObj);
			///////////////////////////////////////////////
			// set up the next values
			_top := _top + printHeight;
			if subText = text then
				break;
			endif;
			text := text[endPos + 1:end];
			endPos := 1;
		else
			// there is enough width and at least one more character available to print
			endPos := endPos + 1;
		endif;
	endwhile;
		
epilog

	if _printAttrib &lt;&gt; 0 then
		_label.fontBold := prevLabelBool;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_label" type="CMUI_Label" usage="input"/>
        <Parameter name="_text" type="String"/>
        <Parameter name="_top" type="Integer" usage="io"/>
        <Parameter name="_tempStrings" type="CM_StringDict" usage="input"/>
        <Parameter name="_printAttrib" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="delete" id="e0986bd7-bbcf-496f-8162-bd19b2c8e4fd">
        <updating/>
