    <JadeMethod name="clearWagonsFromRake" id="341d4bf5-9ed9-4205-9c8a-98ce8f45c030">
        <updating/>
        <source>clearWagonsFromRake(_trainDepartEvent : CMEVT_TrainTransaction output; _passport : CM_Passport input)updating;
//--------------------------------------------------------------
//Created: 23 February 2004 By: cnwgd1
//16 Dec 2013	cnwrs1	Par 33035 - add CamsDateTime to CM_EventTransaction
//--------------------------------------------------------------
vars
	wagon 	: CM_Wagon;
	iter	: Iterator;
	train : CM_Train;
	rArea : CM_Rail;
	trainDepartEvent : CMEVT_TrainTransaction;
	wagMoveController : CMIF_WagonMoveController;
begin
	iter := self.allWagons.createIterator;
	
	//26 Feb 2021	NDL	TFS 50837
	if self.effectiveTimeStamp.isValid then
		create wagMoveController transient;
		wagMoveController.autoSetEffectiveTimeStamp();
	endif;

	while iter.next(wagon) do
		wagon.departureProcess(wagMoveController, trainDepartEvent); // PAR 19710
		if trainDepartEvent &lt;&gt; null then	//should only be one
			_trainDepartEvent := trainDepartEvent;	//16 Dec 2013	cnwrs1	Par 33035 - add CamsDateTime to CM_EventTransaction
		endif;
		wagon.cleanupAllJobsForRelease(_passport);
		
		if wagon.myRailLine &lt;&gt; null then
			rArea := wagon.myRailLine.myRailArea;
			wagon.myRailLine.removeWagon(wagon);
		endif;
	endwhile; 
		
	if _passport.hasErrors then
		return;
	endif;
	
	//Double check for any rogue jobs
	if self.clearAll then
		self.myRailJSIORake.clearRake(_passport);
	endif;

// PAR 19710	self.allWagons.purge(); We want to keep the wagons on the train
	self.tidyRaiLine(_passport);
	
	if self.myRailArea &lt;&gt; null then
		rArea := self.myRailArea;
	endif;
	
	if rArea &lt;&gt; null then
		rArea.causeEvent(_passport.myTerminal.getTerminalEvent(Rail_Clear_Rake_Event), false,rArea);
	endif;
	//self.myRailArea.causeEvent(_passport.myTerminal.getTerminalEvent(Rail_Clear_Rake_Event), false, self.myRailArea);
			
epilog
	delete iter;
	delete wagMoveController;

end;</source>
        <Parameter name="_trainDepartEvent" type="CMEVT_TrainTransaction" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setEffectiveTimeStampOverride" id="8b238c17-3e21-4ee8-90fc-8189ac413757">
        <updating/>
        <source>setEffectiveTimeStampOverride(newTS : TimeStamp) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 February 2021	navndl1	Initial creation	TFS 50837

*/

vars

begin

	self.effectiveTimeStamp := newTS;

epilog

end;</source>
        <Parameter name="newTS" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setTrainFromWagons" id="b0d7d5b3-a7f9-4408-a74e-aec0238c804c">
        <updating/>
        <source>setTrainFromWagons() updating;
// ---------------------------------------------------------------------------
// Created:     29 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	wagon : CM_Wagon;
begin
	if self.myTrain &lt;&gt; null then
		if not self.allTrains.includes(self.myTrain) then
			self.allTrains.add(self.myTrain);
		endif;
		return;
	endif;
	
	foreach wagon in self.allWagons discreteLock do
		if wagon.myTrainOutwards &lt;&gt; null then
			self.myTrain := wagon.myTrainOutwards;
			
			if not self.allTrains.includes(self.myTrain) then
				self.allTrains.add(self.myTrain);
			endif;
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tidyRaiLine" id="13d0dedd-d7b3-407b-9512-57d0dfb8d750">
        <updating/>
        <source>tidyRaiLine(_passport : CM_Passport input)updating, protected;
//--------------------------------------------------------------
//Created: 04 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	railLine 	: CM_RailLine;
begin
	
	foreach railLine in self.allRailLines do
		exclusiveLock(railLine);
		railLine.tidyWagons();
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validate" id="f37ddb61-fb29-44ff-aa65-ccaf63cf6298">
        <updating/>
        <source>validate(_passport : CM_Passport input)updating;
//--------------------------------------------------------------
//Created: 04 April 2003 By: cnwgd1
//22/08/2023	navkc1	CR 59610 Task 59611: Jade - Stop Prevention
//--------------------------------------------------------------
vars
	warnStr,
	fromPos,
	toPos,
	railLine	: String;
begin

	if self.myTrain &lt;&gt; null then
		
		self.validateJobCompleteTrain(_passport);
		
		if not _passport.hasErrorsOrWarnings() then
			//app.raiseCMWarning4(CONFIRM_CLEAR_OF_RAKE_TRAIN, railLine, fromPos.String, toPos.String, self.myTrain.getCodeDateString(), null, null, self.myTrain);
			
			app.raiseCMWarning1(Pleas_confi_that_want_clear_ra, self.myTrain.getCodeDateString(), null, null, self.myTrain);
		endif;
		
		self.myTrain.validateDepartureProcess(); //22/08/2023	navkc1	CR 59610 Task 59611
		
	else
		if self.myRailArea = null then
		//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(CM_Rail_Area), null, null);
			app.raiseCMException1(Input_required_field_Required, app.getErrorString(CM_Rail_Area), null, null); // cnwdb2	PAR 35364
			return;
		endif;
	
		if self.myRailJSIORake = null and self.myTrain = null then
			app.raiseCMException(Must_have_rail_or_train, null, null);
			return;
		endif;	
	
		if (not self.clearAll) then	
			if self.startPosition = null then
			//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Start_position), null, null);
				app.raiseCMException1(Input_required_field_Required, app.getErrorString(Start_position), null, null); // cnwdb2	PAR 35364
			endif;
			if self.endPosition = null then
			//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(End_position), null, null);
				app.raiseCMException1(Input_required_field_Required, app.getErrorString(End_position), null, null); // cnwdb2	PAR 35364
			endif;
			if self.startPosition &gt; self.endPosition then
				app.raiseCMException(ERR_START_GT_END, null, null);
			endif;
			if self.allRailLines.isEmpty then
				app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(No_Rail_lines_clear) &amp; " " &amp; app.getErrorString(Contact_developer));		
			endif;
		elseif self.allRailLines.size &lt;&gt; self.myRailArea.allRailLines.size then
			app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(Rail_lines_mismatch) &amp; " " &amp; app.getErrorString(Contact_developer));
		endif;									
	
		if self.clearAll then
			fromPos 	:= app.getErrorString(Start);
			toPos		:= app.getErrorString(End);
			railLine	:= app.getErrorString(CM_LIT_ALL);
		else
			fromPos := self.startPosition.String;
			toPos := self.endPosition.String;
			railLine := self.myRailArea.id &amp; ' ' &amp; self.allRailLines.first.id;
		endif;
		
		app.raiseCMWarning3(CONFIRM_CLEAR_OF_RAKE, railLine, fromPos.String, toPos.String, null, null, self.myTrain);
		
		self.validateJobsComplete(_passport);
	endif;
		
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateJobCompleteTrain" id="7582f738-4aae-4153-aa73-76f62df2b050">
        <updating/>
        <source>validateJobCompleteTrain(_passport : CM_Passport input)updating, protected;
//--------------------------------------------------------------
//Created: 04 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	startPos,
	endPos,
	idx : Integer;
	wagon : CM_Wagon;
	job : CM_Job;
	msgStr : String;
begin
	
	self.allWagons.clear();
	
	foreach wagon in self.myTrain.allWagonsByOrderOutward discreteLock do
		idx := idx + 1;
		if wagon = null then
			continue;
		endif;
		sharedLock(wagon);
		
		if app.getMyTerminalConfigDO_NOT_USE(UseOutwardRailConfirm).Boolean and (not wagon.confirmedOutwards) then
			//app.raiseCMException1(Full_Replacement_Message, app.getErrorString1(Wagon_must_be_confirmed, wagon.id), null, null);
			app.raiseCMException1(Wagon_must_be_confirmed, wagon.id, null, null);
			continue;
		endif;
		if (not wagon.confirmed)  then
			continue;
		endif;
		
		if not self.allWagons.includes(wagon) then
			self.allWagons.add(wagon);
		endif;

		foreach job in wagon.allRailJobs do
			exclusiveLock(job);
			//if job.status &lt;&gt; JOB_COMPLETE then
			if job.status &lt;&gt; JOB_COMPLETE and not job.areAllnonCompleteWLEsInTransit then	//11 Nov 2009	NDL Par 21519
				msgStr := msgStr &amp; job.jobId &amp; '; ';					
			endif;
			if (not job.isRelease) and (not job.isTransitJob()) then
				if job.status &lt;&gt; JOB_COMPLETE then
					app.setContinueCMExceptions(false);
					app.raiseCMException1(VB_UNACTIONED_RECEIPT, job.jobId, null, null);
					return;
				endif;
			endif;				
		endforeach; 	
	endforeach;
	
	self.warningMessage := msgStr;	
	
	if self.warningMessage &lt;&gt; null then
		app.raiseCMException2(Follo_jobs_have_been_compl_can, self.warningMessage,self.myTrain.code, null,  self.myRailArea);
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateJobsComplete" id="4cee6885-4013-4824-8dd4-a6ff6bfce3d3">
        <updating/>
        <source>validateJobsComplete(_passport : CM_Passport input)updating, protected;
//--------------------------------------------------------------
//Created: 04 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	railLine: CM_RailLine;
begin
	
	self.allWagons.clear();
	
	foreach railLine in self.allRailLines do
		if self.clearAll then
			self.endPosition := railLine.maximumWagons;
		endif;
		railLine.setRakeRegionDataToClear(self);
	endforeach;

 	// Allow them to clear part of a rake, but warn that not all the 
 	// outward jobs are completed yet. They can always return them to build priority
	if self.warningMessage &lt;&gt; null then
		app.raiseCMWarning1(RAKE_UNACTIONED_JOBS, self.warningMessage, null, null, self.myRailArea);
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
