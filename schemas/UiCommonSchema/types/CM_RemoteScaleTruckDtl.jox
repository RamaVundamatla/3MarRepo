<Class name="CM_RemoteScaleTruckDtl">
    <JadeMethod name="loadRemoteTable" id="c8d54f16-a397-482c-8f43-f85878b8a7df">
        <updating/>
        <source>loadRemoteTable(_table: CM_EntryTable io) updating;

vars

	extra	: CM_RemoteDataExtra;

begin

	inheritMethod(_table);
	_table.setColumnHeadings('Item', 'Value');
	self.addRemoteRow(_table, 'Docket ID', self.docketId, null);
	self.addRemoteRow(_table, 'Scaler Code', self.scalerCode, null);
	self.addRemoteRow(_table, 'Scaling Time', self.startTime, null);
	self.addRemoteRow(_table, 'Finish Time', self.finishTime, null);
	self.addRemoteRow(_table, 'Supplier', self.supplier, null);
	foreach extra in self.allRemoteDataExtra do
		self.addRemoteRow(_table, 'Scaled Item ' &amp; extra.CM_RemoteScalingExtra.id, Click, extra);
	endforeach;
	

end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="io"/>
    </JadeMethod>
</Class>
