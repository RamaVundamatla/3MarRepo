    <JadeMethod name="getDictForTIState" id="61351dcb-1334-4dfd-ab9f-f0858e3ef900">
        <source>getDictForTIState(_state : Integer; _haveId : Boolean) : Collection;
// ---------------------------------------------------------------------------
// Created:     20 June 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if _state = TI_STATE_NORMAL then 
		if _haveId then
			return self.allOnsiteTIsByIdCargoType;
		else
			return self.allOnsiteTIsByCargoTypeId;
		endif;
	elseif _state = TI_STATE_NOTIFIED then
		if _haveId then
			return self.allNotifiedTIsByIdCargoType;
		else
			return self.allNotifiedTIsByCargoTypeId;
		endif;
	elseif _state = TI_STATE_TBA then 
		if _haveId then
			return self.allTbaTIsByIdCargoType;
		else
			return self.allTbaTIsByCargoTypeId;
		endif;
	elseif _state = TI_STATE_PLACEHOLDER then	//13 Mar 2020	NDL	TFS 47004 
		if _haveId then
			return self.allRRPTIsByIdCargoType;
		else
			return self.allRRPTIsByCargoTypeId;
		endif;
	elseif _state = TI_STATE_DELETED then 
		if _haveId then
			return self.allDeletedTIsByIdCargoType;
		else
			return self.allDeletedTIsByCargoTypeId;
		endif;
	elseif _state = TI_STATE_OFFLOADED then
		if _haveId then
			return self.allOffloadedTIsByIdCargoType;
		else
			return self.allOffloadedTIsByCargoTypeId;
		endif;

	elseif _state = TI_STATE_ONSHIP then
		if _haveId then
			return self.allOnshipTIsByIdCargoType;
		else
			return self.allOnshipTIsByCargoTypeId; // AKB2002SEP was below
		endif;
	else
		if _haveId then
			return self.allOffsiteTIsByIdCargoType;
		else
			return self.allOffsiteTIsByCargoTypeId;
		endif;
	endif;
	
	return null;

end;</source>
        <Parameter name="_state" type="Integer"/>
        <Parameter name="_haveId" type="Boolean"/>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="getDischargeMoveCount" id="c9b37e7d-87cd-4a6c-96d7-52f2ab91ed0b">
        <source>getDischargeMoveCount() : Integer;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2012	cnwdw1	Initial creation
*/
vars
	count : Integer;
	aJS : CM_JobSheet;
begin
	foreach aJS in self.allJobSheets discreteLock do
		count := count + aJS.CM_VoyageJobSheet.allShipReceivals.size;
	endforeach;
	return count;
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDischargePortForTranship" id="025cb437-479d-4449-9898-c29af2ea6ee9">
        <source>getDischargePortForTranship(_transhipPort : CM_Port) : CM_Port;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 March 2010	cnwas3	pae 23043

*/

vars
	portRotation : CM_PortRotation;
begin

	foreach portRotation in self.allPortRotations do
		if portRotation.allTranshipPorts.includes(_transhipPort) then
			return portRotation.myPort;
		endif;
	endforeach;
	return null;
end;</source>
        <Parameter name="_transhipPort" type="CM_Port"/>
        <ReturnType type="CM_Port"/>
    </JadeMethod>
    <JadeMethod name="getDischargePortOrdinal" id="195c3f88-62cb-4e39-8730-ba4f67d0271c">
        <source>getDischargePortOrdinal(port : String) : Integer;
// ---------------------------------------------------------------------------
// Created:     17 January 2017 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	numPorts, ordinal : Integer;
	portObj : CM_Port;
begin
		
	numPorts := self.allPorts.size();
		
	foreach portObj in self.allPorts discreteLock do
		ordinal := ordinal + 1;
		if (portObj.code = port) then
			return (numPorts - ordinal) + 1;
		endif;
	endforeach;

	return 1;
epilog

end;</source>
        <Parameter name="port" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="501f285c-1081-4810-aa7e-dc8948af4868">
        <source>getDisplayDetails(_short : Boolean): String;
// ---------------------------------------------------------------------------
// Created:     22 March 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//06 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
// ---------------------------------------------------------------------------

vars

begin

	if _short then
		return self.code;
	else
		return self.code &amp; ' ' &amp; self.description;
	endif;

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="f2b8523b-d5ef-470f-b08e-ff3896d94acd">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
/* Changes

Date		Name	TFS#		Description
============================================================================
08/03/2011	cnwmh5	PAR #27142  	Change to local variable rather than self for handleDeleteObject exception
27 Mar 2013	PJS		PAr # 31232
05/03/2015	cnwdap1	PAR #35826 	   
					CCMS SFW 1410	Added expected arrival/departure date/time
18/04/2017	cnwdap1	TFS 4050 		LNX Job ID Enhancements
20/03/2018	jlgdap1	TFS 37540 		PEl1 Voyage Statuses Pelindo 1
04/06/2019	jlgka1	TFS 44772		LNX - Changing Berth and having the Voyage Enquiry screen display updated Berth.
03/06/2020  cnwma1  TFS 49400	    ASPA - Invoice Enhancements for Barges
01/10/2021	jlizm1	TFS 51963 		SAL Voyage Request Changes
09/03/2022	jlizm1	TFS 52834 		SAL file attachments filter by work order
16.06.2022 navsrk20 Bug 52514		MTN - Voyage Process Issue Bulk Create Of Barge
30/06/2022	navdap1	TFS 53362 		EUP Master Data Interface Customers Between TOS and ERP
27/09/2023	navkc1	CR 60428 		Task 60701: UI - Customs Status on Transport UI
26/11/2024	navdap1	MTN-33516 		NSW | OnePort - Voyage Already Exists With External Code Error
============================================================================*/
vars
	invalidObj 		 : Boolean;
	dischargeCompany : CM_Bank;
	date 			 : Date;
	voyStatus 		 : CM_VoyageStatus;					// TFS 37540
	woDtl 			 : CM_WorkOrderDtl;					// TFS 51963
	count 			 : Integer;							// TFS 52834
begin
	if _attrName = ETRow_Name then
		if self.vesselName &lt;&gt; null then
			return self.vesselName.trimBlanks;
		else
			return self.code.trimBlanks;
		endif;
	elseif _attrName = ETRow_ExternalRef then // PAR 36155
		return self.externalRef;
	elseif _attrName = ETRow_GeneralRemarks then  // ### TFS 51923 08SEP2021 NAVAB1
		if self.myHMSVoyageData &lt;&gt; null then // ### TFS 51923 08SEP2021 NAVAB1
			return self.myHMSVoyageData.remarksGeneral; // ### TFS 51923 08SEP2021 NAVAB1
		else
			return self.remarks;  // ### TFS 51923 08SEP2021 NAVAB1
		endif;
		
	elseif _attrName = ETRow_DepartTargetDT then
		return self.systemToLocalTime(self.departTargetDT).date.shortFormatJMT();	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_DepartTargetTM then
		return self.systemToLocalTime(self.departTargetDT).time.shortFormatJMT();	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_PilotOnBoardDate then
		return self.systemToLocalTime(self.pilotOnBoardDT).date.shortFormatJMT();	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_PilotOnBoardTime then
		return self.systemToLocalTime(self.pilotOnBoardDT).time.shortFormatJMT();	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_LabourOnBoard then
		return self.systemToLocalTime(self.labourOnBoard).date.shortFormatJMT();	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_LabourOnBoardTime then
		return self.systemToLocalTime(self.labourOnBoard).time.shortFormatJMT();	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_LabourOnShore then
		return self.systemToLocalTime(self.labourOnShore).date.shortFormatJMT();	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_LabourOnShoreTime then
		return self.systemToLocalTime(self.labourOnShore).time.shortFormatJMT();	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_ShipExchangeDate then
		return self.systemToLocalTime(self.shipExchangeDate).date.shortFormatJMT();	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_ShipExchangeTime then
		return self.systemToLocalTime(self.shipExchangeDate).time.shortFormatJMT();	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_ShipExchangeCompleteDate then
		return self.systemToLocalTime(self.shipExchangeCompleteDT).date.shortFormatJMT();	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_ShipExchangeCompleteTime then
		return self.systemToLocalTime(self.shipExchangeCompleteDT).time.shortFormatJMT();	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_MyHMSVesselType then
		if self.myHMSVoyageData &lt;&gt; null then
			return self.myHMSVoyageData.getDisplayStringForAttribute(ETRow_MyHMSVesselType, _short);
		else
			return null;
		endif;
	elseif _attrName = ETRow_MyTerminal then
		return self.myTerminal.getDisplayDetails(true);
	elseif _attrName = ETRow_Arrival then
		return self.systemToLocalTime(self.arrivedDT).date.shortFormatJMT();	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_CreationDate then
		return self.systemToLocalTime(self.createdTime).shortCurrentLocaleFormat();	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_Arrives
	or _attrName = ETRow_Eta then
		return self.systemToLocalTime(self.arrivedDT).shortCurrentLocaleFormat();	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_Departs
	or _attrName = ETRow_Etd then
		return self.systemToLocalTime(self.departedDT).shortCurrentLocaleFormat();	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_ArriveDT then
		return self.systemToLocalTime(self.arrivedDT).shortCurrentLocaleFormat();	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_DepartDT then
		return self.systemToLocalTime(self.departedDT).shortCurrentLocaleFormat();	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_ArriveTM then
		return self.systemToLocalTime(self.arrivedDT).Time.currentLocaleFormatJMT();	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_DepartTM then
		return self.systemToLocalTime(self.departedDT).Time.currentLocaleFormatJMT();	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_ShipType
	or _attrName = ETRow_Pilots
	or _attrName = ETRow_Agents
	or _attrName = ETRow_Drafts then
		if self.myHMSVoyageData &lt;&gt; null then
			return self.myHMSVoyageData.getDisplayStringForAttribute(_attrName, _short);
		endif;
		
		return 'N/A';
	elseif _attrName = ETRow_MyTrade then
		if self.myTrade &lt;&gt; null then
			return self.myTrade.description.asStringJMT();
		endif;
	elseif _attrName = ETRow_ShippingLine then
		if self.myShippingLine &lt;&gt; null then
			return self.myShippingLine.description;
		else
			return 'N/A';
		endif;
	elseif _attrName = ETRow_VoyageType then
		return self.getVoyageTypeString();
	elseif _attrName = ETRow_MyVoyageGlobal then
		if self.myVoyageGlobalArrival &lt;&gt; null then
			return self.myVoyageGlobalArrival.code;
		endif;
		
		return null;
	elseif _attrName = ETRow_CreateShipLineStructures then
		//epr par 22944 18/3/10
		return (self.myCellularVoyageStructure &lt;&gt; null).asStringJMT; 
	elseif _attrName = ETRow_VoyagePlanningCode then
		//epr par 22944 18/3/10
		if self.myVoyagePlanningCode &lt;&gt; null then
			return self.myVoyagePlanningCode.code.asStringJMT;
		endif;	
		return null;
	elseif _attrName = ETRow_APRecMoveMap then
		//epr par 22944 18/3/10
		if self.myMMReceival &lt;&gt; null then
			return self.myMMReceival.id.asStringJMT;
		endif;
		return null;
	elseif _attrName = ETRow_APRelMoveMap then
		//epr par 22944 18/3/10
		if self.myMMRelease &lt;&gt; null then
			return self.myMMRelease.id.asStringJMT;
		endif;
		return null;
	elseif _attrName = ETRow_Bank then
		on Exception do app.handleDeletedObject(exception,dischargeCompany,invalidObj);
		//epr par 22944 18/3/10
		dischargeCompany := self.myDischargeCompany; 
		if dischargeCompany &lt;&gt; null then //and not invalidObj then
			return self.myDischargeCompany.code;
		endif;
		return null;
	elseif _attrName = ETRow_BridgeAfterBay or
		_attrName = ETRow_ISOVessel or
		_attrName = ETRow_Use40Id or
		_attrName = ETRow_NumberOfHolds or
		_attrName =	ETRow_StowageNumbering or
		_attrName =	 'stowageNumbering' then
		//epr par 22944 18/3/10
		if self.myCellularVoyageStructure &lt;&gt; null then
			return  self.myCellularVoyageStructure.getDisplayStringForAttribute(_attrName,_short);
		endif;
		
		return null;
		
	elseif 	_attrName = ETRow_VisitType then
		if self.myHMSVoyageData &lt;&gt; null then 
			if self.myHMSVoyageData.myVisitType &lt;&gt; null then 
				return self.myHMSVoyageData.getDisplayStringForAttribute(_attrName, _short);
			endif;
		endif;
		return null;
	elseif _attrName = ETRow_CraneClearance then
	//epr par 22944 18/3/10
		return self.craneClearance.zeroNotAllowed;
	elseif _attrName = ETRow_StarboardBerthed
	or _attrName = ETRow_Side then
		if self.starboardBerthed then
			return "Starboard Berthed";
		else
			return "Port side to";
		endif;
	elseif _attrName = ETRow_VesselType then
		return self.getVesselTypeDescr();
	//jlgka1 TFS 44772 --&gt;
	elseif _attrName = ETRow_MyCurrentBerth then		
		if self.getMyCurrentBerth &lt;&gt; null then
			return self.getMyCurrentBerth.getDisplayDetails(_short);
		else
			return null;
		endif;
	//jlgka1 TFS 44772 &lt;--	
	elseif _attrName = ETRow_MyBerth
	or _attrName = ETRow_BerthPriority
	or _attrName = ETRow_ToBerthPreference
	or _attrName = ETRow_MyVesselCategoryIn
	or _attrName = ETRow_MyVesselCategoryOut	
	or _attrName = ETRow_PortDepartingToCode	
	or _attrName = ETRow_PortArrivingFromCode
	or _attrName = ETRow_CargoToDischarge
	or _attrName = ETRow_CargoToLoad
	or _attrName = ETRow_CountryCode
	or _attrName = ETRow_CoastalServiceVessel
	or _attrName = ETRow_ExcludeReport
	or _attrName = ETRow_EstTieUpTime
	or _attrName = ETRow_HasBowThrust
	or _attrName = ETRow_HasSternThrust
	or _attrName = ETRow_HasHoldTanks
	or _attrName = ETRow_HasRamp
	or _attrName = ETRow_HasFixedProp
	or _attrName = ETRow_IsPilotExempt
	or _attrName = ETRow_MyTidalClassArrival
	or _attrName = ETRow_MyTidalClassDept
	or _attrName = ETRow_MyShippingAgent
	or _attrName = ETRow_MyLineCompany
	or _attrName = ETRow_MyVesselType
	or _attrName = ETRow_NumTugsIn
	or _attrName = ETRow_NumTugsOut
	or _attrName = ETRow_NumLCrewLetGo
	or _attrName = ETRow_NumLCrewTieUp
	or _attrName = ETRow_ProcessingStatus
	or _attrName = ETRow_TripReference
	or _attrName = ETRow_Dockage
	or _attrName = ETRow_MyPortFrom
	or _attrName = ETRow_LastPort
	or _attrName = ETRow_MyPortTo 
	or _attrName = ETRow_LengthOverall 
	or _attrName = ETRow_GrossRegTonnes
	or _attrName = ETRow_NetRegTonnes		// 30680 CCMS QNS 2178
	or  _attrName = ETRow_DeadWeight 
	or _attrName = ETRow_Beam 
	or _attrName = ETRow_DraftFore 
	or  _attrName = ETRow_DraftAft 
	or _attrName = ETRow_BridgeToBow 
	or  _attrName = ETRow_BridgeToStern 
	or _attrName = ETRow_BowToFwdBay 
	or _attrName = ETRow_SternToAftBay 
	or _attrName = ETRow_SternToBunker
	or _attrName = ETRow_FirstRealBerth	//09 Oct 2012	NDL	Par 30490
	then
		if self.myHMSVoyageData &lt;&gt; null then
			return self.myHMSVoyageData.getDisplayStringForAttribute(_attrName, _short);
		endif;
		
		return null;
	elseif _attrName = ETRow_CreateHMSData then
		return app.getYesNo(self.myHMSVoyageData &lt;&gt; null);
	elseif _attrName = ETRow_IsNonPlannedVoyage then
		return ""; // PAR 33644 (not self.isNonPlannedVoyage).String;
	elseif _attrName = ETRow_IsNonWorkedVoyage then
		return  ""; // PAR 33644 (not self.isNonWorkedVoyage).String;
	elseif _attrName = ETRow_NonPlannedEffectiveDate then
		if self.nonPlannedEffectiveDT.isValid then
			return self.systemToLocalTime(self.nonPlannedEffectiveDT).date.shortFormatJMT();	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support
		else
			return null;
		endif;
	elseif _attrName = ETRow_NonPlannedEffectiveTime then
		if self.nonPlannedEffectiveDT.isValid then
			return self.systemToLocalTime(self.nonPlannedEffectiveDT).time.currentLocaleFormatJMT();	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support
		else
			return null;
		endif;
	elseif _attrName = ETRow_EffectiveDT then
		if self.nonPlannedEffectiveDT.isValid then
			return self.systemToLocalTime(self.nonPlannedEffectiveDT).shortCurrentLocaleFormat();	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support
		else
			return null;
		endif;
	elseif _attrName = ETRow_AirDraft then
		return self.airDraft.asStringJMT;
	elseif _attrName = ETRow_MaxVoyageBeam then
		return self.maxVesselBeam.asStringJMT;
	elseif _attrName = ETRow_DraftBow then
		return self.draftBow.asStringJMT;
	elseif _attrName = ETRow_DraftMid then
		return self.draftMid.asStringJMT;
	elseif _attrName = ETRow_DraftStern then
		return self.draftStern.asStringJMT;
	elseif _attrName = ETRow_BuildingLine then
		return self.buildingLine.asStringJMT;
	elseif _attrName = ETRow_LoaWithRampsDown then
		return self.loaWithRampsDown.asStringJMT;
	elseif _attrName = ETRow_LoadRate then		//	Aug 2011	cnwjre1		CCMS 1120 Par 28082 Log voyage operations changes
		return self.loadRate.asStringJMT;
		// 31232
	elseif _attrName = ETRow_IncludesLOLO then
		return self.structureIncludesLOLO.asStringJMT();
	elseif _attrName = ETRow_IncludesRORO then
		return self.structureIncludesRORO.asStringJMT();
	elseif _attrName = ETRow_IncludesHolds then
		return self.structureIncludesHolds.asStringJMT();
		
	elseif _attrName = ETRow_ExpectedArrivalDT then								// PAR #35826
		if self.estimatedArrivalDT.isValid then									// PAR #35826
			return self.systemToLocalTime(self.estimatedArrivalDT).shortCurrentLocaleFormat();			// PAR #35826	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support
		else																	// PAR #35826
			return null;														// PAR #35826
		endif;																	// PAR #35826
	elseif _attrName = ETRow_ExpectedDepartureDT then							// PAR #35826
		if self.estimatedDepartureDT.isValid then								// PAR #35826
			return self.systemToLocalTime(self.estimatedDepartureDT).shortCurrentLocaleFormat();			// PAR #35826	// 21/4/16 cnwmp6 TFS 488 - Multi timezone support
		else																	// PAR #35826
			return null;														// PAR #35826
		endif;																	// PAR #35826
		
	elseif _attrName = ETRow_FileAttachments then	// TFS 52834
		count := self.getNumFiles();				// TFS 52834
		if count &gt; 0 then							// TFS 52834
			return count.asStringJMT();				// TFS 52834
		else
			return null;							// TFS 52834
		endif;
		
	elseif _attrName = ETRow_GenLandingDate then		//15 Mar 2016	NDL	TFS 1407
		date := self.getGeneralLandingDate(true);
		if date.isValid then
			return date.shortFormatJMT();
		endif;
		return null;
		
	elseif  _attrName = ETRow_RejectReason then				// TFS 51963
		woDtl := self.allWorkOrders.getWODDetailOfTypeStatus(WO_TASK_NEWVOYAGE, WO_STATUS_NOTAPPROVED);	// TFS 51963
		if woDtl &lt;&gt; null and woDtl.myParent &lt;&gt; null then	// TFS 51963
			return woDtl.myParent.remarks;					// TFS 51963
		endif;
		return null;
		
	//elseif _attrName = ETRow_VoyageExternalCode then		// TFS 4050		//MTN-11756 (TFS 66169) - Added below
	//	return self.voyageCodeExternal;						// TFS 4050		//MTN-11756 (TFS 66169)
		
	elseif _attrName = ETRow_Status then							// TFS 37540
		voyStatus := app.myRoot.allVoyageStatuses[self.status];		// TFS 37540
		if voyStatus &lt;&gt; null then									// TFS 37540
			return voyStatus.description;							// TFS 37540
		endif;														// TFS 37540
		return self.status.String;									// TFS 37540
	
	elseif _attrName = ETRow_VoyageProcess then	//22 Jan 2019	NDL	TFS 42996
		if self.myVoyageProcess = null then
			//Start 16.06.2022 navsrk20 52514
			return app.getErrorString(Unknown);
			/*if CM_VoyageProcessDefault.firstInstance = null then
				return app.getErrorString(CM_Default);
			else
				return CM_VoyageProcessDefault.firstInstance.description;
			endif;*/
			//End 16.06.2022 navsrk20 52514
		else
			return self.myVoyageProcess.description;
		endif;
	elseif _attrName = ETRow_VoyageGroupCode then //03/06/2020 cnwma1 Bug #49400
		return self.voyageGroupCode;
	elseif _attrName = ETRow_CargoForecast then		//Apr 19, 2022 TFS #53142 
		return self.getCargoForecastStr();			//Cargo Forecast Form
	elseif _attrName = ETRow_MyOperator and app.myRoot.getConfig(ComboByNameOperator).Boolean then	// TFS 53362
		if self.myOperator &lt;&gt; null then
			return self.myOperator.description;
		endif;
	elseif _attrName = ETRow_CustomStatus then 
		return self.getCustomStatus(); //27/09/2023	navkc1	CR 60428 Task 60701
	// TFS 63839
	elseif _attrName = ETRow_InwardCode then
		//if self.isAutomaticProcess then		//MTN-11756 (TFS 66169)			// MTN-33516
		if self.myTerminal.getConfig(AllowDupVoyageInOutCodes).Boolean then		// MTN-33516
			return self.inwardCodeAuto;			//MTN-11756 (TFS 66169)
		else									//MTN-11756 (TFS 66169)
			return self.inwardCode;				//MTN-11756 (TFS 66169)
		endif;									//MTN-11756 (TFS 66169)
	elseif _attrName = ETRow_VoyageExternalCode then
		//if self.isAutomaticProcess then			//MTN-11756 (TFS 66169)		// MTN-33516
		if self.myTerminal.getConfig(AllowDupVoyageInOutCodes).Boolean then		// MTN-33516
			return self.voyageCodeExternalAuto;	//MTN-11756 (TFS 66169)
		else									//MTN-11756 (TFS 66169)
			return self.voyageCodeExternal;		//MTN-11756 (TFS 66169)
		endif;									//MTN-11756 (TFS 66169)
	// TFS 63839 end
	else
		return inheritMethod(_attrName, _short);
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDownHoursForTsRange" id="61ccbcf8-1742-4537-b6c1-733b46fc3211">
        <source>getDownHoursForTsRange( _craneWorkPointId : String; _startTS : TimeStamp; _endTS : TimeStamp ):Decimal;


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 April 2012	cnwndl1	Initial creation	Par 29369

*/

vars

	opHrs : CM_WorkPointOperatingHours;
	opHrsSet : CM_WorkPointOperatingHoursSet;
	downTimeInterval : TimeStampInterval;
	minutesDown : Integer;
	hours : Decimal [8,2];
	minuteUpArray : BooleanArray;
	minuteInterval : TimeStampInterval;
	workTimeStamp : TimeStamp;
	index : Integer;

begin

	if not _startTS.Date.isValid
	or not _endTS.Date.isValid
	or not self.includesWPOpHrsFor( _craneWorkPointId )	//we are not using Work Point Operating Hours for this voyage/crane
	then
		return 0;
	endif;
	
	// get a collection of CM_WorkPointOperatingHours for the associated crane that overlap the range.
	create opHrsSet transient;
	self.getWPOpHrsInTSRangeFor( opHrsSet, _craneWorkPointId, _startTS, _endTS );
	
	downTimeInterval := null;
	if opHrsSet.isEmpty then
		// we are down for the entire period.
		downTimeInterval := _endTS - _startTS;
		minutesDown := downTimeInterval.asMinutes().Integer;
		
	else
		create minuteUpArray transient;
		minuteInterval.set(0,60000);  // one minute.
		workTimeStamp := _startTS;
		index := 1;
		//prefil minute array with false for every minute of the period.
		while true do
			if workTimeStamp &gt;= _endTS then
				break;
			endif;
			minuteUpArray[index] := false;
			workTimeStamp := workTimeStamp + minuteInterval;
			index := index + 1;
		endwhile;
		
		if not minuteUpArray.isEmpty then
			foreach opHrs in opHrsSet do
				opHrs.applyMinutesUp( minuteUpArray, _startTS, _endTS );
			endforeach;
		endif;
		
		foreach index in 1 to minuteUpArray.size do
			if not minuteUpArray[index] then
				minutesDown := minutesDown + 1;
			endif;
		endforeach;
		
	endif;
	
	if minutesDown &gt; 0 then
		hours := minutesDown / 60;
	endif;
	
	return hours;

epilog

	delete opHrsSet;
	delete minuteUpArray;

end;</source>
        <Parameter name="_craneWorkPointId" type="String"/>
        <Parameter name="_startTS" type="TimeStamp"/>
        <Parameter name="_endTS" type="TimeStamp"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getEDIMessageCode" id="3e0e07f4-85f6-4420-9139-54f4e46799f9">
        <source>getEDIMessageCode(): String;
//----------------------------------------------------------------
//	Created:	01 December 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	portCode		: String;
	str : String;
begin
	portCode := self.myTerminal.getConfig(PortDestCode).String;
	str := self.callSign.trimBlanks &amp; self.code.trimBlanks &amp; portCode.trimBlanks;
	return str[1:14]; //cnwrs1 par 15044 oct 2007
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEarliestCutoffDT" id="9b470cce-ff7b-4056-bbe5-d0b9e038ce4e">
        <source>getEarliestCutoffDT() : TimeStamp;
//
//09 Nov 2016	cnwrs1	TFS 2933 MSL SQL Extract
//
vars
	earliestCutoffDT : TimeStamp;
	recCutoff : CM_ReceivalCutoffVoyage;
begin
	earliestCutoffDT := null;
	foreach recCutoff in self.allReceivalCutoffs do
		if recCutoff.cutoffDateTime &lt;&gt; null then
			if earliestCutoffDT = null then
				earliestCutoffDT := recCutoff.cutoffDateTime;
			else
				if recCutoff.cutoffDateTime &lt; earliestCutoffDT then
					earliestCutoffDT := recCutoff.cutoffDateTime;
				endif;
			endif;
		endif;
	endforeach;
	return earliestCutoffDT;
end;
</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getEarliestCutoffPreNoteDT" id="cdebcc04-ca11-4393-b6af-6b5eed48c8a7">
        <source>getEarliestCutoffPreNoteDT() : TimeStamp;
/*
//04/03/2025	navkc1 JIRA Story MTN-34227: MTN | Prenote Voyage Cut Offs - TRX Code changes for Prenote Cutoffs
*/
vars
	earliestCutoffPreNoteDT : TimeStamp;
	recCutoff : CM_ReceivalCutoffVoyage;
begin
	earliestCutoffPreNoteDT := null;
	foreach recCutoff in self.allReceivalCutoffs do
		if recCutoff.cutoffDateTimePN &lt;&gt; null then
			if earliestCutoffPreNoteDT = null then
				earliestCutoffPreNoteDT := recCutoff.cutoffDateTimePN;
			else
				if recCutoff.cutoffDateTimePN &lt; earliestCutoffPreNoteDT then
					earliestCutoffPreNoteDT := recCutoff.cutoffDateTimePN;
				endif;
			endif;
		endif;
	endforeach;
	return earliestCutoffPreNoteDT;
end;
</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getEarliestDTForCode" id="2ac98832-275d-46a5-8dd1-3964817b442c">
        <source>getEarliestDTForCode( _code : String ):TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 November 2017	jlgndl1	Initial creation	TFS 7888

*/
vars

	termCutoff : CM_ReceivalCutoffTermDef;
	earliestTSPN : TimeStamp;
	cutoffTSPN : TimeStamp;
	earliestTS : TimeStamp;
	cutoffTS : TimeStamp;
	voyCutoff : CM_ReceivalCutoffVoyage;

begin

	if self.overrideDefaults then
		voyCutoff := self.allReceivalCutoffs.getAtKey( _code, null );
		if voyCutoff &lt;&gt; null then
			return voyCutoff.earliestDateTime;
		endif;
		
	else
		termCutoff := self.myTerminal.allReceivalCutoffDefs[ _code ];
		if termCutoff &lt;&gt; null then
			termCutoff.getCutoffsForVoyage( self, earliestTS, cutoffTS);
			return earliestTS;
		endif;
		
	endif;
	
	return null;

epilog

end;
</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getEarliestDTForCodeLocalTZ" id="e2738964-1110-4a0d-958a-1c3763ea84e5">
        <source>getEarliestDTForCodeLocalTZ( _code : String ):TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 November 2017	jlgndl1	Initial creation	TFS 7888

*/

vars
	
	dbTs : TimeStamp;
	
begin
	
	dbTs := self.getEarliestDTForCode( _code );
	
	if dbTs &lt;&gt; null then
		return self.systemToLocalTime( dbTs );
	else
		return	null;
	endif;

epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getEarliestDTPNForCode" id="5970006c-ed98-4a37-973e-bcaec3972c96">
        <source>getEarliestDTPNForCode( _code : String ):TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/03/2025	navkc1 JIRA Story MTN-34227: MTN | Prenote Voyage Cut Offs - TRX Code changes for Prenote Cutoffs

*/
vars

	termCutoff : CM_ReceivalCutoffTermDef;
	earliestTSPN : TimeStamp;
	cutoffTSPN : TimeStamp;
	earliestTS : TimeStamp;
	cutoffTS : TimeStamp;
	voyCutoff : CM_ReceivalCutoffVoyage;

begin

	if self.overrideDefaults then
		voyCutoff := self.allReceivalCutoffs.getAtKey( _code, null );
		if voyCutoff &lt;&gt; null then
			return voyCutoff.earliestDateTimePN;
		endif;
		
	else
		termCutoff := self.myTerminal.allReceivalCutoffDefs[ _code ];
		if termCutoff &lt;&gt; null then
			termCutoff.getCutoffsPNForVoyage(self, earliestTSPN, cutoffTSPN);
			return earliestTSPN;
		endif;
	endif;
	
	return null;

epilog

end;
</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getEarliestEarliestRecPNDT" id="1ea91345-57ba-4bd6-a6ef-8d007dfe7ea8">
        <source>getEarliestEarliestRecPNDT() : TimeStamp;
/*
04/03/2025	navkc1 JIRA Story MTN-34227: MTN | Prenote Voyage Cut Offs - TRX Code changes for Prenote Cutoffs
*/
vars
	earliestEarliestReceivalPNDT : TimeStamp;
	recCutoff : CM_ReceivalCutoffVoyage;
begin
	earliestEarliestReceivalPNDT := null;
	foreach recCutoff in self.allReceivalCutoffs do
		if recCutoff.earliestDateTimePN &lt;&gt; null then
			if earliestEarliestReceivalPNDT = null then
				earliestEarliestReceivalPNDT := recCutoff.earliestDateTimePN;
			else
				if recCutoff.earliestDateTimePN &lt; earliestEarliestReceivalPNDT then
					earliestEarliestReceivalPNDT := recCutoff.earliestDateTimePN;
				endif;
			endif;
		endif;
	endforeach;
	return earliestEarliestReceivalPNDT;
end;
</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getEarliestEarliestReceivalDT" id="57c8c425-af91-4c06-b152-8014825c5557">
        <source>getEarliestEarliestReceivalDT() : TimeStamp;
//
//09 Nov 2016	cnwrs1	TFS 2933 MSL SQL Extract
//
vars
	earliestEarliestReceivalDT : TimeStamp;
	recCutoff : CM_ReceivalCutoffVoyage;
begin
	earliestEarliestReceivalDT := null;
	foreach recCutoff in self.allReceivalCutoffs do
		if recCutoff.earliestDateTime &lt;&gt; null then
			if earliestEarliestReceivalDT = null then
				earliestEarliestReceivalDT := recCutoff.earliestDateTime;
			else
				if recCutoff.earliestDateTime &lt; earliestEarliestReceivalDT then
					earliestEarliestReceivalDT := recCutoff.earliestDateTime;
				endif;
			endif;
		endif;
	endforeach;
	return earliestEarliestReceivalDT;
end;
</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getEarliestReceivalDT" id="edaaefc7-9634-4a55-85be-0c6e463e3d5f">
        <source>getEarliestReceivalDT(_recCutoffCode : String; _operator : CM_Operator): TimeStamp;

/*
Date			Who		Reason
10 June 2009	cnwar2	Initial creation

*/
vars
//	recCutoffDef 	: CM_ReceivalCutoffTermDef;
	recCutoff		: CM_ReceivalCutoffVoyage;
	
begin
	recCutoff := self.allReceivalCutoffs[_recCutoffCode, _operator];
	
	if recCutoff &lt;&gt; null then
		return recCutoff.earliestDateTime;
	endif;
	
	return null;
end;</source>
        <Parameter name="_recCutoffCode" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getEarliestReceivalPNDT" id="ac5a3166-6ad4-499c-90b1-eb589ac14b2a">
        <source>getEarliestReceivalPNDT(_recCutoffCode : String; _operator : CM_Operator): TimeStamp;

/*
Date			Who		Reason
04/03/2025	navkc1 JIRA Story MTN-34227: MTN | Prenote Voyage Cut Offs - TRX Code changes for Prenote Cutoffs

*/
vars
	recCutoff		: CM_ReceivalCutoffVoyage;
	
begin
	recCutoff := self.allReceivalCutoffs[_recCutoffCode, _operator];
	
	if recCutoff &lt;&gt; null then
		return recCutoff.earliestDateTimePN;
	endif;
	
	return null;
end;</source>
        <Parameter name="_recCutoffCode" type="String"/>
