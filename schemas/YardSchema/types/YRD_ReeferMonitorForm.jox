    <JadeMethod name="addObjectsToTable" id="9bcac1e4-1e20-43d5-94f1-a09fe16dff91">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:     22 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 08/12/2009	cnwdap1		CCMS MES 1007 Allow other cargo types to be reefer
// 04/03/2010	cnwdap1		PAR #22924 Correct changes made for 1007 when filtering on cargo id
// 11/03/2010	cnwdap1		PAR #22938 Fix inquiry when ID not entered for non-container reefer cargo
// 14/07/2025	naviv1		MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
vars
	cargoTypeKey,
	idLength		: Integer;
	tmpId			: String;
	contDict,
	contDictRev,
	dict,
	revDict			: Dictionary;
	ti				: CM_TrackedItem;
	iter			: Iterator;
	haveId			: Boolean;
	idKey			: String;
	breakOut		: Boolean;
	tmpTIs			: CM_TISet;
begin

	haveId	:= (self.filterCargoID &lt;&gt; null);
	self.setCaption("Reefer Monitoring");

	// DVB 15/12/2005 Causing locks by keeping dicts locked for duration of method.
//	app.cmsBeginLoad(ls);

	if self.filterVoyage &lt;&gt; null then
		dict := self.filterVoyage.allOnsiteTIsByCargoTypeId;
		//no rev dict
	elseif self.filterTerminalArea &lt;&gt; null then
		create contDict as CM_TIByCargoTypeIdDict transient;
		create contDictRev as CM_TIByCargoTypeIdDictRev transient;
		self.getTiDictsForTermArea(self.filterTerminalArea, contDict, contDictRev);		//myTerminal.allOnsiteTIsByCargoTypeId;
		dict 	:= contDict;
		revDict := contDictRev;
	else
		dict 	:= self.myTerminal.allOnsiteTIsByCargoTypeId;
		revDict := self.myTerminal.allOnsiteTIsByCargoTypeIdRev;
	endif;
	
	if haveId then
		tmpId	 := self.filterCargoID;
		idLength := tmpId.length;
		iter := dict.createIterator;
		
		create tmpTIs transient;

		dict.startKeyGeq(TI_CargoType_Container, tmpId, iter);

		while iter.next(ti) do
			iter.getCurrentKeys(cargoTypeKey, idKey);  //MTN-35226
			if idKey[1 : idLength] &lt;&gt; tmpId then
				continue;						// PAR #22924
			endif;
			if self.includeObjectTI(ti, breakOut) then
				self.addObjectToTable(ti, _numItems, breakOut);
				tmpTIs.add(ti);
			endif;
			if breakOut then
				break;
			endif;
		endwhile;
		
		delete iter;

		// now check the reversed dicts if there is one
		if revDict &lt;&gt; null  then
			tmpId := tmpId.reverse;
				
			iter := revDict.createIterator;
			revDict.startKeyGeq(TI_CargoType_Container, tmpId, iter);
				
			while iter.next(ti) do
				iter.getCurrentKeys(cargoTypeKey, idKey);  //MTN-35226
				//if ti.idReversed[1 : idLength] &lt;&gt; tmpId then
				if idKey[1 : idLength] &lt;&gt; tmpId then
					continue;						// PAR #22924
				endif;
			   if ti.isKindOf(self.myDataClass) and
			      (not tmpTIs.includes(ti)) then
					if self.includeObjectTI(ti, breakOut) then
						self.addObjectToTable(ti, _numItems, breakOut);
					endif;
					if breakOut then
						break;
					endif;
				endif;
			endwhile;
		endif;
		
	else	//dont have part id
		iter := dict.createIterator;
		dict.startKeyGeq(TI_CargoType_Container, null, iter);
		while iter.next(ti) do
			//dict.getIteratorKeys(cargoTypeKey, idKey, iter);
			//if cargoTypeKey &lt;&gt; TI_CargoType_Container then
			//	continue;					// PAR #22924
			//endif;
			if self.includeObjectTI(ti, breakOut) then
				self.addObjectToTable(ti, _numItems, breakOut);
			endif;
			if breakOut then
				break;
			endif;
		endwhile;
		delete iter;
	endif;

epilog
//	app.cmsEndLoad(ls);
	delete contDict;
	delete contDictRev;
	delete iter;
	delete tmpTIs;
end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="94b60c3f-5022-46a9-a2a6-794fe40a2237">
        <source>addToolbarControls() protected;
//----------------------------------------------------------------
//	Created:	30 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	toolbar			: CMUI_Toolbar;
	showCaptions	: Boolean;
	
begin
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnPrintLabel, CMUI_Toolbar.Control_Alignment_Left);
	
	inheritMethod();
	showCaptions := toolbar.showCaptions;

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.addButton(self.btnWorkList, CMUI_Toolbar.Control_Alignment_Left);
	
	//29 Jul 2020	NDL	TFS 49581
	if app.getMyUser.canDo(null,Sub_ReeferJobs) then
		toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
		if app.getMyUser.canDo( self.myTerminal, PmAdmReeferWalkView ) then
			toolbar.addButton(self.btnWalkPath, CMUI_Toolbar.Control_Alignment_Left);
		endif;
		if app.getMyUser.canDo( self.myTerminal, PmAdmReeferMaintView ) then
			toolbar.addButton(self.btnShowJobs, CMUI_Toolbar.Control_Alignment_Left);
		endif;
		if app.getMyUser.canDo( self.myTerminal, PmAdmReeferAddJob ) then
			toolbar.addButton(self.btnAddJob, CMUI_Toolbar.Control_Alignment_Left);
		endif;
		if app.getMyUser.canDo( self.myTerminal, PmAdmReeferAutoView ) then
			toolbar.addButton(self.btnAutoJobs, CMUI_Toolbar.Control_Alignment_Left);
		endif;
		if app.getMyUser.canDo( self.myTerminal, PmAdmReeferLayoutView ) then // ### TFS 51361 01JUL2021 NAVAB1
			toolbar.addButton(self.btnReeferLayout, CMUI_Toolbar.Control_Alignment_Left); // ### TFS 51361 01JUL2021 NAVAB1
		endif;
	endif;
	
	// hide the edit and save buttons - they have no meaning in this form
	toolbar.removeButtonByName(self.btnEditTV.name);
	toolbar.removeButtonByName(self.btnEditWc.name);
	toolbar.removeButtonByName(self.btnSaveBase.name);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="armNotesForObject" id="f66cf2c2-5968-4d7e-8245-0b527b8b2c61">
        <source>armNotesForObject(_obj: Object);
// ---------------------------------------------------------------------------
// Created:     09 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	
	beginNotification(_obj, self.myTerminal.getTerminalEvent(EVENT_TEMP_CREATE), Response_Continuous, 0);
	beginNotification(_obj, Object_Update_Event, Response_Continuous, 0);
	beginNotification(_obj, self.myTerminal.getTerminalEvent(TIEvent_Connect), Response_Continuous, 0);

	
	
end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
