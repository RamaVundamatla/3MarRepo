    <JadeMethod name="getVoyageStageFromEnum" id="6efa606d-2e0e-4e2a-af2c-6d4748e31de4">
        <source>getVoyageStageFromEnum(_enum : Integer) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//20/06/2024	navkc1 CR 64611 Task 64623: Jade - New Voyage Process

*/

vars

begin
	if _enum = CM_VoyageStage.VoyStage_DischManLoad then
		return app.getErrorString(VoyStage_DischManLoadStr);
	elseif _enum = CM_VoyageStage.VoyStage_LoadManLoad then
		return app.getErrorString(VoyStage_LoadManLoadStr); 
	elseif _enum = CM_VoyageStage.VoyStage_LoadListLoad then
		return app.getErrorString(VoyStage_LoadListLoadStr); 
	elseif _enum = CM_VoyageStage.VoyStage_DischListLoad then
		return app.getErrorString(VoyStage_DischListLoadStr); 
	elseif _enum = CM_VoyageStage.VoyStage_LoadCompLoad then
		return app.getErrorString(VoyStage_LoadCompLoadStr); 
	elseif _enum = CM_VoyageStage.VoyStage_DischCompLoad then
		return app.getErrorString(VoyStage_DischCompLoadStr); 
	elseif _enum = CM_VoyageStage.VoyStage_DischManMoved then
		return app.getErrorString(VoyStage_DischManMovedStr); 
	elseif _enum = CM_VoyageStage.VoyStage_LoadManMoved then
		return app.getErrorString(VoyStage_LoadManMovedStr); 
	elseif _enum = CM_VoyageStage.VoyStage_InvoiceGenerated then
		return app.getErrorString(VoyStage_InvoiceGeneratedStr); 
	elseif _enum = CM_VoyageStage.VoyStage_InvoicePosted then
		return app.getErrorString(VoyStage_InvoicePostedStr); 
	elseif _enum = CM_VoyageStage.VoyStage_VoyageClosed then
		return app.getErrorString(VoyStage_VoyageClosedStr); 
	endif;
	
	return null;
epilog

end;</source>
