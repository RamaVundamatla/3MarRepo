    <JadeMethod name="setControlsForAddEdit" id="95616aa8-6b6c-4f36-b556-19c09f513dbf">
        <updating/>
        <source>setControlsForAddEdit( _event : CM_EventTransaction ) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
06 November 2009	cnwndl1	Initial creation	Par 21519
08/04/2011			cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
*/

vars

	now : TimeStamp;
	loadState : Boolean;
	
begin

	delete self.myProxyObject;	// delete any pre-existing proxy.
	btnEditEvent.enabled := false;
	btnDelete.enabled := false;
	
	if _event &lt;&gt; null then
		// updating an existing Train Event Transaction, or selecting it for deletion.
		app.cmsBeginLoad(loadState);
		self.myProxyObject := _event.pxyCreateUpdateProxy;
		app.cmsEndLoad(loadState);
		
	else
		// adding a new one
		now := app.actualTimeServer;
		cmbEventType.enabled := true;
		txtDate.setDate(now.Date);
		txtTime.setTime(now.Time);
		self.setupCmbCharge(true);
		
	endif;
	
	self.grpEventDetail.enabled := true;
	self.grpEvents.enabled := false;
	self.btnNewEvent.enabled := false;
	self.btnSaveBase.enabled := true;
	
epilog
	app.cmsEndLoad(loadState);		// 08/04/2011 cnwmh5 #27347
end;</source>
        <access>protected</access>
        <Parameter name="_event" type="CM_EventTransaction"/>
    </JadeMethod>
    <JadeMethod name="setMyTrain" id="b4a4c1d6-8db1-43e7-9afa-fbdb0e18f04b">
