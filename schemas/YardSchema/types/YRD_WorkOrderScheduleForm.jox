    <JadeMethod name="getWorkOrderTIDtl" id="64f20654-98fd-4a17-9dbd-a7370dd82172">
        <source>getWorkOrderTIDtl(col : Integer) : CM_WorkOrderTIDtl;
// -----------------------------------------------------------------------------
// Created:		18 August 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
