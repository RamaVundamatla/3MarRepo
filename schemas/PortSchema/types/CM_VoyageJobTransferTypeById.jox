    <JadeMethod name="getMatchesDescription" id="bcc6f361-251b-48f4-8160-de3f7915db55">
        <source>getMatchesDescription( _desc : String ):CM_VoyageJobTransferType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2019	jlgndl1	Initial creation	TFS 44773

*/

vars

	type : CM_VoyageJobTransferType;
	iter : Iterator;

begin

	if self.isEmpty then
		return null;
	endif;
	
	iter := self.createIterator;
	while iter.next( type ) do
		if type.description = _desc then
			return type;
		endif;
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <Parameter name="_desc" type="String"/>
        <ReturnType type="CM_VoyageJobTransferType"/>
    </JadeMethod>
</CollClass>
