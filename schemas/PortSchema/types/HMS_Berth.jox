    <JadeMethod name="lowPriorityAtOtherBerth" id="bf498946-abf5-4166-b6e5-3761592bb2b4">
        <source>lowPriorityAtOtherBerth(_startTime, _endTime : TimeStamp) : Boolean;
/*
Purpose:			See if there is a lower-priority voyage at any other berths in the harbour
					in the time period supplied

Parameters:			_startTime - time to start searching
					_endTime - time to finish searching

Return Value:		true if a low-priority voyage was found, otherwise false

Date		Who		Reason
23/08/2012	cnwdap1	Initial creation PAR #30223
*/
vars
	berth 		: HMS_Berth;
	start, high : Boolean;
	priority	: Integer;
	iter 		: Iterator;
	movement	: HMS_VoyageMovement;
	
begin
	// no wharf? then there can't be any other berths
	if self.myWharf = null then
		return false;
	endif;
	
	foreach berth in self.myWharf.allBerths where berth &lt;&gt; self do
		delete iter;
		iter := berth.allVoyageMovements.createIterator;
		berth.allVoyageMovements.startKeyGeq(_startTime, iter);
		while iter.next(movement) do
			if movement.occursOnDTNEW &gt; _endTime then
				break;
			endif;
			
			// is this a low-priority voyage?
			start := false;
			high := false;
			priority := movement.myHMSVoyageData.myVoyage.getSchedulePriority(start, high, null);
			if priority = null then
				return true;
			endif;
		endwhile;
	endforeach;
	
	return false;
epilog
	delete iter;
end;</source>
        <Parameter name="_startTime" type="TimeStamp"/>
        <Parameter name="_endTime" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="d59761d3-0d31-4e66-a2d2-f641b8a2d89f">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------------------
//Created: 11 July 2003 By: cnwgd1
//--------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy : HMS_Berth;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	proxy.myHarbour := self.myHarbour;
	proxy.myWharf := self.myWharf;
	proxy.myRoot := app.myRoot;	// 10 May 2012	NDL	Par 29537
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
