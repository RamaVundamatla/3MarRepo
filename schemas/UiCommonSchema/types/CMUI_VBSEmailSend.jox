    <JadeMethod name="populateToAddress" id="9e3eb3bf-8a49-4aec-9d31-ba7084250b99">
        <source>populateToAddress();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Oct 2022	navak20 ChangeRequest 54046: EUP - VBS MTN - [7] - Email configuration and notifications
13 Jul 2023 Defect  59074: MTN - 1090 exception is raised when the start date/time is before the current time
*/

vars
	emailId				: CM_EmailAddress2;
	emailAddressList	: String;
	emailAddresses		: CM_EmailEntityByTypeNameDict;
	
begin
	if self.myCarrier &lt;&gt; null then										//13.07.2023 navma1 #59074
		emailAddresses := self.myCarrier.allPINNotifyEmailAddresses;
	endif;
	
	if self.myCarrier = null or emailAddresses.isEmpty then
		app.msgBox("No emails configured for this Carrier", "Warning", MsgBox_OK_Only);
		return;
	endif;
	
	foreach emailId in emailAddresses as CM_EmailAddress2 do
			emailAddressList := emailId.emailAddress &amp; ",";
	endforeach;
	emailAddressList := emailAddressList.stripTrailingChar(",");
	self.txtToAddress.text := emailAddressList;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="sendEmail" id="a0f41ea3-803f-4b30-aede-1c379e1580fd">
        <source>sendEmail();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Oct 2022	navak20 ChangeRequest 54046: EUP - VBS MTN - [7] - Email configuration and notifications
01 Mar 2023	navpw1	ChangeRequest 54046: (56729) - Fixed Email Issues
*/

vars
	alertDesc,
	toAddress,
	ccAddress,
	bccAddress,
	fromAddress,
	sendSubject,
	sendMessage,
	error			: String;
	fileName		: String;
	
	attachedFiles	: HugeStringArray;	// ### TFS 54046 (56729) 01Mar2023 NAVPW1
	file			: File;				// ### TFS 54046 (56729) 01Mar2023 NAVPW1
	path,								// ### TFS 54046 (56729) 01Mar2023 NAVPW1
	sendFilePath	: String;			// ### TFS 54046 (56729) 01Mar2023 NAVPW1
	outputFolder	: FileFolder;		// ### TFS 54046 (56729) 01Mar2023 NAVPW1
	ts				: TimeStamp;		// ### TFS 54046 (56729) 01Mar2023 NAVPW1
	
begin
	alertDesc	:= "Vehicle Booking Slots Email";
	toAddress	:= self.txtToAddress.text;
	ccAddress	:= self.txtCcAddress.text;
	bccAddress	:= self.txtBccAddress.text;
	fromAddress	:= app.myRoot.getConfig(AutoSendersEmailAddress).String;
	sendSubject	:= self.txtSubject.text;
	sendMessage	:= self.txtMessageBody.text;
	
	ts := app.actualTimeServer;
	
	fileName := "vbsdetails" &amp; "-" &amp; ts.date.formatAsYYYYMMDD()  &amp;
				  ts.time.formatAsHHMMSS() &amp; ".csv";
	
	// ### TFS 54046 (56729) 01Mar2023 NAVPW1
	create attachedFiles transient;
	
	app.checkTempDirFolderPath(path, method.qualifiedName, CMIF_ConfigRoot.name&amp; '::' &amp; CMIF_ConfigRoot::systemTempDir.name);
	
	create outputFolder transient;
	outputFolder.fileName := path;
	
	if not outputFolder.isAvailable() then
		outputFolder.make();
	endif;
	
	create file;
	file.kind := File.Kind_Unknown_Text;	// 25/2/16 cnwmp6 PAR 36286 unicode version
	file.fileName := path &amp; fileName;
	if not file.isAvailable then
		file.writeString(self.vbsDetails);
		file.close;
	else
		app.writeLog("File " &amp; file.fileName &amp; " not found." , LogINFO);
	endif;
	
	sendFilePath := path &amp; fileName;
	attachedFiles.add(sendFilePath);
	// ### TFS 54046 (56729) 01Mar2023 NAVPW1
	
	app.myTrxCA.trxCreateEmailSendRequest(alertDesc,
											toAddress,
											fromAddress,
											ccAddress,
											bccAddress,
											sendSubject,
											sendMessage,
											attachedFiles,
											null,
											null,
											null,
											null,
											null,
											app.myPassport);
	
	if not app.myPassport.trxCompletedOK then
		error := app.getErrorString2(FailureWithError, app.getErrorString(Email_Request), app.myPassport.returnCode.String);
		app.remoteErrorWarningToAlert(error, null, app.myPassport.allErrors, null, false, true);
		return;
	endif;
	
epilog
	delete outputFolder;
	delete file;
	delete attachedFiles;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setMyCarrier" id="bf6e05ec-0c77-41b4-9ca6-af27b877c331">
        <updating/>
        <source>setMyCarrier(_allSelectedSlots : ObjectArray) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Oct 2022	navak20 ChangeRequest 54046: EUP - VBS MTN - [7] - Email configuration and notifications

*/

vars
	vbsSlots : CM_VehicleBookingTimeSlot;
begin
	foreach vbsSlots in _allSelectedSlots as CM_VehicleBookingTimeSlot do
		self.allSelectedSlots.add(vbsSlots);
	endforeach;
	self.myCarrier := self.allSelectedSlots.first.CM_VehicleBookingTimeSlot.myCarrier;
epilog

end;</source>
        <Parameter name="_allSelectedSlots" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="setVbsDetails" id="0861242a-b9cf-4147-bb05-7d0e4b0c6448">
        <updating/>
        <source>setVbsDetails(_vbsDetails : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 February 2023	navpw1	Initial creation TFS: 54046 (55834)

*/

begin
	self.vbsDetails := _vbsDetails;
	
end;</source>
        <Parameter name="_vbsDetails" type="String"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="5ba855c3-389e-4356-90c7-65f64b9ea9b6">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2022	navak20	Initial creation

*/

vars

begin
	inheritMethod();
	self.handleMenusForModalDisplay();
	self.btnOk.caption := "Send";
	self.btnCancel.caption := "Close";
	self.populateToAddress();
	self.createEmailAttachment();
	self.txtSubject.text := self.createEmailSubject();
	self.createEmailBody();
	self.btnOk.default := false;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showRecipientAddress" id="ee8500dc-3e01-47f0-9201-31046d7936b8">
        <updating/>
        <source>showRecipientAddress() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Oct 2022	navak20 ChangeRequest 54046: EUP - VBS MTN - [7] - Email configuration and notifications

*/

vars
	form : CMUI_RecipientSelector;
	termEmailDefaults	: CM_PINObjectDefaultEmail;
	
begin
	
	termEmailDefaults := self.myTerminal.getEmailDefaultsSettings( PINEmail_CargoRelease );
	if termEmailDefaults &lt;&gt; null then
		self.myEmailDefault := termEmailDefaults.cloneSelf(true).CM_PINObjectDefaultEmail;
	endif;
	if self.myEmailDefault &lt;&gt; null then
		self.myEmailDefault.setAddresses( self.myTerminal,self.myCarrier, null, PINEmail_CargoRelease );
	endif;
	create form transient;
	
	self.setNavigatorHeading(form.caption);
	form.myEmailController := self.myEmailDefault.myEmailController;
	form.myTerminal := self.myTerminal;
	form.mode := CMUI_RecipientSelector.Mode_To;
	form.centreWindow;
	form.showModal;

	if form.modalResult = IDOK then
		if self.txtToAddress.text &lt;&gt; null then
			self.txtToAddress.text := self.txtToAddress.text &amp; "," &amp; self.myEmailDefault.myEmailController.allToAddresses.getAddresses();
		else
			self.txtToAddress.text := self.myEmailDefault.myEmailController.allToAddresses.getAddresses();
		endif;
		if self.txtCcAddress.text &lt;&gt; null then
			self.txtCcAddress.text := self.txtCcAddress.text &amp; "," &amp; self.myEmailDefault.myEmailController.allCcAddresses.getAddresses();
		else
			self.txtCcAddress.text := self.myEmailDefault.myEmailController.allCcAddresses.getAddresses();
		endif;
		if self.txtBccAddress.text &lt;&gt; null then
			self.txtBccAddress.text := self.txtBccAddress.text &amp; "," &amp; self.myEmailDefault.myEmailController.allBccAddresses.getAddresses();
		else
			self.txtBccAddress.text := self.myEmailDefault.myEmailController.allBccAddresses.getAddresses();
		endif;
	endif;


end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="30dc426f-1799-458a-8026-72571df76941">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 16 February 2023 14:12:07.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025574, locale);
	btnBccAddress.translateCaption(Xlat_0025575, locale);
	btnCcAddress.translateCaption(Xlat_0025576, locale);
	btnToAddress.translateCaption(Xlat_0025577, locale);
	lblAttachment.translateCaption(Xlat_0025578, locale);
	lblMessage.translateCaption(Xlat_0025579, locale);
	lblSubject.translateCaption(Xlat_0025580, locale);
end;</source>
    </JadeMethod>
</GUIClass>
