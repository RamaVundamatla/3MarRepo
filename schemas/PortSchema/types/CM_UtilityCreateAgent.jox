        <source>utlCreateProcessTerminal(_proxy : CM_ProcessTerminal; 
						_real : CM_ProcessTerminal output;
						_passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 June 2018	jlgndl1	Initial creation	TFS 39140

*/

vars
	
begin

	self.initialiseActivity();
	
