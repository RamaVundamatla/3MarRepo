    <JadeMethod name="getTotalRequest" id="3f83143f-ad5d-489f-be5c-7f15c1ea609d">
        <source>getTotalRequest(_qty: Boolean): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Nov 2023	navhl20	Bug 61242: EUP | Release Cargo Work order progress not based on the Total Quantity of the cargo items
17 Apr 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work
*/

vars
	ti		: CM_TrackedItem;
	total	: Integer;
	wt   	: Decimal[14,4];
	invalid	: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, ti, invalid);
	if _qty then
		foreach  ti in self.allSelectedTIs discreteLock do  		//28.05.2024 navma1 #64224
			invalid := false;
			ti.edition;
			if invalid then
				continue;
			endif;
			
			total := total + ti.totalQuantity;
		endforeach;
		return total;
	else
		foreach  ti in self.allSelectedTIs discreteLock do   		//28.05.2024 navma1 #64224
			invalid := false;
			ti.edition;
			if invalid then
				continue;
			endif;
			
			wt := wt + ti.totalWeight;
		endforeach;
		return wt;
	endif;
epilog

end;</source>
        <Parameter name="_qty" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
