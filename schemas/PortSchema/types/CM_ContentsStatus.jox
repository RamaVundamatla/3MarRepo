<Class name="CM_ContentsStatus" id="b39874ec-b14d-47e8-b924-a314726c8392">
    <superclass name="CM_CargoStatus"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>


 FCL = 1
 LCL = 2
 EMPTY = 3</text>
    <DbClassMap file="terminal"/>
    <JadeMethod name="auditId" id="61eee4f1-a369-4726-a94f-4f41fce6d681">
        <source>auditId(): String;
// ---------------------------------------------------------------------------
// Created:     May 2006 by cnwrs1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return self.description.trimBlanks();
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getYADisplay" id="db96c3c2-5798-4eca-9290-49b4f1e5fa56">
        <source>getYADisplay(): String;
// Created:		Oct 2010	cnwjre1	added for CCMS 1043 snap shot summary invoicing
vars

begin
	if self.code = TI_CONTENTS_STATUS_NULL and self.description = null then
		return "No Status";
	endif;

	return self.description;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getYAIdentifier" id="bc921dda-843b-4987-a617-aaecf38e5ee8">
        <source>getYAIdentifier(): String;
// Created:		Oct 2010	cnwjre1	added for CCMS 1043 snap shot summary invoicing
vars

begin
	if self.code = TI_CONTENTS_STATUS_NULL and self.abbreviation = null then
		return "NONE";
	endif;

	return self.abbreviation;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="9fc3a4e0-2bf2-482b-b8f7-ab7c4b02a649">
        <source>validateForCreate();
/*
------------------------------------------------------------------------
Created:			09 June 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
begin
	if app.myRoot.allContentsStatuses[self.code] &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code.String, null, null);
	endif;
	
	self.validateForUpdate();
end;</source>
    </JadeMethod>
</Class>
