end;</source>
        <Parameter name="pFileName" type="String"/>
        <Parameter name="pNodeOptions" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getVersion" id="3ba98ab1-9143-453a-b3d5-2b5ee058cf72">
        <source>getVersion(): String;
// --------------------------------------------------------------------------------
// Created:		16 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
