    <JadeMethod name="addClassForReload" id="1369da92-e8e9-49a9-9fcc-6c4974fc9bad">
        <updating/>
        <source>addClassForReload(className:String) updating;
//	Description :	Add the current class (specified by name) to the collection
//					of classes to be reloaded
//
//	Created By  : cnwavl1 on 25 January 1999
//
//	History
//	Date        UserId		Srr			Description
//  --------	--------	--------	----------------------------------
//
vars
	class	:	Class;

begin
	//	get the class matching the name
	class	:=	currentSchema.getClass(className);

	//	name is for a valid class
	if class	&lt;&gt;	null	then

		//	if the class is not in the collection already - add it
		if	not reloadClasses.includes(class)	then
			reloadClasses.add(class);
		endif;
	endif;
end;</source>
        <Parameter name="className" type="String"/>
    </JadeMethod>
    <JadeMethod name="addClassForUnload" id="2745ad9a-9a5f-45dd-8f34-20f495a41764">
        <updating/>
        <source>addClassForUnload(className:String) updating;
//	Description :	Add the current class (specified by name) to the collection
//					of classes to be unloaded
//
//	Created By  : cnwavl1 on 25 January 1999
//
//	History
//	Date        UserId		Srr			Description
//  --------	--------	--------	----------------------------------
vars
	class	:	Class;

begin
	//	get the class matching the name
	class	:=	currentSchema.getClass(className);

	//	name is for a valid class
	if class	&lt;&gt;	null	then

		//	if the class is not in the collection already - add it
		if	not unloadClasses.includes(class)	then
			unloadClasses.add(class);
		endif;
	endif;
end;</source>
        <Parameter name="className" type="String"/>
    </JadeMethod>
    <JadeMethod name="classForReload" id="6348db1b-bc98-42a8-ba4b-434de0bf6ca0">
        <source>classForReload(pClass : Class)  : Boolean;

// determine if the current class is to be reloaded

begin
	// check and make sure this class is still suitable
	if not includeTypeOfClass(pClass) then
    	return false;
	endif;

	// default - reload all classes
	if reloadClasses = null then
		return true;
	endif;
	
	if	reloadClasses.size() = 0 then
		return true;
	endif;

	//	reload specified classes only
	return	reloadClasses.includes(pClass);
end;</source>
        <Parameter name="pClass" type="Class"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="classForUnload" id="ad23d6e8-c81c-43d3-9afb-5d200d6d62ad">
        <source>classForUnload(pClass : Class) : Boolean;

// determine if the cuurent class is to be unloaded

begin
	// check and make sure this class is still suitable
	if not includeTypeOfClass(pClass) then
    	return false;
	endif;

	// default - unload all classes
	if unloadClasses = null then
		return true;
	endif;
	
	if unloadClasses.size() = 0 then
		return true;
	endif;

	//	unload specified classes only
	return	unloadClasses.includes(pClass);
end;</source>
        <Parameter name="pClass" type="Class"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="exceptionHandler" id="b24c11e1-aad6-4490-91b5-6c45f3c23f3b">
        <updating/>
        <source>exceptionHandler(pException : Exception): Integer updating;

begin
	//write "object = " &amp; debugObject;
	//write "collection = " &amp; debugCollection;
	//write "reference = " &amp; debugReference;

	logFile.writeLine("Reload failed");
	logFile.writeLine("object = " &amp; debugObject);
	logFile.writeLine("field = " &amp; debugField);
	logFile.writeLine("collection = " &amp; debugCollection);
	logFile.writeLine("reference = " &amp; debugReference);

	logFile.close();

	return Ex_Pass_Back;
end;</source>
        <Parameter name="pException" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="includeTypeOfClass" id="f5da1e38-c5ed-4a1f-8926-4fa02e7b3259">
        <source>includeTypeOfClass(pClass : Class)  : Boolean;

// determine if the current class type is to be unloaded/reloaded

vars
	superClass : Class;

begin
	// check and make sure this class is still suitable

	superClass := pClass.getSuperclass;
	if	pClass.isSystemObject  				or
		pClass._isSubschemaCopy				or
		pClass.isKindOf(CollClass)  		or
		pClass.isKindOf(GUIClass)  			or
		pClass.isKindOf(ExceptionClass)		or
		pClass.isKindOf(Application) 		or
		superClass.isKindOf(Application)	or
		pClass.name = 'Application'  		or
		superClass.name = 'Application'		or
		pClass.isKindOf(Global)  			or
		superClass.isKindOf(Global)  		or
		superClass.name = 'Global'  		or
		pClass.transient  					or
		pClass.name = app.getName()			then
    	return false;
    else
    	return true;
	endif;
end;</source>
        <Parameter name="pClass" type="Class"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="reloadJadeDB" id="36d4f51f-f904-4683-b618-add83990be21">
        <updating/>
        <source>reloadJadeDB() updating;

// goes through the data file three times, 
// 1: to create objects, and set simple attributes including arrays and binaries
// 2: set values for references (requires that all objects have been created)
// 3: populate collections      (requires that all refs are set: collection key may be a reference)


// there are 5 parts to this method, separated by ************************
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	recordPos			: Integer;
	theField			: String;
	className			: String; 
	select 				: CMDFileOpen;
	class 				: Class;
	superClass			: Class;
	tempClass			: Class;
	lastClassName		: String;
	sch 				: Schema;
	obj 				: Object;
	newObject			: Object;
	textLine 			: String;
	totalObjects, totalUnloaded, ct : Integer;
	keepReading			: Boolean;
	processing			: Boolean;
	match				: Boolean;
	validClass			: Boolean;
	intCount			: Integer;
	intStartCount		: Integer;
	intReturn			: Integer;
	intMaxRecordSize	: Integer;

begin
	on Exception do exceptionHandler(exception);

//**********************************************************************************	
// open the data file, start a log file, setup progress dialog

	create select;
	select.dialogTitle := 'Select file name for Reload Text file';
	select.filter := "Text (*.txt)|*.txt|All Files (*.*)|*.*";
	if select.open = 0 then
		textFileName := select.fileName;
		create textFile;
		textFile.maxRecordSize := 64000;
		textFile.kind := File.Kind_Unknown_Text;	// 1/3/16 cnwmp6 PAR 36286 unicode version
		textFile.openInput(textFileName);
		sch := currentSchema;
		if sch = null then
			sch := Schema.firstInstance.getSchema('HCSTestSchema');
		endif;


		textLine := textFile.readLine;
		recordPos := 1;
		theField := textLine.getNextToken(recordPos);

		// this is the length of the longest line 

		longestLine:= theField.Integer;


		// need to allow for the longestLine in the file (have added 5 extra bytes) as got
		// the Jade error re record length exceeds maxrecordSize when it  maxrecordsize 
		// was equal to the longest line  


		if (longestLine + 5) &gt; textFile.maxRecordSize then
     	  // now close the file and reopen again

      		textFile.close();


    		textFile.maxRecordSize := (longestLine + 5);
		  	textFile.kind := File.Kind_Unknown_Text;	// 1/3/16 cnwmp6 PAR 36286 unicode version
			textFile.openInput(textFileName);

			textLine := textFile.readLine;
			recordPos := 1;

			// skip over the longest line
			theField := textLine.getNextToken(recordPos);
		endif;

  		// hold the maxRecordSize attribute for use when we re-read through the file again for
  		// loading references

  		intMaxRecordSize := textFile.maxRecordSize;

		// now the total objects
		theField := textLine.getNextToken(recordPos);
        if theField.trimBlanks &lt;&gt; 'TotalObjects' then
			app.msgBox('No control total', 'Error', 0);
			return;
		endif;
		totalObjects := textLine.getNextToken(recordPos).Integer;

		select.dialogTitle := 'Select file name for Reload Binary file';
		select.filter := "Data (*.dat)|*.dat|All Files (*.*)|*.*";
		select.fileName := textLine[recordPos:end];
		if select.open &lt;&gt; 0 then
			textFile.close();
			delete textFile;
			return;
		endif;
		binaryFileName := select.fileName;
		create binaryFile;
		binaryFile.kind := 1;
		binaryFile.openInput(binaryFileName);


		create logFile;
		logFile.allowReplace := true;
		logFile.mode := File.Mode_Append;
		logFile.mode := 3;
		logFile.kind := File.Kind_Unknown_Text;	// 1/3/16 cnwmp6 PAR 36286 unicode version
		logFile.openOutput("ReLoadDB.log");
		logFile.writeLine("***** Start of Reload " &amp; app.actualTimeServer().String &amp; " *****"); // 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support

		intStartCount := writeClassCounts(sch);
		if intStartCount &lt;&gt; 0 then

			intReturn := app.msgBox ( "Database is not empty - Continue?", " Reload Confirmation" , MsgBox_OK_Cancel );

			if intReturn = MsgBox_Return_Cancel	 then 
				terminate;
			endif;	

		endif;



		create prog;
		prog.caption := 'Reload of Schema ' &amp; currentSchema.getName;
		prog.setParent(app.getForm(app.mdiFrame.getName));
		prog.show;
		prog.showProgressBar('0 of ' &amp; totalObjects.String &amp; ' objects loaded', '', 0, totalObjects);

		logFile.writeLine('Start of ' &amp; sch.getName &amp; ' schema Data Reload.');
		logFile.writeLine('');
		beginTransaction;

//**************************************************************************************
// first pass through the data:
// creates instances of all the classes
// sets attributes (except references and collections)

		processing := true; 

		ct := 0;

		while processing do 

			if textFile.endOfFile() then
				break;
			endif;

			textLine := textFile.readLine;

			recordPos := 1;

            className := textLine.getNextToken(recordPos);
			if className &lt;&gt; lastClassName then 

				validClass := false;

    			//  commit transaction and begin another transaction 


    			commitTransaction;

    			beginTransaction;					


				// check to see if a  valid class

				currentClass := sch.getClass(className);
				if currentClass = null then
					validClass := false;
					logFile.writeLine ('Class ' &amp; className &amp; 'has been deleted');

				else

					// check to see that this class is still to be reloaded
					if classForReload(currentClass) then 
		            	validClass := true;
	                 	selectClassProperties(); // makes a list of the class properties

	                 else
						write currentClass.name &amp; "class not reloaded";
	                 	logFile.writeLine ('Class ' &amp; className &amp; 'type has changed - cannot be reloaded');		

	                endif;  // on class to be reloaded
				endif; // on current class = null 
			endif; // class name &lt;&gt; last class name

			if validClass then

    			debugObject := textLine[1:100];

// Gregs code for reloading of 'global'
// added these 3 lines, and the endif;
				if currentClass.name = global.getName() then
					newObject := global;
				else				

					create newObject as currentClass;
				endif;
					xref[textLine.getNextToken(recordPos)] := newObject;	// xref[the old objects Oid String] = the new object
					newObject.reloadObjectData(self,textLine);

			endif;	

			totalUnloaded := totalUnloaded + 1;
			ct:= ct + 1;
			if ct &gt; 10 then
				if prog.showProgressBar(totalUnloaded.String &amp; ' of ' &amp; 
						totalObjects.String &amp; ' objects reloaded', 'Resolving  Class ' 
						&amp; className, totalUnloaded, totalObjects) = 1 then
					textFile.close();
					delete textFile;
					prog.unloadForm;	
					delete select;
					abortTransaction;
					return;
				endif;				
				ct := 0;
			endif;					

		endwhile;

		textFile.close();

//**************************************************************************************
// second pass through the data:
// picks up references 


		// ensure that we reopen the file with the correct maxrecord size

		textFile.maxRecordSize := intMaxRecordSize;
		textFile.kind := File.Kind_Unknown_Text;	// 1/3/16 cnwmp6 PAR 36286 unicode version
		textFile.openInput(textFileName);
		binaryFile.close();
		binaryFile.kind := 1;
		binaryFile.openInput(binaryFileName);

		prog.unloadForm;	
		create prog;
		prog.caption := 'Start of ' &amp; sch.getName() &amp; ' schema References Reload';
		prog.setParent(app.getForm(app.mdiFrame.getName()));
		prog.show;

		// now read through the data processing the instances so as to reload the references

		processing := true; 
        lastClassName := null;

		debugCollection := null;
		debugField := null;
		debugObject := null;
		debugReference := null; 

		ct := 0;
		totalUnloaded := 0;

		// skip over the first line of control information
		textFile.readLine; 

		validClass := false;

		while processing do 

			if textFile.endOfFile() then
				break;	
			endif;


			textLine := textFile.readLine;

			recordPos := 1;

            className := textLine.getNextToken(recordPos);
			if className &lt;&gt; lastClassName then 

				validClass := false;

				//  commit transaction and begin another transaction 

    			commitTransaction;
    			beginTransaction;			

				// check to see if a  valid class

				currentClass := sch.getClass(className);
				if currentClass = null then
					validClass := false;

				else
					// check to see that this class is still to be reloaded
					if classForReload(currentClass) then 
		                validClass := true;
		            	selectClassProperties();

		     		else
						write currentClass.name &amp; "references not reloaded";		                

					endif; 
				endif; 

			endif; 

			if validClass then

				debugObject := textLine[1:100];
				newObject := xref[textLine.getNextToken(recordPos)]; // xref[the old objects Oid String] = the new object

				newObject.reloadObjectReferences(self,textLine);

			endif;	

			totalUnloaded := totalUnloaded + 1;
			ct := ct + 1;
			if ct &gt; 10 then
				if prog.showProgressBar(totalUnloaded.String &amp; ' of ' &amp; 
						totalObjects.String &amp;  ' references Resolved', 'Resolving References for Class '  
						&amp; className, totalUnloaded, totalObjects) = 1 then

					textFile.close();
					delete textFile;
					prog.unloadForm;	
					delete select;
					abortTransaction;
					return;
				endif;				
				ct := 0;
			endif;					

		endwhile;

		textFile.close();

//**************************************************************************************
// third pass through the data:
// populates collections


		// ensure that we reopen the file with the correct maxrecord size

		textFile.maxRecordSize := intMaxRecordSize;
		textFile.kind := File.Kind_Unknown_Text; // 1/3/16 cnwmp6 PAR 36286 unicode version
		textFile.openInput(textFileName);
		binaryFile.close();
		binaryFile.kind := 1;
		binaryFile.openInput(binaryFileName);

		prog.unloadForm;	
		create prog;
		prog.caption := 'Start of ' &amp; sch.getName() &amp; ' schema Collections Reload';
		prog.setParent(app.getForm(app.mdiFrame.getName()));
		prog.show;

		// now read through the data processing the instances so as to reload the collections

		processing := true; 
        lastClassName := null;

		debugCollection := null;
		debugField := null;
		debugObject := null;
		debugReference := null; 

		ct := 0;
		totalUnloaded := 0;

		// skip over the first line of control information
		textFile.readLine; 

		validClass := false;

		while processing do 

			if textFile.endOfFile() then
				break;	
			endif;


			textLine := textFile.readLine;

			recordPos := 1;

            className := textLine.getNextToken(recordPos);
			if className &lt;&gt; lastClassName then 

				validClass := false;

				//  commit transaction and begin another transaction 

    			commitTransaction;

    			beginTransaction;			



				// check to see if a  valid class

				currentClass := sch.getClass(className);
				if currentClass = null then
					validClass := false;

				else


					// check to see that this class is still to be reloaded

					if classForReload(currentClass) then 

		            	validClass := true;
		           		selectClassProperties();

		          	else
						write currentClass.name &amp; " collection not reloaded";		                

					endif; 
				endif; 

			endif; 

			if validClass then

				debugObject := textLine[1:100];

				newObject := xref[textLine.getNextToken(recordPos)]; // xref[the old objects Oid String] = the new object
				newObject.reloadObjectCollections(self,textLine);

			endif;	

			totalUnloaded := totalUnloaded + 1;
			ct := ct + 1;
			if ct &gt; 10 then
				if prog.showProgressBar(totalUnloaded.String &amp; ' of ' &amp; 
						totalObjects.String &amp;  ' collections Resolved', 'Resolving Collections for Class '  
						&amp; className, totalUnloaded, totalObjects) = 1 then

					textFile.close();
					delete textFile;
					prog.unloadForm;	
					delete select;
					abortTransaction;
					return;
				endif;				
				ct := 0;
			endif;					

		endwhile;

//**********************************************************************************	
// close the progress dialog, data file, log file.


		prog.showProgressBar(totalUnloaded.String &amp; ' of ' &amp; 
							totalObjects.String &amp; ' objects reloaded', '', 
							totalUnloaded, totalObjects);
		prog.unloadForm;


		commitTransaction;

		// now get the counts 


		logFile.writeLine ("**** After the reload ****");

		totalObjects := writeClassCounts(sch);

		logFile.writeLine(totalUnloaded.String &amp; ' of ' &amp; totalObjects.String &amp; ' objects reloaded');

		textFile.close();

		delete textFile;
		binaryFile.close();
		delete binaryFile;

		logFile.writeLine('End of ' &amp; sch.getName() &amp; ' schema Reload.');

		logFile.writeLine(' ');

		logFile.close();
		delete logFile;

	endif;
	
	delete select;

	app.msgBox ( "Reload has completed successfully ", " Reload Complete" , MsgBox_OK_Only );
end;</source>
    </JadeMethod>
    <JadeMethod name="selectClassProperties" id="905f402e-4ea4-4374-97e0-3bbfdcb62051">
        <updating/>
        <source>selectClassProperties() updating;

vars
	theClass			: Class;
	thisClass			: Class;
	thePropertyColl		: PropertyNDict;
    prop				: Property;
   	inv					: InverseSet;
    inverse				: Inverse;
    propName			: String;
    doWrite				: Boolean;
    reference			: ExplicitInverseRef;
    
begin
	currentClassProperties.clear();
	theClass	:= currentClass;
	thisClass	:= currentClass;

	while theClass &lt;&gt; null do
		thePropertyColl	:=	theClass.getProperties();
		
	  	foreach prop in thePropertyColl do
	  		if not prop.virtual then
	    		if prop.getType.isKindOf(Class) then
					// property is a  non-primitive type
	    			propName := prop.name;
                    if prop.isKindOf(CompAttribute) then
                        currentClassProperties.add(prop);
                    elseif prop.isKindOf(ImplicitInverseRef) then
                        currentClassProperties.add(prop);
					else
						reference := prop.ExplicitInverseRef;

	                    if reference.updateMode.Integer = 0 then
	                        // manual property - select for unload/reload
	                        currentClassProperties.add(prop);
	                    elseif reference.updateMode.Integer = 1 then
	                        // must be a Manual/Automatic property - consider for selection
	                        inv := reference.cnEcGetInverses();
                            // fetch a single inverse (may be multiple - but we don't need to know here)
                            inverse := inv.first();
                            // now select this property if relationship is not one-many and:
                            // a) prop is leftend of the inverse (includes b) and c) cases) or
                            // b) many-to-one i.e this prop is svp and inverse is an mvp
                            // c) inverse itself has multiple inverses
                            if inverse.isLeftEnd(reference) then
                                // we are the left hand endpoint of an inverse
                                // select if relationship is not one-many
								if (not prop.getType.isCollection or inverse.getRightEnd.getType.isCollection) and
                                   ((not prop.getType.isCollection and inverse.getLeftEnd.getType.isCollection) or
	                                   inv.size() = 1) then
                                    currentClassProperties.add(prop);
                                endif;
                            else
                                // we are right hand side of an inverse
                                // select if relationship is not one-many and
                                // other side has multiple inverses or
                                // relationship is many-one
								if (not prop.getType.isCollection or inverse.getLeftEnd.getType.isCollection) and
                                   ((not prop.getType.isCollection and inverse.getLeftEnd.getType.isCollection) or
                                     inverse.getLeftEnd.ExplicitInverseRef.cnEcGetInverses().size() &gt; 1) then
                                    currentClassProperties.add(prop);
                                endif;
                            endif;
	                    endif;
                    endif;
				else //	a primitive attribute
					currentClassProperties.add(prop);
				endif;
			endif;

	    endforeach;
		
		delete thePropertyColl;
		
		theClass := theClass.getSuperclass;
		if theClass.name = 'Object' then
			theClass := null;
		endif;
    endwhile;
end;</source>
    </JadeMethod>
    <JadeMethod name="unWriteReadable" id="d72b847a-b03d-42a0-8837-e9bb8eeee537">
        <source>unWriteReadable(text : String) : Boolean;

vars
	maxIndex				: Integer;
	loopIndex				: Integer;
	
begin
	maxIndex := text.length;
	loopIndex := 1;
	
	while loopIndex &lt;= maxIndex do 
//		if text[loopIndex:1].Character.Integer &lt; 32		or		// 15/3/16 cnwmp6 PAR 36286 unicode version
//		   text[loopIndex:1].Character.Integer &gt; 127	then	// 15/3/16 cnwmp6 PAR 36286 unicode version
		if (not text[loopIndex:1].Character.isPrintable()) or (text[loopIndex:1] = Tab) then	// 15/3/16 cnwmp6 PAR 36286 unicode version
			return(true);
		endif;
		
		loopIndex := loopIndex + 1;
	endwhile;
	
	return(false);
end;</source>
        <Parameter name="text" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="unloadJadeDB" id="2cafc102-812a-4539-9ffa-abdc493ab918">
        <updating/>
        <source>unloadJadeDB() updating;
// 3 parts to this method, separated by ************************
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
constants
	AllZeros : String = "0000000000000000000000";
	MakeLength : Integer = 8;

vars
	select 			: CMDFileSave;
	class 			: Class;
	superClass		: Class;
	sch 			: Schema;
	obj 			: Object;
	line 			: String;
	totalObjects	: Integer;
	totalUnloaded	: Integer;
	ct				: Integer;
	intInLength		: Integer;
	strOutString	: String;
	strInString		: String;
	allClasses		: ClassColl;
	
begin
//**********************************************************************************	
// open the data file, start a log file, setup progress dialog

	create select;
	select.dialogTitle := 'Select file name for Unload Text file';
	select.filter := "Text (*.txt)|*.txt|All Files (*.*)|*.*";
	if select.open = 0 then
		create textFile;
		textFile.allowReplace := true;
		//textFile.kind := 2;	// 1/3/16 cnwmp6 PAR 36286 unicode version
		textFile.openOutput(select.fileName);
		select.dialogTitle := 'Select file name for Unload Binary file';
		select.filter := "Data (*.dat)|*.dat|All Files (*.*)|*.*";
		select.fileName := select.fileName[1:select.fileName.length-3] &amp; 'dat';
		if select.open &lt;&gt; 0 then
			textFile.close();
			delete textFile;
			return;
		endif;

		create binaryFile;
		binaryFile.allowReplace := true;
		binaryFile.kind := 1;
		binaryFile.openOutput(select.fileName);
		sch := currentSchema;
		if sch = null then
			sch := Schema.firstInstance.getSchema('HCSTestSchema');
		endif;


		create logFile;
		logFile.allowReplace := true;
		logFile.kind := File.Kind_Unknown_Text;	// 1/3/16 cnwmp6 PAR 36286 unicode version
		logFile.mode := File.Mode_Append;
		logFile.mode := 3;
		logFile.openOutput("UnloadDB.log");

		// state the number of instances before we start 



		logFile.writeLine("***** Before starting Unload " &amp; app.actualTimeServer().String &amp; " *****");// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support

		totalObjects := writeClassCounts(sch);

		create prog;
		prog.caption := 'Unload of ' &amp; currentSchema.getName;
		prog.setParent(app.getForm(app.mdiFrame.getName));
		prog.show;


		logFile.writeLine(" ");
		logFile.writeLine("****** During Unload ******"); 
		textFile.writeLine('00000000' &amp; '   ' &amp; 'TotalObjects ' &amp; totalObjects.String &amp; '/' &amp; binaryFile.fileName);


		if prog.showProgressBar('0 of ' &amp; totalObjects.String 
							&amp; ' objects unloaded', '', 0, totalObjects) = 1 then
			textFile.close();
			delete textFile;
			prog.unloadForm;	
			delete select;
			return;
		endif;	

//**********************************************************************************	
// unload objects and values

		allClasses	:=	sch.getAllClasses(false);
		
		foreach class in allClasses do

			if classForUnload(class) then

				currentClass := class;

				selectClassProperties();
				ct := 10;
				foreach obj in class.instances do
					ct := ct + 1;
					totalUnloaded := totalUnloaded + 1;
					if ct &gt; 10 then
						if prog.showProgressBar(totalUnloaded.String &amp; ' of ' &amp; 
								totalObjects.String &amp; ' objects unloaded', 'Unloading Class ' 
								&amp; class.getName, totalUnloaded, totalObjects) = 1 then
							textFile.close();
							delete textFile;
							prog.unloadForm;	
							delete select;
							return;
						endif;				
						ct := 0;
					endif;	

					obj.unloadObjectData(self);
				endforeach;		
                logFile.writeLine('Class ' &amp; class.getName &amp; ' had ' &amp; countInstances.String &amp; ' instances unloaded.');

                countInstances := 0;	
            else
				//write class.name &amp;": ignored";
			endif;				

		endforeach;

//**********************************************************************************	
// do finish stuff: close log and data file, end progress dialog		

		logFile.writeLine(totalUnloaded.String &amp; ' of ' &amp; totalObjects.String &amp; ' objects unloaded.');
		logFile.writeLine(" ");

		prog.showProgressBar(totalUnloaded.String &amp; ' of ' &amp; 
							totalObjects.String &amp; ' objects unloaded', '', 
							totalUnloaded, totalObjects);




		// before we close the textfile ... update it with the longest length textline
		//				

		textFile.seek(0);


		strInString := longestLine.String;
		intInLength := strInString.length;

		// will truncate if the length in exceeds the length that we 
		// are making the  integer up to

		if intInLength &gt; MakeLength then
			intInLength := MakeLength;
		endif;

    	strOutString[1:MakeLength] := AllZeros;
   		strOutString[((MakeLength - intInLength) + 1) : MakeLength] := strInString;

   		textFile.writeString(strOutString[1:8]);


		textFile.close();
		delete textFile;
		binaryFile.close();
		delete binaryFile;
		prog.unloadForm;	
	endif;
	delete select;

	app.msgBox("Unload has completed successfully ", " Unload Complete" , MsgBox_OK_Only);
epilog
	delete allClasses;
end;</source>
    </JadeMethod>
    <JadeMethod name="writeClassCounts" id="92e2fb05-e620-4736-8b20-0bd0419ef2c7">
        <updating/>
        <source>writeClassCounts(sch : Schema) :Integer updating;
/*

Date		Who		Reason
23 Nov 2011	cnwkpd1	PAR #28731 - fix transient leaks
	
*/

vars
	intCount			: Integer;
	intTotalCount		: Integer;
	theClass			: Class;
	superClass			: Class;
	thePropertyColl		: PropertyNDict;
	prop				: Property;
	intProgCount		: Integer;
	staProp				: StringArray;
	inaCount			: IntegerArray;
	obj					: Object;
	intIndex			: Integer;
	intTotalColl		: Integer;
	thisColl			: Collection;
	strString			: String;
	intClassCollCount	: Integer;
	thisClass			: Class;
	allClasses			: ClassColl;

begin
	create prog;
	prog.caption := ('Logging Class totals for '  &amp; currentSchema.getName);
	prog.setParent(app.getForm(app.mdiFrame.getName));
	prog.show;
	
	allClasses	:=	sch.getAllClasses(false);
	
	foreach theClass in allClasses do
		if includeTypeOfClass(theClass)	then
			intTotalCount := intTotalCount + theClass.instances.size();
		endif;
	endforeach;
	
	delete allClasses;
	
    if intTotalCount = 0 then 
    	prog.unloadForm;
    	return intTotalCount;
    endif;

	//  now that we have the count then we can go thru again and get the count for all
	// the collections for a class... for this we need to go through each instance

	create staProp transient;
	create inaCount transient;
	allClasses	:=	sch.getAllClasses(false);
	
	foreach theClass in allClasses do
		if includeTypeOfClass(theClass)	then

			logFile.writeLine("Class " &amp; theClass.getName &amp; " has " &amp; theClass.instances.size().String &amp; " instances");

			// now need to go through the properties for the class and add the relevant 
			// ones into the array 
			thisClass := theClass;

			while thisClass &lt;&gt; null do 
				thePropertyColl	:=	thisClass.getProperties();
				
				foreach prop in thePropertyColl do
					if not prop.virtual then 
						if prop.getType.isKindOf(Class) then 
							if prop.getType.isCollection then 
							 	staProp.add(prop.name);
							 	inaCount.add(0);
							 endif;
						endif;
					endif;
				endforeach;
				
				delete thePropertyColl;
				thisClass := thisClass.getSuperclass;
				
				if thisClass.name = 'Object' then
					thisClass := null;
				endif;

			endwhile; 

			// now we can go thru all the instances and add the running totals into the array

			foreach obj in theClass.instances do 

				intIndex := 1;
				intProgCount := intProgCount + 1;
				intCount := intCount + 1;

				while intIndex &lt;= staProp.size() do
					thisColl := obj.getPropertyValue(staProp[intIndex]).Collection;
					if thisColl &lt;&gt; null then 
						inaCount[intIndex] := (inaCount[intIndex] + thisColl.size());
						intTotalColl := intTotalColl + thisColl.size();
						intClassCollCount := intClassCollCount + thisColl.size();
					endif;
					intIndex := intIndex + 1;
				endwhile;

				if intCount &gt; 10 then 
					intCount := 1;
				 	if prog.showProgressBar(intProgCount.String &amp; ' of ' &amp; intTotalCount.String 
						&amp; ' being totalled', 'Tallying ' &amp; theClass.getName, intProgCount, intTotalCount) = 1 then
						prog.unloadForm;
						terminate;
					endif;
				endif;		

			endforeach;

			 // list out the current array details here

               intIndex := 1;

               while intIndex &lt;= staProp.size() do 
                	logFile.writeLine ("   -- " &amp; inaCount[intIndex].String &amp; " " &amp;  staProp[intIndex] &amp;  " instances for all class instances");
                	intIndex := intIndex + 1;
               endwhile;

			if staProp.size() &gt; 0 then 
				logFile.writeLine ("       -- Total Collection instances for class is " &amp; intClassCollCount.String);
			endif;

			intClassCollCount := 0;
			staProp.clear();
			inaCount.clear();
		endif;

	endforeach;

	// now do the totals 

	logFile.writeLine(""); 

	logFile.writeLine("** Total object Instances for all Classes is " &amp; intTotalCount.String);
	logFile.writeLine("** Total Collection instances for all objects is " &amp; intTotalColl.String);

	prog.showProgressBar(intTotalCount.String &amp; ' of ' &amp; intTotalCount.String 
							&amp; ' being totalled', ' ' , intTotalCount, intTotalCount);

    prog.unloadForm;

    return intTotalCount;
epilog
	delete allClasses;
	delete staProp;		// PAR #28731
	delete inaCount;
end;</source>
        <Parameter name="sch" type="Schema"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
