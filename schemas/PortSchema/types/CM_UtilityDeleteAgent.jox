    <JadeMethod name="utlDeleteEDIBayPlan" id="588740f5-a4cc-4aea-bc98-bcd54b2e9383">
        <updating/>
        <source>utlDeleteEDIBayPlan(_voyage : CM_Voyage io; _controllerToDel : CM_VoyageEDIBayPlanController io; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     25 February 2003 by cnwdwq1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx			: Integer;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	// note that validation agent locks object
	app.myValDA.valDeleteEDIBayPlan(_voyage,  _controllerToDel, _passport );
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	idx := _voyage.allEDIBayPlans.indexOf(_controllerToDel);
	
	if _passport.noErrors then
		_voyage.eraseEDIBayPlan(_controllerToDel );
		_voyage.setRemarks(app.getErrorString(EDI) &amp; " #" &amp; idx.String &amp; " Bay Plan deleted - " &amp; app.userName.toUpper, true);
	endif;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="io"/>
