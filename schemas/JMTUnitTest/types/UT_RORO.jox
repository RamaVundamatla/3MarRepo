	ediControllerAgent.getEDIFile_EDIData_Status();			// gets ediStatusCode and ediStatusDesc
	self.assertEqualMsg(ediControllerAgent.ediStatusCode, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS.display, errorStr);
	ediFile := ediControllerAgent.getEDIFile_By_ediClientRef(clientRef);*/

	ediFile := self.ediLoadFileName(ediText, EDIFileType_UserDefined, UserDefinedShipManifest, UserDefinedShipManifest&amp;method.name);
	self.assertNotNull(ediFile);
	
	self.clearExpectedTrxErrors();
	self.expectTrxError(WarningPileHeightExceed2);	
	self.ediVerify(ediFile);
	tempStr	:= 'Verify Failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	// status 3 is verify status and 14 is verified warnings
	//self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, tempStr);
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load Failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg(ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS, tempStr);

	app.writeLog("***File8 "&amp;errorStr&amp;"***", LogINFO);
	wrongError := true;
	foreach error in app.myPassport.allErrors do
		if error.errorCode = 87387 then
			wrongError := false;
		endif;
	endforeach;
	self.assertEqualMsg(wrongError, false, "wrong Error");
	// now check that the correct slots are rotated
/*	foreach ediTI in ediFile.ediData.allEDITrackedItems  discreteLock where ediTI.isKindOf(CM_EDILayoutTI) do
		locationID := ediTI.CM_EDILayoutTI.layoutId.trimBlanks();
		if locationID &lt;&gt; null then
			if ediTI.CM_EDILayoutTI.isRotationMaster then
				locationID := locationID &amp; "R"; // has been rotated will now have an R in teh end
			endif;
			roroDeck := voyageROROStructure.getDeckFromLocationString(locationID).CM_DeckVoyage;
			self.assertNotNullMsg(roroDeck, "RORO Deck");
			if roroDeck &lt;&gt; null then
				startLocn :=  roroDeck.allDeckItems[locationID].CM_ROROLocnDefn;
//				self.assertNotNullMsg(startLocn, "Rotation location");
			endif;	
		endif;
	endforeach;*/
	
	// 16/09/2015 cnwmh5
	beginTransaction;
	foreach ti in voyage.allOnshipTIsByIdCargoType do
		ti.setRemarks(self.createdByUnitTest(ti.remarks), true);
	endforeach;
	commitTransaction;	
	
epilog
	delete ediControllerAgent;
	delete pxyFileTypeUser;
	delete ediDataParams;
end;
</source>
