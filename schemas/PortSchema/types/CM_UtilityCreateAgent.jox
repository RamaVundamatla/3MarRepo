    <JadeMethod name="utlCreateCustDocDetail" id="28a001ba-3285-413b-9f26-8aa64f33d6b4">
        <source>utlCreateCustDocDetail(_pxyObject : CM_CustomDocumentDetail; _realObject : CM_CustomDocumentDetail output; _passport : CM_Passport input);
// ##### CR 56094  TASK 59616 NAVAB1 08AUG2023
vars
	theTerminal : CM_Terminal;
	header : CM_CustomDocument;
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	app.myValCA.valCustDocDetail(_pxyObject);

	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	create _realObject as _pxyObject.class persistent;
	_realObject.setForCreate(_pxyObject);
	self.myCreateAuditAgent.audCreateGeneric(_realObject);
	
	if _passport.noErrors then
		// only required if the class is audited
		
		// ### TFS CR 59615 TASK 59620 15AUG2023 NAVAB1
		header := _realObject.myParentCustomDocument; 
		if header = null
		and _realObject.myParentCustomDocumentDetail &lt;&gt; null then
			header := _realObject.myParentCustomDocumentDetail.myParentCustomDocument;
		endif;
		if header&lt;&gt; null then
			 theTerminal := header.myTerminal;
			app.myEventManager.createSingleObjInfoNoteEvt(header,theTerminal.getTerminalEvent(Event_CustDocDetailCreate),_realObject);	
		endif;
		
		_realObject.myTrackedItem.updateNoteForTransport(); //23/02/2023	navkc1 CR 62580 Task 62581
	endif;
	
end;</source>
        <Parameter name="_pxyObject" type="CM_CustomDocumentDetail"/>
        <Parameter name="_realObject" type="CM_CustomDocumentDetail" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateCustDocHeader" id="9fdf763d-b3bb-461c-9bbd-55bf3d086ecf">
        <source>utlCreateCustDocHeader(_pxyObject : CM_CustomDocument; _realObject : CM_CustomDocument output; _passport : CM_Passport input);
// ##### CR 56094  TASK 59616 NAVAB1 08AUG2023
// 29/08/2023	navkc1	CR 59556  Task 59593: UI - Cust Docs Auto Id
vars
	theTerminal : CM_Terminal;
	custDocType	: CM_CustomDocumentType;
	autoIdGen	: CM_AutoIdCustomDocs;
	firstTI		: CM_TrackedItem;
	date		: Date;
	tiTrans		: CM_TITransaction;
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	app.myValCA.valCustDocHeader(_pxyObject);

	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	create _realObject as _pxyObject.class persistent;
	_realObject.setForCreate(_pxyObject);
	
	if _passport.noErrors then
		theTerminal := _realObject.myTerminal;
		//29/08/2023	navkc1	CR 59556  Task 59593 - If Custom Document Type is using auto id, overwrite it
		custDocType := _realObject.myCustomDocumentType;
		if custDocType.hasAutoId then
			autoIdGen := theTerminal.getMyAutoIdGenerator(CM_AutoIdCustomDocs).CM_AutoIdCustomDocs;
			if autoIdGen &lt;&gt; null then
				date := _pxyObject.getFirstTiDate();
				_realObject.setCode(autoIdGen.getNextIdForYear(date));
			endif;
		endif;
		// only required if the class is audited
		self.myCreateAuditAgent.audCreateGeneric(_realObject);
		
		app.myEventManager.createSingleObjInfoNoteEvt(theTerminal,theTerminal.getTerminalEvent(Event_CustDocHeaderCreate),_realObject);	
	endif;

end;</source>
        <Parameter name="_pxyObject" type="CM_CustomDocument"/>
        <Parameter name="_realObject" type="CM_CustomDocument" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
