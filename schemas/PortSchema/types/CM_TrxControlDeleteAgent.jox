    <JadeMethod name="trxDeleteLRReasonCode" id="e3d4f09a-b106-401d-90cf-9411ce411ec9">
        <updating/>
        <source>trxDeleteLRReasonCode(_labourRestrictionReasonCode : CM_LabourRestrictionReasonCode io; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     22 May 2005 by cnwhjg1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	self.raiseExceptionIfNull(_labourRestrictionReasonCode, 'Labour Restriction Reason Code');

	app.setContinueCMExceptions(false);

	beginTransaction;

	self.exclusiveLockObjectToDelete(_labourRestrictionReasonCode);

	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;

	if _passport.noErrors then
		app.myUtilityDA.myDeleteAuditAgent.audDeleteGeneric(_labourRestrictionReasonCode);
	endif;

	if _passport.noErrors then
		_labourRestrictionReasonCode.erase(NORMAL_ERASE);
	endif;

epilog		
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_labourRestrictionReasonCode" type="CM_LabourRestrictionReasonCode" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxDeleteLayoutGraphic" id="4062d773-5d29-498d-a4e6-747653465514">
        <updating/>
        <source>trxDeleteLayoutGraphic(pLayoutGraphic : CM_LayoutGraphic; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if pLayoutGraphic = null then
		app.raiseCMException1(ERR_DEL_NULLOBJECT, 'Terminal Area Layout Graphic', null, null);
		return;
	endif;

	// Start the transaction
	beginTransaction;

	app.myUtilityDA.utlDeleteLayoutGraphic(pLayoutGraphic, _passport);
		
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="pLayoutGraphic" type="CM_LayoutGraphic"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxDeleteLicenseKey" id="a977fa06-1e45-4e35-b7b6-90f16eb8e08a">
        <updating/>
        <source>trxDeleteLicenseKey(_obj : CM_Object input; 
		_licenseName,
		_productCode : String;
		_expectedEdition : Integer; 
		_passport : CM_Passport input) updating;
//------------------------------------------------------------------------------------
// Created:	13 September 2004 By: cnwgd1
//--------------------------------------------------
// Purpose:		Removes a previously registered license key
//
// Parameters:	_licenseName - The name of the customer who's license to delete.
//-------------------------------------------------------------------------------------
vars
	rtnValue 	: Boolean;
	licObj		: Object;
	tmpRoot		: CM_Root;
	tmpTerm		: CM_Terminal;
	cmifMonitor	: CMIF_Monitor;	
begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	self.raiseExceptionIfNull(_obj, 'License Object');

	if CM_Root.hasInstance(_obj) then
		tmpRoot := _obj.CM_Root;
	elseif CM_Terminal.hasInstance(_obj) then
		tmpTerm := _obj.CM_Terminal;
	else
		// license obj only valid for cm_root or cm_terminal class
		app.raiseCMException(ErrInvalidLicenseClass, null, null);
		return;
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	if _licenseName = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(License_Name), 'licenseName', null);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(License_Name), 'licenseName', null);// cnwdb2	PAR 35364
		return;
	endif;

	if _productCode = null
	or _productCode &lt;&gt; ProductCode_JMT
	and _productCode &lt;&gt; ProductCode_JMT_EDI then
		app.raiseCMException1(ErrInvalidLicenseProductCode, _productCode, '_productCode', null);
		return;
	endif;	

	if _productCode = ProductCode_JMT_EDI then
		self.raiseExceptionIfNull(tmpRoot, 'CM_Root');
	endif;			

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	cmifMonitor := _passport.myCMIFMonitor;

	beginTransaction;
	
	exclusiveLock(_obj);
	if _obj.edition &lt;&gt; _expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'License Object', null, null);
		return;
	endif;

	if _passport.hasErrors then
		return;
	endif;
	
	if _obj &lt;&gt; app.myRoot then
		// lock root to ensure single thread of validation
		exclusiveLock(app.myRoot);
	endif;

	app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(_obj, true);
	if _passport.hasErrors then
		return;
	endif;

	// Deliberately done this way so as to avoid any references to the security module
	licObj := app.myCheckerObject;
	if licObj = null then
		app.raiseCMException(ErrLicenseObjectNotFound, null, null);
		return;
	endif;

	// We will handle the transactions
	licObj.sendMsgWithParams('setTransactionStateFlag', false);
	
	rtnValue := licObj.sendMsgWithParams('deleteLicenseKey', _licenseName, _productCode).Boolean;
	
	if (not rtnValue) then
		return;
	endif;

	if _passport.hasErrors then
		return;
	endif;		

	if tmpRoot &lt;&gt; null then
		tmpRoot.setLicenseName(null, _productCode);
	elseif tmpTerm &lt;&gt; null then
		tmpTerm.setLicenseName(null);
	else
		app.raiseCMException(ErrInvalidLicenseClass, null, null);
		return;
	endif;
	
	if _passport.noErrors
	and _productCode = ProductCode_JMT then
		app.myRoot.resetRootSecurityRoles(cmifMonitor);
	endif;
	
	if _passport.noErrors then
		// This is only required if the class is being auditted
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(_obj, false);
	endif;


epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_obj" type="CM_Object" usage="input"/>
        <Parameter name="_licenseName" type="String"/>
        <Parameter name="_productCode" type="String"/>
        <Parameter name="_expectedEdition" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
