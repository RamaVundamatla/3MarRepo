    <JadeMethod name="auditId" id="c8e9e2d2-7399-4798-8902-2459e614a396">
        <source>auditId(): String;
// --------------------------------------------------------------------------------
// Created:		7 December 2009 by cnwjo3
//
vars

begin
	if self.myVoyage &lt;&gt; null then
		return self.myVoyage.auditId &amp; " - Voyage Allocation Config" &amp; self.myIMEXStatus.auditId;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLDocGetChildRefKey" id="f3649c82-c7b0-465d-9e3a-3148404d1009">
        <source>exportAsXMLDocGetChildRefKey(_property: Property input): Property;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars

begin
	if _property = CM_VoyageAllocationConfig::myYACriteriaTypeForColour then
		return CM_YACriteriaType::type;
	endif;

	return inheritMethod(_property);

epilog

end;</source>
        <Parameter name="_property" type="Property" usage="input"/>
        <ReturnType type="Property"/>
    </JadeMethod>
    <JadeMethod name="exportAsXMLInverseRef" id="84354fda-c472-4502-a881-c084792b60c5">
        <source>exportAsXMLInverseRef(_property: Reference): Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars

begin
	if _property = CM_VoyageAllocationConfig::myYACriteriaTypeForColour then
		
		return ExportAsChild;
	endif;
		
	return inheritMethod(_property);
	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Reference"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="importFromXMLDocReference" id="3ea936e0-fb27-47e5-aeb2-eb242dfe4348">
        <updating/>
        <source>importFromXMLDocReference(_property: Property; _xmlElement: JadeXMLElement input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 April 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	childElement : JadeXMLElement;
begin
	if _property = CM_VoyageAllocationConfig::myYACriteriaTypeForColour then
		childElement:=_xmlElement.getElementByTagName(CM_YACriteriaType::type.name);	
		if childElement &lt;&gt; null then
			self.myYACriteriaTypeForColour:=app.myRoot.allYACriteriaTypes[childElement.textData.Integer];
		endif;
	else
		inheritMethod(_property, _xmlElement);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_xmlElement" type="JadeXMLElement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="c2b29c82-e9ad-4bd3-87fd-7a165d3c73a3">
        <source>pxyCreateUpdateProxy(): SelfType;
// --------------------------------------------------------------------------------
// Created:		7 December 2009 by cnwjo3
//
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	pxy				: CM_VoyageAllocationConfig;
	completedOK		: Boolean;
	
begin
	pxy := inheritMethod();

	pxy.myVoyage := self.myVoyage;
	pxy.myYACriteriaTypeForColour := self.myYACriteriaTypeForColour;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="cb77dc33-b833-4446-bd92-86c02caf5490">
        <updating/>
        <source>setForCreate(_yaConfig : CM_YAConfig; _imexStatus: Integer;  _defaultColourType : CM_YACriteriaType) updating;
// --------------------------------------------------------------------------------
// Created:		7 December 2009 by cnwjo3
//
// Purpose:		Look pretty.  Not going to use this method in the future
//
vars

begin
	self.myIMEXStatus := app.myRoot.allImexStatuses[_imexStatus];
end;</source>
        <Parameter name="_yaConfig" type="CM_YAConfig"/>
        <Parameter name="_imexStatus" type="Integer"/>
        <Parameter name="_defaultColourType" type="CM_YACriteriaType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="76968da6-42db-4917-9748-0321b44f4be3">
        <updating/>
        <source>setForUpdate(_proxyYAIMEXConfig: CM_VoyageAllocationConfig) updating;
// --------------------------------------------------------------------------------
// Created:		7 December 2009 by cnwjo3
//
vars

begin
	self.allOpCriteria.clear;
	_proxyYAIMEXConfig.allOpCriteria.copy(self.allOpCriteria);
	
	self.myYACriteriaTypeForColour := _proxyYAIMEXConfig.myYACriteriaTypeForColour;
end;</source>
        <Parameter name="_proxyYAIMEXConfig" type="CM_VoyageAllocationConfig"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateIMEX" id="16df0e45-f359-47dc-9b9f-40d18a99bc8b">
        <updating/>
        <source>setForUpdateIMEX() updating;
// --------------------------------------------------------------------------------
// Created:		7 December 2009 by cnwjo3
//
// Purpose:		set IMEX Status
//
vars

begin
	self.myIMEXStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
end;</source>
    </JadeMethod>
    <JadeMethod name="setForUpdateVoyage" id="b1f4dedf-4c82-4f6a-8bb2-a94062c694a2">
        <updating/>
        <source>setForUpdateVoyage(_voyage : CM_Voyage) updating;
// --------------------------------------------------------------------------------
// Created:		7 December 2009 by cnwjo3
//
vars

begin
	self.myVoyage := _voyage;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setNullVoyage" id="773535ac-7d6f-409b-943d-35d09c0c2b37">
        <updating/>
        <source>setNullVoyage() updating;
// --------------------------------------------------------------------------------
// Created:		8 December 2009 by cnwjo3
//
// Purpose:		Quick and dirty.  SHouldn't program like this ever
//
vars

begin
	self.myVoyage := null;
end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyVoyage" id="472ea0ad-ce26-4e16-a5f4-0e9091bddbd0">
        <updating/>
        <source>setProxyVoyage(_opCriteriaColl, _groupLabelCriteriaColl : CM_YACriteriaTypeArray; _colour : Integer; _yaCriteriaType : CM_YACriteriaType; _myProxyVoyage : CM_Voyage; _defaultColourType : CM_YACriteriaType) updating;
// --------------------------------------------------------------------------------
// Created:		7 December 2009 by cnwjo3
//
vars

begin
	self.setProxy(_opCriteriaColl, _groupLabelCriteriaColl, _colour, _defaultColourType);
	
	self.myVoyage := _myProxyVoyage;
	
	self.myYACriteriaTypeForColour := _yaCriteriaType;
end;
</source>
        <Parameter name="_opCriteriaColl" type="CM_YACriteriaTypeArray"/>
        <Parameter name="_groupLabelCriteriaColl" type="CM_YACriteriaTypeArray"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_yaCriteriaType" type="CM_YACriteriaType"/>
        <Parameter name="_myProxyVoyage" type="CM_Voyage"/>
        <Parameter name="_defaultColourType" type="CM_YACriteriaType"/>
    </JadeMethod>
    <JadeMethod name="setYACriteriaTypeForColour" id="b644ebee-6b1d-4531-8ab7-322d6ec9f2c8">
        <updating/>
        <source>setYACriteriaTypeForColour(_criteriaType : CM_YACriteriaType ) updating;
/*

Date		Who		Reason
10 April 2017	cnwer1	Initial creation TFS 3614

*/

vars

begin

epilog
	self.myYACriteriaTypeForColour:=_criteriaType;
end;</source>
        <Parameter name="_criteriaType" type="CM_YACriteriaType"/>
    </JadeMethod>
