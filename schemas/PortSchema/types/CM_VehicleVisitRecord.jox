    <JadeMethod name="getOperatorCodesString" id="93ef096e-7780-4016-ab81-62e3070a4899">
        <source>getOperatorCodesString():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 October 2013	cnwndl1	Initial creation	Par 32587

*/

vars

	ti : CM_TrackedItem;
	tiSet : CM_TISet;
	op : CM_Operator;
	opSet : CM_OperatorSet;
	retString : String;
	strArray : StringArray;
	str : String;

begin

	create tiSet transient;
	self.allReceivedTrackedItems.copy(tiSet);
	foreach ti in self.allReleasedTrackedItems do
		tiSet.addNoDuplicates( ti, false );
	endforeach;
	
	create opSet transient;
	foreach ti in tiSet do
		op := ti.myOperator;
		if op &lt;&gt; null then
			opSet.addNoDuplicates( op, false );
		endif;
	endforeach;
	
	foreach op in opSet do
		if retString &lt;&gt; null then
			retString := retString &amp; ", ";
		endif;
		retString := retString &amp; op.code;
	endforeach;
	
	return retString;

epilog

	delete tiSet;
	delete opSet;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
