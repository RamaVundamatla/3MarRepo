    <JadeMethod name="uAddCodeGroupSourceLocations" id="854265e2-a0b0-4084-8d82-520dd9bc2c3b">
        <source>uAddCodeGroupSourceLocations();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 June 2013	cnwndl1	Initial creation

*/

vars

	index : Integer;
	codeGroup : CM_CodeGroup;
	
	iter : Iterator;
	deleteCodeSet : CM_CodeSet;
	subSub : CM_SourceSubSubLocation; 
	sub : CM_SourceSubLocation;
	sLoc : CM_SourceLocation;
	deleteCodeGroups : CM_CodeGroupsByTypeNameDict;

begin

	create deleteCodeSet transient;
	iter := CM_SourceSubSubLocation.instances.createIterator;
	while iter.next(subSub) do
		if subSub.description.pos("Test generated",1) &gt; 0 then
			deleteCodeSet.add(subSub);
		endif;
	endwhile;
	if not deleteCodeSet.isEmpty then
		beginTransaction;
		deleteCodeSet.purge();
		commitTransaction;
	endif;
	delete deleteCodeSet;
	delete iter;
	
	create deleteCodeSet transient;
	iter := CM_SourceSubLocation.instances.createIterator;
	while iter.next(sub) do
		if sub.description.pos("Test generated",1) &gt; 0 then
			deleteCodeSet.add(sub);
		endif;
	endwhile;
	if not deleteCodeSet.isEmpty then
		beginTransaction;
		deleteCodeSet.purge();
		commitTransaction;
	endif;
	delete deleteCodeSet;
	delete iter;
	
	create deleteCodeSet transient;
	iter := CM_SourceLocation.instances.createIterator;
	while iter.next(sLoc) do
		if sLoc.description.pos("Test generated",1) &gt; 0 then
			deleteCodeSet.add(sLoc);
		endif;
	endwhile;
	if not deleteCodeSet.isEmpty then
		beginTransaction;
		deleteCodeSet.purge();
		commitTransaction;
	endif;
	delete deleteCodeSet;
	delete iter;
	
	create deleteCodeGroups transient;
	iter := app.myRoot.allCodeGroups.createIterator;
	while iter.next(codeGroup) do
		if codeGroup.groupType &lt;&gt; CodeGroup_SourceLocation then
			continue;
		endif;
		if codeGroup.name.pos("Test",1) = 1 then
			deleteCodeGroups.add(codeGroup);
		endif;
	endwhile;
	if not deleteCodeGroups.isEmpty then
		beginTransaction;
		deleteCodeGroups.purge();
		commitTransaction;
	endif;
	delete deleteCodeGroups;
	delete iter;

	foreach index in 1 to 60 do

		
		
		codeGroup := app.myRoot.allCodeGroups.getAtKeyGeq(CodeGroup_SourceLocation, "Test" &amp; index.padLeadingWith("0",2) );
		if codeGroup = null or codeGroup.groupType &lt;&gt; CodeGroup_SourceLocation then
			codeGroup := self.addCodeGroup( "Test" &amp; index.padLeadingWith("0",2), CodeGroup_SourceLocation );
		else
			continue;
		endif;
	
		self.addSourceLocation( codeGroup,	//_codeGroup : CM_CodeGroup;
								"A" &amp; index.padLeadingWith("0",2),	//_code : String;
								"Test generated",	//_description : String;
								10,	//_numSubs : Integer;
								10	//_numSubSubs :Integer
								);
								
		self.addSourceLocation( codeGroup,	//_codeGroup : CM_CodeGroup;
								"B" &amp; index.padLeadingWith("0",2),	//_code : String;
								"Test generated",	//_description : String;
								10,	//_numSubs : Integer;
								10	//_numSubSubs :Integer
								);
								
		self.addSourceLocation( codeGroup,	//_codeGroup : CM_CodeGroup;
								"C" &amp; index.padLeadingWith("0",2),	//_code : String;
								"Test generated",	//_description : String;
								10,	//_numSubs : Integer;
								10	//_numSubSubs :Integer
								);
								
		self.addSourceLocation( codeGroup,	//_codeGroup : CM_CodeGroup;
								"D" &amp; index.padLeadingWith("0",2),	//_code : String;
								"Test generated",	//_description : String;
								10,	//_numSubs : Integer;
								10	//_numSubSubs :Integer
								);
								
		self.addSourceLocation( codeGroup,	//_codeGroup : CM_CodeGroup;
								"E" &amp; index.padLeadingWith("0",2),	//_code : String;
								"Test generated",	//_description : String;
								10,	//_numSubs : Integer;
								10	//_numSubSubs :Integer
								);
								
		self.addSourceLocation( codeGroup,	//_codeGroup : CM_CodeGroup;
								"F" &amp; index.padLeadingWith("0",2),	//_code : String;
								"Test generated",	//_description : String;
								10,	//_numSubs : Integer;
								10	//_numSubSubs :Integer
								);
							
	endforeach; 

epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="uAddContainer" id="ae3eb506-bb03-43ce-93cf-f35ce46b84ce">
        <source>uAddContainer();
//26 September 2008	cnwdw1	
//
vars
	id: String;
	isoType: String;
	commodity: String;
	operator: String;
	imex: String;
	location: String;
	lc: CM_LocationsController;
	height: Integer;
	ti: CM_TrackedItem;
	count: String;
	i: Integer;
begin
	id := "id";
	read id;
	isoType := "isoType";
	read isoType;
	commodity := "commodity";
	read commodity;
	operator := "operator";
	read operator;
	imex := "imex - I, E or S";
	read imex;
	if imex = "I" then
		self.opts.addAssociation("IMEX", TI_IMEX_STATUS_IMPORT);
	elseif imex = "E" then
		self.opts.addAssociation("IMEX", TI_IMEX_STATUS_EXPORT);
	else
		self.opts.addAssociation("IMEX", TI_IMEX_STATUS_STORAGE);
	endif;
	location := "location";
	read location;
	count := "Number to create";
	read count;
	
	if location &lt;&gt; null then
		if count.Integer = 0 then
			ti := addContainerOpts(id, isoType, commodity, self.getOperator(operator));	
			getTerminal.findLocationFromString(location, false, lc, height);
			move(ti, lc);
		else
			foreach i in 1 to count.Integer do
				ti := addContainerOpts(id&amp; i.String.cnEcPadzeros(count.length), isoType, commodity, self.getOperator(operator));	
				assertNotNull(ti);
				getTerminal.findLocationFromString(location, false, lc, height);
				move(ti, lc);
			endforeach;
		endif;
	endif;
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="uAddContainerGrid" id="870b8776-d3e0-484c-b51b-30330e2372be">
        <source>uAddContainerGrid();
//26 September 2008	cnwdw1	
//
vars
	id: String;
	isoType: String;
	commodity: String;
	operator: String;
	imex: String;
	location: String;
	lc: CM_LocationsController;
	height: Integer;
	ti: CM_TrackedItem;
	count: String;
	idx : Integer;
	tmpID : String;
	i, nextNum: Integer;
	gridArea : CM_GridArea;
	row : Integer;
	gridRow : CM_GridRow;
begin
	id := "id";
	read id;
	isoType := "isoType";
	read isoType;
	commodity := "commodity";
	read commodity;
	operator := "operator";
	read operator;
	imex := "imex - I, E or S";
	read imex;

	if imex = "I" then
		self.opts.addAssociation("IMEX", TI_IMEX_STATUS_IMPORT);
	elseif imex = "E" then
		self.opts.addAssociation("IMEX", TI_IMEX_STATUS_EXPORT);
	else
		self.opts.addAssociation("IMEX", TI_IMEX_STATUS_STORAGE);
	endif;
	location := "location";
	read location;
	count := "Number to create";
	read count;
	
	if location &lt;&gt; null then
		if count.Integer = 0 then
			ti := addContainerOpts(id, isoType, commodity, self.getOperator(operator));	
			getTerminal.findLocationFromString(location, false, lc, height);
			move(ti, lc);
		else
			gridArea := getTerminal().allTerminalAreas[location].CM_GridArea;
			row := 1;
//			idx := count.Integer;
			foreach i in 1 to count.Integer do : outerLoop

				while true do : idLoop
					nextNum := nextNum + 1;
					
					tmpID := id &amp; nextNum.String.cnEcPadzeros(count.length);
					if getTerminal().allOnsiteTIsByIdCargoType[tmpID, TI_CargoType_Container] = null then
						break idLoop;
					endif;
				endwhile;
				
				ti := addContainerOpts(tmpID, isoType, commodity, self.getOperator(operator));	
				assertNotNull(ti);
				
				while true do
					gridRow := gridArea.allGridRows[row];
					if gridRow = null then
						break outerLoop;
					endif;
					lc := gridRow.getNextAvailableLocation(1);
					if lc = null then
						row := row + 1;
					else
						break;
					endif;
				endwhile;
				move(ti, lc);
			endforeach;
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
