//04 December 2008	cnwdw1	
//
vars

begin
	_theTable.refresh;
end;
</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setViewMode" id="f4ac5f98-5aaa-478a-88a1-4dae70a71f76">
        <source>setViewMode( _viewMode : Integer) : Integer;
/*

Date		Who		Reason
22 July 2013	cnwer1	Initial creation PAR

*/

vars
	viewMode : Integer;
begin
    viewMode := _viewMode;				
	
	if viewMode = VIEW_COMMODITY then
		self.btnViewCommodity.value:=true;
	elseif viewMode = VIEW_CONSIGNEE then
		self.btnViewCommodity.value:=true;
	elseif viewMode = VIEW_DISPORT then
		self.btnViewDischarge.value:=true;
	elseif viewMode = VIEW_ISOGROUP then
		self.btnViewISOGroup.value:=true;
	elseif viewMode =VIEW_OPERATOR then
		self.btnViewOperator.value:=true;
	elseif  viewMode = VIEW_STATUS  then	
		self.btnViewStatus.value:=true;
	elseif   viewMode = VIEW_TEMPERATURE then
		self.btnViewTempRange.value:=true;
	else
		self.btnViewVoyage.value := true;
		viewMode := VIEW_VOYAGE;
	endif;
	return viewMode;
end;
</source>
        <Parameter name="_viewMode" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setYardAllocLegend" id="f5825787-8cb2-4ced-b055-00e9d23a6138">
        <updating/>
        <source>setYardAllocLegend() updating;
// ---------------------------------------------------------------------------
// Created:		June 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anObj,yalloc : Object;
	cdc : YRD_RoRoLaneDrawingController;
	objSet : ObjectSet;
	vMode : Integer;
begin
	create objSet transient;
	foreach anObj in self.allDrawingControllers do
		cdc := anObj.YRD_RoRoLaneDrawingController;
		vMode := cdc.viewMode;
		// Need rethinking!! Invalid object created by notes coming in after this stuff. Invalid object is
		// rectified but after this method as already been called.
		foreach yalloc in cdc.myDrawingAttrController.allYardAllocations where global.isValidObject(yalloc) do
			if yalloc.CM_YardAllocation.isDisabled then
				continue;
			endif;
			objSet.addNoDuplicates(yalloc,false);
		endforeach;
		
	endforeach;

	foreach anObj in self.allDrawingControllers do
		cdc := anObj.YRD_RoRoLaneDrawingController;
		cdc.myDrawingAttrController.allYardAllocations.clear;
		objSet.copy(cdc.myDrawingAttrController.allYardAllocations);
		
	endforeach;

	self.doNotesForLegendStartStop(vMode,cdc);

epilog
	delete objSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="f5cd9bb3-323c-49ca-b0a3-7949fec3a44a">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     21 January 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	self.frmToolbar.alignContainer := Frame.AlignContainer_Top; // this will make the dkcMain line up its top

	self.showToolbar := true;
	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;

	self.defYardBackColUnselected := self.myTerminal.getConfig(DefYardBackColUnselected).Integer;
	self.defYardBackColSelected := self.myTerminal.getConfig(DefYardBackColSelected).Integer;

	self.initSelectAreasGroupBox();
	self.initSelectAreasCollection();		
	
	self.doInitInfoTable();
	
	self.tblYAM.setForm(self);
	self.tblYAM.initialise(true, self.fraPictures, self.pic1, self.pic2, self.pic3);
	
	if self.xmlYA then
		self.btnViewYardAlloc.value := true;
		self.doBtnViewYardAllocClick();
		self.tblYAM.expandAllYALocations(false);
	endif;	

	// this sets the captions for some menus
	self.getXMLSettingsForSetup();
	
	if self.xmlLegend then
		self.mnuGridHideLegend.caption := self.MNU_LEGEND_HIDE;
	else
		self.dkbColorLegend.visible := false;
		self.mnuGridHideLegend.caption := self.MNU_LEGEND_SHOW;

	endif;
	self.mnuGridHideLegend_click(self.mnuGridHideLegend); // this reverses the lines above and sets things correctly
	// must set the width AFTER the click call above
	self.dkbColorLegend.width := 100;
	self.dkbCargoPic.visible:=self.myTerminal.getConfig(ShowCargoPicture).Boolean;
	self.dkbGridArea.isForRoRoLanes := true;

	if self.xmlMacro then
		self.mnuGridHideMacro.caption := self.MNU_MACRO_HIDE;
	else
		self.mnuGridHideMacro.caption := self.MNU_MACRO_SHOW;
	endif;
	self.mnuGridHideMacro_click(self.mnuGridHideMacro); // this reverses the lines above and sets things correctly

	if self.xmlDirections then		// 11/10/17 MAP TFS7084
		self.mnuGridHideDirections.caption := self.MNU_DIRECTIONS_HIDE;
	else
		self.mnuGridHideDirections.caption := self.MNU_DIRECTIONS_SHOW;
	endif;
	
	self.frmStatusLine.initFrame();
	inheritMethod();
	
	//cnwvu1 PAR 13144 - display caption when minimised first initialise
	if self.windowState = self.WindowState_Minimized then
		self.doSetCaption();
	endif;


end;</source>
    </JadeMethod>
    <JadeMethod name="showArea" id="5495e8e7-ee18-4f4d-8a09-f2a930ff5398">
        <updating/>
        <source>showArea(_area : CM_RoRoLaneArea; _index : Integer; _viewMode : Integer; _isSelected : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	numDB : Integer;
	cdc : YRD_RoRoLaneDrawingController;
	ydb : YRD_ContainerGridAreaDockBar;
	tmpScrollableFrame	: CMUI_ScrollableFrame;
	tmpController	: YRD_RoRoLaneDrawingController;
	tmpDkbGridArea	: CMUI_GridAreaDockBar;
begin
	
	
	self.dkbGridArea.visible := false;
	self.dkcGridArea.visible := true;
	self.tblGridAreaInfo.rows := 0;
	
	// NOTE. the create of YDB creates the frames etc.
	ydb := self.dkbGridArea.cloneSelf(true);
	self.allDockBars.add(ydb);
	
	self.addControl(ydb);  //this is the issue cnwjo3
	ydb.parent := self.dkcGridArea;
	ydb.visible := true;
	ydb.postCreate();
	ydb.myRoRoLaneDrawingController.myRoRoLaneAreaForm := self;
	//ydb.left := _index;		//cnwmc5 - 14 Oct 2013 - PAR 32794 - Don't understand why this is here? Seems to be breaking order..

	self.myDrawingFrame := ydb.myDrawingFrame; 
	self.myDrawingFrame.doAutoScrolling := true;
	cdc := ydb.myRoRoLaneDrawingController;
	cdc.showDrawingFrame(false);

	self.setMyCurrentDrawingController(ydb.myRoRoLaneDrawingController, false);
	ydb.myDrawingFrame.myDragSelectFrame.visible := false;
	
	ydb.setHLabelDetails(0, false);
	ydb.setVLabelDetails(0, false);
	// when able add labels as virtual to CMUI_GridAreaDockBar and
	// make dkbGridArea.myScrollableFrame protected
	tmpScrollableFrame := ydb.myScrollableFrame;
	tmpScrollableFrame.labels := ScrollBars_Both;

	cdc.setYAMTable(self.tblYAM);
	cdc.setFlip(self.xmlFlipH,self.xmlFlipV);
	//cnwjo3 par 19907
	if self.xmlZoomFactor &gt; 0 then
		cdc.setScale(self.xmlZoomFactor, true, true); 
	else
		cdc.setScale(1, true, true);
	endif;

	
	cdc.moveMode := self.moveModeForm;
	cdc.init(_area);
	cdc.setViewMode(_viewMode);
	cdc.drawSelf(true);
	cdc.notableObjectsClear();
	cdc.notableObjectAdd(_area);
	
	if _isSelected then
		ydb.myDrawingFrame.changeRoRoBackColor(self.defYardBackColSelected);
	else
		ydb.myDrawingFrame.changeRoRoBackColor(self.defYardBackColUnselected);	
		
	endif;
	ydb.cnEcResizeContents();

	self.myCurrentDrawingController.setScale(self.xmlZoomFactor, true, true);



	
end;</source>
        <Parameter name="_area" type="CM_RoRoLaneArea"/>
        <Parameter name="_index" type="Integer"/>
        <Parameter name="_viewMode" type="Integer"/>
        <Parameter name="_isSelected" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showAreaSelector" id="e4ca8006-ee9c-4bac-8a9e-d6d1da52d89f">
        <source>showAreaSelector();
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theFrame : CMUI_MoveableFrame;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	theFrame := self.frmSelectAreas;
	
	theFrame.centreHorizontallyInParent();
	theFrame.top := 100;
	
	theFrame.zOrder(1);
	self.msgSelectAreas.width := 327;

	self.msgSelectAreas.setSelected(self.allTerminalAreas);
	self.showAreaSelectorEnable(true);
epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="showAreaSelectorEnable" id="8fe2293e-da71-41a7-91f7-e864c8acc7d4">
