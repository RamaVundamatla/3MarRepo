    <JadeMethod name="delete" id="6e7efd91-6ae1-40b0-b640-dd074f249f1a">
        <updating/>
        <source>delete() updating;
/* ---------------------------------------------------------------------------
Created:     08 June 2009 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin
	self.allAvailableVMObjects.purge();
	self.allSelectedVMObjects.purge();
	self.allOpTerminalConfigs.purge();
	//epr TFS 3581 6/3/17 leaking transients
	delete self.myViewListboxAvailable;
	delete self.myViewListboxSelected;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doAddNewEmail" id="a442b9e3-ae95-4c78-a609-b242b58cb5e8">
        <source>doAddNewEmail(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 August 2009	cnwndl1	Initial creation CCMS 1609 Par 20521

*/

vars

	errObj					: CM_Error;
	ignoreWarnings,rtnValue	: Boolean;
	newEmailAddress,
	proxyEmailAddress		: CM_EmailAddress2;
	lEmailAddress, lTitle	: String; 
	theForm					: SOP_TableMaintForm;
	objectArray				: CM_ObjectArray;
	
begin

	theForm := self.myForm; 

	lTitle := theForm.txtEmailName.getControl(2).text.trimWhiteSpace;
	lEmailAddress := theForm.txtName.getControl(2).text.trimWhiteSpace;

 	create proxyEmailAddress transient;
	
	proxyEmailAddress.setProxyForEmailAddress(lTitle, lEmailAddress, null);

	app.myTrxCA.trxCreateEmailAddress2(proxyEmailAddress, newEmailAddress,app.myPassport);
	
	if newEmailAddress &lt;&gt; null then
		create objectArray transient;
		theForm.mulSelect2.getSelected(objectArray);
		objectArray.add(newEmailAddress);
		theForm.mulSelect2.setAvailable(app.myRoot.allEmailEntities, true);
		theForm.mulSelect2.setSelected(objectArray);
		
		theForm.txtEmailName.getControl(2).text := null;
		theForm.txtName.getControl(2).text := null;
	endif;

	return app.myPassport.trxCompletedOK;
	
epilog

	delete objectArray;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doBtnAdvanced" id="d3d618e0-2a81-4084-826a-931392501ea7">
        <updating/>
        <source>doBtnAdvanced() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 Sep 2009	cnwkpd1	PAR #20398 - Add Booking Reference cross reference functionality
					Refactored out from SOP_TableMaintForm
					
*/

vars
	theForm 		: SOP_TableMaintForm;
	selectedObj		: Object;
	settingsFormObj	: SOP_OperatorAdvSettingsForm;
	
begin
	theForm := self.myForm;
	selectedObj	:= theForm.myCurrentObject;
	
	if selectedObj.isKindOf(CM_Operator) then
		create settingsFormObj;
		settingsFormObj.setOpertator(selectedObj.CM_Operator);
		settingsFormObj.showModal();
	endif;

	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doComboTerminalClick" id="b908e7db-edcd-4163-bf46-26c50b4c5ba2">
        <updating/>
        <source>doComboTerminalClick() updating;

vars

	theForm 	: SOP_TableMaintForm;
	operator	: CM_Operator;


begin

	theForm := self.myForm;

	self.initRecCutoffsTbl();	// 24/05/2009 cnwar2 CCMS1040/#19796
	
	//self.setOperatorTerminalConfig();
	if theForm.mode = theForm.Mode_View then
		operator := theForm.myCurrentObject.CM_Operator;
	else
		operator := theForm.myProxyObject.CM_Operator;
	endif;
	
	self.getOperatorTerminalConfig(operator);
	
end;</source>
    </JadeMethod>
