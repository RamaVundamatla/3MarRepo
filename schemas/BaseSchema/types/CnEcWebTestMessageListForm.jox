    <JadeMethod name="doEnableButtonsTest" id="94179e0d-fe63-488b-9bcc-b3cded70664a">
        <source>doEnableButtonsTest() protected;
// --------------------------------------------------------------------------------
// Created:		13 June 2000 by cnwdad1
//
// Purpose:		Set the currently enabled button controls.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	isIncludeSelected	: Boolean;
	isAvailableSelected	: Boolean;

begin
	isIncludeSelected		:=	(lstTestIncluded.listIndex &lt;&gt; CNEC_NULL_INDEX);
	isAvailableSelected		:=	(lstTestMessages.listIndex &lt;&gt; CNEC_NULL_INDEX);

	btnTestInsert.enabled	:=	isAvailableSelected;
	optTestAbove.enabled	:=	isAvailableSelected;
	optTestBelow.enabled	:=	isAvailableSelected;
	btnTestRemove.enabled	:=	isIncludeSelected;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFormLoad" id="519eada2-aac1-4088-a308-b414e12fb27d">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		13 June 2000 by cnwdad1
//
// Purpose:		Standard form load method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	centreWindow();
	self.doLoadMessageProperties();
	self.doEnableButtonsTest();
	self.doShowTestDetails(self.aMyWebTest);
	modalResult	:=	0;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadMessageProperties" id="53837af9-13e8-467d-9e98-67a8fec5d5b9">
        <updating/>
        <source>doLoadMessageProperties() updating, protected;
// --------------------------------------------------------------------------------
// Created:		13 June 2000 by cnwdad1
//
// Purpose:		Populate the receiver's control with a list of the web test's messages.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.setFormCaption(CAPTION_NAME, false, false);
	self.lblTestName.caption	:=	self.aMyWebTest.testName;
	lstTestMessages.listCollection(app.myBaseRoot.allWebTestMessages, true, 0);
	optTestBelow.value			:=	true;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doShowTestDetails" id="da615c76-3e44-421c-80c3-264ac239f7da">
        <source>doShowTestDetails(pWebTest:CnEcWebTest) protected;
// --------------------------------------------------------------------------------
// Created:		13 June 2000 by cnwdad1
//
// Purpose:		Populate a listbox with a list of all of the web test's included messages.
//
// Parameters:	pWebTest - The web test who's included messages to populate.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pWebTest = null then
		lstTestIncluded.clear();
		optTestAbove.value		:=	false;
		optTestBelow.value		:=	true;
		btnTestInsert.enabled	:=	false;
		btnTestRemove.enabled	:=	false;
	else
		lstTestIncluded.listCollection(pWebTest.allMessagesToTest, true, 0);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pWebTest" type="CnEcWebTest"/>
    </JadeMethod>
    <JadeMethod name="doTestMessageInsert" id="b644a815-3ee9-4fa4-8a78-c027a3cbdefb">
        <updating/>
        <source>doTestMessageInsert():Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		13 June 2000 by cnwdad1
//
// Purpose:		Insert a web test message into the web test's included list.  This
//				involes calling an updating transaction.
//
// Parameters:	None
//
// Returns:		True if the method succeeded, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	webTest			: CnEcWebTest;
	testMessage		: CnEcWebTestMessage;

begin
	webTest	:=	self.aMyWebTest;

	if webTest = null then
		self.aError	:=	"Please select the Web Test you wish to add the Message to.";
	else
		testMessage	:=	lstTestMessages.listObject.CnEcWebTestMessage;

		if testMessage = null then
			self.aError	:=	"Please select the Message that you wish to add to the Web Test.";
		else
			self.aError	:=	self.aMyTA.valWebTestTestMessageAdd(webTest, testMessage, lstTestIncluded.listIndex, optTestAbove.value);

			if self.aError = null then
				self.aError	:=	self.aMyTA.trxWebTestTestMessageAdd(webTest, testMessage, lstTestIncluded.listIndex, optTestAbove.value);
			endif;
		endif;
	endif;

	return self.doShowError();
epilog
	self.doEnableButtonsTest();
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTestMessageRemove" id="d8bb4b5f-06a6-405e-96f6-7376664ae7dd">
        <updating/>
        <source>doTestMessageRemove():Boolean updating, protected;
// --------------------------------------------------------------------------------
// Created:		13 June 2000 by cnwdad2
//
// Purpose:		Remove a web test message from the web test's included list.  This
//				involes calling an updating transaction.
//
// Parameters:	None
//
// Returns:		True if the method succeeded, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	webTest		: CnEcWebTest;

begin
	webTest	:=	self.aMyWebTest;

	if webTest = null then
		self.aError	:=	"Please select the Web Test you wish to remove the Message from.";
	else
		self.aError	:=	self.aMyTA.valWebTestTestMessageRemove(webTest, lstTestIncluded.listIndex);

		if self.aError = null then
			self.aError	:=	self.aMyTA.trxWebTestTestMessageRemove(webTest, lstTestIncluded.listIndex);

			if self.aError = null then
				lstTestIncluded.listIndex	:=	CNEC_NULL_INDEX;
			endif;
		endif;
	endif;

	return self.doShowError();
epilog
	self.doEnableButtonsTest();
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
