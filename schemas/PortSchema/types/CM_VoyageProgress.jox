    <JadeMethod name="comparisonOKForOperator" id="97be9c30-bf4e-4d9b-a760-bd0c51419961">
        <source>comparisonOKForOperator(_comparisonAgent : CM_LoadListComparisonAgent; _operator : CM_Operator) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2024	navra1	Initial creation for //navra1 - MTN-33185 - 1th Nov 2024

*/

vars
	ediTI : CM_EDITrackedItem;
	currentOperatorCode : String;
	currPortCode : String;						//navra1 - DEFECT-33512 - 26th Nov 2024

begin
	currentOperatorCode := _operator.code;
	
	currPortCode := self.myVoyage.myTerminal.getConfig(PortDestCode).String.trimBlanks();	//navra1 - DEFECT-33512 - 26th Nov 2024

	if (_comparisonAgent.allDiscrepancyTIs &lt;&gt; null and _comparisonAgent.allDiscrepancyTIs.size() &gt; 0) then
		foreach ediTI in _comparisonAgent.allDiscrepancyTIs do
			//navra1 - DEFECT-33512 - 26th Nov 2024 - start
			//should this TI be compared at all? it might be a TI that just got loaded or discharged
			if _comparisonAgent.comparisonMode = TI_IMEX_STATUS_IMPORT then	//ie.DISCHARGE_COMPARISON
				if ediTI.CM_EDILoadListTI.loadPort = currPortCode then
					continue;	//this is load cargo for this vessel and would be considered in load comparison, so dont consider it now as a part of DISCHARGE_COMPARISON				
				endif;
			else															//ie.LOAD_COMPARISON
				if ediTI.CM_EDILoadListTI.dischargePort = currPortCode then
					continue;	//this is discharge cargo for this vessel and would be considered in discharge comparison, so dont consider it now as a part of LOAD_COMPARISON
				endif;
			endif;
			//navra1 - DEFECT-33512 - 26th Nov 2024 - end
		
			if ediTI.CM_EDILoadListTI.operatorCode = currentOperatorCode then
				return false;
			endif;
		endforeach;
	endif;
	
	if (_comparisonAgent.allUnmatchedDBTIs &lt;&gt; null and _comparisonAgent.allUnmatchedDBTIs.size() &gt; 0) then
		foreach ediTI in _comparisonAgent.allUnmatchedDBTIs do
			//navra1 - DEFECT-33512 - 26th Nov 2024 - start
			//should this TI be compared at all? it might be a TI that just got loaded or discharged
			if _comparisonAgent.comparisonMode = TI_IMEX_STATUS_IMPORT then	//ie.DISCHARGE_COMPARISON
				if ediTI.CM_EDILoadListTI.loadPort = currPortCode then
					continue;	//this is load cargo for this vessel and would be considered in load comparison, so dont consider it now as a part of DISCHARGE_COMPARISON				
				endif;
			else															//ie.LOAD_COMPARISON
				if ediTI.CM_EDILoadListTI.dischargePort = currPortCode then
					continue;	//this is discharge cargo for this vessel and would be considered in discharge comparison, so dont consider it now as a part of LOAD_COMPARISON
				endif;
			endif;
			//navra1 - DEFECT-33512 - 26th Nov 2024 - end
			
			if ediTI.CM_EDILoadListTI.operatorCode = currentOperatorCode then
				return false;
			endif;
		endforeach;
	endif;
	
	if (_comparisonAgent.allUnmatchedLLTIs &lt;&gt; null or _comparisonAgent.allUnmatchedLLTIs.size() &gt; 0) then
		foreach ediTI in _comparisonAgent.allUnmatchedLLTIs do
			//navra1 - DEFECT-33512 - 26th Nov 2024 - start
			//should this TI be compared at all? it might be a TI that just got loaded or discharged
			if _comparisonAgent.comparisonMode = TI_IMEX_STATUS_IMPORT then	//ie.DISCHARGE_COMPARISON
				if ediTI.CM_EDILoadListTI.loadPort = currPortCode then
					continue;	//this is load cargo for this vessel and would be considered in load comparison, so dont consider it now as a part of DISCHARGE_COMPARISON				
				endif;
			else															//ie.LOAD_COMPARISON
				if ediTI.CM_EDILoadListTI.dischargePort = currPortCode then
					continue;	//this is discharge cargo for this vessel and would be considered in discharge comparison, so dont consider it now as a part of LOAD_COMPARISON
				endif;
			endif;
			//navra1 - DEFECT-33512 - 26th Nov 2024 - end
		
			if ediTI.CM_EDILoadListTI.operatorCode = currentOperatorCode then
				return false;
			endif;
		endforeach;
	endif;	
	
	return true;

epilog

end;</source>
        <Parameter name="_comparisonAgent" type="CM_LoadListComparisonAgent"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createOrUpdateVoyageStage" id="745e662f-c140-4668-92b5-882884109171">
        <source>createOrUpdateVoyageStage(_stageNameInteger : Integer ; 
							_voyageProgress : CM_VoyageProgress; 
							_operatorCode : String; 
							_stageStatus : Integer; 
							_stageType : Integer ; 
							_invoiceList : CM_InvoiceBySeqNumDict;
							_debtorCode : String;
							_ediData : CM_EDIData;									//navra1 - MTN-34348 - 13th March 2025
							_ediDataDesc : String;									//navra1 - MTN-34348 - 13th March 2025
							_failureMessage : String;
							_failureDescription : String) : CM_VoyageStage;			//navra1 - CR 66185 - 18th Sep 2024
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 July 2024	navra1	Initial creation for //navra1 - CR 65374 - 26th July 2024

*/

vars
	proxyVoyStage : CM_VoyageStage;
	voyageStageExisting : CM_VoyageStage;
	shouldCreateDuplicateStage : Boolean;			//navra1 - MTN-34829 - 8th May 2025
begin
	//check if there already existing stage a stage for this _stageName for this operator, and update that
	voyageStageExisting := self.getStageForOperator(_stageNameInteger, _operatorCode, _stageType);			//navra1 - MTN-34829 - 8th May 2025
	
	if voyageStageExisting = null then
		create proxyVoyStage transient;
		proxyVoyStage.setProxy(_stageNameInteger, _voyageProgress, _operatorCode, _stageStatus, _stageType, _invoiceList, _debtorCode, _ediData, _failureMessage, _failureDescription);			//navra1 - CR 66185 - 18th Sep 2024	//navra1 - MTN-34348 - 13th March 2025
		
		if process.isInTransactionState() then
			app.myUtilityCA.utlCreateVoyStageForOpAndVoy(proxyVoyStage, voyageStageExisting, app.myPassport);
		else
			app.myTrxCA.trxCreateVoyStageForOpAndVoy(proxyVoyStage, voyageStageExisting, app.myPassport);		
		endif;
	else	
		proxyVoyStage := app.createUpdateProxy(voyageStageExisting).CM_VoyageStage;
		proxyVoyStage.setProxy(_stageNameInteger, _voyageProgress, _operatorCode, _stageStatus, _stageType, _invoiceList, _debtorCode, _ediData, _failureMessage, _failureDescription);		//navra1 - MTN-34348 - 13th March 2025
		
		if process.isInTransactionState() then
			app.myUtilityUA.utlUpdateVoyStageForOpAndVoy(proxyVoyStage, app.myPassport);	
		else
			app.myTrxUA.trxUpdateVoyStageForOpAndVoy(proxyVoyStage, app.myPassport);	
		endif;
	endif;
	
	return voyageStageExisting;
epilog	
	delete proxyVoyStage;
end;</source>
        <Parameter name="_stageNameInteger" type="Integer"/>
        <Parameter name="_voyageProgress" type="CM_VoyageProgress"/>
        <Parameter name="_operatorCode" type="String"/>
        <Parameter name="_stageStatus" type="Integer"/>
        <Parameter name="_stageType" type="Integer"/>
        <Parameter name="_invoiceList" type="CM_InvoiceBySeqNumDict"/>
        <Parameter name="_debtorCode" type="String"/>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <Parameter name="_ediDataDesc" type="String"/>
        <Parameter name="_failureMessage" type="String"/>
        <Parameter name="_failureDescription" type="String"/>
        <ReturnType type="CM_VoyageStage"/>
    </JadeMethod>
    <JadeMethod name="getComparisonFailureDesc" id="995cdf6e-29ab-4256-b460-e620b69cccc3">
        <source>getComparisonFailureDesc(comparisonAgent : CM_LoadListComparisonAgent; _operatorCode : String) : String;		//navra1 - MTN-34829 - 8th May 2025
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 October 2024	navra1	Initial creation for //navra1 - MTN-33017 - 11th Oct 2024

*/

vars
	desc : String;
	llTI : CM_EDITrackedItem;
	discrepancies : String;
	dis : String;
	currPortCode : String;							//navra1 - DEFECT-33512 - 26th Nov 2024
	operatorStr : String;							//navra1 - MTN-34829 - 8th May 2025
	needHeading : Boolean;							//navra1 - MTN-36063 - 24th Sep 2025
	
begin

	currPortCode := self.myVoyage.myTerminal.getConfig(PortDestCode).String.trimBlanks();		//navra1 - DEFECT-33512 - 26th Nov 2024
	
	//navra1 - MTN-34829 - 8th May 2025 - start
	if _operatorCode &lt;&gt; null then
		operatorStr := "(Operator : " &amp; _operatorCode &amp; ")";
	else
		operatorStr := "(Operators : All)";
	endif;
	//navra1 - MTN-34829 - 8th May 2025 - end
	
	if comparisonAgent.allDiscrepancyTIs &lt;&gt; null and comparisonAgent.allDiscrepancyTIs.size() &gt; 0 then		
		needHeading := true;					//navra1 - MTN-36063 - 24th Sep 2025
		
		foreach llTI in comparisonAgent.allDiscrepancyTIs do		
			if llTI.isKindOf(CM_EDILoadListComparisonTI) then
				//navra1 - MTN-34829 - 8th May 2025 - start
				if _operatorCode &lt;&gt; null and _operatorCode &lt;&gt; llTI.CM_EDILoadListTI.operatorCode then
					continue;
				endif;
				//navra1 - MTN-34829 - 8th May 2025 - end
				
				//navra1 - DEFECT-33512 - 26th Nov 2024 - start
				//should this TI be compared at all? it might be a TI that just got loaded or discharged
				if comparisonAgent.comparisonMode = TI_IMEX_STATUS_IMPORT then	//ie.DISCHARGE_COMPARISON
					if llTI.CM_EDILoadListTI.loadPort = currPortCode then
						continue;	//this is load cargo for this vessel and would be considered in load comparison, so dont consider it now as a part of DISCHARGE_COMPARISON				
					endif;
				else															//ie.LOAD_COMPARISON
					if llTI.CM_EDILoadListTI.dischargePort = currPortCode then
						continue;	//this is discharge cargo for this vessel and would be considered in discharge comparison, so dont consider it now as a part of LOAD_COMPARISON
					endif;
				endif;
				//navra1 - DEFECT-33512 - 26th Nov 2024 - end
				
				//navra1 - MTN-36063 - 24th Sep 2025 - start
				if needHeading then
					desc := "The following pieces of cargo had discrepancies " &amp; operatorStr &amp; " : " &amp; CrLf;						//navra1 - MTN-34829 - 8th May 2025
					needHeading := false;
				endif;
				//navra1 - MTN-36063 - 24th Sep 2025 - end
				
				discrepancies := '';
				foreach dis in llTI.CM_EDILoadListComparisonTI.allDiscrepancyAttributes do
					discrepancies := discrepancies &amp; dis &amp; Comma;
				endforeach;
				discrepancies.stripTrailingChar(",");
				
				desc := desc &amp; "    " &amp; llTI.id &amp; '-' &amp; "Discrepancies in " &amp; discrepancies &amp; CrLf;
			endif;
		endforeach;
	endif;
		
	if comparisonAgent.allUnmatchedDBTIs &lt;&gt; null and comparisonAgent.allUnmatchedDBTIs.size() &gt; 0 then
		needHeading := true;					//navra1 - MTN-36063 - 24th Sep 2025
		
		foreach llTI in comparisonAgent.allUnmatchedDBTIs do
			if llTI.isKindOf(CM_EDILoadListTI) then					//navra1 - MTN-36063 - 24th Sep 2025
				//navra1 - MTN-34829 - 8th May 2025 - start
				if _operatorCode &lt;&gt; null and _operatorCode &lt;&gt; llTI.CM_EDILoadListTI.operatorCode then
					continue;
				endif;
				//navra1 - MTN-34829 - 8th May 2025 - end
				
				//navra1 - DEFECT-33512 - 26th Nov 2024 - start
				//should this TI be compared at all? it might be a TI that just got loaded or discharged
				if comparisonAgent.comparisonMode = TI_IMEX_STATUS_IMPORT then	//ie.DISCHARGE_COMPARISON
					if llTI.CM_EDILoadListTI.loadPort = currPortCode then
						continue;	//this is load cargo for this vessel and would be considered in load comparison, so dont consider it now as a part of DISCHARGE_COMPARISON				
					endif;
				else															//ie.LOAD_COMPARISON
					if llTI.CM_EDILoadListTI.dischargePort = currPortCode then
						continue;	//this is discharge cargo for this vessel and would be considered in discharge comparison, so dont consider it now as a part of LOAD_COMPARISON
					endif;
				endif;
				//navra1 - DEFECT-33512 - 26th Nov 2024 - end
				
				//navra1 - MTN-36063 - 24th Sep 2025 - start
				if needHeading then
					if desc = null then
						desc := "The following pieces of cargo were only found in the MTN Database " &amp; operatorStr &amp; " : " &amp; CrLf;						//navra1 - MTN-34829 - 8th May 2025
					else
						desc := desc &amp; CrLf &amp; "The following pieces of cargo were only found in the MTN Database " &amp; operatorStr &amp; " : " &amp; CrLf;		//navra1 - MTN-34829 - 8th May 2025
					endif;
					
					needHeading := false;					
				endif;
				//navra1 - MTN-36063 - 24th Sep 2025 - end
				
				desc := desc &amp; "    " &amp; llTI.id &amp; CrLf;					//navra1 - MTN-36063 - 24th Sep 2025
			endif;
		
			
		endforeach;
	endif;
	
	if comparisonAgent.allUnmatchedLLTIs &lt;&gt; null and comparisonAgent.allUnmatchedLLTIs.size() &gt; 0 then
		needHeading := true;					//navra1 - MTN-36063 - 24th Sep 2025
		
		foreach llTI in comparisonAgent.allUnmatchedLLTIs do
			if llTI.isKindOf(CM_EDILoadListTI) then					//navra1 - MTN-36063 - 24th Sep 2025
				//navra1 - MTN-34829 - 8th May 2025 - start
				if _operatorCode &lt;&gt; null and _operatorCode &lt;&gt; llTI.CM_EDILoadListTI.operatorCode then
					continue;
				endif;
				//navra1 - MTN-34829 - 8th May 2025 - end
				
				//navra1 - DEFECT-33512 - 26th Nov 2024 - start
				//should this TI be compared at all? it might be a TI that just got loaded or discharged
				if comparisonAgent.comparisonMode = TI_IMEX_STATUS_IMPORT then	//ie.DISCHARGE_COMPARISON
					if llTI.CM_EDILoadListTI.loadPort = currPortCode then
						continue;	//this is load cargo for this vessel and would be considered in load comparison, so dont consider it now as a part of DISCHARGE_COMPARISON				
					endif;
				else															//ie.LOAD_COMPARISON
					if llTI.CM_EDILoadListTI.dischargePort = currPortCode then
						continue;	//this is discharge cargo for this vessel and would be considered in discharge comparison, so dont consider it now as a part of LOAD_COMPARISON
					endif;
				endif;
				//navra1 - DEFECT-33512 - 26th Nov 2024 - end
				
				//navra1 - MTN-36063 - 24th Sep 2025 - start
				if needHeading then
					if desc = null then
						desc := "The following pieces of cargo were only found in the Load/Discharge List " &amp; operatorStr &amp; " : " &amp; CrLf;					//navra1 - MTN-34829 - 8th May 2025
					else
						desc := desc &amp; CrLf &amp; "The following pieces of cargo were only found in the Load/Discharge " &amp; operatorStr &amp; " : " &amp; CrLf;			//navra1 - MTN-34829 - 8th May 2025
					endif;
					
					needHeading := false;
				endif;
				//navra1 - MTN-36063 - 24th Sep 2025 - end
				
				desc := desc &amp; "    " &amp; llTI.id &amp; CrLf;					//navra1 - MTN-36063 - 24th Sep 2025
			endif;
		
			
		endforeach;
	endif;
	
	return desc;
epilog

end;</source>
        <Parameter name="comparisonAgent" type="CM_LoadListComparisonAgent"/>
        <Parameter name="_operatorCode" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDischargeListForMyVoyage" id="0645b9f7-c511-4e45-b5b4-830888b790a8">
        <source>getDischargeListForMyVoyage() : CM_EDIDataLoadList protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2024	navra1	Initial creation for //navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024

*/

vars
	ediDatas : CM_EDIDataArray;
	oneEdiData : CM_EDIData;
	returnEdiData : CM_EDIDataLoadList;
begin
	create ediDatas transient;
	
	self.myVoyage.getAllEDILoadLists(ediDatas);
	
	foreach oneEdiData in ediDatas do
		if oneEdiData.isKindOf(CM_EDIDataLoadList) then			//should obviously be
			if oneEdiData.CM_EDIDataLoadList.listType = 'D' then
				//just return the first DISCHARGE list you come across, this might need to be changed
				returnEdiData := oneEdiData.CM_EDIDataLoadList;
				break;
			endif;
		endif;
	endforeach;
	
	return returnEdiData;	
	
epilog
	delete ediDatas;
end;</source>
        <access>protected</access>
        <ReturnType type="CM_EDIDataLoadList"/>
    </JadeMethod>
    <JadeMethod name="getLatestDischListForMyVoyage" id="521ff141-ef57-40eb-935c-0d5b400a3f5f">
        <source>getLatestDischListForMyVoyage() : CM_EDIDataLoadList protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 May 2025	navra1	Initial creation for //navra1 - MTN-34901 - 26th May 2025

*/

vars
	ediDatas : CM_EDIDataArray;
	oneEdiData : CM_EDIData;
	returnEdiData : CM_EDIDataLoadList;
begin
	
	create ediDatas transient;
	
	self.myVoyage.getAllEDILoadLists(ediDatas);
	
	foreach oneEdiData in ediDatas do
		if oneEdiData.isKindOf(CM_EDIDataLoadList) then			//should obviously be
			if oneEdiData.CM_EDIDataLoadList.listType = 'D' then				
				if returnEdiData = null or oneEdiData.createdTime &gt; returnEdiData.createdTime then
					returnEdiData := oneEdiData.CM_EDIDataLoadList;			
				endif;
			endif;
		endif;
	endforeach;
	
	return returnEdiData;	

epilog
	delete ediDatas;
end;</source>
        <access>protected</access>
        <ReturnType type="CM_EDIDataLoadList"/>
    </JadeMethod>
