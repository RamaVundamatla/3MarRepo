    <JadeMethod name="convertBaseToTarget" id="37510d14-eac9-40b3-8b35-225a0d444735">
        <source>convertBaseToTarget(pMeasure: Real; pUnitTo: Integer): Real protected, abstract, number = 1004;</source>
        <abstract/>
        <access>protected</access>
        <Parameter name="pMeasure" type="Real"/>
        <Parameter name="pUnitTo" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="convertMeasure" id="6841b147-7803-49b9-a6bc-650282d59c75">
        <source>convertMeasure(pUnitTo: Integer): Real;
// --------------------------------------------------------------------------------
// Created:		25 May 2001 by cnwdad1
//
// Purpose:		Convert the receiver's measure into the specified unit(s).
//
// Parameters:	pUnitTo - The type of units to convert the measure into (refer to
//					the class constants on the subclasses for valid unit types).
//
// Returns:		The converted measure.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	convertedMeasure	: Real;
	
begin
	convertedMeasure	:=	self.convertBaseToTarget(self.baseUnit, pUnitTo);
epilog
	return convertedMeasure;
end;</source>
        <Parameter name="pUnitTo" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="convertToBaseUnit" id="bfe5fd55-3b42-400f-bbb9-22241acf1485">
        <source>convertToBaseUnit(pUnitFrom: Integer): Real protected, abstract, number = 1003;</source>
        <abstract/>
        <access>protected</access>
        <Parameter name="pUnitFrom" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getAllUnits" id="d803f8f6-9c61-4c30-a755-5cb23434f539">
        <source>getAllUnits(pAllUnits:IntegerArray input) abstract;
// --------------------------------------------------------------------------------
// Created:		10 May 2008 by Darrell
//
// Purpose:		Populates the specified array with all Unit of Measure IDs.
//
// Parameters:	pAllUnits - The array to populate.
//
// Returns:		Then populated array parameter.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------</source>
        <abstract/>
        <Parameter name="pAllUnits" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getUnitName" id="abfa757f-a72d-45db-b06a-24a9077a25d1">
        <source>getUnitName(pUnit:Integer):String abstract;
// --------------------------------------------------------------------------------
// Created:		09 May 2008 by Darrell
//
// Purpose:		Returns the name of the specified Unit.
//
// Parameters:	pUnit - The Unit who's name to return.
//
// Returns:		The name of the Unit, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------</source>
        <abstract/>
        <Parameter name="pUnit" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="693a69f2-be16-4ac7-bd11-538a813570c4">
        <updating/>
        <source>updateMe(pMeasure:Real; pUnit:Integer) updating;
// --------------------------------------------------------------------------------
// Created:		25 May 2001 by cnwdad1
//
// Purpose:		Sets the receiver's current measure, and the type of units.
//
// Parameters:	pMeasure - The current measurement value.
//				pUnit - The type of unit the value is measured in (refer to the
//					class constants on the subclasses for valid unit types).
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	isConvertToBase	: Boolean;
	
begin
	isConvertToBase	:=	false;
	
	if self.measure &lt;&gt; pMeasure then
		self.measure	:=	pMeasure;
		isConvertToBase	:=	true;
	endif;
	
	if self.unit &lt;&gt; pUnit then
		self.unit		:=	pUnit;
		isConvertToBase	:=	true;
	endif;
	
	if isConvertToBase then
		self.baseUnit	:=	self.convertToBaseUnit(pUnit);
	endif;
end;</source>
        <Parameter name="pMeasure" type="Real"/>
        <Parameter name="pUnit" type="Integer"/>
    </JadeMethod>
</Class>
