        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isEventBlockUnit" id="1044600e-de3b-47f4-8314-59b5b97ab88d">
        <source>isEventBlockUnit( _theUnit : Integer) : Boolean;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 22 August 2022
TFS#		: 54897
Function	:

*** Changes ***
Date			Name		TFS#		Description
23/08/2022		jlika1		TFS 54897 	MTN - Days being charged is incorrect
****************************************************/

vars

begin
	if (_theUnit = INV_CALC_TYPE_EVENT_TIME_DAYS or
		_theUnit = INV_CALC_TYPE_EVENT_TIME_HOURS or
		_theUnit = INV_CALC_TYPE_EVENT_TIME_MINUT or 
		_theUnit = INV_CALC_TYPE_EVENT_DAYS_FULL)  then
		
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_theUnit" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="8d8a876e-dcb1-4729-9320-8fc49760f0ca">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

