    <JadeMethod name="cmbBlock_click" id="9218e8a8-1d26-41ba-ad8c-1ff950322fab">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbBlock_click(combobox: ComboBox input) updating;

vars

	area : CM_RowArea;

begin


	area := combobox.listObject.CM_RowArea;
	if area &lt;&gt; null then
		setCurrentArea(area);
		doLoadLabels(area);
		doLoadPreviousRows(area, null); // adm 300708 Par 17575 null means no change in behaviour
		hideStartingLabels(area.isMarkedUp);
	endif;

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbBlock_displayEntry" id="11d802a1-aaad-4e88-a10f-1278ae7cbff9">
