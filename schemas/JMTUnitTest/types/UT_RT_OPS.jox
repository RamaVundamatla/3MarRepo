    <JadeMethod name="xInternalMoveOfTrailer" id="c676223c-d542-4818-b284-f86dc6bf81e0">
        <source>xInternalMoveOfTrailer();
//07 January 2009	cnwdw1	

// This test is depreciated as IMVS cannot do pickup/setdown tasks
constants
	Trailer = "UTTRAILER01";
	CargoType = "TRLR";
	TrailerType = "UTTRLR";
	Cargo = "UUT0000001";
	Truck = "UTTRUCK";
	BlockStack1 = "UTBS1";
	BlockStack2 = "UTBS2";
	IMV = "UIMV";
vars
	ti, trailer: CM_TrackedItem;
	vvr: CM_VehicleVisitRecord;
	bs1, bs2: CM_BlockStack;
	q1, q2: CM_RadioTelemetryQueue;
	tas: StringArray;
	imv: CM_Machine;
	task: CM_RTQueueTask;
	dualGate: CM_Gate;
begin
	self.deleteCargo(Trailer, CargoType);
	self.deleteContainer(Cargo);
	self.deleteTerminalArea(BlockStack1);
	self.deleteTerminalArea(BlockStack2);
	self.deleteMachine(IMV);
	self.deleteRTDevice("91");
	self.deleteVehicle(Truck);
	
	bs1 := self.addBlockStack(BlockStack1, 100, null);
	bs2 := self.addBlockStack(BlockStack2, 100, null);
	dualGate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);

	ti := self.addContainer(Cargo, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString),"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.opts.purge;
	self.opts.addAssociation("AutoComplete", true);
	vvr := self.gateInTrailer(Truck, Trailer, CargoType, TrailerType, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, dualGate);

	trailer := self.getTrackedItem(Trailer);
	self.move(trailer, bs1.myLocationsController);
	assertEqual(trailer.myPrimaryActualLocation, bs1.myLocationsController);
	
	self.moveQueued(trailer, bs2.myLocationsController);
	assertTrue(trailer.allQueuedFutureMoves.size = 1);
	assertEqual(trailer.allQueuedFutureMoves.first.getPrimaryLocation, bs2.myLocationsController);
	
	
	create tas transient; tas.add(bs1.id); tas.add(bs2.id);
	self.addIMV(IMV, 91, tas, null);
	
	// lets make sure it is in the Master queue
	self.moveRTTask(trailer.getQueueEntry, self.getQueue("MASTER"));

	// Work first straddle task - move to Area 2
	imv := self.getMachine(IMV);
	assertNotNull(imv);
	self.machineLogon(imv);
	task := self.machineTaskRequest(imv);
	assertEqual(task.taskType, TASK_PICKUP);
	assertEqual(task.status, TASK_OFFERED);
	self.machineAcceptTask(imv, task);
	self.machinePickup(imv);
	self.machineSetdown(imv, trailer, BlockStack2);
	self.machineLogOff(imv);
	
	assertEqual(trailer.myPrimaryActualLocation, bs2.myLocationsController);

epilog
	delete tas;
end;</source>
    </JadeMethod>
</Class>
