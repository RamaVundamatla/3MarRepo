    <JadeMethod name="tiHasBeenScanned" id="4d8daf1a-b803-4fca-a312-08fce33374c0">
        <source>tiHasBeenScanned( _ti : CM_TrackedItem; _tiID : String; _cargoGroupId : String output ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2018	jlgndl1	Initial creation	TFS 40116

*/

vars

	ti : CM_TrackedItem;
	tiId : String;

begin

	_cargoGroupId := null;

	if _ti &lt;&gt; null then
		if self.allProcessedTis.includes( _ti ) then
			if _ti.myCargoGroup &lt;&gt; null then
				_cargoGroupId := _ti.myCargoGroup.id;
			endif;
			return true;
		endif;
	endif;
	
	if _tiID &lt;&gt; null then
		tiId := _tiID.trimBlanks;
		foreach ti in self.allProcessedTis discreteLock do
			if ti.id.toUpper = tiId then
				if ti.myCargoGroup &lt;&gt; null then
					_cargoGroupId := ti.myCargoGroup.id;
				endif;
				return true;
			endif;
		endforeach;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_tiID" type="String"/>
        <Parameter name="_cargoGroupId" type="String" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateCreate" id="5c916605-eb1c-4e93-b12a-b4dc75ec0183">
        <source>validateCreate(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 July 2015	cnwndl1	Initial creation

*/

vars

	notifyCG : CM_NotifiedCargoGroup;
	cga : CM_CargoGroupAssignment;
	
	cg : CM_TrackedItem;	//CM_CargoGroup;

begin

	inheritMethod(_passport);
	
	//26 Oct 2018	NDL	TFS 39186
	if self.id.trimBlanks = null then
		app.raiseCMException(Cargo_group_assignm_require,null,null);
		return;
	endif;
	
	//23 Nov 2015	NDL	Par Par 36338 TFS 192/14
	cga := self.myTerminal.allWorkTasksDict.getAtKey( self.type, self.id).CM_CargoGroupAssignment;	
	if cga &lt;&gt; null then
		app.raiseCMException1(Cargo_group_assign_alread_exis,self.id,null,null);
		return;
	endif;
	
	//02 Oct 2018	NDL	TFS 39186
	foreach cg in self.allCargoGroupsByIdDict do
		cg.CM_CargoGroup.validateForAssignment( _passport );
	endforeach;
	
	foreach notifyCG in self.allNotifiedCargoGroupByIdDict do
		notifyCG.validateMe( _passport );
	endforeach;

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
