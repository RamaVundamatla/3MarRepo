    <JadeMethod name="searcherShowHideControls" id="18ef4dc8-58bd-4c39-a234-a8a82c6128e5">
        <source>searcherShowHideControls(_hide: Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     07 March 2011 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if not self.usesQueryFrame then
		return;
	endif;
	
	inheritMethod(_hide);
	
	self.btnPrint.enabled		:= _hide;
	self.btnExportCSVQE.enabled	:= _hide;
	self.btnRefresh.enabled		:= _hide;
	self.btnSelectAll.enabled	:= _hide;
	self.btnComment.enabled		:= _hide;
	
	self.tblData.enabled		:= _hide;
epilog

end;</source>
