    <JadeMethod name="doBulkPrint" id="75a33dd2-4c0f-41f4-ad26-755867357ba0">
        <updating/>
        <source>doBulkPrint() : Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 16/02/2016	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	selectedHolds : CM_ObjectArray;
	tmpJadeReport : JadeReport;
	headerForm : CMUI_ReportLine;
	footerForm : CM_GenericTablePrint;
	minScale : Decimal[12,2];
	thePageWidth, thePageHeight : Integer;

begin
	create selectedHolds transient;
	self.getSelectedHolds(selectedHolds);
	
	if selectedHolds.size = 0 then
		app.msgBox(app.getErrorString(Select_hold_print),app.getErrorString(Error), MsgBox_OK_Only);
		return false;
	endif;
	
	app.printer.close;
	
	create headerForm transient;
	create footerForm transient;
	self.setupHeaderFooter(headerForm, footerForm, null);
	
	create tmpJadeReport transient;
	tmpJadeReport.description := app.getErrorString(Hold_definition);
	app.printer.setReport(tmpJadeReport);
	
	//width printable page width less the margins
	thePageWidth := app.printer.pageWidth;
	//page height less the print position which at this stage is just the header frame
	thePageHeight := app.printer.pageHeight - app.printer.getPrintPosition ;
	
	minScale := (thePageHeight-Margin) / thePageHeight;
	self.doBulkPrintHolds(selectedHolds, minScale, thePageHeight, self.chkPrintMacro.value);
	
	if self.chkPrintPreview.value then
		app.printPreview(tmpJadeReport, true);
	else
		app.printer.printReport(tmpJadeReport);
	endif;
	app.printer.close();

	return true;
epilog
	delete headerForm;
	delete selectedHolds;
	delete footerForm;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doBulkPrintHoldDataDetails" id="e404c0f9-4ca3-495c-ad63-48c764ba5d94">
        <source>doBulkPrintHoldDataDetails(_holdOrStack : CM_Object) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 16/02/2016	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	dataContainer : CM_DataContainer;
	value : String;
	heading : String;
	block : CM_DataContainerBlock;
	
begin
	create dataContainer transient;	
	dataContainer.headerColour := White;
	dataContainer.valueColour := White;
	
	if _holdOrStack.isKindOf(CM_GeneralCargoController) then
		_holdOrStack.CM_GeneralCargoController.getExtraInfo(dataContainer);
	elseif _holdOrStack.isKindOf(CM_ShipBlockController) then
		_holdOrStack.CM_ShipBlockController.getExtraInfo(dataContainer);
	else
		return;
	endif;
	
	self.tblPrint.userObject := _holdOrStack; 
	self.tblPrint.left := 10;
	self.tblPrint.width := 900;
	self.tblPrint.gridLines := false;
	self.showExtraInformation(dataContainer, self.tblPrint, true, true, 6, 1, 6, 1, 1);
	
	self.tblPrint.resetHeight;
	self.tblPrint.height := self.tblPrint.clientHeight + Margin;
	
	app.printer.printActive(self.tblPrint);
	
epilog
	delete dataContainer;
end;</source>
        <access>protected</access>
        <Parameter name="_holdOrStack" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="doBulkPrintHolds" id="a114bd8f-7cb5-4431-ac58-92a582cc5d4e">
        <updating/>
        <source>doBulkPrintHolds(	_selectedHolds : CM_ObjectArray; 
					_scale : Decimal;
					_thePageHeight : Integer;
					_printDataDetails : Boolean	) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 16/02/2016	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
// 27/07/2016	cnwmp6		Added legend to last page
//
vars
	hold : Object;
	pageHeight : Real;
	deckImage : Binary;
	result : Integer;
	legendImage: Binary;
	
begin
	if _printDataDetails then
		foreach hold in _selectedHolds do
			self.doBulkPrintHoldDataDetails(hold.CM_GeneralCargoController);
			app.printer.drawLine(0, app.printer.getPrintPosition, app.printer.pageWidth, app.printer.getPrintPosition, Black);
		endforeach;
		self.doBulkPrintHoldDataDetails(self.myBulkPlanningForm.myCurrentVoyage.myShipBlockStack);
		app.printer.drawLine(0, app.printer.getPrintPosition, app.printer.pageWidth, app.printer.getPrintPosition, Black);
	endif;
	
	deckImage := self.getBulkHoldsImage(_selectedHolds, _scale, legendImage);
	if deckImage = null then
		return;
	endif;
	
	self.picPrint.visible := true;
	
	self.picPrint.zOrder(1);
	self.picPrint.autoRedraw := true;
	self.picPrint.transparent := false;
	self.picPrint.backColor := White;
	self.picPrint.borderStyle := Window.BorderStyle_None;
	self.picPrint.move(0, 0, app.printer.pageWidth, _thePageHeight);
	self.picPrint.stretch := self.picPrint.Stretch_Pic_Proportional;
	self.picPrint.useImage(deckImage);
	
	result := app.printer.printActive(self.picPrint);
	
	self.picLegend.visible := true;
	self.picLegend.zOrder(1);
	self.picLegend.autoRedraw := true;
	self.picLegend.transparent := false;
	self.picLegend.backColor := White;
	self.picLegend.borderStyle := Window.BorderStyle_None;
	self.picLegend.move(0, 0, app.printer.pageWidth, _thePageHeight);
	self.picLegend.stretch := self.picPrint.Stretch_Pic_Proportional;
	self.picLegend.useImage(legendImage);

	result := app.printer.printActive(self.picLegend);
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_selectedHolds" type="CM_ObjectArray"/>
        <Parameter name="_scale" type="Decimal"/>
        <Parameter name="_thePageHeight" type="Integer"/>
        <Parameter name="_printDataDetails" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="aac8d8c5-b416-4964-95f4-fdc992e566df">
        <updating/>
        <source>doOK() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 16/02/2016	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars

begin
	if not self.doBulkPrint() then
		return;
	endif;

	inheritMethod();
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getBulkHoldsImage" id="02af20e6-ce2e-4ee1-9609-bdd7163b1486">
        <updating/>
        <source>getBulkHoldsImage(_selectedHolds : CM_ObjectArray; _scale : Decimal; _legend : Binary output) : Binary updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 16/02/2016	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
// 27/07/2016	cnwmp6		Change signature to also return image of legend
//
vars
	hold : Object;
	form : SHP_BulkVoyagePlanningForm;

begin
	form := app.loadForm(SHP_BulkVoyagePlanningForm, SHP_Assistant, false, false, false, self.myTerminal, null).SHP_BulkVoyagePlanningForm;
	if form = null then
		return null;
	endif;
	
	// create a copy of the form, and do the drawing on it
	form.setupForm();
	form.activate();
	foreach hold in _selectedHolds do
		form.allSelectedHolds.add(hold.CM_GeneralCargoController);
	endforeach;
	form.displayMode := self.modeView;
	form.myBulkDrawingController.setPropertyValue(SHP_BulkDrawingController::viewMode.name, self.modeViewBy);
	form.setModes;
	form.voyageLoad(self.modeView);
	form.myBulkDrawingController.setPropertyValue(SHP_BulkDrawingController::isStarboardBerthed.name, self.myBulkPlanningForm.myBulkDrawingController.isStarboardBerthed);
	form.myBulkDrawingController.setPropertyValue(SHP_BulkDrawingController::workingMode.name, self.myBulkPlanningForm.myBulkDrawingController.workingMode);
	form.myBulkDrawingController.setPropertyValue(SHP_BulkDrawingController::actPlanQueMode.name, self.modeViewSub);
	form.redraw();
	if form.myBulkDrawingController.isStarboardBerthed then
		form.picStern.parent := form.dkcGridArea;
		form.picStern.move(0, 0, form.picStern.width, form.picStern.height);
		form.picBow.parent := form.dkcGridArea;
		form.picBow.move(form.dkcGridArea.width-form.picBow.width, 0, form.picBow.width, form.picBow.height);
	else
		form.picSternRev.parent := form.dkcGridArea;
		form.picSternRev.move(form.dkcGridArea.width-form.picSternRev.width, 0, form.picSternRev.width, form.picSternRev.height);
		form.picBowRev.parent := form.dkcGridArea;
		form.picBowRev.move(0, 0, form.picBowRev.width, form.picBowRev.height);
	endif;
	
	_legend := form.frmColLegendTIs.createPictureAsType(false, true, 24, Window.PictureType_Png);
	// now grab the image created in the scrolling frame to use in printing
	return form.dkcGridArea.createPictureAsType(false, true, 24, Window.PictureType_Png);
	
epilog
	delete form;
end;</source>
        <Parameter name="_selectedHolds" type="CM_ObjectArray"/>
        <Parameter name="_scale" type="Decimal"/>
        <Parameter name="_legend" type="Binary" usage="output"/>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getModeString" id="3f8c1379-4bf8-4b27-af6d-f67c97dd618c">
        <source>getModeString() : String protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 16/02/2016	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	str : String;

begin
	if self.modeView = ShpDisplayMode_Actual then
		str := $SHP_ACTUAL_Hold_View &amp; Space &amp; app.getViewModeString(self.modeViewBy);
		
	elseif  self.modeView = ShpDisplayMode_Ops then
		str := $SHP_OPS_Hold_View &amp; Space;
		if self.modeView = ShpDisplayMode_Actual then
			str := str &amp; Space &amp; $SHP_ACTUAL_Hold_View;
		elseif self.modeViewSub = ShpDisplayMode_Proposed then
			str := str &amp; Space &amp; $SHP_PLANNED_Hold_View;
		elseif self.modeViewSub = ShpDisplayMode_Queued then
			str := str &amp; Space &amp; $SHP_QUEUED_Hold_View;
		endif;
		str := str &amp; Space &amp; app.getViewModeString(self.modeViewBy);
		
	endif;
	
	return str;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSelectedHolds" id="3b3d4d4d-41f6-4273-bcb0-0e45476eedd4">
        <source>getSelectedHolds(_selectedHolds : CM_ObjectArray input) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 16/02/2016	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	idx : Integer;
begin
	idx := 1;
	
	if self.chkPrintAllHolds.value then
		
		while idx &lt;=  self.lstHolds.listCount do
			_selectedHolds.add(self.lstHolds.itemObject[idx]);
			idx:=idx + 1;
		endwhile;
		
	else
	
		while idx &lt;=  self.lstHolds.listCount do
			if self.lstHolds.itemSelected[idx] then
				
				_selectedHolds.add(self.lstHolds.itemObject[idx]);
			endif;
			idx:=idx + 1;
		endwhile;
		
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_selectedHolds" type="CM_ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getVoyageCode" id="bac5a040-6248-4f4c-a6dc-7484faba1c1f">
        <source>getVoyageCode() : String protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 16/02/2016	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars

begin
	if self.myBulkPlanningForm &lt;&gt; null and self.myBulkPlanningForm.myCurrentVoyage &lt;&gt; null then
		return self.myBulkPlanningForm.myCurrentVoyage.code;
	else
		return null;
	endif;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initDetails" id="8122b079-95fa-4e9a-9352-7aec31c76fd8">
        <updating/>
        <source>initDetails(_printObject : CM_Object;
			_modeView : Integer;
			_modeViewSub : Integer;
			_modeViewBy : Integer;
			_parentForm : CM_BaseForm	) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 16/02/2016	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	hold : CM_GeneralCargoController;
	structure : CM_Object;
	iter : Iterator;
	
begin

	self.chkPrintAllHolds.value := false;
	if _printObject.isKindOf(CM_GeneralCargoController) then
		hold := _printObject.CM_GeneralCargoController;
		structure := hold.myGCVoyage;
	elseif _printObject.isKindOf(CM_GeneralCargoVesselStructure) or _printObject.isKindOf(CM_GeneralCargoVoyageStructure) then
		structure := _printObject;
		self.chkPrintAllHolds.value := true;
	endif;
	
	self.myBulkVoyage := structure;

	self.lstHolds.clear;
	self.lstHolds.sorted := false;

	if structure.isKindOf(CM_GeneralCargoVesselStructure) then
		iter := structure.CM_GeneralCargoVesselStructure.allHoldLocnDefnByHatchPlace.createIterator;
	elseif structure.isKindOf(CM_GeneralCargoVoyageStructure) then
		iter := structure.CM_GeneralCargoVoyageStructure.allLocationsByHatchPlace.createIterator;
	endif;
	
	while iter.next(hold) do
		self.lstHolds.addItem(hold.getFullId);
		self.lstHolds.itemObject[self.lstHolds.newIndex] := hold;
		self.lstHolds.itemLevel[self.lstHolds.newIndex] := 1;
		self.lstHolds.itemExpanded[self.lstHolds.newIndex] := true;
	endwhile;
	
	if _printObject.isKindOf(CM_GeneralCargoController) then
		self.lstHolds.listObject := _printObject;
		//if it is a multi select list box just setting the list object does not
		// show the visual selection !!!!! if it isn't multi select is does
		self.lstHolds.itemSelected[self.lstHolds.listIndex] := true;
	endif;	
	
	if self.chkPrintAllHolds.value then
		self.lstHolds.enabled := false;
	endif;

	self.modeView := _modeView;
	self.modeViewSub := _modeViewSub;
	self.modeViewBy := _modeViewBy;
	self.myBulkPlanningForm := _parentForm.SHP_BulkVoyagePlanningForm;
end;</source>
        <Parameter name="_printObject" type="CM_Object"/>
        <Parameter name="_modeView" type="Integer"/>
        <Parameter name="_modeViewSub" type="Integer"/>
        <Parameter name="_modeViewBy" type="Integer"/>
        <Parameter name="_parentForm" type="CM_BaseForm"/>
    </JadeMethod>
