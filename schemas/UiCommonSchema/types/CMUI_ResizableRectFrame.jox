    <JadeMethod name="mouseDown" id="a7a385c5-fe28-41cf-9a05-f03db754bce5">
        <controlMethod name="CMUI_MoveableFrame::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mouseDown(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 Jan 2009	cnwjk3	Initial creation
28 Aug 2009	cnwer1	CCMS 1076
*/

vars

begin
	inheritMethod(frame, button, shift, x, y);

	self.isSelected := true;
	
	if x &lt; self.thickness and y &gt; self.height-self.thickness then
		if self.canResizeHeight then
			self.resizingBottom := true;
		endif;
		if self.canResizeWidth then
			// Mouse over bottom left corner
			self.resizingLeft := true;
		endif;	
		self.inResizeMode := true;
	elseif x &lt; self.thickness and y &lt; self.thickness then
		if self.canResizeWidth then
			// Mouse over bottom left corner
			self.resizingLeft := true;
		endif;	
		
		if self.canResizeHeight then
			// Mouse over top left corner
			
			self.resizingTop := true;
		endif;
		self.inResizeMode := true;
	elseif y &gt; self.height-self.thickness and x &gt; self.width-self.thickness then		
		if self.canResizeWidth then
			// Mouse over bottom left corner
			self.resizingRight := true;
		endif;	
		if self.canResizeHeight then
			self.resizingBottom := true;
		endif;
		self.inResizeMode := true;
	elseif y &lt; self.thickness and x &gt; self.width-self.thickness then
		if self.canResizeWidth then
			// Mouse over bottom left corner
			self.resizingRight := true;
		endif;	
		if self.canResizeHeight then
			// Mouse over top left corner
			
			self.resizingTop := true;
		endif;
		self.inResizeMode := true;
	elseif x &lt; self.thickness then
		if self.canResizeWidth then
			self.inResizeMode := true;
			self.resizingLeft := true;
		endif;
	elseif y &lt; self.thickness then
		if self.canResizeHeight then
			self.inResizeMode := true;
			self.resizingTop := true;
		endif;
	elseif x &gt; self.width-self.thickness then 
		if self.canResizeWidth then
			self.inResizeMode := true;
			self.resizingRight := true;
		endif;
	elseif y &gt; self.height-self.thickness then		
		if self.canResizeHeight then
			self.inResizeMode := true;
			self.resizingBottom := true;
		endif;
	endif;
	
	if self.name = "frmWorkZone" then
		self.inDragMode:=false;
		self.enableEvent('mouseMove', true);
	endif;
	
	self.form.IF_CMUI_RectangleHandler.onRectSelected(self);
epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseEnter" id="897ce893-0162-4109-b8e0-50a3dd3ad089">
        <controlMethod name="CMUI_MoveableFrame::mouseEnter"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mouseEnter(frame: Frame input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 January 2009	cnwjk3	Initial creation

*/

vars

begin
	if self.isLocked then
		return;
	endif;
	
	self.isFirstMove := true;
	// Have to do this for cursor handling to work
	self.enableEvent('mouseMove', true);
epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mouseLeave" id="2454828c-230d-4ac4-9ca1-7b511a1af47d">
        <controlMethod name="CMUI_MoveableFrame::mouseLeave"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mouseLeave(frame: Frame input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 January 2009	cnwjk3	Initial creation

*/

vars

begin
	inheritMethod(frame);
	self.isFirstMove := false;
epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mouseMove" id="818ab3dd-891b-4d47-926e-b9414f2c8378">
        <controlMethod name="CMUI_MoveableFrame::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mouseMove(frame: CMUI_MoveableFrame input; button: Integer; shift: Integer; x: Real; y: Real) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 January 2009	cnwjk3	Initial creation
28 August 2009	cnwer1  - can now define whether this is just for resizing width or height 
						- changes mouse icon accordingly
*/

vars
	adjustment,
	newWidth,
	newHeight,
	newLeft,
	newTop,
	parentX,
	parentY			: Real;
	resizeMsgFreq : Integer;
begin
	
	if self.isLocked then
		return;
	endif;

	if not self.inResizeMode then 
		if x &lt; self.thickness and y &gt; self.height-self.thickness then
			// Mouse over bottom left corner
			if self.canResizeHeight and self.canResizeWidth then
				app.mousePointer := Window.MousePointer_NESW;
			elseif self.canResizeWidth then 
				app.mousePointer := Window.MousePointer_WE;
			elseif self.canResizeHeight then
				app.mousePointer := Window.MousePointer_NS;
			endif;		
		elseif x &lt; self.thickness and y &lt; self.thickness then
			// Mouse over top left corner
			if self.canResizeHeight and self.canResizeWidth then
				app.mousePointer := Window.MousePointer_NWSE;	
			elseif self.canResizeWidth then 
				app.mousePointer := Window.MousePointer_WE;
			elseif self.canResizeHeight then
				app.mousePointer := Window.MousePointer_NS;
			endif;		
		elseif y &gt; self.height-self.thickness and x &gt; self.width-self.thickness then		
			// Mouse over bottom right corner
			if self.canResizeHeight and self.canResizeWidth then
				// Mouse over bottom right corner
				app.mousePointer := Window.MousePointer_NWSE;	
			elseif self.canResizeWidth then 
				app.mousePointer := Window.MousePointer_WE;
			elseif self.canResizeHeight then
				app.mousePointer := Window.MousePointer_NS;
			endif;		
		elseif y &lt; self.thickness and x &gt; self.width-self.thickness then
			// Mouse over top right corner
			if self.canResizeHeight and self.canResizeWidth then
				// Mouse over top right corner
				app.mousePointer := Window.MousePointer_NESW;
			elseif self.canResizeWidth then 
				app.mousePointer := Window.MousePointer_WE;
			elseif self.canResizeHeight then
				app.mousePointer := Window.MousePointer_NS;
			endif;		
		elseif x &lt; self.thickness then
			// Mouse over left rect border
			if self.canResizeWidth then
				// Mouse over left rect border
				app.mousePointer := Window.MousePointer_WE;
				
			else
				
				app.mousePointer :=Window.MousePointer_Default;
			endif;
			self.form.IF_CMUI_RectangleHandler.canResizeOthers(self, x, y);
		elseif y &lt; self.thickness then
			// Mouse over top rect border
			if self.canResizeHeight then
				
				// Mouse over top rect border
				app.mousePointer := Window.MousePointer_NS;
				
			else
				
				app.mousePointer :=Window.MousePointer_Default;
			endif;
			self.form.IF_CMUI_RectangleHandler.canResizeOthers(self, x, y);
		elseif x &gt; self.width-self.thickness then 
			// Mouse over right rect border
			if self.canResizeWidth then
				// Mouse over right rect border
				app.mousePointer := Window.MousePointer_WE;
			else
				app.mousePointer :=Window.MousePointer_Default;
			endif;
			self.form.IF_CMUI_RectangleHandler.canResizeOthers(self, x, y);
		elseif y &gt; self.height-self.thickness then		
			// Mouse over bottom rect border
			if self.canResizeHeight then
				// Mouse over bottom rect border
				app.mousePointer := Window.MousePointer_NS;
			else
				app.mousePointer :=Window.MousePointer_Default;
			endif;
			self.form.IF_CMUI_RectangleHandler.canResizeOthers(self, x, y);
		else
			if self.canResizeHeight and self.canResizeWidth then
				// Mouse somewhere in the middle
				app.mousePointer := Window.MousePointer_Size;
				
			else
				
				app.mousePointer :=Window.MousePointer_Default;
			endif;
			self.form.IF_CMUI_RectangleHandler.canResizeOthers(self, x, y);
		endif;
	endif;
	
	if self.inResizeMode then
		parentX := x + frame.left;
		parentY := y + frame.top;
		
		if self.resizingLeft then
			adjustment := (frame.mouseDownX - parentX);
			newLeft := self.origLeft - adjustment;
			if newLeft &lt; self.origLeft + self.origWidth then
				self.width := self.origWidth + adjustment;
				self.left := newLeft;
			endif;		
		endif; 

		if self.resizingTop then
			adjustment := (frame.mouseDownY - parentY);
			newTop := self.origTop - adjustment;
			if newTop &lt; self.origTop + self.origHeight then
				self.height := self.origHeight + adjustment;
				self.top := newTop;
			endif;		
		endif; 
		
		
		if self.resizingRight then
			adjustment := (parentX - frame.mouseDownX);
			newWidth := self.origWidth + adjustment;
			if newWidth &gt; 0 then
				self.width := newWidth;
			endif;		
		endif; 
	
		if self.resizingBottom then
			adjustment := (parentY - frame.mouseDownY);
			newHeight := self.origHeight + adjustment;
			if newHeight &gt; 0 then
				self.height := newHeight;
			endif;		
		endif; 
		
		resizeMsgFreq:=ResizingMsgFreq;
		if self.userObject.isKindOf(CMIF_MachineWorkzone) then
			resizeMsgFreq:=1;
		endif;
		self.resizingCounter := self.resizingCounter + 1;
		if self.resizingCounter mod resizeMsgFreq = 0 then
			//self.form.sendMsgWithParams('onRectResizing', self);
			self.form.IF_CMUI_RectangleHandler.onRectResizing(self);
		endif;
	
	else
	//	if self.canResizeHeight and self.canResizeWidth then ///epr CCMS 1366 I want to be able to move without resizing
			if button &lt;&gt; 0 then
				self.visible := false;
			endif;
			inheritMethod(frame, button, shift, x, y);
			if button &lt;&gt; 0 then
				self.visible := true;
			endif;
	
			if button &lt;&gt; 0 then
				self.movingCounter := self.movingCounter + 1;
				if self.movingCounter mod MovingMsgFreq = 0 then
					//self.form.sendMsgWithParams('onRectMoving', self);
					self.form.IF_CMUI_RectangleHandler.onRectMoving(self);
				endif;
			endif;
		//endif;
	endif;
epilog

end;</source>
        <Parameter name="frame" type="CMUI_MoveableFrame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseUp" id="216f133a-31c7-4844-8502-7c7d4160fc40">
        <controlMethod name="CMUI_MoveableFrame::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 January 2009	cnwjk3	Initial creation

*/

vars

begin
	inheritMethod(frame, button, shift, x, y);
	self.form.IF_CMUI_RectangleHandler.onRectChanged(self);
	self.inResizeMode := false;
	//self.refreshNow();  // CCMS CPL 2052
	self.enableEvent('mouseMove', true);
epilog

end;</source>
