    <JadeMethod name="canUserSet" id="3497af00-c61d-4f52-96ab-b661d04281a0">
        <source>canUserSet(_propName: String): Boolean;
//
// 30 Jun 2014	cnwrs1	Par 34702 - Add support for JMT XML
//
vars

begin
	if _propName = CM_EDIBOLOutLogTI::myEDIDataBOLOutLog.name or
	   _propName = CM_EDIBOLOutLogTI::myLogLot.name or
	   _propName = CM_EDIBOLOutLogTI::myLogVoyageStructure.name or
	   _propName = CM_EDIBOLOutLogTI::myOperator.name or
	   _propName = CM_EDIBOLOutLogTI::myTerminal.name or
	   _propName = CM_EDIBOLOutLogTI::myVoyageGlobal.name then
		return false;
	else
		return inheritMethod(_propName);
	endif;
end;
</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getLogLengthCode" id="95658800-6ecb-441e-8050-9a0ce4ba0589">
        <source>getLogLengthCode(_lenText : String) : String ;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 March 2009	cnwrd1	Initial creation - for par 18499
bodgefix for log length codes.
29/08/2014	cnwdap1	PAR #34722 "3.60" as a length code was being rejected because this method was converting it to "3.6"
					Now we interrogate the decimal to see if the frist character after the decimal place is non-zero
					If it is, just return the whole string 

We get 3.00 from import file we want to try find a code of "3.0"
For 3.95 we want "3.95"

This was 'easy' from the self.logLength Decimal when it was 6 scale 1, now (to support codes of x.xx) it is 6.2 and will break the x.x codes.


need to find the decimal place, if trailing 0 is 2 decimal places we truncate.

This is assuming there is no '3' code!! (wouldnt have worked before...)
*/

vars
	result : String;
	strLen : Integer;
	decPos : Integer;
	tmpDec : Decimal[8,2];
	outDec : Decimal[6,1];
	char   : String;					// PAR #34722
begin



	tmpDec := _lenText.Decimal;
	tmpDec  := tmpDec * 100;
	
	if ( tmpDec mod 10 ) &gt; 0 then
	// we have 2 used decimal places
		return  _lenText;
	else
	//we have 1
		decPos := _lenText.pos(".", 1);				// PAR #34722
		if decPos &lt;&gt; null then						// PAR #34722
			char := _lenText[decPos+1:1];			// PAR #34722
			if char.Integer &gt; 0 then				// PAR #34722
				return _lenText;					// PAR #34722
			endif;									// PAR #34722
		endif;										// PAR #34722
		outDec := _lenText.Decimal;
		return outDec.String;
	endif;

return result;

epilog

end;</source>
        <Parameter name="_lenText" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
