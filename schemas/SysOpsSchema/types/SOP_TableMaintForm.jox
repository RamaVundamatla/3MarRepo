*/

vars
	
begin	
	if self.myCurrentTableItem.isKindOf(SOPTM_ToDoTaskDesc) then
		self.myCurrentTableItem.SOPTM_ToDoTaskDesc.setupTransactionTypes(app.getToDoTaskStringToInt(combobox.text));
		self.myCurrentTableItem.SOPTM_ToDoTaskDesc.setupResources(app.getToDoTaskStringToInt(combobox.text));			    // ### TFS  #56634[54259] 18NOV2022 NAVAB1
	elseif self.myCurrentTableItem.isKindOf(SOPTM_ToDoTaskResource) then 													// ### TFS  #56634[54259] 18NOV2022 NAVAB1
		self.myCurrentTableItem.SOPTM_ToDoTaskResource.populateTodoTask(app.getToDoTaskStringToInt(combobox.text)); 		// ### TFS  #56634[54259] 18NOV2022 NAVAB1
		self.myCurrentTableItem.SOPTM_ToDoTaskResource.showHideAdditionalInfo(app.getToDoTaskStringToInt(combobox.text));   // ### TFS  #56634[54259] 18NOV2022 NAVAB1
	endif;	
epilog

end;</source>
