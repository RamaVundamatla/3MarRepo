/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2011	#cnwdz2	 

*/

vars

begin
	self.raiseExceptionIfNotTransient(method);
	
	self.className := _className[1:self.description.maxLength].trimBlanks;

epilog

end;</source>
        <Parameter name="_className" type="String"/>
    </JadeMethod>
    <JadeMethod name="tidyUpStringForCSVOutput" id="65f602a5-ef63-4b2e-997b-0bcd424012fe">
        <source>tidyUpStringForCSVOutput(_fieldString : String): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 May 2011	#cnwdz2	 

*/

vars
    fieldString : String;
begin
	fieldString := _fieldString.removeCrLfs();
	if fieldString = null then
		return null;
	endif;
	return fieldString.csvEncode();
epilog

end;</source>
