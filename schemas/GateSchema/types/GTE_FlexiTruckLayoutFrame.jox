    <JadeMethod name="createContainerFrame" id="dc90b806-15b8-401f-a617-ecc57fe5d38a">
        <source>createContainerFrame() : GTE_FlexiContainerFrame protected;
// ---------------------------------------------------------------------------
// Created:     16 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	frmCont		: GTE_FlexiContainerFrame;

begin

	create frmCont transient;
	frmCont.parent := self;
	form.addControl(frmCont);

	frmCont.height := 80;
	frmCont.visible := false;
	
	return frmCont;
	
end;</source>
        <access>protected</access>
        <ReturnType type="GTE_FlexiContainerFrame"/>
    </JadeMethod>
    <JadeMethod name="deselectContainer" id="87837850-1bb1-4b69-9249-b2644b5b2815">
        <updating/>
        <source>deselectContainer() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 July 2009	cnwas3	Initial creation

*/
begin

	if self.myFlexiSelectedContainer &lt;&gt; null then
		self.myFlexiSelectedContainer.deSelect();
		self.myFlexiSelectedContainer := null;
	endif;
	if self.myFlexiDraggedContainer &lt;&gt; null then
		self.myFlexiDraggedContainer := null;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="disableDoorsDirections" id="6bf71fd8-11e3-4f7f-b610-10c202a5ec5a">
        <updating/>
        <source>disableDoorsDirections() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 August 2009	cnwas3	Initial creation

*/

vars
	frame : GTE_FlexiContainerFrame;
begin
	
	foreach frame in self.allFlexiContainerFrames do
		frame.enableDoorsDirBtn(false);
	endforeach;
	//also disable the movement of containers throughout the layout
	self.setMoveButtons(false);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="displayContainers" id="b8234ce3-0348-49a4-b983-0100fff73b30">
        <updating/>
        <source>displayContainers() updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	contFrm		: GTE_FlexiContainerFrame;
	leftPos	: Integer;
	
begin

	if self.myFlexiSelectedContainer &lt;&gt; null and (not self.myFlexiSelectedContainer.visible) then
		self.myFlexiSelectedContainer.deSelect;
		self.myFlexiSelectedContainer := null;
	endif;
	
	self.setLengths();

	leftPos := self.myTruckBedLeftPic.left.Integer;

	foreach contFrm in self.allFlexiContainerFrames do

		if (not contFrm.visible) then
			continue;
		endif;

		contFrm.setWidth(self.length10, self.length20, self.length40);
		contFrm.left := leftPos;

		if self.myFlexiSelectedContainer = null then
			self.myFlexiSelectedContainer := contFrm;
			contFrm.select;
		endif;
			
		leftPos := (contFrm.left + contFrm.width + 1).Integer;
		
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="dragDropContainer" id="dc1fb9c5-cb5c-4f4a-8129-634d4d03a3c5">
        <updating/>
        <source>dragDropContainer(pToContainer : GTE_FlexiContainerFrame) updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	fromIdx,
	toIdx		: Integer;
	toContainer	: GTE_FlexiContainerFrame;
		
begin

	if pToContainer = self.myFlexiDraggedContainer then
		// dropped back on itself so no need to swap!
		return;
	endif;

	fromIdx	:= self.allFlexiContainerFrames.indexOf(self.myFlexiDraggedContainer);
	toIdx 	:= self.allFlexiContainerFrames.indexOf(pToContainer);

	if toIdx &lt;&gt; 0 and fromIdx &lt;&gt; 0 then
		// Swap the containers.  This is done in this convulated fashion as a straight swap got
		// the inverses screwed and left one container with its inverse not set.

		toContainer := pToContainer;

		self.swapContainers(fromIdx, toIdx);

		toContainer.deSelect();
		self.myFlexiDraggedContainer.select();
		self.displayContainers();

		self.myFlexiDraggedContainer := null;

	endif;
	
end;</source>
        <Parameter name="pToContainer" type="GTE_FlexiContainerFrame"/>
    </JadeMethod>
    <JadeMethod name="driveOff" id="bbd6b6d6-11a6-4400-8138-b393d13f1b0e">
        <updating/>
        <source>driveOff() updating;
// ---------------------------------------------------------------------------
// Created:     17 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx,
	lag		: Integer;
	tmpSound	: Sound;
begin

	tmpSound := app.myRoot.getConfig(TruckDriveOffWav).Sound;

	if tmpSound &lt;&gt; null then
		tmpSound.play;
		app.doWindowEvents(1000);
	endif;

	lag := 100;
	
	while true do
		self.myTruckCabPicture.left 	:= self.myTruckCabPicture.left - 1;
		self.myTruckBedLeftPic.left		:= self.myTruckBedLeftPic.left - 1;
		self.myTruckBedMiddlePic.left	:= self.myTruckBedMiddlePic.left - 1;
		self.myTruckBedRightPic.left	:= self.myTruckBedRightPic.left - 1;
		self.displayContainers;
		self.refreshNow;
		if (self.myTruckBedRightPic.left + self.myTruckBedRightPic.width) &lt; 0 then
			break;
		endif;
		app.doWindowEvents(lag);
		idx := idx + 1;
		if idx = 40 then
			lag := 10;
		elseif idx = 100 then
			lag := 5;
		elseif idx = 200 then
			lag := 2;
		endif;
	endwhile;

	if tmpSound &lt;&gt; null then
		app.doWindowEvents(1000);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="driveOn" id="a8921a4f-2740-4c29-87cc-e682a3596953">
        <updating/>
        <source>driveOn() updating;
// ---------------------------------------------------------------------------
// Created:     17 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	startPos,
	idx,
	lag			: Integer;
	tmpSound	: CM_Sound;

begin

	tmpSound := app.myRoot.getConfig(TruckDriveOnWav).CM_Sound;

	// set initial position off the screen
	startPos := self.parent.width.Integer;
	self.myTruckCabPicture.left 	:= startPos;
	self.myTruckBedLeftPic.left		:= self.myTruckCabPicture.left + self.myTruckCabPicture.width;
	self.myTruckBedMiddlePic.left	:= self.myTruckBedLeftPic.left + self.myTruckBedLeftPic.width;
	self.myTruckBedRightPic.left	:= self.myTruckBedMiddlePic.left + self.myTruckBedMiddlePic.width;
	self.displayContainers;
	self.refreshNow;

	lag := startPos - self.leftMargin;
	if lag &gt; 0 then
		lag := (lag / 2000).Integer;
	else
		lag := 1;
	endif;

	if tmpSound &lt;&gt; null then
		tmpSound.play;
		app.doWindowEvents(1);
	endif;
	
	while true do
		self.myTruckCabPicture.left 	:= self.myTruckCabPicture.left - 1;
		self.myTruckBedLeftPic.left		:= self.myTruckBedLeftPic.left - 1;
		self.myTruckBedMiddlePic.left	:= self.myTruckBedMiddlePic.left - 1;
		self.myTruckBedRightPic.left	:= self.myTruckBedRightPic.left - 1;
		self.displayContainers;
		self.refreshNow;
		if self.myTruckCabPicture.left &lt; self.leftMargin then
			break;
		endif;
		if lag &gt; 0 then
			app.doWindowEvents(lag);
		else
			if idx mod 3 = 0 then
				app.doWindowEvents(1);
			endif;
		endif;
		idx := idx + 1;
	endwhile;

end;</source>
    </JadeMethod>
    <JadeMethod name="hideTruck" id="c0a345a6-b084-4c8a-b243-71113cd59044">
        <source>hideTruck();
// ---------------------------------------------------------------------------
// Created:     20 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	contFrm	: GTE_FlexiContainerFrame;

begin

	foreach contFrm in self.allFlexiContainerFrames do
		contFrm.visible := false;
	endforeach;

	self.myTruckCabPicture.visible 		:= false;
	self.myTruckBedLeftPic.visible 		:= false;
	self.myTruckBedMiddlePic.visible 	:= false;
	self.myTruckBedRightPic.visible 	:= false;

end;</source>
    </JadeMethod>
    <JadeMethod name="moveSelectedContainer" id="3e7b7d9f-8aca-42a0-a926-23cb305c5cbf">
        <updating/>
        <source>moveSelectedContainer(pBtn : JadeMask) updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if pBtn = self.myMoveLeftBtn then
		self.moveSelectedLeft();
	elseif pBtn = self.myMoveRightBtn then
		self.moveSelectedRight();
	endif;

end;</source>
        <Parameter name="pBtn" type="JadeMask"/>
    </JadeMethod>
    <JadeMethod name="moveSelectedLeft" id="56d34aff-602a-4abf-bc16-01eca2cf12e6">
        <updating/>
        <source>moveSelectedLeft() updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	oldIdx,
	newIdx	: Integer;
	
begin

	if self.myFlexiSelectedContainer = null then
		return;
	endif;
	
	oldIdx := self.allFlexiContainerFrames.indexOf(self.myFlexiSelectedContainer);
	newIdx := oldIdx - 1;
	
	if newIdx &lt;= 0 then
		return;
	endif;
	
	if (not self.allFlexiContainerFrames[newIdx].visible) then
		return;
	endif;
	
	self.swapContainers(oldIdx, newIdx);
	self.displayContainers();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="moveSelectedRight" id="53552e1d-e229-46e7-86da-390783e9a245">
        <updating/>
        <source>moveSelectedRight() updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	oldIdx,
	newIdx	: Integer;
	
begin

	if self.myFlexiSelectedContainer = null then
		return;
	endif;
	
	oldIdx := self.allFlexiContainerFrames.indexOf(self.myFlexiSelectedContainer);
	newIdx := oldIdx + 1;
	
	if newIdx &gt; self.allFlexiContainerFrames.size then
		return;
	endif;
	
	if (not self.allFlexiContainerFrames[newIdx].visible) then
		return;
	endif;
	
	self.swapContainers(oldIdx, newIdx);
	self.displayContainers();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="numVisibleContainers" id="444810c5-8b71-48ac-a404-093eeff84480">
        <methodInvocation>mapping</methodInvocation>
        <source>numVisibleContainers(set: Boolean; _value: Integer io) mapping, protected;
// ---------------------------------------------------------------------------
// Created:     20 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	contFrm	: GTE_FlexiContainerFrame;

begin

	if set then
		return;
	endif;
	
	_value := 0;
	foreach contFrm in self.allFlexiContainerFrames do
		if contFrm.visible then
			if contFrm.length = 40 then
				_value := _value + 4;
			elseif contFrm.length = 20 then
				_value := _value + 2;
			else
				_value := _value + 1;
			endif;
		endif;
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="paint" id="e1ad0df7-ee69-4039-a90f-3f504f665950">
        <updating/>
        <source>paint(frame: Frame input) updating;
// ---------------------------------------------------------------------------
// Created:     16 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(frame);

	if isInPainter then
		if not self.isBuilt then
			self.isBuilt := true;
			self.buildSelf;
		endif;

	elseif not isBuilt then
		self.buildSelf;
		self.isBuilt := true;
	endif;

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="refresh" id="29c54cae-14d6-4761-b8fb-13781e26f28a">
        <updating/>
        <source>refresh() updating;
// ---------------------------------------------------------------------------
