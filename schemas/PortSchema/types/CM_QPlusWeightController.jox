<Class name="CM_QPlusWeightController" id="23c32c2d-2a55-4214-9821-f5edff0788b2">
    <superclass name="CM_WeightIntController"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <JadeMethod name="generateDevTestData" id="2efe932b-c7a1-488a-8d84-48cb3e21c7c7">
        <source>generateDevTestData();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 July 2021	navndl1	Initial creation	TFS 51575 - Model IQ710 Weigh bridge as configured at Penn terminals.

*/

vars

	randomNum : Integer;
	strResponse : String;
	binResponse : Binary;
	weight : Decimal[16,4];

begin
	
	/*
	response message format - length = 18.
	stx 		1-3 	= 's' &amp; Cr &amp; Lf
	plus/minus 	4 		= "-" for negative, or space for positive.
	weight	 	5-12	= a numbers with leading spaces to represent the number of units of weight
	units		13		= "L" = lbs, " " = none, 'K' = Kgs, 'T' = tons, 'G' = grams, 'O' = ounces
	mode		14		= "G" = gross,  "N" = nett
	status		15		= " " = valid, "I" = invalid, "M" = motion, "O" = over capacipty
	etx 		16-18 	= Cr &amp; Lf &amp; Lf
	*/
	
	randomNum := app.random(6);
	
	if randomNum = 1 then
		strResponse := "s" &amp; Cr &amp; Lf &amp; " " &amp; "00000012" &amp; "T" &amp; "G " &amp; Cr &amp; Lf &amp; Lf;
	elseif randomNum = 2 then
		strResponse := "s" &amp; Cr &amp; Lf &amp; " " &amp; "00012012" &amp; "K" &amp; "G " &amp; Cr &amp; Lf &amp; Lf;
	elseif randomNum = 3 then
		strResponse := "s" &amp; Cr &amp; Lf &amp; " " &amp; "00026400" &amp; "L" &amp; "G " &amp; Cr &amp; Lf &amp; Lf;
	elseif randomNum = 4 then
		strResponse := "s" &amp; Cr &amp; Lf &amp; " " &amp; "00000015" &amp; "T" &amp; "G " &amp; Cr &amp; Lf &amp; Lf;
	elseif randomNum = 5 then
		strResponse := "s" &amp; Cr &amp; Lf &amp; " " &amp; "00015015" &amp; "K" &amp; "G " &amp; Cr &amp; Lf &amp; Lf;
	elseif randomNum = 6 then
		strResponse := "s" &amp; Cr &amp; Lf &amp; " " &amp; "00033000" &amp; "L" &amp; "G " &amp; Cr &amp; Lf &amp; Lf;
	endif;
	
	binResponse := strResponse.Binary;
	
	weight := self.getWeight( binResponse );
	
	self.myWeightCallerInterface.sendWeight(weight);

epilog

end;</source>
    </JadeMethod>
