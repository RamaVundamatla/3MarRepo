    <JadeMethod name="makeMessageHeader" id="e92d5818-c374-4c60-93b6-59ea57fc96ad">
        <updating/>
        <source>makeMessageHeader(_camFile : CM_CamFile input; _camTaskHistory : CM_CamTaskHistory input; _unhSeqNumber : Integer io; 
					_type : String; _fileType : String; _coll :HugeStringArray input) : String updating;
// 10/02/2011	cnwcs5	CCMS JMT 1977/PAR 26531 - changed _camFile/_camTaskHistory parameter usage from io to input
// 16/05/2011	cnwcs5 	CCMS SCT 2058/par 27460 - replace literals with characters defined on protocol
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
vars
	protocol	:CM_CamProtocol;
	strLine : String;
begin
	_unhSeqNumber 	:= _unhSeqNumber + 1;
	protocol		:= _camTaskHistory.camProtocol;	// par 27460 cnwcs5
	
	// UNH Segment
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeUNHSegment (protocol, _unhSeqNumber, _fileType, "D", "95B", "UN", "ANZ10", null, _camTaskHistory.runDateTime), _coll); 	//cnwmc5 - 15 Oct 2014 - CCMS 2380
	// BGM segment
	strLine := strLine &amp; self.outputFileMessage(_camTaskHistory, self.makeBGMSegment (protocol, _type, _unhSeqNumber, 9, null), _coll);

	_camFile.incrementMessageCount();
	return strLine;
end;</source>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_fileType" type="String"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageLOC_GATEIN" id="07a54515-9e64-4c93-9291-e9b843270601">
        <source>makeMessageLOC_GATEIN(_camProtocol :CM_CamProtocol; _group :HugeStringArray input;  _activity :Integer; _ti :CM_TrackedItem; _contentsStatus :String) protected;
/*	

Date		Who		Reason
19 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars
	code, fCode	:String;
begin
	code := _ti.dischargePort.trimRight;
	
	if code = null then
		code := _ti.destinationPort.trimRight;
	endif;

	fCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, _camProtocol.terminal).trimRight;

	if fCode &lt;&gt; null then
		self.makeLOCSegment (_camProtocol, _group, '11', fCode, '139', '6', null, null, null);	// par 27460 09/05/2011 cnwcs5 
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_contentsStatus" type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessageLOC_GATEOUT" id="d6d08218-0ba4-4ee7-af0b-97b2b31776bf">
        <source>makeMessageLOC_GATEOUT(_camProtocol :CM_CamProtocol; _group :HugeStringArray input;  _activity :Integer; _ti :CM_TrackedItem; _contentsStatus :String) protected;
/*	

Date		Who		Reason
19 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars
	code, pCode, fCode	:String;
	terminal			:CM_Terminal;
begin
	terminal	:= _camProtocol.terminal;
	
	//get the port code
	code 	:= _ti.loadPort; //par18107 cnwrs1 oct 2008
	pCode 	:= self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, terminal);
	
	if pCode = null then
		pCode := code;
	endif;
	
	pCode := pCode.trimRight;
	
	//get the consignee code
	code 	:= _ti.consignee;
	fCode 	:= self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_CONSIGNEE_BYOP, terminal);
	
	if fCode = null then
		fCode := code;
	endif;
	
	fCode := fCode.truncatedAt(25); //PAR 19038 cnwgb1 20.5.09
	
	self.makeLOCSegment (_camProtocol, _group, '9', pCode, '139', '6', fCode, 'CNE', 'ZZZ');	// par 27460 09/05/2011 cnwcs5 				
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_activity" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_contentsStatus" type="String"/>
    </JadeMethod>
    <JadeMethod name="makeMessages" id="a2eb3ff1-c34e-4916-9233-8ff4f8072661">
        <source>makeMessages(_trackedItem:CM_TrackedItem; _transaction: CM_TITransaction; _camProtocol: CM_CamProtocol; _camMessage: CM_CamMessage input; _xlVoyageId: String; _terminal: CM_Terminal; _secondTrx : CM_TITransaction);
// 10/02/2011	cnwcs5	CCMS JMT 1977/PAR 26531 - changed _camMessage parameter usage from io to input
// 18/05/2011	cnwcs5	ccms sct 2058/par27460 - user defined special characters
// 05 Jan 2012	cnwrs1	Par 28933 - do not produce SEL message for MT containers
// 30/05/2016	cnwdap1	TFS #2061 COPARN/CODECO/COARRI/EDI VGM Updates
// 15/07/2016   cnwma1  TFS #2376 POL - CODECO NAD lines in wrong segment and doubling up on information
// 07/07/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
//23/08/2017	cnwma1  TFS #5834-PNL - EDI Translation - ISO Code foreign out
// 19 Sep 2017	jlgrs1	TFS 6957 Codeco/Coarri VGM extra details
// 21 Jun 2022	jlizm1	TFS 53754 LNX Different local and server time zones causing incorrect edi outputs
vars
	fCode, code, 
	imExStatus		: String;
	ti				:CM_TrackedItem;
	contentsStatus 	: String; //ccms 1670 cnwrs1 Apr 2007
	isoCode,fIsoCode : String;
	includeVGM : Boolean;
begin
//COSCO
	ti := _transaction.myTrackedItem;
	if _camProtocol.useVGM and 
	   _camProtocol.getIncludeExtraVGM and
	   ti &lt;&gt; null and 
	   ti.isWeightCertified and 
	   not ti.isEmpty then		// TFS #2061
		includeVGM := true;
	endif;
	//ccms 1670 cnwrs1 Mar 2008
	contentsStatus := self.contentsStatusToString(_transaction.contentsStatus, _camMessage.activity, _transaction.type);
	if contentsStatus = "5" then
		// cnwrl1 19/10/2010 PAR 25867 - start of replacement coding
		// set up the potential group of GID, TMP, SGP and DGS records.
		if ti.CM_Container.getTemperature &lt;&gt; NULL_TEMPERATURE or ti.allTIHazards.isNotEmpty then
			// GID+ - Goods Item Details
			self.makeGIDSegment (_camProtocol, _camMessage.group3, 1);	// par 27460 09/05/2011 cnwcs5 
			// TMP Segment
			self.makeTMPSegment (_camProtocol, _camMessage.group3, 2, ti.getTemperature, "CEL");	// par 27460 17/05/2011 cnwcs5 	
			// Split Goods Placement
			self.makeSGPSegment (_camProtocol, _camMessage.group3, ti.id.trimRight, null);		// par 27460 09/05/2011 cnwcs5 	
			// ie Dangerous Goods
			if not _camProtocol.dgsDetailsInGroup14  then							//JIRA-20814
				self.makeMessageHazardsData (ti, _camProtocol, _camMessage.group3);	// par 27460 09/05/2011 cnwcs5 	
			endif;																	//JIRA-20814
		endif;
	endif;
	
	if contentsStatus = "5" then
		imExStatus := self.imExStatusToString(ti); //full
	else
		imExStatus := ""; //empty
	endif;
	
	// EQD+ segment
	//self.makeEQDSegment (_camProtocol, _camMessage.group5, "CN", ti.id.trimRight, ti.CM_Container.isoType, '102', '5', null, imExStatus, contentsStatus); // par 27460 17/05/2011 cnwcs5 	//23/08/2017 cnwma1 TFS #5834
	isoCode := ti.CM_Container.isoType;
	fIsoCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode, isoCode, XLATION_TYPE_ISOTYPE_BYOP, _terminal);
	self.makeEQDSegment (_camProtocol, _camMessage.group5, "CN", ti.id.trimRight, fIsoCode, '102', '5', null, imExStatus, contentsStatus);  //23/08/2017 cnwma1 TFS #5834	
	_camMessage.eqdCount := _camMessage.eqdCount + 1;
	
	// RFF segments
	self.makeRFFSegment (_camProtocol, _camMessage.group5, "CV",  "F1");	// par 27460 17/05/2011 cnwcs5 			
	
	// RFF+BN
	self.makeMessageRFF_BN (_camProtocol, _camMessage.group5, _camMessage.activity, ti, _transaction);	// par 27460 cnwcs5

	// RFF+CN - special18 field
	self.makeMessageRFF_CN (_camProtocol, _camMessage.group5, ti);	// par 27460 cnwcs

	// if creating extra messages for pack/unpack add 1 minute to the second message
	self.makeDTMSegment (_camProtocol, _camMessage.group5, '7', self.transDateTime(_transaction, _camMessage.activity, _camProtocol), '203');	// TFS 53754
	if includeVGM then
		self.makeMessageDTM_VGM(_camProtocol, _camMessage.group5, ti);					// TFS 4492
	endif;

	if _camMessage.activity = CODECO_GATEIN then	//Par 18631. Dec 2008
		// LOC segments
		self.makeMessageLOC_GATEIN (_camProtocol, _camMessage.group5, _camMessage.activity, ti, contentsStatus);	// par 27460, cnwcs5

	endif;

	if _camMessage.activity = CODECO_GATEOUT then
		// LOC
		self.makeMessageLOC_GATEOUT (_camProtocol, _camMessage.group5, _camMessage.activity, ti, contentsStatus);	// par 27460, cnwcs5		

	endif;

	code := _terminal.getConfig(PortDestCode).String;
	fCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode, code, XLATION_TYPE_PORT_BYOP, _terminal);
	// LOC+165
	self.makeLOCSegment (_camProtocol, _camMessage.group5, '165', fCode, '160', '20', null, null, null);	// par 27460 09/05/2011 cnwcs5 				
	// MEA+ segment
	self.makeMEASegmentForTotalWeight(_camProtocol, _camMessage.group5,ti,null); //epr par 37551 TFS 1429 16/2/16
	// DIM+ segment
	self.makeMessageDimensionsData (_camProtocol, _camMessage.group5, ti);		// par 27460 17/05/2011 cnwcs5
	//the SEL for the seal number
	self.makeMessageSealsData( ti, _camMessage, _camMessage.group5, _camProtocol, contentsStatus);	//15 Sep 2010	NDL	Par 25608
	// FTX+AAI
	self.makeMessageFTX_DeliveryReason (_camProtocol, _camMessage.group5, ti);	// par 27460 cnwcs5	
	if includeVGM then
		self.makeMessageFTX_VGM(_camProtocol, _camMessage.group5, ti);					// TFS 4492
	endif;
	// EQA - the only attached equipment is a reefer generator
	self.makeEQASegment (_camProtocol, _camMessage.group5, 'RG', ti);	// par 27460 09/05/2011 cnwcs5
	// TDT+1
	self.makeMessageTDT1Segment (_camProtocol, _camMessage.group5, _camMessage.activity, _transaction, ti); // par 27460 09/05/2011 cnwcs5
	
	// TFS #2061 NDA for VGM																			// TFS #2061
	if includeVGM then				// TFS #2061
		self.makeMessageNAD_VGM(_camProtocol, _camMessage.group5, ti);									// 15/07/2016 cnwma1  TFS #2376
	endif;																								// TFS #2061
	
	// ie Dangerous Goods													//JIRA-20814
	if _camProtocol.dgsDetailsInGroup14  then								//JIRA-20814
		self.makeMessageHazardsData (ti, _camProtocol, _camMessage.group5);	//JIRA-20814
	endif;																	//JIRA-20814
end;
</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_xlVoyageId" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_secondTrx" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_NAD" id="0ab8262e-6309-491b-8ed2-5a41e69c6b23">
        <updating/>
        <source>outputHeader_NAD (_protocol :CM_CamProtocol; _camMessage :CM_CamMessage input; _camTaskHistory :CM_CamTaskHistory input; _coll :HugeStringArray input) : String updating, protected;
/*
Date		Who		Reason
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
vars
	terminal	:CM_Terminal;
	code, port	:String;
	strLine : String;
begin
	terminal	:= _protocol.terminal;
	
	code 	:= terminal.getConfig(PortDestCode).String;
	port 	:= self.getXlatedForeignCode(_protocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_PORT_BYOP, terminal).trimBlanks;

	strLine := strLine &amp; self.outputFileMessage (_camTaskHistory, self.makeNADSegment (_protocol, null, "CF", _protocol.camGroup.recipient.trimBlanks, '160', '143'), _coll);
	
	_camMessage.segmentCount := _camMessage.segmentCount + 1;

	strLine := strLine &amp; self.outputFileMessage (_camTaskHistory, self.makeNADSegment (_protocol, null, "MS", port, '160', '143'), _coll);

	_camMessage.segmentCount := _camMessage.segmentCount + 1;
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_UNB" id="168085b6-40b0-404b-9645-daaf73eb0904">
        <updating/>
        <source>outputHeader_UNB(_protocol: CM_CamProtocol; _camTaskHistory: CM_CamTaskHistory input; _seqNumber: Integer; _coll :HugeStringArray input; _contextObj : CM_Object) : String updating, protected;
/*
Date		Who		Reason
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
vars

	senderCode, recipientCode, msg	:String;
	ts : TimeStamp;	//30 Apr 2018	NDL	TFS 37406
	
begin

	//30 Apr 2018	NDL	TFS 37406
	ts := _camTaskHistory.runDateTime;
	if _protocol.singleContainerPerUNB and _contextObj &lt;&gt; null then
		_protocol.incrementTSForContext( _contextObj, ts );
	endif;
	
	senderCode 		:= _protocol.camGroup.senderCode.trimBlanks;
	recipientCode 	:= _protocol.camGroup.recipient.trimBlanks;

	msg 	:= self.makeUNBSegment (_protocol, "UNOA", 1, senderCode, 'ZZ', recipientCode, 'ZZ', _seqNumber, null, false, ts );
	
	return self.outputFileMessage(_camTaskHistory, msg, _coll); 

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_seqNumber" type="Integer"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <Parameter name="_contextObj" type="CM_Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="outputHeader_UNH_BGM" id="ad2d2780-a83e-42b6-86eb-ae560c8b70ee">
        <updating/>
        <source>outputHeader_UNH_BGM(_camMessage: CM_CamMessage input; _camTaskHistory: CM_CamTaskHistory input; _camFile: CM_CamFile input; _unhSeqNumber: Integer io; _coll: HugeStringArray input) : String updating, protected;
/*
Date		Who		Reason
20/12/2012	cnwcs5	CCMS SFW 1294 /par 30855
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
//25 Feb 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
vars
	strLine : String;
begin
	if _camMessage.activity = CODECO_GATEIN then
		strLine := strLine &amp; self.makeMessageHeader(_camFile, _camTaskHistory, _unhSeqNumber, "34:::ARR", "CODECO", _coll);
		
		_camMessage.segmentCount := _camMessage.segmentCount + 2;
	elseif _camMessage.activity = CODECO_GATEOUT then
		strLine := strLine &amp; self.makeMessageHeader(_camFile, _camTaskHistory, _unhSeqNumber, "36:::DEP", "CODECO", _coll);
		
		_camMessage.segmentCount := _camMessage.segmentCount + 2;
	else 
		//epr par 37551 16/2/16
		strLine := inheritMethod(_camMessage, _camTaskHistory, _camFile, _unhSeqNumber, _coll);
	endif;
	return strLine;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_camTaskHistory" type="CM_CamTaskHistory" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_unhSeqNumber" type="Integer" usage="io"/>
        <Parameter name="_coll" type="HugeStringArray" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processTransaction" id="2030508c-ba7c-49d2-afbb-f0584c903dc5">
        <updating/>
        <source>processTransaction(_transaction: CM_TITransaction; _camProtocol: CM_CamProtocol; _camAgent : CM_CamControllerAgent input; _camFile: CM_CamFile input) updating;
/* special version for COSCO which creats onr message per container */
// 12/05/2010	cnwcs5	par 23967 - change _camFile paremeter to be input not io so as to correctly reflect its usage
//12 Jul 2012	cnwrs1	CCMS 1269 CAMS reduce number of Trxs
//18 Jul 2012	cnwrs1	CCMS 1269 CAMS remove CM_CamTask
// 17 Dec 201	cnwcs5	CCMS SFW 1294 / par 30855
// 04 Feb 2013	cnwcs5	CCMS SFW 1294 /par 30855
//20 dec 2016	cnwrs1	TFS 3158 Cams Exclusion report does not include the rehandles and sobs
vars
	camMessage 			: CM_CamMessage;
	messageTypeArray 	: IntegerArray;
	messageType 		: Integer;
	xlVoyageId,code,xlVoyage : String;
	voyageOid			:CM_Voyage;
	contentsStatus 		: String;
	arrayPos3, arrayPos4, arrayPos5 : Integer;
	theTI 				: CM_TrackedItem;
	vesselName 			: String; //par18987 cnwrs1 Mar 2009
	firstTime			: Boolean;					// cnwrl1 05/08/2010 PAR 21961
begin
	_camAgent.writeDebugLog(class.name&amp;'::'&amp;method.name&amp;" process "&amp;_transaction.getCamsDisplayDetails);
	
	theTI := _transaction.myTrackedItem;

	create messageTypeArray transient;

	//get the translated voyage Code
	xlVoyageId := self.getVoyageCode(_transaction, _camProtocol, vesselName); //par18987 cnwrs1 Mar 2009
	
	// Only need to clear the camTask tiMessages for each new transaction not each messageType.
	firstTime	:= true;					// cnwrl1 05/08/2010 PAR 21961
	
	self.getMessageType(_transaction, messageTypeArray, _camProtocol,_camAgent);
		
	if messageTypeArray.size &gt; 0 then
		foreach messageType in messageTypeArray do
			//translate the voyage Code
			code 		:= _transaction.myTrackedItem.myVoyage.code;
			xlVoyage 	:= self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, code, XLATION_TYPE_VOYAGETERMINAL, _camProtocol.terminal);
			camMessage 	:= self.setCamMessage(messageType, _camProtocol, _camFile, _transaction, xlVoyage, vesselName, voyageOid, _camProtocol.terminal);

			if camMessage &lt;&gt; null then
				contentsStatus := self.contentsStatusToString(_transaction.contentsStatus, camMessage.activity, _transaction.type);

				arrayPos3 := camMessage.group3.size;
				arrayPos4 := camMessage.group4.size;
				arrayPos5 := camMessage.group5.size;
				
				camMessage.camVoyage.voyageOid  := null; //transaction.trackedItem.voyage;
				camMessage.tiId 				:= _transaction.myTrackedItem.id.trimRight;
				
				self.makeMessages(null, _transaction, _camProtocol, camMessage, xlVoyage, _camProtocol.terminal, null);

				camMessage.setupCAMSInfoDetails(_camProtocol, arrayPos3, arrayPos4, arrayPos5, _transaction);	//12 Jul 2012	cnwrs1	CCMS 1269 CAMS reduce number of Trxs
			else
				if _camAgent.logExcludedTransactions then
					_camAgent.logReasonForExclusion(_transaction, "CAM Message is null " &amp; _transaction.String &amp; ".");
				endif;
			endif;
		endforeach;
	endif;
epilog
	if messageTypeArray &lt;&gt; null then
		delete messageTypeArray;
	endif;
end;
</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setCamMessage" id="9ab32fc8-ef21-41f7-9216-70bd3c6312c2">
        <updating/>
        <source>setCamMessage(_messageType:Integer; _camProtocol: CM_CamProtocol; _camFile: CM_CamFile input; _transaction: CM_TITransaction; _voyageCode, _vesselName: String output; _voyageOid: CM_Voyage output; _terminal:CM_Terminal): CM_CamMessage updating;
// 12/05/2010	cnwcs5	par 23967 - change _camFile paremeter to be input not io so as to correctly reflect its usage
vars
	camMessage : CM_CamMessage;
	fCode : String;
	vesselName : String; //par18987 cnwrs1 mar 2009
begin

	//get the voyage code
	_voyageOid := null;
	if _voyageOid &lt;&gt; null then
		_voyageCode := "";
		_voyageOid := null;
		if _transaction.myTrackedItem.voyageCode &lt;&gt; "" then
			_voyageOid := _terminal.lookupVoyage(_transaction.myTrackedItem.voyageCode, null, false);
			if _voyageOid &lt;&gt; null then
				if _voyageOid.inwardCode &lt;&gt; "" then
					_voyageCode := _voyageOid.inwardCode;
					_voyageOid := _terminal.lookupVoyage(_voyageCode, null, false);
				endif;
			endif;
		endif;
	else
		fCode := _transaction.myTrackedItem.voyageCode.trimRight;
		_voyageOid := _transaction.myTrackedItem.myVoyage;
		//translate the voyage Code
		if fCode = "HOLD" then
			_voyageCode := fCode;
		elseif fCode = NULL_VOYAGE_CODE then
			_voyageCode := null;
		else
			_voyageCode := self.getXlatedForeignCode(_camProtocol.operatorXlationCode.trimBlanks, fCode, XLATION_TYPE_VOYAGETERMINAL, _terminal);
		endif;
	endif;

// setup the cam message for this transaction
	camMessage := self.getCamMessageById(_camFile, _voyageCode, vesselName, _messageType, _transaction.myTrackedItem.id);  //par 21520 cnwrs1 oct 2009
	return camMessage;
end;</source>
        <Parameter name="_messageType" type="Integer"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camFile" type="CM_CamFile" usage="input"/>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_voyageCode" type="String" usage="output"/>
        <Parameter name="_vesselName" type="String" usage="output"/>
        <Parameter name="_voyageOid" type="CM_Voyage" usage="output"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_CamMessage"/>
    </JadeMethod>
</Class>
