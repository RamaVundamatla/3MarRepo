        <source>jtdSetRandomSelection(b : Boolean) updating;

begin
	self.jtdRandomSelection := b;
end;</source>
        <Parameter name="b" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jtdSetStopWhenAllRun" id="494088cf-d2f4-4867-a5c5-6fe5b883eeb6">
        <updating/>
        <source>jtdSetStopWhenAllRun(b : Boolean) updating;

begin
	self.jtdStopWhenAllRun := b;
end;</source>
        <Parameter name="b" type="Boolean"/>
    </JadeMethod>
</Class>
