    <JadeMethod name="propertyNotVerified" id="9201a3ae-214a-4674-8192-3875e3c51d79">
        <source>propertyNotVerified(_propName: String): Boolean;
//
// 30 Apr 2019	jlgrs1	TFS40086 JMT Not all EDI TrackedItem stringArray are exposed to the EDI JMT Internal
//08 Aug 2023	jlirs1	unittest tCustomStopExport was failing
//
vars

begin
	if _propName = CM_EDICustomStopTI::clientRef.name then
		return true;
	elseif _propName = CM_EDICustomStopTI::customsRef.name then
		return true;
	elseif _propName = CM_EDICustomStopTI::entryNumber.name then
		return true;
	elseif _propName = CM_EDICustomStopTI::isUSCustomMessage.name then
		return true;
	elseif _propName = CM_EDITrackedItem::messageMode.name then
		return true;
	elseif _propName = CM_EDICustomStopTI::myVoyage.name then
		return true;
	elseif _propName = CM_EDICustomStopTI::packCount.name then
		return true;
	elseif _propName = CM_EDICustomStopTI::quantityEntered.name then
		return true;
	elseif _propName = CM_EDICustomStopTI::quantityReleased.name then
		return true;
	elseif _propName = CM_EDICustomStopTI::quantity.name then
		return true;
	elseif _propName = CM_EDICustomStopTI::responseStatus.name then
		return true;
	elseif _propName = CM_EDICustomStopTI::transmissionDate.name then
		return true;
	elseif _propName = CM_EDICustomStopTI::typeString.name then
		return true;
	elseif _propName = CM_EDICustomStopTI::vesselName.name then
		return true;
	elseif _propName = CM_EDICustomStopTI::voyageCode.name then
		return true;
	elseif _propName = CM_EDICustomStopTI::roleCode.name then		//08 Aug 2023	jlirs1	unittest tCustomStopExport was failing
		return true;
	elseif _propName = CM_EDICustomStopTI::statementCode.name then	//08 Aug 2023	jlirs1	unittest tCustomStopExport was failing
		return true;
	else
		return inheritMethod(_propName);
	endif;
epilog

end;</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sealEDINumVerify" id="58cae5ec-218f-4642-81ee-2803cdc5d3c3">
        <source>sealEDINumVerify();
//
// 26 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
//
vars

begin
	if self.sealEDINum = null then
		app.raiseCMWarning2(ERR_FIELD_COMMODITY, self.sealEDINum, 'Seal Number', 'sealEDINum', self, self);
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="sealEDITypeVerify" id="f064c4fe-e2e5-496e-880c-e07f8ca8d5fb">
        <source>sealEDITypeVerify();
//
// 26 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
//
vars

begin
	if self.sealEDIType = null then
		app.raiseCMWarning2(ERR_FIELD_COMMODITY, self.sealEDIType, 'Seal Type', 'sealEDIType', self, self);
	endif;
end;

</source>
    </JadeMethod>
    <JadeMethod name="sealTypeTranslate" id="510329a7-0131-4c0c-b6fe-05d2146ec602">
        <source>sealTypeTranslate(_sealTypeStr : String) : String;
//
/// 06 Jul 2017	jlgrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
//
vars
	sealType : CM_SealType;
	sealTypeStr : String;
begin
	if _sealTypeStr = "SH" then
		sealTypeStr := SealType_Shipper;
	elseif _sealTypeStr = "CU" then
		sealTypeStr := SealType_Customs;
	elseif _sealTypeStr = "TO" then
		sealTypeStr := SealType_TerminalOperator;
	elseif _sealTypeStr = "AB" then
		sealTypeStr := SealType_Unknown;
	elseif _sealTypeStr = "OP" then
		sealTypeStr := SealType_Operator;
	else
		sealTypeStr := _sealTypeStr[1:10];
	endif;
	return sealTypeStr;
end;
</source>
        <Parameter name="_sealTypeStr" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="d3770ebd-18fa-4503-961c-89e8e674a859">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
//
// 15 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
//
vars

begin
	inheritMethod(_proxyEDITI);
	self.sealEDINum := _proxyEDITI.sealEDINum;
	self.sealEDIType := _proxyEDITI.sealEDIType;
end;
</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setSealNumCMIFReceive" id="ffb5d31c-37a5-4b52-9313-60335c0578d5">
        <updating/>
        <source>setSealNumCMIFReceive(_cmifReceive : CMIF_Receival) updating;
//
// 06 Jul 2017	jlgrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
//
vars
	sealType : CM_SealType;
begin
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;self.sealEDIType.String&amp;' '&amp;self.sealEDINum;
	sealType := app.myRoot.getSealType(self.sealEDIType);
	if sealType = null then
		sealType := app.myRoot.getSealType(SealType_Unknown);
	endif;
	if sealType &lt;&gt; null then
		_cmifReceive.setSealNumberValueAdditional(sealType, self.sealEDINum, null);
	endif;
end;
</source>
        <Parameter name="_cmifReceive" type="CMIF_Receival"/>
    </JadeMethod>
    <JadeMethod name="setSealNumCMTrackedItemProxy" id="9a457418-6ca1-4b40-836c-661b66956f90">
        <updating/>
        <source>setSealNumCMTrackedItemProxy(_proxyTrackedItem : CM_TrackedItem input) updating;
//
// 06 Jul 2017	jlgrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
//
vars
	sealType : CM_SealType;
begin
	sealType := app.myRoot.getSealType(self.sealEDIType);
	if sealType = null then
		sealType := app.myRoot.getSealType(SealType_Unknown);
	endif;
	if sealType &lt;&gt; null then
		_proxyTrackedItem.setSealNumberValueAdditional(sealType, self.sealEDINum, null);
	endif;
end;
</source>
        <Parameter name="_proxyTrackedItem" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
</Class>
