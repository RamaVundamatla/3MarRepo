    <JadeMethod name="addAutoSchedule" id="5950ff9f-af16-4013-9ae2-75f6a8a23234">
        <source>addAutoSchedule(_autoSchedule : String; _scheduleTS : TimeStamp; _recurValue : Integer) :CM_AutoSchedule;
/*

Purpose:			

/* Changes

Date		Name	TFS#	Description
============================================================================
14/04/2014	cnwma1			Initial creation
16/04/2019	jlgka1	43863	Added Recurring value.
============================================================================*/

vars
	pxyAutoSched  : CM_AutoSchedule;
	realAutoSched : CM_AutoSchedule;
begin

	deleteAutoSchedule(_autoSchedule, _scheduleTS);
		
	//time := "11:30".Time;
	create pxyAutoSched transient;
	pxyAutoSched.setForDate(_autoSchedule,					//Description
							_scheduleTS.date.day.String,	// Day
							_scheduleTS.time,				//Time
							_recurValue);	      			// jlgka1 TFS 43863
							
	if self.opts.includesKey("autoTasksArray") then
		self.opts.obj("autoTasksArray").CM_AutoTaskArray.copy(pxyAutoSched.allAutoTasks);	
	endif;	
							
	app.myTrxCA.trxCreateAutoSchedule(pxyAutoSched,realAutoSched,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return realAutoSched;
	
epilog
	delete pxyAutoSched;

end;</source>
        <Parameter name="_autoSchedule" type="String"/>
        <Parameter name="_scheduleTS" type="TimeStamp"/>
        <Parameter name="_recurValue" type="Integer"/>
        <ReturnType type="CM_AutoSchedule"/>
    </JadeMethod>
    <JadeMethod name="addAutoTask" id="67d88be2-9f52-49d4-9848-fb87ac0a8cb3">
        <source>addAutoTask(_autoTaskClassName, _autoDescription : String; _user : CM_User; _terminal : CM_Terminal) : CM_AutoTask;

/*

Purpose:		Create / Add an Auto Task

Date			Who		Reason
10/02/2016		cnwmh5	Initial creation

*/

vars

	pxyAutoTask					: CM_AutoTask;
	autoTask					: CM_AutoTask;
	klass						: Class;
	prop						: Property;
	assoc						: CM_Association;
	obj							: Object;
	
	
	properties					: PropertyColl;
	
	iter						: Iterator;
	iterAssoc					: Iterator;
	
	optsKey						: String;

begin

	self.deleteAutoTask(_autoDescription, _autoTaskClassName);

	klass := rootSchema.getSchema("PortSchema").getClass(_autoTaskClassName);
	self.assertNotNull(klass);
	
	create pxyAutoTask as klass transient;
	
	// set the default values for the auto task
	pxyAutoTask.setValueForRow(ETRow_BgpAutoDescription,_autoDescription);
	pxyAutoTask.setValueForRow(ETRow_BgpAutoUser, _user);
	pxyAutoTask.setValueForRow(ETRow_BgpAutoTerminals, _terminal);
	
	// grab the properties for the auto task and set accordingly	
	properties := pxyAutoTask.class.allPropertiesUpTo(klass);
	
	iter := properties.createIterator;
	while iter.next(prop) do
		delete iterAssoc;
		iterAssoc := self.opts.createIterator;
		self.opts.startKeyGeq(prop.name.toUpper(), iterAssoc);
		while iterAssoc.next(assoc) do
			self.opts.getIteratorKeys(optsKey, iterAssoc);
			if optsKey = prop.name.toUpper() then
				if prop.type.inheritsFrom(Collection) then
					assoc.getValue().Collection.copy(pxyAutoTask.getPropertyValue(prop.name).Collection);
				else
					pxyAutoTask.setPropertyValue(prop.name, assoc.getValue());
				endif;
				break;
			endif;
			self.opts.removeAssoc(optsKey);
		endwhile;
	endwhile;
	
	// create the auto task
	app.myTrxCA.trxCreateAutoTask(pxyAutoTask, autoTask, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return autoTask;
	
epilog

	delete pxyAutoTask;
	delete properties;
	delete iterAssoc;
	delete iter;

end;</source>
        <Parameter name="_autoTaskClassName" type="String"/>
        <Parameter name="_autoDescription" type="String"/>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_AutoTask"/>
    </JadeMethod>
    <JadeMethod name="addAvailabilityGrade" id="b258bb49-f6e5-4ece-bdbf-6ebe0210ed3b">
        <source>addAvailabilityGrade(_availGradeId : Integer; _availGradeDesc : String; _suitableForRelease, _notAvailable : Boolean) : CM_MTGrade;

/*

Purpose:		Add a commodity	

Date			Who		Reason
29/11/2011		cnwmh5	Initial creation

*/

vars

	pxyAvailGrade					: CM_MTGrade;
	availGrade,
	availGradeToDelete 				: CM_MTGrade;
		
begin

	// delete the existing availability grade
	availGradeToDelete := app.myRoot.allAvailabilityGrades[_availGradeId];
	self.deleteAvailabilityGrade(availGradeToDelete);

	create pxyAvailGrade transient;
	
	pxyAvailGrade.setProxy(_availGradeId,			// Id / Code
						   _availGradeDesc,			// Description
						   _suitableForRelease,		// Sutiable for Release
						   _notAvailable,			// not available
						   0,						// colour
						    null,					// Allowed Release terminal
						    null);					// allowed edit sub terminal
						  
	app.myTrxCA.trxCreateAvailabilityGrade(pxyAvailGrade, availGrade, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return availGrade;

epilog
	delete pxyAvailGrade;
end;</source>
        <Parameter name="_availGradeId" type="Integer"/>
        <Parameter name="_availGradeDesc" type="String"/>
        <Parameter name="_suitableForRelease" type="Boolean"/>
        <Parameter name="_notAvailable" type="Boolean"/>
        <ReturnType type="CM_MTGrade"/>
    </JadeMethod>
    <JadeMethod name="addBGPManager" id="d0aa7ea6-41e4-4391-b0af-c9acc111106d">
        <source>addBGPManager(_bgpName : String) : BGP_Manager;

/*

Purpose:		Create a BGP Manager

Date			Who		Reason
18/02/2015		cnwmh5	Initial creation

*/

vars
	
	cmif 				: CMIF_BGPManagerChildren;
	manager				: BGP_Manager;
	
	isServer			: Boolean;
	
begin

	self.deleteBGPManager(_bgpName);


	create cmif transient;
	
	if opts.includesKey("IsServer") then
		isServer := self.opts.bool("IsServer");
	endif;	
	
	cmif.isServer 				:= isServer;					// Server
	cmif.managerName			:= _bgpName;					// Manager Name
	cmif.numberOfRemotes		:= 1;							// No Generic
	
	/*
	_cmif.numberOfRemotes		:= remote;						
	_cmif.numberOfReports		:= report;						// No. Reports
	_cmif.numberOfDirectories	:= directory;					// No. Directories
	_cmif.numberOfTcpIpServers	:= tcpServer;					// No. TCP/IP Servers
	_cmif.isAutoTimer			:= timer;						// Auto Timer
	_cmif.numberOfTcpIpClients	:= tcpClient;					// No. TCP/IP Clients
	_cmif.isLockKeeper			:= isLockKeeper;				// Lock Keeper
	_cmif.isChangeTracker		:= isChangeTracker;				// Change Tracker
	_cmif.isBackupJournal 		:= isBackupJournal;				// Backup Journal
	_cmif.machineNameSpecific	:= machineNameSpecific;			// Machine Name
	_cmif.isAutoWarning			:= isAutoWarning;				// Auto Warning
	_cmif.isVSBookGen			:= isVSBookGen;					// Slot Booking Generator
	*/
	
	app.myTrxCA.trxCreateBGPManager(manager, cmif, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

	return manager;
	
epilog

	delete cmif;

end;</source>
        <Parameter name="_bgpName" type="String"/>
        <ReturnType type="BGP_Manager"/>
    </JadeMethod>
    <JadeMethod name="addBOL" id="d0d80077-121e-4bd1-ac4a-8b76f433fbed">
        <source>addBOL(_bolNumber : String; _voyage : CM_Voyage; _operator : CM_Operator; _notifyParty : String; _terminal : CM_Terminal): CM_BOL;
//08 January 2010	cnwml2
//25/07/2022    navgm20     ChangeRequest 54095: EUP - Outturn Remarks on BOL

vars
	realBOL	: CM_BOL;
	pxyBOL : CM_BOLIn;
	pxyBOLItem : CM_BOLDtl;
	subTerminal : CM_SubTerminal;
begin

	// get the subterminal
	if app.isSubTerminalsOn(self.getTerminal) and not self.getTerminal.getConfig(IsSubTerminalAreaDefined).Boolean then
		subTerminal := self.getSubTerminal(null);								// 29/04/2014 cnwmh5	
		self.assertNotNull(subTerminal);
	endif;

	create pxyBOL transient;	
	pxyBOL.setProxy(_bolNumber, _voyage, _operator, _notifyParty, 5, BOLType_GeneralBillOfLading, _terminal, subTerminal, null, null, null, false, null, null, null,
																																								null);//13/07/2022 navgm20 Tfs 54095
	
	create pxyBOLItem transient;
	pxyBOLItem.setProxy(pxyBOL, TI_CargoType_Container, "APPL", "colour", "mark",30, 5, 6000, 200, 300, 400, "ACDG", "ACDG", "remarks");
	pxyBOL.allBOLDtls.add(pxyBOLItem);
	
	app.myTrxCA.trxCreateBOL(pxyBOL, realBOL, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return realBOL;
epilog
	delete pxyBOL;
end;
</source>
        <Parameter name="_bolNumber" type="String"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_notifyParty" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_BOL"/>
    </JadeMethod>
    <JadeMethod name="addBOLItem" id="50c797fa-a947-42a6-97c2-870dfdfc9e19">
        <source>addBOLItem(_bol: CM_BOL input): CM_BOL;
//06 July 2009	cnwdw1	
//
vars
	pxyBOL, newBOL: CM_BOL;
	pxyBOLItem: CM_BOLDtl;
begin
	create pxyBOLItem transient;		
	pxyBOLItem.setProxy(_bol, TI_CargoType_Container, "APPL", "colour", "mark", 5, 30, 6000, 200, 300, 400, "ACDG", "ACDG", "remarks");

	pxyBOL := app.createUpdateProxy(_bol).CM_BOL;

	app.myTrxCA.trxCreateBOL(pxyBOL, newBOL, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	return _bol;
epilog
	delete pxyBOLItem;
end;</source>
        <Parameter name="_bol" type="CM_BOL" usage="input"/>
        <ReturnType type="CM_BOL"/>
    </JadeMethod>
