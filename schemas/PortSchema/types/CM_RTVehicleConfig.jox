    <JadeMethod name="setForCreate" id="9d339379-3e02-4eff-b2fb-831096471666">
        <updating/>
        <source>setForCreate(_proxy : CM_RTVehicleConfig;
			 _myMachine : CM_Machine;
			 _myMachineType : CM_MachineType;
			 _myTerminal : CM_Terminal) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 May 2010	cnwer1	Initial creation
16 Apr 2012 cnwer1  Par 29432 1310 exception
*/

vars

begin
	if _myMachine = null  and _myMachineType = null and
		_myTerminal = null then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR,self.class.name, method.name," Terminal, Machine Type and Machine are null",null,null);
		return;
	endif;
	
	
	
	if _myMachine &lt;&gt; null then
		self.myMachine:=_myMachine;
	elseif _myMachineType &lt;&gt; null and _myTerminal &lt;&gt; null then
		//epr par 29432 - check for existing type config
		self.myTerminalMachineType:=_myTerminal.allRTTermMachTypeConfigs[_myMachineType];
		if self.myTerminalMachineType = null then
			create  self.myTerminalMachineType persistent;	
			self.myTerminalMachineType.setDetails(_myTerminal,_myMachineType);
		endif;
		
	elseif _myTerminal &lt;&gt; null and _myMachineType = null then
		self.myTerminal:=_myTerminal;
	endif;
	
	self.setForUpdate(_proxy);
epilog

end;</source>
        <Parameter name="_proxy" type="CM_RTVehicleConfig"/>
        <Parameter name="_myMachine" type="CM_Machine"/>
        <Parameter name="_myMachineType" type="CM_MachineType"/>
        <Parameter name="_myTerminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="728cea23-0829-40dc-baf3-47997c86510e">
        <updating/>
        <source>setForUpdate(_proxy : CM_RTVehicleConfig) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 May 2010	cnwer1	Initial creation
15 Sep 2020	jlgdap1	TFS 49316 MTN Machine Idle Time
01 Jul 2021	navdap1	TFS 51409 PNL Queued Jobs in Driver Mode
15 Jul 2021	navdap1	TFS 51286 STWR Vehicle App Notification Message
01 Sep 2021 navma1	ChangeRequest 51485: PRP - Multi-Roll Pickup Enhancement
25 Aug 2022 jlier1	TFS 54513 - creating defauilt rt vehicle config
03 Oct 2022	navds21	TFS 50083 MTN - Machine Delay Idle Time
20 Feb 2023	navmd1	TFS 56666 SNO - 1310 when creating new Terminal level RT Config. Added Separator to ETView names.
21 Mar 2023	jlika1	TFS 57126	CUX - Make VMT filtering configurable per RT Config
18 Mar 2025	navpw1	JIRA: MTN-34259 - Added a config option to be set on a vehicle basis to Retain Cargo Id in Driver Mode for Overstowed containers

*/
constants
	CargoView = "cargo view";
	TaskView = "task view";
	DirectorView = "director view";
	PrimaryTaskView = "primary tasks";
	SecondaryTaskView = "secondary tasks";
	PrimaryCargoView = "primary cargo";
	SecondaryCargoView = "secondary cargo";
	PrimaryDirectorView = "primary director";
	SecondaryDirectorView = "secondary director";
vars
	taskEntTableDef,
	cargoEntTableDef,
	theEntDef  : EntTableDef;
	theName 			: String;
begin

	self.automaticGetNextTask:=_proxy.automaticGetNextTask;
	self.allowNonRTMoves:=_proxy.allowNonRTMoves;
	self.autoplanDriverInitiatedMove:=self.allowNonRTMoves and _proxy.autoplanDriverInitiatedMove; //epr TFS 6846 8/9/17
	self.allowCargoSearch:=_proxy.allowCargoSearch;
	self.useSeperatePickupSetdown:=_proxy.useSeperatePickupSetdown;
	self.useDetailsViewForPickup := _proxy.useDetailsViewForPickup; //+ cnwmd1 Par 25509
	self.useDetailsViewForSetdown := _proxy.useDetailsViewForSetdown; //+ cnwmd1 Par 25509
	self.allowChangeSetdown:=_proxy.allowChangeSetdown;
	self.allowChangeQueue:=_proxy.allowChangeQueue;
	self.autoResequenceJobs:=_proxy.autoResequenceJobs;
	self.overstowMoveMode:=_proxy.overstowMoveMode;
	self.highlightHight := _proxy.highlightHight; //07/03/2011 cnwdz2 25644
	self.ignoreWarnings:=_proxy.ignoreWarnings;
	self.defaultGraphicView:=_proxy.defaultGraphicView;
	self.allowTandemToDiffTargets := _proxy.allowTandemToDiffTargets;		// 21/11/19 MAP TFS47394
	self.allowColumnFiltering := _proxy.allowColumnFiltering;	
	self.retainCargoIdDriverMode := _proxy.retainCargoIdDriverMode;			// ### JIRA: MTN-34259 18Mar2025 NAVPW1
	self.doSwapChangeCargo := _proxy.doSwapChangeCargo; //29/10/2025	navkc1 JIRA 36186
	
	self.autoSearchDirector := _proxy.autoSearchDirector;	//10 Nov 2017	NDL	TFS 7427
	
	//09/11/2010 cnwdz2 26196
	self.columnLabelsPlacement := _proxy.columnLabelsPlacement;
	self.rowLabelsPlacement := _proxy.rowLabelsPlacement;
	
	self.defaultTaskViewMode:=_proxy.defaultTaskViewMode;
	self.taskViewMode:=_proxy.taskViewMode;

	self.limitEnquiryToCurrentQ:=_proxy.limitEnquiryToCurrentQ;
	self.maxNumberOverstowForDriver:=_proxy.maxNumberOverstowForDriver;
	self.maxNumberQueryResults:=_proxy.maxNumberQueryResults;
	self.maxNumberQueueEntries:=_proxy.maxNumberQueueEntries;
	self.maxNumberSearchResults:=_proxy.maxNumberSearchResults;
	self.showSecondaryQueues:=_proxy.showSecondaryQueues; //epr par 25206
	
	self.acceptTimerInterval:=_proxy.acceptTimerInterval;
	self.pickupTimerInterval:=_proxy.pickupTimerInterval;
	
	
	self.tableFontSize:=_proxy.tableFontSize;
	self.tableSelectedFontSize:=_proxy.tableSelectedFontSize;
	
	self.allAvailableGraphicViews.clear;
	_proxy.allAvailableGraphicViews.copy(self.allAvailableGraphicViews);

	self.myQueriesForDrivers:= _proxy.myQueriesForDrivers;
	
	if self.myNightScreenConfig = null then
		create self.myNightScreenConfig persistent;
	endif;
	if _proxy.myNightScreenConfig &lt;&gt; null then
		self.myNightScreenConfig.setForUpdate(_proxy.myNightScreenConfig);
	endif;
	
	if self.myDayScreenConfig = null then
		create self.myDayScreenConfig persistent;
	endif;
	if _proxy.myDayScreenConfig &lt;&gt; null then
		self.myDayScreenConfig.setForUpdate(_proxy.myDayScreenConfig);
	endif;
	
	if self.myVisibleCargoFields = null then
		create self.myVisibleCargoFields persistent;
		theName:=self.getUniqueViewName &amp; CM_RTVehicleConfig.ETVIEW_SEPARATOR &amp; CargoView;
		theEntDef:=app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_RTEnquiry];
		self.myVisibleCargoFields.set(theName,theName,theEntDef);
	endif;
	
	
	self.myVisibleCargoFields.allEntTableRows.clear;
	if _proxy.myVisibleCargoFields &lt;&gt; null then
		_proxy.myVisibleCargoFields.allEntTableRows.copy(self.myVisibleCargoFields.allEntTableRows);
	endif;
	
	if self.myVisibleTaskFields = null then
		create self.myVisibleTaskFields persistent;
		theName:=self.getUniqueViewName &amp; CM_RTVehicleConfig.ETVIEW_SEPARATOR &amp; TaskView;
		theEntDef:=app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_MachineRTFields];
		self.myVisibleTaskFields.set(theName,theName,theEntDef);	
	endif;
	
	self.myVisibleTaskFields.allEntTableRows.clear;
	if _proxy.myVisibleTaskFields &lt;&gt; null then
		_proxy.myVisibleTaskFields.allEntTableRows.copy(self.myVisibleTaskFields.allEntTableRows);
	endif;
	
	if self.myVisibleDirectorFields = null then
		create self.myVisibleDirectorFields persistent;
		theName:=self.getUniqueViewName &amp; CM_RTVehicleConfig.ETVIEW_SEPARATOR &amp; DirectorView;
		theEntDef:=app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_RTEnquiry];
		self.myVisibleDirectorFields.set(theName,theName,theEntDef);
	endif;
	
	self.myVisibleDirectorFields.allEntTableRows.clear;
	if _proxy.myVisibleDirectorFields &lt;&gt; null then
		_proxy.myVisibleDirectorFields.allEntTableRows.copy(self.myVisibleDirectorFields.allEntTableRows);
	endif;
	//epr TFS 4828 20/6/17
	if self.myPrimaryTaskFields = null then
		create self.myPrimaryTaskFields persistent;
		theName:=self.getUniqueViewName &amp; CM_RTVehicleConfig.ETVIEW_SEPARATOR &amp; PrimaryTaskView;
		theEntDef:=app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_VehicleAppFields];
		self.myPrimaryTaskFields.set(theName,theName,theEntDef);
	endif;
	
	self.myPrimaryTaskFields.allEntTableRows.clear;
	if _proxy.myPrimaryTaskFields &lt;&gt; null then
		_proxy.myPrimaryTaskFields.allEntTableRows.copy(self.myPrimaryTaskFields.allEntTableRows);
	endif;
	
	//epr TFS 4828 20/6/17
	if self.mySecondaryTaskFields = null then
		create self.mySecondaryTaskFields persistent;
		theName:=self.getUniqueViewName &amp; CM_RTVehicleConfig.ETVIEW_SEPARATOR &amp; SecondaryTaskView;
		theEntDef:=app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_VehicleAppFields];
		self.mySecondaryTaskFields.set(theName,theName,theEntDef);
	endif;
	
	self.mySecondaryTaskFields.allEntTableRows.clear;
	if _proxy.mySecondaryTaskFields &lt;&gt; null then
		_proxy.mySecondaryTaskFields.allEntTableRows.copy(self.mySecondaryTaskFields.allEntTableRows);
	endif;
	
	
	//epr TFS 5256 05/7/17
	if self.myPrimaryCargoFields = null then
		create self.myPrimaryCargoFields persistent;
		theName:=self.getUniqueViewName &amp; CM_RTVehicleConfig.ETVIEW_SEPARATOR &amp; PrimaryCargoView;
		theEntDef:=app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_VehicleAppCargoFields];
		self.myPrimaryCargoFields.set(theName,theName,theEntDef);
	endif;
	
	self.myPrimaryCargoFields.allEntTableRows.clear;
	if _proxy.myPrimaryCargoFields &lt;&gt; null then
		_proxy.myPrimaryCargoFields.allEntTableRows.copy(self.myPrimaryCargoFields.allEntTableRows);
	endif;
	
	//epr TFS 5256 05/7/17
	if self.mySecondaryCargoFields = null then
		create self.mySecondaryCargoFields persistent;
		theName:=self.getUniqueViewName &amp; CM_RTVehicleConfig.ETVIEW_SEPARATOR &amp; SecondaryCargoView;
		theEntDef:=app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_VehicleAppCargoFields];
		self.mySecondaryCargoFields.set(theName,theName,theEntDef);
	endif;
	
	self.mySecondaryCargoFields.allEntTableRows.clear;
	if _proxy.mySecondaryCargoFields &lt;&gt; null then
		_proxy.mySecondaryCargoFields.allEntTableRows.copy(self.mySecondaryCargoFields.allEntTableRows);
	endif;
	
		//epr TFS 5256 05/7/17
	if self.myPrimaryDirectorFields = null then
		create self.myPrimaryDirectorFields persistent;
		theName:=self.getUniqueViewName &amp; CM_RTVehicleConfig.ETVIEW_SEPARATOR &amp; PrimaryDirectorView;
		theEntDef:=app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_VehicleAppCargoFields];
		self.myPrimaryDirectorFields.set(theName,theName,theEntDef);
	endif;
	
	self.myPrimaryDirectorFields.allEntTableRows.clear;
	if _proxy.myPrimaryDirectorFields &lt;&gt; null then
		_proxy.myPrimaryDirectorFields.allEntTableRows.copy(self.myPrimaryDirectorFields.allEntTableRows);
	endif;
	
		//epr TFS 5256 05/7/17
	if self.mySecondaryDirectorFields = null then
		create self.mySecondaryDirectorFields persistent;
		theName:=self.getUniqueViewName &amp; CM_RTVehicleConfig.ETVIEW_SEPARATOR &amp; SecondaryDirectorView;
		theEntDef:=app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_VehicleAppCargoFields];
		self.mySecondaryDirectorFields.set(theName,theName,theEntDef);
	endif;
	
	self.mySecondaryDirectorFields.allEntTableRows.clear;
	if _proxy.mySecondaryDirectorFields &lt;&gt; null then
		_proxy.mySecondaryDirectorFields.allEntTableRows.copy(self.mySecondaryDirectorFields.allEntTableRows);
	endif;
	
	
	
	self.displayAcceptOnLeftHandSide := _proxy.displayAcceptOnLeftHandSide;  //cnwjo3 par 26026
	self.removeSplitScreen	:=_proxy.removeSplitScreen;
	
	//epr TFS 4828 21/6/17 Vehicle App changes
	self.messagePollingInterval:=_proxy.messagePollingInterval;
	self.listPollingInterval:=_proxy.listPollingInterval;
	//epr par 33425 14/2/14
	if  self.myTerminal &lt;&gt; null then
	
		if _proxy.myIsoTypeHookCode = null then
			delete self.myIsoTypeHookCode;
		else
			
			if self.myIsoTypeHookCode = null then
				create self.myIsoTypeHookCode persistent;
				self.myIsoTypeHookCode.setForCreate(_proxy.myIsoTypeHookCode);
			else
				self.myIsoTypeHookCode.setForUpdate(_proxy.myIsoTypeHookCode);
			endif;
		endif;
		
		if _proxy.myDoorDirectionHookCode = null then
			delete self.myDoorDirectionHookCode;
		else
			
			if self.myDoorDirectionHookCode = null then
				create self.myDoorDirectionHookCode persistent;
				self.myDoorDirectionHookCode.setForCreate(_proxy.myDoorDirectionHookCode);
			else
				self.myDoorDirectionHookCode.setForUpdate(_proxy.myDoorDirectionHookCode);
			endif;
		endif;
		
		if _proxy.myLocationHookCode = null then
			delete self.myLocationHookCode;
		else
			
			if self.myLocationHookCode = null then
				create self.myLocationHookCode persistent;
				self.myLocationHookCode.setForCreate(_proxy.myLocationHookCode);
			else
				self.myLocationHookCode.setForUpdate(_proxy.myLocationHookCode);
			endif;
		endif;
	endif;
	
	self.idleTimeAllowable := _proxy.idleTimeAllowable;					// TFS 49316
	self.idleTimeUntilAlert := _proxy.idleTimeUntilAlert;				// TFS 49316
	self.idleTimeRecordInHistory := _proxy.idleTimeRecordInHistory;		// TFS 49316
	
	self.allowChangeQSetdown := _proxy.allowChangeQSetdown;				// TFS 51409
	self.allowNonRTQMoves := _proxy.allowNonRTQMoves;					// TFS 51409
	
	self.driverDismissMessages := _proxy.driverDismissMessages;			// TFS 51286
	self.allowDriverMultiMoves := _proxy.allowDriverMultiMoves;    		//31.09.2021 navma1 #51485
	self.locationDisplayFormat := _proxy.locationDisplayFormat;        // 29/10/21 jlier1 52160
	self.delayTimeAllowable := _proxy.delayTimeAllowable;				// 03.10.2022 navds21 TFS 50083
	self.delayTimeUntilAlert := _proxy.delayTimeUntilAlert;				// 03.10.2022 navds21 TFS 50083
epilog

end;</source>
        <Parameter name="_proxy" type="CM_RTVehicleConfig"/>
    </JadeMethod>
    <JadeMethod name="setMachineIdleTimeDetails" id="7b69a28c-01af-41e3-8b58-9668d1ea8b07">
        <updating/>
        <source>setMachineIdleTimeDetails(_idleTime, _idleTimeAlert,_delayTimeAllowable,_delayTimeUntilAlert: Integer; _idleHistory: Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 14/09/2020	jlgdap1		Initial creation TFS 49316 MTN Machine Idle Time
// 03/10/2022   navds21     TFS 50083 MTN - Machine Delay Idle Time
//
vars

begin
	self.idleTimeAllowable := _idleTime;
	self.idleTimeUntilAlert := _idleTimeAlert;
	self.idleTimeRecordInHistory := _idleHistory;
	self.delayTimeUntilAlert := _delayTimeUntilAlert; //03.10.2022 navds21 TFS 50083
	self.delayTimeAllowable := _delayTimeAllowable; //03.10.2022 navds21 TFS 50083
	
epilog

end;</source>
        <Parameter name="_idleTime" type="Integer"/>
        <Parameter name="_idleTimeAlert" type="Integer"/>
        <Parameter name="_delayTimeAllowable" type="Integer"/>
        <Parameter name="_delayTimeUntilAlert" type="Integer"/>
        <Parameter name="_idleHistory" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setVehicleAppDetails" id="3f1e6027-e5bf-4fea-b0b1-dd90dcf320dd">
        <updating/>
        <source>setVehicleAppDetails(	_messagePoll : Integer;
						_listPoll	 : Integer;
						_primaryTaskFields : EntTableView;
						_secondaryTaskFields  : EntTableView;
						_primaryCargoFields : EntTableView;
						_secondaryCargoFields : EntTableView;
						_primaryDirectorFields : EntTableView;
						_secondaryDirectorFields : EntTableView;
						_autoplanDriverInitiatedMove : Boolean;
						_driverDismissMessages : Boolean;
						_locationDisplayFormat : Integer;
						_allowColumnFiltering : Boolean) updating;			// TFS 51286
/*

Date		Who		Reason
20 Jun 2017	cnwer1	Initial creation TFS 4829 - Vehicle Apps
15 Jul 2021	navdap1	TFS 51286 STWR Vehicle App Notification Message
01 Nov 2021 jlier1 	TFS 52160 
21 Mar 2023	jlika1	TFS 57126	CUX - Make VMT filtering configurable per RT Config
*/

vars

begin
	self.messagePollingInterval:=_messagePoll;
	self.listPollingInterval:=_listPoll;
	self.myPrimaryTaskFields:=_primaryTaskFields;
	self.mySecondaryTaskFields:=_secondaryTaskFields;
	self.myPrimaryCargoFields :=_primaryCargoFields;
	self.mySecondaryCargoFields :=_secondaryCargoFields;
	self.myPrimaryDirectorFields:=_primaryDirectorFields;
	self.mySecondaryDirectorFields:=_secondaryDirectorFields;
	self.autoplanDriverInitiatedMove := _autoplanDriverInitiatedMove;
	self.driverDismissMessages := _driverDismissMessages;				// TFS 51286
	self.locationDisplayFormat := _locationDisplayFormat;
	self.allowColumnFiltering := _allowColumnFiltering;
epilog

end;</source>
        <Parameter name="_messagePoll" type="Integer"/>
        <Parameter name="_listPoll" type="Integer"/>
        <Parameter name="_primaryTaskFields" type="EntTableView"/>
        <Parameter name="_secondaryTaskFields" type="EntTableView"/>
        <Parameter name="_primaryCargoFields" type="EntTableView"/>
        <Parameter name="_secondaryCargoFields" type="EntTableView"/>
        <Parameter name="_primaryDirectorFields" type="EntTableView"/>
        <Parameter name="_secondaryDirectorFields" type="EntTableView"/>
        <Parameter name="_autoplanDriverInitiatedMove" type="Boolean"/>
        <Parameter name="_driverDismissMessages" type="Boolean"/>
        <Parameter name="_locationDisplayFormat" type="Integer"/>
        <Parameter name="_allowColumnFiltering" type="Boolean"/>
    </JadeMethod>
