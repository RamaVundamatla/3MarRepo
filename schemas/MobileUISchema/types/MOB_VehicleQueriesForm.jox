        <source>btnRun_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 June 2010	cnwer1	Initial creation

*/

vars

begin

	if self.btnRun.caption = app.getErrorString(Run_Query) then
		self.runQuery();
	elseif self.btnRun.caption = app.getErrorString(Back) then
		self.tblQueryResults.visible:=false;
		self.btnRun.caption :=app.getErrorString(Run_Query);
	endif;
epilog

end;</source>
