<Class name="CMIF_SelectionControl" id="0672100c-8a23-4028-953f-ae2bcfdabc84">
    <superclass name="CMIF_Object"/>
    <transient/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <text>Used to control the multicall selection process.</text>
    <PrimAttribute name="abortSearch" id="04e154eb-6d31-4c6e-879d-5296ad681c85">
        <embedded/>
        <type name="Boolean"/>
        <text>Set if the search is to be aborted</text>
    </PrimAttribute>
    <PrimAttribute name="destroySearchSet" id="546df03a-c04a-4560-8e07-1760ffc3b36a">
        <embedded/>
        <type name="Boolean"/>
        <text>Set if the search set is to be destroyed</text>
    </PrimAttribute>
    <PrimAttribute name="more" id="fe061a3f-e2d5-43b8-a45f-8b6a282acbe4">
        <embedded/>
        <type name="Boolean"/>
        <text>Set if there are more candidates to try</text>
    </PrimAttribute>
    <PrimAttribute name="pExpTree" id="6f8096d3-8126-4c1c-b4a8-dae873ab46fa">
        <embedded/>
        <type name="Integer"/>
        <text>ExpressionTree *, the expression tree for multiple calls</text>
    </PrimAttribute>
    <PrimAttribute name="pSearchSet" id="d3f58bbb-aed4-4bc8-9828-60d1f2809824">
        <embedded/>
        <type name="Integer"/>
        <text>DskObjectSet *, if not NULL the search set to check</text>
    </PrimAttribute>
    <PrimAttribute name="pSelectSet" id="93df9ffd-0a32-4d5a-9cc9-60da18a2737a">
        <embedded/>
        <type name="Integer"/>
        <text>DskObjectSet *, if not NULL append the new selection to this set</text>
    </PrimAttribute>
    <PrimAttribute name="satisfiedByPaths" id="9d5ee744-e65b-4c33-9e57-0ffddb72675d">
        <embedded/>
        <type name="Boolean"/>
        <text>Set if the selection criteria satisfies one or more optimisation paths</text>
    </PrimAttribute>
    <PrimAttribute name="searchSetIndex" id="6de9d252-34f7-4cb2-9b54-a0dc6139b348">
        <embedded/>
        <type name="Integer"/>
        <text>0 based index into the search set</text>
    </PrimAttribute>
    <PrimAttribute name="searchSetLimit" id="2bb0797a-74ac-4d29-aa7f-4e0b07db5bc6">
        <embedded/>
        <type name="Integer"/>
        <text>Maximum number to search</text>
    </PrimAttribute>
    <PrimAttribute name="selectSetLimit" id="fdaaea14-048b-4c5e-910d-e4088f3b49e2">
        <embedded/>
        <type name="Integer"/>
        <text>Maximum number to retrieve</text>
    </PrimAttribute>
    <PrimAttribute name="useDefaultSet" id="07b6236d-1fb6-48d4-92b9-3d18deed9273">
        <embedded/>
        <type name="Boolean"/>
        <text>if no optimisation path is found for the selection criteria then use the default path (slow!)</text>
    </PrimAttribute>
</Class>
