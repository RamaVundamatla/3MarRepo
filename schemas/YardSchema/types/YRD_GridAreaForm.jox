    <JadeMethod name="doMnuGridPlanDischargeClick" id="215f5f6b-c349-4a71-b80a-7d6417f413f7">
        <updating/>
        <source>doMnuGridPlanDischargeClick(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
