    <JadeMethod name="clickFile" id="7a4ce687-4f91-4c8c-95e3-2e9f98780665">
        <source>clickFile();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 May 2011	cnwndl1	Initial creation

*/

vars

	outputText : String;
	line : String;
	outFile : File;
	fileLine : String;
	openDialog : CMDFileOpen;
	
	pos : Integer;

begin

	create openDialog transient;
	openDialog.filter := 'All Files|*.txt';
	openDialog.filterIndex := 1;
	
	if openDialog.open() = 0 then
		
		create outFile transient;
		outFile.mode := File.Mode_Output;
		outFile.allowCreate := true;
		outFile.openOutput(openDialog.fileName);
		
		app.mousePointer := MP_HOURGLASS;
		
		outputText := self.txtOutput.text;
		
		pos := outputText.pos(CrLf,1);
		while pos &gt; 0 do
			line := outputText[1:pos - 1];			
			outFile.writeLine( line );
			outputText := outputText[pos + 2:end];
			pos := outputText.pos(CrLf,1);
			if outputText = CrLf then
				break;
			endif;
			if outputText.length &lt; 2 then
				break;
			endif;
		endwhile;
		
		line := outputText;
		outFile.writeLine( line );
		
		outFile.close;
		
		app.msgBox("File '" &amp; outFile.fileName &amp; "' created",app.getErrorString(Complete),MsgBox_OK_Only);
	endif;
	
	app.mousePointer := MP_DEFAULT;

epilog

	delete outFile;

end;</source>
    </JadeMethod>
    <JadeMethod name="clickFind" id="adb5a063-f286-48dd-81a2-18291d0bc8dd">
        <source>clickFind();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 May 2011	cnwndl1	Initial creation

*/

vars

	startPos : Integer;
	searchText : String;
	pos : Integer;

begin

	searchText := txtFind.text.toUpper.trimBlanks;
	
	startPos := txtOutput.selStart + txtOutput.selLength;
	if startPos = txtOutput.text.length then
		startPos := 1;
	endif;
	pos := txtOutput.text.toUpper.pos(searchText,startPos);
	
	if pos &gt; 0 then
		txtOutput.selStart := pos - 1;
		txtOutput.selLength := searchText.length;
	else
		txtOutput.selStart := txtOutput.text.length;
		txtOutput.selLength := 0;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="clickPrint" id="ca1cf3de-1446-4714-aaf9-8844682ae638">
        <source>clickPrint();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 May 2011	cnwndl1	Initial creation

*/

vars

	outputText : String;
	pos : Integer;
	line : String;
	longestLine : Integer;
	printerName : String;

begin
	
	app.mousePointer := MP_HOURGLASS;
	
	self.tblPrint.columns := 1;
	self.tblPrint.rows := 2;
	self.tblPrint.fixedRows := 2;
	
	self.tblPrint.setCellText(1,1,"Logging output");
	self.tblPrint.accessCell(1,1).alignment := Table.Alignment_Center_Middle;
	
	self.tblPrint.addItem(" ");
	
	outputText := self.txtOutput.text;
	
	pos := outputText.pos(CrLf,1);
	while pos &gt; 0 do
		line := outputText[1:pos - 1];
		if line.length &gt; longestLine then
			longestLine := line.length;
		endif;
		self.tblPrint.addItem(line);
		outputText := outputText[pos + 2:end];
		pos := outputText.pos(CrLf,1);
		if outputText = CrLf then
			break;
		endif;
		if outputText.length &lt; 2 then
			break;
		endif;
	endwhile;
	
	line := outputText;
	if line.length &gt; longestLine then
		longestLine := line.length;
	endif;
	self.tblPrint.addItem(line);
		
	app.printer.setPrinter(printerName);
	self.doPrintOutTable(self.tblPrint, self.caption[1:100], true, true, true, longestLine &lt; 120);
	
epilog

	app.printer.close;
	app.mousePointer := MP_DEFAULT;

end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="ac6a38a3-5f66-4739-bfa6-7d7cb5425d83">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 May 2011	cnwndl1	Initial creation
21 March 2023 navvt20 Bug 57109: MTN - JMTSupportUser - Errors when opening System Logging View
*/

vars

begin

	//self.permissionView	:= PmAdmSysAdminSpec; // 21 March 2023 navvt20 TFS 57109
	self.permissionView	:= PmAdmSysAdminSpecView; // 21 March 2023 navvt20 TFS 57109
	self.permissionMaint := PmAdmSysAdminSpec;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doInspectFromString" id="be79fee0-8005-43e8-9c8f-015629f8f807">
        <source>doInspectFromString();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 August 2011	cnwndl1	Initial creation

*/

vars

	str : String;
	msg : String;
	pos : Integer;
	obj : Object;
	invalidObject : Boolean;

begin

	on Exception do app.handleDeletedObject(exception, obj, invalidObject);

	str := txtOutput.text[ txtOutput.selStart + 1 : txtOutput.selLength ];
	
	if str = null then
		msg :=  "No text selected in 'Output' to look for an OID within!";
		app.msgBox( msg, "Error", MsgBox_OK_Only );
		return;
	endif; 
	
	pos := str.pos("/",1);
	if pos &gt; 0 and pos &lt;= str.length then
		str := str[ pos + 1 : end ];
	endif;
	
	pos := str.pos("&gt;",1);
	
	if pos &gt; 0 and pos &lt;= str.length then
		str := str[ 1 : pos - 1 ].trimBlanks;
	endif;
	
	obj := str.asOid.Object;
	
	if obj &lt;&gt; null then
		obj.inspectModal();
		if invalidObject then
			msg :=  "'" &amp; str &amp; "' unable to be resolved to a valid object ( May have been deleted ).";
			app.msgBox( msg, "Error", MsgBox_OK_Only );
		endif;
		return;
	endif;
	
	msg := "'" &amp; str.trimBlanks &amp; "' can not be resolved to a valid object.";
	app.msgBox( msg, "Error", MsgBox_OK_Only );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="4740c68c-3c89-4bf0-9908-0f2d804154cd">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2011	cnwndl1	Initial creation	Par 27438

*/

vars

begin

	inheritMethod();
	
	self.grpMethods.left := 5;
	self.grpMethods.top := 5;
	self.grpMethods.width := self.clientWidth - 10;
	self.grpMethods.height := self.clientHeight - 10;
	
	self.txtOutput.width := self.grpMethods.width - ( self.txtOutput.left * 2 );
	
	self.txtOutput.height := self.grpMethods.height - ( self.txtOutput.top + 30 );
	
	self.btnClose.top := self.txtOutput.top + self.txtOutput.height + 5;
	self.btnClose.left := self.txtOutput.width - ( self.btnClose.width - self.txtOutput.left );
	self.btnInspect.top := self.btnClose.top;
	self.btnInspect.left := ( self.btnClose.left - self.btnClose.width ) - 5;
	self.btnLogLevel.top := self.btnClose.top;
	self.btnLogLevel.left := ( self.btnInspect.left - self.btnLogLevel.width ) - 5;
	self.lblCurrent.top := self.btnClose.top;
	self.lblCurrent.left := ( self.btnLogLevel.left - self.lblCurrent.width ) - 5;
	
	
	self.btnClear.top := self.btnClose.top;
	self.btnPrint.top := self.btnClose.top;
	self.btnFile.top := self.btnClose.top;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setButtons" id="d422a589-7a33-4513-a854-b11e793023fd">
        <source>setButtons();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 May 2011	cnwndl1	Initial creation

*/

vars

begin

	self.btnPrint.enabled := false;
	self.btnFile.enabled := false;
	self.btnClear.enabled := false;
	self.btnFind.enabled := false;
	
	if txtOutput.text.trimBlanks &lt;&gt; null then
		self.btnPrint.enabled := true;
		self.btnFile.enabled := true;
		self.btnClear.enabled := true;
		self.btnFind.enabled := self.txtFind.text.trimBlanks &lt;&gt; null;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setCurrentCapt" id="65830386-50ba-4f2a-a48e-89910427b066">
        <source>setCurrentCapt( index : Integer );
/*

Purpose:			

