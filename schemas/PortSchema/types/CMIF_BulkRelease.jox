    <JadeMethod name="createReserves" id="42a3ec5a-57b1-4856-910f-78374c7e966a">
        <source>createReserves(_pxyRelease: CM_BulkRelease input);

// 18/09/2012	cnwcs5	par 30390 - change of signature for CM_ReserveSelection setProxy
//09 Sep 2014	cnwrs1	CCMS 2351 att Sequence to Release request 
//19/07/2022	navtnr20	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level
//28 June 2023 navmv20 CR 58410 Task 58411: UI - Cargo Review - Release Request		
// 6/12/2023	navcs2	ChangeRequest 57537: EUP | Release Request By Type - with Weight
														
vars
	pxyReserve	: CM_ReserveSelection;
begin
	
	if self.type = BR_TYPE_PACKING then
		// only old release request screen coming through here, so cludge pack
		// attributes into new model
		create pxyReserve transient;
		
		pxyReserve.setProxy(CM_ReserveSelection.PackType_Child,
										null,
										null,
										null,
										null,
										null,  //cnwrd1 par 20810 9/10/9
										self.packProduct,
										null,
										self.packQuantity,
										null,
										false,
										false,
										false,
										null,
										null,
										null,
										null,
										null,
										null,
										null,
										null,
										null,
										null,
										null,
										null,
										null,
										null,
										null,
										null,
										null,
										false,
										null,
										null,null,null,null,null,false,false,null,null,null,null,null,null,null,null,
										null, // ### TFS 53953 11July2022 NAVPW1
										null,null,  //12-07-2022 navtnr20 53974
										null, //28/06/2023 navmv20 CR 58410 Task 58411
										false, // 6/12/2023 navcs2 ChangeRequest 57537
										false,	//19/02/2023	navkc1 CR 60078 Task 62450
										null,	//24/04/2025	navrv30	MTN 34319
										null);
										
		pxyReserve.setMyHeader(_pxyRelease);
	endif;
end;</source>
        <Parameter name="_pxyRelease" type="CM_BulkRelease" usage="input"/>
    </JadeMethod>
