    <JadeMethod name="getYear" id="9db829bf-a09b-4413-994d-722a20fee21f">
        <updating/>
        <source>getYear() : Integer updating;
/*

Date		    Who			Reason
01 November 2010	cnwas3	  Initial creation

*/

vars
	newYear : Integer;
begin
	newYear := self.myYearTextBox.text.asIntegerJMT();
	if newYear &lt;&gt; self.selectedDate.year and newYear &lt;= maximumYear then
		self.setYear(newYear);
	endif;
	return self.selectedDate.year;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getYearAsString" id="dad62764-3207-4ef3-922a-801835d488da">
