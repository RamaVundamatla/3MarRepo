    <JadeMethod name="btnLogLevel_click" id="a0b414e3-4a55-4fa2-b00b-07a49ab3408e">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnLogLevel_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 November 2019	jlgndl1	Initial creation	TFS 47053

*/

vars

	processObj : Process;
	form : CMUI_SetLoggingLevel;
	result : Integer;

begin

	processObj := process;
	
	if processObj &lt;&gt; null then
		create form transient;
		form.setProcessObject( processObj );
		form.showModal();
		
		result := form.modalResult;
	
		if result &gt;= LogINFO and result &lt;= LogTRACE then
			processObj.causeEvent( EVENT_APP_LOG_LEVEL, true, result );
		endif;
	endif;
	
epilog

	delete form;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
