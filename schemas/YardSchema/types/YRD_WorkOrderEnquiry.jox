    <JadeMethod name="doShowCargo" id="8932ab98-61f2-4f9b-9709-cdd238160210">
        <source>doShowCargo();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 January 2010	cnwrd1	Initial creation

*/

vars
	realWorkOrder 	: CM_WorkOrder;
	task 			: CM_WorkOrderDtl;
	selObj			: Object;
	cargoEnquiry 	: CM_ContainerEnqForm;
	tiColl			: CM_TISet;
begin
	selObj := self.tblData.allSelectedObjects.first;
	
	if self.isEnqType_WorkOrder then
	
		if selObj = null then
			app.msgBox(app.getErrorString(Please_select_work_order), app.getErrorString(No_Work_order_selected), MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		
		if selObj.isKindOf(CM_WorkOrder) then
			realWorkOrder := selObj.CM_WorkOrder;
		else
			app.raiseUnexpectedProgramError(self.class.name, method.name, "unexpected class type");
		endif;
		
	elseif self.isEnqType_Task() then
		
		if selObj = null then
			app.msgBox(app.getErrorString(Please_select_task), app.getErrorString(No_Task_selected), MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		
		if selObj.isKindOf(CM_WorkOrderDtl) then
			task := selObj.CM_WorkOrderDtl;
		else
			app.raiseUnexpectedProgramError(self.class.name, method.name, "unexpected class type");
		endif;
		
		realWorkOrder := task.getMyParent;
		if realWorkOrder = null then
			return;
		endif;
	
	endif;


	create tiColl transient;
	 realWorkOrder.getAllTIs(tiColl);
	
	cargoEnquiry := app.loadForm(CM_ContainerEnqForm, CMUI_Assistant, false, false, false, realWorkOrder.myTerminal , null).CM_ContainerEnqForm;	
	cargoEnquiry.setFilterCargoTypeId (true);
		
	if cargoEnquiry = null then
		return;
	endif;
	
	cargoEnquiry.show(); 
	cargoEnquiry.displaySelectorResults(tiColl, null);
	

epilog
	delete tiColl;

	app.mousePointer := MousePointer_Default;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doShowCargoEnquiry" id="bc6febe0-fe70-4d32-9276-98b45e37c6c0">
        <source>doShowCargoEnquiry(_woTask : CM_WorkOrderDtl);
/*

Purpose:			TFS 39349

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2018	jlgab1	Initial creation
30 Aug 2022 namva1	Bug 54696: MTN - Work Orders - Double clicking on the Packing Cargo on the Extra Info table is taking to Parent cargo
08 Feb 2023 navma1  ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
*/

vars
	tis 		: CM_TISet;
	tisa		: CM_TIArray;
	selObj 		: Object;
	workOrder 	: CM_WorkOrder;

begin

	create tis transient;
	
	// 30.08.2022 navma1 #54696
	if _woTask &lt;&gt; null then
		if _woTask.isKindOf(CM_WodPack) then
			_woTask.CM_WodPack.allPackingTIs.copyNoDuplicates(tis,false);
		endif;
	else
	
		selObj := self.tblData.allSelectedObjects.first;
		if selObj = null then
			app.msgBox(app.getErrorString(Please_Select_An_Item_Fiirst),app.getErrorString(Problem),MsgBox_OK_Only);
			return;
		endif;
		
		//08.02.2023 navma1 #56457:[56458]
		if selObj.isKindOf(CM_WorkOrderTIDtl) then
			selObj.CM_WorkOrderTIDtl.allSelectedTIs.copy(tis);
		elseif selObj.isKindOf(CM_WorkOrderTI) then
			workOrder := selObj.CM_WorkOrderTI;
			workOrder.getAllTIs(tis);
		endif;		
	endif;
	
	if tis.isEmpty() then
		return;
	endif;	
	
	create tisa transient;
	tis.copy(tisa);
	
	self.myAssistant.showCargoEnquiryForTIs(tisa.first, tisa,self.myMasterMenuAction, false);


epilog
	delete tis;
	delete tisa;
end;</source>
        <Parameter name="_woTask" type="CM_WorkOrderDtl"/>
    </JadeMethod>
    <JadeMethod name="doShowCashReceipt" id="62f047df-5508-4f3d-a7f7-63b80942b872">
        <source>doShowCashReceipt(_cashreceipt : CM_CashReceipt);
/*

Purpose:			TFS 39518

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2018	jlgab1	Initial creation

*/

vars

	form : Form;
	debtorNode : CM_DebtorNode;
	debtor : CM_Debtor;

	sch : Schema;
	formClass, assistClass : Class;
	mth : Method;
	who : String;
	whn : TimeStamp;
	selObj 		: Object;
	workOrder 	: CM_WorkOrder;
	controller : CMIF_ProformaWOController;
begin

		
	sch := rootSchema.getSchema("InvoiceSchema");
	formClass := sch.getClass("INV_CashDrTransactionEnquiry");
	assistClass := sch.getClass("INV_Assistant");

	form := app.getForm(formClass.name);
	if form = null then
		form := app.loadForm(formClass, assistClass, false, false, false, self.myTerminal, null);
	endif;
	
	if form &lt;&gt; null then
		form.setPropertyValue("myQueryReceipt",_cashreceipt);
		form.show;
	endif;

epilog

end;</source>
        <Parameter name="_cashreceipt" type="CM_CashReceipt"/>
    </JadeMethod>
    <JadeMethod name="doShowSearcherClick" id="de0ecbb5-cdc5-4ad9-b02c-ba4c4e1cec7c">
        <updating/>
        <source>doShowSearcherClick() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 Jan 2010	cnwrd1	Initial creation
05 Oct 2019	cnwma1	Bug 46906: PEL1 - Urgent Error Max Table Row Work Order
*/

vars

begin
	inheritMethod();
	self.fldQuery.topSheet := self.shtQuery1;  //07.10.2019 cnwma1 # 46906
	self.cmbOrganisation.setFocus();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doShowTasks" id="a27457c0-03ac-4c16-ad10-92fc4b1c2841">
        <source>doShowTasks();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11/11/2009	cnwrd1	Initial creation
22/05/2018	jlgdap1	TFS 38560 PEL1 Voyage Work Orders
26/07/2022	navcs2	ChangeRequest 54156: MTN - Work Order New UI Release
24/08/2022  namva1	ChangeRequest 54644: MTN - Work Order Refactor - IsSpecial
13/09/2022  navma1	ChangeRequest 54645: MTN - Work Order Refactor (Additional Changes and remove IsSpecial)
*/


vars
	taskForm 		: YRD_TaskJobTasks;
	workOrder,
	realWorkOrder 	: CM_WorkOrder;
	task 			: CM_WorkOrderDtl;
	selObj			: Object;
	voyage			: CM_Voyage;				
	showNewScreen   : Boolean;
begin
	
	// 24.08.2022 namva1 #54644
	if app.isSpecial then
		showNewScreen := true;
	endif;
	showNewScreen := true;				//13.09.2022 navma1 #54645
	
	// 24.08.2022 namva1 #54644
	if showNewScreen then
		self.showNewWorkOrder();
		return;
	endif;
	
	selObj := self.tblData.allSelectedObjects.first;
	
	if self.isEnqType_WorkOrder then
	
		if selObj = null then
			app.msgBox(app.getErrorString(Please_select_work_order), app.getErrorString(No_Work_order_selected), MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		
		if selObj.isKindOf(CM_WorkOrder) then
			realWorkOrder := selObj.CM_WorkOrder;
		else
			app.raiseUnexpectedProgramError(self.class.name, method.name, "unexpected class type");
		endif;
		
		workOrder := app.createUpdateProxy(realWorkOrder).CM_WorkOrder; //create proxy wo
		
	elseif self.isEnqType_Task() then
		
			if selObj = null then
			app.msgBox(app.getErrorString(Please_select_task), app.getErrorString(No_Task_selected), MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		
		if selObj.isKindOf(CM_WorkOrderDtl) then
			task := selObj.CM_WorkOrderDtl;
		else
			app.raiseUnexpectedProgramError(self.class.name, method.name, "unexpected class type");
		endif;
		
		workOrder := app.createUpdateProxy(task.myParent).CM_WorkOrder; //create proxy wo
	
	endif;
	
	
	app.mousePointer := MousePointer_HourGlass;
	if workOrder &lt;&gt; null and workOrder.isVoyageWorkOrder then				// TFS 38560
		voyage := workOrder.CM_WorkOrderVoyage.getMyVoyageObject();			// TFS 38560
	endif;																	// TFS 38560
	
	taskForm := app.getForm(YRD_TaskJobTasks.name).YRD_TaskJobTasks;
	if taskForm = null then
		taskForm := app.loadForm(YRD_TaskJobTasks, YRD_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).YRD_TaskJobTasks;
	endif;
	
	if taskForm = null then
		return;
	endif;
	
	taskForm.centreWindow;
	taskForm.setMyTerminal(self.myTerminal);
	taskForm.initialise( self, workOrder, YRD_TaskJobTasks.Mode_Update, workOrder.getProxyTask(task), workOrder.getWorkOrderMode, voyage );	// TFS 38560
	taskForm.setDeleteProxy(true);
	taskForm.show;
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doShowTrain" id="056bdbcd-51f5-49b0-88da-d03b6c2d593f">
        <source>doShowTrain(_obj : CM_Train);
