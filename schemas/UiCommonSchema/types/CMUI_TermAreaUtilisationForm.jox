vars
begin
	delete self.myQueryAgent;
	delete self.mySummaryLine;	//24 Oct 2013	NDL	Par 32079
	delete self.myBSSummary;
	delete self.myBulkSummary;
	delete self.myGCSummary;
	delete self.myGridSummary;
	delete self.myRoroSummary;

	inheritMethod();
	
end;</source>
    </JadeMethod>
</GUIClass>
