    <JadeMethod name="selectPictures" id="df2a0c44-73b0-47fc-aa44-24d09ed6da5b">
        <updating/>
        <source>selectPictures(_use12Bit, 
				_use16Bit,
				_use24Bit,
				_useOther : Boolean) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     10 January 2003		cnwth2	
//
// Purpose:     Returns false if user cancels
//			 
// ----------   ----------  --------------------------------------------------
vars
	picturePicker			: CMUI_PicturePicker;
	menuEntity				: CM_MenuEntity;
begin
	
	menuEntity := self.listObject.CM_MenuEntity;
	
	create picturePicker transient;
	
	if (menuEntity.isKindOf(CM_MenuUserDtl)) or (menuEntity.isKindOf(CM_MenuToolbar)) then
		picturePicker.isForHeader := false;
	else
		picturePicker.isForHeader := true;
	endif;
	if menuEntity.isKindOf(CM_MenuToolbar) then
		picturePicker.heading 		:= menuEntity.CM_MenuToolbar.heading;
	else
		picturePicker.txtHeading.visible := false;
		picturePicker.lblHeading.visible := false;
	endif;
	picturePicker.openPicture	:= menuEntity.pictureStringButton;
	picturePicker.closePicture	:= menuEntity.pictureStringButtonDown;
	picturePicker.leafPicture	:= menuEntity.pictureStringIcon;
	
	picturePicker.use12Bit := _use12Bit;
	picturePicker.use16Bit := _use16Bit;
	picturePicker.use24Bit := _use24Bit;
	picturePicker.useOther := _useOther;
	
	picturePicker.showModal;
	if picturePicker.modalResult &lt;&gt; IDOK then
		return false;
	endif;
	
	beginTransaction;
	menuEntity.setPictures(picturePicker.openPicture,
							picturePicker.closePicture,
							picturePicker.leafPicture);
	commitTransaction;
	self.doWindowEvents(0);
	self.displayTree(true, null);
	return true;
	
epilog
	delete picturePicker;

end;</source>
        <Parameter name="_use12Bit" type="Boolean"/>
        <Parameter name="_use16Bit" type="Boolean"/>
        <Parameter name="_use24Bit" type="Boolean"/>
        <Parameter name="_useOther" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setExpandedObjects" id="b7b37fb1-a150-48b0-bcfc-81ab5a8de115">
        <source>setExpandedObjects();
// ---------------------------------------------------------------------------
// Created:     09 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	idx2	: Integer;
	obj		: Object;
begin

	foreach obj in self.allExpandedObjects do
		idx2 := self.findObject(obj);
		if idx2 &gt; 1 then
			self.itemExpanded[idx2] := true;
			self.itemPicture[idx2] := obj.CM_MenuEntity.pictureButton; //self.itemObject[idx2].CM_MenuEntity.getPictureButton;
 		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="swap" id="9763f006-fcfa-4940-9257-ce77874e8e66">
        <updating/>
        <source>swap(_action1, _action2 : CMUI_MenuAction) updating;
// ---------------------------------------------------------------------------
// Created:     20 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx1,
	idx2	: Integer;

begin

	idx1 := self.findObject(_action1);
	idx2 := self.findObject(_action2);
	
	if idx1 &lt;= 0 or idx2 &lt;= 0 then
		// One or other of the objects where not found
		app.raiseUnexpectedProgramError(class.name, method.name, 'Object (' &amp; _action1.String &amp; ') or (' &amp; _action2.String &amp; ') not found');
		return;
	endif;
	
	self.itemObject[idx1] := _action2;
	self.itemText[idx1] := _action2.heading;

	self.itemObject[idx2] := _action1;
	self.itemText[idx2] := _action1.heading;

	// check if either item was selected and swap selected status
	if self.listIndex = idx1 then
		self.itemSelected[idx1] := false;
		self.itemSelected[idx2] := true;
		self.listIndex := idx2;
	elseif self.listIndex = idx2 then
		self.itemSelected[idx2] := false;
		self.itemSelected[idx1] := true;
		self.listIndex := idx1;
	endif;
	
end;</source>
        <Parameter name="_action1" type="CMUI_MenuAction"/>
        <Parameter name="_action2" type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="userNotify" id="b0d37a38-4ff9-4b2f-93f4-0c1679cdb35e">
        <updating/>
        <source>userNotify(listbox: ListBox input; eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// ---------------------------------------------------------------------------
// Created:     07 November 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	menuEnt	: CM_MenuEntity;
	idx,idx2		: Integer;
	invalid : Boolean;
begin

	if eventType = CMUI_NavObject_Refresh then
		self.displayTree(true, null);
		return;
	endif;

	if userInfo &lt;&gt; null and (not userInfo.isKindOf(CM_MenuEntity)) then
		return;
	endif;
	
	if eventType = CMUI_NavObject_Add then
		if userInfo &lt;&gt; null then
			menuEnt := userInfo.CM_MenuEntity;

			on Exception do app.handleDeletedObject(exception,menuEnt,invalid);
			menuEnt.creationTime();  //cause exception if invalid
			
			if invalid then
				// 37017 this can be invalid because the form has been created and then unloaded and the unload deletes this before the notification gets here
				//		so just exit without any error
				////app.raiseUnexpectedProgramError(class.name, method.name, 'Error loading form');
				return;
			endif;
			
			idx2 := self.findObject(menuEnt);
			if idx2 &gt; 0 then 
			// is somewhere in here already so dont add. (added specifically for Par 9535) Other
			// Code added to fix this par is on SOP_TerminalConfig::setupForm 
				return;
			endif;
	
			idx := self.findObject(menuEnt.myParent);

			if idx &gt; 0 then
				idx := idx + 1;
				self.addItemObjectAt(menuEnt, idx);

			else
				//can't find what I'm supposed to go under, so have to bail
				//on this whole idea really
				return;
			endif;

			// select the newly added item
			if self.listIndex &gt; 0 then
				self.itemSelected[self.listIndex] := false;
			endif;
			
			self.itemSelected[idx] := true;
			self.listIndex := idx;
		endif;
		return;
	endif;

	if eventType = CMUI_NavObject_Delete then	
		if userInfo &lt;&gt; null then

			menuEnt := userInfo.CM_MenuEntity;
			idx := self.findObject(menuEnt);
			if idx &gt; 0 then
				self.removeItem(idx);
			endif;
		endif;
		return;
	endif;

	if eventType = CMUI_NavObject_Select then
		if userInfo &lt;&gt; null then
			menuEnt := userInfo.CM_MenuEntity;
			idx := self.findObject(menuEnt);
			if idx &gt; 0 then
				if self.listIndex &gt; 0 then
					self.itemSelected[self.listIndex] := false;
				endif;
				self.itemSelected[idx] := true;
				self.itemExpanded[idx] := true;
				self.listIndex := idx;
			else
				self.listIndex := -1;
			endif;
		else
			self.listIndex := -1;
		endif;
		return;
	endif;


	if eventType = CMUI_NavObject_Update then
		if userInfo &lt;&gt; null then
			menuEnt := userInfo.CM_MenuEntity;
			on Exception do app.handleDeletedObject(exception,menuEnt,invalid);
			menuEnt.creationTime();  //cause exception if invalid
			
			if invalid then			
			//if (not app.isValidObject(menuEnt)) then
				return;
			endif;
			idx := self.findObject(menuEnt);
			if idx &gt; 0 then
				self.itemText[idx] := menuEnt.getHeading;
				self.itemPicture[idx] := menuEnt.pictureIcon;	//getPictureIcon;
			endif;
		endif;
		return;
	endif;

	inheritMethod(listbox, eventType, theObject, eventTag, userInfo);

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
