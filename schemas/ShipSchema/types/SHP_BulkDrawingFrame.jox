    <JadeMethod name="getParentFormMode" id="883b17b6-ccd7-435a-88c2-8e3ab17c8a9e">
        <source>getParentFormMode() : Integer;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/02/2016	cnwdap1		Initial creation PAR #36766 Bulk Graphical Representation
//
vars
	theForm : Form;
	mode : Integer;

begin
	theForm := self.form;
	
	if theForm &lt;&gt; null and theForm.isKindOf(SHP_BulkVoyagePlanningForm) then
		if theForm.SHP_BulkVoyagePlanningForm.displayMode = ShpDisplayMode_Actual then	
			mode := ShpDisplayMode_Actual;
		elseif theForm.SHP_BulkVoyagePlanningForm.displayMode = ShpDisplayMode_Queued then	
			mode := ShpDisplayMode_Queued;
		elseif theForm.SHP_BulkVoyagePlanningForm.displayMode = ShpDisplayMode_Proposed then	
			//proposed or colour code load or colour code discharge
			mode := ShpDisplayMode_Proposed;
		else
			mode := ShpDisplayMode_Actual;
		endif;
	else
		mode := ShpDisplayMode_Actual;	// default value.
	endif;
	
	return mode;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getPointsForObject" id="470f78cd-6692-437b-a0c6-b5ec21b3e31d">
        <source>getPointsForObject(_obj: Object; _x1: Integer output; _y1: Integer output; _x2: Integer output; _y2: Integer output): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	iter : Iterator;
	obj : Object;	
	found : Boolean;

begin
	if _obj = null then
		return false;
	endif;

	iter := self.allObjectsOnDeck.createIterator;
	while iter.next(obj) do
		if obj = _obj then
			found := true;
			break;
		endif;
	endwhile;
	
	if (not found) then
		iter := self.allObjectsUnderDeck.createIterator;
		while iter.next(obj) do
			if obj = _obj then
				found := true;
				break;
			endif;
		endwhile;
	endif;
	//else
	//	app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '  unhandled object ' &amp; _obj.String);
	//endif;

	if found then
		iter.getCollection.ExtKeyDictionary.getIteratorKeys(_x1, _y1, _x2, _y2, iter);
	endif;

	return found;
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_x1" type="Integer" usage="output"/>
        <Parameter name="_y1" type="Integer" usage="output"/>
        <Parameter name="_x2" type="Integer" usage="output"/>
        <Parameter name="_y2" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getUnderDeckOffSet" id="62675bf5-f96e-4316-bd73-b3b7f7b5503e">
        <source>getUnderDeckOffSet() : Integer;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars

begin
	return self.myBulkDrawingController.yUnderDeckPos;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleMouseUp" id="9b378396-877c-4d51-90f2-b44d659c210a">
        <updating/>
        <source>handleMouseUp(_obj : Object; _button : Integer; _shift : Integer; _x : Real; _y : Real) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	theLCs : CM_LCArray;
	controller : SHP_BulkDrawingController;
	gcController : CM_GeneralCargoController;
	isSelect,
	isSelectAlt,
	isControlKey,
	isBlock : Boolean;
	isOnDeck : Boolean;
	startObj : Object;
	
begin
	if _obj = null then
		return;
	endif;

	controller := self.myBulkDrawingController;
	if controller = null then
		app.raiseCMException1(MethodWithNullParam, 'bulkDrawingController', null, null);
		return;
	endif;

	if (not controller.isSelectObjectsEnabled) then
		return;
	endif;
	
	if (not _shift.isShiftKeyPressed) and  
	   (not _shift.isControlKeyPressed) and 
	   (not _shift.isAltKeyPressed) then // NO SHIFT, ALT or CONTROL

		if _button = Button.MouseButton_Left then
			// clear existing selection
			controller.clearAllSelectedObjects();
			isSelect := true;
		endif;

	elseif _shift.isShiftKeyPressed then // SHIFT
		if _shift.isAltKeyPressed then // ALT
			isSelectAlt := true;
			isBlock := true;
		else
			isSelect := true;
			isBlock := true;
		endif;

	elseif _shift.isControlKeyPressed then // CONTROL
		isControlKey := true;
		if _shift.isAltKeyPressed then // ALT
			isSelectAlt := true;
		else
			isSelect := true;
		endif;

	elseif _shift.isAltKeyPressed then // ALT
		if _button = Button.MouseButton_Left then
			controller.clearAllSelectedObjectsAlt();
			isSelectAlt := true;
		endif;
	endif;

	if (not (isSelect or isSelectAlt)) then
		return;
	endif;
	
	if isSelect and controller.allSelectedObjects.includes(_obj) then
		controller.allSelectedObjects.remove(_obj);
		self.drawObject(_obj, controller);
		
		//par 18740.  If an item is deselected then set the currently
		//selected item to the first item in the forms selected objects.
		if controller.allSelectedObjects.size &gt; 0 then
		else
			//all selected objects on the form have been deselected
			//set to NULL so other forms don't attempt to plan
			if app.myMoveController &lt;&gt; null then
				app.myMoveController.mySlotRequest := null;
			else
				//not in planning mode.  Doing nothing actually.  Most likely testing.
			endif;
		endif;
		
		return;
		
	elseif isSelectAlt and controller.allSelectedObjectsAlt.includes(_obj) then
		controller.allSelectedObjectsAlt.remove(_obj);
		self.drawObject(_obj, controller);
		return;
	endif;
	
	if _obj.isKindOf(CM_ShipBlockController) then
		isOnDeck := true;
	elseif _obj.isKindOf(CM_GeneralCargoController) then
		isOnDeck := _obj.CM_GeneralCargoController.isOnDeck;
	endif;
	if isOnDeck then
		startObj := self.allObjectsOnDeck.first;
		if isSelect then
			self.selectObject(_obj, startObj, false);
		elseif isSelectAlt then
			self.selectObject(_obj, startObj, true);
		endif;
	else
		startObj := self.allObjectsUnderDeck.first;
		if isSelect then
			self.selectObject(_obj, startObj, false);
		elseif isSelectAlt then
			self.selectObject(_obj, startObj, true);
		endif;
	endif;
	
epilog
	delete theLCs;
	self.enableEvent("mouseMove", false);
	app.isDragging := false;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_button" type="Integer"/>
        <Parameter name="_shift" type="Integer"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="init" id="7c0ab51f-2875-4b4a-a154-a1e809baa2d2">
        <updating/>
        <source>init(_holdsForHatch : CM_ObjectArray; _x, _y, _width, _height : Real; _colour : Integer; _controller : SHP_BulkDrawingController; _redraw : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
// 29/06/2016  cnwma1		TFS #2173 JMT - SHP_BulkVoyagePlanningForm 1035 string too long
//
vars
	hold : CM_LocationsController;
	obj : Object;

begin
	self.clearGraphics;
	if not _redraw then
		self.allHoldsOnDeck.clear;
		self.allHoldsUnderDeck.clear;
		self.allObjectsOnDeck.clear;
		self.allObjectsUnderDeck.clear;
	endif;
	
	if _holdsForHatch = null or _holdsForHatch.isEmpty then
		return;
	endif;
	
	self.myHold := _holdsForHatch[1].CM_LocationsController;
	self.move(_x, _y, _width, _height);
	//write "frame " &amp; self.myHold.getFullId &amp; " moved to " &amp; self.left.String &amp; ":" &amp; self.top.String &amp; ":" &amp; self.width.String &amp; ":" &amp; self.height.String;

	self.backColor	:= _colour;
	//self.id := self.myHold.getID;       //cnwma1 29/06/2016 TFS #2173
	self.id := self.myHold.getHoldID();   //cnwma1 29/06/2016 TFS #2173
	self.ignoreSkin := true;
	if not _redraw then
		foreach obj in _holdsForHatch do
			hold := obj.CM_LocationsController;
			if hold.isKindOf(CM_GeneralCargoController) then
				if hold.CM_GeneralCargoController.isOnDeck then
					self.allHoldsOnDeck.add(hold);
				else
					self.allHoldsUnderDeck.add(hold);
				endif;
			endif;
		endforeach;
	endif;
	
	self.myBulkDrawingController := _controller;

	self.setDrawingPositions(_controller);
epilog

end;</source>
        <Parameter name="_holdsForHatch" type="CM_ObjectArray"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
        <Parameter name="_width" type="Real"/>
        <Parameter name="_height" type="Real"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_controller" type="SHP_BulkDrawingController"/>
        <Parameter name="_redraw" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="mouseUp" id="1bbc8e1b-286b-4721-8de9-4f220b0ba497">
        <controlMethod name="CMUI_GridAreaDrawingFrame::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseUp(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	shpForm : SHP_BulkVoyagePlanningForm;

begin
	inheritMethod(frame, button, shift, x, y);

	shpForm := self.form.SHP_BulkVoyagePlanningForm;
	shpForm.doGridAreaMouseUpEvent(self, button, shift, x, y);
epilog
	
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
