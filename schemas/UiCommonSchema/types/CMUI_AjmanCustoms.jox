	topMMs := 189;	bottomMMs := 193;	leftMMs := 0;	rightMMs := 28;		self.moveLabel( self.lblAO, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 57
	topMMs := 193;	bottomMMs := 197;	leftMMs := 0;	rightMMs := 28;		self.moveLabel( self.lblAP, topMMs, leftMMs, rightMMs, bottomMMs );	// Field 58
