    <JadeMethod name="doPreSelectorSearch" id="5a83d252-7f10-4671-9358-80ffcdac08ea">
        <updating/>
        <source>doPreSelectorSearch(removedCritLines: ObjectSet input; tempLines: ObjectSet input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
04 November 2019	jlger1	Initial creation 47132
25 March 2025		jlizm1	MTN 34447 Location enquiry not correctly displaying planned cargo from voyage
21/8/25 navsaa30 NSW - Deleted cargo cannot be removed permanently from MTN since upgrading from .12 to .15
*/

vars
	crit : CM_SelectorCriteriaLine;
	obj : Object;
	value : Any;
begin

	self.myEnqController.setDisplayMode( self.displayMode );	//28 Feb 2020	NDL	TFS 48724

	crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::myPrimaryActualLocation.name);
	if crit &lt;&gt; null and crit.myQueryOperator.getSearchValue &lt;&gt; null  then
		value:=crit.myQueryOperator.getSearchValue;
		if self.displayMode = DISPLAY_MODE_PLAN then
			removedCritLines.add(crit);
			crit:=self.doCreateCriteriaLine(app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,null], self.myCriteriaLineHolder, CM_TrackedItem::getPlannedLocationDisplay.name, CM_QueryOperator.Operator_Equal, value);
			if crit &lt;&gt; null then
				tempLines.add(crit);
			endif;
		elseif self.displayMode = DISPLAY_MODE_QUEUE then
			removedCritLines.add(crit);
			crit:=self.doCreateCriteriaLine(app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,null], self.myCriteriaLineHolder, CM_TrackedItem::getQueuedLocationDisplay.name, CM_QueryOperator.Operator_Equal, value);
			if crit &lt;&gt; null then
				tempLines.add(crit);
			endif;	
		endif;
		
	endif;
	crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::myTerminalArea.name);
	if crit &lt;&gt; null and crit.myQueryOperator.getSearchValue &lt;&gt; null  then
		value:=crit.myQueryOperator.getSearchValue;
		if self.displayMode = DISPLAY_MODE_PLAN then
			removedCritLines.add(crit);
			crit:=self.doCreateCriteriaLine(app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,null], self.myCriteriaLineHolder, CM_TrackedItem::plannedTermAreaId.name, CM_QueryOperator.Operator_Equal, value);
			tempLines.add(crit);
		elseif self.displayMode = DISPLAY_MODE_QUEUE then
			removedCritLines.add(crit);
			crit:=self.doCreateCriteriaLine(app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,null], self.myCriteriaLineHolder, CM_TrackedItem::getQueuedTermAreaId.name, CM_QueryOperator.Operator_Equal, value);
			tempLines.add(crit);	
		endif;
	
	endif;
	
	crit:= self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::getTAType.name);
	if crit &lt;&gt; null and self.displayMode &lt;&gt; DISPLAY_MODE_ACTUAL then
		removedCritLines.add(crit);
	endif;
	
	
	if (self.filterCargoTypeId  &gt; BOLType_Min) and (self.filterCargoTypeId  &lt; BOLType_Max) then
		crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::site.name);
		if crit &lt;&gt; null then
			removedCritLines.add(crit);
		endif;
	endif;
	
	if self.displayMode = DISPLAY_MODE_PLAN or self.displayMode = DISPLAY_MODE_QUEUE then
		// When displaying planned/queued cargo, cargo may currently be on voyage but will still want to see, so remove site
		crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::site.name);
		if crit &lt;&gt; null then
			removedCritLines.addNoDuplicates(crit, false);
		endif;
	endif;
	
	if self.filterTerminalArea.type = TA_TYPE_DELETE then				//navsaa30 21/8/25 #35560
		crit := self.myCriteriaLineHolder.findCriteriaByName(CM_TrackedItem::site.name);
		if crit &lt;&gt; null then
			removedCritLines.add(crit);
		endif;
		self.doCreateCriteriaLine(app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,null], self.myCriteriaLineHolder, CM_TrackedItem::site.name, CM_QueryOperator.Operator_Equal, TI_SITE_UNDEFINED);
	endif;
	
	inheritMethod(removedCritLines, tempLines);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="removedCritLines" type="ObjectSet" usage="input"/>
        <Parameter name="tempLines" type="ObjectSet" usage="input"/>
    </JadeMethod>
