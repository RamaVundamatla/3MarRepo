    <JadeMethod name="cmbCargoTypeHS_closeup" id="9d4dd693-b89e-4cc6-821d-06c5d05afbe3">
        <controlMethod name="ComboBox::closeup"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbCargoTypeHS_closeup(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
22 August 2024	navlw1	TFS 65152: NSW | IFCSUM Enhancements

*/

vars
	cargoType : CM_CargoType;
begin
	if combobox.name = self.cmbCargoTypeHS.name then
		self.tblActionIFCSUMHS.setCellText(self.tblActionIFCSUMHS.row, self.tblActionIFCSUMHS.column, combobox.text);
	endif;
	// need to move the code below to a method
	self.cmbCargoSubtype.clear();
	if combobox.text &lt;&gt; null then
		cargoType := app.myRoot.allCargoTypesByDescription[combobox.text];
		if cargoType &lt;&gt; null then
			self.myAssistant.comboBoxProduct(self.cmbCargoSubtype,cargoType,null,null);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
