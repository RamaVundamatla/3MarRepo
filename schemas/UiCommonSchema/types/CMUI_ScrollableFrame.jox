	app.mousePointer := Window.MousePointer_HourGlass;
	self.scrollTo(1, 1);

epilog 
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="scrollTopRight" id="513bee7c-e1e0-4706-958a-512072deab3c">
