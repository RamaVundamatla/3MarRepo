    <JadeMethod name="getYADescription" id="852466e5-c5d1-4ec7-ab3e-9a7f7ea1bb46">
        <source>getYADescription() : String;
// ---------------------------------------------------------------------------
// Created:		November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	yal : CM_YardAllocation;
	desc : String;
begin
	foreach yal in self.allYardAllocations discreteLock where yal.includeInYardDisplays()  do
		if desc = null then
			desc := yal.code;
		else
			desc := desc &amp; ", " &amp; yal.code;
		endif;
	endforeach;

	return desc;
end;</source>
