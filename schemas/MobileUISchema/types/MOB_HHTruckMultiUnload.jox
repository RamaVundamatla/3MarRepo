    <JadeMethod name="doClickItem" id="58b8b6a5-405e-43f1-bd66-db2cff22a092">
        <updating/>
        <source>doClickItem() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2011	cnwndl1	Initial creation	Par 28285

*/

vars

	row : JadeTableRow;
	ti : CM_TrackedItem;
	selected : Boolean;

begin

	if self.tblCargo.row &gt; self.tblCargo.rows or self.tblCargo.row &lt; 1 then
		return;
	endif;
	row := self.tblCargo.accessRow(self.tblCargo.row);
	
	if row = null then
		return;
	endif;
	
	ti := row.itemObject.CM_TrackedItem;
	selected := self.tblCargo.accessCell(self.tblCargo.row,1).text.Integer = 1;
	
	if selected then
		self.tblCargo.allMySelectedObjects.addExclusive( ti );
	else
		if self.tblCargo.allMySelectedObjects.includes( ti ) then
			self.tblCargo.allMySelectedObjects.remove( ti );
		endif;
	endif;
	
	self.txtNumItems.text := self.tblCargo.allMySelectedObjects.size.String;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doFindLocation" id="aa76ad7f-8a60-4cdb-948e-6203e7b06935">
        <updating/>
        <source>doFindLocation() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2011	cnwndl1	Initial creation	Par 28285

*/

vars

	idString : String;
	tmpFoundLC: CM_LocationsController;
	tmpFoundHeight : Integer;
	errMess : String;

begin

	idString := txtLocation.text.trimBlanks.toUpper;
	if idString = null or idString = lblLocation.caption.toUpper then
		self.myLocation := null;
		return;
	endif;
	
	self.myTerminal.findLocationFromString(idString, true, tmpFoundLC, tmpFoundHeight);
	
	if tmpFoundLC = null then
		errMess := app.getErrorString1(Location_NotFound, "'" &amp; idString &amp; "'");
	else
		
		if not tmpFoundLC.isYardLocation then
			errMess := app.getErrorString(Location_must_yard);
		elseif tmpFoundLC.isVehicle then
			errMess := app.getErrorString(Location_Not_vehicle);
		elseif tmpFoundLC.isMachineController then	
			errMess := app.getErrorString(Location_must_yard);
		endif;
		
	endif;
	
	if errMess &lt;&gt; null then
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
		self.txtLocation.setFocus();
		self.myLocation := null;
		return;
	endif;
	
	self.myLocation := tmpFoundLC;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResizeControls" id="cfd3b4a0-ea33-4a98-818a-0f8e4b7531d1">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	stdLeft : Real;
	top : Real;
	stdWidth : Real;
	stdHeight : Real;
	width : Real;
	tabIndex : Integer;
	quarterWidth : Real;
	halfWidth : Real;
	threeQuarterWidth : Real;
	tableHeight : Real;

begin

	self.setResizeableMarginAndFontSize();
	tabIndex := 4000;
	stdLeft :=  self.resizedMargin;
	top := self.resizedMargin;
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	halfWidth := ( stdWidth / 2 ) - self.resizedMargin;
	threeQuarterWidth := ( 3 * stdWidth / 4 ) - self.resizedMargin;
	quarterWidth := ( stdWidth / 4 ) - self.resizedMargin;
	
	if _initialSetup then
		self.lblCargoType.setAndIncrementTabIndex( tabIndex );
		self.lblCargoType.visible := true;
	endif;
	self.lblCargoType.move(	stdLeft,
							top,
							halfWidth,
							stdHeight );
	
	if _initialSetup then
		self.txtCargoType.setAndIncrementTabIndex( tabIndex );
		self.txtCargoType.visible := true;
		self.txtCargoType.enabled := false;
	endif;
	self.txtCargoType.move(	stdLeft + halfWidth + self.resizedMargin + self.resizedMargin,
							top,
							halfWidth,
							stdHeight );
							
	tableHeight := self.clientHeight - self.resizedMargin - ( ( stdHeight + self.resizedMargin ) * 3  ) - self.btnOne.height - ( self.resizedMargin * 4 );
	
	top := self.txtCargoType.top + self.txtCargoType.height + self.resizedMargin;						
	if _initialSetup then
		self.tblCargo.setAndIncrementTabIndex( tabIndex );
		self.tblCargo.visible := true;
		self.tblCargo.enabled := true;
	endif;
	self.tblCargo.move(	stdLeft,
						top,
						stdWidth,
						tableHeight );
						
	top := self.tblCargo.top + self.tblCargo.height + self.resizedMargin;
	if _initialSetup then
		self.lblNumItems.setAndIncrementTabIndex( tabIndex );
		self.lblNumItems.visible := true;
	endif;
	self.lblNumItems.move(	stdLeft,
							top,
							threeQuarterWidth,
							stdHeight );
							
	if _initialSetup then
		self.txtNumItems.setAndIncrementTabIndex( tabIndex );
		self.txtNumItems.visible := true;
		self.txtNumItems.enabled := false;
	endif;
	self.txtNumItems.move(	stdLeft + threeQuarterWidth + self.resizedMargin  + self.resizedMargin,
							top,
							quarterWidth,
							stdHeight );
							
	top := self.txtNumItems.top + self.txtNumItems.height + self.resizedMargin;
	if _initialSetup then
		self.txtLocation.setAndIncrementTabIndex( tabIndex );
		self.txtLocation.visible := true;
	endif;
	self.txtLocation.move(	stdLeft,
							top,
							stdWidth,
							stdHeight );


	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="d2aa3439-5493-49ad-83a9-5d10b8670786">
        <source>doSave():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2011	cnwndl1	Initial creation	par 28285
20 October   2014   cnwma1  PAR #35011 Lander Load from Truck does not ask for move confirmation
*/

vars

	errMess : String;
	selectedTis : CM_TIArray;
	ti : CM_TrackedItem;
	job : CM_RoadJob;
	wle : CM_WorkListEntry;
	incompleteWle : CM_WorkListEntry;
	idx	: Integer;

begin

	if self.myLocation = null then
		errMess := app.getErrorString( No_Location_entered );
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
		self.txtLocation.setFocus();
		return false;
	endif;
	
	if not self.myLocation.isYardLocation then
		errMess := app.getErrorString(Location_must_yard);
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
		self.txtLocation.setFocus();
		return false;
	endif;
	
	if self.tblCargo.allMySelectedObjects.isEmpty then
		errMess := app.getErrorString(Cargo_selected_offloading);
		self.msgBox( errMess, app.getErrorString(Error), MsgBox_OK_Only, true );
		return false;
	endif;
	
	create selectedTis transient;
	self.tblCargo.allMySelectedObjects.copy( selectedTis );
	
	foreach ti in selectedTis do
	
		job := ti.jobRoadReceive;
		if job &lt;&gt; null and not job.workListEntries.isEmpty then
			foreach wle in job.workListEntries do
				if not wle.isReceipt then
					continue;
				endif;
				if wle.status = WLE_COMPLETED then
					continue;
				endif;
				if wle.myTrackedItem &lt;&gt; ti then
					continue;
				endif;
				incompleteWle := wle;
				break;
			endforeach;
		endif;
		if not self.myMobileGenericAgent.moveTI( ti, null, self.myLocation, incompleteWle, false, 0, 0, null ) then //20/10/2014 cnwma1 PAR #35011 
			return false;
		else
			//its a good 'un - disable and unselect in the table just in case we fail the next one and the user returns there and tries again.
			if self.tblCargo.findObjectInRow(ti, idx) then
				self.tblCargo.accessRow( idx ).enabled := false;
				self.tblCargo.accessCell(idx, 1).text := TableCheckBox_NotSelected;
				self.tblCargo.allMySelectedObjects.remove(ti);
				self.txtNumItems.text := self.tblCargo.allMySelectedObjects.size.String;
			endif;
		endif;
		
	endforeach;
	
	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="c8a8df62-db4a-441e-a7bc-34e08a4a0a0e">
        <updating/>
        <source>handleBtnOne() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2011	cnwndl1	Initial creation	Par 28285

*/

vars

begin

	if doSave() then
		self.myMobileGenericAgent.setMyMultiUnloadArrayContent( null );
		self.myMobileGenericAgent.setTruck( self.myMobileGenericAgent.myTruck );	// force reload of data.
		self.doBackButtonClick();
	endif;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="handleBtnTwo" id="405dc2ee-c443-4310-8234-c0a777cc02d3">
        <updating/>
        <source>handleBtnTwo() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2011	cnwndl1	Initial creation	Par 28285

*/

vars

begin

	self.myMobileGenericAgent.setMyMultiUnloadArrayContent( null );
	self.myMobileGenericAgent.setTruck( self.myMobileGenericAgent.myTruck );	// force reload of data.
	self.doBackButtonClick();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateTblCargo" id="2b608575-b600-4aa3-9a23-ca38630d60bd">
        <updating/>
        <source>populateTblCargo()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2011	cnwndl1	Initial creation

*/

vars

	size : Integer;
	index : Integer;
	ti : CM_TrackedItem;
	cell : JadeTableCell;
	row : JadeTableRow;

begin

	size := self.myAvailableTis.size;
	
	self.tblCargo.fixedColumns := 0;
	self.tblCargo.columns := 2;
	self.tblCargo.fixedRows := 0;
	self.tblCargo.rows := size;

	foreach index in 1 to size do
		ti := myAvailableTis[index];
		row := self.tblCargo.accessRow(index);
		row.itemObject := ti;
		self.tblCargo.setCellText( index, 1, TableCheckBox_Selected &amp; Tab &amp; ti.id );
	endforeach;
	
	self.myAvailableTis.copy(self.tblCargo.allMySelectedObjects);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupControls" id="608b387f-5764-4144-8760-8b977c51208d">
        <updating/>
        <source>setupControls() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2011	cnwndl1	Initial creation	par 28285

*/

vars

	cargoTypeString : String;

begin
						
	self.doResizeControls(true);
							
	self.txtCargoType.text := self.myAvailableTis.first.cargoTypeDescr;
	self.populateTblCargo();
	self.txtNumItems.text := self.tblCargo.allMySelectedObjects.size.String;
	self.txtLocation.text := self.lblLocation.caption.toUpper;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="716744b7-7fec-4969-a3fb-c121edf1856e">
        <updating/>
        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2011	cnwndl1	Initial creation	Par 28285

*/

vars

begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	if self.myMobileGenericAgent.myMultiUnloadArray = null or self.myMobileGenericAgent.myMultiUnloadArray.isEmpty then
		self.handleBtnTwo();
		return;
	endif;
	self.myMobileGenericAgent.myMultiUnloadArray.copy( myAvailableTis );
	
	self.caption := app.getErrorString(Multi_unload) &amp; " " &amp; self.myMobileGenericAgent.myTruck.getDisplayDetails(true);
	
	inheritMethod();
	
	self.setupCmdButtons( 2, app.getErrorString(Save), app.getErrorString(Back), null, null, null );
	
	self.setupControls();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
