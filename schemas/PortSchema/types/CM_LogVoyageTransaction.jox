    <JadeMethod name="addToStockMovement" id="b3f25883-6beb-4561-9094-053848140db0">
        <updating/>
        <source>addToStockMovement(_stkMove: CM_StockMovement) updating;
// ---------------------------------------------------------------------------
// Created:     24 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
