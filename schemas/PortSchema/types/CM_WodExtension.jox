    <JadeMethod name="getCurrentLocation" id="39a4efb6-71af-4aee-8be9-e816f1f200fc">
        <source>getCurrentLocation(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 October 2018	jlgndl1	Initial creation	TFS 41272

*/

vars

	berth : HMS_Berth;
	voyage : CM_Voyage;
	departMovement : HMS_VoyageMovement;
	movement : HMS_VoyageMovement;

begin

	//11 Oct 2018 -  New rule, use departure movement instead
	voyage := self.getMyVoyageObject();
	if voyage &lt;&gt; null then
		departMovement := voyage.getMovementDeparture();
		if departMovement &lt;&gt; null then
			movement := departMovement.myPreviousMovement.HMS_VoyageMovement;
		endif;
	endif;
//	movement := self.getMyParent.getMyHMSVoyageMovement();
	
	if movement &lt;&gt; null then
		berth := movement.getMyBerth;
		if berth &lt;&gt; null then
			return berth.description;
		endif;
	endif;

	return inheritMethod();

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="b0809aae-f6f4-4acf-8852-c4602099a27c">
        <source>getDisplayString(_useShortDesc: Boolean): String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 18/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
//29 Sep 2021   navma1 	    ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
//
vars
	displayString : String;
	typeDesc      : String;
begin
	typeDesc := self.getTypeDescription();								  //29.09.2021 navma1 #51925
	
	if _useShortDesc then
		displayString := typeDesc;
	else
		displayString := self.getLongDescription(typeDesc,null);		//29.09.2021 navma1 #51925
	endif;
	
	return displayString;
epilog

end;</source>
        <Parameter name="_useShortDesc" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
