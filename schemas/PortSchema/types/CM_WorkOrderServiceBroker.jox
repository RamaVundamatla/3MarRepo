    <JadeMethod name="getDescription" id="398b6df2-fab3-40fc-bdb8-f0a1549d3bce">
        <source>getDescription(): String;
/*
Purpose:	TFS 39236		
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
*/

vars
	invalid			: Boolean;
	returnVal		: String;
	eventType		: Integer;
begin
	
	eventType := self.workOrderType;
	if eventType = null then
		return null;
	endif;
	
	returnVal := self.getWorkOrderTypeDesc();
	
	return returnVal;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInvoiceLineDesc" id="aa6a1da5-8f61-47f4-9e39-7e01ab44f1ac">
        <source>getInvoiceLineDesc(_aSBController : CMIF_ServiceBroker input);
/*
Purpose:	TFS 39236		
Date			Who			Reason
JUNE 2018		CNWAB1		Initial creation
23 Oct 2024  	navlw1 		JIRA-33107: Invoice Logging Use Levels
25 Feb 2025		navah1		Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/
vars
	lineDescription:   CM_InvoiceLineDesc;
	tmpDebtor : CM_Debtor;
	aDM : CM_DebtorMap;
	ti:CM_TrackedItem;
	trans : CM_WOTransaction;
	canLogExtra	: Boolean;	//28.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//28.02.2025 navah1	#34141
	trans := _aSBController.myTransactionWO;
	if trans &lt;&gt; null then
		tmpDebtor := trans.getMyDebtor();
		if tmpDebtor &lt;&gt; null then
			if canLogExtra then	//28.02.2025 navah1	#34141
				app.invLog("Debtor " &amp; tmpDebtor.name, LogTRACE.String);
			endif;
			aDM := self.allDebtorMapsByDebtor[tmpDebtor.name];		
			if aDM &lt;&gt; null then
				if canLogExtra then	//28.02.2025 navah1	#34141
					app.invLog("Debtor map for " &amp; tmpDebtor.name, LogTRACE.String);
				endif;
				aDM.getInvoiceLineDesc(_aSBController);
				return;
			endif;
		endif;
	endif;
	if canLogExtra then	//28.02.2025 navah1	#34141
		app.invLog("Debtor map for DEFAULT", LogTRACE.String);
	endif;
	self.myChildQuantityMap.getInvoiceLineDesc(_aSBController);
	
end;</source>
        <Parameter name="_aSBController" type="CMIF_ServiceBroker" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTranMapBreadCrumb" id="db865eb8-b619-4e91-add6-2d969720bb66">
        <source>getTranMapBreadCrumb(): String;
/*
Purpose:	TFS 39236		
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
*/

vars

begin
	return self.myTransMap.getTranMapBreadCrumb() &amp; "/" &amp; self.getWOClassName();

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWOClassName" id="bf15a1d6-82ca-4e35-8a6f-1b215a27b4c9">
        <source>getWOClassName():String;
/*
Purpose:	TFS 39236		
Date				Who			Reason
JUNE 2018		CNWAB1		Initial creation
*/

vars

begin
	if self.workOrderType &lt;&gt; null then
		return self.getWorkOrderTypeDesc();
	else
		return "Default (Event)";
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWOResourceInUse" id="fcc5d958-d931-441b-ad71-d6c109a9f727">
        <source>getWOResourceInUse(_resources : CM_ResourceTypeDict io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map

*/

vars
	broker : CM_ToDoResourceServiceBroker;
begin
	if _resources = null then
		return;
	endif;
	
	foreach broker in self.allToDoResourceServiceBrokers discreteLock do
		if broker.myResourceType &lt;&gt; null then
			_resources.addNoDuplicates(broker.myResourceType, false);
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_resources" type="CM_ResourceTypeDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getWorkOrderTypeDesc" id="e585d58f-1774-4214-8f1c-cf045c94509f">
