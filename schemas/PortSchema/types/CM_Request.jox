    <JadeMethod name="pxyCreateUpdateProxy" id="60bbda21-df47-4965-9107-e9ee2b143204">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------

vars
	lRequestProxy	: CM_Request;
	completedOK		: Boolean;
	
begin

	lRequestProxy := inheritMethod();
	
	lRequestProxy.bulkRelease 		:= self.bulkRelease;
	lRequestProxy.myJob 				:= self.myJob;
	lRequestProxy.setMyOriginatingBulkRelease(self.myOriginatingBulkRelease);
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return lRequestProxy;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete lRequestProxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="removeBulkReleaseTI" id="0efed92e-476d-4624-a273-841399206ae6">
