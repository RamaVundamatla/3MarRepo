    <JadeMethod name="translateForm" id="998743b2-1f0d-4f1c-96c0-c01b52533a77">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0005964, locale);
	btnPrint.translateBubbleHelp(Xlat_0016577, locale);
	btnPrint.translateCaption(Xlat_0016578, locale);
	btnRedraw.translateBubbleHelp(Xlat_0001611, locale);
	btnRedraw.translateCaption(Xlat_0001613, locale);
	cmbVesselHMS.translateBubbleHelp(Xlat_0001612, locale);
	lbDepthMin.translateCaption(Xlat_0001614, locale);
	lblDate.translateCaption(Xlat_0001615, locale);
	lblDepth.translateCaption(Xlat_0001616, locale);
	lblDepthPositive.translateCaption(Xlat_0001628, locale);
	lblDraft.translateCaption(Xlat_0005965, locale);
	lblDraftM.translateCaption(Xlat_0001618, locale);
	lblEntranceWin.translateCaption(Xlat_0001605, locale);
	lblFRNegitive.translateCaption(Xlat_0001607, locale);
	lblFRPositive.translateCaption(Xlat_0001608, locale);
	lblFlow.translateCaption(Xlat_0001619, locale);
	lblFlowRate.translateCaption(Xlat_0001620, locale);
	lblLegendBerth.translateCaption(Xlat_0001606, locale);
	lblLegendRegion.translateCaption(Xlat_0001603, locale);
	lblRegion.translateCaption(Xlat_0001621, locale);
	lblSummary.translateCaption(Xlat_0001622, locale);
	lblSummaryFlowR.translateCaption(Xlat_0001604, locale);
	lblTZWarning.translateCaption(Xlat_0001623, locale);
	lblTidalClass.translateCaption(Xlat_0001609, locale);
	lblTimeAtPosn.translateCaption(Xlat_0001610, locale);
	lblVessel.translateCaption(Xlat_0001624, locale);
	lblZoneTime.translateCaption(Xlat_0001625, locale);
	optArrival.translateCaption(Xlat_0001626, locale);
	optDeparture.translateCaption(Xlat_0001627, locale);
end;</source>
    </JadeMethod>
