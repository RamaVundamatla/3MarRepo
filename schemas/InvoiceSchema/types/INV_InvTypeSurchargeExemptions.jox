    <JadeMethod name="doControlEvent" id="620d2e49-ee6f-4f9e-a642-fd5d13f1e297">
        <updating/>
        <source>doControlEvent(_control: Control) updating;
/*

Purpose:			Used to handle changes made to multi select group boxes. To filter the other group boxes on the form

Parameters:			_control	Control	Control that had a change made

Return Value:		NONE

Date		Who		Reason
16 September 2022	navpw1	Initial creation TFS: 54565 (54385) - EUP - Inv Config - Invoice Surcharges

*/

vars
 	allSelectedCargoTypes		: CM_CargoTypeSet;
	allSelectedCargoSubTypes	: CM_ProductSet;
	allSelectedCommodities		: CM_CommoditySet;
	cargoSubTypeArray			: CM_ProductArray;
	commodityArray				: CM_CommodityArray;
	cargoType					: CM_CargoType;
	cargoSubType				: CM_Product;
	commodity					: CM_Commodity;
	
begin
	inheritMethod(_control);
	
	if _control = self.mulSCTCargoTypes.myAddSelectedBtn or
	   _control = self.mulSCTCargoTypes.myAddAllBtn or		
	   _control = self.mulSCTCargoTypes.myRemoveSelectedBtn or
	   _control = self.mulSCTCargoTypes.myRemoveAllBtn
	then
		//Populate Sub Cargo Types
		//Populate Commodities
		create allSelectedCargoTypes transient;
		create allSelectedCargoSubTypes transient;
		create allSelectedCommodities transient;
		
		self.mulSCTCargoTypes.getSelected(allSelectedCargoTypes);
		self.mulSCTSubCargoTypes.getSelected( allSelectedCargoSubTypes );	
		self.mulSCTCommodities.getSelected( allSelectedCommodities );
		
		create cargoSubTypeArray transient;
		create commodityArray transient;
		
		foreach cargoType in allSelectedCargoTypes discreteLock do
			
			foreach cargoSubType in cargoType.allProducts discreteLock do
				cargoSubTypeArray.addExclusive(cargoSubType);
				
			endforeach;
			
			foreach commodity in cargoType.allCommodities discreteLock do
				commodityArray.addExclusive(commodity);
				
			endforeach;
			
		endforeach;
		
		self.mulSCTSubCargoTypes.setAvailable(cargoSubTypeArray, true);
		self.mulSCTSubCargoTypes.setSelected(allSelectedCargoSubTypes);
		
		self.mulSCTCommodities.setAvailable(commodityArray, true);
		self.mulSCTCommodities.setSelected(allSelectedCommodities);
		
	endif;	
	
epilog
	delete allSelectedCargoTypes;
	delete allSelectedCargoSubTypes;
	delete allSelectedCommodities;
	delete cargoSubTypeArray;
	delete commodityArray;
	
end;</source>
        <Parameter name="_control" type="Control"/>
    </JadeMethod>
    <JadeMethod name="doSaveACS" id="41862e6e-a734-489f-8315-e356adbdcfe9">
        <source>doSaveACS():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 March 2018	jlgndl1	Initial creation	TFS 37818

*/

vars

	surchargeRate : Decimal[12,6];
	dr : CM_Debtor;
	surInvLineType : CM_InvoiceLineDesc;
	real : CM_DebtorSurchargeRate;
	theReturn : Integer;

begin

	surchargeRate := self.txtACSPercent.text.asDecimalJMT();
	dr := self.cmbACSDebtor.listObject.CM_Debtor;
	surInvLineType := self.cmbACSInvLineType.listObject.CM_InvoiceLineDesc;
	
	if self.myCurrentInvTypeSurExempt = null then
		app.msgBox( app.getErrorString(Current_surcharge_exemptions), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	if surInvLineType = null then
		app.msgBox( app.getErrorString(Surcha_invoic_line_type_select), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	if self.myProxyDrSurRate = null then
		app.msgBox( app.getErrorString(Proxy_Object_Null_For_Update), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	if surchargeRate &lt;= 0 then
		app.msgBox( app.getErrorString(Surch_rate_must_great_than_zer), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	if dr = null then
		app.msgBox( app.getErrorString(INV_Please_Select_A_Debtor), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	self.myProxyDrSurRate.setProxy(	dr,	//_dr : CM_Debtor;
									self.myCurrentInvTypeSurExempt,	//_mySurAndExempt : CM_InvoiceTypeSurchargeExempt;
									surInvLineType,	//_mySurInvLineType : CM_InvoiceLineDesc;
									surchargeRate	//_surchargeRate : Decimal
									);
									
	real := self.myProxyDrSurRate.pxyGetRealObject;
	
	while true do
		if real = null then
			//create a new one
			app.myTrxCA.trxCreateDrSurchargeRate( self.myProxyDrSurRate, real, app.myPassport );
		else
			//update an existing one
			app.myTrxUA.trxUpdateDrSurchargeRate( self.myProxyDrSurRate, app.myPassport );
		endif;
	
		if app.myPassport.trxCompletedOK then
			return true;
			
		else
			theReturn := app.showErrorWarningDialog("Debtor Surcharge Rate", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		
		break;
	
	endwhile;

	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveAF" id="bcfe75ff-a3e0-46f5-babc-613885573d07">
        <source>doSaveAF():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 April 2018	jlgndl1	Initial creation	TFS 37819

*/

vars

	rangeStart : Real;
	rangeEnd : Real;
	dr : CM_Debtor;
	invLineType : CM_InvoiceLineDesc;
	addInvLineTypes : CM_InvoiceLineDescSet;
	real : CM_InvTypeAdditionalCharges;
	theReturn : Integer;
	rowIndex : Integer;

begin

	rangeStart := self.txtAFRangeStart.text.asRealJMT();
	rangeEnd := self.txtAFRangeEnd.text.asRealJMT();
	if rangeEnd &gt; CM_InvoiceTypeSurchargeExempt.HighValue_15_2 then	//24 Apr 2018	NDL	TFS 37819 rework.
		rangeEnd := CM_InvoiceTypeSurchargeExempt.HighValue_15_2;
	endif;
	dr := self.cmbAFDebtor.listObject.CM_Debtor;
	
	create addInvLineTypes transient;
	foreach rowIndex in 1 to self.lstAFInvLineTypes.rows do
		if self.lstAFInvLineTypes.accessCell(rowIndex,1).text = "1" then
			invLineType := self.lstAFInvLineTypes.accessRow(rowIndex).itemObject.CM_InvoiceLineDesc; 
			if invLineType&lt;&gt; null then
				addInvLineTypes.add( invLineType );
			endif;
		endif;
	endforeach;
	
	if self.myCurrentInvTypeSurExempt = null then
		app.msgBox( app.getErrorString(Current_surcharge_exemptions), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	if addInvLineTypes.isEmpty then
		app.msgBox( app.getErrorString(Surcha_invoic_line_type_select), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	if self.myProxyAFCharges = null then
		app.msgBox( app.getErrorString(Proxy_Object_Null_For_Update), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	if rangeStart &lt; 0 then
		app.msgBox( app.getErrorString(XXX_less_than_zero), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	if rangeEnd &lt;= 0 then
		app.msgBox( app.getErrorString(Range_not_zero), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	if rangeEnd &lt; rangeStart then	
		app.msgBox( app.getErrorString(Range_not_less_than_range_star), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	if dr = null then
		app.msgBox( app.getErrorString(INV_Please_Select_A_Debtor), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	self.myProxyAFCharges.setProxy(	addInvLineTypes,	//_allAdditionalInvTypes : CM_InvoiceLineDescSet input;
									dr,	//_myDebtor : CM_Debtor;
									self.myCurrentInvTypeSurExempt,	//_mySurchargeExemption : CM_InvoiceTypeSurchargeExempt;
									rangeStart,	//_rangeStart : Real;
									rangeEnd	//_rangeEnd : Real
									);
									
	real := self.myProxyAFCharges.pxyGetRealObject;
	
	while true do
		if real = null then
			//create a new one
			app.myTrxCA.trxCreateInvTypeAddedFees( self.myProxyAFCharges, real, app.myPassport );
		else
			//update an existing one
			app.myTrxUA.trxUpdateInvTypeAddedFees( self.myProxyAFCharges, app.myPassport );
		endif;
	
		if app.myPassport.trxCompletedOK then
			return true;
			
		else
			theReturn := app.showErrorWarningDialog("Additional Fees", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		
		break;
	
	endwhile;

	return false;

epilog

	delete addInvLineTypes;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveDMC" id="1d26e77e-aece-4c38-86e2-0753a97e7c40">
        <source>doSaveDMC():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2018	jlgndl1	Initial creation	TFS 38914

*/

vars

	minChg : Decimal[23,6];
	dr : CM_Debtor;
	minChgLineType : CM_InvoiceLineDesc;
	real : CM_InvTypeDebtorMinCharge;
	theReturn : Integer;

begin

	minChg := self.txtDMCMinCharge.text.asDecimalJMT();
	dr := self.cmbDMCDebtor.listObject.CM_Debtor;
	minChgLineType := self.cmbDMCInvLineType.listObject.CM_InvoiceLineDesc;
	
	if self.myCurrentInvTypeSurExempt = null then
		app.msgBox( app.getErrorString(Current_surcharge_exemptions), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	if minChgLineType = null then
		app.msgBox( app.getErrorString(Minim_charg_line_type_must_sel), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	if self.myProxyDMCharges = null then
		app.msgBox( app.getErrorString(Proxy_Object_Null_For_Update), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	if minChg &lt;= 0 then
		app.msgBox( app.getErrorString(Minim_charg_must_great_than_ze), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	if dr = null then
		app.msgBox( app.getErrorString(INV_Please_Select_A_Debtor), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	self.myProxyDMCharges.setProxy(	dr,	//_myDebtor : CM_Debtor;
									minChg,	//_minimumChargeAmount : Real;
									minChgLineType,	//_myMinimumChargeInvoiceLineType : CM_InvoiceLineDesc;
									self.myCurrentInvTypeSurExempt	//_mySurchargesAndExemptions : CM_InvoiceTypeSurchargeExempt
									);
									
	real := self.myProxyDMCharges.pxyGetRealObject;
	
	while true do
		if real = null then
			//create a new one
			app.myTrxCA.trxCreateDrMinimumChg( self.myProxyDMCharges, real, app.myPassport );
		else
			//update an existing one
			app.myTrxUA.trxUpdateDrMinimumChg( self.myProxyDMCharges, app.myPassport );
		endif;
	
		if app.myPassport.trxCompletedOK then
			return true;
			
		else
			theReturn := app.showErrorWarningDialog("Debtor Minimum Charge", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		
		break;
	
	endwhile;

	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveET" id="5375e04d-131e-495a-b8fd-87aebc6ee81e">
        <source>doSaveET():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2018	jlgndl1	Initial creation	TFS 37821

*/

vars

	rangeStart : Real;
	rangeEnd : Real;
	dr : CM_Debtor;
	taxExempt : Integer;
	taxCode : String;
	real : CM_InvoiceTypeExternalTax;
	theReturn : Integer;
	rowIndex : Integer;

begin

	rangeStart := self.txtETRangeStart.text.asRealJMT();
	rangeEnd := self.txtETRangeEnd.text.asRealJMT();
	if rangeEnd &gt; CM_InvoiceTypeSurchargeExempt.HighValue_15_2 then	//24 Apr 2018	NDL	TFS 37819 rework, and again 24 Jul 2019	NDL TFS 45509
		rangeEnd := CM_InvoiceTypeSurchargeExempt.HighValue_15_2;
	endif;
	dr := self.cmbETDebtor.listObject.CM_Debtor;
	if self.cmbETTaxRule.listIndex &gt; 0 then
		taxExempt := self.cmbETTaxRule.itemData[ self.cmbETTaxRule.listIndex ];
	endif;
	taxCode := self.txtETTaxCode.text.trimBlanks;
	
	
	if self.myCurrentInvTypeSurExempt = null then
		app.msgBox( app.getErrorString(Current_surcharge_exemptions), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
		
	if self.myProxyETTax = null then
		app.msgBox( app.getErrorString(Proxy_Object_Null_For_Update), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	if taxCode = null then
		app.msgBox( app.getErrorString(Externa_code_not_empty), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	if rangeStart &lt; 0 then
		app.msgBox( app.getErrorString(XXX_less_than_zero), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	if rangeEnd &lt;= 0 then
		app.msgBox( app.getErrorString(Range_not_zero), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	if rangeEnd &lt; rangeStart then	
		app.msgBox( app.getErrorString(Range_not_less_than_range_star), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	if dr = null then
		app.msgBox( app.getErrorString(INV_Please_Select_A_Debtor), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;

	self.myProxyETTax.setProxy(	taxCode,	//_extTaxCode : String;
								taxExempt,	//_extTaxRule : Integer;
								dr,	//_myDebtor : CM_Debtor;
								self.myCurrentInvTypeSurExempt,	//_mySurchargeExemption : CM_InvoiceTypeSurchargeExempt;
								rangeStart,	//_rangeStart : Real;
								rangeEnd	//_rangeEnd : Real
								);
									
	real := self.myProxyETTax.pxyGetRealObject;
	
	while true do
		if real = null then
			//create a new one
			app.myTrxCA.trxCreateInvTypeDrExtTax( self.myProxyETTax, real, app.myPassport );
		else
			//update an existing one
			app.myTrxUA.trxUpdateInvTypeDrExtTax( self.myProxyETTax, app.myPassport );
		endif;
	
		if app.myPassport.trxCompletedOK then
			return true;
			
		else
			theReturn := app.showErrorWarningDialog("External tax", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		
		break;
	
	endwhile;

	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveGMC" id="cd957ec6-8219-41aa-8f30-f215eee09c13">
        <source>doSaveGMC():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2019	jlgndl1	Initial creation	TFS 43687

*/

vars

	minChgAmount : Decimal[23,6];	//26 Jul 2019	NDL	TFS 45509
	minChgInvLineType : CM_InvoiceLineDesc;
	allLineTypesForMinimumCharge : CM_InvoiceLineDescSet;
	description : String;
	moveType : String;
	grpLinesBy : Integer;
	realGrpMinCharge : CM_InvTypeGroupingMinCharge;
	theReturn : Integer;
	msg : String;

begin

	minChgAmount := self.txtGMCMinCharge.text.asDecimalJMT();
	minChgInvLineType := self.cmbGMCInvLineType.listObject.CM_InvoiceLineDesc;
	description := self.txtGMCDescription.text;
	moveType := self.cmbGMCMoveType.text;
	if self.optGMCWholeInv.value then
		grpLinesBy := CM_InvTypeGroupingMinCharge.GroupTypeInvoice;
	elseif self.optGMCMovement.value then
		grpLinesBy := CM_InvTypeGroupingMinCharge.GroupTypeMovement;
	endif;
	
	create allLineTypesForMinimumCharge transient;
	self.mulGMCInvLineTypes.getSelected( allLineTypesForMinimumCharge );
	
	if self.myCurrentInvTypeSurExempt = null then
		app.msgBox( app.getErrorString(Current_surcharge_exemptions), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	if minChgInvLineType = null then
		app.msgBox( app.getErrorString(Minim_charg_line_type_must_sel), app.getErrorString(Error), MsgBox_OK_Only );
		self.cmbGMCInvLineType.setFocus();
		return false;
	endif;
	
	if description = null then
		app.msgBox( app.getErrorString(Input_required_field_Desc), app.getErrorString(Error), MsgBox_OK_Only );
		self.txtGMCDescription.setFocus();
		return false;
	endif;
	
	if allLineTypesForMinimumCharge.isEmpty then
		app.msgBox( app.getErrorString(Invoice_line_types_selecte), app.getErrorString(Error), MsgBox_OK_Only );
		self.mulGMCInvLineTypes.myAvailableListBox.setFocus();
		return false;
	endif;
	
	if grpLinesBy = CM_InvTypeGroupingMinCharge.GroupTypeMovement and moveType = null then
		app.msgBox( app.getErrorString(Input_required_field_moveType), app.getErrorString(Error), MsgBox_OK_Only );
		self.cmbGMCMoveType.setFocus();
		return false;
	endif;
	
	if minChgAmount = 0 then
		app.msgBox( app.getErrorString(Minim_charg_must_great_than_ze), app.getErrorString(Error), MsgBox_OK_Only );
		self.txtGMCMinCharge.setFocus();
		return false;
	endif;
	
	

	self.myProxyGMCharges.setProxy(	allLineTypesForMinimumCharge,	//_allLineTypesForMinimumCharge : CM_InvoiceLineDescSet;
									description,	//_description : String;
									grpLinesBy,	//_groupLinesBy : Integer;
									minChgAmount.Real,	//_minimumChargeAmount : Real;
									moveType,	//_moveType : String;
									minChgInvLineType,	//_myMinimumChargeInvoiceLineType : CM_InvoiceLineDesc;
									self.myCurrentInvTypeSurExempt	//_mySurchargesAndExemptions : CM_InvoiceTypeSurchargeExempt
									);
									
	realGrpMinCharge := self.myProxyGMCharges.pxyGetRealObject;
	
	while true do
		if realGrpMinCharge = null then
			//create a new one
			app.myTrxCA.trxCreateGrpMinimumChg( self.myProxyGMCharges, realGrpMinCharge, app.myPassport );
		else
			//update an existing one
			app.myTrxUA.trxUpdateGrpMinimumChg( self.myProxyGMCharges, app.myPassport );
		endif;
	
		if app.myPassport.trxCompletedOK then
			return true;
			
		else
			theReturn := app.showErrorWarningDialog("Debtor Minimum Charge", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		
		break;
	
	endwhile;

	return false;

epilog

	delete allLineTypesForMinimumCharge;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveISA" id="03dfabb6-ee2d-47d7-b434-286528ea3cae">
        <source>doSaveISA() : Boolean;
/*

Purpose:			Saves a new Invoice Type Debtor Separation from the panel

Parameters:			NONE

Return Value:		Boolean	Representing whether it was successful

Date		Who		Reason
24 August 2022	navpw1	Initial creation TFS: 54565 (54384) - EUP - Inv Config - Invoice Surcharges

*/

vars
	theReturn 				: Integer;
	debtor 					: CM_Debtor;
	accrualType 			: CM_FinancialPeriodEnd;
	separatedByVoyage,
	separatedByVoyageGroup,
	separatedByCargoId,
	separatedByCargoGrpId,
	separatedByBol,
	separatedByBooking,
	separatedByReleaseReq,
 	separatedByPONumber: Boolean;
	real 					: CM_InvTypeDebtorSeparation;
	
begin
	if self.cmbISADebtor.listIndex &gt; 0 then
		debtor := self.cmbISADebtor.itemObject[self.cmbISADebtor.listIndex].CM_Debtor;
	endif;
	
	if self.cmbISAAccuralType.listIndex &gt; 0 then
		accrualType := self.cmbISAAccuralType.itemObject[self.cmbISAAccuralType.listIndex].CM_FinancialPeriodEnd;
	endif;
	
	separatedByVoyage 		:= self.optISAVoyageSepYes.value;
	separatedByVoyageGroup 	:= self.optISAVoyageGrpSepYes.value;
	separatedByCargoId 		:= self.optISACargoIdSepYes.value;
	separatedByCargoGrpId 	:= self.optISACargoGrpIdSepYes.value;
	separatedByBol 			:= self.optISABolSepYes.value;
	separatedByBooking 		:= self.optISABookingSepYes.value;
	separatedByReleaseReq 	:= self.optISAReleaseReqSepYes.value;
	separatedByPONumber 	:= self.optISAPONumberYes.value; // ### BUG 56925 07MAR2023 NAVAB1
	
	self.myProxyInvTypeDebtorSep.setProxy(
									debtor,						//_debtor 					: CM_Debtor;
									accrualType,				//_accrualType 				: CM_FinancialPeriodEnd
									separatedByVoyage,			//_separatedByVoyage 		: Boolean;
									separatedByVoyageGroup,		//_separatedByVoyageGroup	: Boolean;
									separatedByCargoId,			//_separatedByCargoId 		: Boolean;
									separatedByCargoGrpId,		//_separatedByCargoGrpId 	: Boolean;
									separatedByBol,				//_separatedByBol 			: Boolean;
									separatedByBooking,			//_separatedByBooking 		: Boolean;
									separatedByReleaseReq,		//_separatedByReleaseReq 	: Boolean;
									separatedByPONumber, // ### BUG 56925 07MAR2023 NAVAB1
									myCurrentInvTypeSurExempt 	//_surchargesAndExemptions 	: CM_InvoiceTypeSurchargeExempt
									);
	
	real := self.myProxyInvTypeDebtorSep.pxyGetRealObject;
	
	while true do
		if real = null then
			//create a new one
			app.myTrxCA.trxCreateInvTypeDtrSeparation(self.myProxyInvTypeDebtorSep, real, app.myPassport);
		else
			//update an existing one
			app.myTrxUA.trxUpdateInvTypeDtrSeparation(self.myProxyInvTypeDebtorSep, app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then
			return true;
			
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Invoice_seperation_accural), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		
		break;
		
	endwhile;
	
	return false;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveSCT" id="809b3d8f-e5d9-45e4-9f2e-25e121610ccd">
        <source>doSaveSCT():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 April 2018		jlgndl1	Initial creation	TFS 37822
20 Jun 2018			NDL		TFS 39305
15 September 2022 	navpw1 	TFS 54565 (54385) - EUP - Inv Config - Invoice Surcharges
19-May-2023 		navtnr20 Bug 57644: FR | 53978 - EUP - Invoicing -  Configuration Enhancements - Surcharges and Exemptions- Negative numbers are not allowed in the Surcharge % or Surcharge Fix amount
*/

vars
	surchargeRate				: Decimal[12,6];
	//cargoType					: CM_CargoType;					// ### TFS 54565 (54385) 19Sep2022 NAVPW1
	surInvLineType				: CM_InvoiceLineDesc;
	//real						: CM_InvTypeCargoSurcharge;
	real						: CM_InvTypeCargoMultiSurcharge;// ### TFS 54565 (54385) 19Sep2022 NAVPW1
	theReturn					: Integer;
	
	//cargoSubType				: CM_Product;					// ### TFS 54565 (54385) 19Sep2022 NAVPW1
	//commodity					: CM_Commodity;					// ### TFS 54565 (54385) 19Sep2022 NAVPW1
	allSelectedInvLineDescs		: CM_InvoiceLineDescSet;
	allSelectedCargoTypes		: CM_CargoTypeSet;				// ### TFS 54565 (54385) 15Sep2022 NAVPW1
	allSelectedCargoSubTypes	: CM_ProductSet;				// ### TFS 54565 (54385) 15Sep2022 NAVPW1
	allSelectedCommodities		: CM_CommoditySet;				// ### TFS 54565 (54385) 15Sep2022 NAVPW1
	allSelectedDebtors			: CM_DebtorSet;					// ### TFS 54565 (54385) 15Sep2022 NAVPW1
	applyGreaterThanAmount,
	surchargeAmount				: Decimal[23,3];				// ### TFS 54565 (54385) 15Sep2022 NAVPW1
	applyGreaterThanLineTotal	: Boolean;						// ### TFS 54565 (54385) 15Sep2022 NAVPW1
	validFrom,
	validTo						: TimeStamp;					// ### TFS 54565 (54385) 15Sep2022 NAVPW1
	
begin
	surchargeRate := self.txtSCTPercent.text.asDecimalJMT();
	surchargeAmount := self.txtSCTSurchargeFixAmnt.text.asDecimalJMT(); 	// ### TFS 54565 (54385) 21Sep2022 NAVPW1
	//cargoType := self.cmbSCTCargoType.listObject.CM_CargoType;			// ### TFS 54565 (54385) 19Sep2022 NAVPW1
	surInvLineType := self.cmbSCTInvLineType.listObject.CM_InvoiceLineDesc;
	//cargoSubType := self.cmbSCTSubCargoType.listObject.CM_Product;		// ### TFS 54565 (54385) 19Sep2022 NAVPW1
	//commodity := self.cmbSCTCommodity.listObject.CM_Commodity;			// ### TFS 54565 (54385) 19Sep2022 NAVPW1
	create allSelectedInvLineDescs transient;
	self.mulSCTInvLineTypes.getSelected( allSelectedInvLineDescs );
	
	if self.myCurrentInvTypeSurExempt = null then
		app.msgBox( app.getErrorString(Current_surcharge_exemptions), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	if surInvLineType = null then
		app.msgBox( app.getErrorString(Surcha_invoic_line_type_select), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	if self.myProxyCTSurRate = null then
		app.msgBox( app.getErrorString(Proxy_Object_Null_For_Update), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	//if surchargeRate &lt;= 0 then
	//if surchargeRate &lt;= 0 and surchargeAmount &lt;= 0 then 																// ### TFS 54565 (54385) 21Sep2022 NAVPW1	//navtnr20 19-04-2023 Bug 57644
	if (surchargeRate &gt;= 0  and surchargeAmount &gt;= 0) and  (surchargeRate &lt;= 0  and surchargeAmount &lt;= 0)then  //navtnr20 19-04-2023 Bug 57644
		//app.msgBox( app.getErrorString(Surch_rate_must_great_than_zer), app.getErrorString(Error), MsgBox_OK_Only );
		app.msgBox( app.getErrorString(Eithe_surch_rate_surch_amoun_m), app.getErrorString(Error), MsgBox_OK_Only ); 	// ### TFS 54565 (54385) 21Sep2022 NAVPW1
		return false;
	endif;
	
	 // ### TFS 54565 (54385) 19Sep2022 NAVPW1 - Commented out
	/*if cargoType = null then
//		app.msgBox( app.getErrorString(Select_cargo_type_continu), app.getErrorString(Error), MsgBox_OK_Only );
 // ### TFS 51219 03JUN2021 NAVAB1		return false;
	endif;*/
	 // ### TFS 54565 (54385) 19Sep2022 NAVPW1 - Commented out
	
	if allSelectedInvLineDescs.isEmpty then
		app.msgBox( app.getErrorString(Must_have_least_selec_invoi_li), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	elseif allSelectedInvLineDescs.includes( surInvLineType ) then
		app.msgBox( app.getErrorString(Select_not_incl_Inv_Line), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	// ### TFS 54565 (54385) 15Sep2022 NAVPW1
	create allSelectedCargoTypes transient;
	self.mulSCTCargoTypes.getSelected( allSelectedCargoTypes );
	
	create allSelectedCargoSubTypes transient;
	self.mulSCTSubCargoTypes.getSelected( allSelectedCargoSubTypes );	
	
	create allSelectedCommodities transient;
	self.mulSCTCommodities.getSelected( allSelectedCommodities );
	
	create allSelectedDebtors transient;
	self.mulSCTDebtors.getSelected( allSelectedDebtors );
	
	applyGreaterThanAmount := self.txtSCTSurchargeGrtrTh.text.asDecimalJMT();
	applyGreaterThanLineTotal := self.optSCTSurchargeLnTl.value;
	validFrom.setDate(self.txtSCTSurchargeFrmDte.text.asDate());
	validFrom.setTime(self.txtSCTSurchargeFrmTme.text.asTimeJMT());
	validTo.setDate(self.txtSCTSurchargeToDte.text.asDate());
	validTo.setTime(self.txtSCTSurchargeToTme.text.asTimeJMT());
	// ### TFS 54565 (54385) 15Sep2022 NAVPW1
	
	self.myProxyCTSurRate.setProxy(	allSelectedCargoTypes,			//_allCargoTypes			: CM_CargoTypeSet;
									allSelectedCargoSubTypes,		//_allCargoSubTypes			: CM_ProductSet;
									allSelectedCommodities,			//_allCommodities			: CM_CommoditySet;
									allSelectedDebtors,				//_debtors					: CM_DebtorSet;
									allSelectedInvLineDescs,		//_allSelectedInvLineDescs	: CM_InvoiceLineDescSet;
									applyGreaterThanAmount,			//_applyGreaterThanAmount	: Decimal;
									applyGreaterThanLineTotal,		//_applyGreaterThanLineTotal: Boolean;
									surchargeAmount,				//_surchargeAmount			: Decimal;
									surchargeRate,					//_surchargeRate			: Decimal;
									validFrom,						//_validFrom				: TimeStamp;
									validTo,						//_validTo					: TimeStamp;
									self.myCurrentInvTypeSurExempt,	//_mySurAndExempt			: CM_InvoiceTypeSurchargeExempt;
									surInvLineType					//_mySurInvLineType			: CM_InvoiceLineDesc
									);
									
	real := self.myProxyCTSurRate.pxyGetRealObject;
	
	while true do
		if real = null then
			//create a new one
			//app.myTrxCA.trxCreateCargoTypeSurRate( self.myProxyCTSurRate, real, app.myPassport );
			app.myTrxCA.trxCreateCargoTypeMultiSurRate( self.myProxyCTSurRate, real, app.myPassport );	// ### TFS 54565 (54385) 19Sep2022 NAVPW1
		else
			//update an existing one
			//app.myTrxUA.trxUpdateCargoTypeSurRate( self.myProxyCTSurRate, app.myPassport );
			app.myTrxUA.trxUpdateCargoTypeMultiSurRate( self.myProxyCTSurRate, app.myPassport ); 		// ### TFS 54565 (54385) 19Sep2022 NAVPW1
		endif;
	
		if app.myPassport.trxCompletedOK then
			return true;
			
		else
			theReturn := app.showErrorWarningDialog("Cargo Type Surcharge Rate", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		
		break;
	
	endwhile;

	return false;
	
epilog
	delete allSelectedCargoTypes;
	delete allSelectedCargoSubTypes;
	delete allSelectedCommodities;
	delete allSelectedInvLineDescs;
	delete allSelectedDebtors;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveSP" id="fbd45208-9da2-4c07-9c5b-ccd7ad5284de">
        <source>doSaveSP() : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/06/2018	jlgdap1		Initial creation TFS 39355 PEL1 Pilot Surcharge
//
vars
	notReadyLineType, tooSoonLineType : CM_InvoiceLineDesc;
	real : CM_InvTypePilotSurcharge;
	returnValue : Integer;

begin
	notReadyLineType := self.cmbSPNotReady.listObject.CM_InvoiceLineDesc;
	tooSoonLineType := self.cmbSPTooSoon.listObject.CM_InvoiceLineDesc;
	
	if self.myCurrentInvTypeSurExempt = null then
		app.msgBox( app.getErrorString(Current_surcharge_exemptions), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	if notReadyLineType = null then
		app.msgBox( app.getErrorString(Voyag_not_ready_invoi_line_typ), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	if tooSoonLineType = null then
		app.msgBox( app.getErrorString(Reque_soon_invoi_line_type_sel), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	if self.myProxySPCharges = null then
		app.msgBox( app.getErrorString(Proxy_Object_Null_For_Update), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	self.myProxySPCharges.setProxy(	self.myCurrentInvTypeSurExempt,	//_surcharges : CM_InvoiceTypeSurchargeExempt;
									notReadyLineType,	//_notReadyLineType : CM_InvoiceLineDesc;
									tooSoonLineType		//_tooSoonLineType : CM_InvoiceLineDesc;
									);
									
	real := self.myProxySPCharges.pxyGetRealObject;
	
	while true do
		if real = null then
			//create a new one
			app.myTrxCA.trxCreatePilotSurcharge( self.myProxySPCharges, real, app.myPassport );
		else
			//update an existing one
			app.myTrxUA.trxUpdatePilotSurcharge( self.myProxySPCharges, app.myPassport );
		endif;
	
		if app.myPassport.trxCompletedOK then
			return true;
		else
			returnValue := app.showErrorWarningDialog("Cargo Type Surcharge Rate", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and returnValue = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		
		break;
	endwhile;

	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveSurchargeExempt" id="735fc57a-8c94-4a20-9b25-defa0b36dd39">
        <source>doSaveSurchargeExempt():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 March 2018	jlgndl1	Initial creation	TFS 37818

*/

vars

	minimumCharge : Real;
	minChgInvLineType : CM_InvoiceLineDesc;
	real : CM_InvoiceTypeSurchargeExempt;
	proxy : CM_InvoiceTypeSurchargeExempt;
	load : Boolean;
	theReturn : Integer;
	currency : CM_CurrencyType;	//02 Nov 2018	NDL	TFS 41684
	taxExeInvType : CM_InvoiceDesc;	//07 May 2019	NDL	TFS 44651

begin

	minimumCharge := self.txtMinCharge.text.asRealJMT();
	if minimumCharge &gt; CM_InvoiceTypeSurchargeExempt.HighValue_15_2 then	//24 Apr 2018	NDL	TFS 37819 rework, and again 24 Jul 2019	NDL TFS 45509
		minimumCharge := CM_InvoiceTypeSurchargeExempt.HighValue_15_2;
	endif;
	minChgInvLineType := self.cmbMinChgLineType.listObject.CM_InvoiceLineDesc;
	currency := self.cmbCurrency.listObject.CM_CurrencyType;	//02 Nov 2018	NDL	TFS 41684
	taxExeInvType := self.cmbTaxExeInvType.listObject.CM_InvoiceDesc;	//07 May 2019	NDL	TFS 44651
	
	real := self.myCurrentInvTypeSurExempt;
	
	if real = null then
		create proxy transient;
	else
		app.cmsBeginLoad( load );
		proxy := real.pxyCreateUpdateProxy();
		app.cmsEndLoad( load );
	endif;
	
	proxy.setProxy(	minimumCharge, //_minimumChargeAmount : Real;
					self.myInvoiceType,	//_myInvoiceType : CM_InvoiceDesc;
					minChgInvLineType,	//_myMinimumChargeInvoiceLineType : CM_InvoiceLineDesc;
					currency,	//_myCurrencyType : CM_CurrencyType;
					taxExeInvType	//_taxExemptInvType : CM_InvoiceDesc
					);
					
	while true do
		if real = null then
			//create a new one
			app.myTrxCA.trxCreateInvTypeSurExempt( proxy, real, app.myPassport );
		else
			//update an existing one
			app.myTrxUA.trxUpdateInvTypeSurExempt( proxy, app.myPassport );
		endif;
	
		if app.myPassport.trxCompletedOK then
			return true;
			
		else
			theReturn := app.showErrorWarningDialog("Minimum Charge Invoice Line Type", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		
		break;
	
	endwhile;

	return false;
	

epilog

	delete proxy;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveVMC" id="2fffd995-4e95-4cfb-a036-a1f19e94f38b">
        <source>doSaveVMC():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2018	jlgndl1	Initial creation	TFS 38914

*/

vars

	minChg : Decimal[23,6];
	vessel : CM_Vessel;
	minChgLineType : CM_InvoiceLineDesc;
	real : CM_InvTypeVesselMinCharge;
	theReturn : Integer;

begin

	minChg := self.txtVMCMinCharge.text.asDecimalJMT();
	vessel := self.cmbVMCVessel.listObject.CM_Vessel;
	minChgLineType := self.cmbVMCInvLineType.listObject.CM_InvoiceLineDesc;
	
	if self.myCurrentInvTypeSurExempt = null then
		app.msgBox( app.getErrorString(Current_surcharge_exemptions), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	if minChgLineType = null then
		app.msgBox( app.getErrorString(Minim_charg_line_type_must_sel), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	if self.myProxyVMCharges = null then
		app.msgBox( app.getErrorString(Proxy_Object_Null_For_Update), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	if minChg &lt;= 0 then
		app.msgBox( app.getErrorString(Minim_charg_must_great_than_ze), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	if vessel = null then
		app.msgBox( app.getErrorString(Input_required_field_vesName), app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif;
	
	self.myProxyVMCharges.setProxy(	minChg,	//_minimumChargeAmount : Real;
									minChgLineType,	//_myMinimumChargeInvoiceLineType : CM_InvoiceLineDesc;
									vessel,	//_myVessel : CM_Vessel;
									self.myCurrentInvTypeSurExempt	//_mySurchargesAndExemptions : CM_InvoiceTypeSurchargeExempt
									);
									
	real := self.myProxyVMCharges.pxyGetRealObject;
	
	while true do
		if real = null then
			//create a new one
			app.myTrxCA.trxCreateVessMinimumChg( self.myProxyVMCharges, real, app.myPassport );
		else
			//update an existing one
			app.myTrxUA.trxUpdateVessMinimumChg( self.myProxyVMCharges, app.myPassport );
		endif;
	
		if app.myPassport.trxCompletedOK then
			return true;
			
		else
			theReturn := app.showErrorWarningDialog("Debtor Minimum Charge", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theReturn = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		
		break;
	
	endwhile;

	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTableSort" id="acb6da2f-4903-46b7-a2aa-3d195021302f">
        <source>doTableSort(_table: Table input; _sortType : Integer; _accessColumnIndex : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
21 April 2023	navmk20	Bug 57645: EUP -FR | 53978 - EUP - Invoicing -  Configuration Enhancements - Surcharges and Exemptions- Date ranges (From and to) mentioned in the column organizer

*/

vars

begin
	_table.accessColumn(_accessColumnIndex).sortOrder := 1;
	_table.accessedColumn.sortType := _sortType;
	_table.resort();
epilog

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
