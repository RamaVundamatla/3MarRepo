    <JadeMethod name="cmbVoyage_click" id="e99f48df-8b64-4602-85d1-7e41d9b3421d">
        <controlMethod name="ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbVoyage_click(combobox: ComboBox input) updating;
//-----------------------------------------
//
// Created : by cnwaer1 21 August 2008
//-----------------------------------------
begin
end;
/* Par 25124 moved to lostfocus
vars
	voyage :CM_Voyage;
	currentDischargePort : CM_Port;
begin

	voyage := combobox.listObject.CM_Voyage;
		
	if voyage.isNullVoyage then
		voyage:= null;
	endif;
	
	self.loadValidOptDischargePort(voyage);
	
	// Discharge port	
	currentDischargePort:=self.cmbDischargePort.listObject.CM_Port;
	self.cmbDischargePort.setObjectAndVoyage(currentDischargePort,voyage);
	self.cmbTranshipPort.setObjectAndVoyageDischPort(currentDischargePort,voyage);
	
	if voyage &lt;&gt; null then
		self.lblVoyageDisplay.caption := "  " &amp; voyage.vesselName &amp;"        "&amp; voyage.arrivedDT.asStringJMT;
		if self.chkReceiveAsStoc.value then
			self.btnExpBook.enabled := true;
			self.btnStockBook.enabled := false;
		else
			self.btnExpBook.enabled := false;
			self.btnStockBook.enabled := true;
		endif;
	else
		self.lblVoyageDisplay.caption := null;
		self.btnExpBook.enabled := false;
		self.btnStockBook.enabled := false;
	endif;

	//+cnwml2 MSL CCMS 1012
	if self.cmbVoyage.listObject = null then
		self.btnExpBook.enabled := false;
		self.btnStockBook.enabled := false;
	endif;
	
	self.loadCmbFromVoyage();
end;*/</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cmbVoyage_lostFocus" id="534d26d1-f8e3-4f28-b1f8-d678824da71f">
        <controlMethod name="CMUI_ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbVoyage_lostFocus(combobox: ComboBox input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 Jul 2010	cnwmd1	Initial creation
					par 25124 Moved from click for performance reasons
*/

vars
	voyage 				 : CM_Voyage;
	currentDischargePort : CM_Port;
begin

	voyage := combobox.listObject.CM_Voyage;
		
	if voyage &lt;&gt; null and voyage.isNullVoyage then
		voyage:= null;
	endif;
	
	self.loadValidOptDischargePort(voyage);
	
	// Discharge port	
	currentDischargePort:=self.cmbDischargePort.listObject.CM_Port;
	self.cmbDischargePort.setObjectAndVoyage(currentDischargePort,voyage);
	self.cmbTranshipPort.setObjectAndVoyageDischPort(currentDischargePort,voyage);
		
	if voyage &lt;&gt; null then
		self.lblVoyageDisplay.caption := "  " &amp; voyage.vesselName &amp;"        "&amp; self.systemToLocalTime(voyage.arrivedDT).asStringJMT;	// 13/7/16 cnwmp6 TFS 488 - Multi timezone support
		if self.chkReceiveAsStoc.value then
			self.btnExpBook.enabled := true;
			self.btnStockBook.enabled := false;
		else
			self.btnExpBook.enabled := false;
			self.btnStockBook.enabled := true;
		endif;
	else
		self.lblVoyageDisplay.caption := null;
		self.btnExpBook.enabled := false;
		self.btnStockBook.enabled := false;
	endif;

	//+cnwml2 MSL CCMS 1012
	if self.cmbVoyage.listObject = null then
		self.btnExpBook.enabled := false;
		self.btnStockBook.enabled := false;
	endif;
	
	self.loadCmbFromVoyage();
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="create" id="0c5e4c71-ba80-4732-a9d8-6d654c0f7b96">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>create() updating, clientExecution;
// 09/03/2010	cnwcs5 par 22605
vars

begin
	self.permissionView  := PmGteBookingRefView;	// par 22605
	self.permissionMaint := PmGteBookingRefMaint;	// par 22605
	self.permissionMaint := PmGteBookingRefNonPendMaint;
	
	create self.myCMIFBookingRef transient;
end;
</source>
    </JadeMethod>
    <JadeMethod name="delete" id="3da971be-f3c8-4313-9a05-8bd99deec0e7">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;

vars

begin
	// OK to use isValidObject as this is always transient
	if global.isValidObject(self.myCMIFBookingRef) then
		delete self.myCMIFBookingRef;
	endif;
	if global.isValidObject(self.myProxyReleaseRequest) then
		delete self.myProxyReleaseRequest;
	endif;
	if global.isValidObject(self.myProxyBookingRef) then
		delete self.myProxyBookingRef;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doDeleteBookingRefItem" id="c2e72aad-b62f-4c92-9a47-c0289a5dc612">
        <updating/>
        <source>doDeleteBookingRefItem() updating;
//-----------------------------------------
//
// Created : by cnwaer1 29 August 2008
//-----------------------------------------
vars

	pxyBookItem : CM_BookingRefItem;
	obj : Object;
	resDel : CM_ReserveDetail;
begin
	if self.tblBookingItems.row &gt; 1 and self.tblBookingItems.allSelectedObjects.size &gt; 0 then					
		if app.msgBox(app.getErrorString1(Lit_Confirm_Delete, "Item(s)"), app.getErrorString(Confirm_Delete), MsgBox_Yes_No) = MsgBox_Return_Yes then		//+cnwml2 PAR20164 SFW CCMS 1091
			foreach obj in self.tblBookingItems.allSelectedObjects do												//+cnwml2 PAR20164 SFW CCMS 1091						
				pxyBookItem := obj.CM_BookingRefItem;																//+cnwml2 PAR20164 SFW CCMS 1091									
			//	pxyBookItem := self.tblBookingItems.allSelectedObjects.first.CM_BookingRefItem;						//-cnwml2 PAR20164 SFW CCMS 1091
				if pxyBookItem &lt;&gt; null and self.myProxyBookingRef.allBookingRefItems.includes(pxyBookItem) then
					if self.myProxyBookingRef.allReleaseRequests.size &gt; 0 then
						foreach resDel in self.myProxyBookingRef.allReleaseRequests.first.allReserveDetails do
							if resDel.myBookingRefItem = pxyBookItem then
								delete resDel;
							endif;
						endforeach;
					endif;
					delete pxyBookItem;
					self.hasBookingRefItemChanged:=true;
				endif;
			endforeach;
			self.loadBookingItemTable();
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doEditBookingRefItem" id="2d8b5a7c-e411-4a75-8dc9-5a60da4bc587">
        <updating/>
        <source>doEditBookingRefItem(bookRefItem : CM_BookingRefItem; _isNewItem : Boolean ) updating;

//cnwjo3
//par 19840 CCMS 1079
//updated parameter bookRefItem from CM_BRefItemContainerto CM_BookingRefItem to work with containers and products
//added new parameter 'isNewItem' so that 'Next' works correctly since we need to create a non-null skeleton obj

// 11/03/2010	cnwcs5	par 22605 - Booking Reserve permission
// 11/06/2015	cnwdap1	PAR #36421 Changed signature of CM_TIHazard::setProxy
// 09/11/2016	cnwdap1	TFS 2842 Hazardous Details Enhancements
// 30/11/2016	cnwdap1	TFS 3058 Correct hazards handling
vars
	form 			: GTE_BookRequestItemForm;
	//pxyBookingRefItem : CM_BRefItemContainer;
	pxyBookingRefItem, bookingRefItem : CM_BookingRefItem;
	
	newPxyBookingRefItem : CM_BRefItemContainer;
	tiHaz ,newHaz	: CM_TIHazard;
	hazard			: CM_Hazard;
	dictHaz 		: CM_HazardByCodeDict;
	dictSpecialLift : CM_SpecialLiftByCodeDict;
	specialLift,
	newSpecialLift	: CM_SpecialLift;
	undgString 		: String;
	limitQ	,isNewItem		: Boolean;
	modalResult, selRow	: Integer;
	
	
	strArray : StringArray;
	str 	 : String;
	spLift : CM_SpecialLift;
	
	marinePol : Integer;					// TFS 2842
	 		
begin
	form := app.loadForm(GTE_BookRequestItemForm,
									self.myAssistant.class,
									false,
									false,
									false,
									self.myTerminal, null).GTE_BookRequestItemForm;
	//form.setMyCMIFBookingRefItem(bookRefItem);
	if bookRefItem &lt;&gt; null then
		form.setMyBooking(bookRefItem);
	endif;
		
	isNewItem := _isNewItem;
	
	if isNewItem then
		create pxyBookingRefItem as CM_BRefItemContainer transient;
		//create pxyBookingRefItem transient;
		if bookRefItem &lt;&gt; null then
			//let the looping on oneself begin
			pxyBookingRefItem.setCargoType(bookRefItem.cargoType);
			if pxyBookingRefItem.cargoType = TI_CargoType_Container then
				pxyBookingRefItem.setISOType(bookRefItem.isoType);
			else
				pxyBookingRefItem.setMyProduct(bookRefItem.myProduct);
			endif;
			
		endif;

		self.myProxyBookingRef.allBookingRefItems.add(pxyBookingRefItem);
	else
		pxyBookingRefItem:=bookRefItem;
	endif;
	
	//+cnwml2 PAR20164 SFW CCMS 1091 start
	if not self.chkNoEmptiesOut.value then
		form.lblMaxRel.enabled := false;
		form.txtMaxRel.enabled := false;
	else
		form.lblMaxRel.enabled := true;
		form.txtMaxRel.enabled := true;
	endif;
	//+cnwml2 PAR20164 SFW CCMS 1091 end
	
	form.setMyProxyBookingRefItem(pxyBookingRefItem);
	form.isNewItem:=isNewItem;
	form.width := 500;
	
	modalResult:=form.showModal;
	
	//if modalResult &lt;&gt; MB_OK then
	if modalResult = IDCANCEL then
		if isNewItem then
			delete pxyBookingRefItem;
		endif;
		return;
	endif;
	
	if not self.hasBookingRefItemChanged then
		 self.hasBookingRefItemChanged:=form.hasChanged;
	endif;
	self.loadBookingItemTable();	
	
	//-cnwml2 PAR20152 SFW CCMS 1091start
	if tblBookingItems.accessedRow.itemObject &lt;&gt; null then											
		//if tblBookingItems.accessedRow.itemObject.CM_BookingRefItem.cargoType = 1 then
		if tblBookingItems.accessedRow.itemObject.CM_BookingRefItem.cargoType = 1 and
		  tblBookingItems.accessedRow.itemObject.CM_BookingRefItem.getResDetailMaxToRelease &gt; 0  then	
			self.btnReserve.enabled := self.canReserve and self.canUpdate and 
									(self.canUpdateNonPendingBooking or
									(self.myCurrentBookingRef = null or
									self.myCurrentBookingRef.status = BOOKING_REF_PENDING));	// 11/03/2010 cnwcs5 par 22605
		else
			self.btnReserve.enabled := false;
		endif;
	endif;
	//+cnwml2 PAR20173 SFW CCMS 1091 end
	
	dictHaz := self.myProxyBookingRef.allTIHazards;
	foreach hazard in pxyBookingRefItem.allTIHazards do
		if dictHaz[hazard.code] = null then
			create newHaz transient;
			//newHaz.setProxy(hazard.code, hazard.description, hazard.CM_TIHazard.allUNDGCodes.asCSV(false),null,hazard.CM_TIHazard.limitedQuantity);									// PAR #36421
			//newHaz.setProxy(hazard.code, hazard.description, hazard.CM_TIHazard.allUNDGCodes.asCSV(false),null,hazard.CM_TIHazard.limitedQuantity,hazard.CM_TIHazard.packingGroup);	// TFS 2842
			newHaz.setProxy(	hazard.code,										// TFS 2842
								hazard.description,									// TFS 2842
								hazard.CM_TIHazard.allUNDGCodes.asCSV(false),		// TFS 2842
								null,												// TFS 2842
								hazard.CM_TIHazard.limitedQuantity,					// TFS 2842
								hazard.CM_TIHazard.packingGroup,					// TFS 2842
								hazard.CM_TIHazard.flashpointTemperature,			// TFS 2842
								hazard.CM_TIHazard.isMarinePollutant,				// TFS 2842
								hazard.CM_TIHazard.acidsBases	);					// TFS 2842
			dictHaz.add(newHaz);
		else
			tiHaz := dictHaz[hazard.code].CM_TIHazard;
			if hazard.CM_TIHazard.getUndgCodesAsString(false) &lt;&gt; null //25 Sep 2019	NDL	TFS 46633 - use full string not truncated version
			and not tiHaz.allUNDGCodes.includes(hazard.CM_TIHazard.getUndgCodesAsString(false)) then	//25 Sep 2019	NDL	TFS 46633 - use full string not truncated version
				undgString:= tiHaz.allUNDGCodes.asCSV(false) &amp;','&amp; hazard.CM_TIHazard.allUNDGCodes.asCSV(false);
				tiHaz.setUNDGCodes(undgString);
			endif;
			limitQ := tiHaz.limitedQuantity and hazard.CM_TIHazard.limitedQuantity;
			tiHaz.setLimitedQuantity(limitQ);
			marinePol := tiHaz.isMarinePollutant;											// TFS 2842
			tiHaz.setIsMarinePollutant(marinePol);											// TFS 2842
			tiHaz.setAcidsBases(hazard.CM_TIHazard.acidsBases);								// TFS 3058
			tiHaz.setFlashpointTemperature(hazard.CM_TIHazard.flashpointTemperature);		// TFS 3058
		endif;
	endforeach;
	
	
	self.lstHazards.loadHazardObjects;
	self.lstHazards.setSelectedFromObject(self.myProxyBookingRef);
	self.closeLstAndDisplayTxtHazards();
	
	foreach specialLift in self.myProxyBookingRef.allSpecialLifts do 
		self.myProxyBookingRef.allSpecialLifts.remove(specialLift);
	endforeach;
	
	dictSpecialLift := self.myProxyBookingRef.allSpecialLifts;
	
	foreach bookingRefItem in myProxyBookingRef.allBookingRefItems do
		foreach specialLift in bookingRefItem.allSpecialLifts do
			create newSpecialLift transient;
			newSpecialLift.setProxy(specialLift.code, specialLift.description);
			dictSpecialLift.addNoDuplicates(specialLift, false); //cnwrd1 changed to addNoDuplicates , par 21144 , 9/10/09
		endforeach;
	endforeach;
	
	myAssistant.listTableSpecialLift(self.lstSpecialLift);
	create strArray transient;
	foreach spLift in myProxyBookingRef.allSpecialLifts do
		strArray.add(spLift.code);
	endforeach;
	myAssistant.setListTableSpecialLift(self.lstSpecialLift, strArray);
	str := self.lstSpecialLift.getSelectedString('code');
	if str.length &gt; 30 then
		self.txtSpecialLift.text := str[1:29]&amp; '...';
	else
		self.txtSpecialLift.text := str;
	endif;
	
	self.tblBookingItems.findObjectInRow(pxyBookingRefItem,selRow);
	
	if selRow &gt; 1 then
		self.tblBookingItems.row:=selRow;
	endif;
	
	if modalResult = IDNEXT then
	//if clicked 'Next' then recall oneself and set up skeleton objs
		create newPxyBookingRefItem transient;
		newPxyBookingRefItem.setCargoType(pxyBookingRefItem.cargoType);
        if newPxyBookingRefItem.cargoType = TI_CargoType_Container then
            newPxyBookingRefItem.setISOType(pxyBookingRefItem.isoType);
        else
            newPxyBookingRefItem.setMyProduct(pxyBookingRefItem.myProduct);
        endif;
		
		self.doEditBookingRefItem(newPxyBookingRefItem,true);
		delete newPxyBookingRefItem;  //remove after save,next or cancel
	endif;

epilog
	delete strArray;	// PAR #18009
	
end;
</source>
        <Parameter name="bookRefItem" type="CM_BookingRefItem"/>
        <Parameter name="_isNewItem" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doEnquireOnBooking" id="029034da-77ca-4695-a938-bbf229cc6f01">
        <updating/>
        <source>doEnquireOnBooking() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 November 2008	cnwer1	Initial creation

*/

vars
	operator : CM_Operator;
	voyage 	: CM_Voyage;
	operatorCode : String;
	foundBookingRef : CM_BookingRef;
	bookingRefCode : String;
	

begin
	bookingRefCode:=self.txtBookingRef.text.trimBlanks;
	if bookingRefCode = null then
		return;
	endif;
	
	if self.myProxyBookingRef &lt;&gt; null and bookingRefCode = self.myProxyBookingRef.bookingReference then
		return;
	endif;
	
	foundBookingRef:=self.myTerminal.getBookingReference(operatorCode,bookingRefCode,voyage);
	
	if foundBookingRef  &lt;&gt; null then
		self.clearDetails();
		self.setMyBookingRefReq(foundBookingRef);
		self.loadBooking();
		self.loadBookingItemTable();
	else
		app.msgBox(app.getErrorString1(Err_No_Booking_Found,bookingRefCode),bookingRefCode,MsgBox_OK_Only);
	endif;
	 
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuColumnOrganiserClick" id="5991b9a2-0dcc-4d62-b393-864e43957b41">
        <updating/>
        <source>doMnuColumnOrganiserClick(menuItem : MenuItem) updating;
//-----------------------------------------
//
// Created : by cnwaer1 01 September 2008
//-----------------------------------------
vars

begin

	//epr par 33900 4/4/14 measurement columns now handled on column orgainser form
	self.tblBookingItems.showColumnOrganiserFrm(self.myTerminal, null);
	setFieldAlignmentOnTable(self.tblBookingItems);
epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem"/>
    </JadeMethod>
    <JadeMethod name="doMnuFormContextMenu" id="39c92298-2b81-410f-a476-22fa49472296">
        <updating/>
        <source>doMnuFormContextMenu(table : CM_DataTable input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
//-----------------------------------------
//
// Created : by cnwaer1 01 September 2008
//-----------------------------------------
vars
	isShowDataMenus		: Boolean;
	isDataValidRow		: Boolean;
	x1, y1				: Real;
begin
	isShowDataMenus	:=	(table = self.tblBookingItems);
	
	self.mnuColumnOrganiser.visible := (table = self.tblBookingItems);
	self.mnuColumnOrganiser.userObject := table;
	
	if isShowDataMenus then
		isDataValidRow	:=	(self.tblBookingItems.row &gt; self.tblBookingItems.fixedRows);
	endif;
	
	if app.isAllowedToInspect() then
		self.mnuSeparator.visible := true;									//+cnwml2 PAR19782 CCMS SFW 1079
		self.mnuTblInspectObject.visible	:=	true;
	else
		self.mnuSeparator.visible := false;									//+cnwml2 PAR19782 CCMS SFW 1079
		self.mnuTblInspectObject.visible	:=	false;
	endif;
		
	
	self.setupContextMenuItems(table);

	x1	:=	x;
	y1	:=	y;
	
	if (not mouse) then  // if keyboard, use current listIndex value
	    x1	:=	1;
	    y1	:=	1;
	endif;

	table.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
	self.popupMenu(mnuTblViewContext, x1.Integer, y1.Integer);
	return false;
end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doMnuShowPrenoted" id="bfdb3cb3-617e-41c5-ba4a-37f4d154987b">
        <source>doMnuShowPrenoted()protected;
// 25 Aug 2009	cnwml2
// 18 Jun 2013	cnwcs5	par 31670
// 24 Jul 2023	navma1	ChangeRequest 59275: MTN - Transport Mode should be used to filter prenotes
vars
	selectedColl,
	itemColl 	: ObjectArray;
	obj 		: Object;								
	
begin
	selectedColl := self.tblBookingItems.allSelectedObjects;
	
	if selectedColl.size = 0 then
		return;
	endif;
	
	create itemColl transient;
	
	foreach obj in selectedColl do											//+cnwml2 PAR19782 CCMS SFW 1079			
		obj.CM_BookingRefItem.getPrenotedTrackedItems (itemColl,null);		//24.07.2023 navma1 #59275
	endforeach;																												

	self.myAssistant.showCargoEnquiryForTIs(itemColl.first.CM_TrackedItem, itemColl, self.myMasterMenuAction, false);
epilog
	delete itemColl;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMnuShowReceived" id="f6d6c7b1-550e-46dd-9c40-5aa3aab476d1">
        <source>doMnuShowReceived()protected;
//-----------------------------------------
// Created : by cnwaer1 01 September 2008
//-----------------------------------------
// 13/06/2013	cnwcs5	par 31670 
vars
	selectedColl,
	itemColl 	: ObjectArray;
	ti 			: CM_TrackedItem;
	obj 		: Object;								
	
begin
	selectedColl := self.tblBookingItems.allSelectedObjects;
	
	if selectedColl.size = 0 then
		return;
	endif;
	
	create itemColl transient;
	
	foreach obj in selectedColl do																														//+cnwml2 PAR19782 CCMS SFW 1079			
		obj.CM_BookingRefItem.getReceivedTrackedItems (itemColl);
	endforeach;																																			//+cnwml2 PAR19782 CCMS SFW 1079

	self.myAssistant.showCargoEnquiryForTIs(itemColl.first.CM_TrackedItem, itemColl, self.myMasterMenuAction, false);									//+cnwml2 PAR19782 CCMS SFW 1079
epilog
	delete itemColl;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMnuShowReleased" id="604f475a-ed0e-4982-a1ba-53badcac6709">
        <source>doMnuShowReleased();
//-----------------------------------------
//
// Created : by cnwaer1 01 September 2008
//-----------------------------------------
vars
	
	realObj,pxyBookItem : CM_BookingRefItem;
	resDtl : CM_ReserveDetail;
	tiArray : ObjectArray;
	ti 		: CM_TrackedItem;
	obj		: Object;							//+cnwml2 PAR19782 CCMS SFW 1079
begin
	create tiArray transient;
	if self.tblBookingItems.allSelectedObjects.size &gt; 0 then
	//	pxyBookItem := self.tblBookingItems.allSelectedObjects.first.CM_BookingRefItem;									//-cnwml2 PAR19782 CCMS SFW 1079	
		foreach obj in self.tblBookingItems.allSelectedObjects do														//+cnwml2 PAR19782 CCMS SFW 1079
			pxyBookItem := obj.CM_BookingRefItem;																		//+cnwml2 PAR19782 CCMS SFW 1079
			if pxyBookItem &lt;&gt; null then
				realObj := app.myProxyManager.getRealObject(pxyBookItem).CM_BookingRefItem;
				if realObj &lt;&gt; null then
					// set fields from Reserve Details
					resDtl := realObj.myReserveDetail;
					if resDtl &lt;&gt; null then
						if resDtl.allTrackedItemsReleased.size &gt; 0 then
							foreach ti in resDtl.allTrackedItemsReleased do
								tiArray.add(ti);
							endforeach;
							//self.myAssistant.showCargoEnquiryForTIs(tiArray.first.CM_TrackedItem, tiArray, self.myMasterMenuAction, false);						//-cnwml2 PAR19782 CCMS SFW 1079
						endif;
					endif;
				endif;
			endif;
		endforeach;																																					//+cnwml2 PAR19782 CCMS SFW 1079
		self.myAssistant.showCargoEnquiryForTIs(tiArray.first.CM_TrackedItem, tiArray, self.myMasterMenuAction, false);												//+cnwml2 PAR19782 CCMS SFW 1079
	endif;
epilog
	delete tiArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuShowReserved" id="4cb8980f-63af-4d6a-b59c-42f81e2773b2">
        <source>doMnuShowReserved();
//-----------------------------------------
//
// Created : by cnwaer1 01 September 2008
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
//-----------------------------------------
vars

	realObj,pxyBookItem : CM_BookingRefItem;
	resDtl : CM_ReserveDetail;
	tiArray : ObjectArray;
	ti 		: CM_TrackedItem;
	obj		: Object;												//+cnwml2 PAR19782 CCMS SFW 1079
begin
	create tiArray transient;
	if self.tblBookingItems.allSelectedObjects.size &gt; 0 then
		//pxyBookItem := self.tblBookingItems.allSelectedObjects.first.CM_BookingRefItem;											//-cnwml2 PAR19782 CCMS SFW 1079
		foreach obj in self.tblBookingItems.allSelectedObjects do																	//+cnwml2 PAR19782 CCMS SFW 1079
			pxyBookItem := obj.CM_BookingRefItem;																					//+cnwml2 PAR19782 CCMS SFW 1079
			if pxyBookItem &lt;&gt; null then
				resDtl := pxyBookItem.myReserveDetail;
				if resDtl &lt;&gt; null then
					/* //23/06/2023	navkc1	CR 58406 Task 58408
					if resDtl.allTrackedItems.size &gt; 0 then
						foreach ti in resDtl.allTrackedItems do
							tiArray.add(ti);
						endforeach;
						//self.myAssistant.showCargoEnquiryForTIs(tiArray.first.CM_TrackedItem, tiArray, self.myMasterMenuAction, false);							//-cnwml2 PAR19782 CCMS SFW 1079
					endif;
					*/
					resDtl.getAllTrackedItems(tiArray, false); //23/06/2023	navkc1	CR 58406 Task 58408
				endif;
			endif;
		endforeach;																																					//+cnwml2 PAR19782 CCMS SFW 1079
		self.myAssistant.showCargoEnquiryForTIs(tiArray.first.CM_TrackedItem, tiArray, self.myMasterMenuAction, false);												//+cnwml2 PAR19782 CCMS SFW 1079
	endif;
epilog
	delete tiArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuViewItemAudit" id="8456ebaf-bf46-4d58-88ae-27920f12bc57">
        <source>doMnuViewItemAudit();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 September 2016	cnwma1	Initial creation

*/

vars
	form 	: GTE_BookRefReserveItemsForm;
	modalResult 	: Integer;
	br				: CM_BulkRelease;
	brItem ,realBrItem		: CM_BookingRefItem;
	row : Integer;
begin

row := self.tblBookingItems.row;
	
	if row &gt; 1 then
		brItem := self.tblBookingItems.accessRow(row).itemObject.CM_BRefItemContainer;	
	endif;
	if brItem &lt;&gt; null then
		realBrItem :=brItem.pxyGetRealObject();
	endif;
	
	app.viewAuditForm(realBrItem.CM_BookingRefItem, self.myAssistant.class, self.myTerminal);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doRemarksChange" id="1bb08f00-a14e-4d6a-a0ca-1e7a06473b40">
        <source>doRemarksChange();
/*

