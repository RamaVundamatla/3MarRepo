    <JadeMethod name="doTblDataDragDrop" id="86acc3a6-c0d9-4888-8f39-f523b0f2a59a">
        <updating/>
        <source>doTblDataDragDrop(table: Table input; win: Window input; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
