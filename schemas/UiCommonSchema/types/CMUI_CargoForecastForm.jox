    <JadeMethod name="setCmbForEdit" id="7e90a138-9b5d-4416-96c9-c8732afd7053">
        <updating/>
        <source>setCmbForEdit(_obj : CM_Object)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2022	navak20	Initial creation	TFS 53142 Cargo Forecast on Voyage &amp; Train

*/

vars
	pxyCargoForecast : CM_CargoForecast;
	commodity : CM_Commodity;
	cargoType : CM_CargoType;
	operator : CM_Operator;
	mode	: String;
begin
		if self.cmbCargoType.listIndex &lt;&gt; -1 then
			cargoType := self.cmbCargoType.itemObject[self.cmbCargoType.listIndex].CM_CargoType;
		endif;
		if self.cmbCommodity.listIndex &lt;&gt; -1 then
			commodity := self.cmbCommodity.itemObject[self.cmbCommodity.listIndex].CM_Commodity;
		endif;
		if self.cmbOperator.listIndex &lt;&gt; -1 then
			operator := self.cmbOperator.itemObject[self.cmbOperator.listIndex].CM_Operator;
		endif;
	
		if self.cmbMode.listIndex &lt;&gt; -1 then
			mode := self.cmbMode.itemText[self.cmbMode.listIndex].String;
		endif;
		
		create pxyCargoForecast transient;	
		pxyCargoForecast := app.createUpdateProxy(_obj).CM_CargoForecast;
		pxyCargoForecast.setProxyForUpdate(cargoType,
		commodity,
		mode,
		operator,
		self.txtQuantity.text.Integer,
		self.txtCargoWeight.getConvertedValue,
		self.txtCargoVolume.getConvertedValue,
		self.myObject);
		
		app.myTrxUA.trxUpdateCargoForecast(pxyCargoForecast, app.myPassport);
epilog
	delete pxyCargoForecast;
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setFieldAlignmentOnTable" id="ae02a685-8e73-42b7-83f2-37114c19c07b">
        <source>setFieldAlignmentOnTable(_table : CM_DataTable io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2022	navtnr20	Initial creation	TFS 53142 Cargo Forecast on Voyage &amp; Train

*/

vars
	entRowArray : StringArray;
	entRow : String;
	align : Integer;
	entRowColumn : Integer;
begin
	create entRowArray transient;
	entRowArray.add(ETRow_CommodityGroup);
	entRowArray.add(ETRow_Operator);
	entRowArray.add(ETRow_ImexStatus);
	entRowArray.add(ETRow_Quantity);
	entRowArray.add(ETRow_Weight);
	entRowArray.add(ETRow_Volume);
	
	align := Table.Alignment_Left;
	foreach entRow in entRowArray do
		if _table.getEntRowColumnByRowName(entRow, entRowColumn) &lt;&gt; null then
			_table.accessColumn(entRowColumn).alignment := align;
		endif;
	endforeach;
epilog
	delete entRowArray;
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="io"/>
    </JadeMethod>
