    <JadeMethod name="listSelectChildItems" id="19f1fdf2-737f-4448-8429-56f604d1018f">
        <source>listSelectChildItems(pTheListbox:ListBox; pListPointer:Integer) protected;
// --------------------------------------------------------------------------------
// Created:		22 January 2003 by cnwdad1
//
// Purpose:		This method will select all child nodes of the specified item index,
//				and then deselect the parent node.
//
// Parameters:	pTheListbox - The control containing the list hierarchy.
//				pListPointer - The item index of the parent node.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	childPointer	: Integer;
	listSize		: Integer;
	parentLevel		: Integer;
	
begin
	listSize	:=	pTheListbox.listCount();
	parentLevel	:=	pTheListbox.itemLevel[pListPointer];
	
	foreach childPointer in (pListPointer + 1) to listSize do
		if pTheListbox.itemLevel[childPointer] &lt;= parentLevel then
			break;
		endif;
		
		pTheListbox.itemSelected[childPointer]	:=	true;
	endforeach;
	
	pTheListbox.itemSelected[pListPointer]	:=	false;
end;</source>
        <access>protected</access>
        <Parameter name="pTheListbox" type="ListBox"/>
        <Parameter name="pListPointer" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="lstProducts_click" id="092f244c-b8fa-4e19-8ade-01fe55d12592">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstProducts_click(listbox: ListBox input) updating;
// --------------------------------------------------------------------------------
// Created:		22 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listPointer	: Integer;
	
begin
	if listbox.listIndex &lt;&gt; JSS_NULL_INDEX then
		// If a product is selected (item level "1", then select all of it's child nodes.
		listPointer	:=	listbox.listIndex;
		
		if listbox.itemLevel[listPointer] = 1 then
			self.listSelectChildItems(listbox, listPointer);
		endif;
	endif;
	
	self.doEnableControls();
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lstProducts_mouseUp" id="4f60ee64-3acf-491d-a5b4-43d801c85f3a">
        <controlMethod name="ListBox::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstProducts_mouseUp(listbox: ListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// --------------------------------------------------------------------------------
// Created:		24 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	listSize	: Integer;
	listPointer	: Integer;
	
begin
	if shift.bitAnd(1) &lt;&gt; 0 then
		// Deselect any level "1" list entries.  Only Level "2" items (Components)
		// should be selected.  This piece of code circumvents the problem where a
		// user does a multi-select by selecting one list item, then holds down the
		// shift key to select a range of lost entries with another mouse click.
		listSize	:=	listbox.listCount();
		
		foreach listPointer in 1 to listSize do
			if listbox.itemLevel[listPointer] = 1
			and listbox.itemSelected[listPointer]
			then
				listbox.itemSelected[listPointer]	:=	false;
			endif;
		endforeach;
	endif;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="lstProducts_pictureClick" id="38d8ce8b-67d9-4582-b587-dee7b8e64355">
        <controlMethod name="ListBox::pictureClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstProducts_pictureClick(listbox: ListBox input; picIndex: Integer; whatClicked: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		22 January 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	listbox.itemExpanded[picIndex]	:=	(not listbox.itemExpanded[picIndex]);
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="picIndex" type="Integer"/>
        <Parameter name="whatClicked" type="Integer"/>
    </JadeMethod>
