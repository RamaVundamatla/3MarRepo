    <JadeMethod name="verifyEDIDataTIs" id="0189efe7-13cf-4140-a290-b978b3f34b2f">
        <updating/>
        <source>verifyEDIDataTIs(_passport: CM_Passport input): Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Jun 2023	jlirs1	Initial creation
19 Jun 2023	navra1	57808 - EUP - Manifest Processing - Train - Create
27 Jun 2023	navdap1	TFS 58813 EUP Mainfest Instructions and corrections
02 Aug 2023 navra1  TFS 59591 - EUP - Train Create
*/

vars
	ediData : CM_EDIData;
	editi : CM_EDITrackedItem;
	errorSet : CM_ErrorSet;
begin	
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, _passport);
	app.setContinueCMExceptions(true);

	if self.myCargoOnSite &lt;&gt; null then
		self.myCargoOnSite.verifyEDIDataTIs(_passport);
		ediData := self.myCargoOnSite;
	elseif self.myGateDocument &lt;&gt; null then
		self.myGateDocument.verifyEDIDataTIs(_passport);
		ediData := self.myGateDocument;
	elseif self.myShipManifest &lt;&gt; null then
		self.myShipManifest.verifyEDIDataTIs(_passport);
		ediData := self.myShipManifest;
	elseif self.myTrainConsist &lt;&gt; null then
		//navra1 - TFS 59591 - 2nd Aug 2023 - start
		foreach editi in self.myTrainConsist.allEDITrackedItems do
			editi.verifySelf();
		endforeach;
		create errorSet transient;
		_passport.moveErrorsToSet(errorSet);
		//navra1 - TFS 59591 - 2nd Aug 2023 - end
		self.myTrainConsist.verifyEDIDataTIs(_passport);
		ediData := self.myTrainConsist;
		_passport.addErrorsFromSet(errorSet);
	endif;
	if ediData &lt;&gt; null then
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(self, ediData.status);
	endif;
	
	return app.myPassport.allErrorWarnings.size;
epilog
	delete errorSet;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
