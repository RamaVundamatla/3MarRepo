    <JadeMethod name="dragDrop" id="d105d4d0-9fba-4e39-830c-a875505f1bf0">
        <updating/>
        <source>dragDrop(pict: CnEcAppGridStatusPicture input; win: Window input; x: Real; y: Real) updating;

vars

begin
	if win.isKindOf(CnEcAppGridAppLabel) then
		parent.CnEcAppGridStatusLabel.dragDrop(parent.CnEcAppGridStatusLabel, win, left + x, top + y);
	endif;
end;</source>
        <Parameter name="pict" type="CnEcAppGridStatusPicture" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
