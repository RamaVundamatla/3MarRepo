    <JadeMethod name="isSourceAMachine" id="df2acf6d-7687-4436-8088-c031204da369">
        <source>isSourceAMachine() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2010	cnwer1	Initial creation

*/

vars
	pickupTask,
	nextTask		: CM_RTQueueTask;
begin
	pickupTask:=self.findTaskOfType(TASK_PICKUP,NULL_INTEGER);
	
	if pickupTask = null then
		return false;
	endif;
	
	nextTask:=self.getPreviousEntryFirstTask;

	if nextTask &lt;&gt; null then
		//if entry is for IMV then get the source lc of ti and then get the lane controller
		if self.machineTypeGroup &lt;&gt; MACHINETYPEGRP_IMV then
		//   the source task expects to be setdown on IMV and not an IMVs entry
			if pickupTask &lt;&gt; null and pickupTask.machineTypeGroup  = MACHINETYPEGRP_IMV then
				if nextTask.taskType = TASK_MOVE then
					return true;
				endif;
			endif;
		endif;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTargetAMachine" id="18a11585-760a-49b5-8211-6b49cab3e7be">
        <source>isTargetAMachine() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2010	cnwer1	Initial creation

*/

vars
	setdownTask,
	nextTask		: CM_RTQueueTask;
begin
	setdownTask:=self.findTaskOfType(TASK_SETDOWN,NULL_INTEGER);
	
	if setdownTask = null then
		return false;
	endif;
	
	
	nextTask:=self.getNextEntryFirstTask;
	
	
	
	
	if nextTask &lt;&gt; null then
		//if entry is for IMV then get the source lc of ti and then get the lane controller
		if self.machineTypeGroup &lt;&gt; MACHINETYPEGRP_IMV then
		//   the source task expects to be setdown on IMV and not an IMVs entry
			if setdownTask &lt;&gt; null and setdownTask.machineTypeGroup  = MACHINETYPEGRP_IMV then
				if nextTask.taskType = TASK_MOVE then
					return true;
				endif;
			endif;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isWorking" id="33e7cf27-cdd2-459f-9da3-df25c76b4532">
