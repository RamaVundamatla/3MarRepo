end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="830e6f7e-f51d-4351-86dd-81b94c5445be">
        <source>setupThumbnailDetails();
// ---------------------------------------------------------------------------
// Created:     23 July 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theForm : SOP_TableMaintForm;
begin
  
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_ShippingAgentTbl);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_ShippingAgentMaint);
	theForm.shtTblInput1.visible := true;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="a03159dd-e750-48db-8ae5-cba43c095d82">
        <updating/>
        <source>showThumbnail(pObj: CM_ShippingAgent) updating;
// ---------------------------------------------------------------------------
// Created:     23 July 2002 by cnwdf1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	theForm : SOP_TableMaintForm;

begin
  
    theForm := self.myForm;
	theForm.tblInput1.clearValues;
	theForm.tblInput1.setValueByName(ETRow_Code, pObj.code);
	theForm.tblInput1.setValueByName(ETRow_Description,	pObj.description);
	theForm.tblInput1.setValueByName(ETRow_NotAvailableForEntry, pObj.notAvailableForEntry);
	theForm.mulSelect1.setSelected(pObj.allContacts);	
	self.disableMulSelect1Contents();
end;</source>
        <Parameter name="pObj" type="CM_ShippingAgent"/>
    </JadeMethod>
</Class>
