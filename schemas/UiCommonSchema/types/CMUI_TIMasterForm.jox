    <JadeMethod name="buildMasterTIMenu" id="e342c135-fd39-4dca-a99a-c6cb00484cea">
        <updating/>
        <source>buildMasterTIMenu( _theTIMaster : CM_TIMaster input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
03 September 2008	cnwrd1	Initial creation
17/06/2010			cnwcs5	par 24342 - no context menu for stops
*/

vars

begin

	
	self.mnuTIMaster.visible := true;

	
	if _theTIMaster.isContainer then
		self.mnuTIMaster.caption := '&amp;' &amp; app.getErrorString(ISO_Container);
	elseif _theTIMaster.isTILC then
		self.mnuTIMaster.caption := '&amp;' &amp; app.getErrorString(Trailer);
	elseif _theTIMaster.isGenerator then
		self.mnuTIMaster.caption := '&amp;' &amp; app.getErrorString(CM_Generator_GC);
	endif;
	
	self.mnuTblVViewAudits.visible	:=	true;
	
	self.doBuildMnuViewTis();
	
	if self.myCurrentTiMaster &lt;&gt; null
	and self.myCurrentTiMaster.isKindOf(CM_TIMaster)
	and self.myCurrentTiMaster.CM_TIMaster.hasAudits
	then
	  // app.myAA.isAnAuditedClass(self.myDataClass) then
		self.mnuTblVViewAudits.caption	:=	"View Audits for " &amp; self.myCurrentTiMaster.CM_TIMaster.auditIdDisplay;
		self.mnuTblVViewAudits.enabled	:=	true;
		self.mnuTblVViewAudits.visible	:=	true;
	endif;
	
	self.doBuildMnuTasksAdd(self.mnuAddTask, _theTIMaster);	

	self.doBuildMnuTasksRemove(self.mnuRemoveTasks, _theTIMaster);	

	// par 24342 self.doBuildMnuStops(self.mnuStops, _theTIMaster);		
epilog

end;</source>
        <Parameter name="_theTIMaster" type="CM_TIMaster" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buildMasterWagonMenu" id="e6145d83-8bf6-4904-a215-8175e324670d">
        <updating/>
        <source>buildMasterWagonMenu() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 July 2009	cnwndl1	Initial creation

*/

vars

begin

	self.mnuTIMaster.visible := false;

	self.mnuShowAll.visible := false;
	self.mnuShowOnSite.visible := false;
	self.mnuShowReal.visible := false;
	self.mnuTblVViewAudits.visible	:=	false;
	
	self.mnuAddTask.visible := false;
	self.mnuRemoveTasks.visible := false;
	self.mnuStops.visible := false;
	
epilog

end;</source>
