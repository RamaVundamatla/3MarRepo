    <JadeMethod name="createUpdateProxy" id="ddb12810-3a59-4c08-bca4-4f7fee9dc59f">
        <updating/>
        <source>createUpdateProxy()updating;
// ---------------------------------------------------------------------------
// Created:		January 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
vars
	ls : Boolean;
begin
	if self.myProxyVoyage &lt;&gt; null then
		delete self.myProxyVoyage;
	endif;
	app.cmsBeginLoad(ls);
	self.myProxyVoyage := app.createUpdateProxy(self.myCurrentVoyage).CM_Voyage;
	self.myCurrentVoyage.myCellularVoyageStructure.pxyCreateUpdateProxyStructure(self.myProxyVoyage.myCellularVoyageStructure);
	self.myCurrentVoyage := self.myProxyVoyage;
epilog			// 08/04/2011 cnwmh5 #27347
	app.cmsEndLoad(ls);
end;</source>
    </JadeMethod>
    <JadeMethod name="displayAftBayEnableDisable" id="7d9b3675-52d6-4540-89d2-5fd18297783b">
        <source>displayAftBayEnableDisable(_enable : Boolean);
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	/*self.txtUnderDeckCell.readOnly := (not _enable);
	self.txtOnDeckCells.readOnly := (not _enable);
	self.txtUnderDeckTier.readOnly := (not _enable);
	self.txtOnDeckTier.readOnly := (not _enable);*/
	self.cmbBayType.enabled := _enable;

	if self.mode = Mode_View then
		/*self.txtUnderDeckCell.readOnly := true;
		self.txtOnDeckCells.readOnly := true;
		self.txtUnderDeckTier.readOnly := true;
		self.txtOnDeckTier.readOnly := true;*/
		self.cmbBayType.enabled := false;
	endif;
end;</source>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayBayDetails" id="74697003-f371-4bb3-9c0c-707619c432e7">
        <updating/>
        <source>displayBayDetails(_theBay : CM_Bay) updating;
//-----------------------------------------
// Changed: November 2005 By: cnwgd1
//-----------------------------------------
vars

	theRowName : String;
	theTierOrder : String;
	theHiCubes,theString : String;
	theFwdBay : CM_Bay;
	theOrdinalHold,idx : Integer;
	theReturn : Integer;
	useDefaultAft : Boolean;
	structure : CM_CellularVoyageStructure;		
begin

	self.setCaption(self.cmbVoyage.text &amp; ' ' &amp; self.Caption);	
	self.myCurrentBay := _theBay;
	if _theBay = null
	or (not global.isValidObject(_theBay)) then
		self.myCurrentBay := null;		
		self.clearBayData();
		return;
	endif;

	if self.myCurrentVoyage &lt;&gt; null then
		structure := self.myCurrentVoyage.myCellularVoyageStructure;
	endif;
		
	self.txt40FootBayID.enabled := true;
	self.currentBayEdition := _theBay.edition;
	
	self.shtBayDetails.caption := "Bay " &amp; _theBay.id &amp; " Details (1 of 1)";
	self.shtBayLayout.caption := "Bay " &amp; _theBay.id &amp; " Layout";

	// Draw The Bay Layout
	self.doBuildComboBay(self.cmbBayLayout); // this will clear out the selected bays for hatch lid
	self.doDrawBay();
	
	self.displayDataForBay(_theBay, false, false);	
			
	theHiCubes := _theBay.getAllCellsHiCubeHeightsString();
	self.txtUDCellsHiCub.text := theHiCubes;
	
	theOrdinalHold := structure.allHolds.indexOf(_theBay.myHold);
	if theOrdinalHold &gt; 0 then
		self.cmbHolds.listIndex := theOrdinalHold;
	else
		self.cmbHolds.listIndex := -1;
	endif;

	theFwdBay := self.myCurrentBay.myForwardBay;

	useDefaultAft := false;
	if theFwdBay &lt;&gt; null then

		if theFwdBay.bayType = BAY_TYPE_TRIPLE then
			useDefaultAft := false;
			//if theFwdBay.myHold.allBays.last = theFwdBay  and (theFwdBay.idBay40.trimBlanks &lt;&gt; null) then
			if (theFwdBay.idBay40.trimBlanks &lt;&gt; null) 
			and (self.myCurrentBay.myHold = theFwdBay.myHold) then
				if theFwdBay.canHandle4045()  then 
					useDefaultAft := true;
				endif;
			endif;
		elseif theFwdBay.bayType = BAY_TYPE_TWIN then
			if theFwdBay.myHold.allBays.last = theFwdBay then
				if (theFwdBay.canHandle4045() and (theFwdBay.idBay40.trimBlanks &lt;&gt; null))
				and (self.myCurrentBay.myHold = theFwdBay.myHold) then 
					useDefaultAft := true;
				endif;
			else
				useDefaultAft := true;
			endif;
		else
			useDefaultAft := false;
		endif;
	endif;	

	if useDefaultAft then
		if theFwdBay.bayType = BAY_TYPE_SINGLE then
			self.shtBayDetails.caption := "Bay " &amp; _theBay.id &amp; " Details (1 of 1)";
		elseif theFwdBay.bayType = BAY_TYPE_TWIN then
			self.shtBayDetails.caption := "Bay " &amp; _theBay.id &amp; " Details (2 of 2)";
		elseif theFwdBay.bayType = BAY_TYPE_TRIPLE then
			self.shtBayDetails.caption := "Bay " &amp; _theBay.id &amp; " Details (2/3 of 3)";
		endif;


		// I'll take this to mean that we are here for the first time so show the defaults from the other bay in this twin
		if self.myCurrentBay.allCellsOnDeckByOrdinal.size = 0 then
			self.displayDataForBay(theFwdBay, true, false);
		else
			// are the tier cell ids different?
			if theFwdBay.CM_Bay.getAllTiersUnderDeck() &lt;&gt; self.myCurrentBay.CM_Bay.getAllTiersUnderDeck() 
			or theFwdBay.CM_Bay.getAllTiersOnDeck() &lt;&gt; self.myCurrentBay.CM_Bay.getAllTiersOnDeck() 
			or theFwdBay.CM_Bay.getAllCellsUnderDeck() &lt;&gt; self.myCurrentBay.CM_Bay.getAllCellsUnderDeck() 
			or theFwdBay.CM_Bay.getAllCellsOnDeck() &lt;&gt; self.myCurrentBay.CM_Bay.getAllCellsOnDeck() then
				self.displayDataForBay(theFwdBay, true, false);
			endif;
		endif;
		// this is the aft bay so hide the 40 bay id field. This is to be kept null
		if theFwdBay.bayType = BAY_TYPE_TRIPLE then
			// if this is a triple, the first 2 bays have a 40 foot bay ID
			if theFwdBay.myHold.allBays.indexOf(theFwdBay) = 2 then
				self.txt40FootBayID.enabled := false;
			endif;
		else
			self.txt40FootBayID.enabled := false;
		endif;
		// disable the data on screen for this 2nd  bay in the twin so that it cannot be changed
		self.displayAftBayEnableDisable(false);
	else
	
		if self.myCurrentBay.bayType = BAY_TYPE_SINGLE then
			self.shtBayDetails.caption := "Bay " &amp; _theBay.id &amp; " Details (1 of 1)";
		elseif self.myCurrentBay.bayType = BAY_TYPE_TWIN then
			self.shtBayDetails.caption := "Bay " &amp; _theBay.id &amp; " Details (1 of 2)";
		elseif self.myCurrentBay.bayType = BAY_TYPE_TRIPLE then
			self.shtBayDetails.caption := "Bay " &amp; _theBay.id &amp; " Details (1 of 3)";
		endif;
		// try to default the hold number for the next bay
		if self.myCurrentBay.myHold = null then
			if theFwdBay &lt;&gt; null  then
				if theFwdBay.myHold &lt;&gt; null then
					idx := self.cmbHolds.findObject(theFwdBay.myHold);
					if idx &gt; 0 then
						idx := idx + 1;
					endif;
					if idx &gt; 0 and idx &lt;= self.cmbHolds.listCount then
						self.cmbHolds.listIndex := idx;
					endif;
				endif;
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_theBay" type="CM_Bay"/>
    </JadeMethod>
    <JadeMethod name="displayDataForBay" id="34cc3971-d09d-4f7f-a090-399fc9dc3d8c">
        <source>displayDataForBay(_theBay : CM_Bay; _fwdBay, _fromTemplate : Boolean);
//-----------------------------------------
// Created: November 2005 By: cnwgd1
//-----------------------------------------

vars
	theTierOrder : String;
	theOrdinalHold : Integer;
begin
	
	if _fwdBay then
		if _theBay.bayType = BAY_TYPE_TRIPLE then
			//which aft?  aft of front or aft of middle?
			if _theBay.myHold.allBays.indexOf(_theBay) = 2 then	//if aft of middle
				self.txt40FootBayID.text := null;
			endif;
		else
			self.txt40FootBayID.text := null;
		endif;
		self.displayAftBayEnableDisable(false);
	else
		self.txtBayID.text := _theBay.id;
		self.txt40FootBayID.text := _theBay.idBay40;
		self.ckbAftwartships.value := _theBay.athwartships;
		self.ckbTwinLiftOD.value := _theBay.isTwinLiftOD;
		self.ckbTwinLiftUD.value := _theBay.isTwinLiftUD;
		self.ckbFortyFootOnly.value := _theBay.fortyFootOnly;
		self.ckbForty5FtOnly.value := _theBay.fortyFiveFootOnly;
	endif;
	
	self.txtUnderDeckCell.text := _theBay.getAllCellsUnderDeck();
	self.txtOnDeckCells.text := _theBay.getAllCellsOnDeck();
	self.txtUnderDeckTier.text := _theBay.getAllTiersUnderDeck();
	self.txtOnDeckTier.text := _theBay.getAllTiersOnDeck();
	self.txtUDCellsHiCub.text := _theBay.getAllCellsHiCubeHeightsString();
	
	self.cmbBayType.listIndex := _theBay.bayType + 1; // zero based
	
	if _theBay.useCellTierODSequencing then
		self.cmbDirOn.listIndex := 1;
	else
		self.cmbDirOn.listIndex := 2;
	endif;		
	
	if _theBay.useCellTierODSequencing40 then
		self.cmbDirOn40.listIndex := 1;
	else
		self.cmbDirOn40.listIndex := 2;
	endif;	
	
	if _theBay.useCellTierUDSequencing then
		self.cmbDirUnder.listIndex := 1;
	else
		self.cmbDirUnder.listIndex := 2;
	endif;	
	
	if _theBay.useCellTierUDSequencing40 then
		self.cmbDirUnder40.listIndex := 1;
	else
		self.cmbDirUnder40.listIndex := 2;
	endif;		
	
	self.txtMaxPileWt20IB.text := (_theBay.maxPileWeight20IB / 1000).asStringJMT;
	self.txtMaxPileWt20OB.text := (_theBay.maxPileWeight20OB / 1000).asStringJMT;
	self.txtMaxPileWt40IB.text := (_theBay.maxPileWeight40IB / 1000).asStringJMT;
	self.txtMaxPileWt40OB.text := (_theBay.maxPileWeight40OB / 1000).asStringJMT;
	self.txtMaxPileWtUD.text := (_theBay.maxPileWeightUD / 1000).asStringJMT;
	
	self.txtRemarks.text := _theBay.remarks;
	self.txtNumOfPlugs.text := _theBay.numOfPlugs.asStringJMT;	
	
	// do not set the hold if from the template. The hold will have been auto set for the next bay
	if not _fromTemplate then
		self.cmbHolds.listIndex :=	self.cmbHolds.findObject(_theBay.myHold);
	endif;
			
	self.ckbFortyFootBay.value := _theBay.fortyFootBay;
	self.ckbForty5FootBay.value := _theBay.fortyFiveFootBay;
//	self.ckbTwinLiftOD.value := _theBay.isTwinLiftOD;
//	self.ckbTwinLiftUD.value := _theBay.isTwinLiftUD;

	theTierOrder := self.txtOnDeckTier.text;
	self.doBuildComboBayString(self.cmbLashFrom, theTierOrder);
	self.doBuildComboBayString(self.cmbUnlashFrom, theTierOrder);
		
	self.cmbLashFrom.listIndex := self.cmbLashFrom.findString(1, _theBay.lashFromTier);
	self.cmbUnlashFrom.listIndex := self.cmbUnlashFrom.findString(1, _theBay.unlashFromTier);
	
	self.cmbOnShipCrane.listIndex := self.cmbOnShipCrane.findString(1, _theBay.getOnShipCraneDescription());

	self.doLoadTblCellLimits();	//	Par 25127	/ CCMS 1140
	
end;</source>
        <Parameter name="_theBay" type="CM_Bay"/>
        <Parameter name="_fwdBay" type="Boolean"/>
        <Parameter name="_fromTemplate" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayVoyage" id="109d933b-3cbe-4c67-8bb6-c576c54a117c">
        <updating/>
        <source>displayVoyage() updating, protected;
//-----------------------------------------
// Created: July 2005 By: cnwgd1
//-----------------------------------------
vars

begin

	if self.myCurrentVoyage &lt;&gt; null then
		// load form with existing ship details.
		self.setCaption(self.cmbVoyage.text &amp; ' ' &amp; self.Caption);
		self.setNavigatorHeading(self.caption);
		
		self.displayVoyageDetails();
		
	else
		self.clearForm();
	endif; 

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayVoyageDetails" id="efff8ef7-7a84-43e9-b864-248d22358846">
        <updating/>
        <source>displayVoyageDetails() updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpStructure : CM_CellularVoyageStructure;
begin
	if self.myCurrentVoyage &lt;&gt; null then
		tmpStructure := self.myCurrentVoyage.myCellularVoyageStructure;
	endif;
	
	self.doBuildComboBay(self.cmbBayLayout);
	self.doBuildComboBay(self.cmbBridgeAftBay);
	self.doBuildComboHolds(tmpStructure);
	self.doBuildComboBay(self.cmbBayList);
	self.cmbBayList.click(self.cmbBayList);	

	if tmpStructure = null then
		return;
	endif;	
	self.txtNumHolds.text := tmpStructure.allHolds.size.String.padLeadingZeros(2);
	self.lblBayOrderTxt.caption := tmpStructure.getPhysicalBayOrder();
	self.cmbBridgeAftBay.listIndex := self.cmbBridgeAftBay.findString(1, tmpStructure.bridgeAfterBay.String);
	self.ckb40BayIds.value := tmpStructure.use40Id;	
	self.ckbISOHalfHeight.value := tmpStructure.isoHalfHeights;		
	
	if tmpStructure.useBayCellTierNumbering then
		self.cmbStowageNumber.listIndex := self.cmbStowageNumber.findString(0, Vessel_Stowage_Type_BCT_Text);
	else
		self.cmbStowageNumber.listIndex := self.cmbStowageNumber.findString(0, Vessel_Stowage_Type_BTC_Text);	
	endif;
	
	self.picVesselBitmap.picture := tmpStructure.myVoyage.bitmap;
	
	self.initSDF(self.mySDF);
	
	// ### PAR 8968. If they are viewing a bay in view mode. Select that bay when they click EDIT.
	if (not global.isValidObject(self.myCurrentBay)) then
		self.myCurrentBay := null;
	endif;
	if self.myCurrentBay &lt;&gt; null then
		if self.initWithBay = false then
			self.initWithBay := true;
		else	
			if not self.myCurrentBay.isTransient then
				self.myCurrentBay := self.myCurrentBay.pxyGetProxyObject.CM_Bay;
			endif;
		endif;
	endif;

end;</source>
    </JadeMethod>
