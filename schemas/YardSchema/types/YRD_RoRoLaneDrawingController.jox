    <JadeMethod name="doDrawFMLetterForTI" id="2cf6ed2d-f991-4b9d-badf-f4badaa81af9">
        <updating/>
        <source>doDrawFMLetterForTI(_theFMLetter : String;			
					_ti : CM_TrackedItem; 
					_isOnTrailer : Boolean;
					_x1, _y1, _x2, _y2 : Real) updating;
// ---------------------------------------------------------------------------
// Created:     01 September 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//PAR 19468 NEW
// ---------------------------------------------------------------------------

vars
	x1, x2, x3, y1, y2, scale : Real;
begin
	x1 := _x1;
	x2 := _x2;
	
	if x2 &lt; x1 then
		x3 := x1;
		x1 := x2;
		x2 := x3;
	endif;
	
	if _theFMLetter &lt;&gt; null then
		y1:=_y1;
		y2:=_y2;
		if _ti.hasTIBehaviourGraphic and not _isOnTrailer then
			self.getTIBehaviourGraphicYOffsets(_ti,_x1.Integer,_y1.Integer,_x2.Integer,_y2.Integer,y1,y2,scale);
		endif;
		
		self.drawFMLetterGraphic(self.myDrawingFrame, _theFMLetter,x1,y1,x2,y2,Gray);
		if not _ti.allQueuedFutureMoves.isEmpty() then																				// cnwjk3 PAR 22733 09/03/2010
			self.addToDrawnObjects( _x1.Integer, y1.Integer, _x2.Integer, y2.Integer, _ti.allQueuedFutureMoves.first());	// cnwjk3 PAR 22733 09/03/2010
		elseif not _ti.allPlannedFutureMoves.isEmpty() then																			// cnwjk3 PAR 22733 09/03/2010
			self.addToDrawnObjects( _x1.Integer, y1.Integer, _x2.Integer, y2.Integer, _ti.allPlannedFutureMoves.first());	// cnwjk3 PAR 22733 09/03/2010	
		else			
			self.addToDrawnObjects( _x1.Integer, y1.Integer, _x2.Integer, y2.Integer, _ti);
		endif;
	endif;
end;</source>
        <Parameter name="_theFMLetter" type="String"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_isOnTrailer" type="Boolean"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
    </JadeMethod>
