        <updating/>
        <source>assembleMessage(_mail : JadeDotNetType input; _fromAddress, _toAddress, _ccAddress, _bccAddress, _subject, _message : String): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
16 January 2024		navmd1	Initial creation TFS 55021 EASendMail Refactor

*/

vars
	exceptionOccurred	: Boolean;
begin
	on Exception do self.handleExceptionsExt(exception, exceptionOccurred);
