    <DbClassMap file="backgroundprocess"/>
    <JadeMethod name="getDisplayStringForAttribute" id="470274c3-9ded-4433-8cf7-f7159a3b9a00">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Nov 2022	navpw1	Initial creation TFS: 55215
17 Apr 2023	navdap1	TFS 57207 EUP - Refactor Inspection App API Message
*/

vars

begin
	if _attrName = ETRow_WebServiceType then
		return ExternalWebServiceEDBIC;
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEndpointValue" id="470e3a60-c8bb-479f-8110-d58beddecd26">
        <source>getEndpointValue(_value : String; _methodType, _endpointPath : String output);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 March 2023	navpw1	Initial creation TFS: 55215

*/

vars
	spaceIdx : Integer;
	
begin
	//Example format below:
	//_value = POST&lt;Space&gt;RailReceival
	//_methodType = POST
	//_endpointPath = RailReceival
	//spaceIdx = 5 (position of space char in string, &lt;Space&gt; above is the space char)
	spaceIdx := _value.pos(Space, 1);
	
	if spaceIdx = 0 or spaceIdx = -1 then
		return;
	endif;
	
	_methodType := _value[1 : spaceIdx -1];
	_endpointPath := _value[spaceIdx +1 : end];
	
end;</source>
        <Parameter name="_value" type="String"/>
        <Parameter name="_methodType" type="String" usage="output"/>
        <Parameter name="_endpointPath" type="String" usage="output"/>
    </JadeMethod>
