    <JadeMethod name="setControlsForAddEdit" id="e3db588c-678f-4eaf-bfd1-f862c91f75ee">
        <updating/>
        <source>setControlsForAddEdit() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 December 2012	cnwmc5	Initial creation HAT 2189

*/

vars
	theForm : SOP_TableMaintForm;

begin
  
  theForm := self.myForm;
	theForm.tblInput1.userInputEnabled := true;
			
	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Rate);
		theForm.tblInput1.enableRowByName(ETRow_DateChanged);
		theForm.tblInput1.moveFirst();
		// call this last as sets cell input type (case etc)
		// if not called can get problems with case on entry. 
		theForm.tblInput1.gotFocus(theForm.tblInput1);
		theForm.tblInput1.getRowByName(ETRow_Code).String.toUpper();
		
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_DutyDocExchangeRate);
		// cannot update code		
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Rate);
		theForm.tblInput1.enableRowByName(ETRow_DateChanged);
	endif;

epilog

end;</source>
    </JadeMethod>
