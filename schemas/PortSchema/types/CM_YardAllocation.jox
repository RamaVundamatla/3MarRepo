	elseif _attrName = ETRow_SubTerminal then
		criteria := self.getCriteriaOfTypeValue( YACriteriaType_SubTerminal );
	
	elseif _attrName = ETRow_TodoTasks then
		criteria := self.getCriteriaOfTypeValue( YACriteriaType_ToDoTasks );
	
	elseif _attrName = ETRow_TrailerType then
		criteria := self.getCriteriaOfTypeValue( YACriteriaType_TrailerType );
	
	elseif _attrName = ETRow_Train then
		criteria := self.getCriteriaOfTypeValue( YACriteriaType_Train );
	
	elseif _attrName = ETRow_TranshipDischPort then
		criteria := self.getCriteriaOfTypeValue( YACriteriaType_TranshipDischPt );
	
	elseif _attrName = ETRow_TranshiptoPort then
		criteria := self.getCriteriaOfTypeValue( YACriteriaType_TranshipToPort );
	
	elseif _attrName = ETRow_Voyage then
		criteria := self.getCriteriaOfTypeValue( YACriteriaType_Voyage );
	
	elseif _attrName = ETRow_VoyageBerth then
		criteria := self.getCriteriaOfTypeValue( YACriteriaType_VoyageBerth );
	
	elseif _attrName = ETRow_VoyageInbound then
