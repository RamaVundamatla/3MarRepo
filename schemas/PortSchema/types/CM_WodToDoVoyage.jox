    <JadeMethod name="prepareAuditDetail" id="e5784b22-3d78-4f70-a65a-addadd534e32">
        <source>prepareAuditDetail(_str : String io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 April 2023	navhl20	ChangeRequest 57301:[57303] EUP - [Framework] - Improve Audits on Work orders
21/04/2023	navcs2	Bug 57691: MTN - WO - Audits are missing for the totalActioned

*/

vars
	tmpStr	 	: String;
	voyage		: CM_Voyage;
begin
	inheritMethod(_str);
	tmpStr := null;
	if self.allVoyages.isNotEmpty then
		foreach voyage in self.allVoyages do
			if tmpStr = null then
				tmpStr := tmpStr &amp; voyage.code;
			else
				tmpStr :=tmpStr &amp; Comma &amp; voyage.code;
			endif;
		endforeach;
		_str := _str &amp; app.getErrorString(Voyages) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	// 21/04/2023	navcs2	Bug 57691 start
	tmpStr := null;
	if self.allVoyagesActioned.isNotEmpty then
		tmpStr := self.allVoyagesActioned.size.String;
		_str := _str &amp; "Number Actioned" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	else
		tmpStr := 0.String;
		_str := _str &amp; "Number Actioned" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	// 21/04/2023	navcs2	Bug 57691 end
epilog

end;</source>
        <Parameter name="_str" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="ff8d7fc4-65b2-4918-aa0c-bd4f83ce6ad6">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Dec 2022	navcs2	ChangeRequest 56822:[56823] EUP - VAS Voyage Work Order

*/

vars
	pxy 			: SelfType;
	completedOK		: Boolean;
begin
	pxy := inheritMethod();
	
	self.allVoyages.copy(pxy.allVoyages);
	self.allVoyagesActioned.copy(pxy.allVoyagesActioned);
	self.allVoyagesCompleted.copy(pxy.allVoyagesCompleted);
	
	completedOK := true;
	return pxy;
epilog
	
	if not completedOK then
		delete pxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="f16c90ce-5eb8-45d4-b822-87bd7d43c1ee">
        <updating/>
        <source>setForUpdate(_pxyWoDDtl: CM_WodToDoVoyage) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 October 2022	navcs2	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
20 Mar 2023  			navhl20 Defect 57233: MTN - Editing Vas Tasks is not working correctly
// ### TFS CR 56814 TASK 56813 07JUL2023 NAVAB1
*/

vars

begin
	inheritMethod(_pxyWoDDtl);
	self.allVoyages.clear();																		//20.3.2023 navhl20	#57233
	_pxyWoDDtl.allVoyages.copyNoDuplicates(self.allVoyages, false);
epilog

end;</source>
        <Parameter name="_pxyWoDDtl" type="CM_WodToDoVoyage"/>
    </JadeMethod>
    <JadeMethod name="setProxyToDo" id="e70c5d1e-96d5-4063-a5e4-4aaafbee6072">
        <updating/>
        <source>setProxyToDo(_allSelectedEntities		: Any) updating;
/*
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Mar 2023 navma1 ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Screen
20 Mar 2023 navhl20 Defect 57233: MTN - Editing Vas Tasks is not working correctly
24 Mar 2023 navhl20 ChangeRequest 57301:[57303] EUP - [Framework] - Improve Audits on Work orders
*/

vars

begin
	self.allVoyages.clear();														//20.3.2023 navhl20	#57233
	_allSelectedEntities.CM_VoyageSet.copyNoDuplicates(self.allVoyages, false);
epilog

end;</source>
        <Parameter name="_allSelectedEntities" type="Any"/>
    </JadeMethod>
