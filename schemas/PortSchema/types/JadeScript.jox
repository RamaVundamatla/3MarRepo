    <JadeMethod name="rel842_par37125" id="df75efaa-4ba0-4df7-a291-6c9ca9fdd1ea">
        <source>rel842_par37125();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 November 2015	cnwma1	Initial creation

*/

vars
	etAgent		: EntTableAgent;
	array 		: StringArray;
	isOtago			: Boolean;
	opr 		 : CM_Operator;
	
begin
	app.initialize();
	isOtago := app.myRoot.isClientPortOtago;
		
	foreach opr  in app.myRoot.allOperators discreteLock do
		if opr.getRequiresImpOperatorPIN then
			if isOtago then
				beginTransaction;
				opr.setPropertyValue("requiresRequestNumber",true);
				commitTransaction;
			endif;
		endif;
	endforeach;
	
	foreach opr  in app.myRoot.allOperators discreteLock do
		if not isOtago then
			beginTransaction;
			opr.setPropertyValue("requiresRequestNumber",false);
			commitTransaction;
		endif;
	endforeach;
	
	create etAgent transient;
	create array transient;

	etAgent.myEntTableDataRoot := app.myRoot.myEntTableDataRoot;

	array.add ("ETRow_RequiresRequestNumber");
	etAgent.trxUpdateFromConstant(array);
	
	write ETRow_RequiresRequestNumber;
epilog
	
	delete etAgent;
	delete array;
end;</source>
    </JadeMethod>
