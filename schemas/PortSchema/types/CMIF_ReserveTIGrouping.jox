    <JadeMethod name="addDetailToHeader" id="52e870da-115c-4c19-a284-6d56959b0aff">
        <updating/>
        <source>addDetailToHeader(detail : CMIF_ReserveTIDetail input) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 27 February 2019
TFS#		: 41708
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	if detail = null then
		return;
	endif;
	
	self.allDetails.add(detail);
end;</source>
        <Parameter name="detail" type="CMIF_ReserveTIDetail" usage="input"/>
    </JadeMethod>
