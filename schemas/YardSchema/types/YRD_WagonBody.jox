    <text>This is the row for the body of the wagon where we draw the twist lock pictures</text>
    <DbClassMap file="Yard"/>
    <PrimAttribute name="picture" id="ab9beec8-595b-4949-9738-4437d21191b6">
        <type name="Binary"/>
    </PrimAttribute>
