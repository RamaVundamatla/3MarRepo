    <JadeMethod name="doTblWorkEntriesContextMnu" id="5e4d4a32-9724-4f8d-9802-faccfabbc7e1">
        <updating/>
        <source>doTblWorkEntriesContextMnu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer) : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
16 October 2009		cnwrd1	Initial creation
25 January 2013		cnwdap1	PAR #31018 CCMS POL 2223 added mnuDisconnect
19 October 2022		jlizm1	TFS 54118 Assigning Releases to Wagons
*/

vars
	xLeft 	: Real;
	yTop	: Real;
	obj	 	: CM_Object;
	visibleBeforeSep : Boolean;
	visibleAfterSep : Boolean;
	
begin

	xLeft := x;
	yTop := y;

	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);   // convert x, y relative to form

	obj := cntrl.accessRow(self.tblWorkEntries.row).itemObject.CM_Object;
	
	if global.isValidObject(obj)
	   and CM_WorkListEntry.hasInstance(obj) then
		self.doBuildMnuTblObj(obj.CM_WorkListEntry);		
	else
		self.doBuildMnuTblObj(null);
	endif;
	
	// only display separator if there are visible items before and after it
	visibleBeforeSep := mnuEnquire.visible or mnuAllocateTI.visible or mnuAutoplan.visible or mnuQueue.visible or
			mnuMoveIt.visible or mnuEdit.visible or mnuPackUnpack.visible;
	//visibleAfterSep := mnuRemarks.visible or mnuSetTargetLocn.visible or mnuComplete.visible or							// PAR #31018
	visibleAfterSep := mnuRemarks.visible or mnuDisconnect.visible or mnuSetTargetLocn.visible or mnuComplete.visible or	// PAR #31018
			mnuAdditional.visible or mnuAssignToTBA.visible or mnuAddDeliveryRequest.visible or mnuDeleteCurrentEntry.visible or
			mnuReturnWorkEntry.visible or mnuProcessRoadExit2.visible or mnuSource.visible or
			mnuTurnAround.visible or mnuDisconnectReefers.visible or mnuRebuildWLEStatus.visible or
			mnuAssignRelWagon.visible or mnuAssignRelWagon2.visible or mnuUnAssignRelWagon.visible or mnuUnAssignRelWagon2.visible or
			self.mnuWagonAssignBulk.visible  or //23 Feb 2017	NDL	TFS 3514
			mnuAssignRelWagonAndQ.visible or mnuAssignRelWagonAndQ2.visible;	//11 may 2010	NDL	Otago CCMS 1935 in testing...
			
	self.mnuTableSep1.visible := visibleBeforeSep and visibleAfterSep;
	
	visibleBeforeSep := visibleBeforeSep or visibleAfterSep;
	visibleAfterSep := mnuColourLegend.visible or mnuColumnOrganiser.visible or mnuToggleMultiSelect.visible;

	self.mnuTableSep2.visible := visibleBeforeSep and visibleAfterSep;

	//+cnwml2 PAR23715 DCT CCMS 1131
	if self.mnuRecSealCheck.visible or self.mnuRelSealCheck.visible then
		self.mnuTableSep3.visible := true;
	else
		self.mnuTableSep3.visible := false;
	endif;
	
	// separators for autoplan submenu
	visibleBeforeSep := mnuAutoplanAll.visible or mnuAutoplanSelected.visible;
	visibleAfterSep := mnuUnplanAll.visible or mnuUnplanSelected.visible;
	
	self.mnuAutoplanSep.visible := visibleBeforeSep and visibleAfterSep;	

	// separators for queue submenu
	visibleBeforeSep := mnuQueueAll.visible or mnuQueueSelected.visible;
	visibleAfterSep := mnuUnqueueSelected.visible or mnuUnqueueAll.visible;
	
	self.mnuQueueSep.visible := visibleBeforeSep and visibleAfterSep;	
	
	// TFS 2734 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuQueue.visible := false;
		self.mnuAutoplan.visible := false;
		self.mnuMove.visible := false;
		self.mnuUnassignTI.visible := false;
		self.mnuMoveIt.visible := false;
	endif;

	self.popupMenu(mnuContextTable, xLeft.Integer, yTop.Integer);
	self.mnuColumnOrganiser.userObject := cntrl;

	return false;
epilog

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
