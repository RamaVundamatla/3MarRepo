    <JadeMethod name="rjd29128LogProblem" id="2f683221-4feb-4935-b5d7-4bae1b125509">
        <source>rjd29128LogProblem();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 May 2012	cnwrd1	Initial creation

*/

vars
	loccon : CM_LocationsController;
	sohLoc : CM_SOHLocation;
	logCon : CM_LogController;
	stockAlloc : CM_StockOrderAllocation;
	hasLine , hasAlloc : Boolean;
begin

write 'start : ' &amp; app.actualTimeServer().asStringTimeDayDate;

	foreach logCon in CM_LogController.instances do
	
		if logCon.status = LC_Status_Archived then
			continue;
		endif;
		
		//if logCon.status = LC_Status_Closed then
		//	continue;
		//endif;
	
		foreach sohLoc in logCon.allProductLocations do
			
		if not sohLoc.allStockOrderAllocations.isEmpty then
		hasLine := false;
		hasAlloc := false;
		
			foreach stockAlloc in sohLoc.allStockOrderAllocations do			
				if stockAlloc.isKindOf(CM_StockOrderLineAlloc) then
					hasLine := true;
				elseif stockAlloc.isKindOf(CM_StockOrderSummaryAlloc) then
					hasAlloc := true;
				endif;			
			endforeach;
		
			if hasLine and not hasAlloc then
				write 'Suspect: ' &amp; sohLoc.getOidAsString &amp;' , ' &amp; sohLoc.myLocationsController.ident &amp; ' term : ' &amp; sohLoc.myLocationsController.myTerminal.name &amp; ' TA : ' &amp; sohLoc.myLocationsController.myTerminalArea.id ;
				write 'sohloc date' &amp; sohLoc.createdTime.asStringJMT();
				
				write ' Log controller status : ' &amp; sohLoc.myLocationsController.status.asStringJMT();
				//sohLoc.inspectModal;
				//break;
			endif;
		
		endif;
		
		endforeach;
	
	endforeach;

write 'end : ' &amp; app.actualTimeServer().asStringTimeDayDate;
end;</source>
    </JadeMethod>
    <JadeMethod name="rjdDeleteVehicles" id="fd984d3e-9952-461d-81ff-7e9d0c1c7884">
        <source>rjdDeleteVehicles();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 September 2015	cnwrd1	Initial creation

*/
vars
	vehicle: CM_Vehicle;
	terminal: CM_Terminal;
	vvr : CM_VehicleVisitRecord;
	iter		: Iterator;
begin

	app.initialize;
	
	foreach terminal in CM_Terminal.instances do
	
		foreach vehicle in terminal.vehicles do
			if vehicle &lt;&gt; null then
			
				if not vehicle.allRoadJobs.isEmpty then
					continue;
				endif;
			
			foreach vvr in vehicle.visitRecords do
				beginTransaction;
					vvr.erase(NORMAL_ERASE);
				commitTransaction;
			endforeach;
	
			
			app.myTrxDA.trxDeleteVehicle(vehicle, app.myPassport); 
	
		endif;
		
		endforeach;
	endforeach;
	

epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="rjdPar33856EdiFileTypeName" id="00fa8e04-8eb3-462a-9650-ee4d686c6a90">
        <source>rjdPar33856EdiFileTypeName();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 May 2014	cnwrd1	Initial creation

*/

vars
	aType : CM_EDIFileTypeX12;
	anObject : Object;
	allObjects		: ObjectArray;
begin

	create allObjects transient;
	CM_EDIFileTypeX12.allInstances(allObjects, 0, true);
	
	write "begin filtetype rename";
	
	foreach anObject in allObjects do
		aType := anObject.CM_EDIFileTypeX12;
		
		
		if aType.isKindOf(CM_EDIFileTypeX12EDI3014010) then
			beginTransaction;
			aType.setPropertyValue('name',"X12 301 - Confirmation (Ocean)");
			commitTransaction;
		endif;
	
		if aType.isKindOf(CM_EDIFileTypeX12EDI3094010) then
			beginTransaction;
			aType.setPropertyValue('name',"X12 309 - U.S. Customs Manifest");
			commitTransaction;
		endif;
		
		if aType.isKindOf(CM_EDIFileTypeX12EDI3154010) then
			beginTransaction;
			aType.setPropertyValue('name',"X12 315 - Status Details");
			commitTransaction;
		endif;
		
		if aType.isKindOf(CM_EDIFileTypeX12EDI3224010) then
			beginTransaction;
			aType.setPropertyValue('name',"X12 322 - Terminal Operations Activity");
			commitTransaction;
		endif;
		
		if aType.isKindOf(CM_EDIFileTypeX12EDI3504010) then
			beginTransaction;
			aType.setPropertyValue('name',"X12 350 - U.S. Customs Status Information");
			commitTransaction;
		endif;
	endforeach;

	write "end filtetype rename";
epilog

end;</source>
    </JadeMethod>
