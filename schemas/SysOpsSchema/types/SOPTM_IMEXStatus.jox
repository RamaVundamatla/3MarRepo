    <JadeMethod name="create" id="43ee8c69-7384-40df-a538-d59e1494f343">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     11 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.name := SOP_TableMaintForm.Table_IMEXStatus;
	self.permissionView	 := PmAdmIMEXStatusView; // tfs 2101
	self.permissionMaint := PmAdmIMEXStatusMaint;
	self.myDataClass := CM_IMEXStatus;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="973d04d0-fc7d-4797-af9e-9a79fcc28b3c">
        <source>doSave(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
02 May 2022			jlizm1	Initial creation TFS 53084 GPHA revceival/release of tranship cargo

*/

vars

	pxyImexStatus	: CM_IMEXStatus;
	tbl				: CM_EntryTable;
	theResult 		: Integer;
	
begin

	tbl := self.myForm.tblInput1;
	pxyImexStatus := self.myForm.myProxyObject.CM_IMEXStatus;
	
	if pxyImexStatus = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy imex status is null');
		return false;
	endif;
	
	pxyImexStatus.setProxyForUpdate(tbl.getValueByName(ETRow_Abbreviation).String,
							tbl.getValueByName(ETRow_Description).String,
							tbl.getValueByName(ETRow_Colour).Integer);
							
	pxyImexStatus.setAllowInterModalTransit(tbl.getValueByName(ETRow_InterModal).Boolean);
							
	while true do
	
		app.myTrxUA.trxUpdateCargoStatus(pxyImexStatus, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Update IMEX Status', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;
	
	return true;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="1563e70e-4cc8-45ca-844d-f5053b9f34ba">
        <source>getCollection(): Collection;
// ---------------------------------------------------------------------------
// Created:     11 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	return app.myRoot.allImexStatuses;


end;</source>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="c6a9ef28-c710-4087-bd80-75937012a735">
        <updating/>
        <source>showThumbnail(_status: CM_IMEXStatus) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
02 May 2022			jlizm1	Initial creation TFS 53084 GPHA revceival/release of tranship cargo

*/

vars

	tbl			: CM_EntryTable;
	
begin

	if _status = null then
		return;
	endif;
	
	inheritMethod(_status);
	
	tbl := self.myForm.tblInput1;
	
	if _status.code = TI_IMEX_STATUS_TRANSHIP then
		tbl.setValueByName(ETRow_InterModal, _status.allowInterModalTransit);
		tbl.showRowByName(ETRow_InterModal, false);
	endif;

epilog

end;</source>
        <Parameter name="_status" type="CM_IMEXStatus"/>
    </JadeMethod>
</Class>
