<Class name="CM_PriorityChanged" id="e5531008-85c6-4875-ad9d-d98a1bf27d39">
    <superclass name="CM_TITransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transact"/>
    <PrimAttribute name="newCustomerPriority" id="7df42070-b3d6-4abd-a850-229038785ce6">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="getDisplayString" id="0946dd92-d79c-4ce5-9c43-8890c26d9d6c">
        <source>getDisplayString(): String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 26 February 2024
TFS#		: 62524
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	return app.getErrorString1(Priority_changed, self.newCustomerPriority);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="089834da-a8ce-4f28-8cb9-ab1ee95fc2ba">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 26 February 2024
TFS#		: 62524
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	lDetail : String;
begin
	if _attrName = ETRow_Details  then
		lDetail := self.getDisplayString();	
		return lDetail;
	else
		return inheritMethod(_attrName, _short);	
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
