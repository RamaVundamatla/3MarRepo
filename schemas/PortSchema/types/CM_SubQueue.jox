    <JadeMethod name="pxyCreateUpdateProxy" id="49c1bc09-d391-4261-bdd6-d1fd7ded1856">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------

vars
	proxy : SelfType;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	proxy.myTerminal := self.myTerminal;
	
	self.allMoveFromTAMasters.copy(proxy.allMoveFromTAMasters);
	self.allMoveToTAMasters.copy(proxy.allMoveToTAMasters);
	
	self.moveToLocnControllers.copy(proxy.moveToLocnControllers);
	self.moveFromLocnControllers.copy(proxy.moveFromLocnControllers);
	
	//jlier1 TFS 52160 19/11/21
	proxy.myVoyage:=self.myVoyage;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="queueType" id="2c342b9e-3e0f-49c2-8184-12dbd1bfaf25">
        <methodInvocation>mapping</methodInvocation>
        <source>queueType(set : Boolean; _value : Integer io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 September 2009	cnwer1	Initial creation

*/

vars

begin
	if not set and self.queueType = 0 then
		_value:=QTYPE_SUBQUEUE;
	endif;	
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setDetails" id="7005f3a9-df80-4424-8a40-e0895804e60b">
        <updating/>
        <source>setDetails(	_theID 						: String;
			_isUni						: Boolean;
			_fromLCs, _toLCs 			: CM_LCArray;
			_fromTA, _toTA 				: CM_TerminalAreaMaster; 
			_lookForFromAreaMove,
			_lookForToAreaMove,
			_isSystemDefined			: Boolean;
			_allowedMachineTypeGroups	: IntegerArray input;
			_terminal : CM_Terminal) 	updating;
/*
----------   ----------  --------------------------------------------------
Created:	10 August 2006 By cnwth2

Purpose:	Set details when we havn't got a proxy - when auto creating RTG lane for example.

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.id := _theID;
	self.isUnidirectional := _isUni;
	
	self.lookForFromAreaMove	:= _lookForFromAreaMove;
	self.lookForToAreaMove		:= _lookForToAreaMove;
	
	if _allowedMachineTypeGroups &lt;&gt; null then
		self.allAllowedMachineTypeGroups.clear();
		_allowedMachineTypeGroups.copy(self.allAllowedMachineTypeGroups);
	endif;

	self.moveFromLocnControllers.clear();
	if _fromLCs &lt;&gt; null then
		_fromLCs.copy(self.moveFromLocnControllers);
	endif;
	self.moveToLocnControllers.clear();
	if _toLCs &lt;&gt; null then
		_toLCs.copy(self.moveToLocnControllers);
	endif;
	
	self.isSystemDefined := _isSystemDefined;
	
	// DVB changed 11/08/06
	//self.moveFromTerminalArea := _fromTA;
	//self.moveToTerminalArea := _toTA;
	
	//self.myMoveToTAMaster		:= _toTA;
	if _toTA &lt;&gt; null then
		self.allMoveToTAMasters.add(_toTA);
	endif;
	//self.allMoveFromTAMasters		:= _fromTA;
	
	if _fromTA &lt;&gt; null then
		self.allMoveFromTAMasters.add(_fromTA);
	endif;

	self.myParentQueue	:= _terminal.radioTelemetry.masterQueue;
	self.myTerminal := _terminal;
	
end;</source>
        <Parameter name="_theID" type="String"/>
        <Parameter name="_isUni" type="Boolean"/>
        <Parameter name="_fromLCs" type="CM_LCArray"/>
        <Parameter name="_toLCs" type="CM_LCArray"/>
        <Parameter name="_fromTA" type="CM_TerminalAreaMaster"/>
        <Parameter name="_toTA" type="CM_TerminalAreaMaster"/>
        <Parameter name="_lookForFromAreaMove" type="Boolean"/>
        <Parameter name="_lookForToAreaMove" type="Boolean"/>
        <Parameter name="_isSystemDefined" type="Boolean"/>
        <Parameter name="_allowedMachineTypeGroups" type="IntegerArray" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="d5887b8f-5fa5-4cff-aeef-15244d5e7983">
        <updating/>
        <source>setForUpdate(_pxyRTQueue : CM_SubQueue; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		October 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(_pxyRTQueue,  _passport);

	self.isUnidirectional := _pxyRTQueue.isUnidirectional;
	
	self.queueType :=_pxyRTQueue.queueType;
		// CCMS 1310
	self.lookForFromAreaMove	:= _pxyRTQueue.lookForFromAreaMove;
	self.lookForToAreaMove		:= _pxyRTQueue.lookForToAreaMove;

	// DVB changed 11/08/06
	//self.moveFromTerminalArea := _pxyRTQueue.moveFromTerminalArea;
	//self.moveToTerminalArea := _pxyRTQueue.moveToTerminalArea;
	
	self.allMoveToTAMasters.clear();
	self.allMoveFromTAMasters.clear();
	_pxyRTQueue.allMoveToTAMasters.copy(self.allMoveToTAMasters);
	_pxyRTQueue.allMoveFromTAMasters.copy(self.allMoveFromTAMasters);
	//self.myMoveToTAMaster		:= _pxyRTQueue.myMoveToTAMaster;
	//self.allMoveFromTAMasters		:= _pxyRTQueue.allMoveFromTAMasters;
	
	self.moveFromLocnControllers.clear();
	self.moveToLocnControllers.clear();
	_pxyRTQueue.moveFromLocnControllers.copy(self.moveFromLocnControllers);
	_pxyRTQueue.moveToLocnControllers.copy(self.moveToLocnControllers);
	
	self.allAllowedMachineTypeGroups.clear();
	_pxyRTQueue.allAllowedMachineTypeGroups.copy(self.allAllowedMachineTypeGroups);
	
	//jlier TFS 52160 8/11/21
	self.myVoyage:=_pxyRTQueue.myVoyage;
	self.voyageJobType:=_pxyRTQueue.voyageJobType;
	
	// DVB Changed this to always set terminal 20/01/02005	
	self.myTerminal := _pxyRTQueue.myTerminal;
	
end;</source>
        <Parameter name="_pxyRTQueue" type="CM_SubQueue"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
