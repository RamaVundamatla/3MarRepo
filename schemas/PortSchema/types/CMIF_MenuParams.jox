        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="integer2" id="e250c4d1-95c9-4945-9ce6-40b59933efe5">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
