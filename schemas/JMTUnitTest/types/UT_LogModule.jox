    <JadeMethod name="deleteLogArea" id="b78a9fda-1332-4cbe-af5b-df18c0caef3a">
        <source>deleteLogArea(_id: String);
// 16 September 2010	by cnwvu1

vars
	logArea : CM_LogArea;
	restr	: CM_LocationRestriction;
	
begin

	logArea := self.getLogArea(_id);
	if logArea = null then
		return;
	endif;
	
	foreach restr in logArea.allRestrictionsLocation do
		app.myTrxDA.trxDeleteRestrictionLocation(restr, app.myPassport);
	endforeach;
	self.assertNoTrxErrorsOrWarnings();
	
	self.deleteTerminalArea(_id);
	self.assertNoTrxErrorsOrWarnings();
	
end;</source>
