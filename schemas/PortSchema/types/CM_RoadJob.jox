    <JadeMethod name="setTIForRelease" id="c581283d-a926-4f5a-8aac-336178961cf0">
        <updating/>
        <source>setTIForRelease(_ti : CM_TrackedItem input; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 08 April 2003 By: cnwgd1
//05 Jun 2025 navma1 MTN-34114  MTN - Performance Improvements - Remove Class::FirstInstance usage  
//--------------------------------------------------------------
vars
	tiArray : CM_TIArray;
	chassis : CM_TILC;
	lc		: CM_LocationsController;
	parent	: CM_TrackedItem;
begin
	
	inheritMethod(_ti, _passport);
	
	create tiArray transient;
	
	self.myVehicle.locationsController.allTrackedItems.copy(tiArray);			//05.06.2025 navma1 #MTN-34114
	
	if (not tiArray.includes(_ti)) then
		
		lc := _ti.myPrimaryActualLocation;
		
		if lc &lt;&gt; null and lc.isKindOf(CM_TILCController) then
			chassis := lc.CM_TILCController.myTILC;
		endif;
		
		parent := _ti.myParent;
		
		if  parent &lt;&gt; null then
			if not tiArray.includes(parent) then
				app.raiseCMException1(ERR_TI_NOT_ON_VEHICLE, _ti.id, null, null);	
			endif;
			return;
		endif;
		
		//epr SFW 1338 
		if chassis = null or not tiArray.includes(chassis) then
			app.setContinueCMExceptions(false);
			app.raiseCMException1(ERR_TI_NOT_ON_VEHICLE, _ti.id, null, null);
			return;
		endif;
	endif;
	
epilog
	delete tiArray;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="sortWLEs" id="49908f80-c628-4d27-9baa-011c54c481f1">
        <source>sortWLEs() :	CM_WLEArray;
//Takes the workListEntries array, and sorts it so that receipts come before releases...
//Purely for enquing purposes...
vars
	sortedWLEs	:	CM_WLEArray;
	tSortedWLEs	:	CM_WLEArray;
	wle	: CM_WorkListEntry;
begin

	create tSortedWLEs transient;	//Destroyed in here
	create sortedWLEs transient;	//Destroyed in calling method..	
	foreach wle in self.workListEntries do
		if wle.myRequest.isKindOf(CM_TIRequest) then
			if wle.myRequest.CM_YardRequest.isReceipt then
				//Add to 1st array
				sortedWLEs.add(wle);			
			else
				//Just add to end of list, is a release
				tSortedWLEs.add(wle);			
			endif;
		else
			//Just add to end of list, is an ISO delivery
			tSortedWLEs.add(wle);			
		endif;
	endforeach;
	foreach wle in tSortedWLEs do
		sortedWLEs.add(wle);			
	endforeach;
 	return sortedWLEs;
epilog
	delete tSortedWLEs;
end;</source>
        <ReturnType type="CM_WLEArray"/>
    </JadeMethod>
    <JadeMethod name="transportMode" id="0cef49e9-b633-4cfa-a514-927ebbbdc9e7">
