    <JadeMethod name="getEDICAMIRPartyRules" id="961fba8e-c4e1-46a9-8ad1-125986a2cf67">
        <source>getEDICAMIRPartyRules(_senderCode : String) : CM_EDIPartyCAMIRRules;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Mar 2024	jlirs1	TFS 57192 - 57193, 62335 Pen Support Import Voyage Translation
*/

vars
	ediPartyRules : CM_EDIPartyRules;
	senderParty	: CM_EDIParty;
	terminal : CM_Terminal;
begin
    terminal := app.myPassport.myTerminal;
	
    if terminal &lt;&gt; null then
        senderParty := terminal.allEDIPartiesBySenderCode[_senderCode];
    endif;
	if senderParty &lt;&gt; null then
		ediPartyRules := self.getEDIPartyRules(senderParty);
	endif;

epilog
	return ediPartyRules.CM_EDIPartyCAMIRRules;
end;</source>
        <Parameter name="_senderCode" type="String"/>
        <ReturnType type="CM_EDIPartyCAMIRRules"/>
    </JadeMethod>
    <JadeMethod name="getEDIPartyRules" id="e981af1f-acd3-4d88-8500-dc89b7e78fe8">
        <source>getEDIPartyRules(_ediParty: CM_EDIParty): CM_EDIPartyRules protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//04 Mar 2024	jlirs1	TFS 57192 - 57193, 62335 Pen Support Import Voyage Translation
*/

vars

begin
	if _ediParty = null then
		return null;
	endif;
	
	return _ediParty.getRulesForFileType(EDIFileTypeCAMIR_CustomsStatus);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ediParty" type="CM_EDIParty"/>
        <ReturnType type="CM_EDIPartyRules"/>
    </JadeMethod>
</Class>
