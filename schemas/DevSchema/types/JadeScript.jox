Parameters:			

Return Value:		

Date		Who		Reason
14 July 2020	jlgma1	Initial creation

*/

vars
	callbackUrl,
	iniFile,
	webServiceURL,
	restWSApplication	: String;
begin
	iniFile           := app.getIniFileName();
	webServiceURL     := app.getProfileString(iniFile, 'JMTCargoChain', 'WebServiceURL', null);
	app.msgBox(webServiceURL,"",0);
	restWSApplication := app.getProfileString(iniFile, 'JMTCargoChain', 'RestWSApplication', null);
	app.msgBox(restWSApplication,"",0);
