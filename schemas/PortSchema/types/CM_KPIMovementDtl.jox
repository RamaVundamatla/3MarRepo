    <JadeMethod name="setFinishTime" id="30e375eb-01d3-4932-9d0e-888f9ea3397d">
        <updating/>
        <source>setFinishTime(_finishTime: TimeStamp) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 April 2014	cnwdw1	Initial creation
*/
vars

begin
