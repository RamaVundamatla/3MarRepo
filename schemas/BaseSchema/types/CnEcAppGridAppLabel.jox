    <JadeMethod name="mouseDown" id="82936c2a-7f25-4ffd-b86c-2ed4625e5bd7">
        <updating/>
        <source>mouseDown(label: CnEcAppGridAppLabel input; button: Integer; shift: Integer; x: Real; y: Real) updating;

vars
	lbl, lblObj : CnEcAppGridAppLabel;

begin
	// If in print preview mode ...
	if app.printer.printPreview then
		// ...disable event handling
		return;
	endif;
	if button = Window.MouseButton_Left then
		mouseX := x;
		mouseY := y;
		moveAppInfo(left + x, top + y);
		// If SHIFT key is pressed and multiselect mode is on ...
		if shift mod 2 = 1 and appGrid.multiSelect then
			// ...select all labels between first selected and current label
			foreach lbl in appGrid.appLabelsSelected
			where lbl.resource = label.resource do
				lblObj := lbl;
				break;
			endforeach;
			if lblObj = null then
				foreach lbl in appGrid.appLabels
				where lbl.resource = label.resource do
					appGrid.select(lbl, true);
					lblObj := lbl;
					break;
				endforeach;
			endif;
			if lblObj &lt;&gt; null then
				foreach lbl in appGrid.appLabels
				where (lbl.resource = lblObj.resource)
				and (label.start &gt; lblObj.start and lbl.start &gt; lblObj.start and lbl.start &lt;= label.start
				or label.start &lt; lblObj.start and lbl.start &lt; lblObj.start and lbl.start &gt;= label.start) do
					appGrid.select(lbl, true);
				endforeach;
			endif;
		// If neither SHIFT nor CTRL key is pressed, or not in multiselect mode	...
		elseif not ((shift div 2) mod 2 = 1 or shift mod 2 = 1) or not appGrid.multiSelect then
			// ...and not in dragging mode ...
			if not appGrid.dragging and label.selected = null then
			 	// ...deselect all labels and select the current one
				appGrid.deselectAll();
				appGrid.select(label, true);
			endif;
		endif;
		if (sizeable or moveable) then
			if sizeable and y &lt;= self.TopOffset then
				sizingTop := true;
			elseif sizeable and y &gt;= height - self.BottomOffset then
				sizingBottom := true;
			elseif moveable and (y &gt;= self.TopOffset and y &lt;= height - self.BottomOffset) then
				appGrid.gridTable.drawMode := 7;
				foreach lbl in appGrid.appLabelsSelected do
					lbl.mouseX := x;
					lbl.mouseY := y;
					lbl.appDragX := lbl.left;
					lbl.appDragY := lbl.top;
					lbl.moving := true;
    			endforeach;
			endif;
		endif;
	endif;
	appGrid.appLabel := label;
	inheritMethod(label, button, shift, x, y);
	appGrid.changeType := appGrid.ChangeType_NoChange;
	appGrid.mouseDown(appGrid, button, shift, x, y);
end;</source>
        <Parameter name="label" type="CnEcAppGridAppLabel" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseMove" id="a9f3a698-d44f-481e-ab65-ed57b6d28d5a">
        <updating/>
        <source>mouseMove(label: CnEcAppGridAppLabel input; button: Integer; shift: Integer; x: Real; y: Real) updating;

vars
	lbl : CnEcAppGridAppLabel;

begin
	// If in print preview mode ...
	if app.printer.printPreview then
		// ...disable event handling
		return;
	endif;
	// If sizing has been interupted by modal window poping up so there will be no mouseUp event...
	if button = Window.MouseButton_None and (moving or sizingTop or sizingBottom or appGrid.dragging) then
		// ...reset all variables 
		moving := false;
		sizingTop := false;
		sizingBottom := false;
		appGrid.dragging := false;
		appGrid.dragMode := 0;
		mousePointer := Window.MousePointer_Default;
		appGrid.appInfo.visible := false;
		return;
	endif;
	if sizingTop then
		// Check if MinMove treshold is exceeded
		if (y - mouseY &gt;= self.MinMove or mouseY - y &gt;= self.MinMove) and height - y + mouseY &gt;= self.MinHeight then
			// If label dragged outside the time scale ...
			if top + y - mouseY &lt; 0 then
				// ...move it back
				moveSelf(left, 0, width, height + top, true);
				return;
			endif;
			// If overlapping is not allowed ...
			if not appGrid.overlapping then
				// ...check if it is about to happen, ...
				foreach lbl in appGrid.appLabels 
				where lbl &lt;&gt; self and lbl.resource = resource and lbl.top &lt; top do
					if top + y - mouseY &lt; lbl.top + lbl.height then
						// ...and move the offender back
						moveSelf(left, lbl.top + lbl.height, width, height - lbl.top - lbl.height + top, true);
						return;
					endif;
				endforeach;
			endif;
			// Move label to the new position, recalculate time values, and set changeType property
			moveSelf(left, top + y - mouseY, width, height - y + mouseY, true);
			appGrid.changeType := appGrid.ChangeType_Resize;
		endif;
		// Move and refresh info label
		moveAppInfo(left + x, top + y);

	elseif sizingBottom then
		// Check for self.MinMove threshold
		if (y - mouseY &gt;= self.MinMove or mouseY - y &gt;= self.MinMove) and height + y - mouseY &gt;= self.MinHeight then
			// If label dragged outside the time scale ...
			if top + height + y - mouseY &gt; appGrid.getY(appGrid.endTime) then
				// ...move it back
				moveSelf(left, top, width, appGrid.getY(appGrid.endTime) - top, true);
				return;
			endif;
			// If overlapping is not allowed ...
			if not appGrid.overlapping then
				// ...check if it is about to happen, ...
				foreach lbl in appGrid.appLabels 
				where lbl &lt;&gt; self and lbl.resource = resource and lbl.top &gt; top do
					// ...and move the offender back
					if  top + height + y - mouseY &gt; lbl.top then
						moveSelf(left, top, width, lbl.top - top, true);
						return;
					endif;
				endforeach;
			endif;
			// Move to a new position
			moveSelf(left, top, width, height + y - mouseY, true);
			mouseY := y;
			appGrid.changeType := appGrid.ChangeType_Resize;					
		endif;
		moveAppInfo(left + x, top + y);

	else
		// Enter drag mode if appropriate
		if moving and button = Window.MouseButton_Left and (y - mouseY &gt;= self.MinMove or mouseY - y &gt;= self.MinMove or x - mouseX &gt;= self.MinMove or mouseX - x &gt;= self.MinMove) then
			dragMode := 1;
			appGrid.dragging := true;
		elseif sizeable and (y &lt;= self.TopOffset or y &gt;= height - self.BottomOffset) then
			mousePointer := Window.MousePointer_NS;
		else
			mousePointer := Window.MousePointer_Default;
		endif;
	endif;

	// Call event handler for the control
	appGrid.mouseMove(appGrid, button, shift, x, y);	
end;</source>
        <Parameter name="label" type="CnEcAppGridAppLabel" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseUp" id="88cc7637-e662-4a99-980a-9fe509934eee">
        <updating/>
        <source>mouseUp(label: CnEcAppGridAppLabel input; button: Integer; shift: Integer; x: Real; y: Real) updating;

vars

begin
	// If in print preview mode ...
	if app.printer.printPreview then
		// ...disable event handling
		return;
	endif;
	mousePointer := Window.MousePointer_Default;
	appGrid.appInfo.visible := false;
	if button = Window.MouseButton_Left then
		if (sizeable or moveable) then
			// If label has been moved or resized ...
			if appGrid.changeType &lt;&gt; appGrid.ChangeType_NoChange and appGrid.changeType &lt;&gt; appGrid.ChangeType_StatusClick then	
				// ...snap it to the grid
				if moving then
					moving := false;			
					moveSelf(left, ((top / gridSnap).rounded * gridSnap).rounded, width, height, true);
				elseif sizingTop then
					if height &lt; self.MinHeight then
						top := top + height - self.MinHeight;
						height := self.MinHeight;
					endif;
					moveSelf(left, ((top / gridSnap).rounded * gridSnap).rounded, width, top + height - ((top / gridSnap).rounded * gridSnap).rounded, true);
				elseif sizingBottom then
					if height &lt; self.MinHeight then
						height := self.MinHeight;
					endif;
					moveSelf(left, top, width, ((height / gridSnap).rounded * gridSnap).rounded, true);
				endif;
			endif;
			// If CNTRL key is pressed while SHIFT key isn't and multiselect mode is on ...			
			if (shift div 2) mod 2 = 1 and not (shift mod 2 = 1) and appGrid.multiSelect then
				// ...and not in dragging mode ...
				if not appGrid.dragging then
					// ...select or deselect current label
					appGrid.select(label, (label.selected = null));
				endif;
			endif;
		endif;
	endif;
	moving := false;
	sizingTop := false;
	sizingBottom := false;
	appGrid.dragging := false;
	inheritMethod(label, button, shift, x, y);
	appGrid.mouseUp(appGrid, button, shift, x, y);
end;</source>
        <Parameter name="label" type="CnEcAppGridAppLabel" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="moveAppInfo" id="59fba651-c326-4edc-9849-e0fb304a17fd">
        <updating/>
        <source>moveAppInfo(relX: Real; relY: Real) updating;

// Draws rectangle to indicate appointment label position (if dragging),
// sets appInfo label caption, and moves it to the position specified by x and y coordinates

vars
	relLeft, relTop : Real;

begin
	// If dragging ...
	if moving then
		// ...set appInfo label caption, and ...
		appGrid.appInfo.caption := appGrid.getTime(appDragY).format("HH:mm") &amp; " -&gt; " &amp; (appGrid.getTime(appDragY) + duration * 60000).format("HH:mm") &amp; ", " &amp; duration.String &amp; " min.";
		// ...check if MinMove threshold is reached 
		if (relX - mouseX - appDragX &gt;= self.MinMove or appDragX - relX + mouseX &gt;= self.MinMove or relY - mouseY - appDragY &gt;= self.MinMove or appDragY - relY + mouseY &gt;= self.MinMove) then
			// Draw rectangle to indicate appointment label position
			appGrid.gridTable.drawRectangle(appDragX, appDragY, appDragX + width, appDragY + height, appGrid.backColor);
			// Calculate future label coordinates
			if relX - mouseX &lt; 0 then
				appDragX := 0;
			elseif relX - mouseX + width &gt; (appGrid.gridTable.columns - appGrid.gridTable.leftColumn + 1) * appGrid.columnWidth then
				appDragX := (appGrid.gridTable.columns - appGrid.gridTable.leftColumn + 1) * appGrid.columnWidth - width;
			else
				appDragX := relX - mouseX;
			endif;
			if relY - mouseY &lt; 0 then
				appDragY := 0;
			elseif relY - mouseY + height &gt; appGrid.getY(appGrid.endTime) then
				appDragY := appGrid.getY(appGrid.endTime) - height;
			else
				appDragY := relY - mouseY;
			endif;
			appGrid.gridTable.drawRectangle(appDragX, appDragY, appDragX + width, appDragY + height, appGrid.backColor);
		endif;

	// If moving ...	
	else
		// ...set appInfo label caption, ...
		appGrid.appInfo.caption := start.format("HH:mm") &amp; " -&gt; " &amp; (start + duration * 60000).format("HH:mm") &amp; ", " &amp; duration.String &amp; " min.";	
		// ...make appInfo label visible, and move it to follow the appointment label movement
		if not appGrid.appInfo.visible then
// cnwdad1 24/06/2005 - The controlToForm method has been de-implemented. Now using the
// Control::convertFormPositioin instead.
//			form.controlToForm(appGrid.gridPlane.hwnd(), relLeft, relTop);
			relLeft	:=	self.getFormLeft();
			relTop	:=	self.getFormTop();
			self.convertFormPosition(relLeft, relTop);
			appGrid.appInfo.move(relLeft + relX + 10, relTop + relY + 10, appGrid.appInfo.width, appGrid.appInfo.height);
			appGrid.appInfo.visible := true;
			appGrid.appInfo.refreshNow();
		endif;
	endif;
end;</source>
        <Parameter name="relX" type="Real"/>
        <Parameter name="relY" type="Real"/>
    </JadeMethod>
    <JadeMethod name="moveSelf" id="e0b94a24-adcd-4a29-af9b-514c3f0fc85a">
        <updating/>
        <source>moveSelf(relX: Real; relY: Real; relWidth: Real; relHeight: Real; blnSet: Boolean) updating;

// Moves appointment to a new position

vars

begin
	if moving then		
		move(relX, appDragY, relWidth, relHeight);
	else
		move(relX, relY, relWidth, relHeight);
	endif;
	if blnSet then
		resource := appGrid.getResource(left + width / 2);
		start := appGrid.getTime(top);
		duration := ((appGrid.getTime(top + height) - start).Integer / 60000).rounded;
	endif;
end;</source>
        <Parameter name="relX" type="Real"/>
        <Parameter name="relY" type="Real"/>
        <Parameter name="relWidth" type="Real"/>
        <Parameter name="relHeight" type="Real"/>
        <Parameter name="blnSet" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="remove" id="242cc7dd-06ad-4e8a-ae6f-cdf87b48ad2c">
        <updating/>
        <source>remove() updating;

// Removes appointment label from the grid

vars

begin
	if appGrid.appLabel = self then
		appGrid.appLabel := null;
	endif;
	delete self;
end;</source>
    </JadeMethod>
    <JadeMethod name="set" id="45786487-158c-4a70-85ef-fcbc6c31c0a0">
        <updating/>
        <source>set(resObj: Object; timStart: Time; intDuration: Integer) updating;

// Sets resource, start and duration for the appointment label

vars
	intInd : Integer;

begin
	intInd := appGrid.appResources.indexOf(resObj);
	if intInd &gt;= 1 and timStart &gt;= appGrid.startTime and (timStart + intDuration * 60000) &lt;= appGrid.endTime then
		resource := resObj;
		start := timStart;
		duration := intDuration;
		moving := false;
		moveSelf(appGrid.columnWidth * (intInd - appGrid.gridTable.leftColumn), appGrid.getY(timStart), appGrid.columnWidth, appGrid.rowHeight / appGrid.timeGrid * intDuration, false);
	endif;
end;</source>
        <Parameter name="resObj" type="Object"/>
        <Parameter name="timStart" type="Time"/>
        <Parameter name="intDuration" type="Integer"/>
    </JadeMethod>
