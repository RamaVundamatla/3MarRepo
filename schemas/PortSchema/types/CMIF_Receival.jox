    <JadeMethod name="setMyTrackedItem" id="e337b183-8da8-41c3-965c-db8c6aa825fc">
        <updating/>
        <source>setMyTrackedItem() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     August 2008 ANDREW BISHOP
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpBR : CM_BulkRelease;
	tmpTI : CM_TrackedItem;
begin
	//Make sure TI exists before continuing
	if self.id = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Cargo Id', ETRow_IdCombo, self.myUserObject);
		app.raiseCMException(Input_required_field_cargoId, ETRow_IdCombo, self.myUserObject); // cnwdb2	PAR 35364
		return false;
	else		
		self.myPersistentTrackedItem := self.myTerminal.allOnsiteTIsByIdCargoType[self.id, self.cargoType];
		if self.myPersistentTrackedItem = null then
			app.raiseCMException1(ERR_TI_NOT_ONSITE, self.id, 'id', self.myUserObject);
			return false;
		endif;
	endif;

	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
