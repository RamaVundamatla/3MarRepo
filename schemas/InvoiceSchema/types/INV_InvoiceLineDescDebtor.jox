    <JadeMethod name="addObjectToTable" id="898fa286-f3c1-4ec1-a3bb-a038a4f33048">
        <updating/>
        <source>addObjectToTable(_obj: Object; _numItems: Integer io; _breakOut: Boolean io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2015	cnwmc5	Initial creation	PAR 35858

*/

vars

begin
	if not _obj.isKindOf(CM_DebtorInvoiceLineDesc) then
		return;
	endif;
	
	if _obj.CM_DebtorInvoiceLineDesc.myBankDebtor &lt;&gt; null
	and not _obj.CM_DebtorInvoiceLineDesc.myBankDebtor.terminal = self.myTerminal then
		return;
	endif;
	
	inheritMethod(_obj, _numItems, _breakOut);

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_numItems" type="Integer" usage="io"/>
        <Parameter name="_breakOut" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addObjectsToTable" id="9613d3fc-974d-46ba-8acb-38de07d0f928">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		THis is the query on change of business unit
//
// ---------------------------------------------------------------------------

vars
	bank		: CM_Bank;
	aInvoiceLineDesc : CM_InvoiceLineDesc;
	theInvoiceLineDescs :	CM_InvoiceLineDescByNarrDict;
	tmpPassport	: CM_Passport;
	breakOut	: Boolean;
begin

	self.setMyDataClass();
	// 35872 do change of business unit
	bank := self.cmbBank.listObject.CM_Bank;
	if bank = null then
		self.myCurrentBank := null;
		return;
	endif;
	if bank &lt;&gt; self.myCurrentBank then
		self.myCurrentBank := bank;
		self.msgLines.setAvailable(bank.invoiceLineDescriptors, true);
	endif;
//	TFS 2682	self.caption := self.myCurrentBank.code &amp; " Invoice Line Debtor";
	self.setCaption("Invoice Line Debtor " &amp; self.myCurrentBank.code);

	theInvoiceLineDescs := self.myCurrentBank.allInvoiceLineDescDebtors;
	tmpPassport := app.myPassport;
	
	foreach aInvoiceLineDesc in theInvoiceLineDescs do
		if self.includeObject(aInvoiceLineDesc, tmpPassport) then
			self.addObjectToTable(aInvoiceLineDesc, _numItems, breakOut);
		endif;
		if breakOut then
			break;
		endif;
	endforeach;

end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
