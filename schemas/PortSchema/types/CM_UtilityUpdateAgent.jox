    <JadeMethod name="utlUpdateRouteTemplate" id="63dd90d9-a7b1-49b9-8255-aab1f4b7af3f">
        <updating/>
        <source>utlUpdateRouteTemplate(_pxyRouteTemplate : HMS_RouteTemplate; _passport : CM_Passport input) updating;
//-----------------------------------------------------------------------
//	Created:	17 October 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------

vars
	realRouteTemplate : HMS_RouteTemplate;
	expectedEdition : Integer;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	_pxyRouteTemplate.raiseExceptionIfNotProxy(method);
	_pxyRouteTemplate.validateMe(_passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	_pxyRouteTemplate.pxyGetRealObjectAndEdition(realRouteTemplate, expectedEdition);
	app.setContinueCMExceptions(true);

	if realRouteTemplate = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, _pxyRouteTemplate.code, null, null);
		return;
	endif;
	
	exclusiveLock(realRouteTemplate);

	if _passport.noErrors and realRouteTemplate.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'RouteTemplate', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realRouteTemplate, true);
	endif;
	
	if _passport.noErrors then
		realRouteTemplate.setForUpdate(_pxyRouteTemplate, _passport);
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realRouteTemplate, false);
	endif;
	
end;</source>
        <Parameter name="_pxyRouteTemplate" type="HMS_RouteTemplate"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateSFTPEntity" id="684a7438-0f0a-4aec-8a35-dba80e9c0623">
        <source>utlUpdateSFTPEntity(_proxySFTPEntity : CM_SFTPEntity input; _passport : CM_Passport input);
//
// 19 Sep 2019	cnwrs1	TFS 46087 SFTP
//
vars
	realSFTPEntity: CM_SFTPEntity;
