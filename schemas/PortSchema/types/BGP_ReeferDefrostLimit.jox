<Class name="BGP_ReeferDefrostLimit" id="962f3693-3e42-412e-a089-9b87ded894c7">
    <superclass name="BGP_Request"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>&lt;display&gt;Reefer Defrost Limit&lt;/display&gt;</text>
    <DbClassMap file="backgroundprocess"/>
    <PrimAttribute name="lastCompleted" id="eb41e9fa-ce5b-4182-9b56-07030236f969">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="action" id="6e079448-1957-4fd6-8a16-d8d041cb7301">
        <updating/>
        <source>action(): Boolean updating;
//----------------------------------------------------------------
//	Created:	Aug 2007 cnwrs1 CCMS1551
//----------------------------------------------------------------
vars
	errCode : Integer;
	errTxt : String;
begin

	on Exception do app.alertExceptionHandler(exception, null, self.getErrorDesc(), errCode, errTxt, true, true);
	on LockException do app.alertLockExceptionHandler(exception);

	self.setUser();
	self.rebuildDefrostReefersDict();
	self.processDefrostReefers();
epilog
	if errCode &lt;&gt; null then
		app.myTrxUA.trxUpdateBGPRequest(self, true, errCode, errTxt, app.myPassport);
	endif;
	inheritMethod();	
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getDisplay" id="415aae4e-b455-485e-9530-349f7a53a1b3">
        <source>getDisplay(): String;
//----------------------------------------------------------------
//	Created:	Aug 2007 cnwrs1 CCMS 1551
//----------------------------------------------------------------
vars
	detail	: String;
	defrostLimit : Integer;
begin
	defrostLimit := self.myTerminal.getConfig(ReeferDefrostAlarmTime).Integer;
	detail := inheritMethod() &amp; Tab &amp; 'Checking for reefer containers beyond defrost limit of '&amp;defrostLimit.String&amp;' hours.';
	return detail;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initRequestFromTask" id="e99eee89-877d-4986-9c5c-148518f6c4d7">
        <updating/>
        <source>initRequestFromTask(_task : CM_AutoTaskReeferDefrostLimit) updating;
//----------------------------------------------------------------
//	Created:	Aug 2007 cnwrs1 CCMS1551
//----------------------------------------------------------------
vars
	now : TimeStamp;
begin
	inheritMethod(_task);
	self.lastCompleted	:= self.myTerminal.lastDefrostReefersDictRebuild;
end;</source>
        <Parameter name="_task" type="CM_AutoTaskReeferDefrostLimit"/>
    </JadeMethod>
    <JadeMethod name="processDefrostReefers" id="4274301b-f73c-4605-9cfc-4ccab97b8900">
        <updating/>
        <source>processDefrostReefers() updating, protected;
//----------------------------------------------------------------
//	Created:	CCMS 1551 July 2007 cnwrs1
//----------------------------------------------------------------
// 09/12/2009	cnwdap1		CCMS MES 1007 Any tracked item could now conceivably be a reefer, based on its cargo subtype
// 11/03/2010	cnwdap1		PAR #22938 Correct reefer checking
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
vars
	iter : Iterator;
	ti : CM_TrackedItem;
	//reefer : CM_Container;	// CCMS 1007
	reefer : CM_TrackedItem;	// CCMS 1007
	severity : Integer;
	defrostHours, defrostLimit : Integer;
	checked	: Boolean;
	soundAlarm : Boolean;
	startTime : TimeStamp;
	defrostString : String;
	msg : String;
begin

	startTime := app.actualTimeServer();
	app.lockKeeperNotifyStartActivity(startTime, method, myTerminal, 'BGP_ReeferAlarm::processDefrostReefers', app.myPassport);
	
	defrostLimit := self.myTerminal.getConfig(ReeferDefrostAlarmTime).Integer;

   	iter := self.myTerminal.allDefrostReefers.createIterator;
	msg := self.myTerminal.allDefrostReefers.size.String &amp; ' defrost reefers';
   	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
   	while iter.next(ti) do
		// CCMS 1007 any cargo can be a reefer, and it could be marked as such at product or cargo type level
		// isReefer method on CM_TrackedItem does this expanded check
		if not ti.isReefer then	// CCMS 1007	// PAR #22938 all reefer checking is now consolidated in isReefer method
			continue;
   		endif;
   		
   		//reefer := ti.CM_Container;	// CCMS 1007
   		reefer := ti.CM_TrackedItem;	// CCMS 1007

		if reefer.getDefrostDate = null then 
			continue;
		endif;
		checked := false;
		soundAlarm := false;
		defrostHours := (reefer.getDefrostDate .differenceInHours(startTime));
		if defrostHours &gt; defrostLimit then

			checked := true;
			soundAlarm := true;
			severity := SEVERE_REEFER_DEFROST;
			defrostString := defrostHours.String &amp; " hrs ";
		endif;		
		app.myTrxUA.trxUpdateReeferDefrostAlert(reefer, severity, defrostString, app.myPassport);
		if not app.myPassport.trxCompletedOK then
			msg := 'Error updating alert for tracked item (' &amp; reefer.id &amp; ').';
			app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
			
			app.myPassport.clearErrorsWarnings();
		endif;
	endwhile;
epilog
	app.lockKeeperNotifyEndActivity(startTime, true, app.myPassport);
	delete iter;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="rebuildDefrostReefersDict" id="a92c0686-9c61-4da9-b376-bf21ae4f0ac9">
        <source>rebuildDefrostReefersDict() protected;
//----------------------------------------------------------------
//	Created:	July 2007 cCMS 1551	by cnwrs1
//----------------------------------------------------------------
// 11/03/2010	cnwdap1	PAR #22938 Correct reefer checking
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
//03 Jan 2013	cnwrs1	32983 crash after user deleted.
vars
	iter		: Iterator;
   	ti			: CM_TrackedItem;
	now			: TimeStamp;
//	rebuildDue	: Boolean;
	err			: CM_Error;
	msg : String;
begin

	if self.lastCompleted.isValid then
		if self.lastCompleted.date &gt;= now.date then
			//only do this once a day
			msg := 'Defrost Reefers already rebuilt today';
			app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
			
			return;
		endif;
	endif;
	msg := 'Checking Defrost Reefers reefer list (' &amp; self.myTerminal.allDefrostReefers.size.String &amp; ').';
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
			
	app.myTrxUA.trxSetTermForDefrostRebuild(self.myTerminal, app.myPassport);						

	if not app.myPassport.trxCompletedOK then
		msg := 'Error setting details for terminal (' &amp; self.myTerminal.code &amp; ').';
		app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		app.myPassport.clearErrorsWarnings();
		//don't quit here - best to keep going
	endif;
							
	iter := self.myTerminal.allOnsiteTIsByCargoTypeId.createIterator;
	self.myTerminal.allOnsiteTIsByCargoTypeId.startKeyGeq(TI_CargoType_Container, null, iter);
	while iter.next(ti) do
		if ti.cargoType = TI_CargoType_Container or (ti.isReefer) then	// PAR #22938 all reefer checking now consolidated in isReefer method
			// containers and TIs with products/cargo types that are marked as reefer are teh ones we want
		else
			continue;
		endif;
		
		if global.isValidObject(ti) then// AKB 07Mar2001
			app.myTrxUA.trxUpdateDefrostDict(ti, app.myPassport);
			if not app.myPassport.trxCompletedOK then
				foreach err in app.myPassport.allErrorWarnings do
					msg := err.errorCode.String &amp; " " &amp; err.text;
					app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
					
				endforeach;
				msg := 'Error adding/removing tracked item Defrost Reefers dictionary (' &amp; ti.id &amp; ').';
				app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
				
				app.myPassport.clearErrorsWarnings();
			endif;
		endif;
	endwhile;
	msg := 'Checked off Defrost Reefers list (' &amp; self.myTerminal.chilledTIsOffPower.size.String &amp; ').';
	app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
	
epilog
	delete iter;
end;
</source>
        <access>protected</access>
    </JadeMethod>
</Class>
