    <JadeMethod name="doCmbBankBuild" id="18d16174-ba15-4c6d-b826-ea032b7e151a">
        <source>doCmbBankBuild();
//	35874 build combo for business unit query
vars
	company			: CM_Bank;
	businessUnits	: CM_CompanyByCodeDict;
	currentBU		: CM_Bank;
	combo			: CMUI_ComboBox;
begin

	combo := self.cmbBank;
	create businessUnits transient;
	currentBU := self.myTerminal.getAvailableCompanies(businessUnits);
	foreach company in businessUnits do
		combo.addItem(company.code);
		combo.itemObject[combo.newIndex] := company;
	endforeach;
	if currentBU &lt;&gt; null then
		combo.listObject := currentBU;
	endif;
epilog
	delete businessUnits;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doCmbDebtorBuild" id="2a9c5d94-5965-4b0d-8539-c6d37a7815bd">
        <source>doCmbDebtorBuild();
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	idx : Integer;
	aDebtor : CM_Debtor;
begin
	self.cmbDebtors.clear;
	foreach aDebtor in app.myRoot.myRootCompany.debtors do
		idx := self.cmbDebtors.addItem(aDebtor.name);
		self.cmbDebtors.itemObject[idx] := aDebtor;
	endforeach;



end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbInvTypesBuild" id="643b4ca4-9635-4faa-9322-84689514fc39">
        <source>doCmbInvTypesBuild();
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	idx : Integer;
	anILD : CM_InvoiceDesc;
begin
	self.cmbInvoiceTypes.clear;
	foreach anILD in self.myCurrentBank.invoiceTypes where not anILD.isNotAvailableForEntry do
		idx := self.cmbInvoiceTypes.addItem(anILD.description);
		self.cmbInvoiceTypes.itemObject[idx] := anILD;
	endforeach;



end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbLinesBuild" id="7d715e82-1281-436b-b663-b44c7ea960b1">
        <source>doCmbLinesBuild();
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	idx : Integer;
	anILD : CM_InvoiceLineDesc;
	bank : CM_Bank;
begin
	bank := self.myCurrentBank;
	self.cmbInvoiceLines.clear;
	foreach anILD in bank.invoiceLineDescriptors where not anILD.isNotAvailableForEntry do
		idx := self.cmbInvoiceLines.addItem(anILD.narration);
		self.cmbInvoiceLines.itemObject[idx] := anILD;
	endforeach;


end;</source>
    </JadeMethod>
    <JadeMethod name="doComboDebtorUpdateBuild" id="3ecb686e-0ddd-4ee1-b3d3-441543626c5b">
        <source>doComboDebtorUpdateBuild(_theDebtors : CM_DebtorNodeByNameDict);
// ---------------------------------------------------------------------------
// Created:		October 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 17/06/2014	cnwdap1		PAR #34422 Remove beginLock / endLock
vars
	debtor : CM_DebtorNode;
	
begin
	//beginLock;			// PAR #34422
	
	self.cmbDebtors.clear;
	self.cmbDebtors.sorted := true;
	
	foreach debtor in _theDebtors do
		if debtor.isKindOf(CM_DebtorGroup) then
			continue;
		endif;
		
		self.cmbDebtors.addItem(debtor.name);
		self.cmbDebtors.itemObject[self.cmbDebtors.newIndex] := debtor;
	endforeach;
	
epilog
	//endLock;				// PAR #34422
	
end;</source>
        <Parameter name="_theDebtors" type="CM_DebtorNodeByNameDict"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="c0dc7522-8289-4445-a652-08fabe24dde5">
        <updating/>
        <source>doDelete() updating;
// ---------------------------------------------------------------------------
// Created:		October 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 11/10/2022	navpw1	TFS: 54566 - Changed method to do Bulk Delete of Invoice Line Mappings
vars
	realMapping			: CM_InvoiceLineDescMapping;
	theReturn,
	row, col			: Integer;							// ### TFS 54566 10Oct2022 NAVPW1
	theTable			: CM_DataTable;						// ### TFS 54566 10Oct2022 NAVPW1
	bank				: CM_Bank;							// ### TFS 54566 10Oct2022 NAVPW1
	realDeleteMappings	: CM_InvLineDescMapByDebtorLType;	// ### TFS 54566 10Oct2022 NAVPW1
	invTypeDescription	: String;							// ### TFS 54566 10Oct2022 NAVPW1
	debtor				: CM_DebtorNode;					// ### TFS 54566 10Oct2022 NAVPW1
	invoiceDescLoop,
	invoiceDesc			: CM_InvoiceDesc;					// ### TFS 54566 10Oct2022 NAVPW1
	lineType			: CM_InvoiceLineDesc;				// ### TFS 54566 10Oct2022 NAVPW1
	
begin
	/*realMapping := self.myCurrentBank.allInvoiceLineDescMappings[self.myCurrentDebtor.CM_Debtor,self.myCurrentInvLineType, self.myCurrentInvType];

	if realMapping = null then	
		return;
	endif;*/ // ### TFS 54566 10Oct2022 NAVPW1 - Removed and replaced with new bulk logic below
	
	theTable	:= self.tblData;
	bank		:= self.myCurrentBank;
	row			:= 1;
	col			:= 1;
	
	create realDeleteMappings transient;
	
	while theTable.selectedNext(row, col) do :selectedObjectsLoop
		debtor				:= theTable.accessColumn(col).itemObject.CM_DebtorNode;
		lineType			:= theTable.accessRow(row).itemObject.CM_InvoiceLineDesc;
		invTypeDescription	:= theTable.accessCell(row, col).text;
		
		foreach invoiceDescLoop in bank.invoiceTypes discreteLock do :invoiceTypeLoop
			if invoiceDescLoop.description &lt;&gt; invTypeDescription then
				continue invoiceTypeLoop;
			endif;
			
			invoiceDesc := invoiceDescLoop;
			break invoiceTypeLoop;
			
		endforeach;
		
		realMapping := self.myCurrentBank.allInvoiceLineDescMappings[debtor.CM_Debtor, lineType, invoiceDesc];
		if realMapping &lt;&gt; null then	
			realDeleteMappings.add(realMapping);
			
		endif;
		
	endwhile;
	
	while true do
		//app.myTrxDA.trxDeleteInvoiceLineDescMap(realMapping, app.myPassport);
		app.myTrxDA.trxDeleteBulkInvLineDescMap(realDeleteMappings, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			self.frmProperties.visible := false;
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("Mapping Remove", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;
	
epilog
	delete realDeleteMappings;
	
end;</source>
    </JadeMethod>
