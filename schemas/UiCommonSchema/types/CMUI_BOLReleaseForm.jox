    <JadeMethod name="translateForm" id="7cea717a-2de8-468f-89bc-b00c48861db2">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007284, locale);
	btnCloseSearch.translateBubbleHelp(Xlat_0000159, locale);
	btnCloseSearch.translateCaption(Xlat_0000162, locale);
	btnNew.translateCaption(Xlat_0000168, locale);
	btnPrint.translateCaption(Xlat_0000169, locale);
	btnPrintReceipt.translateBubbleHelp(Xlat_0000181, locale);
	btnPrintReceipt.translateCaption(Xlat_0000182, locale);
	btnResetSearch.translateBubbleHelp(Xlat_0000160, locale);
	btnResetSearch.translateCaption(Xlat_0000163, locale);
	btnSearch.translateBubbleHelp(Xlat_0000167, locale);
	btnSearch.translateCaption(Xlat_0000170, locale);
	btnShowSearch.translateCaption(Xlat_0000165, locale);
	btnVoyageDefin.translateBubbleHelp(Xlat_0000161, locale);
	btnVoyageDefin.translateCaption(Xlat_0000164, locale);
	lblArriveDT.translateCaption(Xlat_0000171, locale);
	lblBerth.translateCaption(Xlat_0000172, locale);
	lblBol.translateCaption(Xlat_0000173, locale);
	lblDischargePort.translateCaption(Xlat_0000131, locale);
	lblLoadPort.translateCaption(Xlat_0000174, locale);
	lblLocation.translateCaption(Xlat_0000175, locale);
	lblNotify.translateCaption(Xlat_0000176, locale);
	lblNumDelivered.translateCaption(Xlat_0000184, locale);
	lblNumRemaining.translateCaption(Xlat_0000185, locale);
	lblQty.translateCaption(Xlat_0000177, locale);
	lblVesselName.translateCaption(Xlat_0000166, locale);
	lblVesselNo.translateCaption(Xlat_0000178, locale);
	lblVoyage.translateCaption(Xlat_0000180, locale);
	lblVoyageNo.translateCaption(Xlat_0000179, locale);
	mnuAddRelease.translateCaption(Xlat_0007285, locale);
	mnuAddReleaseFor.translateCaption(Xlat_0007286, locale);
	mnuCargoContext.translateCaption(Xlat_0007287, locale);
	mnuCargoEnquiry.translateCaption(Xlat_0007288, locale);
	mnuColourLegend.translateCaption(Xlat_0007289, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0007290, locale);
	mnuDeleteRelease.translateCaption(Xlat_0007291, locale);
	mnuInspect.translateCaption(Xlat_0007292, locale);
	optViewAll.translateCaption(Xlat_0004991, locale);
	optViewUnrelease.translateCaption(Xlat_0004992, locale);
	shtReleaseRecord.translateCaption(Xlat_0000132, locale);
end;</source>
