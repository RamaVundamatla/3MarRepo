        <updating/>
        <source>lstIncluded_mouseMove(listbox: ListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     19 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if button = 1 and app.dragDetected(x, y, self.origXPos, self.origYPos) then
		if button = 1 and listbox.listIndex &gt;= 1 then
			self.dragMode := DragMode_Drag;
		endif;
	endif;

end;</source>
