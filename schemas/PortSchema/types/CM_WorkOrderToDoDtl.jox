    <JadeMethod name="addProxyToDoTask" id="52304a45-6359-430c-9464-397ff7210271">
        <source>addProxyToDoTask(toDoTask : CM_ToDoTaskDesc);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
17 November 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen

*/

vars

begin
	self.allToDoTasksDescs.add(toDoTask);
epilog

end;</source>
        <Parameter name="toDoTask" type="CM_ToDoTaskDesc"/>
    </JadeMethod>
    <JadeMethod name="canActionTask" id="9ac74037-905b-47f8-91d5-a7e1d6929870">
        <source>canActionTask(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
16 March 2023		navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs (Task 54263)

*/

vars

begin
	if self.status = WO_STATUS_APPROVED and self.getToDoTaskCountByStatus(STATUS_TODO) = 0 then
		return true;
	else 
		return false;
	endif;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canCompleteToDoTask" id="8510491f-140d-4027-8524-490dd23fa6bb">
        <source>canCompleteToDoTask(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
16 March 2023		navma1	Initial creation
16 March 2023		navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs (Task 54263)

*/

vars
	toDoTaskCount: Integer;
begin
	toDoTaskCount := self.getToDoTaskCountByStatus(STATUS_TODO); 
	
	if app.myPassport.isVASEnabled() and toDoTaskCount &gt; 0 then
		if self.status = WO_STATUS_PARTCOMPLETE or 
		   self.status = WO_STATUS_APPROVED or 
		   self.status = WO_STATUS_ACTIONED then	
			return true;
		endif;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="completeMe" id="dcf81a77-6ff0-4a45-89cd-ed0942896fe1">
        <source>completeMe();

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
30 November 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/

vars
	dtl : CM_WorkOrderDtl;
	workOrder : CM_WorkOrder;
	complete : Boolean;
begin
	workOrder:=self.getMyParent;
	// check is parent is now also complete
	complete := true;
	foreach dtl in workOrder.allWoDtls do
		if not dtl.CM_WorkOrderToDoDtl.status = WO_STATUS_COMPLETE then
			complete := false;
			break;
		endif;
	endforeach;
	if complete then 
		workOrder.completeMe();
	endif;
	
	// update edition on parent so we get a notification in the Work Order Enquiry screen
	self.updateObjectEdition(workOrder);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createTransWhenAction" id="3f38434c-4753-4f2f-b12f-3723587663eb">
        <source>createTransWhenAction(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Jul 2023	navma1	Bug 59158: MTN - Actioning ToDo work orders doesn't create Update Transaction
*/

vars

begin
	if not self.getMyTerminal.getConfig(AllowAutoActionToDoWO).Boolean then
		return true;
	endif;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createWOJobs" id="c4968626-ae71-4bc3-a34f-ffbeb3695cd6">
        <source>createWOJobs( _woActionIF     : CMIF_WorkOrderAction;
			  _jobParams  	   : CMIF_WorkOrderJobParams input; 
			  _realJob         : CM_Job io;
			  _passport        : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Apr 2023 navma1  ChangeRequest 57569:[57570] EUP - [Framework] Refactor Actioning Work Order Tasks
06 Jun 2023 navma1  ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation
17 Jul 2023	navma1	Bug 59158: MTN - Actioning ToDo work orders doesn't create Update Transaction
*/

vars
	toDotaskDesc 	: CM_ToDoTaskDesc;
	term		 	: CM_Terminal;
	idx				: Integer;
begin
	
	if self.CM_WorkOrderToDoDtl.allToDoTasksDescs.isEmpty then
		return;
	endif;

	term						 := self.myParent.myTerminal;										
	_jobParams.jobId 			 := getJobId();
	_jobParams.myWorkOrderDtl 	 := self; 											
	_jobParams.requiredByDT 	 := self.requiredByDT;
	
	idx := 1;
	
	foreach toDotaskDesc in self.CM_WorkOrderToDoDtl.allToDoTasksDescs do
		_jobParams.myToDoTaskDesc := toDotaskDesc;
		_jobParams.jobId 		  := _jobParams.jobId &amp; Hyphen &amp; idx.String;
		
		app.myUtilityCA.utlCreateInternalWorkOrderJob(self,_jobParams, _realJob, _passport );
		idx := idx +1;
	endforeach;
epilog

end;</source>
        <Parameter name="_woActionIF" type="CMIF_WorkOrderAction"/>
        <Parameter name="_jobParams" type="CMIF_WorkOrderJobParams" usage="input"/>
        <Parameter name="_realJob" type="CM_Job" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createWOTransaction" id="90d0956f-945f-4b9e-a0b7-1e5ced48a1ab">
        <source>createWOTransaction(_transType: Integer; _resourceUsageProxys : CM_ResourceTypeUsageSet; _task : CM_ToDoTask): CM_WOTransaction;
/*
Purpose:			

Date		Who		Reason
18 March 2024	navab1	CR 62818 TASK 62821
*/

vars
	trans : CM_WOTransaction;
	job : CM_Job;
begin
	trans :=  inheritMethod(_transType, _resourceUsageProxys, _task); // ### JIRA 23013 16OCT2024 NAVAB1

	job := self.allJobs.first;

	if job &lt;&gt; null then
		if job.isRetrospective() then
			trans.setDateTime(job.retrospectiveDT);
		endif;
	endif;
	
	return trans;

epilog

end;</source>
        <Parameter name="_transType" type="Integer"/>
        <Parameter name="_resourceUsageProxys" type="CM_ResourceTypeUsageSet"/>
        <Parameter name="_task" type="CM_ToDoTask"/>
        <ReturnType type="CM_WOTransaction"/>
    </JadeMethod>
    <JadeMethod name="doActionTask" id="2b22a71a-e79a-4813-954d-a3c2f92c4c90">
        <updating/>
        <source>doActionTask(_woActionIF: CMIF_WorkOrderAction; _realJob: CM_Job io; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2023		navma1	Initial creation

*/

vars

begin
	inheritMethod(_woActionIF, _realJob, _passport);
	
	self.doActionTaskKnown(_woActionIF,_realJob,_passport);

epilog

end;</source>
        <Parameter name="_woActionIF" type="CMIF_WorkOrderAction"/>
        <Parameter name="_realJob" type="CM_Job" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doActionTaskKnown" id="964dc90e-0855-48dd-80d2-62c909760dea">
        <updating/>
        <source>doActionTaskKnown(_woActionIF  : CMIF_WorkOrderAction;
				  _realJob	   : CM_Job io;
				  _passport    : CM_Passport input)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Apr 2023 navma1  ChangeRequest 57569:[57570] EUP - [Framework] Refactor Actioning Work Order Tasks
17 Jul 2023	navma1	Bug 59158: MTN - Actioning ToDo work orders doesn't create Update Transaction
*/

vars
	workOrder 		: CM_WorkOrderToDo;
	jobParams		: CMIF_WorkOrderJobParams;
begin
	workOrder		:= self.myParent.CM_WorkOrderToDo;
	
	/*
	Move to Actioned Collection
	*/
	
	if self.isKindOf(CM_WodToDoNonOperational) then
		self.CM_WodToDoNonOperational.allDebtors.copy(self.CM_WodToDoNonOperational.allDebtorsActioned);
		
	elseif self.isKindOf(CM_WodToDoTrain) then
		self.CM_WodToDoTrain.allTrains.copy(self.CM_WodToDoTrain.allTrainsActioned);
	
	elseif self.isKindOf(CM_WodToDoVBS) then
		self.CM_WodToDoVBS.allVBSSlots.copy(self.CM_WodToDoVBS.allVBSSlotsActioned);
		
	elseif self.isKindOf(CM_WodToDoVehicleVisit) then
		self.CM_WodToDoVehicleVisit.allVehicleVisits.copy(self.CM_WodToDoVehicleVisit.allVehiclesActioned);
		
	elseif self.isKindOf(CM_WodToDoVoyage) then
		self.CM_WodToDoVoyage.allVoyages.copy(self.CM_WodToDoVoyage.allVoyagesActioned);
		
	elseif self.isKindOf(CM_WodToDoWagon) then
		self.CM_WodToDoWagon.allWagons.copy(self.CM_WodToDoWagon.allWagonsActioned);

	endif;
	
	if app.myPassport.noErrors then		
		//Create WO Job
		create jobParams transient;
		self.createWOJobs(_woActionIF,jobParams,_realJob,_passport); 				
	endif;
	
epilog
	delete jobParams;
end;</source>
        <Parameter name="_woActionIF" type="CMIF_WorkOrderAction"/>
        <Parameter name="_realJob" type="CM_Job" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUnApprove" id="0b588b99-4250-4e9a-aa86-9104735ce893">
        <updating/>
        <source>doUnApprove(_passport : CM_Passport input)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Apr 2024 navhl20 ChangeRequest 63583: EUP | 54014 - Cargo Work Orders Enhancements - Remedial
11 Sep 2024 navah1  Bug 65907: EUP - Error 1310 when actioning work order that has been un - approved before
*/

vars
	linkedJob,
	job 		: CM_Job;
	doUnApprove	: Boolean;
	wle			: CM_WorkListEntry;
	term		: CM_Terminal;
begin
	doUnApprove := true;
	foreach job in self.allJobs do
		if not job.status = JOB_UNACTIONED then
			doUnApprove := false;
		endif;
	endforeach;
	
	if doUnApprove then
		foreach job in self.allJobs do
			wle := job.workListEntries.first(); //10/04/2025	navkc1 JIRA Story MTN-34492
			
			//10/04/2025	navkc1 JIRA Story MTN-34492
			if wle &lt;&gt; null then
				linkedJob := wle.getLinkedJob();
			endif;
			
			app.myUtilityDA.utlDeleteJob(job, _passport);
			
			//10/04/2025	navkc1 JIRA Defect Sub-task MTN-34619 - Send notification on the linked job so the WO Ops screen gets updated
			if linkedJob &lt;&gt; null then
				term := linkedJob.getMyTerminal();
				
				if term &lt;&gt; null then
					linkedJob.causeEvent(term.getTerminalEvent(WorkOrderJob_Update_Event), false, linkedJob);
				endif;
			endif;
		endforeach;
	endif;
	
	if self.allJobs.isEmpty() then
		self.setStatus(WO_STATUS_USERENTRY);
	endif;
	
	//11.09.2024 navah1 #65907 Start
	self.allToDoTasks.purge(); 
	
	if self.isKindOf(CM_WodToDoNonOperational) then
		 self.CM_WodToDoNonOperational.allDebtorsActioned.clear();
		
	elseif self.isKindOf(CM_WodToDoTrain) then
		self.CM_WodToDoTrain.allTrainsActioned.clear();
	
	elseif self.isKindOf(CM_WodToDoVBS) then
		self.CM_WodToDoVBS.allVBSSlotsActioned.clear();
		
	elseif self.isKindOf(CM_WodToDoVehicleVisit) then
		self.CM_WodToDoVehicleVisit.allVehiclesActioned.clear();
		
	elseif self.isKindOf(CM_WodToDoVoyage) then 
		self.CM_WodToDoVoyage.allVoyagesActioned.clear(); 
		
	elseif self.isKindOf(CM_WodToDoWagon) then
		self.CM_WodToDoWagon.allWagonsActioned.clear();
	endif;
	//11.09.2024 navah1 #65907 End
	
epilog

 

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="ce2a28a5-e790-4910-b1ab-078e19c3e236">
