    <JadeMethod name="doVesselChange" id="8b16961c-b3e8-412f-b134-4dea07717c14">
        <updating/>
        <source>doVesselChange() updating;
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//-----------------------------------------
vars
begin

	if self.myCurrentWorkingVoyage &lt;&gt; null then
		self.doVesselChangeWorkingVoyage();
	else
		self.loadAddVoyage();
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doVesselChangeWorkingVoyage" id="510254a9-29fa-409d-9c21-b5483640a189">
        <updating/>
        <source>doVesselChangeWorkingVoyage() updating;
//-----------------------------------------
//Created: July 2003 By: cnwgd1
//-----------------------------------------
vars
	posn:				Integer;
	workingMovement:	CMIF_HMS_WorkingMovement;
	newShip:			CM_Vessel;
	agent:				CM_ShippingAgent;
	contact:			CM_EmailAddress2;
	agentIsDefault:		Boolean;
	shippingLine:		CM_ShippingLine;
	lastVoyage:			CM_Voyage;
	commodity: 			CM_Commodity;
	stevedore:			CM_Stevedore;
	dwellTime:			Integer;
	tmpDT:				TimeStamp;
	vesselData:			HMS_VesselData;
begin
	if self.myCurrentWorkingVoyage = null then
		return;
	endif;
	// A change has occurred: Enable the 'Apply' button
	self.enableDisableApplyBtn(true);
	
	newShip := self.cmbVessel.listObject.CM_Vessel;	
	if newShip = null then
		return;
	endif;
	vesselData := newShip.myHMSVesselData;
	if vesselData = null then
		if app.msgBox(app.getErrorString1(HMS_Cannot_Create_Voyage, newShip.name), app.getErrorString(HMS_Vessel_Data_Required), MsgBox_Stop_Icon+MsgBox_Yes_No) = MsgBox_Return_Yes then
			//Open vessel definition
			self.showVesselMaintenance(newShip);
		endif;
		self.cmbVessel.listIndex := self.cmbVessel.findObject(self.myCurrentVessel);
		return;
	endif;		
	
	// ------------------------------------------------------------------------------
	// If ship for selected voyage has changed, then update the default agent and shipping line on all movements
	self.myCurrentWorkingVoyage.myHMSVoyageData.setPxyFromVessel(newShip, self.myCurrentWorkingVoyage.ofTerminal);

	self.setMyCurrentVessel(newShip);

	self.loadPreferredBerthList();

	if myCurrentWorkingVoyage.ofClonedVoyage=null then
		// ADD mode - new voyage - use allClonedMovements

		self.setLastVoyageDefaults(newShip);

		foreach workingMovement in myCurrentWorkingVoyage.allClonedMovements do
			// Set initialise values for new ship
			workingMovement.init_CustomerForMove(agent,shippingLine,agentIsDefault,contact);			
			workingMovement.myShippingAgent:=agent;
			workingMovement.myShippingLine:=shippingLine;
			workingMovement.myContact:=contact;
			workingMovement.isAgentDefault:=agentIsDefault;			
			workingMovement.myMoveTidalClass:=workingMovement.init_MoveTidalClass;
			
			tmpDT := workingMovement.occursOnDT;
			if workingMovement.moveType = HMSMovementTypeArrival then
				tmpDT := myCurrentWorkingVoyage.arrivedDT;
			elseif workingMovement.moveType = HMSMovementTypeDeparture then
				tmpDT := myCurrentWorkingVoyage.departedDT;
			endif;
			workingMovement.setInitialiseValues(agentIsDefault, tmpDT, workingMovement.moveType);
			workingMovement.allWorkingResUsed.purge();
			vesselData.getDefaultResourcesForCMIFMove(workingMovement);	
		endforeach;

	else
		// EDIT mode - use allWorkingMovements and set notYetSaved property so
		// that these changes are reflected in the database
		foreach workingMovement in myCurrentWorkingVoyage.ofClonedVoyage.allWorkingMovements do

			// Set initialise values for new ship
			workingMovement.init_CustomerForMove(agent,shippingLine,agentIsDefault,contact);						
			workingMovement.myShippingAgent:=agent;
			workingMovement.myShippingLine:=shippingLine;
			workingMovement.myContact:=contact;
			workingMovement.isAgentDefault:=agentIsDefault;						
			workingMovement.notYetSaved:=true;
			workingMovement.myMoveTidalClass:=workingMovement.init_MoveTidalClass;
			tmpDT := workingMovement.occursOnDT;					
			workingMovement.setInitialiseValues(agentIsDefault, tmpDT, workingMovement.moveType);										
		endforeach;
	endif;
	// ------------------------------------------------------------------------------
	// Set default class in 
	if self.myCurrentWorkingVoyage.myHMSVoyageData.myVesselCategoryIn&lt;&gt;null then
		posn:=cbxClassIn.findObject(self.myCurrentWorkingVoyage.myHMSVoyageData.myVesselCategoryIn);
		if posn&gt;0 then
			cbxClassIn.listIndex:=posn;
			cbxClassIn.text:=cbxClassIn.itemText[cbxClassIn.listIndex];
		endif;
	endif;
	// Set default class out 
	if self.myCurrentWorkingVoyage.myHMSVoyageData.myVesselCategoryIn&lt;&gt;null then
		posn:=cbxClassOut.findObject(self.myCurrentWorkingVoyage.myHMSVoyageData.myVesselCategoryIn);
		if posn&gt;0 then
			cbxClassOut.listIndex:=posn;
			cbxClassOut.text:=cbxClassOut.itemText[cbxClassOut.listIndex];
		endif;
	endif;

	// Modified by Russell 01/04/99
	// ----------------------------------------------------------
	// Generate new voyage code
	tbxVoyageCode.text := self.createSystemVoyCode();

	self.loadSummaryTbl();

end;</source>
    </JadeMethod>
    <JadeMethod name="enableDisableApplyBtn" id="0708a3c0-5bfd-4f93-8868-69f47bf7740c">
        <updating/>
        <source>enableDisableApplyBtn(enab: Boolean) updating;

vars
begin
 	// This method enables and disables the 'APPLY' button
 	if canEdit=true then
	 	if enab=true then
	 		btnApply.enabled := true;
	 	else
	 		btnApply.enabled := false;
	 		self.btnShipDetails.visible := false;	 		
	 	endif;
	 endif;		
end;</source>
        <Parameter name="enab" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="enableMoveEditDelete" id="af479b49-c473-4f6b-a5d0-ca5ce6f1f6c8">
        <updating/>
        <source>enableMoveEditDelete() updating;

vars
	currColumn:		Integer;
begin
	// This method is called when a movement is selected in the movements table
	// The 'Edit' button is enabled in all cases
	// The 'Delete' button is enabled only if the selected movement is a SHIFT movement

	btnEditMovement.enabled:=true;
	btnEditMovement.bubbleHelp:="";

	if canEdit=true then
		currColumn:=self.tblMovements.column;
		self.tblMovements.column:=1;
		if self.tblMovements.currentMovement &lt;&gt; null then
			if self.tblMovements.currentMovement.moveType = HMSMovementTypeShift then
				// Enable delete button
				btnDeleteMove.enabled:=true;
				btnDeleteMove.bubbleHelp:="";
			else
				// Disable delete button
				btnDeleteMove.enabled:=false;
				btnDeleteMove.bubbleHelp:="Delete cannot be performed, " &amp; CrLf &amp; "on an 'Arrival' or 'Departure' movement";
			endif;
		endif;
		self.tblMovements.column:=currColumn;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="enableMoveMaint" id="04043e7f-0da1-4c4b-aabd-820a144f73a9">
        <updating/>
        <source>enableMoveMaint() updating;

vars

begin
 	// This method is called when an existing voyage has a collection of movements
	// associated with it. The method enables the movement 'ADD' button and sets the
	// the bubble help on all movement maintenance buttons
	btnAddMovement.enabled := true;
	btnAddMovement.bubbleHelp := "Add a new 'SHIFT' movement";
	btnEditMovement.enabled := false;
	btnEditMovement.bubbleHelp := "Edit cannot be performed, " &amp; CrLf &amp; "No movement is selected";
	btnDeleteMove.enabled := false;
	btnDeleteMove.bubbleHelp := "Delete cannot be performed, " &amp; CrLf &amp; "No movement is selected";

	// Disable arrival and departure Date/Time editing on the voyage details form
	// This is now handled by the movement details form
	self.txtDateArrival.enabled := false;
	self.txtDateArrival.bubbleHelp := "To change the arrival date," &amp; CrLf &amp; "'Edit' the arrival movement below";
	self.txtTimeArrival.enabled := false;
	self.txtTimeArrival.bubbleHelp := "To change the arrival time," &amp; CrLf &amp; "'Edit' the arrival movement below";
	self.txtDateDepart.enabled := false;
	self.txtDateDepart.bubbleHelp := "To change the departure date," &amp; CrLf &amp; "'Edit' the departure movement below";
	self.txtTimeDepart.enabled := false;
	self.txtTimeDepart.bubbleHelp := "To change the departure time," &amp; CrLf &amp; "'Edit' the departure movement below";
end;</source>
    </JadeMethod>
