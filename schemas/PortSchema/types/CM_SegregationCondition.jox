    <JadeMethod name="setForUpdate" id="80d1cd05-e90c-42aa-a1b0-df395f91335c">
        <updating/>
        <source>setForUpdate(_pxyCondition : CM_SegregationCondition) updating;
/*
----------   ----------  --------------------------------------------------
Created:	24 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	
begin
	self.raiseExceptionIfTransient(method);
	
	self.code 				:= _pxyCondition.code;
	self.description		:= _pxyCondition.description;
	self.colour				:= _pxyCondition.colour;
	self.isActive			:= _pxyCondition.isActive;
	self.allowedSameArea 	:= _pxyCondition.allowedSameArea;
	self.proximityHorizontal:= _pxyCondition.proximityHorizontal;
	self.proximityVertical	:= _pxyCondition.proximityVertical;
	self.proximityDepth		:= _pxyCondition.proximityDepth;
	self.myTerminal			:= app.myPassport.myTerminal;
	
	// 09/02/2015 cnwar2 #33755 - backed out
	/*// 27/01/2014 cnwar2 #33232
	if self.proximityHorizontal = 0
	and self.proximityVertical = 0 then
		self.isActive := false;
	endif;*/
	
end;


</source>
        <Parameter name="_pxyCondition" type="CM_SegregationCondition"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="30b1efd8-58b5-4c6e-b73d-7e0f13e77bb2">
        <updating/>
        <source>setProxy(_code,
		_description		: String;
		_colour				: Integer;
		_isActive,
		_allowedSameArea	: Boolean;
		_proxHorz,
		_proxVert,
		_proxDepth			: Integer) updating;
/*
----------   ----------  --------------------------------------------------
Created:	24 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	self.code 				:= _code;
	self.description		:= _description;
	self.colour				:= _colour;
	self.isActive			:= _isActive;
	self.allowedSameArea 	:= _allowedSameArea;
	self.proximityHorizontal:= _proxHorz;
	self.proximityVertical	:= _proxVert;
	self.proximityDepth		:= _proxDepth;
	
end;


</source>
