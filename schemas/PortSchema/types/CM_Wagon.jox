        <interfaceImplements>
            <JadeInterfaceMethod name="IF_DamageDetails::purgeAllDamageInstances"/>
        </interfaceImplements>
        <source>purgeAllDamageInstance();

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2009	cnwer1	Initial creation

