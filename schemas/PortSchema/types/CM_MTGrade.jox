    </JadeMethod>
    <JadeMethod name="validateMe" id="87f7cd3e-9ea9-44bb-ae4e-0b32efd89bda">
        <source>validateMe() protected;
/*
28 Aug 2017	cnwma1 TFS #5624 JMT- Error appearing when opening Terminal Admin 'MT Threshold Details' table
*/
vars
	term : CM_Terminal;
	mTThreshold : CM_MTThreshold;
begin
	// null is allowed but only once
	/*if self.code = null then
		app.raiseCMException1(REQUIRED_FIELD, 'Availability Grade Code', null, null);
	endif;*/
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Availability Grade Description', null, null);
		app.raiseCMException(Input_required_field_avaiGrdD, null, null); // cnwdb2	PAR 35364
	endif;
//	if self.isNotAvailableForEntry and not self.allCodeTranslations.isEmpty then
//		app.raiseCMException2(NotAvailableForEntryError, 'Availability Grade', 'Code Group Translations exist', null, null);
//	endif;
	
	//28.8.2017 cnwma1 TFS #5624
	if self.isNotAvailableForEntry then
		foreach term in app.myRoot.allTerminals do
			foreach mTThreshold in term.allMTThresholds do
				if mTThreshold.myMTGrade &lt;&gt; null then
					if self.code = mTThreshold.myMTGrade.code then
						app.raiseCMException2(Error_MTGRADE_NA, self.description,term.code,null, null); 
						break;
					endif;
				endif;
			endforeach;
		endforeach;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
