    <JadeMethod name="aaa_test" id="d34c9b65-ecdc-4255-aa34-565cbad752ee">
        <source>aaa_test();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 September 2025	naviv1	Initial creation

*/

vars
	terminal : CM_Terminal;
	ti, pxyTI : CM_TrackedItem;
	coll : CM_TITransactionByTypeDateDict;
begin
	app.initialize();
	terminal		:= app.myRoot.allTerminals["DAVE"];
	
	app.myPassport.setMyTerminal(terminal);
	 
	ti := "2367.62939885".asOid.CM_TrackedItem;
	
	beginLoad;
	pxyTI := ti.pxyCreateUpdateProxy();
	endLoad;
	
	pxyTI.zSetPxyLoadSeqNumber("TEST");
	
	app.myTrxUA.trxUpdateTrackedItem(pxyTI,null,TI_UPDMODE_NORMAL, null, app.myPassport);
	
	write ti.loadSeqNumber;
	
	exclusiveLock(coll);
	
	
epilog

end;</source>
