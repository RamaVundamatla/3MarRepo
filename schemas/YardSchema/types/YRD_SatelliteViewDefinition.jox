    <JadeMethod name="doResize" id="20f3cc05-88fb-4805-b62a-d49f5bff3196">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 Jul 2008	cnwer1	Initial creation
10 Dec 2019	Bug 47939: STWO - Objects out of view in satellite definition screen

*/

vars

begin
	inheritMethod();

	self.frmScrollablMain.height := self.dkcGridArea.height;//-10;
	self.frmScrollablMain.width  := self.dkcGridArea.width;
	//self.frmScrollablMain.resizeScrollingFrame(2000,2000);    	  //10.12.2019 cnwma1 #47939
	self.frmScrollablMain.resizeScrollingFrame(4000,3000);    	      //10.12.2019 cnwma1 #47939
	self.frmScrollablMain.repositionScrollBars();                

	self.lstAreas.width  := dkcFilter.width - dkcFilter.borderWidthLeft - dkcFilter.borderWidthRight - 5;
	self.lstAreas.height := dkcFilter.height - 1;
	
epilog

end;</source>
