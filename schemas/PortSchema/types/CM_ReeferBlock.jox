    <JadeMethod name="auditIdDisplay" id="0b3775b9-88b4-401f-b3b0-2324b0f8315f">
        <source>auditIdDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2020	jlgndl1	Initial creation	TFS 49579

*/

vars

begin
	return "Reefer Walk Path " &amp; self.name;

epilog

