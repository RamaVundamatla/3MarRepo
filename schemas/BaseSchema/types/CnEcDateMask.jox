    <JadeMethod name="dateFormat" id="a705e935-2e5a-49ab-aa6a-3ad92a0ad5c0">
        <source>dateFormat():String protected;
// --------------------------------------------------------------------------------
// Created:		05 July 2003 by cnwdad1
//
// Purpose:		Returns the format of the date.
//
// Parameters:	None
//
// Returns:		The date format.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
//write app.currentLocaleInfo.dateInfo.shortFormat;
	return app.currentLocaleInfo.dateInfo.shortFormat;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="dateFormatNoSeparators" id="e1d7348b-80b5-41d3-810b-a4e44951beb7">
        <source>dateFormatNoSeparators():String protected;
// --------------------------------------------------------------------------------
// Created:		05 July 2003 by cnwdad1
//
// Purpose:		Returns the format of the date, without any separator characters.
//
// Parameters:	None
//
// Returns:		The date format.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dateFormat		: String;
	dateSeparator	: String;
	
begin
	dateSeparator	:=	app.currentLocaleInfo.dateInfo.separator;
	dateFormat		:=	self.dateFormat();
	dateFormat		:=	dateFormat.cnEcRemoveSubstring(dateSeparator);
	
	return dateFormat;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="dblClick" id="98ecc1cf-7ccc-4601-bf7e-47d268cb4a69">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>dblClick(editMask: JadeEditMask input) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		14 February 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	calendarFormObj	: CnEcCalendarSelectForm;

begin
	app.mousePointer	:=	Busy;

	if self.readOnly then
		return;
	endif;

	create calendarFormObj;

	if self.text.Date.isValid() then
		calendarFormObj.setStartDate(self.text.Date);
	endif;

	self.doPositionCalendar(calendarFormObj);
	calendarFormObj.showModal();

	if calendarFormObj.modalResult = Form.CNEC_MODAL_SELECT then
		self.setDate(calendarFormObj.getDate());
	endif;

	inheritMethod(editMask);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="editMask" type="JadeEditMask" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doPositionCalendar" id="72eb3f74-ef6c-452e-854d-b583d7547f62">
        <updating/>
        <source>doPositionCalendar(pCalendarFormObj:CnEcCalendarSelectForm io) updating, protected;
// --------------------------------------------------------------------------------
// Created:		14 February 2003 by cnwdad1
//
// Purpose:		Positions the pop-up calendar form next to the calling control.
//
// Parameters:	pCalendarFormObj - The pop-up calendar form.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	controlObj			: Control;
	parentFormObj		: Form;
	screenTop			: Real;
	screenLeft			: Real;
	screenHeight		: Real;
	screenWidth			: Real;
	posControlLeft		: Real;
	posControlTop		: Real;
	posFormLeft			: Real;
	posFormTop			: Real;
	
begin
	// Starting with self, well work up the tree of the control's parents.
	
	controlObj	:=	self;
	
	while not controlObj.parent.isKindOf(Form) do
		controlObj	:=	controlObj.parent.Control;
	endwhile;
	
	// Get the screen and date mask control dimensions.
	
	parentFormObj	:=	controlObj.parent.Form;
	parentFormObj.getDeskTopWorkArea(screenLeft, screenTop, screenWidth, screenHeight);
	self.windowToScreen(posControlLeft, posControlTop);
	
	// We'll start by placing the calendar form at the right if the date mask control.
	
	posFormLeft	:=	posControlLeft + self.width;
	posFormTop	:=	posControlTop;
	
	// Now work out where to place the calendar form.
	
	if (posFormLeft + pCalendarFormObj.width) &gt; screenWidth then
		// The right-hand edge of the form is outside the screen area, so try putting
		// the calendar form on the left-hand side of the control.
		posFormLeft	:=	posControlLeft - pCalendarFormObj.width;
		
		if posFormLeft &lt; screenLeft then
			// The left-hand edge of the form is outside the screen area, so try putting
			// the calendar form immediately beneath the control.
			posFormLeft	:=	posControlLeft;
			posFormTop	:=	posControlTop + self.height;
		endif;
	endif;
	
	if (posFormTop + pCalendarFormObj.height) &gt; screenHeight then
		// The bottom edge of the form is outside the screen area, so try putting
		// the calendar form above the control.
		posFormTop	:=	(posControlTop + self.height) - pCalendarFormObj.height;
		
		if posFormTop &lt; screenTop then
			// The top edge of the form is outside the screen area, so we'll reset the
			// calendar form positions to zero and let the form center itself when it loads.
			posFormLeft	:=	0;
			posFormTop	:=	0;
		endif;
	endif;
	
	// Set the values on the pop-up calendar form.
	
	pCalendarFormObj.setPosition(posFormLeft.Integer, posFormTop.Integer);
end;</source>
        <access>protected</access>
        <Parameter name="pCalendarFormObj" type="CnEcCalendarSelectForm" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setDate" id="6233537c-1318-42ef-9d36-925f7e94bcbc">
        <updating/>
        <source>setDate(pDate:Date) updating;
// --------------------------------------------------------------------------------
// Created:		12 February 2003 by cnwdad1
//
// Purpose:		Sets the receiver's current date.
//
// Parameters:	pDate - The new date value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if pDate.isValid() then
		self.textUser	:=	pDate.format(self.dateFormatNoSeparators());
	else
		self.textUser	:=	null;
	endif;
end;</source>
        <Parameter name="pDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="907ad5b8-5600-4c7b-aff9-ef8e359b4946">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating, clientExecution;
// --------------------------------------------------------------------------------
// Created:		14 February 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	today	: Date;
	
begin
	self.autoTab	:=	true;
	self.insertMode	:=	false;
	self.mask		:=	self.dateFormat();
	
	inheritMethod(cntrl, persistCntrl);
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
    <JadeMethod name="xHandlerDate" id="67442a51-750e-41ed-a6fb-8b64eafc6435">
        <source>xHandlerDate(pExceptionObj:Exception; pErrorMsg:String output):Integer protected;
// --------------------------------------------------------------------------------
// Created:		21 June 2007 by cnwdad1
//
// Purpose:		An exception handler to deal with an invalid date when fetching the
//				text entered by the user.
//
// Parameters:	_exceptinObj - A reference to the exception object.
//
// Returns:		The action to take following the exception.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	pErrorMsg	:=	"The date format is not valid (" &amp; self.text.trimBlanks() &amp; ")";
	
	return Ex_Abort_Action;
end;</source>
        <access>protected</access>
        <Parameter name="pExceptionObj" type="Exception"/>
        <Parameter name="pErrorMsg" type="String" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
