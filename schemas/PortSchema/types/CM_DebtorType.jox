    <JadeMethod name="isSystemGenerated" id="142a436a-0912-435c-a87f-8e0ef0928ca6">
        <source>isSystemGenerated() : Boolean;
// ---------------------------------------------------------------------------
// Created:	14 April 2008 By Graeme Black cnwgb1 Par 16666
// All debtor types corresponding to pre-existing types have codes SDT1..SDT8
//  June 2010 par 24094 added SDT9 Carrier
// 11/01/2017	cnwdap1		TFS 3042 SNO Empty Container Pool Management - added SDT0
// 31/05/2019	jlgdap1		TFS 44554 AAT Stevedore Data Access
// ---------------------------------------------------------------------------
begin
	//return self.code.length = 4 							// TFS 44554
	return (self.code.length = 4 or self.code.length = 5)	// TFS 44554
		and self.code[1:3] = "SDT"
		and self.code[4] &lt;= '9';
		//and self.code[4] &gt; '0';			// TFS 3042
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
