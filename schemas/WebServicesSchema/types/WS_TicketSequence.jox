<Class name="WS_TicketSequence" id="e77bb8b6-af88-441a-ade1-0d2433df0497">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>A series of numbers that will represent log numbers, attached to a log docket</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="fromId" id="36c2e128-f82c-42d7-abd6-690d61de763f">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="scale" id="9fa1def0-91ca-4950-b642-9db20d6f86bd">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="toId" id="1b89de3b-ac8e-4758-b67c-9153274cc67f">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="ca2adb5d-d014-4c45-9cf9-a4ef0f9f5ca9">
        <updating/>
        <source>setProxyFromObject(_ticket : CM_Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 December 2014	cnwmc5	Initial creation

*/

vars

begin
	inheritMethod(_ticket);
	
	if _ticket.isKindOf(CM_TicketSequenceData) then
		self.fromId := _ticket.CM_TicketSequenceData.fromId;
		self.toId	:= _ticket.CM_TicketSequenceData.toId;
		self.scale	:= _ticket.CM_TicketSequenceData.scale;
	elseif _ticket.isKindOf(CM_TicketSequence) then
		self.fromId := _ticket.CM_TicketSequence.fromId;
		self.toId	:= _ticket.CM_TicketSequence.toId;
		self.scale	:= _ticket.CM_TicketSequence.scale;
	endif;

epilog

end;</source>
        <Parameter name="_ticket" type="CM_Object"/>
    </JadeMethod>
</Class>
