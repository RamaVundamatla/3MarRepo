    <JadeWebServicesMethod name="getCommodities" id="291edeb9-fbb8-4743-a975-e58d212dcd0e">
        <usesRPC>default</usesRPC>
        <source>getCommodities() : WS_CommoditiesResponse webService;

/*

Purpose:			Get all the valid Commoditoes for the current user.

Parameters:			None

Return Value:		


Date		Who		Reason
15 Jul 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars
	response		: WS_CommoditiesResponse;
	completedOK		: Boolean;
	
	commodity		: CM_Commodity;
	proxyCommodity	: WS_Commodity;
	failedDAC  		: CM_DataAccessController;
	passport		: CM_Passport;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	passport := app.myPassport;
	
	// Populate response - cloned from CMUI_ComboCommodity
	foreach commodity in app.myRoot.allCommodities discreteLock do
		if commodity.isNotAvailableForEntry then
			continue;
		endif;
		
		if not commodity.canUserAccessSelf(null, failedDAC, passport) then
			continue;
		endif;
		
		create proxyCommodity transient;
		proxyCommodity.setProxyFromObject(commodity);
		response.allCommodities.add(proxyCommodity);
		
	endforeach;
	
	
	// Got to here, everything is OK
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Get all the valid Commoditoes for the current user.</text>
        <wsdlName>getCommodities</wsdlName>
        <ReturnType type="WS_CommoditiesResponse"/>
    </JadeWebServicesMethod>
