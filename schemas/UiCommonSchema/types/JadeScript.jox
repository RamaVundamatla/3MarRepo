    <JadeMethod name="findDateCastz" id="17820454-8b01-412c-99dc-45bcb648f0c8">
        <source>findDateCastz();
//-----------------------------------------------------------
//
// Created by cnwsh3
//
// Date: 30 March 2006
//
// Finds any ".Date cases in method source.
//
// ----------------------------------------------------------

vars

	methColl 			: 	MethodNDict;
	classColl 			: 	ClassColl;
	schColl 			: 	SchemaColl;
	schem 				: 	Schema;
	meth 				: 	Method;
	objClass 			: 	Class;
	hasQuotes 			: 	Boolean;
	sourcePosition 		: 	Integer;
	sourceText,
	currentSchemaName,
	className 			: 	String;
	file   				: 	File;
	found,
	knownString			:	Boolean;
begin
	
	//Create a file to put results in.
	create file transient;
	file.allowCreate := true;
	file.fileName := 'C:/temp/DateCheck.txt';
	file.kind := File.Kind_Unknown_Text;
	file.mode := File.Mode_Append;
	file.open;
	
	//Get all subschemas and put them in a collection along with the current schema
	create schColl transient;
	currentSchema.withAllSubschemas(schColl);
	
	//Look through each schema for non system classes.
	foreach schem in schColl do
	
		currentSchemaName := schem.getName();
		//Put non system classes in a collection.
		classColl := schem.getAllClasses(false);
		
		//Get all non systm methods for each class.
		foreach objClass in classColl do
		
			create methColl transient;
			objClass.getMethods(methColl);
			
			//Check each method for source.
			foreach meth in methColl do

				//reset start position for token search.
				sourcePosition := 1;
				knownString := false;
				found := false;
				if meth.getSchema.getName() = currentSchemaName then
					if meth.getName = 'btnSave_click' then	
						app.writeStatement( 'Method');
					endif;
					sourceText := meth.getSource();
					//if there is a quote in the method, write it out to file
					sourcePosition := sourceText.pos('.Date', sourcePosition);
					if sourcePosition &lt;&gt; 0 then
							found := true;
					endif;
						
					if found then
						//There must be a quote in there somewhere so log it.
						className := objClass.getName();
						file.writeLine(currentSchemaName &amp; " &gt;&gt; " &amp; className &amp; "::" &amp; meth.getName());
					endif;
				endif;
			endforeach;
		endforeach;
		
	endforeach;

epilog
	delete schColl;
	delete methColl;
	delete file;
end;</source>
    </JadeMethod>
    <JadeMethod name="jadeSkinLoad" id="9a834e9b-d061-4c1c-bc3f-0750aa611851">
        <updating/>
        <source>jadeSkinLoad() updating;
// ---------------------------------------------------------------------------
// Created:     08 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	js	: JadeSkin;
	f	: File;
	path	: String;
	propCol	: PropertyColl;
	prop	: Property;
	pos		: Integer;
	
begin

	path := app.getJadeInstallDir.toLower;

	pos := path.reversePos("\");
	if pos = 0 then
		return;
	endif;
	path := path[1 : pos-1] &amp; '\c_temp';

	js := JadeSkin.firstInstance;
	
	if js = null then
		return;
	endif;
	
	create f transient;
	f.mode := File.Mode_Input;
	f.kind := File.Kind_Binary;
	
	propCol := JadeSkin.allProperties();
	
	beginTransaction;
	
	foreach prop in propCol do
		if prop.name[1:3] = 'img' then
			f.fileName := path &amp; '\' &amp; prop.name &amp; '.png';
	
			if f.isAvailable then
				f.open; 
	 
				js.setPropertyValue(prop.name, f.readBinary(f.fileLength));
	
				f.close;
			endif;
		endif;
	endforeach;

	commitTransaction;
		
epilog
	delete f;
	
end;</source>
    </JadeMethod>
