<Class name="CM_QStrVoyOpsCheckStatusMethod" id="ed0bf256-9046-45cd-8cf0-c5421f305837">
    <superclass name="CM_QStringLookupMethod"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="615e60e5-8b9e-4254-a53f-adec0ed29e76">
        <updating/>
        <source>create() updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 29 January 2024
TFS#		: 62158
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	oper : CM_QueryOperator;
begin
	if self.isTransient then 
		return;
	endif;
	
	create oper as CM_QStringIsOneOf persistent;
	self.allAllowedOperators.add(oper);
end;</source>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="17279608-1886-4809-8830-4f501dddeecc">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 29 January 2024
TFS#		: 62158
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	selectStr	: String;	
begin
	_combo.clear();
	_combo.sorted := true;
	
	_combo.addItem(app.getErrorString(Complete));
	_combo.addItem(app.getErrorString(Pending));
	_combo.addItem(app.getErrorString(NotApplicable));
	
	if CM_QStringLookup.hasInstance(_queryOperator) then
		_combo.text := _queryOperator.CM_QStringLookup.selectionValue;
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		_combo.text := _queryOperator.CM_QStringLookupNotEqual.selectionValue;
	endif;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="32b37d7a-a5b6-4dbb-91e0-412773a71f56">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 29 January 2024
TFS#		: 62158
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	idx,intSite	: Integer;
	strObj		: CM_String;
	objArr		: ObjectArray;
begin

	_tbl.purgeTableObjects();
	_tbl.clear;
	_tbl.rows := _tbl.fixedRows;	

	create objArr transient;
	create strObj transient;
	strObj.string := app.getErrorString(Complete);
	objArr.add(strObj);
	create strObj transient;
	strObj.string := app.getErrorString(Pending);
	objArr.add(strObj);
	create strObj transient;
	strObj.string := app.getErrorString(NotApplicable);
	objArr.add(strObj);
	
	foreach strObj in objArr as CM_String do
		if _operator &lt;&gt; null and _operator.CM_QStringIsOneOf.allSelectionValues.includes(strObj.string) then
			idx := _tbl.addItem(1.String &amp; Tab &amp; strObj.string);
		else
			idx := _tbl.addItem(0.String &amp; Tab &amp; strObj.string);	
		endif;
		_tbl.accessRow(idx).itemObject := strObj;
		_tbl.row := idx;
		_tbl.change(_tbl);
	endforeach;
epilog
	delete strObj;
	delete objArr;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="9c85c9e5-6783-4b0a-acc2-f7ad793b8a4b">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 29 January 2024
TFS#		: 62158
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	str			: String;
	numRows,
	idx			: Integer;
	strObj		: CM_String;
	checkStatus	: StringArray;  

begin

	create checkStatus transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			strObj := _tbl.accessRow(idx).itemObject.CM_String;
			checkStatus.add(strObj.string);
		endif;
	endforeach;
	
	_op.setSearchValue(checkStatus);

epilog
	delete checkStatus;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
</Class>
