    <JadeMethod name="showThumbnail" id="f6ef05ae-6f12-433e-b604-82b0fffe3890">
        <updating/>
        <source>showThumbnail( pObj: HMS_PilotExemptionRule ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2012	cnwndl1	Initial creation	Par 29496

*/

vars

	theForm : SOP_HMS_TableMaintForm;

begin

	theForm := self.myForm.SOP_HMS_TableMaintForm;
	theForm.tblInput1.clearValues;
	self.populateCombos();	
	theForm.tblInput1.setTableFromObject(pObj, null);
	theForm.tblInput1.setValueByName(ETRow_Criteria, pObj.getCriteriaStr);
	theForm.cmbCriteria.listIndex := theForm.cmbCriteria.findStringExact(1,pObj.getCriteriaStr);
	theForm.tblInput1.setValueByName(ETRow_Operator, pObj.getOperatorStr);
	theForm.cmbOperator.listIndex := theForm.cmbOperator.findStringExact(1,pObj.getOperatorStr);
	

epilog

end;</source>
        <Parameter name="pObj" type="HMS_PilotExemptionRule"/>
    </JadeMethod>
</Class>
