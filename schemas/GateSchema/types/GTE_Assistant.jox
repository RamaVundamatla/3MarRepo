    </JadeMethod>
    <JadeMethod name="showHideTemperatureFields" id="63f9cd86-3797-4bbf-a851-ebfbe720438e">
        <source>showHideTemperatureFields(pCargoType : Integer; pISOType : CM_ISOType; pOperatorCode : String; pTbl : CM_EntryTable input;
						  pTerminal : CM_Terminal);
// ---------------------------------------------------------------------------
// Created:     23 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	1/3/01			AA		Added code to check if reefer, fantainer, porthole etc
// ---------------------------------------------------------------------------
vars
	tmpOperator		: CM_Operator;
	useFahrenheit	: Boolean;
	isoType : CM_ISOType;
	isPoweredItem, isReefer : Boolean;
	
begin

	/* The rules:
	1: Non containers show no temp related fields
	2: Dry containers show no temp related fields
	3: Reefers show all temp fields; humidity and vents depends on operator
		Reefers show Controlleld Atmosphere boxes. Par15482
	4: Fantainers show humidity and vents if the operator wants them
	5: Display temps in F in the operator wants it
	6: If no operator or isoType supplied use the config defaults
	*/
	
	isoType := pISOType;

	if isoType = null then
		//isoType := app.theConfig.defISOType;
		isPoweredItem 	:= false;
		isReefer 		:= false;
		showHideCOUFields(pTbl, false);
	else
		isPoweredItem 	:= isoType.isReefer or isoType.isFantainer;
		isReefer 		:= isoType.isReefer;
		//showHideCOUFields(pTbl, isoType.isPorthole);		//Show for port hole only
	endif;
	
	if pCargoType &lt;&gt; TI_CargoType_Container or isPoweredItem = false then
		pTbl.hideRowByName(ETRow_CarriageTempC, false);
		pTbl.hideRowByName(ETRow_PackTempC, false);
		pTbl.hideRowByName(ETRow_CarriageTempF, false);
		pTbl.hideRowByName(ETRow_PackTempF, false);
		pTbl.hideRowByName(ETRow_PackDate, false);
		pTbl.hideRowByName(ETRow_PackTime, false);
		pTbl.hideRowByName(ETRow_AllowableTimeOffPower, false);
		pTbl.hideRowByName(ETRow_Humidity, false);
		pTbl.hideRowByName(ETRow_Ventilation, false);
		pTbl.hideRowByName(ETRow_IsControlledAtmosphere, false);

		return;
	endif;
		
	if pOperatorCode &lt;&gt; null then
		tmpOperator := app.myRoot.allOperators[pOperatorCode];
	endif;

	if tmpOperator = null then
		tmpOperator := pTerminal.getConfig(DefOperator).CM_Operator;
	endif;
	
	if isReefer then		//Not the fantainers
		if tmpOperator = null then
			useFahrenheit := false;
		else
			useFahrenheit := tmpOperator.displayTempFahrenheit;
		endif;
		if useFahrenheit then
			pTbl.showRowByName(ETRow_CarriageTempF, false);
			pTbl.showRowByName(ETRow_PackTempF, false);

			// RJS 10/6/01 show C fields and allow input.  Lost focus of will set the other
			pTbl.showRowByName(ETRow_CarriageTempC, false);
			pTbl.showRowByName(ETRow_PackTempC, false);
		else
			pTbl.showRowByName(ETRow_CarriageTempC, false);
			pTbl.showRowByName(ETRow_PackTempC, false);

			pTbl.hideRowByName(ETRow_CarriageTempF, false);
			pTbl.hideRowByName(ETRow_PackTempF, false);
		endif;

		pTbl.showRowByName(ETRow_PackDate, false);
		pTbl.showRowByName(ETRow_PackTime, false);
		pTbl.showRowByName(ETRow_AllowableTimeOffPower, false);
		
		pTbl.showRowByName( ETRow_IsControlledAtmosphere, false );	//Par15482

	endif;
	
	if isPoweredItem and 
	   tmpOperator &lt;&gt; null and 
	   tmpOperator.requiresHumidity then
		pTbl.showRowByName(ETRow_Humidity, false);
	else
		pTbl.hideRowByName(ETRow_Humidity, false);
	endif;
	
	if isPoweredItem and 
	   tmpOperator &lt;&gt; null and 
	   tmpOperator.requiresVentilation then
		pTbl.showRowByName(ETRow_Ventilation, false);
	else
		pTbl.hideRowByName(ETRow_Ventilation, false);
	endif;	
end;</source>
        <Parameter name="pCargoType" type="Integer"/>
        <Parameter name="pISOType" type="CM_ISOType"/>
        <Parameter name="pOperatorCode" type="String"/>
        <Parameter name="pTbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="pTerminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="showHideWagonField" id="5151c6db-55be-4632-bca3-80450568b33d">
        <source>showHideWagonField(pTbl : CM_EntryTable io; pTransModeStr : String);
// ---------------------------------------------------------------------------
// Created:     19 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if pTransModeStr = TI_TRANSMODE_RAIL_STR then
		pTbl.showRowByName(ETRow_Wagon, true);	
		pTbl.showRowByName(ETRow_WagonTrain, true);	// 04 Nov 2009	NDL	Par 21519
		pTbl.disableRowByName(ETRow_WagonTrain);	//04 Nov 2009	NDL Par 21519
	else
		pTbl.hideRowByName(ETRow_Wagon, false);	// do not give error if not found
		pTbl.hideRowByName(ETRow_WagonTrain, false);	// 04 Nov 2009	NDL	Par 21519
	endif;

end;</source>
        <Parameter name="pTbl" type="CM_EntryTable" usage="io"/>
        <Parameter name="pTransModeStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="showRFIDTagFormForRoadEntry" id="c013e2c4-c23d-4d21-b778-ee96e36727d2">
        <source>showRFIDTagFormForRoadEntry(_job : CM_RoadJob input);
/*

Purpose:			


Return Value:		


Date				Who		Reason
06 September 2006	cnwer1	Initial creation - PAR#xxxx
28 August 2009		cnwcs5	ccms1061 - gate config changes
23/02/2010			cnwcs5	par 18061 - use flag on gate to decide whether to show RFID tag form
*/
vars
	wle 		:	CM_WorkListEntry;
	preGateUnplannedAlerts : CM_AlertsArray;
	alert		: CM_SystemAlert;
	invalid		: Boolean;
	gate		: CM_Gate;
begin
	//th2 added 2/10/06 - job has been deleted already if auto-completing
	on Exception do app.handleDeletedObject (exception,_job, invalid);

//	if _job &lt;&gt; null and _job.myTerminal.hasRFIDTags then par 18061
	if _job &lt;&gt; null then	// 23/02/2010 cnwcs5 par 18061
		if _job.cameThroughTwinStageGate then	// 28/08/2009 - cnwcs5
			create preGateUnplannedAlerts transient;

			foreach wle in _job.workListEntries do
				//th2 - added test for null - might be a release by ISO type in which case no TI yet
				if wle.myTrackedItem &lt;&gt; null and
				   wle.myTrackedItem.myPrimaryQueuedLocation = null then
					create alert transient;
					alert.setSeverity(SEVERE_ERROR);
					alert.details:= app.getErrorString2(ContainerFailedToAutoQueue, wle.myTrackedItem.id, _job.myVehicle.code);
					//"Container " &amp; wle.myTrackedItem.id &amp; " on vehicle " &amp;  _job.myVehicle.code &amp; " failed to be auto-queued";
					alert.setLinkedTo(wle);
					alert.add;
					app.commitAlert;
					if app.alertManager.lastNormalAlert &lt;&gt; null then
						preGateUnplannedAlerts.add(app.alertManager.lastNormalAlert);
					endif;
				endif;	
			endforeach;	
// 23/02/2010 cnwcs5 par 18061 - commented out
//			self.showRFIDTagForm(_job,preGateUnplannedAlerts,CMUI_RFIDTag.Mode_FromGateIn); 
//		else 
//			return;
// 23/02/2010 cnwcs5 par 18061 - end
		endif;
// 23/02/2010 cnwcs5 par 18061 - start
		gate := _job.getGateIn;
		
		if gate &lt;&gt; null and gate.promptForRFIDTag then
			//23 Apr 2012	NDL	Par 29417
			if _job &lt;&gt; null and _job.getMyRFIDTag &lt;&gt; null then
				return;
			endif;
			self.showRFIDTagForm(_job,preGateUnplannedAlerts,CMUI_RFIDTag.Mode_FromGateIn);
		endif;
// 23/02/2010 cnwcs5 par 18061 - end
	endif;
epilog
	if preGateUnplannedAlerts &lt;&gt; null then
		delete preGateUnplannedAlerts;
	endif;
end;</source>
        <Parameter name="_job" type="CM_RoadJob" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showRoadExitCompleteForm" id="55736236-ad8b-4e1e-9008-69b896849d8a">
        <source>showRoadExitCompleteForm(_job : CM_Job; _masterMenuAction : CMUI_MenuAction);
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 31 May 2007
//
//----------------------------------------------------------------------

vars
	frm	: GTE_RoadExitCompleteForm;
	job : CM_Job;
begin
	//DON'T HAVE A JOB SO NO POINT IN SHOWING THE FORM AT THIS STAGE.
	if _job = null then
		return;
	endif;

	if frm = null then
		frm := app.loadForm(GTE_RoadExitCompleteForm, GTE_Assistant, false, false, false, self.myTerminal, _masterMenuAction).GTE_RoadExitCompleteForm;
	endif;
	
	if frm = null then
		return;
	endif;
	
	frm.myJob := _job;
	
	frm.show();
epilog

end;</source>
        <Parameter name="_job" type="CM_Job"/>
        <Parameter name="_masterMenuAction" type="CMUI_MenuAction"/>
    </JadeMethod>
    <JadeMethod name="temperatureFieldLostFocus" id="a9fbb157-308d-4a2a-b596-4489b04f7d2d">
        <source>temperatureFieldLostFocus(pText : String; _table : CM_EntryTable input; 
					_otherRowName : String; pInputIsFarenheit, pShowAsFarenheit : Boolean);
// ---------------------------------------------------------------------------
// Created:     08 August 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	otherRow	: Integer;
	otherText	: String;

begin

	otherRow := _table.getRowByName(_otherRowName);
	if otherRow &lt;= 0 then
		return;
	endif;

	if pText.trimRight &lt;&gt; null then
//		otherText := self.displayTemperature(pText.Real, pInputIsFarenheit, pShowAsFarenheit);
		otherText := app.getTemperatureDisplay(pText.Real, pInputIsFarenheit, pShowAsFarenheit);
	endif;

	_table.setValue(otherRow, otherText);

end;</source>
        <Parameter name="pText" type="String"/>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
        <Parameter name="_otherRowName" type="String"/>
        <Parameter name="pInputIsFarenheit" type="Boolean"/>
        <Parameter name="pShowAsFarenheit" type="Boolean"/>
    </JadeMethod>
</Class>
