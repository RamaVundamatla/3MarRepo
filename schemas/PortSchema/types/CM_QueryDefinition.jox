    <JadeMethod name="upgradeQueryProperties" id="19e62ce7-e664-4cf5-8205-e6dfa31adb91">
        <source>upgradeQueryProperties(_oldPropertyNames, _newPropertyNames :StringArray; _oldClasses, _newClasses :ObjectArray; _doSelector :Boolean);
// ---------------------------------------------------------------------------
// Created:     21 September 2010 by cnwcs5 par 25708
// Purpose:     When the property/method name changes this method can be used
//				to change any selector queries or summaries to use the new 
//				propertyName
// Parameters:  _oldPropertyNames	- ordered list of all old property names being replaced
//				_newPropertyNames	- ordered list of all new property names to be used 
//				_oldClasses			- ordered list of all old CM_Queryproperty subclasses for old properties
//				_newClasses			- ordered list of all new CM_QueryProperty subclasses for new properties
//				_doSelector			- if false selector queries will not be updated
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
vars
	newProperties	:ObjectArray;
	oldClass,
	newClass	:Class;
	tempOld, 
	tempNew		:CM_QueryProperty;
	tempOp		:CM_QueryOperator;
	mode, type	:Integer;
	obj			:Object;
	xtab		:CM_OutputFormat_XTAB;
	ss			:CM_OutputFormat_SS;
	data		:CM_SnapshotData;
	grouping	:CM_XTABGrouping;
	field		:CM_XTABField;
	mapping		:CM_XTABMapping;
	prop		:CM_QueryProperty;
	str			:String;
	lastCommit	:TimeStamp;
	menuEntity	:CM_MenuEntity;
	query		:CM_MenuUserQuery;
	int, size	:Integer;			
begin
/*	IMPORTANT NOTE:
	Qualified for use with the following conversions:
	- CM_QStringProperty -&gt; CM_QStringMethod
	
	Please add other conversions as they are qualified.

	ANOTHER IMPORTANT NOTE:
	The old CM_QueryProperty and the new CM_QueryProperty should share the SAME set of
	query operators.  This is because, if there are mappings for the old query property that 
	use an operator that is not valid for the new query property, then we cannot
	upgrade the mapping.  The same issue applies to selector criteria
	
	To check whether there is likely to be a problem we use the old and new classes passed into
	this method.  MAKE SURE YOU SET THESE CORRECTLY!!!
	
	YET ANOTHER IMPORTANT NOTE:
	This method is re-runnable and may result in several transactions. The time consuming part
	of this upgrade is the snapshot summary data so if we have been in transaction state for &gt; 10 seconds
	a commit/beginTransaction will be done
	
	ONE MORE NOTE ...
	Please check the CM_YardAllocation::createCriteriaFromXTABProperty method for the old feature.  You will need to
	update this method if the old, feature is referenced in this method.
*/
	create newProperties transient;
	
	foreach int in 1 to _oldPropertyNames.size do
		prop 	:= self.allQueryProperties[_newPropertyNames[int]];
		
		if prop = null then
			app.raiseUnexpectedProgramError (self.class.name, method.name,'invalid property');
		endif;
		// maintain corresponding array of new qury properties
		newProperties.add(prop);
		//	operators are set in the constructor. we need to create persistent objects because operators
		//	don't get created for transients	
		create tempOld as _oldClasses[int].Class persistent;	// gets deleted at end of method
		create tempNew as _newClasses[int].Class persistent; // gets deleted at end of method
	
		foreach tempOp in tempOld.allAllowedOperators do
			if tempNew.allAllowedOperators[tempOp.description] = null then
				// operator not valid for new query property
				app.raiseUnexpectedProgramError (self.class.name, method.name,'new property type does not support all operators for old property type');
			endif;
		endforeach;
	//	they also need to be of the same type so that if there are fields using a function
	//	e.g. average then they can still use this function after the upgrade
		if (tempOld.isDecimalOrInteger and not tempNew.isDecimalOrInteger) or 
			(tempNew.isDecimalOrInteger and not tempOld.isDecimalOrInteger)then
			app.raiseUnexpectedProgramError (self.class.name, method.name,'Cannot change from/to decimal');
		endif;
		if (tempOld.isBoolean and not tempNew.isBoolean) or 
			(tempNew.isBoolean and not tempOld.isBoolean)then
			app.raiseUnexpectedProgramError (self.class.name, method.name,'Cannot change from/to boolean');
		endif;
		delete tempOld;
		delete tempNew;
	endforeach;
	
//	Now the actual upgrade
	lastCommit	:= app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	mode		:= self.mode;
	type		:= self.type;
	//prop 		:= self.allQueryProperties[_newPropertyName];
	
	//if prop = null then
		//app.raiseUnexpectedProgramError (self.class.name, method.name,'invalid property');
	//endif;
	
	// do summaries first
	foreach obj in app.myRoot.allOutputFormats_XTAB do
		xtab := obj.CM_OutputFormat_XTAB;
		
		if xtab.type &lt;&gt; type or
			xtab.mode &lt;&gt; mode then
			continue;
		endif;
		str := ('Checking Summary Definition - ' &amp; xtab.name);
		app.writeStatement (str);
		app.writeLog (str, LogINFO);
		
		if self.upgradeQueryProperties_XTAB (xtab, _oldPropertyNames, _newPropertyNames) then
			str := ('- Completed Summary Definition upgrade - ' &amp; xtab.name);
			app.writeStatement (str);
			app.writeLog (str, LogINFO);
		endif;
	endforeach;
	
	// mappings
	foreach obj in app.myRoot.allXTABMappingsByName do
		mapping := obj.CM_XTABMapping;
		
		if mapping.mode = mode and
			mapping.type = type then
			
			foreach int in 1 to _oldPropertyNames.size do
				if mapping.propertyName = _oldPropertyNames[int] then
					prop 	:= self.allQueryProperties[_newPropertyNames[int]];
					
					self.upgradeQueryProperties_Mapping (mapping, _oldPropertyNames[int], _newPropertyNames[int], prop, _oldClasses[int].Class, _newClasses[int].Class);
				endif;
			endforeach;
		endif;
	endforeach;

	if self.type &lt;&gt; self.TrackedItem_Query_Type then
		// no snapshot summaries for anythibng other than tracked item type
		return;
	endif;
	
	// now do snapshot summaries
	foreach obj in app.myRoot.allOutputFormats_SS do
		ss := obj.CM_OutputFormat_SS;
		
		if ss.type &lt;&gt; type or
			ss.mode &lt;&gt; mode then
			continue;
		endif;
		str := ('Checking Snapshot Summary Definition - ' &amp; ss.name);
		app.writeStatement (str);
		app.writeLog (str, LogINFO);
			
		if self.upgradeQueryProperties_SS (ss, _oldPropertyNames, _newPropertyNames, lastCommit) then
		
			str := ('- Completed Snapshot Summary Definition upgrade - ' &amp; ss.name);
			app.writeStatement (str);
			app.writeLog (str, LogINFO);	
		endif;
	endforeach;
	
	if not _doSelector then
		return;
	endif;
	
	if self.type &lt;&gt; self.TrackedItem_Query_Type then
		// no selector queries for anythibng other than tracked item type
		return;
	endif;
	
	// now do selector queries
	foreach menuEntity in app.myRoot.myQueryMenuRoot.allMenuUserItemsWithAMenuItem do
		query := menuEntity.CM_MenuUserQuery;
		// all queries are assumed to be tracked item type
		if query.queryMode &lt;&gt; self.mode then	
			// not the same mode
			continue;
		endif;
			
		// now upgrade the selector query
		if self.upgradeQueryProperties_Query (query, _oldPropertyNames, _newPropertyNames, newProperties) then
			str := ('- Completed Selector Query upgrade- ' &amp; query.heading);
			app.writeStatement (str);
			app.writeLog (str, LogINFO);
		endif;
	endforeach;
	
epilog
	// if we got an exception these the transaction will have been aborted and these 
	// guys will be invalid.  I use isValidObject because this is just an upgrade script
	if global.isValidObject (tempNew) then
		delete tempNew;
	endif;
	if global.isValidObject (tempOld) then
		delete tempOld;
	endif;
	
	delete newProperties;
end;</source>
        <Parameter name="_oldPropertyNames" type="StringArray"/>
        <Parameter name="_newPropertyNames" type="StringArray"/>
        <Parameter name="_oldClasses" type="ObjectArray"/>
        <Parameter name="_newClasses" type="ObjectArray"/>
        <Parameter name="_doSelector" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="upgradeQueryProperties_Mapping" id="4385a6f5-01ce-42a0-aa7e-5c7854791f9c">
        <source>upgradeQueryProperties_Mapping(_mapping :CM_XTABMapping input; _oldPropertyName, _newPropertyName :String;
								_newProperty :CM_QueryProperty; _oldClass, _newClass :Class)protected;
// ---------------------------------------------------------------------------
// Created:     19 October 2010 by cnwcs5 par 25708
// Purpose:     When the property/method name changes this method is used
//				to change any mappings to use the new propertyName    
// Parameters:  _mapping
//				_oldPropertyName
//				_newPropertyName
//				_newProperty
//				_oldClass
//				_newClass
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars	
	str			:String;
	line		:CM_XTABMappingLine;
	op, newOp	:CM_QueryOperator;
begin
	str := ('Starting Mapping Definition upgrade - ' &amp; _mapping.name);
	app.writeStatement (str);
	app.writeLog (str, LogINFO);
	
	_mapping.setPropertyValue (CM_XTABMapping::propertyName.name, _newPropertyName);
	
	// we may also need to make sure that the query operators for the mapping are the correct type
	if _oldClass &lt;&gt; _newClass then
		foreach line in _mapping.allMappingLines do
			op 		:= line.myQueryOperator;
			newOp	:= self.upgradeQueryProperties_QueryOp (op, _newProperty);
			
			if newOp &lt;&gt; op then
				// the type of operator has changed
				delete op;
				// set the new operator	
				line.setPropertyValue (CM_XTABMappingLine::myQueryOperator.name, newOp);
			endif;
		endforeach;
	endif;
	
	str := ('Completed Mapping Definition upgrade - ' &amp; _mapping.name);
	app.writeStatement (str);
	app.writeLog (str, LogINFO);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_mapping" type="CM_XTABMapping" usage="input"/>
        <Parameter name="_oldPropertyName" type="String"/>
        <Parameter name="_newPropertyName" type="String"/>
        <Parameter name="_newProperty" type="CM_QueryProperty"/>
        <Parameter name="_oldClass" type="Class"/>
        <Parameter name="_newClass" type="Class"/>
    </JadeMethod>
    <JadeMethod name="upgradeQueryProperties_Query" id="760f3f4d-72f1-4a2a-be72-ae327151d4b7">
        <source>upgradeQueryProperties_Query(_query :CM_MenuUserQuery; _oldPropertyNames, _newPropertyNames :StringArray; 
								_newProperties :ObjectArray):Boolean protected;
// ---------------------------------------------------------------------------
// Created:     19 October 2010 by cnwcs5 par 25708
// Purpose:     When the property/method name changes this method is used
//				to change any selector queries to use the new propertyName    
// Parameters:  _query
//				_oldPropertyNames
//				_newPropertyNames
//				_newProperties
//				_oldClass
//				_newClass
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str, oldName,
	newName		:String;
	int, size	:Integer;
	qclh		:CM_QueryCriteriaLineHolder;
	scl			:CM_SelectorCriteriaLine;
	op			:CM_QueryOperator;	
	newProp,
	clone		:CM_QueryProperty;
	result		:Boolean;
begin
	str := ('Checking Selector Query - ' &amp; _query.heading);
	app.writeStatement (str);
	app.writeLog (str, LogINFO);
	
	// allColumns has all possible properties at the time the query was last saved
	// does not get used in query execution so no real need to change - it will
	// get updated if the query is saved again
	
	// allVisible columns has all columns that are displayed - need to update this because
	// property may no longer be valid.
	size := _query.allVisibleColumns.size;
	
	if size &gt; 0 then
		foreach int in 1 to size do	
			str := _query.allVisibleColumns[int];
			
			if _oldPropertyNames.includes(str) then
				// replace old name with new name
				_query.allVisibleColumns [int] := _newPropertyNames[_oldPropertyNames.indexOf (str)];
				
				result := true;
			endif;
		endforeach;
	endif;
	
	// allCriteriaLineHolders - this gets tricky because they have operators associated with them too
	foreach qclh in _query.allCriteriaLineHolders do
		foreach scl in qclh.allCriteriaLines do
			if not _oldPropertyNames.includes (scl.propName) then
				continue;
			endif;
			
			result 	:= true;
			int		:= _oldPropertyNames.indexOf (scl.propName);
			oldName := scl.propName;
			newName := _newPropertyNames[int];
			newProp	:= _newProperties[int].CM_QueryProperty;
			// this criteria line is for one of our properties
			scl.setPropertyValue (CM_SelectorCriteriaLine::propName.name, newName);
			// it has its own local CM_QueryProperty so we may need to clone a new one
			if scl.myQueryProperty &lt;&gt; null and scl.myQueryProperty.class &lt;&gt; newProp.class then
				// the new  query property is a different type
				clone := newProp.cloneSelf (false).CM_QueryProperty;
				// the queryOperator will also need to be cloned as the new type
				op := self.upgradeQueryProperties_QueryOp (scl.myQueryOperator, newProp);
				
				if op &lt;&gt; scl.myQueryOperator then
					// the type of operator has changed
					delete scl.myQueryOperator;
				
					scl.setPropertyValue (CM_SelectorCriteriaLine::myQueryOperator.name, op);
				endif;
				
				// delete the old property and establish relationship with new property
				delete scl.myQueryProperty;
				
				scl.setPropertyValue (CM_SelectorCriteriaLine::myQueryProperty.name, clone);
			else
				// just update the property name and values from the new CM_QueryProperty
				scl.myQueryProperty.setPropertyValue (CM_QueryProperty::propertyName.name, newName);
				scl.myQueryProperty.setPropertyValue (CM_QueryProperty::propertyName.name, newProp.allocationAttribute);
				scl.myQueryProperty.setPropertyValue (CM_QueryProperty::propertyName.name, newProp.displayNull);
				scl.myQueryProperty.setPropertyValue (CM_QueryProperty::propertyName.name, newProp.isVisible);
				scl.myQueryProperty.setPropertyValue (CM_QueryProperty::propertyName.name, newProp.needToUpperCase);
				scl.myQueryProperty.setPropertyValue (CM_QueryProperty::propertyName.name, newProp.niceName);
				scl.myQueryProperty.setPropertyValue (CM_QueryProperty::propertyName.name, newProp.propertyClassName);
				// query operator should still be OK since no change of type
			endif;
		endforeach;
	endforeach;

	return result;
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_query" type="CM_MenuUserQuery"/>
        <Parameter name="_oldPropertyNames" type="StringArray"/>
        <Parameter name="_newPropertyNames" type="StringArray"/>
        <Parameter name="_newProperties" type="ObjectArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="upgradeQueryProperties_QueryOp" id="cd4e8f3c-52ae-4a5d-b9b7-4288073cbfe0">
        <source>upgradeQueryProperties_QueryOp(_op :CM_QueryOperator input; _newProperty :CM_QueryProperty):CM_QueryOperator protected;
// ---------------------------------------------------------------------------
// Created:     18 October 2010 by cnwcs5 par 25708
// Purpose:     When the property/method name changes this method is used
//				to change any query operators to use the new propertyName   
// Parameters:  _op				- old query operator
//				_newProperty	- new query property
//				_oldClass		
//				_newClass
// Returns:     New query operator
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	allowedOp, newOp		:CM_QueryOperator;
	str						:String;
begin
	// find the operator with he same name for the new property
	// we rely on the fact that for different types the description will be the same
	allowedOp	:= _newProperty.allAllowedOperators [_op.description];
	// there are only a few conversions we can handle and they must share all the same query operators
	// we check this much earlier on though
	if allowedOp = null then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Cannot create substitute query operator - invalid conversion');
	endif;
	// newOp the operator
	if allowedOp.class = _op.class then
		// Could be same type or:
		// CM_QBooleanProperty -&gt; CM_QBooleanMethod or
		// CM_QDateProperty -&gt; CM_QDateMethod or
		// CM_QDecimalProperty -&gt; CM_QDecimalMethod or
		// CM_QStringProperty -&gt; CM_QStringMethod or
		// CM_QIntegerProperty -&gt; CM_QIntegerMethod or
		// CM_QIntegerLookupProperty -&gt; CM_QIntegerLookupMethod or
		// CM_QReferenceLookupProperty -&gt; CM_QReferenceMethod or	// don't share same ops so wont get here till they do
		// CM_QStringLookupProperty -&gt; CM_QStringLookupMethod then

		newOp := _op;
		
		str := ('Query Operator - ' &amp; _op.description &amp; ' ' &amp; _op.getSearchValueStr (_newProperty) &amp; ' retained');
		app.writeStatement (str);
		app.writeLog (str, LogINFO);
	// there are a few other valid conversions
	// integer to decimal
	// decimal to integer
	elseif (allowedOp.class.inheritsFrom (CM_QueryIntegerOperators) and _op.class.inheritsFrom (CM_QueryDecimalOperator)) or
		(allowedOp.class.inheritsFrom (CM_QueryDecimalOperator) and _op.class.inheritsFrom (CM_QueryIntegerOperators)) then
		// Could be
		// CM_QIntegerProperty -&gt;  CM_QDecimalProperty or CM_QDecimalMethod
		// CM_QIntegerMethod -&gt;  CM_QDecimalProperty or CM_QDecimalMethod
		// CM_QDecimalProperty -&gt;  CM_QIntegerProperty or CM_QIntegerMethod
		// CM_QDecimalMethod -&gt;  CM_QIntegerProperty or CM_QIntegerMethod
			
		// they use the effectively the same operators but the classes are different
		// we rely on the fact they they share the same description
		if _op.isKindOf (CM_QueryIntegerOperators) then
			// integer -&gt; decimal
			newOp := allowedOp.cloneSelfAs (allowedOp.class, false).CM_QueryOperator;
			
			newOp.setPropertyValue (CM_QueryDecimalOperator::searchValue.name, _op.CM_QueryIntegerOperators.searchValue.Integer);
			
			str := ('Query Operator - ' &amp; _op.description &amp; ' ' &amp; _op.getSearchValueStr (_newProperty) &amp; ' upgraded to ' &amp; newOp.class.name);
			app.writeStatement (str);
			app.writeLog (str, LogINFO);
		else
			// decimal -&gt; integer
			create newOp as allowedOp.class persistent;
			
			// description is set in constructor
			newOp.setPropertyValue (CM_QueryDecimalOperator::searchValue.name, _op.CM_QueryDecimalOperator.searchValue.Integer);
			
			if _op.isKindOf (CM_QDecimalInRange) or _op.isKindOf (CM_QDecimalNotInRange) then
				// no Integer equivalent so we will never get here - if you want to do this change 
				// you will need to create Integer In Range, Not In Range operators and uncomment the code below
				app.raiseUnexpectedProgramError (self.class.name, method.name, 'Cannot create substitute query operator - invalid conversion');
				
/*					if _op.isKindOf (CM_QDecimalInRange) then
					newOp.setPropertyValue (CM_QIntegerInRange::lowerValue.name, allowedOp.CM_QDecimalInRange.lowerValue.Integer);
				elseif _op.isKindOf (CM_QDecimalNotInRange) then
					newOp.setPropertyValue (CM_QIntegerNotInRange::lowerValue.name, allowedOp.CM_QDecimalNotInRange.lowerValue.Integer);
				endif;*/
			endif;
			
			str := ('Query Operator - ' &amp; _op.description &amp; ' ' &amp; _op.getSearchValueStr (_newProperty) &amp; ' upgraded to ' &amp; newOp.class.name);
			app.writeStatement (str);
			app.writeLog (str, LogINFO);
		endif;
	else
		// should not get here as will have been checked earlier on
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Cannot create substitute query operator - invalid operators conversions');
	endif;
	
	if newOp = null then
		// should not get here as will have been checked earlier on
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Cannot create substitute query operator - newOp is null');
	endif;
	
	return newOp;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <Parameter name="_newProperty" type="CM_QueryProperty"/>
        <ReturnType type="CM_QueryOperator"/>
    </JadeMethod>
    <JadeMethod name="upgradeQueryProperties_SS" id="8eba51c7-2113-4858-b33b-d2a25a0fe69e">
        <source>upgradeQueryProperties_SS(_ss :CM_OutputFormat_SS; _oldPropertyNames, _newPropertyNames :StringArray;
						_lastCommit :TimeStamp io):Boolean protected;
// ---------------------------------------------------------------------------
// Created:     21 September 2010 by cnwcs5 par 25708
// Purpose:     When the property/method name changes this method is used
//				to change any snapshot summaries to use the new propertyName    
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
vars
	grouping		:CM_XTABGrouping;
	field			:CM_XTABField;
	data			:CM_SnapshotData;
	obj, newObj		:CM_DynamicObject_Snapshot;
	xtab			:CM_OutputFormat;
	changedGrouping,
	changedField	:Boolean;
	ssField			:CM_SnapshotField;
	temp			:Object;
	coll			:ObjectSet;
	array			:ObjectArray;
	int				:Integer;
	propertyName, str	:String;
	didUpdate		:Boolean;
	oldName, newName	:String;
begin
	if app.actualTimeServer.getDifferenceInSeconds (_lastCommit) &gt;= 10 then// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		commitTransaction;
		_lastCommit := app.actualTimeServer;	// in case the commit took a long time// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		str := '*** commit transaction ***';
		app.writeStatement (str);
		app.writeLog (str, LogINFO);
		beginTransaction;
	endif;
	
	// update any grouping properties
	foreach grouping in _ss.allGroupings do
		foreach int in 1 to _oldPropertyNames.size do
			oldName := _oldPropertyNames[int];
			newName := _newPropertyNames[int];
			
			if grouping.propertyName = oldName then
				changedGrouping := true;
				str := ('Updating summary snapshot grouping property - ' &amp; oldName &amp; ' to ' &amp; newName);
				app.writeStatement (str);
				app.writeLog (str, LogINFO);
				grouping.setPropertyValue (CM_XTABGrouping::propertyName.name, newName);
				
				didUpdate := true;
			endif;
		endforeach;
	endforeach;
	// update any fields for the snapshot
	foreach field in _ss.allFields do
		foreach int in 1 to _oldPropertyNames.size do
			oldName := _oldPropertyNames[int];
			newName := _newPropertyNames[int];
			
			if field.propertyName = oldName then
				changedField := true;
				str := ('Updating summary snapshot field property - ' &amp; oldName &amp; ' to ' &amp; newName);
				app.writeStatement (str);
				app.writeLog (str, LogINFO);
				field.setPropertyValue (CM_XTABField::propertyName.name, newName);
				
				didUpdate := true;
			endif;
		endforeach;
	endforeach;
	
	if not changedGrouping and not changedField then
		// nothing changed
		return false;
	endif;
	
	// upgrade any xtabs that have been created for this snapshot
	foreach xtab in _ss.allOutputFormats_XTAB do
		str := ('Checking Summary Definition for Snapshot - ' &amp; xtab.name);
		app.writeStatement (str);
		app.writeLog (str, LogINFO);
		if self.upgradeQueryProperties_XTAB (xtab.CM_OutputFormat_XTAB, _oldPropertyNames, _newPropertyNames) then
			str := ('Completed Summary Definition for Snapshot upgrade - ' &amp; xtab.name);
			app.writeStatement (str);
			app.writeLog (str, LogINFO);
		endif;
	endforeach;
	
	// now it gets trickier - the snapshot data are actually collections of dynamic objects
	// so we need to delete and re-create them
	create coll transient;
	create array transient;
	
	foreach data in _ss.allSnapshotDatas do
		coll.clear;
		// copy all snapshot data to a temp coll - these guys will be deleted
		data.allSnapshotData.copy (coll);
		
		str := ('Starting Snapshot Summary Data upgrade - ' &amp; data.myTerminal.code &amp; ' ' &amp; 
											data.runDateTime.asStringJMT &amp; ' ' &amp; coll.size.String &amp; ' objects');
		app.writeStatement (str);
		app.writeLog (str, LogINFO);
		
		if changedGrouping then
			// break the relationship between the snapshot and the dynamic children
			// we will be creating some new ones
			data.allSnapshotData.clear;
		endif;
		
		foreach temp in coll do
			obj	:= temp.CM_DynamicObject_Snapshot;
			
			if changedField then
				foreach int in 1 to _oldPropertyNames.size do
					oldName := _oldPropertyNames[int];
					newName := _newPropertyNames[int];
					
					foreach ssField in obj.allFields do
						if ssField.propertyName &lt;&gt; oldName then
							continue;
						endif;
						// update the proerty name
						ssField.setPropertyValue (CM_XTABField::propertyName.name, newName);
					endforeach;
				endforeach;
			endif;
			
			if changedGrouping then
				// need to clone the object and then take its fields with it
				create newObj;
				// copy the jade properties
				obj.allObjects.copy (newObj.allObjects);
				
				//cnwjo3 par 26336.  Not populating allValues anymore
				//obj.allValues.copy (newObj.allValues);
				
				// we need to move the field from the old object to the new one.
				array.clear;
				obj.allFields.copy (array);		// copies all fields to temporary collection
				obj.allFields.clear;			// clears inverse
				array.copy (newObj.allFields);	// re-establish new inverse
				
				// copy the user defined properties
				newObj.setupProperties (_ss);
				
				if newObj.propertyCount &gt; 0 then
					foreach int in 1 to newObj.propertyCount do
						propertyName := newObj.getPropertyName (int);
						
						if _newPropertyNames.includes (propertyName) then
							oldName := _oldPropertyNames[_newPropertyNames.indexOf (propertyName)];
							// this is the changed property
							newObj.setPropertyValue (propertyName, obj.getPropertyValue (oldName));
						else
							// same property name
							newObj.setPropertyValue (propertyName, obj.getPropertyValue (propertyName));
						endif;
					endforeach;
				endif;
				
				data.allSnapshotData.add (newObj);
			endif;	
		endforeach;
		
		if app.actualTimeServer.getDifferenceInSeconds (_lastCommit) &gt;= 10 then// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			commitTransaction;
			_lastCommit := app.actualTimeServer;	// in case the commit took a long time// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			str := '*** commit transaction ***';
			app.writeStatement (str);
			app.writeLog (str, LogINFO);
			beginTransaction;
		endif;
	endforeach;	
	
	return didUpdate;
epilog
	delete coll;
	delete array;
end;</source>
        <access>protected</access>
        <Parameter name="_ss" type="CM_OutputFormat_SS"/>
        <Parameter name="_oldPropertyNames" type="StringArray"/>
        <Parameter name="_newPropertyNames" type="StringArray"/>
        <Parameter name="_lastCommit" type="TimeStamp" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="upgradeQueryProperties_XTAB" id="65533be8-912e-4590-86b6-ea15ef635483">
        <source>upgradeQueryProperties_XTAB(_xtab :CM_OutputFormat_XTAB; _oldPropertyNames, _newPropertyNames :StringArray):Boolean protected;
// ---------------------------------------------------------------------------
// Created:     21 September 2010 by cnwcs5 par 25708
// Purpose:     When the property/method name changes this method can be used
//				to change summaries to use the new propertyName   
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	grouping	:CM_XTABGrouping;
	field		:CM_XTABField;
	str			:String;
	oldName, newName	:String;
	didUpdate	:Boolean;
	int			:Integer;
begin
	foreach int in 1 to _oldPropertyNames.size do
		oldName := _oldPropertyNames[int];
		newName	:= _newPropertyNames[int];
		
		foreach grouping in _xtab.allTabs do		
			if grouping.propertyName = oldName then
				str := ('- Updating tab property - ' &amp; oldName &amp; ' to ' &amp; newName);
				app.writeStatement (str);
				app.writeLog (str, LogINFO);
	
				grouping.setPropertyValue (CM_XTABGrouping::propertyName.name, newName);
				
				didUpdate := true;
			endif;
		endforeach;
		
		foreach grouping in _xtab.allRows do
			if grouping.propertyName = oldName then
				str := ('- Updating row property - ' &amp; oldName &amp; ' to ' &amp; newName);
				app.writeStatement (str);
				app.writeLog (str, LogINFO);
				grouping.setPropertyValue (CM_XTABGrouping::propertyName.name, newName);
				
				didUpdate := true;
			endif;
		endforeach;
		
		foreach grouping in _xtab.allColumns do
			if grouping.propertyName = oldName then
				str := ('- Updating column property - ' &amp; oldName &amp; ' to ' &amp; newName);
				app.writeStatement (str);
				app.writeLog (str, LogINFO);
				grouping.setPropertyValue (CM_XTABGrouping::propertyName.name, newName);
				
				didUpdate := true;
			endif;
		endforeach;
		
		foreach field in _xtab.allFields do
			if field.propertyName = oldName then
				str := ('- Updating field property - ' &amp; oldName &amp; ' to ' &amp; newName);
				app.writeStatement (str);
				app.writeLog (str, LogINFO);
				field.setPropertyValue (CM_XTABField::propertyName.name, newName);
				
				didUpdate := true;
			endif;
		endforeach;
	endforeach;
	
	return didUpdate;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_xtab" type="CM_OutputFormat_XTAB"/>
        <Parameter name="_oldPropertyNames" type="StringArray"/>
        <Parameter name="_newPropertyNames" type="StringArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
