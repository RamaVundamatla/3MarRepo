    <JadeMethod name="delete" id="d76df749-81ee-4bb4-91e4-e22aef73c9df">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 August 2019	jlgns1	Initial creation

*/

vars

begin
	self.allReserveDetails.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyForStaging" id="09f3fb6f-ae69-4972-afbf-520dbe268928">
        <updating/>
        <source>setProxyForStaging(_release: CM_BulkRelease; _includePackingParent : Boolean; _isForPicking : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Jul 2021	jlier1	Initial creation TFS 51626
28 Oct 2021	jlier1	TFS 52263 - needed to exclude packing parent
05 Mar 2025	navdap1	MTN-34024 PRP | Deadlock 1081, Yard Allocation &amp; Release Request Performance
*/

vars
	reserveDetail	: CM_ReserveDetail;
	wsReserveDetail : WS_ReserveDetail;
	firstStagingLC : CM_LocationsController;
begin
	self.isPacking:=_release.isPackingType;
	self.totalOutstanding		:= _release.getTotalOutstanding;	
	self.totalStaged			:= _release.getTotalStaged(null, firstStagingLC);
	
	foreach reserveDetail in _release.allReserveDetails discreteLock do
		if not _includePackingParent and reserveDetail.isPackingParent then
			continue;
		endif;
		create wsReserveDetail  transient;
		wsReserveDetail.setProxyFromObject(reserveDetail);
		wsReserveDetail.setProxyForStaging(reserveDetail, _isForPicking);			// MTN-34024
		self.allReserveDetails.add(wsReserveDetail);
	endforeach;
	
	if _release.isPackingType then
		foreach reserveDetail in _release.allReservePackingChildren discreteLock do					
		
			create wsReserveDetail transient;
			wsReserveDetail.setProxyFromObject(reserveDetail);
			wsReserveDetail.setProxyForStaging(reserveDetail, _isForPicking);	// MTN-34024
			self.allReserveDetails.add(wsReserveDetail);
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_release" type="CM_BulkRelease"/>
        <Parameter name="_includePackingParent" type="Boolean"/>
        <Parameter name="_isForPicking" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="cb375155-1cba-4a6b-8935-de7cb38b7699">
        <updating/>
        <source>setProxyFromObject(_release: CM_BulkRelease) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 August 2019	jlgns1	Initial creation
6/08/2019 	JLGNS1	ChangeRequest 45293: JMT Handheld Apps - Release Staging Jade
26/7/2021	jlier1	TFS 51626 - STW Release Staging
*/

vars
	reserveDetail	: CM_ReserveDetail;
	wsReserveDetail : WS_ReserveDetail;

begin
	inheritMethod(_release);
	
	self.totalRequested			:= _release.getTotalRequested();		
	self.totalWeightRequested	:= _release.getTotalWeightRequested();	
	self.totalVolumeRequested	:= _release.getTotalVolumeRequested();
	self.releaseNo 				:= _release.code; 
	self.releaseByType 			:= _release.releaseByType;
	self.typeDescription		:= _release.getTypeDescription;
	
		
	
	

epilog

end;</source>
        <Parameter name="_release" type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="setProxyReserveDetails" id="6e8e53a2-bfea-46b2-b587-5c0c160c5bd2">
        <updating/>
        <source>setProxyReserveDetails(_release: CM_BulkRelease) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 July 2021	jlier1	Initial creation TFS 51626 - refactored from setProxyFromObject

*/

vars
	reserveDetail	: CM_ReserveDetail;
	wsReserveDetail : WS_ReserveDetail;
begin
	foreach reserveDetail in _release.allReserveDetails discreteLock do
		//epr TFS 45291 23/9/19 
		if reserveDetail.isFullyLoaded then
			continue;
		endif;
	
		if reserveDetail.isKindOf(CM_ReserveSelection) then
			create wsReserveDetail as WS_ReserveSelection transient;
		elseif reserveDetail.isKindOf(CM_ReserveTI) then
			create wsReserveDetail as WS_ReserveTI transient;
		endif;
		wsReserveDetail.setProxyFromObject(reserveDetail);

		self.allReserveDetails.add(wsReserveDetail);
	endforeach;
epilog

end;</source>
        <Parameter name="_release" type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="setProxyRoadRelSummary" id="37a18472-f6de-49b0-9793-1cc76a610b0e">
        <updating/>
        <source>setProxyRoadRelSummary(_release: CM_BulkRelease) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Apr 2025	navma1	MTN-34595 	DPH - Release Staging – Improve Performance of getRoadReleaseSummary() API

*/

vars
	reserveDetail		: CM_ReserveDetail;
	wsReserveDetail 	: WS_ReserveDetail;
	reserveSet			: CM_ReserveDetailSet; 
begin
	
	create reserveSet	transient;
	
	_release.allReserveDetails.copy(reserveSet);
	
	foreach reserveDetail in reserveSet discreteLock do
		//epr TFS 45291 23/9/19 
		if reserveDetail.isFullyLoaded then
			continue;
		endif;
	
		if reserveDetail.isReserveSelection then
			create wsReserveDetail as WS_ReserveSelection transient;
		else
			create wsReserveDetail as WS_ReserveTI transient;
		endif;
		
		wsReserveDetail.setProxyRoadReserveSummary(reserveDetail);

		self.allReserveDetails.add(wsReserveDetail);
	endforeach;
epilog
	delete reserveSet;
end;</source>
        <Parameter name="_release" type="CM_BulkRelease"/>
    </JadeMethod>
</Class>
