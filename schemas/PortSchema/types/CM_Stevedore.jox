    <JadeMethod name="pxyCreateUpdateProxy" id="dd256f59-8a91-40b2-8032-e485610e7276">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------
// Created:	07 April 2004 By: cnwgd1
//--------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// 30/05/2019	jlgdap1		TFS 44554 AAT Stevedore Data Access
vars
	proxy : SelfType;
	completedOK		: Boolean;
begin
	proxy := inheritMethod();
	self.allContacts.copy(proxy.allContacts);
	proxy.myDebtor := self.myDebtor;				// TFS 44554
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
