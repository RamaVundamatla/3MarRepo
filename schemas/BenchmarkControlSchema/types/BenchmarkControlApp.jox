    <JadeMethod name="getUserCmdLine" id="8ff28295-1bef-45fe-a6de-59a76811d85a">
        <updating/>
        <source>getUserCmdLine():String updating;

vars
	s,t:String;
	i,j:Integer;
begin
	if app.isUnicode then
		s:=(call getCommandLineW);
	else
		s:=(call getCommandLine);
	endif;
	logMessage("&lt;"&amp;s&amp;"&gt;");
	i:=s.toLower.pos(" endjade ",1);
	if i=0 then return null; endif;  // No endJade token
	return s[i+8:end].trimBlanks;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="housekeepingRemoveDir" id="c5c96736-6226-4f92-9f13-3223874b174c">
        <updating/>
        <source>housekeepingRemoveDir(dirName:String; files,folders:Integer io; retentionDays:Integer; verbose:Boolean) updating;

vars
	ff:FileFolder; fn:FileNode;
	fnDaysOld,ffDaysOld:Integer;
	ts:TimeStamp;
begin
	create ff transient;
	//ff.usePresentationFileSystem := false;
	ff.fileName := dirName;
	if not ff.isAvailable then
		app.logMessage("folder is not available " &amp; ff.fileName);
		return;
	endif;
	ffDaysOld := ts.date - ff.lastModifiedTime.date;  // must capture folder timestamp now, because the first purge with change it to today!
	//app.logMessage(ffDaysOld.String &amp; Tab &amp; ff.fileName);  // this logging is normally suppressed
	foreach fn in ff.files do
		if fn.isKindOf(FileFolder) then
			housekeepingRemoveDir(fn.fileName, files, folders, retentionDays, false);  // recursion!!
		else
			fnDaysOld := ts.date - fn.lastModifiedTime.date; 
			if fnDaysOld &gt; retentionDays and ffDaysOld &gt; retentionDays then  // file is old enough and the folder it is in is old enough
				//app.logMessage("removing old file " &amp; fn.fileName);  // this logging is normally suppressed
				files := files + 1;
				fn.readOnly := false;
				fn.purge;
			endif;
		endif;
	endforeach;
	if ff.files.size = 0 and ffDaysOld &gt; retentionDays then
		if verbose then
			app.logMessage("removing folder " &amp; ff.fileName);
		endif;
		folders := folders + 1;
		ff.purge;
	endif;
epilog
	delete ff;
end;
</source>
        <Parameter name="dirName" type="String"/>
        <Parameter name="files" type="Integer" usage="io"/>
        <Parameter name="folders" type="Integer" usage="io"/>
        <Parameter name="retentionDays" type="Integer"/>
        <Parameter name="verbose" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isAnyAppRunning" id="dabf7ad3-b4e8-46c2-8ffb-a7bad1845cb2">
        <updating/>
        <source>isAnyAppRunning(name:String):Boolean updating;

vars
	proc:Process;
	error:Boolean;
begin
	on Exception do jtdObjNotFoundExceptionHandler(exception, error);
	foreach proc in Process.instances where proc.persistentApp.name = name and proc &lt;&gt; process do
		return true;
	endforeach;
	
	return false;
end;
</source>
        <Parameter name="name" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSuperuser" id="01c7c984-4d56-4bf8-8636-3a15b1d145cf">
        <source>isSuperuser():Boolean;

vars
	s:String;
begin
	s:=process.getUserCode;
	if s = "cnwjhp1" or s = "cnwmjw1" or s = "cnwcmh1" or s = "wynjr2" or s = "wynhk1" then
		return true;
	endif;
	return false;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jtdComputerName" id="72443a46-e323-45e0-b927-7a0e1acdf1b1">
        <source>jtdComputerName() : String;

vars
	str		: String;
	pos		: Integer;
begin
	//  Strips off domain part of computer name (for Unix hosts)

	str		:= app.computerName;
	if str &lt;&gt; null then
		pos		:= 1;
		return str.scanUntil(".", pos);
	else
		return "NO_COMPUTERNAME";
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdComputerNameAppServer" id="a7e5ca70-7d05-4e10-85a8-6a364e29c378">
        <source>jtdComputerNameAppServer() : String;

vars
	str		: String;
	pos		: Integer;
begin
	//  Strips off domain part of computer name (for Unix hosts)

	str		:= app.computerNameAppServer;
	pos		:= 1;
	return str.scanUntil(".", pos);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdGetApplicationType" id="5cf62959-f2d1-41d9-8d90-fe129a5d4591">
        <source>jtdGetApplicationType() : String;

vars

begin
	if applicationType = "G" then
		return "GUI";
	elseif applicationType = "F" then
		return "GUI_No_Forms";
	elseif applicationType = "S" then
		return "Non_GUI";
	elseif applicationType = "W" then
		return "Web_Enabled";
	elseif applicationType = "N" then
		return "Non_GUI_Web";
	else
		return applicationType;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdGetClassAndOid" id="86b1397f-e13d-40dc-8c57-579d02879f97">
        <source>jtdGetClassAndOid(obj : Object) : String;

vars
 	classNo		: Integer;
	oidStr		: String;
	class		: Class;
	error		: Boolean;
	oid			: String;
begin
	if obj &lt;&gt; null then
		on Exception do jtdObjNotFoundExceptionHandler(exception, error);
		oidStr		:= obj.String;
		if not error then
			return oidStr;
		else
			class	:= getClassForObject(obj);			// refactored for 3.0 using 6.0.18 method
			oid		:= getOidStringForObject(obj);
			oidStr	:= class.name &amp; "/" &amp; oid;
			return oidStr;
		endif;
    	
	    if error then
	    	return "&lt;Unknown class, oid=" &amp; oid &amp; "&gt;";
	    endif;

	else
		return "&lt;null&gt;";
	endif;
end;</source>
        <Parameter name="obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdGlobalExceptionHandler" id="7fa67764-1e38-44e5-8d00-1e3302000a9c">
        <source>jtdGlobalExceptionHandler(ex:Exception):Integer;

vars
	dumpStack:JtdDumpStack;
begin
	create dumpStack transient;
	dumpStack.dumpStack(ex);
	if ex.errorCode = 5030  // file in use
	then
		return Ex_Resume_Next;
	endif;
	if app.name = "DoCommand" then
		if not process.isInTransactionState then
			beginTransaction;
		endif;
		node.userExitCode:=ex.errorCode;
		commitTransaction;
		
	elseif app.name = "MachineStatusMgr" or app.name = "PingStatusMgr" then
		if process.isInTransientTransactionState then
			abortTransientTransaction;
		endif;
		
	elseif app.name = "FunctionalTests" then
		app.msgBox("Exception " &amp; ex.errorCode.String &amp; CrLf &amp; "A stack dump has been produced.", "Exception Occurred", MsgBox_OK_Only);
		
	elseif app.name = "BmkStdRun" then
		terminate;
	endif;
	abortTransaction;
	return Ex_Abort_Action;
epilog
	delete dumpStack;
end;</source>
        <Parameter name="ex" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jtdObjNotFoundExceptionHandler" id="79657d78-03db-4c1b-8fc9-60ba2dc469ce">
        <source>jtdObjNotFoundExceptionHandler(exObj:Exception; error:Boolean output):Integer;

begin
	if exObj.errorCode = 4
	or exObj.errorCode = 1046  // invalid class number
	or exObj.errorCode = 1072
	or exObj.errorCode = 1090
	or exObj.errorCode = 1092	then
	   	error := true;
		return Ex_Resume_Next;
	else
		return Ex_Pass_Back;
	endif;
end;</source>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="error" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="logFileException" id="691035ee-4e54-4bb4-9bbb-9972295ab1b3">
        <source>logFileException(ex:Exception):Integer;

begin
	app.logMessage("Exception " &amp; ex.errorCode.String &amp; " (" &amp; ex.text &amp; ")");  // this can be null // from " &amp; ex.reportingMethodDesc.method.qualifiedName);
	if ex.errorObject.isKindOf(File) then
		app.logMessage("File name is " &amp; ex.errorObject.File.fileName);
	endif;
	return Ex_Resume_Next;
end;
</source>
        <Parameter name="ex" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="logMessage" id="b1897f61-13cf-4714-abca-5b976d064aba">
        <updating/>
        <source>logMessage(s:String) updating;
/*  Uses the JadeLog class to write a message to msg&lt;n&gt;.log  */
begin
	if msgLog=null then
		create msgLog;
		msgLog.fileName:="msg";
		msgLog.formatOutput:=false;
//		msgLog.maxFileSize:=1000;  // leave commented out to use value from ini file
	endif;
	msgLog.log(actualTimeAppServer.logFormat&amp;" "
					&amp;name&amp;"/"&amp;cnGetInstanceId(process).String&amp;": "
					&amp;s&amp;CrLf);
end;</source>
        <Parameter name="s" type="String"/>
    </JadeMethod>
    <JadeMethod name="logMessageGraduated" id="bbee6f20-72ad-48ae-ad36-beafc2d5cf81">
        <updating/>
        <source>logMessageGraduated(s:String; elapsedSeconds:Integer) updating;
//	log first time, then every 10 seconds for the first minute, then once a minute
begin
	if elapsedSeconds &lt;= 60 and elapsedSeconds mod 10 = 0 or elapsedSeconds mod 60 = 0 then
		logMessage(s);
	endif;
end;
</source>
        <Parameter name="s" type="String"/>
        <Parameter name="elapsedSeconds" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="logMyMessage" id="cea0eb1e-b18f-449c-ae86-caac9f013147">
        <updating/>
        <source>logMyMessage(s:String) updating;
/*  Uses the JadeLog class to write a message to &lt;myname&gt;&lt;n&gt;.log  */
begin
	if msgMyLog=null then
		create msgMyLog;
		msgMyLog.fileName:=app.computerName.toLower&amp;"_msg";
		msgMyLog.formatOutput:=false;
//		msgMyLog.maxFileSize:=1000;  // leave commented out to use value from ini file
	endif;
	msgMyLog.log(actualTimeAppServer.logFormat&amp;" "
					&amp;name&amp;"/"&amp;cnGetInstanceId(process).String&amp;": "
					&amp;s&amp;CrLf);
end;</source>
        <Parameter name="s" type="String"/>
    </JadeMethod>
    <JadeMethod name="miscPath" id="8868763e-1a98-4098-85b9-7586bfd8399a">
        <source>miscPath():String;

begin
	return app.dbPath.replace("c_system", "c_misc");
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="purgePrePreparedEnvironment" id="a005b654-2fc1-4e9c-88d4-e6fc2e8fa182">
        <executionLocation>server</executionLocation>
        <source>purgePrePreparedEnvironment(fastbuildid:String) serverExecution;

vars
	m:Machine;
	fn:FileNode; ff:FileFolder;
	files,folders:Integer;
begin
	create ff transient;
	foreach m in Machine.instances where m.hostName &lt;&gt; "cnwchcs118" do
		ff.fileName := "\\" &amp; m.hostName &amp; "\t$\prepreparedenvironments";
		if ff.isAvailable then
			foreach fn in ff.files where fn.name.contains(fastbuildid) do
				app.logMessage(fn.fileName &amp; " " &amp; fn.lastModifiedTime.String);
				files := 0;
				folders := 0;
				app.housekeepingRemoveDir(fn.fileName, files, folders, -1, true);
				app.logMessage("deleted " &amp; files.String &amp; " files, " &amp; folders.String &amp; " folders");
			endforeach;
		else
			app.logMessage("no prepreparedenvironments on " &amp; m.hostName);
		endif;
	endforeach;
epilog
	delete ff;
end;
</source>
        <Parameter name="fastbuildid" type="String"/>
    </JadeMethod>
    <JadeMethod name="raiseNormalException" id="0f22a05e-1290-4ac4-9ca4-9c7368976f78">
        <updating/>
        <source>raiseNormalException(errorcode : Integer; erroritem : String; errortext : String; resumable : Boolean) updating;

vars
	exObj : NormalException;
begin
	create exObj transient;
	exObj.errorCode 		:= errorcode;
	exObj.errorItem			:= erroritem;
	exObj.extendedErrorText	:= errortext;
	exObj.continuable		:= false;
	exObj.resumable			:= resumable;
	raise exObj;
end;</source>
        <Parameter name="errorcode" type="Integer"/>
        <Parameter name="erroritem" type="String"/>
        <Parameter name="errortext" type="String"/>
        <Parameter name="resumable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sendEmail" id="81a6d902-adea-4237-abfd-842630ad61fb">
        <updating/>
        <source>sendEmail(toAddress,ccAddress,subject,body:String) updating;  //, clientExecution;
//	send a notification to EmailSender app, running out of TestResultsSchema
//	separate addresses by commas
//	subject line cannot contain semicolons (they get replaced by commas)
//	To and CC may be required?
vars
	emailNote:String;
begin	
	if isAnyAppRunning("EmailSender") then
		emailNote := toAddress.replace(";", ",") &amp; ';' &amp; ccAddress.replace(";", ",") &amp; ';' &amp; subject.replace(";", ",") &amp; ';' &amp; body;
		app.logMessage(method.qualifiedName &amp; " " &amp; emailNote);
		system.causeEvent(SendEmailNote, true, emailNote);	
	else
		app.logMessage(method.qualifiedName &amp; " Error - EmailSender app is not running " &amp; CrLf &amp; emailNote);
		return;
	endif;
end;
</source>
        <Parameter name="toAddress" type="String"/>
        <Parameter name="ccAddress" type="String"/>
        <Parameter name="subject" type="String"/>
        <Parameter name="body" type="String"/>
    </JadeMethod>
    <JadeMethod name="sendEmailToAdmin" id="118720ae-cdfe-4a98-aa1d-e1450a0c9546">
        <updating/>
        <source>sendEmailToAdmin(subject,body:String) updating;  //, clientExecution;
//	send a notification to EmailSender app, running out of TestResultsSchema
//	separate addresses by commas
//	subject line cannot contain semicolons (they get replaced by commas)
//	To and CC lists are contained from jblWorker.conf
vars
	f:File;
	jblworkerConf:String;
begin	
	create f transient;
	f.usePresentationFileSystem := false;
	
	f.fileName := "c:\thinbin\tools\jblworker.conf";
	jblworkerConf := f.readString(f.fileLength);
	f.close;
	
	sendEmail(jblworkerConf.getXMLValue("email"),jblworkerConf.getXMLValue("ccemail"),subject,body);
	
epilog
	delete f;
end;
</source>
        <Parameter name="subject" type="String"/>
        <Parameter name="body" type="String"/>
    </JadeMethod>
