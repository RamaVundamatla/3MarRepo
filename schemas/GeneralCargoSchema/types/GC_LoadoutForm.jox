    <JadeMethod name="setContainerCombos" id="a28b185c-7098-44c2-aa8b-dc152c7f4933">
        <updating/>
        <source>setContainerCombos(_ti : CM_TrackedItem) updating, protected;
// ---------------------------------------------------------------------------
// Created:     08 November 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tmpImexStatus	: CM_IMEXStatus;
	tmpCommodity	: CM_Commodity;
	tmpOperator		: CM_Operator;
	tmpContents		: CM_ContentsStatus;
	tmpDisPort		: CM_Port;
	user			: CM_User;
	failedDAC  :CM_DataAccessController;
begin

	user := app.getMyUser();
	
	self.cmbTypeToPack.listObject := _ti.myCargoType;

	tmpOperator := app.myRoot.allOperators[_ti.operatorCode];
//	if tmpOperator &lt;&gt; null and 
//	   (not tmpOperator.isNotAvailableForEntry) and
//	   tmpOperator.canUserAccessSelf(null, app.myPassport) then
//		self.cmbContOp.listObject := tmpOperator;
//	ccms1235 - above code handles in combo box methods
		self.cmbContOp.setObject(tmpOperator);
//	endif;
	
	//tmpDisPort := app.myRoot.allPorts[_ti.dischargePort];
	tmpDisPort := app.myRoot.allPorts[_ti.dischargePort];
	if tmpDisPort &lt;&gt; null and 
	   (not tmpDisPort.isNotAvailableForEntry) then
	   	self.cmbDisPort.setObject (tmpDisPort);
	   //	self.cmbDisPort.listObject := tmpDisPort;
	endif;

	tmpImexStatus := app.myRoot.allImexStatuses[_ti.getImExStatus()];
	if tmpImexStatus &lt;&gt; null then
		self.cmbIMEX.listObject := tmpImexStatus;
	endif;
	
	tmpCommodity := app.myRoot.allCommodities[_ti.commodity];
	if tmpCommodity &lt;&gt; null and 
	   (not tmpCommodity.isNotAvailableForEntry) and
	   tmpCommodity.canUserAccessSelf(null, failedDAC, app.myPassport) then
		self.cmbCommodity.listObject := tmpCommodity;
	endif;
	
	if CM_Container.hasInstance(_ti) then
		tmpContents := app.myRoot.allContentsStatuses[_ti.CM_Container.contentsStatus];
		if tmpContents &lt;&gt; null and
		   tmpContents.canUserAccessSelf(null, failedDAC, app.myPassport) then
			self.cmbContents.listObject := tmpContents;
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setContainerDetails" id="203c66a3-7a10-4284-97bc-5b76cf7ebe5e">
        <updating/>
        <source>setContainerDetails() protected, updating;
// ---------------------------------------------------------------------------
// Created:     08 November 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	ti 				: CM_TrackedItem;
	cargoType		: CM_CargoType;
	id				: String;
	tbl				: CM_EntryTable;
	entView			: EntTableView;
	entTableRow		: EntTableRow;
	aBR : CM_BulkRelease;

begin

	cargoType := self.cmbTypeToPack.listObject.CM_CargoType;
	id := self.cmbPackInto.text;
	if cargoType = null then
		ti := self.myTerminal.allOnsiteTIsByIdCargoType[id, null];
	else
		ti := self.myTerminal.allOnsiteTIsByCargoTypeId[cargoType.id, id];		
	endif;
	
	if ti = null then
		return;
	endif;

	// ### CCMS 1288 AKB2005APR
	// cnwdad1 28/05/2007 - PAR #14118.
	//aBR := ti.allBulkReleasesAssigned[BR_TYPE_PACKING, BR_ACTIVE, null, null];
	aBR := ti.allBulkReleasesAssigned.getAtKeyGeq(BR_TYPE_PACKING, BR_ACTIVE, null, null);
	if aBR &lt;&gt; null then
		self.doCmbBRBuild(aBR);
	else
		self.cmbBR.listIndex := -1;
	endif;		
	self.cmbBR.lostFocus(self.cmbBR);

	
	tbl := self.tblMasterEnt;
	entView := tbl.myEntTableDef.allEntTableViews['BOLOutEntContOnly'];
	if entView = null then
		return;
	endif;
	
	foreach entTableRow in entView.allEntTableRows do
		if entTableRow.name = ETRow_SealNumCustoms then
			//15 Sep 2010	NDL	Par 25608 - change to using method 'getSealNumCustoms' or 'getSealNumCustomsFirst'
			tbl.setValueByName(ETRow_SealNumCustoms,ti.getSealNumCustomsFirst); 
			//To prevent all customs seal nums being returned (only want current one as can lead to too large string error)
			continue;
		endif;
		tbl.setValueByName(entTableRow.name, ti.getDisplayStringForAttribute(entTableRow.name, false));
	endforeach;

	self.setContainerCombos(ti);
		
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="8780f524-4b36-41d0-9a53-5d46ffcd2dd8">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:     02 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	defaultDate			: Date;
begin

	self.doChangeEntryView();
	self.btnAutoAssign.enabled := true;
	self.btnDelete.visible := false;
	self.btnDeleteDocket.enabled := false;

	if self.mode = self.Mode_New then
		defaultDate := app.actualTimeServer.date;
		self.tblMasterEnt.setValueByName(ETRow_ReferenceDate, defaultDate);
		self.cmbConsignee.clear();  // clear myObject in combo box from any previous edit 
		self.cmbConsignor.clear();  // using clear also clears out any dirty objects 
		self.cmbOperator.clear();  
		self.cmbContOp.clear();  
//		self.setState(STATE_DISABLED);
	else
		self.btnAddShow.enabled := false;
		self.btnAddDetail.enabled := false;
		self.btnRemoveDtl.enabled := false;
		self.btnRemoveDtl2.enabled := false;
		self.btnUpdateDetail.enabled := false;
		self.btnUpdateShow.enabled := false;
		self.btnSaveBase.enabled := true;
		self.tblDataDetail.enabled := false;
		self.tblDetailEnt.enabled := false;
		self.tblMasterEnt.disableRowByName(ETRow_MyStockOrder);
		self.tblMasterEnt.disableRowByName(ETRow_ProcessOpt);
		self.tblMasterEnt.disableRowByName(ETRow_ItemTypeToPack);
		self.tblMasterEnt.disableRowByName(ETRow_ParentToPack);
		self.tblMasterEnt.disableRowByName(ETRow_Charged);
		
		self.tblMasterEnt.disableRowByName(ETRow_TransportMode);
		self.tblMasterEnt.disableRowByName(ETRow_CarrierCode);
		self.tblMasterEnt.disableRowByName(ETRow_VehicleId);
		self.tblMasterEnt.disableRowByName(ETRow_Wagon);
		self.tblMasterEnt.disableRowByName(ETRow_WagonTrain);	//04 Nov 2009	NDL	Par 21519
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForView" id="5a9fd5b2-8957-4a31-8586-ec6f37ae7659">
        <updating/>
        <source>setControlsForView() updating;
// ---------------------------------------------------------------------------
// Created:     10 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod();
	self.btnAutoAssign.enabled := false;
	self.btnDelete.visible := false;
	self.btnDeleteDocket.enabled := true;
	self.tblDataDetail.enabled := true;
	self.tblDetailEnt.enabled := true;
	
	
	self.btnAddShow.enabled := false;
	self.btnRemoveDtl.enabled := false;
	
	self.tblMasterEnt.enableRowByName(ETRow_MyStockOrder);
	self.tblMasterEnt.enableRowByName(ETRow_ProcessOpt);
	self.tblMasterEnt.enableRowByName(ETRow_ItemTypeToPack);
	self.tblMasterEnt.enableRowByName(ETRow_ParentToPack);
	self.tblMasterEnt.enableRowByName(ETRow_Charged);
	
	self.tblMasterEnt.enableRowByName(ETRow_TransportMode);
	self.tblMasterEnt.enableRowByName(ETRow_CarrierCode);
	self.tblMasterEnt.enableRowByName(ETRow_VehicleId);
	self.tblMasterEnt.enableRowByName(ETRow_Wagon);
	self.tblMasterEnt.enableRowByName(ETRow_WagonTrain);	//04 Nov 2009	NDL	Par 21519
end;</source>
    </JadeMethod>
    <JadeMethod name="setForPermission" id="6b669620-6a4d-47a2-a4b2-74d6460d59b5">
        <source>setForPermission();
// ---------------------------------------------------------------------------
// Created:     14 October 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	user : CM_User;
begin
	inheritMethod();

	user := app.getMyUser();
	if user = null then
		return;
	endif;
	
	if (not user.canDo(self.myTerminal, self.permissionMaint)) then
		self.btnDeleteDocket.visible := false;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setSearchValues" id="e1c7ec3d-66d2-4bd9-be16-56341df97e60">
        <updating/>
        <source>setSearchValues() updating;
// ---------------------------------------------------------------------------
// Created:     31 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tmpDate		: Date;
begin
	self.filtDocketNumber := self.tblSearch.getValueByName(ETRow_FiltBOLNumber).String;
	self.myFiltOperator := self.cmbFiltOperator.listObject.CM_Operator;
	
	if self.cmbFiltStatus.listIndex &gt; 0 and self.cmbFiltStatus.text &lt;&gt; Any_String then
		self.filtStatus := self.cmbFiltStatus.itemData[self.cmbFiltStatus.listIndex];
	else
		self.filtStatus := null;
	endif;
	
	if self.cmbFiltProOpt.listIndex &gt; 0 then
		self.filtProcessOption := self.cmbFiltProOpt.itemData[self.cmbFiltProOpt.listIndex];
	else
		self.filtProcessOption := null;
	endif;
	
	self.myFiltVoyage := self.cmbFiltVoyage.listObject.CM_Voyage;
	
//	tmpDate := self.tblSearch.getValueByName(ETRow_FiltDateFrom).Date;
	tmpDate := self.tblSearch.getValueAsDate(ETRow_FiltDateFrom);
	
	if tmpDate.isValid then
		self.filtDateFrom := tmpDate;
	else
		self.filtDateFrom := null;
	endif;
	
//	tmpDate := self.tblSearch.getValueByName(ETRow_FiltDateTo).Date;
	tmpDate := self.tblSearch.getValueAsDate(ETRow_FiltDateTo);
	
	if tmpDate.isValid then
		self.filtDateTo:= tmpDate;
	else
		self.filtDateTo:= null;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setState" id="c00794de-24d1-46e0-869a-e00d4f3de161">
        <source>setState(_state : Integer) protected;
// ---------------------------------------------------------------------------
// Created:     18 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	
	if _state = STATE_DISABLED then	 
		self.btnAddShow.enabled := false;
		self.btnAutoAssign.enabled := false;
		self.btnRemoveDtl.enabled := false;
//		self.btnUpdateShow.enabled := false;
		self.btnSaveBase.enabled := false;
	elseif _state = STATE_ENABLED then
		if self.allowDetailAdd then 
			self.btnAddShow.enabled := true;
			self.btnAutoAssign.enabled := true;
		endif;
		if self.allowDetailUpdate then
//			self.btnUpdateShow.enabled := true;
		endif;
		if self.allowDetailRemove then
			self.btnRemoveDtl.enabled := true;
		endif;
		self.btnSaveBase.enabled := true;	
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setTblDataDetailCells" id="9f801f55-35ea-46e0-87f2-90e7cd5a0621">
        <updating/>
        <source>setTblDataDetailCells(_theRow : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     26 July 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
backColour : Integer;
	tmpTable : CM_DataTable;
	intCol		: Integer;
begin

	tmpTable := self.tblDataDetail;
	
	backColour := tmpTable.accessedRow.backColor;
	tmpTable.accessCell(_theRow, self.colCargoType).backColor := White;
	tmpTable.accessCell(_theRow, self.colItem).backColor := White;
	tmpTable.accessCell(_theRow, self.colProduct).backColor := White;	
									
	//disable cells that do not need input
	//intCol := tmpTable.getColumnByRowName(ETRow_Weight);					//-cnwml2 MSL CCMS 1017
	intCol := tmpTable.getColumnByRowName(ETRow_TotalWeight);				//+cnwml2 MSL CCMS 1017
	if intCol &gt; 0 then
		tmpTable.accessCell(_theRow, intCol).enabled := false;
		tmpTable.accessCell(_theRow, intCol).backColor := backColour;				
	endif;
	
	intCol := tmpTable.getColumnByRowName(ETRow_Volume);
	if intCol &gt; 0 then
		tmpTable.accessCell(_theRow, intCol).enabled := false;
		tmpTable.accessCell(_theRow, intCol).backColor := backColour;	
	endif;			

	intCol := tmpTable.getColumnByRowName(ETRow_Location);
	if intCol &gt; 0 then
		tmpTable.accessCell(_theRow, intCol).enabled := false;
		tmpTable.accessCell(_theRow, intCol).backColor := backColour;
	endif;				

	intCol := tmpTable.getColumnByRowName(ETRow_LineNo);
	if intCol &gt; 0 then
		tmpTable.accessCell(_theRow, intCol).enabled := false;
		tmpTable.accessCell(_theRow, intCol).backColor := backColour;	
	endif;			
end;</source>
        <Parameter name="_theRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setViewForBOLOut" id="a8ae3511-45c7-41d7-b024-2f9d0c93b18c">
        <source>setViewForBOLOut(_processOption, _transportMode : Integer) : EntTableView;
// ---------------------------------------------------------------------------
// Created:     01 April 2004	cnwth2
//
// Purpose:     Sets the view, but also returns it so it can be used in the showThimbnail to
//				populate the appropriate rows
//			 
// ----------   ----------  --------------------------------------------------
vars
	viewName			: String;
	entView				: EntTableView;
begin

	if _processOption = Process_Direct_Loadout then
		if _transportMode = TI_TRANSMODE_ROAD then
			viewName := 'BOLOutEntRoad';
		elseif _transportMode = TI_TRANSMODE_RAIL then
			viewName := 'BOLOutEntRail';
		elseif _transportMode = TI_TRANSMODE_SHIP then
			viewName := 'BOLOutEntShip';
		else
			viewName := 'BOLOutEntDirect';
		endif;
	elseif _processOption = Process_Pack then
		viewName := 'BOLOutEntPack';
	else
		viewName := 'BOLOutEntDefault';	
	endif;
	
	entView := self.tblMasterEnt.myEntTableDef.allEntTableViews[viewName];
	self.tblMasterEnt.showHideRowsByView(entView, self.tblDetailEnt.ShowHideRows, false);
	self.tblMasterEnt.adjustHeight(300);
	self.splMain.cnEcResizeContents();
	return entView;

end;</source>
        <Parameter name="_processOption" type="Integer"/>
        <Parameter name="_transportMode" type="Integer"/>
        <ReturnType type="EntTableView"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="6a0d69dd-7c18-4d68-b529-9f1081b24439">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     01 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tbl			: CM_DataTable;
begin
	inheritMethod();

	self.setViewForBOLOut(null, null);
	tbl := self.tblDataDetail;
	tbl.multiSelect := self.tblDataDetail.MultiSelect_Simple;
//	tbl.userInputEnabled := false;
	tbl.tabKey := J_key_Tab;
	
	if tbl.columns &gt; 0 then
		tbl.sortColumn[1] := 1;
		if tbl.columns &gt; 1 then	
			tbl.sortColumn[2] := 2;
			if tbl.columns &gt; 2 then	
				tbl.sortColumn[3] := 3;
			endif;
		endif;
	endif;
	
	self.tblSearch.setValueByName(ETRow_FiltStatus, Any_String);
	self.doCmbBRBuild(null);
	self.setColIndexsTblDataDetail();
	self.allTmpItems.setMembership(CMIF_TIsForProduct);
	self.allTmpItems.addMemberKey(CMIF_TIsForProduct::myProduct.name, true, false);
	self.allTmpItems.endKeys(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="showHideDeleteDocketFrm" id="a286b53a-2da9-45ca-af08-e31c9896b610">
        <updating/>
        <source>showHideDeleteDocketFrm(_show : Boolean) updating, protected;
// ---------------------------------------------------------------------------
// Created:     28 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	frm			: CMUI_MoveableFrame;
begin
	frm := self.frmDeleteDocket;
	self.splMain.enabled := (not _show);
	
	self.btnNew.enabled := (not _show);
	self.btnShowSearcher.enabled := (not _show);
	self.btnSearch.enabled := (not _show);
	
	frm.parent := self;
	frm.zOrder(1);
	frm.left := (self.width / 2) - (frm.width / 2);
	frm.top := (self.height / 2) - (frm.height / 2);
	
	frm.visible := _show;
	
	if _show then
		self.cmbTAType.setFocus();
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_show" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="9cef9dce-bd6b-449c-bd9d-314149d2f10b">
        <updating/>
        <source>showThumbnailData(_obj: CM_Object) updating;
// ---------------------------------------------------------------------------
// Created:     01 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	detailTbl		: CM_DataTable;
	masterTbl		: CM_EntryTable;
	bolOut			: CM_BOLOut;
	tmpOperator		: CM_Operator;
	tmpConsign		: CM_ConsigneeConsignor;
	tmpCarrier		: CM_Carrier;
	tmpVoy			: CM_Voyage;
	entRow			: EntTableRow;
	entView			: EntTableView;
	orderLineTI		: CM_BOLOutStockOrderLineTI;
	theProcessOpt	: Integer;
	ti				: CM_TrackedItem;
	bolOutTILine	: CM_BOLOutStockOrderLineTI;
begin
	if (not CM_BOLOut.hasInstance(_obj)) then
		return;
	endif;
	

	masterTbl := self.tblMasterEnt;
	bolOut := _obj.CM_BOLOut;
	theProcessOpt := bolOut.processOption;
	entView := self.setViewForBOLOut(theProcessOpt, bolOut.transportMode);
	
	foreach entRow in entView.allEntTableRows do
		masterTbl.setValueByName(entRow.name, bolOut.getDisplayStringForAttribute(entRow.name, false));
	endforeach;

	//row values have been set, not set the combobox listObjects
	if bolOut.myOperator &lt;&gt; null then //rs par 10942
		tmpOperator := app.myRoot.allOperators[bolOut.myOperator.code];
	endif;
//	if tmpOperator &lt;&gt; null and (not tmpOperator.isNotAvailableForEntry) and (self.cmbOperator.findObject(tmpOperator) &lt;&gt; -1) then
//		self.cmbOperator.listObject := tmpOperator;
//	endif;
	self.cmbOperator.setObject(tmpOperator);
			
	tmpConsign := app.myRoot.allConsigneeConsignors[bolOut.consignee];
//	if tmpConsign &lt;&gt; null /* and (not tmpConsign.isNotAvailableForEntry)*/ then
		self.cmbConsignee.setObject(tmpConsign);
//		self.cmbConsignee.listObject := tmpConsign; HG CCMS1235 09/12/04
//	else
//	self.cmbConsignee.setObject(null);
//	endif;
	
	if bolOut.isCharged then 
		masterTbl.setValueByName(ETRow_Charged, true);
	else 
		masterTbl.setValueByName(ETRow_Charged, false); 
	endif;
	
//	HG CCMS1235 09/12/04
	tmpConsign := app.myRoot.allConsigneeConsignors[bolOut.consignor];
//	if tmpConsign &lt;&gt; null /* and (not tmpConsign.isNotAvailableForEntry)*/ then
		self.cmbConsignor.setObject(tmpConsign);
//		self.cmbConsignee.listObject := tmpConsign; 
//	else
//	self.cmbConsignor.setObject(null);
//	endif;
	
	masterTbl.setValueByName(ETRow_ReferenceDate, bolOut.referenceDate);
	self.cmbProcessOpt.text := app.processOptionEnumToString(theProcessOpt);
	
	if theProcessOpt = Process_Direct_Loadout then
		if bolOut.transportMode = TI_TRANSMODE_ROAD then
			self.cmbTransportMode.text := app.transModeToString(TI_TRANSMODE_ROAD);
			tmpCarrier := app.myRoot.allCarriers[bolOut.carrierCode];
			if tmpCarrier &lt;&gt; null then
			// DVB changed 15/09/04
				//self.cmbCarrier.listObject := tmpCarrier;
				self.cmbCarrier.setObject(tmpCarrier);
				self.myAssistant.comboBoxVehicleTable(self.tblMasterEnt, ETRow_Vehicle, tmpCarrier);
				self.tblMasterEnt.setValueByName(ETRow_Vehicle, bolOut.vehicle);	
			endif;
			
		elseif bolOut.transportMode = TI_TRANSMODE_RAIL then
			self.cmbTransportMode.text := app.transModeToString(TI_TRANSMODE_RAIL);
			//cnwth2 to set the wagon in her
		
		elseif bolOut.transportMode = TI_TRANSMODE_SHIP then
			self.cmbTransportMode.text := app.transModeToString(TI_TRANSMODE_SHIP);
	
			if bolOut.myVoyage &lt;&gt; null and
			   self.myTerminal.allVoyagesByCode.includesKey(bolOut.myVoyage.code, bolOut.myVoyage.arrivedDT ) then
				self.cmbVoyage.listObject := bolOut.myVoyage;
			endif;
		endif;
		
	elseif theProcessOpt = Process_Pack then
		if bolOut.myMasterTI &lt;&gt; null then
			self.setContainerCombos(bolOut.myMasterTI);
		endif;
	endif;

	detailTbl := self.tblDataDetail;
	foreach ti in bolOut.allTrackedItems do
		if ti.myBOLOutStockOrderTI = null then
			self.addObjectToDetailTable(ti);
		endif;
	endforeach;
	
	foreach bolOutTILine in bolOut.allBOLOutStockOrderTIs do
		self.addObjectToDetailTable(bolOutTILine);
	endforeach;
	
	self.doAssignLineNos();
	
end;</source>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="showThumbnailDataDetail" id="c4a06a99-1a32-4f2d-8b9a-6a47c62f3700">
        <updating/>
        <source>showThumbnailDataDetail(_obj: Object) updating;
// ---------------------------------------------------------------------------
// Created:     05 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	bolOutLine		: CMIF_BOLOutLine;
	entDef			: EntTableDef;
	entRow			: EntTableRow;
	tmpId			: String;
begin
	if (not CMIF_BOLOutLine.hasInstance(_obj)) then
		return;
	endif;
	
	bolOutLine := _obj.CMIF_BOLOutLine;
	entDef := self.tblDetailEnt.myEntTableDef;
	
	foreach entRow in entDef.allEntTableRows do
		self.tblDetailEnt.setValueByName(entRow.name, bolOutLine.getDisplayStringForAttribute(entRow.name, false));
	endforeach;
	
	
	if self.cmbCargoType.listObject &lt;&gt; bolOutLine.myCargoType then
		self.cmbCargoType.listObject := bolOutLine.myCargoType;
		self.myAssistant.comboBoxProduct(self.cmbProduct, bolOutLine.myCargoType, null, bolOutLine.myProduct);
	endif;
	
	if bolOutLine.myTrackedItem &lt;&gt; null then
		tmpId := bolOutLine.myTrackedItem.id;
	endif;
	
	if self.cmbProduct.listObject &lt;&gt; bolOutLine.myProduct then
		self.cmbProduct.listObject := bolOutLine.myProduct;
		//self.myAssistant.comboBoxTIsByProduct(self.cmbItem, bolOutLine.myProduct, tmpId);
		self.maintainIDCombos(null);
	endif;
	
	
	self.cmbItem.text := tmpId;

end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="c7b03c9e-c82a-4c2c-a4db-a8a21ecc393d">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0005799, locale);
	btnAutoAssign.translateBubbleHelp(Xlat_0001290, locale);
	btnAutoAssign.translateCaption(Xlat_0001292, locale);
	btnCancelDelete.translateCaption(Xlat_0001293, locale);
	btnContinueDel.translateCaption(Xlat_0001294, locale);
	btnDeleteDocket.translateBubbleHelp(Xlat_0001291, locale);
	btnDeleteDocket.translateCaption(Xlat_0001295, locale);
	chkIgnoreWarning.translateCaption(Xlat_0001296, locale);
	chkReceivalTxns.translateCaption(Xlat_0001297, locale);
	chkReceiveCharge.translateCaption(Xlat_0001298, locale);
	chkUnpackCharges.translateCaption(Xlat_0001299, locale);
	chkUnpackTxns.translateCaption(Xlat_0001300, locale);
	lblAreaType.translateCaption(Xlat_0001301, locale);
	lblDeleteBOL.translateCaption(Xlat_0001302, locale);
	lblLocation.translateCaption(Xlat_0001303, locale);
	lblTerminalArea.translateCaption(Xlat_0001304, locale);
	mnuArchiveAllPrevious.translateCaption(Xlat_0005800, locale);
	mnuArchiveSelected.translateCaption(Xlat_0005801, locale);
	mnuEnquireChild.translateCaption(Xlat_0005802, locale);
	mnuEnquireParent.translateCaption(Xlat_0005803, locale);
	mnuInspectObject.translateCaption(Xlat_0005804, locale);
	mnuTblDtlDataContext.translateCaption(Xlat_0005805, locale);
	mnuTblMstDataContext.translateCaption(Xlat_0005806, locale);
	mnuTblMstEntContext.translateCaption(Xlat_0005807, locale);
	mnuUnarchiveAllFuture.translateCaption(Xlat_0005808, locale);
	mnuUnarchiveSelected.translateCaption(Xlat_0005809, locale);
end;</source>
    </JadeMethod>
