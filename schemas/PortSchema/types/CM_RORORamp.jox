    <JadeMethod name="delete" id="c08e630f-926f-499b-b255-ddf63112151c">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	if self.isTransient then
		return;
	endif;
	
	if self.myDeck &lt;&gt; null then
		self.myDeck.causeEvent(EVENT_DECK_ITEM_DELETE,false,self);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="609aa113-09fe-4254-b52e-8aedf4dcee2f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	if _attrName = ETRow_IsMovable then
		return self.isMovable.asStringJMT();
	elseif _attrName = ETRow_Length then
		return self.length.asStringJMT;
	elseif _attrName = ETRow_Width then
		return self.width.asStringJMT;
	elseif _attrName = ETRow_MaxClearHeight  then
		return self.maxClearHeight.asStringJMT();
	elseif _attrName = ETRow_MaxLoadAxel then
		return self.maxLoadAxel.asStringJMT();
	elseif _attrName= ETRow_MaxLoadM2 then
		return self.maxLoadM2.asStringJMT();
	elseif _attrName = ETRow_MaxTotalWeight then
		return self.maxLoadTotal.asStringJMT();
	elseif _attrName = ETRow_TotalWeight then
		return app.getErrorString(NotApplicable);
	else
		return inheritMethod(_attrName, _short);
	endif;
	
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
