	elseif _attrName = ETRow_CargoForecastReqdFields then
		create forecastFields transient;
		self.myIntFaceConfig.cargoForecastReqdFields.getTokensForDelimiter(Comma, forecastFields);
		values := self.myForm.doPopulateCargoForecastTbl(forecastFields);
		_tbl.setValue(_row, values);
	//06.09.2022 navtnr20 54505
	
	// 14.09.2022 navak20 TFS 54628
	elseif _attrName = ETRow_DefaultIMEXStatusForYA then
		theForm.doPopulateIMEXStatus(theConfig.defYAIMEXForNew);
		if theConfig.defYAIMEXForNew &lt;&gt; null then
			_tbl.setValueByName(ETRow_DefaultIMEXStatusForYA, theConfig.defYAIMEXForNew.description);
		endif;
	// 14.09.2022 navak20 TFS 54628	
	elseif _attrName = ETRow_ToDoTaskMAFILashing then //jlier1 TFS 54700 2/9/22
		_tbl.setValue(_row, theConfig.toDoTaskMAFILashingDesc);
		theForm.myAssistant.comboBoxToDoTasks(theForm.cmbToDoTaskLashing, theConfig.toDoTaskMAFILashing);	
	elseif _attrName = ETRow_ReeferJobGrouping then //27Sep2022 navsp1 TFS 54899
		theForm.cmbSortOrder.sorted := false;
		theForm.doCmbSortOrderBuild();
		if theForm.myCurrentObject &lt;&gt; null then
			sortOrder := theForm.myCurrentObject.CM_Terminal.getConfig(ReeferJobGrouping).String;
			allJobs := theForm.myCurrentObject.CM_Terminal.getConfig(AllReeferJobsForTerminal).Boolean;
		endif;
		if sortOrder = null then
			theForm.cmbSortOrder.listIndex := 1;
		else
			theForm.cmbSortOrder.listIndex := theForm.cmbSortOrder.findString(1,sortOrder);
		endif;
		if allJobs then
			theForm.cmbSortOrder.itemEnabled[1] := true;
		else
			theForm.cmbSortOrder.itemEnabled[1] := false;
			if theForm.cmbSortOrder.listIndex = 1 then
				theForm.cmbSortOrder.listIndex := 2;
			endif;
		endif;
		_tbl.setValue(_row,theForm.cmbSortOrder.text);
	elseif _attrName = ETRow_DefTranshipInwardVoyage then
		_tbl.setValue(_row, theConfig.defTranshipInwardVoyageCode);
		
		if self.myIntFaceConfig.defTranshipInwardVoyage = null then
			theForm.myAssistant.comboBoxVoyageObject(theForm.cmbDefTranInVoy, null);
			theForm.cmbDefTranInVoy.text := null;
		else
			theForm.myAssistant.comboBoxVoyageObject(theForm.cmbDefTranInVoy, self.myIntFaceConfig.defTranshipInwardVoyage.code);
		endif;
	elseif _attrName = ETRow_DefTranshipOutwardVoyage then
		_tbl.setValue(_row, theConfig.defTranshipOutwardVoyageCode);
		
		if self.myIntFaceConfig.defTranshipOutwardVoyage = null then
			theForm.myAssistant.comboBoxVoyageObject(theForm.cmbDefTranOutVoy, null);
			theForm.cmbDefTranOutVoy.text := null;
		else
			theForm.myAssistant.comboBoxVoyageObject(theForm.cmbDefTranOutVoy, self.myIntFaceConfig.defTranshipOutwardVoyage.code);
		endif;
	//29/03/2023	navkc1	CR# 56430 TASK 56439
	elseif _attrName = ETRow_StateShortlandZeroQtyWgt then
		theForm.loadCmbStateShortland(theConfig.stateShortlandZeroQtyWgt);
		_tbl.setValueByName(ETRow_StateShortlandZeroQtyWgt, self.getStateShortlandText(theConfig.stateShortlandZeroQtyWgt));
		
	// TFS 63307 hide "Allow Progressive Updates..." option from everyone except us and Euroports
	elseif _attrName = ETRow_AllowProgressiveUpdates then
		_tbl.setValue(_row, theConfig.allowProgressiveUpdates);
		if not app.myRoot.isClientEuroPorts and not app.isInternalEnvironment(false) then
			_tbl.hideRowByName(ETRow_AllowProgressiveUpdates, false);
		endif;
	// TFS 63307 end
	
	elseif _attrName = ETRow_AllowDupVoyageInOutCodes then
		_tbl.setValue(_row, theConfig.allowDupVoyageInOutCodes);
		//if not app.myRoot.canDoEDIFileType(EDIFileType_JSONOnePortVoyage) then		//JIRA-32985
		//	_tbl.hideRowByName(ETRow_AllowDupVoyageInOutCodes, false);					//JIRA-32985 - Enable this config to everyone
		//endif;																		//JIRA-32985
	// MTN-33516 end
	elseif _attrName = ETRow_UseAddRemInOneStop then	//20-Jan-2025 naviv1 #19155	
		_tbl.setValue(_row, theConfig.useAddRemInOneStop);
	elseif _attrName = ETRow_ProcOnSiteForBOLDTR then	//JIRA-19185
		_tbl.setValue(_row, theConfig.procOnSiteForBOLDTR);
	elseif _attrName = ETRow_CusresUNHIsCondition then	//JIRA-33684
		_tbl.setValue(_row, theConfig.cusresUNHIsCondition);
		
	// MTN-35604 start
	elseif _attrName = ETRow_EdiVoyagePartialWarning or _attrName = ETRow_EdiVoyagePartialWarnDays then
		extDef := app.myRoot.getFirstActiveEWSForEndpoint(ETRow_NswVesselMovements);
		if extDef = null then
			_tbl.hideRowByName(ETRow_EdiVoyagePartialWarning, false);
			_tbl.hideRowByName(ETRow_EdiVoyagePartialWarnDays, false);
		else
			_tbl.showRowByName(ETRow_EdiVoyagePartialWarning, false);
			_tbl.showRowByName(ETRow_EdiVoyagePartialWarnDays, false);
		endif;
		
		if _attrName = ETRow_EdiVoyagePartialWarning then
			_tbl.setValueByName(ETRow_EdiVoyagePartialWarning, theConfig.ediVoyagePartialWarning);
		elseif _attrName = ETRow_EdiVoyagePartialWarnDays then
			_tbl.setValueByName(ETRow_EdiVoyagePartialWarnDays, theConfig.ediVoyagePartialWarnDays);
		endif;
	// MTN-35604 end
	
	else
		if _attrName     = ETRow_GrossLoadingTime then
			_tbl.hideRowByName(ETRow_GrossLoadingTime, false);
		elseif _attrName = ETRow_GrossDischargeTime then
			_tbl.hideRowByName(ETRow_GrossDischargeTime, false);
		elseif _attrName = ETRow_NonChargeTime then
			_tbl.hideRowByName(ETRow_NonChargeTime, false);
		elseif _attrName = ETRow_VesselDownTime then
			_tbl.hideRowByName(ETRow_VesselDownTime, false);
		elseif _attrName = ETRow_VesselLoadRate then
			_tbl.hideRowByName(ETRow_VesselLoadRate, false);
		elseif _attrName = ETRow_VesselDischargeRate then
			_tbl.hideRowByName(ETRow_VesselDischargeRate, false);
		elseif _attrName = ETRow_VesselDraftArrival then
			_tbl.hideRowByName(ETRow_VesselDraftArrival, false);
		elseif _attrName = ETRow_VesselDraftDeparture then
			_tbl.hideRowByName(ETRow_VesselDraftDeparture, false);
		//Start 25.01.2023 navdp20 TFS 56236
		elseif _attrName = ETRow_AllowAutoActionToDoWO then
			_tbl.setValue(_row,theConfig.allowAutoActionToDoWO);
			if app.myPassport.isVASEnabled then
				_tbl.showRowByName(ETRow_AllowAutoActionToDoWO,false);
			else
				_tbl.hideRowByName(ETRow_AllowAutoActionToDoWO,false);
			endif;
		//End 25.01.2023 navdp20 TFS 56236
		elseif _attrName = ETRow_CooSplittingOperator then
			_tbl.setValue(_row, theConfig.cooSplitOperator);	//navtnr20 19-07-2023 58234
		//06Mar2023 navsp1 TFS 56275
		elseif _attrName = ETRow_EDIEnforceVeslMatchExprt then
			if not _tbl.getValueByName(ETRow_EDIEnforceVoyageMatch).Boolean then
				_tbl.disableRowByName(ETRow_EDIEnforceVeslMatchExprt);
			else
				_tbl.setValueByName(ETRow_EDIEnforceVeslMatchExprt,theConfig.eDIEnforceVeslMatchExprt);
			endif;
		elseif _attrName = ETRow_IsOverlandedDefaultValue then
			_tbl.setValue(_row, theConfig.isOverlandedDefaultValue);
		elseif _attrName = ETRow_InvoiceAPIOutputMode then		//20.08.2024 navnk30 #65567
			_tbl.setValue(_row, theConfig.invoiceAPIOpModeConfig);
			theForm.myAssistant.comboBoxInvAPIOutputMode(theForm.cmbInvAPIOPMode, null);
		// 29.10.25	Navcs2	MTN-36399 Start
		elseif _attrName = ETRow_BookingAutoRelReqVoyage then			
			str := app.bookingAutoRelEnumToString(theConfig.bookingAutoRelReqVoyage);
			_tbl.setValue(_row, str);
			theForm.myAssistant.comboBoxUpdateAutoRelReqVoy(theForm.cmbBookingRelVoyage, theConfig.bookingAutoRelReqVoyage);
		// 29.10.25	Navcs2	MTN-36399 End
		else
			rtnValue	:=	false;		
		endif;
		if app.myRoot.isDeprecated("8.1.2") then
			_tbl.hideRowByName(ETRow_UseBookingSummView, false);
		endif;
	endif;
	
	return rtnValue;
epilog
	delete forecastFields; 	//06.09.2022 navtnr20 54505
end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setWeightAuthDetails" id="3bc33133-b8f3-4b24-bedd-174999e94150">
        <updating/>
        <source>setWeightAuthDetails() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 04/07/2017	cnwdap1		Initial creation TFS 4492 SNO VERMAS Changes
//
vars
	form : SOP_TableMaintForm;
	defWeighTerm, weighAuthTerm : CM_WeighAuthTerminal;
	weighAuth : CM_WeighAuthority;

begin
	form := self.myForm;
	form.cmbCertName.clear;
	form.cmbAuthName.clear;
	
	// if we're adding a terminal, load the certified combo with all authorities
	if form.mode = form.Mode_Add then
		foreach weighAuth in app.myRoot.allWeighAuthorities discreteLock where not weighAuth.notAvailableForUse do
			form.cmbCertName.addItemObject(weighAuth.certifiedName, weighAuth);
		endforeach;
	else
		defWeighTerm := form.myAssistant.myTerminal.getDefaultWeighAuthority();
		if defWeighTerm &lt;&gt; null then
			form.cmbAuthName.addItemObject(defWeighTerm.myWeighAuthority.authorisedName, defWeighTerm.myWeighAuthority);
		endif;
		foreach weighAuthTerm in form.myAssistant.myTerminal.allWeighAuthTerminals discreteLock do
			if weighAuthTerm.myWeighAuthority.notAvailableForUse then
				continue;
			endif;
			form.cmbCertName.addItemObject(weighAuthTerm.myWeighAuthority.certifiedName, weighAuthTerm.myWeighAuthority);
		endforeach;
		if defWeighTerm &lt;&gt; null then
			form.cmbCertName.listIndex := form.cmbCertName.findObject(defWeighTerm.myWeighAuthority);
			form.cmbAuthName.listIndex := form.cmbAuthName.findObject(defWeighTerm.myWeighAuthority);
		endif;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupContextMenuItems" id="b1458c1f-5f2e-4d85-a1b3-d5670bd961ac">
        <updating/>
        <source>setupContextMenuItems(conwin: Window input) updating;
//25 August 2010	cnwml2
//+cnwml2 PAR23715 SFW CCMS1131

vars
	theForm : SOP_TableMaintForm;
	tmpMenu	: MenuItem;
begin
	inheritMethod(conwin);
	theForm := self.myForm;
	
	//30 Mar 2011  NDL
	if app.isSpecial then
		theForm.mnuContext5.enabled := true;
		theForm.mnuContext5.visible := true;
		theForm.mnuContext5.caption := "Find Config Option";
		tmpMenu := theForm.cloneMenu(theForm.mnuTblVCloneDataTbl, theForm.mnuContext5, false);
	endif;

	if theForm.fldInput.topSheet.name = "shtFolder1" then
		if theForm.fldTab1.topSheet.name = "shtFldSheet2" then
			if theForm.mode = theForm.Mode_Update then
				theForm.mnuAdd.visible := true;
			endif;
		endif;
	endif;
	tmpMenu := theForm.cloneMenu(theForm.mnuTblVCloneDataTbl, theForm.mnuAdd, false); 	

epilog

end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="402563d4-743c-4887-93ea-d6a810c79432">
        <updating/>
        <source>setupThumbnailDetails() updating;
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------
// 21/06/2023	navdap1		TFS 56747 EUP Manifest Load - Internal (Zimmer) - Create
// 01/08/2025   navsp1      JIRA-35530 Solution Implementation - COPRAR Trailer Support
vars
	theForm 	: SOP_TableMaintForm;
	canMaint	: Boolean;
	
begin
	if self.allEntTableDefs.isEmpty then
		app.processGlobalConstantGroup(PortSchemaName, ConfigTypeConstants, SOPTM_Terminal::setAllEntTableDefs.name, self);
	endif;

  	theForm := self.myForm;
	
	if app.myRoot.allowMultiTerminal then
		canMaint := app.getMyUser.canDo(null, self.permissionMaint);
	  	theForm.allowAdd := canMaint;
		// cnwrl1 09/04/2009 PAR 19377
		// Do not show the delete button since you cannot delete any terminal anyway - get error number 75854.
		theForm.allowDelete	:= false;
//		theForm.allowDelete := canMaint;	// cnwrl1 09/04/2009 - what it was
		if canMaint and (not app.myRoot.canDo(PmSite)) then
			theForm.btnLicenseNew.visible := true;
		endif;
	else
	  	theForm.allowAdd := false;
		theForm.allowDelete := false;
	endif;

	theForm.useProxyObject := true;
	
	theForm.setTblDataEntRows(ETDef_TerminalTbl);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_TerminalMaint);
	theForm.shtTblInput1.visible := true;	
	  
	
	theForm.lblName2.autoSize := true;
	theForm.lblName2.caption :='Default Cargo\BoL Type';
	theForm.lblName3.caption := 'Default Cargo Type';
	theForm.lblName4.caption := 'Default BOL Type';
	theForm.lblName5.caption := "Default Cargo Group Type";		// TFS 56747
	theForm.lblName6.caption := "Default Trailer Cargo Type";   //JIRA-35530
    
	theForm.initTblInput(theForm.tblInput2, null);
	
	theForm.fldInput.topSheet := theForm.shtTblInput1;
	theForm.populateFillOptionCombo(theForm.cmbFillOption, null);
epilog   

end;</source>
    </JadeMethod>
    <JadeMethod name="sheetChange" id="d523d6a2-5e89-44c6-a522-858999054678">
        <updating/>
        <source>sheetChange(folder: Folder input) updating;
// ---------------------------------------------------------------------------
// Created:     09 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theSheet	: Sheet;
	entTableDef	: EntTableDef;
	idx			: Integer;
	defName		: String;
	theTable	: CM_EntryTable;
	terminal	: CM_Terminal;
	timezone	: CMIF_TimeZoneInfo;
	combo		: CMUI_ComboBoxTimezone;
		
begin

	theSheet := folder.topSheet;

	if theSheet.name &lt;&gt; self.myForm.shtTblInput2.name then
		return;
	endif;

	idx := theSheet.index;
	if idx &lt;= 0 or idx &gt; self.allEntTableDefs.size then
		return;
	endif;

	theTable := self.myForm.tblInput2;
	theTable.parent := theSheet;	
		
	if self.myForm.myCurrentObject.isKindOf(CM_Terminal) then 
		terminal := self.myForm.myCurrentObject.CM_Terminal;
	endif; 	

	theTable.setTerminologyRelevant(null, terminal);
	
	defName := self.allEntTableDefs[idx];
	entTableDef := app.myController.getEntTableDef(defName);
	//epr tfs 2011 performance work
	if self.myForm.mode &lt;&gt; self.myForm.Mode_View and entTableDef.name = ETDef_TerminalLogSpecific then	
		self.getAllCheckScaleReports();				
	endif;
	
	theTable.setEntTableDef(entTableDef, null, null);
	theTable.setTableFromObject(self.myIntFaceConfig, 'setTableFromObjectSpecial');
	theSheet.cnEcResizeContents();
	
	theTable.optimiseHeadingColumn();
	
	
	//epr tfs 1882
	self.displayCriteriaDesc(CM_TableViewForm.Mode_View);
	
//	if not app.isSpecial then
//		theTable.disableRowByName(ETRow_TimeZoneID);
//		theTable.disableRowByName(ETRow_TimeZoneShortID);
//	endif;
	if terminal &lt;&gt; null then
		if self.myIntFaceConfig &lt;&gt; null then
			theTable.setValueByName(ETRow_TimeZoneShortID, self.myIntFaceConfig.timeZoneShortID);
		endif;
		combo := self.myForm.cmbTerminalTZone;
		foreach timezone in combo.allTimeZones do
			if self.myIntFaceConfig = null and timezone.id = terminal.timeZoneID then
				theTable.setValueByName(ETRow_TimeZoneID, timezone.displayName);
				combo.setObject(timezone);
				break;
			elseif self.myIntFaceConfig &lt;&gt; null and timezone.id = self.myIntFaceConfig.timeZoneID then
				theTable.setValueByName(ETRow_TimeZoneID, timezone.displayName);
				combo.setObject(timezone);
				break;
			endif;
		endforeach;
	endif;
	
end;</source>
        <Parameter name="folder" type="Folder" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showHideRoadGateChkCrit" id="ed18013c-4ab4-4b58-ac7a-9e370c47cab4">
        <source>showHideRoadGateChkCrit();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Oct 2019	jlgndl1	Initial creation	TFS 46911
02 Dec 2019 cnwma1	ChangeRequest 47743: PEN - Field contents not fitting window
24 Feb 2022 navukv20 BUG 52311 MTN - Error 1090 while creating a terminal  
*/

vars

	theForm				  : SOP_TableMaintForm;
	usingRaodGateCriteria : Boolean;
	str 				  : String;
	proxyTerminal		  : CM_Terminal;
	term 				  : CM_Terminal;

begin

	theForm := self.myForm;
	
	term := theForm.myTerminal;
	if term = null then
		proxyTerminal := theForm.myProxyObject.CM_Terminal;
		//if proxyTerminal &lt;&gt; null then
		if proxyTerminal &lt;&gt; null and proxyTerminal.pxyGetRealObject &lt;&gt; null then//29 Oct 2019	NDL	TFS 46911 - Found during Documentation.
		//	term := proxyTerminal;
			term := proxyTerminal.pxyGetRealObject;//29 Oct 2019	NDL	TFS 46911 - Found during Documentation.
		elseif CM_Terminal.hasInstance(theForm.myCurrentObject) then
			term := theForm.myCurrentObject.CM_Terminal;
		endif;
	endif;
	
	//usingRaodGateCriteria := getCargoCheckOption(theForm.cmbCargoCheckOption.text) = 1;	//ETRow_RoadGateCargoCheckOption  25.02.2022 navukv20 #52311 
	if term &lt;&gt; null then	                                                                //25.02.2022 navukv20 #52311 
		usingRaodGateCriteria := getCargoCheckOption(theForm.cmbCargoCheckOption.text) = 1;	//ETRow_RoadGateCargoCheckOption
	endif;					                                                                //25.02.2022 navukv20 #52311 
	
	if usingRaodGateCriteria then
		theForm.tblInput2.showRowByName(ETRow_RoadGateCargoCheckCrit,false);
		if term.myRoadGateCargoCheckCriteria = null              			
		or term.myRoadGateCargoCheckCriteria.allCriteria.isEmpty					
		then
			str := app.getErrorString1( Not_configured, app.getErrorString(Filter_criteria) );
			if theForm.mode &lt;&gt; theForm.Mode_View then
				str := str &amp; ",  " &amp; app.getErrorString( Dbl_Click_To_Add_Update );
			endif;
			
		else
			/* 02.12.2019 cnwma1 #47743
			if theForm.mode &lt;&gt; theForm.Mode_View then
				str := app.getErrorString1( Is_Configured, app.getErrorString(Filter_criteria) );
				str := str &amp; ",  " &amp; app.getErrorString( Dbl_Click_To_Add_Update );
			else
				str := term.myRoadGateCargoCheckCriteria.getTableDisplayString();
			endif;
			*/
			str := app.getErrorString1( Is_Configured, app.getErrorString(Filter_criteria) );  //02.12.2019 cnwma1 #47743
			str := str &amp; ",  " &amp; app.getErrorString( Dbl_Click_To_Add_Update );                //02.12.2019 cnwma1 #47743
		endif; 
		
		theForm.tblInput2.setValueByName(ETRow_RoadGateCargoCheckCrit, str );	
	else
		theForm.tblInput2.hideRowByName(ETRow_RoadGateCargoCheckCrit,false);
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showHideVehicleBooking" id="0c05a1c8-aa5c-4547-82cd-a045e2da5a72">
        <source>showHideVehicleBooking() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2013	cnwndl1	Initial creation	Par 31393
10 Oct 2022 navma1	ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
*/

vars

	theForm : SOP_TableMaintForm;
	proxyTerminal	: CM_Terminal;
	term : CM_Terminal;

begin
	
	theForm := self.myForm;
	
	if not app.isVehicleBookingEnabled then
		theForm.tblInput2.hideRowByName(ETRow_VsUseVehicleScheduling,false);
	else
		theForm.tblInput2.showRowByName(ETRow_VsUseVehicleScheduling,false);
	endif;
	
	proxyTerminal := theForm.myProxyObject.CM_Terminal;
	if proxyTerminal &lt;&gt; null then
		term := proxyTerminal;
	elseif CM_Terminal.hasInstance(theForm.myCurrentObject) then
		term := theForm.myCurrentObject.CM_Terminal;
	endif;
	
	if term &lt;&gt; null and not term.isVehicleBookingEnabled then
		theForm.tblInput2.hideRowByName(ETRow_VsOntimeGracePeriod,false);
		theForm.tblInput2.hideRowByName(ETRow_VsTruckDriverMand,false);
		theForm.tblInput2.hideRowByName(ETRow_VsGenerateDaysInAdvance,false);
		theForm.tblInput2.hideRowByName(ETRow_VsPurgeSlotsOlderThan,false);
		theForm.tblInput2.hideRowByName(ETRow_VsBookMinAdvanceHrs,false);
		theForm.tblInput2.hideRowByName(ETRow_VsBookMinAdvancePu,false);
		theForm.tblInput2.hideRowByName(ETRow_VsBookingRule,false);
		theForm.tblInput2.hideRowByName(ETRow_VsDefaultProcess,false);						//05.10.2022 navma1 #52967
	else
		theForm.tblInput2.showRowByName(ETRow_VsOntimeGracePeriod,false);
		theForm.tblInput2.showRowByName(ETRow_VsTruckDriverMand,false);
		theForm.tblInput2.showRowByName(ETRow_VsGenerateDaysInAdvance,false);
		theForm.tblInput2.showRowByName(ETRow_VsPurgeSlotsOlderThan,false);
		theForm.tblInput2.showRowByName(ETRow_VsBookMinAdvanceHrs,false);
		theForm.tblInput2.showRowByName(ETRow_VsBookMinAdvancePu,false);
		theForm.tblInput2.showRowByName(ETRow_VsBookingRule,false);
		theForm.tblInput2.showRowByName(ETRow_VsDefaultProcess,false);						//05.10.2022 navma1 #52967
	endif; 
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="c89de679-a54c-4b8c-a235-b1c9bc6fa2ed">
        <updating/>
        <source>showThumbnail(pTerminal : CM_Terminal) updating;

// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 31/10/2008	consw1		SFW1030 - Rework of Yard Allocations
// 14/10/2009	cnwcs5		par21044 - replace VTA with yard interchange area
// 11/02/2010	cnwdap1		PAR #22332 Change Warehouse Area type from "General Cargo Area" to "Interchange Area"
// 12/02/2010	cnwmh5		PAR #22353 - set config's default gate entry/exit to null
// 04/07/2017	cnwdap1		TFS 4492 SNO VERMAS Changes
// 12/03/2018	jlgdap1		TFS 37427 PEl1 Voyage Status Enhancements
// 25/09/2018	cnwma1		ChangeRequest 41080: PEL1 - Assigning Operators ID to Cranes/Work-Points
// 05 Nov 2018	jlgrs1		TFS 38414 Remain on Board defaults
// 27/07/2022   navma1		ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
// 22 Feb 2023	jlika1		TFS 56385 - POB - IFCSUM Tranship
// 21 Jun 2023	navdap1		TFS 56747 EUP Manifest Load - Internal (Zimmer) - Create
// 04 Aug 2023	jlika1		TFS 59720 EUP | Default Cargo Group Type on Terminal Config
// 16 Aug 2023  navma1		Bug 58727: ATD - Pack/Unpack gives Error (1201). Kernel stack overflow
// 01 Aug 2025  navsp1      JIRA-35530 Solution Implementation - COPRAR Trailer Support
vars
	theForm		 : SOP_TableMaintForm;
	emlEnt		 : CM_EmailEntity;
	tmpConfig	 : CMIF_ConfigTerminal;
	term 		 : CM_Terminal;
	defImex 	 : Integer;
	imex 		 : CM_IMEXStatus;
	selectedImex : CM_IMEXStatus;
begin
	term := pTerminal; // PAR 33572

	if pTerminal = null then
		return;
	endif;
	
	if self.myIntFaceConfig = null then
		create self.myIntFaceConfig transient;
	endif;
	
	tmpConfig	:=	self.myIntFaceConfig;
  	theForm		:=	self.myForm;
	
	if (not pTerminal.isTransient) then
		// as the proxy terminal does not have the necessary collection.  Rely on
		// what was already there.

		theForm.myAssistant.myTerminal := pTerminal;
		
	endif;
	
	theForm.tblInput1.clearValues;
	theForm.tblInput1.setValueByName(ETRow_Code, pTerminal.code);
	theForm.tblInput1.setValueByName(ETRow_Name, pTerminal.name);
	theForm.mulSelect2.setSelected(pTerminal.allCargoBOLTypes);
	theForm.myAssistant.comboBoxCargoBolType(theForm.cmbCargoBOLType, pTerminal.defaultCargoBolType,   true, true, true,  pTerminal &lt;&gt; null);		//16.08.2023 navma1 #58727
	theForm.myAssistant.comboBoxCargoBolType(theForm.cmbCargoType2,   pTerminal.defaultCargoType,      true, false, true, pTerminal &lt;&gt; null);		//16.08.2023 navma1 #58727
	theForm.myAssistant.comboBoxCargoBolType(theForm.cmbBOLType,      pTerminal.defaultBolType,        false, true, true, pTerminal &lt;&gt; null);		//16.08.2023 navma1 #58727
	//theForm.myAssistant.comboBoxCargoBolType(theForm.cmbCargoGroup, pTerminal.defaultCargoGroupType, true, false, true, false);		// TFS 56747
	theForm.myAssistant.comboBoxCargoGroupType(theForm.cmbCargoGroup, pTerminal.defaultCargoGroupType); // jlika1 59720
	theForm.myAssistant.comboBoxTrailerCargoType(theForm.cmbTrailerCargoType, pTerminal.defaultTrailerCargoType);      //JIRA-35530
    
	tmpConfig.setFromPersistentData(pTerminal);
	// set config's default gate entry/exit to null
	tmpConfig.gateDefaultEntry := null;				// 12/02/2010 cnwmh5 #22353
	tmpConfig.gateDefaultExit := null;				// 12/02/2010 cnwmh5 #22353
	
	tmpConfig.myCalendar      := theForm.myAssistant.myTerminal.getMyHolidayCalendar;
	tmpConfig.myVBSProcess    := theForm.myAssistant.myTerminal.getMyVBSProcess();		//27.07.2022 navma1 #53697
	
	tmpConfig.portLogoPic := pTerminal.getConfig(PortLogoPic).Binary;
	tmpConfig.rtPortLogoPic := pTerminal.getConfig(RtPortLogoPic).Binary;
	//epr TFs 8211 removed old drawing stuff

   	theForm.myAssistant.comboBoxBank(theForm.cmbBank, tmpConfig.defCompany);
   	theForm.myAssistant.comboBoxCommodity(theForm.cmbCommodity, app.myRoot.allCommodities[tmpConfig.defCommodity]);
	theForm.myAssistant.comboBoxCommodity(theForm.cmbMTCommodity, app.myRoot.allCommodities[tmpConfig.emptyCommodity]);	//09 Mar 2012	NDL	Par 28817
	theForm.myAssistant.comboBoxStopCharging(theForm.cmbStopCharging, self.myIntFaceConfig.stopCharging);
   	theForm.myAssistant.comboBoxCommodityReefer(theForm.cmbReeferCmdty, app.myRoot.allCommodities[tmpConfig.defReeferComdty]);
	theForm.myAssistant.comboBoxCommodity(theForm.cmbHazCmdty, app.myRoot.allCommodities[tmpConfig.defHazCommodity]);
	theForm.myAssistant.comboBoxPort(theForm.cmbDischargePort, tmpConfig.defDischargePort, null);
	theForm.myAssistant.comboBoxPort(theForm.cmbLoadPort, tmpConfig.defLoadPort, null);
   	theForm.cmbCommodityGrp.setObject(app.myRoot.allCommodityGroups[tmpConfig.defCommodityGroup]);
   	theForm.cmbDebtor.setObject(tmpConfig.defDebtor);
	theForm.cmbCalendar.setObject(tmpConfig.myCalendar);  // added for VTMIS invoicing HG 2/02/05 

	if tmpConfig.financialIOClass = null then
	  	theForm.myAssistant.comboBoxFinancialIOClass(theForm.cmbFinancialIO, null); // CCMS 1215
 	else
	  	theForm.myAssistant.comboBoxFinancialIOClass(theForm.cmbFinancialIO, tmpConfig.financialIOClass.class); // CCMS 1215
   	endif;
	theForm.myAssistant.comboBoxISOType(theForm.cmbISOType, tmpConfig.defISOType);
	theForm.myAssistant.comboBoxISOType(theForm.cmbReeferISOType, tmpConfig.defReeferISOType);
	theForm.myAssistant.comboBoxISOType(theForm.cmbISOType40, tmpConfig.defISOType40);
	theForm.myAssistant.comboBoxISOType(theForm.cmbReefISOTy40, tmpConfig.defReeferISOType40);
	theForm.myAssistant.comboBoxOperator(theForm.cmbOperator, tmpConfig.defOperator, null);
	
	//26 May 2017	NDL	TFS 4452
	defImex := tmpConfig.defRecTrailIMEX;
	if defImex = 0 then
		defImex := TI_IMEX_STATUS_STORAGE;
	endif;
	selectedImex := app.myRoot.allImexStatuses.getAtKey( defImex );
	theForm.cmbDefTrailImex.clear();
	foreach imex in app.myRoot.allImexStatuses where 										
		imex.code = TI_IMEX_STATUS_STORAGE or
		imex.code = TI_IMEX_STATUS_REMAINONBOARD  do
		theForm.cmbDefTrailImex.addItemObject(imex.description, imex);
	endforeach;
	if selectedImex &lt;&gt; null then
		theForm.cmbDefTrailImex.listIndex := theForm.cmbDefTrailImex.findObject(selectedImex);
	endif;
	
	theForm.myAssistant.comboBoxOperator(theForm.cmbTrailDefOper, tmpConfig.defRecTrailOper, null);	//22 Oct 2020	NDL	TFS 50113
		
   	theForm.myAssistant.comboBoxStevedore(theForm.cmbStevedore, tmpConfig.defStevedore);
	theForm.myAssistant.comboBoxTAType(theForm.cmbTAType, tmpConfig.defTAType, false);
  	theForm.cmbTranshipConsi.setObject(tmpConfig.transhipConsign);
	theForm.myAssistant.comboBoxTurnaroundArea(theForm.cmbTurnaround,tmpConfig.defTurnaroundArea);
	
	// PAR #22332 theForm.myAssistant.comboBoxTerminalArea(theForm.cmbWarehouseArea,TA_TYPE_IRREGULAR_BLOCK_AREA, theForm.myAssistant.myTerminal.allTerminalAreas[tmpConfig.defWarehouseArea]);	// PAR 21304
	theForm.myAssistant.comboBoxTerminalArea(theForm.cmbWarehouseArea,TA_TYPE_YARD_INTERCHANGE, theForm.myAssistant.myTerminal.allTerminalAreas[tmpConfig.defWarehouseArea]);	// PAR 21304	// PAR #22332
	// PAR 20144 - and road ops area to combobox of yard interchange areas
	theForm.myAssistant.comboBoxTerminalArea(theForm.cmbRoadOpsArea,TA_TYPE_YARD_INTERCHANGE, theForm.myAssistant.myTerminal.allTerminalAreas[tmpConfig.defRoadOpsArea]);
	

	theForm.myAssistant.comboBoxDischargeMachineMode(theForm.cmbDefVCQDis); 	// PAR 24877 6/7/10
	theForm.myAssistant.comboBoxDischargeMachineMode(theForm.cmbDefVCQLoad); 	// PAR 24877 6/7/10
	theForm.myAssistant.comboBoxDischargeHHOptions(theForm.cmbDisHHLandOpt);	// PAR 24877 6/7/10
	
	if tmpConfig.defVoyage = null then
		theForm.myAssistant.comboBoxVoyageObject(theForm.cmbVoyage, null);
	else
		theForm.myAssistant.comboBoxVoyageObject(theForm.cmbVoyage, tmpConfig.defVoyage.code);
	endif;
	
	theForm.myAssistant.comboBoxToDoTasks(theForm.cmbToDoTask, tmpConfig.toDoTaskNoInfo);	//28 Jun 2011	NDL	Par 27003
	
	//cnwmc5 - PAR 31238
	theForm.myAssistant.comboBoxCarrierRail(theForm.cmbRailCarrier, app.myRoot.allCarriers[tmpConfig.defRailCarrier]);
	
	theForm.myAssistant.comboBoxRailIdFormat(theForm.cmbRailIdFormat, tmpConfig.railDefaultWCIdFormat);	// 07 Jann 2015	NDL	Par 35346
	
	//cnwmc5 - 18 July 2014 - CCMS 2353 PEN
	theForm.myAssistant.comboBoxTermnialStopsTable(theForm.cmbStopsTable, tmpConfig.ediCustomsStopsTable);
	
	theForm.myAssistant.comboBoxQuerySelectorSet( theForm.cmbGridAreaSel, tmpConfig.gridAreaSelectorSet );	//20 Jul 2011	NDL	Par 27890
	
	theForm.myAssistant.comboBoxWagonClass(theForm.cmbWagonClass, app.myRoot.allWagonClasses[tmpConfig.defWagonClass]);

	
	theForm.myAssistant.comboBoxVoyageProcess(theForm.cmbVoyProcess, app.myRoot.allVoyageProcesses[tmpConfig.defaultVoyageProcess]);	// TFS 37427
	
	theForm.myAssistant.comboBoxSecurityRoleTerminal(theForm.cmbCraneOpSR, tmpConfig.shipCraneOpHrsSecRole); //25.09.2018 cnwma1 TFS #41080
	
	//02 Jun 2021	NDL	TFS 51245	
	theForm.myAssistant.comboBoxEventTypeUser( theForm.cmbRailYardEType, CM_EventType.TRAIN_EVENT, tmpConfig.getMyTerminal );
	if tmpConfig.myLocActRailToYard &lt;&gt; null then
		theForm.cmbRailYardEType.listIndex := theForm.cmbRailYardEType.findObject( tmpConfig.myLocActRailToYard );
	endif;
	
	//18 Jun 2021	NDL	TFS 51245	
	theForm.myAssistant.comboBoxEventTypeUser( theForm.cmbVoyRailEType, CM_EventType.TRAIN_EVENT, tmpConfig.getMyTerminal );
	if tmpConfig.myLocActVesselToRail &lt;&gt; null then
		theForm.cmbVoyRailEType.listIndex := theForm.cmbVoyRailEType.findObject( tmpConfig.myLocActVesselToRail );
	endif;
	
	//18 Jun 2021	NDL	TFS 51245	
	theForm.myAssistant.comboBoxEventTypeUser( theForm.cmbYardRailEType, CM_EventType.TRAIN_EVENT, tmpConfig.getMyTerminal );
	if tmpConfig.myLocActYardToRail &lt;&gt; null then
		theForm.cmbYardRailEType.listIndex := theForm.cmbYardRailEType.findObject( tmpConfig.myLocActYardToRail );
	endif;
	
	//18 Jun 2021	NDL	TFS 51245	
	theForm.myAssistant.comboBoxEventTypeUser( theForm.cmbRailVoyEType, CM_EventType.TRAIN_EVENT, tmpConfig.getMyTerminal );
	if tmpConfig.myLocActRailToVessel &lt;&gt; null then
		theForm.cmbRailVoyEType.listIndex := theForm.cmbRailVoyEType.findObject( tmpConfig.myLocActRailToVessel );
	endif;
	
	
	emlEnt := app.myRoot.allEmailEntities.getAtKeyGeq(Email_Address,tmpConfig.camsEmailAddress);
	
	if emlEnt = null then
		emlEnt := app.myRoot.allEmailEntities.getAtKeyGeq(Email_Group,tmpConfig.camsEmailAddress);
	endif;
	
	// setup local collection of available terminals without the current object
	self.allAvailableTerminals.clear();
	app.myRoot.allTerminals.copy(self.allAvailableTerminals);
	if theForm.myCurrentObject &lt;&gt; null then
		self.allAvailableTerminals.removeIfPresent(theForm.myCurrentObject.CM_Terminal);
	endif;
	
   	theForm.cmbEmailAddress.setObject(emlEnt);
	
	//14 Aug 2018	NDL	TFS 40267
	theForm.cmbRoundHrs.clear();
	theForm.cmbRoundHrs.itemData[ theForm.cmbRoundHrs.addItem("1") ] := 1;
	theForm.cmbRoundHrs.itemData[ theForm.cmbRoundHrs.addItem("2") ] := 2;
	theForm.cmbRoundHrs.itemData[ theForm.cmbRoundHrs.addItem("3") ] := 3;
	theForm.cmbRoundHrs.itemData[ theForm.cmbRoundHrs.addItem("4") ] := 4;
	theForm.cmbRoundHrs.itemData[ theForm.cmbRoundHrs.addItem("6") ] := 6;
	theForm.cmbRoundHrs.itemData[ theForm.cmbRoundHrs.addItem("8") ] := 8;
	theForm.cmbRoundHrs.itemData[ theForm.cmbRoundHrs.addItem("12") ] := 12;
	
	self.myIntFaceConfig.timeZoneShortID := pTerminal.timeZoneShortID;
	self.myIntFaceConfig.timeZoneID      := pTerminal.timeZoneID;
	self.setWeightAuthDetails();											    // TFS 4492

	theForm.myAssistant.comboBoxToDoTasks(theForm.cmbToDoTaskLashing, tmpConfig.toDoTaskMAFILashing);	//2/9/22 TFS 54700 jlier1
	
	if tmpConfig.defTranshipInwardVoyage = null then
		theForm.myAssistant.comboBoxVoyageObject(theForm.cmbDefTranInVoy, null);
	else
		theForm.myAssistant.comboBoxVoyageObject(theForm.cmbDefTranInVoy, tmpConfig.defTranshipInwardVoyage.code);
	endif;
	
	if tmpConfig.defTranshipOutwardVoyage = null then
		theForm.myAssistant.comboBoxVoyageObject(theForm.cmbDefTranOutVoy, null);
	else
		theForm.myAssistant.comboBoxVoyageObject(theForm.cmbDefTranOutVoy, tmpConfig.defTranshipOutwardVoyage.code);
	endif;
	
	theForm.mulSelect2.cnEcResizeContents;
	self.sheetChange(theForm.fldInput);

	self.initShtFld1();			//+cnwml2 PAR23715 SFW CCMS1131
end;</source>
        <Parameter name="pTerminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="skipToAttribute" id="15af69a3-9757-41ed-a44a-e1f2956094f7">
        <updating/>
        <source>skipToAttribute( _attributeName : String; _shtName : String ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
12 July 2012	cnwndl1	Initial creation
10 Oct 2022 	navma1 	ChangeRequest 53697: EUP - VBS MTN - [1] - VBS Slot Types
08 Nov 2023		navlw1	Bug 60951: EUP | 53824 - Transport Manifest - VBS Slot Not Always Being Created
20 Mar 2025 	navlc30 JIRA 34268 - Create a new setting that is to be enabled for this new functionality
*/

vars

	index : Integer;
	control : Control;
	tmpSheet : CMUI_Sheet;
	folder : Folder;
	tbl : CM_EntryTable;
	entRow : EntTableRow;
	row : Integer;
	msg : String;
	controlEntRow : EntTableRow;
	otherName : String;

begin

	foreach index in 1 to self.myForm.controlCount do
		control := self.myForm.controls(index);
		if control.isKindOf( CMUI_Sheet ) then
			tmpSheet := control.CMUI_Sheet;
		else
			continue;
		endif;
		if _shtName &lt;&gt; tmpSheet.caption then
			continue;
		endif;
		folder := tmpSheet.parent.Folder;
		folder.topSheet := tmpSheet;
		self.sheetChange(folder);
		if self.myForm.tblInput2.parent = tmpSheet then
			tbl := self.myForm.tblInput2;
			entRow := tbl.myEntTableDef.getEntTableRowByHeading(_attributeName);
			if entRow &lt;&gt; null then
				row := tbl.myEntTableDef.allEntTableRows.indexOf(entRow);
			endif;
		elseif self.myForm.fldTab1.parent = tmpSheet then
			tbl := self.myForm.tblFldSheet1;
			foreach index in 1 to tbl.rows do
				if tbl.getCellText(index,1) = _attributeName then
					row := index;
					break;
				endif;
			endforeach;
		else
			tbl := null;
		endif;
		
		if tbl = null then
			continue;
		endif;
		
		if row &gt; tbl.fixedRows and row &lt;= tbl.rows then		
			app.doWindowEvents(1);	// seems to be required if the form is new...
			if tbl.accessRow(row).visible then
				tbl.accessRow(row).selected := true;
				tbl.topRow := row;
			else
				//
				if entRow.name = ETRow_VsTruckDriverMand
				or entRow.name = ETRow_VsOntimeGracePeriod
				or entRow.name = ETRow_VsGenerateDaysInAdvance
				or entRow.name = ETRow_VsPurgeSlotsOlderThan
				or entRow.name = ETRow_VsBookMinAdvanceHrs
				or entRow.name = ETRow_VsBookMinAdvancePu
				or entRow.name = ETRow_VsBookingRule
				or entRow.name = ETRow_VsDefaultProcess					//05.10.2022 navma1 #52967
				or entRow.name = ETRow_AllowVBSInPast					// #60951
				or entRow.name = ETRow_VsEnhancedStdVBS					//20.03.2025 navlc30 #34268
				then
					if not self.myForm.myCurrentObject.CM_Terminal.isVehicleBookingEnabled then
						controlEntRow := tbl.myEntTableDef.getEntTableRow(ETRow_VsUseVehicleScheduling);
						if controlEntRow &lt;&gt; null then
							otherName := controlEntRow.getHeading(null, null, app.myCurrentLocale);
							row := tbl.myEntTableDef.allEntTableRows.indexOf(controlEntRow);
							if tbl.accessRow(row).visible then
								tbl.accessRow(row).selected := true;
								tbl.topRow := row;
							endif;
						else
							otherName := ETRow_VsUseVehicleScheduling;
						endif;
						msg := app.getErrorString2(Not_visible_unless_enabled, entRow.getHeading(null, null, app.myCurrentLocale), otherName );
						app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Only );
					endif;
				endif;
			endif;
		endif;
		if row &gt; tbl.fixedRows and row &lt;= tbl.rows then
			self.selectedConfigRow := tbl.topRow; // TFS 52235 2NOV2021 NAVLW1
		endif;
		return;
	endforeach;

epilog

end;</source>
        <Parameter name="_attributeName" type="String"/>
        <Parameter name="_shtName" type="String"/>
    </JadeMethod>
</Class>
