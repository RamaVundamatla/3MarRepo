    <JadeMethod name="tblAlerts_contextMenu" id="26a1dd30-37e0-4447-bf11-c2a5af638358">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblAlerts_contextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

vars
	alert : CM_SystemAlert;
begin

	self.mnuRemoteData.enabled := self.btnEditRemote.enabled;
	self.mnuOrganiser.userObject:=cntrl;
	self.mnuInspect.userObject:=null;
	self.mnuInspect.visible:=app.isAllowedToInspect();
	if self.mnuInspect.visible then
		alert := cntrl.accessRow(cntrl.row).itemObject.CM_SystemAlert;
		self.mnuInspect.userObject:=alert;
	endif;
	
	return self.showContextMenu(mnuSA, cntrl, conwin, mouse, x, y);

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
