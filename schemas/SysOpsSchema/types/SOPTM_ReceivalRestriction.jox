    <JadeMethod name="create" id="fb466535-61b2-4845-b952-0e6132ec10e5">
        <updating/>
        <source>create() updating;

/*
Date		Who		Reason
20 May 2009	cnwar2	Initial creation

*/
vars

begin
	self.name := SOP_TableMaintForm.Table_ReceivalCutoff;
	self.permissionView	 := PmAdmRecRestrictView;
	self.permissionMaint := PmAdmRecRestrictMaint;
