    <JadeMethod name="bmkStdRunFini" id="13a2a119-6c53-431a-8bd5-7576abcd0b10">
        <updating/>
        <source>bmkStdRunFini() updating;

begin

epilog
	endNotificationForSubscriber(myBmkStdRun);
	delete myBmkStdRun;
	app.logMessage(null);
end;
</source>
