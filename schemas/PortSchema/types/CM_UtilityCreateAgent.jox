    <JadeMethod name="utlCreateFPDateTime" id="fac87e74-aedb-4f11-a8f5-8759955bd4d1">
        <source>utlCreateFPDateTime(_proxyFinancialPeriodDateTime:CM_FinancialPeriodDateTime; _newFinancialPeriodDateTime:CM_FinancialPeriodDateTime output; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	cancelSave : Boolean;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valFPDateTime(_proxyFinancialPeriodDateTime);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	app.setContinueCMExceptions(false);

	create _newFinancialPeriodDateTime persistent;
	_newFinancialPeriodDateTime.setForCreate(_proxyFinancialPeriodDateTime);
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_newFinancialPeriodDateTime);
//		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_FINPERIOD_CREATE),false,_newFinancialPeriodDateTime);
		app.myRoot.causeEvent(EVENT_FINPERIOD_CREATE,false,_newFinancialPeriodDateTime);
	endif;

end;</source>
        <Parameter name="_proxyFinancialPeriodDateTime" type="CM_FinancialPeriodDateTime"/>
        <Parameter name="_newFinancialPeriodDateTime" type="CM_FinancialPeriodDateTime" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateFPDateTimeBulk" id="d1f6fd7f-0a08-4b51-a729-442880809992">
        <source>utlCreateFPDateTimeBulk(_financialPeriodEnd:CM_FinancialPeriodEnd input; _allProxyDates : CM_FinancialPeriodDateTimeDict);
/*
Purpose:			
Date				Who			Reason
FEBRUARY 2015		CNWAB1		Initial creation
*/
vars
	cancelSave : Boolean;
	pxyDate, actualDate : CM_FinancialPeriodDateTime;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	
	foreach pxyDate in _allProxyDates discreteLock do
		app.myValCA.valFPDateTime(pxyDate);
		if not self.checkValidationWithPassport(app.myPassport) then
			app.setContinueCMExceptions(false);
			return;
		endif;
	
	
	endforeach;
 	app.setContinueCMExceptions(false);

	foreach pxyDate in _allProxyDates discreteLock do
		create actualDate persistent;
		actualDate.setForCreate(pxyDate);
		
		if app.myPassport.noErrors then
			self.myCreateAuditAgent.audCreateGeneric(actualDate);
			app.myRoot.causeEvent(EVENT_FINPERIOD_CREATE,false,actualDate);
		endif;
	endforeach;
	

end;</source>
        <Parameter name="_financialPeriodEnd" type="CM_FinancialPeriodEnd" usage="input"/>
        <Parameter name="_allProxyDates" type="CM_FinancialPeriodDateTimeDict"/>
    </JadeMethod>
