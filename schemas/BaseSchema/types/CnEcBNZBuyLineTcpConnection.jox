    <DbClassMap file="basemap"/>
    <JadeMethod name="cnEcDoWaitLoop" id="b78d05ed-2bda-4483-ae1c-30caaa9dc43b">
        <source>cnEcDoWaitLoop(pTimeoutPeriod:Integer) protected;
// --------------------------------------------------------------------------------
//	Buyline version, as ETX character as last character in message.
// re-implementation specifically for BuyLine.
// because BuyLine messages use a non-std end of message indicator, the auto
// advise by exception of buffer receipt is not invoked, thus we would always
// wait the entire timeout period. 
// --------------------------------------------------------------------------------
constants
	Trailer		= #03.Character;	//etx char (0x03)
vars
	secondsSinceLast	: Integer;
	startTime			: Integer;

begin
	startTime	:=	app.clock();

	while (self.state = Connection.Connected) do
	
		if self.cnEcReceiveBuffer.String.pos(Trailer,1) &gt; 0 then
			//write "Trailer detect break via pos";
			break;
		endif;
		
		process.sleep(1000);

		// If the connection has been closed by the remote device, then the following
		// "doWindowsEvents" call will result in an exception that should be handled
		// by the caller of this method (such an exception should indicate that all
		// of the read buffer has been received from the remote device).
		app.doWindowEvents(0);

		secondsSinceLast	:=	(app.clock() - self.cnEcLastReceiveTime) div 1000;

		if secondsSinceLast &gt; pTimeoutPeriod then
			// We've timed out, so we'll assume that all of the read buffer has been received.
			//write "Timed out";
			break;
		endif;
	endwhile;
epilog
	cnEcMonitor(process.userCode &amp; " - " &amp; self.class().name &amp; ": Read buffer done after " &amp; ((app.clock() - startTime) div 1000).String &amp; " seconds.");
end;</source>
        <access>protected</access>
        <Parameter name="pTimeoutPeriod" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcDoWebGetRequest" id="e1edec13-a0e0-4cb0-9007-a0ddf90b9222">
        <updating/>
        <source>cnEcDoWebGetRequest(pServer: String; pFilePath: String; pMessage: String; pTimeout: Integer; pResponse: String io): Boolean updating;

// re-implementation specifically for BuyLine.
// because BuyLine messages use a non-std end of message indicator, the auto
// advise by exception of buffer receipt is not invoked, thus we would always
// wait the entire timeout period. 


vars
	messageToSend		: String;
	errorPrefix			: String;
	bLength				: Integer;

begin
	on ConnectionException do self.cnEcExHandlerWebRequest(exception);

	self.cnEcErrorMessage	:=	null;
	self.cnEcReceiveBuffer	:=	null;
	errorPrefix				:=	self.class().name &amp; "::" &amp; method.name &amp; ":";
	
	if pTimeout &lt; 1 then
		cnEcMonitor(errorPrefix &amp; " Invalid timeout period - must be greater than zero.");
		return false;
	endif;
	
	self.fillReadBuffer	:=	false;

	if self.cnEcDoOpenConnection(pServer, self.cnEcGetServerPort(), self.fillReadBuffer) then
		messageToSend	:=	pFilePath &amp; pMessage;
		
		if self.sendClearText(messageToSend) then
			
			if self.cnEcDoReadAsynchBuffer(100, self, "cnEcDoReadCallBack") then
			
				if self.cnEcDoWaitForReceiveBuffer(pTimeout) then
					pResponse	:=	self.cnEcReceiveBuffer.String;
					//write pResponse;
				else
					cnEcMonitor(errorPrefix &amp; "false - returned by self.cnEcDoWaitForReceiveBuffer");
					return false;
				endif;  
			else
				cnEcMonitor(errorPrefix &amp; "false - returned by self.cnEcDoReadAsynchBuffer");
				return false;
			endif;
		else
			cnEcMonitor(errorPrefix &amp; "false - returned by self.sendClearText");
			return false;
		endif;
	else
		cnEcMonitor(errorPrefix &amp; "false - returned by self.cnEcDoOpenConnection");
		return false;
	endif;

	return true;
epilog
	self.close();
end;</source>
        <Parameter name="pServer" type="String"/>
        <Parameter name="pFilePath" type="String"/>
        <Parameter name="pMessage" type="String"/>
        <Parameter name="pTimeout" type="Integer"/>
        <Parameter name="pResponse" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetBufferLength" id="e62bc165-39ec-452d-8fd4-2e82bf152364">
        <source>cnEcGetBufferLength(): Integer protected;
// --------------------------------------------------------------------------------
// Created:		16 May 2001 by cnwdad1
//
// Purpose:		Reimplementation of superclass method.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.cnEcReceiveBuffer &lt;&gt; null then
		return self.cnEcReceiveBuffer[2:3].Integer - 4;
	else
		return 4;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="cnEcGetServerPort" id="51d7ebc2-cd62-435a-a75b-cf33e454d324">
        <source>cnEcGetServerPort(): Integer protected;

// BuyLine always uses port 1997.

vars

begin
	return 1997;
end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="sendClearText" id="01cf2c29-34d9-42ae-a8a8-57ae93078674">
        <updating/>
        <source>sendClearText(pMessage:String io):Boolean updating, protected;
//
// Pretty much a copy of ::cnEcDoWebWriteBuffer but without
// the addition of the LF characters etc.
//
vars
	hasSucceeded	: Boolean;
	writeBuffer		: Binary;

begin
	hasSucceeded	:=	false;

	if app.isUnicode() then								// cnwdad1 04/09/2000.
// cnwdad1 14/11/2001 - Put back CardSchema's cnUnicodeToAnsi which is now included in the current CardSchema release.
//		writeBuffer	:=	pMessage.cnEcUnicodeToAnsi;		// cnwdad1 29/01/2001.		// cnwdad1 14/11/2001.
		writeBuffer	:=	pMessage.cnUnicodeToAnsi();		// cnwdad1 29/01/2001.		// cnwdad1 14/11/2001
	else												// cnwdad1 04/09/2000.
		writeBuffer	:=	pMessage.Binary;
	endif;
													// cnwdad1 04/09/2000.	
	self.writeBinary(writeBuffer);

	hasSucceeded	:=	true;
epilog
	return hasSucceeded;
end;</source>
        <access>protected</access>
        <Parameter name="pMessage" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
