/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2016	cnwkpd1	TFS 488 - Multi Timezone Support

*/

vars

begin
	on Exception do self.handleException(exception) global;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="log" id="29abcb25-8dcb-46f2-b725-4a0284c05cee">
        <source>log(_msg : String);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 April 2016	cnwkpd1	TFS 488 - Multi Timezone Support
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	message 		: String;
	
begin
	message := app.actualTimeServer.String &amp; " " &amp; _msg;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	write message;
	
	lbxMsgs.addItemAt(message, 1);
	
	
epilog

end;</source>
        <Parameter name="_msg" type="String"/>
    </JadeMethod>
    <JadeMethod name="openEvent" id="ddfd7b96-cbcb-412d-bf6f-933e7b94f7a4">
        <source>openEvent(_conn : Connection);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 April 2016	cnwkpd1	TFS 488 - Multi Timezone Support

*/

vars

begin
	log(method.name &amp; " " &amp; _conn.String &amp; " state=" &amp; _conn.state.String);
	mySerialPort.readUntilAsynch(Cr.Binary, 1000, self, MainForm::readEvent.name);
epilog

end;</source>
        <Parameter name="_conn" type="Connection"/>
    </JadeMethod>
    <JadeMethod name="readEvent" id="c9aa7541-a187-494f-b522-1c85afa371b7">
        <source>readEvent(_conn : Connection; _data : Binary);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 April 2016	cnwkpd1	TFS 488 - Multi Timezone Support

*/

vars

begin
	log(method.name &amp; " " &amp; _conn.String &amp; " state=" &amp; _conn.state.String &amp; " pendingClose=" &amp; pendingClose.String &amp; " |" &amp; _data.ansiToString() &amp; "|");
	
	if pendingClose then
		stopListening();
	else
		mySerialPort.readUntilAsynch(Cr.Binary, 1000, self, MainForm::readEvent.name);
	endif;

epilog

end;</source>
        <Parameter name="_conn" type="Connection"/>
        <Parameter name="_data" type="Binary"/>
    </JadeMethod>
    <JadeMethod name="startListening" id="1dc16f5a-179c-4162-b719-c8b6bbb779b2">
        <source>startListening();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 April 2016	cnwkpd1	TFS 488 - Multi Timezone Support

*/

vars

begin
	if mySerialPort &lt;&gt; null then
		log(method.name &amp; " calling openAsynch");
		mySerialPort.openAsynch(self, MainForm::openEvent.name);
	else
		log(method.name &amp; " Error - mySerialPort is null");
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="stopListening" id="8ec04726-4f97-46e5-8d87-a4a03516334c">
        <source>stopListening();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 April 2016	cnwkpd1	TFS 488 - Multi Timezone Support

*/

vars

begin
	if mySerialPort &lt;&gt; null then
		log(method.name &amp; " calling closeAsynch for " &amp; mySerialPort.String);
		mySerialPort.closeAsynch(self, MainForm::closeEvent.name);
	else
		log(method.name &amp; " Error - mySerialPort is null");
	endif;
	
epilog

end;</source>
    </JadeMethod>
