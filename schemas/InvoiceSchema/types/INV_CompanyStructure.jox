    <JadeMethod name="setDebtorRootDeaultCombo" id="96b57cc6-cfdd-42d3-b792-ca8bc9d6de33">
        <source>setDebtorRootDeaultCombo();
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	index:     Integer;
	theCMB : CMUI_ComboBox;
begin
	theCMB := cmbDebtorInvProp;
	
	// 08/05/2013 cnwmh5 #31522 - Change to use myCurrentBU if not null or updateMode = update
	if self.updateMode = self.UpdateMode_New or self.myCurrentBU = null then
		index := theCMB.findObject(app.myRoot.myRootCompany.rootDebtor);
	else
		index := theCMB.findObject(self.myCurrentBU);
	endif;
	
	if index &gt; 0 then
		theCMB.listIndex := index;
	endif;



end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="2a6221d7-3c18-4d00-b711-b146b73ff103">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 30/12/2022	navkc1	TFS CR 55300 TASK 55525 - Business Unit Maint changes  for auto id
// ---------------------------------------------------------------------------

vars

begin
	self.frmProperties.height := PROPHEIGHT;
	inheritMethod();
	self.initPropertyTable(ETDef_InvMaintComp);
	
	self.lstData.defaultLineHeight := 30; // ### TFS 50421 27OCT2021 NAVAB1
	self.lstData.fontSize := 10; // ### TFS 50421 27OCT2021 NAVAB1

	self.setNavigatorHeading(self.caption);
	
	self.loadCompanies();
	self.loadDebtors();
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_COMPANY_CREATE), Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_COMPANY_DELETE), Response_Continuous, null);
	self.beginNotification(self.myTerminal, self.myTerminal.getTerminalEvent(EVENT_COMPANY_UPDATE), Response_Continuous, null);

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnDelete.enabled := false;
		self.btnNew.enabled := false;
		self.btnNewCompany.enabled := false;
		self.btnUpdate.enabled := false;
		self.btnSusp.enabled := false;
		self.btnAutoId.enabled := false; // 30/12/2022	navkc1	TFS CR 55300 TASK 55525
		
		self.mnuCSBU.enabled := false;
		self.mnuCSDelete.enabled := false;
		self.mnuCSComp.enabled := false;
		self.mnuCSUpdate.enabled := false;
		self.mnuCSSuspend.enabled := false;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="showPropertyFrame" id="d2448fb4-95e9-42a6-bfa1-0576050ae9fb">
        <updating/>
        <source>showPropertyFrame(_entTableView: String; _mode: Integer; _actualHeight: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
	cell : JadeTableCell;
	actualHeight: Integer;
	theTable : CM_EntryTable;
	propertiesForm : INV_BusinessUnitMaint; // TFS 39618
begin
	theTable := self.tblProperties;
	
	if self.modePropertyUpdate = self.MODEPROPERTY_BU then
			create propertiesForm transient; // TFS 39618
			propertiesForm.myCurrentBank := self.myCurrentBU;
			propertiesForm.myCurrentCompany := self.myCurrentCompany;
			propertiesForm.myParentForm := self; // TFS 39618
			propertiesForm.myTerminal := self.myTerminal;
			propertiesForm.centreWindow();
			propertiesForm.mode := INV_BusinessUnitMaint.MODE_UPDATE;
			propertiesForm.showModal(); // TFS 39618	
	elseif self.modePropertyNew = self.MODEPROPERTY_BU then
			create propertiesForm transient; // TFS 39618
			propertiesForm.myCurrentCompany := self.myCurrentCompany;
			propertiesForm.myCurrentBank := null;
			propertiesForm.myParentForm := self; // TFS 39618
			propertiesForm.myTerminal := self.myTerminal;
			propertiesForm.centreWindow();
			propertiesForm.mode := INV_BusinessUnitMaint.MODE_NEW;
			propertiesForm.showModal(); // TFS 39618	
	endif;

	if self.modePropertyNew = self.MODEPROPERTY_COMPANY 
	or self.modePropertyUpdate = self.MODEPROPERTY_COMPANY then
		actualHeight := 150;
	else
		actualHeight := _actualHeight;
	endif;
	if self.modePropertyNew = self.MODEPROPERTY_COMPANY then
		inheritMethod(_entTableView, _mode, actualHeight);
	endif;
	
	if self.modePropertyNew = self.MODEPROPERTY_BU then
		self.setDebtorRootDeaultCombo();
		self.cmbDebtorInvProp.lostFocus(self.cmbDebtorInvProp);
	elseif self.modePropertyNew = self.MODEPROPERTY_COMPANY then
		theTable.accessColumn(1).width := 240;
		theTable.accessColumn(2).width := (theTable.width - 240).Integer;
	endif;

	// TFS 2062 for a new company these 3 rows were aligned in the middle of the text box but when displayed with data were aligned at top/left (from table setValue)
	//   so align them top/left here for consistency
	idx := theTable.getRowByName(ETRow_BankDetails);
	theTable.accessRow(idx).height := 50;
	cell := theTable.accessCell(idx, 2);
	cell.alignment := Table.Alignment_Left_Top;
	idx := theTable.getRowByName(ETRow_Address);
	theTable.accessRow(idx).height := 100;
	cell := theTable.accessCell(idx, 2);
	cell.alignment := Table.Alignment_Left_Top;
	idx := theTable.getRowByName(ETRow_RemAddress);
	theTable.accessRow(idx).height := 100; // CCMS 1587
	cell := theTable.accessCell(idx, 2);
	cell.alignment := Table.Alignment_Left_Top;

	if self.myCurrentCompany &lt;&gt; null then
		theTable.setValueByName(ETRow_Parent, self.myCurrentCompany.mailingName);
	endif;
	theTable.disableRowByName(ETRow_Parent);
	if self.modePropertyNew = self.MODEPROPERTY_COMPANY then
		self.lstData.enabled := false;
		self.frmToolbar.enabled := false;
	endif;
end;</source>
        <Parameter name="_entTableView" type="String"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_actualHeight" type="Integer"/>
    </JadeMethod>
