    <JadeMethod name="setMyGeneratorTypeDefault" id="f517de88-2cf2-41d8-8cce-885e36dc9047">
        <updating/>
        <source>setMyGeneratorTypeDefault(_passport : CM_Passport input) updating;
/* ---------------------------------------------------------------------------
Created:	28 September 2009	by cnwvu1

Purpose:	PAR 20478 - TEKLOGIX: receiving a generator via rail line
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	gen			: CM_Generator;
	pxyGenType,
	genType		: CM_GeneratorType;

begin

	genType := app.myRoot.allGeneratorTypes[GeneratorTypeCodeDefault];

	if genType = null then
		create pxyGenType transient;
		pxyGenType.setProxy( GeneratorTypeCodeDefault, "Standalone", GeneratorType_StandAlone, 0 );
		app.myTrxCA.trxCreateGeneratorType( pxyGenType, genType, _passport );
		if _passport.hasErrors() then
			app.raiseUnexpectedProgramError(class.name, method.name, "passport error - Standalone generator type not created &gt;&gt;" &amp; _passport.getErrorsAsString());
			return;
		endif;
	endif;

	self.setMyGeneratorType(genType);
	
epilog
	if pxyGenType &lt;&gt; null then
		delete pxyGenType;
	endif;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
