    <JadeMethod name="setForCreate" id="92106096-96a7-4312-b62b-ca0bc67c1acf">
        <updating/>
        <source>setForCreate(_pxyWorkTask: CM_WorkTask; _passport: CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 19/01/2018	jlgdap1		Initial creation TFS 36658 STWR Cargo Scanning Enhancements
//
vars
	notifiedGroup : CM_NotifiedCargoGroup;

begin
	inheritMethod(_pxyWorkTask, _passport);
	
	self.ediLoadedTS := app.actualTimeAppServer;	//05 Jul 2018	NDL	TFS 39186
	
	if app.isJMTUnitTest then
		foreach notifiedGroup in self.allNotifiedCargoGroupByIdDict do
			notifiedGroup.createCargoGroup(notifiedGroup.id, _passport);
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_pxyWorkTask" type="CM_WorkTask"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="16422a05-3cd8-45e3-88b6-28f605a416e5">
        <updating/>
        <source>setForUpdate(	_pxyCgAssign : CM_CargoGroupAssignment;
				_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 July 2015	cnwndl1	Initial creation	Par 36608

*/

vars

	pxyNotifiedCargo : CM_NotifiedCargoGroup;
	notifiedCargo : CM_NotifiedCargoGroup;
	pxyCargoGroup : CM_TrackedItem;	//CM_CargoGroup;
	cargoGroup : CM_CargoGroup;
	pxyCargoId : String;
	count : Integer;

begin

	inheritMethod( _pxyCgAssign, _passport );
	
	self.ediLoadedTS := _pxyCgAssign.ediLoadedTS;	//05 Jul 2018	NDL	TFS 39186

	self.allCargoIds.clear();
	self.allCargoIdsDict.purge();
	
	foreach pxyCargoId in _pxyCgAssign.allCargoIds do
		allCargoIdsDict.putAtKey(pxyCargoId, self); // the object doesn't matter.
	endforeach;
	
	if app.isJMTUnitTest then
		self.allNotifiedCargoGroupByIdDict.purge();
		
		foreach pxyNotifiedCargo in _pxyCgAssign.allNotifiedCargoGroupByIdDict do
			pxyNotifiedCargo.setMyCargoGroupAssignment( null );
			create notifiedCargo persistent;
			notifiedCargo.setForCreate( pxyNotifiedCargo, _passport );
			notifiedCargo.setMyCargoGroupAssignment( self );
			pxyNotifiedCargo.setMyCargoGroupAssignment( _pxyCgAssign );
			count := count + notifiedCargo.allPreAssignedCargoIdsDict.size;
		endforeach; 
	endif;
	
	foreach pxyCargoGroup in _pxyCgAssign.allCargoGroupsByIdDict do
		cargoGroup:= self.createUpdateCargoGroupReal( pxyCargoGroup.CM_CargoGroup );
		count := count + cargoGroup.allPreAssignedCargoIdsDict.size;
	endforeach;
	
	count := count + allCargoIdsDict.size;
	
	self.totalTIcount := count;

epilog

end;</source>
        <Parameter name="_pxyCgAssign" type="CM_CargoGroupAssignment"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
