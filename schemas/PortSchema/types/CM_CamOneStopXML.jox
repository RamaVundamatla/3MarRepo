    <JadeMethod name="makeDeclarantSubSectXML" id="ebfac0a1-360d-4503-a82d-e0f2b2d6e3bc">
        <source>makeDeclarantSubSectXML( _ti: CM_TrackedItem; _parentElem : JadeXMLElement input ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/08/2016	cnwndl1	Initial creation	TFS 2561 / 2277
19/07/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
*/

vars

	rootElem : JadeXMLElement;
	xmlElem : JadeXMLElement;

begin

	rootElem := _parentElem.addElement('Declarant');
	
	if _ti = null then
		return;
	endif;
	
	xmlElem := rootElem.addElement('NameOfDeclarant');
	xmlElem.setText( _ti.weightCertifiedName );
	
	xmlElem := rootElem.addElement('CompanyOfDeclarant');
	xmlElem.setText( _ti.weightCertifiedReference );
	
	if _ti.isKindOf(CM_Container) and _ti.CM_Container.myVGMDetails &lt;&gt; null then	// TFS 4492
		xmlElem := rootElem.addElement('DeclarantPhone');							// TFS 4492
		xmlElem.setText( _ti.CM_Container.myVGMDetails.vgmTelephone );				// TFS 4492
																					// TFS 4492
		xmlElem := rootElem.addElement('DeclarantEmail');							// TFS 4492
		xmlElem.setText( _ti.CM_Container.myVGMDetails.vgmElectronicMail );			// TFS 4492
	endif;																			// TFS 4492
	
epilog

end;</source>
