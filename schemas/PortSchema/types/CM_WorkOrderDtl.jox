    <JadeMethod name="getToDoTaskDescStr" id="58109d90-7047-4c3c-9676-53b181ad726d">
        <source>getToDoTaskDescStr() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/11/2024	navkc1 JIRA Story MTN-19092: EUP | 54014 - Work Orders Enhancements - Improved Search and usability

*/

vars
	str				: String;
	todoTaskDesc	: CM_ToDoTaskDesc;
	todoTaskDescs	: CM_ToDoTaskDescSet;
begin
	
	todoTaskDescs := self.getTodoTaskDescObj();
	
	if todoTaskDescs = null then
		return null;
	endif;
	
	foreach todoTaskDesc in todoTaskDescs do
		if todoTaskDesc.code = null then
			continue;
		endif;
		
		/*
		if str = null then
			str := todoTaskDesc.description;
		else
			if str.pos(todoTaskDesc.description, 1) &gt; null then
				continue;
			else
				str &amp;= Comma &amp; todoTaskDesc.description;
			endif;
		endif;
		*/
		
		str.addStringToList(todoTaskDesc.description, Comma); //04/04/2025	navkc1 JIRA Story MTN-33940
	endforeach;
	
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
