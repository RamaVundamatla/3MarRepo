    <JadeMethod name="getLoadOutErrors" id="3c836a92-6af6-42fe-ac06-c2c906c787fd">
        <source>getLoadOutErrors(_ignoreAssignedLocnCheck, _ignoreBolProductCheck : Boolean) : Boolean;
//--------------------------------------------------------------
//Created: 17 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	bolOutExt : CM_BOLExtLogOut;
	logLocn : CM_LogController;
	logVoy : CM_Voyage;
	bolProductCode : String;
	planLocn, 
	currentLocn : CM_LocationsController;	
	rtnCode		: Boolean;
	
begin

	rtnCode := true;

	bolOutExt 		:= self.myReleaseBOL.myExtension.CM_BOLExtLogOut;
	bolProductCode 	:= bolOutExt.getProductCode;
	planLocn 		:= self.getPrimaryLocation(PLANNING_MODE);
	currentLocn 	:= self.getPrimaryLocation(REAL_MODE);
	
//	if bolOutExt.myVoyage.isKindOf(CM_LogVoyage) then
	if bolOutExt.myVoyage &lt;&gt; null and bolOutExt.myVoyage.myLogVoyageStructure &lt;&gt; null then
		logVoy := bolOutExt.myVoyage;
	endif;

	if logVoy &lt;&gt; null then
		if logVoy.allOnshipTIsByIdCargoType.includesKey(self.id, self.cargoType) then
			rtnCode := false;
			bolOutExt.addLogLoadError(self.id, self, app.getErrorString1(Log_ID_already_on_vessel, null) , ERR_TI_ONSHIP);						
		endif;
	endif;
	
	if logVoy = null then	// PAR 22136 Jan 2010
		rtnCode := false;
	//	bolOutExt.addLogLoadError(self.id, self, 'Voyage not found', REQUIRED_FIELD);						
		bolOutExt.addLogLoadError(self.id, self, 'Voyage not found', Input_required_field_Required); 

	endif;
	
	if self.site &lt;&gt; TI_SITE_ONSITE then
		rtnCode := false;

		if self.site = TI_SITE_ONSHIP then
			if self.myVoyage &lt;&gt; null then
				// Don't set the myLog reference for this error
				bolOutExt.addLogLoadError(self.id, null,
				 						  'Already loaded onto vessel ' &amp; self.myVoyage.vesselName,
										  ERR_TI_ONSHIP);			
			else
				// Don't set the myLog reference for this error			
				bolOutExt.addLogLoadError(self.id, null, 'On another vessel.', ERR_TI_ONSHIP);
			endif;
		else
			// Don't set the myLog reference for this error		
			bolOutExt.addLogLoadError(self.id, null, 'Not on site.', ERR_TI_NOT_ONSITE);
		endif;
	endif;

	if currentLocn &lt;&gt; null then
		if currentLocn.isKindOf(CM_LogController) then	
			logLocn := currentLocn.CM_LogController;
		endif;
	endif;
	
	if (not _ignoreAssignedLocnCheck) and logLocn &lt;&gt; null and logVoy &lt;&gt; null then
		if (not logVoy.myLogVoyageStructure.isLocationLoadedAssigned(logLocn)) then
			rtnCode := false;
			bolOutExt.addLogLoadError(self.id, self, 'Row ' &amp; logLocn.id &amp; ' not assigned to voyage', LogRowNotAssignedToVoyage);
		endif;
	endif;

	if self.isUnscaled then
		rtnCode := false;
		bolOutExt.addLogLoadError(self.id, self, 'Unscaled', LogUnscaled);
	endif;
	
	if (not _ignoreBolProductCheck) and self.myProduct.code &lt;&gt; bolProductCode then
		rtnCode := false;
		bolOutExt.addLogLoadError(self.id, self, 'Specs do not match that of load out docket', LogSpecsMismatch);
	endif;
	
	if (not _ignoreBolProductCheck) then
		if (not bolOutExt.myLogLot.checkProductOrdered(self.myProduct)) then
			rtnCode := false;
			bolOutExt.addLogLoadError(self.id, self, 'Specs not valid for lot', LogSpecsMismatch);
		endif;
	endif;				
		
	return rtnCode;
	
end;</source>
        <Parameter name="_ignoreAssignedLocnCheck" type="Boolean"/>
        <Parameter name="_ignoreBolProductCheck" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getLoadOutLocationID" id="bbeea622-1aff-436a-89fa-eacf35e1ac2e">
