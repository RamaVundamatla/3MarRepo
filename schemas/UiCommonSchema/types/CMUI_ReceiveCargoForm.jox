        <source>lstStops_hasLostFocus(_fieldFrame: CMUI_FieldFrame input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 July 2009	cnwdap1	Initial creation

*/

vars
	str 	: String;

begin
	// get codes from list box, display in text box and disappear the list box
	str := self.lstAllStops.getSelectedString(CM_StopsTable::code.name);
	if str.length &gt; 30 then
		self.txtAllStops.text := str[1:29]&amp; '...';
	else
		self.txtAllStops.text := str;
	endif;
	self.txtAllStops.visible := true;
	self.lstAllStops.visible := false;
	self.lstAllStops.parent := _fieldFrame;
epilog

end;</source>
