    <JadeMethod name="getTableDisplay" id="46cf8bd8-e958-4e04-9f6e-6ca4e95f9de9">
        <source>getTableDisplay(_altCode: Boolean; _showUNDGCodes : Boolean): String;
//----------------------------------------------------------------
//	Created:	01 April 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	hazClass	: CM_HazardClass;
begin
	if _altCode then
		hazClass := app.myRoot.allHazardClasses[self.code];
		if hazClass &lt;&gt; null
		and hazClass.alternateCode &lt;&gt; null then
			return hazClass.alternateCode;
		endif;
	endif;
	return self.code;
	
end;</source>
        <Parameter name="_altCode" type="Boolean"/>
        <Parameter name="_showUNDGCodes" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hazardLargestDepthSep" id="352c4d85-9c92-4eda-8393-daae0183a8f5">
        <source>hazardLargestDepthSep(_terminal : CM_Terminal; _ruleType : Integer) : Integer;
/*
----------   ----------  --------------------------------------------------
Created:	21 November 2006 By cnwth2

Purpose:	Returns the largest depth of 20fts (stacked 20s inbetween) for 
			any hazard segregation rule associated with this hazard for the 
			_terminal and _ruletype passed in.

			_ruleType will be either:

			Segregation_Type_Rail
			Segregation_Type_Road
			Segregation_Type_Ship
			Segregation_Type_Yard
			
Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	iter			: Iterator;
	segRuleDict		: CM_SegRuleByTypeEntity1Entity2;
	segRule			: CM_SegregationRule;
	ruleTypeKey		: Integer;
	entity1Key,
	entity2Key		: CM_Object;
	largestVal		: Integer;
begin
	if _ruleType = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Segregation rule type passed in was null');
		return null;
	endif;
	
	segRuleDict := _terminal.allSegRulesByEntity1Entity2;
	iter := segRuleDict.createIterator;
	segRuleDict.startKeyGeq(_ruleType, self, null, iter);
	
	while iter.next(segRule) do
		segRuleDict.getIteratorKeys(ruleTypeKey, entity1Key, entity2Key, iter);
		if (ruleTypeKey &lt;&gt; _ruleType) or entity1Key &lt;&gt; self then
			break;
		endif;
		
		if segRule.mySegregationCondition.proximityDepth &gt; largestVal then
			largestVal := segRule.mySegregationCondition.proximityDepth;
		endif;
	endwhile;
	
	return largestVal;

epilog
	delete iter;
end;


</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_ruleType" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hazardLargestHorizontalSep" id="19107112-530d-420f-8e85-d22cc9a9c3e1">
        <source>hazardLargestHorizontalSep(_terminal 	: CM_Terminal; 
						_ruleType 		: Integer;
						_sepValue 		: Integer output;
						_notSameArea 	: Boolean output);
/*
----------   ----------  --------------------------------------------------
Created:	21 November 2006 By cnwth2

Purpose:	Returns the largest horizontal number of 20ft slots (or grid columns) for 
			any hazard segregation rule associated with this hazard for the 
			_terminal and _ruletype passed in.

			_ruleType will be either:

			Segregation_Type_Rail
			Segregation_Type_Road
			Segregation_Type_Ship
			Segregation_Type_Yard
			
Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	iter			: Iterator;
	segRuleDict		: CM_SegRuleByTypeEntity1Entity2;
	segRule			: CM_SegregationRule;
	ruleTypeKey		: Integer;
	entity1Key,
	entity2Key		: CM_Object;
begin
	if _ruleType = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Segregation rule type passed in was null');
		return;
	endif;
	
	segRuleDict := _terminal.allSegRulesByEntity1Entity2;
	iter := segRuleDict.createIterator;
	segRuleDict.startKeyGeq(_ruleType, self, null, iter);
	
	while iter.next(segRule) do
		segRuleDict.getIteratorKeys(ruleTypeKey, entity1Key, entity2Key, iter);
		if (ruleTypeKey &lt;&gt; _ruleType) or entity1Key &lt;&gt; self then
			break;
		endif;
		
		if segRule.mySegregationCondition.proximityHorizontal &gt; _sepValue then
			_sepValue := segRule.mySegregationCondition.proximityHorizontal;
		endif;
	endwhile;
	
	
epilog
	delete iter;
end;


</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_ruleType" type="Integer"/>
        <Parameter name="_sepValue" type="Integer" usage="output"/>
        <Parameter name="_notSameArea" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="hazardLargestVerticalSep" id="cb1335dc-b1e2-432f-9a88-ff4033486d9d">
        <source>hazardLargestVerticalSep(_terminal 		: CM_Terminal; 
						_ruleType 		: Integer;
						_sepValue 		: Integer output;
						_notSameArea 	: Boolean output);
/*
----------   ----------  --------------------------------------------------
Created:	21 November 2006 By cnwth2

Purpose:	Returns the largest vertical number of 20ft slots (or grid rows) for 
			any hazard segregation rule associated with this hazard for the 
			_terminal and _ruletype passed in.

			_ruleType will be either:

			Segregation_Type_Rail
			Segregation_Type_Road
			Segregation_Type_Ship
			Segregation_Type_Yard
			
Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	iter			: Iterator;
	segRuleDict		: CM_SegRuleByTypeEntity1Entity2;
	segRule			: CM_SegregationRule;
	ruleTypeKey		: Integer;
	entity1Key,
	entity2Key		: CM_Object;
	
begin
	if _ruleType = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Segregation rule type passed in was null');
		return;
	endif;
	
	segRuleDict := _terminal.allSegRulesByEntity1Entity2;
	iter := segRuleDict.createIterator;
	segRuleDict.startKeyGeq(_ruleType, self, null, iter);
	
	while iter.next(segRule) do
		segRuleDict.getIteratorKeys(ruleTypeKey, entity1Key, entity2Key, iter);
		if (ruleTypeKey &lt;&gt; _ruleType) or entity1Key &lt;&gt; self then
			break;
		endif;
		
		if segRule.mySegregationCondition.proximityVertical &gt; _sepValue then
			_sepValue := segRule.mySegregationCondition.proximityVertical;
		endif;
		
		if (not segRule.mySegregationCondition.allowedSameArea) then
			_notSameArea := true;
		endif;
	endwhile;
	
epilog
	delete iter;
end;


</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_ruleType" type="Integer"/>
        <Parameter name="_sepValue" type="Integer" usage="output"/>
        <Parameter name="_notSameArea" type="Boolean" usage="output"/>
    </JadeMethod>
