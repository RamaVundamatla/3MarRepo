<GUIClass name="CMUI_BGPOptionButton" id="45726b9b-07da-4db8-b668-4ee1138933ff">
    <superclass name="CMUI_OptionButton"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <ImplicitInverseRef name="myFrame" id="a1ebff2d-fe54-41c4-bba2-491a125c0381">
        <embedded/>
        <type name="CMUI_Frame"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="click" id="0c4887eb-44df-45bc-a40a-e973a3289fe3">
        <updating/>
        <source>click(optionbutton: OptionButton input) updating;

// cnwdvb1 18 December 2002 

vars

begin
	inheritMethod(optionbutton);
	if self.myFrame &lt;&gt; null then
		self.myFrame.doOptionButtonClick(self);
	endif;

end;</source>
        <Parameter name="optionbutton" type="OptionButton" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyFrame" id="ede81a4d-a047-43a6-9e12-2d41d57280ed">
        <updating/>
        <source>setMyFrame(_frame : CMUI_BGPAutoScheduleFrame) updating;

// cnwdvb1 17 December 2002 

vars

begin

	self.myFrame := _frame;
end;</source>
        <Parameter name="_frame" type="CMUI_BGPAutoScheduleFrame"/>
    </JadeMethod>
    <DevControlTypes name="CMUI_BGPOptionButton">
        <bitmap></bitmap>
