    <JadeMethod name="utlCreateTISnapShot" id="8f29ef4e-8ee3-4b66-bdef-794638d8d158">
        <source>utlCreateTISnapShot(_pxyTISnap: CM_TISnapShot; _passport: CM_Passport input): CM_TISnapShot;
//----------------------------------------------------------------
//	Created:	11 May 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tiSnap		: CM_TISnapShot;
	terminal	: CM_Terminal;
begin


	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	//validation??
	if _pxyTISnap = null then
		app.raiseUnexpectedProgramError(class.name, method.name, "proxy smap shot is null");
	endif;
	
	if _pxyTISnap.operatorCode = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "operator code", 'operatorCode', null);
		app.raiseCMException(Input_required_field_opCode, 'operatorCode', null); // cnwdb2	PAR 35364
	endif;
	
	if _pxyTISnap.myVoyage = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "voyage", 'myVoyage', null);
		app.raiseCMException(Input_required_field_voyage, 'myVoyage', null); 
	else
		terminal := _pxyTISnap.myVoyage.myTerminal;
	endif;
	
	if not self.checkValidationWithPassport(_passport) then
		return null;
	endif;
	
	app.setContinueCMExceptions(false);

	create tiSnap persistent;
	tiSnap.setupDefault(terminal, _passport);
	tiSnap.setFromProxyLtd(_pxyTISnap);

	return tiSnap;
end;</source>
