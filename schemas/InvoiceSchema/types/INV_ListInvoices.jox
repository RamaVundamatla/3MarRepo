    <JadeMethod name="setContextMenus" id="ae8f0d2c-9def-41b8-9a52-308742eb7745">
        <updating/>
        <source>setContextMenus() updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//13 November 2019	jlgma1	Bug 47455: CPL - Change in Invoice Audit screen displayed by Right Click Context Menu
// 31/01/2023	navkc1	TFS CR 55305 Task 55537 UI - Invoice List UI changes
// 27/02/2023 	navtnr20 Bug 56507: UI - Invoice List Colour Legend
// 5/12/2023	navra1  TFS 54090 CR 61417 - Task 61418 &amp; 61420
// ---------------------------------------------------------------------------
vars
	invoice 	: CM_Invoice;
	invoices	: ObjectArray;
	canDoCreditNote : Boolean;
begin
	canDoCreditNote := app.getMyUser().canDo(self.myTerminal, PmAdmInvoiceCreditNoteMaint); //01/11/2023	navkc1 Bug 60895
	
	self.mnuOverrideExtRef.visible := self.displayOverrideExtRef(); //08/12/2025	navkc1 JIRA 36262
	
	//self.mnuContextColourLegend.visible := false; //27-02-2023 navtnr20 BUG 56507
	self.mnuContextColourLegend.visible := true; //27-02-2023 navtnr20 BUG 56507
	self.mnuContextSep01.visible 		:= true;
	self.mnuSendReportMain.visible 		:= true; 	//epr par 36958 29/9/15
	self.mnuSendReportAll.visible 		:= true;
	self.mnuSendReportSelected.visible 	:= true;
	self.mnuSendReportSeparator.visible := true;
	self.mnuSendReportSelected.visible  := true;
	self.mnuInvoicePostConf.visible  := false; // ### TFS BUG 63257 28MAR2024 NAVAB1
	self.mnuInvMerge.visible  := true; // ### TFS CR 58085 TASK 61346 11JAN2024 NAVAB1
	self.mnuContextCrteCrdFrmInv.enabled := canDoCreditNote;
	self.mnuContextLinkCredit.enabled := canDoCreditNote;
	self.mnuContextUnlinkCredit.enabled := canDoCreditNote;
	
	//13.11.2019 cnwma1 #47455
	// TFS BUG 58789 26JUNE2023 NAVAB1 self.mnuInvAudits.visible    := false;
	self.mnuInvAudits.visible    := false; // TFS BUG 58789 26JUNE2023 NAVAB1
	self.mnuAuditsForObject.visible    := true; // TFS BUG 58789 26JUNE2023 NAVAB1
	if self.myCurrentInvoice &lt;&gt; null then
		self.enableDisablePostConf(); // ### TFS BUG 63257 28MAR2024 NAVAB1
		/* TFS BUG 58789 26JUNE2023 NAVAB1
		if not  self.myCurrentInvoice.hasAudits then	//14 Jan 2021	NDL	TFS 50152
			self.mnuInvAudits.visible  := true;
			self.mnuInvAudits.caption  := "Audit Enquiry...";
		endif;
		*/
		if not self.myCurrentInvoice.unqualifiedAudits.isEmpty 
		or not self.myCurrentInvoice.qualifiedAudits.isEmpty then 
				self.mnuInvAudits.visible := true;
		endif;
		
		if self.myCurrentInvoice.myInvoiceProcess.isInvoiceAPIProcess() then			//navra1 - TFS 54090 CR 61417 - Task 61418 &amp; 61420  - 5th Dec 2023
			self.mnuApiActivity.visible := true;										//navra1 - TFS 54090 CR 61417 - Task 61418 &amp; 61420  - 5th Dec 2023
			self.mnuInvExport.visible := false;											//navra1 - TFS 54090 CR 61417 - Task 61418 &amp; 61420  - 3rd Jan 2023
			self.mnuInvExport2File.visible := false;									//navra1 - TFS 54090 CR 61417 - Task 61418 &amp; 61420  - 3rd Jan 2023
		else																			//navra1 - TFS 54090 CR 61417 - Task 61418 &amp; 61420  - 5th Dec 2023
			self.mnuApiActivity.visible := false;										//navra1 - TFS 54090 CR 61417 - Task 61418 &amp; 61420  - 5th Dec 2023
		endif;																			//navra1 - TFS 54090 CR 61417 - Task 61418 &amp; 61420  - 5th Dec 2023
	endif;
	
	/* //01/11/2023	navkc1 Bug 60895
	// 31/01/2023	navkc1	TFS CR 55305 TASK 55537
	invoices := self.tblData.allSelectedObjects;
	invoice := invoices.first().CM_Invoice;
	// If the first selected invoice is a credit note, then we don't display the option to create credit notes,
	// because we are taking the first selected invoice as a refrence to clone the credit note
	if invoice &lt;&gt; null then
		if invoice.isCreditNote() then
			self.mnuContextCrteCrdFrmInv.enabled := false;
		else
			self.mnuContextCrteCrdFrmInv.enabled := true;
		endif;
	endif;
	*/
	
	
	self.disableCreditNoteContext(); //01/11/2023	navkc1 Bug 60895
end;</source>
    </JadeMethod>
    <JadeMethod name="setCorrectComboStyle" id="56d85b33-b672-4a5c-91ed-b219533c6ba8">
