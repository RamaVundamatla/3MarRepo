    <JadeMethod name="getAuditText" id="22ca12d7-e69d-40a2-a566-9d6d03f21137">
        <source>getAuditText(): String;
/* ---------------------------------------------------------------------------
Created:     09 June 2008 by cnwrs2

Purpose:     PAR 16906 - record audit details for collections
        
Change Date	Who		Reason
26/06/2008  concms1	PAR 17268 - CAMs message by freight forwarder
24/03/0211	CNWCS5	Add exception handler as self.operators is not inversed
------------------------------------------------------------------------------*/
vars
	txt,
	tmpStr, strFF,
	strOp			: String;					// 23/03/2011 cnwcs5
	op				: CM_Operator;
	ff				: CM_ConsigneeConsignor;
	gotException	: Boolean;					// 23/03/2011 cnwcs5
begin
	txt := inheritMethod();
	
	on Exception do app.handleDeletedObject (exception, op, gotException);	// 23/03/2011 cnwcs5

	foreach op in self.operators do
		strOp := op.code;													// 23/03/2011 cnwcs5
		// if op is deleted the exception handler will resume here		
		if gotException then												// 23/03/2011 cnwcs5
			gotException := false;											// 23/03/2011 cnwcs5
			continue;														// 23/03/2011 cnwcs5
		endif;																// 23/03/2011 cnwcs5
		
		tmpStr 	:= tmpStr &amp; strOp &amp; ',';									// 23/03/2011 cnwcs5
	endforeach;
	
	if not self.operators.isEmpty then
		tmpStr := tmpStr[1:tmpStr.length-1];	// remove trailing comma
	endif;
	
// par 17268 - start
	foreach ff in self.allFreightForwarders do
		if strFF = null then
			strFF := ff.code;
		else
			strFF := strFF &amp; ',' &amp; ff.code;
		endif;
	endforeach;
// par 17268 - end

	txt := txt &amp; 'Operators' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator &amp;
			'Freight Forwarders' &amp; AuditStringSeparator &amp; strFF.length.String &amp; AuditStringSeparator &amp; strFF &amp; AuditStringSeparator;	// par 17268

	return txt;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="20c9318c-9460-46fc-82d6-0714636275e0">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     09 September 2002 by cnwdf1
//
// Purpose:
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26 June 2008	cpcms1		par 17268 CAMs messages by freight forwarder
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// ---------------------------------------------------------------------------
vars
	tmpCamGroup : CM_CamGroup;
	completedOK		: Boolean;
begin

	tmpCamGroup :=  inheritMethod();
	self.operators.copy(tmpCamGroup.operators);
	self.allFreightForwarders.copy (tmpCamGroup.allFreightForwarders);	// par 17268
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return tmpCamGroup;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete tmpCamGroup;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
