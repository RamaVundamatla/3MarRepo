    <JadeMethod name="initSelectorControlsForVoyage" id="62e9d3e7-c551-4f7a-ae90-b2abe8abfd3d">
        <source>initSelectorControlsForVoyage(_voyage : CM_Voyage; _resetHoldSelector : Boolean) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	idx: Integer;
begin
	if _voyage = null then
		if _resetHoldSelector then
			self.msgHolds.setAvailable(null, true);
			self.msgHolds.setSelected(null);
		endif;
		return;
	endif;
	
	if _resetHoldSelector then
		// setup controls for Hold selector
		if self.selectMode = self.SelectModeHold then
			self.msgHolds.setAvailable(_voyage.myGeneralCargoVoyage.allLocationsByHatchPlace, true);
			if _voyage.myShipBlockStack &lt;&gt; null then		// 20/7/16 cnwmp6 TFS 1601
				idx := self.msgHolds.myAvailableListBox.addItem("Ship Block Stack");
				self.msgHolds.myAvailableListBox.itemObject[idx] := _voyage.myShipBlockStack;
			endif;
			self.msgHolds.setSelected(null);
		endif;
		self.btnSelectVoyOK.bubbleHelp := "Show " &amp; self.cmbVoyage.text;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_resetHoldSelector" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="initWithObject" id="7d8ea301-a857-489a-8bc7-3f338f4cb6dd">
        <updating/>
        <source>initWithObject() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	aHold : CM_GeneralCargoController;

begin
	if not self.allSelectedHolds.isEmpty then
		// This is being called from another Planning form. i.e. then NEW planning window has been clicked. 
		// So the default is actual. If the original screen is in actual then switch to proposed, so that the switchDisplayMode called below sets the toolbars correctly
		if self.displayMode = ShpDisplayMode_Actual then
			self.switchDisplayMode(ShpDisplayMode_Proposed,false);
		endif;
		self.top := self.top + 20;
		self.left := self.left + 20;
		self.cmbVoyage.listObject := self.myCurrentVoyage;
		self.myCurrentVoyage := null;
		if self.selectMode = self.SelectModeHold then
			self.cmbVoyage.click(self.cmbVoyage);
			self.msgHolds.setSelected(self.allSelectedHolds);
			self.btnSelectVoyOK.click(self.btnSelectVoyOK);
		endif;
		self.switchDisplayMode(self.displayModeHistory,true);		
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="19f301f7-1cb3-4a2b-b0c5-dba1292f225b">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 15/02/2016	cnwdap1		Initial creation PAR #36766 Bulk Graphical Representation
//
vars

begin
	if keyCode = CMUI_Key_F5 then
		// a menu has the F5 key defined as a hot-key so ignore here
		return;
	endif;
	
	if keyCode = CMUI_Key_Esc then
		delete app.myMoveController;
		app.myDraggedTrackedItem := null;
		app.isDragging := false;
		self.dragMode := self.DragMode_None;
		self.myDrawingFrame.clearUpDragDrop();
		self.myBulkDrawingController.clearUpDragDrop();
		return;
	endif;
	
	if keyCode = CMUI_Key_F3 then
		if app.isControlKeyDown()
		and not app.isAltKeyDown()
		and not app.isShiftKeyDown()
		then
//			self.showSelectorForm();	// 27/7/16 cnwmp6 TFS 1601
		else
			if self.frmSelectVoyage.visible then
				self.frmSelectVoyage.visible := false;
			else
				self.frmSelectVoyage.visible := true;
			endif;
		endif;
		return;
	endif;
	
	inheritMethod(keyCode, shift);
epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="layoutRedraw" id="2f8d0a73-e98e-4082-a7b9-ec5f9a7b6ebc">
        <updating/>
        <source>layoutRedraw(_evenIfHidden: Boolean) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	msg : String;
	theX1, theX2, theY1, theY2 : Integer;
	theWidth, theHeight, theTop, theLeft : Integer;
	theMainFrame, theViewFrame : Frame;
	theScale, numCol, numRow : Integer;
	thePCWidth, thePCHeight, thePCHScroll, thePCVScroll : Real;
	aReal : Real;
	tmpDkbPos : CMUI_JadeDockBar;
	saveVisible	: Boolean;
	
begin
	tmpDkbPos := self.dkbPosition;

	if (not tmpDkbPos.visible) and
	   (not _evenIfHidden) then
		return;
	endif;

	theMainFrame := self.frmPosition;
	theViewFrame := self.frmPositionView;
	
	if self.myCurrentDrawingController.scaleFactor =1 then
		self.positionScale := 4;
	elseif self.myCurrentDrawingController.scaleFactor = 1.5 then
		self.positionScale := 5;
	elseif self.myCurrentDrawingController.scaleFactor = 2 then
		self.positionScale := 7;
	elseif self.myCurrentDrawingController.scaleFactor = 3 then
		self.positionScale := 10;
	elseif self.myCurrentDrawingController.scaleFactor = 4 then
		self.positionScale := 13;
	elseif self.myCurrentDrawingController.scaleFactor = 6 then
		self.positionScale := 19;
	elseif self.myCurrentDrawingController.scaleFactor = 9 then
		self.positionScale := 28;
	else
		self.positionScale := 10;
	endif;
	theScale := self.positionScale;
	
	theTop := (self.frmToolbar.top + self.frmToolbar.height + 1).Integer;
	theLeft := 100;

	tmpDkbPos.zOrder(1);
	
	// save and reset visible status so that
	// the floating frame is resized
	saveVisible := tmpDkbPos.visible;
	if saveVisible then
		tmpDkbPos.visible := false;
	endif;

//	tmpDkbPos.width := ((self.myDrawingFrame.width / theScale) + 15).max(self.frmPosToolbar.getMinWidth() + 20);
	tmpDkbPos.width := ((self.myDrawingFrame.width / theScale) + 15);
	tmpDkbPos.height := (self.myDrawingFrame.height / theScale) + 15 + 25;

	tmpDkbPos.visible := saveVisible;

	self.frmPosToolbar.width := tmpDkbPos.clientWidth;
	self.frmPosToolbar.repositionAfterResize();

	// Draw the new view
	theMainFrame.clearGraphics;
	self.myBulkDrawingController.drawMinature(theMainFrame, theScale);
	
	self.scrollPositionFrame();
	theMainFrame.refreshNow();

	theViewFrame.clearGraphics;
	theViewFrame.drawRectangle(0, 0, theViewFrame.clientWidth, theViewFrame.clientHeight, Red);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_evenIfHidden" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="650e3be8-74e5-4fa7-a8ae-2be6a6933014">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	voyage : CM_Voyage;

begin
	self.selectMode := self.SelectModeHold;
	self.showHoldSelector(self.selectMode);
	self.mnuGridLayout.visible := true;
	self.mnuWorkDisplayLayout.visible := true;

	self.positionScale := 10;
	inheritMethod();

	self.switchDisplayMode(ShpDisplayMode_Actual, false);
	voyage := app.getMyCurrentVoyageForTerminal(self.myTerminal);
	if voyage &lt;&gt; null and voyage.myGeneralCargoVoyage &lt;&gt; null then
		self.setMyCurrentVoyage(voyage, true);
	endif;
	
	// init with object 
	self.initWithObject();
	self.resize;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="mnuCreateQuickTIClick" id="6eb9dc3f-bad0-4ae4-a273-a9c9b1a75edc">
        <updating/>
        <source>mnuCreateQuickTIClick() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 31/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	slots : CM_LCSet;
	numItems, idx : Integer;
	is40 : Boolean;
	ct : CM_CargoType;
	ctType : String;
	mess, mess2 : String;
	lc : CM_LocationsController;
begin

	if app.msgBox("Create Containers (Yes) or GC (No)", "Cargo Type", MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
		is40 := app.msgBox("Create 40 foot?", "Quick Cargo", MsgBox_Yes_No) = MsgBox_Return_Yes;
		if is40 then
			mess := "40 Foot";
		else
			mess := "20 Foot";
		endif;

		numItems := 10;
		read numItems;
	
		if app.msgBox("Create " &amp; numItems.String &amp; " Quick Cargo " &amp; mess &amp; " Containers in " &amp; mess2  &amp; "?", "Quick Container Cargo", MsgBox_Yes_No) = MsgBox_Return_Yes then
			create slots transient;
			if self.myCurrentDrawingController.allSelectedObjects.isEmpty then
				slots.add(self.myCurrentVoyage.myShipBlockStack);
			else
				slots.add(self.myCurrentDrawingController.allSelectedObjects.first.CM_LocationsController);
			endif;
			
			foreach idx in 1 to numItems discreteLock do
				self.myCurrentVoyage.createQuickCargo(slots, is40);
			endforeach;

			if app.myPassport.hasErrorsOrWarnings() then
				app.myPassport.allErrorWarnings.inspectModal();
			endif;
			return;
		endif;
		
	else
		numItems := 10;
		read numItems;
		
		ctType := "CANNONBALL";
		read ctType;
		ct := app.myRoot.getCargoTypeFromAbbrev(ctType);
		if ct &lt;&gt; null then
			mess := ct.description;
		else
			mess := "GC";
		endif;
		
		if self.myCurrentDrawingController.allSelectedObjects.isEmpty then
			mess2 := " on " &amp;  self.myCurrentVoyage.code;
		else
			lc := self.myCurrentDrawingController.allSelectedObjects.first.CM_LocationsController;
			mess2 := " in " &amp;  lc.getFullId;
		endif;
		
		if app.msgBox("Create " &amp; numItems.String &amp; " Quick Cargo " &amp; mess &amp; " Items " &amp; mess2 &amp; "?", "Quick GC Cargo", MsgBox_Yes_No) = MsgBox_Return_Yes then
		
			self.myCurrentVoyage.createQuickCargoShipLC(numItems, ct, lc);

			if app.myPassport.hasErrorsOrWarnings() then
				app.myPassport.allErrorWarnings.inspectModal();
			endif;
			return;
		endif;
	endif;

epilog
	delete slots;
end;</source>
    </JadeMethod>
    <JadeMethod name="processStopsEDI" id="88f6e2ba-6b25-4042-a3dd-5c5196cd07d7">
        <source>processStopsEDI();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 01/09/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars

	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin

	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxProcessStopsEDIOnShip(self.myCurrentVoyage, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Process Customs EDI', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="redraw" id="d0b40612-58b6-4b4e-83ff-06f735af2e54">
        <updating/>
        <source>redraw() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	frm : SHP_BulkDrawingFrame;

begin
	//epr TFS 4188 21/4/17
	if self.dkcGridArea.height &lt; 500 then
		self.dkcGridArea.height:=500;
	endif;
	
	self.sizeBowAndSternGraphics();
	if self.myBulkDrawingController.isStarboardBerthed then
		self.frmScrollBackgrd.move(self.frmScrollBackgrd.left, self.frmScrollBackgrd.top, self.dkbGridArea.width-self.picBow.width, self.frmScrollBackgrd.height);
	else
		self.frmScrollBackgrd.move(self.frmScrollBackgrd.left, self.frmScrollBackgrd.top, self.dkbGridArea.width-self.picSternRev.width, self.frmScrollBackgrd.height);
	endif;
	self.frmScrollBackgrd.myDragSelectFrame.move(self.frmScrollBackgrd.myDragSelectFrame.left, self.frmScrollBackgrd.myDragSelectFrame.top, self.frmScrollBackgrd.width, self.frmScrollBackgrd.height-5);
	self.myBulkDrawingController.drawSelf(true);
	if self.myBulkDrawingController.isStarboardBerthed then
		self.frmScrollBackgrd.move(self.frmScrollBackgrd.left, self.frmScrollBackgrd.top, self.dkbGridArea.width-self.picBow.width, self.frmScrollBackgrd.height);
	else
		self.frmScrollBackgrd.move(self.frmScrollBackgrd.left, self.frmScrollBackgrd.top, self.dkbGridArea.width-self.picSternRev.width, self.frmScrollBackgrd.height);
	endif;
	self.frmScrollBackgrd.myDragSelectFrame.move(self.frmScrollBackgrd.myDragSelectFrame.left, self.frmScrollBackgrd.myDragSelectFrame.top, self.frmScrollBackgrd.width, self.frmScrollBackgrd.height-5);
	
	/*self.picStern.move(self.dkcSubMain.left, self.dkcMain.top, 100, self.dkbGridArea.height);
	self.frmMiddle.move(self.dkcSubMain.left + 100, self.dkcMain.top, self.dkbGridArea.width - 150, self.dkbGridArea.height);
	self.picBow.move(self.dkcSubMain.width + self.dkcSubMain.left - 55, self.dkcMain.top+1, 55, self.dkbGridArea.height);
	*/
	//self.picStern.move(self.dkcSubMain.left, self.dkcMain.top, self.dkcMain.width*100/888, self.dkbGridArea.height);
	//self.frmMiddle.move(self.dkcSubMain.left + self.dkcMain.width*100/888, self.dkcMain.top, (self.dkbGridArea.width - ((self.dkcMain.width*100/888)+(self.dkcMain.width*55/888))), self.dkbGridArea.height);
	//self.picBow.move(self.dkcSubMain.width + self.dkcSubMain.left - (self.dkcMain.width*55/888), self.dkcMain.top+1, self.dkcMain.width*55/888, self.dkbGridArea.height);
	/*if self.myBulkDrawingController = null or self.myBulkDrawingController.isStarboardBerthed then
		self.picStern.move(self.dkcSubMain.left, self.dkcMain.top, self.dkcMain.width*.112612, self.dkbGridArea.height);
		self.frmMiddle.move(self.dkcSubMain.left + self.dkcMain.width*.112612, self.dkcMain.top, (self.dkbGridArea.width - ((self.dkcMain.width*.112612)+(self.dkcMain.width*.061937))), self.dkbGridArea.height);
		self.picBow.move(self.dkcSubMain.width + self.dkcSubMain.left - (self.dkcMain.width*.061937), self.dkcMain.top+1, self.dkcMain.width*.061937, self.dkbGridArea.height);
		self.picSternRev.visible := false;
		self.picBowRev.visible := false;
		self.picStern.visible := true;
		self.picBow.visible := true;
	else
		self.picBowRev.move(self.dkcSubMain.left, self.dkcMain.top+1, self.dkcMain.width*.061937, self.dkbGridArea.height);
		self.frmMiddle.move(self.dkcSubMain.left + self.dkcMain.width*.061937, self.dkcMain.top, (self.dkbGridArea.width - ((self.dkcMain.width*.112612)+(self.dkcMain.width*.061937))), self.dkbGridArea.height);
		self.picSternRev.move(self.dkcSubMain.left+self.dkcSubMain.width-(self.dkcMain.width*.112612), self.dkcMain.top, self.dkcMain.width*.112612, self.dkbGridArea.height);
		self.picStern.visible := false;
		self.picBow.visible := false;
		self.picSternRev.visible := true;
		self.picBowRev.visible := true;
	endif;*/
	
	self.drawShipDeckAndHull();
	self.frmStatusLine.doResize();
	self.frmMiddle.zOrder(0);
	self.frmScrollBackgrd.myDragSelectFrame.zOrder(1);
	if self.picStern.visible then
		self.picStern.zOrder(1);
		self.picBow.zOrder(1);
	else
		self.picSternRev.zOrder(1);
		self.picBowRev.zOrder(1);
	endif;
	
	self.frmScrollBackgrd.myDragSelectFrame.borderStyle := Window.BorderStyle_Double;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="resize" id="a2a631fb-6625-4957-a024-5bc8be5cd40a">
        <controlMethod name="Form::resize"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>resize() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	ctrl : Control;

begin
	self.frmStatusLine.cnEcResizeContents;
	self.redraw();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="runImportTasks" id="9573c334-0d9b-45d6-a9e0-b976d089fc9a">
        <updating/>
        <source>runImportTasks() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 01/09/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars

	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin
	app.mousePointer := Window.MousePointer_HourGlass;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxRunImportTasksOnShip(self.myCurrentVoyage, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Run Import Tasks', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="setCaptionForModes" id="32757bec-3b22-45f4-abe8-d7d9cfca6d6a">
        <updating/>
        <source>setCaptionForModes(_theMode : Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	theString : String;
	invalid : Boolean;
	vCode : String;
	voyage : CM_Voyage;

begin
	theString := self.setCaptionForModesGetView(_theMode);

	voyage := self.myCurrentVoyage;
	if voyage &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception,voyage,invalid);
		vCode := voyage.code;
		vCode := voyage.code &amp; " - " &amp; voyage.vesselName &amp; " (" &amp; voyage.starboardBerthedRWD() &amp; ")";
	endif;
	
	if invalid then
		voyage := null;
		self.myCurrentVoyage := null;  //if I null the invalid object here it will avoid errors in a couple of other areas too
	endif;
	
	if voyage &lt;&gt; null then
		 theString := vCode.trimBlanks &amp; " - " &amp; theString;
		self.setNavigatorHeading(vCode.trimBlanks); // NAVIGATOR
	endif;
	self.setCaption(theString); //epr TFS 2362 4/8/16
	
epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_theMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setCaptionForModesGetView" id="6b2e741a-a483-45ba-985c-9eadb9c1ea53">
        <source>setCaptionForModesGetView(_theMode : Integer) : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	tmpString, theString : String;

begin
	if self.myBulkDrawingController = null then
		return null;
	endif;
	
	if _theMode = ShpDisplayMode_Actual then
		theString := theString &amp; " " &amp; $SHP_ACTUAL_Hold_View &amp; ", by " &amp; app.getViewModeString(self.myBulkDrawingController.viewMode); 
	elseif _theMode = ShpDisplayMode_Proposed then
		theString := theString &amp; " " &amp; $SHP_PLANNED_Hold_View &amp; ", by " &amp; app.getViewModeString(self.myBulkDrawingController.viewMode); 
	elseif _theMode = ShpDisplayMode_Queued then
		theString := theString &amp; " " &amp; $SHP_QUEUED_Hold_View &amp; ", by " &amp; app.getViewModeString(self.myBulkDrawingController.viewMode); 
		
	elseif _theMode = ShpDisplayMode_Ops then 
		theString := theString &amp; " " &amp; $SHP_OPS_Hold_View &amp; ", by " &amp; app.getViewModeString(self.myBulkDrawingController.viewMode); 
	endif;
	
	return theString;	
epilog

end;</source>
        <Parameter name="_theMode" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setDisplayMenuForProposed" id="118b0f8b-2f48-4891-b315-3843f2aed3e8">
        <source>setDisplayMenuForProposed();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	mnuChild : MenuItem;

begin
	mnuChild := self.mnuDisplay.getMenuItem(DISPLAY_MODE_PLAN); 
	if mnuChild &lt;&gt; null then
		mnuChild.caption := "Display Planned";
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setDisplayMode" id="ac811dbf-9fbc-4468-b594-85989883495a">
        <updating/>
        <source>setDisplayMode(_mode: Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 01/02/2016	cnwdap1		Initial creation PAR #36766 Bulk Graphical Display
//
vars
	oldMode,
	newMode	: Integer;

begin
	oldMode := self.myBulkDrawingController.actPlanQueMode;
	
	if _mode = DISPLAY_MODE_ACTUAL then
		newMode := ShpDisplayMode_Actual;

	elseif _mode = DISPLAY_MODE_PLAN then
		newMode := ShpDisplayMode_Proposed;
		self.setDisplayMenuForProposed();

	elseif _mode = DISPLAY_MODE_QUEUE then
		newMode := ShpDisplayMode_Queued;
		
	else
		return;
	endif;

	self.myBulkDrawingController.setActPlanQueMode(newMode);
	if newMode &lt;&gt; oldMode then
		//self.myBulkDrawingController.drawSelf(true);
		//self.picStern.zOrder(1);
		self.redraw();
	endif;
	if self.myCurrentVoyage &lt;&gt; null then
		self.doNotesForLegendStartStop(self.myBulkDrawingController.viewMode);
	endif;
	self.frmStatusLine.displayMode := _mode;
	self.setCaptionForModes(newMode);

epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setModes" id="0dd2f75d-0468-4bc2-b9ab-0e31df4b31ac">
        <source>setModes();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	oldMode : Integer;
	drawingController : SHP_BulkDrawingController;

begin
	self.mnuWorkMain.visible := false;

	drawingController := self.myBulkDrawingController;
	drawingController.setModes(self.displayMode, self.imexMode, self.workingMode);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyCurrentVoyage" id="902c998b-a5e8-4865-9dce-8f10c0d91bd3">
        <updating/>
        <source>setMyCurrentVoyage(_voyage : CM_Voyage; _resetHoldSelector : Boolean) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	oldVoyage,
	newVoyage : CM_Voyage;
	tmpEDIEvent	: Integer;

begin
	oldVoyage := self.myCurrentVoyage;

	if oldVoyage = _voyage then
		return;
	endif;
	
	if _voyage &lt;&gt; null
	and _voyage.myGeneralCargoVoyage = null then
		newVoyage := null;
	else
		newVoyage := _voyage;
	endif;
	
	if _voyage &lt;&gt; null and _voyage.myTerminal &lt;&gt; self.myTerminal then
		newVoyage := null;
	else
		newVoyage := _voyage;
	endif;
	
	tmpEDIEvent := self.myTerminal.getTerminalEvent(Voyage_NewEDI_Event);

	if oldVoyage &lt;&gt; null then
		self.myBulkDrawingController.clear();
		self.endNotification(oldVoyage, tmpEDIEvent);
	endif;

	if newVoyage = null then
		// set details to null
		self.myCurrentVoyage := null;
		self.cmbVoyage.listObject := null;
		self.initSelectorControlsForVoyage(null, true);
		return;
	endif;
	
	// setup details for new voyage
	
	self.myCurrentVoyage := newVoyage;
	self.myBulkDrawingController.setFromVoyage(newVoyage);
	self.btnActual.value := true;

	if self.cmbVoyage.listObject &lt;&gt; newVoyage and
	   self.cmbVoyage.findObject(newVoyage) &gt; 0 then
		self.cmbVoyage.listObject := newVoyage;
	endif;
	
	self.initSelectorControlsForVoyage(newVoyage, _resetHoldSelector);

	self.allSelectedHolds.clear();

	// we always switch to actual when displaying a new voyage
	if self.displayMode &lt;&gt; ShpDisplayMode_Actual then
		// need to update buttons, etc
		self.switchDisplayMode(ShpDisplayMode_Actual, false);
	endif;

	if app.getMyCurrentVoyage() &lt;&gt; newVoyage then
		app.setMyCurrentVoyage(newVoyage);
	endif;
	
	self.setCaptionForModes(self.displayMode);

	self.beginNotification(_voyage, tmpEDIEvent, Response_Continuous, null);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_resetHoldSelector" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="d4c1f760-2c0e-4999-95e5-84173ce6a88e">
        <updating/>
        <source>setupForm() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	terminal : CM_Terminal;

begin
	// The user can access the summarise functionality only if they have at least view security role.
	self.bAllowSummaryDefn	:= app.myCurrentUserCan( self.myTerminal, PmSummaryDefView );
	
	self.positionScale := 10;
	self.picCargo.ignoreSkin := true;
	self.picCargo.borderStyle := Frame.BorderStyle_None;
	self.picCargo.picture := null;
	
	self.frmToolbar.alignContainer := Frame.AlignContainer_Top; 
	
	create self.myBulkDrawingController transient;
	self.myCurrentDrawingController := self.myBulkDrawingController;
	self.myBulkDrawingController.setIsStarboardBerthed(true);
	
	create self.myConfig as CMIF_ConfigUserVoyagePlanning transient;
	self.myConfig.setFromPersistentData(app.getMyUser);
	self.myConfig.CMIF_ConfigUserVoyagePlanning.shipSelectByHolds := true;
	self.myConfig.CMIF_ConfigUserVoyagePlanning.shipSelectByBayMulti := false;
	self.myConfig.CMIF_ConfigUserVoyagePlanning.shipSelectByBayOne := false;
	self.myBulkDrawingController.setConfig(self.myConfig.CMIF_ConfigUserVoyagePlanning);

	self.myDrawingFrame := self.frmScrollBackgrd;

	self.showToolbar := true;
	self.toolbarStyle	:= self.ToolbarStyle_ShowNoHide;
	self.frmBay.enableEvent("mouseMove", false);

	self.doInitialiseSDF();
	
	self.myBulkDrawingController.zeroFilledSeqNum := self.myTerminal.getConfig(ShipRemoveLeadingZeros).Boolean;
	self.myBulkDrawingController.setDisplayMode(DISPLAY_MODE_ACTUAL);

	inheritMethod();

	self.setupFormInit();

	self.mnuWorkDisplayMain.visible := true;
	self.doMnuWorkDisplayViewVisible(false);

	self.setupSelectVoyageFrame();
	self.setupVoyageCombo(self.cmbVoyage, false);

	self.isSelectorCapable := true;
	
	terminal := self.myTerminal;
	self.isSameTwinSeqReq := terminal.getConfig(SameSeqNumberTwinLift).Boolean;
	self.allocateCraneLane:= terminal.getConfig(AllocateCraneLane).Boolean;
	
	app.addPlanningForm(self); // PAR 27749	
	
	self.frmStatusLine.hideMoveModeFrame(false);
	self.frmStatusLine.hideDisplayModeFrame(false);
	
	// turn off the resize handles  
	//epr TFS 4188 21/4/17 turn the resize back on
	
	self.minimumHeight := 600;
	self.minimumWidth := 800;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupFormInit" id="b737dba1-66d6-41ef-ac50-06096529009f">
        <updating/>
        <source>setupFormInit() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	mnuChild : MenuItem;
	regKeys : IntegerArray;
	tmpStr : String;
	ctrl : CMUI_GridAreaScrollableFrame;
	
begin
	self.moveModeForm := PLANNING_MODE;

	// FORM SETTINGS
	tmpStr := $VoyagePlanning;
	tmpStr := tmpStr.cnEcRemoveSubstring("&amp;");
	self.setCaption(tmpStr);
	self.mnuWorkMain.caption := $VoyagePlanning;
	self.setNavigatorHeading(self.caption); // NAVIGATOR
	self.mnuGridHideMacro.visible := true;
	self.myDrawingFrame.visible := true;
	self.fldBtns.top := 3000;
	self.mnuGridSelectCargo.caption := "&amp;Select Cargo For Discharge...";

	// ######### SUNDRY CONTROLS
	self.frmBay.borderStyle := BorderStyle_None;
	//self.frmStatusLine.doMenuMoveClick(CMUI_GridAreaStatusLine.MENU_MOVE_PLAN);
	self.frmStatusLine.doMenuDisplayClick(DISPLAY_MODE_ACTUAL);
	if not self.myTerminal.getConfig(ShipImportTaskOptions).Boolean then
		self.btnImportTasks.visible := false;
		self.btnCustomsEDI.visible := false;
		self.mnuOnshipTasks.visible := false;
		self.chkImportTasks.visible := false;
		self.chkCustomsEDI.visible := false;
	endif;
	
	// ####### SPLITTERS
	self.dkbCargoPic.visible := false;

	// ### INHERITED MENUS
	self.setDisplayMenuForProposed();
	
	self.doEnableVoyage(false);
	
	app.mousePointer := Window.MousePointer_Default;

	self.beginNotification(self, EVENT_PLANNING_GET_NEXT_IN_SEQ, Response_Continuous, null);
	self.beginClassNotification(CM_Voyage, false, self.myTerminal.getTerminalEvent(EVENT_VOYAGE_BERTHING_CHANGED), Response_Continuous, null);
	
	// All key strokes are turned off by default. This turns them back on and includes the H key. H for Help.
	create regKeys transient;
	regKeys.add(CMUI_Key_F4);
	regKeys.add(CMUI_Key_F12);
	regKeys.add(CMUI_Key_F9); // Magnify
	regKeys.add(CMUI_Key_Esc);
	self.addRegisteredKeys(regKeys);

	self.backColor := self.myDrawingFrame.backColor;
	
	self.sizeBowAndSternGraphics();
	self.drawShipDeckAndHull();
	
	// Extra info table
	self.tblGridAreaInfo.columns := 13;	// 22/7/16 cnwmp6 TFS 1601
	
	create self.myVoyageStats transient;
	
epilog
	delete regKeys;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupSelectVoyageFrame" id="45a3e088-177f-4054-94a8-684cd7ecaa62">
        <updating/>
        <source>setupSelectVoyageFrame() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars

begin
	self.frmSelectVoyage.height	:= 300;
	self.frmSelectVoyage.width	:= 400;
	
	self.msgHolds.caption 		:= null;
	self.msgHolds.multiSelect 	:= ListBox.MultiSelect_Extended;

	self.msgHolds.formDisplayEntryMethodName := "displayHolds";
	self.msgHolds.availableHeading := app.getErrorString(Available_holds);
	self.msgHolds.selectedHeading := app.getErrorString(Selected_holds);

	self.msgHolds.myBaseForm	:= self;
	self.msgHolds.mySelectedListBox.sorted := false;
	self.msgHolds.readOnly := false;
	self.msgHolds.left := 5;
	self.msgHolds.width := self.frmSelectVoyage.clientWidth - 10;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupVoyageCombo" id="401c160d-827c-4d45-a012-4c56764126b2">
        <updating/>
        <source>setupVoyageCombo(_theCombo : ComboBox input;_codeOnly : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	voyage,
	saveVoyage : CM_Voyage;
	idx : Integer;
	saveObjFound : Boolean;
	passport : CM_Passport;
	failedDAC : CM_DataAccessController;
	
begin
	_theCombo.clear;
	passport := app.myPassport;
	saveVoyage := _theCombo.listObject.CM_Voyage;
	if saveVoyage = null then
		saveVoyage := self.myCurrentVoyage;
	endif;
	
	foreach	voyage in self.myTerminal.allVoyagesByCode do
		if voyage.myGeneralCargoVoyage &lt;&gt; null then
			if voyage.myGeneralCargoVoyage.allLocationsByHatchPlace.size = 0 then
				continue;
			endif;

			if voyage.isCancelled then  //jlier1 TFS51963 5/10/21
				continue;
			endif;
			
			if not voyage.canUserAccessSelf(null, failedDAC, passport) then
				continue;
			endif;
			if voyage = saveVoyage then
				saveObjFound := true;
			endif;
			
			if _codeOnly then
				idx := _theCombo.addItem(voyage.code.trimBlanks );
			else
				idx := _theCombo.addItem(voyage.code.trimBlanks &amp; " " &amp; voyage.vesselName.trimBlanks);
			endif;
			_theCombo.itemObject[idx] := voyage;
		endif;
	endforeach;
	
	if saveObjFound then
		_theCombo.listObject := saveVoyage;
	endif;
epilog

end;</source>
        <Parameter name="_theCombo" type="ComboBox" usage="input"/>
        <Parameter name="_codeOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showHideToolbars" id="7e82c282-6fd3-4313-b382-d7d126a0c1e2">
        <updating/>
        <source>showHideToolbars(_hide: Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
