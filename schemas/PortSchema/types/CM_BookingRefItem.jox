    <JadeMethod name="getOnSiteLocations" id="63359c71-0384-4ad4-aaa9-67a5398d88e1">
        <source>getOnSiteLocations(): String;
// ---------------------------------------------------------------------------
// Created:     12 May 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	locations 		: String;
	ti 				: CM_TrackedItem;
	onSite, i 		:  Integer;
	locationArray   : StringArray;
	str				: String;
begin
	create locationArray transient;
	onSite	:= self.getNumOnsiteItemsUnpacked;
	locations := "";
	if onSite &gt; 0 then
		i := 0;
		foreach ti in self.allTIs where (ti.state &lt;&gt; TI_STATE_NOTIFIED and ti.myParent = null)  do
			if ti.myPrimaryActualLocation &lt;&gt; null then //  par 17686 08/08/08
				if not locationArray.includes(ti.myPrimaryActualLocation.getFullId) then
					locationArray.add(ti.myPrimaryActualLocation.getFullId);
				endif;	
			endif;
		endforeach;
		foreach str in locationArray do
			locations := locations &amp; str;
			if str &lt;&gt; locationArray.last then
				locations := locations &amp; CrLf;
			endif;
		endforeach;
	endif;
	return locations;
epilog
	delete locationArray;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOnsiteTrackeditems" id="533a8d00-63e4-4570-bb09-2c1e1c33a976">
        <source>getOnsiteTrackeditems(_coll :Collection input;_contextObject : Object);
/*

Purpose:			Get all onsite items

Parameters:			_coll : the collection to be filled

Return Value:		null

Date		Who		Reason
04 Dec 2024	navhl20 Bug MTN-33579: EUP - Attach cargo from booking is not doing anything for release ship work order
*/

vars
	item	: CM_BookingRefItem;
	ti		: CM_TrackedItem;
	iter	: Iterator;
begin
	//make sure we're working with the real object
	if self.isTransient then
		item := app.myProxyManager.getRealObject(self).CM_BookingRefItem;
		if item &lt;&gt; null then
			item.getOnsiteTrackeditems(_coll,_contextObject);
			return;
		endif;
	endif;
	
	iter := self.allTIsByState.createIterator();
	
	//get all items with state &gt; notified
	self.allTIsByState.startKeyGeq(TI_STATE_UNDEFINED, "", 0,iter);
	while iter.next(ti) do
		//check state key
		if iter.getCurrentKey(1).Integer &gt;= TI_STATE_NOTIFIED then
			break;
		endif;
		_coll.add (ti);
	endwhile;

	//get all items with state &lt; merged
	self.allTIsByState.startKeyGeq(TI_STATE_OFFSITE, "", 0, iter);
	while iter.next(ti) do
		//check state key
		if iter.getCurrentKey(1).Integer &gt;= TI_STATE_MERGED then
			break;
		endif;
		_coll.add (ti);
	endwhile;
epilog
	delete iter;

end;</source>
        <Parameter name="_coll" type="Collection" usage="input"/>
        <Parameter name="_contextObject" type="Object"/>
    </JadeMethod>
