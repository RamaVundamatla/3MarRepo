    <JadeMethod name="doFormLoad" id="6e7c514f-163a-4955-9482-326599d39eb4">
        <updating/>
        <source>doFormLoad() updating, protected;
// --------------------------------------------------------------------------------
// Created:		12 January 2000 by cnwdad1
//
// Purpose:		Performs all neccessary initializations for the form upon loading.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	date		: Date;
	time		: Time;
	menuIndex	: Integer;
	menuCount	: Integer;
	menuItem	: MenuItem;

begin
	centreWindow();
	beginTimer(1000, Timer_Continuous, 0);
	lblCurrentTime.caption	:=	" " &amp; date.format("dd/MM/yyyy") &amp; ",  " &amp; time.format("hh:mm:ss");
	lblUserId.caption		:=	" " &amp; app.userName() &amp; "@" &amp; app.computerName().trimBlanks() &amp; " ";
	self.doMoveControls();
	picBusy.visible			:=	false;
	picReady.visible		:=	true;
	lstRunTest.listCollection(app.myBaseRoot.allWebTests, true, 0);
	lstMessage.listCollection(app.myBaseRoot.allWebTestMessages, true, 0);
	lstWebTest.listCollection(app.myBaseRoot.allWebTests, true, 0);
	lstClientTest.listCollection(app.myBaseRoot.allWebTests, true, 0);
	cmbResultTest.listCollection(app.myBaseRoot.allWebTests, true, 0);
	txtClientPathBin.text	:=	"\\" &amp; self.getDatabaseServerName() &amp; "\";
	txtClientPathIni.text	:=	"\\" &amp; self.getDatabaseServerName() &amp; "\";

	self.doLoadRemoteClientList();
	beginClassNotification(Process, false, Any_System_Event, Response_Continuous, 0);
	self.doEnableButtonsMessages();
	self.doEnableButtonsTests();
	self.doEnableButtonsResults();
	self.doEnableButtonsRunTests();
	self.doEnableButtonsClientTests();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadRemoteClientList" id="02eaf2ed-1d19-417c-ba2c-7fbdfebb0df1">
        <source>doLoadRemoteClientList() protected;
// --------------------------------------------------------------------------------
// Created:		09 June 2000 by cnwdad1
//
// Purpose:		Loads all currently connected JADE client nodes into the listbox.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	PROC_BACKGROUND		: Integer = 0;	// Background process
	PROC_JADEDEV		: Integer = 1;	// JADE development (that is, JADE itself)
	PROC_USERAPP_DEV	: Integer = 2;	// A non-development process (that is, a user application running from a non-production mode database)
	PROC_USERAPP_PROD	: Integer = 3;	// A production process (that is, a user application running from a production mode database)
	PROC_JADEDEBUG		: Integer = 4;	// JADE Debugger

vars
	theNode			: Node;
	theProcess		: Process;
	listbox			: ListBox;
	processType		: Integer;
	nodeIterator	: Iterator;
	procIterator	: Iterator;

begin
	listbox	:=	lstClientRemote;
	listbox.clear;

	nodeIterator	:=	system.nodes.createIterator();

	while nodeIterator.next(theNode) do
		if self.getShareLockClientList(theNode) then
			procIterator	:=	theNode.processes.createIterator();

			while procIterator.next(theProcess) do
				processType	:=	theProcess.type.Integer;

				if processType = PROC_USERAPP_DEV or processType = PROC_USERAPP_PROD then
					if theProcess.persistentApp.name &lt;&gt; app.name then
					 	if self.getShareLockClientList(theProcess) then
							listbox.addItem(theProcess.persistentApp.name &amp; ": " &amp; theProcess.userCode);
							unlock(theProcess);
						endif;
					endif;
				endif;
			endwhile;
		endif;

		delete procIterator;
		unlock(theNode);
	endwhile;

	if listbox.listCount = 0 then
		listbox.addItem("&lt;no processes running&gt;");
	endif;
epilog
	delete nodeIterator;
	delete procIterator;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLockExceptionClientList" id="07a2fc4f-6282-4bb6-bb1f-2b9bf15e5453">
        <source>doLockExceptionClientList(pTheException:Exception):Integer protected;
// --------------------------------------------------------------------------------
// Created:		14 June 2000 by cnwdad1
//
// Purpose:		Exception Handler exclusively for the "getShareLockClientList" method.
//				We use this method so that if we try to lock an obect that no longer
//				exists, then we want to simply ignore the object an keep going,
//				otherwise we'll pass back to to previous exception handler.
//
// Parameters:	pTheException - The exception object.
//
// Returns:		The excepton return value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	OBJECT_NOT_FOUND	: Integer = 4;

begin
	if pTheException.errorCode = OBJECT_NOT_FOUND then
		// If the object is not found, then it's already been deleted, so
		// we'll just continue on our merry way and ignore that object.
		return Ex_Resume_Next;
	else
		return Ex_Pass_Back;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pTheException" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doMoveControls" id="c3044dfd-5ad0-4a60-9f62-9744f6388261">
        <source>doMoveControls() protected;
// --------------------------------------------------------------------------------
// Created:		12 January 2000 by cnwdad1
//
// Purpose:		Realigns controls when the size of the form is altered.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	picBusy.move((staStatusLine.width - picBusy.width - 7), 1, picBusy.width, picBusy.height);
	picReady.move((staStatusLine.width - picReady.width - 7), 1, picReady.width, picReady.height);
	lblCurrentTime.move((picReady.left - lblCurrentTime.width - 3), 0, lblCurrentTime.width, lblCurrentTime.height);
	lblUserId.move((lblCurrentTime.left - lblUserId.width - 3), 0, lblUserId.width, lblUserId.height);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doShowLoadedForm" id="624865a2-dfad-4bdd-9282-430ff7ef2bf0">
        <source>doShowLoadedForm(pFormName:String):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		29 January 2000 by cnwdad1
//
// Purpose:		If the requested form is already loaded, it'll be given the focus,
//				otherwise a false flag value wil be returned.
//
// Parameters:	pFormName - The name of the form to be given focus.
//
// Returns:		Boolean - True if the form was found, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	loadedForm	: Form;

begin
	loadedForm	:=	app.getForm(pFormName);

	if loadedForm = null then
		return false;
	else
		loadedForm.setFocus();
		return true;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pFormName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowMessageDetails" id="6b2cf200-0765-449c-955d-097f481c7536">
