    <JadeMethod name="btnShowBookItms_click" id="f9719216-e2b8-48d3-bd4e-7ff6076e7439">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnShowBookItms_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
07 July 2009	cnwml2	Initial creation
25/02/2010		cnwcs5	par 21894 - use translations for bubble help instead of literals
09/03/2010		cnwcs5	par 22843 - disable edit status button in booking item mode
24/03/2010		cnwcs5	par 22602 - disable roll button in bookimg item mode to avoid exception
*/

	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars

begin
	if self.isBookingItemMode then													// 25/02/2010 cnwcs5 par 21894
		btn.bubbleHelp 	:= app.getErrorString(GTE_BookingRefM_BbtnShowBook);		// 25/02/2010 cnwcs5 par 21894
		
		btnEditStatus.enabled	:= false;											// 09/03/2010 cnwcs5 par 22843
		btnEditVoyage.enabled	:= false;											// 24/03/2010 cnwcs5 par 22602
	else
		btn.translateBubbleHelp (Xlat_0011308, self.getLocale);	// 25/02/2010 cnwcs5 par 21894
		
		btnEditStatus.enabled	:= self.allowUpdate;								// 09/03/2010 cnwcs5 par 22843
		btnEditVoyage.enabled	:= true;											// 24/03/2010 cnwcs5 par 22602
	endif;

	self.doBtnShowBookItems(self.filterBookingReference, self.filterOperatorCode, self.filterVoyageCode, self.filterStatus, self.filterReconciled, self.filterBookingType);  //+cnwml2 PAR22280
epilog

end;</source>
