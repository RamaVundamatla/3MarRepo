    <JadeMethod name="createPasteFile" id="1de2e4df-94ff-441f-a754-aaca8432bf53">
        <source>createPasteFile(pSourcePath:String;
				pTargetPath:String;
				pNodeOptions:Integer;
				pIsFolder:Boolean;
				pIsCutAndPaste:Boolean;
				pIsSourceUnix:Boolean;
				pIsTargetUnix:Boolean):JSSFMPasteFile;
// --------------------------------------------------------------------------------
// Created:		17 September 2002 by cnwdad2
//
// Purpose:		Create a JSSFMPasteFile object for this background copy.
//
// Parameters:	pSourcePath - The file or directory to be copied.
//				pTargetPath - The destination of the file/directory.
//				pNodeOptions - Flags to identify the JADE nodes of the source and
//					target file/directiry.
//				pIsFolder - A flag to indicate whether we're copying a folder (if
//					false, then we're copying a file).
//				pIsCutAndPaste - A flag to indicate whether we're doing a cut and
//					paste (i.e. a move).  If false, then we're only pasting.
//				pIsSourceUnix - A flag to indicate whether the source platform is Unix.
//				pIsTargetUnix - A flag to indicate whether the target platform is Unix.
//
// Returns:		The newly created Paste File object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	thePasteFile	: JSSFMPasteFile;
	
begin
	create thePasteFile;
	
	thePasteFile.updateMe(	pSourcePath,
							pTargetPath,
							pNodeOptions,
							pIsFolder,
							pIsCutAndPaste,
							pIsSourceUnix,
							pIsTargetUnix,
							self);
	
	return thePasteFile;
end;</source>
        <Parameter name="pSourcePath" type="String"/>
        <Parameter name="pTargetPath" type="String"/>
        <Parameter name="pNodeOptions" type="Integer"/>
        <Parameter name="pIsFolder" type="Boolean"/>
        <Parameter name="pIsCutAndPaste" type="Boolean"/>
        <Parameter name="pIsSourceUnix" type="Boolean"/>
        <Parameter name="pIsTargetUnix" type="Boolean"/>
        <ReturnType type="JSSFMPasteFile"/>
    </JadeMethod>
    <JadeMethod name="doCopy" id="8df250f3-e1eb-4951-a097-f0bdda5fdf07">
        <source>doCopy(pTheFileAgent:JSSFMFileAgent input);
// --------------------------------------------------------------------------------
// Created:		17 September 2002 by cnwdad2
//
// Purpose:		Iterates the Paste File collection and sends a request to the File
//				Agent to perform the file/directory copy.
//
// Parameters:	pTheFileAgent - The File Agent object which peforms file actions.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	thePaste	: JSSFMPasteFile;
	theFolder	: FileFolder;
	progress	: String;
	partsCount	: Integer;
	partsDone	: Integer;
	
begin
	beginNotification(self, self.EVENT_STOP_COPY, Response_Continuous, 0);
	
	create theFolder transient;
	
	foreach thePaste in self.allPasteFiles do
		if thePaste.isFolder then
			theFolder.fileName	:=	thePaste.sourcePath;
			partsCount	:=	partsCount + theFolder.files().size();
		else
			partsCount	:=	partsCount + 1;
		endif;
	endforeach;
	
	delete theFolder;
	
	partsDone	:=	0;
	
	foreach thePaste in self.allPasteFiles do
		thePaste.doCopy(pTheFileAgent);
		
		partsDone	:=	partsDone + 1;
		progress	:=	self.getOidString() &amp; "|" &amp; (partsDone / partsCount * 100).rounded().String;
		self.causeEvent(self.EVENT_PROGRESS, true, progress);
		
		app.doWindowEvents(0);
		
		if self.isCancelled then
			break;
		endif;
	endforeach;
epilog
	delete theFolder;
	endNotification(self, self.EVENT_STOP_COPY);
end;</source>
        <Parameter name="pTheFileAgent" type="JSSFMFileAgent" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTableDisplay" id="584aa14a-ecc5-479e-b19e-457e9486acc4">
        <source>getTableDisplay():String;
// --------------------------------------------------------------------------------
// Created:		18 September 2002 by cnwdad2
//
// Purpose:		Returns a tab-delimited string for displaying the Background Copy
//				details in a table control.
//
// Parameters:	None
//
// Returns:		The tab-delimited display string.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableRow	: String;
	
begin
	tableRow	:=	self.computerName &amp; Tab &amp; self.sourceNode &amp; Tab &amp; self.targetNode;
	
	return tableRow;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="a688177e-500f-4776-a4ff-46fce1b5c39a">
        <updating/>
        <source>updateMe(pComputerName:String; pSourceNode:String; pTargetNode:String; pTheRoot:JSSFMRoot) updating;
// --------------------------------------------------------------------------------
// Created:		17 September 2002 by cnwdad1
//
// Purpose:		Sets the properties and references on the receiver.
//
// Parameters:	pComputerName - The machine name of the computer that initiated the
//					background copy.
//				pSourceNode - The machine from which the file/directory is being copied.
//				pTargetNode - The machine to which the file/directory is being copied.
//				pTheRoot - The owner object of the Background Copy.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	currentTime		: TimeStamp;
	
begin
	// Set non-key properties.
	
	if self.sourceNode &lt;&gt; pSourceNode then
		self.sourceNode		:=	pSourceNode;
	endif;
	
	if self.targetNode &lt;&gt; pTargetNode then
		self.targetNode		:=	pTargetNode;
	endif;
	
	// Set key properties.
	
	if self.computerName &lt;&gt; pComputerName then
		self.computerName	:=	pComputerName;
	endif;
	
	self.timestamp	:=	currentTime;
	
	// Set any inverse references.
	
	if self.myRoot &lt;&gt; pTheRoot then
		self.myRoot			:=	pTheRoot;
	endif;
end;</source>
        <Parameter name="pComputerName" type="String"/>
        <Parameter name="pSourceNode" type="String"/>
        <Parameter name="pTargetNode" type="String"/>
        <Parameter name="pTheRoot" type="JSSFMRoot"/>
    </JadeMethod>
    <JadeMethod name="userNotification" id="5a12acbe-9f11-4084-88d7-1224331a9108">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// --------------------------------------------------------------------------------
// Created:		17 September 2002 by cnwdad2
//
// Purpose:		Handles notifications to stop the file copy.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theTA		: JSSFMTransactionAgent;
	progress	: String;
	
begin
	if eventType = self.EVENT_STOP_COPY then
		theTA	:=	app.myServiceObject.getTA();
		
		beginTransaction;
			self.isCancelled	:=	true;
			progress			:=	self.getOidString() &amp; "|" &amp; "Stopping...";
			self.causeEvent(self.EVENT_PROGRESS, false, progress);
		commitTransaction;
		
		app.doWindowEvents(0);
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</Class>
