    <JadeMethod name="validate" id="b4caf1d7-1093-4184-b94f-094dbf50c635">
        <updating/>
        <source>validate(_passport : CM_Passport input; pUserObject : Object; _cmif : CMIF_BookingRef) updating, protected;
// ---------------------------------------------------------------------------
// Created:     31 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
// 12/03/2010	cwwmh5		PAR22235 - Validate the discharge port
// 13/07/2011	cnwcs5		par 26557 - set myuserObject to receiver on errors/warnings
// 10/04/2015   cnwma1      PAR 35933 Vehicle Bookings - Release Requests
// 28/09/2016	cnwdap1		TFS 2652 STWR Tasks on bookings - can't complete a booking if any stops/tasks are outstanding
// 25/02/2019	jlgrs1		TFS 43312 - More Deadlocking in Multiuser EDI
// 28/05/2024	navdap1		TFS 64315 CUX - System Lock when creating bookings and prenotes via Booking and Cargo APIs
vars
	bookRefReal,
	existingRef			: CM_BookingRef;
	bItem				: CM_BookingRefItem;
	blnError			: Boolean;
	reason				: String;					// TFS 2652
begin
	self.raiseExceptionIfNotTransient(method);
	
	if self.bookingReference = null then
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(BookingRef), null, self);
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(BookingRef), null, self); // cnwdb2	PAR 35364
	endif;
	
	if self.bookingReference.pos(' ', 1) &gt; 0 then  //cnwma1 10/04/2015 PAR #35933
		app.raiseCMException1(VB_BAD_BOOKING_NO, self.bookingReference, null, self);
		return;
	endif;
	
	if self.operatorCode = null then																					//+cnwml2 PAR19846 CCMS SFW 1079
	//	app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Operator), null, self);								//+cnwml2 PAR19846 CCMS SFW 1079
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Operator), null, self);								// cnwdb2	PAR 35364
	endif;																												//+cnwml2 PAR19846 CCMS SFW 1079
		
	bookRefReal := self.pxyGetRealObject;
	if not app.isValidObject(bookRefReal) then
		bookRefReal := null;
	endif;
//	if CM_BookingRef.hasInstance(pUserObject) then // dh deleted this
// dh 20/8/2008 par 16344 (see also par 16916 &amp; 16820 )
// this was not working for a new booking ref where pUserObject was a CM_MenuAction, so try this
	if not CM_EDIBookingRefTI.hasInstance(pUserObject) then   // dh added this
		if CM_EDIBookingHeaderTI.hasInstance(pUserObject) then
			// TFS 64315 locked in the trx instead of here to avoid deadlocks
			/*if not self.tryLock(pUserObject.CM_EDIBookingHeaderTI.getMyTerminal.allBookingRefsByOperatorRef, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
				self.exclusiveLock(pUserObject.CM_EDIBookingHeaderTI.getMyTerminal.allBookingRefsByOperatorRef);
			endif;
			if not self.tryLock(pUserObject.CM_EDIBookingHeaderTI.getMyTerminal.allBookingRefsByRef, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
				self.exclusiveLock(pUserObject.CM_EDIBookingHeaderTI.getMyTerminal.allBookingRefsByRef);
			endif;
			if pUserObject.CM_EDIBookingHeaderTI.getVoyage &lt;&gt; null then
				if not self.tryLock(pUserObject.CM_EDIBookingHeaderTI.getVoyage.allBookingRefs, Exclusive_Lock, Transaction_Duration, LockTimeout_Server_Defined) then
					self.exclusiveLock(pUserObject.CM_EDIBookingHeaderTI.getVoyage.allBookingRefs);
				endif;
			endif;
			TFS 64315 end*/
		endif;
		existingRef := self.myTerminal.getBookingReference(self.operatorCode, self.bookingReference, self.myVoyage); // adn 150908 Par 17936
		if existingRef &lt;&gt; null and existingRef.myVoyage &lt;&gt; null and existingRef &lt;&gt; bookRefReal then			//+cnwml2 PAR24269
//			app.raiseCMException3(ERR_DUPLICATE_KEY, 'Booking Reference for', self.operatorCode &amp; " "&amp; self.bookingReference , null,'bookingReference', null);
			app.raiseCMException2(Booking_referenceDup, self.operatorCode &amp; " "&amp; self.bookingReference , null,'bookingReference', null);
			
			
		endif;
	endif;
	
	// 12/03/2010 cnwmh5 #22235
	self.validateDischargePort();
	
	self.validateHazardsOnBookingItems();
	
	//03 Sep 2009	NDL	CCMS 1609 Par 10521
	if CM_EDIBookingRefTI.hasInstance(pUserObject) then
		// not doing the warnings for event creation fo EDI trx.
	else
		// if there is a cmif, the proxy sub collection of bref items isn't populated or isn't populated with
		// the latest changes.
		self.validateBookingRefDiscrepEvent( _cmif );
	endif;
	
	// adm 070909 Par 20129
	self.validateCommodity();	
	
	self.validateTIHazards(); //epr CCMS 2280
	
	//CCMS MSL 1012	
	if self.isStockBookingRef then
		if self.allLinkedStockBookingItems.size &gt; 0 then
			app.raiseCMWarning(RemoveLinkedStockBookingItems, null, null, self);  //PAR 26622
		endif;
	else
		blnError := false;
		foreach bItem in self.allBookingRefItems do	
			if bItem.allLinkedExportBookings.size &gt; 0 then
				blnError := true;
			endif;
		endforeach;
		
		if blnError then
			app.raiseCMWarning(RemoveLinkedExpBookings, null, null, self);     //PAR 26622
		endif;
	endif;
	
	if bookRefReal &lt;&gt; null and bookRefReal.status &lt;&gt; BOOKING_REF_CLOSED and self.status = BOOKING_REF_CLOSED then	// TFS 2652
		foreach bItem in self.allBookingRefItems where bItem.myBookingRefItemActions &lt;&gt; null do						// TFS 2652
// TFS 4052			if not bItem.myBookingRefItemActions.areAllActionsComplete(reason) then									// TFS 2652
			if not bItem.myBookingRefItemActions.areAllActionsCompleted(reason) then									// TFS 4052
				app.raiseCMWarning2(Booking_cannot_closed, self.bookingReference, reason, null, null, null);		// TFS 2652
			endif;																									// TFS 2652
		endforeach;																									// TFS 2652
	endif;																											// TFS 2652
epilog
		
end;</source>
        <access>protected</access>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="pUserObject" type="Object"/>
        <Parameter name="_cmif" type="CMIF_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="validateBookingRefDiscrepEvent" id="77e1abc0-5543-4efb-ad30-eb72cb2897df">
        <source>validateBookingRefDiscrepEvent( _cmif : CMIF_BookingRef ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 September 2009	cnwndl1	Initial creation	CCMS 1609 Par 10521

*/

vars

	operator : CM_Operator;
	ti : CM_TrackedItem;
	proxyDiscrep : CMEVT_BookingRefDiscrep;
	warningText : String;
	localSet : CM_TISet;
	realBookingRef : CM_BookingRef;
	cmifBookRefItem : CMIF_BookingRefItem;
	bookRefItem : CM_BookingRefItem;
	
begin

	create localSet transient;

	if _cmif &lt;&gt; null then
		foreach cmifBookRefItem in _cmif.allCMIF_BRItems do
			bookRefItem := cmifBookRefItem.myRealBookingRefItem;
			if bookRefItem &lt;&gt; null then
				foreach ti in bookRefItem.allTIs do
					if not localSet.includes(ti) then
						localSet.add(ti);
					endif;
				endforeach;
			endif;
		endforeach;
	else
		if self.isTransient and self.allTIs.isEmpty then
			realBookingRef := self.pxyGetRealObject();
			if realBookingRef &lt;&gt; null then
				if not realBookingRef.allTIs.isEmpty then
					realBookingRef.allTIs.copy(localSet);
				endif;
			endif;
		else
			if not self.allTIs.isEmpty then
				self.allTIs.copy(localSet);
			endif;
		endif;
	endif;

	if localSet.isEmpty then
		return;
	endif;
	
	operator := self.myOperator;
	if operator = null or operator.allAttribForBookingRefDiscrep.isEmpty then
		//no attributes to check.
		return;
	endif;

	foreach ti in localSet do
	
		delete proxyDiscrep;
	
		create proxyDiscrep transient;
		if _cmif &lt;&gt; null then
			proxyDiscrep.setFromTiAndCmif(ti,_cmif);
		else
			proxyDiscrep.setFromTiAndBookingRef(ti,self,null);
		endif;
		
		if not proxyDiscrep.hasDiscrepancies then
			continue;
		endif;
		
		//see if we already have one showing the same differences
		if ti.getBookingRefDiscrepDuplicate( proxyDiscrep ) &lt;&gt; null then
			continue;
		endif;
	
		// if we have got to here, we will be generating a new Booking Reference Discrepancy,
		// so generate a warning.
		warningText := proxyDiscrep.getDescription;
	
		app.raiseCMWarning1(Book_refere_discrep_create, warningText, null, null, self);
		//we only want one.
		break;
		
	endforeach;
		
		
epilog

	delete proxyDiscrep;
	delete localSet;

end;</source>
        <access>protected</access>
        <Parameter name="_cmif" type="CMIF_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="validateBookingTIForPacking" id="4984247d-3eb3-4fff-b127-c1ff60db7187">
        <source>validateBookingTIForPacking(_ti: CM_TrackedItem; _errStr: String output);
/* ---------------------------------------------------------------------------
Created:	09 December 2010	by cnwvu1

Purpose:	
   
Change Date		Who		Reason
05/04/2023		navpw1	TFS: 56707 (56712) - Added more criteria for getting a Booking item
------------------------------------------------------------------------------*/
vars
	bookingItem		: CM_BookingRefItem;
	isNotMatching	: Boolean;
	iso 			: CM_ISOType;
	prodCode 		: String;
	reason			: String;  //05/04/2024	navkc1 Bug 63509
begin

	if _ti = null then
		return;	// no cargo to validate
	endif;
	
	//---------------------------------------------------------------------------
	//		checking Cargo Type, ISO Type and Product Code, i.e. Cargo Subtype
	//---------------------------------------------------------------------------
	// this code is similar to CM_BookingRef.getMatchingItemForTI(), except we don't need to check commodity for pack/unpack.
	if _ti.isKindOf(CM_Container) then
		iso :=  app.myRoot.allISOTypes[_ti.CM_Container.isoType];
	else
		iso := null;
	endif;
	if _ti.myProduct &lt;&gt; null then
		prodCode := _ti.myProduct.code;
	else
		prodCode := null;
	endif;
	
	bookingItem := self.getMatchingItem(_ti.myCargoType, null, iso, prodCode, _ti.mark, _ti.markNumber, _ti.getColour, _ti.purchaseOrder, _ti.serviceOrder, reason); // ### TFS 56707 (56712) 05Apr2023 NAVPW1
	
	if bookingItem = null then	// there is no matching booking ref item. Need to display warning.
		_errStr := app.getErrorString2(Mismatch_booking_ti_CargoType, self.bookingReference, _ti.id);
	endif;
	
	
	//---------------------------------------------------------------------------
	//				checking Operator, Voyage and Ports
	//---------------------------------------------------------------------------
	if (self.myOperator &lt;&gt; null) and (self.myOperator &lt;&gt; _ti.myOperator) then
		isNotMatching := true;
	endif;

	if not isNotMatching then
		if (self.myVoyage &lt;&gt; null) and (self.myVoyage &lt;&gt; _ti.myVoyage) then
			if self.myVoyage.isNullVoyage() then							// if null voyage on booking - it is ok, i.e. booking matches ti
			elseif (_ti.myVoyage = null) or (_ti.myVoyage.isNullVoyage()) then// if null voyage on container - it is ok, i.e. booking matches ti
			else
				isNotMatching := true;
			endif;
		endif;
	endif;
	
	if not isNotMatching then
		if (self.destinationPort &lt;&gt; null) and (self.destinationPort &lt;&gt; self.destinationPort) then
			isNotMatching := true;
		endif;
	endif;
	
	if not isNotMatching then
		if (self.dischargePort &lt;&gt; null) and (self.dischargePort &lt;&gt; _ti.dischargePort) then
			isNotMatching := true;
		endif;
	endif;

	
	// construct errStr to be displayed later
	if isNotMatching then
		if _errStr &lt;&gt; null then
			_errStr := _errStr &amp; CrLf;
		endif;
		_errStr := _errStr &amp; app.getErrorString2(Mismatch_booking_ti_fields, self.bookingReference, _ti.id);
	endif;

	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_errStr" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="validateCommodity" id="e1e2163a-da27-430e-83ae-307d0390edc0">
        <updating/>
        <source>validateCommodity() updating,protected;

vars
	tmpCommodity	: CM_Commodity;

begin
	// cnwrl1 29/10/2010 PAR 26152
	if self.commodity = null then
		return;
	endif;
	
	// If a commodity has been entered then it must exist in the system (eg in EDI can just enter any old value).
	self.commodity	:= self.commodity.toUpper();
	tmpCommodity	:= app.myRoot.allCommodities[ self.commodity ];
	
	if tmpCommodity = null then
		app.raiseCMWarning1(ERR_INVALID_COMMODITY, self.commodity, app.getString( Commodity ), self, self);	//par26681 cnwrs1 29 Decd 2010
		return;
	endif;
	
	// found one but must also be available to be used.
	if tmpCommodity.isNotAvailableForEntry then
		// The users (in particular CentrePort) want an error not a warning as warning often get missed.
		app.raiseCMWarning1(Commodity_available_entry, self.commodity, app.getString( Commodity ), self, self);	//par26681 cnwrs1 29 Decd 2010
	endif;
	
	// Need to make sure the commodity contains the relevant cargo type.
	if tmpCommodity.allCargoTypes[ self.cargoType ] = null
	and self.myCargoType &lt;&gt; null and self.myCargoType.isCommodityRequired then		//cnwmc5 - 18 Feb 2016 - PAR 37522
		app.raiseCMWarning2(CargoType_NotValid4_Commodity, self.cargoTypeDescr, self.commodity, ETRow_CargoTypeDescr, self, self);	//par26681 cnwrs1 29 Decd 2010
	endif;
	// cnwrl1 29/10/2010 PAR 26152 - end of coding
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateDischargePort" id="fb3ed0c5-bf1c-46c6-ad10-2deef0d38abe">
        <source>validateDischargePort() protected;
/*
Date			Who		Reason
12 March 2010	cnwmh5	Initial creation
14/07/2011		cnwcs5	par 26557 - set myUserObject for the error
*/
vars

begin
	if self.myVoyage &lt;&gt; null
	and self.dischargePort &lt;&gt; null
	and not self.myVoyage.isNullVoyage //19 May 2021	NDL	TFS 50897
	and not self.myVoyage.allPorts.includes(app.myRoot.allPorts[self.dischargePort])
	then
		app.raiseCMWarning2(DISCH_PORT_NO_LONGER_VALID, self.dischargePort, self.myVoyage.code, 'dischargePort', self, self);
	endif;
	
	// 27/11/2014 cnwar2 #32661
	if self.dischargePort = self.myTerminal.getConfig(PortDestCode).String then
		app.raiseCMWarning2(ERR_INVALID_PORT_SELF, 'discharge', self.dischargePort, 'dischargePort', self, self);
	endif;
		
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="5ba2a112-562a-4560-91c1-764d0ec84220">
        <updating/>
        <source>validateForCreate(_passport : CM_Passport input; pUserObject : Object; _cmif : CMIF_BookingRef)updating;
// ---------------------------------------------------------------------------
// Created:     31 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 10/7/2006 NDC1 cnwsh3 7.4.2 	Previously no validation for operator or id 
//							so dup key error occurred when adding and clicking save straight away.
// 08/02/2010		cnwcs5	par 22672 - validate booking items
// ---------------------------------------------------------------------------
vars
	item	:CM_BookingRefItem;
begin
	self.raiseExceptionIfNotTransient(method);
	
	self.validate(_passport, pUserObject, _cmif);
	
	// par 22762 - start
	foreach item in self.allBookingRefItems do
		if item.pxyGetRealObject = null then
			item.validateForCreate (_passport, self.myTerminal);
		else
			item.validateForUpdate (_passport, self.myTerminal);
		endif;
	endforeach;
	// par 22762 - end
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="pUserObject" type="Object"/>
        <Parameter name="_cmif" type="CMIF_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="54276b7f-aa46-403f-bc89-3b83098af0fb">
        <source>validateForDelete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
// 27/06/2018	cnwma1		Bug 39441: Getting 1090 when searching for work orders

*/

vars

begin
	if self.allWorkOrderSources.size &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, self.bookingReference,app.getErrorString(WorkOrder), null, null);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="c4487a2e-e8eb-46e7-bcae-ede6effa1131">
        <updating/>
        <source>validateForUpdate(_passport : CM_Passport input; pUserObject : Object; _cmif : CMIF_BookingRef) updating;
// ---------------------------------------------------------------------------
// Created:     31 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/02/2010	cnwcs5		par 22762 - validate booking items
// ---------------------------------------------------------------------------
vars
	proxyTI		: CM_TrackedItem;
	updCntrl	: CMIF_TIUpdateController;
	item		: CM_BookingRefItem;
begin

	self.raiseExceptionIfNotTransient(method);
	self.validate(_passport, pUserObject, _cmif);
	
	// par 22762 - start
	/* 28159 Mar 2012 only do this for create not update - it is validating the existing booking just before updating it
	//	 waste of time at best, causes unwanted errors at worst - 
	//   reported problem was old commodity not longer available for entry
	foreach item in self.allBookingRefItems do
		if item.pxyGetRealObject = null then
			item.validateForCreate (_passport, pUserObject);
		else
			item.validateForUpdate (_passport, pUserObject);
		endif;
	endforeach;
	// par 22762 - end
	*/
	
	//cnwjo3 ccms 1039 par 22315
	self.validateRestrictedFields();
	

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="pUserObject" type="Object"/>
        <Parameter name="_cmif" type="CMIF_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="validateHazardsOnBookingItems" id="15b4961e-c1f9-4400-855c-3f2e0b8992a0">
        <source>validateHazardsOnBookingItems() protected;
/*

Purpose:  check if hazard items exist on the booking items but not on the booking			

Parameters:			

Return Value:		


Date		Who		Reason
15 September 2008	cnwer1	Initial creation

*/

vars
	iter : Iterator;
	cmHazBookingItem : CM_BookingRefItem;
	tiHazard : CM_TIHazard;
begin
	if not app.myPassport.myTerminal.getConfig(UseBookingSummView).Boolean then
		return;
	endif;
		
	foreach cmHazBookingItem in self.allBookingRefItems discreteLock do
		delete iter;
		iter:=cmHazBookingItem.allTIHazards.createIterator;
		while iter.next(tiHazard) do
			if self.allTIHazards[tiHazard.code] = null then
				app.raiseCMWarning1(WARN_HAZ_REMOVE_BOOKING,tiHazard.code,"Hazards",null,null);
				return;
			endif;
		endwhile;	
	endforeach;
epilog
	delete iter;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateRestrictedFields" id="b5c447eb-5224-4f9a-8a89-11050359a3d3">
        <source>validateRestrictedFields() protected;
// --------------------------------------------------------------------------------
// Created:		11 February 2010 by cnwjo3
//
// Purpose:		If Restrictions have been set for the users security roles and for the tis operators then
//				raise error.  CCMS 1039 PAR 22315, cnwjo3
//
vars
	realObj : CM_BookingRef;
	operatorName : String;
	operatorCode : String;
begin
	if self.isTransient then
		realObj := app.myProxyManager.getRealObject(self).CM_BookingRef;
	else
		realObj := self;
	endif;

	if realObj = null then
		return;  //ops, this is some crazy proxy thing.  Can't restrict here!
	endif;
	
	if realObj.myOperator = null then
		return;  //oops, no operator.  Can't retrict operators when no operator
	endif;	
	
	if self.restrictCargoBookingUpdates(self.myTerminal,realObj.myOperator) then
		operatorName := realObj.myOperator.description;
		operatorCode := realObj.myOperator.code;
		//Booking Reference
		if realObj.bookingReference &lt;&gt; self.bookingReference then
			app.raiseCMException2(ERR_RESTRICTIONS_BR,operatorName,operatorCode,null,self);	
		endif;
		//Voyage
		if realObj.voyageCode &lt;&gt; self.voyageCode then
			app.raiseCMException2(ERR_RESTRICTIONS_VC,operatorName,operatorCode,null,self);	
		endif;
		//Operator
		if realObj.myOperator.code &lt;&gt; self.myOperator.code then  //for some reason operatorCode is updated in real before validation occurs.  don't know why... using myOperator.code instead
			app.raiseCMException2(ERR_RESTRICTIONS_Op,operatorName,operatorCode,null,self);	
		endif;
		//Port Of Discharge
		if realObj.dischargePort &lt;&gt; self.dischargePort then
			app.raiseCMException2(ERR_RESTRICTIONS_DisPort,operatorName,operatorCode,null,self);	
		endif;
		//Destination
		if realObj.destinationPort &lt;&gt; self.destinationPort then
			app.raiseCMException2(ERR_RESTRICTIONS_DestPort,operatorName,operatorCode,null,self);	
		endif;
	else
		return;  //just for cleanness
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateTIHazards" id="52596ebb-0ded-4d97-a0c5-5fecb3dbaffb">
        <source>validateTIHazards() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 April 2013	cnwer1	Initial creation CCMS 2280

*/

vars
	haz : CM_Hazard;
begin

	foreach haz in self.allTIHazards discreteLock do
		haz.validateTIHazard(self.myTerminal);
	endforeach;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="vesselCode" id="c603fc69-d56c-4af9-8d8d-e42a6579b93c">
        <methodInvocation>mapping</methodInvocation>
        <source>vesselCode(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:     30 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	_value := null;

	if self.myVoyage = null then
		return;
	endif;

	_value := self.myVoyage.vesselCode;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
