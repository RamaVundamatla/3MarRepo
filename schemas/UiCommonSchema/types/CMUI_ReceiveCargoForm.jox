    <JadeMethod name="initFieldsForEntDefName" id="91418423-15ec-4170-9bc9-08f26ca28c89">
        <updating/>
        <source>initFieldsForEntDefName(_theEntDef: String; _setFocus: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/03/2014	cnwndl1	Initial creation	Par 33596
30/07/2015	cnwdap1	PAR #36421 Hazardous Materials Handling
16/07/2022	navmd1	TFS 52777 Tidy up/review code
*/

vars
	cargoType : CM_CargoType;

begin
	self.currentEntTableDef := _theEntDef;						// PAR #36421
	
	inheritMethod(_theEntDef, _setFocus);
	
	cargoType := self.cmbType.getObject().CM_CargoType;
	self.setNumItemsCaptionAndEnabled( cargoType );
	
	// restore seal control values
	self.restoreSealControlValues();	// TFS 52777

epilog

end;</source>
