    <JadeMethod name="updateVoyJobStatus" id="40ed7f79-29df-4bdc-a637-d12fbc2e05f5">
        <source>updateVoyJobStatus();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
*/

vars
	job 	: CM_VoyageWorkPointJob;
	woJob	: CM_WorkOrderJob;
	jobArr	: CM_JobArray;
	wle		: CM_WorkListEntry;
begin
	jobArr := self.job.getAllVoyJobs();
	
	if jobArr &lt;&gt; null and jobArr.isNotEmpty() then
		foreach job in jobArr as CM_VoyageWorkPointJob do
			job.completeWLE(null);
		endforeach;
	endif;
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="updateWOJobStatus" id="e8002cb0-7291-4a15-b71b-5ffc59049e63">
        <source>updateWOJobStatus();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Jun 2023 navma1  ChangeRequest 58339: EUP | Delivery Dispatch Screen - Road Operation
18 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
05 Mar 2024 navhl20 Bug 62758: EUP | FR | Work Order status - complete without loading all items
11 Mar 2024 navhl20 Bug 62868: EUP - Ship job status not updating with correct status
*/

vars
	woWle		   : CM_WorkListEntry;
	wod			   : CM_WorkOrderTIDtl;
	woJob		   : CM_Job;
begin
	woWle := self.myWorkOrderWLE;
	
	if woWle &lt;&gt; null then
		woJob := woWle.job;
		if woJob &lt;&gt; null then
			woJob.updateStatus();
			if woJob.status = WLE_COMPLETED then
				wod:= woJob.myWODtl;
				if wod &lt;&gt; null then
					wod.completeMe();
				endif;
			endif;
		endif;
	endif;
	
	//if self.isKindOf(CM_VoyageWorkPointJob) then	//05.03.2024 navhl20 #62758
	if self.job.isShipJob() then				//11.03.2024 navhl20 #62868
		self.updateVoyJobStatus();				//18.12.2023 navhl20 #58400[61617]
	endif;
epilog

end;</source>
    </JadeMethod>
