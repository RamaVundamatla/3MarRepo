vars

begin
	self.dsl.machineLogon(self.myMachine);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="moving" id="fdaa8a54-a0f2-469f-abe1-5a0898e120d1">
        <updating/>
        <source>moving() updating;

vars

begin
	self.movingUntil := self.getCurrentTime.addSeconds(self.minTravelTime + app.random(self.maxTravelTime - self.minTravelTime));
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="work" id="a9dfeaf7-a77d-4be3-b8c8-ecdbb5dd4ffd">
        <updating/>
        <source>work() updating;

vars
begin
	if self.isMoving() then
		self.logMessage(LOG_FULL, "Work " &amp; self.getMachineId &amp; " isMoving until " &amp; self.movingUntil.asStringForWebInterface);
		return;
	elseif self.isIdle() then
		self.logMessage(LOG_FULL, "Work " &amp; self.getMachineId &amp; " isIdle");
		self.doAccept(self.getWork());
		return;
	elseif self.isTaskReadyForPickup() then
		self.logMessage(LOG_FULL, "Work " &amp; self.getMachineId &amp; " isReadyForPickup");
		self.doPickup();
		return;
	elseif self.isTaskReadyForSetdown() then
		self.logMessage(LOG_FULL, "Work " &amp; self.getMachineId &amp; " isReadyForSetdown");
		self.doSetdown();
		return;
	else
		self.logMessage(LOG_FULL, "Work " &amp; self.getMachineId &amp; " waiting");
	endif;
epilog

end;</source>
    </JadeMethod>
</Class>
