    <JadeMethod name="isISOType" id="3463af4a-f2f7-4997-8e5f-8f5863d67236">
        <source>isISOType() : Boolean;
//------------------------------------------------
// Created: 18 April 2006 By: cnwgd1
//------------------------------------------------
vars

begin
	if self.id = TI_CargoType_COU
	or self.id = TI_CargoType_Container
	or self.id = TI_CargoType_Generator
	or self.id = TI_CargoType_LCL then
		return true;
	else
		return false;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSystemCargoBOLType" id="a1e5eb4e-efd7-4aa5-a688-5637e0e454fd">
        <methodInvocation>mapping</methodInvocation>
        <source>isSystemCargoBOLType(set: Boolean; _value: Boolean io) mapping;
// ---------------------------------------------------------------------------
// Created:     16 October 2002		cnwth2	
//
// Purpose:     
//			 
// Changed On	By			Reason
// ----------   ----------  --------------------------------------------------
// 19/03/2014	cnwdap1		PAR #33606 CCMS SFW 1366 Bulk - Car and Chassis are no longer system cargo types
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	//if self.id &lt;= TI_CargoBOLType_Max then																	// PAR #33606
	if self.id &lt;= TI_CargoBOLType_Max and self.id &lt;&gt; TI_CargoType_Car and self.id &lt;&gt; TI_CargoType_Chassis then	// PAR #33606
		_value := true;
	endif;
	
	

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
