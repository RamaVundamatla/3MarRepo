    <JadeMethod name="setupControls" id="30809ad4-dda4-465a-9689-a26d724498e3">
        <updating/>
        <source>setupControls() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 15/07/2014	cnwdap1		Initial creation PAR #34568 CCMS SFW 1389 Alternative Id Cargo Check
//
vars

	top 		: Real;
	stdWidth 	: Real;
	stdHeight 	: Real;

begin

	self.setResizeableMarginAndFontSize();
	
	top := self.resizedMargin;
	stdWidth := self.width - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;

	self.lblAlternativeId.visible := true;
	self.lblAlternativeId.move(self.resizedMargin,	top, stdWidth, stdHeight);
					 
	top := lblAlternativeId.top + lblAlternativeId.height + self.resizedMargin;
	self.txtAlternativeId.visible := true;
	self.txtAlternativeId.move(self.resizedMargin, top, stdWidth - self.resizedMargin, stdHeight);
	if self.myTrackedItem &lt;&gt; null then
		self.txtAlternativeId.text := self.myTrackedItem.alternativeId;
	endif;
	
	top := self.txtAlternativeId.top + self.txtAlternativeId.height + self.resizedMargin;
	self.chkToDo.move(self.resizedMargin, top, ((stdWidth * 2) / 3), stdHeight);
	
	self.doResizeControls(true);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="367fa4e0-377b-42a4-80a9-f9a9faf1e7e0">
        <updating/>
        <source>setupForm() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 15/07/2014	cnwdap1		Initial creation PAR #34569 CCMS SFW 1389 Alternative Id Cargo Check
//
vars

begin
	self.myTrackedItem := self.myMobileGenericAgent.myNextTiToAction;
	app.myMobileAgent.setMyProxy( self.myTrackedItem );
	app.myMobileAgent.setMySelectedTI(self.myTrackedItem);
	
	inheritMethod();

	self.setupCmdButtons( 2, app.getErrorString(Save), BACK_BUTTON, null, null, null );
	
	self.setupControls();
	self.setupInputs();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupInputs" id="fc4ef197-6ab0-4768-9fe3-065d6c22523a">
        <updating/>
        <source>setupInputs() protected, updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 15/07/2014	cnwdap1		Initial creation PAR #34568 CCMS SFW 1389 Alternative Id Cargo Check
//
vars
	cargoCheck	: CM_CargoCheck;
	item 		: CM_CargoCheckItem;
	toDo		: CM_ToDoTask;

begin
	self.chkToDo.visible := false;
	cargoCheck := self.myMobileGenericAgent.getEquipCheckContextFromState();
	if cargoCheck &lt;&gt; null then
		foreach item in cargoCheck.allCargoCheckItems discreteLock where item.requiredExtraInfo = EXTRA_INFO_ALTERNATIVE_ID do
			if item.myToDoTaskDesc &lt;&gt; null then
				self.myCargoCheckItem := item;
				self.chkToDo.visible := true;
				self.chkToDo.caption := item.myToDoTaskDesc.description;
				if self.myTrackedItem &lt;&gt; null then
					foreach toDo in self.myTrackedItem.allToDoTasksToDo where toDo.toDoTaskDescCode = item.myToDoTaskDesc.code do
						self.chkToDo.value := true;
						break;
					endforeach;
				endif;
			endif;
		endforeach;
	endif;
		
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="4754dbf5-10e1-4ffb-8e21-8334aedc1617">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 31 July 2014.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019763, locale);
	chkToDo.translateCaption(Xlat_0019764, locale);
	lblAlternativeId.translateCaption(Xlat_0019765, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtAlternativeId_lostFocus" id="4b30199e-4372-48e0-a553-bf9c32934911">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtAlternativeId_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 July 2016	cnwndl1	Initial creation

*/

vars

begin

	app.convertScannedCargoId( self.myTerminal, textbox, true, null );	//06 Jul 2016	NDL	TFS 2275

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
</GUIClass>
