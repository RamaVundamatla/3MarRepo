    <JadeMethod name="getSuggestedCode" id="5a8090bb-c77f-4afa-bf34-e50990ecd23e">
        <source>getSuggestedCode() : String;
/*
----------   ----------  --------------------------------------------------
Created:	09 August 2007 By cnwth2

Purpose:	Returns 5 character code best guess for the _description passed in

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
constants
	MinLength = 3;
	MaxLength = 5;
	
vars
	words		: StringArray;
	workDescr,
	alphaChar,
	outputCode,
	word		: String;
	
	idx,
	charsPerWord,
	len,
	pos			: Integer;
	
begin
	workDescr := self.trimBlanks.toUpper;
	if workDescr = null then
		return null;
	endif;
		
	//snap off words
	create words transient;
	len := workDescr.length;
	pos := 1;
	while pos &lt;= len do
		word := workDescr.getNextToken(pos).toUpper;
	
		if word &lt;&gt; null then
			words.add(word);
		endif;
	endwhile;
	
	if words.isEmpty then//should never happen given above code, but avoids division by zero below nonetheless
		return null;
	endif;
	//work out an appropriate number of chars to use from each word
	if words.size &gt;= MaxLength then
		charsPerWord := 1;
	else
		charsPerWord := (MaxLength / words.size).roundedUp.Integer;
	endif;
	//build up the code
	foreach word in words do : wordLoop
		pos := 1;
		foreach idx in 1 to charsPerWord do : charLoop
			//if looking at the first char of the word, then a vowel is fine, otherwise skip them (second param below)
			alphaChar := word.getAlphaCharAfterPos(pos, (pos &gt; 1));
			if alphaChar = null then
				continue wordLoop;
			endif;
			outputCode := outputCode &amp; alphaChar;
			if outputCode.length &gt;= MaxLength then
				break wordLoop;
			endif;
		endforeach;
	endforeach;
	
	if outputCode.length &lt; MinLength then
		return null;
	endif;
	
	return outputCode;
	
epilog
	delete words;
end;


</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTokensForDelimiter" id="1adc0beb-a84b-4279-b059-befad8169ba8">
        <source>getTokensForDelimiter(_delimiter : String; _array : StringArray input);
// ---------------------------------------------------------------------------
// Created:     01 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
03 Dec 2008	cnwkpd1	PAR #17554 - Changes for JMT RIA Application
					Changed the delimiter from Character to String 
					
*/

vars
	theStr,
	theToken	: String;
	pos,
	theLen		: Integer;

begin

	theStr := self;

	if theStr = null or _delimiter = null then
		return;
	endif;
	
	theLen := theStr.length;

	pos := 1;
	while (pos &gt; 0) do
		theToken := theStr.scanUntil(_delimiter, pos);  // Outputs this
		_array.add(theToken);
		if pos = 0 then
			break;
		endif;
		pos := pos + 1;
		if pos &gt; theLen then
			// last character must be a delimiter so
			// add null entry for the last item
			_array.add(null);
			break;
		endif;
	endwhile;
	
end;</source>
        <Parameter name="_delimiter" type="String"/>
        <Parameter name="_array" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTokensForDelimiterHuge" id="546eb5c5-7805-4aea-929e-8e450167c2e9">
        <source>getTokensForDelimiterHuge(_delimiter : String; _array : HugeStringArray input);
/*

Purpose:			A new version of the "getTokensForDelimiter" method, but using a
					HugeStringArray instead.

Parameters:			Delimiter(s) to use to split receiver

Return Value:		Array is populated with tokens

Date		Who		Reason
21 Jun 2005	cnwdad1	
27 Nov 2014	cnwkpd1	PAR #35261 - Rationalisation of all getTokens methods in preparation 
					for JADE 7.1

*/

vars
	theStr,
	theToken	: String;
	pos,
	theLen		: Integer;

begin
	theStr	:=	self;

	if theStr = null or _delimiter = null then
		return;
	endif;
	
	theLen	:=	theStr.length();
	pos		:=	1;
	
	while (pos &gt; 0) do
		theToken	:=	theStr.scanUntil(_delimiter, pos);  // Outputs this
		_array.add(theToken);
		
		if pos = 0 then
			break;
		endif;
		
		pos	:=	pos + 1;
		
		if pos &gt; theLen then
			// last character must be a delimiter so
			// add null entry for the last item
			_array.add(null);
			break;
		endif;
	endwhile;
end;</source>
        <Parameter name="_delimiter" type="String"/>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTokensForDelimiterHugeNoNul" id="28df19f6-d8fb-484e-88e1-0117c6527cb6">
        <source>getTokensForDelimiterHugeNoNul(_delimiter : String; _array : HugeStringArray input);

/*

Purpose:		same as getTokensForDelimiterHuge but with no enbeded nulls in the array	

Parameters:			

Return Value:		


Date		Who		Reason
12 May 2010	cnwrd1	Initial creation
27 Nov 2014	cnwkpd1	PAR #35261 - Rationalisation of all getTokens methods in preparation 
					for JADE 7.1

*/


vars
	theStr,
	theToken	: String;
	pos,
	theLen		: Integer;

begin
	theStr	:=	self;

	if theStr = null or _delimiter = null then
		return;
	endif;
	
	theLen	:=	theStr.length();
	pos		:=	1;
	
	while (pos &gt; 0) do
		theToken	:=	theStr.scanUntil(_delimiter, pos);  // Outputs this
		
		if theToken &lt;&gt; null then
			_array.add(theToken);
		endif;
		
		if pos = 0 then
			break;
		endif;
		
		pos	:=	pos + 1;
		
		if pos &gt; theLen then
			break;
		endif;
	endwhile;
end;</source>
        <Parameter name="_delimiter" type="String"/>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTokensHugeTruncate" id="d7869d40-09ca-4dc7-987a-f55b23bc8100">
        <source>getTokensHugeTruncate(_delimiter : String; _array : HugeStringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 April 2018	jlgndl1	Initial creation	TFS 38135

*/

vars
	theStr,
	theToken	: String;
	pos,
	theLen		: Integer;
	
	maxLength : Integer;
	truncLength : Integer;

begin

	maxLength := _array.getMaxLength;
	truncLength := maxLength - 4;
	
	theStr	:=	self;

	if theStr = null or _delimiter = null then
		return;
	endif;
	
	theLen	:=	theStr.length();
	pos		:=	1;
	
	while (pos &gt; 0) do
		theToken	:=	theStr.scanUntil(_delimiter, pos);
		
		if theToken &lt;&gt; null then
			if theToken.length &gt; maxLength then
				theToken := theToken[1:truncLength] &amp; "...";
			endif;
			_array.add(theToken);
		endif;
		
		if pos = 0 then
			break;
		endif;
		
		pos	:=	pos + 1;
		
		if pos &gt; theLen then
			break;
		endif;
	endwhile;
end;</source>
        <Parameter name="_delimiter" type="String"/>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTrailingInteger" id="abf7c72d-6b98-4b84-9463-1e59a9f55546">
        <source>getTrailingInteger() : Integer;
//--------------------------------------------------------------
//Created: 03 May 2002 By: cnwgd1
//--------------------------------------------------------------
constants
	MaxInteger = 2147483647;

vars
	pos		: Integer;
	numStr,
	revStr	: String;
	tempDec	: Real ;//Decimal[23,0];

begin

	revStr := self.reverse();
	pos := 1;
	numStr := revStr.scanWhile('0123456789', pos);

	if numStr = null then
		return -1;
	endif;

	numStr := numStr.reverse();

	tempDec := numStr.Decimal;
	while tempDec &gt; MaxInteger do
		numStr := numStr[2:end];
		tempDec := numStr.Decimal;
	endwhile;
	
	return numStr.Integer;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTrailingIntegerString" id="3a656e4b-471f-4a6d-acf3-7c8259f3f150">
        <source>getTrailingIntegerString() : String;
//--------------------------------------------------------------
//Created: 03 May 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	pos		: Integer;
	numStr,
	revStr	: String;

begin

	revStr := self.reverse();
	pos := 1;
	numStr := revStr.scanWhile('0123456789', pos);
	
	revStr := numStr.reverse();
	return revStr;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTrimedTokensForDelimiter" id="447794c0-b994-4bfc-be52-63b355935665">
        <source>getTrimedTokensForDelimiter(_delimiter : String; _array : StringArray input);
// ---------------------------------------------------------------------------
// Created:     18 Mar 2009 by cnwdz2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
18 Mar 2009	cnwdz2	PAR #17554 - Changes for JMT RIA Application
					PAR 19178 Blanks are trimed out from each token 
					
*/

vars
	theStr,
	theToken	: String;
	pos,
	theLen		: Integer;

begin

	theStr := self;

	if theStr = null or _delimiter = null then
		return;
	endif;
	
	theLen := theStr.length;

	pos := 1;
	while (pos &gt; 0) do
		theToken := theStr.scanUntil(_delimiter, pos);  // Outputs this
		theToken := theToken.trimBlanks();
		_array.add(theToken);
		if pos = 0 then
			break;
		endif;
		pos := pos + 1;
		if pos &gt; theLen then
			// last character must be a delimiter so
			// add null entry for the last item
			_array.add(null);
			break;
		endif;
	endwhile;
	
end;</source>
        <Parameter name="_delimiter" type="String"/>
        <Parameter name="_array" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getUNEDIFACTTimeStamp" id="a1525429-fffe-421b-a8c7-b574a99f7d3b">
        <source>getUNEDIFACTTimeStamp(_format:Integer) : TimeStamp;

// cnwrs1 nov 2005 

vars

//	dateStr,
//	timeStr,
	yearStr			: String;
	dateResult		: Date;
	timeResult		: Time;
	timeStampResult	: TimeStamp;
	yearInt			: Integer;
	
begin

	dateResult := null;
	timeResult := null;
	if _format = 101 then //YYMMDD
		if self.length &lt;&gt; 6 then
			return null;
		endif;
		yearStr := self[1:2];
		if yearStr.Integer &gt; 90 and yearStr.Integer &lt; 100 then
			yearInt := 1900 + yearStr.Integer;	
		elseif yearStr.Integer &lt; 90 then
			yearInt := 2000 + yearStr.Integer;
		else
			yearInt := yearStr.Integer;
		endif;
		dateResult.setDate(self[5:2].Integer, self[3:2].Integer, yearInt);
	elseif _format = 102 then //CCYYMMDD
		if self.length &lt;&gt; 8 then
			return null;
		endif;
		dateResult.setDate(self[7:2].Integer, self[5:2].Integer, self[1:4].Integer);
	elseif _format = 203 then //CCYYMMDDHHMM
		if self.length &lt;&gt; 12 then
			return null;
		endif;
		dateResult.setDate(self[7:2].Integer, self[5:2].Integer, self[1:4].Integer);
		timeResult.setTime(self[9:2].Integer, self[11:2].Integer, 0, 0);
	elseif _format = 204 then //CCYYMMDDHHMMSS
		if self.length &lt;&gt; 14 then
			return null;
		endif;
		dateResult.setDate(self[7:2].Integer, self[5:2].Integer, self[1:4].Integer);
		timeResult.setTime(self[9:2].Integer, self[11:2].Integer, self[13:2].Integer, 0);
	elseif _format = 401 then //HHMM
		if self.length &lt;&gt; 4 then
			return null;
		endif;
		timeResult.setTime(self[1:2].Integer, self[3:2].Integer, 0, 0);
	else	//unknown format return null
		return null;
	endif;
		
	if dateResult.isValid then
		timeStampResult.setDate(dateResult);
	endif;
	
	if timeResult.isValid then
		timeStampResult.setTime(timeResult);
	endif;

	if timeStampResult.isValid then
		return timeStampResult;


	else
		return null;
	endif;
end;
</source>
        <Parameter name="_format" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getWeightedAsciiValue" id="2202639f-ec7d-45ad-b4bf-66d5db82a733">
        <source>getWeightedAsciiValue() : Integer;
// ---------------------------------------------------------------------------
// Created:     30 September 2002 by cnwrs2
//
// Purpose:     Returns an integet with the ascii value of each char multipled by
//				its position in the string
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	rtnValue,
	max,
	idx		: Integer;

begin

	max := self.length;
	if max = 0 then
		return rtnValue;
	endif;

	foreach idx in 1 to max do
		rtnValue := rtnValue + (idx * self[idx].Integer);
	endforeach;

	return rtnValue;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getWords" id="61ccee29-bf11-4385-8232-51aa74e7e0bb">
        <source>getWords(array : StringArray input);
	// Parses a string adding words to an array. 

constants
	Chars = "-0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ_abcdefghijklmnopqrstuvwxyz";

vars
	idx : Integer;
	word : String;

begin
	if length = 0 then
		return;
	endif;

	idx := 1;
	while idx &gt; 0 do
		scanUntil(Chars, idx);
		if idx = 0 then
			break;
		endif;
		word := scanWhile(Chars, idx);
		array.add(word);
	endwhile;
end;</source>
        <Parameter name="array" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getWordsAsUpperCase" id="7967453f-369b-49ba-ab66-53a43b805e13">
        <source>getWordsAsUpperCase(array : StringArray input);
	// Parses a string adding words (converted into uppercase) to an array. 

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 September 2009	cnwndl1	Initial creation

*/

constants
	Chars = "-0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ_abcdefghijklmnopqrstuvwxyz";

vars
	idx : Integer;
	word : String;

begin
	if length = 0 then
		return;
	endif;

	idx := 1;
	while idx &gt; 0 do
		scanUntil(Chars, idx);
		if idx = 0 then
			break;
		endif;
		word := scanWhile(Chars, idx);
		array.add(word.toUpper);
	endwhile;
end;</source>
        <Parameter name="array" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="handleEscapeChar" id="38041d4e-f4dc-4fd4-8041-a544344a6da0">
        <source>handleEscapeChar(_escapeChar:Character; _startPos:Integer):String;
// --------------------------------------------------------------------------------
// Created:		08 November 2010
//
// Purpose:		Taking the specified escape character, re-build the receiver into a
//				new string.
//
// Parameters:	_escapeChar - The excape character.
//				_startPos - The character position to start from.
//
// Returns:		The processed string, or null.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//				cnwdad1		Initial creation.
// --------------------------------------------------------------------------------
vars
	workLen		: Integer;
	escapePos	: Integer;
	charPos		: Integer;
	workStr		: String;
	startStr	: String;
	endStr		: String;
	
begin
	if _escapeChar = null then
		return null;
	endif;
	
	escapePos	:=	_startPos;
	workStr		:=	self;
	
	while true do
		escapePos	:=	workStr.pos(_escapeChar, escapePos);
		
		if escapePos = 0 then
			break;
		endif;
		
		if escapePos &gt; 1 then
			startStr	:=	workStr[1:escapePos - 1];
		endif;
		
		workLen	:=	workStr.length();
		
		if workLen &gt; escapePos then
			if workStr[escapePos + 1:1].trimBlanks() = null then
				charPos	:=	escapePos + 1;
			else
				charPos :=	escapePos + 2;
			endif;
			
			if charPos &lt;= workLen then
				endStr	:=	workStr[charPos:end];
			else
				endStr	:=	null;
			endif;
		else
			endStr	:=	null;
		endif;
		
		workStr	:=	startStr &amp; endStr;
	endwhile;
	
	return workStr;
end;</source>
        <Parameter name="_escapeChar" type="Character"/>
        <Parameter name="_startPos" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasInvalidChars" id="353aaaf3-d69d-4584-835d-a19999c38aa3">
        <source>hasInvalidChars() : Boolean;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 12 March 2007
//
//  Basic check to see if the receiver contains any of the characters that have been passed in.
//  If one of the characters exists then the str will be different when compared.
//
//----------------------------------------------------------------------

vars
	str2 	: String;
	pos 	: Integer;
begin
	pos := 1;
	str2 := self.scanUntil(InvalidCharSet, pos);
	
	//The resultant string is different to how it was passed in so there must be an invalid char there somewhere.
	if str2 = self then
		return false;
	endif;
	
	//Nope, couldn't find any of the chars.
	return true;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasInvalidChars2" id="69b08874-a4ba-4e65-942f-df16b58498d3">
        <source>hasInvalidChars2() : Boolean;
//
// 16 Jan 2017	cnwrs1	TFS 3221 - have a invaliDcharacter list that allows full stop and forward slash
//
vars
	str2 	: String;
	pos 	: Integer;
begin
	pos := 1;
	str2 := self.scanUntil(InvalidCharSet2, pos);
	
	//The resultant string is different to how it was passed in so there must be an invalid char there somewhere.
	if str2 = self then
		return false;
	endif;
	
	//Nope, couldn't find any of the chars.
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hhhhmmToMinutes" id="b9449761-d409-484f-8a51-5785a960693b">
        <source>hhhhmmToMinutes():Integer;
// --------------------------------------------------------------------------------
// Created:		15 September 2006 by cnwdad1
//
// Purpose:		Converts a string of hours and minutes (formated as hhhh:mm) into
//				minutes.
//
// Parameters:	None
//
// Returns:		The total number of minutes.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
constants
	SEPARATOR		: Character = ":";
	
vars
	hours			: Integer;
	minutes			: Integer;
	totalMinutes	: Integer;
	workString		: String;
	stringLen		: Integer;
	separatorPos	: Integer;
	
begin
	workString		:=	self;
	stringLen		:=	workString.length();
	separatorPos	:=	workString.pos(SEPARATOR, 1);
	
	if separatorPos = 1 and stringLen = 1 then
		return 0;
	endif;
	
	if separatorPos = 0 then
		return 0;
	elseif separatorPos = 1 then
		minutes	:=	workString[2:end].Integer;
	elseif separatorPos = stringLen then
		hours	:=	workString[1:(separatorPos - 1)].Integer;
	else
		hours	:=	workString[1:(separatorPos - 1)].Integer;
		minutes	:=	workString[(separatorPos + 1):end].Integer;
	endif;
	
	totalMinutes	:=	hours * CNEC_MINUTES_IN_HOUR + minutes;
	
	return totalMinutes;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="incrementHex" id="785433c7-a5f2-43df-8393-79e0643963eb">
        <updating/>
        <source>incrementHex() updating;
//
// Purpose:			Increment a hex string - so for instance 00DC becomes 00DD
//					A full FFFF string becomes 0000
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 02/06/2022	navdap1		Initial creation TFS 53362 EUP Master Data interface customers between TOS and ERP
//
vars
	idx : Integer;
	char : Character;

begin
	foreach idx in 1 to self.length reversed do
		char := self[idx:1].Character;
		if char = "F" then
			self[idx:1] := "0";
		else
			char := (char.Integer + 1).Character;
			self[idx:1] := char;
			break;
		endif;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="incrementID" id="bddc507e-3840-41c4-a5f6-31c6094f3fbe">
        <updating/>
        <source>incrementID(_numBy : Integer) : String updating;
// 08/01/2026	navcs2	MTN-36895 MTN  - Improve Auto-Generation Performance for Cargo

vars

	nextLogId 		: String;
	trailingNum		: String;
	lastNum			: String;
	trailingNumLen	: Integer;		// 08/01/2026	navcs2	MTN-36895

begin

	if self.isInteger then
		nextLogId := (self.Integer + _numBy).String;
	else
		trailingNum := self.getTrailingIntegerString();
		lastNum :=  self.getTrailingInteger().String;
		lastNum := (lastNum.Integer + _numBy).String;		
		
		trailingNumLen := trailingNum.length;			// 08/01/2026	navcs2	MTN-36895
		
		if trailingNumLen &gt; lastNum.length then			// 08/01/2026	navcs2	MTN-36895
			//epr par 32971 12/11/13
			nextLogId:= trailingNum[1:trailingNumLen - lastNum.length] &amp; lastNum;	// 08/01/2026	navcs2	MTN-36895
			nextLogId :=  self[1:(self.length-trailingNumLen)  ] &amp;  nextLogId;		// 08/01/2026	navcs2	MTN-36895
			//nextLogId := (self.cnEcStripAtEnd(trailingNum) &amp; lastNum.padZeros(trailingNum.length));
		else
			nextLogId := (self.cnEcStripAtEnd(trailingNum) &amp; lastNum);			
		endif;			
	endif;
	return nextLogId;
end;</source>
        <Parameter name="_numBy" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="insertAfterCapitals" id="1d917deb-22b5-427b-840a-e23e0e279aea">
        <source>insertAfterCapitals(insertString : String) : String;

/*

Purpose:			Insert the passed in token after any capital letter (CentrePort code)
					For voice interface - changes string so that capitals are read phonetically by spacing them out.
					write "ABCZazA A".insertAfterCapitals(", ");

Parameters:			Token to insert

Return Value:		Resulting string


Date		Who		Reason
10 March 2009	cnwkpd1	PAR #18743 - CCMS 1784 - Voice Directed Changes for Twin Lift

*/

vars
	returnString :	String;
	idx :	Integer;
	
begin
	idx := 1;
	while idx &lt;= self.length do
		returnString := returnString &amp; self[idx];
		if self[idx] &gt;= 'A' and self[idx] &lt;= 'Z' then
			returnString := returnString &amp; insertString;
		endif;
		idx := idx + 1;
	endwhile;
	
	return returnString;
end;
</source>
        <Parameter name="insertString" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="insertCrIntoLongString" id="05715a57-5cde-43fe-ab62-2f4edc047056">
        <source>insertCrIntoLongString(_lenth : Integer; _delimiter : Character; _numCR : Integer io) : String;
// ---------------------------------------------------------------------------
// Created:     21 April 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	a,c,d,  idx : Integer;
	new, b : String;
	
begin
	b := self;
	c:= _lenth;
	d := 0;
	foreach idx in 1 to b.length do
		if idx &gt;= c then
			if b[idx:1] = _delimiter then
				if new = null then
					new := b[d +1 : (idx - d)];
				else
					new := new &amp; CrLf &amp; b[d+ 1: (idx - d)];
					_numCR := _numCR + 1;
				endif;
				
				c:= idx + _lenth;
				d := idx + 1;
			endif;
		endif;
	endforeach;
	if new = null then
		new := b[d + 1 : (idx - d)];
	else
		new := new &amp; CrLf &amp; b[d + 1 : end];
		_numCR := _numCR + 1;
	endif;
	
	return new;

epilog

end;</source>
        <Parameter name="_lenth" type="Integer"/>
        <Parameter name="_delimiter" type="Character"/>
        <Parameter name="_numCR" type="Integer" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isAlpha" id="cb3a3673-2436-4837-9ca0-b56f44abceef">
        <source>isAlpha() : Boolean;
// ---------------------------------------------------------------------------
// Created:     16 October 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if self.length = 0 then
		return true;
	endif;
	
	return (self[1] &gt;= 'A' and self[1] &lt;= 'Z') or (self[1] &gt;= 'a' and self[1] &lt;= 'z');

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isBlank" id="e5717db9-7ea8-457f-be23-768b6880472c">
        <source>isBlank(): Boolean;

/*

Date		Who		Reason
20 May 2009	cnwkpd1	PAR #18983 - Change check to test i = 0, which is what
					JADE scanWhile returns when there are no characters not on the 
					passed in set

*/

vars
	i				: Integer;
	
begin
	if self = null then
		return true;
	endif;

	i := 1;
	self.scanWhile(Blank_Characters, i);

	return i = 0;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isBlankRecordCSV" id="b96073cb-93a5-4dfa-b507-1956866f5b6d">
        <source>isBlankRecordCSV():Boolean;
// --------------------------------------------------------------------------------
// Created:		11 December 2008 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is a blank
//				CSV record. ie only contains spaces, null and/or commas
//
// Parameters:	None
//
// Returns:		True if the receiver is blank, otherwiae false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	record		: String;
	
begin
//	record	:=	self.replaceString(",", "").trimBlanks();
	record	:=	self.replaceString( CNEC_COMMA, null ).trimBlanks();
	
	if record = null then
