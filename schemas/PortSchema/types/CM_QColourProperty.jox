    <DbClassMap file="query"/>
    <JadeMethod name="getValueForObject" id="cc238b18-a7dd-445b-ae97-a2dc939de5ab">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 December 2009	cnwdap1	Initial creation
*/
vars

begin
	if _obj = null then
		return null;
	elseif not _obj.isKindOf(CM_BreakBulkGeneric) then
		return 0;
	endif;
	
	return _obj.sendMsg(self.propertyName);
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
