    <JadeMethod name="txtSlotCode1_change" id="92491a15-b6b5-49ef-b569-d419dd935b7b">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtSlotCode1_change(textbox: TextBox input) updating;

/*

Purpose:		Update the slot defn code	

Date			Who		Reason
21/11/2011		cnwmh5	Initial creation #28838

