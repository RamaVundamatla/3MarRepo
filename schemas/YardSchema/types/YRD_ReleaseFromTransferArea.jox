    <JadeMethod name="doReleaseCargo" id="de8a863e-95dc-4817-8a49-887e7e5a5dfb">
        <source>doReleaseCargo():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2019	jlgndl1	Initial creation	TFS 46020

*/

vars

	consignee : CM_ConsigneeConsignor;
	selectedConsignCode : String;
	delNum : String;
	delReason : String;
	delReasonCode : Integer;
	result : Integer;
	obj : Object;
	sendConsignEDI : Boolean;
	errDetail : String;
	err : CM_Error;
	retVal : Integer;
	opt : Integer;
	allConsigneesToEmail : CM_ConsigneeConsignorSet;
	ti : CM_TrackedItem;
	consigneeReleasedTis : CM_TISet;
	
begin

	app.mousePointer := MousePointer_HourGlass;
	
	delNum := self.txtDeliveryNum.text;
	delReason := self.cmbDelReason.text;
	if delReason = null then
		app.msgBox(app.getErrorString(Input_required_field_delivReas), self.caption, MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		self.cmbDelReason.setFocus();
		return false;
	endif;
	delReasonCode := app.deliveryReasonStringToEnum(delReason);
	sendConsignEDI := self.chkEmailConsign.value;
	consignee := self.cmbConsignee.listObject.CM_ConsigneeConsignor;
	if consignee &lt;&gt; null then
		selectedConsignCode := consignee.code;
	elseif self.optReplace.value then
		if sendConsignEDI then
			//no one to send to ???
			retVal := app.msgBox(app.getErrorString(NoConsigneeSelectedContinue), self.caption, MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon);
			if retVal = MsgBox_Return_No then
				self.cmbConsignee.setFocus();
				return false;
			endif;
		endif;
	elseif self.optRetain.value and consignee = null then
		app.msgBox(app.getErrorString(Input_required_field_consignee), self.caption, MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		self.cmbConsignee.setFocus();
		return false;
	endif;
	
	if self.optReplace.value then
		opt := self.Replace;
	elseif self.optRetain.value then
		opt := self.RetainNonBlank;
	elseif self.optNoChange.value then
		opt := self.NoUpdate;
	endif;

	if app.isDevelopmentSystem  and
	   sendConsignEDI then				// cnwjre1 added this test from other development - unconditional msg seems a little silly
		//Don't sent emails to the consignee
		sendConsignEDI := false;
		app.msgBox("DEV System!  Email wont be sent.", "DEV System", null);
	endif;	
	
	while true do
		app.myTrxDA.trxReleaseFromTransArea(self.allTisToRelease, opt, selectedConsignCode, delNum, delReasonCode, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog('Release Cargo', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
	create allConsigneesToEmail transient;
	foreach ti in self.allTisToRelease do
		if ti.isOnSite then
			//failed to be released, skip it.
			continue;
		endif;
		if ti.consignee = null then
			continue;
		endif;
		consignee := ti.getConsigneeObject;
		if consignee = null or consignee.emailAddress = null then
			continue;
		endif;
		allConsigneesToEmail.addNoDuplicates( consignee, false );
	endforeach;
	
	//not a part of the above trx as this process shouldn't stop the release from going ahead
	//if this fails the user will not be able to do anything about it
	if not allConsigneesToEmail.isEmpty and sendConsignEDI then
		create consigneeReleasedTis transient;
		foreach consignee in allConsigneesToEmail do
			consigneeReleasedTis.clear();
			foreach ti in self.allTisToRelease do
				if ti.isOnSite then
					//failed to be released, skip it.
					continue;
				endif;
				if consignee = ti.getConsigneeObject then
					//process only the ones for this consignee
					consigneeReleasedTis.addNoDuplicates( ti, false );
				endif;
			endforeach;
			
			if not consigneeReleasedTis.isEmpty then
				app.myTrxDA.trxSendEDIToConsignee(consigneeReleasedTis, consignee.code, app.myPassport);
				if app.myPassport.hasErrors then
					errDetail := app.getErrorString1( Consignee_oneParam, consignee.code ) &amp; CrLf;
					foreach err in app.myPassport.allErrorWarnings do
						errDetail := errDetail &amp; err.errorCode.String &amp; ": " &amp; err.text &amp; CrLf;
					endforeach;
					app.msgBox(app.getErrorString(CargoReleaseOK) &amp; CrLf &amp; app.getErrorString(Err_EmailConsignee) &amp; CrLf &amp; errDetail, "Email EDI Error", MsgBox_OK_Only + MsgBox_Information_Icon);
				endif;
			endif;
		endforeach;
	endif;
	
	return true;
	
epilog
	
	delete consigneeReleasedTis;
	delete allConsigneesToEmail;
	delete consigneeReleasedTis;
	app.mousePointer := MousePointer_Default;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="bb3fb962-2f5b-4fbd-b0c0-2ae1f969a63e">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2019	jlgndl1	Initial creation	TFS 46020

*/

vars

	xmlString : String;

begin

	xmlString := inheritMethod();
	
	xmlString := xmlString &amp; global.formatAsXML( self.optNoChange.name, self.optNoChange.value.String );
	xmlString := xmlString &amp; global.formatAsXML( self.optReplace.name, self.optReplace.value.String );
	xmlString := xmlString &amp; global.formatAsXML( self.optRetain.name, self.optRetain.value.String );
	xmlString := xmlString &amp; global.formatAsXML( self.chkEmailConsign.name, self.chkEmailConsign.value.String );
	
	return xmlString;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="bf361e1f-607f-4d0d-bbb1-988f67847e36">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2019	jlgndl1	Initial creation	TFS 46020

*/

vars

	xmlString : String;

begin

	inheritMethod(_userWindow);
	
	if _userWindow = null then
		return;
	endif;
	
	xmlString := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.optNoChange.name).String;
	if xmlString &lt;&gt; null then
		self.optNoChange.value := xmlString.Boolean;
	endif;
	
	xmlString := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.optReplace.name).String;
	if xmlString &lt;&gt; null then
		self.optReplace.value := xmlString.Boolean;
	endif;
	
	xmlString := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.optRetain.name).String;
	if xmlString &lt;&gt; null then
		self.optRetain.value := xmlString.Boolean;
	endif;
	
	xmlString := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.chkEmailConsign.name).String;
	if xmlString &lt;&gt; null then
		self.chkEmailConsign.value := xmlString.Boolean;
	endif;

epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="populateCombos" id="36951b78-5c54-448b-9074-4f78c0ef9e7e">
        <source>populateCombos();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2019	jlgndl1	Initial creation	TFS 46020

*/

vars

	consign : CM_ConsigneeConsignor;
	reason : CM_DeliveryReleaseReason;
	index : Integer;

begin

	self.cmbConsignee.clear();
				
	foreach consign in app.myRoot.allConsigneeConsignors do
		index := self.cmbConsignee.addItem(consign.code &amp; ' ' &amp; consign.description);
		self.cmbConsignee.itemObject[index] := consign;
	endforeach;			
	
	
	
	self.cmbDelReason.clear();
	
	self.cmbDelReason.addItem(DELSTR_IST);
	self.cmbDelReason.addItem(DELSTR_NIB);
	self.cmbDelReason.addItem(DELSTR_PEX);
	self.cmbDelReason.addItem(DELSTR_RPK);
	self.cmbDelReason.addItem(DELSTR_SNT);
	self.cmbDelReason.addItem(DELSTR_TSC);
	
	foreach reason in app.myRoot.allDeliveryReasonselReasons do  
		index := self.cmbDelReason.addItem(reason.description);
		self.cmbDelReason.itemObject[index] := reason;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setTisToRelease" id="1eae31f3-facc-46be-b083-713ffc64c326">
        <updating/>
        <source>setTisToRelease( _allTisToRelease : CM_TISet input )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2019	jlgndl1	Initial creation	TFS 46020

*/

vars

begin

	self.allTisToRelease.clear();
	if not _allTisToRelease.isEmpty then
		_allTisToRelease.copy( self.allTisToRelease );
	endif;

epilog

end;</source>
        <Parameter name="_allTisToRelease" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="e3202cc0-8038-47d3-aa91-11d8c325d146">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2019	jlgndl1	Initial creation	TFS 46020

*/

vars

begin

	inheritMethod();
	
	self.populateCombos();
	
	self.btnOk.enabled := app.myCurrentUserCan( self.myTerminal, self.permissionMaint );
	
	if not self.optNoChange.value
	and not self.optReplace.value
	and not self.optRetain.value
	then
		self.optReplace.value := true;
	endif;
	
	self.centreOverParent(10);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="c7d77336-17c9-49c5-a30a-ab25cc80181e">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 23 August 2019 14:56:35.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023697, locale);
	chkEmailConsign.translateCaption(Xlat_0023698, locale);
	grpConsignee.translateCaption(Xlat_0023699, locale);
	lblConsignee.translateCaption(Xlat_0023700, locale);
	lblConsigneeRule.translateCaption(Xlat_0023701, locale);
	lblDelReason.translateCaption(Xlat_0023702, locale);
	lblDeliveryNum.translateCaption(Xlat_0023703, locale);
	optNoChange.translateCaption(Xlat_0023704, locale);
	optReplace.translateCaption(Xlat_0023705, locale);
	optRetain.translateCaption(Xlat_0023706, locale);
end;</source>
    </JadeMethod>
</GUIClass>
