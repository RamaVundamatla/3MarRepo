        <source>showInvoiceAllocationMapping(_terminal : CM_Terminal; _parent : CM_BaseForm; _alloc : CM_InvoiceAllocation);
/*
Purpose:			TFS 7496
Date				Who			Reason
NOVEMBER 2017		CNWAB1		Initial creation
*/

vars
	mappingForm	: INV_InvoiceAllocMappingForm;
begin
	mappingForm := app.loadForm(INV_InvoiceAllocMappingForm, 
							INV_Assistant, 
							false, 
							false,
							false, 
							_terminal,
							null).INV_InvoiceAllocMappingForm;	
	
	if mappingForm = null then
		return;
	endif;
	mappingForm.myInvoiceAlllocation := _alloc;
	mappingForm.setParentForm( _parent );	//04 Feb 2019	NDL	TFS 43153
	mappingForm.centreOverParent( 1 );	//04 Feb 2019	NDL	TFS 43153
	mappingForm.showModal;		
epilog

end;</source>
