    <JadeMethod name="getTotalLoaded" id="3029260a-461f-4714-b54b-eb35bd921cfb">
        <source>getTotalLoaded(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 March 2017	cnwndl1	Initial creation TFS 3477

*/

vars

	ti : CM_TrackedItem;
	lc : CM_LocationsController;
	iter : Iterator;

begin
	
	//if self.myReserveHeader &lt;&gt; null then	//01 Mar 2018	NDL	TFS 37377
		ti := self.getTI;
		if ti = null then
			return null;
		endif;
		if not ti.isOnSite then
			return null;
		endif;
		if ti.isChild then
			return null;
		endif;
		if ti.myPrimaryActualLocation &lt;&gt; null then
			lc := ti.myPrimaryActualLocation;
			if lc.isVehicle or lc.isTILCController then
				return ti.totalQuantity.max(1);
			endif;
		endif;
		
	//endif;
	
	return null;

epilog
	
	

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalOutstanding" id="f4fd16e8-fe4b-4c62-8662-dcae7ddf9574">
        <source>getTotalOutstanding(): Integer;
// -----------------------------------------------------------------------------
// Created:		21 September 2009 by consw1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
// -----------------------------------------------------------------------------

vars

	aTI : CM_TrackedItem;
begin

	
	//aTI := self.allTrackedItems.first;
	aTI := self.getFirstTI(false); //23/06/2023	navkc1	CR 58406 Task 58408
	
	if aTI = null then
		return 0;
	endif;

	//epr par 35154 18/11/14
	if aTI.myCargoType.isBreakBulkMulti then 
		if self.allTrackedItemsReleased.isEmpty() then
			return self.totalRequested;
		endif;
	
		return 0;
	else
		if self.allTrackedItemsReleased.isEmpty() then
			return 1;
		endif;
	
		return 0;
	endif;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalReleased" id="1f3dcc33-7b63-4366-b6a1-e1b23b5c49ac">
        <source>getTotalReleased(): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 May 2013	cnwrd1	Initial creation

*/

vars
	aTI : CM_TrackedItem;
begin
	//epr TFS 45287 16/8/19
	if self.isPackingChild then
		return self.getTotalPacked;
	endif;
	
	if self.allTrackedItemsReleased.isEmpty() then
		return 0;
	endif;
	
	if self.allTrackedItemsReleased.size = 1 then
	//epr par 32330 29/8/13

		return self.totalRequested.max(1);
	else
		return self.allTrackedItemsReleased.size;
	endif;
	

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalRequested" id="dbe1846c-d6f4-4086-b845-55baaab3298f">
        <source>getTotalRequested(): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 May 2013	cnwrd1	Initial creation
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars
	aTI : CM_TrackedItem;
	isRelease : Boolean;
begin

	
	//aTI := self.allTrackedItems.first;
	aTI := self.getFirstTI(false); //23/06/2023	navkc1	CR 58406 Task 58408
	
	if aTI = null then
		aTI := self.allTrackedItemsReleased.first;
		isRelease:=true;
	endif;

	if aTI = null then
		return 0;
	endif;
	

//	epr par 34623 25/7/14
	if aTI.myCargoType.isBreakBulkMulti then	//11 July 2014	NDL	Par 34552
		 // ### TFS 51936 04NOV2021 NAVAB1
		if self.isCompleteBySplit() then
			return 0;
		endif;
		
		//epr TFS 41398 21/02/19 	
		return self.totalRequested.max(1);		
		
	elseif aTI.isBulkbyWeightOrVolume then
		return 0;
	else
		return 1; //self.totalRequested;
	endif;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalStaged" id="892159d0-1d9f-45e7-bb26-d3586baa56cb">
        <source>getTotalStaged( _tiSet : CM_TISet input; _firstStagingLC : CM_LocationsController output; _allStagingAreas : CM_LCSet input ): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 October 2015	cnwndl1	Initial creation	Par 37033

*/

vars

	ti : CM_TrackedItem;
	ta : CM_TerminalArea;
	iter : Iterator;
	lc : CM_LocationsController;

begin
	
	//if self.myReserveHeader &lt;&gt; null then	//01 Mar 2018	NDL	TFS 37377
		ti := self.getTI;
		if ti = null then
			return null;
		endif;
		if not ti.isOnSite then
			return null;
		endif;
		if ti.isChild then
			return null;
		endif;
		lc := ti.myPrimaryActualLocation;	//05 May 2017	NDL	TFS 4016
		if lc &lt;&gt; null then
			ta := lc.myTerminalArea;
			if ta &lt;&gt; null then
				if ta.type = TA_TYPE_YARD_INTERCHANGE then
					if _firstStagingLC = null then
						_firstStagingLC := lc;
					endif;
					if _allStagingAreas &lt;&gt; null and not _allStagingAreas.includes( lc ) then	//05 May 2017	NDL	TFS 4016
						_allStagingAreas.add( lc );
					endif;
					if _tiSet &lt;&gt; null then
						if _tiSet.addNoDuplicates(ti,false) then
							return ti.totalQuantity.max(1);
						else
							return 0;
						endif;
					endif;
					return ti.totalQuantity.max(1);
				endif;
			endif;
		endif;
		
	//endif;
	
	return null;

epilog
	
	

end;</source>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
        <Parameter name="_firstStagingLC" type="CM_LocationsController" usage="output"/>
        <Parameter name="_allStagingAreas" type="CM_LCSet" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTrackedItems" id="74eb531c-63d2-4b72-b644-388a962acdb8">
        <source>getTrackedItems() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 January 2017	cnwrh7	Initial creation TFS2929
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars
	strId	:  String;
	ti			:  CM_TrackedItem;
	allTis	: CM_TISet; 
begin
	if self.allTrackedItems = null then
		return null;
	endif;
	
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	self.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
	//foreach ti in self.allTrackedItems  discreteLock do 
	foreach ti in allTis discreteLock do  //23/06/2023	navkc1	CR 58406 Task 58408
		if strId = "" then
			strId := ti.id ;
		else
			strId := strId &amp; "," &amp; ti.id ;
		endif;
	endforeach;
	return strId;
epilog
	delete allTis; 
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTrackedItemsReleased" id="5a3c0620-2f7c-4327-9a6c-442bea268e73">
        <source>getTrackedItemsReleased() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 January 2017	cnwrh7	Initial creation TFS2929

*/

vars
	strId	:  String;
	ti			:  CM_TrackedItem;
begin
		if self.allTrackedItemsReleased = null then
			return null;
		endif;
		foreach ti in self.allTrackedItemsReleased  discreteLock do 
			if strId = "" then
				strId := ti.id ;
			else
				strId := strId &amp; "," &amp; ti.id ;
			endif;
		endforeach;
		return strId;
epilog
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVolumeForSummary" id="f005528c-b261-4ae8-93d3-cde19be9b759">
