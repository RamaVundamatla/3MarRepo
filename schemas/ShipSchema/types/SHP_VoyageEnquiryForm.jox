    <JadeMethod name="updateKPIStats" id="ee26adf4-5e41-4be5-8df9-edade3bc46fa">
        <updating/>
        <source>updateKPIStats() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:		24 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theReturn : Integer;
begin
	if self.myCurrentVoyage = null then
		return false;
	endif;
	while true do
		app.myTrxUA.trxUpdateVoyageKPIStats(self.myCurrentVoyage,true, app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			return true;
		else
			theReturn := app.showErrorWarningDialog("Voyage KPI Stats", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		break;
	endwhile;
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
