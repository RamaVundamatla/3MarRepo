begin
	
	// Drawing  portrait, so rows == columns &amp; columns == rows
	
	if self.flipH then
		x1 := self.myDrawingFrame.width + self.xDrawOffset - self.rightOffset;	
	else
		x1 := self.xDrawOffset + self.leftOffset;
	endif;
		
	gridWidth  := self.getGridWidth();
	gridHeight := self.getGridHeight();
	
	if self.flipH then
		col := self.rightGridColDraw;	
