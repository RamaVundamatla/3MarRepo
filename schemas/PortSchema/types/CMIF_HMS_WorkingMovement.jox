    <JadeMethod name="berthing_AutoPositionOnBerth" id="e916fd7a-db91-4b7e-8202-9f9e09493f94">
        <source>berthing_AutoPositionOnBerth(wharfPosnParams: CMIF_HMS_WharfPosnCheckParams input):Boolean;

vars
	showMsgs			: Boolean;
	harbour				: HMS_Harbour;
	minClearance		: Integer;
	loa					: Decimal[6,2];	
	berthStart,
	berthEnd			: Integer;
	zeroSideClearance,
	maxSideClearance,
	zeroSideMark,
	maxSideMark			: Decimal[12,2];
	bowAtZeroSide		: Boolean;
	msgBoxType			: Integer;
   	msgString			: String;
	isCheckClearance	: Boolean;

begin
	isCheckClearance	:=	self.myHarbour.isDoClearanceCheck;		// cnwdad1 26/02/2007.
	
	// This method attempts to automatically position a ship on the requested berth
	// Overview of method steps is as follows
	// 1. centre ship on berth
	// 2. calc clearances for this position. If clearances are valid, return this position.
	//    If both clearances (fore and aft) are invalid, then give msg "ship cannot
	//    be berthed here" and return false. Else if only one clearance is invalid,
	//    see whether the ship can be moved so that both clearances become valid
	//    and that the ship's centre mark is still over the requested berth. If it is, 
	//    then return this position. 
	//  
	// 3. NOTE. The move position referred to above is calculated by:
	//		mark from centering + current clearance + min clearance

    harbour			:=	self.myHarbour;
    minClearance	:=	harbour.minimumClearance;
    loa				:=	wharfPosnParams.myHMSVoyageData.dim_LengthOverall;
    berthStart		:=	wharfPosnParams.berth.startPosition;
    berthEnd		:=	(wharfPosnParams.berth.startPosition) + (wharfPosnParams.berth.length);

	self.berthing_CentreShip(wharfPosnParams);
	showMsgs	:=	false;
	
	if check_BerthDurationClearances(wharfPosnParams,showMsgs)=false then
		// Either the fore or the aft clearance (or both) are invalid

		// Get marks and clearances
		if wharfPosnParams.bowMark&lt;wharfPosnParams.sternMark then
			zeroSideMark:=wharfPosnParams.bowMark;
			maxSideMark:=wharfPosnParams.sternMark;
			zeroSideClearance:=wharfPosnParams.foreClearance;
			maxSideClearance:=wharfPosnParams.aftClearance;
			bowAtZeroSide:=true;
		else
			zeroSideMark:=wharfPosnParams.sternMark;
			maxSideMark:=wharfPosnParams.bowMark;
			zeroSideClearance:=wharfPosnParams.aftClearance;
			maxSideClearance:=wharfPosnParams.foreClearance;
			bowAtZeroSide:=false;
		endif;		

		if wharfPosnParams.foreClearance &lt; minClearance
		and wharfPosnParams.aftClearance &lt; minClearance
		and isCheckClearance									// cnwdad1 26/02/2007.
		then
        	// CASE A: Both fore and aft clearance are invalid
        	// Display msg - insuffient room to position the ship on this berth
        	msgBoxType:=MsgBox_OK_Only+MsgBox_Exclamation_Mark_Icon;
			msgString := app.getErrorString(MSGBOX_InsufficentClearText) &amp; wharfPosnParams.berth.description;// &amp; " CASE A";
			app.msgBox(msgString, app.getErrorString(MSGBOX_InsuffientClear), msgBoxType);

        elseif  (wharfPosnParams.foreClearance&lt;minClearance and wharfPosnParams.aftClearance&gt;minClearance) or  (wharfPosnParams.foreClearance&gt;minClearance and wharfPosnParams.aftClearance&lt;minClearance) then
        	// CASE B: Fore or aft clearance is invalid - check to see if the ship could be moved so that there
        	//          is sufficient clearance on both sides
        	if  zeroSideClearance+maxSideClearance&gt;(2*minClearance) then
        		// Combined clearances are greater than minimum allowance - calc new position for ship 
        		// and then check to see that its centre in still over the target berth
        		if zeroSideClearance&lt;maxSideClearance then
        			// Zero side clearance is invalid - move ship up wharf to the first valid position
        			zeroSideMark:=zeroSideMark+(minClearance-zeroSideClearance);
        			maxSideMark:=maxSideMark+(minClearance-zeroSideClearance);
        			// Set new clearances
        			if maxSideClearance=ClearanceUnbounded then
        				maxSideClearance:=ClearanceUnbounded;
        			else
        				maxSideClearance:=maxSideClearance+(minClearance-zeroSideClearance);
        			endif;
        			zeroSideClearance:=minClearance;
        		else
        			// Max side clearance is invalid - move ship down wharf to the first valid position
        			zeroSideMark:=zeroSideMark-(minClearance-maxSideClearance);
        			maxSideMark:=maxSideMark-(minClearance-maxSideClearance);
        			// Set new clearances
        			if zeroSideClearance=ClearanceUnbounded then
        				zeroSideClearance:=ClearanceUnbounded;
        			else
        				zeroSideClearance:=zeroSideClearance-(minClearance-maxSideClearance);
        			endif;
        			maxSideClearance:=minClearance;
        		endif;

        		// Check that centre of ship is still on target berth
        	
                if ((zeroSideMark + (loa / 2).Integer) &lt;= berthEnd) and ((zeroSideMark + (loa / 2).Integer) &gt;= berthStart) then
                	// Centre of ship is still on target berth
                	// Set bow and stern marks for auto set postion
        			if bowAtZeroSide=true then 
        				wharfPosnParams.bowMark:=zeroSideMark;
						wharfPosnParams.sternMark:=maxSideMark;
						wharfPosnParams.foreClearance:=zeroSideClearance;
						wharfPosnParams.aftClearance:=maxSideClearance;
					else
						wharfPosnParams.bowMark:=maxSideMark;
						wharfPosnParams.sternMark:=zeroSideMark;
						wharfPosnParams.foreClearance:=maxSideClearance;
						wharfPosnParams.aftClearance:=zeroSideClearance;
					endif;

					

					return true;
				else
					if isCheckClearance then
						// Display msg - insuffient room to position the ship on this berth
						msgBoxType:=MsgBox_OK_Only+MsgBox_Exclamation_Mark_Icon;
						msgString:=app.getErrorString(MSGBOX_InsufficentClearText) &amp; wharfPosnParams.berth.description; //&amp; " CASE B";
						app.msgBox(msgString, app.getErrorString(MSGBOX_InsuffientClear), msgBoxType);
						return false;
					else
						return true;
					endif;
				endif;

			endif;
		endif;
	else
		
		return true;
	endif;
end;</source>
        <Parameter name="wharfPosnParams" type="CMIF_HMS_WharfPosnCheckParams" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="berthing_BowSternFromOrient" id="7e15db3d-9f31-4917-9a0d-e91c7f390c9b">
        <source>berthing_BowSternFromOrient(wharfPosnParams: CMIF_HMS_WharfPosnCheckParams input);

vars
	waterOnLeftmyWharf:	Boolean;	
begin
 	// This method takes the start and end positions of a ship along the wharf and returns its bow and stern marks
 	// based on the orientation of the ship:wharf:sea

 	waterOnLeftmyWharf:=wharfPosnParams.berth.myWharf.waterOnLeft;

    if waterOnLeftmyWharf=true and wharfPosnParams.orientation=1 then
    	// CASE A: Water on left of wharf, ship is PortSideTo, bowMark=min, sternMark=max
    	wharfPosnParams.bowMark:=wharfPosnParams.shipStartOnWharf;
    	wharfPosnParams.sternMark:=wharfPosnParams.shipEndOnWharf;
    elseif waterOnLeftmyWharf=true and wharfPosnParams.orientation=2 then
    	// CASE B: Water on left of wharf, ship is StarboardSideTo, bowMark=max, sternMark=min
    	wharfPosnParams.bowMark:=wharfPosnParams.shipEndOnWharf;
    	wharfPosnParams.sternMark:=wharfPosnParams.shipStartOnWharf;
    elseif waterOnLeftmyWharf=false and wharfPosnParams.orientation=1 then
    	// CASE C: Water on right of wharf, ship is PortSideTo, bowMark=max, sternMark=min
    	wharfPosnParams.bowMark:=wharfPosnParams.shipEndOnWharf;
    	wharfPosnParams.sternMark:=wharfPosnParams.shipStartOnWharf;
    elseif waterOnLeftmyWharf=false and wharfPosnParams.orientation=2 then
    	 // CASE D: Water on right of wharf, ship is StarboardSideTo, bowMark=min, sternMark=max
    	wharfPosnParams.bowMark:=wharfPosnParams.shipStartOnWharf;
    	wharfPosnParams.sternMark:=wharfPosnParams.shipEndOnWharf;
    endif;

end;</source>
        <Parameter name="wharfPosnParams" type="CMIF_HMS_WharfPosnCheckParams" usage="input"/>
    </JadeMethod>
    <JadeMethod name="berthing_CalcClearances" id="6da1bbe8-01c8-484d-90f5-d4d11696580e">
        <source>berthing_CalcClearances(bowMark, sternMark:Decimal; foreClearance, aftClearance:Decimal io; movementToCheck: CMIF_HMS_WorkingMovement; berth:HMS_Berth; controller: CMIF_HMS_ViewController);

vars
   	movement:			CMIF_HMS_WorkingMovement;
   	closestStartPosn,
   	closestEndPosn,
   	moveStartPosn,
   	moveEndPosn,
   	currentStartPosn,
   	currentEndPosn:		Decimal[12,2];
begin
	// This method calculates the fore and aft clearances for a movement to a berth, based the following supplied information
	// bowMark, sternMark, and the wharf that these marks apply to

	// Initialise the closestStartPosn and closestEndPosn variables
	closestStartPosn:=0;
	closestEndPosn:=berth.myWharf.length;
	berthing_StartEndFromOrient(currentStartPosn,currentEndPosn, bowMark, sternMark);

 	foreach movement in controller.allMovementsInViewByDT where ((movement.getMovementNext&lt;&gt;null) and (movement.myWorkingVoyage&lt;&gt;movementToCheck.myWorkingVoyage)) do
 		if movement.myBerth&lt;&gt;null then
 			if (berth.myWharf=movement.myBerth.myWharf) then
 				if 	movement.occursOnDT&lt;=movementToCheck.occursOnDT and movement.getMovementNext.occursOnDT&gt;=movementToCheck.occursOnDT then
 				// ie. this movement is in existance at the same time as the movementToCheck occurs
 					berthing_StartEndFromOrient(moveStartPosn,moveEndPosn, movement.bowMarkTo, movement.sternMarkTo);
 					if	moveStartPosn&gt;currentStartPosn then
 						// this movement starts further up the wharf than the movementToCheck
 						if moveStartPosn&lt;closestEndPosn then
 							// This is the closest movement on the far end side
 							closestEndPosn:=moveStartPosn;
 						endif;
 					else
 						// this movement start further down the wharf than the movementToCheck 
 						if moveEndPosn&gt;closestStartPosn then
 							// This is the closest movement on the start (0m) side
 							closestStartPosn:=moveEndPosn;
 						endif;	
 					endif;
				endif;
			endif;
		endif;
	endforeach;

	// Calculate clearances
	if bowMark&gt;sternMark then
		foreClearance:=closestEndPosn-currentEndPosn;
		aftClearance:=currentStartPosn-closestStartPosn;
	else
		foreClearance:=currentStartPosn-closestStartPosn;
		aftClearance:=closestEndPosn-currentEndPosn;
	endif;
end;</source>
        <Parameter name="bowMark" type="Decimal"/>
        <Parameter name="sternMark" type="Decimal"/>
        <Parameter name="foreClearance" type="Decimal" usage="io"/>
        <Parameter name="aftClearance" type="Decimal" usage="io"/>
        <Parameter name="movementToCheck" type="CMIF_HMS_WorkingMovement"/>
        <Parameter name="berth" type="HMS_Berth"/>
        <Parameter name="controller" type="CMIF_HMS_ViewController"/>
    </JadeMethod>
    <JadeMethod name="berthing_CalcSternPosn" id="6964a59b-fb52-4064-a1f3-c52e45966c6f">
        <source>berthing_CalcSternPosn(wharfPosnParams: CMIF_HMS_WharfPosnCheckParams input);

vars
    waterOnLeftmyWharf:	Boolean;
    loa:				Decimal[6,2];
begin
 	// This method calculates the stern position for a ship, when supplied with the 
 	// bow mark, berth, and orientation, and ship L.O.A.

 	waterOnLeftmyWharf:=wharfPosnParams.berth.myWharf.waterOnLeft;
 	loa:=wharfPosnParams.myHMSVoyageData.dim_LengthOverall;

 	if waterOnLeftmyWharf=true and wharfPosnParams.orientation=1 then
    	// CASE A: Water on left of wharf, ship is PortSideTo, bowMark=min, sternMark=max
    	wharfPosnParams.sternMark:=wharfPosnParams.bowMark+loa;
    elseif waterOnLeftmyWharf=true and wharfPosnParams.orientation=2 then
    	// CASE B: Water on left of wharf, ship is StarboardSideTo, bowMark=max, sternMark=min
    	wharfPosnParams.sternMark:=wharfPosnParams.bowMark-loa;
    elseif waterOnLeftmyWharf=false and wharfPosnParams.orientation=1 then
    	// CASE C: Water on right of wharf, ship is PortSideTo, bowMark=max, sternMark=min
    	wharfPosnParams.sternMark:=wharfPosnParams.bowMark-loa;
    elseif waterOnLeftmyWharf=false and wharfPosnParams.orientation=2 then
    	 // CASE D: Water on right of wharf, ship is StarboardSideTo, bowMark=min, sternMark=max
    	wharfPosnParams.sternMark:=wharfPosnParams.bowMark+loa;
    endif;

end;</source>
        <Parameter name="wharfPosnParams" type="CMIF_HMS_WharfPosnCheckParams" usage="input"/>
    </JadeMethod>
    <JadeMethod name="berthing_CentreShip" id="861a0ae0-ec26-443e-81f2-44fd442cc34e">
        <source>berthing_CentreShip(wharfPosnParams: CMIF_HMS_WharfPosnCheckParams input);

vars
	loa				: Decimal[6,2];
	berthStart		: Integer;
	centreOfBerth	: Integer;
begin

	// This method returns bow and stern marks for the ship that are centred on the berth supplied.
	
	loa	:=	wharfPosnParams.myWorkingMovementToCheck.myWorkingVoyage.myHMSVoyageData.dim_LengthOverall;
	berthStart		:=	wharfPosnParams.berth.startPosition;
	centreOfBerth	:=	berthStart + (wharfPosnParams.berth.length / 2).Integer;
	wharfPosnParams.shipStartOnWharf	:=	centreOfBerth - (loa / 2).Integer;
	wharfPosnParams.shipEndOnWharf		:=	centreOfBerth + (loa / 2).Integer;

	// Determine whether bow or stern of ship is closest to start of wharf.
	berthing_BowSternFromOrient(wharfPosnParams);
end;</source>
        <Parameter name="wharfPosnParams" type="CMIF_HMS_WharfPosnCheckParams" usage="input"/>
    </JadeMethod>
    <JadeMethod name="berthing_GetBerthFromMarks" id="364e3f4f-2857-46f4-aeef-3b20fdfee568">
        <source>berthing_GetBerthFromMarks(bowMark, sternMark: Decimal; wharf: HMS_Wharf): HMS_Berth;

vars
	centreBerth,
	berth,
	previousBerth	: HMS_Berth;
	currentMeter,
	previousMeter,
	int,
	centreMark		: Decimal[12,2];	
begin
	// Calculate centre of ship
	if bowMark&gt;sternMark then
		centreMark:=sternMark + ((bowMark-sternMark)/2);
	else
		centreMark:=bowMark + ((sternMark-bowMark)/2);
	endif;

	previousMeter := 0;

	// find centre berth
	foreach berth in wharf.allBerths do
		currentMeter := berth.startPosition;
		if centreMark&gt;=berth.startPosition and centreMark&lt;=(berth.startPosition + berth.length).Integer then
			centreBerth:=berth;
			break;
		endif;
		// check if the vessel has been dropped into a dead zone (zone that is not considered a normal part of the berth)
		if centreMark &gt;= previousMeter and centreMark &lt;= currentMeter then
			if previousMeter = 0 then
				centreBerth := berth;
			else	
				int := ((currentMeter - previousMeter)/2);
				if centreMark &lt;= (previousMeter + int) then
					if previousBerth &lt;&gt; null then
						centreBerth := previousBerth;
					else
						centreBerth := berth;
					endif;	
				else
					centreBerth := berth;
				endif;
			endif;
		endif;
		previousBerth := berth;
		previousMeter := berth.startPosition + berth.length;
	endforeach;

	return centreBerth;

end;</source>
        <Parameter name="bowMark" type="Decimal"/>
        <Parameter name="sternMark" type="Decimal"/>
        <Parameter name="wharf" type="HMS_Wharf"/>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="berthing_StartEndFromOrient" id="65c691f8-e645-4d27-a866-e48d1c541718">
        <source>berthing_StartEndFromOrient(startPos, endPos: Decimal io; bowMark, sternMark:Decimal);

vars

begin
 	// This method takes the bow and stern marks of a ship along the wharf and returns its start and end positions
 	// based on the orientation of the ship:wharf:sea

 	if bowMark&gt;sternMark then
 		startPos:=sternMark;
 		endPos:=bowMark;
 	else
 		startPos:=bowMark;
 		endPos:=sternMark;
 	endif;	
end;</source>
        <Parameter name="startPos" type="Decimal" usage="io"/>
        <Parameter name="endPos" type="Decimal" usage="io"/>
        <Parameter name="bowMark" type="Decimal"/>
        <Parameter name="sternMark" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="calc_Clearances" id="ae80e4a8-f28e-4ba1-950f-498ba2124df6">
        <updating/>
        <source>calc_Clearances(closestMoveUpWharf:CMIF_HMS_WorkingMovement output; closestMoveDownWharf:CMIF_HMS_WorkingMovement output)updating;
//-------------------------------------------------
// Also see HMS_VoyageMovement::getForAftClearances()
//-------------------------------------------------
vars
	movement,
	movePrev,
   	tmpNextMove,
   	tmpNextMoveToCheck			:CMIF_HMS_WorkingMovement;
   	workingVoy:				CMIF_HMS_WorkingVoyage;
   	closestStartPosn,
   	closestEndPosn,
   	moveStartPosn,
   	moveEndPosn,
   	currentStartPosn,
   	currentEndPosn,
   	moveBowMark,
   	moveSternMark,
   	distToSectionLimit,
   	newAftClearance,
   	newForeClearance,
   	oldAftClearance,
   	oldForeClearance:		Decimal[12,2];
   	minClearance:			Integer;
   	tmpDict:				CMIF_HMS_WorkingMoveByDateDict;
   	moveOccursDT,
   	voyDepartureDT,
   	voyArrivalDT:			TimeStamp;
   	tmpLockout:				HMS_WharfLockout;
   	moveWharf:				HMS_Wharf;
   	section:				HMS_WharfSection; 

begin
	// This method calculates the clearances for a ship for its entire duration at a particular berth
	// This method calculates the minimum fore and aft clearances for a movement's duration at a berth, 
	// based the following supplied information	bowMark, sternMark, and the wharf that these marks apply to.
	
	moveOccursDT := self.occursOnDT;

	// save old clearances 
	oldAftClearance := self.aftClearanceTo;
	oldForeClearance := self.foreClearanceTo;

	// Initialise the closestStartPosn and closestEndPosn variables
	closestStartPosn := -1*(ClearanceUnbounded);
	closestEndPosn := ClearanceUnbounded;
												
	tmpNextMoveToCheck := self.getMovementNext();	
	if tmpNextMoveToCheck &lt;&gt; null then
		voyDepartureDT := tmpNextMoveToCheck.occursOnDT;
	else
		voyDepartureDT := moveOccursDT;
	endif;

	voyArrivalDT := moveOccursDT;		
	minClearance := self.myHarbour.minimumClearance;	
	self.overlapsWharfSection := false;

	if self.myClonedVoyage &lt;&gt; null then
		workingVoy := self.myClonedVoyage;
	else
		workingVoy := self.myWorkingVoyage;
	endif;

	if self.moveType = HMSMovementTypeDeparture then
		movePrev := self.getMovementPrevious;
		// Get the current wharf
		if movePrev &lt;&gt; null then
			moveWharf := movePrev.myBerth.myWharf;
			moveBowMark := movePrev.bowMarkTo;
			moveSternMark := movePrev.sternMarkTo;	
			movePrev.berthing_StartEndFromOrient(currentStartPosn, currentEndPosn, moveBowMark, moveSternMark);
			voyArrivalDT := movePrev.occursOnDT;					
		endif;
		voyDepartureDT := moveOccursDT;
  	endif;

	if moveWharf = null then
		// Get the current wharf
		moveWharf		:= self.myBerth.myWharf;
		moveBowMark		:= self.bowMarkTo;
		moveSternMark	:= self.sternMarkTo;
		self.berthing_StartEndFromOrient(currentStartPosn, currentEndPosn, moveBowMark, moveSternMark);
  	endif;  	
	
	if tmpNextMoveToCheck &lt;&gt; null then
		if self.myViewController &lt;&gt; null then
			tmpDict := self.myViewController.allMovementsInViewByDT;
		elseif self.myViewControllerCurrent &lt;&gt; null then
			tmpDict := self.myViewControllerCurrent.allMovementsInViewByDT;
		else
			tmpDict := self.myWorkingVoyage.ofCurrentView.allMovementsInViewByDT;
		endif;	
				
	 	foreach movement in tmpDict where (movement.myWorkingVoyage &lt;&gt; workingVoy) do
			tmpNextMove := movement.getMovementNext();
			if tmpNextMove = null then
				continue;
			endif;
			if movement.isLogicalBerth() then
	 			continue;
	 		endif;
			if movement.myBerth.myWharf &lt;&gt; moveWharf then
				continue;
			endif;
			if movement.myPersistentMovement = self.myPersistentMovement then
				continue;
			endif;
			if movement.myClone &lt;&gt; null and movement.myClone.myClonedVoyage = workingVoy then
				continue;	// 01/04/2008 cnwar2 #16322 - for case where shift movement repositioned over original
			endif;
			
			//if movement.occursOnDT&lt;=self.getMovementNext.occursOnDT and movement.getMovementNext.occursOnDT&gt;=self.occursOnDT then //&lt;&lt;--- 6.3.4
			//if movement.occursOnDT &lt;= voyDepartureDT and tmpNextMove.occursOnDT &gt;= moveOccursDT then 
		//	if movement.occursOnDT &lt;= moveOccursDT and tmpNextMove.occursOnDT &gt;= moveOccursDT then //&lt;&lt;--- 7.2.3	&amp; 7.3.3	
		//	if movement.occursOnDT&lt;=tmpNextMove.occursOnDT and tmpNextMove.occursOnDT&gt;=moveOccursDT then  //16 Apr 2014	NDL	Par 33573 
			if self.timesOverlap(movement) then	//26 May 2014	NDL	Par 34175
				
				// ie. this movement is in existance (overlaps) at the same time as the movementToCheck occurs
				self.berthing_StartEndFromOrient(moveStartPosn, moveEndPosn, movement.bowMarkTo, movement.sternMarkTo);
	
				if moveStartPosn &gt; currentStartPosn then
					// this movement starts further up the wharf than the movementToCheck
					if moveStartPosn &lt; closestEndPosn then
						// This is the closest movement on the far end side
						closestEndPosn := moveStartPosn;
						// Modified by Russell
						// ------------------------------
						closestMoveUpWharf := movement;
						// ------------------------------
					endif;
				else
					// this movement start further down the wharf than the movementToCheck 
					if moveEndPosn &gt; closestStartPosn then
						// This is the closest movement on the start (0m) side
						closestStartPosn := moveEndPosn;
						// Modified by Russell
						// ------------------------------
						closestMoveDownWharf := movement;
						// ------------------------------
					endif;	
				endif;
			endif;
		endforeach;
	endif;

	// check - calculate wharf lock out clearances	
	foreach tmpLockout in moveWharf.allWLockoutsByBothDT 
	where tmpLockout.startOfLockoutDT &lt; voyDepartureDT
	and tmpLockout.endOfLockoutDT &gt; voyArrivalDT do
		
		// Check to see if ship is within any part of this lockout
		// and is closer than any other ship
		if tmpLockout.startMarkOnWharf &gt; currentStartPosn then
			// this movement starts further up the wharf than the movementToCheck
			if tmpLockout.startMarkOnWharf &lt; closestEndPosn then
				// This lockout is closest to movement on the far end side
				closestEndPosn := tmpLockout.startMarkOnWharf;
			endif;
		else
			// this lockout start further down the wharf than anything else 
			if tmpLockout.endMarkOnWharf &gt; closestStartPosn then
				// This lockout is closest to movement on the start (0m) side
				closestStartPosn := tmpLockout.endMarkOnWharf;
			endif;	
		endif;	

	endforeach;	

	// Calculate clearances
	if self.bowMarkTo &gt; self.sternMarkTo then
		if closestEndPosn &lt; ClearanceUnbounded then
			newForeClearance := closestEndPosn-currentEndPosn;
		else
			// Fore clearance is unrestricted
			newForeClearance := ClearanceUnbounded; 
		endif;
		if closestStartPosn &gt; (-1*(ClearanceUnbounded)) then
			newAftClearance := currentStartPosn-closestStartPosn;
		else
			// Aft clearance is unrestricted
			newAftClearance := ClearanceUnbounded;
		endif;		
	else
		if closestEndPosn&lt;ClearanceUnbounded then
			newAftClearance := closestEndPosn-currentEndPosn;
		else
			// Fore clearance is unrestricted
			newAftClearance := ClearanceUnbounded; 
		endif;
		if closestStartPosn &gt; (-1*(ClearanceUnbounded)) then
			newForeClearance := currentStartPosn-closestStartPosn;
		else
			// Aft clearance is unrestricted
			newForeClearance := ClearanceUnbounded;			
		endif;	

	endif;

	// Calc clearances to wharf ends if unlimited by other vessels.
	if moveBowMark &gt; moveSternMark then
		if newForeClearance = ClearanceUnbounded then
			// Calc clearance from bow to max metre end of wharf
			newForeClearance := ((moveWharf.length) - moveBowMark);
			self.overlapsWharfSection := newForeClearance &lt; minClearance;
		endif;
		if newAftClearance = ClearanceUnbounded then
			// Calc clearance from stern to zero metre end of wharf
			newAftClearance := moveSternMark;
			self.overlapsWharfSection := newAftClearance &lt; minClearance;			
		endif;
	else
		if newAftClearance = ClearanceUnbounded then
			// Calc clearance from stern to max metre end of wharf
			newAftClearance := ((moveWharf.length) - moveSternMark);
			self.overlapsWharfSection := newAftClearance &lt; minClearance;			
		endif;
		if newForeClearance = ClearanceUnbounded then
			// Calc clearance from bow to zero metre end of wharf
			newForeClearance := moveBowMark;
			self.overlapsWharfSection := newForeClearance &lt; minClearance;			
		endif;	
	endif;

	// Calc clearances to wharf section ends if less than current clearances
	foreach section in moveWharf.allWharfSections do
		// Check to see if ship is within any part of this section
		if currentEndPosn &gt;= section.startMeterage 
		and currentStartPosn &lt;= section.endMeterage then
			// Ship overlaps some portion of this section.
			// Calc clearances to sections ends
			// Ship is closer to start of wharf than the end of this section
			distToSectionLimit := (section.endMeterage) - currentEndPosn;
			if moveBowMark &gt; moveSternMark then
				if distToSectionLimit &lt; newForeClearance then
					// Bow closer to section end than stern and....
					// Section end is closer than current foreClearance - reduce clearance;
					newForeClearance := distToSectionLimit;
					self.overlapsWharfSection := true;
				
				endif;
			else
				if distToSectionLimit &lt; newAftClearance then
					// Stern closer to section end than bow and....
					// Section end is closer than current aftClearance - reduce clearance;
					newAftClearance := distToSectionLimit;
					self.overlapsWharfSection := true;
				endif;
			endif;

			// Ship is closer to end of wharf than section start
			distToSectionLimit := currentStartPosn - (section.startMeterage);
			if moveBowMark &gt; moveSternMark then
				if distToSectionLimit &lt; newAftClearance then
					// Stern closer to section start than bow and....
					// Section start is closer than current aftClearance - reduce clearance;
					newAftClearance := distToSectionLimit;
					self.overlapsWharfSection := true;
				
				endif;
			else
				if distToSectionLimit &lt; newForeClearance then
					// Bow closer to section start than stern and....
					// Section start is closer than current foreClearance - reduce clearance;
					newForeClearance := distToSectionLimit;
					self.overlapsWharfSection := true;
				
				endif;
			endif;
		endif;
	endforeach;

	 //16 Apr 2014	NDL	Par 33575 
/*	//epr par 29451 never want a negative clearance
	if newForeClearance &lt; 0 then
		newForeClearance:=0;
	endif;
	
	if newAftClearance &lt; 0 then
		newAftClearance :=0;
	endif;
*/	
	// Update clearances
	self.foreClearanceTo := newForeClearance;
	self.aftClearanceTo := newAftClearance;

	// Check to see if clearances have changed
	if oldAftClearance &lt;&gt; newAftClearance 
	or oldForeClearance &lt;&gt; newForeClearance then
		// Clearances have changed
		self.clearancesHaveChanged := true;
	endif;

end;
</source>
        <Parameter name="closestMoveUpWharf" type="CMIF_HMS_WorkingMovement" usage="output"/>
        <Parameter name="closestMoveDownWharf" type="CMIF_HMS_WorkingMovement" usage="output"/>
    </JadeMethod>
    <JadeMethod name="checkAndSetInitialValues" id="a7821f76-7223-4615-b890-d93998077e03">
        <updating/>
        <source>checkAndSetInitialValues() updating;
//AJA 7/8/00: This checks and sets initial values if required,
//especially where marine services are now needed
vars
	pLaunchLocation:	Integer;
	tugsLocation:		Integer;
	timePilot:			Integer;
	timeTugs:			Integer;
	timeLines:			Integer;
begin
		if numLineCrewRequired = 0 then
			numLineCrewRequired := init_NumLinesCrewReqd;
		endif;

		// Set pilot exempt status
		pilotExempt:= init_IsPilotExempt;

        if sideTo = 0 then
			sideTo := init_Orientation;
		endif;

		// Set pilot launch
		/*if myPilotLaunch = null then
			myPilotLaunch:= init_PilotLaunch; PAR 10455 do not default to first pilot launch
		endif;*/

		// Set pilot
		/*if myPilot = null then
			myPilot:= init_Pilot; PAR 10455 do not default to first pilot
   		endif;*/

		// Set line company
		/*if myLineCompany = null then
			myLineCompany:=init_LineCompany; PAR 10455 do not default to first line company
		endif;*/

		// Set Marine Service order locations (Pilot Launch, Tugs)
		init_MarineServOrderLocations(pLaunchLocation,tugsLocation);
		locationPilotLaunch:=pLaunchLocation;
		locationTug:=tugsLocation;


		// Set relative order times for marine services (if zero at this stage)
		if relativeOrderTimeLines=0 and relativeOrderTimePlaunch=0 and relativeOrderTimeTugs=0 then
			init_MarineServOrderTimes(timePilot,timeTugs,timeLines);
			relativeOrderTimeLines:=timeLines;
			relativeOrderTimePlaunch:=timePilot;
			relativeOrderTimeTugs:=timeTugs;
		endif;	
end;</source>
    </JadeMethod>
    <JadeMethod name="checkIfMovementAlreadyExists" id="06ca1b59-44de-4aef-8638-f81a7bb8a507">
        <source>checkIfMovementAlreadyExists(_viewController : CMIF_HMS_ViewController; _date : Date; _time : Time; _addMode : Boolean) : Boolean;

/*

Purpose:		Checks for existing date / time movement for the voyage

Parameters:			

Return Value:		


Date		Who		Reason
27 July 2010	cnwmh5	Initial creation #23248

*/

vars

	movement	: CMIF_HMS_WorkingMovement;
	currentMovement	: CMIF_HMS_WorkingMovement;
		
	found		: Boolean;
	tsToCheck	: TimeStamp;
	
begin

	// set initial values
	tsToCheck.setDate(_date);
	tsToCheck.setTime(_time);

	// get the view controller and read through allMovementsInViewByDT
	if _viewController &lt;&gt; null then
		currentMovement := _viewController.myCurrentWorkingMovement;
		movement := self.myWorkingVoyage.allWorkingMovements.getAtKey(tsToCheck);
		if movement &lt;&gt; null then  
			if not _addMode and movement &lt;&gt; currentMovement then
				found := true;
				app.raiseCMException3(Canno_date_time_movmt_exists, self.getVoyage().code, 
					_time.asStringJMT, _date.asStringJMT, null, null);
			elseif _addMode then
				found := true;
				app.raiseCMException3(Canno_date_time_movmt_exists, self.getVoyage().code, 
					_time.asStringJMT, _date.asStringJMT, null, null);
			endif;
		endif;
	endif;
	
	return found;
	
epilog

end;</source>
        <Parameter name="_viewController" type="CMIF_HMS_ViewController"/>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_time" type="Time"/>
        <Parameter name="_addMode" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="check_BerthDurationClearances" id="245e10e9-8bcf-412c-a791-e0f3ecdd0491">
        <source>check_BerthDurationClearances(posnParams: CMIF_HMS_WharfPosnCheckParams input;showMsgs:Boolean):Boolean;

vars
   	movement,
   	tempNextMove,
   	tempNextMoveToCheck:CMIF_HMS_WorkingMovement;	
   	closestStartPosn,
   	closestEndPosn,
   	moveStartPosn,
   	moveEndPosn,
   	currentStartPosn,
   	currentEndPosn:		Decimal[12,2];
   	msgBoxType: 		Integer;
   	msgString:			String;
   	harbour:			HMS_Harbour;
   	minClearance:		Integer;
	
begin
	harbour			:=	myHarbour;
	minClearance	:=	harbour.minimumClearance;
	// This method calculates the minimum fore and aft clearances for a movement's duration at a berth, 
	// based the following supplied information	bowMark, sternMark, and the wharf that these marks apply to.

	// Initialise the closestStartPosn and closestEndPosn variables
	closestStartPosn	:=	-1 * (ClearanceUnbounded);
	//closestEndPosn	:=	posnParams.berth.myWharf.length;
	closestEndPosn		:=	ClearanceUnbounded;
	self.berthing_StartEndFromOrient(currentStartPosn,currentEndPosn, posnParams.bowMark, posnParams.sternMark);

 	foreach movement in posnParams.controller.allMovementsInViewByDT
	where ((movement.getMovementNext &lt;&gt; null)
	and (movement.myWorkingVoyage &lt;&gt; posnParams.myWorkingMovementToCheck.myWorkingVoyage))
	do
 		if movement.myBerth &lt;&gt; null then
 			if (posnParams.berth.myWharf = movement.myBerth.myWharf) then
 				tempNextMoveToCheck	:=	posnParams.myWorkingMovementToCheck.getMovementNext();
 				tempNextMove		:=	movement.getMovementNext();
				
 				if movement.occursOnDT &lt;= posnParams.myWorkingMovementToCheck.getMovementNext().occursOnDT
				and movement.getMovementNext().occursOnDT &gt;= posnParams.myWorkingMovementToCheck.occursOnDT
				then
 				// ie. this movement is in existance (overlaps) at the same time as the movementToCheck occurs
 					self.berthing_StartEndFromOrient(moveStartPosn,moveEndPosn, movement.bowMarkTo, movement.sternMarkTo);
					
 					if moveStartPosn &gt; currentStartPosn then
 						// this movement starts further up the wharf than the movementToCheck
 						if moveStartPosn &lt; closestEndPosn then
 							// This is the closest movement on the far end side
 							closestEndPosn	:=	moveStartPosn;
 						endif;
 					else
 						// this movement start further down the wharf than the movementToCheck 
 						if moveEndPosn &gt; closestStartPosn then
 							// This is the closest movement on the start (0m) side
 							closestStartPosn	:=	moveEndPosn;
 						endif;	
 					endif;
				endif;
			endif;
		endif;
	endforeach;

	// Calculate clearances
	if posnParams.bowMark &gt; posnParams.sternMark then
		if closestEndPosn &lt; ClearanceUnbounded then
			posnParams.foreClearance	:=	closestEndPosn-currentEndPosn;
		else
			// Fore clearance is unrestricted
			posnParams.foreClearance	:=	ClearanceUnbounded; 
		endif;
		if closestStartPosn &gt; (-1 * (ClearanceUnbounded)) then
			posnParams.aftClearance	:=	currentStartPosn - closestStartPosn;
		else
			// Aft clearance is unrestricted
			posnParams.aftClearance	:=	ClearanceUnbounded;
		endif;		
	else
		if closestEndPosn &lt; ClearanceUnbounded then
			posnParams.aftClearance	:=	closestEndPosn - currentEndPosn;
		else
			// Fore clearance is unrestricted
			posnParams.aftClearance	:=	ClearanceUnbounded; 
		endif;
		if closestStartPosn &gt; (-1 * (ClearanceUnbounded)) then
			posnParams.foreClearance	:=	currentStartPosn-closestStartPosn;
		else
			// Aft clearance is unrestricted
			posnParams.foreClearance	:=	ClearanceUnbounded;
		endif;	
	endif;

	if self.myHarbour.isDoClearanceCheck then			// cnwdad1 26/02/2007.
		if posnParams.foreClearance &lt; ClearanceUnbounded and posnParams.foreClearance &lt; minClearance then
			// Fore clearance is less than the minimum clearance and is not unbounded
			if showMsgs = true then  
				msgBoxType	:=	MsgBox_OK_Only+MsgBox_Exclamation_Mark_Icon;
				msgString	:=	app.getErrorString(MSGBOX_MinForeClear) &amp; " '" &amp; posnParams.myHMSVoyageData.vesselName &amp; "' " &amp; app.getErrorString(MSGBOX_WhileAtBerth) &amp; "'" &amp; posnParams.berth.description &amp; "' is '" &amp; posnParams.foreClearance.String &amp; "' (m). " &amp; app.getErrorString(MSGBOX_LessThanMinClear) &amp; " '" &amp; harbour.minimumClearance.String &amp; "' (m).";
				msgString	:=	msgString &amp; " " &amp; app.getErrorString(MSGBOX_NegativeClearance);
				app.msgBox(msgString, app.getErrorString(MSGBOX_InsuffientClear), msgBoxType);
			endif;
			
			return false;
			
		elseif posnParams.aftClearance &lt; ClearanceUnbounded and posnParams.aftClearance &lt; minClearance then
			// Aft clearance is less than the minimum clearance and is not unbounded
			if showMsgs = true then  
				msgBoxType	:=	MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon;
				msgString	:=	app.getErrorString(MSGBOX_MinAftClear) &amp; " '" &amp; posnParams.myHMSVoyageData.vesselName &amp; "' " &amp; app.getErrorString(MSGBOX_WhileAtBerth) &amp; "'" &amp; posnParams.berth.description &amp; "' is '" &amp; posnParams.aftClearance.String &amp; "' (m). " &amp; app.getErrorString(MSGBOX_LessThanMinClear) &amp; " '" &amp; harbour.minimumClearance.String &amp; "' (m).";
				msgString	:=	msgString &amp; " " &amp; app.getErrorString(MSGBOX_NegativeClearance);
				app.msgBox(msgString, app.getErrorString(MSGBOX_InsuffientClear), msgBoxType);
			endif;
			
			return false;
		else
			return true;
		endif;
	else
		return true;
	endif;
end;</source>
        <Parameter name="posnParams" type="CMIF_HMS_WharfPosnCheckParams" usage="input"/>
        <Parameter name="showMsgs" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="check_CalcClearances" id="07054e57-d145-4b29-9ed9-58b7e2466186">
        <updating/>
        <source>check_CalcClearances(closestMoveUpWharf, closestMoveDownWharf :	CMIF_HMS_WorkingMovement;
					 _autoPosition : Boolean; _raiseWarnings : Boolean) : Boolean updating;

vars
   	moveOverlaped			: CMIF_HMS_WorkingMovement;
   	voyageForMoves			: CMIF_HMS_WorkingVoyage;
   	msgBoxType				: Integer;
   	msgString				: String;
   	minClearance			: Integer;
   	berthAtShiftedPosn		: HMS_Berth;
   	updateClearances		: Boolean;
   	shiftRequired			: Decimal[12,2];
   	nonShiftedBowMark		: Decimal[12,2];
   	nonShiftedSternMark		: Decimal[12,2]; // RH 26/11
   	voyageDisplayStr		: String;
	section					: HMS_WharfSection;
	outsideSections			: Boolean;
	
begin
	if self.myBerth = null then
		return false;
	elseif self.myBerth.isLogicalBerth() then
		return true;
	endif;
	

	minClearance	:=	self.myHarbour.minimumClearance;

	// This method calculates the minimum fore and aft clearances for a movement's duration at a berth, 
	// based the following supplied information	bowMark, sternMark, and the wharf that these marks apply to.
	if self.myClonedVoyage &lt;&gt; null then
		voyageForMoves	:=	self.myClonedVoyage;
	else
		voyageForMoves	:=	self.myWorkingVoyage;
	endif;

	voyageDisplayStr	:=	voyageForMoves.myHMSVoyageData.vesselName &amp; ' ' &amp; 
				self.moveType &amp; ' movement on ' &amp; self.occursOnDT.shortCurrentLocaleFormat();	

	if _autoPosition then
		// If clearances are invalid for the centered ship, see if it is possible to move the 
		// ship to a new position on the same berth that is OK
		if self.foreClearanceTo&lt;minClearance then
			// Fore clearance is less than the minimum clearance 
			// TEST: Is there enough aft clearance to move the ship in this direction
			//       and still have it on this berth.
			shiftRequired	:=	minClearance - self.foreClearanceTo;
			
			// TEST: see if there is enoght aft clearance to move the ship by the shiftRequired metres.
			if (self.aftClearanceTo-shiftRequired) &gt; minClearance then
				// Modified by RH 26/11	- Store bow and stern marks before shift
				nonShiftedBowMark	:=	bowMarkTo;		
   				nonShiftedSternMark	:=	sternMarkTo;

				// OK to move shift in aft direction
				// Move to new position
				if bowMarkTo &gt; sternMarkTo then
					bowMarkTo	:=	bowMarkTo - shiftRequired;
					sternMarkTo	:=	sternMarkTo - shiftRequired;
				else
					bowMarkTo	:=	bowMarkTo+shiftRequired;
					sternMarkTo	:=	sternMarkTo+shiftRequired;
				endif;
				
				// TEST: Is the centre of the ship still over the target berth.
				berthAtShiftedPosn	:=	berthing_GetBerthFromMarks(bowMarkTo, sternMarkTo, myBerth.myWharf);
				
				if berthAtShiftedPosn &lt;&gt; self.myBerth then
					// Ship has had to be shift off the target berth in order to meet
					// minimum cleranace requirements - warn user
					if bowMarkTo &gt; sternMarkTo then
						moveOverlaped	:=	closestMoveUpWharf;
					else
						moveOverlaped	:=	closestMoveDownWharf;
					endif;
					
					if moveOverlaped &lt;&gt; null then
	                    if moveOverlaped.myWorkingVoyage.myHMSVoyageData.berthPriority &lt; voyageForMoves.myHMSVoyageData.berthPriority then
							msgBoxType	:=	MsgBox_Yes_No + MsgBox_Question_Mark_Icon;
// cnwdad1 14/10/2008 - PAR #16784.
//							msgString	:=	app.getErrorString(MSGBOX_ShipOnBerthLessOlap);
							msgString	:=	app.getErrorString(MSGBOX_ShipOnBerthMoreOlap);
							
							if _raiseWarnings
							and app.msgBox(msgString, app.getErrorString(MSGBOX_ShipAlreadyOnBerthTitle), msgBoxType) &lt;&gt; MsgBox_Return_Yes
							then
								return false;
							else
								// User has chosen to override berth booking priority warning. Set bow and stern
								// marks back to the non-shifted position.
								// Modified by RH 26/11	
								bowMarkTo	:=	nonShiftedBowMark;		
	   							sternMarkTo	:=	nonShiftedSternMark;
							endif; 
						else
							msgBoxType	:=	MsgBox_Yes_No + MsgBox_Question_Mark_Icon;
							msgString	:=	app.getErrorString(MSGBOX_ShipOnBerthMoreOlap);
							
							if _raiseWarnings
							and app.msgBox(msgString, app.getErrorString(MSGBOX_ShipAlreadyOnBerthTitle), msgBoxType) &lt;&gt; MsgBox_Return_Yes
							then
								return false;
							else
								// User has chosen to override berth booking priority warning. Set bow and stern
								// marks back to the non-shifted position.
								// Modified by RH 26/11	
								bowMarkTo	:=	nonShiftedBowMark;		
	   							sternMarkTo	:=	nonShiftedSternMark;
							endif; 
						endif;
					endif;
				else
					// Shift is OK - set new clearances
					foreClearanceTo	:=	minClearance;
					aftClearanceTo	:=	aftClearanceTo - shiftRequired;
				endif;
			else
				// Clearances fore &amp; aft insufficient - messaging below will report this error
			endif;
			
		elseif self.aftClearanceTo &lt; minClearance then
			// Aft clearance is less than the minimum clearance 
			// TEST: Is there enough fore clearance to move the ship in this direction
			//       and still have it on this berth.
			shiftRequired	:=	minClearance - self.aftClearanceTo;
			
			// TEST: see if there is enoght fore clearance to move the ship by the shiftRequired metres.
			if (self.foreClearanceTo - shiftRequired)&gt;minClearance then
				// OK to move shift in fore direction
				// Move to new position             

				// Modified by RH 26/11	- Store bow and stern marks before shift
				nonShiftedBowMark	:=	bowMarkTo;		
   				nonShiftedSternMark	:=	sternMarkTo;

				if bowMarkTo &gt; sternMarkTo then
					bowMarkTo	:=	bowMarkTo+shiftRequired;
					sternMarkTo	:=	sternMarkTo+shiftRequired;
				else
					bowMarkTo	:=	bowMarkTo-shiftRequired;
					sternMarkTo	:=	sternMarkTo-shiftRequired;
				endif;
				
				// TEST: Is the centre of the ship still over the target berth.
				berthAtShiftedPosn	:=	berthing_GetBerthFromMarks(bowMarkTo, sternMarkTo, myBerth.myWharf);
				
				if berthAtShiftedPosn &lt;&gt; myBerth then
					// Ship has had to be shift off the target berth in order to meet
					// minimum cleranace requirements - warn user
					if bowMarkTo &gt; sternMarkTo then
						moveOverlaped	:=	closestMoveDownWharf;
					else
						moveOverlaped	:=	closestMoveUpWharf;
					endif;
					
                    if moveOverlaped.myWorkingVoyage.myHMSVoyageData.berthPriority &lt; voyageForMoves.myHMSVoyageData.berthPriority then
						msgBoxType	:=	MsgBox_Yes_No + MsgBox_Question_Mark_Icon;
// cnwdad1 14/10/2008 - PAR #16784.
//						msgString	:=	app.getErrorString(MSGBOX_ShipOnBerthLessOlap);
						msgString	:=	app.getErrorString(MSGBOX_ShipOnBerthMoreOlap);
						
						if _raiseWarnings
						and app.msgBox(msgString, app.getErrorString(MSGBOX_ShipAlreadyOnBerthTitle), msgBoxType) &lt;&gt; MsgBox_Return_Yes
						then
							return false;
						else
							// User has chosen to override berth booking priority warning. Set bow and stern
							// marks back to the non-shifted position.
							// Modified by RH 26/11	
							bowMarkTo	:=	nonShiftedBowMark;		
   							sternMarkTo	:=	nonShiftedSternMark;
						endif; 
					else
						msgBoxType	:=	MsgBox_Yes_No + MsgBox_Question_Mark_Icon;
						msgString	:=	app.getErrorString(MSGBOX_ShipOnBerthMoreOlap);
						
						if _raiseWarnings
						and app.msgBox(msgString, app.getErrorString(MSGBOX_ShipAlreadyOnBerthTitle), msgBoxType) &lt;&gt; MsgBox_Return_Yes
						then
							return false;
						else
							// User has chosen to override berth booking priority warning. Set bow and stern
							// marks back to the non-shifted position.
							// Modified by RH 26/11	
							bowMarkTo	:=	nonShiftedBowMark;		
   							sternMarkTo	:=	nonShiftedSternMark;
						endif; 
					endif;
				else
					// Shift is OK - set clearances
					foreClearanceTo	:=	foreClearanceTo-shiftRequired;
					aftClearanceTo	:=	minClearance;
				endif;
			else
				// Clearances fore &amp; aft insufficient - messaging below will report this error
			endif;
		endif;
	endif;
	// -------  of if _autoPosition -------------------------------------------------------------------------------
	
	 //16 Apr 2014	NDL	Par 33575 
	if self.myBerth.myWharf &lt;&gt; null and not self.overlapsWharfSection then
		outsideSections := true;
		foreach section in self.myBerth.myWharf.allWharfSections do
			if section.startMeterage &lt; bowMarkTo and section.endMeterage &gt; sternMarkTo then
				// totally within this section
				outsideSections := false;
				break;
			endif;
		endforeach;
	endif;
	
	if (not _raiseWarnings) then
		// Don't raise the message just update the clearances
		updateClearances	:=	true;	
	
	elseif self.foreClearanceTo &lt; ClearanceUnbounded and self.foreClearanceTo &lt; minClearance then
		// Fore clearance is less than the minimum clearance and is not unbounded

		msgBoxType	:=	MsgBox_Yes_No + MsgBox_Question_Mark_Icon;
		msgString	:=	app.getErrorString(MSGBOX_MinForeClear) &amp; " '" &amp; voyageDisplayStr &amp; "' " &amp; app.getErrorString(MSGBOX_WhileAtBerth) &amp; "'" &amp; self.myBerth.description &amp; "' is '" &amp; self.foreClearanceTo.String &amp; "' (m). " &amp; app.getErrorString(MSGBOX_LessThanMinClear) &amp; " '" &amp; minClearance.String &amp; "' (m).";
		
		if self.overlapsWharfSection then
			msgString	:=	msgString &amp; " " &amp; app.getErrorString(MSGBOX_WharfSectionOverlap) &amp; ". " &amp; app.getErrorString(MSGBOX_OverrideOverlapYesNo);
		else
			msgString	:=	msgString &amp; " " &amp; app.getErrorString(MSGBOX_NegativeClearance) &amp; " " &amp; app.getErrorString(MSGBOX_OverrideOverlapYesNo);
		endif;

		if app.msgBox(msgString, app.getErrorString(MSGBOX_InsuffientClear), msgBoxType) &lt;&gt; MsgBox_Return_Yes then
			return false;
		else
			// Update clearances on workingMovement
			updateClearances	:=	true;
		endif; 

	elseif self.aftClearanceTo &lt; ClearanceUnbounded and self.aftClearanceTo &lt; minClearance then
		// Aft clearance is less than the minimum clearance and is not unbounded
		msgBoxType	:=	MsgBox_Yes_No + MsgBox_Question_Mark_Icon;
		msgString	:=	app.getErrorString(MSGBOX_MinAftClear) &amp; " '" &amp; voyageDisplayStr &amp; "' " &amp; app.getErrorString(MSGBOX_WhileAtBerth) &amp; "'" &amp; self.myBerth.description &amp; "' is '" &amp; self.aftClearanceTo.String &amp; "' (m). " &amp; app.getErrorString(MSGBOX_LessThanMinClear) &amp; " '" &amp; minClearance.String &amp; "' (m).";
		
		if self.overlapsWharfSection then
			msgString	:=	msgString &amp; " " &amp; app.getErrorString(MSGBOX_WharfSectionOverlap) &amp; ". " &amp; app.getErrorString(MSGBOX_OverrideOverlapYesNo);
		else
			msgString	:=	msgString &amp; " " &amp; app.getErrorString(MSGBOX_NegativeClearance) &amp; " " &amp; app.getErrorString(MSGBOX_OverrideOverlapYesNo);
		endif;

		if app.msgBox(msgString, app.getErrorString(MSGBOX_InsuffientClear), msgBoxType) &lt;&gt; MsgBox_Return_Yes then
			return false;
		else
			// Update clearances on workingMovement
			updateClearances	:=	true;
		endif;
	elseif outsideSections then	 //16 Apr 2014	NDL	Par 33575
		msgBoxType	:=	MsgBox_Yes_No + MsgBox_Question_Mark_Icon;
		msgString	:=	msgString &amp; " " &amp; app.getErrorString2(HMSWharfSectionUndefined, " ", " ") &amp; CrLf &amp; app.getErrorString(MSGBOX_OverrideOverlapYesNo);
		if app.msgBox(msgString, app.getErrorString(Warning), msgBoxType) &lt;&gt; MsgBox_Return_Yes then
			return false;
		else
			// Update clearances on workingMovement
			updateClearances	:=	true;
		endif;
	else
		// Update clearances on workingMovement
		updateClearances	:=	true;
	endif;

	if updateClearances then
		// Update clearance on workingMovement
		// New Code - Russell 16/03/99
		// -------------------------------------------------------------
		if self.myClonedMovement &lt;&gt; null then
			if self.myClonedMovement.foreClearanceTo &lt;&gt; self.foreClearanceTo 
			or self.myClonedMovement.aftClearanceTo &lt;&gt; self.aftClearanceTo
			then
				self.myClonedMovement.foreClearanceTo	:=	self.foreClearanceTo;
				self.myClonedMovement.aftClearanceTo	:=	self.aftClearanceTo;
				// NOTE: - To get these changes to save to the persistent database, need to set the .notYetSaved property
				// on the working movement to 'true' - CAUTION - this may have unforeseen implications.
			endif;
		endif;
		// --------------------------------------------------------------
		return true;
	else
		return false;
	endif;	
end;</source>
        <Parameter name="closestMoveUpWharf" type="CMIF_HMS_WorkingMovement"/>
        <Parameter name="closestMoveDownWharf" type="CMIF_HMS_WorkingMovement"/>
        <Parameter name="_autoPosition" type="Boolean"/>
        <Parameter name="_raiseWarnings" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="check_Clearances" id="6b8a0a25-310d-40b6-8b33-e706212c2089">
        <updating/>
        <source>check_Clearances(_autoPosition, _raiseWarnings : Boolean) : Boolean updating;

vars
   	closestMoveUpWharf		: CMIF_HMS_WorkingMovement;
   	closestMoveDownWharf	: CMIF_HMS_WorkingMovement;
	errorObj				: Object;
	isInvalid				: Boolean;
	
begin
// cnwdad1 13/10/2008 - PAR #17979.
	on Exception do app.handleDeletedObject(exception, errorObj, isInvalid);
	errorObj	:=	self;
	
	if self.myHarbour.isDoClearanceCheck then		// cnwdad1 26/02/2007.
		// This method calculates the minimum fore and aft clearances for a movement's duration at a berth, 
		// based the following supplied information	bowMark, sternMark, and the wharf that these marks apply to.
		self.calc_Clearances(closestMoveUpWharf, closestMoveDownWharf);
	
		// Check clearances
		if not isInvalid then
			return self.check_CalcClearances(closestMoveUpWharf, closestMoveDownWharf, _autoPosition, _raiseWarnings);
		endif;
	else
		return true;
	endif;
end;</source>
        <Parameter name="_autoPosition" type="Boolean"/>
        <Parameter name="_raiseWarnings" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="check_DateIsValidForClone" id="2559d2f1-5bde-4b44-9255-c3f17b487e39">
        <source>check_DateIsValidForClone(_movementType:String; _moveDate: Date; _moveTime: Time; _selectedVoyage: CMIF_HMS_WorkingVoyage):Boolean;

/*

Date		Who		Reason
19 Mar 2008	cnwkpd1	PAR #16176 - Don't allow Shift movements to be at the same time as
					as the Arrival or Departure
					
*/

vars
   	moveToCheck:	CMIF_HMS_WorkingMovement;
   	arrvMove:		CMIF_HMS_WorkingMovement;
   	deptMove:		CMIF_HMS_WorkingMovement;
   	msgBoxType:		Integer;
   	moveDT,
	chkTS		:	TimeStamp;
	
begin

 	// This method checks that the movement date is valid for a cloned movement/voyage	
	moveDT.setDate(_moveDate);
	moveDT.setTime(_moveTime);

 	if _movementType = HMSMovementTypeArrival then
 		// Arrival Movement - must occur before all other movements
 		arrvMove := _selectedVoyage.allClonedMovements.first;
 		// Get first movement in voyage.allWorkingMovements collection directly after the arrival movement
 		moveToCheck := _selectedVoyage.allClonedMovements.getAtKeyGtr(arrvMove.occursOnDT);
		if moveToCheck.moveType = HMSMovementTypeShift and moveToCheck.myPersistentMovement &lt;&gt; null then
			chkTS := moveToCheck.occursOnDT.addMinutes(-moveToCheck.myPersistentMovement.steamingTime);
		else
			chkTS := moveToCheck.occursOnDT;
		endif;
        if chkTS &lt;= moveDT then			// PAR #16176 - was &lt;
        	// Error - arrival movement must occur before all other movements
			app.raiseCMException2(HMSMovementDateTime, HMSMovementTypeArrival, 'before', ETRow_OccursOnDate, null);			
        	return false;
        endif;
        
        return true;
	
	elseif _movementType = HMSMovementTypeShift then
 		// Shift Movement - must occur after arrival and before departure movements
 		if moveDT &lt;= _selectedVoyage.arrivedDT then				// PAR #16176 - was &lt;
 			// Error - The shift movement cannot occur before the arrival movement
			app.raiseCMException3(HMSMovementShiftDT, 'after', 'Arrival', _selectedVoyage.arrivedDT.shortCurrentLocaleFormat(), ETRow_OccursOnDate, null);			
			return false;
 		
 		elseif moveDT &gt;= _selectedVoyage.departedDT then		// PAR #16176 - was &gt;
 			// Error - The shift movement cannot occur after the departure movement
			app.raiseCMException3(HMSMovementShiftDT, 'before', 'Departure', _selectedVoyage.departedDT.shortCurrentLocaleFormat(), ETRow_OccursOnDate, null);			
			return false;
 		endif;
 		
 		return true;
	
	elseif _movementType = HMSMovementTypeDeparture then
		// Departure Movement - must occur after all other movements
		deptMove := _selectedVoyage.allClonedMovements.last;
 		// Get first movement in voyage.allWorkingMovements collection directly before the departure movement
 		moveToCheck := _selectedVoyage.allClonedMovements.getAtKeyLss(deptMove.occursOnDT);
        if moveToCheck.occursOnDT &gt;= moveDT then				// PAR #16176 - was &gt;
        	// Error - departure movement must occur after all other movements
			app.raiseCMException2(HMSMovementDateTime, HMSMovementTypeDeparture, 'after', ETRow_OccursOnDate, null);        				
			return false;
        endif;
        return true;
 	endif;
	
	return true;
	
end;</source>
        <Parameter name="_movementType" type="String"/>
        <Parameter name="_moveDate" type="Date"/>
        <Parameter name="_moveTime" type="Time"/>
        <Parameter name="_selectedVoyage" type="CMIF_HMS_WorkingVoyage"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="check_DepthsAlongWharf" id="0d80d9b0-320e-481a-b315-2ddd26bdf886">
        <source>check_DepthsAlongWharf(_minDraft: Decimal; fromBerth: HMS_Berth; toBerth: HMS_Berth; _voyageDisplayStr : String);

vars
 	startBerthMark:	Integer;
 	endBerthMark:	Integer;
 	berth:			HMS_Berth;
 	msgBoxType:		Integer;
 	msgString:		String;
	berthDict:		HMS_BerthByCodeDict;
begin
	// This method check the depth of all berths between fromBerth and toBerth on the 
	// same wharf against the minimum depth for a ship

	//Do not reset _rtnValue as the calling method may have warnings

	if fromBerth.startPosition &lt; toBerth.startPosition then
		startBerthMark := fromBerth.startPosition+fromBerth.length;
		endBerthMark := toBerth.startPosition;
	else
		startBerthMark := toBerth.startPosition+toBerth.length;
		endBerthMark := fromBerth.startPosition;
	endif;

	berthDict := fromBerth.myWharf.allBerths;
	
	foreach berth in berthDict do
		if berth.startPosition &gt;= startBerthMark 
		and berth.startPosition &lt; endBerthMark then
			// Check the depth at this berth
			if berth.minimumDepth &lt; _minDraft then
				// Min draft for ship exceeded
				/*msgBoxType:=MsgBox_Yes_No+MsgBox_Question_Mark_Icon;
				msgString:=$MSGBOX_InsufDepthClear &amp; berth.description &amp; ". " &amp; $MSGBOX_AcceptChanges;
				if app.msgBox(msgString, $MSGBOX_InsufDepthClearTitle, msgBoxType)&lt;&gt;MsgBox_Return_Yes then
					return false;
				endif;*/
				app.raiseCMWarning5(HMSDepthsAtToFromBerths, 'minimum', _minDraft.String, _voyageDisplayStr, berth.minimumDepth.String, berth.code, null, null,null);								
			else
				// Draft OK
			endif;
		endif;
	endforeach;

end;</source>
        <Parameter name="_minDraft" type="Decimal"/>
        <Parameter name="fromBerth" type="HMS_Berth"/>
        <Parameter name="toBerth" type="HMS_Berth"/>
        <Parameter name="_voyageDisplayStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="check_TidalWindow" id="449c48b2-9d45-49f0-abab-661f3bc9a118">
        <source>check_TidalWindow();

/*

Date		Who		Reason
26 Mar 2008	cnwkpd1	PAR #16289 - Change Working Movement Drafts to Decimal[8,2] to match HMS_VoyageMovement
28 Jan 2014 cnwdap1	PAR #33337 CCMS PTR 2214 HMS Enhancements
*/

vars
	toBerth:			HMS_Berth;
	fromBerth:			HMS_Berth;
	foreDraft:			Decimal[8,2];			// PAR #16289
	aftDraft:			Decimal[8,2];			// PAR #16289
	msgBoxType:			Integer;
	msgString:			String;
	pathToCheck:		HMS_MovementPath;
	path:				HMS_MovementPath;
	regA:				HMS_HarbourRegion;
	regB:				HMS_HarbourRegion;
	baseTimeAtRegA:		Boolean;
	harbour:			HMS_Harbour;
	directionFwd:		Boolean;
	calcTimeA_B:		Boolean;
	basetime:			TimeStamp;
	checkPoint:			HMS_CheckPoint;
	pathSegment:		HMS_PathSegment;
	regToCheck:			HMS_HarbourRegion;
	offSetTime:			Time;
	minDraft:			Decimal[8,2];			// PAR #16289
	errMsg:				String;
	movePrev:			CMIF_HMS_WorkingMovement;
	enterLeaveStatus:	String;
	vesselDisplayStr:			String;
	berthCode:			String;
	clocksChangeToday: Boolean;
begin
	// This method checks that the all checkpoints and berth depth checks for this movement are 
	// valid 

	// Set reference to harbour
	harbour := self.myHarbour;
	// Set fore and aft draft
	if self.draftMax &gt;= 0.1 then		//4.1.1 Draft Enhancements: Use movement drafts as default
		foreDraft := self.draftFwd;
		aftDraft := self.draftAft;
		vesselDisplayStr := self.myWorkingVoyage.myHMSVoyageData.vesselCode;					
	elseif self.myClonedMovement &lt;&gt; null then
		if self.myClonedMovement.draftMax &gt;= 0.1 then
			foreDraft := self.myClonedMovement.draftFwd;
			aftDraft := self.myClonedMovement.draftAft;		    
		else
			foreDraft := self.myClonedMovement.myWorkingVoyage.myHMSVoyageData.dim_DraftFore;
			aftDraft := self.myClonedMovement.myWorkingVoyage.myHMSVoyageData.dim_DraftAft;
		endif;
		vesselDisplayStr := self.myClonedMovement.myWorkingVoyage.myHMSVoyageData.vesselCode;
	else
		// ---------------------------------------------------------
		if self.myWorkingVoyage &lt;&gt; null then
			foreDraft := self.myWorkingVoyage.myHMSVoyageData.dim_DraftFore;
			aftDraft := self.myWorkingVoyage.myHMSVoyageData.dim_DraftAft;
			vesselDisplayStr := self.myWorkingVoyage.myHMSVoyageData.vesselCode;
		elseif self.myClonedVoyage &lt;&gt; null then
			foreDraft := self.myClonedVoyage.myHMSVoyageData.dim_DraftFore;
			aftDraft := self.myClonedVoyage.myHMSVoyageData.dim_DraftAft;
			vesselDisplayStr := self.myClonedVoyage.myHMSVoyageData.vesselCode;			
		endif;	
		// ---------------------------------------------------------
 	endif;

	vesselDisplayStr := vesselDisplayStr &amp; ' ' &amp; self.moveType &amp; ' movement on ' &amp; self.occursOnDT.shortCurrentLocaleFormat() ;

	if self.moveType = HMSMovementTypeArrival then
		// Arrival movement ie fromBerth=null
		toBerth := self.myBerth;
		fromBerth := null;
		if self.myHarbour.defaultArrvBerth &lt;&gt; null then
			regA := self.myHarbour.defaultArrvBerth.myHarbourRegion;
		endif;
		regB := toBerth.myHarbourRegion;
		// Determine which end of the path the base time needs to be associated with
   		if harbour.baseTimeArrive=AtSea then
   			baseTimeAtRegA := true;
   		endif;		
	elseif self.moveType = HMSMovementTypeDeparture then
		// Departure movement ie toBerth=null
		toBerth := null;
		fromBerth := self.getMovementPrevious.myBerth;
		regA := fromBerth.myHarbourRegion;
		if self.myHarbour.defaultDepartBerth &lt;&gt; null then
			regB := self.myHarbour.defaultDepartBerth.myHarbourRegion;
		endif;
		// Determine which end of the path the base time needs to be associated with
   		if harbour.baseTimeDepart = AtWharf then
   			baseTimeAtRegA := true;
   		endif;
	else
		// Shift movement
		toBerth		:=	self.myBerth;
		movePrev	:=	self.getMovementPrevious();
		
		if movePrev &lt;&gt; null then
			fromBerth := movePrev.myBerth;
			regA := fromBerth.myHarbourRegion;
			regB := toBerth.myHarbourRegion;
			
			// Determine which end of the path the base time needs to be associated with
			if harbour.baseTimeDepart=AtBerthDepartingFrom and (not fromBerth.isLogicalBerth()) then
				baseTimeAtRegA := true;
			endif;
		endif;
	endif;

	// Check depth for 'From Berth'
	if fromBerth &lt;&gt; null then
		berthCode := fromBerth.code;
		if (not fromBerth.isLogicalBerth()) then
			if foreDraft &gt; fromBerth.minimumDepth then
				// Vessel draft exceeds berth minimum depth
				app.raiseCMWarning5(HMSDepthsAtToFromBerths, 'Fore', foreDraft.String, vesselDisplayStr, fromBerth.minimumDepth.String, berthCode, null, null, self.myBerth);												
			elseif aftDraft &gt; fromBerth.minimumDepth then
				// Vessel draft exceeds berth minimum depth
				app.raiseCMWarning5(HMSDepthsAtToFromBerths, 'Aft', aftDraft.String, vesselDisplayStr, fromBerth.minimumDepth.String, berthCode, null, null, null);															
			endif;			
		endif;
	endif;

	// Check depth for 'To Berth'
	if toBerth &lt;&gt; null then
		berthCode := toBerth.code;
		if (not toBerth.isLogicalBerth()) then
			if foreDraft&gt;toBerth.minimumDepth then
				// Vessel draft exceeds berth minimum depth
				app.raiseCMWarning5(HMSDepthsAtToFromBerths, 'Fore', foreDraft.String, vesselDisplayStr, toBerth.minimumDepth.String, berthCode, null, null, null);												
			elseif aftDraft &gt; toBerth.minimumDepth then
				// Vessel draft exceeds berth minimum depth
				app.raiseCMWarning5(HMSDepthsAtToFromBerths, 'Aft', aftDraft.String, vesselDisplayStr, toBerth.minimumDepth.String, berthCode, null, null, null);																
			endif;			
		endif;
	endif;

	// Get Enter/Leaving harbour status for movement
	movePrev := self.getMovementPrevious;
	enterLeaveStatus := self.getShipEnterLeaveStatus(regA,regB,movePrev);

	// Check to see if a path is defined. If it is, then check checkpoints on path
    foreach path in harbour.allMovementPaths do
    	if path.myRegionFrom=regA and path.myRegionTo=regB then
    		pathToCheck := path;
    		// Set direction along path to fwd=true ie. The ship is travelling
    		// from regA to regB
    		directionFwd := true;
    	elseif path.myRegionFrom=regB and path.myRegionTo=regA then
    		pathToCheck := path;
    		// Set direction along path to fwd=false ie. The ship is travelling
    		// from regB to regA
    		directionFwd := false;
    		// Swap BT for reverse direction
    		baseTimeAtRegA := not(baseTimeAtRegA);

    	endif;
    endforeach;

 	if pathToCheck &lt;&gt; null then
   		// Check this path. Step through all regions along path and
   		// check their respective checkpoints at the appropriately offset times

		// Set basetime to movement time   	
		basetime := self.occursOnDT;   	
		
		// PAR 10371
		// Check the daylight saving time status of the move time
		if harbour.checkIfDaylightSaving(basetime, clocksChangeToday) //&lt;&lt;-- If move time is daylight saving time
		and (not harbour.checkIfDaylightSaving(app.actualTimeServer, clocksChangeToday)) then //&lt;&lt;-- and system time isn't daylight saving time
			// Convert move time from NZDT to NZST
			basetime := basetime.changeByXXMinutes(-60); //&lt;&lt;-- make move time to check standard time as system time is stardard time
		elseif harbour.checkIfDaylightSaving(app.actualTimeServer, clocksChangeToday) //&lt;&lt;-- if system time is daylight savings time
		and (not harbour.checkIfDaylightSaving(basetime, clocksChangeToday)) then //&lt;&lt;-- and move time is standard time then
			// Move time is standard time but system time is Daylight time
			// Convert time to daylight time
			basetime := basetime.changeByXXMinutes(60);	//&lt;&lt;-- make move time daylight savings time as system is daylight saving time	
		endif;

       	if (baseTimeAtRegA = true and directionFwd = true) then
   			// Check regions along path in direction = from 'A' to 'B'
			// Check checkpoints at reg A at basetime
			if regA.hasCheckpointsWithTidalModel() then
				// Checkpoints to check
				if app.myHMSRvTide.getChkPointState(regA,self,self.moveType,basetime,errMsg,enterLeaveStatus)=false then
					// Check point at region A has failed
					if not harbour.suppressTidalWarnings then										// PAR #33337
						app.raiseCMWarning2(HMSTidalWindow, regA.code, errMsg, null, null, regA);						
					endif;																			// PAR #33337
				endif;
			endif;
			foreach pathSegment in pathToCheck.allPathSegments do
				regToCheck := pathSegment.myRegionTo;
				offSetTime.setTime(0, pathSegment.steamingTimeAB, 0, 0);
				basetime := basetime+offSetTime;
				if regToCheck.hasCheckpointsWithTidalModel() then
					if app.myHMSRvTide.getChkPointState(regToCheck,self,self.moveType,basetime,errMsg,enterLeaveStatus)=false then
						// Check point at region B has failed
						if not harbour.suppressTidalWarnings then									// PAR #33337
							app.raiseCMWarning2(HMSTidalWindow, regToCheck.code, errMsg, null, null, regToCheck);							
						endif;																		// PAR #33337
					endif;
				endif;
			endforeach;
   		elseif (baseTimeAtRegA = false and directionFwd = true) then
   			// Check regions along path in direction = from 'B' to 'A'
			// Check checkpoints at reg B at basetime
			//if regB.allCheckpoints.size&gt;0 then
				// Checkpoints to check
				if app.myHMSRvTide.getChkPointState(regB,self,self.moveType,basetime,errMsg,enterLeaveStatus)=false then
					// Check point at region B has failed
					if not harbour.suppressTidalWarnings then										// PAR #33337
						app.raiseCMWarning2(HMSTidalWindow, regB.code, errMsg, null, null, regB); 						
					endif;																			// PAR #33337
   				endif;
   			//endif;
			foreach pathSegment in pathToCheck.allPathSegments reversed do
				regToCheck := pathSegment.myRegionFrom;
				offSetTime.setTime(0, pathSegment.steamingTimeAB, 0, 0);
				basetime := basetime-offSetTime;
				if regToCheck.hasCheckpointsWithTidalModel() then
					if app.myHMSRvTide.getChkPointState(regToCheck, self, self.moveType, basetime, errMsg, enterLeaveStatus) = false then
						// Check point at region A has failed
						if not harbour.suppressTidalWarnings then									// PAR #33337
							app.raiseCMWarning2(HMSTidalWindow, regToCheck.code, errMsg, null, null, regToCheck);    														
						endif;																		// PAR #33337
					endif;
				endif;
			endforeach;
   		elseif (baseTimeAtRegA = true and directionFwd = false) then
   			// Check regions along path in direction = from 'B' to 'A'
			// Check checkpoints at reg A at basetime
			if regA.hasCheckpointsWithTidalModel() then
				// Checkpoints to check
				if app.myHMSRvTide.getChkPointState(regA,self,self.moveType,basetime,errMsg,enterLeaveStatus)=false then
					// Check point at region A has failed
					if not harbour.suppressTidalWarnings then										// PAR #33337
						app.raiseCMWarning2(HMSTidalWindow, regA.code, errMsg, null, null, regA);						
					endif;																			// PAR #33337
				endif;
			endif;
			foreach pathSegment in pathToCheck.allPathSegments do
				regToCheck := pathSegment.myRegionTo;
				offSetTime.setTime(0,pathSegment.steamingTimeBA,0,0);
				basetime := basetime-offSetTime;
				if regToCheck.hasCheckpointsWithTidalModel() then
					if app.myHMSRvTide.getChkPointState(regToCheck,self,self.moveType,basetime,errMsg,enterLeaveStatus)=false then
						// Check point at region B has failed
						if not harbour.suppressTidalWarnings then									// PAR #33337
							app.raiseCMWarning2(HMSTidalWindow, regToCheck.code, errMsg, null, null, regToCheck);   														
						endif;																		// PAR #33337
					endif;
				endif;
			endforeach;
   		elseif (baseTimeAtRegA = false and directionFwd = false) then
   			// Check regions along path in direction = from 'B' to 'A'
			// Check checkpoints at reg B at basetime
			if regB.hasCheckpointsWithTidalModel() then
				// Checkpoints to check
				if app.myHMSRvTide.getChkPointState(regB,self,self.moveType,basetime,errMsg,enterLeaveStatus)=false then
					// Check point at region B has failed
					if not harbour.suppressTidalWarnings then										// PAR #33337
						app.raiseCMWarning2(HMSTidalWindow, regB.code, errMsg, null, null, regB);   							   												
					endif;																			// PAR #33337
				endif;
			endif;

			foreach pathSegment in pathToCheck.allPathSegments reversed do
				regToCheck := pathSegment.myRegionFrom;
				offSetTime.setTime(0,pathSegment.steamingTimeBA,0,0);
				basetime := basetime+offSetTime;
				if regToCheck.hasCheckpointsWithTidalModel() then
					if app.myHMSRvTide.getChkPointState(regToCheck,self,self.moveType,basetime,errMsg,enterLeaveStatus)=false then
						// Check point at region A has failed
						if not harbour.suppressTidalWarnings then									// PAR #33337
							app.raiseCMWarning2(HMSTidalWindow, regToCheck.code, errMsg, null, null, regToCheck); 
						endif;																		// PAR #33337
					endif;
				endif;
			endforeach;
   		endif;
   	else
   		// If path is not defined and to &amp; from berths are on the same wharf, check
		// all berth depths in between.
		if fromBerth &lt;&gt; null 
		and toBerth &lt;&gt; null then
			if fromBerth.myWharf = toBerth.myWharf 
			and (not fromBerth.isLogicalBerth()) then
				// Both berths are on the same wharf and the wharf is a physical wharf
				// Check the depths alomg the wharf
				if foreDraft &gt; aftDraft then
					minDraft := foreDraft;
				else
					minDraft := aftDraft;
				endif;	
				self.check_DepthsAlongWharf(minDraft, fromBerth, toBerth, vesselDisplayStr);
			endif;
		endif;
   	endif;



end;</source>
    </JadeMethod>
    <JadeMethod name="check_WharfLockouts" id="36eab1e3-72d6-45cd-8a54-1d74c3693960">
        <source>check_WharfLockouts();

vars
	nextMove:		CMIF_HMS_WorkingMovement;
	lockout:		HMS_WharfLockout;
	moveStart:		TimeStamp;
	moveEnd:		TimeStamp;
	shipStart,
	shipEnd:		Decimal[12,2];
	msgBoxType:		Integer;
	msgString:		String;
	lockDetails:	String;
	theWharf:		HMS_Wharf;
begin
	// This method checks the current movement to see if any section of the 
	// wharf that it is occuping is locked out at any stage before the next
	// movement in this voyage.

	if self.moveType=HMSMovementTypeDeparture then
		// Checks N/A
		return;
	else
		// Get next move in voyage
		nextMove:= self.getMovementNext;
		if nextMove = null then
		 	// This method checks that the movement date is valid for a cloned movement/voyage
		 	if self.moveType = HMSMovementTypeArrival then
		 		// Arrival Movement - must occur before all other movements
		       	// Error - arrival movement must occur before all other movements
				app.raiseCMException2(HMSMovementDateTime, HMSMovementTypeArrival, 'before', ETRow_OccursOnDate, null);
		 	elseif self.moveType = HMSMovementTypeShift then
				// Error - The shift movement cannot occur after the departure movement
				app.raiseCMException3(HMSMovementShiftDT, 'before', 'Departure', null, ETRow_OccursOnDate, null);
			endif;
		else
			moveEnd := nextMove.occursOnDT;		
		endif;
		moveStart := self.occursOnDT;
	endif;
	
	// Check that berth for current move is not logical
	if self.isLogicalBerth() then
		// Wharf is logical - check N/A
		return;
	endif;
	
	theWharf := self.myBerth.myWharf;
	// Get ship position on wharf
	if self.bowMarkTo &lt; self.sternMarkTo then
		shipStart := self.bowMarkTo;
		shipEnd := self.sternMarkTo;
	else
		shipStart := self.sternMarkTo;
		shipEnd := self.bowMarkTo;
	endif;
	// Modified by Russell 07/04/99 
	// ------------------------------------------------------------------------------
	// Wharf is physical - Check for PERMANENT Lockouts
	// NOTE: - These lockouts cannot be over-ridden
	foreach lockout in self.myHarbour.allWLockoutsPermanent 
	where lockout.startOfLockoutDT &lt; moveEnd 
	and lockout.endOfLockoutDT &gt; moveStart do
		// These lockouts occur within the time that the movement stay at the toBerth
		if lockout.myWharf = theWharf then
			// Lockout applies to same wharf as move.myBerth
			// Check position along wharf
			if shipStart &lt; lockout.endMarkOnWharf 
			and shipEnd &gt; lockout.startMarkOnWharf then
				// This section of the wharf is PERMANENTLY locked out - notify user
				// NOTE: - These lockouts cannot be over-ridden
				app.raiseCMException4(HMSWharfLockout, theWharf.code, lockout.startMarkOnWharf.String, lockout.endMarkOnWharf.String, lockout.reason, null, null);					
			endif;
		endif;
	endforeach;

	// Wharf is physical - check for lockouts
	foreach lockout in self.myHarbour.allWLockoutsByStartDT 
	where lockout.startOfLockoutDT &lt; moveEnd 
	and lockout.endOfLockoutDT &gt; moveStart do
		// These lockouts occur within the time that the movement stay at the toBerth
		if lockout.myWharf = theWharf then
			// Lockout applies to same wharf as move.myBerth
			// Check position along wharf
			if shipStart &lt; lockout.endMarkOnWharf 
			and shipEnd &gt; lockout.startMarkOnWharf then
				// This section of the wharf is locked out - notify user
				app.raiseCMWarning4(HMSWharfLockout, theWharf.code, lockout.startMarkOnWharf.String, lockout.endMarkOnWharf.String, lockout.reason, null, null, self.myBerth);										
			endif;
		endif;
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="check_WharfOverHang" id="280ca597-97fa-4ed5-9cc9-5e99af995fd9">
        <source>check_WharfOverHang();

vars
	wharfMin:			Integer;
	wharfMax:			Integer;
	overhangAllowance:	Integer;
	invalid:			Boolean;
	whichMarkExceeded:	String;
	markValue,
	proposedOverhang:	Decimal[12,2];	
	theWharf:			HMS_Wharf;
	
begin
	// This method checks whether the bow and stern marks for the ship's position 
	// are valid for the wharf in question - this takes into account overhang allowances.
	
	if not self.myHarbour.isDoClearanceCheck then		// cnwdad1 12/02/2008.
		return;
	endif;
	
	theWharf := self.myBerth.myWharf;
	
	wharfMin := 0-(theWharf.overhangZeroMetreEnd);
	wharfMax := (theWharf.length) + (theWharf.overhangMaxMetreEnd);

	if self.bowMarkTo &lt; wharfMin then
		proposedOverhang := self.bowMarkTo.abs;
		overhangAllowance := theWharf.overhangZeroMetreEnd;
		invalid := true;
		whichMarkExceeded := 'Bow Mark';
		markValue := self.bowMarkTo;
	elseif self.sternMarkTo &lt; wharfMin then
		proposedOverhang := self.sternMarkTo.abs;
		overhangAllowance := theWharf.overhangZeroMetreEnd;
		invalid := true;
		markValue := self.sternMarkTo;
		whichMarkExceeded := 'Stern Mark';
	elseif self.bowMarkTo &gt; wharfMax then
		proposedOverhang := self.bowMarkTo-(wharfMax-theWharf.overhangMaxMetreEnd);
		overhangAllowance := theWharf.overhangMaxMetreEnd;
		invalid := true;
		markValue := self.bowMarkTo;
		whichMarkExceeded := 'Bow Mark';
	elseif self.sternMarkTo &gt; wharfMax then
		proposedOverhang := self.sternMarkTo-(wharfMax-theWharf.overhangMaxMetreEnd);
		overhangAllowance := theWharf.overhangMaxMetreEnd;
		invalid := true;
		markValue := self.sternMarkTo;
		whichMarkExceeded := 'Stern Mark';
	endif;

	if invalid then
		// MSG - ship cannot exceed wharf overhang allowance of XX meters
		app.raiseCMException4(HMSWharfOverhang, whichMarkExceeded, markValue.String, overhangAllowance.String, theWharf.code, null, null);			
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="clonedMove_CalcSternPosn" id="b5366f4c-2a32-42da-b40a-58537f0365f2">
        <updating/>
        <source>clonedMove_CalcSternPosn() updating;
//
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------------------
// 21/10/2013	cnwdap1		PAR #32744 Stop bow/stern miscalculations when only the time was changed, 
//							and that meant the ship sprite was drawn off the wharf
//							
vars
	displayMarksLeftToRight,								// PAR #32744
    waterOnLeftmyWharf:	Boolean;
    loa:				Decimal[6,2];
begin
 	// This method calculates the stern position for a ship, when supplied with the 
 	// bow mark, berth, and orientation, and ship L.O.A.

 	waterOnLeftmyWharf:=self.myBerth.myWharf.waterOnLeft;
	displayMarksLeftToRight:=self.myBerth.myWharf.displayLeftToRight;
 	if self.myClonedVoyage&lt;&gt;null then
 		loa:=self.myClonedVoyage.myHMSVoyageData.dim_LengthOverall;
 	else	
 		loa:=self.myWorkingVoyage.myHMSVoyageData.dim_LengthOverall;
    endif;
	
	// PAR #32744 re-jig following code to try to clarify what's going on....
	// The order here is important - wharf first, then berth, then ship
	if waterOnLeftmyWharf and displayMarksLeftToRight and self.sideTo = OrientPortSideTo then
		self.sternMarkTo := self.bowMarkTo + loa;
	elseif waterOnLeftmyWharf and displayMarksLeftToRight and self.sideTo = OrientStarboardSideTo then
		self.sternMarkTo := self.bowMarkTo - loa;
	elseif waterOnLeftmyWharf and not displayMarksLeftToRight and self.sideTo = OrientPortSideTo then
		self.sternMarkTo := self.bowMarkTo + loa;
	elseif waterOnLeftmyWharf and not displayMarksLeftToRight and self.sideTo = OrientStarboardSideTo then
		self.sternMarkTo := self.bowMarkTo - loa;
	elseif not waterOnLeftmyWharf and displayMarksLeftToRight and self.sideTo = OrientPortSideTo then
		self.sternMarkTo := self.bowMarkTo - loa;
	elseif not waterOnLeftmyWharf and displayMarksLeftToRight and self.sideTo = OrientStarboardSideTo then
		self.sternMarkTo := self.bowMarkTo + loa;
	elseif not waterOnLeftmyWharf and not displayMarksLeftToRight and self.sideTo = OrientPortSideTo then
		self.sternMarkTo := self.bowMarkTo - loa;
	elseif not waterOnLeftmyWharf and not displayMarksLeftToRight and self.sideTo = OrientStarboardSideTo then
		self.sternMarkTo := self.bowMarkTo + loa;
	endif;
	// PAR #32744 end - old code is below
	/*//epr par 30973 22/2/13
 	if waterOnLeftmyWharf=true and self.sideTo=OrientPortSideTo then
    	// CASE A: Water on left of wharf, ship is PortSideTo, bowMark=min, sternMark=max
		if displayMarksLeftToRight then
			self.sternMarkTo:=self.bowMarkTo-loa;
		else
			self.sternMarkTo:=self.bowMarkTo+loa;
		endif;
    elseif waterOnLeftmyWharf=true and self.sideTo=OrientStarboardSideTo then
    	// CASE B: Water on left of wharf, ship is StarboardSideTo, bowMark=max, sternMark=min
		if displayMarksLeftToRight then
			self.sternMarkTo:=self.bowMarkTo+loa;
		else
			self.sternMarkTo:=self.bowMarkTo-loa;
		endif;
    elseif waterOnLeftmyWharf=false and self.sideTo=OrientPortSideTo then
    	// CASE C: Water on right of wharf, ship is PortSideTo, bowMark=max, sternMark=min
		if displayMarksLeftToRight then
			self.sternMarkTo:=self.bowMarkTo-loa;
		else
			self.sternMarkTo:=self.bowMarkTo+loa;
		endif;
    elseif waterOnLeftmyWharf=false and self.sideTo=OrientStarboardSideTo then
    	// CASE D: Water on right of wharf, ship is StarboardSideTo, bowMark=min, sternMark=max
		if displayMarksLeftToRight then
			self.sternMarkTo:=self.bowMarkTo+loa;
		else
			self.sternMarkTo:=self.bowMarkTo-loa;
		endif;
    endif;
	write "old  bowMarkTo " &amp; self.bowMarkTo.String &amp; ", sternMarkTo " &amp; self.sternMarkTo.String;
*/
end;</source>
    </JadeMethod>
    <JadeMethod name="clonedMove_CentreShip" id="5318e568-95db-4cb0-92d2-16eb11459443">
        <updating/>
        <source>clonedMove_CentreShip(_loa : Decimal) : Boolean updating;

vars
	
begin
	// This method returns bow and stern marks for the ship that are centred on the
	// berth supplied.
	
	if self.myBerth &lt;&gt; null then
		self.myBerth.getMarksForCentringOnBerth(_loa, self.sideTo, self.bowMarkTo, self.sternMarkTo);
		return true;
	else
		return false;
	endif;
	

end;</source>
        <Parameter name="_loa" type="Decimal"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clonedMove_RefreshMarks" id="e2709e06-5b85-4745-bd5c-312c86c2da67">
        <updating/>
        <source>clonedMove_RefreshMarks():Boolean updating;

vars
	loa:				Decimal[6,2];
	waterOnLeftOfWharf:	Boolean;	
begin
	// This method refreshes the bow and stern marks for the ship (based on its current
	// database image). NOTE - the position to be changed (bow or stern) is determined from
	// the current display orientation of the wharves on the screen

	if self.myClonedVoyage&lt;&gt;null then
 		loa:=self.myClonedVoyage.myHMSVoyageData.dim_LengthOverall;
 	else	
 		loa:=self.myWorkingVoyage.myHMSVoyageData.dim_LengthOverall;
    endif;

    // Check to see if ship length has changed
    if (self.bowMarkTo-self.sternMarkTo).Integer.abs&lt;&gt;loa then
    	// Length has changed - recalc marks
    	if (not self.isLogicalBerth()) then
    		if self.myBerth.myWharf.displayLeftToRight=false then
    			// Adjust ship mark on end closest to zeroMeter end of wharf
    			if self.bowMarkTo&gt;self.sternMarkTo then
    				// Stern closest to zeroMeter end of wharf
    				self.sternMarkTo:=self.bowMarkTo-loa;
    			else
    				// Bow closest to zeroMeter end of wharf
    				self.bowMarkTo:=self.sternMarkTo-loa;
    			endif;
    		else
    			// Adjust ship mark on end closest to maxMeter end of wharf
    			if self.bowMarkTo&gt;self.sternMarkTo then
    				// Bow closest to maxMeter end of wharf
    				self.bowMarkTo:=self.sternMarkTo+loa;
    			else
    				// Stern closest to maxMeter end of wharf
    				self.sternMarkTo:=self.bowMarkTo+loa;
    			endif;
    		endif;
    		// Marks have changed
    		return true;
    	else
    		// Logical wharf - marks not relevant
    		return false;
    	endif;
    else
    	// Length still OK 
    	return false;
	endif;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="clonedMove_SetActOrPlanAsReqd" id="3e5d843b-5c8a-46ec-ae72-6d86ba62df28">
        <updating/>
        <source>clonedMove_SetActOrPlanAsReqd(newTime:	TimeStamp) updating;

vars
	now:	TimeStamp;
begin
	//now:="22 February 1999, 00:00:00".TimeStamp; // For testing only
 	// When the time that is being set is less than the current time,
 	// ask the user if they wish to set the 'Actual' or the 'Planned' Time.
	
	if newTime &gt; now  and self.moveStatus = MovementStatus_Actual then
		self.moveStatus := MovementStatus_Planned;		
	else
	
		if newTime &lt; now
		and self.moveStatus &lt;&gt; MovementStatus_Actual then
			// Ask user if 'Act' or 'Plan'
			if app.msgBox(app.getErrorString(HMS_ActualTimeForMove), app.getErrorString(Confirm_ACTUAL_Time), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
				// Time is actual
				self.moveStatus := MovementStatus_Actual;		
			endif;
		endif;	
	endif;
end;</source>
        <Parameter name="newTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="clonedMove_SetActualTimeIfReqd" id="d8982b33-c056-45e7-9020-9dbeb60c2545">
        <updating/>
        <source>clonedMove_SetActualTimeIfReqd(_newTime: TimeStamp) updating;

vars
	now:		TimeStamp;
	msgString:	String;
begin
	//now:="22 February 1999, 00:00:00".TimeStamp; // For testing only

 	// When the time that is being set is less than the current time,
 	// ask the user if they wish to set the 'Actual' or the 'Planned' Time.
	if _newTime &gt; now and self.moveStatus = MovementStatus_Actual then
		self.moveStatus := MovementStatus_Planned;		
	else
		if _newTime &lt; now 
		and self.moveStatus &lt;&gt; MovementStatus_Actual then
			// Ask user if 'Act' or 'Plan'
			msgString := app.getErrorString2(HMSMovementActualDT, self.moveType, _newTime.shortCurrentLocaleFormat());
			/*msgString:="The time that the '" &amp; self.moveType &amp; "' movement occurs on has passed." &amp; CrLf;
			msgString:=msgString &amp; "Do you wish to confirm that '" &amp; newTime.Date.format("dd MMM yy")  &amp; ", " &amp; newTime.Time.userFormat($HMS_Time24Hour) &amp; "'" &amp; CrLf;
			msgString:=msgString &amp; "is now the 'ACTUAL' time that this movement occurred?";*/
			if app.msgBox(msgString, app.getErrorString(Confirm_ACTUAL_Time), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
				// Time is actual
				self.moveStatus := MovementStatus_Actual;
			endif;
		endif;
	endif;

end;</source>
        <Parameter name="_newTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="copyMovement" id="39bf2775-7dd9-4f57-aad8-92f0d457d985">
        <updating/>
        <source>copyMovement(_fromMovement : HMS_VoyageMovement input;
			 workingVoyage : CMIF_HMS_WorkingVoyage;
			 permanentVoyage : HMS_VoyageData;
			 auditActive : Boolean;
			 _passport : CM_Passport input) updating;
// 29 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
//14 Sep 2022 	navgm20	ChangeRequest 54739: EUP - PLAN - Berth planning by bollards

vars
 	permResourceUsed:		HMS_ResourceUsed;
 	workResourceUsed:		CMIF_HMS_ResourceUsed;
 	tug:					HMS_Tug;
	cancelledWorkingMovement: 	CMIF_HMS_WorkingMovement;

begin
	// This method copies permanent movement information to a working movement and 
	self.aftClearanceTo := _fromMovement.aftClearanceTo;
	self.isAgentDefault := _fromMovement.isAgentDefault;
	self.bowMarkTo := _fromMovement.bowMarkTo;
	self.foreClearanceFrom := _fromMovement.foreClearanceFrom;
	self.foreClearanceTo := _fromMovement.foreClearanceTo;
	self.locationPilotLaunch := _fromMovement.locationPilotLaunch;
	self.locationTug := _fromMovement.locationTug;
	self.moveType := _fromMovement.moveType;
	self.numLineCrewRequired := _fromMovement.numLineCrewRequired;

	self.occursOnDT := _fromMovement.occursOnDTNEW;
	self.vesselDraft	:=	_fromMovement.vesselDraft;
	self.relativeOrderTimeLines := _fromMovement.relativeOrderTimeLines;
	self.relativeOrderTimePlaunch := _fromMovement.relativeOrderTimePlaunch;
	self.relativeOrderTimeTugs := _fromMovement.relativeOrderTimeTugs;
	self.remarks := _fromMovement.remarks;
	self.pilotExempt := _fromMovement.pilotExempt;
	self.shipsMaster := _fromMovement.shipsMaster;
	self.chargeForMove := _fromMovement.chargeForMove;
	self.sideTo := _fromMovement.sideTo;
	self.sternMarkTo := _fromMovement.sternMarkTo;

	//14/09/2022 navgm20 TFS 54739- Start
	self.bowToBollard	:= _fromMovement.bowToBollard;
	self.sternToBollard	:= _fromMovement.sternToBollard;
	self.bridgeToBollard	:= _fromMovement.bridgeToBollard;
	self.myBowBollard	:= _fromMovement.myBowBollard;
	self.mySternBollard	:= _fromMovement.mySternBollard;
	self.myBridgeBollard	:= _fromMovement.myBridgeBollard;
	//14/09/2022 navgm20 TFS 54739- End
	
    // Modified by Russell 09/08/99
    // ---------------------------------------------------------------------
    //self.moveDTActual := _fromMovement.moveDTActual;
    //self.moveDTPlanned := _fromMovement.moveDTPlanned;
    self.moveStatus := _fromMovement.moveStatusNEW;
    // ---------------------------------------------------------------------

 	// Update references
 	//self.myPilot := _fromMovement.getMyPilot;
	
	//31 Oct 2018	NDL	TFS 41662
	/*self.allPilots.clear(); // --&gt; TFS 44438
	if _fromMovement.allPilots.isEmpty then
		 if _fromMovement.getUnConvertedMyPilotRef &lt;&gt; null then // converting single to multi
			self.allPilots.add( _fromMovement.getUnConvertedMyPilotRef );
		 endif;
	else
		_fromMovement.allPilots.copy( self.allPilots );
	endif;*/ // &lt;-- TFS 44438

 	self.myMaster := _fromMovement.myMaster;
 	//self.myPilotLaunch := _fromMovement.myPilotLaunch; // TFS 44438
 	self.myLineCompany := _fromMovement.myLineCompany;
 	self.myShippingAgent := _fromMovement.myShippingAgent;
 	self.myShippingLine := _fromMovement.myShippingLine;
 	self.myContact := _fromMovement.myContact;

	self.draftFwd := _fromMovement.draftFwd;	//4.1.1 Draft Enhancements
	self.draftAft := _fromMovement.draftAft;

 	foreach tug in _fromMovement.allTugsUsed do
 		self.allTugsUsed.add(tug);
 	endforeach;

 	self.myBerth := _fromMovement.getMyBerth;
 	self.myMoveTidalClass := _fromMovement.myTidalClass;
 	self.myHarbour := _fromMovement.myHarbour;
 	self.myWorkingVoyage := workingVoyage;
 	self.myPersistentMovement := _fromMovement;
 	self.myHMSVoyageData := _fromMovement.myHMSVoyageData;

 	// Add movement to the working voyage collection allWorkingMovements
	if self.myWorkingVoyage &lt;&gt; null then
		self.myWorkingVoyage.allWorkingMovements.add(self);
	endif;
 	// Create workingResourceUsed objs for each permanentResourceUsed object
 	self.setResourcesUsed(_fromMovement, null);
	self.setMvmntPilotDetails(_fromMovement, null); // TFS 44438
 	/*Now Done above in self.setResourcesUsed.
 	foreach permResourceUsed in _fromMovement.allResourceUsed do
 		create workResourceUsed transient;
 		workResourceUsed.myPersistentResourceUsed := permResourceUsed;
 		workResourceUsed.myResource := permResourceUsed.myResource;
 		workResourceUsed.myResourceType := permResourceUsed.myResourceType;
		workResourceUsed.myWorkingMovement := self;
		workResourceUsed.myViewController := self.myViewController;
		workResourceUsed.notYetSaved := false; 		
		workResourceUsed.fromDateTime := permResourceUsed.fromDateTime;
		workResourceUsed.toDateTime := permResourceUsed.toDateTime;
		workResourceUsed.unitsUsed := permResourceUsed.unitsUsed;
  	endforeach;*/
	
	self.createPxyMarineServiceTimings( _fromMovement );	//19 Jun 2018	NDL	TFS 39215
	
	//20 Nov 2018	NDL	TFS 42043
	if _fromMovement.myCancelledMovement &lt;&gt; null then
		create cancelledWorkingMovement;
		cancelledWorkingMovement.copyMovement(_fromMovement.myCancelledMovement.HMS_VoyageMovement, null, null, false, _passport );
		self.myCancelledMovement := cancelledWorkingMovement;
	endif;

end;</source>
        <Parameter name="_fromMovement" type="HMS_VoyageMovement" usage="input"/>
        <Parameter name="workingVoyage" type="CMIF_HMS_WorkingVoyage"/>
        <Parameter name="permanentVoyage" type="HMS_VoyageData"/>
        <Parameter name="auditActive" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createClone" id="24f35979-e7d0-412e-9ac2-de1319714e49">
        <updating/>
        <source>createClone(cloneWorkingVoyage: CMIF_HMS_WorkingVoyage; myReplacement : CMIF_HMS_WorkingMovement input ) updating;
// 29 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
//22 Sep 2022 navsj20	ChangeRequest 54739: EUP - PLAN - Berth planning by bollards

vars
 	clonedMovement:			CMIF_HMS_WorkingMovement;
 	workResourceUsed,
 	newWorkResourceUsed:	CMIF_HMS_ResourceUsed;
 	tug:					HMS_Tug;
	clonedCancelledMovement: CMIF_HMS_WorkingMovement;
	tempMvmntPilotDetails, // TFS 44438
	cloneMvmntPilotDetails	: HMS_MovementPilotDetails; // TFS 44438
begin
 	// This method creates a temporary clone of a working movement for checking/reversal purposes
 	// Get lastest copy of all referenced objects when creating clone

 	create clonedMovement transient;
 	clonedMovement := self.cloneSelf(true);
 	clonedMovement.cloneHasChanged := false;
	clonedMovement.myPersistentMovement := self.myPersistentMovement;
	clonedMovement.myBerth := self.myBerth;

    clonedMovement.pilotExempt := self.pilotExempt or self.requiresMarineServices = false;
    clonedMovement.myMaster := self.myMaster;
	//clonedMovement.myPilot := self.myPilot;
	//30 Oct 2018	NDL	TFS 41662
	/* clonedMovement.allPilots.clear(); // --&gt; TFS 44438
	if not self.allPilots.isEmpty then
		self.allPilots.copy( clonedMovement.allPilots );
	endif;*/ // &lt;-- TFS 44438

	/*clonedMovement.allMovementPilotDetails.clear(); // --&gt; TFS 44438
	foreach tempMvmntPilotDetails in self.allMovementPilotDetails do
		cloneMvmntPilotDetails := tempMvmntPilotDetails.cloneMySelf(true);
		clonedMovement.allMovementPilotDetails.add(cloneMvmntPilotDetails);
	endforeach;*/ // &lt;-- TFS 44438

 	//clonedMovement.myPilotLaunch := self.myPilotLaunch; // TFS 44438
 	clonedMovement.myLineCompany := self.myLineCompany;
 	clonedMovement.myShippingAgent := self.myShippingAgent;
 	clonedMovement.myShippingLine := self.myShippingLine;
 	clonedMovement.myContact := self.myContact;
	clonedMovement.myHMSVoyageData := self.myHMSVoyageData;
	// START 22 Sep 2022	navsj20	TFS 54739
	clonedMovement.myBowBollard		:= self.myBowBollard;
	clonedMovement.myBridgeBollard 	:= self.myBridgeBollard;
	clonedMovement.mySternBollard 	:= self.mySternBollard;
	clonedMovement.bowToBollard		:= self.bowToBollard;
	clonedMovement.bridgeToBollard 	:= self.bridgeToBollard;
	clonedMovement.sternToBollard 	:= self.sternToBollard;
	// END 22 Sep 2022	navsj20	TFS 54739
 	if self.requiresMarineServices = true then
		clonedMovement.numLineCrewRequired := self.numLineCrewRequired;
	else
		clonedMovement.numLineCrewRequired := 0;
	endif;

 	foreach tug in self.allTugsUsed do
 		clonedMovement.allTugsUsed.add(tug);
 	endforeach;


	clonedMovement.myMoveTidalClass := self.myMoveTidalClass;
	if cloneWorkingVoyage &lt;&gt; null then
		clonedMovement.myClonedVoyage := cloneWorkingVoyage;
	elseif myReplacement &lt;&gt; null then	//20 Nov 2018	NDL	TFS 42043
		myReplacement.myCancelledMovement := clonedMovement;
	endif;
	clonedMovement.myWorkingVoyage := self.myWorkingVoyage;
	clonedMovement.myClonedMovement := self;
	clonedMovement.myHarbour:=myHarbour;

	// Create workingResourceUsed objs for each workingResourceUsed object in self.allWorkingResUsed
 	clonedMovement.setResourcesUsed(null, self);
	clonedMovement.setMvmntPilotDetails(null, self); // TFS 44438
	
	clonedMovement.createPxyMarineServiceTimings( self.myPersistentMovement );	//19 Jun 2018	NDL	TFS 39215
	
	//20 Nov 2018	NDL	TFS 42043
	if self.myCancelledMovement &lt;&gt; null then
		self.myCancelledMovement.createClone( null, clonedMovement );
	endif;

end;</source>
        <Parameter name="cloneWorkingVoyage" type="CMIF_HMS_WorkingVoyage"/>
        <Parameter name="myReplacement" type="CMIF_HMS_WorkingMovement" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createPxyMarineServiceTimings" id="c4e79504-0b5a-47dc-a3da-5b78c38e479e">
        <updating/>
        <source>createPxyMarineServiceTimings( _copyFrom : HMS_Movement )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2018	jlgndl1	Initial creation	TFS 39215

*/

vars

begin

	if _copyFrom &lt;&gt; null and _copyFrom.myMarineServiceTimings &lt;&gt; null then
		self.myProxyMarineServicesTimings := _copyFrom.myMarineServiceTimings.cloneSelf( true);
	else
		create self.myProxyMarineServicesTimings transient;
	endif;
	self.myProxyMarineServicesTimings.setMyVoyageMovement( _copyFrom );
	
epilog

end;</source>
        <Parameter name="_copyFrom" type="HMS_Movement"/>
    </JadeMethod>
    <JadeMethod name="createResourcesUsed" id="897e379e-b4f7-4c12-8c90-a672413e3eaa">
        <updating/>
        <source>createResourcesUsed() updating;
//
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------
// 24/01/2014	cnwdap1		PAR #33337 CCMS PTR 2214 HMS Enhancements
// 20/05/2014	cnwdap1		PAR #34172 Protect from 1090
// 29 Apr 2019	jlgsl4		TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
// 24 May 2019	jlgsl4		TFS 44939 - PEL1 - persistent to transient error
vars
	vesselData:			HMS_VesselData;
	vessel:				CM_Vessel;
	hmsVDHarbour		: HMS_VesselDataHarbour;
	lastVoyage 			: CM_Voyage;
	lastVoyageData		: HMS_VoyageData;
	lastMovement		: HMS_VoyageMovement;
	tmpMoveResource		: HMS_ResourceTypeForMovement;
	movementPilotDetails : HMS_MovementPilotDetails; // TFS 44939
begin
  	// This method create a new collection of resource used objects for the
  	// movement being edited or added
	vessel := self.myClonedVoyage.getMyVessel();
	if vessel = null then
		return;
	endif;
	
	vesselData := vessel.myHMSVesselData;
	if vesselData = null then
		return;
	endif;
	
	// Lorcan Par 11330 if its a shioft then load the pilot and line company with the previous shift (or if none then previous arrival)
	if self.moveType = HMSMovementTypeShift then
		hmsVDHarbour := vesselData.allVesselDataForHarbour[self.myHarbour];
		if hmsVDHarbour &lt;&gt; null then
			tmpMoveResource := hmsVDHarbour.allMovementResourcesByMovement[self.moveType];
			if tmpMoveResource &lt;&gt; null then
				lastVoyage := hmsVDHarbour.myHarbour.getVesselsLastVoyage(vesselData.myVessel.code);
			endif;
			if lastVoyage &lt;&gt; null then
				lastVoyageData := lastVoyage.myHMSVoyageData;
			endif;				
			if lastVoyageData &lt;&gt; null then
				lastMovement := lastVoyageData.getMovementForMoveType(self.moveType);
				if lastMovement = null then
					lastMovement := lastVoyageData.getMovementForMoveType(HMSMovementTypeArrival);
				endif;
			endif;
			if lastMovement &lt;&gt; null then
				self.myMaster 		:= lastMovement.myMaster;
			//	self.myPilot 		:= lastMovement.getMyPilot;
				//31 Oct 2018	NDL	TFS 41662
				/*if lastMovement.allPilots.isEmpty then // --&gt; TFS 44438
					if lastMovement.getUnConvertedMyPilotRef &lt;&gt; null then	// converting single to multi
						self.allPilots.add( lastMovement.getUnConvertedMyPilotRef );
					endif;
				else
					lastMovement.allPilots.copy( self.allPilots );
				endif;*/ // -- TFS 44438
				self.allMovementPilotDetails.clear(); // --&gt; TFS 44939
				if not lastMovement.allMovementPilotDetails.isEmpty then // TFS 44939
					foreach movementPilotDetails in lastMovement.allMovementPilotDetails do
						self.allMovementPilotDetails.add(movementPilotDetails.cloneMySelf(true));
					endforeach;
				endif; // &lt;-- TFS 44438				
				self.myLineCompany 	:= lastMovement.myLineCompany;
			endif;
		endif;
	endif;
	
	//if not self.myHMSVoyageData.allDefaultMovementResources.isEmpty then									// PAR #33337	// PAR #34172
	if self.myHMSVoyageData &lt;&gt; null and not self.myHMSVoyageData.allDefaultMovementResources.isEmpty then	// PAR #33337	// PAR #34172
		self.myHMSVoyageData.getDefaultResourcesForCMIFMove(self);				// PAR #33337
	else																		// PAR #33337
		vesselData.getDefaultResourcesForCMIFMove(self);	
	endif;																		// PAR #33337
end;</source>
    </JadeMethod>
    <JadeMethod name="createWorkingMovement" id="fc00e0b8-4961-48e6-8a96-50accfbd6f5e">
        <updating/>
        <source>createWorkingMovement(newWorkingVoyage: CMIF_HMS_WorkingVoyage; undoMovePair, redoMovePair, _refreshView : Boolean): CMIF_HMS_WorkingMovement updating;
// 29 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
//26 Sep 2022 navsj20	ChangeRequest 54739: EUP - PLAN - Berth planning by bollards

vars
  	editMovementChange: 	CMIF_HMS_MovementEdit;
  	addMovementChange:		CMIF_HMS_MovementAdd;
  	newWorkingMovement:	   	CMIF_HMS_WorkingMovement;
  	newWorkResourceUsed,
	workResourceUsed:		CMIF_HMS_ResourceUsed;
	tug:					HMS_Tug;
	defaultTideClass:		HMS_TidalClass;	// Modified by Russell 30/03
begin
	// This method creates a new editedWorkingMovement from a clonedWorkingMovement that has been changed
 	newWorkingMovement := self.cloneSelf(true);
 	newWorkingMovement.cloneHasChanged := false;
	newWorkingMovement.myPersistentMovement := self.myPersistentMovement;
	newWorkingMovement.myBerth := self.myBerth;

	//newWorkingMovement.myPilot := self.myPilot;
	//30 Oct 2018	NDL	TFS 41662
	/*newWorkingMovement.allPilots.clear(); // --&gt; TFS 44438
	if not self.allPilots.isEmpty then
		self.allPilots.copy( newWorkingMovement.allPilots );
	endif;*/ // &lt;-- TFS 44438

	/*self.allMovementPilotDetails.clear(); // TFS 44438
	if not self.allMovementPilotDetails.isEmpty then
		self.allMovementPilotDetails.copy(newWorkingMovement.allMovementPilotDetails);
	endif; // TFS 44438*/

	newWorkingMovement.myMaster := self.myMaster;
 	newWorkingMovement.myPilotLaunch := self.myPilotLaunch;
 	newWorkingMovement.myLineCompany := self.myLineCompany;
 	newWorkingMovement.myShippingAgent := self.myShippingAgent;
 	newWorkingMovement.myShippingLine := self.myShippingLine;
 	newWorkingMovement.myContact := self.myContact;
 	newWorkingMovement.myHMSVoyageData := self.myHMSVoyageData;
	// START 26 Sep 2022	navsj20	TFS 54739
	newWorkingMovement.bowToBollard:= self.bowToBollard;
	newWorkingMovement.bridgeToBollard:= self.bridgeToBollard;
	newWorkingMovement.sternToBollard:= self.sternToBollard;
	newWorkingMovement.myBowBollard:= self.myBowBollard;
	newWorkingMovement.myBridgeBollard:= self.myBridgeBollard;
	newWorkingMovement.mySternBollard:= self.mySternBollard;
	// END 26 Sep 2022	navsj20	TFS 54739
 	self.allTugsUsed.copy(newWorkingMovement.allTugsUsed);

	newWorkingMovement.myMoveTidalClass := self.myMoveTidalClass;
	newWorkingMovement.myHarbour := self.myHarbour;

	if self.myClonedMovement = null then
		// new added movement
		newWorkingMovement.myWorkingVoyage := self.myWorkingVoyage;
		newWorkingMovement.myViewController := self.myViewController;
		// Modified by Russell 30/03
		// ------------------------------------------------
		if self.moveType&lt;&gt;HMSMovementTypeShift then
			if self.moveType=HMSMovementTypeArrival then
				// Arrival: Set default tidal class for movement
				defaultTideClass:=self.myClonedVoyage.myHMSVoyageData.myTidalClass;
				if defaultTideClass=null then
					defaultTideClass:=self.myClonedVoyage.myHMSVoyageData.myTidalClassDept;
				endif;
				newWorkingMovement.myMoveTidalClass:=defaultTideClass;
			else
				// Departure: Set default tidal class for movement
				defaultTideClass:=self.myClonedVoyage.myHMSVoyageData.myTidalClassDept;
				if defaultTideClass=null then
					defaultTideClass:=self.myClonedVoyage.myHMSVoyageData.myTidalClass;
				endif;
				newWorkingMovement.myMoveTidalClass:=defaultTideClass;
			endif;
		endif;
		// ------------------------------------------------
	else
		// new edited movement
		newWorkingMovement.myWorkingVoyage := self.myClonedMovement.myWorkingVoyage;
		newWorkingMovement.myViewController := self.myClonedMovement.myViewController;
	endif;

	newWorkingMovement.notYetSaved := true;

	// if movetype is an arrival or departure, update arrival and departure DT on voyage
	if newWorkingMovement.myWorkingVoyage &lt;&gt; null then
		if newWorkingMovement.moveType = HMSMovementTypeArrival then
			 newWorkingMovement.myWorkingVoyage.arrivedDT := newWorkingMovement.occursOnDT;
		elseif newWorkingMovement.moveType = HMSMovementTypeDeparture then
			newWorkingMovement.myWorkingVoyage.departedDT := newWorkingMovement.occursOnDT;
		endif;
	endif;

	// Create workingResourceUsed objs for each workingResourceUsed object in self.allWorkingResUsed
	newWorkingMovement.setResourcesUsed(null, self);
	newWorkingMovement.setMvmntPilotDetails(null, self); // TFS 44438

  	// Purge allWorkingResUsed on clone  
  	self.allWorkingResUsed.purge;
	self.allMovementPilotDetails.purge; // TFS 44438

	// do not create change objects for new arrival and departure moves - these are covered
	// by the voyage add change object
	if self.myWorkingVoyage &lt;&gt; null then 
		if self.myClonedMovement = null then
			// new added movement
			create addMovementChange;
			addMovementChange.appliesToMovement := newWorkingMovement;
			addMovementChange.ofViewController := self.myViewController;
			self.myViewController.changeApply(addMovementChange, false, _refreshView);
		else
			// new edited movement

			// Put something in here..... pass in another parameter from
			// the controller that sets the undo/redo pair flag on the change
			create editMovementChange;
			// Modified by Russell 08/04/99
			// --------------------------------------------------------------
			editMovementChange.undoNext := undoMovePair;
			editMovementChange.redoNext := redoMovePair;
			// --------------------------------------------------------------
			editMovementChange.versionPrevious := self.myClonedMovement;
			editMovementChange.appliesToMovement := newWorkingMovement;
			editMovementChange.ofViewController := self.myClonedMovement.myViewController;
			self.myClonedMovement.myViewController.changeApply(editMovementChange, false, _refreshView);
  		endif;
  	else
  		// New voyage - new movement - set references
  		newWorkingMovement.myWorkingVoyage := newWorkingVoyage;
  		newWorkingMovement.myVoyageForDisplay := newWorkingVoyage;
  	endif;
	
	//19 Jun 2018	NDL	TFS 39215
	if self.myProxyMarineServicesTimings &lt;&gt; null then
		newWorkingMovement.myProxyMarineServicesTimings := self.myProxyMarineServicesTimings.cloneSelf( true );
	endif;

  	return newWorkingMovement;
end;</source>
        <Parameter name="newWorkingVoyage" type="CMIF_HMS_WorkingVoyage"/>
        <Parameter name="undoMovePair" type="Boolean"/>
        <Parameter name="redoMovePair" type="Boolean"/>
        <Parameter name="_refreshView" type="Boolean"/>
        <ReturnType type="CMIF_HMS_WorkingMovement"/>
    </JadeMethod>
    <JadeMethod name="delete" id="301ad967-6f73-4ded-b5cf-f401091d4433">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 June 2018	jlgndl1	Initial creation	TFS 39215

*/

vars

begin

	if self.myProxyMarineServicesTimings &lt;&gt; null then
		delete self.myProxyMarineServicesTimings;
	endif;
	
	if self.myCancelledMovement &lt;&gt; null then	//21 Nov 2018	NDL	TFS 42043
		delete self.myCancelledMovement;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="draftMax" id="0815d813-cac0-40aa-b06d-5d5756f55a15">
        <methodInvocation>mapping</methodInvocation>
        <source>draftMax(set: Boolean; _value: Decimal io) mapping;
//4.1.1 Draft Enhancements. 
//DraftMax is a virtual read only proprty. It returns the forward or aft draft
//for the movement, whichever is the greater.
vars

begin
	if set = false then
 	  	if draftFwd &gt; draftAft then
  	 		_value := draftFwd;
   		else
   			_value := draftAft;
   		endif;
   	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getBaseTimeBerth" id="cd43364d-6882-438e-971c-1b52cb937515">
        <updating/>
        <source>getBaseTimeBerth():HMS_Berth updating;

vars
  	movePrev:		CMIF_HMS_WorkingMovement;
  	harbour:		HMS_Harbour;
begin
	// This method returns the berth that the basetime is relative to for a movement
	// Determine which end the basetime is relative to:
	harbour:=myHarbour;
	if self.moveType=HMSMovementTypeArrival then
		// Arrival movement
   		if harbour.baseTimeArrive=AtSea then
   			return harbour.defaultDepartBerth;
   		else
   			return self.myBerth; 
   		endif;		
	elseif self.moveType=HMSMovementTypeDeparture then
		// Departure movement 
   		if harbour.baseTimeDepart=AtWharf then
   			movePrev:=self.getMovementPrevious;
   			return movePrev.myBerth;
   		else
   			return harbour.defaultDepartBerth;
   		endif;
	else
		// Shift movement
		movePrev:=self.getMovementPrevious;
		if harbour.baseTimeDepart=AtBerthDepartingFrom then
  			if movePrev.isLogicalBerth() then
   				return self.myBerth;
   			else
   				return movePrev.myBerth;
   			endif;
   		else
   			if self.isLogicalBerth() then
   				return movePrev.myBerth;
   			else
   				return self.myBerth;
   			endif;
   		endif;
	endif;
end;</source>
        <ReturnType type="HMS_Berth"/>
    </JadeMethod>
    <JadeMethod name="getBridgeMarkTo" id="74a2d4d9-4a84-47dc-a3ac-0b4a63301c3d">
        <source>getBridgeMarkTo() : Decimal;
//--------------------------------------------------
// Created:	25 May 2004 By: cnwgd1
//--------------------------------------------------
vars
	
begin
	if self.bowMarkTo &lt; self.sternMarkTo then
		return self.bowMarkTo + self.myWorkingVoyage.myHMSVoyageData.dist_BridgeToBow;		   	
	else
		return self.bowMarkTo - self.myWorkingVoyage.myHMSVoyageData.dist_BridgeToBow;		   			
	endif;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="11f14955-8b5a-42ad-ab16-9cc058a254e9">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
// -------------------------------------------
// Created 18 May 2004 by cnwdvb1
// -------------------------------------------

/*

Date		Who		Reason
29 Mar 2008	cnwkpd1	PAR #16118 - Standardise display of from berth when no previous movement is found
					If there is no previous movement, then display the arrival berth from the 
					default sea harbour region
30 Mar 2008	cnwkpd1	PAR #16204 - Handle deleted voyages
15 Aug 2012	cnwdap1	PAR #30148 Show movement remarks in movements table
06 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
*/

vars

	movePrev			: CMIF_HMS_WorkingMovement;	
	tug					: HMS_Tug;
	str					: String;
	offsetTime			: Time;
  	orderTime			: Time;
	defaultTideClass	: HMS_TidalClass;
	workingResourceUsed	: CMIF_HMS_ResourceUsed;
	seaHarbourRegion	: HMS_HarbourRegion;		// PAR #16118
	seaHRArrivalBerth	: HMS_Berth;
	realMovePrev 		: HMS_VoyageMovement;
	permVoyage			: CM_Voyage;				// PAR #16204
	invalidVoyage		: Boolean;					// PAR #16204
	
begin
	if _attrName =	ETRow_HmsMovementType then
		return self.moveType;
	elseif _attrName = ETRow_HmsMovementDay then	
		return self.systemToLocalTime(self.occursOnDT).Date.format("ddd").String.toUpper;	// 15/7/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_HmsMovementDate then
		return self.systemToLocalTime(self.occursOnDT).Date.shortFormatJMT();	// 15/7/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_HmsMovementTime then
		return self.systemToLocalTime(self.occursOnDT).Time.shortFormatJMT();	// 15/7/16 cnwmp6 TFS 488 - Multi timezone support
	elseif _attrName = ETRow_HmsMovementStatus then
		if self.moveStatus=MovementStatus_Planned then
 			return app.getErrorString(Planned);
 		elseif self.moveStatus = MovementStatus_ConfirmedPlan then
 			return app.getErrorString(PlanConfirmed);
 		elseif self.moveStatus = MovementStatus_Actual then
	 		return app.getErrorString(Actual);
 		else
 			return null;
 		endif;
	elseif _attrName = ETRow_HmsMovementShip then
		return self.myWorkingVoyage.myHMSVoyageData.vesselName;
	elseif _attrName = ETRow_HmsMovementVoyage then
		return self.myWorkingVoyage.code;
	elseif _attrName = ETRow_HsmMovementVoyageNo then
		permVoyage := self.myWorkingVoyage.ofPermanentVoyage;			// PAR #16204
		if permVoyage &lt;&gt; null then
			on Exception do app.handleDeletedObject(exception, permVoyage, invalidVoyage);		// PAR #16204
 			if permVoyage.vesselCode = self.myWorkingVoyage.myHMSVoyageData.vesselCode and
			   permVoyage.arrivedDT = self.myWorkingVoyage.arrivedDT then
 				// Arrived DT and vessel have not changed for the voyage
	 			// Calc voyage number
				return self.myHarbour.getVesselVisitCountStr(self.myWorkingVoyage.myHMSVoyageData.vesselCode, self.myWorkingVoyage.arrivedDT);
 			else
 				// Arrived DT or vessel have changed for the voyage
	 			// Voyage number is no longer valid
 				return app.getErrorString(ShipVoyageCodeInvalid);
	 		endif;
	 	else 
 			return app.getErrorString(ShipVoyageCodeInvalid);
	 	endif;
	 	return null;
	elseif _attrName = ETRow_HmsMovementFromPort then
		if self.myWorkingVoyage.ofPortFrom = null then
			return null;
		else
			return self.myWorkingVoyage.ofPortFrom.description;
		endif;
	elseif _attrName = ETRow_HmsMovementToPort then	
		if self.myWorkingVoyage.ofPortTo &lt;&gt; null then
			return self.myWorkingVoyage.ofPortTo.description;
		endif;
		return null;
	elseif _attrName = ETRow_HmsMovementFromBerth then
//		if self.moveType = HMSMovementTypeArrival then // dh 19/3/2008 par 16208 - moved this 'if' around
//			return self.myBerth.description;
//		elseif movePrev &lt;&gt; null then
		movePrev := self.getMovementPrevious();			// PAR #16118
		if movePrev &lt;&gt; null then
 			if movePrev.myBerth &lt;&gt; null then
	 			return movePrev.myBerth.description;
	 		endif;
 		elseif self.moveType = HMSMovementTypeArrival then 		// dh par 16208
			// Else drop into alternate method, using the sea harbour region arrival berth
			seaHarbourRegion := app.myRoot.getSeaHarbourRegion();			// PAR #16118
			if seaHarbourRegion &lt;&gt; null then
				seaHRArrivalBerth := seaHarbourRegion.getArrivalBerth();
				if seaHRArrivalBerth &lt;&gt; null then
					return seaHRArrivalBerth.description;
				endif;
			endif;
			//return self.myHarbour.defaultArrvBerth.description; // dh par 16208
		elseif self.myHarbour.defaultDepartBerth &lt;&gt; null then
 			return self.myHarbour.defaultDepartBerth.description;
	 	endif;
	 	return null;
	elseif _attrName = ETRow_HmsMovementToBerth then
		if self.moveType = HMSMovementTypeArrival and self.isLogicalBerth() then
			if self.myHarbour.defaultArrvBerth &lt;&gt; null then
	 			return self.myHarbour.defaultArrvBerth.description;	
	 		else
	 			return null;		
	 		endif;
		else
			return self.myBerth.description;
		endif;
	elseif _attrName = ETRow_HmsMovementBowMark then
		if self.isLogicalBerth() then
 			return app.getErrorString(NotApplicable);
 		else
 			return self.bowMarkTo.String;
	 	endif;
	elseif _attrName = ETRow_HmsMovementSternMark then
		if self.isLogicalBerth() then
 			return app.getErrorString(NotApplicable);
 		else
 			return self.sternMarkTo.String;
	 	endif;
	elseif _attrName = ETRow_HmsMovementClearance then
		if self.isLogicalBerth() then
 		// Logical berth - clearances not applicable
 			return app.getErrorString(NotApplicable);
 		else
 			if self.foreClearanceTo &gt; 99990 or self.foreClearanceTo &lt; -99990 or
	 			self.isLogicalBerth() then
 				return app.getErrorString(Unlimited);
 			else
 				return self.foreClearanceTo.String;
	 		endif;
	 	endif;
	elseif _attrName = ETRow_HmsMovementClearanceA then
			// Set movement bow to
 	 	if self.isLogicalBerth() then
 			// Logical berth - clearances not applicable
 			return app.getErrorString(NotApplicable);
	 	else
 			if self.aftClearanceTo &gt; 99990 or self.aftClearanceTo &lt; -99990 or
 			self.isLogicalBerth() then
 				return app.getErrorString(Unlimited);
 			else
 				return self.aftClearanceTo.String;
	 		endif;
	 	endif;
	elseif _attrName = ETRow_HmsMovementOrientation then
		if self.sideTo &lt; 1 or self.isLogicalBerth() then
	 		return app.getErrorString(NotApplicable);
	 	else
 			if self.sideTo = OrientPortSideTo then
	// 			return app.getErrorString(PortSideTo); // dh 19/3/08 par 16208
	  			return app.getErrorString(PortSideToBerth);
	 		else
	 //			return app.getErrorString(StarboardSideTo);// dh 19/3/08 par 16208
	 			return app.getErrorString(StarboardSideToBerth);
	 		endif;
 		endif;
	elseif _attrName = ETRow_HmsMovementPilotExempt then
		if self.pilotExempt then
 			return app.getYesNo(true);
 		else
 			return  app.getYesNo(false);
 		
	 	endif;
	elseif _attrName = ETRow_HmsMovementPilot then
	//	if self.getFirstPilot &lt;&gt; null and not self.pilotExempt then
 	//		return self.getFirstPilot.description;
	// 	else
	// 		return app.getErrorString(NotRequired);
	// 	endif;
		//31 Oct 2018	NDL	TFS 41662
		if not self.pilotExempt then
			str := self.getPilotsString();
		endif;
		if str = null then
			str := app.getErrorString(NotRequired);
		endif;
		return str;
	elseif _attrName = ETRow_HmsMovementShipsMaster then
		return self.shipsMaster;
	elseif _attrName = ETRow_HmsMovementPilotLaunch then
		if self.myPilotLaunch &lt;&gt; null and not self.pilotExempt then
			movePrev := self.getMovementPrevious();		// PAR #16118
			if movePrev &lt;&gt; null and self.moveType= HMSMovementTypeShift then
 				if movePrev.myBerth &lt;&gt; null then
 					if movePrev.isLogicalBerth() or self.isLogicalBerth() then
 					// Ship is being SHIFTed to or from sea - pilot launch is required
 						return self.myPilotLaunch.description;
 					else
	 					// Ship is being SHIFTed within the harbour - pilot launch is NOT required
	 					return app.getErrorString(NotRequired);
 					endif;
 				else 
 					// Destination berth for ship not set - set pilot launch to 'Not Required'
 					return app.getErrorString(NotRequired);
 				endif;
 			else
	 			// Move is not a shift and is not pilot exempt - ie. launch is required
 				return self.myPilotLaunch.description; 				
 			endif;
 		elseif self.myPilotLaunch = null and not self.pilotExempt then
	 		return app.getErrorString(NoneSelected);
	 	else
 			return app.getErrorString(NotRequired);
 		endif;

	elseif _attrName = ETRow_HmsMovementTugs then
		foreach tug in self.allTugsUsed do
			str := str &amp; tug.description &amp; ",";
	 	endforeach;
 		if str.length &gt; 0 then
	 		// trim last comma
			return str[1:((str.length)-2)];
		endif;
		return null;
	elseif _attrName = ETRow_HmsMovementLinesCo then
		if self.myLineCompany&lt;&gt;null then
	 		return self.myLineCompany.description;
		endif;
		return null;
	elseif _attrName = ETRow_HmsMovementLinesCrew then
		return self.numLineCrewRequired.String;
	elseif _attrName = ETRow_HmsMovementLinesTime then
		if self.numLineCrewRequired &gt; 0 then
 			if self.relativeOrderTimeLines &lt; 0 then
 				offsetTime.setTime(0,((self.relativeOrderTimeLines) * -1),0,0);
	 			orderTime := (self.systemToLocalTime(self.occursOnDT) - offsetTime).Time;	// 15/7/16 cnwmp6 TFS 488 - Multi timezone support
	 		else
	 			offsetTime.setTime(0,(self.relativeOrderTimeLines),0,0);
	 			orderTime := (self.systemToLocalTime(self.occursOnDT) + offsetTime).Time;	// 15/7/16 cnwmp6 TFS 488 - Multi timezone support
	 		endif;
	 		return orderTime.Time.shortFormatJMT();
 		endif;
 		return null;
	elseif _attrName = ETRow_HmsMovementTugsTime then
		if self.requiresMarineServices = true then
	 		if self.relativeOrderTimeTugs&lt;0 then
	 			offsetTime.setTime(0,((self.relativeOrderTimeTugs)*-1),0,0);
	 			orderTime := (self.systemToLocalTime(self.occursOnDT) - offsetTime).Time;	// 15/7/16 cnwmp6 TFS 488 - Multi timezone support
 			else
 				offsetTime.setTime(0,(self.relativeOrderTimeTugs),0,0);
	 			orderTime := (self.systemToLocalTime(self.occursOnDT) + offsetTime).Time;	// 15/7/16 cnwmp6 TFS 488 - Multi timezone support
	 		endif;
 			if self.locationTug = AlongSide then
 				return "(A)  " &amp; orderTime.Time.shortFormatJMT();
	 		else
	 			return "(O)  " &amp; orderTime.Time.shortFormatJMT();
	 		endif;
	 	endif;
	 	return null;
	elseif _attrName = ETRow_HmsMovementPilotLaunchT then
	 	if not self.pilotExempt then
			movePrev := self.getMovementPrevious();		// PAR #16118
 			if movePrev &lt;&gt; null and self.moveType = HMSMovementTypeShift then
 				if movePrev.myBerth &lt;&gt; null then
 					if movePrev.isLogicalBerth()
 					or self.isLogicalBerth() then
 					// Ship is being SHIFTed to or from sea - pilot launch is required
	 					if self.relativeOrderTimePlaunch &lt; 0 then
	 						offsetTime.setTime(0,((self.relativeOrderTimePlaunch)*-1),0,0);
	 						orderTime := (self.systemToLocalTime(self.occursOnDT) - offsetTime).Time;	// 15/7/16 cnwmp6 TFS 488 - Multi timezone support
 						else
	 						offsetTime.setTime(0,(self.relativeOrderTimePlaunch),0,0);
	 						orderTime := (self.systemToLocalTime(self.occursOnDT) + offsetTime).Time;	// 15/7/16 cnwmp6 TFS 488 - Multi timezone support
	 					endif;
	 					if self.locationPilotLaunch=AlongSide then
	 						return "(A)  " &amp; orderTime.Time.shortFormatJMT();
	 					else
	 						return "(O)  " &amp; orderTime.Time.shortFormatJMT();
	 					endif;
 					else
 						// Ship is being SHIFTed within the harbour - pilot launch is NOT required
 						return app.getErrorString(NotRequired);
 					endif;
 				else
 					// Destination berth for ship not set - set pilot launch to 'Not Required'
	 				return app.getErrorString(NotRequired); 						
 				endif;
 			else 
	 			// Move self not a shift and is not pilot exempt - ie. launch is required
	 			if self.relativeOrderTimePlaunch &lt; 0 then
	 				offsetTime.setTime(0,((self.relativeOrderTimePlaunch)*-1),0,0);
	 				orderTime := (self.systemToLocalTime(self.occursOnDT) - offsetTime).Time;	// 15/7/16 cnwmp6 TFS 488 - Multi timezone support
	 			else
	 				offsetTime.setTime(0,(self.relativeOrderTimePlaunch),0,0);
	 				orderTime := (self.systemToLocalTime(self.occursOnDT) + offsetTime).Time;	// 15/7/16 cnwmp6 TFS 488 - Multi timezone support
	 			endif;
	 			if self.locationPilotLaunch=AlongSide then
	 				return "(A)  " &amp; orderTime.Time.shortFormatJMT();
	 			else
	 				return "(O)  " &amp; orderTime.Time.shortFormatJMT();
	 			endif;
	 		endif; 					
 		else
	    	return app.getErrorString(NotRequired);
   		endif; 		

	elseif _attrName = ETRow_HmsMovementDefTideClass then
		if self.moveType=HMSMovementTypeDeparture then
   			defaultTideClass := self.myWorkingVoyage.myHMSVoyageData.myTidalClassDept;
	   	else
   			defaultTideClass:=self.myWorkingVoyage.myHMSVoyageData.myTidalClass;
	   	endif;
   		if defaultTideClass &lt;&gt; null then
	   		return defaultTideClass.description;
	   	else
	   		return app.getErrorString(NotApplicable);
	   	endif;
	elseif _attrName = ETRow_HmsMovementMoveTideClass then
		if self.myMoveTidalClass &lt;&gt; null then
 	  		return self.myMoveTidalClass.description;
	   	else
   			return app.getErrorString(NotApplicable);
	   	endif;
	elseif _attrName = ETRow_HmsMovementResources then
		foreach workingResourceUsed in self.allWorkingResUsed do
			if workingResourceUsed.myResource &lt;&gt; null then
	 			str := str &amp; workingResourceUsed.myResource.description &amp; ", ";
	 		elseif workingResourceUsed.myResourceType &lt;&gt; null then
	 			str := str &amp; workingResourceUsed.myResourceType.description &amp; ", ";	 		
	 		endif;
	 	endforeach;
 		if self.allWorkingResUsed.size &gt; 0 then
 			// trim last comma
			return str[1:((str.length)-2)];
		endif;
		return null;
	elseif _attrName = ETRow_HmsMovementChargable then
		return app.getYesNo(self.chargeForMove);
	elseif _attrName = ETRow_HmsMovementCustomer then
		if self.isAgentDefault then
 			if self.myShippingAgent &lt;&gt; null then
 				return self.myShippingAgent.description;
	 		endif;
	 	else
	 		if self.myShippingLine&lt;&gt;null then
	 			return self.myShippingLine.description;
 			endif;
	 	endif;
	 	return null;
	elseif _attrName = ETRow_HmsMovementMainContact then
		if self.myContact &lt;&gt; null then
 			return self.myContact.name;
	 	endif;
	 	return null;
	elseif _attrName = ETRow_HmsMovementLOA then
		return self.myWorkingVoyage.myHMSVoyageData.dim_LengthOverall.String;	 	
		
	// PAR #301484 start
	elseif _attrName = ETRow_Remarks then
		return self.remarks;
	// PAR #30148 end
	
	endif;
 	return null;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="4412972d-525d-44b1-bd6a-424a73abaad5">
        <source>getExtraInfo(_dataContainer: CM_DataContainer);
//--------------------------------------------------
// Created: 07 December 2004 By: cnwgd1
//--------------------------------------------------
vars
	block : CM_DataContainerBlock;
begin
	
	if _dataContainer = null then
		return;
	endif;
	
	if self.myPersistentMovement &lt;&gt; null then
		self.myPersistentMovement.getExtraInfo(_dataContainer);
		return;
	endif;
	
	block := _dataContainer.addNewBlock;
	block.addNewItem(self.moveType &amp; ' Movement Remarks', DC_Label, 1, null);
	block.addNewItem(self.remarks, DC_Data, 1, null);
	
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getFirstPilotLaunch" id="f7d6c9f4-e930-4e69-9654-cf16575a98eb">
        <source>getFirstPilotLaunch() : HMS_PilotLaunch;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple pilot launches, post 040 cut/release

*/

vars

begin
	if not self.allMovementPilotDetails.isEmpty then
		return self.allMovementPilotDetails.first.myPilotLaunch;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="HMS_PilotLaunch"/>
    </JadeMethod>
    <JadeMethod name="getFirstRegionWithChkPts" id="0357095e-7fc6-4736-8670-52d1a466641b">
        <updating/>
        <source>getFirstRegionWithChkPts(_totalOffsetTime: Integer io; _enterLeaveStatus:String io; _movePrev: CMIF_HMS_WorkingMovement):HMS_HarbourRegion updating;

vars
//	toBerth:			HMS_Berth;
//	fromBerth:			HMS_Berth;
	pathToCheck:		HMS_MovementPath;
	pathObj:			HMS_MovementPath;
	regA:				HMS_HarbourRegion;
	regB:				HMS_HarbourRegion;
	baseTimeAtRegA:		Boolean;
	harbourObj:			HMS_Harbour;
	directionFwd:		Boolean;
	pathSegment:		HMS_PathSegment;
	regToCheck,
	regToCheckFirst :			HMS_HarbourRegion;
	offSetTime:			Integer;

begin
	// This method returns the first region with checkpoints that is 
 	// crossed as a ship moves from one region to another. It also calculates the 
 	// offset time (from basetime) to this region and the 'entering/leaving' the harbour status.

 	// SCRUCTURE:
 	// Check to see if a path exists for this movement
 	// If it does, find first region on path with checkpoints
 	// If it doesn't, check both to and from regions for checkpoints

	// Set reference to harbour
	harbourObj	:=	self.myHarbour;

	// Get enterLeaveStatus and from/to regions
	_enterLeaveStatus	:=	self.getShipEnterLeaveStatus(regA, regB, _movePrev);

	

	// Initialise offset time
	_totalOffsetTime	:=	0;
	
	// Determine which end the basetime is relative to:
	if self.moveType = HMSMovementTypeArrival then
		// Arrival movement
		// Determine which end of the path the base time needs to be associated with
   		if harbourObj.baseTimeArrive = AtSea then
   			baseTimeAtRegA	:=	true;
   		endif;
		
	elseif self.moveType = HMSMovementTypeDeparture then
		// Departure movement 
		// Determine which end of the path the base time needs to be associated with
   		if harbourObj.baseTimeDepart = AtWharf then
   			baseTimeAtRegA	:=	true;
   		endif;
		
	else
		// Shift movement
		// Determine which end of the path the base time needs to be associated with
   		if harbourObj.baseTimeDepart = AtBerthDepartingFrom then
   			baseTimeAtRegA	:=	true;
			
   			if _movePrev &lt;&gt; null then
   				// If the shift is from a logical berth eg Roadstead, then set BT to
   				// the time at the physical berth (ie destination or regB)
   				if _movePrev.isLogicalBerth() then
   					baseTimeAtRegA	:=	false;
   				endif;
   			endif;
   		endif;
	endif;

	// Check to see if a path is defined. If it is, then find the first region with checkpoints 
	// along the path

//	foreach path in harbour.allMovementPaths do
	foreach pathObj in app.myRoot.allHMSMovementPaths do
		if pathObj.myRegionFrom = regA and pathObj.myRegionTo = regB then
			pathToCheck		:=	pathObj;
			// Set direction along path to fwd=true ie. The ship is travelling
			// from regA to regB
			directionFwd	:=	true;
		elseif pathObj.myRegionFrom = regB and pathObj.myRegionTo = regA then
			pathToCheck		:=	pathObj;
			// Set direction along path to fwd=false ie. The ship is travelling
			// from regB to regA
			directionFwd	:=	false;
			// Swap BT ends
			baseTimeAtRegA	:=	not(baseTimeAtRegA);  //- not sure why this is here - RH 06/08/99
		endif;
	endforeach;

   	if pathToCheck &lt;&gt; null then
   		// Check this path
   		// Step through all regions along path and check their respective checkpoints
   		// at the appropriately offset times
   		if (baseTimeAtRegA = true and directionFwd = true) then
   			// Check regions along path in direction = from 'A' to 'B'
			regToCheckFirst:=regA;
   		elseif (baseTimeAtRegA = false and directionFwd = true) then
   			// Check regions along path in direction = from 'B' to 'A'
			regToCheckFirst:=regB;
   		elseif (baseTimeAtRegA = true and directionFwd = false) then
   			// Check regions along path in direction = from 'A' to 'B'
			regToCheckFirst:=regA;
   		elseif (baseTimeAtRegA = false and directionFwd = false) then
   			// Check regions along path in direction = from 'B' to 'A'
			// Set basetime=movement time
			//basetime	:=	self.occursOnDT;
			regToCheckFirst:=regB;
   		endif;
		
		// epr par 16635 refactored this method a bit
		regToCheck :=self.getRegionWithChkPtsAlongPath(regToCheckFirst,pathToCheck,_totalOffsetTime, directionFwd, baseTimeAtRegA);
		if regToCheck &lt;&gt; null then
			return regToCheck;
		endif;
   	else
   		// If path is not defined - check region A and B for checkpoints
   		if regA &lt;&gt; null and regA.hasCheckpointsWithTidalModel() then
   			return regA;
   		elseif regB &lt;&gt; null and regB.hasCheckpointsWithTidalModel() then
   			return regB;
   		else
			return null;
		endif;
   	endif;
end;</source>
        <Parameter name="_totalOffsetTime" type="Integer" usage="io"/>
        <Parameter name="_enterLeaveStatus" type="String" usage="io"/>
        <Parameter name="_movePrev" type="CMIF_HMS_WorkingMovement"/>
        <ReturnType type="HMS_HarbourRegion"/>
    </JadeMethod>
    <JadeMethod name="getLaycanDifference" id="5d47eef9-dac3-431d-8f49-eaff7914775f">
        <source>getLaycanDifference() : Integer;
//-----------------------------------------------------------------------
//	Created:	06 October 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars

begin
	//Check we are not adding a scenario voyage directly to the Graphical view as this won't have a persitent movement yet.
	if self.myPersistentMovement &lt;&gt; null then
		if  self.myPersistentMovement.myVoyageGlobal = null then
			return 0;
		endif;
		
		if self.myPersistentMovement.myVoyageGlobal.allHMSMovements.first &lt;&gt; self.myPersistentMovement then
			return 0;
		endif;
	
	
		return self.myPersistentMovement.myVoyageGlobal.getLaycanDifference();
	endif;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMovementNext" id="c7311fc0-1298-4e03-b589-459aa12caf59">
        <source>getMovementNext():CMIF_HMS_WorkingMovement;

vars
 	workingMovementNext: CMIF_HMS_WorkingMovement;	
begin
	// This method returns the movement (of the same voyage) that occurs directly
	// after this movement as depicted by the current view
	if self.myClonedMovement = null 
	and self.myWorkingVoyage &lt;&gt; null then
		workingMovementNext := self.myWorkingVoyage.allWorkingMovements.getAtKeyGtr(self.occursOnDT);
	elseif self.myClonedVoyage &lt;&gt; null then
		workingMovementNext := self.myClonedVoyage.allClonedMovements.getAtKeyGtr(self.occursOnDT);	
	endif;

	return workingMovementNext;
end;</source>
        <ReturnType type="CMIF_HMS_WorkingMovement"/>
    </JadeMethod>
    <JadeMethod name="getMovementPrevious" id="5e47dc19-f06a-411b-9553-3d27e6275a05">
        <source>getMovementPrevious():CMIF_HMS_WorkingMovement;

vars
 	workingMovementPrevious: CMIF_HMS_WorkingMovement;	
	previousWorkingVoyage : CMIF_HMS_WorkingVoyage;
	previousOccursOn	: TimeStamp;
begin
	// This method returns the movement (of the same voyage) that occurs directly
	// before this movement as depicted by the current view
	//process.debug;
	if self.myClonedMovement = null 
	and self.myWorkingVoyage &lt;&gt; null then
		workingMovementPrevious := self.myWorkingVoyage.allWorkingMovements.getAtKeyLss(self.occursOnDT);
	elseif self.myClonedVoyage &lt;&gt; null then
		workingMovementPrevious := self.myClonedVoyage.allClonedMovements.getAtKeyLss(self.occursOnDT);	
	endif;

	if workingMovementPrevious = null and self.myWorkingVoyage &lt;&gt; null then
		//  must be the first movement
		//  check the global voyages previous voyage 
		previousWorkingVoyage:=self.myWorkingVoyage.getPreviousCMIFWorkingVoyage();
		if previousWorkingVoyage &lt;&gt; null then
			previousOccursOn:=previousWorkingVoyage.allWorkingMovements.last.occursOnDT;
			workingMovementPrevious:=previousWorkingVoyage.allWorkingMovements.getAtKeyLss(previousOccursOn);
		endif;
	endif;
	return workingMovementPrevious;
end;</source>
        <ReturnType type="CMIF_HMS_WorkingMovement"/>
    </JadeMethod>
    <JadeMethod name="getMyPersistantVoyage" id="5b64bbc6-1a91-4a42-bd81-e826b827ceb7">
