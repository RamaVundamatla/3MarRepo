    <JadeMethod name="mnuPlanItems_click" id="2abceb93-17c0-4287-a022-d52dbf0eae06">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuPlanItems_click(menuItem: MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 March 2012	cnwndl1	Initial creation	Par 29195

*/

vars

	table : CM_DataTable;
	obj : Object;
	testResults : CM_TestAutoPlanResultSet;
	testResult : CM_TestAutoPlanResult;
	ti : CM_TrackedItem;
	moveController : CMIF_MoveController;
	wle : CM_WorkListEntry;
	targetLocn : CM_LocationsController;
	result : Integer;

begin

	table := menuItem.userObject.CM_DataTable;
	
	if table = null or table &lt;&gt; self.tblWouldPlan or  table.allSelectedObjects.isEmpty then
		return;
	endif;
	
	create testResults transient;
	foreach obj in table.allSelectedObjects do
		testResult := obj.CM_TestAutoPlanResult;
		testResults.add( testResult );
	endforeach;
	
	foreach testResult in testResults do
	
		ti := testResult.myTrackedItem;
		targetLocn := testResult.CM_TestAutoPlanPlanned.myPlannedLocation;
		
		create moveController transient;
		moveController.setMyTrackedItem(ti);
		moveController.isRehandleMove := ti.isRehandle;
		moveController.setMoveMode(PLANNING_MODE);
		moveController.setMyToPrimaryLocation(targetLocn);
		
		wle := ti.getWLEforFailedAutoPlan();	// in case this move it is to override of a failed auto plan
		if wle &lt;&gt; null then
			moveController.setMyWorkListEntry(wle);	
			moveController.setJobForMove(wle.job);	
		endif;
		
		while true do
			if targetLocn.isWagon() then
				app.myTrxUA.trxMoveTrackedItemNewRailJob(moveController, app.myPassport);
			else
				app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
			endif;
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				table.removeItemObject(testResult);
				break;
			else
				result := app.showErrorWarningDialog('Move', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   result = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				break;
			endif;
		endwhile;	
		
		delete moveController;
		
		if app.myPassport.hasErrors then
			break;
		endif;
		
	endforeach;
	
	self.doRefresh();
	

epilog

	delete moveController;
	delete testResults;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuRemoveItems_click" id="b74c7637-98be-4f75-955b-d20fbeeac168">
        <controlMethod name="MenuItem::click"/>
