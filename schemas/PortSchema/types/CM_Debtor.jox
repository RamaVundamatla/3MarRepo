    <JadeMethod name="getContractPrimary" id="93890d2d-a5a1-4e34-a273-2394a499f12f">
        <source>getContractPrimary(_bank : CM_Bank; _date : TimeStamp) : CM_InvoiceContract;
/*
Purpose:			

Date		Who		Reason
16 January 2023	navab1	TFS CR 55644 TASK 55684
*/

vars
	contract : CM_InvoiceContract;
begin
	foreach contract in self.allInvoiceContractsByFromTS discreteLock 
		where contract.myBusinessUnit = _bank do // ### TFS BUG 60627 15NOV2023 NAVAB1 - only for the correct business unit
		
		if contract.primary then
			// ### TFS BUG 60627 15NOV2023 NAVAB1 - check the date
			if not _date.isValid() then
				return contract;
			endif;
			
			if _date &gt;= contract.fromTS
			and _date &lt;= contract.toTS then
				return contract;
			endif;
		endif;
	endforeach;
	
	/* // ### TFS BUG 62181 25JAN2024 NAVAB1
	// ### TFS BUG 60627 15NOV2023 NAVAB1 - nothing fopr the date so do nto use the date.
	foreach contract in self.allInvoiceContracts discreteLock do
		if contract.primary then
			return contract;
		endif;
	endforeach;
	*/
	return null;
epilog

end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_date" type="TimeStamp"/>
        <ReturnType type="CM_InvoiceContract"/>
    </JadeMethod>
