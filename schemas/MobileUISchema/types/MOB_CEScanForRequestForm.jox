    <JadeMethod name="translateForm" id="9def54e8-c849-4dea-9074-fac5c5d782b9">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017597, locale);
	btn_Back.translateCaption(Xlat_0012967, locale);
	btn_Complete.translateCaption(Xlat_0012968, locale);
	btn_Details.translateCaption(Xlat_0012969, locale);
	lbl_CargoID.translateCaption(Xlat_0012970, locale);
	lbl_GrossWeight.translateCaption(Xlat_0012971, locale);
	sht_CargoID.translateCaption(Xlat_0012972, locale);
	sht_Request.translateCaption(Xlat_0012973, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
</GUIClass>
