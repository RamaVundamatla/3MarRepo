    <JadeMethod name="getRackYALocationString" id="c9838aa1-2d2c-4f0e-a279-c4f31256534f">
        <source>getRackYALocationString() : String;
/*
Purpose:			
Date		Who		Reason
04 September 2013	cnwab1	Initial creation
*/

vars
	idx, x1, y1, z1 : Integer;
	rack : CM_IrregularBlockController;
	obj : Object;
	objs : ObjectSet;
	allRacks : CM_IrregularBlockLCsByRegion;
begin
	create allRacks transient;
	foreach obj in self.myCurrentDrawingController.allSelectedObjects discreteLock do
		rack := obj.CM_IrregularBlockController;
		
		rack.getSortKeys(x1, y1, z1);
		
		allRacks.putAtKey(z1,y1, x1,rack);
	endforeach;
	
	return allRacks.getYAShelfLocationString(true); // TFS 43424 TRUE
epilog
	delete allRacks;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTermAreaDetailsForQuery" id="275f6542-4cb0-45ac-9bc0-c4e7d08aa664">
        <source>getTermAreaDetailsForQuery( _terminal : CM_Terminal output;
							_terminalAreas : CM_TAMasterByIdDict io;
							_gridRows : CM_GridObjectSet io;
							_enqController : CM_EnquiryController output;
							_viewMode : Integer output
							);

/*

Purpose:			
						used by "frmSelectorPane"
Parameters:			

Return Value:		


Date		Who		Reason
27 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

begin

	_terminal := self.myTerminal;
	
	if not self.allTerminalAreas.isEmpty then
		self.allTerminalAreas.copy( _terminalAreas );
	endif;
	
	if not self.allGridRows.isEmpty then
		self.allGridRows.copy( _gridRows );
	endif;
	
	_enqController := self.mySelectorEnquiryController;

	if self.myCurrentDrawingController &lt;&gt; null then
		_viewMode := self.myCurrentDrawingController.viewMode;
	else
		_viewMode := VIEW_VOYAGE;
	endif;
	
	return;
	
	// not called because of the return above, just here to give a reference
	// so some clown doesn't delete the high level one.
	inheritMethod(  _terminal, _terminalAreas, _gridRows, _enqController, _viewMode );
	

epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal" usage="output"/>
        <Parameter name="_terminalAreas" type="CM_TAMasterByIdDict" usage="io"/>
        <Parameter name="_gridRows" type="CM_GridObjectSet" usage="io"/>
        <Parameter name="_enqController" type="CM_EnquiryController" usage="output"/>
        <Parameter name="_viewMode" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForExit" id="761301bb-136f-4188-b6fd-66c72ee1f089">
        <updating/>
        <source>getXMLSettingsForExit(): String updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpObj : Object;
	theXML		: String;

begin
	theXML := inheritMethod();
	foreach tmpObj in self.allTerminalAreas do
		theXML := theXML &amp; global.formatAsXML(XML_TA, tmpObj.CM_TerminalArea.id);
	endforeach;
	return theXML;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="70b7d557-1aee-455c-84d8-266b48181b51">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theXML : String;
	hideMacro : Boolean;
begin

	theXML := inheritMethod();

	// NOTE if these menus have a caption saying SHOW it means that the item is hidden
	hideMacro :=  (self.mnuGridHideMacro.caption = self.MNU_MACRO_SHOW);

	theXML := theXML &amp; 
			global.formatAsXML(XML_FH,self.xmlFlipH.Integer.String) &amp;
			global.formatAsXML(XML_FV,self.xmlFlipV.Integer.String) &amp;
			global.formatAsXML(XML_ZS,self.xmlZoomFactor.String) &amp;
			global.formatAsXML(XML_HM,hideMacro.Integer.String) &amp;
			global.formatAsXML(XML_HT,(self.mnuGridHideToolbar.caption = self.MNU_TOOLBAR_SHOW).Integer.String) &amp;
			global.formatAsXML(XML_SE,(self.mnuHideSelectorPanel.caption = self.MNU_SELECTOR_SHOW).Integer.String) &amp; //28 Jul 2011	NDL	Par 27890
			global.formatAsXML(XML_HL,(self.mnuGridHideLegend.caption = self.MNU_LEGEND_SHOW).Integer.String);


	return theXML;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="8e1f3f34-0a7f-4b77-a683-ea177880f96e">
        <updating/>
        <source>getXMLSettingsForSetup() updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		Get the user preferences from the user details for this form
// ---------------------------------------------------------------------------
vars
	userWindow		: CM_UserWindow;
	theXML, theXMLValue : String;
	flipH, flipV, hideL,hideT,hideM, dso : Boolean;
	hideS : Boolean; //28 Jul 2011	NDL	Par 27890
	zoomScale : Real;
begin
	// par 11163 rs jan 2006
	userWindow := self.myUserWindow;
	if userWindow = null then
		userWindow := app.getUserWindow(self.name, false);
	endif;

	if userWindow = null then  
		return;
	endif;
	theXML := userWindow.xmlInfo;


 	// #### HIDE LEGEND
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_HL);
 	hideL := false;
 	if theXMLValue &lt;&gt; null then
 		hideL := theXMLValue.Integer.Boolean;
 	endif;
	
	//28 Jul 2011	NDL	Par 27890
	// #### HIDE SELECTOR
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_SE);
 	hideS := false;
 	if theXMLValue &lt;&gt; null then
 		hideS := theXMLValue.Integer.Boolean;
 	endif;
	
	
 	// #### HIDE MACRO
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_HM);
 	hideM := false;
 	if theXMLValue &lt;&gt; null then
 		hideM := theXMLValue.Integer.Boolean;
 	endif;
 	// #### HIDE TOOLBAR
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_HT);
 	hideT  := false;
 	if theXMLValue &lt;&gt; null then
 		hideT := theXMLValue.Integer.Boolean;
 	endif;
 
	// #### FLIP HORIZONTAL
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_FH);
 	flipH := false;
 	if theXMLValue &lt;&gt; null then
 		flipH := theXMLValue.Integer.Boolean;
 	endif;
 	
 	// #### FLIP VERTICAL
 	theXMLValue := theXML.cnEcGetTagValueOfName(XML_FV);
 	flipV := false;
 	if theXMLValue &lt;&gt; null then
 		flipV := theXMLValue.Integer.Boolean;
 	endif;

	// #### ZOOM SCALE
 	zoomScale := theXML.cnEcGetTagValueOfName(XML_ZS).Real;
 
 	if zoomScale = 0 then
	 	zoomScale := CMUI_GridDrawingController.ScaleFactor_2;
	endif;
	self.xmlZoomFactor := zoomScale;
 	// ### SET CONTROLS
 
	self.xmlFlipH := flipH;
	self.xmlFlipV := flipV;
	self.xmlLegend := hideL;
	self.xmlSelector := hideS;	//28 Jul 2011	NDL	Par 27890
	self.xmlToolbar := hideT;
	self.xmlMacro := hideM;
	self.xmlZoomFactor := zoomScale;
epilog

 	if self.xmlZoomFactor = 0 then
	 	self.xmlZoomFactor := CMUI_GridDrawingController.ScaleFactor_2;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="getYardAllocString" id="a8aaaab9-407d-4cd6-9a29-5792380745fd">
        <source>getYardAllocString(_objs : ObjectSet) : String;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anObject : Object;
	anLC : CM_LocationsController;
	locTxt : String;
	ta : CM_TerminalArea;
begin
	
	if _objs = null then
		return null;
	endif;
	
	if _objs.isEmpty then
		return null;
	endif;
	
	foreach anObject in _objs do
		anLC := anObject.CM_LocationsController;

		if ta &lt;&gt; anLC.myTerminalArea then
			if ta &lt;&gt; null then // not the first time
				locTxt := locTxt &amp;  "; ";
			endif;
			ta := anLC.myTerminalArea;
			locTxt := locTxt &amp; ta.id &amp; " " &amp; anLC.ident;
		else
			locTxt := locTxt &amp;  "," &amp; anLC.ident;
		endif;
	endforeach;
	
	return locTxt;
end;</source>
        <Parameter name="_objs" type="ObjectSet"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleGridAreaScrolledEvent" id="47e24f3c-afa2-4b05-9bc8-e43b9deee197">
        <source>handleGridAreaScrolledEvent();
// ---------------------------------------------------------------------------
// Created:     24 August 2004 by cnwrs2
//
// Purpose:     Callback method from dkbGridArea.myScrollableFrame scrolled
// ---------------------------------------------------------------------------
vars
begin

	
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="1d75cfce-892e-45c5-a2f4-286fbfa7d911">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
// ---------------------------------------------------------------------------
// Created:		April 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	str		: String;
	pos		: Integer;
	tmpTA	: CM_TerminalArea;
	
begin
	inheritMethod(_userWindow);
	
	return;
	
	
	
	
	
	
	
	
	pos := 1;
	
	while true do
		str := _userWindow.xmlInfo.cnEcGetNextTagValueOfName(XML_TA, pos);
		if pos &lt;= 0 then
			break;
		endif;
		
		tmpTA := self.myTerminal.allTerminalAreas[str];
		if tmpTA = null then
			continue;
		endif;

		self.myCurrentTerminalArea := tmpTA;
		self.allTerminalAreas.add(tmpTA);

	endwhile;

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="e6823388-f21a-4ffe-b268-ee05b4710f33">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	ydc : YRD_GCRackDrawingController;
	anObj : Object;
begin
	if keyCode = CMUI_Key_F3 then
		if app.isControlKeyDown()
		and not app.isAltKeyDown()
		and not app.isShiftKeyDown()
		then
			self.showSelectorForm(true);
		else
			return;
			
			if self.frmSelectAreas.visible then
				self.showAreaSelectorEnable(false);
			else
				self.showAreaSelector();
			endif;
			return;
		endif;

	elseif keyCode = CMUI_Key_Esc then
		delete app.myMoveController;
		app.myDraggedTrackedItem := null;
		app.isDragging := false;
		self.dragMode := self.DragMode_None;
		
		ydc := self.myCurrentDrawingController;
		ydc.doCancelDrag();
		return;
		
	elseif keyCode = J_key_Delete then
		self.doDeleteKeyDown();
		
	endif;

	inheritMethod(keyCode, shift);
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="aa8984fb-fa25-4b8c-99ca-39b27c5f842c">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theMainFrame, 
	theViewFrame : Frame;
	regKeys : IntegerArray;
	key1, key2 : Point;
	x1,x2,y1,y2 : Integer;
begin
	self.dkbGridArea.isForGCRacks := true;



	inheritMethod();
	self.positionScaleX := 10;
	if self.xmlToolbar then
		self.mnuGridHideToolbar.caption := self.MNU_TOOLBAR_HIDE;
	else
		self.mnuGridHideToolbar.caption := self.MNU_TOOLBAR_SHOW;
	endif;
	self.mnuGridHideToolbar_click(self.mnuGridHideToolbar); 

	self.defYardBackColUnselected := self.myTerminal.getConfig(DefYardBackColUnselected).Integer;
	self.defYardBackColSelected := self.myTerminal.getConfig(DefYardBackColSelected).Integer;
	self.isSelectorCapable := true;

	self.setAllRacks();
	
	self.doQuery(VIEW_DISPORT);
	
	create regKeys transient;
	regKeys.add(CMUI_Key_Esc);
	self.addRegisteredKeys(regKeys);
	regKeys.add(J_key_Delete);
	self.addRegisteredKeys(regKeys);

	self.doSetCaption();	// PAR 21532 CCMS SFW 1025
epilog
	if global.isValidObject(self.userObject) then
		delete self.userObject; // this is a transient object set created in the calling form.
	endif;
	delete regKeys;

end;</source>
        <access>protected</access>
    </JadeMethod>
