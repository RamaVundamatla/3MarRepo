begin
	create theLines transient;
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	
	// delete required voyages and vessels
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel := self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName);
	container := self.getTrackedItem(ContainerName).CM_Container;
	self.assertIsDeleted(container);
	
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	// Now create the required voyages and vessels
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatName.display &amp; ' failed');
	
	voyage := self.addVoyageNonPlannedNonWorked(VoyageName,
													BoatName,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage ' &amp; VoyageName &amp; ' failed');

	// Add the container to the voyage
	container := self.addContainerForExport(ContainerName,
										operator,
										"2200",					// ISOType is not needed
										"MT",					// commodity is not needed
										TI_IMEX_STATUS_STORAGE,	// import not export
										"PAR30360",					// booking id
										voyage.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	self.assertNotNull(voyage.myShipBlockStack);
	self.move(container, voyage.myShipBlockStack);
	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_UnpackComplete), null);
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "FAC", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_UnpackComplete).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["Maersk Codeco"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, false, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false,
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, true, true, false, false, false, true, true, false, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);
	beginTransaction;
	camProtocol.setPackUnpackStatusChange(false);
	commitTransaction;

	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);
	camTaskHistory.rawDataToHSA(theLines);

	create strArray transient;
	strArray.add("UNB+UNOA:2+");
	strArray.add("UNH+1+CODECO:D:95B:UN:SMDG16'");	
	strArray.add("BGM+36+1+9'");
	strArray.add("TDT+20+VYPAR30360+1+++++:146::VSPAR30360'");
	strArray.add("LOC+11+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+SLS+NZCHC:172:20'");
	strArray.add("EQD+CN+PARC1230001+2200:102:5++2+5'");
	strArray.add("RFF+BN:PAR30360'");
	strArray.add("DTM+7:");
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+13+1'");
	strArray.add("UNH+2+CODECO:D:95B:UN:SMDG16'");	
	strArray.add("BGM+34+2+9'");
	strArray.add("TDT+20+VYPAR30360+1+++++:146::VSPAR30360'");
	strArray.add("LOC+9+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+SLS+NZCHC:172:20'");
	strArray.add("EQD+CN+PARC1230001+2200:102:5+++4'");
	strArray.add("RFF+BN:PAR30360'");
	strArray.add("DTM+7:");
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+13+2'");
	strArray.add("UNZ+2+0'");
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqual(tempStr[1:str.length], str);
	endforeach;
epilog
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete strArray;
	delete lRegisteredCargoTypes;
	delete theLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCamCodecoOperators" id="418348fb-a02d-4868-b0fd-e14f7b8406bb">
        <source>tCamCodecoOperators();
// cnwrs1
// cnwgb1
/*
4 June 2014 cnwgb1  PAR 34285 
//30 Jan 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
*/
constants
	VoyageName1		= 'VOY34285';				// all upper case!
	InVoyName1		= 'VOYIN34285';				// all upper case!
	BoatCode		= 'VES34285';
    BoatName        = 'My Vessel';
	ContainerName1	= 'CONU3428501';
	ContainerName2	= 'CONU3428502';
	ContainerName3	= 'CONU3428503';
	ContainerName4	= 'CONU3428504';
	TestOperator	= 'UTOP';
    TestOperator2   = "UTO2";
	CamGroup = "P34285";
	CamProtocol = "PAR34285";
    ReleaseNumber = "1234";
    CarrierCode = "UT_CA3";
    CarrierCodeTr = "CA3";
vars
	runDateTime : TimeStamp;
	lRegisteredCargoTypes : IntegerArray;
	tempStr	: String;
	idx : Integer;
	container1 : CM_Container;
	container2 : CM_Container;
	container3 : CM_Container;
	container4 : CM_Container;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage1 : CM_Voyage;
	passport : CM_Passport;
	terminal : CM_Terminal;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	emailCarrierAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
	objArray : CM_ObjectArray;	//transaction are added to this array and this array is purged at the end to ensure the transactions dont affect other unit tests
	transObj : CM_TITransaction;
	strArray : StringArray;
	str : String;
    bolNumber : String;
    thisTerminal : String;
    carrier : CM_Carrier;
    cargoOp : CM_Operator;
	theLines : HugeStringArray;
	portCode : String;
begin
	create theLines transient;
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get voyage operator ' &amp; TestOperator.display);
	cargoOp := self.getOperator(TestOperator2);
	self.assertNotNullMsg(cargoOp, 'Failed to get voyage operator ' &amp; TestOperator2.display);
	portCode := self.getTerminal.getConfig(PortDestCode).String;
	self.setTerminalConfig(PortDestCode, "USCHT");
	
	create objArray transient;
	
    // Delete required voyages and vessels, if exists
	self.deleteVoyage(VoyageName1);
	voyage1 := self.getVoyage(VoyageName1);
	self.assertIsDeleted(voyage1);
	
 	self.deleteVessel(BoatCode);
	vessel := self.getVessel(BoatCode);
	self.assertIsDeleted(vessel);
 
 
    //Delete the Carrier and Translation, if exists
    self.deleteEDIOutwardXlation(CarrierCodeTr, XLATION_TYPE_CARRIER_BYOP, operator, null);
    self.deleteEDIInwardXlation(CarrierCode, XLATION_TYPE_CARRIER_BYOP, operator, null);
    self.deleteCarrier(CarrierCode);
    carrier := self.getCarrier(CarrierCode);
    self.assertIsDeleted(carrier);

	
	// Delete the cargo, if exists
    self.deleteContainer(ContainerName1);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	self.deleteContainer(ContainerName2);
	container2 := self.getTrackedItem(ContainerName2).CM_Container;
	self.assertIsDeleted(container2);
	self.deleteContainer(ContainerName3);
	container3 := self.getTrackedItem(ContainerName3).CM_Container;
	self.assertIsDeleted(container3);
	self.deleteContainer(ContainerName4);
	container4 := self.getTrackedItem(ContainerName4).CM_Container;
	self.assertIsDeleted(container4);
    
	// Now create the required voyages and vessels
	vessel := self.addVesselCellularWithCode(BoatCode, BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatCode.display &amp; ' failed');
	

	voyage1 := self.addVoyageWithInwardCode(        VoyageName1, 
                                                    InVoyName1,
													BoatCode,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage1, 'Add voyage ' &amp; VoyageName1 &amp; ' failed');
    
    // Add the Carrier &amp; Translation
	create emailCarrierAddresses transient;
    carrier := self.addCarrier(CarrierCode, "A Unit Test Carrier", emailCarrierAddresses, false, false, true, null);
    self.assertNotNullMsg( carrier, 'Add carrier ' &amp; CarrierCode &amp; ' failed' );
    self.createEDIXlation(CarrierCodeTr, CarrierCode,    XLATION_TYPE_CARRIER_BYOP,    true, operator, null );

	// Add the containers &amp; transactions
    //Test1 Container included because operator AND cargo operator are correct
	container1 := self.addContainerForExport(ContainerName1,
										operator,
										"2200",					// ISOType is not needed
										"MT",					// commodity is not needed
										TI_IMEX_STATUS_EXPORT,	// import not export
										"BK34285",					// booking id
										voyage1.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName1.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
    beginTransaction;
    container1.setReleaseCarrier(CarrierCode);
    commitTransaction;	self.assertNotNullMsg(container1, tempStr);
    transObj := self.createTransaction(container1, global.getTiTxnTypeForClass(CM_ReleaseRoad), startDateTime);
	objArray.add(transObj);

	//Test2 Included because Voyage operator is correct
	container2 := self.addContainerForExport(ContainerName2,
										cargoOp,
										"2200",					// ISOType is not needed
										"MT",					// commodity is not needed
										TI_IMEX_STATUS_EXPORT,	// import not export
										"PAR34285",					// booking id
										voyage1.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName2.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container2, tempStr);
    beginTransaction;
    container2.setReleaseCarrier(CarrierCode);
    commitTransaction;
    transObj := self.createTransaction(container2, global.getTiTxnTypeForClass(CM_ReleaseRoad), startDateTime);
	objArray.add(transObj);

	
    //Test3 Shouldn't see this as there is no voyage and Cargo Op is not in CAM Group
	container3 := self.addContainerForExport(ContainerName3,
										cargoOp,
										"2200",					// ISOType is not needed
										"MT",					// commodity is not needed
										TI_IMEX_STATUS_EXPORT,	// import not export
										"PAR34285",					// booking id
										null,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName3.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;

	self.assertNotNullMsg(container3, tempStr);
    transObj := self.createTransaction(container3, global.getTiTxnTypeForClass(CM_ReleaseRoad), startDateTime);
	objArray.add(transObj);
    
	//Test4 Should see this as operator Is in the Cam Group Operator list, even though there is no voyage
	container4 := self.addContainerForExport(ContainerName4,
										operator,
										"2200",	
										"MT",					
										TI_IMEX_STATUS_EXPORT,
										"PAR34285",				
										null,
										null,					
										null).CM_Container;		
	tempStr	:= 'Adding Container ' &amp; ContainerName4.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container4, tempStr);
    transObj := self.createTransaction(container4, global.getTiTxnTypeForClass(CM_ReleaseRoad), startDateTime);
	objArray.add(transObj);

	// Setup the CAM Group
    //Delete old one if exists
    self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
    //Create from Scratch
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
    //operatorDict.add(cargoOp);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", null, false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	// Setup the CAM Protocol
    // Delete old one if it exists
    camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
    //Create from Scratch
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveRoad).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseRoad).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["UN/EDIFACT Codeco"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "USCHT", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, true, scheduleTimes, false, false, false, false, false, false, false, false, false, false, true/*BGM per movement*/, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false, 
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, true, true, false, false, false, false, false, true, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);

	//Run CAMS for this protocol for this period
//	startDateTime := startDateTime.addSeconds(-10);	//addMinutes(-1);
    endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);

    
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
       if tempStr[1:3] &lt;&gt; "EQD" then 
            continue;
        endif;
        self.assertIsOneOf( tempStr[18], "Wrong Container reported", "1", "2", "4" );
        idx := idx+1;
	endforeach;  
    self.assertEqualMsg(idx, 3, "Incorrect number of messages produced");
    
	beginTransaction;
	objArray.purge;
	commitTransaction;
epilog
	self.setTerminalConfig(PortDestCode, portCode);
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete emailCarrierAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete objArray;
	delete strArray;
	delete lRegisteredCargoTypes;
	delete theLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCamCodecoPEV_FLS" id="df3e14cc-807c-492f-bb4a-d345386e1cf1">
        <source>tCamCodecoPEV_FLS();
// cnwrs1
// par 27653
// 09 Jul 2013	cnwrs1	Par 31968The FLS Codeco should use RFF+BM for Bill of Lading number
// 10 Jul 2010	cnwrs1	Par 31974 suppress RRF+BN for GIE (GATEINMT) and LEWIS, SEATRUCK GOE (GATEOUTMT)
// 08 Aug 20134 cnwgb1  Par 32247 Various translation issues
//30 Jan 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
constants
	VoyageName1		= 'VOY32767';				// all upper case!
	InVoyName1		= 'VOYIN32767';				// all upper case!
	BoatCode		= 'VES32767';
    BoatName        = 'My Vessel';
	ContainerName1	= 'CONU3276701';
	ContainerName2	= 'CONU3276702';
	ContainerName3	= 'CONU3276703';
	ContainerName4	= 'CONU3276704';
	TestOperator	= 'UTOP';
	CamGroup = "P32767";
	CamProtocol = "PAR32767";
    ReleaseNumber = "1234";
    CarrierCode = "UT_CA2";
    CarrierCodeTr = "CA2";
vars
	runDateTime : TimeStamp;
	lRegisteredCargoTypes : IntegerArray;
	tempStr	: String;
	idx : Integer;
	container1 : CM_Container;
	container2 : CM_Container;
	container3 : CM_Container;
	container4 : CM_Container;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage1 : CM_Voyage;
	passport : CM_Passport;
	terminal : CM_Terminal;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	emailCarrierAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
	objArray : CM_ObjectArray;	//transaction are added to this array and this array is purged at the end to ensure the transactions dont affect other unit tests
	transObj : CM_TITransaction;
	strArray : StringArray;
	str : String;
    bolNumber : String;
    thisTerminal : String;
    carrier : CM_Carrier;
	theLines : HugeStringArray;
	portCode : String;
begin
	self.setTerminalConfig(GateInAutoBOLNumber, true);
	create theLines transient;
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	portCode := self.getTerminal.getConfig(PortDestCode).String;
	self.setTerminalConfig(PortDestCode, "USPEV");
	create objArray transient;
	
    // Delete required voyages and vessels, if exists
	self.deleteVoyage(VoyageName1);
	voyage1 := self.getVoyage(VoyageName1);
	self.assertIsDeleted(voyage1);
	
 	self.deleteVessel(BoatCode);
	vessel := self.getVessel(BoatCode);
	self.assertIsDeleted(vessel);
 
 
    //Delete the Carrier and Translation, if exists
    self.deleteEDIOutwardXlation(CarrierCodeTr, XLATION_TYPE_CARRIER_BYOP, operator, null);
    self.deleteEDIInwardXlation(CarrierCode, XLATION_TYPE_CARRIER_BYOP, operator, null);
    self.deleteCarrier(CarrierCode);
    carrier := self.getCarrier(CarrierCode);
    self.assertIsDeleted(carrier);

	
	// Delete the cargo, if exists
    self.deleteContainer(ContainerName1);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	self.deleteContainer(ContainerName2);
	container2 := self.getTrackedItem(ContainerName2).CM_Container;
	self.assertIsDeleted(container2);
	self.deleteContainer(ContainerName3);
	container3 := self.getTrackedItem(ContainerName3).CM_Container;
	self.assertIsDeleted(container3);
	self.deleteContainer(ContainerName4);
	container4 := self.getTrackedItem(ContainerName4).CM_Container;
	self.assertIsDeleted(container4);
    
	// Now create the required voyages and vessels
	vessel := self.addVesselCellularWithCode(BoatCode, BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatCode.display &amp; ' failed');
	

	voyage1 := self.addVoyageWithInwardCode(        VoyageName1, 
                                                    InVoyName1,
													BoatCode,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage1, 'Add voyage ' &amp; VoyageName1 &amp; ' failed');
    
    // Add the Carrier &amp; Translation
	create emailCarrierAddresses transient;
    carrier := self.addCarrier(CarrierCode, "A Unit Test Carrier", emailCarrierAddresses, false, false, true, null);
    self.assertNotNullMsg( carrier, 'Add carrier ' &amp; CarrierCode &amp; ' failed' );
    self.createEDIXlation(CarrierCodeTr, CarrierCode,    XLATION_TYPE_CARRIER_BYOP,    true, operator, null );

	// Add the containers &amp; transactions
    //Test1 Empty Out  CM_TrackedItem::bookingReference = BK... Carrier Set
	container1 := self.addContainerForExport(ContainerName1,
										operator,
										"2200",					// ISOType is not needed
										"MT",					// commodity is not needed
										TI_IMEX_STATUS_EXPORT,	// import not export
										"BK32767",					// booking id
										voyage1.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName1.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
    beginTransaction;
    container1.setReleaseCarrier(CarrierCode);
    commitTransaction;	self.assertNotNullMsg(container1, tempStr);
    transObj := self.createTransaction(container1, global.getTiTxnTypeForClass(CM_ReleaseRoad), startDateTime);
	objArray.add(transObj);

	//Test2 Empty Out  CM_TrackedItem::bookingReference = ... Carrier Set
	container2 := self.addContainerForExport(ContainerName2,
										operator,
										"2200",					// ISOType is not needed
										"MT",					// commodity is not needed
										TI_IMEX_STATUS_EXPORT,	// import not export
										"PAR32767",					// booking id
										voyage1.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName2.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container2, tempStr);
    beginTransaction;
    container2.setReleaseCarrier(CarrierCode);
    commitTransaction;
    transObj := self.createTransaction(container2, global.getTiTxnTypeForClass(CM_ReleaseRoad), startDateTime);
	objArray.add(transObj);

	
    //Test3 Empty Out  CM_TrackedItem::clientRef = BK... Carrier Set
	container3 := self.addContainerForExport(ContainerName3,
										operator,
										"2200",					// ISOType is not needed
										"MT",					// commodity is not needed
										TI_IMEX_STATUS_EXPORT,	// import not export
										"PAR32767",					// booking id
										voyage1.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName3.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
    beginTransaction;
    container3.setDeliveryRelease(ReleaseNumber);
	container3.setClientRef("BK327672");
    container3.setReleaseCarrier(CarrierCode);
    commitTransaction;
	self.assertNotNullMsg(container3, tempStr);
    transObj := self.createTransaction(container3, global.getTiTxnTypeForClass(CM_ReleaseRoad), startDateTime);
	objArray.add(transObj);
    
	//Test4 Empty Out  CM_TrackedItem::clientRef = ... Carrier Set
	container4 := self.addContainerForExport(ContainerName4,
										operator,
										"2200",					// ISOType is not needed
										"MT",					// commodity is not needed
										TI_IMEX_STATUS_EXPORT,	// import not export
										"PAR32767",					// booking id
										voyage1.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName4.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
    beginTransaction;
	container4.setClientRef("CR001");
    container4.setReleaseCarrier(CarrierCode);
    commitTransaction;
	self.assertNotNullMsg(container4, tempStr);
    transObj := self.createTransaction(container4, global.getTiTxnTypeForClass(CM_ReleaseRoad), startDateTime);
	objArray.add(transObj);

	// Setup the CAM Group
    //Delete old one if exists
    self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
    //Create from Scratch
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "PEVT0", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	// Setup the CAM Protocol
    // Delete old one if it exists
    camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
    //Create from Scratch
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveRoad).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseRoad).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["FLS Codeco"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "USPEF", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, true/*BGM per movement*/, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false, 
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, true, true, false, false, false, false, false, false, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);

	//Run CAMS for this protocol for this period
    endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

    
	create strArray transient;
	strArray.add("UNB+UNOA:2+UT+REP+");//Partial Comparison
	strArray.add("UNH+1+CODECO:D:95B:UN:ITG14'");
	strArray.add("BGM+36+1+9'");
	strArray.add("TDT+1++++:::172'");
	strArray.add("NAD+CA+SHIP:172'");
	strArray.add("GID+1'");
	strArray.add("EQD+CN+CONU3276701+2200:102:5+++4'");
	strArray.add("RFF+BN:BK32767'");
	strArray.add("DTM+7:");//Partial Comparison
	strArray.add("LOC+165+USPEV:139:6+PEVT0:TER:ZZZ'");
	strArray.add("MEA+AAE+T+KGM:2000'");
	strArray.add("FTX+AAI++");								// partial comparison
	strArray.add("CNT+16:1'");
	strArray.add("UNT+13+1'");

	strArray.add("UNH+2+CODECO:D:95B:UN:ITG14'");
	strArray.add("BGM+50+2+9'");
	strArray.add("TDT+1++++:::172'");
	strArray.add("NAD+CA+SHIP:172'");
	strArray.add("GID+1'");
	strArray.add("EQD+CN+CONU3276702+2200:102:5+++4'");
	strArray.add("RFF+BN:'");
	strArray.add("DTM+7:");//Partial Comparison
	strArray.add("LOC+165+USPEV1:139:6+CA2:TER:ZZZ'");
	strArray.add("MEA+AAE+T+KGM:2000'");
	strArray.add("FTX+AAI++");								// partial comparison
	strArray.add("CNT+16:1'");
	strArray.add("UNT+13+2'");

	strArray.add("UNH+3+CODECO:D:95B:UN:ITG14'");
	strArray.add("BGM+36+3+9'");
	strArray.add("TDT+1++++:::172'");
	strArray.add("NAD+CA+SHIP:172'");
	strArray.add("GID+1'");
	strArray.add("EQD+CN+CONU3276703+2200:102:5+++4'");
	strArray.add("RFF+BN:BK327672'");
	strArray.add("DTM+7:");//Partial Comparison
	strArray.add("LOC+165+USPEV:139:6+PEVT0:TER:ZZZ'");
	strArray.add("MEA+AAE+T+KGM:2000'");
	strArray.add("FTX+AAI++");								// partial comparison
	strArray.add("CNT+16:1'");
	strArray.add("UNT+13+3'");

	strArray.add("UNH+4+CODECO:D:95B:UN:ITG14'");
	strArray.add("BGM+50+4+9'");
	strArray.add("TDT+1++++:::172'");
	strArray.add("NAD+CA+SHIP:172'");
	strArray.add("GID+1'");
	strArray.add("EQD+CN+CONU3276704+2200:102:5+++4'");
	strArray.add("RFF+BN:'");
	strArray.add("DTM+7:");//Partial Comparison
	strArray.add("LOC+165+USPEV1:139:6+CA2:TER:ZZZ'");
	strArray.add("MEA+AAE+T+KGM:2000'");
	strArray.add("FTX+AAI++");								// partial comparison
	strArray.add("CNT+16:1'");
	strArray.add("UNT+13+4'");
	strArray.add("UNZ+4+0'");

	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqual(tempStr[1:str.length], str);
	endforeach;  
    
	beginTransaction;
	objArray.purge;
	commitTransaction;
epilog
	self.setTerminalConfig(PortDestCode, portCode);
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete emailCarrierAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete objArray;
	delete strArray;
	delete lRegisteredCargoTypes;
	delete theLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCamCodecoPenICLUnpackComplete" id="cd79c66a-fae7-4b4e-bfeb-06988e85f89e">
        <source>tCamCodecoPenICLUnpackComplete();
// cnwrs1
// 06 Jun 20	cnwrs1	Par34344 - Create ICL Codeco message
//30 Jan 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
constants
	VoyageName		= 'VYPAR34344';				// all upper case!
	BoatName		= 'VSPAR34344';
	ContainerName	= 'PARC1230001';
	TestOperator	= 'UTOP';
	BlockStackName	= 'BS34344';
	CamGroup = "P34344";
	CamProtocol = "PAR34344";
vars
	runDateTime : TimeStamp;
	tempStr	: String;
	idx : Integer;
	container : CM_Container;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	passport : CM_Passport;
	bs : CM_BlockStack;
	terminal : CM_Terminal;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	lRegisteredCargoTypes : IntegerArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
//	time : Time;
	transObj : CM_TITransaction;
	time1 : String;
	time2 : String;
	strArray : StringArray;
	str : String;
	theLines : HugeStringArray;
begin
	create theLines transient;
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	
	// delete required voyages and vessels
	self.deleteVoyage(VoyageName);
	voyage := self.getVoyage(VoyageName);
	self.assertIsDeleted(voyage);
	
	self.deleteVessel(BoatName);
	vessel := self.getVessel(BoatName);
	self.assertIsDeleted(vessel);
	
	// delete the cargo - this should have already been done if on the voyage, but just in case.
	self.deleteContainer(ContainerName);
	container := self.getTrackedItem(ContainerName).CM_Container;
	self.assertIsDeleted(container);
	
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	// Now create the required voyages and vessels
	vessel := self.addVesselCellular(BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatName.display &amp; ' failed');
	
	voyage := self.addVoyageNonPlannedNonWorked(VoyageName,
													BoatName,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage ' &amp; VoyageName &amp; ' failed');

	// Add the container to the voyage
	container := self.addContainerForExport(ContainerName,
										operator,
										"2200",					// ISOType is not needed
										"MT",					// commodity is not needed
										TI_IMEX_STATUS_STORAGE,	// import not export
										"PAR34344",					// booking id
										voyage.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container, tempStr);
	self.assertNotNull(voyage.myShipBlockStack);
	self.move(container, voyage.myShipBlockStack);
	transObj := self.createTransaction(container, global.getTiTxnTypeForClass(CM_UnpackComplete), null);
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "FAC", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_UnpackComplete).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["ICL Codeco"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "NZCHC", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, true, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false, 
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, true, true, false, false, false, true, true, false, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);

	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	create strArray transient;
	strArray.add("UNB+UNOA:2+");
	strArray.add("UNH+1+CODECO:D:95B:UN:SMDG16'");	
	// PAR 35025 strArray.add("BGM+36+1+9'");
	strArray.add("BGM+37+1+9'"); // PAR 35025
	strArray.add("TDT+20+VYPAR34344+1+++++:146::VSPAR34344'");
// PAR 35025	strArray.add("LOC+11+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+NZCHC:160:87'");
// PAR 35025		strArray.add("EQD+CN+PARC1230001+2200:102:5++3+5'");
	strArray.add("EQD+CN+PARC1230001+2200:102:5++2+4'"); // PAR 35025	
    strArray.add("RFF+BN:PAR34344'");
	strArray.add("DTM+7:");
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("DAM+1+0'");  //cnwma1 21/07/2016 TFS 2217
	strArray.add("CNT+16:1'");
// PAR 35025			strArray.add("UNT+13+1'");
	strArray.add("UNT+13+1'"); //cnwma1 21/07/2016 TFS 2217
	strArray.add("UNZ+1+0'"); // PAR 35025
	
	/* PAR 35025
	strArray.add("UNH+2+CODECO:D:95B:UN:SMDG16'");	
	strArray.add("BGM+34+2+9'");
	strArray.add("TDT+20++1+++++:146::'");
	strArray.add("LOC+9+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+NZCHC:160:87'");
	strArray.add("EQD+CN+PARC1230001+2200:102:5++2+4'");
	strArray.add("RFF+BN:PAR34344'");
	strArray.add("DTM+7:");
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+13+2'");
	strArray.add("UNZ+2+0'");
	*/
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
		self.assertEqual(tempStr[1:str.length], str);
		/* PAR 35025
		if idx = 10 then
			time1 := tempStr[7:12];
		elseif idx = 23 then
			time2 := tempStr[7:12];
		endif;
		*/
	endforeach;
	/* PAR 35025
	if time1 &gt; time2 then
		self.assertEqual(time1, "the gate out Full must be before the gate in MT");
	endif;
	*/
epilog
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete strArray;
	delete lRegisteredCargoTypes;
	delete theLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCamCodecoPennICLChasGateIO1" id="34fabe8d-5a0e-4d19-ac84-8cf59aef02cf">
        <source>tCamCodecoPennICLChasGateIO1();
// cnwrs1
// 19 Jun 2014	Par 34159
//30 Jan 2015	cnwrs1	Par 35544 - Refactor Cams file storage to string
//22 Jan 2016	cnwrs1	37444 Use Cams controller rundate time rathyer than current date time
//13 May 2016	cnwrs1	TFS 1987 CargoSubType EDI Xlation
constants
	VoyageName1		= 'VYPAR34159_1';				// all upper case!
	BlockStackName	= 'BS34159';
	BoatCode		= 'VSPAR34159';
    BoatCodeTrans   = 'TVS34159';
    BoatName        = 'My Vessel';
	ContainerName1	= 'PARC1230001';
	ContainerName2	= 'PARC1230002';
	ContainerName3	= 'PARC1230003';
	ContainerName4	= 'PARC1230004';
	Chassis1 = "CHAS34159_1";
	Chassis2 = "CHAS34159_2";
	Chassis3 = "CHAS34159_3";
	Chassis4 = "CHAS34159_4";
	Vehicle1 = "VH34159_1";
	Vehicle2 = "VH34159_2";
	Vehicle3 = "VH34159_3";
	Vehicle4 = "VH34159_4";
	TestOperator	= 'UTOP';
	CamGroup = "P34159";
	CamProtocol = "PAR34159";
    ReleaseNumber = "1234";
    CarrierCode = "UT_CA1";
    CarrierCodeTr = "CA1";
vars
	runDateTime : TimeStamp;
	bs : CM_BlockStack;
	tempStr	: String;
	idx : Integer;
	container1 : CM_Container;
	container2 : CM_Container;
	container3 : CM_Container;
	container4 : CM_Container;
	operator : CM_Operator;
	vessel : CM_Vessel;
	voyage1 : CM_Voyage;
	passport : CM_Passport;
	terminal : CM_Terminal;
	startDateTime : TimeStamp;
	endDateTime : TimeStamp;
	camGroup : CM_CamGroup;
	camProtocol : CM_CamProtocol;
	camTaskHistory : CM_CamTaskHistory;
	operatorDict : CM_OperatorByCodeDict;
	emailEntity : CM_EmailEntity;
	camProtocolDesc : CM_CamProtocolDesc;
	registeredTransactions : StringArray;
	lRegisteredCargoTypes : IntegerArray;
	scheduleTimes : TimeArray;
	freightForwarders : CM_ConsigneeConsignorSet;
	allCoarriExportPorts : CM_PortByCodeDict;
	emailCopyAddresses : CM_EmailEntityByTypeNameDict;
	emailCarrierAddresses : CM_EmailEntityByTypeNameDict;
	packOperators : CM_OperatorByCodeDict;
	packExportConsignees : CM_ConsignByCodeDict;
	camEditTriggerFields : CM_CamEditTriggerFieldDict;
	camTrainEventTypes : CM_EventTypeByNameDict;
	allPackAreas : CM_TAByIdDict;
	objArray : CM_ObjectArray;	//transaction are added to this array and this array is purged at the end to ensure the transactions dont affect other unit tests
	transObj : CM_TITransaction;
	strArray : StringArray;
	str : String;
    bolNumber : String;
    thisTerminal : String;
    carrier : CM_Carrier;
	cargoType : CM_CargoType;
	chassis1 : CM_TILC;
	chassis2 : CM_TILC;
	chassis3 : CM_TILC;
	chassis4 : CM_TILC;
	ti : CM_TrackedItem;
	theLines : HugeStringArray;
begin
	create theLines transient;
	startDateTime := app.actualTimeServer;
	passport := app.myPassport;
	operator := self.getOperator(TestOperator);
	self.assertNotNullMsg(operator, 'Failed to get operator ' &amp; TestOperator.display);
	self.setTerminalConfig(PortDestCode, "NZPOE");
	
	create objArray transient;
	
    // Delete EDI Translations for required voyages and vessels
	self.deleteEDIInwardXlation(VoyageName1,XLATION_TYPE_VOYAGETERMINAL, operator, null);
	self.deleteEDIOutwardXlation(VoyageName1,XLATION_TYPE_VOYAGETERMINAL, operator, null);
    self.deleteEDIOutwardXlation(BoatCodeTrans, XLATION_TYPE_VESSEL_BYOP, operator, null);
    self.deleteEDIInwardXlation(BoatCode, XLATION_TYPE_VESSEL_BYOP, operator, null);
   
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

    // Delete required voyages and vessels
	self.deleteVoyage(VoyageName1);
	voyage1 := self.getVoyage(VoyageName1);
	self.assertIsDeleted(voyage1);
 
	self.deleteVessel(BoatCode);
	vessel := self.getVessel(BoatCode);
	self.assertIsDeleted(vessel);
    
    //Delete the Carrier and Translation
    self.deleteEDIOutwardXlation(CarrierCodeTr, XLATION_TYPE_CARRIER_BYOP, operator, null);
    self.deleteEDIInwardXlation(CarrierCode, XLATION_TYPE_CARRIER_BYOP, operator, null);
    self.deleteCarrier(CarrierCode);
    carrier := self.getCarrier(CarrierCode);
    self.assertIsDeleted(carrier);

	
	// Delete the cargo - this should have already been done if on the voyage, 
    // but just in case some other test is using the same IDs, delete anyway
	self.deleteContainer(ContainerName1);
	container1 := self.getTrackedItem(ContainerName1).CM_Container;
	self.assertIsDeleted(container1);
	self.deleteContainer(ContainerName2);
	container2 := self.getTrackedItem(ContainerName2).CM_Container;
	self.assertIsDeleted(container2);
	self.deleteContainer(ContainerName3);
	container3 := self.getTrackedItem(ContainerName3).CM_Container;
	self.assertIsDeleted(container3);
	self.deleteContainer(ContainerName4);
	container4 := self.getTrackedItem(ContainerName4).CM_Container;
	self.assertIsDeleted(container4);
    
	// Now create the required voyages and vessels
	vessel := self.addVesselCellularWithCode(BoatCode, BoatName, operator);
	self.assertNotNullMsg(vessel, 'Add vessel ' &amp; BoatCode.display &amp; ' failed');
	
	bs := self.addBlockStack(BlockStackName, 3, 500);
	self.assertNotNull(bs);

	voyage1 := self.addVoyageWithInwardCode(        VoyageName1, 
                                                    null,
													BoatCode,
													TestOperator, 
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage1, 'Add voyage ' &amp; VoyageName1 &amp; ' failed');

    // Now add the edi data translations for the vessels and voyages
    self.createEDIXlation(BoatCodeTrans, BoatCode,    XLATION_TYPE_VESSEL_BYOP,    true, operator, null );

    
	cargoType := app.myRoot.allCargoTypesById[TI_CargoType_Chassis];
	self.deleteCargo(Chassis1, cargoType);		// 13/05/2011 cnwmh5
	ti := self.createTrackedItem(Chassis1, cargoType.id, null, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), false, 
		bs.myLocationsController);
	self.assertNotNull(ti);
	chassis1 := ti.CM_TILC;
    transObj := self.createTransaction(chassis1, global.getTiTxnTypeForClass(CM_ReleaseRoad), startDateTime);
	self.deleteCargo(Chassis2, cargoType);		// 13/05/2011 cnwmh5
	ti := self.createTrackedItem(Chassis2, cargoType.id, null, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), false, 
		bs.myLocationsController);
	self.assertNotNull(ti);
	chassis2 := ti.CM_TILC;
    transObj := self.createTransaction(chassis2, global.getTiTxnTypeForClass(CM_ReleaseRoad), startDateTime);
	self.deleteCargo(Chassis3, cargoType);		// 13/05/2011 cnwmh5
	ti := self.createTrackedItem(Chassis3, cargoType.id, null, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), false, 
		bs.myLocationsController);
	self.assertNotNull(ti);
	chassis3 := ti.CM_TILC;
    transObj := self.createTransaction(chassis3, global.getTiTxnTypeForClass(CM_ReceiveRoad), startDateTime);
	self.deleteCargo(Chassis4, cargoType);		// 13/05/2011 cnwmh5
	ti := self.createTrackedItem(Chassis4, cargoType.id, null, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), false, 
		bs.myLocationsController);
	self.assertNotNull(ti);
	chassis4 := ti.CM_TILC;
    transObj := self.createTransaction(chassis4, global.getTiTxnTypeForClass(CM_ReceiveRoad), startDateTime);
    
	// Add the Carrier &amp; Translation
	create emailCarrierAddresses transient;
    carrier := self.addCarrier(CarrierCode, "A Unit Test Carrier", emailCarrierAddresses, false, false, true, null);
    self.assertNotNullMsg( carrier, 'Add carrier ' &amp; CarrierCode &amp; ' failed' );
    self.createEDIXlation(CarrierCodeTr, CarrierCode,    XLATION_TYPE_CARRIER_BYOP,    true, operator, null );

	// Add the container to the voyage
	container1 := self.addContainerForExport(ContainerName1,
										operator,
										"2200",					// ISOType is not needed
										"GENL",					// commodity is not needed
										TI_IMEX_STATUS_EXPORT,	// import not export
										"PAR34159",					// booking id
										voyage1.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName1.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container1, tempStr);
	self.move(container1, bs);
    // Add the container to the voyage

	container2 := self.addContainerForExport(ContainerName2,
										operator,
										"2200",					// ISOType is not needed
										"MT",					// commodity is not needed
										TI_IMEX_STATUS_EXPORT,	// import not export
										"PAR34159",					// booking id
										voyage1.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName2.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
	self.assertNotNullMsg(container2, tempStr);
	self.move(container2, bs);
    beginTransaction;
    container2.setDeliveryRelease(ReleaseNumber);
	container2.setClientRef("CR001");
    container2.setReleaseCarrier(CarrierCode);
	container2.setPropertyValue("vehicle", Vehicle2);
    commitTransaction;
   
	container3 := self.addContainerForExport(ContainerName3,
										operator,
										"2200",					// ISOType is not needed
										"GENL",					// commodity is not needed
										TI_IMEX_STATUS_EXPORT,	// import not export
										"PAR34159",					// booking id
										voyage1.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName3.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
    bolNumber := container3.billOfLading;
	self.assertNotNullMsg(container3, tempStr);
	beginTransaction;
	container3.setPropertyValue("vehicle", Vehicle3);
	commitTransaction;
     transObj := self.createTransaction(container3, global.getTiTxnTypeForClass(CM_ReleaseRoad), startDateTime);
    
	container4 := self.addContainerForExport(ContainerName4,
										operator,
										"2200",					// ISOType is not needed
										"MT",					// commodity is not needed
										TI_IMEX_STATUS_EXPORT,	// import not export
										"PAR34159",					// booking id
										voyage1.code,
										null,					// dischargePort
										null).CM_Container;			// transhipToPort
	tempStr	:= 'Adding Container ' &amp; ContainerName4.display &amp; ' failed.' &amp; CrLf &amp; passport.getAllErrorsWarningsAsString;
    beginTransaction;
    container4.setDeliveryRelease(ReleaseNumber);
	container4.setClientRef("CR001");
    container4.setReleaseCarrier(CarrierCode);
	container4.setPropertyValue("releaseVehicle", Vehicle4);
	commitTransaction;
	self.assertNotNullMsg(container4, tempStr);
    transObj := self.createTransaction(container4, global.getTiTxnTypeForClass(CM_ReleaseRoad), startDateTime);
    
	objArray.add(transObj);
	self.deleteCamProtocol(CamProtocol);
	self.deleteCamGroup(CamGroup);
	camGroup := self.getCamGroup(CamGroup);
	self.assertIsDeleted(camGroup);
	create operatorDict transient;
	create freightForwarders transient;
	operatorDict.add(operator);
	camGroup := self.addCamGroup(CamGroup, CamGroup, "REP", "UT", "NZCHC", "JAXT0", false, false, false, operatorDict, freightForwarders, 16, "SHIP");
	self.assertNotNull(camGroup);
	
	camProtocol := self.getCamProtocol(CamProtocol);
	self.assertIsDeleted(camProtocol);
	create allCoarriExportPorts transient;
	create emailCopyAddresses transient;
	create packOperators transient;
	create packExportConsignees transient;
	create registeredTransactions transient;
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReceiveRoad).asStringJMT);
	registeredTransactions.add(global.getTiTxnTypeForClass(CM_ReleaseRoad).asStringJMT);
	create scheduleTimes transient;
	create camEditTriggerFields transient;
	create camTrainEventTypes transient;
	create allPackAreas transient;
	create lRegisteredCargoTypes transient;
	lRegisteredCargoTypes.add(TI_CargoType_Container);
	lRegisteredCargoTypes.add(TI_CargoType_Chassis);
	camProtocolDesc := app.myRoot.allCamProtocolDescs["ICL Codeco"];
	emailEntity := app.myRoot.allEmailEntities[1, "Mr. Testing"];
	camProtocol := self.addCamProtocol(CamProtocol, CamProtocol, allCoarriExportPorts, camGroup, "JAXT0", emailEntity, false, emailCopyAddresses, false, "CamMessage", "CamSubject",
	                                   startDateTime, startDateTime, false, null, "txt", TestOperator, packOperators, packExportConsignees, '', camProtocolDesc, registeredTransactions,
									   false, 1, false, scheduleTimes, false, false, false, false, false, false, false, false, false, false, true/*BGM per movement*/, false, 
									   false, false, false, false, false, false, false, false, false, false, false, false, 
									   0, 0, 0, 0, '', '', '', camEditTriggerFields, camTrainEventTypes, null, false, 0, self.getTerminal, true, true, false, false, false, false, false, true, true, 
									   allPackAreas, null, null, lRegisteredCargoTypes);
	if camProtocol &lt;&gt; null then
	beginTransaction;
	camProtocol.setIncludeChassis(true);
	commitTransaction;
	endif;
	tempStr	:= 'Add failed ' &amp; CrLf &amp; app.myPassport.getAllErrorsWarningsAsString();
	self.assertNotNullMsg(camProtocol, tempStr);
	self.assertNotNull(camProtocol);

	endDateTime := startDateTime.addMinutes(1);
	self.runCamsAdhoc(startDateTime, endDateTime, runDateTime, camProtocol);
	camTaskHistory := camProtocol.taskHistoryByProtocolSeq.first;
	self.assertNotNull(camTaskHistory);

	create strArray transient;
/*	strArray.add("UNB+UNOA:2+UT+REP+");//Partial Comparison

	strArray.add("UNH+1+CODECO:D:95B:UN:SMDG16'");
	strArray.add("BGM+34+1+9'");
	strArray.add("TDT+20++1+++++:146::'");
	strArray.add("LOC+9+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+JAXT0:160:87'");
	strArray.add("EQD+CH+"&amp;Chassis3&amp;"+:102:5+++4'");
	strArray.add("DTM+7:");//Partial Comparison
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+11+1'");

	strArray.add("UNH+2+CODECO:D:95B:UN:SMDG16'");
	strArray.add("BGM+34+2+9'");
	strArray.add("TDT+20++1+++++:146::'");
	strArray.add("LOC+9+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+JAXT0:160:87'");
	strArray.add("EQD+CH+"&amp;Chassis4&amp;"+:102:5+++4'");
	strArray.add("DTM+7:");//Partial Comparison
	
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+11+2'");

	strArray.add("UNH+3+CODECO:D:95B:UN:SMDG16'");
	strArray.add("BGM+36+3+9'");
	strArray.add("TDT+20++1+++++:146::'");
	strArray.add("LOC+11+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+JAXT0:160:87'");
	strArray.add("EQD+CH+"&amp;Chassis1&amp;"+:102:5+++4'");
	strArray.add("DTM+7:");//Partial Comparison
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+11+3'");

	strArray.add("UNH+4+CODECO:D:95B:UN:SMDG16'");
	strArray.add("BGM+36+4+9'");
	strArray.add("TDT+20++1+++++:146::'");
	strArray.add("LOC+11+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+JAXT0:160:87'");
	strArray.add("EQD+CH+"&amp;Chassis2&amp;"+:102:5+++4'");
	strArray.add("DTM+7:");//Partial Comparison
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+11+4'");

	strArray.add("UNH+5+CODECO:D:95B:UN:SMDG16'");
	strArray.add("BGM+36+5+9'");
	strArray.add("TDT+20+" &amp; VoyageName1 &amp; "+1+++++:146::MY VESSEL'");
	strArray.add("LOC+11+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+JAXT0:160:87'");
	strArray.add("EQD+CN+"&amp;ContainerName3&amp;"+2200:102:5++2+5'");
	strArray.add("RFF+BN:PAR34159'");
	strArray.add("DTM+7:");//Partial Comparison
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("DAM+1+0'"); //cnwma1 21/07/2016 TFS 2217
	strArray.add("CNT+16:1'"); //cnwma1 21/07/2016 TFS 2217
	strArray.add("UNT+14+5'");

	strArray.add("UNH+6+CODECO:D:95B:UN:SMDG16'");
	strArray.add("BGM+36+6+9'");
	strArray.add("TDT+20+" &amp; VoyageName1 &amp; "+1+++++:146::MY VESSEL'");
	strArray.add("LOC+11+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+JAXT0:160:87'");
	strArray.add("EQD+CN+"&amp;ContainerName4&amp;"+2200:102:5++2+4'");
	strArray.add("RFF+BN:1234'");
	strArray.add("DTM+7:");//Partial Comparison
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("DAM+1+0'"); ///cnwma1 21/07/2016 TFS 2217
	strArray.add("TDT+1++3++UT_CA1+++"&amp;Vehicle4&amp;"'");
	strArray.add("CNT+16:1'"); //cnwma1 21/07/2016 TFS 2217
	strArray.add("UNT+15+6'");
	
	strArray.add("UNZ+6+0'"); */
	
	
	//14 Aug 2020	NDL TFS 49876 - Data the same but order corrected.
	
	strArray.add("UNB+UNOA:2+UT+REP+");//Partial Comparison
	
	strArray.add("UNH+1+CODECO:D:95B:UN:SMDG16'");
	strArray.add("BGM+36+1+9'");
	strArray.add("TDT+20+" &amp; VoyageName1 &amp; "+1+++++:146::MY VESSEL'");
	strArray.add("LOC+11+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+JAXT0:160:87'");
	strArray.add("EQD+CN+"&amp;ContainerName3&amp;"+2200:102:5++2+5'");
	strArray.add("RFF+BN:PAR34159'");
	strArray.add("DTM+7:");//Partial Comparison
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("DAM+1+0'"); //cnwma1 21/07/2016 TFS 2217
	strArray.add("CNT+16:1'"); //cnwma1 21/07/2016 TFS 2217
	strArray.add("UNT+14+1'");

	strArray.add("UNH+2+CODECO:D:95B:UN:SMDG16'");
	strArray.add("BGM+36+2+9'");
	strArray.add("TDT+20+" &amp; VoyageName1 &amp; "+1+++++:146::MY VESSEL'");
	strArray.add("LOC+11+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+JAXT0:160:87'");
	strArray.add("EQD+CN+"&amp;ContainerName4&amp;"+2200:102:5++2+4'");
	strArray.add("RFF+BN:1234'");
	strArray.add("DTM+7:");//Partial Comparison
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("MEA+AAE+G+KGM:4000'");
	strArray.add("DAM+1+0'"); ///cnwma1 21/07/2016 TFS 2217
	strArray.add("TDT+1++3++UT_CA1+++"&amp;Vehicle4&amp;"'");
	strArray.add("CNT+16:1'"); //cnwma1 21/07/2016 TFS 2217
	strArray.add("UNT+15+2'");
	
	strArray.add("UNH+3+CODECO:D:95B:UN:SMDG16'");
	strArray.add("BGM+36+3+9'");
	strArray.add("TDT+20++1+++++:146::'");
	strArray.add("LOC+11+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+JAXT0:160:87'");
	strArray.add("EQD+CH+"&amp;Chassis1&amp;"+:102:5+++4'");
	strArray.add("DTM+7:");//Partial Comparison
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+11+3'");

	strArray.add("UNH+4+CODECO:D:95B:UN:SMDG16'");
	strArray.add("BGM+36+4+9'");
	strArray.add("TDT+20++1+++++:146::'");
	strArray.add("LOC+11+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+JAXT0:160:87'");
	strArray.add("EQD+CH+"&amp;Chassis2&amp;"+:102:5+++4'");
	strArray.add("DTM+7:");//Partial Comparison
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+11+4'");

	strArray.add("UNH+5+CODECO:D:95B:UN:SMDG16'");
	strArray.add("BGM+34+5+9'");
	strArray.add("TDT+20++1+++++:146::'");
	strArray.add("LOC+9+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+JAXT0:160:87'");
	strArray.add("EQD+CH+"&amp;Chassis3&amp;"+:102:5+++4'");
	strArray.add("DTM+7:");//Partial Comparison
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+11+5'");

	strArray.add("UNH+6+CODECO:D:95B:UN:SMDG16'");
	strArray.add("BGM+34+6+9'");
	strArray.add("TDT+20++1+++++:146::'");
	strArray.add("LOC+9+NZPOE:139:6'");
	strArray.add("NAD+CF+SHIP:160:20'");
	strArray.add("NAD+MS+JAXT0:160:87'");
	strArray.add("EQD+CH+"&amp;Chassis4&amp;"+:102:5+++4'");
	strArray.add("DTM+7:");//Partial Comparison	
	strArray.add("LOC+165+NZPOE:160:20'");
	strArray.add("CNT+16:1'");
	strArray.add("UNT+11+6'");

	strArray.add("UNZ+6+0'");
    
	theLines.clear();
	camTaskHistory.rawDataToHSA(theLines);
	foreach tempStr in theLines do
		idx := idx + 1;
		str := strArray[idx];
	//	self.assertEqual(tempStr[1:str.length], str);
		self.assertTrueMsg(tempStr[1:str.length] = str, "Actual = '" &amp; tempStr[1:str.length] &amp; "' Expected = '" &amp; str &amp; "' @ index of " &amp; idx.String );
	endforeach;  
    
	beginTransaction;
	objArray.purge;
	commitTransaction;
epilog
	delete operatorDict;
	delete freightForwarders;
	delete allCoarriExportPorts;
	delete emailCopyAddresses;
	delete emailCarrierAddresses;
	delete packOperators;
	delete packExportConsignees;
	delete registeredTransactions;
	delete scheduleTimes;
	delete camEditTriggerFields;
	delete camTrainEventTypes;
	delete allPackAreas;
	delete lRegisteredCargoTypes;
	delete objArray;
	delete strArray;
	delete theLines;
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;CreateTrackedItemFixed&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
