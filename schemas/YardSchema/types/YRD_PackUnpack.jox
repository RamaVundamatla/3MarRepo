    <JadeMethod name="doTblContainerContext" id="7bf2323c-feea-49c9-9854-1cfb64e49bca">
        <updating/>
        <source>doTblContainerContext(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     03 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	x1, 
	y1					: Real;
begin
	x1 := x;
	y1 := y;
	
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
	if app.isAllowedToInspect() then
		self.mnuInspectContainer.visible := true;
	else
		self.mnuInspectContainer.visible := false;
	endif;
	
	self.mnuClear.visible:= not self.btnCancelBase.enabled;
	self.mnuEditContainer.visible:=self.myTI &lt;&gt; null;
	self.mnuEnquireContainer.visible:=self.myTI &lt;&gt; null;
	
	self.mnuSep2.visible	:= app.isAllowedToInspect();		// cnwrl1 13/10/2010 PAR 23899/25674
	
	self.popupMenu(self.mnuTblContainerContext, x1.Integer, y1.Integer);
	return false;
	
end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblContainerQueryRowColChg" id="f5d50477-d076-4bc4-9ca0-4970d477bdfe">
        <updating/>
        <source>doTblContainerQueryRowColChg(table: Table input; newSheet: Integer; newRow: Integer; newCol: Integer):Boolean updating, protected;
//23 August 2010	cnwml2
//+cnwml2 PAR23715 SFW CCMS1131

vars
	rowName : String;
	control : Control;
begin

	//+cnwml2 PAR23715 SFW CCMS1131
	rowName := table.CM_EntryTable.getAttrName(table.row);
	if rowName.startsWith("DtRow_") then
		control := self.getControl("tblSeals"&amp; rowName[7:end]);
		if control &lt;&gt; null then
			self.myAssistant.stringsTableQueryRowChange(table.CM_EntryTable, self.saveRowHeight, control.CM_Table);
			self.tblSeals.height := 20;
			table.cnEcResizeContents();
		endif;
	endif;
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="newSheet" type="Integer"/>
        <Parameter name="newRow" type="Integer"/>
        <Parameter name="newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblDataUserNoteTI" id="ba71ebf2-cf09-47a3-8985-0757f3687aaf">
        <updating/>
        <source>doTblDataUserNoteTI(_terminalArea : CM_TerminalArea; _ti : CM_TrackedItem; _event : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     29 December 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
06 Jul 2010	cnwkpd1	PAR #24795 - Tidy up notifications and performance of Pack/Unpack

*/

vars
	row 	: Integer;
	str 	: String;
	theLC	: CM_LocationsController;	
	termArea	: CM_TerminalArea;

begin
	if _ti = null or self.myFilterObject = null or self.myFilterObject.getMyTerminalArea = null then
		return;
	endif;


	theLC	:= _ti.myPrimaryActualLocation;
	termArea := self.myFilterObject.getMyTerminalArea;
	
	// Only display if we are looing at correct ta
	if termArea &lt;&gt; _terminalArea then
		return;
	endif;

	if _event = EVENT_TI_MOVE_FROM_LOCATION then
//		self.endNotification(_ti, Any_System_Event);
		if self.tblUnpacked.findObjectInRow(_ti, row) then
			// This line doesn't seem to be required Andrew. 
			// Works without it. Putting it in selected wrong line.
			self.tblUnpacked.removeItem(row);
			self.disarmNotesForObject(_ti);		// PAR #24795
		endif;
		
	elseif _event = EVENT_TI_MOVE_TO_LOCATION then

		if theLC = null then
			return;
		endif;
		//epr par 34711 26/8/14 it was removing it from the unpack tbl when it was at that location
		if theLC.myTerminalArea = termArea then	
			if self.tblUnpacked.findObjectInRow(_ti, row) then
				//its in here can return
				return;
			else
				//not in here add it
				row := self.addTblDataRow(null, _ti, self.tblUnpacked);
				self.tblUnpacked.colourAddedRow(row, self.colorRow1, self.colorRow2);
			endif;
		else
			//remove if in here
			if self.tblUnpacked.findObjectInRow(_ti, row) then // if in row will be being moved from here????
				self.tblUnpacked.removeItem(row);
				self.disarmNotesForObject(_ti);		// PAR #24795		
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="_terminalArea" type="CM_TerminalArea"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_event" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doTblPackContext" id="65cfbfcd-615b-49e9-8aac-8a955c85f571">
        <updating/>
        <source>doTblPackContext(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     18 November 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	x1, 
	y1					: Real;
begin
	x1 := x;
	y1 := y;
	
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return false;
	endif;

	if app.isAllowedToInspect() then
		self.mnuInspectPack.visible := true;
	else
		self.mnuInspectPack.visible := false;
	endif;
	
	self.mnuSep5.visible	:= app.isAllowedToInspect();		// cnwrl1 13/10/2010 PAR 23899/25674
	
	self.popupMenu(self.mnuTblPackContext, x1.Integer, y1.Integer);
	return false;
	
end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblUnpackContext" id="d5bd8f37-21a7-44de-bf9a-8dccc422d694">
        <updating/>
        <source>doTblUnpackContext(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	x1, 
	y1					: Real;
begin

	x1 := x;
	y1 := y;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form
	
	if app.isAllowedToInspect() then
		self.mnuInspectUnpack.visible := true;
	else
		self.mnuInspectUnpack.visible := false;
	endif;
	
	self.mnuSep4.visible	:= app.isAllowedToInspect();		// cnwrl1 13/10/2010 PAR 23899/25674

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.mnuCreateCargoUnpack.visible := false;
		self.mnuExportBooking.visible := false;
		self.mnuEditUnpacked.visible := false;
	endif;
	
	
	
	self.popupMenu(self.mnuTblUnpackContext, x1.Integer, y1.Integer);
	return false;
	
end;</source>
        <access>protected</access>
