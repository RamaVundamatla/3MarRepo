	form.shtViewTable1.caption := 'Terminals';
	
	self.showTSWWebServiceTerminalData(null);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="7ab0f5d8-d4d5-47e1-9275-27c4903ca492">
        <updating/>
        <source>setupThumbnailDetails() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10 August 2016	cnwdap1		Initial creation PAR #
//
vars
	form : SOP_TableMaintForm;
	def : EntTableDef;
	tWidth : Integer;
	table : CM_DataTable;

begin
  	form := self.myForm;
	form.useProxyObject := true;
	table := form.tblData4;
	form.setTblDataEntRows(ETDef_WebServiceMaint);

	form.shtTblInput1.caption := 'Details';
	form.initTblInput(form.tblInput1, ETDef_WebServiceMaint);
	form.shtTblInput1.visible := true;

	form.tblView1.visible := false;
	table.visible := true;
			
	def := app.myController.getEntTableDef(ETDef_WebServiceTerminalMaint);
	table.setColumnHeadingsFromDef(def.name, false);
	table.zAddSortColumn(def.name, true);
	table.selectMode := CM_DataTable.SelectMode_None;
  
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showTSWWebServiceTerminalData" id="7b012305-5ed0-469d-88d1-73cd119919a2">
        <source>showTSWWebServiceTerminalData(_tswWebService : CM_TSWWebService);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/08/2016	cnwdap1		Initial creation TFS #1832 TSW Changes
//
vars
	table : CM_DataTable;
	def : EntTableDef;
	theWidth : Integer;
	form : SOP_TableMaintForm;
	terminal : CM_Terminal;
	idx : Integer;
	tswWebServiceTerminal : CM_TSWWebServiceTerminal;
	textBox : CMUI_TextBox;
	control : Control;

begin
	table := self.myForm.tblData4;
	table.enabled := true;	
	table.clearAllData();
	foreach idx in self.myForm.controlCount to 1 step -1 do
		control := self.myForm.controls(idx);
		if control.name = self.myForm.txtPartnerCode.name and control.index &gt; 0 then
			delete control;
		endif;
	endforeach;
	
	// load table with all terminals this user can access
	foreach terminal in app.myRoot.allTerminals where app.getMyUser.getUserTerminal(terminal) &lt;&gt; null do
		idx := table.addItem(terminal.code &amp; Space &amp; Hyphen &amp; Space &amp; terminal.name);
		table.accessCell(idx, 1).itemObject := terminal;
		if table.accessCell(idx, 2).cellControl = null then
			textBox := self.myForm.txtPartnerCode.loadControl(idx).CMUI_TextBox;
			textBox.parent := table;
			table.accessCell(idx, 2).cellControl := textBox;
		endif;
	endforeach;
	if _tswWebService &lt;&gt; null then
		foreach tswWebServiceTerminal in _tswWebService.allTSWWebServiceTerminals do
			foreach idx in table.fixedRows + 1 to table.rows do
				if table.accessCell(idx, 1).itemObject = tswWebServiceTerminal.myTerminal then
					table.accessCell(idx, 2).text := tswWebServiceTerminal.partnerCode;
					table.accessRow(idx).itemObject := tswWebServiceTerminal;
				endif;
			endforeach;
		endforeach;
	endif;
	table.accessColumn(1).width := (table.width * 2/3).Integer -1;
	table.accessColumn(2).width := (table.width * 1/3).Integer -1;
epilog

end;</source>
        <Parameter name="_tswWebService" type="CM_TSWWebService"/>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="a45ca20a-ede4-4102-99fe-f33e4b375500">
        <updating/>
        <source>showThumbnail(_tswWebService : CM_TSWWebService) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/08/2016	cnwdap1		Initial creation TFS #1832 TSW Changes
// 10/03/2022	navdap1		TFS 52746 PNL Custom Hold Clearance for Export Units using BOL with TSW EDI
//
vars
	form : SOP_TableMaintForm;
	vehicle : CM_Vehicle;
	first : Boolean;
	list : String;	

begin
    form := self.myForm;
	form.tblInput1.clearValues;
	form.shtViewTable1.caption := 'Terminals';

	form.tblInput1.setValueByName(ETRow_Name, _tswWebService.name);
    form.tblInput1.setValueByName(ETRow_Submitter, _tswWebService.submitter);
	form.tblInput1.setValueByName(ETRow_AllowBOLForExports, app.myRoot.getConfig(AllowBOLForExports));		// TFS 52746
	
	self.showTSWWebServiceTerminalData(_tswWebService);
epilog

end;</source>
        <Parameter name="_tswWebService" type="CM_TSWWebService"/>
    </JadeMethod>
</Class>
