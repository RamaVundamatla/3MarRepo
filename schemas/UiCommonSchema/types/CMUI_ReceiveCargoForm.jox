    <JadeMethod name="saveSealControlValues" id="165ce2c0-1b9f-4e0c-a8ba-41b428f95147">
        <updating/>
        <source>saveSealControlValues() protected, updating;
// 30047 save seal GUI control values before re-cloning them so can restore the values
vars
	cargoType		: CM_CargoType;
	obj 			: Object;
	control 		: Control;
	sealValue 		: String;
	sealTypeName	: String;

begin
	cargoType := self.cmbType.getObject().CM_CargoType;
	if cargoType = null then
		if self.myPxyGTEEntity &lt;&gt; null and self.myPxyGTEEntity.isKindOf(CMGTE_Container) then
			cargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
		endif;
	endif;
	self.sealTypes.clear();
	self.sealValues.clear();

	if cargoType &lt;&gt; null then
		foreach obj in self.allClonedControls do
			control := obj.Control;
			if control.isKindOf(CMUI_FieldTextBox) then
				sealValue := control.CMUI_FieldTextBox.getString;
				sealTypeName := control.name;
				self.sealTypes.add(sealTypeName);
				self.sealValues.add(sealValue);
			endif;
		endforeach;
	endif;	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setAdditionalDetailsLabel" id="1eb2a073-851a-4b68-9624-94c32d4cf3cb">
        <source>setAdditionalDetailsLabel();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 September 2009	cnwdap1	Initial creation
25 November  2015	cnwma1  PAR #36943 Shipping Reference error during extract
20 may 2022	navgm20 53204: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - UI
16 August 2022	navak20	TFS ChangeRequest 54441: EUP - Additional Field - Country of Origin
21 Feb 2023 navtnr20	TFS CR 55648 Task 55663: UI - Contract Id
*/
vars

	hasData : Boolean;

begin
	self.lblAdditionalDet.caption := null;
	
	//03 May 2018	NDL	TFS 37795
	if self.isPreNoteForm then
		if self.myProxyTrackedItem &lt;&gt; null
		and  ( self.myProxyTrackedItem.remarksAdditional1.trimBlanks &lt;&gt; null or
			self.myProxyTrackedItem.remarksAdditional2.trimBlanks &lt;&gt; null )
		then
			hasData := true;
		endif;
	endif;
	
	if self.txtDescription.getString &lt;&gt; null or self.txtAllStops.text &lt;&gt; null or
	   self.txtToDoTasks.text &lt;&gt; null or self.cmbSpecialStow.getObject &lt;&gt; null or
	   self.cmbShippingLine.getObject &lt;&gt; null or									// 20 may 2022 navgm20 TFS 53204
	   self.cmbCtryOfOrigin.getObject &lt;&gt; null or									// 16.08.2022 navak20 TFS 54441
	   self.cmbInvContractID.getObject &lt;&gt; null or //21.02.2023 navtnr20 TFS CR 55648 Task 55663
	   self.txtSpecialLift.text &lt;&gt; null or self.cmbFreightFwdr.getObject &lt;&gt; null or
	   self.cmbCustomsAgent.getObject &lt;&gt; null or self.txtHouseBOL.getString &lt;&gt; null or
	   self.txtConsignVoy.getString &lt;&gt; null or self.txtEquipXchg.getString &lt;&gt; null or
	   self.txtPurchaseOrder.getString &lt;&gt; null or self.cmbBusUnit.getObject &lt;&gt; null or
	   self.txtShippingRef.getString &lt;&gt; null or hasData then																//25/11/2015 cnwma1 PAR #36943
		self.lblAdditionalDet.caption := "Click to View Details";
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setBOLDimensionDetails" id="54f5af7b-1ecc-4fc4-841d-44fb30de9f76">
        <source>setBOLDimensionDetails();

/*

Purpose:			Set BOL details dimensions

Parameters:			

Return Value:		


Date		Who		Reason
11 January 2011	cnwmh5	Initial creation #26710

*/

vars
	bolDetail	: CM_BOLDtl;
begin
	
	bolDetail := self.myBOLDtl;
	if bolDetail = null then 
		return;
	endif;
	
	self.tblLength.setValueDefault(bolDetail.length.asStringJMT);	//25 Oct 2013	NDL	Par 32720
	self.tblWidth.setValueDefault(bolDetail.width.asStringJMT);	//25 Oct 2013	NDL	Par 32720
	self.tblHeight.setValueDefault(bolDetail.height.asStringJMT);	//25 Oct 2013	NDL	Par 32720
	
epilog

end;</source>
