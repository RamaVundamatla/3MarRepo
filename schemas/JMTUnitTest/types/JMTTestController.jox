    <JadeMethod name="dumpTerminalConfig" id="0f5412dc-a089-4d67-a371-7150e171396e">
        <source>dumpTerminalConfig() protected;

/*

Purpose:			Write the details of terminal config

Date			Who		Reason
30/04/2013		cnwmh5	Initial creation

*/

vars

	terminal						: CM_Terminal;
	stateObject						: CM_StateObject;
	stateData						: CM_StateData;
	obj								: Object;
	
begin
	
	app.writeLog("Dump Terminal UT Config Details", LogINFO);
	
	terminal := app.myRoot.allTerminals["UT"];
	if terminal = null then 
		return;
	endif;
	
	foreach obj in terminal.getAllStateData() discreteLock do
		stateObject := obj.CM_StateObject;
		foreach stateData in stateObject.allStateData discreteLock do
			if stateData.isKindOf(CM_StateBinary) then
				continue;
			endif;
			app.writeLog(Tab &amp; stateData.key &amp; Tab &amp; stateData.getValue().String, LogINFO);
		endforeach;
	endforeach;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="emailResults" id="b4fda3a0-bfa9-4f1b-81c5-7d275621e54d">
        <source>emailResults(_to: String; _message: String; _subject: String; _xmlString : String; _isHtml: Boolean);
//27 April 2009	cnwdw1	
//
// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
// 09 Sep 2025 		navah1 			MTN-34969: MTN - Investigate formatting Unit Test Emails in HTML - Phase2
vars
	sm				: CM_SmtpConnection;
	i				: Integer;
	str 			: String;
	toUser			: String;
	tmpDir			: String;
	attachment		: CnAttachment;
	log				: File;
	pos				: Integer;							// 04/10/2013 cnwmh5
	tokens			: StringArray;
	user			: String;
	largeMessage	: Boolean;
	messageString	: String;
	xmlString		: String;
begin

	app.writeLog("*****Sending email - start:" &amp; CrLf &amp; Tab &amp; "sendEmail: " &amp; self.sendEmail.String &amp; Tab &amp; "Message Size:" &amp; _message.length.String &amp; Tab &amp; "XML Size:" &amp; _xmlString.length.String, LogINFO);
	if not self.sendEmail then
		return;
	endif;
	
	messageString := _message;
	xmlString := _xmlString;
	
	if _message.length &gt; 1000000 then	// &gt; ~1MB
		app.writeLog("Email text too large, sending as attachment instead", LogWARN);
		largeMessage := true;
		xmlString := messageString;
		messageString := "Email Results too big for email - attaching as log instead";
	endif;
	
	/*
	if not _to.cnContains(";") then								// allow for the passing of multiple email addresses at one time
		toUser := self.getEmailToUser(_to);
		toUser := toUser &amp; app.masterAddress.toUpper();			//cnwmc5 - 12/10/2012
	else
		toUser := _to;
	endif;
	write "Send Email to: " &amp; toUser;
	
	// 24/02/2020 Workout which user to send to
	create tokens transient;
	toUser.getTokensForDelimiter(";", tokens);
	toUser := null;
	foreach user in tokens do
		if toUser.length &gt; 0 then
			toUser := toUser &amp; ";";
		endif;
		toUser := toUser &amp; app.returnCorrectUserName(user, false);
	endforeach;
	if toUser.cnContains('michael.d.hill.nz@gmail.com'.toUpper()) then
		toUser := 'michael.d.hill.nz@gmail.com';
	else
		toUser := "michael.hill@navis.com";
	endif;
	*/
	toUser := _to;
	
	str := app.myRoot.getConfig(SystemTitle).String;
	
	//if str.cnContains("DMAST") then
	//	str := str.replaceWord("DMAST", "EMAST");
	//endif;
		
	create sm;	
	self.beginNotification(sm, CnSmtpConnection.Completion_Event_Type, Response_Cancel, 0);
	sm.name			:= "smtp.cnw.co.nz";
	//sm.sendFrom		:= "JMTUnitTest@jadeworld.com";	
	
	///str := "cnwdmast@jadeworld.com";								// 04/10/2013 cnwmh5
	pos := 2;
	str := app.cnGetServerMiscPath()[3:end];
	str := str[1:end].scanUntil("\", pos) &amp;  app.masterAddress;							// "@jadeworld.com"; // 17/02/2020 jlgmh5
	
	//if str.cnContains("dmast") then
	//	str := str.replaceWord("dmast", "emast");
	//endif;
	sm.sendFrom		:= str;
	sm.sendTo		:= toUser.toLower;
	str := app.myRoot.getConfig(SystemTitle).String;
	
	//if str.cnContains("DMAST") then
	//	str := str.replaceWord("DMAST", "EMAST");
	//endif;
	
	sm.subject		:=	"Automated Test Results " &amp; " (" &amp; str &amp; ") - "  &amp;  _subject;
	//sm.subject		:=	"JMT Unit Test Results " &amp; " (" &amp; str &amp; ") - "  &amp;  _subject;
	sm.message		:=	self.stripNONASCIICharacters(messageString);
	if _isHtml then //09.09.2025 navah1 #34969
		sm.contentType	:=	"Html";	
	endif;
	// 21/10/2011 cnwmh5 - Add attaching of xml to email
	if xmlString &lt;&gt; null then
		tmpDir := app.getTempDirectoryFromSysConfig(); //PAR22336 - cnwsh3 - try and provide a location away from the temp dir to process.
		app.checkTempDirFolderPath(tmpDir, method.qualifiedName, CMIF_ConfigRoot.name &amp; '::' &amp; CMIF_ConfigRoot::systemTempDir.name);//PAR22336 - cnwsh3 30/07/2010
		
		create log transient;
		if largeMessage then
			log.openOutput(tmpDir &amp; "JMTUnitTestResults_" &amp; app.actualTimeServer.getNumeralString &amp; ".log");// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
		else
			log.openOutput(tmpDir &amp; "JMTUnitTestResultsAsXML_" &amp; app.actualTimeServer.getNumeralString &amp; ".xml");// 12 May 2016		cnwns1			TFS 488 - Multi Timezone Support
		endif;
		
		log.writeString(xmlString);
		log.commit();
		log.close();
		
		if log &lt;&gt; null then
			create attachment transient;
			attachment.fileName := log.fileName;
			attachment.mySmtpConnection := sm;
		endif;	
	endif;
	
	app.writeLog("*****Sending email:" &amp; CrLf &amp;
		Tab &amp; "To: " &amp; sm.sendTo &amp; CrLf &amp; 
		Tab &amp; "From: " &amp; sm.sendFrom &amp; CrLf &amp;
		Tab &amp; "Subject: " &amp; sm.subject, 
		LogINFO);

    sm.send;
	
	// Lets try and ignore SMTP timeouts when sending large emails
	on Exception do self.exHandlerTCPErrors(exception);
	
	// spin while we wait for the email to complete
	foreach i in 1 to 100 do 
		app.writeLog("*****Waiting for SMTP Server response*****", LogINFO);
		app.doWindowEvents(1000);
		if self.emailComplete then
			app.writeLog("*****Email send completed*****", LogINFO);
			break;
		endif;
	endforeach;
	
	// Delete the temp attachment file
	// NB: This will leave the file on disk if the email fails to send... which is *probably* ok... for now
	if log &lt;&gt; null and self.emailComplete then
		on Exception do self.exHandlerLastResort(exception);
		log.purge();
		if log.isAvailable then
			app.writeLog("File error code: " &amp; log.errorCode.String, LogERROR);
			process.sleep(30000);	// wait 30 seconds and try again
			log.purge();
		endif;
		on Exception do null;
	endif;
	
epilog
	delete log;
end;</source>
        <Parameter name="_to" type="String"/>
        <Parameter name="_message" type="String"/>
        <Parameter name="_subject" type="String"/>
        <Parameter name="_xmlString" type="String"/>
        <Parameter name="_isHtml" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="exHandlerLastResort" id="33ef3c52-23e0-4a12-a703-38d285300449">
        <source>exHandlerLastResort(ex : Exception) : Integer protected;
//08 February 2009	cnwdw1	
//
vars

begin
	app.writeLog(method.qualifiedName &amp; " called for " &amp; ex.errorCode.String, LogERROR);
	return Ex_Resume_Next;
end;</source>
        <access>protected</access>
        <Parameter name="ex" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="exHandlerTCPErrors" id="48b03da6-5468-426b-b2f6-b823d1c12288">
        <source>exHandlerTCPErrors(_ex : Exception) : Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 December 2022	navmd1	Initial creation

*/

constants
	TCPInvalidState	: Integer = 31011;

vars
	retVal : Integer;
begin

	retVal := Ex_Pass_Back;
	
	// One we care about
	if _ex.errorCode = TCPInvalidState or _ex.isKindOf(ConnectionException) then
		// These errors should all be resumable
		retVal := Ex_Resume_Next;
	endif;

epilog
	return retVal;
end;</source>
        <access>protected</access>
        <Parameter name="_ex" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getAllTests" id="edf0f07c-a211-4295-8df9-2a7a6b198929">
        <source>getAllTests(allTests: MethodSet io);
//21 December 2010	cnwdw1	
//
vars
	allSubclasses: ClassColl;
	allMethods: MethodSet;
	meth: Method;
	subclass: Class;
begin

	create allSubclasses transient;
	UT_UnitTest.allSubclasses(allSubclasses);
	foreach subclass in allSubclasses where not subclass.abstract do
		create allMethods transient;
		subclass.allMethods(allMethods);
		foreach meth in allMethods do
			if not app.isUnitTestMethod(meth) then
				allMethods.remove(meth);
			endif;
		endforeach;
		allMethods.copy(allTests);
		delete allMethods;
	endforeach;	
epilog
	delete allMethods;
	delete allSubclasses;
end;</source>
        <Parameter name="allTests" type="MethodSet" usage="io"/>
    </JadeMethod>
