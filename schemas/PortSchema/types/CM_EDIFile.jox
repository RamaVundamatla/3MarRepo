    <JadeMethod name="validateForDelete" id="8dac83b8-36c3-4440-ad7e-4f8d05f8dd15">
        <source>validateForDelete();
//----------------------------------------------------------------
//	Created:	05 August 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if self.ediData &lt;&gt; null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'deleting edi file with valid edi data');
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="writeFile" id="0cd22d03-28ec-4fb3-b3bd-edeaaf448d9a">
        <source>writeFile();
//----------------------------------------------------------------
//	Created:	26 August 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 20 Jan 2012	cnwrs1	CCMS MSL 1009 PAR 29024 
//12 Jan 2015	cnwrs1	Par 35504 - Refactor EDI file load for .NET
vars
	fileObj			: File;
	binaryLine		: Binary;
	fileLine		: String;
	convertedLine	: String;
	theLines : HugeStringArray;
begin
	if self.fileName = null then
		return;	// for unitest just create compressed data
	endif;
	create fileObj;
	fileObj.fileName	:=	self.fileName;
	
	if fileObj.isAvailable() then
		fileObj.purge();
	endif;
	
	fileObj.mode	:=	File.Mode_Output;
	fileObj.open();

	create theLines transient;
	self.myEDIFileType.rawDataToHSA(self, theLines);
	foreach fileLine in theLines do
		convertedLine	:=	fileLine.convertSpecialToAlphaEquiv();
		convertedLine	:=	convertedLine.stripAbove7E();
		fileObj.writeLine(convertedLine); //par 16227 cnwrs1 mar 2008
	endforeach;
epilog
	if fileObj &lt;&gt; null and
	   fileObj.isOpen() then
		fileObj.close();
	endif;
	delete theLines;
	delete fileObj;
end;</source>
    </JadeMethod>
</Class>
