    <JadeMethod name="keyValuePairTest" id="a6a0a731-1de8-4b63-a991-8db35780c02d">
        <source>keyValuePairTest();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2023	navra1	Initial creation

*/

vars
	nameValuePairs : CM_NameValuePairDict; 
	pair, existingPair : CM_NameValuePair;
	insts:ObjectArray;

begin
	//clear out
	/*
	beginTransaction;	
		create insts transient;
		CM_NameValuePairDict.allInstances(insts, 0, false);
		insts.purge();		
	commitTransaction;
	return;
	*/
	//clear out - end
	
	beginTransaction;	
		nameValuePairs := CM_NameValuePairDict.firstInstance();
		if nameValuePairs = null then
			create nameValuePairs persistent;
		endif;
	commitTransaction;
	
	//test multiple deletes
	beginTransaction;
	create pair persistent;
	pair.createNewPair("1","1");
	nameValuePairs.add(pair);	
	create pair persistent;
	pair.createNewPair("1","2");
	nameValuePairs.add(pair);
	create pair persistent;
	pair.createNewPair("1","3");
	nameValuePairs.add(pair);
	commitTransaction;
	//test multiple deletes - end
	
	
	
	
	beginTransaction;
	create pair persistent;
	
	pair.createNewPair("1","7");
	
		existingPair := nameValuePairs[pair.name];		
	
	if existingPair &lt;&gt; null then		
		nameValuePairs.remove(existingPair);
	endif;
	
	nameValuePairs.add(pair);
	
	commitTransaction;
	/*
	pair.createNewPair("1","2");
	
	nameValuePairs.add(pair);
	commitTransaction;*/
	write "hi";
	
epilog

end;

</source>
    </JadeMethod>
    <JadeMethod name="new" id="33044eb0-7cc2-432c-804e-ef01fa613da5">
        <source>new();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2023	navra1	Initial creation

*/

vars
	dict : CM_CountryByCodeDict;	
	str : String;
	countries : CM_CountryByCodeDict;
	c:CM_Country;
	arr : ObjectArray;
	o : Object;
	term : CM_Terminal;
	a:CM_TIByIdCargoTypeDict;
	op:CM_OperatorByCodeDict;
	
begin

	op:=app.myRoot.allOperators;

	term:=app.myRoot.allTerminals['UT'];

	foreach term in app.myRoot.allTerminals do	
		//a:=term.allCargoGroupsByIdCargoType;
		
	endforeach;
	
	//'2142.3715450'.asOid().inspect();
	beginTransaction;
