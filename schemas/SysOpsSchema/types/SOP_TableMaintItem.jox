    <JadeMethod name="addObjectsToTable" id="14fd7054-4279-4ac8-8f9a-17adff9924fa">
        <updating/>
        <source>addObjectsToTable(_numItems : Integer io) updating;

// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	04/06/2021	navmd1		TFS 51320 - Add filter to Sys/Terminal forms
// ---------------------------------------------------------------------------

vars
	col		: Collection;
			
begin
	if self.filteredObjects.size &gt; 0 then		// TFS 51320
		col := self.filteredObjects;			// TFS 51320
	else
		col := self.getCollection();
		if col = null then
			return;
		endif;
	endif;
	
	self.myForm.copyCollectionToTable(col, _numItems);

end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
