    <JadeMethod name="translateForm" id="94c7758a-874d-4f62-91d5-b77e964b4945">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 18 June 2025 14:06:29.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006682, locale);
	btnAddBerthPref.translateBubbleHelp(Xlat_0003150, locale);
	btnAddBerthPref.translateCaption(Xlat_0003154, locale);
	btnBayDefinition.translateBubbleHelp(Xlat_0003117, locale);
	btnBayDefinition.translateCaption(Xlat_0003122, locale);
	btnChangeBitmap.translateBubbleHelp(Xlat_0003151, locale);
	btnChangeBitmap.translateCaption(Xlat_0003155, locale);
	btnCopy.translateCaption(Xlat_0003217, locale);
	btnDelete.translateBubbleHelp(Xlat_0003206, locale);
	btnDelete.translateCaption(Xlat_0003207, locale);
	btnDeleteBerthPr.translateBubbleHelp(Xlat_0003118, locale);
	btnDeleteBerthPr.translateCaption(Xlat_0003123, locale);
	btnEdit.translateBubbleHelp(Xlat_0003216, locale);
	btnEdit.translateCaption(Xlat_0003218, locale);
	btnEventAlloc.translateCaption(Xlat_0021757, locale);
	btnExport.translateBubbleHelp(Xlat_0017991, locale);
	btnExport.translateCaption(Xlat_0003208, locale);
	btnExtRampAdd.translateCaption(Xlat_0015671, locale);
	btnExtRampDelete.translateCaption(Xlat_0015672, locale);
	btnExtRampUpdate.translateCaption(Xlat_0015673, locale);
	btnExtractImage.translateBubbleHelp(Xlat_0003152, locale);
	btnExtractImage.translateCaption(Xlat_0003156, locale);
	btnHoldDef.translateBubbleHelp(Xlat_0019174, locale);
	btnHoldDef.translateCaption(Xlat_0019175, locale);
	btnImport.translateBubbleHelp(Xlat_0017992, locale);
	btnImport.translateCaption(Xlat_0003209, locale);
	btnNew.translateBubbleHelp(Xlat_0003220, locale);
	btnNew.translateCaption(Xlat_0003221, locale);
	btnRoRoDeckDef.translateBubbleHelp(Xlat_0015674, locale);
	btnRoRoDeckDef.translateCaption(Xlat_0015675, locale);
	btnSectDelete.translateCaption(Xlat_0015676, locale);
	btnSectUpdate.translateCaption(Xlat_0015677, locale);
	btnSectionsAdd.translateCaption(Xlat_0015678, locale);
	btnShipGraphics.translateCaption(Xlat_0003157, locale);
	btnShippingAgent.translateBubbleHelp(Xlat_0003119, locale);
	btnShippingAgent.translateCaption(Xlat_0003124, locale);
	btnShippingLine.translateBubbleHelp(Xlat_0003153, locale);
	btnShippingLine.translateCaption(Xlat_0003158, locale);
	btnTankAdd.translateCaption(Xlat_0015679, locale);
	btnTankDelete.translateCaption(Xlat_0015680, locale);
	btnTankUpdate.translateCaption(Xlat_0015681, locale);
 //	btnVAAdd.translateCaption(Xlat_0016784, locale);
 //	btnVAAddAll.translateCaption(Xlat_0016785, locale);
 //	btnVAMoveDown.translateCaption(Xlat_0016786, locale);
 //	btnVAMoveUp.translateCaption(Xlat_0016787, locale);
 //	btnVARemove.translateCaption(Xlat_0016788, locale);
 //	btnVARemoveAll.translateCaption(Xlat_0016789, locale);
	chkIsBarge.translateCaption(Xlat_0023458, locale);
	ckbBowThrusters.translateCaption(Xlat_0003159, locale);
