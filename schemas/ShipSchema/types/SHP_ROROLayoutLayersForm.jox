    <JadeMethod name="btnFillLayers_click" id="82de8221-b399-4aab-b8b1-32419a8c65f3">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnFillLayers_click(btn: Button input) updating;
/*
Date		    Who			Reason
07 April 2011	cnwas3	  Initial creation: CCMS 1031
*/

vars

begin
	if self.myCurrentProxyItemLayout &lt;&gt; null then
		if self.myUIStylesFrame = null then
			self.myAssistant.SHP_Assistant.showGraphicFillStylesForm(self,self.myCurrentProxyItemLayout);
		else
			self.myUIStylesFrame.zOrder(1);

		endif;
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
