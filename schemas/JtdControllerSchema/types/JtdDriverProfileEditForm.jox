        <updating/>
        <source>lstDrvProfiles_contextMenu(cntrl: ListBox input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;

begin
	self.jtdEnableMenuItems;
	self.popupMenu(self.mnuProfilePopup, (cntrl.left + x).Integer, (cntrl.top + y).Integer);
	return true;
end;</source>
        <Parameter name="cntrl" type="ListBox" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
