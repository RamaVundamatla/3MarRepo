    <JadeMethod name="canUserAccessSelf" id="a7c63cb7-b19e-465a-9e38-4312fb1230cf">
        <source>canUserAccessSelf(_user : CM_User; _failedDAC  :CM_DataAccessController output; _passport : CM_Passport) : Boolean;
// ---------------------------------------------------------------------------
// Created:      28 May 2003 by cnwsgp1
//
// Passport is passed in instead of user for performance reasons.  The data
// data access controllers for the current user are set on passport on startup.
// ---------------------------------------------------------------------------
vars
	dac 		:  CM_DataAccessController;
	operator 	: CM_Operator;
begin
	if app.isSpecial() then
		return true;
	endif;

	dac := _passport.allDataAccessControllers[CM_Operator.name];

	if dac = null then
		// no Operator Data Access Group so view all
		return true;
	endif;
	
	// no operators so all users can view
	if self.allOperators.size &lt; 1 then
		return true;
	endif;
	
	// does user have access to any of the operators for this code group
	foreach operator in self.allOperators do
		if dac.canAccess(operator) then
			return true;
		endif;
	endforeach;

	_failedDAC := dac;
	return false;
end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_failedDAC" type="CM_DataAccessController" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAllCodesCSV" id="ad03f385-c545-4d9b-b2cf-a45016591ee4">
        <source>getAllCodesCSV() : String;
/* TFS 2942
Purpose:			
Date		Who		Reason
14 December 2016	cnwab1	Initial creation
*/

vars
	obj : CM_Code;
	value : String;
begin
	foreach obj in self.allCodes discreteLock do
		if value = "" then
			value := obj.code;
		else
			value := value &amp; "," &amp; obj.code;
		endif;
	endforeach;
	
	return value;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
