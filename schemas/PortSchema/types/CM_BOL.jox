    </JadeMethod>
    <JadeMethod name="doUpdateLocation" id="1b39188f-6d4b-4b6d-9734-f30f0bd3d4e0">
        <updating/>
        <source>doUpdateLocation(_mode : Integer; 
				_newLocn : CM_LocationsController;
				_passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 29 May 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpTI			: CM_TrackedItem;
	moveController	: CMIF_MoveController;
	cancelSave, 
	firstTime 	: Boolean;
	coll		: Collection;
	obj			: Any;
begin

	coll := self.getTICollectionForTerminal(_passport.myTerminal);

	if coll.isEmpty then	
		return;
	endif;

	create moveController transient;
	moveController.setMoveMode(_mode);
	moveController.setJobForMove(self.myYardJob);		
	moveController.isSystemMove := true;
	moveController.isForcedMove := true;	
	moveController.setMyToPrimaryLocation(_newLocn);
	firstTime := true;
	foreach obj in coll do
		tmpTI := obj.CM_TrackedItem;
		if firstTime then
			moveController.setMyTrackedItem(tmpTI);		
			firstTime := false;
			continue;
		endif;
		moveController.allOtherTrackedItems.add(tmpTI);
	endforeach;

	app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);

epilog
	delete moveController;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_newLocn" type="CM_LocationsController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doesAllowType" id="eb94b8db-feaf-4aa8-b769-b8c1eb86576e">
        <source>doesAllowType(_passport : CM_Passport input; _giveError : Boolean) : Boolean;
//--------------------------------------------------
// Created:	19 November 2003 By: cnwgd1
//--------------------------------------------------
vars
	search		: CMIF_SearchTypes;
begin
	if self.myPlannedLocation = null then
		return false;
	endif;
	
	create search transient;
	search.myOperator := self.myOperator;
	search.mySpecies	:= self.myLogSpecies;
	search.myGrade	:= self.myLogGrade;
	search.myType	:= self.myLogType;
	search.myTreatment:= self.myLogTreatment;
	search.myLength	:= self.myLogLength;
	
	return self.myPlannedLocation.doesAllowType(search, _giveError);
	
epilog
	delete search;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_giveError" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="executeMoveForMode" id="148c9467-f2ae-45db-a6c8-3e264fce59f4">
        <updating/>
        <source>executeMoveForMode(_moveMode : Integer; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 10 December 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if self.myExtension &lt;&gt; null then
		self.myExtension.executeMoveForMode(_moveMode, _passport);
	else
		self.doMoveToLocation(_moveMode, _passport);
	endif;
end;</source>
        <Parameter name="_moveMode" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="exportMeXML" id="7cf2d0d6-251c-40ad-af61-dbeea91fe1e4">
        <source>exportMeXML(_file: File; _objArray: ObjectArray io; _exportReferences: Boolean; _exportCollections: Boolean);

vars

begin
	if self.bolType &lt;&gt; BOLType_GeneralDocket or self.bolType &lt;&gt; BOLType_GeneralBillOfLading then
		return;
	endif;
	
	inheritMethod(_file, _objArray, _exportReferences, _exportCollections);
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
        <Parameter name="_exportReferences" type="Boolean"/>
        <Parameter name="_exportCollections" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="exportMyCollectionsXML" id="ead286fe-4e0d-4b0b-9ff6-bb55c5fa9af7">
        <source>exportMyCollectionsXML(_file: File; _objArray: ObjectArray io);

vars
	ti			: CM_TrackedItem;
begin
	//tis already loaded - just store their ID
	_file.writeLine('&lt;allTrackedItems&gt;');
	foreach ti in self.allTrackedItems do
		_file.writeLine('&lt;id&gt;' &amp; ti.id &amp; '&lt;/id&gt;');
	endforeach;
	_file.writeLine('&lt;/allTrackedItems&gt;');
	
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="exportMyReferencesXML" id="a1854688-1446-4db4-93fe-8aaaf35ea622">
        <source>exportMyReferencesXML(_file: File; _objArray: ObjectArray io);

vars

begin
	
	if CM_BOLExtWarehouse.hasInstance(self.myExtension) then
		_file.writeLine('&lt;myExtension&gt;');
		self.myExtension.exportMe(_file, _objArray);
		_file.writeLine('&lt;/myExtension&gt;');
	endif;
	
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_objArray" type="ObjectArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllActiveStops" id="963d1c7e-a4f5-4d62-a0de-94c4d9cc28d5">
        <source>getAllActiveStops(_stops : CM_StopsByIdDict input);

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 February 2015	cnwndl1	Initial creation	NDL	Par 35426

*/

vars

begin

	self.getAllActiveStopsAsAtDate(_stops, null);

epilog

end;</source>
        <Parameter name="_stops" type="CM_StopsByIdDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllActiveStopsAsAtDate" id="90c898b1-6b82-40ec-ad86-5c56939f82a1">
        <source>getAllActiveStopsAsAtDate( _stops : CM_StopsByIdDict input; _asAtDate : Date );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 February 2015	cnwndl1	Initial creation	Par 35426

*/

vars
	stop	: CM_Stops;
	iter1	: Iterator;
	
begin
	_stops.clear();
	
	// An active stop is what where the stops clearanceExpiryDate is null or clearanceExpiryDate &lt; today.
	// It can no longer be checked by just establishing the presence of the stop in the allStops collection.
	iter1	:= self.allStops.createIterator();
	while iter1.next(stop) do : cond_loop
		if stop.isStopActiveAsAtDate( _asAtDate ) then		// null means as at today
			_stops.addNoDuplicates( stop, false );
		endif;
	endwhile cond_loop;
	
epilog
	delete iter1;
end;
</source>
        <Parameter name="_stops" type="CM_StopsByIdDict" usage="input"/>
        <Parameter name="_asAtDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="getAllActiveStopsSize" id="4c486cf9-0859-4ad0-a113-a1739a1aab0b">
        <source>getAllActiveStopsSize() : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 February 2015	cnwndl1	Initial creation	NDL	Par 35426

*/

vars
	allStops	: CM_StopsByIdDict;
	
begin
	create allStops transient;
	self.getAllActiveStops(allStops);
	
	return allStops.size();
epilog
	delete allStops;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
