    <JadeMethod name="setComboValues" id="acee10da-1b57-4048-9a56-858a91f5c378">
        <source>setComboValues(_combo : ComboBox input; _params : CM_QueryCriteriaLineHolder; _queryOperator : CM_QueryOperator; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     06 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	dict				: CM_MenuItemByTypeMenuIdDict;
	baseScm 			: Schema;
	category 			: ConstantCategory;
	constDict			: ConstantNDict;
	const 				: Constant;
	state,
	cnt					: Integer;	
begin
	_combo.clear();
	
	_combo.addItem(app.planningStateEnumToString(NULL_PLANSTATE));
	_combo.addItem(app.planningStateEnumToString(NOTIFIED_STATE));
	_combo.addItem(app.planningStateEnumToString(RECEIVED_STATE));
	_combo.addItem(app.planningStateEnumToString(PLANNED_LOAD_STATE));
	_combo.addItem(app.planningStateEnumToString(LOADED_STATE));
	_combo.addItem(app.planningStateEnumToString(PLANNED_DISCHARGE_STATE));
	_combo.addItem(app.planningStateEnumToString(DISCHARGED_STATE));
	_combo.addItem(app.planningStateEnumToString(DELIVERED_STATE));
	_combo.addItem(app.planningStateEnumToString(SHIFTED_STATE));
	
	if CM_QIntegerLookupEqual.hasInstance(_queryOperator) then
		_combo.text := app.planningStateEnumToString(_queryOperator.CM_QIntegerLookupEqual.searchValue);
	elseif CM_QIntegerLookupNotEqual.hasInstance(_queryOperator) then
		_combo.text := app.planningStateEnumToString(_queryOperator.CM_QIntegerLookupNotEqual.searchValue);
	endif;
	
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="99256715-2ace-44e2-9951-0cdbe6a70c08">
        <source>setListValues(_tbl : Table input; _params : CM_QueryCriteriaLineHolder; _operator : CM_QIntegerIsOneOf; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     06 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	intArray	: IntegerArray;
	idx,intSite	: Integer;
	strObj		: CM_String;
begin

	_tbl.purgeTableObjects();
	_tbl.clear;
	_tbl.rows := _tbl.fixedRows;
	
	create intArray transient;
	
	intArray.add(NULL_PLANSTATE);
	intArray.add(NOTIFIED_STATE);
	intArray.add(RECEIVED_STATE);
	intArray.add(PLANNED_LOAD_STATE);
	intArray.add(LOADED_STATE);
	intArray.add(PLANNED_DISCHARGE_STATE);
	intArray.add(DISCHARGED_STATE);
	intArray.add(DELIVERED_STATE);
	intArray.add(PLANNED_SHIFT_STATE);
	intArray.add(SHIFTED_STATE);
	
	self.setListTableFromIntConstants(_tbl, _operator, intArray, TI_PLANNINGSTATE_Constant);	

epilog
	delete intArray;
end;
/*vars
	
	_tbl.addItem(self.doesIncludeState(NULL_PLANSTATE, _operator) 		&amp; Tab &amp; app.planningStateEnumToString(NULL_PLANSTATE));
	_tbl.addItem(self.doesIncludeState(NOTIFIED_STATE, _operator) 		&amp; Tab &amp; app.planningStateEnumToString(NOTIFIED_STATE));
	_tbl.addItem(self.doesIncludeState(RECEIVED_STATE, _operator) 		&amp; Tab &amp; app.planningStateEnumToString(RECEIVED_STATE));
	_tbl.addItem(self.doesIncludeState(PLANNED_LOAD_STATE, _operator) 	&amp; Tab &amp; app.planningStateEnumToString(PLANNED_LOAD_STATE));
	_tbl.addItem(self.doesIncludeState(LOADED_STATE, _operator) 		&amp; Tab &amp; app.planningStateEnumToString(LOADED_STATE));
	_tbl.addItem(self.doesIncludeState(PLANNED_DISCHARGE_STATE, _operator) &amp; Tab &amp; app.planningStateEnumToString(PLANNED_DISCHARGE_STATE));
	_tbl.addItem(self.doesIncludeState(DISCHARGED_STATE, _operator) 	&amp; Tab &amp; app.planningStateEnumToString(DISCHARGED_STATE));
	_tbl.addItem(self.doesIncludeState(DELIVERED_STATE, _operator) 		&amp; Tab &amp; app.planningStateEnumToString(DELIVERED_STATE));
	_tbl.addItem(self.doesIncludeState(PLANNED_SHIFT_STATE, _operator) 	&amp; Tab &amp; app.planningStateEnumToString(PLANNED_SHIFT_STATE));
	_tbl.addItem(self.doesIncludeState(SHIFTED_STATE, _operator) 		&amp; Tab &amp; app.planningStateEnumToString(SHIFTED_STATE));
	
	
end;

*/</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
