    <JadeMethod name="setProxyYRDPadRow" id="843c776b-a8a0-43dc-9620-0c922d8bdfdd">
        <source>setProxyYRDPadRow(_gridArea : CM_GridArea) : CM_GridRow;

vars

	gridRow : CM_GridRow;

begin

// This can wait until we sort out a few problems with proxies.
//	if self.myGridRow &lt;&gt; null then
//		gridRow := app.createUpdateProxy(self.myGridRow).CM_GridRow;
//	else
		create gridRow transient;
//	endif;
	gridRow.setForProxy(self.row, self.label, _gridArea);
	return gridRow;

end;</source>
        <Parameter name="_gridArea" type="CM_GridArea"/>
        <ReturnType type="CM_GridRow"/>
    </JadeMethod>
