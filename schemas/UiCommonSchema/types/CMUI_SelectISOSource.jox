    <JadeMethod name="cmbYardArea_click" id="5b09bb37-2592-4f52-8a9f-703d5518e498">
        <controlMethod name="CMUI_ComboBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbYardArea_click(combobox: ComboBox input) updating;
// CCMS 1101 show best pick check box only for gridded areas
vars
	sourceTA	: CM_TerminalArea;
begin
	if combobox.listIndex &gt; 0 then
		sourceTA := combobox.itemObject[combobox.listIndex].CM_TerminalArea;
	endif;

	if sourceTA &lt;&gt; null then
		self.chkBestPick.visible := sourceTA.isGridArea();
	endif;

end;

</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
