    <JadeMethod name="doResizeControls" id="eec26ff1-4e66-47ab-b80c-385e15678927">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 September 2016	cnwndl1	Initial creation	TFS 2246 / 2680

*/

vars

	top : Real;
	width : Real;
	now : TimeStamp;
	stdHeight : Real;
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	
	top := self.resizedMargin;
	width := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	tabIndex := 4000;
	
	if _initialSetup then
		self.cmbVoyage.setAndIncrementTabIndex( tabIndex );
		self.cmbVoyage.visible := true;
	endif;
	self.cmbVoyage.move(	self.resizedMargin,
							top,
							width,
							stdHeight
							);
	
	top := top + self.cmbVoyage.height + self.resizedMargin;
	
	/////////////
	if _initialSetup then
		self.lblOnShip.setAndIncrementTabIndex( tabIndex );
		self.lblOnShip.visible := true;
	endif;
	self.lblOnShip.move(	self.resizedMargin,
						top,
						width,
						stdHeight
						);
						
	top := top + self.lblOnShip.height;
	if _initialSetup then
		self.lblInYard.setAndIncrementTabIndex( tabIndex );
		self.lblInYard.visible := true;
	endif;
	self.lblInYard.move(	self.resizedMargin,
							top,
							width,
							stdHeight
							);
	/////////////////
	top := top + self.lblInYard.height + stdHeight;
	if _initialSetup then
		self.cmbROROArea.setAndIncrementTabIndex( tabIndex );
		self.cmbROROArea.visible := true;
	endif;
	self.cmbROROArea.move(	self.resizedMargin,
							top,
							width,
							stdHeight
							);
	
	top := top + self.cmbROROArea.height + self.resizedMargin;
	if _initialSetup then
		self.cmbROROLane.setAndIncrementTabIndex( tabIndex );
		self.cmbROROLane.visible := true;
		self.cmbROROLane.sorted := false;
	endif;
	self.cmbROROLane.move(	self.resizedMargin,
							top,
							width,
							stdHeight
							);
							
	top := top + self.cmbROROLane.height + self.resizedMargin;
	if _initialSetup then
		self.lblDirection.setAndIncrementTabIndex( tabIndex );
		self.lblDirection.visible := true;
	endif;
	self.lblDirection.move(	self.resizedMargin,
						top,
						width,
						stdHeight
						);
						
	top := top + self.lblDirection.height + self.resizedMargin;
	if _initialSetup then
		self.optLeft.setAndIncrementTabIndex( tabIndex );
		self.optLeft.visible := false;
	endif;
	self.optLeft.move(	self.resizedMargin,
						top,
						width,
						stdHeight
						);
						
	top := top + self.optLeft.height + self.resizedMargin;
	if _initialSetup then
		self.optRight.setAndIncrementTabIndex( tabIndex );
		self.optRight.visible := false;
	endif;
	self.optRight.move(	self.resizedMargin,
						top,
						width,
						stdHeight
						);
	
/*	top := top + self.optRight.height + ( self.resizedMargin * 4 );
	if _initialSetup then
		self.lblOnShip.setAndIncrementTabIndex( tabIndex );
		self.lblOnShip.visible := true;
	endif;
	self.lblOnShip.move(	self.resizedMargin,
						top,
						width,
						stdHeight
						);
						
	top := top + self.lblOnShip.height;
	if _initialSetup then
		self.lblInYard.setAndIncrementTabIndex( tabIndex );
		self.lblInYard.visible := true;
	endif;
	self.lblInYard.move(	self.resizedMargin,
							top,
							width,
							stdHeight
							); */
						
	self.resizeCmdButtons();

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="6906092a-2992-4801-bb1c-59ce1cdcecbb">
        <updating/>
        <source>handleBtnOne() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 September 2016	cnwndl1	Initial creation	TFS 2246 / 2680

*/

vars

	ta : CM_TerminalArea;
	lc : CM_LocationsController;
	icArea : CM_InterchangeArea;
	msg : String;

begin

	self.myMobileGenericAgent.setMyTerminalArea(null);
	self.myMobileGenericAgent.setMyLocationsController(null);
	self.myMobileGenericAgent.setForward(true);
	
	ta := self.cmbROROArea.listObject.CM_TerminalArea;
	if ta = null then
		msg := self.lblROROArea.caption;
		return;
	endif;
	
	lc := self.cmbROROLane.listObject.CM_LocationsController;
	if lc = null then
		msg := self.lblROROLane.caption;
		return;
	endif;
	
	if not self.optLeft.value and not self.optRight.value then
		msg := app.getErrorString(Please_select_working_directi);
		return;
	endif;
	
	self.myMobileGenericAgent.setMyTerminalArea(ta);
	self.myMobileGenericAgent.setMyLocationsController(lc);
	self.myMobileGenericAgent.setForward( self.optLeft.value );
	self.myMobileGenericAgent.setMyVoyage( self.cmbVoyage.listObject.CM_Voyage );	//12 Sep 2016	NDL	TFS 2246
	self.gotoForm( MOB_HHVehicleROROLaneStd, false );	//27 Apr 2017	NDL	TFS 4160/4238

epilog

	if msg &lt;&gt; null then
		app.beep();
		self.msgBox(msg , app.getErrorString(Error), MsgBox_OK_Only, true);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
