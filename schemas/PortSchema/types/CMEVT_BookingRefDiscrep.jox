    <JadeMethod name="isForOperator" id="2dc4f042-6faf-4f43-90e0-5d68b887ddde">
        <source>isForOperator( _operator : CM_Operator ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 September 2009	cnwndl1	Initial creation	CCMS 1609 Par 20521

*/

vars

begin

	if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.myOperator = _operator then
		return true;
	endif;
	
	if self.myBookingRef &lt;&gt; null and self.myBookingRef.myOperator = _operator then
		return true;
	endif;
	
	if _operator &lt;&gt; null then
		if self.includesAttributeWithValueOf( ETRow_CargoType, _operator.code ) then
			return true;
		endif;
	endif; 

	return false;
	
epilog

end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isForVoyage" id="88d4669b-c8e5-4ae3-9656-7db749261e9f">
        <source>isForVoyage( _voyage : CM_Voyage ):Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 September 2009	cnwndl1	Initial creation	CCMS 1609 Par 20521

*/

vars

begin

	if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.myVoyage = _voyage then
		return true;
	endif;
	
	if self.myBookingRef &lt;&gt; null and self.myBookingRef.myVoyage = _voyage then
		return true;
	endif;
	
	if _voyage &lt;&gt; null then
		if self.includesAttributeWithValueOf( ETRow_Voyage, _voyage.code ) then
			return true;
		endif;
	endif; 


	return false;
	
epilog

end;</source>
