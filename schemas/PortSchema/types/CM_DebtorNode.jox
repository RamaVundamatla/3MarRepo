    <JadeMethod name="addDefaultRateForService" id="9390d2e6-bebe-4bb8-b2e6-481f21967532">
        <source>addDefaultRateForService(s : CM_Service; _bank : CM_Bank);

vars
	d : TimeStamp;
	rate : CM_DebtorRate;
	rateEntry : CM_RateEntry;
	rdg : CM_RootDebtorGroup;
	theBank : CM_Bank;
begin
	theBank := _bank;
	rdg := theBank.getRootDebtorGroup();
	
	//now create a dummy entry in the default debtor for this service. Note that all services must
	//be added to the default debtor so the all debtors can potentially inherit its rates.
	if rdg.serviceRates[s] = null then
		create rate;
		rate.service := s;
		rate.debtorNode := rdg;
		create rateEntry;
		rateEntry.rate := rate;
		rateEntry.startTimestamp := d;
		
		
		app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(rate); // TFS 45953
		app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(rateEntry); // TFS 45953
		
	endif;

end;</source>
        <Parameter name="s" type="CM_Service"/>
        <Parameter name="_bank" type="CM_Bank"/>
    </JadeMethod>
