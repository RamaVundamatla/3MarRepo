    <JadeMethod name="getEndDate" id="d4695607-98d7-4f46-a1e7-df3a73532adf">
        <source>getEndDate():TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 May 2013	cnwndl1	Initial creation	Par 31393
27 Sept 2021 navmj1 Bug 51070: PRP - Vehicle Booking Date / Time Bug
*/

vars

	date : TimeStamp;

begin

	date := self.toDate.asTimeStampFromWebInterface();		//27.9.2021 NAVMJ1 #51070
	// date := self.toDate.asDateFromWebInterface();	//27.9.2021 NAVMJ1 #51070
	return date;

epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getStartDate" id="5db4f8a4-0b39-443a-bf3a-d15aeb3a4f63">
