    <JadeMethod name="delete" id="68a4e06b-3a2b-415e-994d-5822f69b6f41">
        <updating/>
        <source>delete() updating;

vars

begin
	self.allJobSheets.purge;
end;
</source>
    </JadeMethod>
    <JadeMethod name="getCraneString" id="3a378ca4-7d03-4829-b501-e2eb6c3101fe">
        <source>getCraneString() : String;

vars
	craneSTR : String;
	js : CM_JobSheet;
	ti : CM_TrackedItem;
begin
	
	// ### for each job sheet get total number of overstowTIs for different job sheet.
	foreach js in self.allJobSheets do
		if craneSTR = null then
			craneSTR := js.CM_VoyageJobSheet.crane;
		else
			craneSTR := craneSTR &amp; ", " &amp; js.CM_VoyageJobSheet.crane;
		endif;
	endforeach;

	return craneSTR;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTIOrder" id="84443e03-ebcb-4b25-9fba-f5e9953cb58f">
        <source>getTIOrder(_ti : CM_TrackedItem; _js : CM_JobSheet output) : Integer;

vars
	wle : CM_WorkListEntry;
	vWLE : CM_VoyageWLE;
	js : CM_JobSheet;
	ti : CM_TrackedItem;
	crane : CM_Crane;
	craneRate : Integer;
begin
	vWLE := _ti.getVoyageWLEUnactioned(true);
	foreach js in self.allJobSheets do
		if js.allWLEByOrder.includes(vWLE) then
			_js := js;
			if self.mode = CMIF_ShipOverstowController.Mode_Absolute
			or self.mode = CMIF_ShipOverstowController.Mode_AsWorked then
				return js.allWLEByOrder.indexOf(vWLE);
			elseif self.mode = CMIF_ShipOverstowController.Mode_RealTimeEstimated then
				crane := js.CM_VoyageJobSheet.getMyCrane();
				craneRate := crane.targetRatePH;
				return (js.allWLEByOrder.indexOf(vWLE) * craneRate).Integer;
			elseif self.mode = CMIF_ShipOverstowController.Mode_RealTimeActual then
				craneRate := js.CM_VoyageJobSheet.getWorkActualRate();
				if craneRate= 0 then
					crane := js.CM_VoyageJobSheet.getMyCrane();
					craneRate := crane.targetRatePH;
				endif;
				return (js.allWLEByOrder.indexOf(vWLE) * craneRate).Integer;
			endif;
			
			
		endif;
	endforeach;
	
	_js := null;
	return 0;
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_js" type="CM_JobSheet" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="init" id="6dd8552d-2a42-4873-8922-733b4695fa7d">
        <updating/>
        <source>init(_voyage : CM_Voyage)updating;

vars

begin
	self.myVoyage := _voyage;
end;
</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
</Class>
