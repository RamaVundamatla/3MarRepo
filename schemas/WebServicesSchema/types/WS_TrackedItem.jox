    <JadeMethod name="delete" id="84b29183-3dac-46b1-9297-c002846662d0">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 September 2008	cnwkao1	Initial creation
06/09/16	cnwns1 	TFS	2525 Added AllChildren
*/

vars

begin
	delete self.cargoType;
	delete self.operatorCode;
	delete self.voyageCode;
	delete self.isoType;
	delete self.imexStatusString;
	delete self.dischargePort;
	delete self.destinationPort;
	delete self.carrier;//11/06/2009 cnwdz2 par19885
	delete self.consignor;
	delete self.consignee;
	delete self.commodity;
	delete self.releaseCarrier;
	delete self.freightForwarder;
	delete self.transportMode;
	delete self.shippingLineCode;
	delete self.allDischargePorts;
	delete self.loadPort;
	delete self.coolingType;
	delete self.voltageType;
	delete self.myCustomsAgent;
	delete self.mySubTerminal;
	delete self.myProduct;
	delete self.shippingLineCode;
	delete self.mySpecialStow; //epr TFs 7521 10/11/17
	delete self.myCountryOfOrigin;	// ### JIRA: MTN-36359 24Dec2025 NAVPW1
	delete self.transhipPort;		// ### JIRA: MTN-36359 24Dec2025 NAVPW1
	
	if not self.allCargoCheckItems.isEmpty then	//17 Oct 2011	NDL	Par 28303
		self.allCargoCheckItems.purge;
	endif;
	
	//cnwmc5 - 20 August 2014 - PAR 34784
	if not self.allTIHazards.isEmpty then
		self.allTIHazards.purge;
	endif;
	
	if not self.allSpecialLifts.isEmpty then
		self.allSpecialLifts.purge;
	endif;
	
	self.allCargoSeals.purge;
	delete self.voltageType;
	
	//jlier1 TFS 53766 30/6/22
	self.allWLELocations.purge;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAttachments" id="38b01b65-d543-471f-a9a7-39ab48454e68">
        <source>getAttachments(obj: CM_TrackedItem) : String;
/*
Purpose:			
Parameters:			
Return Value:		
Date		Who		Reason
21 Jan 2009	cnwdz2	Initial creation
*/
constants
	Delimiter	: String = "; ";
	
vars
	attachments : CM_TISet;
	attachment  : CM_TrackedItem;
	retVal		: String;
	delimLen	: Integer;
		
begin
	if obj &lt;&gt; null then
		delimLen := Delimiter.length() + 1; 
		//obj.getAllChildren(children);//PAR 22954
		//foreach attachment in children do
		foreach attachment in obj.allChildren do//cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
			retVal := retVal &amp; Delimiter &amp; attachment.id;
			
		endforeach;	
		
		if retVal.length() &lt; delimLen then
			return null;
		else
			return retVal[delimLen:end]; //remove the first delimiter 
		endif;
		
	else
		return null;
		
	endif;
	
epilog

end;</source>
        <Parameter name="obj" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOptionalDischargePortsDesc" id="2f763c6a-6753-4610-91d6-4e061ec28239">
        <source>getOptionalDischargePortsDesc(obj: CM_TrackedItem) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 September 2008	cnwkao1	Initial creation

*/
constants
	Delimiter	: String = ", ";
	
vars
	portCode	: String;
	retVal		: String;
	delimLen	: Integer;
	port		: CM_Port;
begin
	foreach portCode in obj.allDischargePorts do
		port := app.myRoot.allPorts.getAtKey(portCode);
		if retVal = null then
			retVal := port.portCode &amp; " (" &amp; port.getCountryCodeForDisplay( Tab ) &amp; ") " &amp; port.description;
		else
			retVal := retVal &amp; Delimiter &amp; port.portCode &amp; " (" &amp; port.getCountryCodeForDisplay( Tab ) &amp; ") " &amp; port.description;
		endif;
	endforeach;	
	
	return retVal;
	
epilog

end;</source>
        <Parameter name="obj" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOptionalDischargePortsId" id="5a5310f6-3caa-4cf9-a4ca-1fc3bb62305a">
        <source>getOptionalDischargePortsId(obj: CM_TrackedItem) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 September 2009	

*/
constants
	Delimiter	: String = ", ";
	
vars
	portCode	: String;
	retVal		: String;
	delimLen	: Integer;
	port		: CM_Port;
begin
	foreach  portCode in obj.allDischargePorts do
		port := app.myRoot.allPorts.getAtKey(portCode);
		if retVal = null then
			retVal := port.getCountryCodeForDisplay( Tab )  &amp; port.portCode;
		else
			retVal := retVal &amp; Delimiter &amp; port.getCountryCodeForDisplay( Tab )  &amp; port.portCode;
		endif;
	endforeach;	
	
	return retVal;
	
epilog

end;</source>
        <Parameter name="obj" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setAllTIHazards" id="1a3c134d-cc2d-40e9-a654-14f17cc0241c">
        <updating/>
        <source>setAllTIHazards(obj: CM_TrackedItem) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 September 2010	#cnwdz2	 25439

*/
vars
	tiHazard 	: CM_Hazard;
	wsTIHazard 	: WS_TIHazard;
	
begin

	foreach tiHazard in obj.allTIHazards do
		create wsTIHazard transient;
		wsTIHazard.setProxyFromObject( tiHazard );
		self.allTIHazards.add( wsTIHazard );
	endforeach;
	
epilog
	
end;</source>
        <Parameter name="obj" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setCargoCheckItems" id="b8284ff7-c87f-4fb3-9408-f326af7b4299">
        <source>setCargoCheckItems( _ti: CM_TrackedItem );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 October 2011	cnwndl1	Initial creation	Par 28303

*/

vars

	cargoCheckItems : CM_CargoCheckItemArray;
	cargoCheckItem : CM_CargoCheckItem;
	wscargoCheck : WS_CargoCheck;
	sealType : CM_SealType;
	allSealTypes : CM_SealTypeSet;

begin

	create cargoCheckItems transient;
	_ti.getCargoCheckItemsForTallyman( cargoCheckItems, true, true );
	
	if cargoCheckItems.isEmpty then
		return;
	endif;
	
	foreach cargoCheckItem in cargoCheckItems discreteLock do
		if cargoCheckItem.requiredExtraInfo &lt;&gt; EXTRA_INFO_SEALS then
			create wscargoCheck transient;
			wscargoCheck.setProxyFromObject( cargoCheckItem );
			self.allCargoCheckItems.add( wscargoCheck );
		endif;
	endforeach;
	
	if _ti.myCargoType = null or _ti.myCargoType.allSealTypes.isEmpty then
		return;
	endif;
	
	create allSealTypes transient;
	foreach cargoCheckItem in cargoCheckItems discreteLock do
		if cargoCheckItem.requiredExtraInfo = EXTRA_INFO_SEALS then
		
			allSealTypes.clear();
			foreach sealType in _ti.myCargoType.allSealTypes do
				if sealType.notAvailableForEntry then
					continue;
				endif;
				allSealTypes.add(sealType);
			endforeach;
			
			foreach sealType in allSealTypes do
				create wscargoCheck transient;
				wscargoCheck.setProxyFromObjectAndSeals( _ti, sealType, cargoCheckItem );
				self.allCargoCheckItems.add( wscargoCheck );
			endforeach;
			
		endif;
	endforeach;

epilog

	delete cargoCheckItems;
	delete allSealTypes;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setColours" id="91094e83-6aef-42bd-b8bf-87a8eadc0fb2">
        <updating/>
        <source>setColours(_theTI : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:     28 March 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpColor : Integer;
	r,g,b : Integer;
	tmpPort : CM_Port;
	tmpISOGrp : CM_ISOTypeGroup;
	tmpIMEX : CM_IMEXStatus;
	tmpOp : CM_Operator;
	tmpW : CM_WeightRange;
	tmpRoot : CM_Root;
	invalid : Boolean;	//05 Feb 2019	NDL	TFS 43255
	edition : Integer;	//05 Feb 2019	NDL	TFS 43255
begin
	// ### VOYAGE COLOUR
	self.colorVoyage := "FFFFFF";
	if _theTI.myVoyage &lt;&gt; null then
	
		on Exception do app.handleDeletedObject( exception, _theTI.myVoyage, invalid );	//05 Feb 2019	NDL	TFS 43255
		edition := _theTI.myVoyage.edition;
		if not invalid then
			tmpColor := _theTI.myVoyage.colour;
			tmpColor.cnEcGetRGBValues (r,g,b);
			self.colorVoyage :=  r.asHex(2).String &amp;  g.asHex(2).String &amp; b.asHex(2).String;
		endif;
	endif;
	
	// ### ISOGroup COLOUR
	self.colorISOGroup := "FFFFFF";
	tmpISOGrp := _theTI.getISOTypeGroup();
	if tmpISOGrp &lt;&gt; null then
		tmpColor := tmpISOGrp.colour;
		tmpColor.cnEcGetRGBValues (r,g,b);
		self.colorISOGroup :=  r.asHex(2).String &amp;  g.asHex(2).String &amp; b.asHex(2).String;
	endif;
	
	// ### IMEX COLOUR
	self.colorImEx := "FFFFFF";
	tmpIMEX := _theTI.getImExStatusObject();
	if tmpIMEX &lt;&gt; null then
		tmpColor := tmpIMEX.colour;
		tmpColor.cnEcGetRGBValues (r,g,b);
		self.colorImEx :=  r.asHex(2).String &amp;  g.asHex(2).String &amp; b.asHex(2).String;
	endif;
	
	// ### OPERATOR COLOUR
	self.colorOperator := "FFFFFF";
	tmpOp := _theTI.myOperator;
	if tmpOp &lt;&gt; null then
		tmpColor := tmpOp.colour;
		tmpColor.cnEcGetRGBValues (r,g,b);
		self.colorOperator :=  r.asHex(2).String &amp;  g.asHex(2).String &amp; b.asHex(2).String;
	endif;
	
	self.colorWeight := "FFFFFF";
	self.colorDishPort := "FFFFFF";
	tmpRoot := _theTI.getRoot();
	if tmpRoot &lt;&gt; null then
		// ### WEIGHT COLOUR
		tmpW := tmpRoot.getColourFromWeightRange(_theTI.getWeightForDisplay());
		if tmpW &lt;&gt; null then
			tmpColor := tmpW.colour;
			tmpColor.cnEcGetRGBValues (r,g,b);
			self.colorWeight :=  r.asHex(2).String &amp;  g.asHex(2).String &amp; b.asHex(2).String;
		endif;
	
		// ### DISCHARGE PORT COLOUR
		tmpPort := tmpRoot.allPorts[_theTI.dischargePort];
		if tmpPort &lt;&gt; null then
			tmpColor := tmpPort.colour;
			tmpColor.cnEcGetRGBValues (r,g,b);
			self.colorDishPort :=  r.asHex(2).String &amp;  g.asHex(2).String &amp; b.asHex(2).String;
		endif;
	
	endif;
	
epilog

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setIdDetails" id="9eab8de7-0a26-474f-8560-d754bfb09a36">
        <updating/>
        <source>setIdDetails(trackedItem : CM_TrackedItem) updating;
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 09 July 2019
TFS#		: 45287
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	if trackedItem = null then
		return;
	endif;
	
	self.cmObjectEdition	:= trackedItem.edition();
	self.cmObjectId			:= trackedItem.getOidAsString();
	self.idTextBox			:= trackedItem.id;
end;</source>
        <Parameter name="trackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setJobDetails" id="6734bfba-bc24-4b68-bf76-07884cc4d875">
        <updating/>
        <source>setJobDetails(_job, _seq : String) updating;
 /*
Purpose:			
Date		Who		Reason
21 August 2015	cnwab1	Initial creation
*/

vars

begin
	self.jobID := _job;
	self.sequenceNum := _seq;
epilog

end;</source>
        <Parameter name="_job" type="String"/>
        <Parameter name="_seq" type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="bdc6c773-8130-45e5-a9d9-4b6a222d44db">
        <updating/>
        <source>setProxyFromObject(obj: CM_TrackedItem) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 Aug 2008	cnwkao1	Initial creation
06 Mar 2009	cnwkpd1	PAR #19039 - remove isValidObject references for performance
13 Jun 2013	cnwdap1	PAR #31754 Imperial Measurements in the RIA
13 Jun 2013	cnwdap1	PAR #31700 Total quantity and number of items for Break-Bulk
14 Jun 2013	cnwdap1	PAR #31800 Added clientRef, colour, itemDesc, markNumber and parentCargoID 
24 Sep 2013	cnwdap1	PAR #32215 CCMS DPH 2290 New Car Attributes
05 Mar 2014	cnwdap1	PAR #33193 CCMS DPH 2285 Added Purchase Order and Service Order fields
28 Jul 2015	cnwdap1	PAR #36682 Added Expiry Date field
24/04/2016	cnwdap1	TFS #1493 Added isConnected and mySpecialStow for Mobile Cargo Details
26/09/16	cnwns1 	TFS	2525 Added hasChildren
14/02/2018	jlgns1	Bug 36930: PNL - Web Portal Cargo Enquiry - Customs Export Delivery Order
19/02/2018	jlghl1	Extending WS_TI for prenote fields
17/04/2018 	jlger1	tfs 38056 17/4/18 measurement types i.e. weights, volumes, lenghts should return stored values
24/07/2018  jlgam15 TFS 39806 Temp to be displayed in F
16/08/2018	jlgdap1	TFS 40003 PEL1 Voyage to Road Moves
5/09/2019 	JLGNS1	Bug 46173: PNL - Vehicle App Driver Initiated Move of overstowed container
30/09/2019	JLGNS1	Bug 46697: SNO - Translating Web App
10 Oct 2019 cnwma1	Bug 46793: Web Portal - Prenotes for non container cargo that has a commodity that requires temperature does not show reefer section
3/12/2019	jlgns1	TFS47394 PNL - Tandem Move Enhancements
28/01/2020	jlgka1	TFS 45987 - JMT - Lander Apps WLE Picker
04/11/2020  cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
05/07/2021	navdap1	TFS 51409 PNL Queued Jobs in Driver Mode
17/11/2021	navdap1	TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
03/05/2022	jlizm1	TFS 53084 GPHA revceival/release of tranship cargo
24/05/2022	jlika1	TFS 53316 - EUP - GEN - Additional Dimensions For Cargo - PortSchema
28/06/2022	navsrk20	Task 53922: Implement shipping line in WS_TrackedItemQueryRequest
18/10/2022	navma1	Bug 54741: MTN - Trailer Type doesn't appear correctly on Mobile apps	
16/11/2022  navlw1	TFS 55392: EUP - Country of Origin
01 Mar 2023	navak20 Task 56421: EUP- Link existing apps to cargo group view - Add Group Id to the cargo details
16 Mar 2023 navlw1  Task 55162: EUP - WMS-Repair BBK extra details recording
01 Nov 2023	jlizm1	TFS 60985 MAFI queueing behaviour configuration
16 Nov 2023 navma1	ChangeRequest 58350: EUP | Sorting Method info displayed in Job Lander, Cargo Lander WEB
20 Feb 2024	jlizm1	TFS 62467 CUX Warning when setdown to MAFI heap
26 Feb 2024 navnk30	Bug 62243: MTN - Mobile Apps - Cargo Lander - Maintenance - Motor Vehicle no longer displaying 'Total Volume'
25 Sep 2024 navma1	Bug 66241: POL - Operator Import Release PIN is being incorrectly displayed in the Web Portal
19 Dec 2024 navsck1 MTN-33476 Display damage (indicator) as a part of the cargo details in the webapps 
31 Jan 2025 navsck1 MTN-33847 MTN | Issues with the Damage Count Field in cargo Apps after Repair
*/

constants 
	Delimiter		: String = ", ";
vars
	consignor		: CM_ConsigneeConsignor;
	port			: CM_Port;
	imexStatus		: CM_IMEXStatus;
	isoType			: CM_ISOType;
	carrier			: CM_Carrier;
	voyage	    	: CM_Voyage;
	tmpCommodity	: CM_Commodity;
	tmpComGroup		: CM_CommodityGroup;
	realCargoType	: CM_CargoType;
	realConsignee	: CM_ConsigneeConsignor;
	realFF			: CM_ConsigneeConsignor;
	subTerminal     : CM_SubTerminal;
	invalidObject	: Boolean;
	container	 	: CM_Container;
	myCustomsAgent  : CM_CustomsAgent;
	myProduct       : CM_Product;
	tmpISOGroup 	: CM_ISOTypeGroup;	
	sl 				: CM_SpecialLift;
	wssl 			: WS_SpecialLift;
	wsss			: WS_SpecialStow;			
	sealType 		: CM_SealType;
	wsCargoSeal		: WS_CargoSeal;
	sealTI 			: CM_SealTI;
	wsTranship 		: WS_Port;
	wle 			: CM_WorkListEntry;
	allOStowTIs 	: CM_TIArray;		//TFS47394
	accessDirection : Integer;			//TFS47394
	machine 		: CM_Machine;	//12 Jan 2021 NDL TFS 50616
	invalid 		: Boolean;	//12 Jan 2021 NDL TFS 50616
	queuedMove 		: CM_FutureMoveQueued;			// TFS 51409
	rtVehicleConfig : CM_RTVehicleConfig;
	shippingLine	: CM_ShippingLine;		//28.06.2022 navsrk20 TFS 53922
	wsWLE 			: WS_WorkListEntry;
	fm 				: CM_FutureMove;
	countryOfOrigin	: CM_Country;
	sortingMethod   : CM_SortingMethod;
	user			: CM_User;
	root			: CM_Root;
	oprImportPin,
	oprExportNum	: String;
	damage 			: CM_DamageInstance;
	damageCount 	: Integer;
begin	
	inheritMethod(obj);

	root					:= app.myRoot;
	self.bookingReference	:= obj.bookingReference;
	
	if obj.isContainer then                     //10.10.2019 cnwma1 #46793
		container := obj.CM_Container;
		
		self.isClean 		 := container.isClean.String;
		self.overHeight      := container.overHeight;
		self.overLengthFront := container.overLengthFront;
		self.overLengthRear  := container.overLengthRear;
		self.overWidthLeft   := container.overWidthLeft;
		self.overWidthRight  := container.overWidthRight;
	endif;
	
	self.setReeferDetails(obj);                          //10.10.2019 cnwma1 #46793
	
	if obj.canSetAvailabilityGrade then
		self.availabilityGrade      := 	obj.getAvailabilityGradeDesc.trimBlanks();
	endif;
	
	if obj.getExpectedArrivalDate.isValid then	//29 Jul 2013	NDL	Par 31763
		self.expectedArrivalDate := obj.getExpectedArrivalDate.asStringForWebInterface();	//29 Jul 2013	NDL	Par 31763
	endif;
	
	if obj.getExpectedArrivalTime.isValid then	//29 Jul 2013	NDL	Par 31763
		self.expectedArrivalTime := obj.getExpectedArrivalTime.asStringForWebInterface();	//29 Jul 2013	NDL	Par 31763
	endif;
	
	realCargoType := obj.myCargoType;
	if realCargoType &lt;&gt; null then
		create self.cargoType transient;
		self.cargoType.setProxyFromObject(realCargoType);
	endif;
	
	tmpCommodity := root.allCommodities[obj.commodity];
	if tmpCommodity &lt;&gt; null then
		create self.commodity transient;
		self.commodity.setProxyFromObject(tmpCommodity);
	endif;
	
	tmpComGroup := root.allCommodityGroups[obj.commodityGroup];//17/04/2009 cnwdz2 par19482
	if tmpComGroup &lt;&gt; null then
		self.comGroup := tmpComGroup.code;
		self.comGroupDesc := tmpComGroup.description;
	endif;
	
	realConsignee := obj.myConsignee;
	if realConsignee &lt;&gt; null then
		create self.consignee transient;
		self.consignee.setProxyFromObject(realConsignee);
	endif;
		
	if obj.consignor &lt;&gt; null then
		consignor := root.allConsigneeConsignors.getAtKey(obj.consignor);
		if consignor &lt;&gt; null then
			create self.consignor transient;
			self.consignor.setProxyFromObject(consignor);
		endif;
	endif;
	
	if obj.destinationPort &lt;&gt; null then
		port := root.allPorts.getAtKey(obj.destinationPort);
		if port &lt;&gt; null then
			create self.destinationPort transient;
			self.destinationPort.setProxyFromObject(port);
		endif;		
	endif;	
	
	if obj.dischargePort &lt;&gt; null then
		port := root.allPorts.getAtKey(obj.dischargePort);
		if port &lt;&gt; null then
			create self.dischargePort transient;
			self.dischargePort.setProxyFromObject(port);
		endif;
	endif;
	
	self.idTextBox			:= obj.id;

	imexStatus := obj.getImExStatusObject();
	if imexStatus &lt;&gt; null then
		create self.imexStatusString transient;
		self.imexStatusString.setProxyFromObject(imexStatus);
		self.imexCodeString := imexStatus.description;
	endif;
	
	isoType := obj.getISOTypeObject();
	if isoType &lt;&gt; null then
		create self.isoType transient;
		self.isoType.setProxyFromObject(isoType);
	endif;
	shippingLine := obj.myShippingLine;		//28.06.2022 navsrk20 TFS 53922
	
	voyage := obj.myVoyage;
	if voyage &lt;&gt; null then
		invalidObject := false;
		on Exception do app.handleDeletedObject(exception, voyage, invalidObject);

		self.vesselDescription := voyage.vesselName;
		self.vesselCode		   := voyage.vesselCode;
		self.voyageCodeString  := voyage.code;
		
		create self.voyageCode transient;
		self.voyageCode.setProxyFromObject(voyage);
		if voyage.myShippingLine &lt;&gt; null then
			if shippingLine = null then						//28.06.2022 navsrk20 TFS 53922
				shippingLine := voyage.myShippingLine;		//28.06.2022 navsrk20 TFS 53922
			endif;											//28.06.2022 navsrk20 TFS 53922
		endif;
		
		if invalidObject then
			delete self.voyageCode;
			delete self.shippingLineCode;
		endif;
		
		on Exception do null;
		
	endif;
	//Start 28.06.2022 navsrk20 TFS 53922
	if shippingLine &lt;&gt; null then
			create self.shippingLineCode transient;
			self.shippingLineCode.setProxyFromObject(shippingLine);
	endif;
	//End 28.06.2022 navsrk20 TFS 53922
	
	// 16/11/2022 navlw1 tfs 55392
	countryOfOrigin := obj.myCountryOfOrigin;
	if countryOfOrigin &lt;&gt; null then
		create self.myCountryOfOrigin transient;
		self.myCountryOfOrigin.setProxyFromObject(countryOfOrigin);
	endif;
	
	if obj.myOperator &lt;&gt; null then
	
		invalidObject := false;
		on Exception do app.handleDeletedObject(exception, obj.myOperator, invalidObject);
		
		create self.operatorCode transient;
		self.operatorCode.setProxyFromObject(obj.myOperator);
		self.operatorCodeString := obj.myOperator.code;
		
		if invalidObject then
			delete self.operatorCode;
		endif;
		
		on Exception do null;
	endif;	
	
	create self.transportMode transient;
	self.transportMode.id			:= app.transportModeENumToString(obj.receiptTransportMode);	
	self.transportMode.description	:= self.transportMode.id;
	
	self.mark := obj.mark; //29/06/2011 cnwdz2 27784
	self.sealNum			:= obj.getSealNum();
	
	//cnwmc5 - 22/01/2013 - CCMS 2238 - PAR #30765
	self.sealNumShippers	:= obj.getSealNumShipper();
	self.sealNumCustoms		:= obj.getSealNumCustoms();
	self.sealNumVent		:= obj.getSealNumVent();
	
	//epr TFS 38056 17/4/18 weights should always be returned in what they are stored in i.e kgs
	self.weightTotal		:=  obj.totalWeight.asStringJMT	;
	
	self.weightCargo := obj.weightCargo.asStringJMT;
	self.weightTare :=  obj.weightTare.asStringJMT;
	
	create self.allDischargePorts transient;
	self.allDischargePorts.description := self.getOptionalDischargePortsDesc(obj);
	self.allDischargePorts.code := self.getOptionalDischargePortsId(obj);
	
	//17/09/2010 cnwdz2 par25439
	self.setAllTIHazards(obj);
	
	//maintainable fields for import release - this could be made optional
	carrier := root.allCarriers.getAtKey(obj.releaseCarrier);
	if carrier &lt;&gt; null then
		create self.releaseCarrier transient;
		self.releaseCarrier.setProxyFromObject(carrier);		
	endif;
	
	realFF := obj.myFreightForwarder;
	if realFF &lt;&gt; null then
		create self.freightForwarder transient;
		self.freightForwarder.setProxyFromObject(realFF);
	endif;	
	
	self.carrierRemarks			:= obj.carrierRemarks;
	self.deliveryReleaseNumber	:= obj.deliveryRelease;
	//self.customsEntryNumber		:= obj.customsEntryNumber;
	//cnwmc5 - PAR 32206 - 5 Sep 2013
	self.overDimension			:= obj.isOverDimensions.String; //app.getYesNo(obj.isOverDimensions);
	
	myCustomsAgent := obj.myCustomsAgent;	//13/10/2009 cnwdz2 par20983
	if myCustomsAgent &lt;&gt; null then
		create self.myCustomsAgent transient;
		self.myCustomsAgent.setProxyFromObject(myCustomsAgent);
	endif;
	
	if obj.myPinNo &lt;&gt; null then
		self.pinNo := obj.myPinNo.pinNo;
	endif;
	
	//11/06/2009 cnwdz2 par19885
	//self.carrier		:= obj.carrier;	
	if obj.carrier &lt;&gt; null then
		carrier := root.allCarriers.getAtKey(obj.carrier);
		if carrier &lt;&gt; null then
			create self.carrier transient;
			self.carrier.setProxyFromObject(carrier);
		endif;
	endif;

	//epr TFS 38056 17/4/18 all measurement types are returned in there stored values 
	self.length :=	obj.length.asStringJMT;
	self.width  :=  obj.width.asStringJMT;
	self.height := 	obj.height.asStringJMT;
	//self.volume :=  obj.volume.asStringJMT;			//26.02.2024 navnk30 #62243
	self.volume :=  obj.getMyTotalVolume.asStringJMT;	//26.02.2024 navnk30 #62243
	
	// 16 Mar 2023 tfs 55162 navlw
	self.cargoVolume := obj.volume.asStringJMT;
	
	self.stopsDescription := obj.getStopsDesc().replace('/', ', ');		//cnwmc5 - PAR 32573
	
	self.hasAttachments	:= self.getAttachments(obj);	
	
	self.locationGeneral := obj.locationGeneral();
	self.receivedDT := obj.receivedDT.asStringForWebInterface();	//26 Oct 2012	NDL	Par 30622
	self.releasedDT := obj.releasedDT.asStringForWebInterface();	//26 Oct 2012	NDL	Par 30622
	
	if obj.loadPort &lt;&gt; null then
		port := root.allPorts.getAtKey(obj.loadPort);
		if port &lt;&gt; null then
			create self.loadPort transient;
			self.loadPort.setProxyFromObject(port);
		endif;
	endif;
	
	//cnwmc5 - PAR 32206 - 5 Sep 2013
	self.damaged 	:= obj.damaged.String;//app.getYesNo(obj.damaged);
	self.toDoTasks  := obj.getToDoTasksDisplay(obj.allToDoTasksToDo, false);
	//self.damagesCount := obj.allDamageInstances.size; 	//19/12/24 navsck1 MTN-33476
	
	damageCount := 0;										//31/01/25 navsck1 MTN-33847
	foreach damage in obj.allDamageInstances do
		if damage.status &lt;&gt; DamageStatusRepaired then
			damageCount := damageCount + 1;
		endif;
	endforeach;												//31/01/25 navsck1 MTN-33847
	self.damagesCount := damageCount;						//31/01/25 navsck1 MTN-33847
	
	/*
	25.9.2024 navma1 #66241
	*/
	user := app.getMyUser();
	oprImportPin := obj.getOperatorImportReleasePIN();
	if oprImportPin &lt;&gt; null then
		if user &lt;&gt; null and user.canViewOperatorImpPin(obj.myTerminal) then
			self.importReleasePIN := oprImportPin;
		else
			self.importReleasePIN := '***';
		endif;
	endif;
	
	oprExportNum := obj.getOperatorExpReleaseNo();
	if oprExportNum &lt;&gt; null then
		if user &lt;&gt; null and user.canViewOperatorExpReleaseNum(obj.myTerminal) then
			self.exportReleaseNumber := oprExportNum;	
		else
			self.exportReleaseNumber := '***';
		endif;
	endif;
	
	if obj.isCoastalOutbound() and obj.customExportEntryNumber = null then
		self.customExportEntryNumber :=  NA_Coastal;
	else
		self.customExportEntryNumber :=  obj.customExportEntryNumber;		//Bug 36930
	endif;
	
	if obj.isStopSetToBeProcessed(StopProcessEDICustomExport) then
		//cnwmc5 - PAR 32206 - 5 Sep 2013
		self.customExportStop :=  'true';//'Yes';
	endif;
	
	//12/05/2010 cnwdz2 23379
	myProduct := obj.myProduct;
	if myProduct &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, myProduct, invalidObject);
		create self.myProduct transient;
		self.myProduct.setProxyFromObject(myProduct);
		on Exception do null;
	endif;	
	
	self.remarks := obj.remarks;
	self.billOfLading := obj.billOfLading; //13/10/2009 cnwdz2 par20983
	self.customsEntryNumber := obj.customsEntryNumber; //13/10/2009 cnwdz2 par20983
	
	subTerminal := obj.mySubTerminal; //22/04/2009 cnwdz2 ccms1735
	if subTerminal &lt;&gt; null then
		create self.mySubTerminal transient;
		self.mySubTerminal.setProxyFromObject(subTerminal);
	endif;
	
	//04/11/2010 cnwdz2 26201
	if obj.isTranshipItem then
		if obj.myImportVoyage = obj.myVoyage then
			self.tranship := app.getErrorString(TI_Tranship_Receival);
		elseif obj.myExportVoyage = obj.myVoyage then
			self.tranship := app.getErrorString(TI_Tranship_Departure);
		endif;
	endif;
	
	self.transitStatus := obj.getTransitStatus;	// TFS 53084
	
	// ### 28/3/11 - AB 
	self.setColours(obj);
	self.dischargePortString := obj.dischargePort;
	self.isoGroupString := "N/A";
	tmpISOGroup := obj.getISOTypeGroup();
	if tmpISOGroup &lt;&gt; null then
		self.isoGroupString := tmpISOGroup.code;
	endif;
	self.contentsStatusString := obj.getContentsStatusDesc(false);
	self.commodityCode := obj.commodity;
	self.consigneeString := obj.consignee;
	self.consignorString := obj.consignor;
	self.isoTypeString := obj.getISOType();
	self.isoLength := obj.getActualLength();
	self.isoHeight := obj.getActualHeight();
    //epr TFS 44883 27/6/19 - need to call method to get if can depend on config like the Rail Position Format 
	self.locnActual := obj.getPrimaryLocationId(REAL_MODE);
	self.locnQueued :=  obj.getPrimaryLocationId(QUEUE_MODE);
	self.locnPlanned := obj.getPrimaryLocationId(PLANNING_MODE);
	self.alternativeId := obj.alternativeId;	//03 May 2013	NDL	Par 31506
	
	self.totalQuantity		:= obj.totalQuantity;							// PAR #31700
	if obj.isKindOf(CM_BreakBulkGeneric) then								// PAR #31700
		self.numItems	:= obj.CM_BreakBulkGeneric.unsplitQuantity;			// PAR #31700
		// jlika1 TFS 53316 --&gt;
		//self.diameter		:= obj.CM_BreakBulkGeneric.diameter.asStringJMT;
		self.diameter		:= obj.CM_BreakBulkGeneric.getDiameter().asStringJMT(); 		// ### TFS 54021 29June2022 NAVPW1
		//self.grade			:= obj.CM_BreakBulkGeneric.grade;
		self.grade			:= obj.CM_BreakBulkGeneric.getGrade();			// ### TFS 54021 29June2022 NAVPW1
		//self.grammage		:= obj.CM_BreakBulkGeneric.grammage.asStringJMT;
		self.grammage		:= obj.CM_BreakBulkGeneric.getGrammage().asStringJMT();		// ### TFS 54021 29June2022 NAVPW1
		//self.rollingLength	:= obj.CM_BreakBulkGeneric.rollingLength.asStringJMT;
		self.rollingLength	:= obj.CM_BreakBulkGeneric.getRollingLength().asStringJMT();	// ### TFS 54021 29June2022 NAVPW1
		// jlika1 TFS 53316 &lt;--
	endif;																	// PAR #31700
		
	self.clientRef			:= obj.clientRef;								// PAR #31800
	if obj.isKindOf(CM_BreakBulkGeneric) then								// PAR #31800
		self.colour			:= obj.CM_BreakBulkGeneric.colour;				// PAR #31800
	endif;																	// PAR #31800
	self.itemDesc			:= obj.description;								// PAR #31800
	self.markNumber			:= obj.markNumber;								// PAR #31800
	if obj.isChild then														// PAR #31800
		self.parentCargoID 	:= obj.getParent.id;							// PAR #31800
		self.parent			:= obj.getParent.id;							// PAR #31800
	endif;																	// PAR #31800
	self.state				:= obj.getStateDisplay;							// PAR #31800
	if obj.state = TI_STATE_NORMAL then										// PAR #31800	
		self.state			:= "On Site";									// PAR #31800
	endif;																	// PAR #31800
	
	if obj.isKindOf(CM_Car) then											// PAR #32215
		self.colour 			:= obj.CM_Car.colour;						// PAR #32215
		self.make				:= obj.CM_Car.make;							// PAR #32215
		self.model				:= obj.CM_Car.model;						// PAR #32215
		self.vehicleType		:= obj.CM_Car.carType;						// PAR #32215
		self.year				:= obj.CM_Car.year;							// PAR #32215
		self.trackingNumber1	:= obj.CM_Car.trackingNumber1;				// PAR #32215
		self.trackingNumber2	:= obj.CM_Car.trackingNumber2;				// PAR #32215
		self.docsReceived		:= obj.CM_Car.docsReceived.Date.asStringForWebInterface;// PAR #32215
		self.docsSent			:= obj.CM_Car.docsSent.Date.asStringForWebInterface;	// PAR #32215
		self.docsCleared		:= obj.CM_Car.docsCleared.Date.asStringForWebInterface;	// PAR #32215
		self.docsReturned		:= obj.CM_Car.docsReturned.Date.asStringForWebInterface;// PAR #32215
		self.isSelfPropelled	:= obj.CM_Car.selfPropelled;				// PAR #32215
		self.doors				:= obj.CM_Car.nbrDoors;						// PAR #32215
		self.newVehicle			:= obj.CM_Car.isNew;						// PAR #32215
	endif;																	// PAR #32215
	
	self.purchaseOrder			:= obj.purchaseOrder;						// PAR #33193
	self.serviceOrder			:= obj.serviceOrder;						// PAR #33193
	
	self.wagon					:= obj.wagon;								// 35603
	if obj.isKindOf(CM_TILC) then											// cnwmc5 - 30 April 2014 - PAR 33988
		self.trailerType 		:= obj.CM_TILC.getTrailerTypeDesc();		// cnwmc5 - 30 April 2014 - PAR 33988
		self.trailerTypeCode	:= obj.CM_TILC.getTrailerType();			// 18.10.2022 navma1 #54741
	endif;																	// cnwmc5 - 30 April 2014 - PAR 33988
	
	foreach sl in obj.allSpecialLifts discreteLock do
		create wssl transient;
		wssl.setProxyFromObject( sl);
		self.allSpecialLifts.add(wssl);
	endforeach;

	if obj.getSpecialStow &lt;&gt; null then						// TFS #1493
		create wsss transient;								// TFS #1493
		wsss.setProxyFromObject(obj.getSpecialStow);		// TFS #1493
		self.mySpecialStow := wsss;							// TFS #1493
	endif;													// TFS #1493
	
	self.isWeightCertified        := obj.isWeightCertified;					// cnwmc5 - 23 May 2016 - TFS 2019
	self.weightCertifiedName      := obj.weightCertifiedName;				// cnwmc5 - 23 May 2016 - TFS 2019	
	self.weightCertifiedReference := obj.weightCertifiedReference;			// cnwmc5 - 23 May 2016 - TFS 2019
	self.hasChildren              := (obj.allChildren.size &gt; 0 ).String;	//TFS 2525 26/09/16
	self.readyStatus              := obj.getReadyStatus();   			    //epr TFS 7402 16/10/17 new development for webportal
	
	//epr 19/10/17 tfs 7401 webportal
	foreach sealType in obj.myCargoType.allSealTypes do
		create wsCargoSeal transient;
		sealTI := obj.allSeals[sealType.sealType];
		if sealTI &lt;&gt; null then
			wsCargoSeal.setProxyFromObject(sealTI);
		else
			wsCargoSeal.setSealType(sealType.sealType);
		endif;
		self.allCargoSeals.add(wsCargoSeal);
	endforeach;
	
	if (obj.myTranshipToPort &lt;&gt; null) then	
		create wsTranship transient;
		wsTranship.setProxyFromObject(obj.myTranshipToPort);
		self.transhipPort := wsTranship;
	endif;
	
	self.isDirectDelivery := obj.directDelivery;
	
	//jlier1 TFS  53766 30/6/22
	foreach wle in obj.allWorklistEntries discreteLock do
		create wsWLE transient;
		wsWLE.setProxyFromObject(wle);
		if wsWLE.id = null then
			delete wsWLE;
			continue;
		endif;
		self.allWLELocations.add(wsWLE);
	endforeach;
	
	foreach fm in obj.allPlannedFutureMoves discreteLock do
		if fm.myWorkListEntry &lt;&gt; null and obj.allWorklistEntries.includes(fm.myWorkListEntry) then
			continue;
		endif;
		create wsWLE transient;
		wsWLE.setProxyFromFM(fm);
		self.allWLELocations.add(wsWLE);
	endforeach;
	
	//jlier1 TFS 54068 18/7/22	
	if self.allWLELocations.size  = 1 then
		if  self.allWLELocations.first.plannedWarehouseArea = null then
			self.allWLELocations.purge;	
		endif;	
	endif;
	
	self.isOverstowed := obj.isOverStowedRTQueue(null);	//Bug 46173
	
	//12 Jan 2021 NDL TFS 50616 - Found in an associated dump file.
	if currentSession &lt;&gt; null then
		on Exception do app.handleDeletedObject( exception, currentSession, invalid );
		machine := currentSession.myCurrentMachine;
	endif;

//	if currentSession &lt;&gt; null and currentSession.myCurrentMachine &lt;&gt; null then						//TFS47394
	if machine &lt;&gt; null then	//12 Jan 2021 NDL TFS 50616
		create allOStowTIs transient;																//TFS47394
		obj.getAllOverstowedTIs(allOStowTIs,false,accessDirection,machine);	//12 Jan 2021 NDL TFS 50616	
		self.overstowedTICount:=allOStowTIs.size;													//TFS47394
	endif;																							//TFS47394
	
	self.stevedoreCodeRecieve := obj.stevedoreCodeRecieve;  //04.11.2020 cnwma1 TFS #50112
	self.stevedoreCodeRelease := obj.stevedoreCodeRelease;  //04.11.2020 cnwma1 TFS #50112
	
	// TFS 51409 start
	self.dwellDays := obj.getDwellDays();
	queuedMove 	   := obj.allQueuedFutureMoves.first.CM_FutureMoveQueued;
	if queuedMove &lt;&gt; null and queuedMove.myWorkListEntry &lt;&gt; null then
		self.queue 		 := queuedMove.myWorkListEntry.queueId;
		self.finalTarget := queuedMove.myWorkListEntry.getFinalTaskTargetLocId;
		
		if self.finalTarget.startsWith(CM_RTQueueTask.TASK_TARGET_MAFI) then
			self.locnQueued := self.finalTarget;	// TFS 60985
		endif;
	endif;
	// TFS 51409 end
	//tfs 52160 jlier1 5/11/21
	rtVehicleConfig:=app.myPassport.myTerminal.myRTVehicleConfig;
	if rtVehicleConfig &lt;&gt; null then
		self.modifiedSource		:= rtVehicleConfig.getCargoLocationHookString(obj);
		self.modifiedISO		:= rtVehicleConfig.getIsoTypeHookString(obj);
		self.modifiedDoorDir	:= rtVehicleConfig.getCargoDoorDirHookString(obj);
	endif;
	
	self.isDischargeToMachine := obj.isDischargeToMachine;   //jlier1 TFS 55828 31/1/22
	self.cargoGroupId 		  := obj.getMyCargoGroupId();	// 01.03.2023 navak20 TFS 56421
	self.itemised			  := obj.itemised;
	
	sortingMethod 			  := obj.mySortingMethod;		//16.11.2023 navma1 #58350
	if sortingMethod &lt;&gt; null then							//16.11.2023 navma1 #58350
		self.sortingMethodCode := sortingMethod.code;
		self.sortingMethodDesc := sortingMethod.description;
	endif;
epilog
	delete allOStowTIs;		//TFS47394
end;</source>
        <Parameter name="obj" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setReeferDetails" id="3fe58b56-8bdc-48a9-b001-b59bb8557201">
        <updating/>
        <source>setReeferDetails(_ti : CM_TrackedItem)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Oct 2019 cnwma1	Bug 46793: Web Portal - Prenotes for non container cargo that has a commodity that requires temperature does not show reefer section

*/

vars
	tmpInt   		: Integer;
begin
	self.isReefer 				 := _ti.isReefer.String;
	self.humidity 		         := _ti.getHumidity.asNullHumidity();	//02 Apr 2020	NDL	TFS 47958
	self.ventilation             := _ti.getVentilation.asNullDecimal();
	self.isControlledAtmosphere  := _ti.isControlledAtmosphere.String;
	self.curtainsIn				 := _ti.getCurtainsIn.String;
	self.carbonDioxide 		     := _ti.getCarbonDioxide.asNullCarbonDioxide();
	self.oxygen 				 := _ti.getOxygen.asNullOxygen();
	self.carriageTempC 		  	 := _ti.getDisplayTemperature(false, true);
	self.carriageTempF 		   	 := _ti.getDisplayTemperature(false, false);	
	self.allowableTimeOffPower 	 := _ti.getAllowableTimeOffPower.asNullDecimal();
	self.expiryDate 		     := _ti.getExpiryDate.asStringForWebInterface();		
	self.packTempC 				 := _ti.getDisplayPackTemperature(true); 
	self.packTempF 				 := _ti.getDisplayPackTemperature(false);    
	self.packDate  				 := _ti.packDate.asStringForWebInterface();
	self.wasOnPowerDuringTransit := _ti.getOnPowerDuringTransit;
	self.transitOnPowerRemarks   := _ti.getTransitOnPowerRemarks;
	self.connectedDate 			 := _ti.getLastConnectDT().asStringForWebInterface();
	self.disconnectedDate		 := _ti.getLastDisconnectDT().asStringForWebInterface();
	self.isConnected 			 := _ti.isConnected;
	
	if _ti.getTransitOnPowerDate &lt;&gt; null then
		self.transitOnPowerDate := _ti.getTransitOnPowerDate.asStringForWebInterface;
	endif;
	if _ti.getTransitOnPowerTime &lt;&gt; null then
		self.transitOnPowerTime := _ti.getTransitOnPowerTime.asStringForWebInterface;
	endif;
	
	tmpInt := _ti.getCoolingType;
	create self.coolingType transient;
	self.coolingType.initFields(tmpInt);
		
	tmpInt := _ti.getVoltageType;
	create self.voltageType transient;
	self.voltageType.initFields(tmpInt);
		
	if _ti.getPreTripDT.isValid then
		self.preTripDT := _ti.getPreTripDT.shortCurrentLocaleFormat();
	endif;
		
	if _ti.packTime &lt;&gt; NULL_TIME then
		self.packTime := _ti.packTime.asStringForWebInterface();
	endif;
	
	self.temperature := _ti.getTemperature();
	if self.temperature = NULL_TEMPERATURE then
		self.temperature := null;
	endif;
	
	if _ti.getLastHumidityReading() &lt;&gt; null then
		self.lastHumidityReading := _ti.getLastHumidityReading().getHumidity; //02 Apr 2020	NDL	TFS 47958
	else
		self.lastHumidityReading := NULL_HUMIDITY; //02 Apr 2020	NDL	TFS 47958
	endif;
	
	if _ti.getLastVentilationReading() &lt;&gt; null then
		self.lastVentilationReading := _ti.getLastVentilationReading().ventilation;
	else
		self.lastVentilationReading := NULL_VENTILATION;
	endif;
	
	if _ti.getLastTempReading() &lt;&gt; null then
		self.lastTemperatureReading := _ti.getLastTempReading().getTemperatureValue();
	else
		self.lastTemperatureReading := NULL_TEMPERATURE;
	endif;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
</Class>
