    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="restwebservice"/>
    <ImplicitInverseRef name="allResourceGroups" id="9c7163b1-8ef8-4039-b0bf-64c189776d32">
        <memberTypeInverse/>
        <type name="WS_RestIntResourceTypeGroupArr"/>
    </ImplicitInverseRef>
