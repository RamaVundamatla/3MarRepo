    <JadeMethod name="camsCMEditOperator" id="d171c192-c083-44a1-b36c-12beeedc52f6">
        <source>camsCMEditOperator();

constants
	CAMProtocol : String = "MSK Codeco";
	Terminal : String = 'T01';
vars
	camProtocol : CM_CamProtocol;
	terminal : CM_Terminal;
	edit : CM_EditOperator;
	camAgent : CM_CamControllerAgent;
begin
	app.initialize;
	create camAgent transient;
	terminal := app.myRoot.allTerminals[Terminal];
	if terminal = null then
		app.writeStatement('Can not find required terminal ' &amp; Terminal);
		return;
	endif;
	app.myPassport.setMyTerminal(terminal);
	camProtocol := terminal.camProtocols[CAMProtocol];
	if camProtocol = null then
		app.writeStatement("Cannot find required cam protocol description");
		return;
	endif;
	foreach edit in CM_EditOperator.instances do
		camProtocol.protocolDesc.CM_CamCODECODesc.checkEditTransactionForOper(edit, camProtocol, camAgent, null);
	endforeach;
epilog
	delete camAgent;
end;
</source>
    </JadeMethod>
    <JadeMethod name="camsCompare" id="2021216b-cd0c-4bd0-b8b4-55ddbfaad125">
        <source>camsCompare();

constants
	DIR1 : String = 'D:\POETest\JMTData\Cams\';
	DIR2 : String = 'D:\POETest821\JMTData\Cams\';
	ErrorLines = 10;
vars
	fileIn1, fileIn2 : File;
	fileOutput : File;
	fileLog : File;
	fileFolder : FileFolder;
	line1, line2 : String;
	fileNode : FileNode;
	folderList : StringArray512;
	folderName : String;
	fileName : String;
	count : Integer;
	errorCount : Integer;
	numFilesInError : Integer;
	available : Boolean;
	file1EOF : Boolean;
	file2EOF : Boolean;
	msg : String;
begin
	app.initialize;
	create folderList transient;
	create fileFolder transient;
	create fileIn1 transient;
	create fileIn2 transient;
	create fileOutput transient;
	create fileLog transient;
	
	fileIn1.kind := File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version
	fileIn2.kind := File.Kind_Unknown_Text; // 26/2/16  cnwns1 PAR 36286 unicode version
	
	fileOutput.fileName := "D:\POETest\JMTData\filecompare2.log";
	fileOutput.mode := File.Mode_Output;
	fileLog.fileName := "D:\POETest\JMTData\fileLog2.log";
	fileLog.mode := File.Mode_Output;
	fileFolder.fileName := DIR1;
	foreach fileNode in fileFolder.files do
		if fileNode.isKindOf(FileFolder) and
		   fileNode.name &lt;&gt; "logs" then
			folderList.add(fileNode.fileName);
			msg := 'Will Process Folder '&amp;fileNode.fileName&amp;'--'&amp;fileNode.name;
			write msg;
			fileLog.writeLine(msg);
		else
			msg := 'Ignore Logs directory -'&amp;fileNode.fileName&amp;'--'&amp;fileNode.name;
			write msg;
			fileLog.writeLine(msg);
		endif;
	endforeach;
//return;
	foreach folderName in folderList do
		msg := ' Process Folder '&amp;folderName;
		write msg;
		fileLog.writeLine(msg);
		fileFolder.fileName := folderName;
		foreach fileNode in fileFolder.files do
			if fileNode.isKindOf(File) then
				fileName := fileNode.fileName;
			else
				continue;
			endif;
			available := false;
			fileIn1.fileName := fileName;
			fileIn1.mode := File.Mode_Input;
			msg := 'Compare '&amp;fileName;
			fileName := fileName.replaceString(DIR1, DIR2);
			fileIn2.fileName := fileName;
			fileIn2.mode := File.Mode_Input;
			msg := msg&amp;' to '&amp;fileName;
			write msg;
			fileLog.writeLine(msg);
			if fileIn1.isAvailable then
				file1EOF := false;
			else
				file1EOF := true;
			endif;
			if fileIn2.isAvailable then
				file2EOF := false;
			else
				file2EOF := true;
			endif;
			if fileIn1.isAvailable and
			   fileIn2.isAvailable then
				available := true;
			endif;
			count := 0;
			errorCount := 0;
			while available do
				if not file1EOF then
					line1 := fileIn1.readLine;
				endif;
				if not file2EOF then
					line2 := fileIn2.readLine;
				endif;
				if fileIn1.endOfFile then
					file1EOF := true;
				endif;
				if fileIn2.endOfFile then
					file2EOF := true;
				endif;
				if file1EOF and
				   file2EOF then
					break;
				endif;
				count := count + 1;
//				if (line1[1:3] = "UNB" and line2[1:3] = "UNB") then
//				   (line1[1:3] = "UNH" and line2[1:3] = "UNH") or
//				   (line1[1:3] = "BGM" and line2[1:3] = "BGM") or
//				   (line1[1:3] = "UNT" and line2[1:3] = "UNT") then
//				else
					if file1EOF then
						numFilesInError := numFilesInError + 1;
						fileOutput.writeLine(class.name&amp;'::'&amp;method.name&amp;' '&amp;fileIn1.fileName&amp;'-'&amp;' '&amp;'-'&amp;line2&amp;'-');
						errorCount := errorCount + 1;
						if errorCount &gt; ErrorLines then
							fileOutput.writeLine(class.name&amp;'::'&amp;method.name&amp;' - more than '&amp;ErrorLines.String&amp;' errors for that file');
							fileOutput.writeLine(' ');
//							errorCount := 0;
							break; 
						endif;
					elseif file2EOF then
						numFilesInError := numFilesInError + 1;
						fileOutput.writeLine(class.name&amp;'::'&amp;method.name&amp;' '&amp;fileIn1.fileName&amp;'-'&amp;line1&amp;'-'&amp;' '&amp;'-');
						errorCount := errorCount + 1;
						if errorCount &gt; ErrorLines then
							fileOutput.writeLine(class.name&amp;'::'&amp;method.name&amp;' - more than '&amp;ErrorLines.String&amp;' errors for that file');
							fileOutput.writeLine(' ');
//							errorCount := 0;
							break; 
						endif;
					else
						if line1 &lt;&gt; line2 then
						numFilesInError := numFilesInError + 1;
							fileOutput.writeLine(class.name&amp;'::'&amp;method.name&amp;' '&amp;fileIn1.fileName&amp;'-'&amp;line1&amp;'-'&amp;line2&amp;'-');
							errorCount := errorCount + 1;
							if errorCount &gt; ErrorLines then
								fileOutput.writeLine(class.name&amp;'::'&amp;method.name&amp;' - more than '&amp;ErrorLines.String&amp;' errors for that file');
								fileOutput.writeLine(' ');
//								errorCount := 0;
								break; 
							endif;
						endif;
					endif;
//				endif;
			endwhile;
			fileIn1.close;
			fileIn2.close;
		endforeach;
	endforeach;
epilog
	msg := class.name&amp;'::'&amp;method.name&amp;' Files In Error='&amp;numFilesInError.String;
	write msg;
	fileLog.writeLine(msg);
	fileLog.close();
	delete fileLog;
	delete folderList;
	delete fileFolder;
	fileIn1.close;
	delete fileIn1;
	fileIn2.close;
	delete fileIn2;
	fileOutput.close;
	delete fileOutput;
end;
</source>
    </JadeMethod>
    <JadeMethod name="camsProtocolCleanupInvalid" id="3ed70439-454b-4d7a-bdb7-d75f939151cc">
        <source>camsProtocolCleanupInvalid();

vars
	camProtocol : CM_CamProtocol;
begin
	app.initialize;
	foreach camProtocol in CM_CamProtocol.instances do
		if camProtocol.protocolDesc = null then
			beginTransaction;
			delete camProtocol;
			commitTransaction;
		endif;
	endforeach;
end;
</source>
    </JadeMethod>
    <JadeMethod name="camsProtocolFixup" id="0406b105-934b-4019-acd2-822b4a4353f5">
        <source>camsProtocolFixup();
//
//21 Nov 2012	cnwrs1	Par 30728	fail with message and alert if directory make fails
//
constants
	Terminal1 : String = 'T01';
	EmailName : String = "Bitbucket";
	SchTime	: Time = '01:00:00:000'.Time;
vars
	emailName : String;
	camProtocol : CM_CamProtocol;
	email : CM_EmailEntity;
	time : Time;
	classColl : ClassColl;
	cls : Class;
	tmpTransType	: CM_TransactionType;
	tmpTransTypeNum : Integer;
	availTransTypeArray : StringArray;
	terminal : CM_Terminal;
	transName : String;
	count : Integer;
begin
	create classColl transient;
  	create availTransTypeArray transient;
	app.initialize;
	terminal := app.myRoot.allTerminals[Terminal1];
	if terminal = null then
		app.writeStatement('Can not find required terminal ' &amp; Terminal1);
		return;
	endif;
	app.myPassport.setMyTerminal(terminal);
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);
	email := app.myRoot.allEmailEntities[Email_Address, emailName];
	foreach camProtocol in terminal.camProtocols do
		if camProtocol.myFTPEntity &lt;&gt; null then
			beginTransaction;
			camProtocol.setPropertyValue(CM_CamProtocol::myFTPEntity.name, null);
			commitTransaction;
		endif;
		if camProtocol.myEmailEntity = null then
			beginTransaction;
			camProtocol.setPropertyValue(CM_CamProtocol::myEmailEntity.name, email);
			commitTransaction;
		endif;
/*		if camProtocol.scheduleTimes.size &gt; 1 then
			beginTransaction;
			count := 0;
			foreach time in camProtocol.scheduleTimes do
				count := count + 1;
				if count &gt; 1 then
					beginTransaction;
					camProtocol.scheduleTimes.remove(time);
					commitTransaction;
				endif;
			endforeach;
		endif;*/
		if camProtocol.scheduleTimes.size = 0 then
			beginTransaction;
			camProtocol.scheduleTimes.add(time);
			commitTransaction;
		endif;
		if camProtocol.destinationFilePath &lt;&gt; null then
			beginTransaction;
			camProtocol.setPropertyValue(CM_CamProtocol::destinationFilePath.name, "\\cnwrs1c\transfer");
			camProtocol.setPropertyValue(CM_CamProtocol::isFileTransferEnabled.name, true);
			commitTransaction;
		endif;
		beginTransaction;
		camProtocol.scheduleTimes.purge();
		camProtocol.scheduleTimes.add(SchTime);
		camProtocol.setPropertyValue(CM_CamProtocol::firstRunDateTime.name, "01/01/2015".asDate.TimeStamp);
		camProtocol.lastRunDateTime := "01/10/2012".asDate.TimeStamp;
		camProtocol.taskHistoryByProtocolSeq.purge;
		camProtocol.setStatus(CAM_IDLESTATUS);	// CAM_HOLDSTATUS
		camProtocol.setPropertyValue(CM_CamProtocol::fileSuffix.name, "txt");
		commitTransaction;
		if camProtocol.registeredTransactions.size = 0 then
/*			classColl.clear();
			availTransTypeArray.clear();
			if camProtocol.protocolDesc.type = EDIFileTypeCams_UserDef then		// ccms 1070 - par 22306 begin
				app.myRoot.allTransactionTypes.copy(availTransTypeArray);		
				if availTransTypeArray.size &gt; 0 then
//					availTransTypeArray.add(tmpTransType);
				endif;
			else
				camProtocol.protocolDesc.availableTransactions(classColl);
				beginTransaction;
				foreach cls in classColl do
//					tmpTransTypeNum := global.getTiTxnTypeForClass(cls);
					//Find the transaction type first to make sure we have something
//					tmpTransType := app.myRoot.allTransactionTypes[tmpTransTypeNum];
//					if tmpTransType &lt;&gt; null then
						if (not availTransTypeArray.includes(cls.name)) then
							availTransTypeArray.add(tmpTransType);
						endif;
					endif;
				endforeach;
				transName := global.getTiTxnTypeForClass(availTransTypeColl[1]).asStringJMT(); // ccms 1070 - par 22306
				camProtocol.registeredTransactions.add(availTransTypeColl[1]);
				commitTransaction;
			endif;*/
		endif;
	endforeach;
epilog
	delete classColl;
	delete availTransTypeArray;
end;

</source>
    </JadeMethod>
    <JadeMethod name="camsRequestRestart" id="bd958985-8665-432b-8678-4f41218f9c44">
        <source>camsRequestRestart();
//
//25 May 2012	cnwrs1		Par 26914 - make cams restart after lock error
//
//28 Jun 2013	cnwrs1	Par31047 - Cams Exception Handler
constants
	Terminal1 : String = 'T01';
	CamProtocol : String = "MSL Coarri";
	SeqNum : Integer = 144;
vars
	terminal : CM_Terminal;
	bgpRequest : BGP_CamsRequest;
	camProtocol : CM_CamProtocol;
	seqNumber : Integer;
begin
	app.initialize;
	terminal := app.myRoot.allTerminals[Terminal1];
	if terminal = null then
		app.writeStatement('Can not find required terminal ' &amp; Terminal1);
		return;
	endif;
	camProtocol := terminal.camProtocols[CamProtocol];
	seqNumber := SeqNum;
	app.myPassport.setMyTerminal(terminal);
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);
	app.changeLogLevel(LogDEBUG);	//22 Nov 2019	NDL	TFS 47053
	create bgpRequest transient;
	bgpRequest.setPropertyValue(BGP_CamsRequest::myTerminal.name, terminal);
	bgpRequest.setPropertyValue(BGP_CamsRequest::myUser.name, app.myPassport.myUser);
	bgpRequest.setPropertyValue(BGP_CamsRequest::myAdhocCamProtocol.name, camProtocol);
	bgpRequest.setPropertyValue(BGP_CamsRequest::sequenceNumber.name, seqNumber);
	bgpRequest.setPropertyValue(BGP_CamsRequest::isRestart.name, true);
	bgpRequest.action();
epilog
	delete bgpRequest;
end;
</source>
    </JadeMethod>
    <JadeMethod name="camsRequestRun" id="f6d60d5b-4f91-4bc5-bd28-9b1c82029376">
