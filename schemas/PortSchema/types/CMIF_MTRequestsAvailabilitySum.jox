    <JadeMethod name="avaGradeCode" id="c34a94d5-be4d-417d-9c3a-44255fc83478">
        <methodInvocation>mapping</methodInvocation>
        <source>avaGradeCode(set: Boolean; _value: String io) mapping;
//----------------------------------------------------------------
//	Created:	14 December 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	mtGrade		: CM_MTGrade;
	mtGradeCode	: CM_MTGradeCode;
	operator	: CM_Operator;
	opGroup		: CM_OperatorGroup;
	canDisplay	: Boolean;
begin
	if set then
		return;
	else
		operator := self.getOperator();
		if operator &lt;&gt; null then
			opGroup := operator.getOperatorGroupIfOnlyOne();
		endif;
				
		mtGrade := app.myRoot.allAvailabilityGrades[self.avaGradeId];
		if mtGrade &lt;&gt; null then
			mtGradeCode := null;
			mtGrade.getTranslationForOperator(mtGrade,operator, opGroup, mtGradeCode, canDisplay);
			if mtGradeCode &lt;&gt; null then
				_value := mtGradeCode.code;
			elseif canDisplay then
				_value := self.avaGradeId.String;
			else
				_value := null;
			endif;
		else
			_value := self.avaGradeId.String;
		endif;
	endif;



epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="avaGradeDesc" id="4abbff93-ca70-4889-a0ad-077055bdd51d">
        <methodInvocation>mapping</methodInvocation>
        <source>avaGradeDesc(set: Boolean; _value: String io) mapping;
//----------------------------------------------------------------
//	Created:	09 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	mtGrade		: CM_MTGrade;
	mtGradeCode	: CM_MTGradeCode;
	operator	: CM_Operator;
	opGroup		: CM_OperatorGroup;
	canDisplay	: Boolean;
begin
	if set then
		return;
	else
		operator := self.getOperator();
		if operator &lt;&gt; null then
			opGroup := operator.getOperatorGroupIfOnlyOne();
		endif;
		
		mtGrade := app.myRoot.allAvailabilityGrades[self.avaGradeId];
		if mtGrade &lt;&gt; null then
			mtGradeCode := null;
			mtGrade.getTranslationForOperator(mtGrade, operator, opGroup, mtGradeCode, canDisplay);
			if mtGradeCode &lt;&gt; null then
				_value := mtGradeCode.description;
			elseif canDisplay then
				_value := mtGrade.description;
			else
				_value := null;
			endif;
		else
			_value := "Grade " &amp; self.avaGradeId.String;
		endif;
	endif;



end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="availableDisplay" id="bfb55882-b61b-4a21-bbd2-69175eb4ae07">
        <source>availableDisplay():String;
//----------------------------------------------------------------
//	Created:	10 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	if self.totalAvailable &lt;&gt; 0 then
		return self.totalAvailable.String;
	endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="balanceTotal" id="3b261636-03f1-4e2f-bf12-527bef807299">
        <methodInvocation>mapping</methodInvocation>
        <source>balanceTotal(set: Boolean; _value: Integer io) mapping;
//----------------------------------------------------------------
//	Created:	08 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if set then
		return;
	else
		_value := self.totalAvailable -	(	self.totalTransportRequests
										+ self.totalShippingRequests
										+ self.totalGeneralCargoRequests
										+ self.totalPendingRequests);
	endif;



end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
