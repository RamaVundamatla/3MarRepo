// ---------------------------------------------------------------------------
// Created:     21 May 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	exclusiveLock(self.myTestDataMove);
	beginTransaction;
	_ti := self.myTestDataMove.getNextTiOnly();
	commitTransaction;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getNextVehicle" id="f2681f4a-b6ee-4b20-92f9-984513ea34ac">
        <updating/>
        <source>getNextVehicle(_terminal : CM_Terminal) : CM_TestDataVehicle updating;

vars
	tmpVehicle	: CM_TestDataVehicle;
	
begin
	
	if self.allVehicles.isEmpty then
		beginTransaction;
		self.createVehicles(_terminal);
		commitTransaction;
	endif;

	beginTransaction;
	exclusiveLock(self.allVehicles);
	tmpVehicle := self.allVehicles.first.CM_TestDataVehicle;
	exclusiveLock(tmpVehicle);
	self.allVehicles.removeAt(1);
	self.allVehicles.add(tmpVehicle);
	commitTransaction;

	return tmpVehicle;

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_TestDataVehicle"/>
    </JadeMethod>
    <JadeMethod name="getNextVesselForVTMIS" id="29f0fa69-21cb-47b4-9b27-5a55c734bd92">
        <updating/>
        <source>getNextVesselForVTMIS() : CM_TestDataVesselForVTMIS updating;

vars
	tmpVessel	: CM_TestDataVesselForVTMIS;
	
begin
	
	if self.allVesselsForVTMIS.isEmpty then
		beginTransaction;
		self.createVesselsForVTMIS(20);
		commitTransaction;
	endif;

	beginTransaction;
	exclusiveLock(self.allVesselsForVTMIS);
	tmpVessel := self.allVesselsForVTMIS.first.CM_TestDataVesselForVTMIS;
	exclusiveLock(tmpVessel);
	self.allVesselsForVTMIS.removeAt(1);
	self.allVesselsForVTMIS.add(tmpVessel);
	commitTransaction;

	return tmpVessel;

end;</source>
        <ReturnType type="CM_TestDataVesselForVTMIS"/>
    </JadeMethod>
