<GUIClass name="GTE_EditReleaseReqBlockEDIForm" id="c7c9442f-c883-41d5-a37c-fb074161e357">
    <superclass name="CMUI_Modal"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>cnwcs5 23/04/2012 - CCMS POL 2172 / par 29480 coparn release updates
</text>
    <ImplicitInverseRef name="allReleaseRequests" id="8d261921-ad75-4451-bf3c-8f7c888c587e">
        <memberTypeInverse/>
        <type name="CM_BulkReleaseSet"/>
        <access>protected</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="optAllowEDI" id="e0d576b7-498b-447a-bfea-d0be86eb4652">
        <embedded/>
        <type name="CMUI_OptionButton"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="optBlockEDI" id="dd6bfbf5-2de3-48dc-b392-9fde2f0cbfa6">
        <embedded/>
        <type name="CMUI_OptionButton"/>
    </ImplicitInverseRef>
    <JadeMethod name="doOK" id="4b0729a5-297e-45f4-ac06-e466d0778e0e">
        <updating/>
        <source>doOK() updating;
/*
Date		Who		Reason
23 April 2012	cnwcs5	Initial creation - CCMS POL 2172 / par 29480 coparn release updates
*/
vars
	value 		: Boolean;
	result		: Integer;
begin	
	if self.optBlockEDI.value then
		value := true;
	endif;
	
	while true do : transaction_loop
		app.myTrxUA.trxUpdateReleaseReqBlockEDI( value, self.allReleaseRequests, app.myPassport );
		
		if app.myPassport.trxCompletedOK() then
			// Clear errors/warnings from form and err/warnings window.
			self.clearErrorWarnings();
			break transaction_loop;
		else
			result	:=	app.showErrorWarningDialog(	self.caption, app.myPassport,
													ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings );
			
			if app.myPassport.noErrors() and result = IDOK then
				// There must have just been warnings that the user has acknowledged so...
				app.myPassport.warningsAcknowledged	:=	true;
				continue transaction_loop;
			endif;
			
			self.setAllErrorWarnings( app.myPassport );	// Copies errors to this form and shows in err/warnings window.
		endif;
		break transaction_loop;
	endwhile transaction_loop;
	
	if result = IDOK then				// otherwise unloads the form!
		inheritMethod();
	endif;
	
epilog
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="setAllReleaseRequests" id="08aea2ec-96f2-43cb-920a-0682696fc241">
        <updating/>
        <source>setAllReleaseRequests(_value : CM_BulkReleaseSet ) updating;
/*
Date		Who		Reason
23 April 2012	cnwcs5	Initial creation - CCMS POL 2172 / par 29480 coparn release updates
*/
vars
	coll	:CM_BulkReleaseSet;
begin
	coll	:= self.allReleaseRequests;
	
	coll.clear;
	_value.copy( coll );
epilog

end;</source>
        <Parameter name="_value" type="CM_BulkReleaseSet"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="1754d281-9cb8-4ef3-96ec-c68867378ff8">
        <updating/>
        <source>setupForm() updating;
/*
Date		Who		Reason
23 April 2012	cnwcs5	Initial creation - CCMS POL 2172 / par 29480 coparn release updates
*/
vars
	terminal	:CM_Terminal;
begin
	if self.allReleaseRequests.isEmpty() then
		// Please select a Release request for this operation
		app.msgBox(	app.getString( NothingSelected, app.getString( Release_request ) ),
					app.getString( Nothing_Selected ),
					MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon + MsgBox_Default_First );
		self.unloadForm();
		return;
	endif;

	inheritMethod();
	
	// load the combo with the valid types
	terminal := self.myTerminal;
	
	self.optBlockEDI.setFocus();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="0a110fac-27dd-4110-b967-ff193988de76">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018145, locale);
	optAllowEDI.translateCaption(Xlat_0018146, locale);
	optBlockEDI.translateCaption(Xlat_0018147, locale);
end;</source>
    </JadeMethod>
</GUIClass>
