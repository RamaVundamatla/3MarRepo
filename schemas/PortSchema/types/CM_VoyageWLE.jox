    <JadeMethod name="getNextBulkReleaseLocation" id="e89a559d-dc9d-433d-9013-a7d0eba8dea8">
        <source>getNextBulkReleaseLocation() : CM_LocationsController;
/*
Purpose: Find the next location in the job that is empty			

Parameters:			

Return Value:		

Date		Who		Reason
22 June 2012	cnwdw1	Initial creation
*/
vars
	reqs: CM_SlotRequestArray;
	req: CM_Request;
	location: String;
	lc: CM_LocationsController;
	job: CM_VoyageJob;
begin

	if self.isBulkRelease then
		job := self.job.CM_VoyageJob;
		if job.isKindOf(CM_VoyageDeckJob) then  //cnwrd1 par 31096 roro releases.
			return self.myRequest.CM_RORORequest.myROROControllerLoad;
		else		
			create reqs transient;
			job.doSortReqsInToSeqOrder(reqs);
			foreach req in reqs do
				if req.CM_SlotRequest.mySlotController.allTrackedItems.size = 0 then
					break;
				endif;
			endforeach;
			if req &lt;&gt; null then
				return req.CM_SlotRequest.mySlotController;
				location := lc.getStowageId(null);
			endif;
		endif;
	endif;
	
	return null;

epilog
	delete reqs;
	
end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getOperator" id="049d3502-d61a-4fb9-bbc8-4f512ece1ab6">
        <source>getOperator() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 June 2010	cnwmh5	Initial creation #20661

*/

vars
	operator : String;
begin

	if self.myTrackedItem &lt;&gt; null then
		operator := self.myTrackedItem.operatorCode;
	else
		if self.isBulkRelease() then
			operator := self.myRequest.getBulkReleaseReserveDetail.getOperatorCode();
		endif;
	endif;
	
	return operator;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOperatorGroup" id="01957fcc-da9c-457d-9bce-df7e4978966d">
        <source>getOperatorGroup() : CM_OperatorGroup;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 March 2012	cnwndl1	Initial creation	Par 29248

*/

vars
	
	operatorGroup : CM_OperatorGroup;
	reserveDetail : CM_ReserveDetail;
	
begin

	if self.myTrackedItem &lt;&gt; null and self.myTrackedItem.myOperator &lt;&gt; null then
		return null;
		
	else
		if self.myRequest &lt;&gt; null then
			operatorGroup := self.myRequest.getMyOperatorGroup();
			if operatorGroup = null then
				if self.myRequest.myOriginatingBulkRelease &lt;&gt; null then
					operatorGroup := self.myRequest.myOriginatingBulkRelease.myOperatorGroup;
				endif;
			endif;
		endif;
	endif;
	
	return operatorGroup;

epilog

end;</source>
        <ReturnType type="CM_OperatorGroup"/>
    </JadeMethod>
    <JadeMethod name="getPlannedLocation" id="69a4c13c-dccd-4d3b-815a-6ec12441b911">
        <source>getPlannedLocation() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 June 2010	cnwmh5	Initial creation

*/

vars
	plannedLocation : String;
	trackedItem		: CM_Container;
	isoType			: CM_ISOType;
	isoGroup 		: CM_ISOTypeGroup;
	voyageController : CM_VoyageController;
	slotController	: CM_SlotController;
	is40			: Boolean;
	allocation 	: CM_VoyageAllocation;
begin

	if self.myTrackedItem &lt;&gt; null then
		plannedLocation := self.locationTarget;
	else
		if self.isBulkRelease() then
		
			if self.myRequest.isKindOf(CM_SlotRequest) then
				
				isoType := self.myRequest.getBulkReleaseReserveDetail.getISOType();
				if isoType = null then
					isoGroup := self.myRequest.getBulkReleaseReserveDetail.getISOGroup();
					if isoGroup &lt;&gt; null then
						isoType := isoGroup.allISOTypes.first;
					endif;
				endif;
				
				slotController := self.myRequest.CM_SlotRequest.mySlotController.CM_SlotController;
				//voyageController := self.myRequest.getVoyageController().CM_VoyageController;
			
				if isoType &lt;&gt; null and not isoType.is20ftLong then
					is40 := slotController.myBayVoyage.canHandle4045();
				endif;
				
				if slotController.mySlotDefnVoyage &lt;&gt; null then
					plannedLocation := slotController.mySlotDefnVoyage.getStowageId(is40, slotController.myVoyage.myCellularVoyageStructure.useBayCellTierNumbering);
				endif;			
			elseif self.myRequest.isKindOf(CM_RORORequest) then
				plannedLocation := self.myRequest.CM_RORORequest.myROROController.getStowageId(null);
			endif;
		else //cnwrd1 ccms 1303

			if self.myRequest.myOriginatingBulkRelease = null and self.myTrackedItem = null then
				allocation := self.myRequest.getFirstAllocation();
			endif;
			voyageController := self.myRequest.getVoyageController().CM_VoyageController;
			
			is40 := allocation.getIs40();
			
			//if slotController.mySlotDefnVoyage &lt;&gt; null then
				plannedLocation := voyageController.getStowageId(self.myTrackedItem);
			//endif;	
		endif;
		
	endif;

	return plannedLocation;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getQuantity" id="60df38ae-5106-4b42-924e-b7c304cf07c1">
        <source>getQuantity(): Integer;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/11/2021	navdap1		Initial creation TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
// 05 Dec 2023  navhl20 	ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
// 03 Oct 2024  navah1		Bug 19944: MTN - Work order operation screen doesn't display Work list entry quantity correctly for Cargo with Duplicate Ids
vars
	ti 		: CM_TrackedItem;
	wleJob	: CM_Job;
begin
	
	ti 		:= self.myTrackedItem;
	wleJob	:= self.job;
	
	if wleJob &lt;&gt; null and wleJob.isVoyageHoldJob then
		if ti &lt;&gt; null and ti.isBulkByQuantity then
			if self.subSeqNum &lt;&gt; null and self.subSeqNum &lt; self.quantity then
				return self.subSeqNum;
			endif;
		endif;
		if ti &lt;&gt; null and ti.isBreakBulkGeneric then  								//04.10.2024 navah1 #19944
			if self.quantity = 0 or self.status= WLE_COMPLETED then  
				return ti.totalQuantity;
			endif;
		endif; 
	elseif wleJob &lt;&gt; null and wleJob.isVoyageWorkpointJob then						  //05.12.2023 navhl20 #58400[61617]
		return self.quantity;
	endif;
	
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getRTLetter" id="6273fb0b-b59b-43ad-804a-43bd149c4174">
        <source>getRTLetter(): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
20 July 2010	cnwer1	Initial creation Par 25061
22 May 2019		jlgzm1	TFS 42840 MSL Direct Release between Voyages and Rail

*/

vars
	rtLetter : String;
	location 	 : CM_LocationsController;
	linkedWLE : CM_WorkListEntry;
	linkedReq : CM_Request;
begin
	rtLetter:= inheritMethod();
	
	// tfs42840 start
	if self.isDRLinkedByFM then
		if self.myFutureMove &lt;&gt; null and
		   self.myFutureMove.moveType = TI_FutureMoveQueued then
			rtLetter := "Q DR";
		elseif self.myFutureMoveDR &lt;&gt; null and
		   self.myFutureMoveDR.moveType = TI_FutureMoveQueued then
			rtLetter := "Q DR";
		else
			rtLetter := "DR";
		endif;
	endif;
	// tfs42840 end
	
	// PAR 31652 we display the discharge WLE for a SOB by we create the FM on the load because it is the target
	if rtLetter = "" then
		if self.isSOB() then
			linkedReq := self.myRequest.myRequestLinkedLoad;
			if linkedReq &lt;&gt; null then
				linkedWLE := linkedReq.allWorkListEntries.first;
				if linkedWLE &lt;&gt; null then
					if linkedWLE.myFutureMove &lt;&gt; null then
						if linkedWLE.myFutureMove.moveType = TI_FutureMoveSOB then
							rtLetter := "P";
						endif;
					endif;
					
				endif;
			endif;
		endif;
	endif;
	
	if rtLetter = "P" then
		if self.isForLoadJob then
			if self.myTrackedItem &lt;&gt; null then
				location:=self.myTrackedItem.getPrimaryLocation(REAL_MODE);
				if location &lt;&gt; null and location.isKindOf(CM_YardController) then
					if location.CM_YardController.myTerminalArea.isKindOf(CM_CraneTransferArea) then
						rtLetter:="CT";
					endif;
				endif;
			endif;
		endif;
	endif;

	
	return rtLetter;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getRowColour" id="1c497d33-44df-4f78-a418-f6b2e7556755">
        <source>getRowColour(_foreColour: Integer output; _backColour: Integer output);
//--------------------------------------------------------------
//Created: 07 May 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	theJob : CM_VoyageJob;
begin

	theJob := self.job.CM_VoyageJob;
	if theJob &lt;&gt; null and theJob.myVoyageJobSheet = null then
		if theJob.isVoyageHoldJob() then // TFS 3190
			inheritMethod(_foreColour, _backColour); // TFS 3190
		
		else
			_foreColour := Black;		
			_backColour := theJob.Colour_JobUnallocated;
		endif;
	elseif self.myTrackedItem &lt;&gt; null  and self.isOverstowedForEntry() then	
	   _foreColour := White;
	   _backColour := Red;	 
	else
		inheritMethod(_foreColour, _backColour);
	endif;

end;</source>
        <Parameter name="_foreColour" type="Integer" usage="output"/>
        <Parameter name="_backColour" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getSeqNum" id="3f1f43a7-4f78-463a-84bc-6633169e19cf">
        <source>getSeqNum(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 December 2008	cnwer1	Initial creation

*/

vars
	voy : CM_Voyage;
begin
	if self.job = null then
		return null;
	endif;
	voy := self.job.CM_VoyageJob.myVoyage;
	if voy = null then
		return null;
	endif;
	if voy.starboardBerthed then
		if self.job.CM_VoyageJob.isTwinLift then
			// With twin lifts the custom is either the same as the 
			// standard twin number or a custom number.
			return self.numSeqStarboardTwinCustom;
		else
			if self.seqNumCustomStarboard = 0 then
				return self.seqNumStarboard;		
			else
				return self.seqNumCustomStarboard;
			endif;
		endif;

	else
	
		if self.job.CM_VoyageJob.isTwinLift then
			// With twin lifts the custom is either the same as the 
			// standard twin number or a custom number.
			return self.numSeqPortTwinCustom;
		else
			if self.seqNumCustomPort = 0 then
				return self.seqNumPort;		
			else
				return self.seqNumCustomPort;
			endif;	
		endif;

	endif;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSeqNumForReport" id="7c6a6c35-2797-4118-aa0d-f62acc2c931a">
        <source>getSeqNumForReport() : String;
// ---------------------------------------------------------------------------
// Created:     04 December 2003	cnwth2
//
// Purpose:     USER IN REPORTS - DON'T DELETE
//			 
// ----------   ----------  --------------------------------------------------
vars
	jrwTrans			: CM_JRWVoyageSummary;
	orderOpt,
	result 				: String;
	isTwinLift			: Boolean;
begin
	jrwTrans := app.myQAFilter.allJRWTransients.first.CM_JRWVoyageSummary;
	
	if jrwTrans = null then
		return null;
	endif;
	
	isTwinLift := self.job.CM_VoyageJob.isTwinLift;
	
	orderOpt := jrwTrans.orderedByOption;
	
	if orderOpt = 'seqNumPort' then
		if isTwinLift then
			result := self.numSeqPortTwin.String;
		else
			result := self.seqNumPort.String;
		endif;
	elseif orderOpt = 'seqNumStarboard' then
		if isTwinLift then
			result := self.numSeqStarboardTwin.String;
		else
			result := self.seqNumStarboard.String;
		endif;
	elseif orderOpt = 'seqNumCustomPort' then
		if isTwinLift then
			result := self.numSeqPortTwinCustom.String;
		else
			result := self.seqNumCustomPort.String;
		endif;
	elseif orderOpt = 'seqNumCustomStarboard' then
		if isTwinLift then
			result := self.numSeqStarboardTwinCustom.String;
		else
			result := self.seqNumCustomStarboard.String;
		endif;
	else// orderOpt = 'seqNumWorkOrder' 
		result := self.subSeqNum.String;
	endif;
	
	if jrwTrans.doPadZeros then
		result := result.String.padLeadingZeros(3);
	endif;
	
	return result;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSeqNumZeroFill" id="03f02a50-dcba-405a-8048-cab0ffdb7062">
        <source>getSeqNumZeroFill(_zeroFill : Boolean; _seqNum : Integer) : String;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theSeqNum : String;
begin
	if _zeroFill then
		theSeqNum := _seqNum.String.padLeadingZeros(3);
	else
		theSeqNum := _seqNum.String;
	endif;

	return theSeqNum;
end;</source>
        <Parameter name="_zeroFill" type="Boolean"/>
        <Parameter name="_seqNum" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSequenceSheetDisplay" id="22a1d423-80a1-4091-a600-4affdbea8d86">
        <source>getSequenceSheetDisplay(sse : CMIF_SeqSheetEntry input);
/*
 ------------------------------------------------------------------------
Created:			16 September 2002 by cnwdwq1
Purpose:			Populates the object with the stuff for this WLE.
							Converted from C++
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	showYardPos : Boolean;
	isCont : Boolean;
	ti : CM_TrackedItem;
begin

	if sse = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'SeqSheet Interface object',null, null);
		return;
	endif;
	ti := self.myTrackedItem;
	sharedLock(self);
	sharedLock (ti);
	if self.job &lt;&gt; null then
		sharedLock(self.job);
	endif;
	//------------
	//Clear method leaves the "wantSeqSheetInfo flag alone"
	//------------
	sse.clear();
	
	isCont := ti.isKindOf(CM_Container);
	
	sse.commodityGroup := ti.commodityGroup;
	sse.consignee := ti.consignee;
	sse.dischargePort := ti.dischargePort;
	if isCont then
		sse.disconnected := not (ti.CM_Container.isConnected);
		sse.doorDirection := self.myRequest.getDoorsDirection;//ti.CM_Container.doorsDirn;
		sse.isoType := ti.CM_Container.isoType;
	endif;
	sse.isHazardous := ti.isHazardous;
	sse.isOverDimension := ti.isOverDimensions;

	if self.job = null then
		return;
	endif;
	//--------------------
	//The showing of the OLD yard positions etc are now switchable, we use the config flag to determine
	//what they wish to see globally.
	//--------------------
	showYardPos := ti.myTerminal.getConfig(ShipShowYardPosition).Boolean;

	if self.job.jobType = JOB_TYPE_DISCHARGE then
		if ti.isRehandle then
			if (ti.site = TI_SITE_ONSHIP) and (ti.releasedDT.isValid = false) then		
				//must be still on the ship unworked
				sse.locationId := ti.locationId;
				sse.plannedLocationId := ti.plannedLocnId;
				
			elseif (ti.site = TI_SITE_ONSITE) and (ti.releasedDT.isValid = false) then		
		   	// discharged but not loaded yet
				if showYardPos then
					sse.locationId := ti.locationId;
				else
					sse.locationId := ti.priorStowage;
				endif;
				sse.plannedLocationId := ti.locationId;
				
			elseif (ti.site = TI_SITE_ONSHIP) and (ti.releasedDT.isValid) then // discharged and loaded
				if showYardPos then
					sse.locationId := ti.locationId;
				else
					sse.locationId := ti.priorStowage;
				endif;
				sse.plannedLocationId := ti.priorLocation;
			endif;
			
		//normal import
		elseif ti.site = TI_SITE_ONSITE then		//if discharged
			if showYardPos then
				sse.locationId := ti.locationId;
			else
				sse.locationId := ti.priorStowage;
			endif;
			sse.plannedLocationId := ti.locationId;
		else
			sse.locationId := ti.locationId;
			sse.plannedLocationId := ti.plannedLocnId;
		endif;

	elseif self.job.jobType = JOB_TYPE_LOAD then
		if ti.isRehandle then
			if ( ti.site = TI_SITE_ONSHIP) and (ti.releasedDT.isValid = false) then	
				//must be still on the ship unworked
				if showYardPos then
					sse.locationId := ti.locationId;
				else
					sse.locationId := ti.plannedLocnId;
				endif;
				sse.plannedLocationId := ti.rehandleLocnId;
				
      	elseif (ti.site = TI_SITE_ONSITE) and (ti.releasedDT.isValid = false) then 	// discharged but not loaded yet
				sse.locationId := ti.locationId;
				sse.plannedLocationId := ti.plannedLocnId;
				
			elseif (ti.site = TI_SITE_ONSHIP) and ti.releasedDT.isValid then 	
				// discharged and loaded 
				if showYardPos then
					sse.locationId := ti.locationId;
				else
					sse.locationId := ti.priorLocation;
				endif;
				sse.plannedLocationId := ti.locationId;
			endif;
		else 
			//normal export load
			if ti.site = TI_STATE_ONSHIP then 
				//  if loaded 
				if sse.wantSeqSheetInfo then		
					//if on a sequence sheet
					if showYardPos then
						sse.locationId := ti.locationId;
					else
						sse.locationId := ti.priorLocation;
					endif;
					sse.plannedLocationId := ti.locationId;
				else
					sse.locationId := ti.locationId;
					sse.plannedLocationId := null;
				endif;
			else 
				//not loaded yet
				sse.locationId := ti.locationId;
				sse.plannedLocationId := ti.plannedLocnId;
			endif;
		endif;
		
	elseif self.job.jobType = JOB_TYPE_SOB then 
		if ti.receivedDT.isValid then	
			//Shifted
			if showYardPos then
				sse.locationId := ti.locationId;
			else
				sse.locationId := ti.priorStowage;
			endif;
			sse.plannedLocationId := ti.locationId;
		else
			sse.locationId := ti.locationId;
			sse.plannedLocationId := ti.plannedLocnId;
		endif;
	endif;
	
//	sse.roughPlanLocationId := ti.roughPlannedLocn;
	sse.operatorCode := ti.operatorCode;
	sse.sequenceNumberPort := self.seqNumPort;
	sse.sequenceNumberStarboard := self.seqNumStarboard;
	sse.sequenceNumberWorkOrder := self.seqNumWorkOrder;
	sse.seqNumCustomPort := self.seqNumCustomPort;
	sse.seqNumCustomStarboard := self.seqNumCustomStarboard;
	sse.status := ti.getImExStatus();
	if isCont then
		sse.temperature := ti.CM_Container.getTemperature;
	endif;
	sse.trackedItemId := ti.id;
	sse.tiType := ti.cargoType;
//no longer valid
//	sse.toBeInspected := ti.toBeInspected;
	sse.totalWeight := ti.totalWeight;
	sse.trackedItem := ti;
	sse.workListEntry := self;
epilog
	unlock(self);
	unlock(ti);
	if self.job &lt;&gt; null then
		unlock(self.job);
	endif;
end;</source>
        <Parameter name="sse" type="CMIF_SeqSheetEntry" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getStatusDescr" id="4629bf1b-d66e-4b2d-adc6-2b936f141d82">
        <source>getStatusDescr() : String;
// ---------------------------------------------------------------------------
// Created:     24 November 2003	cnwth2
//
// Purpose:     USED IN REPORTS - DO NOT DELETE
//			 
// ----------   ----------  --------------------------------------------------
vars
	container			: CM_Container;
	statusDescr			: String;
	cargoStatus			: CM_CargoStatus;
	transitStat			: Integer;
	imexObj				: CM_IMEXStatus;
	transitStatObj		: CM_TransitStatus;
begin
	
	// 09/06/2010 cnwmh5 #20661
	if self.myTrackedItem = null and self.isBulkRelease then
		return app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT].description[1:3];
	endif;
	
	if self.myTrackedItem = null or 
	   (not CM_Container.hasInstance(self.myTrackedItem)) then
		return null;
	endif;
	
	container := self.myTrackedItem.CM_Container;
	transitStat := container.getTransitStatus(); 
	if transitStat &lt;&gt; null then
		transitStatObj := app.myRoot.allTransitStatuses[transitStat];
		if transitStatObj &lt;&gt; null then
			return transitStatObj.abbreviation;
		endif;
	endif;
	
	
	imexObj := container.getImExStatusObject;
	if imexObj &lt;&gt; null then
		return imexObj.abbreviation;
	else
		return "Unkn";
	endif;
	

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSubTerminal" id="f1a49b31-d58b-4244-94f5-7ad8918f45df">
        <source>getSubTerminal() : CM_SubTerminal;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 June 2010	cnwmh5	Initial creation #20661

*/

vars
	subTerminal : CM_SubTerminal;
begin

	if self.myTrackedItem &lt;&gt; null then
		subTerminal := app.myRoot.allSubTerminals[self.myTrackedItem.subTerminalCode];
	else
		if self.isBulkRelease() then
			subTerminal := self.myRequest.getBulkRelease.mySubTerminal;
		endif;
	endif;
	
	return subTerminal;
epilog

end;</source>
        <ReturnType type="CM_SubTerminal"/>
    </JadeMethod>
    <JadeMethod name="getTIId" id="ee86f26d-734b-4c35-a910-b3b56a4bbf3a">
        <source>getTIId() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 June 2010	cnwmh5	Initial creation #20661

*/

vars
	id 	: String;
begin

	if self.myTrackedItem &lt;&gt; null then
		id := self.myTrackedItem.id;
	else
		if self.isBulkRelease() then
			// id := "TBA" &amp; getPlannedLocation();
			id := self.myRequest.getDisplayStringForAttribute(ETRow_Id, true);  //cnwrd1 par 24522 29.6.2010
		endif;
	endif;
	
	return id;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTargetLocation" id="eae3b7f1-79e5-4b90-afe6-7c969c1cfda8">
        <source>getTargetLocation(): CM_LocationsController;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 May 2019	jlgzm1	TFS 42840 MSL - Direct Delivery Between LOLO RORO Voyages and Rail

*/

vars
	locCont : CM_LocationsController;
	invalidObject : Boolean;
begin
	locCont := inheritMethod();

	if locCont = null then
		
		if self.myFutureMoveDR &lt;&gt; null then
			on Exception do app.handleDeletedObject( exception, self.myFutureMoveDR, invalidObject );
			locCont := self.myFutureMoveDR.getPrimaryLocation();
		endif;
	endif;
	
	return locCont;

epilog

end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getTiTxnTypesToCreate" id="ebe12dc0-3901-4bee-b06e-9747c9870a6a">
        <source>getTiTxnTypesToCreate(_intArray: IntegerArray input);
//--------------------------------------------------
// Created:	10 December 2003 By: cnwgd1
//--------------------------------------------------
vars
	ti : CM_TrackedItem;
begin
	inheritMethod(_intArray);

	ti := self.myTrackedItem;
	if ti = null then
		return;
	endif;

//	if self.isSOB() then PAR 7254 AKB2004JAN - SOB have Release ship
//		return;
//	endif;	
	
	if self.isReceipt and CM_YardController.hasInstance(ti.myPrimaryActualLocation) then
		if ti.getLastTransOfType(TRANS_TYPE_REC_SHIP) = null then
			_intArray.add(TRANS_TYPE_REC_SHIP);
			_intArray.add(TRANS_TYPE_WHARFAGE);
			app.addTiTxnSubTerminalReceive(ti, TI_TRANSMODE_SHIP, _intArray);				// PAR 20706 (swap order)
		endif;
		if CM_VoyageJob.hasInstance(self.job)
		and self.job.CM_VoyageJob.isExportReturn then
			_intArray.add(TRANS_TYPE_EXPORT_RETURNED);
		endif;			
	/*elseif ti.isOnShip()  then
		app.addTiTxnSubTerminalRelease(ti, TI_TRANSMODE_SHIP, _intArray);				// PAR 20706 (swap order)
		_intArray.add(TRANS_TYPE_REL_SHIP);
		_intArray.add(TRANS_TYPE_WHARFAGE);		
		_intArray.add(TRANS_TYPE_STORAGE);*/
	endif;
end;</source>
