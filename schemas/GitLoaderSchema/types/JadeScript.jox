<Class name="JadeScript">
    <JadeMethod name="testCopyClientFiles" id="151ccc74-f673-41a9-be5c-7fb24aa8757b">
        <source>testCopyClientFiles();

constants
	MUL_FILE		: String = "C:\DevelopmentEnvs\navkmast\deploymentStaging\changedFiles.mul";	// This is NOT mocked, and is an actual file on disk
vars
	filesToCopy		: StringArray;
	mulFileOnDisk	: File;
	baseFilePath	: String;
	line			: String;
	idx				: Integer;
	fileName		: String;
begin
	create filesToCopy transient;
	filesToCopy.add(MUL_FILE);

	create mulFileOnDisk transient;
	mulFileOnDisk.usePresentationFileSystem := true;
	mulFileOnDisk.kind := File.Kind_Unknown_Text;
	mulFileOnDisk.mode := File.Mode_Input;
	mulFileOnDisk.fileName := MUL_FILE;
	mulFileOnDisk.endOfLine := null;	// Allow either CR, LF or CRLF rather than just CRLF
	
	baseFilePath := MUL_FILE[1:MUL_FILE.reversePos(mulFileOnDisk.directorySeparator())];
	
	while not mulFileOnDisk.endOfFile() do
		line := mulFileOnDisk.readLine();
		if line[1:1] = "#" then
			continue;	// Ignore 'comments' / #MULTIPLE_SCHEMA_EXTRACT header
		endif;
		idx := 1;
		while idx &gt; 0 and idx &lt; line.length do
			fileName := line.scanUntil(" ", idx);
			if fileName &lt;&gt; null then
				filesToCopy.add(baseFilePath &amp; fileName);
			endif;
			if idx &gt; 0 then
				idx += 1;
			endif;
		endwhile;
	endwhile;

	write filesToCopy.display();
	
epilog
	delete mulFileOnDisk;
	delete filesToCopy;
end;
</source>
    </JadeMethod>
    <JadeMethod name="testLogDirectoryFiles" id="df542c00-40a9-4bd4-aa67-41c332d9c012">
        <source>testLogDirectoryFiles();

vars
	logDir	: FileFolder;
	file	: FileNode;
begin
	create logDir transient;
	logDir.usePresentationFileSystem := false;
	logDir.fileName := app.getJadeLogDir();
	logDir.mask := "JMTRelease_*.log";
	
	write "Checking for JMTRelease logs in: " &amp; logDir.fileName;
	foreach file in logDir.files do
		write "Found: " &amp; file.name;
	endforeach;
	
epilog
	delete logDir;
end;
</source>
    </JadeMethod>
    <JadeMethod name="testMulLoad" id="58122216-f7f6-4e75-8d8c-920563a7c529">
        <source>testMulLoad();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
22 October 2025	navmd1	Initial creation DOMTN-403

*/

vars
	hsa 	: HugeStringArray;
begin
	create hsa transient;
	hsa.add("gitSHAhash=12345678");
	hsa.add("mulFile=C:\DevelopmentEnvs\z_thinclients\JadeSchemaLoaderTesting\changedFiles.mul");
	hsa.add("reorgRequired=false");
	hsa.add("refreshEntTables=true");
	hsa.add("refreshErrorStrings=true");
	app.init(hsa);
	
	// init calls terminate, so only epilog is called after this
	
epilog
	delete hsa;
	write process.userExitCode;
end;</source>
    </JadeMethod>
    <JadeMethod name="testRecompileMethods" id="1dcb9541-fc04-4a68-93a5-9d0124380b3a">
        <source>testRecompileMethods();

vars
	logger		: CMIF_Logger;
	initParams	: HugeStringArray;
	agent		: GitFileLoadAgent;
	result		: Integer;
begin
	// Dummy Init
	create logger transient;
	app.sendMsgWithParams("setLogger", logger);
	app.setPropertyValue("logLevel", LogWARN);

	create initParams transient;
	initParams.add(GitFileLoadAgent::gitSHAhash.name &amp; "=123456abx");
	agent := create GitFileLoadAgent(initParams);
	
	write "Recompiling Methods...";
	agent.sendMsgWithIOParams(GitFileLoadAgent::doRecompileMethods.name, result);
	write "Result: " &amp; result.String;
	
	write logger.getLogs();
	
epilog
	app.sendMsgWithParams("setLogger", null);		// this deletes logger
	//delete logger;
	
	delete initParams;
	delete agent;
end;</source>
    </JadeMethod>
    <JadeMethod name="testRestartApps" id="d9ca1b30-29b2-45f0-94aa-976cdc605ac0">
        <source>testRestartApps();

vars
	logger		: CMIF_Logger;
	initParams	: HugeStringArray;
	agent		: GitFileLoadAgent;
	result		: Integer;
	apps		: StringArray;
begin
	create logger transient;
	app.sendMsgWithParams("setLogger", logger);

	create initParams transient;
	initParams.add(GitFileLoadAgent::gitSHAhash.name &amp; "=123456abx");
	agent := create GitFileLoadAgent(initParams);
	
	write "Shutting down apps...";
	agent.sendMsg(GitFileLoadAgent::shutdownForegroundApps.name);
	apps := agent.getPropertyValue(GitFileLoadAgent::appsToRestart.name).StringArray;
	write "AppsToRestart =";
	write apps.display();
	
	write "Restarting apps...";
	agent.sendMsgWithIOParams(GitFileLoadAgent::restartForegroundApps.name, result);
	
	write logger.getLogs();
	
epilog
	app.sendMsgWithParams("setLogger", null);
	
	delete initParams;
	delete agent;
end;</source>
    </JadeMethod>
</Class>
