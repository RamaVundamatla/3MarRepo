    <JadeMethod name="getAuditText" id="a7a470c3-b395-4bf8-890d-f68e6451186f">
        <source>getAuditText(): String;
/*
Purpose:			

Date		Who		Reason
03 August 2023	navab1	CR 56093 TASK 59624
01/09/2023	navkc1	CR 59937 Task 59939: UI - Cust Doc Mandatory Fields

*/

vars
	txt,
	tmpStr	: String;
	stop : CM_StopsTable;
	nextDocType : CM_CustomDocumentType;
	custLic : CM_CustomLicense;
	mandAttr	: String;
	entDef		: EntTableDef;
	entRow		: EntTableRow;
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();

	// ### STOPS TO APPLY
	tmpStr := null;
	if self.allStopsToApply.size() &gt; 0 then
		
		foreach stop in self.allStopsToApply do
			if stop &lt;&gt; null then
				tmpStr := stop.code &amp; " - " &amp; stop.heading &amp; Cr &amp; tmpStr;
			endif;
		endforeach;
		
		txt := txt &amp; "Stops to Apply" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	endif;

	// ### STOPS TO CLEAR
	tmpStr := null;
	if self.allStopsToClear.size() &gt; 0 then
		
		foreach stop in self.allStopsToClear do
			if stop &lt;&gt; null then
				tmpStr := stop.code &amp; " - " &amp; stop.heading &amp; Cr &amp; tmpStr;
			endif;
		endforeach;
		
		txt := txt &amp; "Stops to Clear" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	endif;

	// ### NEXT DOC TYPES
	tmpStr := null;
	if self.allNextDocumentTypes.size() &gt; 0 then
		foreach nextDocType in self.allNextDocumentTypes do
			if nextDocType &lt;&gt; null then
				tmpStr := nextDocType.code &amp; " - " &amp; nextDocType.description &amp; Cr &amp; tmpStr;
			endif;
		endforeach;
		
		txt := txt &amp; "Next Doc Types" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		
	endif;

	// ### LICENSES
	tmpStr := null;
	if self.allCustomLicenses.size() &gt; 0 then
		foreach custLic in self.allCustomLicenses do
			if custLic &lt;&gt; null then
				tmpStr := custLic.code &amp; " - " &amp; custLic.description &amp; Cr &amp; tmpStr;
			endif;
		endforeach;
		
		txt := txt &amp; "Custom Licenses" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
		
	endif;
	
	tmpStr := CM_CustomDocumentType@getDirectStrFromInt(self.direction);
	txt := txt &amp; "Direction" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	//01/09/2023	navkc1	CR 59937 Task 59939
	// Mandatory attributes
	tmpStr := null;
	if self.allMandatoryFields.size() &gt; 0 then
		entDef := app.myRoot.myEntTableDataRoot.getEntTableDef(ETDef_CustDocTypeMandAttr);
		foreach mandAttr in self.allMandatoryFields do
			if entDef &lt;&gt; null then
				entRow := entDef.getEntTableRow(mandAttr);
			endif;
			if entRow &lt;&gt; null then
				tmpStr := entRow.getHeading(null, null, app.myCurrentLocale) &amp; Cr &amp; tmpStr;
			else
				tmpStr := mandAttr &amp; Cr &amp; tmpStr;
			endif;
		endforeach;
		
		txt := txt &amp; "Mandatory Attribtes" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	endif;
	
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCustomDocsUsed" id="ddbd0f28-28be-4db6-8bdb-4cf81bee454c">
        <source>getCustomDocsUsed() : String;
/*
Purpose:			

Date		Who		Reason
03 August 2023	navab1	CR 56093 TASK 59623
*/

vars
	retStr, dispStr : String;
	custObj : CM_CustomDocument;
begin
	foreach custObj in self.allCustomDocuments discreteLock do
		dispStr := custObj.code;
		/*
		if dispStr &lt;&gt; null then
			if retStr.pos(dispStr,1) = 0 then
				if retStr = null then
					retStr := dispStr;
				else
					retStr := retStr &amp; ","&amp; dispStr;
				endif;
			endif;
		endif;
		*/
		
		retStr.addStringToList(dispStr, ","); //04/04/2025	navkc1 JIRA Story MTN-33940
	endforeach;
	
	return retStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCustomLicenseUsed" id="cef978da-e3a2-4fcd-90e8-fa6bed1df5be">
        <source>getCustomLicenseUsed() : String;
/*
Purpose:			

Date		Who		Reason
03 August 2023	navab1	CR 56093 TASK 59623
*/

vars
	retStr, dispStr : String;
	custObj : CM_CustomLicense;
begin
	foreach custObj in self.allCustomLicenses discreteLock do
		dispStr := custObj.code;
		/*
		if dispStr &lt;&gt; null then
			if retStr.pos(dispStr,1) = 0 then
				if retStr = null then
					retStr := dispStr;
				else
					retStr := retStr &amp; ","&amp; dispStr;
				endif;
			endif;
		endif;
		*/
		
		retStr.addStringToList(dispStr, ","); //04/04/2025	navkc1 JIRA Story MTN-33940
	endforeach;
	
	return retStr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDirectIntFromStr" id="3a3fcae3-f809-48e2-a7fe-f2a09be0bc5c">
        <options>4</options>
        <source>getDirectIntFromStr(_dir : String) : Integer typeMethod;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	CR 60426 Task 60570: Jade - Cust Doc on TI and Trans Selector Query

*/

vars
	int	: Integer;
begin
	
	if _dir = CM_CustomDocumentType.CustDocTypeDirStr_Inward then
		return CM_CustomDocumentType.CustDocTypeDir_Inward;
	elseif _dir = CM_CustomDocumentType.CustDocTypeDirStr_Outward then
		return CM_CustomDocumentType.CustDocTypeDir_Outward;
	elseif _dir = CM_CustomDocumentType.CustDocTypeDirStr_Both then
		return CM_CustomDocumentType.CustDocTypeDir_Both;
	endif;
	
	return -1;
	
epilog

end;</source>
        <Parameter name="_dir" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDirectStrFromInt" id="920e7a47-8293-4d60-a132-76fb00bec60c">
        <options>4</options>
        <source>getDirectStrFromInt(_dir : Integer) : String typeMethod;
/*
Purpose:			

Date		Who		Reason
07 August 2023	navab1	CR 56093 TASK 59625
*/

vars
	reStr : String;
begin
		if _dir = CM_CustomDocumentType.CustDocTypeDir_Inward then
			reStr :=  CM_CustomDocumentType.CustDocTypeDirStr_Inward;
		elseif _dir = CM_CustomDocumentType.CustDocTypeDir_Outward then
			reStr :=  CM_CustomDocumentType.CustDocTypeDirStr_Outward;
		elseif _dir = CM_CustomDocumentType.CustDocTypeDir_Both then
			reStr :=  CM_CustomDocumentType.CustDocTypeDirStr_Both;
		endif;

		return reStr;
epilog

end;</source>
        <Parameter name="_dir" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="15d67c01-2620-4c59-84c1-c2f36e44b3d5">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Purpose:			

Date		Who		Reason
07 August 2023	navab1	CR 56093 TASK 59625
*/

vars
	reStr : String;

begin

	if _attrName = ETRow_NafeList then
		return self.notAvailForEntry.getYesNo();
	elseif _attrName = ETRow_HasAutoIdList then
		return self.hasAutoId.getYesNo();
	elseif _attrName = ETRow_StopsApplied then
		return self.allStopsToApply.auditIdDisplay();
	elseif _attrName = ETRow_StopsCleared then
		return self.allStopsToClear.auditIdDisplay();
	elseif _attrName = ETRow_NextCustDocTypes then
		return self.allNextDocumentTypes.auditIdDisplay();
	elseif _attrName = ETRow_PrevCustDocTypes then
		return self.allPrevDocumentTypes.auditIdDisplay();
	elseif _attrName = ETRow_CustLicense then
		return self.allCustomLicenses.auditIdDisplay();
		
	elseif _attrName = ETRow_Direction then
		reStr := CM_CustomDocumentType@getDirectStrFromInt(self.direction);
	else
		reStr:=  inheritMethod(_attrName, _short);
	endif;
	
	return reStr;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getYADisplay" id="441231ae-6f42-4d37-83d3-2618257e40d9">
