    <JadeMethod name="lstDataDisplayRow" id="e433f4c5-ebd5-416d-8306-2fd10571fc47">
        <source>lstDataDisplayRow(_obj: Object): String;
// ---------------------------------------------------------------------------
// Created:     26 June 2009 by concms1
// Purpose:     CCMS 1061 - Gate Config Changes  
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if _obj.isKindOf (CM_Gate) then
		return _obj.CM_Gate.name;
	elseif _obj.isKindOf (CM_GateAreaUsage) then
		return _obj.CM_GateAreaUsage.myGateArea.id;
	endif;
	
	return inheritMethod(_obj);

epilog

end;</source>
