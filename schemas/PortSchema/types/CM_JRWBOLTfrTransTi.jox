    <JadeMethod name="setValues" id="3dfa7122-8d68-44f3-aba5-437a043b1ce3">
        <updating/>
        <source>setValues(	_parent : CM_JRWBOLTfrTransactions;
			_bolHistStr : String;
			_ti : CM_TrackedItem;
			_lastBolTrx : CM_BOLTransferTransaction
			) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2016	cnwndl1	Initial creation	TFS 1904

*/

vars

begin

	self.houseBOLHistoryStr := _bolHistStr;
	self.houseBOLHistStrKey := _bolHistStr[1:200];
	
	self.myTrackedItem := _ti;
	if _ti &lt;&gt; null then
		self.cargoId := _ti.id;		
	endif;
	
	if _lastBolTrx &lt;&gt; null then
		self.commodity := _lastBolTrx.commodity;
		self.latestBolNumber := _lastBolTrx.myBOL.number;
		self.operatorCode := _lastBolTrx.operator;
		self.quantity := _lastBolTrx.quantity;
		self.volume := _lastBolTrx.volume;
		self.weight := _lastBolTrx.weight;
		self.voyageCode := _lastBolTrx.voyageCode;
	endif;

	self.myParentCollection := _parent;

epilog

end;</source>
        <Parameter name="_parent" type="CM_JRWBOLTfrTransactions"/>
        <Parameter name="_bolHistStr" type="String"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_lastBolTrx" type="CM_BOLTransferTransaction"/>
    </JadeMethod>
</Class>
