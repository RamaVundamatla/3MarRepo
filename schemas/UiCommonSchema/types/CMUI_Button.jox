    <JadeMethod name="click" id="f67b5d53-4c35-4661-96ec-1717137e7fa8">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

begin

	if self.parent.isKindOf( CMUI_SelectorPanel ) then
		self.parent.CMUI_SelectorPanel.handleButtonClick( self );
	else
		inheritMethod(btn);
		
	endif;

epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cnEcResizeContents" id="28874b30-92f9-4b43-988d-4a695de35c47">
        <updating/>
        <source>cnEcResizeContents() updating;
// ---------------------------------------------------------------------------
// Created:     30 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.repositionAfterResize();

end;</source>
    </JadeMethod>
    <JadeMethod name="repositionAfterResize" id="ad845057-d4d1-4f19-b28e-e37b1de3dbe7">
        <updating/>
        <source>repositionAfterResize() updating;
// ---------------------------------------------------------------------------
// Created:     09 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
 	newLeft, newTop, newWidth, newHeight,
   	parentWidth,
   	parentHeight	: Real;

begin

	newLeft 	:= self.left;
	newTop 		:= self.top;
	newWidth 	:= self.width;
	newHeight	:= self.height;
	
	if self.parent.isKindOf(Form) then
		parentWidth  := self.parent.Form.clientWidth;
		parentHeight := self.parent.Form.clientHeight;
	elseif self.parent.isKindOf(Control) then
		parentWidth  := self.parent.Control.clientWidth;
		parentHeight := self.parent.Control.clientHeight;
	else
		parentWidth  := self.parent.width;
		parentHeight := self.parent.height;
	endif;

	if lockRight then
		newLeft := (parentWidth - newWidth - self.distanceFromRight).max(0);
	endif;
	if lockBottom then
		newTop := (parentHeight - newHeight - self.distanceFromBottom).max(0);
	endif;

	if newLeft &lt;&gt; self.left or newTop &lt;&gt; self.top or newWidth &lt;&gt; self.width or newHeight &lt;&gt; self.height then
		self.move(newLeft, newTop, newWidth, newHeight);
		//self.cnEcResizeContents;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setDistanceFromBottom" id="593d574f-6284-4630-8a93-bb0aeb1fea03">
        <updating/>
        <source>setDistanceFromBottom(_value : Real) updating;
// ---------------------------------------------------------------------------
// Created:     09 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.distanceFromBottom &lt;&gt; _value then
		self.distanceFromBottom := _value;
	endif;
	
end;</source>
        <Parameter name="_value" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setDistanceFromRight" id="4cc12c83-f37d-486f-8676-1c9a0a1ab880">
        <updating/>
        <source>setDistanceFromRight(_value : Real) updating;
// ---------------------------------------------------------------------------
// Created:     09 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.distanceFromRight &lt;&gt; _value then
		self.distanceFromRight := _value;
	endif;
	
end;</source>
        <Parameter name="_value" type="Real"/>
    </JadeMethod>
    <JadeMethod name="setVisibleEnabled" id="52e81bf2-e81d-46a9-b8c3-b61ee83c1a9e">
        <updating/>
        <source>setVisibleEnabled(_visible, _enabled : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     21 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.visible	:= _visible;
	self.enabled	:= _enabled;

end;</source>
        <Parameter name="_visible" type="Boolean"/>
        <Parameter name="_enabled" type="Boolean"/>
    </JadeMethod>
