    <JadeMethod name="validateMe" id="00ab2be3-05bd-436a-b6d4-00447814ac0b">
        <source>validateMe() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Jul 2020 cnwma1  Bug 49243: MTN - Cargo Chain Web Service Callback INI value
*/

vars
	ext,
	realMe 		  : CM_ExternalWebServiceDef;
begin
	inheritMethod();
   
    if self.callBackUrl = null then
        app.raiseCMException1(Input_required_field_Required, app.getString(Callback_Url), self.callBackUrl, null);
    endif;
   
    realMe := self.pxyGetRealObject();
   
    // Check if there is already an active Ext Web Service def of our type
    if self.active then
        foreach ext in app.myRoot.allExternalWebServices discreteLock where ext.active do
            if ext.isKindOf(CM_CargoChainServiceDef) then
                if realMe = null or ext &lt;&gt; realMe then
                    app.raiseCMException2(ERR_Active_ExtWebDef, ExternalWebServiceCARGOCHAIN, ext.name, null, null);
                    break;
                endif;
            endif;
        endforeach;
    endif;
	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
