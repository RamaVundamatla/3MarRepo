    <JadeMethod name="deleteOperator" id="f7311b09-cd6b-4d9b-9923-d31f1fdf9a0f">
        <source>deleteOperator(_opCode: String);

vars
	operator: CM_Operator;
	ti: CM_TrackedItem;
	opTerm: CM_OperatorTerminal;
	product: CM_Product;
	voyOp: CM_VoyageOperator;
	releaseRequest: CM_BulkRelease;
	bol: CM_BOL;
	booking: CM_BookingRef;
	terminal 	: CM_Terminal;
	voyage		: CM_Voyage;
	vessel		: CM_Vessel;
	tempTermStr	: String;
begin

	operator := self.getOperator(_opCode);
	if operator = null then
		return;
	endif;
	
	foreach opTerm in operator.allOperatorTerminals do
		foreach ti in opTerm.allDeletedTIsByCargoTypeId do
			self.deleteTrackedItem(ti, false); // AKB added false
		endforeach;
		foreach ti in opTerm.allOnsiteTIsByCargoTypeId do
			self.deleteTrackedItem(ti, false); // AKB added false
		endforeach;
		foreach ti in opTerm.allNotifiedTIsByCargoTypeId do
			self.deleteTrackedItem(ti, false); // AKB added false
		endforeach;
		foreach ti in opTerm.allTbaTIsByCargoTypeId do
			self.deleteTrackedItem(ti, false); // AKB added false
		endforeach;
		// cnwjre1 May 2014 add offsite cargo as well for cash tests
		foreach ti in opTerm.allOffsiteTIsByCargoTypeId do
			self.deleteTrackedItem(ti, false);
		endforeach;

		self.opts.purge;
		self.opts.addAssoc("Terminal", opTerm.myTerminal.code);
		foreach releaseRequest in opTerm.allBulkReleases do
			self.deleteReleaseRequest(releaseRequest.code);
		endforeach;
		foreach booking in opTerm.allBookingRefsByRef do
			self.deleteBooking(booking.bookingReference);
		endforeach;		
		foreach bol in opTerm.allBOLByTypeNumber do
			self.deleteBOL(null, bol);
		endforeach;
		self.opts.purge;
		
		
	endforeach;
	
	foreach product in operator.allProducts do
		self.deleteProduct(product.code, operator, product.myCargoType);
	endforeach;
	
	foreach voyOp in operator.allVoyageOperators do
		self.deleteVoyage(voyOp.myVoyage.code);
	endforeach;
	
	beginTransaction;
	operator.allVoyageOperators.purge;
	commitTransaction;
	
	tempTermStr := self.opts.str("Terminal");
	foreach terminal in app.myRoot.allTerminals do							// 14/09/2012 cnwmh5
		self.opts.removeAssoc("Terminal");
		self.opts.addAssoc("Terminal", terminal.code);
		beginTransaction;
		if terminal.getConfig(DefOperator).CM_Operator = operator then
			terminal.setConfig(DefOperator, null);
		endif;
		commitTransaction;
		foreach booking in terminal.allBookingRefsByRef do
			self.deleteBooking(booking.bookingReference);
		endforeach;
	endforeach;
	self.opts.removeAssoc("Terminal");
	if tempTermStr &lt;&gt; null then
		self.opts.addAssoc("Terminal", tempTermStr);
	endif;
	
	beginTransaction;														// 14/09/2012 cnwmh5
	foreach voyage in operator.allVoyages do
		voyage.setPropertyValue("myOperator", null);
	endforeach;
	commitTransaction;
	
	beginTransaction;														// 14/09/2012 cnwmh5
	foreach vessel in app.myRoot.allVessels do
		vessel.setPropertyValue("myOperator", null);
	endforeach;
	commitTransaction;
	
	app.myTrxDA.trxDeleteOperator(operator, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();

end;</source>
        <Parameter name="_opCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="deleteOperatorGroup" id="ab2af41a-0f3c-4c31-8d47-6d399c32824c">
        <source>deleteOperatorGroup(_operatorGroup : Any);

/*

Purpose:		Delete operator group

Date			Who		Reason
06/03/2014		cnwmh5	Initial creation

*/

vars

	operatorGroup					: CM_OperatorGroup;
	operator						: CM_Operator;

begin

	if _operatorGroup.isKindOf(String) then
		operatorGroup := app.myRoot.allOperatorGroups[_operatorGroup.String].CM_OperatorGroup;
	elseif _operatorGroup.isKindOf(CM_OperatorGroup) then
		operatorGroup := _operatorGroup.CM_OperatorGroup;
	endif;

	if operatorGroup = null then
		return;
	endif;
	
	// need to remove the operators from the collection before deleting
	beginTransaction;
	foreach operator in operatorGroup.allOperators do
		operatorGroup.allOperators.remove(operator);
	endforeach;
	commitTransaction;	
	
	app.myTrxDA.trxDeleteOperatorGroup(operatorGroup, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
epilog

end;</source>
        <Parameter name="_operatorGroup" type="Any"/>
    </JadeMethod>
    <JadeMethod name="deleteOrganisation" id="948c2e41-368d-455e-89a9-5b47d62c2ad8">
        <source>deleteOrganisation(_organisationId : String);

/*

Purpose:		Delete a Organisation	

Date			Who		Reason
29/11/2011		cnwmh5	Initial creation

*/

vars

	organisation			: CM_Organisation;
	user					: CM_User;

begin

	organisation := app.myRoot.allOrganisations[_organisationId];
	if organisation &lt;&gt; null then
	
		beginTransaction;
		foreach user in organisation.allUsers do
			user.setMyOrganisation(null);		
		endforeach;
		commitTransaction;
		
		app.myTrxDA.trxDeleteOrganisation(organisation, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;

epilog

end;</source>
        <Parameter name="_organisationId" type="String"/>
    </JadeMethod>
