    <JadeMethod name="setDetails" id="d9116169-2988-4ce9-a638-13b64d3c39b7">
        <updating/>
        <source>setDetails(	_form : SHP_JobControllerForm;
			_voyage : CM_Voyage;
			_frmScrollable : CMUI_ScrollableFrame; 
			_frmScrolling : CMUI_ScrollingFrame;
			_frmJobBubble: Frame;
			_top,
			_height,
			_width : Real;
			_timeScale : Real;
			_voyageZoom : Real;
			_hideCompleted : Boolean) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
30 January 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.scrolledOffset:=0;
	self.setHideCompleted(_hideCompleted);
	self.myForm:=_form;
	self.setMyVoyage(_voyage);
	self.frmScrollableMain:=_frmScrollable;
	self.frmScrollingMain:=_frmScrolling;
	self.frmJobBubble :=_frmJobBubble;
	self.top:=_top;
	self.setHeight(_height);
	self.setWidth(_width);
	self.timeScale:=_timeScale;
	self.voyageZoom:=_voyageZoom;
		
	self.frmScrollableMain.myTopLeftFillerFrame.borderStyle:=Control.BorderStyle_Single;
	self.frmScrollableMain.myTopLeftFillerFrame.ignoreSkin:=true;
	
	
	
epilog

end;</source>
