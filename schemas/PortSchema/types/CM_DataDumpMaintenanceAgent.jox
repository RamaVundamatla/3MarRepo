        <source>xCM_Voyage(_features : CMIF_ExternalDBFeatureSet input) updating;
// 06/04/2010	cnwsh3	PAR27353 -	shipExchangeDate and shipExchangeCompleteDT need to be exposed for extract to SQL
// 26/02/2013	cnwdap1	PAR #31213 CCMS PNL 2255 Additional voyage SQL fields
// 25 Jun 2014	cnwrs1	Par 34470 New SQL native classes are missing edition 
// 05/03/2015	cnwdap1	PAR #35826 CCMS SFW 1410 Added expected arrival/departure date/time
// 09 Nov 2016	cnwrs1	TFS 2933 MSL SQL Extract
// 11/04/2017	cnwdap1	TFS 4050 LNX Job ID Enhancements
// 20/11/2017	jlgdap1	TFS 7511 LNZ Remove duplicate attribute names 'shipExchangeCompleteDT' and 'shipExchangeDate'
// 22/04/2020	jlgdap1	TFS 49171 ASPA April SQL Data Export Field Exposure
// 03/06/2020   cnwma1 ChangeRequest 49400: ASPA - Invoice Enhancements for Barges
// 08/04/2022	jlika1	TFS 53181	GPHA - Voyage Code Translation for Multiple Terminals and Co-Loaders
