    <JadeMethod name="qryVehicleBookings" id="b2a908fe-7820-4b75-b5c0-06a0172b1274">
        <updating/>
        <source>qryVehicleBookings(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 April 2013	cnwndl1	Initial creation	Par 31393

*/

vars
	numSelected 	: Integer;
	jrwTrans		: CM_JRWVehicleBookings;
	filter			: CMQF_VehicleBookingReport;
	
begin
	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	filter := _filter.CMQF_VehicleBookingReport;
	jrwTrans := self.createJRWTransient(CM_JRWVehicleBookings).CM_JRWVehicleBookings;
	
	jrwTrans.dateFrom := filter.dateFrom;
	jrwTrans.dateTo := filter.dateTo;
	jrwTrans.myCarrier := filter.getMyCarrier;
	jrwTrans.inclUnBooked := filter.inclUnBooked;
	jrwTrans.setAllTerminals(filter.allTerminals);
	
	filter.filterObjects(jrwTrans.allVehicleBookings, _passport);
	
	numSelected := jrwTrans.allVehicleBookings.size;
epilog
	return numSelected;
end;
</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
