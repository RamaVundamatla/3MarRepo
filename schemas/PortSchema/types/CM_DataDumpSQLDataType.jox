    <JadeMethod name="createSelf" id="9154bfed-56b3-4328-a9a7-ccf634cb0500">
        <updating/>
        <source>createSelf(_root : CM_Root) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
20 April 2010	conkc1	Initial creation

*/
constants
	// Jade types
	JBinaryUB       : String = "IMAGE";
	JBinaryL        : String = "BINARY";
	JBoolean        : String = "BIT";
	JByte           : String = "TINYINT";
	JCharacter      : String = "NCHAR(1)";
	JDate2000       : String = "DATETIME";
	JDate2008       : String = "DATE";
	JDecimal        : String = "DECIMAL";
	JInteger        : String = "INT";
	JInteger64      : String = "BIGINT";
	JJadeBytes      : String = "IMAGE";
	JOID            : String = "NCHAR(16)";
	Jreal           : String = "FLOAT";
	JStringUB       : String = "NTEXT";
	JStringL        : String = "NVARCHAR";
	JStringUTF8UB   : String = "NTEXT";
	JStringUTF8L    : String = "NCHARVAR";
	JTime2000       : String = "DATETIME";
	JTime2008       : String = "TIME";
	JTimeStamp2000  : String = "DATETIME";
	JTimeStamp2008  : String = "DATETIME2";

vars
	sqlDataType : CM_DataDumpSQLDataType;
begin
	beginTransaction;
	
	if _root.allDataDumpSQLDataTypes[CM_DataDumpSQLDataType.SQLBigInt] = null then
		create sqlDataType;
		sqlDataType.name       := CM_DataDumpSQLDataType.SQLBigInt;
		sqlDataType.myRoot     := _root;
	endif;

	if _root.allDataDumpSQLDataTypes[CM_DataDumpSQLDataType.SQLBinary] = null then
		create sqlDataType;
		sqlDataType.name       := CM_DataDumpSQLDataType.SQLBinary;
		sqlDataType.myRoot     := _root;
	endif;

	if _root.allDataDumpSQLDataTypes[CM_DataDumpSQLDataType.SQLBinaryVB] = null then
		create sqlDataType;
		sqlDataType.name       := CM_DataDumpSQLDataType.SQLBinaryVB;
		sqlDataType.myRoot     := _root;
	endif;
	
	if _root.allDataDumpSQLDataTypes[CM_DataDumpSQLDataType.SQLBit] = null then
		create sqlDataType;
		sqlDataType.name       := CM_DataDumpSQLDataType.SQLBit;
		sqlDataType.myRoot     := _root;
	endif;

	if _root.allDataDumpSQLDataTypes[CM_DataDumpSQLDataType.SQLChar] = null then
		create sqlDataType;
		sqlDataType.name       := CM_DataDumpSQLDataType.SQLChar;
		sqlDataType.myRoot     := _root;
	endif;
	
	if _root.allDataDumpSQLDataTypes[CM_DataDumpSQLDataType.SQLDateTime2] = null then
		create sqlDataType;
		sqlDataType.name       := CM_DataDumpSQLDataType.SQLDateTime2;
		sqlDataType.myRoot     := _root;
	endif;
	
	if _root.allDataDumpSQLDataTypes[CM_DataDumpSQLDataType.SQLDateTime] = null then
		create sqlDataType;
		sqlDataType.name       := CM_DataDumpSQLDataType.SQLDateTime;
		sqlDataType.myRoot     := _root;
	endif;
	
	if _root.allDataDumpSQLDataTypes[CM_DataDumpSQLDataType.SQLDate] = null then
		create sqlDataType;
		sqlDataType.name       := CM_DataDumpSQLDataType.SQLDate;
		sqlDataType.myRoot     := _root;
	endif;
	
	if _root.allDataDumpSQLDataTypes[CM_DataDumpSQLDataType.SQLMoney] = null then
		create sqlDataType;
		sqlDataType.name       := CM_DataDumpSQLDataType.SQLMoney;
		sqlDataType.myRoot     := _root;
	endif;
	
	if _root.allDataDumpSQLDataTypes[CM_DataDumpSQLDataType.SQLDecimal] = null then
		create sqlDataType;
		sqlDataType.name       := CM_DataDumpSQLDataType.SQLDecimal;
		sqlDataType.myRoot     := _root;
	endif;
	
	if _root.allDataDumpSQLDataTypes[CM_DataDumpSQLDataType.SQLFloat] = null then
		create sqlDataType;
		sqlDataType.name       := CM_DataDumpSQLDataType.SQLFloat;
		sqlDataType.myRoot     := _root;
	endif;
	
	if _root.allDataDumpSQLDataTypes[CM_DataDumpSQLDataType.SQLImage] = null then
		create sqlDataType;
		sqlDataType.name       := CM_DataDumpSQLDataType.SQLImage;
		sqlDataType.myRoot     := _root;
	endif;
	
	if _root.allDataDumpSQLDataTypes[CM_DataDumpSQLDataType.SQLInteger] = null then
		create sqlDataType;
		sqlDataType.name       := CM_DataDumpSQLDataType.SQLInteger;
		sqlDataType.myRoot     := _root;
	endif;
	
	if _root.allDataDumpSQLDataTypes[CM_DataDumpSQLDataType.SQLNChar] = null then
		create sqlDataType;
		sqlDataType.name       := CM_DataDumpSQLDataType.SQLNChar;
		sqlDataType.myRoot     := _root;
	endif;
	
	if _root.allDataDumpSQLDataTypes[CM_DataDumpSQLDataType.SQLNText] = null then
		create sqlDataType;
		sqlDataType.name       := CM_DataDumpSQLDataType.SQLNText;
		sqlDataType.myRoot     := _root;
	endif;
	
	if _root.allDataDumpSQLDataTypes[CM_DataDumpSQLDataType.SQLVarChar] = null then
		create sqlDataType;
		sqlDataType.name       := CM_DataDumpSQLDataType.SQLVarChar;
		sqlDataType.myRoot     := _root;
	endif;
	
	if _root.allDataDumpSQLDataTypes[CM_DataDumpSQLDataType.SQLNVarChar] = null then
		create sqlDataType;
		sqlDataType.name       := CM_DataDumpSQLDataType.SQLNVarChar;
		sqlDataType.myRoot     := _root;
	endif;
	
	if _root.allDataDumpSQLDataTypes[CM_DataDumpSQLDataType.SQLText] = null then
		create sqlDataType;
		sqlDataType.name       := CM_DataDumpSQLDataType.SQLText;
		sqlDataType.myRoot     := _root;
	endif;
	
	if _root.allDataDumpSQLDataTypes[CM_DataDumpSQLDataType.SQLTime] = null then
		create sqlDataType;
		sqlDataType.name       := CM_DataDumpSQLDataType.SQLTime;
		sqlDataType.myRoot     := _root;
	endif;
	
	if _root.allDataDumpSQLDataTypes[CM_DataDumpSQLDataType.SQLTinyInt] = null then
		create sqlDataType;
		sqlDataType.name       := CM_DataDumpSQLDataType.SQLTinyInt;
		sqlDataType.myRoot     := _root;
	endif;

	commitTransaction;
epilog

end;</source>
        <Parameter name="_root" type="CM_Root"/>
    </JadeMethod>
</Class>
