    <JadeMethod name="rel841_par36484" id="ce89f2bd-b865-421b-a242-dfcc7cf03afa">
        <source>rel841_par36484();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 13/07/2015	cnwdap1		Initial creation PAR #36484
//
vars
	transAgent 	: CM_TranslationAgent;
	tmpArray 	: StringArray;

begin
	create transAgent transient;
	create tmpArray transient;
