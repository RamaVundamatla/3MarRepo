    <JadeMethod name="addPreNoteItem" id="4bea5e78-4fe6-40e6-ae85-361f6affa669">
        <updating/>
        <source>addPreNoteItem(_trackedItem : CM_TrackedItem) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 August 2009	cnwdap1	Initial creation
*/
vars
	idx : Integer;
	ct : CM_CargoType;
begin
	idx := self.cmbCargoID.findStringExact(1, _trackedItem.id);
	if idx = -1 then
		idx := self.cmbCargoID.addItem(_trackedItem.id);
	endif;
		self.cmbCargoID.itemObject[idx] := _trackedItem;
		self.cmbCargoID.listIndex		:= idx;
		self.cmbCargoID_click(self.cmbCargoID);
//	endif;
	
//	self.cmbCargoType.listObject := _trackedItem.myCargoType;
	self.cmbCargoType.listIndex := self.cmbCargoType.findObject( _trackedItem.myCargoType );	//10 Sep 2015	NDL	Par 36390
epilog

end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="cf6d557b-3a9e-4168-9573-415c4436440d">
        <updating/>
        <source>addToolbarControls() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 July 2009	cnwmd1	Initial creation

*/

vars
	toolbar		: CMUI_Toolbar;
begin
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnNextCargo, CMUI_Toolbar.Control_Alignment_Left);

	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
