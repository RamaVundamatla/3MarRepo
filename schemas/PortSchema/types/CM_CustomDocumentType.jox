    <JadeMethod name="pxyCreateUpdateProxy" id="1263954c-028b-4686-9546-b1dfe971474a">
        <source>pxyCreateUpdateProxy(): SelfType;
/*
Purpose:			

Date		Who		Reason
03 August 2023	navab1	 CR 56093 TASK 59623
*/

vars
	pxySelf : SelfType;
begin
	pxySelf :=  inheritMethod();
	
	pxySelf.myTerminal := self.myTerminal;
	self.allStopsToApply.copy(pxySelf.allStopsToApply);
	self.allStopsToClear.copy(pxySelf.allStopsToClear);
	self.allNextDocumentTypes.copy(pxySelf.allNextDocumentTypes);
	
	return pxySelf;

epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="69a9d36c-1fe0-4c22-bdf0-659eeacefbb4">
        <updating/>
        <source>setForCreate(_pxy : SelfType) updating;
/*
Purpose:			

Date		Who		Reason
03 August 2023	navab1	 CR 56093 TASK 59623
*/

vars

begin
	
	self.myTerminal := _pxy.myTerminal;

	self.setForUpdate(_pxy);
epilog

end;</source>
        <Parameter name="_pxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="5a8d5fd5-2f3a-409a-9edc-249365c04ff5">
        <updating/>
        <source>setForUpdate(_pxy : SelfType) updating;
/*
Purpose:			

Date		Who		Reason
03 August 2023	navab1	 CR 56093 TASK 59623
01/09/2023	navkc1	CR 59937 Task 59939: UI - Cust Doc Mandatory Fields
05/09/2023	navkc1	CR 60156  Task 60157: UI - Cust Doc Type Colour
*/

vars

begin
	self.code := _pxy.code;
	self.description := _pxy.description;
	self.direction := _pxy.direction;
	self.hasAutoId := _pxy.hasAutoId;
	self.notAvailForEntry := _pxy.notAvailForEntry;

	self.allStopsToApply.clear();
	self.allStopsToClear.clear();
	self.allNextDocumentTypes.clear();
	self.allCustomLicenses.clear();
	self.allMandatoryFields.clear(); //01/09/2023	navkc1	CR 59937 Task 59939
	
	_pxy.allStopsToApply.copy(self.allStopsToApply);
	_pxy.allStopsToClear.copy(self.allStopsToClear);
	_pxy.allNextDocumentTypes.copy(self.allNextDocumentTypes);
	_pxy.allCustomLicenses.copy(self.allCustomLicenses);
	_pxy.allMandatoryFields.copy(self.allMandatoryFields); //01/09/2023	navkc1	CR 59937 Task 59939
	
	//05/09/2023	navkc1	CR 60156  Task 60157
	self.colour := _pxy.colour;
epilog

end;</source>
        <Parameter name="_pxy" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="a33826e2-168f-4b4e-b7ff-383674e1117c">
        <updating/>
        <source>setProxy(_code, _desc : String; _direction : Integer; _hasAutoId, _nafe : Boolean; _term : CM_Terminal; 
				_nextCustDocType : CM_CustomDocumentTypeByCode; 
				_stopsApply, _stopClear : CM_StopsTableSet;
				_licenses : CM_CustomLicenseByCode;
				_mandatoryFields : StringArray;
				_colour : Integer)  updating;
/*
Purpose:			

Date		Who		Reason
03 August 2023	navab1	 CR 56093 TASK 59623
01/09/2023		navkc1	CR 59937 Task 59939: UI - Cust Doc Mandatory Fields
05/09/2023		navkc1	CR 60156  Task 60157: UI - Cust Doc Type Colour
*/

vars

begin
	self.code := _code;
	self.description := _desc;
	self.hasAutoId := _hasAutoId;
	self.notAvailForEntry := _nafe;
	self.direction := _direction;
	
	self.myTerminal := _term;
	
	self.allStopsToApply.clear();
	if _stopsApply &lt;&gt; null then
		_stopsApply.copy(self.allStopsToApply);
	endif;
	
	self.allStopsToClear.clear();
	if _stopClear &lt;&gt; null then
		_stopClear.copy(self.allStopsToClear);
	endif;
	
	self.allNextDocumentTypes.clear();
	if _nextCustDocType &lt;&gt; null then
		_nextCustDocType.copy(self.allNextDocumentTypes);
	endif;
	
	self.allCustomLicenses.clear();
	if _licenses &lt;&gt; null then
		_licenses.copy(self.allCustomLicenses);
	endif;
	
	//01/09/2023	navkc1	CR 59937 Task 59939
	self.allMandatoryFields.clear();
	if _mandatoryFields &lt;&gt; null then
		_mandatoryFields.copy(self.allMandatoryFields);
	endif;
	
	//05/09/2023	navkc1	CR 60156  Task 60157
	self.colour := _colour;
	
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_desc" type="String"/>
        <Parameter name="_direction" type="Integer"/>
        <Parameter name="_hasAutoId" type="Boolean"/>
        <Parameter name="_nafe" type="Boolean"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_nextCustDocType" type="CM_CustomDocumentTypeByCode"/>
