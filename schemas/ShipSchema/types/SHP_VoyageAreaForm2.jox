        <source>doPicStdS2PT2BClick() updating;
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		Port Side Standard Sequencing - Top To Bottom
//				Set the sequence numbers of the requests for the selected job in Port Side Standard Sequencing
