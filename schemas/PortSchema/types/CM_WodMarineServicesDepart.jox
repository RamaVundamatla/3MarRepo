    <JadeMethod name="actionForApproved" id="d16d7b30-7bc9-4933-b354-a865e45d26e5">
        <updating/>
        <source>actionForApproved(_voyage: CM_Voyage input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/07/2018	jlgdap1		Initial creation TFS 39741 PEL1 marine Service Timings Changes
// 04/12/2018	jlgdap1		TFS 42252 PEL1 Issues with voyages with no tug or pilot
//
vars
	wodMarineServiceDtl : CM_WodMarineServiceDetail;
	movement : HMS_VoyageMovement;
	serviceTimings : HMS_MarineServicesTimings;				// TFS 42252
begin
	inheritMethod(_voyage);
	
	//19 Sep 2018	NDL	TFS 40810
	movement :=_voyage.getMovementDeparture;
	if movement &lt;&gt; null then
		
		movement.populateFromWodMarineServDept( self );
		if self.requiredByDT.isValid then
			movement.setOccursOnDT(self.requiredByDT);
			_voyage.setDepartureDT(self.requiredByDT);	//26 Sep 2018	NDL	TFS 40810
		endif;
		if movement.myMarineServiceTimings = null then		// TFS 42252
			if movement.isTransient then					// TFS 42252
				create serviceTimings transient;			// TFS 42252
			else											// TFS 42252
				create serviceTimings persistent;			// TFS 42252
			endif;											// TFS 42252
			serviceTimings.setMyVoyageMovement(movement);	// TFS 42252
		endif;												// TFS 42252
		//16 Oct 2018	NDL	TFS 41412
		if movement.myMarineServiceTimings &lt;&gt; null then
			movement.myMarineServiceTimings.setMovementDateTimes( self.getOccursDT, false, true, false, false );	
		endif;
	endif;
	
	// set the Approved Date/Time for Pilot and Tug resources
	foreach wodMarineServiceDtl in self.allMarineServiceDetails do
		if wodMarineServiceDtl.myHMSResource.isResourceForClass(HMS_ResourceForPilot) 
		or wodMarineServiceDtl.myHMSResource.isResourceForClass(HMS_ResourceForTug) then
			wodMarineServiceDtl.doMarineServiceTimingsUpdate(false, false, true, false);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionForCancelled" id="e4ee2f0b-6301-4162-b307-cb1c1dd44345">
        <updating/>
        <source>actionForCancelled(_voyage: CM_Voyage input) updating;

vars
voyStatus : CM_VoyageStatus;
	movement	: HMS_VoyageMovement;
begin
	inheritMethod(_voyage);
	
	//01/10/2021	jlier1	TFS 51963 - changes voyage process
	voyStatus :=_voyage.myVoyageProcess.allStatusesById[Voyage_Status_DepServPending];
	
	_voyage.setStatusFromObject(voyStatus);
	
	//delete any resources on movement
	movement:=_voyage.getMovementDeparture;
	if movement &lt;&gt; null then
		movement.allResourceUsed.purge;
	endif;
end;
</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionForNotApproved" id="863d38c1-72f4-4b98-b246-6fa795dc6989">
        <source>actionForNotApproved(_voyage: CM_Voyage input);
/*
Purpose:	TFS 41539		
Date				Who			Reason
OCTOBER 2018		CNWAB1		Initial creation
*/

vars
	status : CM_VoyageStatus;
begin
	inheritMethod(_voyage);
	
	

	if _voyage.myVoyageProcess.isMTNWOProcess then	 //jlier1 TFS 51963 1/10/21
		status := app.myRoot.allVoyageStatuses[Voyage_Status_DepServRejected];	
	else
		return;
	endif;
		
	_voyage.setStatusFromObject(status);
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionItems" id="08bfd18c-f214-42a2-92e1-7b714c5232a5">
        <updating/>
        <source>actionItems(_woActionIF: CMIF_WorkOrderAction; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 August 2018	jlgndl1	Initial creation	TFS 39900

*/

vars

	voyageStatus : CM_VoyageStatus;
	movement : HMS_VoyageMovement;
	harbour : HMS_Harbour;
	voyage : CM_Voyage;
	resUsedAgent : CMIF_HMSResourceUsedProforma;
	pxyResource, realResource : HMS_ResourceUsed;
	obj : Object;
	
begin

	if canCreateResources( voyageStatus ) then
		harbour := self.getMyTerminal.myHarbour;
		voyage := self.getMyVoyageObject;
		if voyage &lt;&gt; null then
			movement := voyage.getMovementDeparture();
			if movement &lt;&gt; null then
				app.myUtilityCA.utlAddHMSResources(self.allMarineServiceDetails, voyageStatus, harbour, movement, _passport);

				// TFS 41411
				if _passport.noErrors then
					create resUsedAgent transient;
					resUsedAgent.initialise();
					resUsedAgent.dummyUpWharfDeparture(movement);
					
					foreach obj in resUsedAgent.allResUsed do
						pxyResource := obj.HMS_ResourceUsed;
						app.myUtilityCA.utlCreateHMSResourceUsed(movement, pxyResource, realResource, _passport);	
					
					endforeach;
				endif;

				self.createExtensionResource(); // TFS 42241
		
				if _passport.noErrors then
					self.setIsComplete;
				endif;	
				
				
			endif;
		endif;
		
		

	endif;
	
	if _passport.noErrors then // TFS 42161
		self.createWorkOrderTransaction(TRANS_TYPE_WO_MARINESERVICEDEP);		 // TFS 42161
	endif;

epilog

end;</source>
        <Parameter name="_woActionIF" type="CMIF_WorkOrderAction"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addMarineServiceDetail" id="c336ceab-8ead-4632-bc09-fc4c12e6c832">
        <source>addMarineServiceDetail(_marineDetail: CM_WodMarineServiceDetail input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 June 2018	jlger1	Initial creation

*/

vars

begin
	if _marineDetail = null then
		return;
	endif;
	
	if not self.allMarineServiceDetails.includes(_marineDetail) then
	
		self.allMarineServiceDetails.add(_marineDetail);
	endif;
epilog

end;</source>
        <Parameter name="_marineDetail" type="CM_WodMarineServiceDetail" usage="input"/>
    </JadeMethod>
    <JadeMethod name="canCancel" id="9393f1dc-1eb4-439e-91f0-96b86be9d07a">
        <source>canCancel(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 August 2018	jlger1	Initial creation

*/

vars
	voyage :CM_Voyage;
	movement : HMS_VoyageMovement;
begin
	voyage := self.getMyVoyageObject;
	if voyage = null then
		return false;
	endif;

	movement := voyage.getMovementDeparture();
	if movement = null then
		return false;
	endif;
	
	return movement.moveStatus &lt;&gt; MovementStatus_Actual;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canCreateResources" id="8c4e249b-84c1-44a7-857b-74daace9a771">
        <source>canCreateResources( _voyageStatus : CM_VoyageStatus output ): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 August 2018	jlgndl1	Initial creation	TFS 39900

*/

vars

	voyage : CM_Voyage;
	voyageProcess : CM_VoyageProcess;
	voyageStatus : CM_VoyageStatus;

begin

	if self.getMyParent &lt;&gt; null and self.getMyParent.taskStatus = WO_STATUS_APPROVED then
		voyage := self.getMyVoyageObject;
		if voyage &lt;&gt; null then
			voyageProcess := voyage.myVoyageProcess;
			if voyageProcess.isMTNWOProcess then //jlier1 TFS 51963 1/10/21
				voyageStatus := app.myRoot.allVoyageStatuses[Voyage_Status_DepServPending];
			endif;
			if voyageStatus &lt;&gt; null and not voyageStatus.allHMSResourcesApproval.isEmpty then
				_voyageStatus := voyageStatus;
				return true;
			endif;
		endif;
	endif;
	
	return inheritMethod( _voyageStatus );

epilog

end;</source>
        <Parameter name="_voyageStatus" type="CM_VoyageStatus" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createExtensionResource" id="d3fd9b45-1412-4cf0-8330-a3b8203bf320">
        <updating/>
        <source>createExtensionResource() updating;
/*
Purpose:	TFS 42241		
Date				Who			Reason
OCTOBER 2018		CNWAB1		Initial creation
*/


vars

	voyageStatus : CM_VoyageStatus;
	movement : HMS_VoyageMovement;
	harbour : HMS_Harbour;
	voyage : CM_Voyage;
	resUsedAgent : CMIF_HMSResourceUsedProforma;
	pxyResource, realResource : HMS_ResourceUsed;
	obj : Object;
	processHarbour : CM_ProcessHarbour;
	hasExtension : Boolean;
	workorder : CM_WorkOrder;
	wod : CM_WorkOrderDtl;
	totalExtension, imsrETMAL : Integer;
	
	fromTS, toTS : TimeStamp;
	imsr : CM_WodMarineServicesInitial;
begin
	harbour := self.getMyTerminal.myHarbour;
	
	if harbour = null then
		return;
	endif;
	voyage := self.getMyVoyageObject;
	
	if voyage = null then
		return;
	endif;
	
	processHarbour := harbour.allProcessHarbours.getAtKey( voyage.myVoyageProcess, harbour );
	
	if processHarbour= null then
		return;
	endif;
	
	if processHarbour.myHMSResourceForExtension = null then
		return;
	endif;
	
	foreach workorder in voyage.allWorkOrders	discreteLock do : extenloop
		foreach wod in workorder.allWoDtls	discreteLock do
			if wod.detailType = WO_TASK_EXTENSION then
				hasExtension := true;
				break extenloop;
			endif;
		endforeach;
	endforeach;
	
	if not hasExtension then
		return; // no extensions then nothing to do
	endif;
	
	// ### We want to create a resource used to charge for the extension, but only for the actual extension time, not what was requested in the ETMALs
	//			So use the IMSR to work out the original departure TS, before any extensions, and use that anfd the current departure TS to set the from/to TS on the RES USED.
	
	imsr := voyage.getWorkOrderForIMSR();
	if imsr &lt;&gt; null then
		imsrETMAL := (imsr.getCurrentLengthOfTime() * 1440).Integer; // IMSR ETMAL in minutes
		fromTS := voyage.arrivedDT.addMinutes(imsrETMAL); // Original Departure TS
		toTS := voyage.departedDT; // Current Departure TS
	

	endif;
	
	// ### Create the Res Used for the Extension
	movement := voyage.getMovementDeparture();
	if movement &lt;&gt; null then
				create pxyResource transient;
				pxyResource.setProxy(harbour,processHarbour.myHMSResourceForExtension.myResourceType,
													processHarbour.myHMSResourceForExtension,null,
													fromTS,
													toTS,
													0,false,null,null); // pass in ZERO units then it will work it out based on the calc type
				app.myUtilityCA.utlCreateHMSResourceUsed(movement, pxyResource, realResource, app.myPassport);	
	endif;


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="createPxyHMSResourceProformas" id="917c90f4-69c0-488d-9478-217547ee8c26">
        <source>createPxyHMSResourceProformas(_hmsUsed : HMS_ResourceUsedSet input; _movement : HMS_VoyageMovement input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2018	jlgab1	Initial creation

*/

vars
	detail : CM_WodMarineServiceDetail;
	used : HMS_ResourceUsed;
	tmpRes : HMS_Resource;
	pxyResUsed : HMS_ResourceUsed;
	berth : HMS_Berth;
begin
	foreach detail in self.allMarineServiceDetails	discreteLock do
		used := detail.createPxyHMSResourceProforma(_movement);
		
		if used&lt;&gt; null then
			_hmsUsed.add(used);
		endif;
		
	endforeach;
	
	/* TFS 39738
	// TFS 39721
	berth := _movement.getMyBerth();
	if berth &lt;&gt; null then
		
		tmpRes := berth.myWharf.getResourceForHarbourMovement(HMSMovementTypeDeparture,HMS_Wharf.First_Resource);
		if tmpRes &lt;&gt; null then
			create pxyResUsed transient;
			pxyResUsed.setProxy(_movement.myHarbour, tmpRes.myResourceType,tmpRes, null, _movement.occursOnDTNEW, _movement.occursOnDTNEW, 1, false);
			pxyResUsed.setMyVoyageMovement(_movement);
			_hmsUsed.add(pxyResUsed);
		endif;
		
		tmpRes := berth.myWharf.getResourceForHarbourMovement(HMSMovementTypeDeparture,HMS_Wharf.Second_Resource);
		if tmpRes &lt;&gt; null then
			create pxyResUsed transient;
			pxyResUsed.setProxy(_movement.myHarbour, tmpRes.myResourceType,tmpRes, null, _movement.occursOnDTNEW, _movement.occursOnDTNEW, 1, false);
			pxyResUsed.setMyVoyageMovement(_movement);
			_hmsUsed.add(pxyResUsed);
		endif;
	endif;
	*/
epilog

end;</source>
        <Parameter name="_hmsUsed" type="HMS_ResourceUsedSet" usage="input"/>
        <Parameter name="_movement" type="HMS_VoyageMovement" usage="input"/>
    </JadeMethod>
