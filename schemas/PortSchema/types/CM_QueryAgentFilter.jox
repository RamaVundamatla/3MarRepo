    <JadeMethod name="qryCashCredits" id="2b14cd02-e3ec-41ea-a7c0-9ac6e341c0a8">
        <updating/>
        <source>qryCashCredits(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
// CCMS 2348 Financial Reporting
vars
	numSelected			: Integer;
	jrwCash				: CM_JRWCashTransactions;
	cashFilter			: CMQF_CashCredit;
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	cashFilter := _filter.CMQF_CashCredit;
	jrwCash := self.createJRWTransient(CM_JRWCashTransactions).CM_JRWCashTransactions;
	
	jrwCash.allCashCredits.clear();
	_filter.filterObjects(jrwCash.allCashCredits, _passport);
	
	jrwCash.setAllTerminals(cashFilter.allTerminals);
	cashFilter.allDebtors.copy(jrwCash.allDebtors);
	jrwCash.baseDate		:= cashFilter.baseDate;
	jrwCash.ageType			:= cashFilter.ageType;
	jrwCash.myVoyage		:= cashFilter.getMyVoyage;
	jrwCash.billOfLading	:= cashFilter.billOfLading;
	jrwCash.cashReceiptNumber := cashFilter.cashReceiptNumber;
	jrwCash.customsEntryNumber := cashFilter.customsEntryNumber;
	jrwCash.cargoId			:= cashFilter.cargoId;
	
	jrwCash.fromDate 		:= cashFilter.startDate;
	jrwCash.toDate			:= cashFilter.endDate;
	
	numSelected := jrwCash.allCashCredits.size;
	
epilog
	
	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
