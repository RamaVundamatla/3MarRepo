    <JadeMethod name="updateStartToFinishTons" id="5c803c62-affb-45a7-abcb-bed91a2822d7">
        <source>updateStartToFinishTons(_bargeUnloadDetail : CMIF_ASPABargeUnloadsDetail io;
						 _tonsCur : Decimal;
						 _tonsMTD : Decimal;
						 _tonsYTD : Decimal);
/*

Purpose: Barge Unload Tons from Start Operation to Finish Operation

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2019	jlgdi1	Initial creation
10 Sep 2019	jlgsl4	TFS 46513 - ASPA - Load/Unload Summary Report errors
*/

begin
	if _bargeUnloadDetail = null then // --&gt; TFS 46513 - don't use _bargeUnloadDetail if null
		return;
	endif; // &lt;-- TFS 46513
	_bargeUnloadDetail.siteCURAveStartFinishTons := _bargeUnloadDetail.siteCURAveStartFinishTons + _tonsCur;
	_bargeUnloadDetail.siteMTDAveStartFinishTons := _bargeUnloadDetail.siteMTDAveStartFinishTons + _tonsMTD;
	_bargeUnloadDetail.siteYTDAveStartFinishTons := _bargeUnloadDetail.siteYTDAveStartFinishTons + _tonsYTD;
end;</source>
        <Parameter name="_bargeUnloadDetail" type="CMIF_ASPABargeUnloadsDetail" usage="io"/>
        <Parameter name="_tonsCur" type="Decimal"/>
        <Parameter name="_tonsMTD" type="Decimal"/>
        <Parameter name="_tonsYTD" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="updateUnloadsBetweenEvents" id="2828fab1-966d-450b-9b31-414d6b0e38c0">
        <source>updateUnloadsBetweenEvents(_fromEventTrans : CM_EventTransaction;
						   _toEventTrans : CM_EventTransaction;
						   _workPoint : CM_WorkPoint;
						   _bargeUnloadDetail : CMIF_ASPABargeUnloadsDetail io;
						   _runDate : TimeStamp);
/*

Purpose:

Parameters:			

Return Value:		

Date		Who		TFS		Reason
19 Aug 2019	jlgdi1	45678	Initial creation

*/

vars
	fromDT : TimeStamp;
	toDT : TimeStamp;
	unloadHrs : Decimal[23,2];
	delayDuration : Decimal[23,2];
	unloadHrsLessDelay : Decimal[23,2];
	
begin
	fromDT :=_fromEventTrans.dateTime;
	toDT := _toEventTrans.dateTime;

	unloadHrs := self.getHoursDuration(fromDT, toDT);
	delayDuration := self.getTotalDelays(_workPoint, fromDT, toDT);
	unloadHrsLessDelay := unloadHrs - delayDuration;

	// Start to Finish
	if (self.myEventStart &lt;&gt; null) and (self.myEventFinish &lt;&gt; null) then 
		if (_fromEventTrans.myEventType = self.myEventStart) and 
		   (_toEventTrans.myEventType = self.myEventFinish)
		then 
			self.updateStartToFinishHours(_bargeUnloadDetail,
										  toDT,
										  _runDate,
										  unloadHrsLessDelay);
			
			return;
		endif;
	endif;
	
	// Arrive to Start Operation
	if (self.myEventStart &lt;&gt; null) then 
		if (_fromEventTrans.type = EVT_VoyageArrival) and 
		   (_toEventTrans.myEventType = self.myEventStart)
		then 
			self.updateArriveToStartHours(_bargeUnloadDetail,
										  toDT,
										  _runDate,
										  unloadHrsLessDelay);
			
			return;
		endif;	
	endif;
	
	// Arrive to Place
	if (self.myEventPlaced &lt;&gt; null) then 
		if (_fromEventTrans.type = EVT_VoyageArrival) and 
		   (_toEventTrans.myEventType = self.myEventPlaced)
		then 
			self.updateArriveToPlaceHours(_bargeUnloadDetail,
										  toDT,
										  _runDate,
										  unloadHrsLessDelay);
			
			return;
		endif;	
	endif;
	
	// Place to Pull
	if (self.myEventPlaced &lt;&gt; null) and (self.myEventPulled &lt;&gt; null) then 
		if (_fromEventTrans.myEventType = self.myEventPlaced) and 
		   (_toEventTrans.myEventType = self.myEventPulled)
		then 
			self.updatePlaceToPullHours(_bargeUnloadDetail,
										  toDT,
										  _runDate,
										  unloadHrsLessDelay);
			
			return;
		endif;
	endif;
end;</source>
        <Parameter name="_fromEventTrans" type="CM_EventTransaction"/>
        <Parameter name="_toEventTrans" type="CM_EventTransaction"/>
        <Parameter name="_workPoint" type="CM_WorkPoint"/>
        <Parameter name="_bargeUnloadDetail" type="CMIF_ASPABargeUnloadsDetail" usage="io"/>
        <Parameter name="_runDate" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="updateUnloadsBySite" id="55a547b5-6d3f-4797-ac81-15b7562bd4ea">
        <source>updateUnloadsBySite(_workPoint : CM_WorkPoint; 
					_voyage : CM_Voyage);
/*

Purpose: Report Details 3 - Barges Unloaded By Site column 

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2019	jlgdi1	Initial creation

*/

vars
	bargeUnloadDetail : CMIF_ASPABargeUnloadsDetail;
	iter : Iterator;
	found : Boolean;
	runDate : TimeStamp;
	unloadHrs : Decimal[23,2];
	delayDuration : Decimal[23,2];
	unloadHrsLessDelay : Decimal[23,2];
	workPointCode : String;
	tonsCur : Decimal[23,2];
	tonsMTD : Decimal[23,2];
	tonsYTD : Decimal[23,2];
	transDateTime : TimeStamp;
	
	arrivedEventType : CM_EventType;
	
	startOperationEventTrans : CM_EventTransaction;
	finishOperationEventTrans : CM_EventTransaction;
	arrivedEventTrans : CM_EventTransaction;
	placedEventTrans : CM_EventTransaction;
	pulledEventTrans : CM_EventTransaction;
	
	startOperationDT : TimeStamp;
	finishOperationDT : TimeStamp;
	
begin
	runDate := self.getRunDateTime();
	iter := self.allASPABargeUnloadDetails.createIterator();
	self.allASPABargeUnloadDetails.startKeyGeq(UnloadingBySite, "", iter);
	workPointCode := _workPoint.code;
	while iter.next(bargeUnloadDetail) do
		if bargeUnloadDetail.type &lt;&gt; UnloadingBySite then 
			break;
		endif;
		
		if bargeUnloadDetail.siteWorkPointCode = workPointCode then 
			found := true;
		endif;
	endwhile;
	
	if not found then 
		create bargeUnloadDetail transient;
		bargeUnloadDetail.type := UnloadingBySite;
		bargeUnloadDetail.siteWorkPointCode := _workPoint.code;
		bargeUnloadDetail.setMyBargeUnloadHeader(self);
	endif;
	
	// get Event Transactions
	// Start Voyage Operation
	if (self.myEventStart &lt;&gt; null) and (_voyage.hasEventOfType(self.myEventStart)) then
		startOperationEventTrans := self.getEventTransactionByType(_voyage, self.myEventStart.type);
	endif;
	
	// Finish Voyage Operation
	if (self.myEventFinish &lt;&gt; null) and (_voyage.hasEventOfType(self.myEventFinish)) then
		finishOperationEventTrans := self.getEventTransactionByType(_voyage, self.myEventFinish.type);
	endif;
	
	arrivedEventType := app.myRoot.allEventTypesByType[EVT_VoyageArrival];
	// Arrived 
	if _voyage.hasEventOfType(arrivedEventType) then
		arrivedEventTrans := self.getEventTransactionByType(_voyage, EVT_VoyageArrival);
	endif;
	
	// Placed
	if (self.myEventPlaced &lt;&gt; null) and (_voyage.hasEventOfType(self.myEventPlaced)) then
		placedEventTrans := self.getEventTransactionByType(_voyage, self.myEventPlaced.type);
	endif;
	
	// Pulled
	if (self.myEventPulled &lt;&gt; null) and (_voyage.hasEventOfType(self.myEventPulled)) then
		pulledEventTrans := self.getEventTransactionByType(_voyage, self.myEventPulled.type);
	endif;
	
	// 1. Barge Unload Count - Start to Finish
	// 2. Barge Unload Hour - Start To Finish
	// 3. Barge Unload TONS - Start to Finish	
	if (startOperationEventTrans &lt;&gt; null) and (finishOperationEventTrans &lt;&gt; null) then 
		startOperationDT := startOperationEventTrans.dateTime;
		finishOperationDT := finishOperationEventTrans.dateTime;
	
		// Barge Unload Count - Start to Finish
		self.updateStartToFinishCounts(bargeUnloadDetail,
									   finishOperationDT,
									   runDate);
		
		// Barge Unload Hour - Start To Finish
		self.updateUnloadsBetweenEvents(startOperationEventTrans,
										finishOperationEventTrans,
										_workPoint,
										bargeUnloadDetail,
										runDate);
		
		// Barge Unload TONS - Start to Finish
		tonsCur := 0.0;
		tonsMTD := 0.0;
		tonsYTD := 0.0;
		self.getUnloadTonsPerHour(_voyage, 
								  startOperationDT, 
								  finishOperationDT,
								  runDate,
								  tonsCur,
								  tonsMTD,
								  tonsYTD);
		self.updateStartToFinishTons(bargeUnloadDetail,
									 tonsCur,
									 tonsMTD,
									 tonsYTD);
									 
									 
	endif;
	
	// Barge Unload Hours - Arrive to Start Operation
	if (arrivedEventTrans &lt;&gt; null) and (startOperationEventTrans &lt;&gt; null) then 
		self.updateUnloadsBetweenEvents(arrivedEventTrans,
										startOperationEventTrans,
										_workPoint,
										bargeUnloadDetail,
										runDate);
	endif;
	
	// Barge Unload Hours - Arrive to Place
	if (arrivedEventTrans &lt;&gt; null) and (placedEventTrans &lt;&gt; null) then 
		self.updateUnloadsBetweenEvents(arrivedEventTrans,
										placedEventTrans,
										_workPoint,
										bargeUnloadDetail,
										runDate);
	endif;

	// Barge Unload Hours - Place to Pulled
	if (placedEventTrans &lt;&gt; null) and (pulledEventTrans &lt;&gt; null) then 		
		self.updateUnloadsBetweenEvents(placedEventTrans,
										pulledEventTrans,
										_workPoint,
										bargeUnloadDetail,
										runDate);
	endif;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_workPoint" type="CM_WorkPoint"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="withinCurrent" id="37121d62-4e7e-41ba-9717-a5c09dab88ed">
        <source>withinCurrent(_eventDateTime : TimeStamp; _runDate : TimeStamp) : Boolean;
/*

Purpose: Returns True if the event date time falls with 24 hours
		 otherwise returns FALSE

Parameters:			

Return Value:		

Date		Who		TFS		Reason
16 Aug 2019	jlgdi1	45678	Initial creation

*/

vars
	prev24Hours : TimeStamp;
	
begin
	prev24Hours := self.getPrev24Hrs(_runDate);
	return (_eventDateTime &gt;= prev24Hours) and (_eventDateTime &lt;= _runDate);
end;</source>
        <Parameter name="_eventDateTime" type="TimeStamp"/>
        <Parameter name="_runDate" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="withinMTD" id="bf0143b8-2d7c-4ba5-8621-3e31516a0fda">
        <source>withinMTD(_eventDateTime : TimeStamp; _runDate : TimeStamp) : Boolean;
/*

Purpose: Returns TRUE if event date time is within 1st day of run date through to run date
		 otherwise returns FALSE
		 
Parameters:			

Return Value:		

Date		Who		TFS		Reason
16 Aug 2019	jlgdi1	45678	Initial creation

*/

vars
	firstDayOfMonth : TimeStamp;
	
begin
	firstDayOfMonth := self.getMonthToDate(_runDate);
	return (_eventDateTime &gt;= firstDayOfMonth) and (_eventDateTime &lt;= _runDate);
end;</source>
        <Parameter name="_eventDateTime" type="TimeStamp"/>
        <Parameter name="_runDate" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="withinYTD" id="89c60a68-6fc2-4130-bfe4-6c23e0a7c464">
        <source>withinYTD(_eventDateTime : TimeStamp; _runDate : TimeStamp) : Boolean;
/*

Purpose: Returns TRUE if the event date time falls within 1st October previous year to run date
		 otherwise returns FALSE

Parameters:			

Return Value:		

Date		Who		TFS		Reason
16 Aug 2019	jlgdi1	45678	Initial creation

*/

vars
	octoberFirstLastYear : TimeStamp;
	
begin
	octoberFirstLastYear := self.getYearToDate(_runDate);
	return (_eventDateTime &gt;= octoberFirstLastYear) and (_eventDateTime &lt;= _runDate);
end;</source>
        <Parameter name="_eventDateTime" type="TimeStamp"/>
        <Parameter name="_runDate" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
