    <JadeMethod name="updateAvailableForUnload" id="3571469c-08e6-4137-9e97-5e0b8357b2e2">
        <source>updateAvailableForUnload(_cargo : CM_TrackedItem);
/*

Purpose: Report Detail # 2 - Barge Currently Available for Unloading per shiop operator

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2019	jlgdi1	Initial creation

*/

vars
	runDate : TimeStamp;
	shipOperator : String;
	cargoType : String;
	cargoSubType : String;
	iter : Iterator;
	bargeUnloadDetail : CMIF_ASPABargeUnloadsDetail;
	found : Boolean;
	
begin
	runDate := self.getRunDateTime();
	shipOperator := _cargo.operatorCode;
	cargoType := _cargo.cargoTypeCode;
	cargoSubType := _cargo.getCargoSubTypeCode();
	
	iter := self.allASPABargeUnloadDetails.createIterator();
	self.allASPABargeUnloadDetails.startKeyGeq(CurrentlyAvailable, "", iter);
	while iter.next(bargeUnloadDetail) do
		if bargeUnloadDetail.type &lt;&gt; BargeUnload then 
			break;
		endif;
		
		// ship operator, cargo type, cargo sub type
		if (bargeUnloadDetail.availOperatorCode = shipOperator) and 
		   (bargeUnloadDetail.availCargoTypeCode = cargoType) and 
		   (bargeUnloadDetail.availCargoSubTypeCode = cargoSubType)
		then 
			found := true;
		endif;
	endwhile;
	
	if not found then 
		create bargeUnloadDetail transient;
		bargeUnloadDetail.type := CurrentlyAvailable;
		bargeUnloadDetail.availOperatorCode := shipOperator;
		bargeUnloadDetail.availCargoTypeCode := cargoType;
		bargeUnloadDetail.availCargoSubTypeCode := cargoSubType;
		bargeUnloadDetail.setMyBargeUnloadHeader(self);
	endif;
	
	bargeUnloadDetail.availTotalBarges := bargeUnloadDetail.availTotalBarges + IncrementByOne;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_cargo" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="updateBargeUnloads" id="9e803848-86d6-45ec-ba7a-555a2c3a6978">
        <source>updateBargeUnloads(_eventTransaction : CM_EventTransaction);
/*

Purpose: Report Detail # 1 - Barge Unloads

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2019	jlgdi1	Initial creation

*/

vars
	bargeUnloadDetail : CMIF_ASPABargeUnloadsDetail;
	iter : Iterator;
	found : Boolean;
	runDate : TimeStamp;
	
begin
	runDate := self.getRunDateTime();
	iter := self.allASPABargeUnloadDetails.createIterator();
	self.allASPABargeUnloadDetails.startKeyGeq(BargeUnload, "", iter);
	
	while iter.next(bargeUnloadDetail) do
		if bargeUnloadDetail.type &lt;&gt; BargeUnload then 
			break;
		endif;
		
		if (bargeUnloadDetail.totalEventType.type = _eventTransaction.type) then 
			found := true;
			break;
		endif;
	endwhile;
	
	if not found then 
		create bargeUnloadDetail transient;
		bargeUnloadDetail.type := BargeUnload;
		bargeUnloadDetail.totalEventType := _eventTransaction.myEventType;
		bargeUnloadDetail.totalEventCode := _eventTransaction.myEventType.name;
		bargeUnloadDetail.setMyBargeUnloadHeader(self);
	endif;
	
	if withinCurrent(_eventTransaction.dateTime, runDate) then 
		bargeUnloadDetail.totalBargesCUR := bargeUnloadDetail.totalBargesCUR + IncrementByOne;
	endif;
	if withinMTD(_eventTransaction.dateTime, runDate) then 
		bargeUnloadDetail.totalBargesMTD := bargeUnloadDetail.totalBargesMTD + IncrementByOne;
	endif;
	if withinYTD(_eventTransaction.dateTime, runDate) then 
		bargeUnloadDetail.totalBargesYTD := bargeUnloadDetail.totalBargesYTD + IncrementByOne;
	endif;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_eventTransaction" type="CM_EventTransaction"/>
    </JadeMethod>
