    <JadeMethod name="actionForCancelled" id="e2e661ec-7d8e-4086-8f75-6c31e92670e0">
        <updating/>
        <source>actionForCancelled(_voyage: CM_Voyage input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 August 2018	jlger1	Initial creation

*/

vars
	allTIs : CM_TISet;
	workOrder : CM_WorkOrderVoyage;
	ti : CM_TrackedItem;
	job : CM_Job;
begin
	
	//epr TFS 42055 23/11/18		
	workOrder:= self.getMyParent.CM_WorkOrderVoyage;
	
	if workOrder = null then
		return;
	endif;
	
	create allTIs transient;
	
	workOrder.getAllTIs(allTIs);
	
	//should only be one that has a link
	ti :=allTIs.first;
	if ti = null then
		return;
	endif;
	
	if ti.isPreNote or ti.isOnShip then
		//delete and delete the job first;
		if ti.isExport then
			job:=ti.allJobsShipRelease.first;
		else
			job:=ti.allJobsShipReceive.first;
		endif;
		
		if job &lt;&gt; null and job.isKindOf(CM_VoyageHoldJob) then
			//
			app.myUtilityDA.utlDeleteJob(job,app.myPassport);
		endif;
		
		app.myUtilityDA.utlDeleteTI(ti,false,app.myPassport);
	endif;
	
epilog
	delete allTIs;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
    </JadeMethod>
    <JadeMethod name="actionItems" id="9d68c042-6e33-43b9-9ff4-5550dc840454">
        <updating/>
        <source>actionItems(_woActionIF: CMIF_WorkOrderAction; _passport: CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 25/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
// 14/06/2018	jlgdap1		TFS 39165 PEL1 Voyage Work order Transactions
// 19/06/2018	jlgdap1		TFS 38560 PEL1 Voyage Work Orders fix ups
// 19 Dec 2018	NDL			TFS Protect against deleted Workpoint object
// 01 Sep 2022  navmv20		ChangeRequest 54610: MTN - Auto Cargo Id New Options
// 08 Feb 2023  navma1 		ChangeRequest 56457: EUP - Allowing different sets of cargo items per work order task [Refactor]
// 10 Apr 2025	navdap1		MTN-14781 CPL | Increase BOL Field Length
vars
	prenote : CMIF_PreNote;
	prenoteArray : CMIF_TIObjectArray;
	cargo : CM_TrackedItem;
	pxyJob, newHoldJob : CM_VoyageHoldJob;
	voyage : CM_Voyage;
	jobType : Integer;
	jobNum : String;
	jobSheet : CM_VoyageJobSheet;
	pxyJobParams : CMIF_VoyageJobParams;
	pxyWLE : CM_VoyageWLE;
	pxyWLEs : CM_WLEArray;
	pxyShift : CM_Shift;
	movement : HMS_VoyageMovement;
	harbour : HMS_Harbour;
	voyageStatus : CM_VoyageStatus;
	bank : CM_Bank;	//18 Oct 2018	NDL	TFS 41375

begin
		
	voyage := self.getMyVoyageObject(); // TFS 39236 
	
	create prenoteArray transient;
	// create a prenote or a cargo on ship, depending on imex status
	if self.imexStatus = TI_IMEX_STATUS_EXPORT then
		create prenote as CMIF_PreNote transient;
	else
		create prenote as CMIF_OnshipCargo transient;
	endif;
	
	//prenote.id := self.getMyTerminal.generateNextCargoId(false, false);   // 1 Sept 2022 navmv20 TFS 54610
	prenote.id := self.getMyTerminal.generateNextCargoId(false, false,null); //1 Sept 2022 navmv20 TFS 54610
	if self.myCargoType = null then
		return;
		
		
	endif;
	prenote.cargoType := self.myCargoType.id;
	if self.myCargoSubType &lt;&gt; null then
		prenote.myProduct := self.myCargoSubType;
	endif;
	if self.myCommodity &lt;&gt; null then
		prenote.commodity := self.myCommodity.code;
	endif;
	create cargo as self.myCargoType.myClassToCreate transient;
	cargo.setCargoType(prenote.cargoType);
	prenote.setMyProxyTrackedItem(cargo);
	
	//prenote.id := self.getMyTerminal.
	prenote.weightTotal := self.totalWeight;
	if self.myCargoType.useTareCargoWeight then
		prenote.weightCargo := self.weightCargo;
		prenote.weightTare := self.weightTare;
	endif;
	
	prenote.volumeTotal := self.totalVolume;
	if self.myCargoType.isBulkByQuantity then
		//TFS 39236 prenote.quantity := self.totalQuantity;
		prenote.numberOfItems := self.totalQuantity; //TFS 39236
	endif;
	
	if self.myLocationsController &lt;&gt; null then
		prenote.stowageLocation := self.myLocationsController.getID;
	endif;
	prenote.imExStatus := app.myRoot.allImexStatuses[self.imexStatus];
	prenote.voyageCode := voyage.code; // TFS 39236 .getMyVoyageObject.code;
	if self.myOperator &lt;&gt; null then
		prenote.operatorCode := self.myOperator.code;
	endif;
	if self.dischargePort &lt;&gt; "-1" then
		prenote.dischargePort := self.dischargePort;
	endif;
	//epr tfs  40812 18/9/18
	prenote.loadPort:=self.loadPort;
	prenote.billOfLading := self.bolNumber[1:35]; //20 May 2019	NDL	TFS 44735	// MTN-14781
	
	if self.myConsignee &lt;&gt; null then
		prenote.consigneeCode := self.myConsignee.code;
	endif;
	if self.myConsignor &lt;&gt; null then
		prenote.consignorCode := self.myConsignor.code;
	endif;
	if self.myFreightForwarder &lt;&gt; null then
		prenote.freightForwarderCode := self.myFreightForwarder.code;
	endif;
	if prenote.isKindOf(CMIF_OnshipCargo) then
		prenote.transportMode := BR_TYPE_SHIP_STR;
	else
		prenote.transportMode := BR_TYPE_ROAD_STR;
	endif;
	prenote.specialStow := self.specialStow; //07 Sep 2018	NDL	TFS 40699
	prenote.receiptTransportMode := app.transModeToCode(prenote.transportMode);
	prenote.myTerminal := self.getMyTerminal;
	prenote.setTrackedItemData(null, cargo, _passport);
	prenoteArray.add(prenote);
	_passport.setWarningsIgnored(true);
	_passport.setWarningsAcknowledged(true);
	
	app.myValCA.valPreNotes(prenoteArray, _passport);
	if _passport.hasErrors() then
		return;
	endif;
	app.setContinueCMExceptions(true);
	
	app.myUtilityCA.utlCreatePreNotes(prenoteArray, false, _passport);
	
	if _passport.noErrors then // TFS 39236
		cargo := prenote.getMyTI();
		cargo.setCompanyOid(voyage.myDischargeCompany); // TFS 39236
		
		//18 Oct 2018	NDL	TFS 41375
		bank := app.myPassport.myTerminal.getCargoBusUnit( cargo );
		if bank &lt;&gt; null and bank &lt;&gt; cargo.companyOid then
			cargo.setCompanyOid(bank);	
		endif;
		
		//18 Oct 2018	NDL	TFS 41463
		if app.isInProformaMode then
			cargo.setTransferTypeFromWODummy( self.transferType );
		endif;
		
		self.getMyParent.addTrackedItem(cargo,self.getMyParent.allWoDtls.first); // TFS 39236	//08.02.2023 navma1 #56457 Task#56458
		
		self.myTrackedItem := cargo; // TFS 42221
		self.setTaskID( cargo.id); // TFS 42221 19DEC18  //jlier1 29/5/25 MTN-34591 
		self.createCargoTransaction(cargo); // TFS 42221
	endif;
	
	// If there is a workpoint, create a voyage hold job for the cargo
	if _passport.noErrors 
	and self.getMyWorkPoint &lt;&gt; null 
	and not app.isInProformaMode then // TFS 39236
		jobSheet := voyage.allJobSheets[self.getMyWorkPoint.code];
		if self.imexStatus = TI_IMEX_STATUS_EXPORT then
			jobType := JOB_TYPE_LOAD;
		else
			jobType := JOB_TYPE_DISCHARGE;
		endif;
		create pxyJob transient;
		pxyJob.setProxyVoyage(voyage);
		jobNum := voyage.getNextJobNumber(jobSheet, self.getMyWorkPoint);
		pxyJob.setProxy(jobNum, jobType);
		pxyJob.setProxyVoyageHoldJob(self.getMyWorkPoint.code, jobNum, null, null, false, jobType, null, null, voyage.arrivedDT,
								voyage.departedDT, false, null, null, null,self.estimatedStartTS,self.estimatedEndTS);
		pxyJob.setTransferType(self.transferType);
		pxyJob.setNumOfGangs(self.numGangs);
		
		create pxyJobParams transient;
		if jobType = JOB_TYPE_LOAD then
			pxyJobParams.myLocation := self.myLocationsController;
		endif;
		pxyJobParams.myVoyage := voyage;
		pxyJobParams.myProxyJob := pxyJob;
		pxyJobParams.myWorkPoint := self.getMyWorkPoint;
		if self.getMyWorkPoint &lt;&gt; null then
			pxyJobParams.craneID := self.getMyWorkPoint.code;
		endif;
		pxyJobParams.transitStatus := TI_TransitStatusNull;
		pxyJobParams.isDischarge := jobType = JOB_TYPE_DISCHARGE;
		
		cargo := prenote.getMyTI();
		if jobType = JOB_TYPE_LOAD then
			pxyJob.allReleaseTrackeditems.add(cargo);
		else
			pxyJob.allReceiveTrackedItems.add(cargo);
		endif;
		create pxyWLE transient;
		create pxyWLEs transient;
		pxyWLE.setMyTrackedItem(cargo);
		if cargo.isBulkByQuantity then
			pxyWLE.setQuantity(prenote.numberOfItems);
		endif;
		if cargo.isBulkByVolume or cargo.isBulkByWeight then
			pxyWLE.setWeight(prenote.weightTotal);
		endif;
		pxyWLEs.add(pxyWLE);
		create pxyShift transient;
		
		if self.estimatedStartTS.isValid then
			pxyShift.startDateTime := self.estimatedStartTS;
		else
			pxyShift.startDateTime := voyage.arrivedDT;
		endif;
		
		if self.estimatedEndTS.isValid then
			pxyShift.endDateTime := self.estimatedEndTS;
		else
			pxyShift.endDateTime := voyage.departedDT;
		endif;
		
		pxyShift.setProxy(null, voyage.arrivedDT.time, voyage.departedDT.time,voyage.code &amp; Space &amp;  pxyJob.id, voyage.code &amp; Space &amp; pxyJob.id, voyage.myTerminal, false);
		pxyJob.setMyShift(pxyShift);
		app.myUtilityCA.utlCreateVoyageHoldJob(pxyJobParams, newHoldJob, _passport, pxyWLEs);
	endif;
	
	//20 Aug 2018	NDL	TFS 40127
	if _passport.noErrors then
		movement := voyage.getMovementArrival();
		if movement &lt;&gt; null then
			if canCreateResources( voyageStatus ) then
				harbour := self.getMyTerminal.myHarbour;
				app.myUtilityCA.utlAddHMSResources(self.allMarineServiceDetails, voyageStatus, harbour, movement, _passport);	
			endif;
		endif;
	endif;
	
	if _passport.noErrors 
	and not app.isInProformaMode then // TFS 39236
		// epr TFS 41310 15/10/18
		
		self.isComplete:=true;
		//jlier1 29/5/25 MTN-34591 
		self.causeTerminalEvent(Event_WODtl_Update);
		if self.myParent &lt;&gt; null then	// ### JIRA: MTN-36931 08Jan2026 NAVPW1	
			self.myParent.causeTerminalEvent(Event_WorkOrder_Update);
		endif;							// ### JIRA: MTN-36931 08Jan2026 NAVPW1
	endif;
	
epilog
	delete prenoteArray;
	delete prenote;
	if pxyWLEs &lt;&gt; null then
		pxyWLEs.purge;
	endif;
	delete pxyWLEs;
	delete pxyShift;
	delete pxyJobParams;
	delete pxyJob;
end;</source>
        <Parameter name="_woActionIF" type="CMIF_WorkOrderAction"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="canAccessConsigneeConsignor" id="86493d63-49d0-47b8-bca1-1248d14a981f">
        <source>canAccessConsigneeConsignor(_user : CM_User): Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/12/2018	jlgdap1		Initial creation TFS 42219 PEL1 Consignee Access Issues
// 19/12/2018	jlgdap1		TFS 42542 PEL1 Freight Forwarder Access and Visibility
// 2/04/2019 	JLGNS1		Bug 44164: PEL1 - Null reference exceptions on PELP system from CM_WodCargoRequest
//
vars
	failedDAC : CM_DataAccessController;

begin
	on Exception do app.handleDeletedObjectReferences(exception ,self);

	if self.myConsignee &lt;&gt; null and self.myConsignee.canUserAccessSelf(_user, failedDAC, app.myPassport) then
		return true;
	endif;
	if self.myConsignor &lt;&gt; null and self.myConsignor.canUserAccessSelf(_user, failedDAC, app.myPassport) then
		return true;
	endif;
	if self.myFreightForwarder &lt;&gt; null and self.myFreightForwarder.canUserAccessSelf(_user, failedDAC, app.myPassport) then		// TFS 42542
		return true;																											// TFS 42542
	endif;																														// TFS 42542
	
	return false;
epilog
	
end;</source>
        <Parameter name="_user" type="CM_User"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canAccessOnWeb" id="391ebae6-0829-450d-b39e-d28b7cdb1f7b">
        <source>canAccessOnWeb(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 January 2020	jlger1	Initial creation 48179

*/

vars
	failedDAC       : CM_DataAccessController;
begin
	if not inheritMethod() then
		return false;
	endif;
	
	
	if not self.myOperator.canUserAccessSelf(app.getMyUser, failedDAC, app.myPassport) then
		return false;
	endif;
				
	if not app.getMyUser.getUserIsFreightForwarder then
		
		if self.myConsignee &lt;&gt; null then
			if not self.myConsignee.canUserAccessSelf(app.getMyUser, failedDAC, app.myPassport) then
				return false;
			endif;
		endif;
		
		if self.myConsignor &lt;&gt; null then
			if not self.myConsignor.canUserAccessSelf(app.getMyUser, failedDAC, app.myPassport) then
				return false;
			endif;
		endif;
	endif;
	
	
	if self.myFreightForwarder &lt;&gt; null then																
		if not self.myFreightForwarder.canUserAccessSelf(app.getMyUser, failedDAC, app.myPassport) then	
			return false;																								
		endif;																										
	else																											
		// if cargo rwequest has no freight forwarder, and the user is marked as a freight forwarder user,			
		// they have no access to this cargo request																
		if app.getMyUser.getUserIsFreightForwarder then																
			return false;																								
		endif;																										
	endif;		
	
	
	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canCancel" id="fbcd9050-1a32-44e0-8f9c-233699a0b49f">
        <source>canCancel(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2018	jlger1	Initial creation

*/

vars
	allTIs : CM_TISet;
	workOrder : CM_WorkOrderVoyage;
	ti : CM_TrackedItem;
	job : CM_Job;
	voyage : CM_Voyage;
	imsr : CM_WodMarineServicesInitial;
begin
	
	//epr TFS 42055 23/11/18	
	workOrder:= self.getMyParent.CM_WorkOrderVoyage;
	
	if workOrder = null then
		return false;
	endif;
	
	//02 Nov 2018	NDL	TFS 41694
	if workOrder.hasBeenApproved then
		voyage := self.getMyVoyageObject;
		if voyage &lt;&gt; null then
			imsr := voyage.getWorkOrderForIMSR();
			if imsr &lt;&gt; null then
				return false;
			endif;
		endif;
	endif;
	
	create allTIs transient;
	
	workOrder.getAllTIs(allTIs);
	
	//should only be one that has a link
	ti :=allTIs.first;
	if ti = null then
		return true;
	endif;
	
	if ti.isPreNote or ti.isOnShip then
		if ti.isExport then
			job:=ti.allJobsShipRelease.first;
		else
			job:=ti.allJobsShipReceive.first;
		endif;
		if job = null then
			return true;
		endif;
		if job.status = JOB_UNACTIONED then
			return true;
		endif;
	endif;
	return false;
epilog
	delete allTIs;
end;	</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canCreateResources" id="6beee97f-c2fd-4db3-a4c5-685994a10fb3">
        <source>canCreateResources(_voyageStatus: CM_VoyageStatus output): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 August 2018	jlgndl1	Initial creation	TFS 40127

*/

vars

	voyage : CM_Voyage;
	voyageProcess : CM_VoyageProcess;
	voyageStatus : CM_VoyageStatus;

begin

	if self.getMyParent &lt;&gt; null and self.getMyParent.taskStatus = WO_STATUS_APPROVED then
		voyage := self.getMyVoyageObject;
		if voyage &lt;&gt; null then
			voyageProcess := voyage.myVoyageProcess;
			if voyageProcess.isMTNWOProcess then //jlier1 TFS 51963 1/10/21
				voyageStatus := app.myRoot.allVoyageStatuses[Voyage_Status_CargoReqPending];
			endif;
			if voyageStatus &lt;&gt; null and not voyageStatus.allHMSResourcesApproval.isEmpty then
				_voyageStatus := voyageStatus;
				return true;
			endif;
		endif;
	endif;
	
	return inheritMethod( _voyageStatus );

epilog

end;</source>
        <Parameter name="_voyageStatus" type="CM_VoyageStatus" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="creatPxyTisForProFormaWO" id="03404c42-dd74-441b-a04f-a64ef6e75dd4">
        <updating/>
        <source>creatPxyTisForProFormaWO() updating;
/*

Purpose:			

Parameters:			Original callers responsibility to purge the transient contents after use,

Return Value:		

Date		Who		Reason
27 June 2018	jlgndl1	Initial creation	TFS 39246

*/

vars

	term : CM_Terminal;
	voyage : CM_Voyage;
	pxyTi : CM_TrackedItem;

	woActionIF : CMIF_WorkOrderAction;

begin
	
	// The proforma TRX will abort transaction after the invoice lines have been created and cloned to transients.
	/*  epr TFS 41310 15/10/18
	if self.myVoyageCargoRequest = null then
	if self.permitType &lt;&gt; INV_WO_PERMIT_CARGOPENALTY 
	and self.permitType &lt;&gt; INV_WO_PERMIT_CARGONOPENALTY then
		return;
	endif;
	endif;*/
	create woActionIF transient;
	woActionIF.myWorkOrderDtl := self;
	
	
	// this call will create cargo based on the request and attach it to the work order
	// then the call in the TRX to _controller.myWorkOrder.getAllTIs( allTIs); will pick them up
	
	self.actionItems(woActionIF, app.myPassport);

epilog
	delete woActionIF;
end;</source>
    </JadeMethod>
    <JadeMethod name="createCargoTransaction" id="5e0a9333-a38b-4d89-8431-e6d0005cf9b4">
        <updating/>
        <source>createCargoTransaction(_ti : CM_TrackedItem input) updating;
/*
Purpose:	TFS 42221		
Date				Who			Reason
DECEMBER 2018		CNWAB1		Initial creation
*/

vars
	txnParams : CMIF_WorkOrderTransController;
begin
	if app.isInProformaMode then
		return;
	endif;
	
	if self.myPermitRequest = null then // not the initial cargo request
		return;
	endif;
	
	// Only for new cargo where there is a permit and it requires a penalty
	if not (self.myPermitRequest.permitType = INV_WO_PERMIT_CARGOPENALTY)  
	and not (self.myPermitRequest.permitType = INV_WO_PERMIT_CONTINUEPENALTY)  then
		return;
	endif;
	
	
	create txnParams transient;

	txnParams.type := TRANS_TYPE_WORKORDER_EXTRATI;
	txnParams.myWorkOrderDetail := self;
	
	_ti.createTransaction(txnParams, app.myPassport);


epilog
	delete txnParams;


end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createPxyHMSResourceProformas" id="86754f4b-5943-45ed-9329-6c3bcc8a2e8d">
        <source>createPxyHMSResourceProformas(_hmsUsed: HMS_ResourceUsedSet input; _movement: HMS_VoyageMovement input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 August 2018	jlgndl1	Initial creation	TFS 40127

*/

vars

	detail : CM_WodMarineServiceDetail;
	used : HMS_ResourceUsed;

begin

	foreach detail in self.allMarineServiceDetails	discreteLock do
		used := detail.createPxyHMSResourceProforma(_movement);
		
		if used&lt;&gt; null then
			_hmsUsed.add(used);
		endif;
		
	endforeach;

epilog

end;</source>
        <Parameter name="_hmsUsed" type="HMS_ResourceUsedSet" usage="input"/>
        <Parameter name="_movement" type="HMS_VoyageMovement" usage="input"/>
    </JadeMethod>
