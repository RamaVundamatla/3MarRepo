    <JadeMethod name="translateForm" id="5f424697-932a-4927-984c-8dc5d14735ab">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0015471, locale);
	btnCopyDeckLayer.translateCaption(Xlat_0015472, locale);
	btnCopyItemDim.translateCaption(Xlat_0015473, locale);
	btnCopyLayerItem.translateCaption(Xlat_0015474, locale);
	btnDltDeckLayer.translateCaption(Xlat_0015475, locale);
	btnDltItemDim.translateCaption(Xlat_0015476, locale);
	btnDltLayerItem.translateCaption(Xlat_0015477, locale);
	btnFillLayers.translateCaption(Xlat_0015478, locale);
	btnItemDimension.translateCaption(Xlat_0015479, locale);
	btnLayerItems.translateCaption(Xlat_0015480, locale);
	btnNewDeckLayer.translateCaption(Xlat_0015481, locale);
	btnNewItemDim.translateCaption(Xlat_0015482, locale);
	btnNewLayerItem.translateCaption(Xlat_0015483, locale);
	btnSaveDeckLayer.translateCaption(Xlat_0015484, locale);
	btnSaveItemDim.translateCaption(Xlat_0015485, locale);
	btnSaveLayerItem.translateCaption(Xlat_0015486, locale);
	grpItemDimension.translateCaption(Xlat_0015487, locale);
	grpLayerItems.translateCaption(Xlat_0015488, locale);
	grpLayers.translateCaption(Xlat_0015489, locale);
	lblItemCode.translateCaption(Xlat_0015490, locale);
	lblItemDesc.translateCaption(Xlat_0015491, locale);
	lblItemObject.translateCaption(Xlat_0015492, locale);
	lblItemRemarks.translateCaption(Xlat_0015493, locale);
	lblLayerCode.translateCaption(Xlat_0015494, locale);
	lblLayerDesc.translateCaption(Xlat_0015495, locale);
	lblLayerRemarks.translateCaption(Xlat_0015496, locale);
	lblLayerType.translateCaption(Xlat_0015497, locale);
	mnuContextMain.translateCaption(Xlat_0015498, locale);
	mnuInspect.translateCaption(Xlat_0015499, locale);
	mnuInspectDeck.translateCaption(Xlat_0015500, locale);
	mnuInspectItem.translateCaption(Xlat_0015501, locale);
	mnuInspectLayer.translateCaption(Xlat_0015502, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="txtItemCode_lostFocus" id="498ac9c2-2b87-44ba-80f3-bf7cff86ed03">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtItemCode_lostFocus(textbox: TextBox input) updating;
// ---------------------------------------------------------------------------
// Created:     05 April 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	idx : Integer;
	invalidItemLayout : Boolean;
begin
	on Exception do app.handleDeletedObject( exception, self.myCurrentProxyItemLayout, invalidItemLayout);//24/08/2011 cnwdz2 28017
	
	if self.myCurrentProxyItemLayout &lt;&gt; null then
		if textbox.text.trimBlanks() &lt;&gt; self.myCurrentProxyLayer.code then
			self.myCurrentProxyItemLayout.setProxyCode(textbox.text.trimBlanks());
			
			if self.tblLayerItems.findObjectInRow(self.myCurrentProxyItemLayout,idx) then
				self.tblLayerItems.accessCell(idx, 2).text := self.myCurrentProxyItemLayout.CM_DeckItemLayout.code;
			endif;
			
		endif;
	endif;
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
