    <JadeMethod name="doLoadSchedulaControl" id="be9d804a-43b1-4eac-9c21-ed2a9210a757">
        <updating/>
        <source>doLoadSchedulaControl() protected, updating;

// cnwdvb1 15 January 2003 
// Date			Who		Reason
// 24/07/2025	jlizm1	MTN 35372 Add table filter to auto schedule form
vars

	schedule		: CM_AutoSchedule;

begin

	if self.state &lt;&gt; State_View then
		if not app.msgBox('Do you wish to abort changes and refresh screen','?',MsgBox_Yes_No) = MsgBox_Return_Yes then
			return;
		endif;
		self.doCancel();
	endif;
	on Exception do xHandler(exception);
	schedule := self.getSelectedSchedule();
	if schedule &lt;&gt; null then
		self.selectedScheduleOid := schedule;
		self.schedula.loadAutoSchedule(schedule, false);
		self.multiSelectTasks.setSelected(schedule.allAutoTasks);
		self.multiSelectTasks.selectFirst(false);
		self.multiSelectTasks.filterLeftListBox();		
		self.multiSelectTasks.filterRightListBox();
//		self.changeButtonStates();
	endif;	
//	self.tblSchedules.setFocus();

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadSchedules" id="2906a56c-2e38-4d7a-a9fa-dea9e36f1bbc">
        <updating/>
        <source>doLoadSchedules() protected, updating;

// cnwdvb1 14 January 2003 
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 11/06/2025	navcs2	MTN-34987 MTN -  Disable SAP Integration
vars

	iter 			: Iterator;
	schedule		: CM_AutoSchedule;
	display			: String;
	row, actualRow	: Integer;
	int : Integer;
	tasksToAdd 		: CM_AutoTasksByReqTypeDescDict;						// 11/06/2025	navcs2	MTN-34987
	task 			: CM_AutoTask;											// 11/06/2025	navcs2	MTN-34987
begin
	create tasksToAdd transient;											// 11/06/2025	navcs2	MTN-34987			
	app.myRoot.allAutoTasks.copy(tasksToAdd);								// 11/06/2025	navcs2	MTN-34987
	task := tasksToAdd.getAtKey(BGP_SAPWSRequest.name, "SAP TPP MA");		// 11/06/2025	navcs2	MTN-34987
	if task &lt;&gt; null then													// 11/06/2025	navcs2	MTN-34987
		tasksToAdd.remove(task);											// 11/06/2025	navcs2	MTN-34987
	endif;																	// 11/06/2025	navcs2	MTN-34987
	
	task := tasksToAdd.getAtKey(BGP_SAPWSRequest.name, "KINERJA");			// 11/06/2025	navcs2	MTN-34987
	if task &lt;&gt; null then													// 11/06/2025	navcs2	MTN-34987
		tasksToAdd.remove(task);											// 11/06/2025	navcs2	MTN-34987
	endif;																	// 11/06/2025	navcs2	MTN-34987
	
	self.state := State_View;
	self.multiSelectTasks.setAvailable(tasksToAdd, true);					// 11/06/2025	navcs2	MTN-34987
	self.tblSchedules.rows := self.tblSchedules.fixedRows;
	iter := app.myRoot.allAutoSchedulesByStartTs.createIterator;
	while iter.next(schedule) do
		// 28218 CCMS 2120 Sep 2011 don't show invoice package schedules (handled elsewhere)
		//27 Jul 2021	NDL	TFS 50517
	//	if schedule.scheduleForInvoicePackage() then
	//		continue;
	//	endif;
		display := Tab &amp; schedule.description &amp; Tab &amp; schedule.getRunTs() &amp; Tab 
		&amp; schedule.getSelectionStateAsString() &amp; Tab &amp; schedule.allAutoTasks.size.String &amp; Tab &amp;
		schedule.getIsActiveString();
		actualRow := self.tblSchedules.addItem(display);
		self.tblSchedules.accessRow(actualRow).itemObject := schedule;
		self.tblSchedules.accessCell(actualRow, self.tblSchedules.fixedColumns + 1).picture := self.getPicture(schedule);
		if not global.isValidObject(self.selectedScheduleOid) then
			self.selectedScheduleOid := schedule;
		endif;
		if self.selectedScheduleOid = schedule then
			row := actualRow;
		endif;
	endwhile;
	
	//05 Apr 2019	NDL	TFS 44149
	foreach int in 1 to self.tblSchedules.columns do
		self.tblSchedules.cnAdjustColumnWidth(int);
	endforeach;
	self.splitter2.cnEcResizeContents();
	
	if row &gt; 1 and row &lt;= self.tblSchedules.rows then
		self.tblSchedules.row := row;
		self.tblSchedules.accessRow(row).selected := true;
		self.tblSchedules.click(self.tblSchedules);
		self.multiSelectTasks.selectFirst(false);
	else
		self.selectedScheduleOid := null;
		self.schedula.loadAutoSchedule(null, false);
		self.multiSelectTasks.readOnly := true;
	endif;
	
	self.tblSchedules.leftColumn := 1;
epilog
	delete iter;
	delete tasksToAdd;										// 11/06/2025	navcs2	MTN-34987			
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadTaskTable" id="5f59001b-eb6e-4c6c-873b-2517f6ebc5a8">
        <updating/>
        <source>doLoadTaskTable(_task : CM_AutoTask) protected, updating;
// cnwdvb1 16 January 2003 

// 06/08/2012	cnwcs5	par 30136 - EDI BGP split
// 09/11/2017	jlgns1	TFS 6960 QNS - Disk space issues and house keeping inside JMT
// 21/07/2023 	navhl20 ChangeRequest 58158: EUP | [Framework] - Delivery Dispatch Garbage Collection
// 28/04/2025	navmd1	MTN-34752 Add indicator to show number of Schedules a Task is used by
// 11 Aug 2025 	navhl20 Story MTN-35650: TPT | Uploading of Photos into MTN Production | 2 | Thin Client Changes
// 16 Sep 2025 	navhl20 Defect MTN-36050: The page goes blank after clicking on the Photo Checks on the Truck Unloader app
// 08 Oct 2025 	navhl20 Story MTN-36217: TPT | Enable Uploading of Photos into MTN Production
vars
	str, viewName, filePath, 
	ssDef, rowName		: String;			// par 30136 Aug 2012
	table				: CM_EntryTable;	// par 30136 Aug 2012
	view				: EntTableView;
	entTableRow			: EntTableRow;
	control				: Control;
	any					: Any;
	obj					: Object;
begin
	
	if _task = null then
		return;
	endif;

	app.mousePointer	:= MousePointer_HourGlass;	
	self.isNewTask 		:= false;
	viewName 			:= _task.getEntryTableViewName();
	
	if viewName = null then
		return;
	endif;	
	
	table := self.tblTaskCreation;
	
	table.showHideRowsByViewName(viewName, CM_EntryTable.ShowHideRows, false); 
	
	view := table.myEntTableDef.allEntTableViews[viewName];
	
	
	
	if not app.isDutyDocEnabled then	//25 Jul 2013	NDL	Par 31691
		table.hideRowByName(ETRow_BgpDutyDocuments, false);
	endif;
	if not app.isVehicleBookingEnabled then	//25 Jul 2013	NDL	Par 31691
		table.hideRowByName(ETRow_BgpAutoVehicleBookings, false);
	endif;
	
	if not app.isCargoGroupEnabled then
		table.hideRowByName(ETRow_ReleasedCargoGroups, false);	//22 Jun 2015	NDL Par 36338
	endif;
	
	if not app.myPassport.isVASEnabled then						//21.7.2023 navhl20 #58158
		table.hideRowByName(ETRow_WorkOrderJobSheets, false);
	endif;
	
	self.doLoadCombos();
	
	if view &lt;&gt; null then
		
		foreach entTableRow in view.allEntTableRows do
			rowName	:= entTableRow.name;
			
			if rowName = ETRow_BgpAutoLocation then
				self.myAssistant.comboBoxLCByType(self.cmbLocations, TA_TYPE_BULK, self.cmbTerminal.listObject.CM_Terminal);
				
			elseif _task.isKindOf(CM_AutoTaskKPISpaceUtilisation) then
				if rowName = ETRow_BgpTerminalAreas then
					self.doListBoxTermAreaBuild(_task.myTerminal);
					self.doSelectTerminalAreas(_task.CM_AutoTaskKPISpaceUtilisation.allQryTerminalAreas);
					self.lstTermArea.lostFocus(self.lstTermArea);
				endif;
				
				if rowName = ETRow_BgpCargoTypes then
					self.doListBoxCargoBuild();
					self.doSelectCargoTypes(_task.CM_AutoTaskKPISpaceUtilisation.allQryCargoTypes);
					self.lstCargoTypes.lostFocus(self.lstCargoTypes);
				endif;
			endif;
			
			if rowName = ETRow_ServerFilePath then
				filePath := table.getValueByName(ETRow_ServerFilePath).String;	
				
				table.setValueByName(ETRow_ServerFilePath, filePath);
			endif;
			
			if rowName = ETRow_CsvFileName then 				
				filePath 	:= table.getValueByName(ETRow_ServerFilePath).String;
				ssDef 		:= table.getValueByName(ETRow_BgpSnapShotDefinition).String;
				
				self.doCSVFilename(rowName, filePath , ssDef);
			endif;
			
			if rowName = ETRow_BgpEDIReprocessFiles then
				// need to clear this here because if edi data types collection is empty obj will be null
				// and we wont go into code below
				self.lstDataTypes.setAllToFalse; 
			endif;
			
			any := _task.getValueForRow(rowName, obj);
			
			if any = null then
				table.setValueByName(rowName, null);	// reset to null if it's null, #24990 15/07/2010
				continue;
			endif;
			
			if any.isKindOf(CM_ReportTemplateByNameDict) then
				table.setValueByName(rowName, any.CM_ReportTemplateByNameDict.getNames());
				
			elseif CM_AutoTaskEventDelete.hasInstance(_task) and rowName = ETRow_BgpAutoEventTypes then
				table.setValueByName(rowName, self.selectEventTypes(any.IntegerArray));
				
			elseif not table.userInputEnabled or obj = null then 
				table.setValueByName(rowName, any);	
			endif;

			if table.userInputEnabled or obj &lt;&gt; null then 
				if entTableRow.controlName &lt;&gt; null then
					control := self.getControl(entTableRow.controlName);
		
					if control &lt;&gt; null then
						if control.isKindOf(CMUI_ComboUser) then 
							control.CMUI_ComboUser.setObject(app.myRoot.allUsers[any.String]);
							
						elseif control.isKindOf(CMUI_ComboBoxObject) then
							control.CMUI_ComboBoxObject.setObject(obj);
							
						elseif control.isKindOf(CMUI_ComboBox) then
							control.CMUI_ComboBox.listIndex := control.CMUI_ComboBox.findString(1,any.String);

						elseif control.isKindOf(CMUI_ListTable) then
							if rowName = ETRow_BgpAutoReportNames then
								str := self.doLoadListTemplatesNew(any.CM_ReportTemplateByNameDict);
								
								table.setValueByName(rowName, str);
								
							elseif rowName = ETRow_BgpAutoRemoteTypes then
								self.doLoadListRemotes(any.String);
								
							elseif rowName = ETRow_BgpAutoEventTypes then
								str := self.selectEventTypes(any.IntegerArray);
							
							elseif rowName = ETRow_BgpEDIReprocessFiles then
								
								self.lstDataTypes.setSelected (obj.IntegerArray); 
								
								table.setValueByName (rowName, any.String);								
							endif;
						endif;
					endif;
				endif;
			endif;
			
			if rowName = ETRow_BgpAutoProduct then
				self.doSelectProduct();
			endif;
			
		endforeach;
	endif;
	
	//jlier1 TFS 53286 13/4/22
	if _task.isKindOf(CM_AutoTaskIFS) then
		self.cmbTerminal.click(self.cmbTerminal);	
		table.setRowReadOnly(ETRow_BgpExternalFinInterface);
		table.setRowReadOnly(ETRow_BgpAutoDirectoryPath);
	endif;
	
	
	table.adjustHeight(self.tblTaskDisplay.height);				//11.08.2025 navhl20 #35650
	
	// navmd1 MTN-34752 28/04/2025
	self.lblScheduleUsage.caption := app.getErrorString1(In_use_by_x_schedules, self.mySelectedAutoTask.allAutoSchedules.size.String);
	self.lblScheduleUsage.zOrder(10);
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
        <Parameter name="_task" type="CM_AutoTask"/>
    </JadeMethod>
    <JadeMethod name="doLoadTasks" id="31f06199-817c-4609-9796-db786233bf05">
        <source>doLoadTasks() protected;

// cnwdvb1 16 January 2003 
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars

	task	 	: CM_AutoTask;
	display		: String;
	iter		: Iterator;
	dyna		: DynaDictionary;
	cmif		: CMIF_ClassSorter;
	theClass	: Class;
	int: Integer;

begin

	create dyna transient;
	dyna.setMembership(CMIF_ClassSorter);
	dyna.addMemberKey('key', false,false);
	dyna.endKeys(true);
	iter := app.myRoot.allAutoTasks.createIterator;
	while iter.next(task) do
		// 28218 CCMS 2120 Oct 2011 don't show invoice package tasks (are internal)
		//27 Jul 2021	NDL	TFS 50517
	//	if task.taskForInvoicePackage() then
	//		continue;
	//	endif;
		create cmif transient;
		theClass := task.class;
		cmif.myClass := theClass;
		cmif.myTask := task;
		cmif.description := theClass.text.cnEcGetTagValueOfName('display');
		cmif.key := cmif.description[1:30];
		dyna.add(cmif);
	endwhile;

	delete iter;
	iter := dyna.createIterator();
	self.tblTaskDisplay.rows := self.tblTaskDisplay.fixedRows;
	while iter.next(cmif) do
		// Get display off class again as there is no limit to display.
		display := cmif.description &amp; Tab &amp; cmif.myTask.description;
		self.tblTaskDisplay.accessRow(self.tblTaskDisplay.addItem(display)).itemObject := cmif.myTask;
	endwhile;

	if self.selectedTaskRow &gt; self.tblTaskDisplay.fixedRows and self.selectedTaskRow &lt;= self.tblTaskDisplay.rows then
		self.tblTaskDisplay.row := self.selectedTaskRow;
		self.tblTaskDisplay.accessRow(self.selectedTaskRow).selected := true;
		self.tblTaskDisplay.click(self.tblTaskDisplay);
	endif;
	
	//08 Apr 2019	NDL	TFS 44149
	foreach int in 1 to self.tblTaskDisplay.columns do
		self.tblTaskDisplay.cnAdjustColumnWidth(int);
	endforeach;
	self.tblTaskDisplay.leftColumn := 1;
	
epilog

	if dyna &lt;&gt; null then
		dyna.purge;
	endif;
	delete iter;	
	delete dyna;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doNewSchedule" id="d3c66792-4a90-48a8-b995-2a26d0788c46">
        <updating/>
        <source>doNewSchedule() protected, updating;

// cnwdvb1 15 January 2003 

vars

	row : Integer;

begin

	delete self.myProxyAutoSchedule;
	create self.myProxyAutoSchedule transient;
	self.tblSchedules.findObjectInRow(self.selectedScheduleOid, row);
	if row &gt; self.tblSchedules.fixedRows then
		self.tblSchedules.accessRow(row).selected := false;
	endif;
	row := self.tblSchedules.addItem('...');
	self.tblSchedules.accessRow(row).selected := true;
	self.schedula.loadAutoSchedule(self.myProxyAutoSchedule, true);
	self.schedula.enabled := true;
	self.state := State_NewSchedule;
	self.multiSelectTasks.setSelected(null);
//	self.changeButtonStates();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doNewTask" id="16facb45-c69b-4d13-8796-277dc4ecabbe">
        <updating/>
        <source>doNewTask(_class : Class) protected, updating;
// cnwdvb1 16 January 2003 

// 06/08/2012	cnwcs5	par 30136 - EDI BGP Split
// 18 Aug 2022	 navrk21	 Bug 52517: MTN - Clear Files BGP task allows users to clear entire hard drive if misconfigured
// 20 Jan 2023	navmd1		TFS 55020 OAuth Email Enhancements - default max retries to 10
// 18 Sep 2025 	navhl20 	Defect MTN-36050: The page goes blank after clicking on the Photo Checks on the Truck Unloader app
// 08 Oct 2025 	navhl20 	Story MTN-36217: TPT | Enable Uploading of Photos into MTN Production
vars
	table				: CM_EntryTable;		// par 30136 Aug 2012
	task				: CM_AutoTask;
	viewName			: String;
	view				: EntTableView;
	entTableRow			: EntTableRow;
begin
	table			:= self.tblTaskCreation;	// par 30136 Aug 2012
	self.isNewTask 	:= true;
	
	delete self.myProxyAutoTask;
	
	if _class = null then
		table.setFocus();
		table.moveFirst();
		
		viewName := 'bgpAutoViewDefault';
		
		table.setValueByName(ETRow_BgpAutoTaskType, null);
		
		self.cmbTAType.listIndex := -1;
		
		table.enableRowByName(ETRow_BgpAutoTaskType);
	else
		create self.myProxyAutoTask as _class transient;
		
		viewName := self.myProxyAutoTask.getEntryTableViewName();
		
		if viewName = null then
			return;
		endif;
	endif;
	
	
	view := table.myEntTableDef.allEntTableViews[viewName];
	table.showHideRowsByViewName(viewName, CM_EntryTable.ShowHideRows, false); 
	table.adjustHeight(500);
	
	if view &lt;&gt; null then
		foreach entTableRow in view.allEntTableRows do
			if not entTableRow.name = ETRow_BgpAutoTaskType then
				table.setValueByName(entTableRow.name, null);
			endif;
			
			if entTableRow.name = ETRow_BgpAutoRemoteTypes then
				self.doLoadListRemotes(null);
			endif;
			
			if entTableRow.name = ETRow_BgpCargoTypes then
				self.doListBoxCargoBuild();
				table.accessRow(table.getRowByName(ETRow_BgpCargoTypes)).height := 100;
			endif;	
			
			if entTableRow.name = ETRow_BgpTerminalAreas then
				table.accessRow(table.getRowByName(ETRow_BgpTerminalAreas)).height := 100;
			endif;	
			
			if entTableRow.name = ETRow_BgpAutoUser then
				self.cmbUser.listIndex := -1;
			endif;
			
			if entTableRow.name = ETRow_BgpAutoLocation then
				self.cmbLocations.clear();
			endif;
					
			if entTableRow.name = ETRow_BgpEDIReprocessFiles then	// par 30136 Aug 2012
				self.lstDataTypes.setAllToFalse;					// par 30136 Aug 2012
			endif;													// par 30136 Aug 2012
			// Start 18.08.2022 navrk21 TFS 52517
			if  entTableRow.name = ETRow_BgpAutoDirectoryPath then
				table.setValueByName(entTableRow.name, "%MISCDIR%");
			endif;
			// End 18.08.2022 navrk21 TFS 52517
			
			if _class = CM_AutoTaskEmailRetry and entTableRow.name = ETRow_NumberOfRetries then
				table.setValueByName(entTableRow.name, 10.Integer);
			endif;
		endforeach;
	endif;
	
	//jlier1 TFS 53286 13/4/22
	if _class = CM_AutoTaskIFS then			
		table.setRowReadOnly(ETRow_BgpExternalFinInterface);
		table.setRowReadOnly(ETRow_BgpAutoDirectoryPath);
	endif;
	
	
	table.adjustHeight(1000);
	
	table.userInputEnabled := true;
	
	table.adjustHeight(self.tblTaskDisplay.height);					//18.09.2025 navhl20 #36050
end;</source>
        <access>protected</access>
        <Parameter name="_class" type="Class"/>
    </JadeMethod>
    <JadeMethod name="doProcessNow" id="a61dc5a2-557a-40db-bcfd-5d66360c9eb1">
        <updating/>
        <source>doProcessNow(_state : Integer) protected, updating;

// cnwdvb1 04 February 2003 
//
//27 May 2015	cnwrs1	Par 36285 Make the BGP Auto Schedule Form multiselect
vars
	showMessage	: Boolean;
	theReturn	: Integer;
	lastRun		: TimeStamp;
	lastRunOn,
	msg1,
	msg2		: String;
	schedule	: CM_AutoSchedule;
	task		: CM_AutoTask;
	obj : Object;
begin

	if self.state = State_View then
		if self.tblSchedules.allSelectedObjects.size &gt; 0 then
			foreach obj in self.tblSchedules.allSelectedObjects do
				schedule := obj.CM_AutoSchedule;
//				schedule := self.getSelectedSchedule();
				if schedule &lt;&gt; null then
					// Oct 2010 cnwjre1 CCMS 1043 ask for confirmation if snapshot invoicing will result
					if _state = CM_AutoSchedule.Make_Now then
						foreach task in schedule.allAutoTasks do
							if task.isKindOf(CM_AutoTaskSummarySnapShot) then
								if task.CM_AutoTaskSummarySnapShot.mySSDefinition.myBankToCharge &lt;&gt; null then
									showMessage := true;
									lastRun := task.CM_AutoTaskSummarySnapShot.mySSDefinition.lastRun;
									if lastRun = null then
										lastRunOn := "not run before";
									else
										lastRunOn := lastRun.Date.asStringJMT();
									endif;
									if msg1 = null then
										msg1 := task.description;
										msg2 := lastRunOn;
									else
										msg1 := msg1 &amp; ", " &amp; task.description;
										msg2 := msg2 &amp; ", " &amp; lastRunOn;
									endif;
								endif;
							endif;
						endforeach;
					endif;
					if showMessage then
						theReturn := app.msgBox("This will produce snapshot invoice lines from summaries " &amp; msg1 &amp; CrLf &amp; 
									"Last run on " &amp; msg2 &amp; CrLf &amp; "Do you want to continue?", 
								   "Snapshot Summary Invoicing Run", MsgBox_Yes_No + MsgBox_Question_Mark_Icon + MsgBox_Default_Second);
						if theReturn = MsgBox_Return_No then
							return;
						endif;
					endif;
					app.myTrxUA.trxUpdateAutoScheduleRunTs(schedule, _state, app.myPassport);	
				endif;
			endforeach;
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="d32e9b54-27a6-40b7-8d09-ca2e881a9ab4">
        <updating/>
        <source>doRefresh() protected, updating;

// cnwdvb1 15 January 2003
// Date			Who		Reason
// 25/07/2025	jlizm1	MTN 35372 Add table filter to auto schedule form

vars

begin
	inheritMethod();
	if self.state &lt;&gt; State_View then
		if not app.msgBox('Do you wish to abort changes and refresh screen','?',MsgBox_Yes_No) = MsgBox_Return_Yes then
			return;
		endif;
		self.doCancel();
		return;
	endif;
	self.doLoadSchedules();	
	self.changeButtonStates();
	self.frmTableFilter.doTableFilter();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="64e02c3f-7eb5-45a9-9710-242b6104904f">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     15 July 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	
	if self.fldSchedules.visible then
		self.fldSchedules.top 	:= self.frmToolbar.height;
	endif;
	inheritMethod();
	self.tblTaskCreation.adjustHeight(1000);

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="44327afd-64ae-4881-bd36-674ae2d52d9f">
        <updating/>
        <source>doSave() protected, updating;
// cnwdvb1 15 January 2003
// adm 300608 Par 16962
// 25/07/2025	jlizm1	MTN 35372 Add table filter to auto schedule form

vars
	realSchedule	: CM_AutoSchedule;
	isSuccess		: Boolean;
	result			: Integer;
begin

	app.mousePointer := MousePointer_HourGlass;	
	if self.state &lt;&gt; State_View then
		if self.schedula.doSave() then
			self.multiSelectTasks.clearRightFilter();
			self.getSelectedTasks();
			while true do
				if self.state = State_NewSchedule then
					app.myTrxCA.trxCreateAutoSchedule(self.myProxyAutoSchedule, realSchedule, app.myPassport);
				elseif self.state = State_EditSchedule then
					app.myTrxUA.trxUpdateAutoSchedule(self.myProxyAutoSchedule, app.myPassport);
				endif;
				if app.myPassport.trxCompletedOK then
					self.clearErrorWarnings();
					delete self.myProxyAutoSchedule;
					if realSchedule &lt;&gt; null then
						self.selectedScheduleOid := realSchedule;
					endif;
					self.doLoadSchedules();
					self.tblSchedules.setFocus();
					break;
				else
					result	:= app.showErrorWarningDialog('Auto Schedule', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and
					result = IDOK then
						// there must have just been warnings that the user has acknoledged so ..
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
					self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
					self.frmTableFilter.doTableFilter();
					return;
				endif;
			endwhile;
		endif;
	endif;
	
	self.frmTableFilter.doTableFilter();
	
epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSaveTask" id="28bfdb35-e8f2-4131-a8c9-25d93e6e5110">
        <updating/>
        <source>doSaveTask() protected, updating;
// cnwdvb1 16 January 2003 

// 06/08/2012	cnwcs5	par 30136 - EDI BGP split
// 03 Mar 2014	cnwrs1 par 33631 SFW 1373
// 13 Apr 2022 jlier1 	TFS 53286
// 25 Jul 2025	jlizm1	MTN 35372 Add table filter to auto schedule form
vars
	proxy				: CM_AutoTask;		// par 30136 Aug 2012
	table				: CM_EntryTable;	// par 30136 Aug 2012
	viewName			: String;
	view				: EntTableView;
	entTableRow			: EntTableRow;
	rowName				: String;			// par 30136  Aug 2012
	dataTypes			: IntegerArray;		// par 30136 Aug 2012
	realAutoTask		: CM_AutoTask;
	passport			: CM_Passport;		// par 30136 Aug 2012
	result				: Integer;
begin

	app.mousePointer := MousePointer_HourGlass;	
	
	proxy := self.myProxyAutoTask;
	
	if proxy = null then
		// By pass error form.
		return;
	endif;
	
	viewName := proxy.getEntryTableViewName();
	
	if viewName = null then
		return;
	endif;	
	
	table := self.tblTaskCreation;
	
	table.clearAllSelected();

	view := table.myEntTableDef.allEntTableViews[viewName];

	if view &lt;&gt; null then
		foreach entTableRow in view.allEntTableRows do
			rowName	:= entTableRow.name;	// par30136 Aug 2012
			
			if rowName = ETRow_ToDoTaskDesc then
				proxy.setValueForRow(rowName, self.cmbToDoTaskDesc.listObject);
				
			elseif rowName = ETRow_BgpAutoExtractDefs then
				proxy.setValueForRow(rowName, self.cmbDataExtract.listObject);
			elseif rowName = ETRow_BgpAutoEDIFTP then
				proxy.setValueForRow(rowName, self.cmbFTPEntity.listObject);
			elseif rowName = ETRow_BgpAutoTerminals then
				proxy.setValueForRow(rowName, self.cmbTerminal.listObject);
				
			elseif rowName = ETRow_BgpAutoUser then
				proxy.setValueForRow(rowName, self.cmbUser.listObject);
				
			elseif rowName = ETRow_BgpAutoReportNames then
				proxy.setValueForRow(rowName, self.listTemplates.allSelectedObjects);
				
			elseif rowName = ETRow_BgpAutoPackages then
				proxy.setValueForRow(rowName, self.cmbPackages.listObject);
				
				elseif rowName = ETRow_BgpAutoProduct then
				proxy.setValueForRow(rowName, self.cmbProduct.myObject);
				
			elseif rowName = ETRow_BgpAutoLocation then
				proxy.setValueForRow(rowName, self.cmbLocations.listObject);
				
			elseif rowName = ETRow_BgpAutoEventTypes then
				proxy.setValueForRow(rowName, self.lstTblEventTypes.allSelectedObjects);
				
			elseif rowName = ETRow_BgpCargoTypes then
				proxy.setValueForRow(rowName, self.lstCargoTypes.allSelectedObjects);
				
			elseif rowName = ETRow_BgpTerminalAreas then
				proxy.setValueForRow(rowName, self.lstTermArea.allSelectedObjects);
				
			elseif rowName = ETRow_BgpHarbours then
				proxy.setValueForRow(rowName,self.cmbHarbours.listObject);
				
			elseif rowName = ETRow_BgpAutoSelectorQuery then
				proxy.setValueForRow(rowName,self.cmbSelectorQuery.listObject);
				
			elseif rowName = ETRow_BgpSnapShotDefinition then
				proxy.setValueForRow(rowName,self.cmbSSDef.listObject);
				
			elseif rowName = ETRow_Period then	// 24016 add item selector and financial period
				proxy.setValueForRow(rowName, self.cmbFinancialPer.listObject);
				
			elseif rowName = ETRow_BgpEDIReprocessFiles then		// par 30136 Aug 2012
				create dataTypes transient;							// par 30136 Aug 2012
				
				self.lstDataTypes.getSelectedIntegers (dataTypes);	// par 30136 Aug 2012
				
				proxy.setValueForRow (rowName, dataTypes);			// par 30136 Aug 2012
			elseif rowName = ETRow_BgpBusinessUnit then
				proxy.setValueForRow( rowName, self.cmbBank.listObject);
			
			elseif rowName = ETRow_BgpExternalFinInterface then
				if  self.cmbTerminal.listObject &lt;&gt; null then
					proxy.setValueForRow( rowName,self.cmbTerminal.listObject.CM_Terminal.getConfig(FinancialIOClass).CM_ExtFinanceIO);
				endif;	
			elseif rowName = ETRow_BgpEmailGroup then
				proxy.setValueForRow( rowName, self.cmbEmailGroup.listObject);
			else
				proxy.setValueForRow(rowName, table.getValueByName(rowName));	
			endif;
		endforeach;
	endif;
	
	passport := app.myPassport;
	
	while true do
		if self.isNewTask then
			app.myTrxCA.trxCreateAutoTask(proxy, realAutoTask, passport);
		else
			app.myTrxUA.trxUpdateAutoTask(proxy, passport);
		endif;

		if passport.trxCompletedOK then
			self.clearErrorWarnings();
			
			delete self.myProxyAutoTask;	// make sure property vakue set to null
			
			self.doLoadSchedules();
			self.doLoadTasks();
			
			table.userInputEnabled := false;
			
			self.tblTaskDisplay.setFocus();
		else
			result := app.showErrorWarningDialog('Auto Task', passport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			
			if passport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				passport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
	self.frmTableFilter.doTableFilter();

epilog
	delete dataTypes;	// par 30136 Aug 2012
	
	app.mousePointer := MousePointer_Default;
end;</source>
        <access>protected</access>
    </JadeMethod>
