	self.statusMsg("Clearing Test Message results...");

	if lstResultMessage.listIndex &lt;&gt; CNEC_NULL_INDEX then
		testMessage	:=	lstResultMessage.listObject.CnEcWebTestMessage;

		if testMessage &lt;&gt; null then
			self.doClearTestResults(null, testMessage);
