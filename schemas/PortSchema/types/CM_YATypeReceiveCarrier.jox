    <JadeMethod name="getObjects" id="14f5b161-2827-4251-b438-1aee87c68c8a">
        <source>getObjects(objects: ObjectLongNameDict input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Apr 2024 navlc30 Bug 56071: PEN- VVR Package not sent

*/

vars
	carrier: CM_Carrier;
begin
	foreach carrier in app.myRoot.allCarriers do
		objects[carrier.getYAIdentifier] := carrier;
	endforeach;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
