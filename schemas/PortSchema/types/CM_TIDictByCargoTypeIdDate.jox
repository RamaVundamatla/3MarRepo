<CollClass name="CM_TIDictByCargoTypeIdDate" id="c9838ffe-9d41-4167-80a6-824112f58ae1">
    <memberType name="CM_TrackedItem"/>
    <superclass name="CM_TrackedItemDicts"/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <abstract/>
    <DbClassMap file="voyages"/>
    <JadeMethod name="lookupAllTIsUsingIdCargoType" id="fdd26693-23c5-410d-a630-691911c3ecd0">
        <source>lookupAllTIsUsingIdCargoType(pId: String; pCargoType: Integer; _set: CM_TISet input; _cmifMonitor : CMIF_Monitor input) : Boolean;
/*
 ------------------------------------------------------------------------
Created:			18 October 2002 by cnwdwq1
Purpose:			If cargoType = TI_CargoType_Null then return ALL LIKE TI with this id
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
14/07/2025	naviv1	35226	MTN - Usage of Iterator.getCurrentKeys  
---------------------------------------------------------------------------
*/
vars
	tmpTI	: CM_TrackedItem;
	iter	: Iterator;
	keyId	: String;
	keyType	: Integer;
	keyTime	: TimeStamp;
begin

	if _set = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'TISet', null, null);
		return false;
	endif;

	iter := self.createIterator;
	self.startKeyGeq(pCargoType, pId, null, iter);
	
	while iter.next(tmpTI) do
		if _cmifMonitor &lt;&gt; null then
			if (not self.checkProgress(_cmifMonitor)) then
				return false;
			endif;
		endif;
		iter.getCurrentKeys(keyType,keyId,keyTime); //MTN-35226
		if pCargoType &lt;&gt; null and keyType &lt;&gt; pCargoType then
			break;
		endif;
		if pId &lt;&gt; null and (not keyId.startsWith(pId)) then
			break;
		endif;
		_set.addNoDuplicates(tmpTI, false);
		if _cmifMonitor &lt;&gt; null then
			_cmifMonitor.numFound := _cmifMonitor.numFound + 1;
		endif;
	endwhile;
	
	return true;
epilog
	delete iter;
end;</source>
        <Parameter name="pId" type="String"/>
        <Parameter name="pCargoType" type="Integer"/>
        <Parameter name="_set" type="CM_TISet" usage="input"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="lookupTIUsingIdCargoType" id="3911025e-3af2-4474-8014-7c5587bca6c4">
        <source>lookupTIUsingIdCargoType(pId: String; pCargoType: Integer): CM_TrackedItem;
/*
 ------------------------------------------------------------------------
Created:			18 October 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	tmpTI	: CM_TrackedItem;
begin

	if pCargoType = TI_CargoType_Null then
		return null;
	endif;
	
	tmpTI := self.getAtKeyGeq( pCargoType, pId, null);
//not checking key
	if tmpTI = null then
		return null;	//Make it a bit obvious
	endif;
	if tmpTI.id = pId then
		return tmpTI;
	endif;
	return null;
end;</source>
        <Parameter name="pId" type="String"/>
        <Parameter name="pCargoType" type="Integer"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
</CollClass>
