    <JadeMethod name="setValueForRow" id="0447b160-3f93-40ce-aec5-7a5fb4163f76">
        <updating/>
        <source>setValueForRow(_rowName: String; _value: Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Jun 2018 cnwma1	ChangeRequest 38637: PEL1 - SAP Request Exchange Rate

*/

vars

begin
	if _rowName = ETRow_BgpFromCurrency then
		self.fromCurrency := _value.asString;
	elseif _rowName = ETRow_BgpToCurrency  then
		self.toCurrency := _value.asString;
	elseif _rowName = ETRow_BgpDaysLookback then
		self.daysLookback := _value.Integer;
	else
		inheritMethod(_rowName, _value);
	endif;	

epilog

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validate" id="47cd0c39-ba77-497f-b4f3-e04aafb503ca">
        <source>validate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Jun 2018 cnwma1	ChangeRequest 38637: PEL1 - SAP Request Exchange Rate

*/

vars

begin
	inheritMethod();
	if self.fromCurrency = null then
		app.raiseCMException(Input_required_field_fromCurr, ETRow_BgpFromCurrency, null); 
	endif;
	
	if self.toCurrency = null then
		app.raiseCMException(Input_required_field_toCurr, ETRow_BgpToCurrency, null); 
	endif;
	
epilog

end;</source>
    </JadeMethod>
