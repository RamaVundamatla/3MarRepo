    <JadeMethod name="getDisplayStringForAttribute" id="c39300ff-d2d2-41bb-99df-062d9c6a1de7">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2017	cnwndl1	Initial creation	TFS 3414

*/

vars

begin

	if _attrName = ETRow_HandlingType then
		if self.myHandlingType = null then
			return "&lt;Unknown&gt;";
		else
			return self.myHandlingType.description;
		endif;
	
	elseif _attrName = ETRow_IsAvailableForEntry then
		return (not self.isNotAvailableForEntry).getYes();
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getHandlingTypeDisplay" id="5d7d267d-1d92-4dd8-8671-29c2dfcbdcbc">
        <source>getHandlingTypeDisplay(_includeExtras : Boolean ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 April 2017	cnwndl1	Initial creation	TFS 3414

*/

vars

	str : String;

begin

	if self.myHandlingType &lt;&gt; null then
		str := self.myHandlingType.getHandlingTypeDisplay &amp; " / ";
	endif;
	
	if self.description.trimBlanks = null then
		str := str &amp; self.code;
	else
		str := str &amp; self.description;
	endif;
	
	return str;

epilog

end;</source>
        <Parameter name="_includeExtras" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
