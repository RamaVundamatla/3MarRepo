    <JadeMethod name="cloneForCopy" id="2073825d-00a1-45d3-a60f-8f3f1e6eabae">
        <source>cloneForCopy(_transient : Boolean; _validOnly : Boolean; _todayDate : Date; _copy : Boolean) : SelfType;
/*

Purpose:			

Parameters:			
			_validOnly : If this is true, then this method will only clone object that has "toTS" greater than _todayDate. Otherwise, clone everything.
			_copy: The invoice contract maintenance has a feature that will optionally update the toTS of all the details and rate entries with the same toTS as the contract. 
					Becasue of the date range checking, when the TRX for updating an invoice contract is in 'update toTS' mode we clone all the details as well as the contract so that the validation
					that checks the date range conflicts can occur correctly.
			
Return Value:		

Date		Who		Reason
21 February 2023	navkc1	Initial creation CR #55652 Task 55681: Jade - Contracts Copy TRX

*/

vars
	clonedDetails		: CM_InvoiceContractDetails;
	contractRate,
	clonedContractRate	: CM_InvoiceContractRate;
	allRates			: CM_InvoiceContractRateSet;
	newTS : TimeStamp;
	time : Time;
begin
	
	clonedDetails := self.cloneSelf(_transient);
	clonedDetails.myBusinessUnit := self.myBusinessUnit;
	clonedDetails.myCalculationType := self.myCalculationType;
	//31/01/2023	navkc1 Bug 61578, If copying into transient, user might want to edit the criteria, clone a copy of that into transient to allow that to happen
	if self.myInvoiceContractCriteria &lt;&gt; null then
		if _transient then
			clonedDetails.myInvoiceContractCriteria := self.myInvoiceContractCriteria.cloneForCopy(true);
		else
			clonedDetails.myInvoiceContractCriteria := self.myInvoiceContractCriteria;
		endif;
	endif;
	clonedDetails.myInvoiceLineType := self.myInvoiceLineType;
	clonedDetails.myShippingTerm := self.myShippingTerm;
	clonedDetails.myUnitOfMeasure := self.myUnitOfMeasure;
	
	 // ### BUG 56908 21MAR2023 NAVAB1 - UPDATE
	if not _copy 
	and clonedDetails.toTS = self.myInvoiceContract.toTS then // only set this on those that match the current end date.
		time.setTime(self.toTS.time.hour,self.toTS.time.minute,self.toTS.time.second,self.toTS.time.milliSecond);
		newTS.setDate(_todayDate);
		newTS.setTime(time);
		clonedDetails.toTS := newTS;
	endif;
	
	if self.allInvoiceContractRates.isEmpty() then
		return clonedDetails;
	endif;
	
	create allRates transient;
	
	self.allInvoiceContractRates.copy(allRates);
	
	foreach contractRate in allRates do
		clonedContractRate := contractRate.cloneForCopy(_transient, _validOnly, _todayDate);
		clonedContractRate.setMyInvoiceContractDetails(clonedDetails);
	endforeach;	
	
	return clonedDetails;
epilog
	delete allRates;
end;</source>
        <Parameter name="_transient" type="Boolean"/>
        <Parameter name="_validOnly" type="Boolean"/>
        <Parameter name="_todayDate" type="Date"/>
        <Parameter name="_copy" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="delete" id="2f90231a-b803-4e14-a434-eff2b6cf87d2">
        <updating/>
        <source>delete() updating;
/*
Purpose:		used for auditing 	

Date		Who		Reason
09 December 2022	navab1	TFS CR 55623 TASK 55785
*/

vars
	iter	: Iterator;
	cmqf	: CMQF_InvoiceContract;
begin
	
	iter := CMQF_InvoiceContract.instances.createIterator;
	while iter.next(cmqf) do
		if cmqf.allContractDetails.includes(self) then
			cmqf.allContractDetails.remove(self);
		endif;
	endwhile;
	
	self.resetAuditsDuringDelete();

epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="deleteClonedProxy" id="4c688b6b-e485-4043-af54-a8de8203f60f">
        <source>deleteClonedProxy();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 March 2023	navkc1	Initial creation CR #55652 Task 56286: UI - Contract Detail Copy TRX

*/

vars
	rate	: CM_InvoiceContractRate;
	
begin
	
	if not self.isTransient() then
		return;
	endif;
	
	foreach rate in self.allInvoiceContractRates do
		rate.allInvoiceContractRateEntries.purge();
	endforeach;
	
	self.allInvoiceContractRates.purge();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="02acf801-9323-4408-ba06-1dd9fd04cdf3">
        <source>getAuditText(): String;
/*
Purpose:			

Date		Who		Reason
09 December 2022	navab1	TFS CR 55623 TASK 55785
06 March 2023		navmk20	Bug 56944: EUP - criteria on a contract detail is not audited
*/

vars
	txt,
	tmpStr	: String;
	
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	
	// Start 6.3.2023 navmk20 TFS 56944
	if self.myInvoiceContractCriteria &lt;&gt; null then
		tmpStr := self.myInvoiceContractCriteria.getCriteriaSummary(",");
		if tmpStr &lt;&gt; null then
			txt := txt &amp;'All Criteria'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
		endif;
	endif;
	// End 6.3.2023 navmk20 TFS 56944
	
	tmpStr := null;
	if self.myCalculationType &lt;&gt; null then
		tmpStr :=self.myCalculationType.code;
		txt := txt &amp;'Calculation Type'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.myInvoiceLineType &lt;&gt; null then
		tmpStr :=self.myInvoiceLineType.narration;
		txt := txt &amp;'Invoice Line Type'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.myShippingTerm &lt;&gt; null then
		tmpStr :=self.myShippingTerm.code;
		txt := txt &amp;'Shipping Term'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.myUnitOfMeasure &lt;&gt; null then
		tmpStr :=self.myUnitOfMeasure.code;
		txt := txt &amp;'Unit Of Measure'&amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	return txt;	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
