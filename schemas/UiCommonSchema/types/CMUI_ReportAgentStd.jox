    <JadeMethod name="getSelectedToDoTaskDescs" id="00462f97-9d47-4c0f-b476-da5187309ca5">
        <source>getSelectedToDoTaskDescs( _todotaskDescArray : CM_ToDoTaskDescSet input )  ;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 October 2010	cnwndl1	Initial creation	Par 23800
14 Aug 2023 navhl20 ChangeRequest 59284:[59664] EUP | FR - VAS Work Order Transactions
*/

vars
	obj : Object;
begin
	if _todotaskDescArray = null then
		app.raiseCMException2( MethodWithNullParam, method.name, '_todotaskDescArray', null, null );
		return;
	endif;
	_todotaskDescArray.clear();
	
	if not self.isRowIncluded( ETRow_Tasks ) and not self.isRowIncluded( ETRow_TskType ) then				//14.8.2023 navhl20 #59284[59664]
		return;
	endif;
	
	foreach obj in self.myLstTblTasks.allSelectedObjects do 
		if not obj.isKindOf( CM_ToDoTaskDesc ) then
			continue;
		endif;
		_todotaskDescArray.add( obj.CM_ToDoTaskDesc );
	endforeach;

epilog

end;</source>
        <Parameter name="_todotaskDescArray" type="CM_ToDoTaskDescSet" usage="input"/>
    </JadeMethod>
