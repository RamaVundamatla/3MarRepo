    <JadeMethod name="setWeightNewLogs" id="ca9da985-96ae-479d-b7d9-035f9c7afb7d">
        <updating/>
        <source>setWeightNewLogs() updating, protected;
//--------------------------------------------------------------
//Created: 19 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	portionPerJas	: Real;
	newLog			: CMIF_LogRegrade;
begin

	//if self.myLog = null or self.myLog.weight &lt;= 0 or self.myLog.volume &lt;= 0 then				//-cnwml2 MSL CCMS 1017
	if self.myLog = null or self.myLog.totalWeight &lt;= 0 or self.myLog.getMyTotalVolume &lt;= 0 then			//+cnwml2 MSL CCMS 1017
		return;
	endif;
	//portionPerJas := self.myLog.weight/self.myLog.volume;					//-cnwml2 MSL CCMS 1017
	portionPerJas := self.myLog.totalWeight / self.myLog.getMyTotalVolume;			//+cnwml2 MSL CCMS 1017
	foreach newLog in self.allNewLogs do
		newLog.setWeight(portionPerJas);
	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="27cdc154-5aa4-45fb-995f-e0cf3eed2e69">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     16 May 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	inheritMethod();
	self.height := 650;  // ### TFS 50421 27OCT2021 NAVAB1 was 600;
	self.splitterFrame.height := 70;
	self.optSpecs.visible := false;
	
	//Par17237 hide the data selection table. --cnwdz2
	self.splitContainer.hideLeftControl(true);

		// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnSaveBase.enabled:= false;
		self.btnNextT.enabled:= false;
		self.btnAdd.enabled:= false;
		self.btnRemove.enabled:= false;
		self.btnUpdate.enabled:= false;
		self.tblNewLogDetail.userInputEnabled := false;
	endif;

end;</source>
    </JadeMethod>
