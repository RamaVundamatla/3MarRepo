    <JadeMethod name="getPlanQueTIsForValidateMove" id="93a94fce-a7e6-44ac-a841-df8c52366f1a">
        <source>getPlanQueTIsForValidateMove(_control : CMIF_MoveController input; _allTIs : CM_TIArray input);
//
//22 Nov 2016 cnwrs1	Par 37738 TFS 2949 incorrect UPSP rail location being displayed
//
vars
	ti : CM_TrackedItem;
	isROBorLoaded : Boolean;
	futureMove : CM_FutureMove;
begin
	//there is a config that says you can plan/queue cargo onto the wago if th cargo is already queued out 
	// this method gets the cargo that will actually be on the wagon
	
	if _control &lt;&gt; null and 
	   _control.moveMode &lt;&gt; REAL_MODE then 
		foreach futureMove in self.allPlannedFutureMoves do
//		foreach ti in self.allTrackedItems discreteLock do
			ti := futureMove.getTrackedItem;
			if ti &lt;&gt; null and
			   ti.myPrimaryQueuedLocation &lt;&gt; null then
//					isROBorLoaded := ti.isROB or not self.myWagon.allReportTIsInwards.includes(ti);  // it is a remain on board or was just loaded
//					if not isROBorLoaded then
				_allTIs.add(ti);
//					endif;
			endif;
		endforeach;
		foreach futureMove in self.allQueuedFutureMoves do
//		foreach ti in self.allTrackedItems discreteLock do
			ti := futureMove.getTrackedItem;
			if ti &lt;&gt; null and
			   ti.myPrimaryQueuedLocation &lt;&gt; null then
//					isROBorLoaded := ti.isROB or not self.myWagon.allReportTIsInwards.includes(ti);  // it is a remain on board or was just loaded
//					if not isROBorLoaded then
				if not _allTIs.includes(ti) then
					_allTIs.add(ti);
				endif;
			endif;
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_allTIs" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getProximity" id="5d7acf5d-286e-4738-8d86-bb8e11351a30">
        <source>getProximity(_otherLC: CM_WagonController; vertProx: Integer output; horzProx: Integer output; depthProx: Integer output);
/*
----------   ----------  --------------------------------------------------
Created:	27 November 2006 By cnwth2

Purpose:	vertical span = N/A (this would be rail lines apart if required, but unlikely)
			horizontal span = number of wagons apart
			depth span = N/A (and extremely unlikely to ever be needed) 

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	otherWagonPosition,
	selfWagonPosition 	: Integer;
	railLine			: CM_RailLine;
begin
	if self.myWagon = null then
		return;
	endif;
	
	railLine := self.myWagon.myRailLine;
	
	if railLine = null or _otherLC.myWagon = null or
	   (railLine &lt;&gt; _otherLC.myWagon.myRailLine) then
		return;
	endif;
	
	selfWagonPosition := railLine.allWagons.indexOf(self.myWagon);
	otherWagonPosition := railLine.allWagons.indexOf(_otherLC.myWagon);
	
	vertProx := (selfWagonPosition - otherWagonPosition).positive;
	
end;


</source>
        <Parameter name="_otherLC" type="CM_WagonController"/>
        <Parameter name="vertProx" type="Integer" usage="output"/>
        <Parameter name="horzProx" type="Integer" usage="output"/>
        <Parameter name="depthProx" type="Integer" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getQueueTasks" id="f0016e9f-3859-4285-b87d-3130569569c3">
        <source>getQueueTasks(arbiter: CM_RTQueueArbiter input; _isSource : Boolean);
//Returns the tasks required to do a unit of work. (move a TI)
//Called from the RTQueueArbiter.
vars
begin
	if myWagon = null then
		return;
	endif;
	
	// 27/09/2010 cnwmh5 #25808 - Start
	if _isSource then
		
			//------------
			//Get the TI to provide its "pickup tasks"
			//------------
			
			self.myWagon.getPickupTasks(arbiter);
		else
			//Target.
			//------------
			//Get the target to provide its "set-down tasks"
			//------------
			self.myWagon.getSetdownTasks(arbiter);
		endif;
		
	//------------------
	//Pass on to the wagon, thats where the TI really is!
	//------------------
	//self.myWagon.getQueueTasks(arbiter);
	// 27/09/2010 cnwmh5 #25808 - End
	
end;</source>
        <Parameter name="arbiter" type="CM_RTQueueArbiter" usage="input"/>
        <Parameter name="_isSource" type="Boolean"/>
    </JadeMethod>
