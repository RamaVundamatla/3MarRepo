    <JadeMethod name="doRefresh" id="2956b67b-c74d-4da6-a922-5b0016c03d90">
        <source>doRefresh() protected;
// --------------------------------------------------------------------------------
// Created:		29 June 2006 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
