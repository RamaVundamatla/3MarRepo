<Class name="WS_WorkListEntry" id="4cc5bf96-c958-4f7c-9b8e-9bd29480e119">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <PrimAttribute name="description" id="b1a7161d-4aa6-4069-8e9b-9ced6ad83b23">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="id" id="ff7ed4e7-dd30-418c-888e-0f1da455106f">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="plannedWarehouseArea" id="78b4d28a-d896-4dd7-afa5-171ce62e5cfd">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setProxyFromFM" id="ba48e2b5-7e87-446a-9ae6-0585fd6325cf">
        <updating/>
        <source>setProxyFromFM(_futureMove : CM_FutureMove input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Jul 2022	jlier1	Initial creation 53766
21 Nov 2024	navdap1	MTN-18821 EUP* | FR 53485 - Warehouse Yard Allocation - Mobile App location selection issues
*/

vars
	targetLocation : CM_LocationsController;
	 terminal : CM_Terminal;
begin
	if _futureMove = null then
		return;
	endif;
	
	if _futureMove.getPrimaryLocation = null then
		return;
	endif;
	targetLocation :=_futureMove.getPrimaryLocation;
	self.id :=targetLocation.getFullId();
	
	terminal := targetLocation.getMyTerminal;
	self.description:=self.id;
	
	// MTN-18821 start
	//if targetLocation &lt;&gt; null and targetLocation.isKindOf(CM_IrregularBlockController) and terminal.getAutoPlanAllowFullGCArea then
	//	self.plannedWarehouseArea:=targetLocation.getLocationArea();
	//endif;
	if _futureMove.isMoveToFullGCArea then
		self.plannedWarehouseArea := targetLocation.getLocationArea;
	endif;
	// MTN-18821 end
	
epilog

end;</source>
        <Parameter name="_futureMove" type="CM_FutureMove" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="c53057e9-0b83-4bd1-8e69-dab06aa7870f">
        <updating/>
        <source>setProxyFromObject( wle : CM_WorkListEntry) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 Jun 2022	jlier1	Initial creation 53766
21 Nov 2024 navdap1	MTN-18821 EUP* | FR 53485 - Warehouse Yard Allocation - Mobile App location selection issues
*/

vars
	targetLocation : CM_LocationsController;
	terminal  : CM_Terminal;
	foundHeight : Integer;
begin	
	if wle = null then
		return;
	endif;
	
	inheritMethod(wle);
	terminal:=wle.getMyTerminal;
	if wle.myFutureMove &lt;&gt; null and wle.myFutureMove.getPrimaryLocation &lt;&gt; null then
		self.id := wle.myFutureMove.getPrimaryLocation.getFullId();
		targetLocation :=wle.myFutureMove.getPrimaryLocation;
	elseif wle.status = WLE_PART_COMPLETE and wle.locationTarget &lt;&gt; null then
		self.id := wle.locationTarget;
		terminal.findLocationFromString(self.id,true,targetLocation,foundHeight);
	else
		return;
	endif;
	self.description:=self.id;
	if (wle.quantity &gt; 1) then
		if wle.isKindOf(CM_VoyageWLE) and wle.CM_VoyageWLE.subSeqNum &lt;&gt; null and wle.CM_VoyageWLE.subSeqNum &lt;&gt; wle.quantity then	// TFS 52360
			self.description := self.description &amp; " (" &amp; wle.CM_VoyageWLE.subSeqNum.asStringJMT &amp; ")";									// TFS 52360
		else																														// TFS 52360
			self.description  := self.description &amp; " (" &amp; wle.quantity.asStringJMT &amp; ")";
		endif;																														// TFS 52360
	endif;
	
	// MTN-18821 start
	//if targetLocation &lt;&gt; null and targetLocation.isKindOf(CM_IrregularBlockController) and terminal.getAutoPlanAllowFullGCArea then
	//	self.plannedWarehouseArea:=targetLocation.getLocationArea();
	//endif;
	if wle.myFutureMove &lt;&gt; null and wle.myFutureMove.isMoveToFullGCArea then
		self.plannedWarehouseArea:=targetLocation.getLocationArea();
	endif;
	// MTN-18821 end
epilog

end;</source>
        <Parameter name="wle" type="CM_WorkListEntry"/>
    </JadeMethod>
</Class>
