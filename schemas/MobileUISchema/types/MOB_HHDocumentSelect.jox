    <JadeMethod name="populateBookingItems" id="112aa80a-b31e-4ca2-9bb5-a7c5d5cb53f4">
        <source>populateBookingItems( _booking : CM_BookingRef; _bookingItem : CM_BookingRefItem );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 October 2016	cnwndl1	Initial creation	TFS 2655 / 2419

*/

vars

	iter : Iterator;
	bookRefItem : CM_BookingRefItem;
	docAction : CM_DocumentActions;
	index : Integer;
	includeNoDA : Boolean;

begin

	self.cmbBookingItems.clear();
	self.cmbBookingItems.sorted := true;
	self.cmbBookingItems.enabled := true;
	
	includeNoDA := app.myCurrentUserCan( self.myTerminal, PmAdmDocActionsView ) or app.myCurrentUserCan( self.myTerminal, PmAdmDocActionsMaint );
	
	if _booking &lt;&gt; null then
		iter := _booking.allBookingRefItems.createIterator;
	
		if not includeNoDA then
			while iter.next( bookRefItem ) do
				docAction := bookRefItem.myBookingRefItemActions;
				if docAction = null then
					continue;
				endif;
				if not docAction.hasActions then
					continue;
				endif;
				//index := self.cmbBookingItems.addItem( bookRefItem.getDisplayString &amp; " - " &amp; docAction.getThumbNailDisp );
				index := self.cmbBookingItems.addItem( docAction.getThumbNailDisp );	//13 Dec 2016	NDL	TFS 3111/2001
				self.cmbBookingItems.itemObject[index] := bookRefItem;
			endwhile;
		else
			while iter.next( bookRefItem ) do
				docAction := bookRefItem.myBookingRefItemActions;
				if docAction = null then
					index := self.cmbBookingItems.addItem( bookRefItem.getDisplayString );
					self.cmbBookingItems.itemObject[index] := bookRefItem;
				else
					//index := self.cmbBookingItems.addItem( bookRefItem.getDisplayString &amp; " - " &amp; docAction.getThumbNailDisp );
					index := self.cmbBookingItems.addItem( docAction.getThumbNailDisp );	//13 Dec 2016	NDL	TFS 3111/2001
					self.cmbBookingItems.itemObject[index] := bookRefItem;
				endif;
			endwhile;
		endif;
		
		if self.cmbBookingItems.listCount &lt; 1 then
			 self.cmbBookingItems.addItem( app.getErrorString(Booking_items_with_actions) );
			 self.cmbBookingItems.listIndex := 1;
			 self.resetButtons;
			 return;
		endif;
	
	endif;
	
	index := 0;
	if _bookingItem &lt;&gt; null then
		index := self.cmbBookingItems.findObject( _bookingItem );
	endif;
	
	if index &gt; 0 then
		self.cmbBookingItems.listIndex := index;
	elseif self.cmbBookingItems.listCount &gt; 1 then
		self.cmbBookingItems.sorted := false;
		self.cmbBookingItems.addItemAt( "&lt;" &amp; app.getErrorString(Please_select_booking_item) &amp; "&gt;", 1 );
		self.cmbBookingItems.listIndex := 1;
	elseif self.cmbBookingItems.listCount = 1 then
		self.cmbBookingItems.listIndex := 1;
	else
		self.cmbBookingItems.enabled := false;
	endif;
	
	self.resetButtons;

epilog

	delete iter;

end;</source>
        <Parameter name="_booking" type="CM_BookingRef"/>
        <Parameter name="_bookingItem" type="CM_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="populateBookings" id="2c9b2f59-d6b0-48fb-b1c7-da8c33c1b960">
        <source>populateBookings( _booking : CM_BookingRef; _bookingItem : CM_BookingRefItem );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 October 2016	cnwndl1	Initial creation	TFS 2655 / 2419

*/

vars

	startObject : CM_BookingRef;
	iter : Iterator;
	booking : CM_BookingRef;
	index : Integer;
	includeNoDA : Boolean;

begin

	self.cmbBookings.clear();
	self.cmbBookings.sorted := true;
	
	includeNoDA := app.myCurrentUserCan( self.myTerminal, PmAdmDocActionsView ) or app.myCurrentUserCan( self.myTerminal, PmAdmDocActionsMaint );

	iter := self.myTerminal.allBookingRefsByStatusRef.createIterator;
	startObject := self.myTerminal.allBookingRefsByStatusRef.getAtKeyGeq(1,null);
	if startObject &lt;&gt; null then
		iter.startAtObject( startObject );
		while iter.next( booking ) do
			if booking.status &lt;&gt; 1 then
				break;
			endif;
			if not includeNoDA and not booking.hasDocActions() then
				continue;
			endif;
			index := self.cmbBookings.addItem( booking.bookingReference );
			self.cmbBookings.itemObject[index] := booking;
		endwhile;
	endif;
	
	if self.cmbBookings.listCount &lt; 1 then
		self.cmbBookings.addItem( app.getErrorString(Booking_availab_with_actions ));
	else
		self.cmbBookings.sorted := false;
		self.cmbBookings.addItemAt( app.getErrorString(Please_select_booking), 1 );
	endif;
	
	self.cmbBookings.listIndex := 1;
	
	if _booking &lt;&gt; null then
		index := self.cmbBookings.findObject( _booking );
		if index &gt; 0 then
			self.cmbBookings.listIndex := index;
		endif;
	endif;
	
	booking := self.cmbBookings.listObject.CM_BookingRef;
	self.populateBookingItems( booking, _bookingItem );

epilog

end;</source>
        <Parameter name="_booking" type="CM_BookingRef"/>
        <Parameter name="_bookingItem" type="CM_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="populateReleases" id="1316271a-5a44-48ba-9279-813d5b975bc5">
        <source>populateReleases( _release : CM_BulkRelease; _reserveDetail : CM_ReserveDetail );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 October 2016	cnwndl1	Initial creation	TFS 2655 / 2419

*/

vars

	startObject : CM_BulkRelease;
	iter : Iterator;
	release : CM_BulkRelease;
	index : Integer;
	type : Integer;
	types : IntegerArray;
	typeString : String;
	includeNoDA : Boolean;

begin

	self.cmbReleases.clear();
	self.cmbReleases.sorted := true;
	
	includeNoDA := app.myCurrentUserCan( self.myTerminal, PmAdmDocActionsView ) or app.myCurrentUserCan( self.myTerminal, PmAdmDocActionsMaint );
	
	create types transient;
	types.add( BR_TYPE_ROAD );
	types.add( BR_TYPE_RAIL );
	types.add( BR_TYPE_SHIP );
	types.add( BR_TYPE_PACKING );

	foreach type in types do
		typeString := "[" &amp; app.releaseRequestTypeEnumToString(type) &amp; "]";
		iter := self.myTerminal.allBulkReleaseByTypeByStByCd.createIterator;
		startObject := self.myTerminal.allBulkReleaseByTypeByStByCd.getAtKeyGeq(type,BR_ACTIVE,null,null);
		if startObject &lt;&gt; null then
			iter.startAtObject( startObject );
			while iter.next( release ) do
				if release.type &lt;&gt; type then
					break;
				endif;
				if release.status &lt;&gt; BR_ACTIVE then
					break;
				endif;
				if not includeNoDA and not release.hasDocActions() then
					continue;
				endif;
				index := self.cmbReleases.addItem( release.code &amp; typeString );
				self.cmbReleases.itemObject[index] := release;
			endwhile;
		endif;
		delete iter;
	endforeach;
	
	if self.cmbReleases.listCount &lt; 1 then
		self.cmbReleases.addItem( app.getErrorString(Release_availab_with_actions ));
	else
		self.cmbReleases.sorted := false;
		self.cmbReleases.addItemAt( app.getErrorString(Please_select_release), 1 );
	endif;
	
	self.cmbReleases.listIndex := 1;
	
	if _release &lt;&gt; null then
		index := self.cmbReleases.findObject( _release );
		if index &gt; 0 then
			self.cmbReleases.listIndex := index;
		endif;
	endif;
	
	release := self.cmbReleases.listObject.CM_BulkRelease;
	self.populateReserveDetails( release, _reserveDetail );

epilog

	delete types;

end;</source>
        <Parameter name="_release" type="CM_BulkRelease"/>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="populateReserveDetails" id="71f7fe77-445d-4626-b421-378581e2d7ef">
        <source>populateReserveDetails( _release : CM_BulkRelease; _reserveDetail : CM_ReserveDetail );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 October 2016	cnwndl1	Initial creation	TFS 2655 / 2419

*/

vars

	iter : Iterator;
	reserveDetail : CM_ReserveDetail;
	docAction : CM_DocumentActions;
	index : Integer;
	includeNoDA : Boolean;

begin

	self.cmbReserveDetails.clear();
	self.cmbReserveDetails.sorted := true;
	self.cmbReserveDetails.enabled := true;
	
	includeNoDA := app.myCurrentUserCan( self.myTerminal, PmAdmDocActionsView ) or app.myCurrentUserCan( self.myTerminal, PmAdmDocActionsMaint );
	
	if _release &lt;&gt; null then
		iter := _release.allReserveDetails.createIterator;
	
		if not includeNoDA then
			while iter.next( reserveDetail ) do
				docAction := reserveDetail.myReserveDetailActions;
				if docAction = null then
					continue;
				endif;
				if not docAction.hasActions then
					continue;
				endif;
				//index := self.cmbReserveDetails.addItem( reserveDetail.getDescription &amp; " - " &amp; docAction.getThumbNailDisp );
				index := self.cmbReserveDetails.addItem( docAction.getThumbNailDisp );		//13 Dec 2016	NDL	TFS 3111/2001
				self.cmbReserveDetails.itemObject[index] := reserveDetail;
			endwhile;
		else
			while iter.next( reserveDetail ) do
				docAction := reserveDetail.myReserveDetailActions;
				if docAction = null then
					index := self.cmbReserveDetails.addItem( reserveDetail.getDescription );
					self.cmbReserveDetails.itemObject[index] := reserveDetail;
				else
					//index := self.cmbReserveDetails.addItem( reserveDetail.getDescription &amp; " - " &amp; docAction.getThumbNailDisp );
					index := self.cmbReserveDetails.addItem( docAction.getThumbNailDisp );		//13 Dec 2016	NDL	TFS 3111/2001
					self.cmbReserveDetails.itemObject[index] := reserveDetail;
				endif;
			endwhile;
		endif;
		
		//27 Jan 2017	NDL	TFS 3157
		if not _release.allReservePackingChildren.isEmpty then
			delete iter;
			iter := _release.allReservePackingChildren.createIterator;
	
			if not includeNoDA then
				while iter.next( reserveDetail ) do
					docAction := reserveDetail.myReserveDetailActions;
					if docAction = null then
						continue;
					endif;
					if not docAction.hasActions then
						continue;
					endif;
					index := self.cmbReserveDetails.addItem( docAction.getThumbNailDisp );
					self.cmbReserveDetails.itemObject[index] := reserveDetail;
				endwhile;
			else
				while iter.next( reserveDetail ) do
					docAction := reserveDetail.myReserveDetailActions;
					if docAction = null then
						index := self.cmbReserveDetails.addItem( reserveDetail.getDescription );
						self.cmbReserveDetails.itemObject[index] := reserveDetail;
					else
						index := self.cmbReserveDetails.addItem( docAction.getThumbNailDisp );
						self.cmbReserveDetails.itemObject[index] := reserveDetail;
					endif;
				endwhile;
			endif;
		endif;
		
		if self.cmbReserveDetails.listCount &lt; 1 then
			 self.cmbReserveDetails.addItem( app.getErrorString(Reserve_details_with_actions) );
			 self.cmbReserveDetails.listIndex := 1;
			 self.resetButtons;
			 return;
		endif;
	
	endif;
	
	index := 0;
	if _reserveDetail &lt;&gt; null then
		index := self.cmbReserveDetails.findObject( _reserveDetail );
	endif;
	
	if index &gt; 0 then
		self.cmbReserveDetails.listIndex := index;
	elseif self.cmbReserveDetails.listCount &gt; 1 then
		self.cmbReserveDetails.sorted := false;
		self.cmbReserveDetails.addItemAt( "&lt;" &amp; app.getErrorString(Please_select_release_detail) &amp; "&gt;", 1 );
		self.cmbReserveDetails.listIndex := 1;
	elseif self.cmbReserveDetails.listCount = 1 then
		self.cmbReserveDetails.listIndex := 1;
	else
		self.cmbReserveDetails.enabled := false;
	endif;
	
	self.resetButtons;

epilog

	delete iter;

end;</source>
        <Parameter name="_release" type="CM_BulkRelease"/>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="resetButtons" id="24afdc5b-3d7d-4801-878c-a84ddfc2dd2d">
        <source>resetButtons();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 October 2016	cnwndl1	Initial creation	TFS 2655 / 2419

*/

vars

	docActions : CM_DocumentActions;
	allowMaint : Boolean;
	
	bookRefItem : CM_BookingRefItem;
	reserve : CM_ReserveDetail;
	parentHasDAs : Boolean;	//12 Dec 2016	NDL	TFS 3023/2001

begin

	
	self.txtDocumentId.visible := ( self.optBooking.value or self.optRelease.value );	//28 Nov 2016	DL	TFS 2955 / 2001
	self.btnTwo.enabled := false; 
	
	docActions := self.getSelectedDocumentAction( parentHasDAs, allowMaint );
	if docActions &lt;&gt; null then
		self.btnOne.enabled := true;
		self.btnTwo.enabled := allowMaint; 
		
	else
		self.btnOne.enabled := parentHasDAs;	
		if self.optBooking.value then
			bookRefItem := self.cmbBookingItems.listObject.CM_BookingRefItem;
			if bookRefItem &lt;&gt; null then
				self.btnTwo.enabled := allowMaint; 
			endif;
			
		elseif self.optRelease.value then
			reserve := self.cmbReserveDetails.listObject.CM_ReserveDetail;
			if reserve &lt;&gt; null then
				self.btnTwo.enabled := allowMaint; 
			endif;
		
		endif;
		
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupControls" id="f7acc8d4-47bc-4c4a-ae57-70a49c4620c4">
        <updating/>
        <source>setupControls() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 October 2016	cnwndl1	Initial creation	TFS 2655 / 2419

*/

vars

	reserveDetail : CM_ReserveDetail;
	bookingItem : CM_BookingRefItem;
	booking : CM_BookingRef;
	release : CM_BulkRelease;

begin

	self.doResizeControls(true);
	
	self.txtDocumentId.lostFocus( self.txtDocumentId );
	
	if not self.myMobileGenericAgent.allReserveDetails.isEmpty then
		reserveDetail := self.myMobileGenericAgent.allReserveDetails.first();
		self.myMobileGenericAgent.setAllReserveDetails( null );
		if reserveDetail &lt;&gt; null then
			release := reserveDetail.myReserveHeader;
		endif;
		self.optRelease.value := true;
		self.cmbReleases.visible := true;
		self.cmbReserveDetails.visible := true;
	endif;
	if not self.myMobileGenericAgent.allBookingRefItems.isEmpty then
		bookingItem := self.myMobileGenericAgent.allBookingRefItems.first();
		self.myMobileGenericAgent.setAllBookingRefItems( null );
		if bookingItem &lt;&gt; null then
			booking := bookingItem.myBookingReference;
		endif;
		self.optBooking.value := true;
		self.cmbBookings.visible := true;
		self.cmbBookingItems.visible := true;
	endif;
	
	self.populateBookings(booking,bookingItem);
	self.populateReleases(release,reserveDetail);
	
	self.resetButtons();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="9dd4a95b-e625-4eeb-a9da-63cce9366acb">
        <updating/>
        <source>setupForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 October 2016	cnwndl1	Initial creation	TFS 2655 / 2419

*/

vars

begin

	
	
	self.setupCmdButtons( 3, app.getErrorString(Next), app.getErrorString(Maintain), app.getErrorString(Back), null, null );
	
	inheritMethod();
	
	self.setupControls();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="bf843777-3445-40d7-baec-0c12a8bf61e3">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 01 December 2016 15:05:43.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021355, locale);
	lblDocumentId.translateCaption(Xlat_0021563, locale);
	optBooking.translateCaption(Xlat_0021356, locale);
	optRelease.translateCaption(Xlat_0021357, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtDocumentId_gotFocus" id="45bdb9f5-e679-442c-9dae-fcbb6d8bf9d0">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtDocumentId_gotFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2016	cnwndl1	Initial creation	TFS 2955 / 2001

*/

vars

begin

	if txtDocumentId.text = lblDocumentId.caption.toUpper then
		txtDocumentId.selStart := 0;
		txtDocumentId.selLength := lblDocumentId.caption.length;
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtDocumentId_lostFocus" id="ad2f05dd-df67-421f-8e89-40ac8b50d365">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtDocumentId_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 November 2016	cnwndl1	Initial creation

*/

vars

begin

	if txtDocumentId.text.trimBlanks = null then
		txtDocumentId.text := lblDocumentId.caption.toUpper;
	endif;
	
	txtDocumentId.selStart := 0;
	txtDocumentId.selLength := 0;
	
	if self.optBooking.value then
		self.findBooking( txtDocumentId.text.trimBlanks );
	elseif self.optRelease.value then
		self.findRelease( txtDocumentId.text.trimBlanks );
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
</GUIClass>
