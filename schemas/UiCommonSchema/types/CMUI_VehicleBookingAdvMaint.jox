    <JadeMethod name="doChangeVbsSlotType" id="8ca56cb3-ebf1-4adb-be65-21782a1990b8">
        <source>doChangeVbsSlotType() protected;
/*

Purpose:			Chanegs the VBS Slot Type on the form and pre loads so data

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
29 May 2023	navpw1	Initial creation TFS: 58178
02 Jun 2023	navpw1	TFS: 58369 - Modified method to stop external reference being enabled when generating more than 1 vbs slot
06 Jul 2023	navma1	ChangeRequest 58753: EUP | Slot Creation - Date and Time defaults and updates
13 Jul 2023 navma1	Defect 59074: MTN - 1090 exception is raised when the start date/time is before the current time
13 Jul 2023 navma1	Bug 59130: FR 53429 EUP | VBS changes MTN - External Ref Validation
*/

vars
	tsNow				  : TimeStamp;
	currentSlotType,
	vbsSlotType			  : CM_VehicleBookingTimeSlotType;	
	numberOfSlots		  : Integer;
	isExtRefUpdateAllowed : Boolean;
	
begin

	vbsSlotType 			:= self.cmbVbsSlotType.listObject.CM_VehicleBookingTimeSlotType;
	currentSlotType			:= self.myProxyVehicleBookingTimeSlot.myVBTimeSlotType;				//13.07.2023 navma1 #59074
	isExtRefUpdateAllowed	:= self.myProxyVehicleBookingTimeSlot.isExternalRefUpdateAllowed;	//30.08.2023 navma1
	if vbsSlotType &lt;&gt; null then
		
		// Populate the CheckBoxes
		self.populateCheckBoxes(vbsSlotType);
		
		self.myProxyVehicleBookingTimeSlot.setVBTimeSlotType(vbsSlotType);
		numberOfSlots := self.txtCopySlots.text.asIntegerJMT;							// ### TFS 58369 02Jun2023 NAVPW1
		
		if not vbsSlotType.isExternelRefUpdateAllowed or								// 22.12.2022 navak20 TFS 55979
			numberOfSlots &gt; 1															// ### TFS 58369 02Jun2023 NAVPW1
		then		
			self.txtExternalReference.enabled	:= false;
			self.lblExternalReference.enabled	:= false;
		else
			self.txtExternalReference.enabled	:= isExtRefUpdateAllowed;
			self.lblExternalReference.enabled	:= isExtRefUpdateAllowed;
		endif;

		if numberOfSlots &gt; 1 then
			self.txtExternalReference.text		:= null;								//13.07.2023 navma1 #59130
		endif;
		if self.vehicleBookingMode = self.MODE_ADD 	  or 
		   self.vehicleBookingMode = self.MODE_UPDATE or 								//06.07.2023 navma1 #58753
		   self.vehicleBookingMode = self.MODE_UPDATE_BULK then    						//06.07.2023 navma1 #58753
			
			if vbsSlotType &lt;&gt; currentSlotType then
				if vbsSlotType.duration &lt;&gt; null then
					self.startDT.setDate(tsNow.date());					//06.07.2023 navma1 #58753
					self.startTM.setTime(vbsSlotType.startTime);		//06.07.2023 navma1 #58753
					self.endDT.setDate(tsNow.date());
					self.endTM.setTime(vbsSlotType.startTime.addMinutes(vbsSlotType.duration));
				endif;
			endif;
		endif;
	endif;
	
	if self.cmbVbsSlotType.getCurrentItemObject &lt;&gt; null then
		self.btnSlotAdd.enabled    := true;
		self.btnSlotEdit.enabled   := true;
		self.btnSlotDelete.enabled := true;
		self.btnSave.enabled       := true;
	else
		self.btnSlotAdd.enabled    := false;
		self.btnSlotEdit.enabled   := false;
		self.btnSlotDelete.enabled := false;
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLostFocusCopySlots" id="649ea0a2-17d9-4821-bce2-e0a9fe7eee49">
        <source>doLostFocusCopySlots() protected;
/*

Purpose:			Disables the external reference field if the number of slots is more than 1

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
02 June 2023	navpw1	Initial creation TFS: 58369

*/

vars
	numberOfSlots	: Integer;
	vehicleBooking	: CM_VehicleBookingTimeSlotType;
	
begin
	numberOfSlots := self.txtCopySlots.text.asIntegerJMT;
	vehicleBooking := self.cmbVbsSlotType.getCurrentItemObject.CM_VehicleBookingTimeSlotType;	// 22.12.2022 navak20 TFS 55979
	
	if (vehicleBooking &lt;&gt; null and not vehicleBooking.isExternelRefUpdateAllowed) 
		or numberOfSlots &gt; 1
	then
		self.txtExternalReference.enabled	:= false;
		self.lblExternalReference.enabled	:= false;
		self.txtExternalReference.text		:= null;
	else
		self.txtExternalReference.enabled	:= true;
		self.lblExternalReference.enabled	:= true;
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSlotTableContextMenu" id="a059f91c-d5f1-4773-8b1a-733acef418bc">
        <updating/>
        <source>doSlotTableContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 Mar 2022 navma1 	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
04 Apr 2022	navcs2	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
*/

vars
	xLeft 	: Real;
	yTop	: Real;
	
begin
	xLeft := x;
	yTop := y;
	
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);
	
	self.popupMenu(self.mnuVbsTimeSlot, xLeft.Integer, yTop.Integer);

	return false;
epilog

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="6c1c9aa6-eeb7-4f19-9f56-aafb0e432eca">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			Gets the XML Settings for Save

Parameters:			NONE

Return Value:		String Returns the settings to be saved

Date			Who		Reason
05 March 2025	navpw1	Initial creation JIRA: MTN-34070

*/

vars
	theXML : String;
	
begin
	theXML := inheritMethod();
	theXML := theXML &amp; self.tblSlotItems.getXmlStrForColumns(false);
	return theXML;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasDeliveryOrPickup" id="38a250f6-99e4-4815-bfef-2857e6629e97">
        <updating/>
        <source>hasDeliveryOrPickup(_booking : CM_VehicleBookingTimeSlot) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
22/07/2022 		navcs2  ChangeRequest 53899: EUP - VBS MTN - [3] - Maintaining VBS Slot
*/

vars
	bookingTimeSlotItem : CM_VehicleBookingTimeSlotItem;
begin
	self.hasPickup := false;
	self.hasDelivery := false;
	
	if _booking &lt;&gt; null then
		foreach bookingTimeSlotItem in _booking.allVehicleBookingItems do
			if bookingTimeSlotItem.direction = DIRECTION_PICKUP then
				hasPickup := true;
			endif;
			
			if bookingTimeSlotItem.direction = DIRECTION_DELIVERY then
				hasDelivery := true;
			endif;
		endforeach;
	
	else
		foreach bookingTimeSlotItem in self.myProxyVehicleBookingTimeSlot.allVehicleBookingItems do
			if bookingTimeSlotItem.direction = DIRECTION_PICKUP then
				hasPickup := true;
			endif;
			
			if bookingTimeSlotItem.direction = DIRECTION_DELIVERY then
				hasDelivery := true;
			endif;
		endforeach;
	endif;

epilog

end;</source>
        <Parameter name="_booking" type="CM_VehicleBookingTimeSlot"/>
    </JadeMethod>
    <JadeMethod name="initTblSlotItems" id="40b16a52-3aac-4640-a721-8466e64def1d">
        <source>initTblSlotItems() protected;
/*

Purpose:			Initializes the Slot Items Table

Parameters:			NONE

Return Value:		NONE

Date			Who		Reason
05 March 2025	navpw1	Initial creation JIRA: MTN-34070

*/

vars
	entTableDef : EntTableDef;
	tbl			: CM_DataTable;
	
begin
	entTableDef := app.myController.getEntTableDef(ETDef_VehicleBookingItem);	
	tbl			:= self.tblSlotItems;	
	
	tbl.setTblDataEntRowsFromDef(entTableDef);
	
	tbl.setMyDataClass(CM_VehicleBookingTimeSlotItem);
	tbl.fixedColumns    := 0;
	tbl.fixedRows 	    := 1;
	tbl.selectMode 		:= CM_DataTable.SelectMode_FixedRow;
	tbl.selectionType   := CM_DataTable.SelectionType_Row;
	tbl.multiSelect 	:= CM_BaseTable.MultiSelect_Simple;
	self.setColorsForTable(tbl);
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="initialise" id="57040a64-feeb-4484-a077-ad8374eb16b7">
        <updating/>
        <source>initialise(timeSlot : CM_VehicleBookingTimeSlot; mode : Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
18 August 2022	navcs2	ChangeRequest 53899: EUP - VBS MTN - [3] - Maintaining VBS Slot
23 Dec 2022		navak20 Task 55979: EUP - VBS MTN - [3] - Maintaining VBS Slot - Review Changes
24 Apr 2023 	navhl20	ChangeRequest 57716:[57718] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 01]
*/

vars
	ls					: Boolean;
	pxySlot,
	vbsTimeslot			: CM_VehicleBookingTimeSlot;
	
begin
	self.vehicleBookingMode := mode;
	
	pxySlot := app.myProxyManager.getProxyObject(timeSlot).CM_VehicleBookingTimeSlot;							//24.4.2023 navhl20 #57716[57718]
	
	if pxySlot &lt;&gt; null then																						//24.4.2023 navhl20 #57716[57718]
		self.myProxyVehicleBookingTimeSlot := pxySlot;
	else
		self.myProxyVehicleBookingTimeSlot := app.createUpdateProxy(timeSlot).CM_VehicleBookingTimeSlot;
	endif;

	if self.vehicleBookingMode = self.MODE_UPDATE_BULK then
		//self.myProxyVehicleBookingTimeSlot := app.createUpdateProxy(timeSlot).CM_VehicleBookingTimeSlot;		//24.4.2023 navhl20 #57716[57718]
		self.adjustControlsForBulkEdit(false);
		return;
	endif;
	
	self.myVBSTimeSlot := timeSlot;
	vbsTimeslot := self.myVBSTimeSlot;
	
	//self.myProxyVehicleBookingTimeSlot := app.createUpdateProxy(timeSlot).CM_VehicleBookingTimeSlot;			//24.4.2023 navhl20 #57716[57718]
	
epilog
	
end;</source>
        <Parameter name="timeSlot" type="CM_VehicleBookingTimeSlot"/>
        <Parameter name="mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="mnuColumnOrganiser_click" id="e4b6ad0c-55fb-4f28-bee8-02bf1b55115d">
