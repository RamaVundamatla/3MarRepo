    <JadeMethod name="setPreviousControllerFromId" id="f477b66f-a894-46fb-a92e-3c9ba996d77d">
        <source>setPreviousControllerFromId(_label : String io) protected;

vars

begin

	// Convert label to upper case.
	_label := _label.toUpper;
	if self.myCurrentRowArea.isMarkedUp then
		// Can we find this string in our starting label combo.
		if self.cmbStartingLabel.findString(1, _label) &lt;&gt; -1 then
			self.tblInput1.setValueByName(ETRow_StartRow, _label);
			self.cmbStartingLabel.text := _label;
			// Get previous data based on distance.
			doGetPreviousData(_label,CM_RowArea.SEARCH_DISTANCE);
		else
			// Get previous data based on alphabetical search.
			self.tblInput1.setValueByName(ETRow_StartRow, null);
			doGetPreviousData(_label,CM_RowArea.SEARCH_ALPHABETICAL);
		endif;	
	else
		// Just get previous data based on alphabetical search.
		doGetPreviousData(_label,CM_RowArea.SEARCH_ALPHABETICAL);
	endif;
		
end;</source>
        <access>protected</access>
        <Parameter name="_label" type="String" usage="io"/>
    </JadeMethod>
