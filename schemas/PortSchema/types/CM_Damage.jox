    <JadeMethod name="getCCEventProperties" id="312eceee-f481-4ac3-8e78-e952e3c01039">
        <source>getCCEventProperties(ccEvent: CMIF_CCEvent) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2019	jlgndl1	Initial creation	TFS 45963

*/

vars

	
	damageDetails : String;
	
begin

	damageDetails := self.getEnquiryRow;

	inheritMethod(ccEvent);
	
	ccEvent.addText( "damageDetails", damageDetails ) ;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="ccEvent" type="CMIF_CCEvent"/>
    </JadeMethod>
    <JadeMethod name="getCCEventType" id="2eb82cee-fa52-4f6b-9a2b-711c0c5fc681">
        <source>getCCEventType(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2019	jlgndl1	Initial creation		TFS 45963

*/

vars

begin
	return CC_EventType_Damaged;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="6c191f7b-e6d5-47b3-a3f7-484a50571c2d">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	lDetail : String;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
		else
			lDetail := inheritMethod(_attrName, _short);	//cnwrs1 CCMS 1826 29 July 2010
			if self.myTrackedItem &lt;&gt; null then
				lDetail := lDetail &amp; self.myTrackedItem.getDamageAuditText;
			endif;
			return lDetail;
		endif;
	elseif _attrName = ETRow_TransDamageDetail then
		if self.myTrackedItem &lt;&gt; null then
			return self.myTrackedItem.getDamageAuditText;
		else
			return null;
		endif;
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="bd4635e9-8964-42ba-8cce-1e9982ac4b1c">
        <source>getEnquiryRow(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2010	cnwmd1	Initial creation

*/

vars
	detail : String;
begin
	detail := inheritMethod();
	
	if self.myTrackedItem &lt;&gt; null then
		detail := detail &amp; self.myTrackedItem.getDamageAuditText;
	endif;
	
	return detail;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForDelete" id="eb1cec2e-ba3c-49db-b381-690f136b6e23">
        <updating/>
        <source>setForDelete(_reason: String) updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 12 August 2010
//
// Implemented version: JMT 7.8.3
// Date  		User  		Change
// 27 July 2022	navak20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
//----------------------------------------------------------------------
vars
	cargoItem : CM_TrackedItem;
begin
	cargoItem := self.myTrackedItem;
	
	inheritMethod(_reason);
	
	//PAR21671 - 12/08/2010 cnwsh3 deleting a damage transaction should reset the isDamaged and damageDT for the cargo item.
	//Don't delete if damage exists against it.
	if cargoItem.allDamageInstances.isNotEmpty() then
		app.raiseCMException1(DamageTransNoDelete, cargoItem.id, CM_TrackedItem::allDamageInstances.name, self);
	endif;
	
	cargoItem.setDamagedDT(false);			//27.07.2022 navsrk20 TFS 53862
epilog
end;</source>
        <Parameter name="_reason" type="String"/>
    </JadeMethod>
    <JadeMethod name="updateTI" id="70f98ad3-f1fd-4955-b287-0e0fa08ef360">
        <updating/>
        <source>updateTI(_passport : CM_Passport input) updating;
// 27 July 2022	navak20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
vars

begin

	inheritMethod(_passport);

	if self.myTrackedItem = null then
		return;
	endif;
	
	//self.myTrackedItem.setDamagedDT();			//27.07.2022 navsrk20 TFS 53862
	self.myTrackedItem.setDamagedDT(false);			//27.07.2022 navsrk20 TFS 53862
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="45861bd0-9577-4e01-9599-d209b123abd1">
        <source>validateForUpdate(pProxyTransaction: CM_TITransaction);
// ---------------------------------------------------------------------------
// Created:     24 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	// You cannot edit any fields for this transaction type
	app.raiseCMException(ERR_INVALID_TRANS_EDIT, null, null);

	inheritMethod(pProxyTransaction);

end;</source>
        <Parameter name="pProxyTransaction" type="CM_TITransaction"/>
    </JadeMethod>
</Class>
