    <JadeMethod name="getNextVoyage" id="d4bc33d9-211b-4481-83ae-c9164a28a9fc">
        <source>getNextVoyage( _voyage : CM_Voyage ) : CM_Voyage;
//-----------------------------------------------------------------------
//	Created:	30 November 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	voyage : CM_Voyage;
	found	: Boolean;
begin
	foreach voyage in self.allVoyages do
		if found then 
			return voyage;
		endif;
		if voyage = _voyage then
			found := true;
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getRealFirstVoyage" id="613f7eba-2320-4e0f-815f-b8c7f2b12cbe">
        <source>getRealFirstVoyage() : CM_Voyage;
//-----------------------------------------------------------------------
//	Created:	20 September 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	voyage : CM_Voyage;
begin

	foreach voyage in self.allVoyages reversed do
		if voyage.myVoyageGlobalArrival = self then
			break;
		endif;
	endforeach;
	
	return voyage;
		
epilog

end;</source>
