    <JadeMethod name="cloneReferences" id="01539f27-44dc-4443-96c8-a3a2648bb238">
        <updating/>
        <source>cloneReferences(_obj: CMQF_Invoice; _transient: Boolean) updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		22 April 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
//----------------------------------------------------------------------
vars

begin
	inheritMethod(_obj, _transient);
	
	self.allCompaniesByCode.clear();
	_obj.allCompaniesByCode.copy(self.allCompaniesByCode);
	
	self.setMyDebtor( _obj.getMyDebtor );
	self.setMyInvoiceType( _obj.getMyInvoiceType );
	self.allInvoiceTypes.clear();
	_obj.allInvoiceTypes.copy(self.allInvoiceTypes);
	self.allInvoiceTypes.removeInvalidObjects();	//18 July 2016	NDL	TFS 2329
	self.setMyConsignee( _obj.getMyConsignee );
	self.setMyCustomsAgent( _obj.getMyCustomsAgent );
	self.setMyDebtorType( _obj.getMyDebtorType );
	self.setMyVoyage( _obj.getMyVoyage );
	self.setMyShippingLine(_obj.getMyShippingLine);	 // ### TFS BUG 56660 23FEB2023 NAVAB1
	
epilog
end;</source>
        <Parameter name="_obj" type="CMQF_Invoice"/>
        <Parameter name="_transient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="filterByCompany" id="f7c584ac-af74-4f85-b5ce-ed6b2d6912df">
        <updating/>
        <source>filterByCompany(_collection : Collection input) updating, protected;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		27 April 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
// 18/03/2016    cnwma1		PAR37681 QNS - Data locked by other user
//----------------------------------------------------------------------
vars
	passport	: CM_Passport;
	company 	: CM_Bank;
	inv			: CM_Invoice;
	iter		: Iterator;
	startObject : Object;
	breakOut 	: Boolean;
begin
	company := self.allCompaniesByCode.first();
	passport := app.myPassport;
	
	// by status
	if self.invoiceStatus &lt;&gt; CM_Invoice.INVOICE_ALL_STATUS then
		iter := company.invoicesByStatus.createIterator;
		startObject := company.invoicesByStatus.getAtKeyGeq( self.invoiceStatus );
		if startObject &lt;&gt; null then
			iter.startAtObject( startObject );
			while iter.next(inv) do
				if inv.status &lt;&gt; self.invoiceStatus then
					break;
				endif;
				if self.includesObject(inv, passport, breakOut) then
					_collection.add(inv);
				endif;
				if breakOut then
					break;
				endif;
			endwhile;
		endif;
	// by type
	elseif self.getMyInvoiceType &lt;&gt; null then
		iter := company.invoicesByType.createIterator;
		startObject := company.invoicesByType.getAtKeyGeq( self.getMyInvoiceType );
		if startObject &lt;&gt; null then
			iter.startAtObject( startObject );
			while iter.next(inv) do
				if inv.invoiceType &lt;&gt; self.getMyInvoiceType then
					break;
				endif;
				if self.includesObject(inv, passport, breakOut) then
					_collection.add(inv);
				endif;
				if breakOut then
					break;
				endif;
			endwhile;
		endif;
	else
		// all invoices
		foreach inv in company.allInvoices discreteLock do                     //18/03/2016 cnwma1  PAR #37681
			if self.checkStatusIncludesObject(inv, passport, breakOut) then
				if not _collection.includes(inv) then
					_collection.add(inv);
				endif;
			endif;
			if breakOut then
				break;
			endif;
		endforeach;
	endif;
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="filterByDate" id="e6c3b26e-6288-454e-a614-ebbf5c5757ce">
        <updating/>
        <source>filterByDate(_collection : Collection input) updating, protected;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		27 April 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
//----------------------------------------------------------------------
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/
vars
	company 	: CM_Bank;
	dateFrom,
	dateTo,
	now			: TimeStamp;
	passport	: CM_Passport;
	breakOut	: Boolean;
	dict		: CM_InvoiceByToDTStatusDict;
	iter 		: Iterator;
	obj			: Object;
	inv			: CM_Invoice;

begin
	company 	:= self.allCompaniesByCode.first;
	passport 	:= app.myPassport;
	
	dateFrom.setDate(self.startDate);
	dateFrom.setTime('00:00:00:000'.Time);
	
	if self.endDate.isValid then
		dateTo.setDate(self.endDate);
		dateTo.setTime('23:59:59:999'.Time);
	else
		dateTo := now;
	endif;
	
	dict := company.allInvoicesByToDate;
	iter := dict.createIterator();
	dict.startKeyGeq(company.terminal, company, dateFrom, self.invoiceStatus, null, iter);
		
	while iter.next(obj) do
		inv := obj.CM_Invoice;
		
		if inv.toDT.date &gt; dateTo.date then
			break;
		endif;

		if self.checkStatusIncludesObject(inv, passport, breakOut) then
			if not _collection.includes(inv) then
				_collection.add(inv);
			endif;
		endif;
		
	endwhile;
	
epilog
	delete iter;		// PAR #26678
	
end;</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="filterByDebtor" id="9a7cc843-b5f3-47cb-a3c6-cb6ab0976595">
        <updating/>
        <source>filterByDebtor(_collection: Collection input) updating, protected;
// debtor is known
vars
	company	    : CM_Bank;
	iter 		: Iterator;
	invoice     : CM_Invoice;
	breakOut    : Boolean;
	passport    : CM_Passport;
	startObject : Object;

begin

	passport := app.myPassport;
	company  := self.allCompaniesByCode.first();
	
	if company &lt;&gt; null then
		//bank and debtor known.
		iter 		:= company.invoicesByDebtor.createIterator;
		startObject := company.invoicesByDebtor.getAtKeyGeq( self.getMyDebtor );
		if startObject &lt;&gt; null then
			iter.startAtObject( startObject );
			while iter.next(invoice) do
				if invoice.debtor &lt;&gt; self.getMyDebtor then
					break;
				endif;
				if self.includesObject(invoice, passport, breakOut) then
					_collection.add(invoice);
				endif;
				if breakOut then
					break;
				endif;
			endwhile;
		endif;
		
	elseif self.invoiceStatus &lt;&gt;  CM_Invoice.INVOICE_ALL_STATUS  then
		//status and debtor known.
		iter 		:= self.getMyDebtor.invoicesByStatus.createIterator;
		startObject := self.getMyDebtor.invoicesByStatus.getAtKeyGeq( self.invoiceStatus );
		if startObject &lt;&gt; null then
			iter.startAtObject( startObject );
			while iter.next(invoice) do
				if invoice.status &lt;&gt; self.invoiceStatus then
					break;
				endif;
				if self.includesObject(invoice, passport, breakOut) then
					_collection.add(invoice);
				endif;
				if breakOut then
					break;
				endif;
			endwhile;
		endif;
			
	else
		//just debtor known
		iter := self.getMyDebtor.allInvoices.createIterator;
		while iter.next(invoice) do
			if self.includesObject(invoice, passport, breakOut) then
				_collection.add(invoice);
			endif;
			if breakOut then
				break;
			endif;
		endwhile;
	endif;
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="filterByNumber" id="56a80dd1-161b-4d30-b102-fcda962b6f1b">
        <updating/>
        <source>filterByNumber(_collection : Collection input; _jrwTrans : CM_JRWInvoice) protected, updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		27 April 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
//----------------------------------------------------------------------
vars
	company 	: CM_Bank;
	inv			: CM_Invoice;
	breakOut	: Boolean;
begin
	//We do a direct comparision so grab the invoice with a matching invoice number if it matches.
	company := self.allCompaniesByCode.first;//Changing to a collection/set later possibly??
	
	inv := company.allInvoices[company.terminal, company, self.invoiceNumber];

	if inv &lt;&gt; null then //Just so it fits with the existing framework.
		if self.checkStatusIncludesObject(inv, app.myPassport, breakOut) then
			_collection.add(inv);
			self.populateSummaries(inv, _jrwTrans);
		endif;
	endif;
	
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_jrwTrans" type="CM_JRWInvoice"/>
    </JadeMethod>
    <JadeMethod name="filterByVoyage" id="7fa6aede-d0b2-4776-a757-3278768e8135">
        <updating/>
        <source>filterByVoyage(_collection : Collection input) updating, protected;
// CCMS 2348
//21/04/2016 CNWMA1 PAR #37681 QNS - locking issue
vars
	inv			: CM_Invoice;
	breakOut 	: Boolean;
begin

	//foreach inv in self.myVoyage.allInvoices do
	foreach inv in self.getMyVoyage.allInvoices discreteLock do      //21/04/216 cnwma1 PAR #37681 
		if self.checkStatusIncludesObject(inv, app.myPassport, breakOut) then
			if not _collection.includes(inv) then
				_collection.add(inv);
			endif;
			if breakOut then
				break;
			endif;
		endif;
	endforeach;
	
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="filterForCargo" id="8aa826e2-cd16-4981-ae1a-a9cec30baa74">
        <updating/>
        <source>filterForCargo(_collection : Collection input) protected, updating;
// INV_ListInvoices code for invoice enquiry by BOL/consignee (but not called from there)
//  revised for 37009 to include cargo id and cargo type, also to use includesObject for other filtering
// 21/04/2016 CMWMA1 PAR #37681 QNS - locking issue
// 21/02/2018 jlgmd1 TFS #37093 SNO - No report output
//22/05/2019 	JLGNS1	Bug 44866: ADP - Error while running report
vars
	bolId			: String;
	mode			: Integer;
	consignee		: CM_ConsigneeConsignor;
	invoice			: CM_Invoice;
	anInvoice		: CM_Invoice;
	invoiceLine		: CM_InvoiceLine;
	terminal		: CM_Terminal;
	theTI			: CM_TrackedItem;
	breakOut 		: Boolean;
	passport 		: CM_Passport;
	iter			: Iterator;

begin
	passport := app.myPassport;
	bolId := self.billOfLading;
	consignee := self.getMyConsignee;
	//mode := self.siteState;		//-TFS 37093
	foreach terminal in self.allTerminals do : termLoop
		foreach mode in self.allQrySites do		//TFS 37093
			delete iter;
			if mode = TI_SITE_ONSITE then
				iter := terminal.allOnsiteTIsByCargoTypeId.createIterator;
			elseif mode = TI_SITE_OFFSITE then
				iter := terminal.allOffsiteTIsByCargoTypeId.createIterator;
			elseif mode = TI_SITE_TBA then
				iter := terminal.allTbaTIsByCargoTypeId.createIterator;
			elseif mode = TI_SITE_PLACEHOLDER then	//13 Mar 2020	NDL	TFS 47004
				iter := terminal.allRRPTIsByCargoTypeId.createIterator;
			elseif mode = TI_SITE_ONSHIP then
				if self.getMyVoyage &lt;&gt; null then
					iter := self.getMyVoyage.allOnshipTIsByCargoTypeId.createIterator();
				endif;
			endif;
			if iter &lt;&gt; null then
				while iter.next(theTI) do
					// 37009 restructure tests and add cargo id, type
					if bolId &lt;&gt; null and
					   theTI.billOfLading &lt;&gt; bolId then
						continue;
					endif;
					if consignee &lt;&gt; null and 
					   theTI.consignee &lt;&gt; consignee.code then
						continue;
					endif;
					if self.cargoId &lt;&gt; null and
					   theTI.id &lt;&gt; self.cargoId then
						continue;
					endif;
					if self.getMyCargoType &lt;&gt; null and
					   theTI.cargoType &lt;&gt; self.getMyCargoType.id then
						continue;
					endif;
					// find per-cargo invoices and invoice lines of transactions for this cargo
					//foreach invoice in theTI.allInvoices do
					foreach invoice in theTI.allInvoices discreteLock do    //21/04/2016 cnwma1 PAR #37681
						if self.includesObject(invoice, passport, breakOut) then
							if not _collection.includes(invoice) then	//22/05/2019 	JLGNS1	Bug 44866
								_collection.add(invoice);
							endif;
						endif;
					endforeach;
					//foreach invoiceLine in theTI.invoiceLines do
					foreach invoiceLine in theTI.invoiceLines  discreteLock do    //21/04/2016 cnwma1 PAR #37681
						anInvoice := invoiceLine.invoice;
						if anInvoice &lt;&gt; null and
						   self.includesObject(anInvoice, passport, breakOut) then
							if not _collection.includes(anInvoice) then
								_collection.add(anInvoice);
							endif;
						endif;
					endforeach;
				endwhile;
			endif;
			if mode = TI_SITE_ONSHIP then
				break termLoop;
			endif;
		endforeach;
	endforeach;
epilog
	delete iter;
end;

</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="filterObjects2" id="fdffb242-f490-4927-829b-cefcbca3d4cc">
        <updating/>
        <source>filterObjects2(_collection: Collection input; _jrwTrans : CM_JRWInvoice; _passport: CM_Passport) updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Implemented version: JMT 7.8.2
// Date  		User  		Change
// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
// CPL CCMS 2120 Oct 2011 add second collection parameter
//----------------------------------------------------------------------
vars
	terminal : CM_Terminal;
	params		: CMIF_InvoiceSelection;
	company	: CM_Bank;
begin
	// 34442 financial selector reports
	if (not self.allQueryCriteriaHolders.isEmpty) then
		self.filterSelectorQuery(_collection, _passport);
		return;
	endif;

	//Rule for invoicing at this stage is a company is required in order to report on invoices. 26/04/2010
	if self.allCompaniesByCode.isEmpty() then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(CM_CompanyBank), 'allCompaniesByCode', null); // cnwdb2	PAR 35364
		return;
	endif;
	
	company := self.allCompaniesByCode.first;  //This could change to group of companies in the future but at the moment we're only using one.
	if self.invoiceNumber &lt;&gt; null then			// this is used in XML posted invoice extraction which is why the _jrwTrans parameter is also here
		self.filterByNumber(_collection, _jrwTrans);
	elseif self.getMyVoyage &lt;&gt; null then
		self.filterByVoyage(_collection);
	elseif self.getMyDebtor &lt;&gt; null then
		self.filterByDebtor(_collection);
	elseif self.billOfLading &lt;&gt; null or
	   self.getMyConsignee &lt;&gt; null or
	   self.siteState &lt;&gt; 0 or
	   self.cargoId &lt;&gt; null or
	   self.getMyCargoType &lt;&gt; null then
		self.filterForCargo(_collection);
	// 37009 start and end date are actually creation date, checking done in includesObject
	//	also reorder the testing so that the cargo-related checks are done last
	///elseif self.startDate.isValid() then
	///	self.filterByDate(_collection);
	else
		// this covers invoice type and status
			self.filterByCompany(_collection);
	endif;
	
epilog
	delete params;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_jrwTrans" type="CM_JRWInvoice"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterSelectorQuery" id="cf4559c3-5c40-49c8-8ed9-ace6c1a9e37a">
        <source>filterSelectorQuery(_collection  : Collection input;
					_passport : CM_Passport) protected;
//	34442 Oct 2014 for invoice selector reports
vars
	criteriaHolder 		: CM_QueryCriteriaLineHolder;
	qDef				: CM_QueryDefinition;
	enqController		: CM_EnquiryController;
	queryAgent			: CM_QueryAgentFilter;

begin

	// Special one because we need the copy
	on CM_BreakOutException do app.myQAFilter.xHandlerBreakOut(exception);
	
	queryAgent := app.myQAFilter;
	if queryAgent = null then
		return;
	endif;
	
	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.Invoicing_Query_Type, self.selectorMode];
	queryAgent.createEnqControllerForMode(self.selectorMode, CM_QueryDefinition.Invoicing_Query_Type, enqController);
	delete enqController.allObjects;
	create enqController.allObjects as _collection.class transient;
	
	foreach criteriaHolder in self.allQueryCriteriaHolders discreteLock do
		enqController.myCriteriaLineHolder := criteriaHolder;
		enqController.doQuery(qDef);
	endforeach;

	enqController.allObjects.copy(_collection);
	
epilog
	if enqController &lt;&gt; null then
		delete enqController.allObjects;
	endif;
	delete enqController;
end;</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="7babf8bc-e782-42cd-a8a7-59b7a80af59c">
        <source>getDisplayStringForAttribute(_attrName: String; _getCalculatedDate: Boolean): String;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		22 April 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
//----------------------------------------------------------------------

// ---------------------------------------------------------------------------
// Created:     19/07/2010 cnwdz2	
//
// Purpose:     PAR24513 extend the current existing getDisplayStringForAttribute method to return an object's oid.		 
// ----------   ----------  --------------------------------------------------
vars
	str : String;
	oid : String;
begin
    return self.getOIDAndDescForAttribute(_attrName, _getCalculatedDate, oid);
/*
	if _attrName = ETRow_InvoiceType then
		if self.myInvoiceType &lt;&gt; null then
			return self.myInvoiceType.description &amp; " (" &amp; self.myInvoiceType.company.terminal.code &amp; ")";
		endif;
		
	elseif _attrName = ETRow_Company then
		if self.allCompaniesByCode.isNotEmpty then //At this point we only report on one company/bus unit 22/04/2010 cnwsh3
			return self.allCompaniesByCode.first.getNameWithTerminalString();
		endif;
		
	elseif _attrName = ETRow_Debtor then
		if self.myDebtor &lt;&gt; null then
			return self.myDebtor.name;
		endif;
		
	elseif _attrName = ETRow_InvoiceStatus then	
		if self.invoiceStatus = -1 then
			return Any_String;
		else
			return app.getInvoiceStatusString(self.invoiceStatus);
		endif;
		
	elseif _attrName = ETRow_InvoiceNumber then
		if self.invoiceNumber = null then
			return null;
		else
			return self.invoiceNumber.String;
		endif;
		
	endif;
	
	return inheritMethod(_attrName, _getCalculatedDate);
*/
epilog
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_getCalculatedDate" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
