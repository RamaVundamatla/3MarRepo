    <JadeMethod name="setValueForRow" id="032cf284-59b3-4ecc-9594-05d4c1bd86d7">
        <updating/>
        <source>setValueForRow(_rowName: String; _value: Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 April 2022	jlier1	Initial creation 53286 

*/

vars

begin
	if _value = null then
		return;
	endif;
	if _rowName = ETRow_BgpExternalFinInterface then
		self.myExtFinanceIO := _value.CM_ExtFinanceIO;
	elseif _rowName = ETRow_BgpBusinessUnit then
		self.myBusinessUnit := _value.CM_Bank;
	elseif _rowName = ETRow_BgpEmailGroup then
		 self.myEmailGroup :=_value.CM_EmailGroup;
	else
		inheritMethod(_rowName, _value);
	endif;	

epilog

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validate" id="67f7429e-d515-482b-8c20-13d60a6ba5d1">
        <source>validate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2022	jlier1	Initial creation

*/

vars
	real : CM_AutoTaskIFS;
	autoSchedule : CM_AutoSchedule;
	iter : Iterator;
	task : CM_AutoTask;
begin

	inheritMethod();
	
	if self.isTransient then
		real := self.pxyGetRealObject().CM_AutoTaskIFS;
	else
		real := self;
	endif;
	
	if self.myTerminal = null then
		app.raiseCMException(Input_required_field_terminal, ETRow_BgpAutoTerminals, null); 
		return;
	endif;
	
	if self.myBusinessUnit = null then
		app.raiseCMException(Input_required_field_BusUnit,null,null);
		return;
	endif;

	if self.myExtFinanceIO = null or  not self.myExtFinanceIO.isKindOf(CM_SALInterface)   then
		app.raiseCMException(Must_select_termina_with_IFS,null,null);
		return ;
	endif;
	
	if self.myExtFinanceIO.exportPath = null then
	
	endif;
	
	
	iter:=app.myRoot.allAutoTasks.createIterator;
	app.myRoot.allAutoTasks.startKeyGeq(self.requestClassName,null,iter);
	
	while iter.next(task) do
		if not task.isKindOf(CM_AutoTaskIFS) then
			break;
		endif;
		
		if self.myBusinessUnit = task.CM_AutoTaskIFS.myBusinessUnit and	
			self.myExtFinanceIO = task.CM_AutoTaskIFS.myExtFinanceIO then
			if task &lt;&gt; real then
				app.raiseCMException2(Integ_task_alrea_exist_termi_b,self.myBusinessUnit.code,self.myExtFinanceIO.getNiceName,null,null);
				
				break;
			endif;
		endif;
		
	endwhile;
	
epilog
	delete iter;
end;</source>
    </JadeMethod>
</Class>
