	unloadArray.add("L,D1058O,S,0.0000,false,");
	unloadArray.add("P,D1058O,1,-6.70,0.00");
	unloadArray.add("P,D1058O,2,-0.80,0.00");
	unloadArray.add("P,D1058O,3,-0.80,2.40");
	unloadArray.add("P,D1058O,4,-6.70,2.40");
	unloadArray.add("P,D1058O,5,-6.70,0.00");

	idx := 0;
	ediFile.myEDIFileType.rawDataToHSA(ediFile, theLines);
	foreach ediText in theLines do
		idx := idx + 1;
		if idx &gt; unloadArray.size then
			self.assertFalseMsg(true, "There is more actual data then expected 2.");
		endif;
		if ediText &lt;&gt; unloadArray[idx] or idx = 1 then
//			write ediText;
//			write unloadArray[idx];
		endif;
		self.assertEqualMsg(ediText, unloadArray[idx], "line "&amp;idx.String&amp;" error 2.");
	endforeach;

	// extract proposed from voyage 2
	delete ediDataParams;
	create ediDataParams transient;
	ediFileType := app.myRoot.allEDIFileTypeUsersByName[UserDefinedShipManifest];
	if ediFileType &lt;&gt; null then
		clientRefNum := clientRefNum + 1;
		clientRef := method.name[1 : ediControllerAgent.ediClientRef.maxLength-1]&amp;clientRefNum.String;		// ie 30
		ediControllerAgent.setEdiClientRef(clientRef);
		ediDataProposed := ediControllerAgent.loadDeckPlanTIs(voyage2, PROPOSED_BAYPLANS, clientRef, voyage2.myOperator, ediFileType);
		ediDataParams.operator := voyage2.myOperator;
		ediFile := ediDataProposed.ediFileArray.last;//should be the one we just created 
		ediControllerAgent.extractFile(ediFile, ediDataProposed.number, ediDataParams);
	endif;
	voyCountExtract := 0;
	layoutCountExtract := 0;
	layoutPointCountExtract := 0; 
	tiCountExtract := 0;
	foreach ediTI in ediDataProposed.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDIVoyageHeaderTI) then
			voyCountExtract := voyCountExtract + 1;
		elseif ediTI.isKindOf(CM_EDILayoutTI) then
			layoutCountExtract := layoutCountExtract + 1;
		elseif ediTI.isKindOf(CM_EDILayoutPointTI) then
			layoutPointCountExtract := layoutPointCountExtract + 1;
		elseif ediTI.isKindOf(CM_EDICargoOnShipTI) then
			tiCountExtract := tiCountExtract + 1;
			if ediTI.id = ContainerId01 then
				self.assertEqual(ediTI.CM_EDICargoOnShipTI.getHazardsAsString(), "1.1, 1.2 (0450, 0440), 1.3");
			endif;
		endif;
	endforeach;
	self.assertEqual(voyCountExtract, voyCountLoad);
	self.assertEqual(layoutCountExtract, layoutCountLoad);//layoutCountLoad);
	self.assertEqual(layoutPointCountExtract, layoutPointCountLoad); //layoutPointCountLoad);
//	self.assertEqual(tiCountExtract, tiCountLoad);
	
	// now check the data lines
