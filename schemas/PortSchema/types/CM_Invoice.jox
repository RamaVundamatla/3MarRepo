    <JadeMethod name="getVoyageBerth" id="f382bf06-243d-4693-95a6-0e05d141d607">
        <source>getVoyageBerth() : String;
/*

Purpose:			Returns the Voyage Berth from voyage movements

Parameters:			NONE

Return Value:		String	Representing the berth code for the voyage movement

Date		Who		Reason
20 Sep 2023	navpw1	Initial creation TFS: 60179 (60188)
22 Nov 2023	navdap1	TFS 61218 POB | FR 60179 - Report Fields for Invoice Not Returning Expected Values
19 Feb 2024 navsaa30 ChangeRequest 61859: POB - Berth Description on Invoice Report
11 Mar 2025 navbs1   Bug MTN-34247: POB | Invoice Not Including Required Information
*/

vars
	invoiceLine		: CM_InvoiceLine;
	transaction		: CM_TITransaction;
	voyage			: CM_Voyage;
	hmsMovement		: HMS_VoyageMovement;
	berth			: HMS_Berth;
begin
	// TFS 61218 rewritten as follows:
	// The understanding is that a single invoice for POB will only contain transactions / cargo for 
	// a single berth i.e. cargo discharged or loaded at berth "A" will have a different debtor to
	// cargo discharged or loaded at berth "B"
	//
	// 1. Get the first invoice line with a transactionTI
	// 2. Get the voyage for the transaction
	// 3. Get the movement for the voyage that matches the date/time of the transaction
	// 4. Return the berth for that movement
	
	//11.03.2025 navbs1  #34247
	/*// 1. Get the first invoice line
 	invoiceLine := self.invoiceLines.first;
	if invoiceLine = null then
		return null;
	endif;
	
	// 2. Get the transaction that created this invoice line
	transaction := invoiceLine.myTransactionTI;
	if transaction = null then
		return null;
	endif;*/
	
	// 1. Get the first invoice line with a transactionTI
	foreach invoiceLine in self.invoiceLines discreteLock do 		//11.03.2025 navbs1  #34247
		if invoiceLine.myTransactionTI &lt;&gt; null and not invoiceLine.voided then 
			transaction := invoiceLine.myTransactionTI;
			break;
		endif;
	endforeach;
	
	if transaction = null then 										//11.03.2025 navbs1  #34247
		return null;
	endif;
	
	// 2. Get the voyage for the transaction
	voyage := transaction.getMyVoyage();
	if voyage = null then
		return null;
	endif;
	
	// 3. Get the movement for the voyage that matches the date/time of the transaction
	hmsMovement := voyage.getMovementForDateTime(transaction.dateTime);
	if hmsMovement = null then									// navsaa30 19.02.2024  #61859
		return null;
	endif;
	 						
	if hmsMovement.isMovementTypeDeparture then					// navsaa30 19.02.2024  #61859
		hmsMovement := hmsMovement.getMovementPrevious().HMS_VoyageMovement;
		if hmsMovement = null then
			return null;
		endif;
	endif;

	berth := hmsMovement.getMyBerth();
	if berth = null then
		 return null;
	endif;

	// 4. Return the berth for that movement
	return berth.code  &amp; " " &amp;  berth.description;				// navsaa30 19.02.2024  #61859
	
	/*allInvoiceLines := self.invoiceLines;
	if allInvoiceLines.isNotEmpty then							//Do we have invoice lines
		invoiceLine := allInvoiceLines.first;					//Get the first invoice line
		trackedItem := invoiceLine.getTrackedItem();			//Get the tracked item from the invoice line
		if trackedItem = null then								//If the tracked item is null check the transaction
			transaction := invoiceLine.myTransactionTI;			//Get the transaction
			if transaction &lt;&gt; null then
				trackedItem := transaction.myTrackedItem;		//Get the tracked item from the transaction
			endif;
		endif;
	endif;

	if trackedItem = null then									//If tracked item is still null get it from the invoice
		trackedItem := self.myTrackedItem;
	endif;

	if trackedItem = null then									//If we still do not have one return null as we cannot proceed further
		return null;
	endif;

	voyage := trackedItem.releaseVoyage;						//Get the release voyage
	if voyage = null then
		isDischarge := true;									//If the voyage is null then we are a discharge
		voyage:= trackedItem.receiveVoyage;						//Get the receival voyage
	endif;

	if voyage = null then										//If the voyage is still null get it from the invoice
		voyage := self.myVoyage;
	endif;

	if voyage = null then										//If the voyage is still null then return null as we cannot continue
		return null;
	endif;

	if isDischarge then											//If its a discharge voyage then get the arrival movement from the voyage
		hmsMovement := voyage.getMovementArrival();
	else
		hmsMovement := voyage.getMovementDeparture();			//Else get the departure movement
	endif;				

	if hmsMovement = null then									//If we do not have a voyage movement then return null as we cannot continue
		return null;
	endif;
	
	berth := hmsMovement.getMyBerth();							//Get the berth for the voyage movement
	
	if berth = null then										//If we do not have a berth then return null as we cannot continue further
		return null;
	endif;
	
	return berth.code;											//Return the berth code*/
epilog
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
