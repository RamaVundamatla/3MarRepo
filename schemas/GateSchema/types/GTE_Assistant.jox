end;</source>
        <Parameter name="pTable" type="CM_EntryTable" usage="input"/>
        <Parameter name="pShow" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showHidePercentScaled" id="028d7fa1-20dc-4c5c-acb8-67b753682bc3">
        <source>showHidePercentScaled(pTable : CM_EntryTable io; pShow : Boolean);
//--------------------------------------------------------------
//Created: 18 March 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if pTable &lt;&gt; null then
		if pShow then
			pTable.showRowByName(ETRow_PercentScaled, true);
			pTable.showRowByName(ETRow_TicketedAll, true);
			pTable.showRowByName(ETRow_TicketSequence, true);						
		else
			pTable.hideRowByName(ETRow_PercentScaled, true);
			pTable.hideRowByName(ETRow_TicketedAll, true);
			pTable.showRowByName(ETRow_TicketSequence, true);						
		endif;
	endif;
end;</source>
        <Parameter name="pTable" type="CM_EntryTable" usage="io"/>
