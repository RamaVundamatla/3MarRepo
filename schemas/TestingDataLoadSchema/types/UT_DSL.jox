    <JadeMethod name="addCamGroup" id="286e1f90-eaac-487b-a359-e9ed61c192ac">
        <source>addCamGroup(_code, _description, _recipient, _senderCode, _senderCodeDepot,	_facilityCode : String;
	_useCallSign, _useDailyFileName, _useVoyageOperator	: Boolean;
	_operators : CM_OperatorByCodeDict;	_freightForwarders : CM_ConsigneeConsignorSet;
	_maxSealLength : Integer; _shippersCode : String) : CM_CamGroup;
// cnwrs1 31 Jan 2011
vars
	proxyCamGroup : CM_CamGroup;
	realCamGroup : CM_CamGroup;
begin
	create proxyCamGroup transient;
	proxyCamGroup.setProxy(_code, _description, _recipient, _senderCode, _senderCodeDepot, _facilityCode, _shippersCode,
							_useCallSign, _useVoyageOperator, _useDailyFileName, _maxSealLength,
							_operators, _freightForwarders, self.getTerminal);
	app.myTrxCA.trxCreateCamGroup(proxyCamGroup, realCamGroup, app.myPassport);
	return realCamGroup;
epilog
	delete proxyCamGroup;
end;
</source>
