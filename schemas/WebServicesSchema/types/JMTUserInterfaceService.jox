    <JadeWebServicesMethod name="getCargoChecks" id="0714e8af-69a1-4194-bd4a-9dd8791da7ec">
        <source>getCargoChecks(cargoChecksRequest : WS_CargoChecksRequest) : WS_CargoChecksResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2011	cnwer1	Initial creation CCMS MES 1033
15 Oct   2015   cnwma1  PAR #36606 Web Service Methods need to validate Terminal/DataAccess on OIDs
*/

vars
	cargoCheck 		: CM_CargoCheck;
	cargoCheckItem	: CM_CargoCheckItem;
	response		: WS_CargoChecksResponse;
	completedOK		: Boolean;
	terminal		: CM_Terminal;
	cmifAutoPlan : CMIF_YAAutoPlanNormal;
	cargo : CM_TrackedItem;
	cargoCheckProxy : WS_CargoCheck;
	failedDAC 		: CM_DataAccessController;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	
	terminal := app.myPassport.myTerminal;
		
	if cargoChecksRequest.cargoUid = "" then
		completedOK := true;
		return response;	
	endif;
	
	//epr TFS 5535 4/8/17 
	cargo := app.myPassport.getObjectOfTypeFromOid(cargoChecksRequest.cargoUid,CM_TrackedItem).CM_TrackedItem;	
	if cargo = null then
		completedOK := true;
		return response;
	endif;

	// Check security access to this message, if required
	//app.checkCurrentUserHasAccess(PmAdmCargocheckMaint);		//	removed 20/4 - permission is for creating cargo checks in jmt, not validating in handheld
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	create cmifAutoPlan as CMIF_YAAutoPlanNormal transient;
	cmifAutoPlan.attachTI(cargo);
		
	cargoCheck:=terminal.allCargoChecks[cargoChecksRequest.context];

	if cargoCheck &lt;&gt; null then
		foreach cargoCheckItem in cargoCheck.allCargoCheckItems do
			if not cargoCheckItem.doesTIMatchMe(cmifAutoPlan) then
				continue;
			endif;
			
			create cargoCheckProxy transient;
			cargoCheckProxy.setProxyFromObjectAndSeals(terminal, null, cargoCheckItem);
			
			response.allCargoChecks.add(cargoCheckProxy);
		
		endforeach;	
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	// ...
	delete cmifAutoPlan;
	
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="cargoChecksRequest" type="WS_CargoChecksRequest"/>
        <ReturnType type="WS_CargoChecksResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getCargoChildrenFromCargoId" id="c2007b68-19c9-4182-8d47-6d2f600ebae8">
        <source>getCargoChildrenFromCargoId(cargoUid : String) : WS_TrackedItemQueryResponse webService;
/*
Purpose:			
Date				Who			Reason
FEBRUARY 2016		CNWAB1		Initial creation
*/



vars
	response		: WS_TrackedItemQueryResponse;
	completedOK		: Boolean;
	cargo 			: CM_TrackedItem;
	childCargo 		: CM_TrackedItem;
	proxyTI			: WS_TrackedItem;
	failedDAC 		: CM_DataAccessController;

begin

	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);

	// Create the response
	create response transient;

	if cargoUid = "" then
		completedOK := true;
		return response;
	endif;
	//epr TFS 5535 4/8/17 
	cargo := app.myPassport.getObjectOfTypeFromOid(cargoUid,CM_TrackedItem).CM_TrackedItem;	
	if cargo = null then
		completedOK := true;
		return response;
	endif;
	
	if cargo.allChildren.size &gt; 0 then
		foreach childCargo in cargo.allChildren do
			if childCargo.hasBeenMerged then
				continue;
			endif;
			
			if childCargo &lt;&gt; null and childCargo.canUserAccessSelf(app.getMyUser(), failedDAC, app.myPassport) then   
				create proxyTI transient;
				proxyTI.setProxyFromObject(childCargo);
				response.allTrackedItems.add(proxyTI);
			endif;	
		endforeach;
	endif;
	// Got to here, everything is ok
	completedOK := true;
	return response;

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction();
end;
</source>
        <Parameter name="cargoUid" type="String"/>
        <ReturnType type="WS_TrackedItemQueryResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getCargoFilterSites" id="76a80312-e8ba-4d56-a979-5c5a118298ed">
        <usesRPC>default</usesRPC>
        <source>getCargoFilterSites() : WS_CargoFilterSitesResponse webService;


/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 December 2008	#cnwdz2	PAR #17554 - Development of new RIA Web Service application

*/

vars
	response		: WS_CargoFilterSitesResponse;
	completedOK		: Boolean;
	cargoFilterSite	: WS_CargoFilterSite;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Populate response
	create cargoFilterSite transient;
	cargoFilterSite.description := CM_ContainerEnqForm.ANYSITE_STRING;
	cargoFilterSite.setFromSiteDesc(CM_ContainerEnqForm.ANYSITE_STRING);
	response.allCargoFilterSites.add(cargoFilterSite);
	
	create cargoFilterSite transient;
	cargoFilterSite.description := CM_ContainerEnqForm.ONSITE_STRING;
	cargoFilterSite.setFromSiteDesc(CM_ContainerEnqForm.ONSITE_STRING);
	response.allCargoFilterSites.add(cargoFilterSite);
	
	create cargoFilterSite transient;
	cargoFilterSite.description := CM_ContainerEnqForm.OFFSITE_STRING;
	cargoFilterSite.setFromSiteDesc(CM_ContainerEnqForm.OFFSITE_STRING);
	response.allCargoFilterSites.add(cargoFilterSite);
	
	create cargoFilterSite transient;
	cargoFilterSite.description := CM_ContainerEnqForm.ONSHIP_STRING;
	cargoFilterSite.setFromSiteDesc(CM_ContainerEnqForm.ONSHIP_STRING);
	response.allCargoFilterSites.add(cargoFilterSite);

	//29 Jan 2014	NDL Par 33347
//	create cargoFilterSite transient;
//	cargoFilterSite.description := CM_ContainerEnqForm.OFFLOADED_STRING;
//	cargoFilterSite.setFromSiteDesc(CM_ContainerEnqForm.OFFLOADED_STRING);
//	response.allCargoFilterSites.add(cargoFilterSite);

	create cargoFilterSite transient;
	cargoFilterSite.description := CM_ContainerEnqForm.NOTIFIED_STRING;
	cargoFilterSite.setFromSiteDesc(CM_ContainerEnqForm.NOTIFIED_STRING);
	response.allCargoFilterSites.add(cargoFilterSite);
	
	//29 Jan 2014	NDL Par 33347
//	create cargoFilterSite transient;
//	cargoFilterSite.description := CM_ContainerEnqForm.DELETED_STRING;
//	cargoFilterSite.setFromSiteDesc(CM_ContainerEnqForm.DELETED_STRING);
//	response.allCargoFilterSites.add(cargoFilterSite);
	
	if app.myRoot.isInterTerminalTransferEnabled() then		
		create cargoFilterSite transient;
		cargoFilterSite.description := CM_ContainerEnqForm.TRANSFER_STRING_TO;
		cargoFilterSite.setFromSiteDesc(CM_ContainerEnqForm.TRANSFER_STRING_TO);
		response.allCargoFilterSites.add(cargoFilterSite);
	
		create cargoFilterSite transient;
		cargoFilterSite.description := CM_ContainerEnqForm.TRANSFER_STRING_FROM;
		cargoFilterSite.setFromSiteDesc(CM_ContainerEnqForm.TRANSFER_STRING_FROM);
		response.allCargoFilterSites.add(cargoFilterSite);
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
