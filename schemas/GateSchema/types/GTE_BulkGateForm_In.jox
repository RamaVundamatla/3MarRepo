    <JadeMethod name="translateForm" id="4d522090-3cdf-4f9d-b444-687b2cfcd55a">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 09 June 2022 08:44:58.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021633, locale);
	btnCancel.translateBubbleHelp(Xlat_0021634, locale);
	btnCancel.translateCaption(Xlat_0021635, locale);
	btnClear.translateBubbleHelp(Xlat_0021636, locale);
	btnClear.translateCaption(Xlat_0021637, locale);
	btnFind.translateBubbleHelp(Xlat_0021638, locale);
	btnGetWeight.translateCaption(Xlat_0021639, locale);
	btnPrint.translateBubbleHelp(Xlat_0021640, locale);
	btnPrint.translateCaption(Xlat_0021641, locale);
	btnSave.translateBubbleHelp(Xlat_0021642, locale);
	btnSave.translateCaption(Xlat_0021643, locale);
//	grpTop.translateCaption(Xlat_0021645, locale);
	lblCargoId.translateCaption(Xlat_0021646, locale);
	lblCargoType.translateBubbleHelp(Xlat_0021647, locale);
	lblCargoType.translateCaption(Xlat_0021648, locale);
	lblCarrier.translateCaption(Xlat_0021649, locale);
	lblDirection.translateCaption(Xlat_0021650, locale);
	lblDirectionIcon.translateCaption(Xlat_0021651, locale);
	lblDriverCode.translateBubbleHelp(Xlat_0021652, locale);
	lblDriverCode.translateCaption(Xlat_0021653, locale);
	lblDriverName.translateBubbleHelp(Xlat_0021654, locale);
	lblDriverName.translateCaption(Xlat_0021655, locale);
	lblGate.translateCaption(Xlat_0021656, locale);
	lblGateLane.translateCaption(Xlat_0021657, locale);
	lblGatePrinter.translateCaption(Xlat_0021658, locale);
	lblInterchange.translateCaption(Xlat_0021659, locale);
	lblPIN.translateCaption(Xlat_0021660, locale);
	lblRFID.translateCaption(Xlat_0021661, locale);
	lblRegno.translateCaption(Xlat_0021662, locale);
	lblState.translateCaption(Xlat_0021663, locale);
	lblSubCarrier.translateCaption(Xlat_0024925, locale);
	lblVisitNo.translateCaption(Xlat_0021664, locale);
	lblVisitType.translateCaption(Xlat_0021665, locale);
	lblWeibridge.translateCaption(Xlat_0021666, locale);
	lblWeighbridgeMessage.translateCaption(Xlat_0021667, locale);
	lblWgtIN.translateCaption(Xlat_0021668, locale);
end;</source>
