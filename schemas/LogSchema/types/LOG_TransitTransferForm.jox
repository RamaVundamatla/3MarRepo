    <JadeMethod name="loadHatchPlace" id="f120a393-0939-4273-9378-be7ee51ee348">
        <source>loadHatchPlace(_cmb1 : ComboBox; _voyage : CM_Voyage; _addNulls : Boolean) protected;

vars

	count	:	Integer;

begin

	_cmb1.clear;
	if _addNulls then
		_cmb1.addItem(null);
	endif;
	foreach count in 1 to _voyage.myLogVoyageStructure.numHatches do
		_cmb1.addItem(count.String);
	endforeach;	

end;</source>
