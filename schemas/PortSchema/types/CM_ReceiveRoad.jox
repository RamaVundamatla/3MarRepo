    <JadeMethod name="getDisplayString" id="5910b8d9-3b51-48ff-8a3f-8e3c64fc1d12">
        <source>getDisplayString(): String;
// created by cnwvu1	26/02/2007
vars
	drstr, amountDisplay, lDetail : String;
begin

	if self.pinNo &lt;&gt; null then
		return 'PIN = ' &amp; self.pinNo;
	else // TFS 42882
		if self.isDirectReleaseMove then
			drstr := " DR ";
		endif;
		amountDisplay := '(' &amp; self.getAmountDisplay() &amp; ') ';
		if amountDisplay &lt;&gt; "() " then
			lDetail:= app.getErrorString(Received) &amp; drstr &amp; " " &amp; amountDisplay &amp; " "  &amp; lDetail;
		else
			lDetail:= app.getErrorString(Received) &amp; drstr &amp;  " " &amp; lDetail;
		endif;
		return lDetail;
	endif;

end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="8bd4c3ed-3a3f-41af-b6c2-46404d403b98">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	lDetail : String;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			return self.getDisplayString();
			
		endif;
							
	elseif _attrName = ETRow_ReceivePinNo then
		return self.pinNo;
	
	elseif _attrName = ETRow_ReceiveRoadFrom then	//14 May 2020	NDL	TFS 49202
		return self.locationRoad;
	elseif _attrName = ETRow_ReceiveRoadTo then	//14 May 2020	NDL	TFS 49202
		return self.locationYard;
	elseif _attrName = ETRow_TrailerType then	//21 Oct 2020	NDL	TFS 50113
		return self.getTrailerType();	
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
