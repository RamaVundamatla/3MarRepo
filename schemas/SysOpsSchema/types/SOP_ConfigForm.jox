    <JadeMethod name="saveSheet" id="be446887-d01f-427a-ad79-95743a5bde3f">
        <source>saveSheet(_sheet : Sheet);
// ---------------------------------------------------------------------------
// Created:     05 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 19 Jun 2017	cnwkpd1	TFS 3369 - Push Events application
// 25 Aug 2025  navec1	MTN-35151: Single Sign On via Okta for MTN Thin Client
// 24 Nov 2025 	navec1	MTN-36234: Okta SSO - Remember SSO Session
// 08 Dec 2025  navlc30 JIRA 36748 CUX - Enforce SSO Login
// ---------------------------------------------------------------------------

vars 
	ssoProvider: String; //54855, AjitM, navam1
begin
//	self.tblConfig.setValueByName(ETRow_AutoPop3Password, self.enteredPassword); //26 Aug 2021	NDL	TFS 51632 - Was moved to Terminal from Root in 2013, i.e no longer relevant here
	self.tblConfig.setValueByName(ETRow_AutoOutwardPassword, self.enteredPassword2);
//	self.tblConfig.setValueByName(ETRow_EventStreamPassword, self.enteredPassword3);
	self.tblConfig.setObjectFromTable(self.myIntFaceConfig, SOP_ConfigForm::setObjectFromTableSpecial.name, false);
//	self.tblConfig.setValueByName(ETRow_AutoPop3Password, "&lt;set&gt;");
	self.tblConfig.setValueByName(ETRow_AutoOutwardPassword, "&lt;set&gt;");
//	self.tblConfig.setValueByName(ETRow_EventStreamPassword, "&lt;set&gt;");

//	self.myIntFaceConfig.sensibleDateFrom	:=	self.tblConfig.getValueByName(ETRow_SensibleDateFrom).Date;
//	self.myIntFaceConfig.sensibleDateTo		:=	self.tblConfig.getValueByName(ETRow_SensibleDateTo).Date;
	self.myIntFaceConfig.sensibleDateFrom	:=	self.tblConfig.getValueAsDate(ETRow_SensibleDateFrom);
	self.myIntFaceConfig.sensibleDateTo		:=	self.tblConfig.getValueAsDate(ETRow_SensibleDateTo);
//	self.myIntFaceConfig.systemTitle		:=	self.tblConfig.getValueByName(ETRow_SystemTitle).String;//par 15403
	//Par 15403, the value was overwrited when the sheet was changed.
//	self.myIntFaceConfig.myTBNVessel		:=	self.cmbTBNVessel.listObject.CM_Vessel;
//	self.myIntFaceConfig.mySeaHarbourRegion	:=	self.cmbSeaRegion.listObject.HMS_HarbourRegion;

	//54855, AjitM, navam1
	ssoProvider := self.getSsoProviderListItem(self.myIntFaceConfig.CMIF_ConfigRoot.ssoProvider);
	if (ssoProvider &lt;&gt; app.mySSOAgent.SSO_Provider_MicrosoftDescr) then
		self.tblConfig.setValueByName(ETRow_SsoAzureClientId, null);
		self.tblConfig.setValueByName(ETRow_SsoAzureTenantId, null);
		self.tblConfig.setValueByName(ETRow_SsoAzureRememberTokenDef, false); //54866, AjitM, navam1
	endif;
	if (ssoProvider &lt;&gt; app.mySSOAgent.SSO_Provider_OktaDescr) then  // MTN-35151 - navec1 - Okta SSO
		self.tblConfig.setValueByName(ETRow_SsoOktaClientId, null);
		self.tblConfig.setValueByName(ETRow_SsoOktaClientSecret, null);
		self.tblConfig.setValueByName(ETRow_SsoOktaDomain, null);	
		self.tblConfig.setValueByName(ETRow_SsoOktaAudience, null);
		self.tblConfig.setValueByName(ETRow_SsoOktaIssuerURI, null);
		self.tblConfig.setValueByName(ETRow_SsoOktaRememberTokenDef, false); // MTN-36234 - navec1 - Okta Remember SSO Session
	endif;
	if ssoProvider = null then
		self.tblConfig.setValueByName(ETRow_SsoAzureClientId, null);
		self.tblConfig.setValueByName(ETRow_SsoAzureTenantId, null);
		self.tblConfig.setValueByName(ETRow_SsoAzureRememberTokenDef, false);	
		self.tblConfig.setValueByName(ETRow_SsoOktaRememberTokenDef, false);	// MTN-36234 - navec1 - Okta Remember SSO Session
		self.tblConfig.setValueByName(ETRow_SsoOktaClientId, null);  // MTN-35151 - navec1 - Okta SSO
		self.tblConfig.setValueByName(ETRow_SsoOktaClientSecret, null);
		self.tblConfig.setValueByName(ETRow_SsoOktaDomain, null);	
		self.tblConfig.setValueByName(ETRow_SsoOktaAudience, null);
		self.tblConfig.setValueByName(ETRow_SsoOktaIssuerURI, null);
		self.tblConfig.setValueByName(ETRow_SsoEnforceSingleSignOn, false);				//08.12.2025 navlc30 #36748
		self.myIntFaceConfig.ssoEnforceSingleSignOn := false;							//08.12.2025 navlc30 #36748
	endif;
end;</source>
        <Parameter name="_sheet" type="Sheet"/>
    </JadeMethod>
    <JadeMethod name="setAllEntTableDefs" id="31c4d2f3-a2a9-4cf2-85c3-9e7e00cecbe3">
        <source>setAllEntTableDefs(_constant : Constant; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     05 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str,
	defName	: String;
	pos		: Integer;
	
begin
	if _constant.valueAsInteger &lt;&gt; ConfigType_Root then
		return;
	endif;

	str := _constant.text;
	pos := 1;
	
	while (pos &gt; 0) do
		defName := str.cnEcGetNextTagValueOfName(XMLTag_DefName, pos);
		if defName &lt;&gt; null then
			self.allEntTableDefs.add(defName);
		endif;
	endwhile;
end;</source>
        <Parameter name="_constant" type="Constant"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setClient" id="d6de6a5f-4fcb-42d7-aca8-98725797302e">
        <source>setClient();
// ---------------------------------------------------------------------------
// Created:     07 October 2010 by cnwab1
/* Changes

Date		Name	TFS#		Description
============================================================================
30/09/2019 	jlgka1 	TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
============================================================================*/

vars
	client : String;
	motherShip : CMUI_SuperAppForm2;
	canDoThis : Boolean;
begin

  // ### JIRA 33851 24JAN2025 NAVAB1
//	if (not app.isDevelopmentSystem) then
	canDoThis:= ( app.myRoot.isClientJadeMaster
			or app.myRoot.isClientJMTTesting);
			

	if not canDoThis then
		app.msgBox("You can only change client if using a NAVIS license", "Error", MsgBox_OK_Only);
		global.beep;
		return;
	endif;

	// ### JIRA 33851 24JAN2025 NAVAB1
	if self.optClientGTUQ.value then 
		client := Client_GT_UMMQASAR;
	elseif self.optClientGPHA.value then
		client :=  Client_GPHA;
	elseif self.optClientQTerm.value then // ### JIRA 33710 20DEC2024 NAVAB1
		client :=  Client_QTerminals;
	elseif	self.optClientJMT.value then
		client := Client_JadeMaster;

	/*
	
	self.optClientWell.value then
		client := Client_CentrePort;
	elseif	self.optClientEverett.value then
		client := Client_PortEverett;
	elseif	self.optClientNelson.value then
		client := Client_PortNelson;
	elseif	self.optClientOtago.value then
		client := Client_PortOtago;
	elseif	self.optClientRioTint.value then
		client := Client_RioTinto;
	elseif	self.optClientSouth.value then
		client := Client_SouthPort;
	elseif	self.optClientTaur.value then
		client := Client_Tauranga;
	elseif	self.optClientOwens.value then
		client := Client_TollOwens;
	elseif	self.optClientTrinium.value then
		client := Client_TriniumDemo;
	elseif self.optClientNZL.value then
		client := Client_NZL;
	elseif self.optClientMessina.value then
		client := Client_Messina;
	elseif self.optClientGTUmQ.value then
		client := Client_GT_UMMQASAR;
		*/
	endif;
	
	beginTransaction;
		app.myRoot.setClient(client);

	commitTransaction;

	global.beep;
	
	//###
	//Give the database path so we can distinguish between other JMTerminals that may be open.
//	if app.isDevelopmentSystem then
	if canDoThis then  // ### JIRA 33851 24JAN2025 NAVAB1
		motherShip := app.getForm(CMUI_SuperAppForm2.name).CMUI_SuperAppForm2;
		if app.myRoot.client &lt;&gt; null then
			motherShip.caption := app.getProductName() &amp; ' - ' &amp; app.dbPath &amp; ". Client : " &amp; app.myRoot.client;
		else
			motherShip.caption := app.getProductName() &amp; ' - ' &amp; app.dbPath &amp; "." ;
		endif;
	endif;
	
	//###
	
	
	self.frmClient.visible := false;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="3427be37-3187-4758-8e8d-8f8e243d7557">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     03 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpBackColor	: Integer;

begin
	inheritMethod(_colorControl);
	
	tmpBackColor := self.backColor;
	
	self.fldConfig.backColor	:= tmpBackColor;
	self.shtEntTbl.backColor	:= tmpBackColor;
	
	self.setColorsForEntryTable(self.tblConfig);

end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setControlState" id="9c7bebbd-2903-43df-8b28-3f8ea60c5657">
        <updating/>
        <source>setControlState(editing: Boolean) updating, protected;
// ---------------------------------------------------------------------------
// Created:     16 May 2003 by cnwsb1
//	Date		Who		Reason
//	16/02/2022	NAVCS2	Bug 52844
// ---------------------------------------------------------------------------
vars
	canEdit : Boolean;

begin
	canEdit := app.myPassport.myUser.canDo(app.myPassport.myTerminal, PmAdmConfigMaint);

	self.btnEditNew.visible := canEdit and not editing;
	self.btnSaveBase.visible := canEdit and editing;
	self.btnCancelBase.enabled := editing; //Bug 52844	16/02/2022	NAVCS2
end;</source>
        <access>protected</access>
        <Parameter name="editing" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setObjectFromTableSpecial" id="44980710-233f-47d4-864d-c24a4aee05c5">
        <source>setObjectFromTableSpecial(_attrName : String;
						_strValue : String;
						_obj : Object input;
						_tbl : CM_EntryTable input) : Boolean;
// ---------------------------------------------------------------------------
// Created:     04 December 2003 by cnwrs2
//
//	********************************************************************************
//	** NOTE: ANY CHANGES HERE MUST ALSO BE REFLECTED IN setTableFromObjectSpecial **
//	********************************************************************************
//
// Purpose:     
//
// Changed On			By		Reason
// 24 Nov  2025 		navec1	MTN-36234: Okta SSO - Remember SSO Session
// 01 Dec 2025          navlc30 JIRA 36748 CUX - Enforce SSO Login
// ---------------------------------------------------------------------------
// 
vars
	rtnCode		: Boolean;
	remSSOSession : Integer; //54866, AjitM, navam1
	ssoProvider : Integer; 	//54866, AjitM, navam1
begin
	rtnCode := true;
	
	if _attrName = ETRow_SensibleDateFrom then
//		_obj.CMIF_ConfigRoot.sensibleDateFrom	:=	self.tblConfig.getValueByName(ETRow_SensibleDateFrom).Date;
		_obj.CMIF_ConfigRoot.sensibleDateFrom	:=	self.tblConfig.getValueAsDate(ETRow_SensibleDateFrom);
	elseif _attrName = ETRow_SensibleDateTo then
//		_obj.CMIF_ConfigRoot.sensibleDateTo		:=	self.tblConfig.getValueByName(ETRow_SensibleDateTo).Date;
		_obj.CMIF_ConfigRoot.sensibleDateTo		:=	self.tblConfig.getValueAsDate(ETRow_SensibleDateTo);
	elseif _attrName = ETRow_SystemTitle then
		_obj.CMIF_ConfigRoot.systemTitle		:=	self.tblConfig.getValueByName(ETRow_SystemTitle).String;
	elseif _attrName = ETRow_MyInvBusHrsDayTypeNorm then // PAR 30681
		_obj.CMIF_ConfigRoot.myInvBusHrsDayTypeNorm := self.cmbCalNormal.listObject.CM_DayType;  
	elseif _attrName = ETRow_MyInvBusHrsDayTypeExcl then // PAR 30681
		_obj.CMIF_ConfigRoot.myInvBusHrsDayTypeExcl := self.cmbCalExclusion.listObject.CM_DayType;  

	elseif _attrName = ETRow_AutoToDoTaskDesc then
		_obj.CMIF_ConfigRoot.autoToDoTaskDesc	:=	self.tblConfig.getValueByName(ETRow_AutoToDoTaskDesc).CM_ToDoTaskDesc;
	elseif _attrName = ETRow_PortLogoPic then
		_obj.CMIF_ConfigRoot.portLogoPic		:=	self.tblConfig.getValueByName(ETRow_PortLogoPic).Binary;
	elseif _attrName = ETRow_SystemBackgroundPic then
		_obj.CMIF_ConfigRoot.systemBackgroundPic:=	self.tblConfig.getValueByName(ETRow_SystemBackgroundPic).Binary;
	elseif _attrName = ETRow_HelpFileFormat then			// PAR #34210
		_obj.CMIF_ConfigRoot.helpFileFormat := self.cmbHelpFileType.itemData[self.cmbHelpFileType.listIndex];
	elseif _attrName = ETRow_MyTBNVessel then
		_obj.CMIF_ConfigRoot.myTBNVessel		:=	self.cmbTBNVessel.listObject.CM_Vessel;
	elseif _attrName = ETRow_MySeaHarbourRegion then
		_obj.CMIF_ConfigRoot.mySeaHarbourRegion	:=	self.cmbSeaRegion.listObject.HMS_HarbourRegion;
//	elseif _attrName = ETRow_AutoPop3Password then
//		_obj.CMIF_ConfigRoot.autoPop3Password	:=	self.tblConfig.getValueByName(ETRow_AutoPop3Password).String;
	elseif _attrName = ETRow_SystemTitle then
		_obj.CMIF_ConfigRoot.systemTitle		:=	self.tblConfig.getValueByName(ETRow_SystemTitle).String;
	elseif _attrName = ETRow_AutoAuthType then
		_obj.CMIF_ConfigRoot.autoAuthType		:= self.cmbAuthType.itemData[self.cmbAuthType.listIndex];
	elseif _attrName = ETRow_AutoUseSSL then
		_obj.CMIF_ConfigRoot.autoUseSSL		:= self.cmbSSL.itemData[self.cmbSSL.listIndex];
	elseif _attrName = ETRow_AutoInwardSSLUsage then
		_obj.CMIF_ConfigRoot.autoInwardSSLUsage		:= self.cmbInwardSSL.itemData[self.cmbInwardSSL.listIndex];
	elseif _attrName = ETRow_MaxAsyncProcesses then //04 April 2024   annamth     CR 61540
		_obj.CMIF_ConfigRoot.maxAsyncProcesses		:= self.tblConfig.getValueByName(ETRow_MaxAsyncProcesses).Integer;
	elseif _attrName = ETRow_MaxWorkersPerUser then //04 April 2024   annamth     CR 61540
		_obj.CMIF_ConfigRoot.maxWorkersPerUser		:= self.tblConfig.getValueByName(ETRow_MaxWorkersPerUser).Integer;
	elseif _attrName = ETRow_AutoEmailSoftware then
		if self.cmbSoftware.listIndex &gt; 0 then
			_obj.CMIF_ConfigRoot.autoEmailSoftware := self.cmbSoftware.itemData[self.cmbSoftware.listIndex];
		endif;
	elseif _attrName = ETRow_EmailLicenseType then			// PAR 22506
		_obj.CMIF_ConfigRoot.emailLicenseType := app.emailLicenseType_StrToEnum(_strValue);
		return true;
	elseif _attrName = ETRow_SsoProvider then			//20.07.2022 navam1 #52824
		if self.cmbSSOProvider.listIndex  &gt; 0 then
			_obj.CMIF_ConfigRoot.ssoProvider := self.cmbSSOProvider.itemData[self.cmbSSOProvider.listIndex];
		endif;	
	elseif _attrName = ETRow_EnablePagination then //jlier1 JIRA-35565 28/7/25
		if not self.tblConfig.isRowVisible(ETRow_EnablePagination) then
			_obj.CMIF_ConfigRoot.enablePagination:= app.myRoot.getConfig(EnablePagination).Boolean;
			return true;
		endif;
		return false;
	
	elseif _attrName = ETRow_SsoAzureRememberTokenDef then			//21.09.2022 navam1 #54866
		// ### TFS 55220 25Oct2022 NAVPW1
		if self.cmbSSOProvider.listIndex &lt; 1 then
			_obj.CMIF_ConfigRoot.ssoAzureRememberTokenDef := false;	
			return rtnCode;
		endif;
		// ### TFS 55220 25Oct2022 NAVPW1
		
		ssoProvider := self.cmbSSOProvider.itemData[self.cmbSSOProvider.listIndex];
		if ssoProvider &gt; 0 then
			if ssoProvider = CMIF_SSOHelper.SSO_Provider_Default then
				_obj.CMIF_ConfigRoot.ssoAzureRememberTokenDef := false;	
			else
				if self.cmbRemSSOSession.listIndex  &gt; 0 then
					remSSOSession := self.cmbRemSSOSession.itemData[self.cmbRemSSOSession.listIndex];
					if remSSOSession = RemSSOSessionEnabled then
						_obj.CMIF_ConfigRoot.ssoAzureRememberTokenDef := true;
					else
						_obj.CMIF_ConfigRoot.ssoAzureRememberTokenDef := false;
					endif;
				endif;
			endif;
		endif;
		
	elseif _attrName = ETRow_SsoOktaRememberTokenDef then			// MTN-36234 - navec1 - Okta Remember SSO Session
		if self.cmbSSOProvider.listIndex &lt; 1 then
			_obj.CMIF_ConfigRoot.ssoOktaRememberTokenDef := false;
			return rtnCode;
		endif;
		
		ssoProvider := self.cmbSSOProvider.itemData[self.cmbSSOProvider.listIndex];
		if ssoProvider &gt; 0 then
			if ssoProvider = CMIF_SSOHelper.SSO_Provider_Default then
				_obj.CMIF_ConfigRoot.ssoOktaRememberTokenDef := false;
			else
				if self.cmbRemSSOSession.listIndex  &gt; 0 then
					remSSOSession := self.cmbRemSSOSession.itemData[self.cmbRemSSOSession.listIndex];
					if remSSOSession = RemSSOSessionEnabled then
						_obj.CMIF_ConfigRoot.ssoOktaRememberTokenDef := true;
					else
						_obj.CMIF_ConfigRoot.ssoOktaRememberTokenDef := false;
					endif;
				endif;
			endif;
		endif;
  	elseif _attrName = ETRow_SsoEnforceSingleSignOn then 			//01.12.2025 navlc30 #36748
		_obj.CMIF_ConfigRoot.ssoEnforceSingleSignOn		:= self.tblConfig.getValueByName(ETRow_SsoEnforceSingleSignOn).Boolean;	
	else
		rtnCode	:=	false;
	endif;
	
	return rtnCode;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_strValue" type="String"/>
        <Parameter name="_obj" type="Object" usage="input"/>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTableFromObjectSpecial" id="5a3f16ec-4fdb-411f-b203-bb7d7b022418">
        <updating/>
        <source>setTableFromObjectSpecial(_tbl : CM_EntryTable input; _attrName : String; _row : Integer; _obj : Object) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     09 September 2002 by cnwdf1
//
//	********************************************************************************
//	** NOTE: ANY CHANGES HERE MUST ALSO BE REFLECTED IN setObjectFromTableSpecial **
//	********************************************************************************
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26 May 2014	cnwkpd1	PAR #34210 - CCMS SFW 1350 - Online Documentation
// 19 Jun 2017	cnwkpd1	TFS 3369 - Push Events application
// 19/06/2018 	JLGNS1	Bug 39307: JMT - 1090 Error (Sytem Config)
// 24 Nov 2025 	navec1	MTN-36234: Okta SSO - Remember SSO Session
// 01 Dec 2025  navlc30 JIRA 36748 CUX - Enforce SSO Login
// ---------------------------------------------------------------------------
vars
	vesselObj	: CM_Vessel;
	regionObj	: HMS_HarbourRegion;
	
begin
	if _attrName = ETRow_AutoToDoTaskDesc then
		_tbl.setValue(_row, self.myIntFaceConfig.CMIF_ConfigRoot.autoToDoTaskDescDesc);
		return true;
	elseif _attrName = ETRow_SystemBackgroundPic then
		_tbl.setValue(_row, self.myIntFaceConfig.CMIF_ConfigRoot.systemBackgroundPic);
		return true;

	elseif _attrName = ETRow_HelpFileFormat then			// PAR #34210
		self.cmbHelpFileType.listIndex := self.getHelpFileTypeListIndex(self.myIntFaceConfig.CMIF_ConfigRoot.helpFileFormat);
		_tbl.setValue(_row, self.cmbHelpFileType.text);
		return true;	
	elseif _attrName = ETRow_MyInvBusHrsDayTypeNorm then  // PAR 30681

		if self.myIntFaceConfig.CMIF_ConfigRoot.myInvBusHrsDayTypeNorm &lt;&gt; null then 
			_tbl.setValue(_row, self.myIntFaceConfig.CMIF_ConfigRoot.myInvBusHrsDayTypeNorm.description);
			self.cmbCalNormal.listObject := self.myIntFaceConfig.CMIF_ConfigRoot.myInvBusHrsDayTypeNorm; // PAR 30681
		else 
			_tbl.setValue(_row, null);
			self.cmbCalNormal.listIndex := -1;
		endif;

	elseif _attrName = ETRow_MyInvBusHrsDayTypeExcl then  // PAR 30681

		if self.myIntFaceConfig.CMIF_ConfigRoot.myInvBusHrsDayTypeExcl &lt;&gt; null then 						// Bug 39307
			_tbl.setValue(_row, self.myIntFaceConfig.CMIF_ConfigRoot.myInvBusHrsDayTypeExcl.description);
			self.cmbCalExclusion.listObject := self.myIntFaceConfig.CMIF_ConfigRoot.myInvBusHrsDayTypeExcl; // PAR 30681
		else 
			_tbl.setValue(_row, null);
			self.cmbCalExclusion.listIndex := -1;
		endif;
	elseif _attrName = ETRow_PortLogoPic then
		_tbl.setValue(_row, self.myIntFaceConfig.CMIF_ConfigRoot.portLogoPic);
		return true;
	elseif _attrName = ETRow_SensibleDateFrom then
		_tbl.setValue(_row, self.myIntFaceConfig.CMIF_ConfigRoot.sensibleDateFrom);
		return true;
	elseif _attrName = ETRow_SensibleDateTo	then
		_tbl.setValue(_row, self.myIntFaceConfig.CMIF_ConfigRoot.sensibleDateTo);
		return true;
	elseif _attrName = ETRow_MyTBNVessel then
		vesselObj	:=	self.myIntFaceConfig.CMIF_ConfigRoot.myTBNVessel;
		
		if vesselObj &lt;&gt; null then
			_tbl.setValue(_row, vesselObj.getDisplayDetails(false));
			cmbTBNVessel.cnEcSetObjectIndex(vesselObj);
			return true;
		else
			return false;
		endif;
	elseif _attrName = ETRow_MySeaHarbourRegion then
		regionObj	:=	self.myIntFaceConfig.CMIF_ConfigRoot.mySeaHarbourRegion;
		
		if regionObj &lt;&gt; null then
			_tbl.setValue(_row, regionObj.getDisplayString());
			cmbSeaRegion.cnEcSetObjectIndex(regionObj);
			return true;
		else
			return false;
		endif;
/* 26 Aug 2021	NDL	TFS 51632 - Was moved to Terminal from Root in 2013, i.e no longer relevant here
		elseif _attrName = ETRow_AutoPop3Password then
		self.enteredPassword := self.myIntFaceConfig.CMIF_ConfigRoot.autoPop3Password;
		if self.enteredPassword &lt;&gt; null then
			tblConfig.setValueByName(ETRow_AutoPop3Password, '&lt;set&gt;');
//			tblConfig.text := '&lt;set&gt;';
		else
			tblConfig.setValueByName(ETRow_AutoPop3Password, null);
//			tblConfig.text := null;
		endif;
		
		return true; */
	elseif _attrName = ETRow_AutoOutwardPassword then
		self.enteredPassword2 := self.myIntFaceConfig.CMIF_ConfigRoot.autoOutwardPassword;
		if self.enteredPassword2 &lt;&gt; null then
			tblConfig.setValueByName(ETRow_AutoOutwardPassword, '&lt;set&gt;');
//			tblConfig.text := '&lt;set&gt;';
		else
			tblConfig.setValueByName(ETRow_AutoOutwardPassword, null);
//			tblConfig.text := null;
		endif;
		return true;
		
	elseif _attrName = ETRow_EmailLicenseType then			// PAR 22506
		_tbl.setValue(_row, app.emailLicenseType_EnumToStr(self.myIntFaceConfig.CMIF_ConfigRoot.emailLicenseType));
		return true;
		
	elseif _attrName = ETRow_SystemTitle then
		_tbl.setValue(_row, self.myIntFaceConfig.CMIF_ConfigRoot.systemTitle);
		return true;
	elseif _attrName = ETRow_AutoAuthType then
		self.cmbAuthType.listIndex := self.getAuthTypeListIndex(self.myIntFaceConfig.CMIF_ConfigRoot.autoAuthType);
		_tbl.setValue(_row, self.cmbAuthType.text);
		return true;
	elseif _attrName = ETRow_AutoUseSSL then
		self.cmbSSL.listIndex := self.getSSLListIndex(self.myIntFaceConfig.CMIF_ConfigRoot.autoUseSSL);
		_tbl.setValue(_row, self.cmbSSL.text);
		return true;
	elseif _attrName = ETRow_AutoInwardSSLUsage then
		self.cmbInwardSSL.listIndex := self.getSSLListIndex(self.myIntFaceConfig.CMIF_ConfigRoot.autoInwardSSLUsage);
		_tbl.setValue(_row, self.cmbInwardSSL.text);
		return true;
	elseif _attrName = ETRow_AutoEmailSoftware then
		self.cmbSoftware.listIndex := self.getEmailSoftwareListIndex(self.myIntFaceConfig.CMIF_ConfigRoot.autoEmailSoftware);
		_tbl.setValue(_row, self.cmbSoftware.text);
		return true;
/*	elseif _attrName = ETRow_EventStreamPassword then
		self.enteredPassword3 := self.myIntFaceConfig.CMIF_ConfigRoot.eventStreamPassword;
		if self.enteredPassword3 &lt;&gt; null then
			tblConfig.setValueByName(ETRow_EventStreamPassword, '&lt;set&gt;');
		else
			tblConfig.setValueByName(ETRow_EventStreamPassword, null);
		endif;
		return true; */
	elseif _attrName = ETRow_UserEmailTemplate then	//21 May 2018	NDL	TFS 39768
		if self.myIntFaceConfig.CMIF_ConfigRoot.userEmailTemplate = null then
			tblConfig.setValueByName(ETRow_UserEmailTemplate, app.getErrorString(Not_Set) &amp; ", " &amp; app.getErrorString(Dbl_Click_Edit_View) );
		else
			tblConfig.setValueByName(ETRow_UserEmailTemplate, app.getErrorString(Set_Only) &amp; ", " &amp; app.getErrorString(Dbl_Click_Edit_View) ); //Dbl_Click_Edit_View
		endif;
		return true;
	elseif _attrName = ETRow_SsoProvider then			//20.07.2022 navam1 #52824
		self.cmbSSOProvider.listIndex := self.getSsoProviderListIndex(self.myIntFaceConfig.CMIF_ConfigRoot.ssoProvider);
		_tbl.setValue(_row, self.cmbSSOProvider.text);
		return true;	
	elseif _attrName = ETRow_SsoAzureRememberTokenDef then			//21.09.2022 navam1 #54866
		self.cmbRemSSOSession.listIndex := self.getRemSSOSessionListIndex(self.myIntFaceConfig.CMIF_ConfigRoot.ssoAzureRememberTokenDef);
		_tbl.setValue(_row, self.cmbRemSSOSession.text);
		return true;
	elseif _attrName = ETRow_SsoOktaRememberTokenDef then			// MTN-36234 - navec1 - Okta Remember SSO Session
		self.cmbRemSSOSession.listIndex := self.getRemSSOSessionListIndex(self.myIntFaceConfig.CMIF_ConfigRoot.ssoOktaRememberTokenDef);
		_tbl.setValue(_row, self.cmbRemSSOSession.text);
		return true;
	elseif _attrName = ETRow_SsoEnforceSingleSignOn then			//01.12.2025 navlc30 #36748
		_tbl.setValue(_row, self.myIntFaceConfig.CMIF_ConfigRoot.ssoEnforceSingleSignOn);
		return true;		
	elseif _attrName = ETRow_MaxAsyncProcesses then			//04 April 2024   annamth     CR 61540
		_tbl.setValue(_row, self.myIntFaceConfig.CMIF_ConfigRoot.maxAsyncProcesses);
		return true;
	elseif _attrName = ETRow_MaxWorkersPerUser then			//04 April 2024   annamth     CR 61540
		_tbl.setValue(_row, self.myIntFaceConfig.CMIF_ConfigRoot.maxWorkersPerUser);
		return true;
	else
		return false;
	endif;

end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="beed3efd-9b2a-4642-9add-bdaec0b6fa08">
        <updating/>
        <source>setupForm() updating;
/*

Date		Who		Reason
26 May 2014	cnwkpd1	PAR #34210 - CCMS SFW 1350 - Online Documentation	
19 Jun 2017	cnwkpd1	TFS 3369 - Push Events application

*/

vars
	entTableDef	: EntTableDef;	
	tmpSheet	: CMUI_Sheet;
	tmpBackColor,
	idx, currSymbol			: Integer;
	defName		: String;
	
begin
	inheritMethod();
	
	self.toolbarStyle	:=	self.ToolbarStyle_ShowNoHide;
	self.showToolbar	:=	true;
	
	self.fldConfig.useSheetBackColors	:=	true;
	self.fldConfig.setDefaultSheetBackColors();
	
	tblConfig.pictureViewMethod		:=	'picViewMethod';
	tblConfig.pictureLoadMethod		:=	'picLoadMethod';
	tblConfig.pictureExtractMethod	:=	'picExtractMethod';
	self.fldConfig.initSheetBackColors();
	
	create self.myIntFaceConfig transient;
	self.myIntFaceConfig.setFromPersistentData(app.myRoot);
	
	app.processGlobalConstantGroup(PortSchemaName, ConfigTypeConstants, SOP_ConfigForm::setAllEntTableDefs.name, self);
	tmpBackColor	:=	self.colorControlBack;
	idx				:=	0;
	
	foreach defName in self.allEntTableDefs do
		entTableDef := app.myController.getEntTableDef(defName);
		
		if entTableDef = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Unknown def (' &amp; defName &amp; ')');
			continue;
		endif;

		if idx = 0 then
			tmpSheet	:=	shtEntTbl;
		else
			tmpSheet	:=	shtEntTbl.getControl(idx).CMUI_Sheet;
			
			if tmpSheet = null then
				tmpSheet			:=	shtEntTbl.loadControl(idx).CMUI_Sheet;
				tmpSheet.backColor	:=	tmpBackColor;
			endif;
		endif;
		
		idx					:=	idx + 1;
		tmpSheet.caption	:=	entTableDef.description;
	endforeach;
	
	self.loadComboVessels();
	self.loadComboSeaRegion();
	self.loadCombosEmail();
	self.loadCombosDefaults();		// PAR #34210
	self.loadCombosAuto();			// TFS 3369
	self.buildComboDayTypes();  // PAR 30681
	self.loadComboSsoProvider();	//20.07.2022 navam1 #52824
	self.loadComboRemSSOSession();	//21.09.2022 navam1 #54866
	self.showSheet(fldConfig.topSheet.CMUI_Sheet);
	tblConfig.userInputEnabled	:=	false;
	self.setControlState(false);
	self.setNavigatorHeading(self.caption);
end;</source>
    </JadeMethod>
    <JadeMethod name="showClients" id="8e5de476-4f6c-4ef9-b478-161a261b0889">
        <source>showClients();
// ---------------------------------------------------------------------------
// Created:		20 July 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	client : String;
begin
	self.frmClient.visible := not self.frmClient.visible;
		
	client := app.myRoot.client;
	
	// ### JIRA 33851 24JAN2025 NAVAB1
	if client = Client_GPHA then
		self.optClientGPHA.value := true;
	elseif client = Client_GT_UMMQASAR then 
		self.optClientGTUQ.value := true;
	elseif client =  Client_QTerminals then // ### JIRA 33710 20DEC2024 NAVAB1
		self.optClientQTerm.value := true;
	elseif client = Client_JadeMaster then
		self.optClientJMT.value := true;
		
		/*
	elseif client = Client_CentrePort then
		self.optClientWell.value := true;
	elseif client = Client_PortEverett then
		self.optClientEverett.value := true;
	elseif client = Client_PortNelson then
		self.optClientNelson.value := true;
	elseif client = Client_PortOtago then
		self.optClientOtago.value := true;
	elseif client = Client_RioTinto then
		self.optClientRioTint.value := true;
	elseif client = Client_SouthPort then
		self.optClientSouth.value := true;
	elseif client = Client_Tauranga then
		self.optClientTaur.value := true;
	elseif client = Client_TollOwens then
		self.optClientOwens.value := true;
	elseif client = Client_TriniumDemo then
		self.optClientTrinium.value := true;
	elseif client = Client_NZL then
		self.optClientNZL.value := true;
	elseif client = Client_Messina then
		self.optClientMessina.value := true;

	elseif client = Client_SCTOslo then
		self.optClientOSLO.value := true;
	elseif client = Client_GT_UMMQASAR then
		self.optClientGTUmQ.value := true;
	elseif client = Client_GT_RUWAIS then
		self.optClientGTRUW.value := true;
		*/
	endif;
	
	self.frmClient.centreWindow();
	self.frmClient.zOrder(1);
end;</source>
    </JadeMethod>
    <JadeMethod name="showHideMsgSearch" id="a159fb48-a475-4a4d-95f5-6b016daacc1b">
        <source>showHideMsgSearch();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 March 2011	cnwndl1	Initial creation

*/

vars

begin

	if self.frmSearchMsg.visible then
		self.frmSearchMsg.visible := false;
		self.btnSearchMsg.default := false;
	else
		
		self.frmSearchMsg.parent := self;
		self.frmSearchMsg.top := self.height /2;
		self.frmSearchMsg.visible := true;
		self.frmSearchMsg.zOrder(1);
		self.txtSearchMsg.setFocus();
		self.btnSearchMsg.default := true;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showHideSSORows" id="32862d0f-b615-4b29-9839-e95c33d92f94">
        <source>showHideSSORows(_value : Integer) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 July 2022 navam1 ChangeRequest 52824: EUP - Azure Active Directory Single Sign On - MTN
25 Aug  2025 navec1	MTN-35151: Single Sign On via Okta for MTN Thin Client
24 Nov  2025 navec1	MTN-36234: Okta SSO - Remember SSO Session
01 Dec 2025 navlc30 JIRA 36748 CUX - Enforce SSO Login

*/

vars
	theTable : CM_EntryTable;
	val	: String;
begin
	theTable := self.tblConfig;
	
	val:= self.getSsoProviderListItem(_value);

	if val &lt;&gt; null and val = app.mySSOAgent.SSO_Provider_MicrosoftDescr then
		theTable.showRowByName(ETRow_SsoAzureRememberTokenDef, false);
		theTable.showRowByName(ETRow_SsoAzureClientId, false);
		theTable.showRowByName(ETRow_SsoAzureTenantId, false);
		theTable.hideRowByName(ETRow_SsoOktaRememberTokenDef, false);	// MTN-36234 - navec1 - Okta Remember SSO Session
		theTable.hideRowByName(ETRow_SsoOktaClientId, false);
		theTable.hideRowByName(ETRow_SsoOktaClientSecret, false);
		theTable.hideRowByName(ETRow_SsoOktaDomain, false);	
		theTable.hideRowByName(ETRow_SsoOktaAudience, false);	
		theTable.hideRowByName(ETRow_SsoOktaIssuerURI, false);
		theTable.showRowByName(ETRow_SsoEnforceSingleSignOn, false);	//01.12.2025 navlc30 #36748	
	elseif val &lt;&gt; null and val = app.mySSOAgent.SSO_Provider_OktaDescr then
		theTable.hideRowByName(ETRow_SsoAzureRememberTokenDef, false);
		theTable.hideRowByName(ETRow_SsoAzureClientId, false);
		theTable.hideRowByName(ETRow_SsoAzureTenantId, false);
		theTable.showRowByName(ETRow_SsoOktaRememberTokenDef, false);	// MTN-36234 - navec1 - Okta Remember SSO Session
		theTable.showRowByName(ETRow_SsoOktaClientId, false);
		theTable.showRowByName(ETRow_SsoOktaClientSecret, false);
		theTable.showRowByName(ETRow_SsoOktaDomain, false);	
		theTable.showRowByName(ETRow_SsoOktaAudience, false);	
		theTable.showRowByName(ETRow_SsoOktaIssuerURI, false);	
		theTable.showRowByName(ETRow_SsoEnforceSingleSignOn, false);	//01.12.2025 navlc30 #36748	
	else
		theTable.hideRowByName(ETRow_SsoAzureRememberTokenDef, false);
		theTable.hideRowByName(ETRow_SsoAzureClientId, false);
		theTable.hideRowByName(ETRow_SsoAzureTenantId, false);
		theTable.hideRowByName(ETRow_SsoOktaRememberTokenDef, false);	// MTN-36234 - navec1 - Okta Remember SSO Session
		theTable.hideRowByName(ETRow_SsoOktaClientId, false);
		theTable.hideRowByName(ETRow_SsoOktaClientSecret, false);
		theTable.hideRowByName(ETRow_SsoOktaDomain, false);	
		theTable.hideRowByName(ETRow_SsoOktaAudience, false);	
		theTable.hideRowByName(ETRow_SsoOktaIssuerURI, false);	
		theTable.hideRowByName(ETRow_SsoEnforceSingleSignOn, false);	//01.12.2025 navlc30 #36748		
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showSheet" id="d30e1de7-158e-45e5-8db7-aee763f83acd">
        <updating/>
        <source>showSheet(_sheet : CMUI_Sheet input) updating;
// ---------------------------------------------------------------------------
// Created:     05 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20/08/2020	jlgdap1		TFS 49764 MTN Retire Basic Authentication to Exchange Online
// ---------------------------------------------------------------------------
vars
	entTableDef	: EntTableDef;
	idx			: Integer;
	defName		: String;

begin

	idx := _sheet.index + 1;		// Add one as this sheets are zero based
	if idx &gt; self.allEntTableDefs.size then
		return;
	endif;

	tblConfig.parent := _sheet;
	
	defName := self.allEntTableDefs[idx];
	entTableDef := app.myController.getEntTableDef(defName);
	tblConfig.setEntTableDef(entTableDef, null, null);
	
	if defName = ETDef_EmailServerConfig then // par 22506
		//self.initEmailLicenseTypeCombo();															// TFS 49764
		self.initEmailLicenseTypeCombo(self.myIntFaceConfig.emailLicenseType = EmailLicenseType_2);	// TFS 49764
	endif;

	//20.07.2022 navam1 #52824
	if defName = ETDef_SecurityConfig then
		self.showHideSSORows(self.myIntFaceConfig.CMIF_ConfigRoot.ssoProvider);
	endif;
	
	tblConfig.setTableFromObject(self.myIntFaceConfig, SOP_ConfigForm::setTableFromObjectSpecial.name);

	self.myAssistant.comboBoxAutoTDTDesc(cmbAutoTDTDesc, self.myIntFaceConfig.CMIF_ConfigRoot.autoToDoTaskDesc);
	self.myAssistant.comboBoxAutoTimerInterval(cmbTimerGet, self.myIntFaceConfig.CMIF_ConfigRoot.autoTimerGetEmail);
	self.myAssistant.comboBoxAutoTimerInterval(cmbTimerProcess, self.myIntFaceConfig.CMIF_ConfigRoot.autoTimerProcessFiles);
	self.myAssistant.comboBoxAutoTimerInterval(cmbTimerSend, self.myIntFaceConfig.CMIF_ConfigRoot.autoTimerSendEmail);
	
	self.tblConfig.setValueByName(ETRow_SensibleDateFrom, self.myIntFaceConfig.CMIF_ConfigRoot.sensibleDateFrom);
	self.tblConfig.setValueByName(ETRow_SensibleDateTo, self.myIntFaceConfig.CMIF_ConfigRoot.sensibleDateTo);
	self.tblConfig.setValueByName(ETRow_SystemTitle, self.myIntFaceConfig.CMIF_ConfigRoot.systemTitle);
	
	//jlier1 JIRA-35565 29/7/25
	if  app.isSpecial then
		self.tblConfig.showRowByName(ETRow_EnablePagination,false);
	else
		self.tblConfig.hideRowByName(ETRow_EnablePagination,false);
	endif;
	
	_sheet.cnEcResizeContents();
	self.tblConfig.top :=5;
	self.txtDoorsMotor.visible := false;
	self.grpInteg.visible := false;
	
	if defName = ETDef_VesselSettings then
		self.showSheetVessel(_sheet);
	elseif defName = ETDef_EmailServerConfig then //cnwrs1 dec 2008 Added as part of par 18653
		self.showSheetEmailServer(_sheet);
	endif;
end;</source>
        <Parameter name="_sheet" type="CMUI_Sheet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showSheetEmailServer" id="206d928c-cf0d-48b0-bef6-749a9df63e82">
        <updating/>
        <source>showSheetEmailServer(_sheet : CMUI_Sheet input) updating;
//
//cnwrs1 dec 2008 Added as part of par 18653
//
//12 Aug 2013	cnwrs1	Par 32224 setup timeout value for this connection
//03 Feb 2017	cnwrs1	TFS 3247 not deleting emails at NXL
//03 Aug 2020	jlgdap1	TFS 49764 MTN Retire Basic Authentication to Exchange Online
//21 May 2021	navdap1	TFS 51244 PNL OAUTH set up
//26 Aug 2021	NDL	TSF 51632 - Remove refernce to ETRow_AutoPop3Password, its not in teh ETDef, hasn't been since 2013 when it was moved to Term
vars
	row : Integer;			// TFS 49764

begin

	//"CARDSCHEMA");
	if self.cmbSoftware.listIndex = BGP_EmailSendRequest.EMAIL_CARDSCHEMA then
		self.tblConfig.disableRowByName(ETRow_AutoPop3Account);
	//	self.tblConfig.disableRowByName(ETRow_AutoPop3Password);
		self.tblConfig.disableRowByName(ETRow_AutoPop3Server);
		self.tblConfig.disableRowByName(ETRow_AutoMailSystem );
		self.tblConfig.disableRowByName(ETRow_AutoUseImap);
		self.tblConfig.disableRowByName(ETRow_AutoUseImap);
		self.tblConfig.disableRowByName(ETRow_AutoImapPort);
		self.tblConfig.disableRowByName(ETRow_AutoImapFlags);
		self.tblConfig.disableRowByName(ETRow_AutoInwardSecurePassword);
		self.tblConfig.disableRowByName(ETRow_AutoInwardSSLUsage);
		self.tblConfig.enableRowByName(ETRow_AutoEmailTimeout);
		self.tblConfig.disableRowByName(ETRow_AutoOutwardAccount);
		self.tblConfig.disableRowByName(ETRow_AutoOutwardPassword);
		self.tblConfig.enableRowByName(ETRow_AutoSmtpServer);
		self.tblConfig.disableRowByName(ETRow_AutoSmtpServerPort);
		self.tblConfig.disableRowByName(ETRow_AutoUseSSL);
		self.tblConfig.disableRowByName(ETRow_AutoAuthType);
		self.tblConfig.disableRowByName(ETRow_AutoCharset);
		self.tblConfig.disableRowByName(ETRow_EmailLicenseType);
		self.tblConfig.hideRowByName(ETRow_TenantId, false);			// TFS 51244
		
		self.tblConfig.showRowByName(ETRow_AutoOutwardAccount, false);		// TFS 49764
		self.tblConfig.showRowByName(ETRow_AutoOutwardPassword, false);		// TFS 49764
		self.tblConfig.showRowByName(ETRow_AutoSmtpServer, false);			// TFS 49764
		self.tblConfig.showRowByName(ETRow_AutoSmtpServerPort, false);		// TFS 49764
		self.tblConfig.showRowByName(ETRow_AutoUseSSL, false);				// TFS 49764
		self.tblConfig.showRowByName(ETRow_AutoAuthType, false);			// TFS 49764
	//"EMAILARCHITECT");
	elseif self.cmbSoftware.listIndex = BGP_EmailSendRequest.EMAIL_EMAILARCHITECT then
		self.tblConfig.enableRowByName(ETRow_AutoPop3Account);
	//	self.tblConfig.enableRowByName(ETRow_AutoPop3Password);
		self.tblConfig.enableRowByName(ETRow_AutoPop3Server);
		self.tblConfig.disableRowByName(ETRow_AutoMailSystem );
		self.tblConfig.enableRowByName(ETRow_AutoUseImap);
		self.tblConfig.enableRowByName(ETRow_AutoUseImap);
		self.tblConfig.enableRowByName(ETRow_AutoImapPort);
		self.tblConfig.enableRowByName(ETRow_AutoImapFlags);
		self.tblConfig.enableRowByName(ETRow_AutoInwardSecurePassword);
		self.tblConfig.enableRowByName(ETRow_AutoInwardSSLUsage);
		self.tblConfig.enableRowByName(ETRow_AutoEmailTimeout);
		self.tblConfig.enableRowByName(ETRow_AutoOutwardAccount);
		self.tblConfig.enableRowByName(ETRow_AutoOutwardPassword);
		self.tblConfig.enableRowByName(ETRow_AutoSmtpServer);
		self.tblConfig.enableRowByName(ETRow_AutoSmtpServerPort);
		self.tblConfig.enableRowByName(ETRow_AutoUseSSL);
		self.tblConfig.enableRowByName(ETRow_AutoAuthType);
		self.tblConfig.enableRowByName(ETRow_AutoCharset);
		self.tblConfig.enableRowByName(ETRow_EmailLicenseType);
		self.tblConfig.hideRowByName(ETRow_TenantId, false);			// TFS 51244
		
		if app.myRoot.getConfig(EmailLicenseType).Integer = EmailLicenseType_3 then	// ### TFS 51526 23Feb2022 NAVPW1
			self.tblConfig.hideRowByName(ETRow_AutoMailSystem, false);				// ### TFS 51526 23Feb2022 NAVPW1
		else																		// ### TFS 51526 23Feb2022 NAVPW1
			self.tblConfig.showRowByName(ETRow_AutoMailSystem, false);				// ### TFS 51526 23Feb2022 NAVPW1
		endif;																		// ### TFS 51526 23Feb2022 NAVPW1
		
		self.tblConfig.showRowByName(ETRow_AutoOutwardAccount, false);		// TFS 49764
		self.tblConfig.showRowByName(ETRow_AutoOutwardPassword, false);		// TFS 49764
		self.tblConfig.showRowByName(ETRow_AutoSmtpServer, false);			// TFS 49764
		self.tblConfig.showRowByName(ETRow_AutoSmtpServerPort, false);		// TFS 49764
		self.tblConfig.showRowByName(ETRow_AutoUseSSL, false);				// TFS 49764
		self.tblConfig.showRowByName(ETRow_AutoAuthType, false);			// TFS 49764
		self.tblConfig.hideRowByName(ETRow_AutoMailSystem, false);			// ### TFS 51526 23Feb2022 NAVPW1
	//"IDSMAIL");
	elseif self.cmbSoftware.listIndex = BGP_EmailSendRequest.EMAIL_IDSMAIL then
		self.tblConfig.enableRowByName(ETRow_AutoPop3Account);
	//	self.tblConfig.enableRowByName(ETRow_AutoPop3Password);
		self.tblConfig.enableRowByName(ETRow_AutoPop3Server);
		self.tblConfig.enableRowByName(ETRow_AutoMailSystem );
		self.tblConfig.enableRowByName(ETRow_AutoUseImap);
		self.tblConfig.enableRowByName(ETRow_AutoUseImap);
		self.tblConfig.disableRowByName(ETRow_AutoImapPort);
		self.tblConfig.disableRowByName(ETRow_AutoImapFlags);
		self.tblConfig.disableRowByName(ETRow_AutoInwardSecurePassword);
		self.tblConfig.disableRowByName(ETRow_AutoInwardSSLUsage);
		self.tblConfig.enableRowByName(ETRow_AutoEmailTimeout);
		self.tblConfig.disableRowByName(ETRow_AutoOutwardAccount);
		self.tblConfig.disableRowByName(ETRow_AutoOutwardPassword);
		self.tblConfig.enableRowByName(ETRow_AutoSmtpServer);
		self.tblConfig.disableRowByName(ETRow_AutoSmtpServerPort);
		self.tblConfig.disableRowByName(ETRow_AutoUseSSL);
		self.tblConfig.disableRowByName(ETRow_AutoAuthType);
		self.tblConfig.disableRowByName(ETRow_AutoCharset);
		self.tblConfig.disableRowByName(ETRow_EmailLicenseType);
		self.tblConfig.hideRowByName(ETRow_TenantId, false);			// TFS 51244
		
		self.tblConfig.showRowByName(ETRow_AutoOutwardAccount, false);		// TFS 49764
		self.tblConfig.showRowByName(ETRow_AutoOutwardPassword, false);		// TFS 49764
		self.tblConfig.showRowByName(ETRow_AutoSmtpServer, false);			// TFS 49764
		self.tblConfig.showRowByName(ETRow_AutoSmtpServerPort, false);		// TFS 49764
		self.tblConfig.showRowByName(ETRow_AutoUseSSL, false);				// TFS 49764
		self.tblConfig.showRowByName(ETRow_AutoAuthType, false);			// TFS 49764
	// TFS 49764 "EMAILARCHITECT OAUTH"
	elseif self.cmbSoftware.listIndex = BGP_EmailSendRequest.EMAIL_EMAILARCHITECTOAUTH then
		self.tblConfig.showRowByName(ETRow_AutoOutwardAccount, false);
		self.tblConfig.showRowByName(ETRow_AutoSmtpServer, false);
		self.tblConfig.showRowByName(ETRow_AutoEmailTimeout, false);
		self.tblConfig.showRowByName(ETRow_AutoCharset, false);
		self.tblConfig.showRowByName(ETRow_EmailLicenseType, false);
		self.tblConfig.showRowByName(ETRow_TenantId, false);			// TFS 51244
		
		// also default to correct license type and disable the license row
		row := self.tblConfig.getRowByName(ETRow_EmailLicenseType);
		if row &lt;&gt; null and self.tblConfig.accessCell(row, self.tblConfig.ColumnValue).comboList &lt;&gt; null then
			self.tblConfig.setValueByName(ETRow_EmailLicenseType, EmailLicenseDescr_2);
		endif;
		self.tblConfig.disableRowByName(ETRow_EmailLicenseType);
		
		self.tblConfig.hideRowByName(ETRow_AutoMailSystem, false);
		self.tblConfig.hideRowByName(ETRow_AutoPop3Account, false);
	//	self.tblConfig.hideRowByName(ETRow_AutoPop3Password, false);
		self.tblConfig.hideRowByName(ETRow_AutoPop3Server, false);
		self.tblConfig.hideRowByName(ETRow_AutoOutwardPassword, false);
		self.tblConfig.hideRowByName(ETRow_AutoMailSystem, false );
		self.tblConfig.hideRowByName(ETRow_AutoUseImap, false);
		self.tblConfig.hideRowByName(ETRow_AutoImapPort, false);
		self.tblConfig.hideRowByName(ETRow_AutoImapFlags, false);
		self.tblConfig.hideRowByName(ETRow_AutoInwardSecurePassword, false);
		self.tblConfig.hideRowByName(ETRow_AutoInwardSSLUsage, false);
		self.tblConfig.hideRowByName(ETRow_AutoSmtpServerPort, false);
		self.tblConfig.hideRowByName(ETRow_AutoUseSSL, false);
		self.tblConfig.hideRowByName(ETRow_AutoAuthType, false);
	// TFS 49764 end
	endif;
	
	// TFS 49764 double-check on license type and software type combinations
	if self.cmbSoftware.listIndex &lt;&gt; BGP_EmailSendRequest.EMAIL_EMAILARCHITECTOAUTH then
		self.initEmailLicenseTypeCombo(false);
		if app.myRoot.getConfig(EmailLicenseType).Integer = EmailLicenseType_0 then
			self.tblConfig.setValueByName(ETRow_EmailLicenseType, EmailLicenseDescr_0);
		elseif app.myRoot.getConfig(EmailLicenseType).Integer = EmailLicenseType_1 then
			self.tblConfig.setValueByName(ETRow_EmailLicenseType, EmailLicenseDescr_1);
		elseif app.myRoot.getConfig(EmailLicenseType).Integer = EmailLicenseType_3 then // ### TFS 51526 23Feb2022 NAVPW1
			self.tblConfig.setValueByName(ETRow_EmailLicenseType, EmailLicenseDescr_3); // ### TFS 51526 23Feb2022 NAVPW1
		else
			self.tblConfig.setValueByName(ETRow_EmailLicenseType, null);
		endif;
	endif;
	// TFS 49764
end;</source>
        <Parameter name="_sheet" type="CMUI_Sheet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showSheetVessel" id="145ee77b-243b-48ff-ba02-1168df4e4686">
        <updating/>
        <source>showSheetVessel(_sheet : CMUI_Sheet input) updating;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theCaption : String;
begin
	self.txtDoorsMotor.parent := _sheet;
	self.grpInteg.parent := _sheet;

	theCaption := "These settings are for the vessel definition and so are set at system level." &amp; CrLf &amp; CrLf;
	theCaption := theCaption &amp; "They are the rules for setting the default directions for doors and motor, for 20's and 40's for each  on deck and under deck slot in the vessel definition. The slot definition settings for 20/40 door/motor directions are copied from the vessel definition to the voyage definition at the time of the voyage creation." &amp; CrLf &amp; CrLf;
	theCaption := theCaption &amp; "When a slot is colour coded, depending on whether it is an integral or not, because of these settings the colour coding's door or motor direction will be set." &amp; CrLf &amp; CrLf;
	theCaption := theCaption &amp; "At Terminal level you can configure the system to use both motor and door directions or just door directions. If you choose to only use door directions then motor direction options are not displayed and the motor direction is always set to the opposite of the door direction." &amp; CrLf &amp; CrLf;	
	theCaption := theCaption &amp; "If you want to use motor and door directions it is totally plausible, for example, to set both 20 door and 20 motor on deck to the same direction." &amp; CrLf &amp; CrLf;
	theCaption := theCaption &amp; "This is because depending on what cargo goes into the slot the colour coding's door or motor direction is set from the default on the slot definition. So if an integral goes into the slot the motor direction will be set from the default motor direction for that slot. Having set the motor direction the door direction is set to the opposite.";
	theCaption := theCaption &amp; " If a non-integral is placed in the slot the door direction will be set and having set the door direction to the default the motor direction is set to the opposite.";
	self.txtDoorsMotor.text  := theCaption;
	self.txtDoorsMotor.readOnly := true;
	self.grpInteg.top := 5;
	self.grpInteg.left := self.tblConfig.left;
	
	self.tblConfig.top := self.grpInteg.top + self.grpInteg.clientHeight + 5;
	self.doResizeVessel();
/*
	self.lblDoorsMotor.left := self.tblConfig.left;
	self.lblDoorsMotor.top := self.tblConfig.top + self.tblConfig.clientHeight + 5;
	self.lblDoorsMotor.width := self.tblConfig.clientWidth;
	self.lblDoorsMotor.height := _sheet.clientHeight - self.tblConfig.top - self.tblConfig.clientHeight;
*/
	self.txtDoorsMotor.visible := true;
	self.grpInteg.visible := true;
	
	
	
end;</source>
        <Parameter name="_sheet" type="CMUI_Sheet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="skipToAttribute" id="bcc84b5a-b98f-44cf-837f-b5ac7ccd43a2">
        <updating/>
        <source>skipToAttribute( _attributeName : String; _shtName : String ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 July 2012	cnwndl1	Initial creation

*/

vars

	idx : Integer;
	tmpSheet : CMUI_Sheet;
	entRow : EntTableRow;
	row : Integer;

begin
	
	foreach idx in 0 to self.allEntTableDefs.size do
		tmpSheet :=	shtEntTbl.getControl(idx).CMUI_Sheet;
		if tmpSheet = null then
			continue;
		endif;
		if _shtName = tmpSheet.caption then
			self.fldConfig.topSheet := tmpSheet;
			self.showSheet( tmpSheet );
			self.tblConfig.setFocus();
			self.tblConfig.doWindowEvents(0);
			entRow := self.tblConfig.myEntTableDef.getEntTableRowByHeading(_attributeName);
			if entRow &lt;&gt; null then
				row := self.tblConfig.myEntTableDef.allEntTableRows.indexOf(entRow);
			endif;
			if row &gt; self.tblConfig.fixedRows and row &lt;= self.tblConfig.rows then
				self.tblConfig.accessRow(row).selected := true;
				self.tblConfig.topRow := row;
				self.tblConfig.row := row;							// ### TFS 55144 25Oct2022 NAVPW1
				self.selectedConfigRow := self.tblConfig.topRow;	// TFS 52235 2NOV2021 NAVLW1
			endif;
			
			return;
		endif;
	endforeach;

epilog

end;</source>
        <Parameter name="_attributeName" type="String"/>
        <Parameter name="_shtName" type="String"/>
    </JadeMethod>
    <JadeMethod name="tblConfig_click" id="ac01c489-3006-41f6-832e-98c5d68d0067">
