<Class name="CM_WOTrainToDoWLE" id="e268eca6-c667-4dd3-b141-1384c10b8502">
    <superclass name="CM_WOToDoWLE"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ExplicitInverseRef name="myTrain" id="e44b2e81-7579-492d-a828-825379dd5025">
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_Train"/>
        <access>readonly</access>
        <Inverse name="CM_Train::allWorkOrderWLEs"/>
    </ExplicitInverseRef>
    <JadeMethod name="addToDoTask" id="e126e7c7-1813-4df7-a1de-f22669b47237">
        <updating/>
        <source>addToDoTask() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 November 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen

*/

vars
	toDoDesc 			: CM_ToDoTaskDesc;
	trainTask 			: CM_ToDoTask;
	passport 			: CM_Passport;
	
begin
	
	if self.myTrain = null then
		//throw error
		return;
	endif;
	
	passport := app.myPassport;
	
	toDoDesc := self.job.CM_WOToDoTaskJob.myToDoTaskDesc;

	if trainTask = null then //add task
		trainTask := myTrain.createToDoTask(toDoDesc.code, self.job.myWorkOrderDtlToDo); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		self.job.myWorkOrderDtlToDo.allToDoTasks.add(trainTask);
	endif;
	
	self.myToDoTask := trainTask;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyTrain" id="ffeab0e1-a606-41b2-8844-6ace9d4081bf">
        <updating/>
        <source>setMyTrain(_train : CM_Train) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 November 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/

vars

begin
	self.myTrain := _train;
	
	self.addToDoTask();
epilog

end;</source>
        <Parameter name="_train" type="CM_Train"/>
    </JadeMethod>
</Class>
