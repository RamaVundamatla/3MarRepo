    <JadeMethod name="delete" id="8f86d200-02ef-4440-a136-d9b848f7ec06">
        <updating/>
        <source>delete() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 24/03/2016	cnwdap1		Initial creation PAR #37675 Transient leaks
//
vars

begin
	delete self.consignor;
	delete self.myBOLID;
	delete self.myLocationController;
	delete self.myLogGrade;
	delete self.myLogGrade;
	delete self.myLogLength;
	delete self.myLogSpecies;
	delete self.myLogTreatment;
	delete self.myLogType;
	delete self.operator;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="de3a852f-c81a-4640-8eb9-4b7368e067e2">
        <updating/>
        <source>setProxyFromObject(_log : CM_Log) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2015	cnwmc5	Initial creation

*/

vars
	consignor	: CM_ConsigneeConsignor;
begin
	inheritMethod(_log);
	
	self.id 		:= _log.id;
	self.sedMax 	:= _log.sedMax;
	self.sedMean	:= _log.sedMean;
	self.sedMin		:= _log.sedMin;
	
	if _log.myReceivalBOL &lt;&gt; null then
		self.loggingOrganisation := _log.myReceivalBOL.loggingOrganisation;
	endif;
	
	if _log.myOperator &lt;&gt; null then
		create self.operator transient;
		self.operator.setProxyFromObject(_log.myOperator);
	endif;
	
	if _log.consignor &lt;&gt; null then
		create self.consignor transient;
		consignor := app.myRoot.allConsigneeConsignors[_log.consignor];
		if consignor &lt;&gt; null then
			self.consignor.setProxyFromObject(consignor);
		endif;
	endif;
	
	//cnwmc5 - 16 April 2015 - CCMS 1138
	if _log.myReceivalBOL &lt;&gt; null then
		create self.myBOLID transient;
		self.myBOLID.setProxyFromObject(_log.myReceivalBOL);
	endif;
	
	//cnwmc5 - 31 August 2015 - CCMS 1142
	self.conditionCode := _log.conditionCode;
	self.jasVolume := _log.jasVolume;
	self.weightTonnes := _log.weightTonnes;
	
	if _log.myLogGrade &lt;&gt; null then
		create self.myLogGrade transient;
		self.myLogGrade.setProxyFromObjectBase(_log.myLogGrade);
	endif;
	
	if _log.myLogLength &lt;&gt; null then
		create self.myLogLength transient;
		self.myLogLength.setProxyFromObject(_log.myLogLength);
	endif;
	
	if _log.myLogSpecies &lt;&gt; null then
		create self.myLogSpecies transient;
		self.myLogSpecies.setProxyFromObjectBase(_log.myLogSpecies);
	endif;
	
	if _log.myLogTreatment &lt;&gt; null then
		create self.myLogTreatment transient;
		self.myLogTreatment.setProxyFromObject(_log.myLogTreatment);
	endif;
	
	if _log.myLogType &lt;&gt; null then
		create self.myLogType transient;
		self.myLogType.setProxyFromObject(_log.myLogType);
	endif;
	
	if _log.getPrimaryLocation(REAL_MODE) &lt;&gt; null then
		create self.myLocationController transient;
		self.myLocationController.setProxyFromObject(_log.getPrimaryLocation(REAL_MODE));
	endif;
	
epilog

end;</source>
        <Parameter name="_log" type="CM_Log"/>
    </JadeMethod>
</Class>
