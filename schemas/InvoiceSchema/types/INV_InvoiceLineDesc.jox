    <JadeMethod name="doCmbBankBuild" id="499bb45a-7117-49f8-ba02-eb89c457cf07">
        <source>doCmbBankBuild();
//	35874 build combo for business unit query
vars
	company			: CM_Bank;
	businessUnits	: CM_CompanyByCodeDict;
	currentBU		: CM_Bank;
	combo			: CMUI_ComboBox;
begin

	combo := self.cmbBank;
	create businessUnits transient;
	currentBU := self.myTerminal.getAvailableCompanies(businessUnits);
	foreach company in businessUnits do
		combo.addItem(company.code);
		combo.itemObject[combo.newIndex] := company;
	endforeach;
	if currentBU &lt;&gt; null then
		combo.listObject := currentBU;
	endif;
epilog
	delete businessUnits;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doCmbChargesBuild" id="02015bc9-b647-4391-bd26-44bf92211aa4">
        <source>doCmbChargesBuild(_type : CM_CalculationType);
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
// Modified:    April 2008 By Graeme Black cnwgb1 for CCMS Cp 1047		
//26.07.2018	cnwma1	Bug 39781: Getting a 1090 on opening Invoice Line Types
// ---------------------------------------------------------------------------

vars

	dt : CM_DebtorType;		//31 Oct 2019	NDL	TFS 47100
	
begin
	
	self.cmbCharges.clear;
	self.cmbCharges.sorted := true; //cnwgb1 27 May 2008 PAR 16666

	if _type = null // PAR 15750
	or _type.isCargoCalcType then // CARGO
		self.myAssistant.comboBoxDebtorType(self.cmbCharges, false, false);
	elseif _type.isVoyageCalcType then // HMS
		self.cmbCharges.addItem(app.myRoot.allDebtorTypes[CM_DebtorType.DT_SHIP_OPERATOR].description);
		self.cmbCharges.itemObject[1] := app.myRoot.allDebtorTypes[CM_DebtorType.DT_SHIP_OPERATOR];
		self.cmbCharges.listIndex := 1;
	elseif _type.isEventCalcType then // EVENTS
		self.cmbCharges.addItem(app.myRoot.allDebtorTypes[CM_DebtorType.DT_EVENT_TYPE].description);
		self.cmbCharges.itemObject[1] := app.myRoot.allDebtorTypes[CM_DebtorType.DT_EVENT_TYPE];
		self.cmbCharges.listIndex := 1;
		
	 // ### TFS 51219 28MAY2021 NAVAB1
	elseif _type.isInventoryType then // INVENTORY
	
		dt := app.myRoot.allDebtorTypes[CM_DebtorType.DT_CARGO_OPERATOR];
		self.cmbCharges.addItemObject(dt.description, dt);
		dt := app.myRoot.allDebtorTypes[CM_DebtorType.DT_CARRIER];
		self.cmbCharges.addItemObject(dt.description, dt);
		dt := app.myRoot.allDebtorTypes[CM_DebtorType.DT_CONSIGNEE];
		self.cmbCharges.addItemObject(dt.description, dt);
		dt := app.myRoot.allDebtorTypes[CM_DebtorType.DT_CONSIGNOR];
		self.cmbCharges.addItemObject(dt.description, dt);
		dt := app.myRoot.allDebtorTypes[CM_DebtorType.DT_SHIP_OPERATOR];
		self.cmbCharges.addItemObject(dt.description, dt);

		self.cmbCharges.listIndex := 1;
		
	elseif _type.isWorkOrderType then // TFS 39198 Voyage WORK ORDERS     //26.07.2018 cnwma1 TFS #39781
		self.cmbCharges.addItem(app.myRoot.allDebtorTypes[CM_DebtorType.DT_SHIP_OPERATOR].description);
		self.cmbCharges.itemObject[1] := app.myRoot.allDebtorTypes[CM_DebtorType.DT_SHIP_OPERATOR];
		self.cmbCharges.listIndex := 1;
	elseif _type.isBolCalcType then	//31 Oct 2019	NDL	TFS 47100
		self.myAssistant.comboBoxDebtorType(self.cmbCharges, false, true);	//29 Oct 2019	NDL	TFS 47100
	endif;
end;</source>
        <Parameter name="_type" type="CM_CalculationType"/>
    </JadeMethod>
    <JadeMethod name="doCmbGroupByBuild" id="55bc7879-22ef-4032-ae8a-206bf65e8ce1">
        <source>doCmbGroupByBuild();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 17/09/2015	cnwdap1		Initial creation PAR #36909 CCMS ADP 2537 Minimum Charge Changes
//
vars

begin
	self.cmbGroupBy.clear;
	self.cmbGroupBy.addItem(app.getErrorString(None));
	self.cmbGroupBy.addItem(app.getErrorString(Invoice));
	self.cmbGroupBy.addItem(app.getErrorString(Invoice_line));
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbInvTypeInvBuild" id="f0b8e265-a3c6-4fd3-9ad3-c5ecd2c3c70a">
        <source>doCmbInvTypeInvBuild();
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	invoiceType : CM_InvoiceDesc;
begin
	self.cmbInvTypeInv.clear;

	foreach invoiceType in self.myCurrentBank.invoiceTypes where not invoiceType.isNotAvailableForEntry do
		self.cmbInvTypeInv.addItem(invoiceType.description);
		self.cmbInvTypeInv.itemObject[self.cmbInvTypeInv.newIndex] := invoiceType;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbUOMBuild" id="3ad500fe-693d-402e-b5d5-0567e4990703">
        <source>doCmbUOMBuild();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who			Reason
31 January 2023	navvt20		TFS CR 56132 Task 56134: UI - Invoice Line Type - UOM

*/

vars
	invUOM : CM_InvoiceUnitOfMeasure;
begin
	self.cmbUOM.clear;
	
	self.cmbUOM.addItem("");
	foreach invUOM in app.myRoot.allInvoiceUnitOfMeasure  do
		self.cmbUOM.addItem(invUOM.description);
		self.cmbUOM.itemObject[self.cmbUOM.newIndex] := invUOM;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbUnitsBuild" id="5b0fa5ae-4f7f-406f-be14-534f4b771ac1">
        <source>doCmbUnitsBuild();
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//	24024	Aug 2010 revised to populate with CM_CalculationType instances instead of from the global constants
//  11/09/2017	cnwma1  TFS #6897 JMT - Calculation Type Label Refactor
// 06 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
// ---------------------------------------------------------------------------

vars

	tmp : Integer;
	haveVTMIS : Boolean;
	haveCARGO : Boolean;
	aCT : CM_CalculationType;
	tmpDesc : String;
begin
	haveVTMIS := app.myRoot.canDo(Mod_Harbour); // VTMIS License  //06.10.2017	cnwma1  TFS #7257
	haveCARGO := app.myRoot.canDo(Mod_CargoHandling); // CONTAINER LICENSE

	self.cmbUnits.clear;
	self.cmbUnits.sorted := true; // PAR 17139

	foreach aCT in app.myRoot.allCalculationTypesByCode do
		if aCT.isVoyageCalcType then // TFS 39198
			if not haveVTMIS then
				continue;
			endif;
		elseif aCT.isCargoCalcType then // TFS 39198
			if not haveCARGO then
				continue;
			endif;
		endif;
		// PAR 30428
		/* // ### TFS BUG 59913 31AUG2023 NAVAB1 
		tmpDesc := "";
		if aCT.isVoyageCalcType then // TFS 39198
			tmpDesc := "HMS - ";
		elseif aCT.isCargoCalcType then // TFS 39198
				tmpDesc := "Cargo - ";
		elseif aCT.isInventoryType then  // ### TFS 51219 28MAY2021 NAVAB1
			tmpDesc := "Inventory - "; // ### TFS 51219 28MAY2021 NAVAB1
		elseif aCT.isEventCalcType then
				tmpDesc := "Event - ";
		elseif aCT.isWorkOrderType and not aCT.isStandardWorkOrder() then // TFS 39198
			tmpDesc := "Work Order - "; // TFS 39198
		endif;
		*/
		//11/09/2017 cnwma1 TFS #6897
		/*if aCT.isStandardCargo then
			tmpDesc := tmpDesc &amp; aCT.getCalcTypeDesc();
		else
			tmpDesc := tmpDesc &amp; aCT.description;
		endif;*/
		
		tmpDesc := aCT.getComboDescription(); // ### TFS BUG 59913 31AUG2023 NAVAB1  description;  //11/09/2017 cnwma1 TFS #6897
		
		self.cmbUnits.addItem(tmpDesc);
		tmp := self.cmbUnits.findString(1, tmpDesc);
		
	 // PAR 17139 NOTE. We use the itemData in the update so we need the text of the list to match the itemData index
// PAR 30428		self.cmbUnits.addItem(aCT.description);
// PAR 30428		tmp := self.cmbUnits.findString(1, aCT.description);
		self.cmbUnits.itemData[tmp] := aCT.calculationType;
		self.cmbUnits.itemObject[tmp] := aCT;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="5f34e28b-bc11-4eef-9e92-b2689b834dbc">
        <updating/>
        <source>doDelete(): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theReturn : Integer;
begin
 
app.msgBox("THIS DELETE OPTION IS ONLY AVAILABLE TO DEVELOPERS" &amp; Cr &amp; "AND SO IS NOT AVAILABLE AT USERS SITES.", "DEVELOPER ONLY", MsgBox_Exclamation_Mark_Icon);
// SEE ANDREW BISHOP 
 
	while true do
 
 	 	app.myTrxDA.trxDeleteInvoiceLineDesc(self.myCurrentObject.CM_InvoiceLineDesc, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			return true;
		else
			theReturn := app.showErrorWarningDialog("Invoice Line Descriptions", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors 
			and theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
		endif;
		break;
	endwhile;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doExportTranslations" id="9550e8c1-0c64-4936-95b5-f67277e596ae">
        <source>doExportTranslations();
/*

Purpose:			Exports the invoice line trnslations for the bank

Parameters:			NONE

Return Value:		NONE

Date				Who		Reason
05 September 2022	navpw1	Initial creation TFS: 54564 (54379)

*/

vars
	cmifInvoiceLineNarration 	: CMIF_InvoiceLineNarration;
	exportFile 					: File;
	fileSave 					: CMDFileSave;
	cmifMonitor					: CMIF_Monitor;
	
begin
	if self.myCurrentBank = null then
		app.msgBox(app.getErrorString(Bank_selected), app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	create exportFile transient;
	exportFile.mode := File.Mode_Output;
	
	create fileSave transient;
	fileSave.filter 	:= '.csv|*.csv';
	fileSave.fileName 	:= '';
	fileSave.initDir	:= "C:\";
	
	if fileSave.open = 0 then
		exportFile.fileName := fileSave.fileName;
	endif;
	
	if exportFile.fileName = null then
		return;
	endif;
	
	self.initModalDialog();
	self.lblModalMessage.caption := Cr &amp; (app.getErrorString(Exporting) &amp; ' ' &amp; app.getErrorString(Invoice_line_type_narra));
	
	create cmifMonitor transient;
	cmifMonitor.myParent := self;
	
	if cmifMonitor &lt;&gt; null then
		cmifMonitor.updateProgress(app.getErrorString(Writing_export_file), 100, 0);
	endif;
	
	self.frmModalDialog.visible := true;
	self.doWindowEvents(2);
	if self.frmModalDialog.visible then
		self.frmModalDialog.doWindowEvents(2);
	endif;
	
	create cmifInvoiceLineNarration transient;
	exportFile.openOutput(exportFile.fileName);
	cmifInvoiceLineNarration.doExtractInvLnTypTransCsvFile(exportFile, self.myCurrentBank, cmifMonitor);
	
epilog
	app.mousePointer := MP_DEFAULT;
	delete cmifInvoiceLineNarration;
	delete exportFile;
	self.frmModalDialog.visible := false;
	delete fileSave;
	delete cmifMonitor;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doFilterTable" id="6f42ffb8-8380-41bc-b30f-1082c31ceb19">
        <updating/>
        <source>doFilterTable() updating;
/*

Purpose:			Filters the tree

Parameters:			NONE

Return Value:		NONE

Date				Who		Reason
14 September 2021	navpw1	Initial creation TFS: 51912

*/

vars
	filterText		: String;
	rowIdx,
	colIdx,
	start			: Integer;
	cell			: JadeTableCell;
	cellText		: String;
	
begin
	//filterText := self.txtFilterBox.text.toUpper();
	filterText := self.frmTableFilter.txtFilterBox.text.toUpper(); //25/06/2024	navkc1 CR 64823 Task 64824
	
	if (filterText = "") then
		self.clearFilter();
		return;
	else
		//self.btnClearFilter.enabled := true;
		self.frmTableFilter.btnClearFilter.enabled := true; //25/06/2024	navkc1 CR 64823 Task 64824
	endif;
	/*
	start := self.tblData.fixedRows + 1;
	foreach rowIdx in start to self.tblData.rows do	: rowLoop
		self.tblData.accessRow(rowIdx); // ### TFS 51912 17Sep2021 NAVPW1 Needed as we use accessedRow below. Plus needed for columns of current row
		foreach colIdx in 1 to self.tblData.columns do
			cell := self.tblData.accessCell(rowIdx, colIdx);
			cellText := cell.text.toUpper;
			if cellText.length &gt; 0 and cellText.pos(filterText, 1) &gt; 0 then
				self.tblData.accessedRow.visible := true;
				continue rowLoop;
			endif;
		endforeach;
		self.tblData.accessedRow.visible := false;
	endforeach;
*/
	self.tblData.topRow := 1;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doImportTranslations" id="6a7bef6f-ffa4-44a4-b7da-190d28e2b480">
        <source>doImportTranslations();
/*

Purpose:			Imports the invoice line translations for the bank

Parameters:			NONE

Return Value:		NONE

Date				Who		Reason
05 September 2022	navpw1	Initial creation TFS: 54564 (54379)

*/

vars
	impFile 		: File;
	fileGet 		: CMDFileOpen;
	cmifMonitor		: CMIF_Monitor;
	warningsResult	: Integer;
	
begin
	create impFile transient;
	impFile.kind := File.Kind_Unknown_Text;
	
	if impFile = null then
		app.raiseUnexpectedProgramError(class.name, method.name, " file is null - create file before calling ");
	endif;
	
	create fileGet transient;
	fileGet.filter 		:= '.csv|*.csv';
	fileGet.fileName 	:= '';
	fileGet.initDir 	:= "C:\";
	
	if fileGet.open = 0 then
		impFile.fileName := fileGet.fileName;
	endif;
	
	if impFile.fileName = null then
		return;
	endif;
	
	self.initModalDialog();
	self.lblModalMessage.caption := Cr &amp; (app.getErrorString(Importing) &amp; ' ' &amp; app.getErrorString(Invoice_line_type_narra));
	
	if app.myPassport.myCMIFMonitor = null then
		create cmifMonitor transient;
		cmifMonitor.myParent := self;
		//cmifMonitor.callBackMethodName := "updateProgress";
		app.myPassport.setMyCMIFMonitor(cmifMonitor);
		
	endif;
	
	if cmifMonitor &lt;&gt; null then
		cmifMonitor.updateProgress(app.getErrorString(Reading_import_file), 100, 0);
		
	endif;
	
	self.frmModalDialog.visible := true;
	self.doWindowEvents(2);
	if self.frmModalDialog.visible then
		self.frmModalDialog.doWindowEvents(2);
	endif;
	
	while true do
		app.myTrxCA.trxImportInvLnTypTransFromFile(impFile, self.myCurrentBank, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			break;
		endif;

		warningsResult := app.showErrorWarningDialog(app.getErrorString(Invoice_line_type_narra), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
		
		if app.myPassport.noErrors and
		   warningsResult = IDOK then
			// there must have just been warnings that the user has acknoledged so ..
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
		
		break;
		
	endwhile;
	
epilog
	delete impFile;
	self.frmModalDialog.visible := false;
	delete cmifMonitor;
	delete fileGet;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doPrint" id="6e55a9bd-00b5-4ae8-8df4-280b325a42e6">
        <updating/>
