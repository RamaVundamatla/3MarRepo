    <JadeMethod name="getTransactionByTypePriorTRX" id="e2114ce7-ea6b-418b-b4d0-4417eb37e22a">
        <source>getTransactionByTypePriorTRX(_transType : Integer) : CM_TITransaction;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 July 2020	jlgndl1	Initial creation	TFS 49606

*/

vars
	ti : CM_TrackedItem;
	iter : Iterator;
	tran : CM_TITransaction;
begin
	ti := self.myTrackedItem;
	
	if ti = null then
		return null;
	endif;
		
	iter := ti.allTransactions.createIterator();
	ti.allTransactions.startKeyGeq(self.dateTime,0,iter);
    

	while iter.back(tran)  do
		if tran.type = _transType then
			return tran;
		endif;
	endwhile;
	
	return null;
		
epilog

	delete iter;

end;</source>
        <Parameter name="_transType" type="Integer"/>
        <ReturnType type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="getTransactionByTypeSameTRX" id="0585d1f5-0d8a-43e4-b508-f77d9f0f90b6">
        <source>getTransactionByTypeSameTRX(_transType : Integer) : CM_TITransaction;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 July 2017	jlgab1	Initial creation

*/

vars
	ti : CM_TrackedItem;
	iter : Iterator;
	start, tran : CM_TITransaction;
begin
	ti := self.myTrackedItem;
	
	if ti = null then
		return null;
	endif;
		
	iter := ti.allTransactions.createIterator();
	ti.allTransactions.startKeyGeq(self.dateTime,0,iter);
    

	while iter.next(tran)  do
		if tran.dateTime = self.dateTime
		and tran.type = _transType then
				return tran;
		endif;
        
        if tran.dateTime &lt;&gt; self.dateTime then
			break;
		endif;
	endwhile;
	
	return null;
		
epilog

	delete iter;	//15 Jan 2018	NDL	TFS 36401

end;</source>
        <Parameter name="_transType" type="Integer"/>
        <ReturnType type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="getTransactionDescription" id="caaefe4f-07f3-4060-81a3-6b34ce7851bc">
        <source>getTransactionDescription(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 May 2024   navrv30     Bug 64076: InvoiceContractID is null on the External Web service message for the Invoice API

*/

vars
	str : String;
begin
	if self.deleted then
		str := "*** DELETED *** ";
	endif;
	str := str &amp; self.typeString;
	if self.superseded then
		str := '    ' &amp; str;
	endif;
	
	if self.deleted then
		str := str &amp; "-" &amp; self.getDeletedDetails();	// 15/10/18 MAP TFS41191
	else
		str := str &amp; "-" &amp; self.getCompletedTaskString;
	endif;
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
