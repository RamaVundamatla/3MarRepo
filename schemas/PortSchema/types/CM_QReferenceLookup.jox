	return true;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSearchValue" id="42653097-c39f-4916-94f2-e7e77bf6e95e">
        <updating/>
        <source>setSearchValue(_value: Any) updating;
// -----------------------------------------------------------------------------
// Created:		09 May 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	self.mySelectionValue := null;
	if _value &lt;&gt; null and _value.isKindOf(Btree) then //19 Jun 2015	NDL	Par 36338
		self.mySelectionValue := _value.Btree.first.Object;
	elseif _value &lt;&gt; null and _value.isKindOf(Array) then //19 Jun 2015	NDL	Par 36338
		self.mySelectionValue := _value.Array[1].Object;
	elseif _value &lt;&gt; null and _value.isKindOf(Object) then // par 18123
		self.mySelectionValue := _value.Object;
	endif;
end;</source>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validateForRT" id="235124ab-c31c-488d-adc9-1fe20f4bc422">
        <source>validateForRT( _queryName, _propName : String );
// -------------------------------------------------------------------------------------
// Created:	28 April 2008 by cnwvu1
//
// Purpose:	Queries for RT must only use the operations having only one searching value.
//			A set of selected values is not valid for the RT Drivers screen. 
// -------------------------------------------------------------------------------------

vars

begin

	return;
	
end;
</source>
        <Parameter name="_queryName" type="String"/>
        <Parameter name="_propName" type="String"/>
    </JadeMethod>
</Class>
