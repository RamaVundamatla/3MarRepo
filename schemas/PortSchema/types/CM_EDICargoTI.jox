    <JadeMethod name="setStatus" id="7401d318-e544-470b-ae8c-2e4465ec7e5f">
        <updating/>
        <source>setStatus(_newStatus: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2016	cnwndl1	Initial creation(_newStatus: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 November 2016	cnwndl1	Initial creation	TFS 2843 / 2604

*/
// 15 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals

vars

	iter : Iterator;
	ediTi : CM_EDITrackedItem;
	invalid : Boolean;

begin

	inheritMethod(_newStatus);
	
	if self.myAttachedItems &lt;&gt; null and not self.myAttachedItems.isEmpty then
		on Exception do app.handleDeletedObject(exception, ediTi,invalid);
		iter := self.myAttachedItems.createIterator;
		while iter.next( ediTi ) do
			if ediTi.isEDIHazDetails or
			   ediTi.isEDISealDetails then
				ediTi.setStatus(_newStatus);
			endif;
		endwhile;
		delete iter;
	endif;

epilog

	delete iter;

end;</source>
        <Parameter name="_newStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setVoyageCode" id="b3c5ba6a-74fa-458b-9b0f-a8e2f05133b8">
        <updating/>
        <source>setVoyageCode( _value : String ) updating;
/*
Date		Who		Reason
09 Jun 2010	cnwrl1	Initial creation as part of PAR 24299 - SFW 1118 EDI Form to allow searching of EDI file by Container / Voyage
11 Apr 2013	cnwcs5	Make use of local variables
20 Nov 2018	jlgrs1	TFS 41659 STWR Make EDI MultiThreaded Stage 6
*/
vars
	config		: CM_EDIConfig;
	coll		: CM_EDITIsByVoyageCodeDict;
	code, 
	codeUpper	: String;
begin
	// need to make sure the manual collection on CM_EDIConfig gets maintained correctly, this collection
	// keeps track of all EDITrackedITems that have some connection to a voyageCode of some kind.
	config := self.myEDIConfig;
	
	if config &lt;&gt; null then
		coll := config.allEDITrackedItemsByVoyageCode;
	endif;
	
	code := self.voyageCode;
	
	// remove the previous non-null value from this collection
	if code &lt;&gt; null and coll &lt;&gt; null then
		codeUpper := code.toUpper;
		
		if coll.includesKey( codeUpper, self ) then
			coll.removeKeyEntry( codeUpper, self, self );
		endif;
	endif;

	// now change it and add this new value to the manual collection (if not null).
	code			:= _value[ 1 : self.voyageCode.maxLength ];
	self.voyageCode	:= code;
	
	if not self.isTransient and
	   code &lt;&gt; null and coll &lt;&gt; null then
		codeUpper := code.toUpper;
		
		if not coll.includesKey( codeUpper, self ) then
			coll.putAtKey( codeUpper, self, self );
		endif;
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateVolume" id="a0a4965a-8c60-4480-90a2-276d1ca501ac">
        <updating/>
        <source>validateVolume(_volume: Real) updating;
//
// 16 Jan 2012	MSL CCMS 1009 PAR 29024
//
vars

begin
	if not (_volume &gt; 0) then
		return;
	endif;
	 	
	if self.height = 0 then
		self.height := 100;
	endif;
	
	//have height
	
	if self.width = 0 then
		if self.length = 0 then
			self.width := 100;
			self.length := (_volume * 100).Integer;
		else
			//have length and height
			self.width := (_volume/((self.length.Real/100) * (self.height.Real/100))).Integer;
		endif;
	else
		//have width and height  adjust length
		self.length := (_volume/((self.width.Real/100) * (self.height.Real/100))).Integer;
	endif;	
	


end;</source>
        <Parameter name="_volume" type="Real"/>
    </JadeMethod>
    <JadeMethod name="verifyAlternateId" id="95b485c1-16d8-45d2-8611-fe6ac9aad6b6">
        <updating/>
        <source>verifyAlternateId() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 May 2013	cnwndl1	Initial creation	Par 31506

*/

vars

begin

	if self.alternativeId = null then
		return;
	endif;
	
	if self.alternativeId = self.id then
		app.raiseCMException( Cargo_same_alterna_id, ETRow_AlternativeId, self );
	endif;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyAvailabilityGrade" id="c7d44465-ca4c-4d74-a15b-08754744aa1a">
        <updating/>
        <source>verifyAvailabilityGrade() updating, protected;
	
/*
Purpose:	Verify the AvailabilityGrade entered it can be null in which case it will default
			to the terminal setting of DefAvailabilityGrade within CM_Container setUserDefinedTI.

Date				Who		Reason
02 February 2010	cnwrl1	Initial creation as part of PAR 21758 - CCMS 1074 = Add AvailabilityGrade to EDI Cargo file types
*/
	
vars
	mtGrade		: CM_MTGrade;
	
begin
	if self.availabilityGrade = null then
		return;
	endif;
	
	// otherwise validate this value against the system AvailabilityGrades.
	mtGrade	:= app.myRoot.allAvailabilityGrades[ self.availabilityGrade ];
	if mtGrade = null then
		app.raiseCMException1( Invalid_AvailabilityGrade, self.availabilityGrade.display, ETRow_AvailabilityGrade, self );
	endif;
	
epilog
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyCargoType" id="76389137-65d2-4049-8965-71250e2f1943">
        <updating/>
        <source>verifyCargoType() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	02 August 2006 By cnwth2

Purpose:	

Changed On	Changed By	Reason
	
----------  ----------	--------------------------------------------------
PAR 33794 changed to valid the cargo as valid in system and valid in terminal
20/06/2023	navdap1		TFS 56747 EUP Manifest Processing - Internal (Zimmer) - Create
						Align this method with CM_EDIPrenoteTI::verifyCargoType
						(because this implementation didn't actually validate the cargo type was valid for the terminal)
*/
vars
	cargoTypeDict		: CM_CargoTypesByIdDict;
	cargoTypeObj		: CM_CargoType;
	term 			    : CM_Terminal;
	root				: CM_Root;
	isContainerCT		: Boolean;
begin

	root			:= app.myRoot;									//30.11.2022 navma1 #52499
	cargoTypeDict   := root.allCargoTypesById;						//30.11.2022 navma1 #52499
	
	
	// ### VALIDATE CARGO IS VALID FOR SYSTEM
	// ###
	
	if self.cargoTypeDescr.toUpper.cnContains('CONTAINER') then		//30.11.2022 navma1 #52499
		isContainerCT := true;
		cargoTypeObj  := cargoTypeDict[TI_CargoType_Container].CM_CargoType;
	endif;
	
	
	if not isContainerCT then	
		cargoTypeObj := cargoTypeDict[self.cargoType].CM_CargoType;
		if cargoTypeObj = null then
		
			//21 Jun 2019	NDL	TFS 44895 - use local dict on app via term method instead, better performance.
			cargoTypeObj := root.getCargoTypeFromAbbrevOrDescr( self.cargoTypeDescr );
			if cargoTypeObj &lt;&gt; null then
				self.cargoType 		:= cargoTypeObj.type;
				self.cargoTypeDescr := cargoTypeObj.description;
			endif;
		else
			self.cargoTypeDescr := cargoTypeObj.description;//keep them in synch
		endif;
	endif;

	if cargoTypeObj = null then
		app.raiseCMException1(Cargot_not_valid_cargot_system, self.cargoTypeDescr, ETRow_CargoTypeDescr, self);
		self.cargoType := null;
		return;
		
	endif;
	
	// ### VALIDATE CARGO IS VALID FOR TERMINAL
	// ###
	
	term := self.getMyTerminal();
		
	/*if isContainerCT then 	
		if not cargoTypeObj.allTerminals.includes( term ) then
			cargoTypeObj := null;
		endif;
	else	
		cargoTypeObj := cargoTypeDict[self.cargoType].CM_CargoType;
		if cargoTypeObj = null then
		
			//21 Jun 2019	NDL	TFS 44895 - use local dict on app via term method instead, better performance.
			cargoTypeObj := term.getCargoTypeFromAbbrevOrDescr( self.cargoTypeDescr );
			if cargoTypeObj &lt;&gt; null then
				self.cargoType 		:= cargoTypeObj.type;
				self.cargoTypeDescr := cargoTypeObj.description;
			endif;
			
		else
			self.cargoTypeDescr := cargoTypeObj.description;//keep them in synch
		endif;
	endif;
	
	if cargoTypeObj = null then*/								// TFS 56747
	if not cargoTypeObj.allTerminals.includes(term) then		// TFS 56747
		app.raiseCMException2(Cargot_not_valid_cargot_termin, self.cargoTypeDescr, term.name, ETRow_CargoTypeDescr, self);
	elseif cargoTypeObj.isNotAvailableForEntry then	//PAR 21733
		app.raiseCMException1(Cargo_type_marked_not_availabl, self.cargoTypeDescr, ETRow_CargoTypeDescr, self);
	else
		self.cargoType 		:= cargoTypeObj.type;
		self.cargoTypeDescr := cargoTypeObj.description;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyCarrier" id="11af48ab-7c56-49ad-bbfd-b5117285cac7">
        <updating/>
        <source>verifyCarrier() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	02 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
03 Mar 2022  navma1		 ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.	
----------   ----------  --------------------------------------------------
*/
vars
	loopCarrier,
	carrier			: CM_Carrier;
	carrierDict		: CM_CarrierByCodeDict;
	carrierStr		: String;
begin
	if self.carrierCode = null then
		return;
	endif;
	
	carrierDict := app.myRoot.allCarriers;
	carrier := carrierDict[self.carrierCode];
	if carrier = null then
		
		carrierStr := self.carrierCode.toUpper;										//03.03.2022 navma1 #52499
		
		foreach loopCarrier in carrierDict do
			if loopCarrier.description.toUpper = carrierStr then					//03.03.2022 navma1 #52499
				self.carrierCode := loopCarrier.code;
				carrier 		 := loopCarrier;
				break;
			endif;
		endforeach;
	endif;
	
	if carrier = null then
		app.raiseCMWarning2(ERR_FIELD_CARRIER, self.carrierCode, 'carrier code', ETRow_CarrierCode, self, self);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyColour" id="cc9fcc33-d4c9-4b3b-b13e-ef1726fb4993">
        <source>verifyColour() protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 14/08/2013	cnwdap1		Initial creation PAR #32123
// 27/08/2013	cnwdap1		PAR #32326 Allow for more than one colour being supplied e.g. "BLUE RED"
//
vars
	colours 	: StringArray;																	// PAR #32326
	str 		: String;																		// PAR #32326

begin
	if self.getMyTerminal.getConfig(ValidateColour).Boolean then
		//if self.colour &lt;&gt; null and app.myDutyDocRoot.allVehicleColours[colour] = null then	// PAR #32326
		//	app.raiseCMException1(ERR_INVALID_COLOURCODE, self.colour, "colour", null);			// PAR #32326
		if self.colour &lt;&gt; null then																// PAR #32326
			colours := self.colour.getTokens;													// PAR #32326
			foreach str in colours do															// PAR #32326
				if app.myDutyDocRoot.allVehicleColours[str] = null then							// PAR #32326
					app.raiseCMException1(ERR_INVALID_COLOURCODE, str, "colour", null);			// PAR #32326
				endif;																			// PAR #32326
			endforeach;																			// PAR #32326
		endif;
	endif;
epilog
	delete colours;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyCommodity" id="d978f9d2-c84c-419c-8470-bc6768133e95">
        <updating/>
        <source>verifyCommodity() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	02 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
18 Jun 2018	jlgrh7 	 	 TFS 39128#ADP - FW: DL for Rotation 1801002901 in production
03 Mar 2022  navma1 	 ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
----------   ----------  --------------------------------------------------
*/
vars
	loopCommodity,
	commodityObj	: CM_Commodity;
	commDict		: CM_CommodityByCodeDict;
	commDescStr,
	commStr			: String;
begin
	
	if self.commodity = null and self.commodityDescription = null then
		self.validateCommodityPlus( null );	//02 Mar 2021	NDL	TFS 50740
		return;
	endif;
	
	commDict 		:= app.myRoot.allCommodities;
	commodityObj 	:= commDict[self.commodity];
	
	if commodityObj = null then
		commodityObj := commDict[self.commodityDescription];
		if commodityObj &lt;&gt; null then													//+TFS39128 								
			self.commodity 				:= commodityObj.code;							//+TFS39128 
			self.commodityDescription 	:= commodityObj.description;					//+TFS39128 
		else
			
			commDescStr	:= self.commodityDescription.toUpper;							//03.03.2022 navma1 #52499
			commStr		:= self.commodity.toUpper;										//03.03.2022 navma1 #52499
			
			foreach loopCommodity in commDict do
				if loopCommodity.description.toUpper = commDescStr or 					//03.03.2022 navma1 #52499
				   loopCommodity.code.toUpper 		 = commStr     then					//03.03.2022 navma1 #52499
				   
					self.commodity 				:= loopCommodity.code;
					self.commodityDescription 	:= loopCommodity.description;
					commodityObj 				:= loopCommodity;
					break;
				endif;
			endforeach;
		endif;
	endif;

	if commodityObj = null then 
		app.raiseCMException2(ERR_FIELD_COMMODITY, self.commodity, ETRow_Commodity, ETRow_Commodity, self); //cnwgb1 PAR 23229 18.3.2010
	else	//02 Mar 2021	NDL	TFS 50740
		self.validateCommodityPlus( commodityObj );
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyCompany" id="e49f2143-73c2-48f5-b582-18688ef7167e">
        <updating/>
        <source>verifyCompany(_terminal : CM_Terminal) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	04 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
// 12 July 2017	jlgrh7 TFS #39433  QNS - Business Unit not coming through from Vessel for Cargo loaded from Ship Manifest and Cargo On Ship EDI
	
----------   ----------  --------------------------------------------------
*/
vars
	loopBank,
	bank					: CM_Bank;
	bankDict			: CM_CompanyByCodeDict;
	voyage 			: CM_Voyage;																						//+TFS39433
begin
	if self.companyCode = null then				
		voyage := self.getVoyage();																						//+TFS39433 Get the Business Unit From the its own voayge first
		if voyage &lt;&gt; null  and voyage.myDischargeCompany &lt;&gt; null then
			self.companyCode := voyage.myDischargeCompany.code;
		endif;
	endif;
			
	if self.companyCode = null then
		self.companyCode := _terminal.getDefaultCompanyCode();
	endif;
	
	bankDict := _terminal.companies;
	bank := bankDict[self.companyCode];

	if bank = null then
		app.raiseCMException2(ERR_FIELD_COMPANY, self.companyCode, app.getErrorString(CM_CompanyBank), ETRow_CompanyCode, self);
	endif;
	
	
end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="verifyConsignee" id="fe160ab1-a158-4d81-a3a0-722fd0de7097">
        <updating/>
        <source>verifyConsignee() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	02 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
16/01/2015   cnwma1      PAR #35510 Mismatching consignee in Loading User Defined Ship Manifest File
30 Nov 2022  navma1 	 ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
04 Oct 2023	 navlw1		 CR 60542: EUP | FR Transport Manifest (And CallOff) Consignor/ee To Raise Error When Verification Fails
----------   ----------  --------------------------------------------------
*/
vars
	loopConsign,
	consign			: CM_ConsigneeConsignor;
begin
	if self.consignee = null then
		return;
	endif;
	
	consign := app.myRoot.allConsigneeConsignors[self.consignee];				//30.11.2022 navma1 #52499
	
	if consign = null then
		if self.myEDIData.isTransportManifestRelated() or self.myEDIData.isCallOffRelated() then // #60542
			app.raiseCMException2(ERR_FIELD_CONSIGNEE,self.consignee,'consignee',ETRow_Consignee,self);
		else
			app.raiseCMWarning2(ERR_FIELD_CONSIGNEE, self.consignee, 'consignee', ETRow_Consignee, self, self);
		endif;
	else	//07 Sep 2021	NDL	TFS 51928
		self.verifyObjectAvailableForEntry( consign );
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyConsignor" id="38d52d69-5ead-4b09-8195-b79a16faabbf">
        <updating/>
        <source>verifyConsignor() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	02 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
16/01/2015   cnwma1      PAR #35510 Mismatching consignee in Loading User Defined Ship Manifest File
30 Nov 2022  navma1 	 ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
04 Oct 2023	 navlw1		 CR 60542: EUP | FR Transport Manifest (And CallOff) Consignor/ee To Raise Error When Verification Fails
----------   ----------  --------------------------------------------------
*/
vars
	loopConsign,
	consign			: CM_ConsigneeConsignor;
begin
	if self.consignor = null then
		return;
	endif;
	
	consign := app.myRoot.allConsigneeConsignors[self.consignor];				//30.11.2022 navma1 #52499
	
	if consign = null then
		if self.myEDIData.isTransportManifestRelated() or self.myEDIData.isCallOffRelated() then // #60542
			app.raiseCMException2(ERR_FIELD_CONSIGNOR, self.consignor,'consignor',ETRow_Consignor,self);
		else
			app.raiseCMWarning2(ERR_FIELD_CONSIGNOR, self.consignor, 'consignor', ETRow_Consignor, self, self);
		endif;
	else	//07 Sep 2021	NDL	TFS 51928
		self.verifyObjectAvailableForEntry( consign );
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyCustomsAgent" id="0a9120d5-b387-4e57-ae35-39cb3abab4b5">
        <updating/>
        <source>verifyCustomsAgent() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 Oct 2012	cnwndl1	Initial creation	Par 30645
03 Mar 2022 navma1  ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
*/

vars
	loopCustAgent 	 : CM_CustomsAgent;
	custAgent 		 : CM_CustomsAgent;
	customsAgentDict : CM_CustomsAgentByCodeDict;
	msg 			 : String;
	customsAgentStr	 : String;
begin
	if self.customsAgent = null then
		return;
	endif;
	
	customsAgentDict := app.myRoot.allCustomsAgents;
	custAgent		 := customsAgentDict[self.customsAgent.toUpper];
	
	if custAgent = null then
		
		customsAgentStr := self.customsAgent.toUpper;							//03.03.2022 navma1 #52499
		
		foreach loopCustAgent in customsAgentDict do
			if loopCustAgent.name.toUpper.cnContains(customsAgentStr) then		//03.03.2022 navma1 #52499
				self.customsAgent := loopCustAgent.code;
				custAgent 		  := loopCustAgent;
				break;
			endif;
		endforeach;
	endif;
	
	if custAgent = null then
		app.raiseCMWarning3(InvalidCustomsAgent, self.customsAgent, self.id, null, ETRow_CustomsAgent, self, self);
	elseif custAgent.isNotAvailableForEntry then
		msg := ", " &amp; app.getErrorString1(NotAvailableForEntry, "'" &amp; custAgent.name  &amp; "'");
		app.raiseCMWarning3(InvalidCustomsAgent, self.customsAgent, self.id, msg, ETRow_CustomsAgent, self, self);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyDestination" id="4ed934e2-436a-4465-8352-ecc705340052">
        <source>verifyDestination() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Sep 2023	jlirs1	TFS 59148 (57770) IFCSUM Port of Origin BOP
25 Sep 2023 	jlirs1	TFS 59170 Port Authority Config
*/

vars
	destination : CM_Port;
begin
	if self.destinationPort = null then
		return;
	endif;
	destination := app.myRoot.allPorts[self.destinationPort];
	if destination = null then
		if not self.getMyTerminal.getConfig(ProcIFCSUMPortAuthority).Boolean then 		// 25 Sep 2023 	jlirs1	TFS 59170 Port Authority Config
//			app.raiseCMWarning1(ERR_INVALID_DEST_PORT, self.destinationPort, 'destination', self, self);
		else
			app.raiseCMException1(ERR_INVALID_DEST_PORT, self.destinationPort, 'destination', self);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyHazards" id="028a980f-2221-4d24-b965-9ba1f7e36dcf">
        <updating/>
        <source>verifyHazards() protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	02 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
02 Feb 2012	cnwrs1		Par 29076 Fix up Hazard Processing in EDI
30 Nov 2022 navma1		ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
*/
vars
	tmpHazards : ObjectArray;
	edi 	   : CM_EDITrackedItem;
begin
	//18 Nov 2016	NDL	TFS 2843 / 2604
	if self.myAttachedItems &lt;&gt; null and self.myAttachedItems.isEmpty then		//30.11.2022 navma1 #52499
		return;
	endif;
	
	foreach edi in self.myAttachedItems where edi.isEDIHazDetails do
		edi.CM_EDIHazDetailsTI.verifySelf();
	endforeach;

	create tmpHazards transient;
	if self.imCodes.isEmpty then
		return;
	endif;
	self.getProxyHazards(self.imCodes, tmpHazards, true);
epilog
	
	if tmpHazards &lt;&gt; null then													//30.11.2022 navma1 #52499
		tmpHazards.purge();
		delete tmpHazards;	
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyIMEXStatus" id="3a2ef7ff-85d5-4850-9942-bf65aed56a7c">
        <updating/>
        <source>verifyIMEXStatus( _terminal : CM_Terminal ) updating, protected;

/*
----------   ----------  --------------------------------------------------
Created:	02 August 2006 By cnwth2

Purpose:	

Changed On	Changed By	Reason
----------	----------	--------------------------------------------------
02/06/2010	cnwrl1		PAR 24174 - Changed to check for IMEXStatus abbreviation.
14/06/2016	cnwdap1		TFS #2122 Prevent tranship items being created on ship in user-defined formats
02/05/2022	jlizm1		TFS 53083 GPHA revceival/release of tranship cargo
30 Nov 2022 navma1		ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
*/
vars
	loopIMEX,
	imex					: CM_IMEXStatus;
	imexDict				: CM_IMEXStatusByCodeDict;
	mtCommodity,
	portDestCode			: String;
	upperIMEXStatus			: String;
	root					: CM_Root;
begin
	if self.imexStatus = null then
		return;
	endif;
	
	root     := app.myRoot;							//30.11.2022 navma1 #52499
	imexDict := root.allImexStatuses;				//30.11.2022 navma1 #52499
	
	if self.imexStatus.isInteger then
		// if the entered IMEX Status is an integer attempt to match it to the system IMEX Statuses
		imex := imexDict[self.imexStatus.Integer];
	endif;
	
	if imex = null then
		upperIMEXStatus	:= self.imexStatus.toUpper();
		
		foreach loopIMEX in imexDict do
			if upperIMEXStatus.cnContains( loopIMEX.description.toUpper ) then
				imex := loopIMEX;
				break;
			endif;
		endforeach;
	endif;
	
	// cnwrl1 02/06/2010 PAR 24174 - start of coding
	if imex = null then
		// Try once last time using the entered imexStatus as the abbreviation.
		foreach loopIMEX in imexDict do
			if upperIMEXStatus = loopIMEX.abbreviation.toUpper then
				self.imexStatus	:= loopIMEX.description;
				imex			:= loopIMEX;
				break;
			endif;
		endforeach;
	endif;
	// cnwrl1 02/06/2010 PAR 24174 - end of coding
	
	portDestCode := _terminal.getConfig(PortDestCode).String;
	mtCommodity	 := _terminal.getDefaultEmptyCommodity();
	
	
	if imex = null then
		if self.commodity &lt;&gt; mtCommodity then										//30.11.2022 navma1 #52499
			if self.dischargePort = portDestCode  then
				self.imexStatus := root.allImexStatuses[TI_IMEX_STATUS_IMPORT].description;
			elseif self.loadPort = portDestCode  then
				self.imexStatus := root.allImexStatuses[TI_IMEX_STATUS_EXPORT].description;
			endif;
		else
			app.raiseCMException2(ERR_FIELD_IMEX, self.imexStatus, 'IMEX Status', ETRow_ImexStatus, self);
		endif;

	elseif imex.code = TI_IMEX_STATUS_IMPORT and self.dischargePort = null then		//set the discharge port
		self.dischargePort := portDestCode;											//30.11.2022 navma1 #52499
	elseif imex.code = TI_IMEX_STATUS_EXPORT and self.loadPort = null then			//set the load port
		self.loadPort := portDestCode;												//30.11.2022 navma1 #52499
	elseif imex.code = TI_IMEX_STATUS_TRANSHIP then
		if not root.allowTranshipInterModal and self.messageMode = self.EDI_ACTION_ADD then		// TFS 53083
			app.raiseCMException(Cannot_create_EDI_Tranship, ETRow_ImexStatus, self);					// TFS #2122
		endif;
		
		//navra1 - 26th Aug 2024 - BUG 65724 - start - if you dont find the tranship cargo on site, return error - dont create		
		if  not self.isEDICargoOnShipTI() and imex.code = TI_IMEX_STATUS_TRANSHIP then
			if app.myPassport.myTerminal.allOnsiteTIsByCargoTypeId[self.cargoType, self.id] = null then
				if _terminal.getConfig(ErrIfTrCarCrOnSiFrIFCSU).Boolean = true then
					app.raiseCMException1(Cargo_item_not_found, self.id, ETRow_Id, self);		//cnwmc5 - 22 May 2014 - PAR 34191				
				endif;
			endif;
		endif;
		//navra1 - 26th Aug 2024 - BUG 65724 - end
	endif;
	
end;
</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="verifyISOType" id="27560faf-3a53-4702-8e9a-6ccb7ff8853e">
        <updating/>
        <source>verifyISOType() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	02 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
03 Mar 2022  navma1 	 ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
----------   ----------  --------------------------------------------------
*/
vars
	loopISOType,
	isoTypeObj		: CM_ISOType;
	isoTypeDict		: CM_ISOTypeByCodeDict;
	isoTypeStr		: String;
begin
	if self.isoType &lt;&gt; null then
		self.cargoType 		:= TI_CargoType_Container;
		self.cargoTypeDescr := app.myRoot.allCargoTypesById[TI_CargoType_Container].description;	//'ISO Container';
	
		if app.myAlternateDict &lt;&gt; null then	//21 Jun 2019	NDL	TFS 44895 - performance
			isoTypeObj := app.myRoot.allISOTypes[self.isoType];
			if isoTypeObj = null then
				isoTypeObj := app.myAlternateDict.getIsoTypeByDesc(self.isoType);
			endif;
		else
			isoTypeDict := app.myRoot.allISOTypes;
			isoTypeObj  := isoTypeDict[self.isoType];
			if isoTypeObj = null then
				
				isoTypeStr := self.isoType.toUpper;											//03.03.2022 navma1 #52499
				
				foreach loopISOType in isoTypeDict do
					if loopISOType.description.toUpper.cnContains(isoTypeStr) then			//03.03.2022 navma1 #52499
						isoTypeObj := loopISOType;
						break;
					endif;
				endforeach;
			endif;
		endif;
		
		//16 Oct 2019	NDL	TFS 46989 - Generator and Chassis Types should be created as their own class of object not containers.
		if isoTypeObj &lt;&gt; null and isoTypeObj.cargoTypeId &lt;&gt; TI_CargoType_Container then
			self.cargoType := isoTypeObj.cargoTypeId;
			self.cargoTypeDescr := app.myRoot.allCargoTypesById[isoTypeObj.cargoTypeId].description;
		endif;
		
	endif;
	
	if self.cargoType = TI_CargoType_Container and isoTypeObj = null then
		app.raiseCMException2(ERR_ISOTYPE_FIELD, self.isoType, ETRow_IsoType, ETRow_IsoType,  self);
	endif;
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyInstructionType" id="b99252cd-fc19-4ee2-9eaf-edde6e0505b1">
        <source>verifyInstructionType() protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 23/06/2023	navdap1		Initial creation TFS 58813 EUP - manifest Instructions
//
vars
	terminal : CM_Terminal;

begin
	if self.instructionType = null then
		return;
	endif;
	
	terminal := self.getMyTerminal();
	if terminal &lt;&gt; null and terminal.allInstructionTypes[self.instructionType] = null then
		app.raiseCMException2(Instruction_type_invalid, self.instructionType, terminal.code, null, null);
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyLocation" id="04726963-456d-4bfc-a275-f3d1ca9aa2da">
        <updating/>
        <source>verifyLocation(_terminal : CM_Terminal; _voyage : CM_Voyage; _site : Integer; _isLocalId : Boolean) updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	03 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
//24 Jan 2012	cmwrs1	CCMS 1009 Par 29024
*/
vars
	foundHeight,
	startPos		: Integer;
	strArray		: StringArray;
	location		: CM_LocationsController;
begin
	create strArray transient;
	if _site = TI_SITE_ONSHIP then
		if _voyage = null then
			//exception already raised for this in validate voyage
			return;
		endif;
		startPos := _voyage.code.length + 2;
		if self.locationId.length &gt;= startPos and
		   self.locationId[1:_voyage.code.length] = _voyage.code then	//24 Jan 2012	cmwrs1	CCMS 1009 Par 29024
			strArray.add(self.locationId[startPos:end]);
		else
			strArray.add(self.locationId);	//24 Jan 2012	cmwrs1	CCMS 1009 Par 29024
		endif;
		
		 _voyage.findLocation(strArray, false, location, foundHeight);
	
		if location = null then
//			app.raiseCMException1(ERR_INVALID_STOWAGE, self.locationId, ETRow_LocationId, null);	// cnwrl1 09/03/2010 PAR 23008 - what it was
			if not _isLocalId then	//24 Jan 2012	cmwrs1	CCMS 1009 Par 29024
				app.raiseCMException1(ERR_INVALID_STOWAGE, self.locationId, ETRow_LocationId, self);
			endif;
		endif;
	
	elseif _site = TI_SITE_ONSITE then
		_terminal.findLocationFromString(self.locationId, false, location, foundHeight);
		if location = null then
//			app.raiseCMException1(ERR_INVALID_LOCN, self.locationId, ETRow_LocationId, null);	// cnwrl1 09/03/2010 PAR 23008 - what it was
			app.raiseCMException1(ERR_INVALID_LOCN, self.locationId, ETRow_LocationId, self);

		endif;
	endif;
	
epilog
	delete strArray;
end;
</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_site" type="Integer"/>
        <Parameter name="_isLocalId" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="verifyOperator" id="b5b7a86d-224e-482c-aa2a-adb552ccfb39">
        <updating/>
        <source>verifyOperator() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	02 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
28 Nov 2024  navma1		 MTN-19124 STWO - Uploading an EDI file 'freezes' MTN.
----------   ----------  --------------------------------------------------
*/
vars
	loopOperator,
	operator					: CM_Operator;
	operatorDict				: CM_OperatorByCodeDict;
	operUpper					: String;
begin
	
	operatorDict := app.myRoot.allOperators;
	operator     := operatorDict[self.operatorCode];
	
	if operator = null then
		operUpper := self.operatorCode.toUpper;						//28.11.2024 navma1 #MTN-19124
		
		foreach loopOperator in operatorDict do
			if loopOperator.description.toUpper = operUpper or
			   loopOperator.code.toUpper 		= operUpper then
				
				self.operatorCode := loopOperator.code;
				operator 		  := loopOperator;
				break;
			endif;
		endforeach;
	endif;
	
	if operator = null then
		app.raiseCMException1(ERR_FIELD_OPERATOR, self.operatorCode, ETRow_OperatorCode, self);
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyParentage" id="f13cbb7f-b14b-4806-9b56-478f59f0c270">
        <source>verifyParentage(_terminal : CM_Terminal);
//
// 15 Jan 2018	jlgrs1	TFS 36636 STW Cargo By Site to be partial loading
// 12 Mar 2018	jglsl4	TFS 37535 Invalid parent cargotype generates null exception
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	parentTI : CM_TrackedItem;
	cargoType : CM_CargoType;
	state : Integer;
	ediTI : CM_EDITrackedItem;
begin
	if self.parentCargoID &lt;&gt; null and
	   self.parentCargoType &lt;&gt; null then
		cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(self.parentCargoType);
		if cargoType &lt;&gt; null then
			parentTI := _terminal.lookupTrackedItem(self.parentCargoID, cargoType.id, state, self.voyageCode, false);
		else // TFS 37535 - raise error if parentCargoType is invalid
			app.raiseCMException1(Cargot_not_valid_cargot_system, self.parentCargoType, ETRow_CargoTypeDescr, self); // TFS 37535
		endif;
		if parentTI = null then
			ediTI := self.myEDIData.allEDITrackedItems[self.parentCargoID];
			if ediTI &lt;&gt; null and cargoType &lt;&gt; null and // TFS 37535 - prevent 1090 if parent cargoType is null
			   ediTI.cargoType &lt;&gt; cargoType.id then
				ediTI := null;
			endif;
		endif;
		if parentTI = null and 
		   ediTI = null then
			// error parent does not exist
			app.raiseCMException2(CargoInvalidParent, self.id, self.parentCargoID, null, self);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="verifyPortOfOrigin" id="462a22c0-1f48-4c77-a510-85deb9625d1c">
        <source>verifyPortOfOrigin() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Sep 2023	jlirs1	TFS 59148 (57770) IFCSUM Port of Origin BOP
25 Sep 2023 	jlirs1	TFS 59170 Port Authority Config
*/

vars
	portOfOrigin : CM_Port;
	portOfOriginStr : String;
begin
	portOfOriginStr := self.getPortOfOrigin();
	if portOfOriginStr = null then
		return;
	endif;
	portOfOrigin := app.myRoot.allPorts[portOfOriginStr];
	if portOfOrigin = null then
		if not self.getMyTerminal.getConfig(ProcIFCSUMPortAuthority).Boolean then 
//			app.raiseCMWarning1(ERR_INVALID_PORT_ORIGIN, portOfOriginStr, 'portOfOrigin', self, self);
		else
			app.raiseCMException1(ERR_INVALID_PORT_ORIGIN, portOfOriginStr, 'portOfOrigin', self);
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyPorts" id="ccde7bb4-38a4-4ca8-aaee-8b102ba2dccf">
        <updating/>
        <source>verifyPorts(_terminal : CM_Terminal) protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	02 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	portDestCode	: String;
	port		: CM_Port;
begin
	if self.dischargePort &lt;&gt; null then
		port := app.myRoot.allPorts[self.dischargePort];
		if port = null then
//PAR 16173 this warning lets bad data get through to prenotes,  in the kiosk the truck driver gets a uninformative error and can not proceed
//PAR 16173			app.raiseCMWarning2(ERR_FIELD_VALUE, self.dischargePort, 'discharge port', ETRow_DischargePort, self, self);
			app.raiseCMException2(ERR_FIELD_DISCHARGE_PORT, self.dischargePort, 'discharge port', ETRow_DischargePort, self);
		else
			portDestCode := _terminal.getConfig(PortDestCode).String;
			//special case to auto-resolve imex if blank at this point
			if self.imexStatus = null and self.messageMode &lt;&gt; EDI_ACTION_MODIFY then  			//cnwmc5 - 22 April 2014 - CCMS 2352
				if port.code = portDestCode and self.commodity &lt;&gt; _terminal.getDefaultEmptyCommodity() then
					self.imexStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_IMPORT].description;
				elseif port.code &lt;&gt; portDestCode then
					self.imexStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT].description;
				endif;	
			endif;
		endif;
	endif;
	
	if self.destinationPort &lt;&gt; null then
		port := app.myRoot.allPorts[self.destinationPort];
		if port = null then
			app.raiseCMWarning2(ERR_FIELD_DESTINATION_PORT, self.destinationPort, 'destination port', ETRow_DestinationPort, self, self);
		endif;
	endif;
	
	if self.loadPort &lt;&gt; null then
		port := app.myRoot.allPorts[self.loadPort];
		if port = null then
//PAR 16173 this warning lets bad data get through to prenotes,  in the kiosk the truck driver gets a uninformative error and can not proceed
//PAR 16173			app.raiseCMWarning2(ERR_FIELD_VALUE, self.loadPort, 'load port', ETRow_LoadPort, self, self);
			app.raiseCMException2(ERR_FIELD_LOAD_PORT, self.loadPort, 'load port', ETRow_LoadPort,  self);		
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="verifyProduct" id="b6d0c8d5-cddc-4ee4-ac3d-ae0711da8bb1">
        <updating/>
        <source>verifyProduct() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	02 August 2006 By cnwth2

Purpose:	

Changed On  Changed By  Reason
28 Nov 2024  navma1		MTN-19124 STWO - Uploading an EDI file 'freezes' MTN.
----------  ----------  --------------------------------------------------
*/
vars
	loopProduct,
	productObj					: CM_Product;
	productDict					: CM_ProductByOpCodeProCodeDict;
	cargoTypeObj				: CM_CargoType;
	productUpper				: String;
begin
	
	if self.product = null and self.cargoType &lt; TI_CargoBOLType_Max then//not user-defined break-bulk type
		return;
	endif;
	
	cargoTypeObj := app.myRoot.allCargoTypesById[self.cargoType];
	
	if cargoTypeObj = null then//this would have been raised earlier
	
		productUpper := self.product.toUpper;									//28.11.2024 navma1 #MTN-19124
		
		foreach loopProduct in CM_Product.instances do
			if loopProduct.description.toUpper = productUpper or
			   loopProduct.code.toUpper 	   = productUpper then
				
				self.product 		 := loopProduct.code;
				productObj			 := loopProduct;
				self.cargoType 		 := loopProduct.myCargoType.id;
				self.cargoTypeDescr  := loopProduct.myCargoType.description;
				break;
			endif;
		endforeach;
	else
		productDict := cargoTypeObj.allProducts;
		productObj  := productDict[self.operatorCode,self.product];
		
		if productObj = null then
			
			productUpper := self.product.toUpper;							  //28.11.2024 navma1 #MTN-19124
			
			foreach loopProduct in productDict do
				if loopProduct.description.toUpper  = productUpper or
				   loopProduct.code.toUpper 		= productUpper then
					
					self.product := loopProduct.code;
					productObj 	 := loopProduct;
					break;
				endif;
			endforeach;
		endif;
	endif;
		
	if productObj = null then
		//if it's user defined cargotype, MUST have a matching product
		// The following is not always valid e.g. Trailers - I am removing it for PAR 22472 cnwgb1 18.3.2010 Cut day!
		//app.raiseCMException2(ERR_FIELD_PRODUCT, self.product, app.getErrorString(Product), ETRow_ProductCode, self);
	else
		if self.quantity = null then
			self.quantity := productObj.myQuantity.value;
		endif;
		
		if self.length = null then
			self.length := productObj.getLengthValue();  //myLength.value; //30.1.09 cnwrd1 par #18821 
		endif;
		if self.width = null then
			self.width := productObj.getWidthValue();  //myWidth.value; //30.1.09 cnwrd1 par #18821 
		endif;
		if self.height = null then
			self.height := productObj.getHeightValue();  //myHeight.value; //30.1.09 cnwrd1 par #18821 
		endif; 
		
		if self.volume = null then
			self.volume := productObj.myVolume.value;
		endif;
		if self.weight = null then
			self.weight := productObj.getWeightValue();  //myWeight.value; //30.1.09 cnwrd1 par #18821 
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifyReceiveStevedore" id="a5ac5b40-625a-4e8c-acc4-5400d77cd9be">
        <source>verifyReceiveStevedore()protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Nov 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores

*/

vars
	stevedoreObj : CM_Stevedore;
begin
	if self.receiveStevedore = null then
		return;
	endif;
	
	stevedoreObj := app.myRoot.allStevedores[self.receiveStevedore];
	
	if stevedoreObj = null then
		app.raiseCMWarning2(ERR_FIELD_STEVEDORE, self.receiveStevedore, app.getErrorString(ReceiveStevedore), ETRow_ReceiveStevedore, self, self);
	endif;
epilog

end;</source>
        <access>protected</access>
