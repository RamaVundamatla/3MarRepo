    <JadeMethod name="getMatchingProforma" id="10d0b32d-51e5-4ead-8c62-efb49245524d">
        <source>getMatchingProforma():CM_ProformaDetails;

/*

Purpose:			
		This method has beed added to fix missing service for QNS
Parameters:			

Return Value:		


Date		Who		Reason
21 Jan 2019	cnwma1	Initial creation	Bug 42984: QNS - RE: Report - Revenues by Service Lines
12/07/2019 	JLGNS1	Bug 45557: GUQ - Voiding on Escalating Cash Receipts (Part2)

*/

vars
	proforma : CM_ProformaDetails;
	cashRec  : CM_CashReceipt;
	
begin
	cashRec := self.myCashReceipt;
	
	if cashRec = null then	//Bug 45557
		return null;		//Bug 45557
	endif;					//Bug 45557
	
	foreach proforma in cashRec.allProformaDetails discreteLock do
		if self.cashValue &lt;&gt; proforma.lineTotal then
			continue;
		endif;
		
		if self.myTrackedItem &lt;&gt; null then
			if self.myTrackedItem &lt;&gt; proforma.myTrackedItem then
				continue;
			endif;
		endif;
		return proforma;
	endforeach;
epilog

end;</source>
        <ReturnType type="CM_ProformaDetails"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementStringForAttrib" id="15381ad7-51d3-4aa4-8ce7-ce2c0b23375e">
