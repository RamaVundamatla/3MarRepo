    <JadeMethod name="doContextMenu" id="d9724664-5f53-4f7e-bf0a-2fb214adb60d">
        <updating/>
        <source>doContextMenu(listbox: CMUI_NavigatorListBox2 input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     28 April 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	x1, 
	y1					: Real;
	menuEntity			: CM_MenuEntity;
	user				: CM_User;
	terminal			: CM_Terminal;
	listPointer			: Integer;
	
begin
	listPointer	:=	listbox.getListIndex(x,y);
	
	if listPointer &lt;= 0 then
		return false; 
	endif;
	
	mnuSort.enabled	:=	listbox.itemHasSubItems(listPointer);
	
	menuEntity := listbox.itemObject[listPointer].CM_MenuEntity;
	if (menuEntity = null) then
		return false;
	endif;
	
	listbox.listObject := menuEntity;	
	
	x1 := x;
	y1 := y;
	if not mouse then  // if keyboard, use current listIndex value
	    x1 := 20;
	    if listbox.listIndex &lt; 0 then
	        y1 := 5;
	    else
	        y1 := listbox.positionTop(listbox.listIndex);
	    endif;
	endif;
	
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);
	
	if menuEntity.isKindOf(CM_MenuUserHdr) then
		if menuEntity.allChildren.isEmpty then
			self.mnuRemoveFolder.enabled := true;
		else
			self.mnuRemoveFolder.enabled := false;
		endif;
		self.mnuRenameFolder.enabled := true;
		
		// PAR 15122 - only allow users to select pic for folders
		self.mnuSelectPicture.enabled := true;
		
		// PAR 15122 - only allow users to select pic for folders
	elseif menuEntity.isKindOf(CM_MenuRoot) then
		self.mnuRemoveFolder.enabled := false;
		self.mnuRenameFolder.enabled := false;		

		self.mnuSelectPicture.enabled := true;
	else
		self.mnuRemoveFolder.enabled := false;
		self.mnuRenameFolder.enabled := false;		

		// PAR 15122 - do not allow users to select pic for menu options
		if (not app.isDevelopmentSystem) then
			self.mnuSelectPicture.enabled := false;
		endif;
	endif;
	
	self.popupMenu(self.mnuOrganizeContext, x1.Integer, y1.Integer);
end;</source>
        <access>protected</access>
        <Parameter name="listbox" type="CMUI_NavigatorListBox2" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDragDrop" id="f5c4ab76-61f8-4f88-9a51-8b0e53c859ce">
        <updating/>
        <source>doDragDrop(listbox: ListBox input; win: Window input; x: Real; y: Real) updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 March 2003		cnwth2	
//
// Purpose:     		 
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 28/10/2005	cnwdad1		PAR #10407 - Moved the database updates here into a
//							proper transaction on the TRX agent.
// --------------------------------------------------------------------------------
vars
	hoverObject			: CM_MenuEntity; //ie. the menu entity that the dragdrop object was dropped 'onto'
	oldParent			: CM_MenuEntity;
	parent				: CM_MenuEntity;
//	arrayPos			: Integer;
	isUnopened			: Boolean;
	topLineIndex		: Integer;
	listboxObj			: CMUI_NavigatorListBox2;
	additionalObj		: CM_MenuEntity;	//25 Nov 2015	NDL	Par 36846
	msg 				: String;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
	
begin
	listboxObj	:=	lstBox;
	
	if self.dragOverIndex = self.origIndex then
		return;
	endif;
	
	if self.myPickupEntity = null then
		return;
	endif;
	
// cnwdad1 25/03/2008 - Added check to see if the drag index is valid.
	if listboxObj.dragListIndex &gt; 0 and listboxObj.dragListIndex &lt;= listboxObj.listCount() then
		hoverObject	:=	listboxObj.itemObject[listboxObj.dragListIndex].CM_MenuEntity;
	endif;
	
	if hoverObject = null then 
		return;
	endif;
	
	topLineIndex	:=	listboxObj.topIndex;
	
	if (hoverObject.isKindOf(CM_MenuUserDtl))
	or (hoverObject.isKindOf(CM_MenuUserQuery))
	or (hoverObject.isKindOf(CM_MenuUserReport))
	then
		parent	:=	hoverObject.myParent;
		
	elseif hoverObject.isKindOf(CM_MenuUserHdr) //if the folder has not sprung open then INSERT BEFORE (not into)
	and (not listboxObj.itemExpanded[self.dragOverIndex]
	and not hoverObject.allChildren.isEmpty)
	then
		if self.myPickupEntity.isKindOf(CM_MenuUserDtl) then //25 Nov 2015	NDL	Par 36846
			parent		:=	hoverObject;
		else
			parent		:=	hoverObject.myParent;
		endif;
		isUnopened	:=	true;
	else
		parent		:=	hoverObject;
	endif;
	
	oldParent := self.myPickupEntity.myParent;
	
	if oldParent = null then
		return;
	endif;
	

	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateMoveMenuItem(	oldParent,
										parent,
										self.myPickupEntity,
										hoverObject,
										isUnopened,
										app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(Error), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
	
	if self.lastMultiIndex &gt; 0 and not self.allMultiSelectObjects.isEmpty then
		//should be good to go
		msg := "You have selected " &amp; self.allMultiSelectObjects.size.String &amp; " extra items to move under " &amp; parent.getHeading &amp; ". Do you want to continue?";
		if app.msgBox( msg, app.getErrorString(Continue), MsgBox_Yes_No ) = MsgBox_Return_Yes then
			foreach additionalObj in self.allMultiSelectObjects do
				oldParent := additionalObj.myParent;
				
				//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
				while true do
				
					app.myTrxUA.trxUpdateMoveMenuItem(	oldParent,
													parent,
													additionalObj,
													hoverObject,
													isUnopened,
													app.myPassport);
				
					if app.myPassport.trxCompletedOK then
						break;
					else
						theResult := app.showErrorWarningDialog(app.getErrorString(Error), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
						if app.myPassport.noErrors and theResult = IDOK then
							app.myPassport.warningsAcknowledged	:= true;
							continue;
						endif;
					endif;
					
					break;
					
				endwhile;
				
			endforeach;
		endif;
	endif;
		
	listboxObj.displayTree(true, null);
	listboxObj.topIndex	:=	topLineIndex;			// Re-position the list back to where it was before the sort.
	listboxObj.cnEcSetObjectIndex(self.myPickupEntity);	// Re-select the menu item that was being sorted.
	
end;</source>
        <access>protected</access>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doDragOver" id="a4bc6885-0705-4281-863c-77a6f9a397cd">
        <updating/>
        <source>doDragOver(listbox: ListBox input; win: Window input; x: Real; y: Real; state: Integer) updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	menuEntity				: CM_MenuEntity;
	listIdx					: Integer;
begin
	listIdx := lstBox.dragListIndex;
	
	if listIdx = self.dragOverIndex then
		return;
	endif;
	
	self.endTimer(self.EVENT_OPENFOLDER);
	self.beginTimer(1000,  Timer_OneShot, self.EVENT_OPENFOLDER);
	self.dragOverIndex	:=	listIdx;
	lstBox.listIndex	:=	listIdx;
end;</source>
        <access>protected</access>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doMenuSort" id="7eac3f38-6201-4e56-bbfe-2ba582671f63">
        <source>doMenuSort() protected;
// --------------------------------------------------------------------------------
// Created:		06 November 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	menuEntityObj	: CM_MenuEntity;
	topLineIndex	: Integer;
	trxResult		: Integer;
	listboxObj		: CMUI_NavigatorListBox2;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
	
begin
	listboxObj		:=	lstBox;
	menuEntityObj	:=	listboxObj.listObject.CM_MenuEntity;
	
	if menuEntityObj = null then
		return;
	endif;
	
	topLineIndex	:=	listboxObj.topIndex;
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxSortMenuEntityChildren(menuEntityObj, false, true, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			listboxObj.displayTree(true, null);				// Re-populate the list with the sorted menu entities.
			listboxObj.topIndex	:=	topLineIndex;			// Re-position the list back to where it was before the sort.
			listboxObj.cnEcSetObjectIndex(menuEntityObj);	// Re-select the menu item that was being sorted.
			break;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(LicenseErrors), app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMouseDown" id="afdacbb9-2f20-4714-a338-0c1757276b28">
        <updating/>
        <source>doMouseDown(listbox: ListBox input; button: Integer; shift: Integer; x: Real; y: Real) updating, protected;
// ---------------------------------------------------------------------------
// Created:     19 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
begin
	if button = 1 then
		self.origXPos	:=	x;
		self.origYPos	:=	y;
	endif;
	
	if lstBox.listObject = null then
		return;
	endif;
	
	//25 Nov 2015	NDL	Par 36846
	if shift = 1 then
		if self.checkMultiSelect( lstBox.listIndex ) then
			return;
		endif;
	else
		self.lastMultiIndex := 0;
	endif;
	
	self.allMultiSelectObjects.clear();
	
	self.origIndex		:=	lstBox.listIndex;
	self.myPickupEntity	:=	lstBox.listObject.CM_MenuEntity;
end;</source>
        <access>protected</access>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="7742c277-9521-445b-baae-3b56a063b442">
        <updating/>
        <source>doOK() updating;
// ---------------------------------------------------------------------------
// Created:     19 December 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
begin
	self.mySelectedMenuEntity := lstBox.listObject.CM_MenuEntity;
	
	if self.mySelectedMenuEntity &lt;&gt; null then
		self.modalResult := IDOK;
	endif;
	
	inheritMethod();
end;</source>
    </JadeMethod>
