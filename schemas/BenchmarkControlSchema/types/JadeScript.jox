		and not m.checkFolder("\\" &amp; m.hostName &amp; "\c$\Users\cnwjbl6\AppData\Local\Temp\2\par-cnwjbl6")
		and not m.checkFolder("\\" &amp; m.hostName &amp; "\c$\Users\cnwjbl6\AppData\Local\Temp\3\par-cnwjbl6")
