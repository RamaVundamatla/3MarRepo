    <JadeMethod name="cmbAuditType_lostFocus" id="cf440318-66bb-4aaf-86eb-af97d0cd542e">
        <controlMethod name="ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbAuditType_lostFocus(combobox: ComboBox input) updating;

vars

begin
	if combobox.text = UPDATED then
		filterType := AuditUpdated;
	elseif combobox.text = CREATED then
		filterType := AuditCreated;
	elseif combobox.text = DELETED then
		filterType := AuditDeleted;
	elseif combobox.text = INFO then	//Par 18495 Feb 2009
		filterType := AuditInformation;
	else
		filterType := AuditAny;
	endif;
	
	tblSearch.setValueByControlName(combobox.name, combobox.text);
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
