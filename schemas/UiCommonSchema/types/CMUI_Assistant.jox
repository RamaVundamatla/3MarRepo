    </JadeMethod>
    <JadeMethod name="comboBoxDateOld" id="d818548b-87ae-4fb3-9ae3-e305298dc4df">
        <source>comboBoxDateOld(pTbl : CM_EntryTable input; pAttrName : String; pFromDate, pToDate : Date);
// ---------------------------------------------------------------------------
// Created:     02 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	fromDate,
	toDate,
	date	: Date;
	reverse	: Boolean;
	str, formatStr		: String;
	
begin

	formatStr := "dd MMM yyyy";
	
	if pFromDate &gt; pToDate then
		reverse := true;
		// swap
		toDate 		:= pFromDate;
		fromDate 	:= pToDate;
	else
		fromDate 	:= pFromDate;
		toDate 		:= pToDate;
	endif;
	
	foreach date in fromDate to toDate do
		if reverse then
			// add to from of string
			if str = null then
				str := date.shortFormatJMT();	//(formatStr);		// changes to format should also be made in displayDate method
			else
				str := date.shortFormatJMT() &amp; Tab &amp; str;	//format(formatStr) &amp; Tab &amp; str;
			endif;
		else
			if str = null then
				str := date.shortFormatJMT();	//format(formatStr);
			else
				str := str &amp; Tab &amp; date.shortFormatJMT();	//format(formatStr);
			endif;
		endif;
	endforeach;

	pTbl.setComboValues(pTbl.getRow(pAttrName), str);

end;</source>
        <text>Not used</text>
        <Parameter name="pTbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="pAttrName" type="String"/>
        <Parameter name="pFromDate" type="Date"/>
        <Parameter name="pToDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="comboBoxDebtor" id="1925a0bb-81bc-4be2-936c-92d766bfe8f5">
        <source>comboBoxDebtor(pCmb : ComboBox input; pTerminal : CM_Terminal; pDebtor : CM_Debtor);

vars

begin
	if app.myRoot.myRootCompany = null then
		return;
	endif;

	pCmb.sorted := false;
	pCmb.listCollection(app.myRoot.myRootCompany.debtors, true, 0);
	if pDebtor &lt;&gt; null and app.myRoot.myRootCompany.debtors.includes(pDebtor) then
		pCmb.text := self.displayEntryDebtor(pDebtor);
		pCmb.listObject := pDebtor;
	endif;

end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="pTerminal" type="CM_Terminal"/>
        <Parameter name="pDebtor" type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="comboBoxDebtorType" id="75f41985-ea5c-4fea-9639-774956a7f1a4">
        <source>comboBoxDebtorType(_cmb : CMUI_ComboBox input; _allowNone : Boolean; _isBOL : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 September 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	aDebtorType : CM_DebtorType;
begin
	_cmb.clear;
	_cmb.sorted:=true;
	// from 30731, option for no debtor type, in storage config
	if _allowNone then
		_cmb.addItemObject(" ", null);
	endif;
	
	foreach aDebtorType in app.myRoot.allDebtorTypes where not aDebtorType.isNotAvailableForEntry do
		if _isBOL then	//29 Nov 2019	NDL		TFS 47100
			if not aDebtorType.isBolDrType then
				continue;
			endif;
		else
			if aDebtorType.code = CM_DebtorType.DT_EVENT_TYPE then // PAR 17557
				continue;
			elseif aDebtorType.isBolDrType then
				continue;
			endif;
		endif;
		
		_cmb.addItemObject(aDebtorType.description,aDebtorType);	
	
	endforeach;
epilog

end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_allowNone" type="Boolean"/>
        <Parameter name="_isBOL" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="comboBoxDefContentsStatus" id="dafab303-efad-4912-b574-a15f5f3c50c0">
        <source>comboBoxDefContentsStatus(_cmb : CMUI_ComboBox input; _contentsStatus : String);
// djw par 18111
// The default can be either LCL or FCL
vars
	lcl, fcl: CM_ContentsStatus;
begin
	_cmb.clear();
	lcl := app.myRoot.allContentsStatuses[TI_CONTENTS_STATUS_LCL];
	_cmb.itemObject[_cmb.addItem(lcl.abbreviation)] := lcl;
	fcl := app.myRoot.allContentsStatuses[TI_CONTENTS_STATUS_FCL];
	_cmb.itemObject[_cmb.addItem(fcl.abbreviation)] := fcl;

	if _contentsStatus = lcl.abbreviation then
		_cmb.listObject := lcl;
	else
		_cmb.listObject := fcl;
	endif;
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_contentsStatus" type="String"/>
    </JadeMethod>
    <JadeMethod name="comboBoxDefaultRelativeTo" id="c214b6bf-7322-4349-a66e-d55832b45050">
        <source>comboBoxDefaultRelativeTo(_table : CM_EntryTable input; _attrName, _value : String; _criteriaType :Integer);

/*
Date		Who		Reason
22 May 2009	cnwar2	Initial creation
22/02/2012	cnwcs5	par 29158 - EDI Booking cutoffs
*/
vars
	row	: Integer;	
	str	: String;
begin
	row := _table.getRow(_attrName);
	str	:= DefaultRelativeTo_Arrival_Str &amp; Tab &amp;
			DefaultRelativeTo_Depart_Str;
			
	if _criteriaType = CM_ReceivalCutoffTermDef.CriteriaType_EDI then
		str := str  &amp; Tab &amp;
				DefaultRelativeTo_ShipExch_Str &amp; Tab &amp;	
				DefaultRelativeTo_RecCutOffStr;		
	endif;
	
	_table.setComboValues(row, str);

	if _value &lt;&gt; null then
		if _criteriaType = CM_ReceivalCutoffTermDef.CriteriaType_EDI or
			_value = DefaultRelativeTo_Arrival_Str or 
			_value = DefaultRelativeTo_Depart_Str then
			_table.setValue(row, _value);
		else
			_table.setValue(row, null);
		endif;
	endif;
	
end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_value" type="String"/>
        <Parameter name="_criteriaType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="comboBoxDelayType" id="e99b740f-259d-4018-9dcf-d9d8491a930d">
        <source>comboBoxDelayType(_combo :CMUI_ComboBoxDelayType input; _includeAll :Boolean; _type :CM_DelayType);
// ---------------------------------------------------------------------------
// Created:     01 April 2011 by cnwcs5
// Purpose:     
// Parameters:  _includeAll	- if true then those "not available for entry" are included
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	dd		:DynaDictionary;
	type	:CM_DelayType;
	obj : Object;
	
begin
	create dd transient;
	
	dd.setMembership(CM_DelayType);
	dd.addMemberKey(CM_DelayType::delayTypeOrder.name, false, false);
	dd.endKeys(true);
	
	foreach type in app.myRoot.allDelayTypes do
		if not _includeAll and type.isNotAvailableForEntry then
			continue;
		endif;
		
		dd.add (type);
	endforeach;
	// make sure we include the type to be selected
	if _type &lt;&gt; null and not dd.includes (_type) then
	//	dd.add (type);
		dd.add (_type);	//14 Sep 2011	NDL Par 28152
	endif;
	// load up the combo
	_combo.clear;
	_combo.sorted := false;
	
	//_combo.listCollection (dd, false, null);
	//14 Sep 2011	NDL Par 28152
	foreach obj in dd do
		type := obj.CM_DelayType;
		_combo.itemObject[_combo.addItem( _combo.displayEntry(null,type,0))] := type;
	endforeach;
	
	_combo.setInitialised (true);
	
	// select _type
	if _type &lt;&gt; null then
		_combo.listObject := _type;
	endif;
epilog
	delete dd;
end;</source>
        <Parameter name="_combo" type="CMUI_ComboBoxDelayType" usage="input"/>
        <Parameter name="_includeAll" type="Boolean"/>
        <Parameter name="_type" type="CM_DelayType"/>
    </JadeMethod>
    <JadeMethod name="comboBoxDelayTypeGroup" id="90e41971-b53b-4908-9b6a-9dda218e5f31">
        <source>comboBoxDelayTypeGroup(_combo : CMUI_ComboBox input; _group : CM_DelayTypeGroup);
// ---------------------------------------------------------------------------
// Created:     23 June 2011 by cnwjre1
// Purpose:     for par 27755 for use in terminal config 'Delay Type Group for Hand Held'
// Parameters:  
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	dd		: DynaDictionary;
	group	: CM_DelayTypeGroup;
	obj		: Object;
begin
	create dd transient;
	
	dd.setMembership(CM_DelayTypeGroup);
	dd.addMemberKey(CM_DelayTypeGroup::description.name, false, false);
	dd.endKeys(true);
	
	foreach group in app.myRoot.allDelayTypeGroups do
		dd.add (group);
	endforeach;
	
	// make sure we include the group to be selected
	if _group &lt;&gt; null and not dd.includes (_group) then
		dd.add (group);
	endif;
	// load up the combo
	_combo.clear;
	_combo.sorted := false;
	// add a null entry to allow setting the config option to 'no group'
	_combo.addItem(" ");
	foreach obj in dd do
		group := obj.CM_DelayTypeGroup;
		_combo.itemObject[_combo.addItem(group.description)] := group;
	endforeach;
	
	// select _group
	if _group &lt;&gt; null then
		_combo.listObject := _group;
	endif;
epilog
	delete dd;
end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_group" type="CM_DelayTypeGroup"/>
    </JadeMethod>
    <JadeMethod name="comboBoxDeliveryAddress" id="f8def00c-42b1-492a-ba56-6a4ae162fa19">
        <source>comboBoxDeliveryAddress(_combo :CMUI_ComboBox input; _deliveryParty : CM_DeliveryParty input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 June 2022	jlier1	Initial creation 53678

*/

vars
	address : CM_Address;
	defaultIndex,idx : Integer;
begin	
	_combo.clear;
	if _deliveryParty = null then
		return;
	endif;

	foreach address in _deliveryParty.allAddresses discreteLock do
		idx:=_combo.addItemObject(address.description,address);
		if address.isDefault then
			defaultIndex:=idx;
		endif;
	endforeach;
	
	if defaultIndex &gt; 0 then
		_combo.setIndex(defaultIndex);
	endif;
epilog

end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_deliveryParty" type="CM_DeliveryParty" usage="input"/>
    </JadeMethod>
    <JadeMethod name="comboBoxDeliveryParty" id="fed15c6c-4f1e-4a80-98a4-3c7b7211eb8c">
        <source>comboBoxDeliveryParty(_combo :CMUI_ComboBox input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 June 2022	jlier1	Initial creation 53678

*/

vars
	iter : Iterator;
	deliveryParty : CM_DeliveryParty;
begin
	_combo.clear;
	_combo.addItem(" ");
	iter:=self.myTerminal.allDeliveryParties.createIterator;
	while iter.next(deliveryParty) do 
		_combo.addItemObject(deliveryParty.code,deliveryParty);
	
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="comboBoxDeliveryReason" id="8a8b6a5d-5110-43de-8847-ac8a97853409">
        <source>comboBoxDeliveryReason(pTbl : CM_EntryTable input; pAttrName, pValue : String);
// ---------------------------------------------------------------------------
// Created:     02 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theRow	: Integer;
	reasons: String;
	reason: CM_DeliveryReleaseReason;
begin

	theRow := pTbl.getRow(pAttrName);
	
	// Check User reasons PAR 21885
	reasons := ''; 
	foreach reason in app.myRoot.allDeliveryReasonselReasons do
		reasons := reasons &amp; Tab &amp; reason.description;
	endforeach;

	reasons := reasons &amp; Tab &amp; 
						DELSTR_IST &amp; Tab &amp;
						DELSTR_NIB &amp; Tab &amp;
						DELSTR_PEX &amp; Tab &amp;
						DELSTR_RPK &amp; Tab &amp;
						DELSTR_SNT &amp; Tab &amp;
						DELSTR_TSC;

	pTbl.setComboValues(theRow, reasons);
	
	if pValue &lt;&gt; null then
		pTbl.setValue(theRow, pValue);
	endif;
	
end;</source>
        <Parameter name="pTbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="pAttrName" type="String"/>
        <Parameter name="pValue" type="String"/>
    </JadeMethod>
    <JadeMethod name="comboBoxDeliveryReasonCombo" id="24fc4cb4-6abf-411a-a63b-cccc1d36cd83">
        <source>comboBoxDeliveryReasonCombo(_combo :CMUI_ComboBox input; _value :String);
/*
Date		Who		Reason
21 November 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
*/
vars
	reason	:CM_DeliveryReleaseReason;
	index	:Integer;
begin
	_combo.clear();
	_combo.addItem(null);
	_combo.addItem(DELSTR_IST);
	_combo.addItem(DELSTR_NIB);
	_combo.addItem(DELSTR_PEX);
	_combo.addItem(DELSTR_RPK);
	_combo.addItem(DELSTR_SNT);
	_combo.addItem(DELSTR_TSC);
	
	foreach reason in app.myRoot.allDeliveryReasonselReasons do
		_combo.addItem(reason.description);
	endforeach;
	
	if _value &lt;&gt; null then
		index := _combo.findStringExact (1, _value);
		
		if index &gt; 0 then
			_combo.listIndex := index;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="comboBoxDestTerminal" id="e265bb2b-9223-45be-89b8-e98c159a5735">
        <source>comboBoxDestTerminal(_cmb : ComboBox input; _fromTerminal, _toTerminal : CM_Terminal);
//----------------------------------------------------------------
//	Created:	23 July 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	term		: CM_Terminal;
	//termDict	: CM_TerminalByCodeDict;
	idx			: Integer;
begin

	_cmb.clear();
	
	if _fromTerminal = null or
	   not app.isInterTerminalTransferEnabled 
	   then
		return;
	endif;
	
	if _fromTerminal.allTerminalsForRelease.isEmpty then
		return;
	endif;
	
	_cmb.addItem("");
	
	foreach term in _fromTerminal.allTerminalsForRelease do
		idx := _cmb.addItem(term.name);
		_cmb.itemObject[idx] := term;
	endforeach;

	/*
	create termDict transient;
	
	_fromTerminal.getOtherTerminals(termDict);
	
	_cmb.addItem("");
	
	foreach term in termDict do
		idx := _cmb.addItem(term.name);
		_cmb.itemObject[idx] := term;
	endforeach;
	*/
	
	if _toTerminal &lt;&gt; null then
		idx := _cmb.findObject(_toTerminal);
		if idx &gt; -1 then
			_cmb.listIndex := idx;
		endif;
	endif;
	
epilog
	//delete termDict;
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_fromTerminal" type="CM_Terminal"/>
        <Parameter name="_toTerminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="comboBoxDestination" id="ec12a57b-43a7-4491-8d2a-fb9d59cf0be9">
        <updating/>
        <source>comboBoxDestination(pCmb : ComboBox input; pPort : CM_Port) updating;
// ---------------------------------------------------------------------------
// Created:     20 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str : String;
begin

//	self.setAllPortCodes(null);
	self.allPortDisplayCodesInitialize();
	pCmb.clear();
	pCmb.listCollection(self.allPortCodeDisplay, false, 0);
	if pPort &lt;&gt; null then
		str := self.displayEntryPort(pPort);
		if str &lt;&gt; null then
			pCmb.text := str;
		endif;
	endif;

end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="pPort" type="CM_Port"/>
    </JadeMethod>
    <JadeMethod name="comboBoxDischarge" id="36610598-661f-483b-b5b5-bf8e5155cd61">
        <updating/>
        <source>comboBoxDischarge(pCmb : ComboBox input; pVoyage : CM_Voyage; pPort : CM_Port) updating;
// ---------------------------------------------------------------------------
// Created:     20 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	portCol	: Collection;
	idx		: Integer;
begin
	
	pCmb.clear();
	
	if pVoyage &lt;&gt; null 
	and (not pVoyage.isNullVoyage) then
		self.allPortsForVoyageInitialize(pVoyage);
		portCol := self.allPortsVoyCodeDisplay;
	else
		//portCol := app.myRoot.allPorts;
		self.allPortDisplayCodesInitialize();
		portCol := self.allPortCodeDisplay;
	endif;
	
	
	pCmb.listCollection(portCol, false, 0);

	if pPort &lt;&gt; null then
		idx := pCmb.findObject(pPort);
		if idx &gt; -1 then
			pCmb.listIndex := idx;
		endif;
	endif;

end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="pVoyage" type="CM_Voyage"/>
        <Parameter name="pPort" type="CM_Port"/>
    </JadeMethod>
