<Class name="CM_WONonOperationalToDoWLE" id="d3e861a6-125f-4262-9279-b1eb968a1b01">
    <superclass name="CM_WOToDoWLE"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <ExplicitInverseRef name="myDebtor" id="679bcdee-992a-4723-a3eb-8c9c9333afad">
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_Debtor"/>
        <access>readonly</access>
        <Inverse name="CM_Debtor::allWorkOrderWLEs"/>
    </ExplicitInverseRef>
    <JadeMethod name="addToDoTask" id="91e3e3ed-f494-490c-8eb7-d68914166232">
        <updating/>
        <source>addToDoTask() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 November 2022	navcs2	ChangeRequest 56691:[56120] EUP - Allow Completing ToDo Work order tasks at Complete ToDo Task Screen

*/

vars
	toDoDesc 			: CM_ToDoTaskDesc;
	nonOpsTask 			: CM_ToDoTask;
	passport 			: CM_Passport;
	
begin
	
	if self.myDebtor = null then
		//throw error
		return;
	endif;
	
	passport := app.myPassport;
	
	toDoDesc := self.job.CM_WOToDoTaskJob.myToDoTaskDesc;

	if nonOpsTask = null then //add task
		nonOpsTask := myDebtor.createToDoTask(toDoDesc.code, self.job.myWorkOrderDtlToDo); // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
		self.job.myWorkOrderDtlToDo.allToDoTasks.add(nonOpsTask);
	endif;
	
	self.myToDoTask := nonOpsTask;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="0f2cc5f7-4598-4eae-88b2-760ad13cf8b3">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2024	navhl20 Bug MTN-33560: EUP | 53813 - Operator not shown for the Non Operational job
*/

vars

begin
	if _attrName = ETRow_MyOperator then
		return self.getOperator();
	endif;
	return inheritMethod(_attrName, _short);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOperator" id="60d25fc4-42a4-443b-8600-8ff227f95cd5">
        <source>getOperator():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Dec 2024	navhl20 Bug MTN-33560: EUP | 53813 - Operator not shown for the Non Operational job
*/

vars
	opr	: String;
begin
	if self.myDebtor &lt;&gt; null then
		opr := self.myDebtor.operators.listStringNoDuplicate(Comma, CM_Operator::code.name);
	endif;
	
	return opr;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setDebtor" id="4ba3fd75-b298-4edb-bbb9-bd0472029ba5">
        <updating/>
        <source>setDebtor(_debtor : CM_Debtor) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 November 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/

vars

begin
	self.myDebtor := _debtor;
	
	self.addToDoTask();
epilog

end;</source>
        <Parameter name="_debtor" type="CM_Debtor"/>
    </JadeMethod>
</Class>
