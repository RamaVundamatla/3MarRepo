    <JadeMethod name="showCalenderForm" id="a5943215-cd50-4b0f-ac90-bb5253daf795">
        <updating/>
        <source>showCalenderForm(_row, _col : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     25 February 2005 by cnwrs2
//
// Purpose:     
//
// Changed On	By			Reason
// ---------------------------------------------------------------------------
// 26/10/2012	cnwdap1		PAR #30247 Date mask and calendar showing different dates
//TFS2304 cnwns1	15/7/16	Multi-timezone issue - Date Picker defaults to System Date
//16/11/17 jlgns1 TFS 6960 QNS - Disk space issues and house keeping inside JMT
vars
	calendarFormObj	: CMUI_CalendarSelectForm;
	cellObj			: JadeTableCell;
	tmpText			: String;
	today			: Date;
	tmpDate			: Date;

	
begin
	app.mousePointer	:=	Busy;
	
	if self.readOnly or (not self.userInputEnabled) then
		return;
	endif;
	
	if _row &lt;= 0 or _col &lt;= 0 or _row &gt; self.rows or _col &gt; self.columns then
		return;
	endif;
	
	
	cellObj		:=	self.accessCell(_row, _col);
	tmpText		:=	cellObj.text;
	//tmpDate	:=	tmpText.asDate();			// PAR #30247
	tmpDate		:=	tmpText.asDateJMT();		// PAR #30247	
	
	create calendarFormObj transient;
	calendarFormObj.setMyTerminal(self.getMyTerminal());				//TFS2304 cnwns1	15/7/16
	if tmpDate.isValid() then											//TFS2304 cnwns1	15/7/16
		calendarFormObj.setStartDate(tmpDate);							//TFS2304 cnwns1	15/7/16
	else																//TFS2304 cnwns1	15/7/16
		today := self.systemToLocalTime(app.actualTimeServer).date();	//TFS2304 cnwns1	15/7/16
		calendarFormObj.setStartDate(today);							//TFS2304 cnwns1	15/7/16
	endif;																//TFS2304 cnwns1	15/7/16

	
	self.doPositionCalendar(calendarFormObj, cellObj);
	calendarFormObj.showModal();
	if calendarFormObj.modalResult = Form.CNEC_MODAL_SELECT then
		tmpDate			:=	calendarFormObj.getDate();
		cellObj			:=	self.accessCell(_row, _col);
		cellObj.text	:=	tmpDate.shortFormatJMT(); 
		//TFS 6960
		if cellObj.cellControl.isKindOf(CMUI_DateMaskBGP) and cellObj.cellControl.CMUI_DateMaskBGP.text &lt;&gt; cellObj.text then
			cellObj.cellControl.CMUI_DateMaskBGP.text := cellObj.text;
		endif;
		//TFS 6960
		//epr TFS 47132 16/12/19
		self.handleCalenderDateChange(cellObj);
	endif;

	self.setFocus();
epilog
	delete calendarFormObj;
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showCalenderTimeForm" id="b461a8cf-02db-4d01-ad61-331c1bee1310">
        <updating/>
        <source>showCalenderTimeForm(_row, _col : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     31 August 2023 by navra1
//
// Purpose:     
//
// Changed On	By			Reason
// ---------------------------------------------------------------------------
// 31/08/2023	navra1 		TFS 59839 - POB | QShips Integration - Editable Last Run Time	

vars
	calendarTimeFormObj	: CMUI_CalendarTimeSelectForm;
	cellObj				: JadeTableCell;
	tmpText				: String;
	today				: Date;
	tmpDate				: Date;
	tmpTime				: Time;	
	time:Time;
	pos					: Integer;
	timeStamp			: TimeStamp;
begin
	app.mousePointer	:=	Busy;
	
	if self.readOnly or (not self.userInputEnabled) then
		return;
	endif;
	
	if _row &lt;= 0 or _col &lt;= 0 or _row &gt; self.rows or _col &gt; self.columns then
		return;
	endif;
	
	
	cellObj		:=	self.accessCell(_row, _col);
	tmpText		:=	cellObj.text;			
	
	timeStamp	:=	tmpText.asTimeStampJMT();
	tmpTime 	:= 	timeStamp.time();
	tmpDate 	:=	timeStamp.date();
	
	//debug
	//write "now splitting"&amp;CrLf;
	//write "time = " &amp; tmpTime.asStringJMT();
	//write "date = " &amp; tmpDate.asStringJMT();	
	////	
	
	create calendarTimeFormObj transient;
	calendarTimeFormObj.setMyTerminal(self.getMyTerminal());				//TFS2304 cnwns1	15/7/16
	if tmpDate.isValid() then												//TFS2304 cnwns1	15/7/16
		calendarTimeFormObj.setStartDate(tmpDate);							//TFS2304 cnwns1	15/7/16
	else																	//TFS2304 cnwns1	15/7/16
		today := self.systemToLocalTime(app.actualTimeServer).date();		//TFS2304 cnwns1	15/7/16
		calendarTimeFormObj.setStartDate(today);							//TFS2304 cnwns1	15/7/16
	endif;																	//TFS2304 cnwns1	15/7/16
	
	if tmpTime.isValid() then					
		calendarTimeFormObj.setStartTime(tmpTime);
	else		
		calendarTimeFormObj.setStartTime(self.systemToLocalTime(app.actualTimeServer).time());						
	endif;																

	
	self.doPositionCalendarTime(calendarTimeFormObj, cellObj);
	calendarTimeFormObj.showModal();
	if calendarTimeFormObj.modalResult = Form.CNEC_MODAL_SELECT then
		//get the new selected date and set it
		timeStamp.setDate(calendarTimeFormObj.getDate());
		timeStamp.setTime(calendarTimeFormObj.getTime());
		cellObj			:=	self.accessCell(_row, _col);
		cellObj.text	:=	timeStamp.asStringJMT(); 
		//TFS 6960
		if cellObj.cellControl.isKindOf(CMUI_DateMaskBGP) and cellObj.cellControl.CMUI_DateMaskBGP.text &lt;&gt; cellObj.text then
			cellObj.cellControl.CMUI_DateMaskBGP.text := cellObj.text;
		endif;
		//TFS 6960
		//epr TFS 47132 16/12/19
		self.handleCalenderDateChange(cellObj);
	endif;

	self.setFocus();
epilog
	delete calendarTimeFormObj;
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
    </JadeMethod>
