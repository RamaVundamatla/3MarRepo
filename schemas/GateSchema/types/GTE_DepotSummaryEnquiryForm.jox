    <JadeMethod name="displayRelReqStatus" id="33f73629-854a-4920-8a73-bef24e455169">
        <source>displayRelReqStatus();
// ---------------------------------------------------------------------------
// Created:     10 February 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 11/08/2011		cnwdap1			PAR #27972 Bulk release transport mode no longer translatable, replaced by string constants
// ---------------------------------------------------------------------------

vars
	idx : Integer;
begin
	self.lstRelStatus.columns := 2;
	self.lstRelStatus.setChkBoxColumn( 1);
	
	if app.myCurrentUserCan(self.myTerminal, PmGteMTReleaseViewRd) then
		//idx := self.lstRelTypes.addItem(Tab &amp; app.getErrorString(BR_TYPE_DESCR_ROAD));	// PAR #27972
		idx := self.lstRelTypes.addItem(Tab &amp; BR_TYPE_ROAD_STR);							// PAR #27972
//		BR_TYPE_ROAD;
	endif;
	if app.myCurrentUserCan(self.myTerminal, PmGteMTReleaseViewRail) then
		//idx := self.lstRelTypes.addItem(Tab &amp; app.getErrorString(BR_TYPE_DESCR_RAIL));	// PAR #27972
		idx := self.lstRelTypes.addItem(Tab &amp; BR_TYPE_RAIL_STR);							// PAR #27972
		//BR_TYPE_RAIL;
	endif;
	if app.myCurrentUserCan(self.myTerminal, PmGteMTReleaseViewGen) then
		//idx := self.lstRelTypes.addItem(Tab &amp; app.getErrorString(BR_TYPE_DESCR_PACKING));	// PAR #27972
		idx := self.lstRelTypes.addItem(Tab &amp; BR_TYPE_PACKING_STR);							// PAR #27972
		//BR_TYPE_PACKING;
	endif;
	if app.myCurrentUserCan(self.myTerminal, PmGteMTReleaseViewShip) then
		//idx := self.lstRelTypes.addItem(Tab &amp; app.getErrorString(BR_TYPE_DESCR_SHIP));	// PAR #27972
		idx := self.lstRelTypes.addItem(Tab &amp; BR_TYPE_SHIP_STR);							// PAR #27972
		//BR_TYPE_SHIP;
	endif;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayRelReqTypes" id="00636b6f-0b2a-4f28-a6d2-d632188740dd">
        <source>displayRelReqTypes();
// ---------------------------------------------------------------------------
// Created:     10 February 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 11/08/2011		cnwdap1			PAR #27972 Bulk release type no longer translatable, replced by string constants
// ---------------------------------------------------------------------------

vars
	idx : Integer;
begin
	self.lstRelStatus.columns := 2;
	self.lstRelStatus.setChkBoxColumn( 1);
	
	//self.lstRelStatus.addItem(Tab &amp; app.getErrorString(BR_TYPE_DESCR_PACKING));	// PAR #27972
	self.lstRelStatus.addItem(Tab &amp; BR_TYPE_PACKING_STR);							// PAR #27972
	self.lstRelStatus.addItem(Tab &amp; BR_ACTIVE_STRING);
	self.lstRelStatus.addItem(Tab &amp; BR_PENDING_STRING);
//	self.lstRelStatus.addItem(Tab &amp; BR_ACTIVE_STRING &amp; ' &amp; ' &amp; BR_PENDING_STRING);
	self.lstRelStatus.addItem(Tab &amp; BR_COMPLETE_STRING);
	self.lstRelStatus.addItem(Tab &amp; BR_ARCHIVE_STRING);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displaySelectorQueries" id="945ba0d4-15f4-469a-9aba-e373d644a22a">
        <source>displaySelectorQueries();
// ---------------------------------------------------------------------------
// Created:     10 February 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	menuEntity		: CM_MenuEntity;
	subMenuEntity		: CM_MenuEntity;
begin


	foreach menuEntity in app.myRoot.myQueryMenuRoot.allChildren  discreteLock do
		if not menuEntity.isKindOf(CM_MenuUserHdr) then
		
			if menuEntity.isKindOf(CM_MenuUserQuery) then
				if menuEntity.CM_MenuUserQuery.getType() = CM_QueryDefinition.TrackedItem_Query_Type then  //cnwrd1 par 25303 4.8.2010
					self.cmbContQuery.addItemObject(menuEntity.getHeading(), menuEntity);
				endif;
			else
				// should be here when?
				self.cmbContQuery.addItemObject(menuEntity.getHeading(), menuEntity);
			endif;
		endif;
		foreach subMenuEntity in menuEntity.allChildren  discreteLock do
			if not subMenuEntity.isKindOf(CM_MenuUserHdr) then
				if subMenuEntity.isKindOf(CM_MenuUserQuery) then
					if subMenuEntity.CM_MenuUserQuery.getType() = CM_QueryDefinition.TrackedItem_Query_Type then			//cnwrd1 par 25303 4.8.2010
					self.cmbContQuery.addItemObject(subMenuEntity.getHeading(), subMenuEntity);
				endif;
				else
					// should be here when?
					self.cmbContQuery.addItemObject(subMenuEntity.getHeading(), subMenuEntity);
				endif;					
			endif;
		endforeach;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displaySummaryDefs" id="cc47cdd4-4199-440c-a632-73bf35fa47ce">
        <source>displaySummaryDefs();
// ---------------------------------------------------------------------------
// Created:     10 February 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	xtab	: CM_OutputFormat;
begin

	foreach xtab in app.myRoot.allOutputFormats_XTAB do
	
		if xtab.CM_OutputFormat_XTAB.type = CM_QueryDefinition.Release_Query_Type then
		//if xtab.CM_OutputFormat_XTAB.mode = CM_QueryDefinition.Release_Query_Mode
		//or xtab.CM_OutputFormat_XTAB.mode = CM_QueryDefinition.ReleaseItem_Query_Mode then
			self.cmbRelSummary.itemObject[ self.cmbRelSummary.addItem( xtab.name ) ]	:= xtab;
			
		elseif xtab.CM_OutputFormat_XTAB.type = CM_QueryDefinition.BookRef_Query_Type then
				continue;
		else
			self.cmbContSummary.itemObject[ self.cmbContSummary.addItem( xtab.name ) ]	:= xtab;
		endif;
	endforeach;
	
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="displayTISummaryDefs" id="e83d407c-5755-4556-9a90-f0a2243a8e88">
        <source>displayTISummaryDefs();
// ---------------------------------------------------------------------------
// Created:     10 February 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	xtab	: CM_OutputFormat;
begin
	self.cmbContSummary.clear;
	foreach xtab in app.myRoot.allOutputFormats_XTAB do
	
		if xtab.CM_OutputFormat_XTAB.type &lt;&gt; self.myQueryDefinition.type then
			continue;
		endif;
		if xtab.CM_OutputFormat_XTAB.mode  &lt;&gt; self.myQueryDefinition.mode then
				continue;
		endif;
		
		self.cmbContSummary.itemObject[ self.cmbContSummary.addItem( xtab.name ) ]	:= xtab;
	endforeach;
	
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="doSearchBRs" id="bd7c8935-ff03-4a6d-8e9c-4bc4f0440a18">
        <source>doSearchBRs() : Boolean;
// ---------------------------------------------------------------------------
// Created:     12 February 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 11/08/2011		cnwdap1			PAR #27972 Bulk release types no longer translatable, replaced by string constants
// 11/07/2025		naviv1			MTN-35226 : MTN - Usage of Iterator.getCurrentKeys  
// ---------------------------------------------------------------------------

vars
	objectSet : CM_ObjectSet;
	aBR : CM_BulkRelease;
	theDate : Date;
	dict : Dictionary;
	iter : Iterator;
	statusesToSearch,
	typesToSearch		: IntegerArray;
	idx, typeToSearch, statusToSearch  : Integer;
	theType, releaseNoKey : String;
	typeKey,statusKey			: Integer;
	tsKey : TimeStamp;
begin
	if self.cmbRelSummary.listIndex &lt; 1 then
		app.msgBox("Please select a release summary definition to use", "Release Query Error", MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;

	create typesToSearch transient;
	create statusesToSearch transient;
	
	foreach idx in 1 to self.lstRelTypes.rows do
		if self.lstRelTypes.accessCell(idx,1).text = "1" then
			theType := self.lstRelTypes.accessCell(idx,2).text;
			//if theType = app.getErrorString(BR_TYPE_DESCR_ROAD) then			// PAR #27972
			if theType = BR_TYPE_ROAD_STR then									// PAR #27972
				typesToSearch.add(BR_TYPE_ROAD);
			//elseif theType = app.getErrorString(BR_TYPE_DESCR_RAIL) then		// PAR #27972
			elseif theType = BR_TYPE_RAIL_STR then								// PAR #27972
				typesToSearch.add(BR_TYPE_RAIL);
			//elseif theType = app.getErrorString(BR_TYPE_DESCR_PACKING) then	// PAR #27972
			elseif theType = BR_TYPE_PACKING_STR then							// PAR #27972
				typesToSearch.add(BR_TYPE_PACKING);
			//elseif theType = app.getErrorString(BR_TYPE_DESCR_ALL) then		// PAR #27972
			elseif theType = BR_TYPE_SHIP_STR then								// PAR #27972
				typesToSearch.add(BR_TYPE_SHIP);
			//elseif theType = app.getErrorString(BR_TYPE_DESCR_ALL) then		// PAR #27972
			elseif theType = null or theType = BR_TYPE_ALL_STR then				// PAR #27972
				typesToSearch.add(BR_TYPE_ROAD);
				typesToSearch.add(BR_TYPE_RAIL);
				typesToSearch.add(BR_TYPE_PACKING);
				typesToSearch.add(BR_TYPE_SHIP);
			endif;
		endif;
	endforeach;
	if typesToSearch.isEmpty() then
		app.msgBox("Please select a release type to use", "Release Query Error", MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;

	foreach idx in 1 to self.lstRelStatus.rows do
		if self.lstRelStatus.accessCell(idx,1).text = "1" then
			theType := self.lstRelStatus.accessCell(idx,2).text;
			if (theType = BR_ACTIVE_STRING &amp; ' &amp; ' &amp; BR_PENDING_STRING) then
				statusesToSearch.add(BR_ACTIVE);
				statusesToSearch.add(BR_PENDING);
			elseif theType = BR_PENDING_STRING then
				statusesToSearch.add(BR_PENDING);
			elseif theType = BR_COMPLETE_STRING then
				statusesToSearch.add(BR_COMPLETE);
			elseif theType = BR_ARCHIVE_STRING then 
			   statusesToSearch.add(BR_ARCHIVE);
			elseif theType = BR_ACTIVE_STRING then
				statusesToSearch.add(BR_ACTIVE);
			//elseif theType = app.getErrorString(BR_TYPE_DESCR_ALL) then		// PAR #27972
			elseif theType = BR_TYPE_ALL_STR then								// PAR #27972
				statusesToSearch.add(BR_PENDING);
				statusesToSearch.add(BR_ACTIVE);
				statusesToSearch.add(BR_COMPLETE);
				statusesToSearch.add(BR_ARCHIVE);
			endif;
		endif;
	endforeach;
	if statusesToSearch.isEmpty() then
		app.msgBox("Please select a release status to use", "Release Query Error", MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;
	
	theDate := self.mskDate.getDate;
	if not theDate.isValid() then
		theDate.setDate(31,12,3000);
	endif;
	
	
	create objectSet transient;
	
	dict := self.myTerminal.allBulkReleaseByTypeByStByCd;
	iter := dict.createIterator();
	
	foreach typeToSearch in typesToSearch do : typeLoop
		foreach statusToSearch in statusesToSearch do : statusLoop
			dict.startKeyGeq(typeToSearch, statusToSearch, null, null, iter);
			while iter.next(aBR) do : innerLoop // PAR 22474
			
				iter.getCurrentKeys(typeKey,statusKey,releaseNoKey,tsKey); //MTN-35226
				if typeKey &lt;&gt; typeToSearch then
					continue typeLoop;
				endif;
				
				if statusKey &lt;&gt; statusToSearch then
					continue statusLoop;
				endif;
				if aBR.dateEstimatedRequired.date &gt; theDate then
					continue innerLoop; // PAR 22474
				endif;
				
				objectSet.add(aBR);
			endwhile;
		endforeach;
	endforeach;
	
	self.doSummariseBRs(objectSet);
	return true;
epilog
	delete iter;
	delete statusesToSearch;
	delete typesToSearch;
	delete objectSet;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSearchTIs" id="9948a5f7-4179-4f2a-bc6b-f95c2e82c3a7">
        <source>doSearchTIs();
// ---------------------------------------------------------------------------
// Created:     12 February 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	selectorQuery : CM_MenuUserQuery;
	myEnqController : CM_EnqControllerContainer;
	criteria : CM_QueryCriteriaLineHolder;
	myQDef: CM_QueryDefinition;
begin

	if self.cmbContQuery.listIndex &lt; 1 then
		app.msgBox("Please select a cargo selector query to use", "Cargo Query Error", MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	if self.cmbContSummary.listIndex &lt; 1 then
		app.msgBox("Please select a cargo summary definition to use", "Cargo Query Error", MsgBox_Exclamation_Mark_Icon);
		return;
	endif;

	myQDef :=  self.myQueryDefinition; //cnwrd1 par 25303 4.8.2010
	
	if myQDef = null then //cnwrd1 par 25915 1.10.2010
		//myQDef := app.myRoot.allQueryDefinitionObjects[TI_CargoType_Container,0];
		myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type,TI_CargoType_Container]; //cnwrd1 par 25265 3.8.2010
	endif;

	
	
	
	selectorQuery := self.cmbContQuery.listObject.CM_MenuUserQuery;
	create myEnqController transient;
	create myEnqController.allObjects as CM_ObjectSet transient;	
	
	foreach criteria  in selectorQuery.allCriteriaLineHolders do
		myEnqController.myCriteriaLineHolder := criteria;	
		myEnqController.doQuery(myQDef);
	endforeach;
	self.doSummariseTIs(myEnqController.allObjects.CM_ObjectSet);
	
//	myEnqController.inspectModal;
epilog
	delete myEnqController;
end;</source>
    </JadeMethod>
    <JadeMethod name="doSummariseBRs" id="3ac1d4e0-6ca9-4277-b39a-c59bb7689c63">
        <source>doSummariseBRs(_objs : CM_ObjectSet);
// ---------------------------------------------------------------------------
