    <JadeMethod name="isWagonSelected" id="194f00c5-4d68-4d27-a0be-03adbde2901f">
        <source>isWagonSelected() : Boolean;

/*

Purpose:			True when the wagon has been selected (by clicking on part of the wagon body or wheels)

Parameters:			

Return Value:		


Date		Who		Reason
04 Jun 2009	consw1	Initial creation

*/

vars
	gridPoint : CMUI_GridPoint;
	
begin
	foreach gridPoint in self.allSelectedPoints do
		if gridPoint.isKindOf(YRD_WagonBody) and gridPoint.column = 1 then
			return true;
			break;
		endif;
	endforeach;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
