<Class name="WS_CargoSeal" id="96b53a00-f3fa-422f-a2d7-b5002a976c9d">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <PrimAttribute name="sealNumber" id="a76269b6-4733-438f-ba73-defc9711dc0a">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="sealType" id="7096bf1b-72b9-441c-9bdd-cdbf1d6f3000">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="sealTypeDesc" id="ee4b20f3-316b-4faf-8d42-c3a91d0db322">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="867db5fd-9655-41db-915c-282b1c583d3f">
        <updating/>
        <source>setProxyFromObject(_object: CM_SealTI) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 October 2017	jlger1	Initial creation tfs 7401 webportal

*/

vars
	
begin
	inheritMethod(_object);
	self.sealNumber:= _object.getSealValueAsString;
	self.setSealType(_object.sealType);
epilog

end;</source>
        <Parameter name="_object" type="CM_SealTI"/>
    </JadeMethod>
    <JadeMethod name="setSealType" id="955e578e-a9b8-40a2-a620-695a1a7bbb19">
        <updating/>
        <source>setSealType(_sealType : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 October 2017	jlger1	Initial creation tfs 7401 webportal

*/

vars
	sealTypeObj : CM_SealType;
begin
	self.sealType:=_sealType;
	sealTypeObj:=app.myRoot.allSealTypes[self.sealType];
	if sealTypeObj &lt;&gt; null then
		self.sealTypeDesc:=sealTypeObj.description;
	endif;
epilog

end;</source>
        <Parameter name="_sealType" type="String"/>
    </JadeMethod>
</Class>
