    <JadeMethod name="getObjects" id="5193d724-939b-4f15-8717-23dc12381a81">
        <source>getObjects(objects: ObjectLongNameDict input);
/*
Purpose:			

Date		Who		Reason
27MAY2021	NAVAB1	TFS 51219
*/

vars
	type: CM_EventType;
begin
	foreach type in app.myRoot.allEventTypesByType where type.isInventoryEvent do 
		objects[type.getYAIdentifier] := type;
	endforeach;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
