        <source>trxCreateBGPRequestExtWS(_pxyBGPRequest: BGP_ExternalWSRequest input; 
							_newBGPRequest : BGP_ExternalWSRequest output;
							_passport : CM_Passport input) updating;
/*
20 Jun 2018	jlgrs1	TFS 38630 PIL1 - Perform Credit Check for Auto-Collection Customer
25 Jul 2018 cnwma1	ChangeRequest 39898: PEL1 - SAP and IPN Message On Off
26 Apr 2023 navmp20 Bug 57703: MTN - External Web Service BGP requests are not created unless the terminal has SAP Financials Enabled
11/06/2025	navcs2	MTN-34987  MTN -  Disable SAP Integration
*/
vars
	term 	: CM_Terminal;
	termArr : ObjectArray;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	//cnwma1  TFS 39898 25/7/18
	//if _pxyBGPRequest.myTerminal &lt;&gt; null then
	
	/*
	
	No longer using SAP		11/06/2025	navcs2	MTN-34987  MTN -  Disable SAP Integration
	
	if _pxyBGPRequest.isSAPWSRequest and _pxyBGPRequest.myTerminal &lt;&gt; null then        //26.04.2023 navmp20 TFS 57703
		if not _pxyBGPRequest.myTerminal.isSapFinancialEnabled then
			return;
		endif;
	endif;
	*/

	beginTransaction;

	app.myUtilityCA.utlCreateBGPRequestExtWS(_pxyBGPRequest, _newBGPRequest, _passport);

	if _passport.noErrors then
		app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(_newBGPRequest);
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);
	delete termArr;
end;
</source>
