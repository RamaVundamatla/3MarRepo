    <JadeMethod name="addBOLIn" id="dc4e248d-318d-444b-9e9b-ac424fee0f70">
        <source>addBOLIn(	_bolno			: String;
			_deviceId		: String;	// RTDeviceId
			//_time			: TS; need to be set automatically
			_vehicleId		: String;
			_carrierId		: String;
			_jasSacled		: Boolean;	//true
			_percentagescaled:Integer;	// 100
			_hundredticketed: Boolean;	// true
			_truckNo		: String; 	//can be the same as vehicleId
			_supplier		: String;	// operator
			_species		: String;
			_grade			: String;
			_logtype		: String;
			_treatment		: String;
			_length			: String;
			_noitems		: Integer;		// number of logs
			//_fellingdate	: string;  need to set automatically "20100901"
			//_scalerinitials	: String; 	//CNWVU1. Need to put usercode
			_yardlocation	: String;	//LOGUT,LOGROWFF
			_forest			: String; 	//F1
			_compartment	: String;	//F1-1
			_fsc			: Boolean;	//true
			_loggingorg		: String;	//LJL
			_grossweight	: Decimal;  //0.000
			_tareweight		: Decimal;	//0.000
			_netweight		: Decimal;  //10.000
			_automatch		: Boolean 	//false
		) : CM_BOLIn;
		
//31 August 2010	cnwvu1
// 19/04/2011		cnwmh5	Changed to use profile as it is meant to use Profile UTProfileLogModule.  Previously it was
//							using the user that was running the app, which for the overnight run is now cnwchcs11 which
//							doesn't exists as a user, so will now use the profiles user.

vars
	remoteManager	: CM_RemoteDataManagerExternal;
	xmlSession		: CM_XMLSession;
	struct 			: CnEcXmlStructureInstance;
	parser			: CnEcXmlParser;
	xmlStr			: String;
	//allBolsObj		: CnEcXmlStructureInstanceSet;
	//bolEntry		: CnEcXmlStructureInstance;
	bolIn			: CM_BOLIn;
	tmpStruct		: CnEcXmlStructureInstance;
	userId			: String;
	terminalCode	: String;
	xmlVersion		: String;
	fellingDate		: Date;
	
begin


//check addBOL on upper level
	//self.deleteBOL("UT_MATBOL001");

	xmlStr			:= XML_BolEntryRq;
	if app.userName().toUpper = "CNWER1" then
		userId			:= app.myPassport.myUser.code; 
	else
		//userId := app.userName().toUpper;
		userId := self.testProfile.getSetting(UT_Profile.P_USER).asString;	// 19/04/2011 cnwmh5
	endif;
	if userId = null then		// 19/49/2011 cnwmh5
		userId := 'UNITTEST';
	endif;
		
	terminalCode	:= self.getTerminal().code;
	fellingDate		:= app.actualTimeServer().Date;
	
	create remoteManager transient;
	create xmlSession transient;

	//------------------------------------------------------------------
	//					Creating XML structure
	//------------------------------------------------------------------
	
	create struct as CnEcXmlGroupInstance transient;
	create parser transient;
	parser.parseToMsgStructure(xmlStr, struct);

	//----------------------------------------------------------------------------------------------------------
	//				Setting current parameters into XML data, 
	//				I am not interested in data from XML_BolEntryRq constant - I use it as patern.
	//----------------------------------------------------------------------------------------------------------
	tmpStruct := struct.findStructure(XML_BOLNO);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _bolno, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_VEHICLEID);		tmpStruct.initializeWithTagData(tmpStruct.tagName, _vehicleId, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_CARRIERID);		tmpStruct.initializeWithTagData(tmpStruct.tagName, _carrierId, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_JASSCALED);		tmpStruct.initializeWithTagData(tmpStruct.tagName, _jasSacled.String, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_PERCENTAGESCALED);tmpStruct.initializeWithTagData(tmpStruct.tagName, _percentagescaled.String, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_HUNDREDTICKETED);	tmpStruct.initializeWithTagData(tmpStruct.tagName, _hundredticketed.String, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_TRUCKNO);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _truckNo, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_SUPPLIER);		tmpStruct.initializeWithTagData(tmpStruct.tagName, _supplier, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_SPECIES);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _species, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_GRADE);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _grade, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_LOGTYPE);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _logtype, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_TREATMENT);		tmpStruct.initializeWithTagData(tmpStruct.tagName, _treatment, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_LENGTH);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _length, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_NOITEMS);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _noitems.String, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_FELLINGDATE);		tmpStruct.initializeWithTagData(tmpStruct.tagName, fellingDate.formatAsYYYYMMDD(), tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_SCALERINITIALS);	tmpStruct.initializeWithTagData(tmpStruct.tagName, userId, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_YARDLOCATION);	tmpStruct.initializeWithTagData(tmpStruct.tagName, _yardlocation, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_FOREST);			tmpStruct.initializeWithTagData(tmpStruct.tagName, _forest, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_COMPARTMENT);		tmpStruct.initializeWithTagData(tmpStruct.tagName, _compartment, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_FSC);				tmpStruct.initializeWithTagData(tmpStruct.tagName, _fsc.String, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_LOGGINGORG);		tmpStruct.initializeWithTagData(tmpStruct.tagName, _loggingorg, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_GROSSWEIGHT);		tmpStruct.initializeWithTagData(tmpStruct.tagName, _grossweight.String, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_TAREWEIGHT);		tmpStruct.initializeWithTagData(tmpStruct.tagName, _tareweight.String, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_NETWEIGHT);		tmpStruct.initializeWithTagData(tmpStruct.tagName, _netweight.String, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_AUTOMATCH);		tmpStruct.initializeWithTagData(tmpStruct.tagName, _automatch.String, tmpStruct.tagAttribute);

	
	//------------------------------------------------------------------
	//						setting XML session
	//------------------------------------------------------------------
	//see CM_XMLWorker::DoTheWork()
	tmpStruct := struct.findStructure(XML_DEVICEID);	tmpStruct.initializeWithTagData(tmpStruct.tagName, _deviceId, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_USERID);		tmpStruct.initializeWithTagData(tmpStruct.tagName, userId, tmpStruct.tagAttribute);
	tmpStruct := struct.findStructure(XML_TERMINAL);	tmpStruct.initializeWithTagData(tmpStruct.tagName, terminalCode, tmpStruct.tagAttribute);
	xmlVersion:= struct.findStructure(XML_VERSION).tagData;


	xmlSession.set(userId, _deviceId, terminalCode, xmlVersion, null/*_passwd*/);	
	
	self.assertNotNull(xmlSession.myTerminal);
	self.assertNotNull(xmlSession.myUser);
	self.assertNotNull(xmlSession.myDevice);
	
	
	//------------------------------------------------------------------
	//						creating a BOLIn
	//------------------------------------------------------------------
	
	remoteManager.processExternal(xmlStr, struct, xmlSession);
	self.assertNoTrxErrorsOrWarnings();
	
	if _bolno = UT_LogTests.BOLInNumber_BadNumber and  self.expectedTrxErrorFound then
		return null;		
	endif;
	
	bolIn := self.getBOL(_bolno, BOLType_Log, _supplier).CM_BOLIn;
	
	self.assertNotNull(bolIn);
	
	return bolIn;

epilog
	delete remoteManager;
	delete xmlSession;
	delete struct;
	delete parser;
	
end;</source>
        <Parameter name="_bolno" type="String"/>
        <Parameter name="_deviceId" type="String"/>
        <Parameter name="_vehicleId" type="String"/>
        <Parameter name="_carrierId" type="String"/>
        <Parameter name="_jasSacled" type="Boolean"/>
        <Parameter name="_percentagescaled" type="Integer"/>
        <Parameter name="_hundredticketed" type="Boolean"/>
        <Parameter name="_truckNo" type="String"/>
        <Parameter name="_supplier" type="String"/>
        <Parameter name="_species" type="String"/>
        <Parameter name="_grade" type="String"/>
        <Parameter name="_logtype" type="String"/>
        <Parameter name="_treatment" type="String"/>
        <Parameter name="_length" type="String"/>
        <Parameter name="_noitems" type="Integer"/>
        <Parameter name="_yardlocation" type="String"/>
        <Parameter name="_forest" type="String"/>
        <Parameter name="_compartment" type="String"/>
        <Parameter name="_fsc" type="Boolean"/>
        <Parameter name="_loggingorg" type="String"/>
        <Parameter name="_grossweight" type="Decimal"/>
        <Parameter name="_tareweight" type="Decimal"/>
        <Parameter name="_netweight" type="Decimal"/>
        <Parameter name="_automatch" type="Boolean"/>
        <ReturnType type="CM_BOLIn"/>
    </JadeMethod>
    <JadeMethod name="addLogArea" id="4ac755c1-c0c7-4ab9-8113-08499648d91f">
        <source>addLogArea( _id, _comment	: String
			//_type			: Integer;	TA_TYPE_LOGAREA
			//_length			: Integer;	0
			//_width			: Integer;	0
			//_releasePoint	: Boolean;	 true by default
			//_terminal			: CM_Terminal;	UT
			//_isGapManaged,	false by default
			//_isMarkedUp		: Boolean;	false by default
			//_labels			: String;	null by default
			//_autoRestrictions,	false by default
			//_stockControlled   : Boolean; true by default
			//_hideFromOverView 	: Boolean;	false by default
			//_allInterchangeAreas	:CM_InterchangeAreaArray;	empty by default
			//_defaultInterchangeArea: CM_InterchangeArea) updating;   null by default
			): CM_LogArea;

// 16 September 2010	cnwvu1

vars
	pxyLogArea,
	realLogArea	: CM_LogArea;
	ta			: CM_TerminalAreaMaster;

begin

	create pxyLogArea transient;
	
	pxyLogArea.setProxy(_id, _comment,
						TA_TYPE_LOGAREA,
						0, 	//_length
						0,	//_width
						true,	//_releasePoint
						self.getTerminal(), //_terminal
						false,	//_isGapManaged
						false,	//_isMarkedUp
						null,	//_labels
						false,	//_autoRestrictions
						true,	//_stockControlled
						false,	//_hideFromOverView
						null,	//_allInterchangeAreas
						null	//_defaultInterchangeArea
			);
	
	app.myTrxCA.trxCreateTerminalArea(pxyLogArea, ta, app.myPassport);
	
	self.assertNotNull(ta);
	realLogArea := ta.CM_LogArea;
	
	return realLogArea;
	
epilog
	delete pxyLogArea;
	

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_comment" type="String"/>
        <ReturnType type="CM_LogArea"/>
    </JadeMethod>
