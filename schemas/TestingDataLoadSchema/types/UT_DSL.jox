    <JadeMethod name="unpackContainer" id="15538c49-9d44-40e0-b681-6651299069de">
        <source>unpackContainer(_ti: CM_TrackedItem input; _unpackTIs: CM_TIArray);
//27 November 2008	cnwdw1	
//+cnwml2 MSL CCMS 1017
vars
	packTIs: CM_TIArray;
	moveController: CMIF_MoveController;
	pxyTI, child: CM_TrackedItem;
	lc : CM_LocationsController;
	wh : CM_BlockStack;
	tareWeight,cargoWeight: Decimal[14,4];
	volumeChild : Decimal[16,4];
	deleteSet : CM_TISet;
	
begin
	create deleteSet transient;
	create packTIs transient;
	create moveController transient;
	moveController.isSystemMove := true;
	if _ti.myPrimaryActualLocation &lt;&gt; null then
		wh := _ti.myPrimaryActualLocation.getSwapStack();
		// If terminal area is in different terminal then don't use it
		if wh &lt;&gt; null and wh.myTerminal &lt;&gt; self.getTerminal then
			wh := null;
		endif;
	endif;
	if wh = null then
		wh := self.getTerminal.allTerminalAreas[self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString].CM_BlockStack;
	endif;
	if wh = null then
		wh := self.addBlockStack(self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString, 1000, null);
	endif;
	lc := wh.myLocationsController;
	moveController.setMyToPrimaryLocation(lc);

	pxyTI := app.createUpdateProxy(_ti).CM_TrackedItem;
	// store the proxy children of the proxy parent so we can tidy up the transients later
	foreach child in pxyTI.allChildren do
		deleteSet.add(child);
	endforeach;
	foreach child in _unpackTIs do
		cargoWeight := cargoWeight + child.totalWeight;
		volumeChild	:= volumeChild + child.getMyTotalVolume;	// 25592. Testing volume. 08/11/2010
	endforeach;
	//pxyTI.setWeightCargo(pxyTI.weightCargo - cargoWeight);			// from 32065 testing, take the child cargo weight off
	//18 Oct 2013	NDL	Par 32826
	if pxyTI.weightCargo &gt;= cargoWeight then
		pxyTI.setWeightCargo(pxyTI.weightCargo - cargoWeight);
	else
		pxyTI.setWeightCargo(0);
	endif;
	//pxyTI.setMyCargoVolume(pxyTI.getMyCargoVolume - volumeChild);	// 25592. Testing volume. 08/11/2010
	//18 Oct 2013	NDL	Par 32826
	if pxyTI.getMyCargoVolume &gt;= volumeChild then
		pxyTI.setMyCargoVolume(pxyTI.getMyCargoVolume - volumeChild);
	else
		pxyTI.setMyCargoVolume(0);
	endif;
	tareWeight := pxyTI.weightTare;
	if pxyTI.weightTare = 0 then
		tareWeight := 100;
	endif;
	//pxyTI.setTotalWeight(tareWeight + cargoWeight, null, app.myPassport);		
	pxyTI.setTotalWeight(tareWeight + pxyTI.weightCargo, null, app.myPassport);		
	app.myTrxUA.trxUpdatePackUnpack(moveController, false, packTIs, _unpackTIs, false, pxyTI, app.myPassport);
	checkTrxResult();

epilog
	delete moveController;
	delete packTIs;
	delete pxyTI;
	if deleteSet &lt;&gt; null then
		deleteSet.purge;
	endif;
	delete deleteSet;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_unpackTIs" type="CM_TIArray"/>
    </JadeMethod>
    <JadeMethod name="unplanTI" id="caaf9c99-0d72-4041-ac9a-41eea063cd59">
        <source>unplanTI(_ti: CM_TrackedItem input);
//07 January 2009	cnwdw1	
//
// 21/06/2011 cnwmh5 Update so that it handles rehandles and sob
vars
	moveControl : CMIF_MoveController;
begin
	create moveControl transient;
	while _ti.isPlanned(PLANNING_MODE) do
		if _ti.allPlannedFutureMoves.size = 0 or 
			(_ti.myPrimaryPlannedLocation &lt;&gt; null and not global.isValidObject(_ti.myPrimaryPlannedLocation)) then
			// whoops 
			beginTransaction;
				_ti.setPropertyValue(CM_TrackedItem::myPrimaryPlannedLocation.name, null);
			commitTransaction; 
			break;
		endif;
		
		moveControl.setMoveMode(PLANNING_MODE);
		moveControl.isForcedMove := true;
		moveControl.setMyTrackedItem(_ti);
		moveControl.setMyWorkListEntry(_ti.allWorklistEntries.last);
		if moveControl.myWorkListEntry &lt;&gt; null then
			moveControl.setMoveIndex(_ti.allPlannedFutureMoves.indexOf(moveControl.myWorkListEntry.myFutureMove));
		endif;
		moveControl.isRehandleMove := _ti.isRehandle;
		moveControl.isFullyUnplan := true;
		app.myTrxUA.trxUpdateMoveTIUndo(moveControl, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endwhile;
	if (_ti.myPrimaryPlannedLocation = null and _ti.allPlannedFutureMoves.size &lt;&gt; 0) then
		// whoops 
		beginTransaction;
			_ti.allPlannedFutureMoves.purge();
		commitTransaction;
	endif;

epilog
	delete moveControl;
	abortTransaction;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="unplanVoyageJobs" id="c84cc6e1-b33c-4076-853f-d54b26305a8e">
        <source>unplanVoyageJobs(_jobs : CM_VoyageJobSet input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 December 2008	cnwer1	Initial creation

*/

vars

begin
	app.myTrxUA.trxUpdateVoyageJobsUnplan(_jobs, app.myPassport);	
	self.assertNoTrxErrorsOrWarnings();
epilog

end;</source>
        <Parameter name="_jobs" type="CM_VoyageJobSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="unqueueTI" id="77a0deef-40bf-42a9-bd8c-a38532d43c4c">
        <source>unqueueTI(_ti: CM_TrackedItem input);
//07 January 2009	cnwdw1	
//
vars
	moveControl : CMIF_MoveController;
	queuedFutureMove : CM_FutureMoveQueued;
	futureMove		: CM_FutureMove;
	allFMs			: CM_FutureMoveArray;
	queueEntry: CM_RTQueueEntry;
	index: Integer;
begin
	create moveControl transient;
	create allFMs transient;
	_ti.allQueuedFutureMoves.copy(allFMs);
	//was causing an endless loops trying to unqueue entries with overstow tasks
	foreach index in 1 to allFMs.size reversed do 
		queuedFutureMove:= allFMs[index].CM_FutureMoveQueued;
		if queuedFutureMove.moveType = TI_FutureMoveOverstow then
			foreach queueEntry in queuedFutureMove.allRTQueueEntries do
				self.zapQueueEntry(queueEntry);
			endforeach;
			continue;
		endif;
		moveControl.setMoveMode(QUEUE_MODE);
		moveControl.isForcedMove := true;
		moveControl.setMyTrackedItem(_ti);
		moveControl.setMoveIndex(index);
		moveControl.setMyWorkListEntry(queuedFutureMove.myWorkListEntry);
		app.myTrxUA.trxUpdateMoveTIUndo(moveControl, app.myPassport);
		// Zap any qeue entries that may be stopping the unqueue
		if not app.myPassport.trxCompletedOK() and queuedFutureMove.allRTQueueEntries.size &gt; 0 then
			foreach queueEntry in queuedFutureMove.allRTQueueEntries do
				self.zapQueueEntry(queueEntry);
			endforeach;
			app.myTrxUA.trxUpdateMoveTIUndo(moveControl, app.myPassport);
		endif;
				
		self.assertNoTrxErrorsOrWarnings();
	endforeach;
	
	// Last desperate effort to unqueue the ti
	if _ti.allQueuedFutureMoves.size &gt; 0 then
		beginTransaction;
			_ti.allQueuedFutureMoves.purge;
		commitTransaction;
	endif;
epilog
	delete moveControl;
	delete allFMs;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="unqueueWLE" id="58e6f492-f189-4bd6-abde-d9b38febe16a">
        <source>unqueueWLE(_wle : CM_WorkListEntry);

vars
	wleArray,
	wlesWithWarnings	: CM_WLEArray;
begin
	create wleArray transient;
	create wlesWithWarnings transient;
	wleArray.add(_wle);

	app.myTrxUA.trxUpdateWLEsUnqueue(wleArray, wlesWithWarnings, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK(), app.myPassport.getAllErrorsWarningsAsString());
epilog
	delete wleArray;
	delete wlesWithWarnings;
end;
</source>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="updateAutoSchedule" id="ef983f7e-b7ee-4765-bb69-aa2362195560">
        <source>updateAutoSchedule(_autoSchedule : CM_AutoSchedule);
/*

Purpose:			

Parameters:			

Return Value:		

/* Changes

Date		Name	TFS#	Description
============================================================================
14/04/2014	cnwma1	Initial creation
16/04/2019	jlgka1	43863	Added Recurring value.
============================================================================*/
vars
	pxyAutoSchedule : CM_AutoSchedule;
	runTS			: Time;
begin

	runTS := "11:30".Time;
	beginLoad;
	pxyAutoSchedule := _autoSchedule.pxyCreateUpdateProxy();
	endLoad;
	
	pxyAutoSchedule.setForDate(_autoSchedule.description,
							  "21",
							  runTS,
							  _autoSchedule.recurValue); // jlgka1 TFS 43863
	app.myTrxUA.trxUpdateAutoSchedule(pxyAutoSchedule,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
epilog
	delete pxyAutoSchedule;
end;</source>
        <Parameter name="_autoSchedule" type="CM_AutoSchedule"/>
