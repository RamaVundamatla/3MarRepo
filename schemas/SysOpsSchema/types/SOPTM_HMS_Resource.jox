    <JadeMethod name="setObjectFromTableSpecial" id="017d8ee4-194a-4435-98fd-aaf38642b52c">
        <source>setObjectFromTableSpecial(_attrName: String; _strValue: String; _resource: HMS_Resource input; _tbl: CM_EntryTable input): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Jan 2019 cnwma1	ChangeRequest 41980: PEL1 - SAP Equipment Details
10 Sep 2022 navsj20	ChangeRequest 54739: EUP - PLAN - Berth planning by bollards
*/

vars

begin
	if _attrName = ETRow_ExternalRef1 then
		_resource.setExternalReference1( _strValue );
		return true;
	// START 10 Sep 2022	navsj20	TFS 54739
	elseif _attrName = ETRow_MyBerth then
		_resource.setMyBerth(self.myForm.SOP_HMS_TableMaintForm.cmbMyBerth.listObject.HMS_Berth);
		return true;
	endif;
	// END 10 Sep 2022	navsj20	TFS 54739
	return false;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_strValue" type="String"/>
        <Parameter name="_resource" type="HMS_Resource" usage="input"/>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTableFromObjectSpecial" id="458d9bbc-2264-4280-a0a8-76da91d6c9c6">
        <updating/>
        <source>setTableFromObjectSpecial(_tbl: CM_EntryTable input; _attrName: String; _row: Integer; _obj: Object): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 Jan 2019 cnwma1	ChangeRequest 41980: PEL1 - SAP Equipment Details
04 Oct 2022 navsj20	ChangeRequest 54739: EUP - PLAN - Berth planning by bollards

*/
vars
	resource,pxy : HMS_Resource;
begin
	resource := _obj.HMS_Resource;
	if _attrName = ETRow_ExternalRef1 then
		_tbl.setValue( _row, resource.externalReference1 );	
		return true;
	endif;
	//START 04 Oct 2022	navsj20	TFS 54739
	if _attrName = ETRow_MyBerth then
		if not resource.myResourceType.isBollard then
			_tbl.hideRowByName(ETRow_MyBerth, true);
			return false;
		else
			_tbl.showRowByName(ETRow_MyBerth,true);
		endif;
		_tbl.setValue( _row, resource.myBerth );
		return true;
	endif;
	// END 04 Oct 2022	navsj20	TFS 54739
	return inheritMethod(_tbl, _attrName, _row, _obj);

epilog

end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="51e56d25-51b4-4fdb-aeb0-0ff5f9cb2a14">
        <updating/>
        <source>setupThumbnailDetails() updating;
//--------------------------------------------------
// Created:	09 February 2004 By: cnwgd1
//--------------------------------------------------
vars
	theForm : SOP_HMS_TableMaintForm;
begin
	inheritMethod();  
	
	theForm := self.myForm.SOP_HMS_TableMaintForm;
	theForm.setTblDataEntRows(ETDef_HMSResource);		//cnwdb2 - 17 April 2014 - PAR 33977

	theForm.myAssistant.comboBoxHMSWharf(theForm.cmbWharf, theForm.myHarbour, null);	
//	theForm.setTblDataEntRows(ETDef_HMSResource);
	self.doCmbCalcTypeBuild();
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="211cfba8-112d-496b-8c5e-748676d1c784">
        <updating/>
        <source>showThumbnail(pObj: HMS_Resource) updating;
//--------------------------------------------------------------
//Created: 09 July 2003 By: cnwgd1
//22 Jan 2019 cnwma1	ChangeRequest 41980: PEL1 - SAP Equipment Details
//15 Sep 2022 navsj20	ChangeRequest 54739: EUP - PLAN - Berth planning by bollards
//--------------------------------------------------------------
vars
	theForm : SOP_HMS_TableMaintForm;
begin
  
    theForm := self.myForm.SOP_HMS_TableMaintForm;
	theForm.tblInput1.clearValues;
	theForm.tblInput1.setTableFromObject(pObj, null);	
	theForm.cmbResourceType.setObject(pObj.myResourceType);
	theForm.cmbResourceType.lostFocus(theForm.cmbResourceType);
	theForm.tblInput1.setTableFromObject(pObj, 'setTableFromObjectSpecial');  //22.01.2019 cnwma1 TFS #41980

	theForm.myAssistant.comboBoxHMSWharf(theForm.cmbWharf, pObj.myHarbour, pObj.myWharf);
	theForm.cmbWharf.lostFocus(theForm.cmbWharf);
	// START 15 Sep 2022	navsj20	TFS 54739
	if pObj.myBerth &lt;&gt; null then
		theForm.cmbMyBerth.text := pObj.myBerth.description;
		if theForm.cmbMyBerth.text &lt;&gt; null then
			theForm.cmbMyBerth.listObject := pObj.myBerth;
			theForm.cmbMyBerth.listIndex := theForm.cmbMyBerth.findObject(pObj.myBerth);
		endif;
	endif;
	theForm.cmbMyBerth.lostFocus(theForm.cmbMyBerth);	
	// END 15 Sep 2022	navsj20	TFS 54739
	self.addCurrentCT2Combo(pObj);

	theForm.cmbCalcType.listObject := pObj.myCalculationTypeQuantity;
	theForm.cmbCalcType.lostFocus(theForm.cmbCalcType);
end;</source>
        <Parameter name="pObj" type="HMS_Resource"/>
    </JadeMethod>
</Class>
