    <JadeMethod name="getObjects" id="ff635cad-2348-4e9b-b644-e14d105669d5">
        <source>getObjects(objects: ObjectLongNameDict input);
//05 August 2008	cnwdw1	
// Return a dict of objects for this criteria type
vars
	imex: CM_IMEXStatus;
begin
	foreach imex in app.myRoot.allImexStatuses do
		objects[imex.getYAIdentifier] := imex;
	endforeach;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
