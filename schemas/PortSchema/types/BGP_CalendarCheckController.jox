    <JadeMethod name="initApp" id="ccfa08b1-01d6-44f3-b812-8ada9b5002b5">
        <updating/>
        <source>initApp() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 November 2010	cnwndl1	Initial creation
//03 Jan 2013	cnwrs1	32983 crash after user deleted.

*/

vars
	ls : Boolean;
	str : String;
	errorText : String;
	errorCode : Integer;
	calendar : CM_Calendar;
	calendarMess : String;
	emailStr : String;
	subject : String;
	sender : String;
	emailAdd : CM_EmailAddress2;
	recipient : String;
	body : String;
	msg : String;
begin
	on Exception do self.xHandlerGlobal(exception) global;
	on LockException do app.alertLockExceptionHandler(exception) global;
	str := self.getOidString();
	str.replaceChar('.' , '_');
	app.logFileNameSpecific := 'BGPController_' &amp; self.logFileName() &amp; '_' &amp; str; 
	
	app.setCnAppAlias(self.class.name);		 //epr TFS 36655 29/4/19
	
	app.initialize();

	app.setIsBackGroundApp(true);
 	app.cmsBeginLoad(ls);
	exclusiveLock(self);
	if self.isRunning() then
		app.isBGPAppAbort := true;
		msg := 'ERR &gt;&gt; app is already running';
		app.writeLog(msg, LogFATAL);	//25 Nov 2019	NDL	TFS 47053
		app.exitLogFile();
		terminate;
	endif;
	
	if app.myPassport &lt;&gt; null then
 		app.myPassport.setMyUser(self.myUser);
  	endif;
	app.myTrxUA.trxUpdateBGPControllerProcess(self, process, process.signOnTime, true, app.myPassport);
	self.beginNotification(self, BGP_Object.BGP_TerminateAppRequest, Response_Cancel , null);
	self.beginNotification(self, BGP_Object.BGP_DebugLevelChangeEvent, Response_Continuous , null);
	self.beginNotification(self, BGP_Object.BGP_OutputInfo, Response_Continuous , null);
	self.beginNotification(self, BGP_Object.BGP_ApplicationStartRequest, Response_Continuous , null);

	foreach calendar in app.myRoot.allCalendars discreteLock do
		calendarMess := calendar.getCalendarNoDatesMessage( self.numDaysNotice );
		if calendarMess = null then
			continue;
		endif;
		if emailStr = null then
			emailStr := calendarMess;
		else
			emailStr := emailStr &amp; CrLf &amp; calendarMess;
		endif;
	endforeach;

	if emailStr &lt;&gt; null then
	
		calendarMess := app.getErrorString(Calendars_require_dates_added);
		emailStr := calendarMess &amp; CrLf &amp; emailStr;
		calendarMess := app.getErrorString(Automated_message_from_jmt);
		emailStr := calendarMess &amp; CrLf &amp; emailStr;
		
		subject := app.getErrorString(JMT_calendar_dates);
		sender := app.myRoot.getConfig(AutoSendersEmailAddress).String;
		body := emailStr;
		foreach emailAdd in self.allSelectedEmailAddresses do
			if recipient = null then
				recipient := emailAdd.emailAddress;
			else
				recipient := recipient &amp; ";" &amp; emailAdd.emailAddress;
			endif;
		endforeach;
	
		app.myTrxCA.trxCreateEmailSendRequest(	self.name,	//_alertDescription,
												recipient,	//_toAddress,
												sender,	//_fromAddress,
												null,	//_ccAddresses,
												null,	//_bccAddresses,
												subject,	//_sendSubject,
												body,	//_sendMessage			: String;
												null,	//_allAttachedFilePaths	: HugeStringArray;
												null,	//_allFileData			: CM_FileDataStorageHdrSet input;
												null,	//_blob					: Binary;
												null,	//_blobFileName			: String;
												EmailSource_System,	//_sourceOfEmail			: Integer;
												null,	//_updateCallbackObj		: Object;
												app.myPassport	//_passport				: CM_Passport input
												);
															 
		if not app.myPassport.trxCompletedOK then
			msg := app.getErrorString1(Email_Send_Failure, subject);
			app.writeLog(msg, LogINFO);	//25 Nov 2019	NDL	TFS 47053
			app.remoteErrorWarningToAlert(app.getErrorString1(Email_Send_Failure, subject), null,  app.myPassport.allErrors, null, false, true);
		endif;
		
	endif;
	
epilog
	app.cmsEndLoad(ls);
	// we've finished now, so just do a finish to tidy ourselves up and stop
	//self.finish();	06 Aug 2013	NDL	Par 32077 - Removed line 
end;</source>
    </JadeMethod>
    <JadeMethod name="setAttributesForCreate" id="0786e3a3-e964-4953-86c2-c1f88e64020b">
        <updating/>
        <source>setAttributesForCreate() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 November 2010	cnwndl1	Initial creation

*/

vars

begin

	self.name				:= 'Calendar Check';
	self.schemaName			:= 'UiCommonSchema';
	self.isEditable			:= true;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setCMIF" id="7f38317b-12d9-4407-9838-585b93bc593c">
        <source>setCMIF(_cmif: CMIF_BGPManagerChildren input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 November 2010	cnwndl1	Initial creation

*/

vars

begin

	inheritMethod(_cmif);
	
	_cmif.numDaysNotice := self.numDaysNotice;
	_cmif.allSelectedEmailAddresses.clear();
	self.allSelectedEmailAddresses.copy( _cmif.allSelectedEmailAddresses );

epilog

end;</source>
        <Parameter name="_cmif" type="CMIF_BGPManagerChildren" usage="input"/>
    </JadeMethod>
