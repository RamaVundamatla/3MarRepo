    <JadeMethod name="lstTblWOType_displayRow" id="07a35f68-267d-471a-a5b2-cf0211fd32e7">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstTblWOType_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 Aug 2023 navhl20 ChangeRequest 58568: EUP - Delivery Dispatch – Reporting

*/

vars
	selected	: Boolean;
begin
	selected := table.CMUI_ListTable.allSelectedObjects.includes(obj);
	return self.myReportAgent.displayTIState(obj.CM_String, selected);
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
