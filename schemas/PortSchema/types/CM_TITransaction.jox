    <JadeMethod name="savePreviousVersion" id="47b0fdc9-6b26-4e86-a95b-126cf768c7a3">
        <updating/>
        <source>savePreviousVersion() updating;
/*
 ------------------------------------------------------------------------
Created:			13 September 2002 by cnwdwq1
Purpose:			Converted from C++ CM_Trans_savePreviousVersion.
							I'm not proud of this but it will do in the short term. Its exactly how the original worked
							and thats NOT NICE.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	clone : CM_TITransaction;
begin
	//--------------------------------------------------
	// Replicate the existing transaction and
	// add into the previous versions collection
	//--------------------------------------------------
	clone := self.cloneSelf(false);
	// Tell transaction its now OLD - need to do before
	// setting refs so updates conditional dicts correctly
	clone.superseded := true;

	self.saveVersionCopyRefs(clone);

	if self.previousVersions = null then
		create self.previousVersions;
	endif;

	//Add to coll.
	self.previousVersions.insert(1, clone);

end;</source>
    </JadeMethod>
    <JadeMethod name="saveVersionCopyRefs" id="1567dbe2-2828-4fdd-a57f-75b23ca45e74">
        <source>saveVersionCopyRefs(toClone : CM_TITransaction input) protected;
/*
 ------------------------------------------------------------------------
Created:			13 September 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	ti				: CM_TrackedItem;
begin
	if toClone = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'Transaction ToClone',null, null);
		return;
	endif;
	//cnwth2 - inc orderNo to avoid dup key
	ti := self.myTrackedItem;
	while ti.allTransactions.includesKey(toClone.dateTime, toClone.orderNo) do
		// need to update orderNo
		toClone.orderNo := toClone.orderNo + 1;
	endwhile;
	
	toClone.myTrackedItem 	 := self.myTrackedItem;
	toClone.myTerminal		 := self.myTerminal;
	
end;</source>
        <access>protected</access>
        <Parameter name="toClone" type="CM_TITransaction" usage="input"/>
    </JadeMethod>
