    <JadeMethod name="hScrollAmount" id="d5a43065-703c-4bd5-b96b-d7a4371a24d7">
        <methodInvocation>mapping</methodInvocation>
        <source>hScrollAmount(set: Boolean; _value: Real io) protected, mapping;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2010	cnwjk3	Initial creation
12 Jul 2010 cnwer1	PAR 24901 - Rail Rakes locations are in 10ft slots so make scrolling bigger
							  - also at smalled scalefactor can afford to make bigger scoll changes
*/

vars

	theGridWidth : Real;
begin

	theGridWidth :=self.getGridWidth();
	
	if self.myDisplayBuilder &lt;&gt; null and 
		self.myDisplayBuilder.isKindOf(CMIF_RDTRailDisplayBuilder) then
		theGridWidth:=theGridWidth * 2;
	endif;
	
	if self.scaleFactor &lt;= 0.5 then
		theGridWidth:=theGridWidth * 2;
	endif;
	
	if set then
		// set code here
	else
		// get code here
		_value := self.hScrollFactor * theGridWidth;
	endif;


epilog

end;</source>
        <access>protected</access>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="hideSelectedLocationHighlight" id="c9f7a7f3-04e5-41a0-911d-ecb3f9772ad6">
        <source>hideSelectedLocationHighlight();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 April 2010	cnwjk3	Initial creation

*/

vars
	picture	: Picture;
begin
	// top
	picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicTopBar();
	picture.top := -1000;
	picture.visible := false;

	// bottom
	picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicBottomBar();
	picture.top := -1000;
	picture.visible := false;

	// left
	picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicLeftBar();
	picture.top := -1000;
	picture.visible := false;
	
	// Right
	picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicRightBar();
	picture.top := -1000;
	picture.visible := false;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="highlightLocation" id="4883ccbf-f0de-4c18-9c19-bdc3a71f34a5">
        <source>highlightLocation( _x1, _y1, _x2, _y2 : Real) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 April 2010	cnwjk3	Initial creation

*/

vars
	picture			: Picture;
	
begin

	picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicHBar();

	// top
	self.myTIFrame.drawPictureIn(picture.picture, _x1, _y1, _x2, _y1 + 4);
	
	// bottom
	self.myTIFrame.drawPictureIn(picture.picture, _x1, _y2-4, _x2, _y2);

	picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicVBar();

	// left
	self.myTIFrame.drawPictureIn(picture.picture, _x1, _y1, _x1+4, _y2);
	
	// right
	self.myTIFrame.drawPictureIn(picture.picture, _x2-4, _y1, _x2, _y2);
		
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="highlightSelectedLocation" id="67a992d1-257e-4d40-a296-e5ac0613bb9b">
        <source>highlightSelectedLocation( _x1, _y1, _x2, _y2 : Real; _ti : CM_TrackedItem ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 April 2010	cnwjk3	Initial creation

*/

vars
	lx1, lx2,
	ly1, ly2		: Real;
	operator 		: CM_Operator;
	tiColour,
	highlightColour,
	oldDrawStyle,
	oldDrawWidth    : Integer;
	picture			: Picture;
begin
	lx1 := _x1;
	lx2 := _x2;
	ly1 := _y1;
	ly2 := _y2;
	
	if _ti &lt;&gt; null then 
	
		operator := app.myRoot.allOperators[_ti.operatorCode];
		if operator &lt;&gt; null then
			tiColour := operator.colour;
			highlightColour := tiColour.getInverseColour();
		else
			highlightColour := Black;
		endif;
		
		// Adjust the selector size to matc the TI. Can only really do this
		// if this is the primary location
		if self.isLandscape and not self.drawMode = CMIF_RDTDrawElement.MODE_END then
			if self.flipH then
				lx1 := lx2 - self.getLengthOfTIInPixels(_ti);
			else
				lx2 := lx1 + self.getLengthOfTIInPixels(_ti);
			endif;
		elseif not self.drawMode = CMIF_RDTDrawElement.MODE_END then
			if self.flipV then
				ly1 := ly2 - self.getLengthOfTIInPixels(_ti);
			else
				ly2 := ly1 + self.getLengthOfTIInPixels(_ti);
			endif;
		endif;

	else
		highlightColour := Black;
	endif;

	oldDrawWidth := self.myTIFrame.drawWidth;
	oldDrawStyle := self.myTIFrame.drawStyle;
	
	self.myTIFrame.autoRedraw := true;
	self.myTIFrame.drawWidth := 4;
	
	// top
	picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicTopBar();
	picture.width := lx2 - lx1;
	picture.height := 4;
	picture.left := lx1;
	picture.top := ly1;
	
	// bottom
	picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicBottomBar();
	picture.width := lx2 - lx1;
	picture.height := 4;
	picture.left := lx1;
	picture.top := ly2 - picture.height;

	// left
	picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicLeftBar();
	picture.width := 4;
	picture.height := ly2 - ly1;
	picture.left := lx1;
	picture.top := ly1;
	
	// Right
	picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicRightBar();
	picture.width := 4;
	picture.height := ly2 - ly1;
	picture.left := lx2 - picture.width;
	picture.top := ly1;
		
	self.showSelectedlocationHighlight();
	
	self.myTIFrame.drawWidth := oldDrawWidth;
	self.myTIFrame.drawStyle := oldDrawStyle;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="init" id="629c7ae9-8613-4381-bd5a-78a67670eb2c">
        <updating/>
        <source>init(_mode : Integer; _drawingFrame, _tiFrame, _viewportFrame : Frame; _zoomFactor : Real) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 April 2010	cnwjk3	Initial creation
20 September 2010 cnwjo3 par 25640
*/

vars

begin
	
	// The viewport frame will have a parent aspect of stretch both, so will always be the right size
	// The drawing and TI frames will be children of the viewport frame and will be larger to allow items
	// to be drawn outside of the viewport.  This helps with scrolling items into view, which span more than
	// one grid square.   The drawing and TI frames need to adjust in size when the zoom level changes. 
	
	self.myViewportFrame := _viewportFrame;
	

	self.myDrawingFrame := _drawingFrame;
	self.myTIFrame := _tiFrame;
	self.myDrawingFrame.autoRedraw := true;
	self.myTIFrame.autoRedraw := true;
	self.resizeTIFrame();
	
	// PAR 25509 - set zoom factor from saved settings (CNWRS2 24 Aug 2010)
	if _zoomFactor = 0 then
		self.scaleFactor := 0.75;
	else
		self.scaleFactor := _zoomFactor;
	endif;
	
	self.flipH := false;
	self.flipV := false;
	//self.isLandscape := false;
	//25 July 2014	NDL	Par 33828
	if self.myRTVehicleConfig &lt;&gt; null and self.myRTVehicleConfig.myMachine &lt;&gt; null and self.myRTVehicleConfig.myMachine.machineType = MACHINETYPE_STRADDLE then
		self.isLandscape := false;
	else
		self.isLandscape := true;
	endif;
	self.isInitialised := true;
	self.showGrid := false;
	self.showGuideLines := false;
	self.isFancyGFX := true;
	self.drawMode := _mode;
	
	self.resizeDrawingFrames();
epilog
	
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_drawingFrame" type="Frame"/>
        <Parameter name="_tiFrame" type="Frame"/>
        <Parameter name="_viewportFrame" type="Frame"/>
        <Parameter name="_zoomFactor" type="Real"/>
    </JadeMethod>
