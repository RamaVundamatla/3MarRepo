    <JadeMethod name="setupThumbnailDetails" id="c6f8ed78-e84a-4707-9bca-6b48d5d2024d">
        <updating/>
        <source>setupThumbnailDetails() updating;

vars
	theForm 	: 	SOP_TableMaintForm;
	def			: 	EntTableDef;
	theWidth	: 	Integer;
	table 		:	CM_DataTable;
begin
  
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	table := theForm.tblData4;
	theForm.setTblDataEntRows(ETDef_CarrierMaintTbl);
	//theForm.zAddColumn('Carrier Id', 'code', Table.InputType_None, 30);
	//theForm.zAddColumn('Description', 'description', Table.InputType_None, 70);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Description, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_CarrierMaint);
	theForm.tblInput1.hideRowByName(ETRow_Vehicles, false);
	theForm.shtTblInput1.visible := true;

	theForm.tblView1.visible := false;
	table.visible := true;
			
	def := app.myController.getEntTableDef(ETDef_VehicleTbl);
	table.setColumnHeadingsFromDef(def.name, false);
	table.zAddSortColumn(def.name, true);
	table.selectMode := CM_DataTable.SelectMode_None;
  
	theForm.txtName.visible := true;
	theForm.btnAddNew.visible := true;
	
	self.colourColumn := theForm.tblData.getColumnByRowName(ETRow_Colour);	// 12/6/17 MAP TFS4209

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="73418efa-eaf8-4784-83c1-7c9473f3aaa5">
        <updating/>
        <source>showThumbnail(pCarrier : CM_Carrier) updating;

//28/08/2018	JLGNS1	Bug 40008: PEN - Restrict Operator Issue
//12/05/2022 	navhl20 TFS 53430  EUP - Sub Carrier registration in MTN

vars

	theForm : SOP_TableMaintForm;
	vehicle:CM_Vehicle;
	first:Boolean;
	list:String;	
	dac: CM_DataAccessController;
begin
  
    theForm := self.myForm;
	theForm.tblInput1.clearValues;
	theForm.shtMultiSelect1.caption := 'PIN Advice Email Addresses (' &amp;pCarrier.allPINNotifyEmailAddresses.size.String &amp; ')';
	theForm.shtViewTable1.caption := 'Vehicles (' &amp; pCarrier.vehicles.size.String &amp; ')';

	theForm.tblInput1.setValueByName(ETRow_Code, pCarrier.code);
    theForm.tblInput1.setValueByName(ETRow_Description,	pCarrier.description);
    theForm.tblInput1.setValueByName(ETRow_IsNotAvailableForEntry, pCarrier.isNotAvailableForEntry);
	theForm.tblInput1.setValueByName(ETRow_IsRail, pCarrier.isRail);		//+ cnwmd1, CCMS 1067, Par 19710
	theForm.tblInput1.setValueByName(ETRow_IsRoad, pCarrier.isRoad);		//+ cnwmd1, CCMS 1067, Par 19710
	theForm.tblInput1.setValueByName(ETRow_IsSubCarrier, pCarrier.isSubCarrier);   	//12/05/2022 navhl20 TFS 53430
	theForm.tblInput1.setValueByName(ETRow_Colour, pCarrier.colour.String);		// 12/6/17 MAP TFS4209
	
	if pCarrier.myDebtor &lt;&gt; null then 	//+ cnwmd1, CCMS 1067
		theForm.tblInput1.setValueByName(ETRow_MyDebtor,pCarrier.myDebtor.name);
		theForm.tblInput1.setValueByName(ETRow_FinancialId, pCarrier.myDebtor.code);	//04.Mar.24 navsp1 TFS 57177
    endif;
   	theForm.cmbDebtor.setObject(pCarrier.myDebtor);

//	theForm.mulSelect1.setAvailable(pCarrier.vehicles, true);
	theForm.mulSelect1.setSelected(pCarrier.allPINNotifyEmailAddresses);
	
	dac := pCarrier.getFirstDACRel();
	if dac &lt;&gt; null then
		theForm.tblInput1.setValueByName(ETRow_OpDAForRelease, dac.name);
	endif;
	theForm.cmbDAOperatorRel.setObject(dac);

	dac := pCarrier.getFirstDACRec();
	if dac &lt;&gt; null then
		theForm.tblInput1.setValueByName(ETRow_OpDAForReceive, dac.name);
	endif;
	theForm.cmbDAOperatorRec.setObject(dac);
	
	self.showVehicleTblData(pCarrier);
		
end;</source>
        <Parameter name="pCarrier" type="CM_Carrier"/>
    </JadeMethod>
    <JadeMethod name="showVehicleTblData" id="199cdfad-bdd2-455e-9fc7-4bba459f210f">
        <source>showVehicleTblData(pCarrier : CM_Carrier);
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 06 October 2003
//
//-----------------------------------------------------------------------

vars
	table		: CM_DataTable;
	def			: EntTableDef;
	theWidth	: Integer;
	theForm		: SOP_TableMaintForm;
	vehicle		: CM_Vehicle;
begin
	table := self.myForm.tblData4;
	table.enabled := true;	
	table.clearAllData();
	
	foreach vehicle in pCarrier.vehicles do
		table.addItemObject(vehicle, vehicle.regNumber &amp; Tab &amp; vehicle.carrierCode &amp; Tab &amp; vehicle.myTerminal.code);
	endforeach;
	self.sortVehicleData(table, 1);
	//table.fitColumnWidths();
end;</source>
        <Parameter name="pCarrier" type="CM_Carrier"/>
    </JadeMethod>
    <JadeMethod name="sortVehicleData" id="37ebe330-203a-4318-94ec-dca279719dc3">
        <source>sortVehicleData(_table : CM_DataTable; _row : Integer);
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 07 October 2003
//
//-----------------------------------------------------------------------

vars

begin
	if _row = null then
		_table.sortColumn[1] := 1;    
	else
		_table.sortColumn[1] := _row;
	endif;
	_table.sortAsc[1]    := true;
	_table.sortCased[1]  := false;
	
	_table.resort;
end;</source>
        <Parameter name="_table" type="CM_DataTable"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblDataShowDataSpecial" id="029a78e9-f4fc-4cd6-b248-a415583aa1d0">
        <source>tblDataShowDataSpecial(_idxRow: Integer; _obj: Object);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 June 2017	cnwmp6	Initial creation	TFS4209

*/

vars
	carrier: CM_Carrier;
	cell : JadeTableCell;
begin

	carrier := _obj.CM_Carrier;
	if _idxRow &lt;&gt; 1 then
		if self.colourColumn &gt; 0 then
			cell := myForm.tblData.accessCell(_idxRow, self.colourColumn);
			cell.text := null;
			cell.backColor := carrier.colour;
		endif;
	endif;	

end;</source>
        <Parameter name="_idxRow" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="tblView1DisplayRow" id="d8c92961-93d6-425f-9932-6dba77f0353a">
