    <JadeMethod name="clearWagonClassFields" id="6387a827-314b-417b-ac6e-9753f77e63a6">
        <updating/>
        <source>clearWagonClassFields() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 June 2009	cnwndl1	Initial creation
11 Sep 2013	NDL	Par 32172

*/

vars

begin
	txt10FootUnits.text := null;
	lbl20FootPos.caption := null;
	
	txtCode.text := null;
	chkEntry.value := false;
	chkGenrator.value := false; 
	chkDoors.value := false; 
	setLocationIdsText( null, null );
	txtStack.text := null;
	tblMaxCWeight.text := null;
	tblTare.text := null;
	setTotalWeight();
	tblMaxCHeight.text := null;
	tblDeckHeight.text := null;
	setTotalHeight();
	self.myAssistant.comboBoxCarrier(self.cmbCarrier, null);
	
	loadTableWagonPos( null );
	loadTableWagonWells();
	
	self.tblOHeight.text := null;
	self.tblOLength.text := null;
	self.tblOWidth.text := null;
	self.cmbWagonType.listIndex := -1;
	
epilog

end;</source>
    </JadeMethod>
