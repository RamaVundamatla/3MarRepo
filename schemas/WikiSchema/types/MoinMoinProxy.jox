<Class name="MoinMoinProxy" id="7e098926-f4b9-4039-9357-7b4df24103d1">
    <superclass name="Object"/>
    <transient/>
    <final/>
    <sharedTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="wiki"/>
    <PrimAttribute name="authToken" id="c639282c-2087-43f8-b4e4-d7a756c9f763">
        <length>129</length>
        <embedded/>
        <type name="String"/>
        <access>protected</access>
    </PrimAttribute>
    <PrimAttribute name="serverURL" id="8b69c7cb-8b96-4631-a1b3-93e59259ffca">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>protected</access>
    </PrimAttribute>
    <JadeMethod name="deleteAuthToken" id="0bf700be-f536-4c84-92f3-7188373332d8">
        <updating/>
        <source>deleteAuthToken( errormsg: String io ) : Boolean updating;

vars
	xmlDocument		: JadeXMLDocument ;
	rootElement		: JadeXMLElement ;
	methodElement	: JadeXMLElement ;
	paramsElement   : JadeXMLElement ;
	paramElement    : JadeXMLElement ;
	valueElement    : JadeXMLElement ;
	stringElement   : JadeXMLElement ;
   	tokenDocument	: JadeXMLDocument ;

    http      : JadeHTTPConnection; //use unpublished class
    cmd       : String;
    parms     : String;
    result    : String[256];
    response  : String; 
    headers   : String;
    
    pos : Integer;
    len : Integer;
begin
    // Create XMLRPC request for deleting an authentication token
    create xmlDocument transient ;
	rootElement	:= xmlDocument.addElement( 'methodCall' );
    methodElement := rootElement.addElement( 'methodName' );
    methodElement.addText( 'deleteAuthToken' );
    paramsElement := rootElement.addElement( 'params' );
    paramElement := paramsElement.addElement( 'param' );
    valueElement := paramElement.addElement( 'value' );
    stringElement := valueElement.addElement( 'string' );
    stringElement.addText( self.authToken );
     
    // BEGIN HTTP stuff
    parms := xmlDocument.writeToString ;
    headers := null;
    cmd := '?action=xmlrpc2';
	
    // create a transient instance of the JadeHTTPCOnnection class and
	// call getHttpPage. Note that the server name (2nd parameter) must
	// include the scheme (in this case https).
    create http transient;
	response := http.getHttpPage('POST', 'https://' &amp; serverURL &amp; '/', cmd, parms, '');
	// A null response implies the call has failed.
	if response &lt;&gt; null then
        
      // Parse the response
      pos := response.pos('&lt;',1); // strip off leading number
      len := response.length;
      response := response[pos:len];   

      create tokenDocument transient;
      tokenDocument.parseString( response );
      methodElement := tokenDocument.findElementByTagName( 'methodResponse' );
      paramsElement := methodElement.getElementByTagName( 'params' );
      paramElement := paramsElement.getElementByTagName( 'param' );
      valueElement := paramElement.getElementByTagName( 'value' );
      stringElement := valueElement.getElementByTagName( 'string' );
      response := stringElement.text;
     
      return "SUCCESS".compareEql(response, true, false, null);   
    else
        errormsg := "Unable to connect to MoinMoin server.";
        return false;
    endif;	 
epilog
    delete tokenDocument;
    delete xmlDocument;    
    delete http;
end;
</source>
        <Parameter name="errormsg" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAttachment" id="16275daa-4b7a-4b48-b494-9a6f6b4147c7">
        <updating/>
        <source>getAttachment( pageName, attachmentName: String; attachmentContent, errormsg: String io ): Boolean updating;

vars
    fileName     : String ;
    fileBinary   : Binary ;
    pos : Integer;
    len : Integer;  
    base64String : String;
    
	xmlDocument		: JadeXMLDocument ;
	rootElement		: JadeXMLElement ;
	methodElement	: JadeXMLElement ;
	paramsElement   : JadeXMLElement ;
	paramElement    : JadeXMLElement ;
	valueElement    : JadeXMLElement ;
	arrayElement    : JadeXMLElement ;
	dataElement     : JadeXMLElement ;
	dataElement2    : JadeXMLElement ;
	structElement   : JadeXMLElement ;
	memberElement   : JadeXMLElement ;
	nameElement     : JadeXMLElement ;
	stringElement   : JadeXMLElement ;
    base64Element   : JadeXMLElement ;
   	tokenDocument	: JadeXMLDocument ;
	faultElement    : JadeXMLElement ;
    resultXML       : String;
    success         : Boolean;
    hasFault        : Boolean;
    values          : JadeXMLElementArray;

    http      : JadeHTTPConnection; //use unpublished class
    cmd       : String;
    parms     : String;
    result    : String[256];
    headers   : String;
    response  : String;  
    
begin  
    // Create XMLRPC request for requesting an attachment
    create xmlDocument transient ;
	rootElement	:= xmlDocument.addElement( 'methodCall' );
    methodElement := rootElement.addElement( 'methodName' );
    methodElement.addText( 'system.multicall' );
    paramsElement := rootElement.addElement( 'params' );
    paramElement := paramsElement.addElement( 'param' );
    valueElement := paramElement.addElement( 'value' );
    arrayElement := valueElement.addElement( 'array' );
    dataElement := arrayElement.addElement( 'data' );
    valueElement := dataElement.addElement( 'value' );
    structElement := valueElement.addElement( 'struct' );
    memberElement := structElement.addElement( 'member' );
    nameElement := memberElement.addElement( 'name' );
    nameElement.addText( 'params' );
    valueElement := memberElement.addElement( 'value' );
    arrayElement := valueElement.addElement( 'array' );
    dataElement2 := arrayElement.addElement( 'data' );
    valueElement := dataElement2.addElement( 'value' );
    stringElement := valueElement.addElement( 'string' );
    stringElement.addText( authToken );
    memberElement := structElement.addElement( 'member' );
    nameElement := memberElement.addElement( 'name' );
    nameElement.addText( 'methodName' );
    valueElement := memberElement.addElement( 'value' );
    stringElement := valueElement.addElement( 'string' );
    stringElement.addText( 'applyAuthToken' );
    valueElement := dataElement.addElement( 'value' );
    structElement := valueElement.addElement( 'struct' );
    memberElement := structElement.addElement( 'member' );
    nameElement := memberElement.addElement( 'name' );
    nameElement.addText( 'params' );
    valueElement := memberElement.addElement( 'value' );
    arrayElement := valueElement.addElement( 'array' );
    dataElement := arrayElement.addElement( 'data' );
    valueElement := dataElement.addElement( 'value' );
    stringElement := valueElement.addElement( 'string' );
    stringElement.addText( pageName.trimBlanks );
    valueElement := dataElement.addElement( 'value' );
    stringElement := valueElement.addElement( 'string' );
    stringElement.addText( attachmentName.trimBlanks );
    memberElement := structElement.addElement( 'member' );
    nameElement := memberElement.addElement( 'name' );
    nameElement.addText( 'methodName' );
    valueElement := memberElement.addElement( 'value' );
    stringElement := valueElement.addElement( 'string' );
    stringElement.addText( 'getAttachment' );

    // BEGIN HTTP stuff
    parms := xmlDocument.writeToString ;
    headers := null;
    cmd := '?action=xmlrpc2';
    
	// create a transient instance of the JadeHTTPCOnnection class and
	// call getHttpPage. Note that the server name (2nd parameter) must
	// include the scheme (in this case https).
    create http transient;
	response := http.getHttpPage('POST', 'https://' &amp; serverURL &amp; '/', cmd, parms, '');
	// A null response implies the call has failed.
	if response &lt;&gt; null then
      // Parse the response
      pos := response.pos('&lt;',1); // strip off leading number
      len := response.length;
      response := response[pos:len];

      create tokenDocument transient;
      tokenDocument.parseString( response );
      methodElement := tokenDocument.findElementByTagName( 'methodResponse' );   

      //Look for SUCCESS and warning messages ( "faultString" )
      resultXML := methodElement.writeToString;
      success := resultXML.cnContains('SUCCESS');
      hasFault := resultXML.cnContains('faultString');
      if hasFault then
        faultElement := tokenDocument.findElementByTagName( 'faultString' );   
        pos := resultXML.pos('faultString',1);
        len := resultXML.length;
        errormsg := resultXML[pos:len];
        success := false;
      endif;
      if success then   
        // Parse out the attachment content
        paramsElement := methodElement.getElementByTagName( 'params' );
        paramElement := paramsElement.getElementByTagName( 'param' );
        valueElement := paramElement.getElementByTagName( 'value' );
        arrayElement := valueElement.getElementByTagName( 'array' );
        dataElement := arrayElement.getElementByTagName( 'data' );
        create values transient;
        dataElement.getElementsByTagName( 'value', values );
        valueElement := values[2]; // The first is &lt;... SUCCESS ...&gt;
        arrayElement := valueElement.getElementByTagName( 'array' );
        dataElement := arrayElement.getElementByTagName( 'data' );
        valueElement := dataElement.getElementByTagName( 'value' );
        base64Element := valueElement.getElementByTagName( 'base64' );
        base64String := base64Element.text;
        base64String := base64String.trimWhiteSpace;

        fileBinary := base64String.base64Decode();    
        attachmentContent := fileBinary.String;
      endif;
      
    else
        errormsg := "Unable to connect to MoinMoin server.";
        success := false;
    endif;

    return success;
epilog
    delete values;        
    delete tokenDocument;
    delete xmlDocument;
    delete http;
end;

</source>
        <Parameter name="pageName" type="String"/>
        <Parameter name="attachmentName" type="String"/>
        <Parameter name="attachmentContent" type="String" usage="io"/>
        <Parameter name="errormsg" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAuthToken" id="ab913376-3e50-41f6-8ced-2584b8f52d4f">
        <updating/>
        <source>getAuthToken( url, userName, password : String; errormsg: String io ): Boolean updating;

vars
    // CALL THIS METHOD FIRST
	xmlDocument		: JadeXMLDocument ;
	rootElement		: JadeXMLElement ;
	methodElement	: JadeXMLElement ;
	paramsElement   : JadeXMLElement ;
	paramElement    : JadeXMLElement ;
	valueElement    : JadeXMLElement ;
	stringElement   : JadeXMLElement ;
   	tokenDocument	: JadeXMLDocument ;

    http      : JadeHTTPConnection; //use unpublished class
    cmd       : String;
    parms     : String;
    result    : String[256];
    token     : String; 
    headers   : String;
    
    pos : Integer;
    len : Integer;
begin
    // Create XMLRPC request for getting an authentication token
    self.serverURL := url;
    create xmlDocument transient ;
	rootElement	:= xmlDocument.addElement( 'methodCall' );
    methodElement := rootElement.addElement( 'methodName' );
    methodElement.addText( 'getAuthToken' );
    paramsElement := rootElement.addElement( 'params' );
    paramElement := paramsElement.addElement( 'param' );
    valueElement := paramElement.addElement( 'value' );
    stringElement := valueElement.addElement( 'string' );
    stringElement.addText( userName.trimBlanks );
    paramElement := paramsElement.addElement( 'param' );
    valueElement := paramElement.addElement( 'value' );
    stringElement := valueElement.addElement( 'string' );
    stringElement.addText( password.trimBlanks );
     
    // BEGIN HTTP stuff
    parms := xmlDocument.writeToString ;
    headers := null;
    cmd := '?action=xmlrpc2';

	// create a transient instance of the JadeHTTPCOnnection class and
	// call getHttpPage. Note that the server name (2nd parameter) must
	// include the scheme (in this case https).
    create http transient;
	token := http.getHttpPage('POST', 'https://' &amp; serverURL &amp; '/', cmd, parms, '');
	// A null token implies the call has failed.
	if token &lt;&gt; null then
      // Parse the response
      pos := token.pos('&lt;',1); // Strip off leading number
      len := token.length;
      token := token[pos:len];
      
      create tokenDocument transient;
      tokenDocument.parseString( token );
      methodElement := tokenDocument.findElementByTagName( 'methodResponse' ); 
      paramsElement := methodElement.getElementByTagName( 'params' );
      paramElement := paramsElement.getElementByTagName( 'param' );
      valueElement := paramElement.getElementByTagName( 'value' );
      stringElement := valueElement.getElementByTagName( 'string' );
      token := stringElement.text;          
      self.authToken := token;
      if token = null then
        errormsg := "Null authentication token.";
        return false;
      endif;
      return true;
    else
        errormsg := "Unable to connect to MoinMoin server." &amp; " server=&lt;https://" &amp; serverURL &amp; "/&gt;  url=&lt;"&amp;  cmd &amp; "&gt; message=&lt;"&amp; parms &amp; "&gt;";
        return false;
    endif;	 
epilog
    delete tokenDocument;
    delete xmlDocument;    
    delete http;
end;
</source>
        <Parameter name="url" type="String"/>
        <Parameter name="userName" type="String"/>
        <Parameter name="password" type="String"/>
        <Parameter name="errormsg" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getPage" id="716201c1-c1db-4b15-b9c7-a8a61e7710a2">
        <updating/>
        <source>getPage( pageName : String; pageContent : String io; errormsg: String io ): Boolean updating;

vars
	xmlDocument		: JadeXMLDocument ;
	rootElement		: JadeXMLElement ;
	methodElement	: JadeXMLElement ;
	paramsElement   : JadeXMLElement ;
	paramElement    : JadeXMLElement ;
	valueElement    : JadeXMLElement ;
	arrayElement    : JadeXMLElement ;
	dataElement     : JadeXMLElement ;
	dataElement2    : JadeXMLElement ;
	structElement   : JadeXMLElement ;
	memberElement   : JadeXMLElement ;
	nameElement     : JadeXMLElement ;
	stringElement   : JadeXMLElement ;
   	tokenDocument	: JadeXMLDocument ;
	faultElement    : JadeXMLElement ;
    resultXML       : String;
    success         : Boolean;
    hasFault        : Boolean;
    values          : JadeXMLElementArray;

    http      : JadeHTTPConnection; //use unpublished class
    cmd       : String;
    parms     : String;
    result    : String[256];
    headers   : String;
    response  : String; 
    
    pos : Integer;
    len : Integer;    
begin
    // Create XMLRPC request for putting a page

    create xmlDocument transient ;
	rootElement	:= xmlDocument.addElement( 'methodCall' );
    methodElement := rootElement.addElement( 'methodName' );
    methodElement.addText( 'system.multicall' );
    paramsElement := rootElement.addElement( 'params' );
    paramElement := paramsElement.addElement( 'param' );
    valueElement := paramElement.addElement( 'value' );
    arrayElement := valueElement.addElement( 'array' );
    dataElement := arrayElement.addElement( 'data' );
    valueElement := dataElement.addElement( 'value' );
    structElement := valueElement.addElement( 'struct' );
    memberElement := structElement.addElement( 'member' );
    nameElement := memberElement.addElement( 'name' );
    nameElement.addText( 'params' );
    valueElement := memberElement.addElement( 'value' );
    arrayElement := valueElement.addElement( 'array' );
    dataElement2 := arrayElement.addElement( 'data' );
    valueElement := dataElement2.addElement( 'value' );
    stringElement := valueElement.addElement( 'string' );
    stringElement.addText( authToken );
    memberElement := structElement.addElement( 'member' );
    nameElement := memberElement.addElement( 'name' );
    nameElement.addText( 'methodName' );
    valueElement := memberElement.addElement( 'value' );
    stringElement := valueElement.addElement( 'string' );
    stringElement.addText( 'applyAuthToken' );
    valueElement := dataElement.addElement( 'value' );
    structElement := valueElement.addElement( 'struct' );
    memberElement := structElement.addElement( 'member' );
    nameElement := memberElement.addElement( 'name' );
    nameElement.addText( 'params' );
    valueElement := memberElement.addElement( 'value' );
    arrayElement := valueElement.addElement( 'array' );
    dataElement := arrayElement.addElement( 'data' );
    valueElement := dataElement.addElement( 'value' );
    stringElement := valueElement.addElement( 'string' );
    stringElement.addText( pageName.trimBlanks );
    memberElement := structElement.addElement( 'member' );
    nameElement := memberElement.addElement( 'name' );
    nameElement.addText( 'methodName' );
    valueElement := memberElement.addElement( 'value' );
    stringElement := valueElement.addElement( 'string' );
    stringElement.addText( 'getPage' );

    // BEGIN HTTP stuff
    parms := xmlDocument.writeToString ;
    headers := null;
    cmd := '?action=xmlrpc2';
    
	// create a transient instance of the JadeHTTPCOnnection class and
	// call getHttpPage. Note that the server name (2nd parameter) must
	// include the scheme (in this case https).
    create http transient;
	response := http.getHttpPage('POST', 'https://' &amp; serverURL &amp; '/', cmd, parms, '');
	// A null response implies the call has failed.
	if response &lt;&gt; null then
      // Parse the response
      pos := response.pos('&lt;',1); // strip off leading number
      len := response.length;
      response := response[pos:len];

      create tokenDocument transient;
      tokenDocument.parseString( response );
      methodElement := tokenDocument.findElementByTagName( 'methodResponse' );   

      //Look for SUCCESS and warning messages ( "faultString" )
      resultXML := methodElement.writeToString;
      success := resultXML.cnContains('SUCCESS');
      hasFault := resultXML.cnContains('faultString');

      if success then   
        // Parse out the page content
        paramsElement := methodElement.getElementByTagName( 'params' );
        paramElement := paramsElement.getElementByTagName( 'param' );
        valueElement := paramElement.getElementByTagName( 'value' );
        arrayElement := valueElement.getElementByTagName( 'array' );
        dataElement := arrayElement.getElementByTagName( 'data' );
        create values transient;
        dataElement.getElementsByTagName( 'value', values );
        valueElement := values[2]; // The first is &lt;... SUCCESS ...&gt;
        arrayElement := valueElement.getElementByTagName( 'array' );
        dataElement := arrayElement.getElementByTagName( 'data' );
        valueElement := dataElement.getElementByTagName( 'value' );
        stringElement := valueElement.getElementByTagName( 'string' );
        pageContent := stringElement.text;
      endif;
      
      if hasFault then
        faultElement := tokenDocument.findElementByTagName( 'faultString' );   
        pos := resultXML.pos('faultString',1);
        len := resultXML.length;
        errormsg := resultXML[pos:len];
      endif;
    else
        errormsg := "Unable to connect to MoinMoin server.";
        success := false;
    endif;

    return success;
epilog
    delete tokenDocument;
    delete xmlDocument;
    delete values;
    delete http;
end;

</source>
        <Parameter name="pageName" type="String"/>
        <Parameter name="pageContent" type="String" usage="io"/>
        <Parameter name="errormsg" type="String" usage="io"/>
        <ReturnType type="Boolean"/>
