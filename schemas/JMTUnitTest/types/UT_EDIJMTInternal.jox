    <JadeMethod name="tTransaction" id="4039ba38-a590-4909-b915-d1e7008df38d">
        <source>tTransaction();
//
// 27 Aug 2014	cnwrs1	Par 34702 - Add support for JMT XML
//
constants
	USER_DEF_NAME : String = "JMTInternalWhatEver";
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	ti : CM_TrackedItem;
	cargoType : CM_CargoType;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
	bs			: CM_BlockStack;		// 25/01/2017 cnwmh5 
begin

	// 25/01/2017 cnwmh5
	bs := self.addBlockStack("TTRAN1", 99, null);
	self.assertNotNull(bs);

	// 09/01/2014 cnwmh5
	cargoType := self.getCargoType("CANNON");
	self.deleteCargo("UT_MAT001", cargoType);		// 13/05/2011 cnwmh5
	ti := self.createTrackedItem("UT_MAT001", cargoType.id, null, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), false,
		bs.myLocationsController);
	self.assertNotNull(ti);

	passportObj	:=	app.myPassport;
	ediText :=
'
&lt;?xml version="1.0" encoding="UTF-8"?&gt;
&lt;JMTInternalTransaction&gt;
&lt;AllTransaction&gt;
&lt;Transaction&gt;
&lt;chargeable&gt;true&lt;/chargeable&gt;
&lt;volume&gt;1200.0000&lt;/volume&gt;
&lt;weight&gt;2000.1200&lt;/weight&gt;
&lt;contentsStatus&gt;1&lt;/contentsStatus&gt;
&lt;orderNumber&gt;1&lt;/orderNumber&gt;
&lt;quantity&gt;4&lt;/quantity&gt;
&lt;transactionType&gt;15&lt;/transactionType&gt;
&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
&lt;commodity&gt;GENL&lt;/commodity&gt;
&lt;companyCode&gt;DCOM&lt;/companyCode&gt;
&lt;consignee&gt;JRDSC&lt;/consignee&gt;
&lt;consignor&gt;ROB&lt;/consignor&gt;
&lt;customsAgent&gt;DEB7&lt;/customsAgent&gt;
&lt;destination&gt;NZCHC&lt;/destination&gt;
&lt;dischargePort&gt;NZPOE&lt;/dischargePort&gt;
&lt;id&gt;UUTT0000001&lt;/id&gt;
&lt;imexStatus&gt;Export&lt;/imexStatus&gt;
&lt;messageMode&gt;U&lt;/messageMode&gt;
&lt;otherCargoId&gt;UT_MAT001&lt;/otherCargoId&gt;
&lt;otherCargoTypeDescr&gt;Cannon&lt;/otherCargoTypeDescr&gt;
&lt;sourceLocn&gt;D101&lt;/sourceLocn&gt;
&lt;targetLocn&gt;A1200&lt;/targetLocn&gt;
&lt;taskDescr&gt;Requires Inspection&lt;/taskDescr&gt;
&lt;transactionTime&gt;10 November 2011, 00:00:00&lt;/transactionTime&gt;
&lt;/Transaction&gt;
&lt;Transaction&gt;
&lt;chargeable&gt;true&lt;/chargeable&gt;
&lt;volume&gt;1200.0000&lt;/volume&gt;
&lt;weight&gt;2000.1200&lt;/weight&gt;
&lt;contentsStatus&gt;2&lt;/contentsStatus&gt;
&lt;orderNumber&gt;2&lt;/orderNumber&gt;
&lt;quantity&gt;4&lt;/quantity&gt;
&lt;transactionType&gt;5&lt;/transactionType&gt;
&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
&lt;commodity&gt;GENL&lt;/commodity&gt;
&lt;companyCode&gt;DCOM&lt;/companyCode&gt;
&lt;consignee&gt;Test2&lt;/consignee&gt;
&lt;consignor&gt;ROB&lt;/consignor&gt;
&lt;customsAgent&gt;DEB7&lt;/customsAgent&gt;
&lt;destination&gt;NZCHC&lt;/destination&gt;
&lt;dischargePort&gt;NZPOE&lt;/dischargePort&gt;
&lt;id&gt;UUTT0000001&lt;/id&gt;
&lt;imexStatus&gt;EXPORT&lt;/imexStatus&gt;
&lt;messageMode&gt;U&lt;/messageMode&gt;
&lt;sourceLocn&gt;D101&lt;/sourceLocn&gt;
&lt;targetLocn&gt;A1200&lt;/targetLocn&gt;
&lt;taskDescr&gt;Requires Inspection&lt;/taskDescr&gt;
&lt;transactionTime&gt;10 November 2011, 00:00:00&lt;/transactionTime&gt;
&lt;/Transaction&gt;
&lt;Transaction&gt;
&lt;chargeable&gt;true&lt;/chargeable&gt;
&lt;volume&gt;1200.0000&lt;/volume&gt;
&lt;weight&gt;2000.1200&lt;/weight&gt;
&lt;contentsStatus&gt;3&lt;/contentsStatus&gt;
&lt;orderNumber&gt;3&lt;/orderNumber&gt;
&lt;quantity&gt;4&lt;/quantity&gt;
&lt;transactionType&gt;52&lt;/transactionType&gt;
&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
&lt;commodity&gt;GENL&lt;/commodity&gt;
&lt;companyCode&gt;DCOM&lt;/companyCode&gt;
&lt;consignee&gt;SPR&lt;/consignee&gt;
&lt;consignor&gt;TOYOT&lt;/consignor&gt;
&lt;customsAgent&gt;DEB7&lt;/customsAgent&gt;
&lt;destination&gt;NZCHC&lt;/destination&gt;
&lt;dischargePort&gt;NZPOE&lt;/dischargePort&gt;
&lt;id&gt;UUTT0000001&lt;/id&gt;
&lt;imexStatus&gt;IMPORT&lt;/imexStatus&gt;
&lt;messageMode&gt;U&lt;/messageMode&gt;
&lt;sourceLocn&gt;D101&lt;/sourceLocn&gt;
&lt;targetLocn&gt;A1200&lt;/targetLocn&gt;
&lt;taskDescr&gt;Requires Inspection&lt;/taskDescr&gt;
&lt;transactionTime&gt;10 November 2011, 00:00:00&lt;/transactionTime&gt;
&lt;/Transaction&gt;
&lt;/AllTransaction&gt;
&lt;/JMTInternalTransaction&gt;
';
	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 3, "incorrect number of EDI trackedItems");
end;
</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;CreateTrackedItemFixed&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tTransactionAction" id="8a807ad3-b816-4072-8ccf-c817a129beaa">
        <source>tTransactionAction();
//
//14 August 2017	jlgrs1	Initial creation
//
constants
	USER_DEF_NAME : String = "JMTInternalTransaction";
	CONTAINERID : String = "SARG1234543";
	VOYAGECODE = 'VOY27418';
	VESSELNAME = 'SHIP27418';
	OPERATORCODE = 'MSK';
	BookingId1 = 'BK27418';
	BlockStackName	= 'BS26728';
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	operator : CM_Operator;
	bs : CM_BlockStack;
	container : CM_Container;
	trans : CM_TITransaction;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
begin
	passportObj := app.myPassport;
	operator := self.getOperator(OPERATORCODE);
	self.deleteVoyage(VOYAGECODE);
	voyage := self.getVoyage(VOYAGECODE);
	self.assertIsDeleted(voyage);
	self.deleteVessel(VESSELNAME);
	vessel := self.getVessel(VESSELNAME);
	self.assertIsDeleted(vessel);
	self.deleteContainer(CONTAINERID);
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertIsDeleted(container);
	vessel := self.addVesselCellular(VESSELNAME,
										operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	voyage := self.addVoyageWithContainerStructur(VOYAGECODE,
													VESSELNAME,
													OPERATORCODE,
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	// Delete and add the required bookings
	self.opts.addAssoc('Stock', true);
	self.opts.addAssocIfNotNull(ETRow_PackAs, app.getString(PackAs_LCL));
	self.deleteBooking(BookingId1);
	container := self.addContainerOnShip(CONTAINERID, operator, "4102", "GOLD", BookingId1, voyage, self.getTerminal.getConfig(PortDestCode).String, "010682").CM_Container;
	bs := addBlockStack(BlockStackName, 100, null);
	self.opts.addAssoc('IsForcedMove', true);
	self.move(container, bs);
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalTransaction xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalTransaction.xsd"&gt;
	&lt;AllTransaction&gt;
		&lt;Transaction&gt;
			&lt;chargeable/&gt;
			&lt;volume/&gt;
			&lt;weight/&gt;
			&lt;contentsStatus/&gt;
			&lt;orderNumber/&gt;
			&lt;quantity/&gt;
			&lt;transactionType&gt;10&lt;/transactionType&gt;
			&lt;length/&gt;
			&lt;cargoTypeDescr/&gt;
			&lt;commodity/&gt;
			&lt;companyCode/&gt;
			&lt;consignee/&gt;
			&lt;consignor/&gt;
			&lt;customsAgent/&gt;
			&lt;description/&gt;
			&lt;destination/&gt;
			&lt;dischargePort/&gt;
			&lt;fullOrMT/&gt;
			&lt;id&gt;'&amp;CONTAINERID&amp;'&lt;/id&gt;
			&lt;imexStatus/&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;operatorCode/&gt;
			&lt;otherCargoId/&gt;
			&lt;otherCargoTypeDescr/&gt;
			&lt;sourceLocn/&gt;
			&lt;targetLocn/&gt;
			&lt;taskDescr/&gt;
			&lt;voyageCode/&gt;
			&lt;transactionTime/&gt;
		&lt;/Transaction&gt;
	&lt;/AllTransaction&gt;
&lt;/JMTInternalTransaction&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");
	container := self.getTrackedItem(CONTAINERID).CM_Container;
	self.assertNotNull(container);
	trans := container.allTransactions.last;
	self.assertEqualMsg(trans.type, 10, "wrong transaction type");
end;
</source>
    </JadeMethod>
    <JadeMethod name="tTranshipAction" id="2ad55449-f643-41e3-8c31-a8bfdc72064f">
        <source>tTranshipAction();
//
//14 August 2017	jlgrs1	Initial creation
//
constants
	USER_DEF_NAME : String = "JMTInternalTranship";
	CONTAINERID1 : String = "SARG1234541";
	CONTAINERID2 : String = "SARG1234542";
	CONTAINERID3 : String = "SARG1234543";
	CONTAINERID4 : String = "SARG1234544";
	VOYAGECODE = 'VOY27418';
	VOYAGECODETSHIP = 'VOY27418_2';
	VESSELNAME = 'SHIP27418';
	VESSELNAMETSHIP = 'SHIP27418_2';
	OPERATORCODE = 'MSK';
	BookingId1 = 'BK27418';
	TIID = 'MSKU27418';
	BlockStackName	= 'BS26728';
vars
	ediFileObj : CM_EDIFile;
	ediDataObj : CM_EDIData;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	voyageT : CM_Voyage;
	operator : CM_Operator;
	bs : CM_BlockStack;
	container : CM_Container;
	passportObj : CM_Passport;
	ediText : String;
	errorMsg : String;
begin
	passportObj := app.myPassport;
	operator := self.getOperator(OPERATORCODE);
	self.deleteVoyage(VOYAGECODE);
	voyage := self.getVoyage(VOYAGECODE);
	self.assertIsDeleted(voyage);
	self.deleteVessel(VESSELNAME);
	vessel := self.getVessel(VESSELNAME);
	self.assertIsDeleted(vessel);
	self.deleteVoyage(VOYAGECODETSHIP);
	voyage := self.getVoyage(VOYAGECODETSHIP);
	self.assertIsDeleted(voyage);
	self.deleteVessel(VESSELNAMETSHIP);
	vessel := self.getVessel(VESSELNAMETSHIP);
	self.assertIsDeleted(vessel);
	self.deleteContainer(CONTAINERID1);
	container := self.getTrackedItem(CONTAINERID1).CM_Container;
	self.assertIsDeleted(container);
	self.deleteContainer(CONTAINERID2);
	container := self.getTrackedItem(CONTAINERID2).CM_Container;
	self.assertIsDeleted(container);
	self.deleteContainer(CONTAINERID3);
	container := self.getTrackedItem(CONTAINERID3).CM_Container;
	self.assertIsDeleted(container);
	self.deleteContainer(CONTAINERID4);
	container := self.getTrackedItem(CONTAINERID4).CM_Container;
	self.assertIsDeleted(container);
	vessel := self.addVesselCellular(VESSELNAME,
										operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	voyage := self.addVoyageWithContainerStructur(VOYAGECODE,
													VESSELNAME,
													OPERATORCODE,
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	vessel := self.addVesselCellular(VESSELNAMETSHIP,
										operator);
	self.assertNotNullMsg(vessel, 'Add vessel failed');
	
	voyageT := self.addVoyageWithContainerStructur(VOYAGECODETSHIP,
													VESSELNAMETSHIP,
													OPERATORCODE,
													self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage, 'Add voyage failed');
	self.deleteTerminalArea(BlockStackName);
	bs := self.getTerminalArea(BlockStackName).CM_BlockStack;
	self.assertIsDeleted(bs);

	// Delete and add the required bookings
	self.opts.addAssoc('Stock', true);
	self.opts.addAssocIfNotNull(ETRow_PackAs, app.getString(PackAs_LCL));
	self.deleteBooking(BookingId1);
	bs := addBlockStack(BlockStackName, 100, null);
	self.opts.addAssoc('IsForcedMove', true);
	container := self.addContainerOnShip(CONTAINERID1, operator, "4102", "GOLD", BookingId1, voyage, self.getTerminal.getConfig(PortDestCode).String, "010682").CM_Container;
	self.move(container, bs);
	container := self.addContainerOnShip(CONTAINERID2, operator, "4102", "GOLD", BookingId1, voyage, self.getTerminal.getConfig(PortDestCode).String, "010682").CM_Container;
	self.move(container, bs);
	container := self.addContainerOnShip(CONTAINERID3, operator, "4102", "GOLD", BookingId1, voyage, self.getTerminal.getConfig(PortDestCode).String, "010682").CM_Container;
	self.move(container, bs);
	container := self.addContainerOnShip(CONTAINERID4, operator, "4102", "GOLD", BookingId1, voyage, self.getTerminal.getConfig(PortDestCode).String, "010682").CM_Container;
	self.move(container, bs);
	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalTranship xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalTranship.xsd"&gt;
	&lt;AllTranship&gt;
		&lt;Tranship&gt;
			&lt;weight/&gt;
			&lt;temperature/&gt;
			&lt;billOfLading&gt;BOL01&lt;/billOfLading&gt;
			&lt;bookingRef/&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;commodity/&gt;
			&lt;containerId&gt;&lt;/containerId&gt;
			&lt;description/&gt;
			&lt;destinationPort/&gt;
			&lt;dischargePort&gt;HKHKG&lt;/dischargePort&gt;
			&lt;exportVesselName&gt;'&amp;VESSELNAMETSHIP&amp;'&lt;/exportVesselName&gt;
			&lt;exportVoyageCode&gt;'&amp;VOYAGECODETSHIP&amp;'&lt;/exportVoyageCode&gt;
			&lt;fullOrMT/&gt;
			&lt;id&gt;'&amp;CONTAINERID1&amp;'&lt;/id&gt;
			&lt;isoType/&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;voyageCode&gt;'&amp;VOYAGECODE&amp;'&lt;/voyageCode&gt;
		&lt;/Tranship&gt;
		&lt;Tranship&gt;
			&lt;weight/&gt;
			&lt;temperature/&gt;
			&lt;billOfLading&gt;BOL01&lt;/billOfLading&gt;
			&lt;bookingRef/&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;commodity/&gt;
			&lt;containerId&gt;&lt;/containerId&gt;
			&lt;description/&gt;
			&lt;destinationPort/&gt;
			&lt;dischargePort&gt;HKHKG&lt;/dischargePort&gt;
			&lt;exportVesselName&gt;'&amp;VESSELNAMETSHIP&amp;'&lt;/exportVesselName&gt;
			&lt;exportVoyageCode&gt;'&amp;VOYAGECODETSHIP&amp;'&lt;/exportVoyageCode&gt;
			&lt;fullOrMT/&gt;
			&lt;id&gt;'&amp;CONTAINERID2&amp;'&lt;/id&gt;
			&lt;isoType/&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;voyageCode&gt;'&amp;VOYAGECODE&amp;'&lt;/voyageCode&gt;
		&lt;/Tranship&gt;
		&lt;Tranship&gt;
			&lt;weight/&gt;
			&lt;temperature/&gt;
			&lt;billOfLading&gt;BOL01&lt;/billOfLading&gt;
			&lt;bookingRef/&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;commodity/&gt;
			&lt;containerId&gt;&lt;/containerId&gt;
			&lt;description/&gt;
			&lt;destinationPort/&gt;
			&lt;dischargePort&gt;HKHKG&lt;/dischargePort&gt;
			&lt;exportVesselName&gt;'&amp;VESSELNAMETSHIP&amp;'&lt;/exportVesselName&gt;
			&lt;exportVoyageCode&gt;'&amp;VOYAGECODETSHIP&amp;'&lt;/exportVoyageCode&gt;
			&lt;fullOrMT/&gt;
			&lt;id&gt;'&amp;CONTAINERID3&amp;'&lt;/id&gt;
			&lt;isoType/&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;voyageCode&gt;'&amp;VOYAGECODE&amp;'&lt;/voyageCode&gt;
		&lt;/Tranship&gt;
		&lt;Tranship&gt;
			&lt;weight/&gt;
			&lt;temperature/&gt;
			&lt;billOfLading&gt;BOL01&lt;/billOfLading&gt;
			&lt;bookingRef/&gt;
			&lt;cargoTypeDescr&gt;ISO Container&lt;/cargoTypeDescr&gt;
			&lt;commodity/&gt;
			&lt;containerId&gt;&lt;/containerId&gt;
			&lt;description/&gt;
			&lt;destinationPort/&gt;
			&lt;dischargePort&gt;HKHKG&lt;/dischargePort&gt;
			&lt;exportVesselName&gt;'&amp;VESSELNAMETSHIP&amp;'&lt;/exportVesselName&gt;
			&lt;exportVoyageCode&gt;'&amp;VOYAGECODETSHIP&amp;'&lt;/exportVoyageCode&gt;
			&lt;fullOrMT/&gt;
			&lt;id&gt;'&amp;CONTAINERID4&amp;'&lt;/id&gt;
			&lt;isoType/&gt;
			&lt;messageMode&gt;A&lt;/messageMode&gt;
			&lt;voyageCode&gt;'&amp;VOYAGECODE&amp;'&lt;/voyageCode&gt;
		&lt;/Tranship&gt;
	&lt;/AllTranship&gt;
&lt;/JMTInternalTranship&gt;';

	ediFileObj := self.ediLoadFileName(ediText, EDIFileType_Unknown, USER_DEF_NAME, USER_DEF_NAME&amp;method.name);

	self.assertNotNull(ediFileObj);
	self.assertEqualMsg(true, passportObj.allErrors.isEmpty(), passportObj.getAllErrorsWarningsAsString());	// cnwrl1 25/08/2010 PAR 25559
	self.assertNotNull(ediFileObj.ediData);		// cnwrl1 25/08/2010 PAR 25559
	self.ediVerify(ediFileObj);
	errorMsg := "Verify Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	// Status 3 is verify status and 14 is verified with warnings.
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						errorMsg,
//						CM_EDIFile.EDI_STATUS_VERIFIED,
//						CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS);
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, errorMsg);
	ediDataObj := ediFileObj.ediData;
	self.ediDBLoad(ediFileObj);
//	self.assertIsOneOf(	ediFileObj.fileStatus,
//						"Load Failed",
//						CM_EDIFile.EDI_STATUS_DBLOADED,
//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 4, "incorrect number of EDI trackedItems");
	container := self.getTrackedItem(CONTAINERID1).CM_Container;
	self.assertNotNull(container);
	self.assertEqualMsg(container.dischargePort, "HKHKG", "wrong remarks");
end;
</source>
