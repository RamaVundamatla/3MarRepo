    <JadeMethod name="getSatDrawHeightInPixels" id="cad9b086-9798-47e6-9c9c-bb4057c85a4e">
        <source>getSatDrawHeightInPixels(_zoom : Real) : Real;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2009	cnwjk3	Initial creation

*/

vars
	height	: Real;
begin
	//epr par 36616 15/10/15
	height := getSatRawDrawHeightInPixels(_zoom);	
	height := height + ((self.SAT_RORO_BORDER_PADDING * 2)* _zoom);
	height := height + (self.SAT_RORO_BORDER_WIDTH * 2);

	return height;
epilog

end;</source>
        <Parameter name="_zoom" type="Real"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getSatDrawWidthInPixels" id="5c96719d-6264-47ed-85a0-8b20e3b37714">
        <source>getSatDrawWidthInPixels(_zoom : Real) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2009	cnwjk3	Initial creation

*/

vars
	width	: Real;
begin
	//epr par 36616 15/10/15
	width := self.getSatRawDrawWidthInPixels(_zoom);
	width := width + ((self.SAT_RORO_LANE_LABEL_WIDTH + (self.SAT_RORO_BORDER_PADDING * 2)) * _zoom);
	
	width := width + (self.SAT_RORO_BORDER_WIDTH * 2);

	return width.Integer;
epilog

end;</source>
        <Parameter name="_zoom" type="Real"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSatRawDrawHeightInPixels" id="dedb72f8-7e37-435a-9780-0ad5ea807b78">
        <source>getSatRawDrawHeightInPixels(_zoom : Real) : Real;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2009	cnwjk3	Initial creation

*/

vars
	height	: Real;
begin
	//epr par 36616 15/10/15
	height := self.getTotalLaneWidthDrawExtent();
	height := height * self.SAT_RORO_PIXELS_PER_METRE;
	height := height + ((self.laneCount -1) * self.SAT_RORO_LANE_GAP);
	height := height * _zoom;	
	return height;
epilog

end;</source>
        <Parameter name="_zoom" type="Real"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getSatRawDrawWidthInPixels" id="e69e5ed0-3ea3-455a-99b5-ff4a329e649a">
        <source>getSatRawDrawWidthInPixels(_zoom : Real) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2009	cnwjk3	Initial creation

*/

vars
	width	: Real;
begin	
	//epr par 36616 15/10/15
	width := self.getLongestLaneDrawExtent();
	width := width * self.SAT_RORO_PIXELS_PER_METRE;
	width := width * _zoom;	
	return width.Integer;
epilog

end;</source>
        <Parameter name="_zoom" type="Real"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSlotUnit" id="6c3e2a7e-49fa-4dfc-a369-659023c137f6">
        <source>getSlotUnit() : Decimal;
// --------------------------------------------------------------------------------
// Created:		26 Janurary 2010 by cnwjo3
//
// Purpose:		Since RoRoLaneAreas are measured in metre units when displaying
//				RoRo information in Satellite View we should not just display
//				the metres since this would be confusing when a Yard Allocation
//				has a group of Block Stacks, Gridded Areas and RoRos, ie: Block Stack
//				Total Total = maxCapacity, Gridded Area Total Total = length *
//				width * height.  Total Total for RoRo at this time is length/slotUnit
//				At this time slotUnit is 6.1 (or same as 1 TEU).
//				Later this functionality may return a value from a new property in this
//				class.  its a future holder so we don't put 6.1 everywhere.
//				CCMS 1018
//
vars

begin
	return 6.1;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getTotalLaneWidthDrawExtent" id="674ac009-b6a3-46c7-a395-247b781b52b7">
        <source>getTotalLaneWidthDrawExtent() : Real protected;

/*

Purpose:			
	Helps with measurement/drawing code

Parameters:			

Return Value:		
	total width of all lanes in metres 

Date		Who		Reason
25 November 2009	cnwjk3	ccms 1018



*/

vars
	totalWidth	: Real;
	lane		: CM_RoRoController;
begin
	foreach lane in self.allLanesByLaneNumber do
		totalWidth := totalWidth + lane.width;
	endforeach;
	return totalWidth;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Real"/>
    </JadeMethod>
