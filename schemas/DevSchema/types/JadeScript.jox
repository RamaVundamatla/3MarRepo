    <JadeMethod name="kpdTestUnicodeFiles" id="5d6d85fd-f254-470a-80bc-645de96375d8">
        <source>kpdTestUnicodeFiles();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Jul 2015	cnwkpd1	PAR #36286 - Changes for Unicode JADE

*/

vars
	f				: File;
	s				: String;
	char			: Character;
	i,
	fileKind,
	maxChar			: Integer;
	fileKinds		: IntegerArray;
	sysType			: String;
	
begin
	if app.isUnicode then
		maxChar := 65535;
		sysType := "Unicode";
	else
		maxChar := 255;
		sysType := "ANSI";
	endif;
	
	maxChar := 127;		// test
	
	create fileKinds transient;
	if not app.isUnicode then
		fileKinds.add(File.Kind_ANSI);
	endif;
//	fileKinds.add(File.Kind_Binary);
	fileKinds.add(File.Kind_Unicode);
	fileKinds.add(File.Kind_Unicode_UTF16BE);
	fileKinds.add(File.Kind_Unicode_UTF16LE);
	fileKinds.add(File.Kind_Unicode_UTF32BE);
	fileKinds.add(File.Kind_Unicode_UTF32LE);
	fileKinds.add(File.Kind_Unicode_UTF8);
	fileKinds.add(File.Kind_Unknown_Text);

	foreach fileKind in fileKinds do
		delete f;
		create f transient;
		f.kind := fileKind;
		f.unicodeBOM := false;	
	
		f.openOutput("c:\temp\unicodetest\test_ex_" &amp; sysType &amp; "_kind_" &amp; fileKind.String &amp; ".txt");
		
		foreach i in 1 to maxChar do
			f.writeLine(i.String &amp; Tab &amp; i.Character);
		endforeach;
	
		f.close();
	endforeach;
	
	
epilog
	delete f;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdTestUnicodeReadFile" id="3e51ee9e-2eb4-47c7-8c3e-e67bed36b425">
        <source>kpdTestUnicodeReadFile();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Jul 2015	cnwkpd1	PAR #36286 - Changes for Unicode JADE

*/

vars
	s,
	fileContent 	: String;
	f				: File;
	
begin
	fileContent := 	'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Grouping,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?,Is Haz?,Direct Delivery?' &amp; CrLf &amp;
					'Cargo,Map36559,(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
					'Cargo,Map36559,CONT| ISO Container,(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
					'Cargo,Map36559,CONT| ISO Container,(Default),(Default),Import,(Default),(Default),(Default),,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
					'Cargo,Map36559,CONT| ISO Container,(Default),(Default),Import,FCL,(Default),(Default),,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
					'Cargo,Map36559,CONT| ISO Container,(Default),(Default),Import,FCL,UT_1,(Default),,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
					'Cargo,Map36559,CONT| ISO Container,(Default),(Default),Import,FCL,UT_1,Todo Task Added,,(Default),CCT02 TODO Resource Quantity ›,(Default),All,VOID' &amp; CrLf &amp;
					'Cargo,Map36559,CONT| ISO Container,(Default),(Default),Import,FCL,UT_1,Todo Task Added,Resource Mappings:UTResA,(Default),CCT02 TODO Resource Quantity ›,(Default),All,UT_ILD01' &amp; CrLf &amp;
					'Cargo,Map36559,CONT| ISO Container,(Default),(Default),Import,FCL,UT_1,Todo Task Added,Resource Mappings:UTResB,(Default),CCT02 TODO Resource Quantity ›,(Default),All,UT_ILD02' &amp; CrLf &amp;
					'Cargo,Map36559,CONT| ISO Container,(Default),(Default),Import,FCL,UT_1,Todo Task Completed,,(Default),(Default) ›,(Default),All,VOID' &amp; CrLf &amp;
					'Cargo,Map36559,CONT| ISO Container,(Default),(Default),Import,FCL,UT_1,Todo Task Completed,Resource Mappings:UTResA,(Default),(Default) ›,(Default),All,UT_ILD03' &amp; CrLf &amp;
					'Cargo,Map36559,CONT| ISO Container,(Default),(Default),Import,FCL,UT_1,Todo Task Completed,Resource Mappings:UTResB,(Default),(Default) ›,(Default),All,UT_ILD04';
	 
	create f transient;
	f.openOutput("c:\temp\testreadline.txt");
	f.writeString(fileContent);
	f.close();
	
	delete f;
	create f transient;
	f.mode		:=	File.Mode_Input;
	f.shareMode	:=	File.Share_Read;
	f.kind		:=	File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	f.fileName 	:= "c:\temp\testreadline.txt";
	f.open();	

	while not f.endOfFile do
		write f.readLine();
	endwhile;
	
epilog
	delete f;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdTestXSDDoc" id="c555e07a-9a45-4e36-a833-b0ed82df2184">
        <source>kpdTestXSDDoc();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2016	cnwkpd1	TFS 488 - Multi Timezone Support


*/

constants
	WSDL_File 		= 'C:\temp\TestJMTXSD\JMTWebService.wsdl';
	InputXSDFile	= 'C:\temp\TestJMTXSD\Prenote.xsd';
	OutputXSDFile	= 'C:\temp\TestJMTXSD\PrenoteWithDoc.xsd';
	
vars
	wsdl,
	xsd 			: JadeXMLDocument;
	wsdlElements,
	xsdElements		: JadeXMLElementArray;
	attribute,
	wsdlAttribute	: JadeXMLAttribute;
	element,
	tiElement,
	wsdlElement,
	annotationElement	: JadeXMLElement;
	wsdlElementsDict	: DynaDictionary;
	iter			: Iterator;
	
begin
	create wsdl transient;
	wsdl.parseFile(WSDL_File);
	
	create wsdlElements transient;
	wsdl.findElementsByNameNS("*", "complexType", wsdlElements);
	
	foreach element in wsdlElements do
		attribute := element.getAttributeByName("name");
		if attribute &lt;&gt; null and
		   attribute.value = "WS_PrenoteFromCargoId" then
			tiElement := element;
			break;
		endif;
	endforeach;
	
	if tiElement = null then
		return;
	endif;
	
	wsdlElements.clear;
	tiElement.findAllElementsByNameNS("*", "element", wsdlElements);
	
	create wsdlElementsDict transient;
	wsdlElementsDict.setMembership(JadeXMLElement);
	wsdlElementsDict.addExternalKey(String, 40, false, true);
	wsdlElementsDict.endKeys(true);
	
	foreach element in wsdlElements do
		attribute := element.getAttributeByName("name");
		if attribute &lt;&gt; null then
			wsdlElementsDict.putAtKey(attribute.value, element);
		endif;
	endforeach;
	iter := wsdlElementsDict.createIterator();
	
	create xsd transient;
	xsd.parseFile(InputXSDFile);
	
	create xsdElements transient;
	xsd.findElementsByNameNS("*", "element", xsdElements);
	
	foreach element in xsdElements do
		attribute := element.getAttributeByName("name");
		if attribute &lt;&gt; null then
			wsdlElementsDict.startKeyGeq(attribute.value, iter);
			while iter.next(wsdlElement) do
				wsdlAttribute := wsdlElement.getAttributeByName("name");
				if wsdlAttribute.value.toLower() &lt;&gt; attribute.value.toLower() then
					break;
				endif;
				
				annotationElement := wsdlElement.getElementByTagName("xsd:annotation");
				if annotationElement &lt;&gt; null then
					annotationElement.copyAsChildOf(element);
					break;
				endif;
			endwhile;
		endif;
	endforeach;
	
	xsd.writeToFile(OutputXSDFile);
	
	write "Finished";
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="kpdTidyUpCamHistory" id="78917e34-e4f8-4656-be86-8e41b0745b66">
        <source>kpdTidyUpCamHistory();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Jun 2015	cnwkpd1	Initial creation


*/

constants
	MaxTranTime		= 5000;

vars
	cth 			: CM_CamTaskHistory;
	i 				: Integer;
	lastCommit		: Decimal[23];
	jdb				: JadeDatabaseAdmin;
	dbFile			: DbFile;
	dbFiles			: DbFileArray;
	free			: Decimal[20];
	
begin
	write "Deleting orphaned CM_CamTaskHistory instances...";
	
	lastCommit := app.relativeMachineTime();
	beginTransaction;
	foreach cth in CM_CamTaskHistory.instances do
		if cth.camProtocol = null then
			delete cth;
			i := i + 1;
			if i mod 2000 = 0 then
				write i.String &amp; " CM_CamTaskHistory instances deleted";
			endif;
		endif;

		if (app.relativeMachineTime() - lastCommit) &gt; MaxTranTime then
			commitTransaction;
			beginTransaction;
			lastCommit := app.relativeMachineTime();
		endif;
	endforeach;
	commitTransaction;
	
	write "Deleted " &amp; i.String &amp; " orphaned CM_CamTaskHistory instances";
	
	write "Compacting cams.dat...";
	
	create dbFiles transient;
	foreach dbFile in DbFile.instances where dbFile.name = "cams" do
		dbFiles.add(dbFile);
		write "cams.dat file size before = " &amp; dbFile.getFileLength().String;
		dbFile.changeAccessMode(DbFile.Mode_ReadOnly);
		dbFile.getFreeSpace(free);
		dbFile.changeAccessMode(DbFile.Mode_Update);
		write "cams.dat free space before = " &amp; free.String;
		break;
	endforeach;
	
	create jdb transient;
	jdb.compactDbFiles(dbFiles, 1, null, true);
	
	write "Compacting cams.dat complete";
	write "cams.dat file size after = " &amp; dbFile.getFileLength().String;
	dbFile.changeAccessMode(DbFile.Mode_ReadOnly);
	dbFile.getFreeSpace(free);
	dbFile.changeAccessMode(DbFile.Mode_Update);
	write "cams.dat free space after = " &amp; free.String;

epilog
	delete jdb;
	delete dbFiles;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdTimeRichText" id="7d23f7cb-d00d-4887-bbbe-c84523a23eeb">
        <source>kpdTimeRichText();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2014	cnwkpd1	PAR #34713 - .NET EDI transform integration

*/

vars
	form			: CMUI_ScrollMsgBoxSearchable;
	i,
	j				: Integer;
	message			: String;
	startTime,
	endTime			: Decimal[20];
	
begin
	app.initialize();
	app.myPassport.setMyUserFromCode("SUPERUSER");
	
	create form transient;
	form.load();
	form.show();
	app.doWindowEvents(1000);
	
	form.caption := "Test";

	foreach i in 1 to 10 do
		foreach j in 1 to 10000 do
			message := message &amp; "XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXZXXXXXXXXXXXXXXXXXXX" &amp; CrLf;
		endforeach;
		
		startTime := app.relativeMachineTime();
		form.loadSmallMessage("Small Message" &amp; CrLf &amp; message, null, "Z");
		endTime := app.relativeMachineTime();
		write "loadSmallMessage, length=" &amp; message.length().String &amp; ", time=" &amp; (endTime - startTime).String;
		app.doWindowEvents(200);
		
		startTime := app.relativeMachineTime();
		form.loadBigMessage("Big Message" &amp; CrLf &amp; message, null, "Z");
		endTime := app.relativeMachineTime();
		write "loadBigMessage, length=" &amp; message.length().String &amp; ", time=" &amp; (endTime - startTime).String;
		app.doWindowEvents(200);
		
	endforeach;

	
epilog
	delete form;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdUpdateReleaseVersion" id="14b978fa-f90e-47e5-b3d9-a91ca4116341">
        <source>kpdUpdateReleaseVersion();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Aug 2015	cnwkpd1	JADE PAR #62909

*/

constants
	NewVersion		= "7.0.00";
	
vars
	ff				: FileFolder;
	f				: FileNode;
	folderName 		: String;
	agent			: DEV_ReleaseExtractAgent;
	
begin
	create ff transient;
	folderName := ff.browseForFolder('Select schema directory', 'D:\Releases\842\JARI_JMT842');
	if folderName = null then
		return;
	endif;
	
	create agent transient;
	
	ff.fileName := folderName;
	foreach f in ff.files where f.isKindOf(File) do
		if f.fileName.toLower().endsWith(".scm") then
			agent.changeSCMVersionNumber(f.fileName, f.usePresentationFileSystem, NewVersion);
		elseif f.fileName.toLower.endsWith(".ddb") then
			agent.changeDDBVersionNumber(f.fileName, f.usePresentationFileSystem, NewVersion);
		endif;
	endforeach;
	
epilog
	delete ff;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="kpdUpgradePerformanceTest" id="7ff2de9a-a40d-4a8d-9a6b-9dae4c86a526">
        <source>kpdUpgradePerformanceTest();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 November 2015	cnwkpd1	PAR #36286 - Changes for Unicode JADE


*/

vars
	menuAgent			: CM_MenuAgent;
	profiler			: JadeProfiler;
	
begin
	app.initialize();
	
	write "Started";
	
	create profiler transient;
	profiler.fileName := "kpd_profile_" &amp; app.actualTimeServer.getNumeralString() &amp; ".log";
	profiler.methodCount := 30;
	profiler.start();
	
	write "Logging to " &amp; profiler.fileName;
	
	create menuAgent transient;
	menuAgent.resetAllMenuDetails();
	
	profiler.report;
	
	write "Finished";
	
epilog
	delete menuAgent;
	delete profiler;
	
end;

</source>
    </JadeMethod>
    <JadeMethod name="listMyFormsToFile" id="3d2c4860-067f-4f45-8328-a36dd76221e8">
        <source>listMyFormsToFile();
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 18 January 2006
//
//----------------------------------------------------------------------
constants
	Release = '7.7.3';
	ReleaseForPath ='773';
vars
	userT	: CM_UserTerminal;
	me1,
	me2,
	me3,
	me4		: CM_MenuEntity;
	sch		: Schema;
	cls		: Class;
	clsColl	: ClassColl;
	obj		: Object;
	str		: String;
	file : File;
	fileFolder : FileFolder;
begin

	app.initialize();
	// this is CNWSH3 Dmast T01
	userT := '3372.104'.asOid.CM_UserTerminal;
	
	// Setup output file
	create fileFolder;
	fileFolder.usePresentationFileSystem := true;
	fileFolder.fileName := "F:\PORT\Testing\JMTerminal V7\MajorReleaseTesting JMT7\" &amp; ReleaseForPath &amp; "JMT";
	
	if not fileFolder.isAvailable() then
		app.writeStatement(self.class.name &amp; ' &gt;&gt;' &amp; method.name &amp; " 0.1 - Folder does not exist, creating now..");
		fileFolder.make();
	else
		app.writeStatement(self.class.name &amp; ' &gt;&gt;' &amp; method.name &amp; " 0.2 - Folder exists, no need to create one.");
	endif;
	
	if not fileFolder.isAvailable() then
		app.writeStatement(self.class.name &amp; ' &gt;&gt;' &amp; method.name &amp; " 1 - File folder could not be created");
		return;
	endif;
	app.writeStatement(self.class.name &amp; ' &gt;&gt;' &amp; method.name &amp; " 1.2 - File path is: " &amp; fileFolder.fileName);
	app.writeStatement(self.class.name &amp; ' &gt;&gt;' &amp; method.name &amp; " 2 - Creating list of forms for JMT Release " &amp; Release );
	create file;
	file.fileName := fileFolder.fileName &amp; '\JMT' &amp; ReleaseForPath &amp;"FormsExtract.xls";
	//file.kind := File.Kind_Unknown_Text;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	file.mode := File.Mode_Output;
	file.open;

	file.writeLine("Forms for " &amp; Release);

	sch := rootSchema.getSchema('UiCommonSchema');
	sch := sch.getSubschema('SysOpsSchema');
	cls := sch.getClass('SOP_TableMaintItem');
	
	create clsColl transient;
	cls.allSubclasses(clsColl);
	
	file.writeLine("*** TERMINAL ***");						
	
	foreach me1 in userT.myMenuRoot.allChildren do
		
		file.writeLine(me1.getQualFormListOutput);
		foreach me2 in me1.allChildren do
			
			file.writeLine(Tab &amp; me2.getQualFormListOutput);
			str := me2.getWindowClassName();
			//Terminal tables
			if str = 'SOP_TableMaintForm' then
				foreach cls in clsColl do : clsLoop
					if cls.abstract 
					or cls.name = "SOPTM_Status" then
						continue clsLoop;
					endif;
					create obj as cls transient;
					if not obj.sendMsg('isSystemItem').Boolean then
						if cls.getSuperclass() &lt;&gt; sch.getClass('SOPTM_HMS') then
							
							file.writeLine(Tab &amp; Tab &amp; obj.sendMsg('getDisplayHeading').String) ;
						endif;
					endif;
					delete obj;
				endforeach;
			endif;
			foreach me3 in me2.allChildren do
				
				file.writeLine(Tab &amp; Tab &amp; me3.getQualFormListOutput);
				foreach me4 in me3.allChildren do
					
					file.writeLine(Tab &amp; Tab &amp; Tab &amp; me4.getQualFormListOutput);
				endforeach;
			endforeach;
		endforeach;
	endforeach;

	file.writeLine("*** SYSTEM ***");
	
	foreach me1 in userT.myUser.myMenuRootForSysEntities.allChildren do
		
		file.writeLine(me1.getQualFormListOutput);
		foreach me2 in me1.allChildren do
			
			file.writeLine(Tab &amp; me2.getQualFormListOutput);
			str := me2.getWindowClassName();
			if str = 'SOP_TableMaintForm' then
				//System Tables
				foreach cls in clsColl do  : clsLoop
					if cls.abstract 
					or cls.name = "SOPTM_Status" then
						continue clsLoop;
					endif;
					create obj as cls transient;
					
					if obj.sendMsg('isSystemItem').Boolean then
						if cls.getSuperclass() &lt;&gt; sch.getClass('SOPTM_HMS') then
							
							file.writeLine(Tab &amp; Tab &amp; obj.sendMsg('getDisplayHeading').String);
						endif;
					endif;
					
					delete obj;
				endforeach;	
			elseif str = 'SOP_HMS_TableMaintForm' then
				//HMS Tables
				foreach cls in clsColl do  : clsLoop
					if cls.abstract 
					or cls.name = "SOPTM_Status" then
						continue clsLoop;
					endif;
					create obj as cls transient;
					if cls.getSuperclass() = sch.getClass('SOPTM_HMS') then
						
						file.writeLine(Tab &amp; Tab &amp; obj.sendMsg('getDisplayHeading').String);
					endif;
					delete obj;
				endforeach;	
			endif;
			foreach me3 in me2.allChildren do
				file.writeLine(Tab &amp; Tab &amp; me3.getQualFormListOutput);
				foreach me4 in me3.allChildren do
					file.writeLine(Tab &amp; Tab &amp; Tab &amp; me4.getQualFormListOutput);
				endforeach;
			endforeach;
		endforeach;
	endforeach;
	file.close;
	app.writeStatement(self.class.name &amp; ' &gt;&gt;' &amp; method.name &amp; " 3 - List of forms to file complete." );
epilog
	delete clsColl;
	delete file;
end;</source>
    </JadeMethod>
    <JadeMethod name="listPrinters" id="8a4281e8-4509-4077-86ad-8c9923a787b7">
        <source>listPrinters();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2013	cnwndl1	Initial creation

*/

vars

	printerArray : CnStringArray;		// Aug 2013, was StringArray, to test 32305
	printName : String;

begin

	create printerArray transient;
	global.getAllServerPrinters(printerArray);
	
	foreach printName in printerArray do
		write "(Server) " &amp; printName;
	endforeach;
	
	printerArray.clear();
	app.printer.getAllPrinters(printerArray);
	
	foreach printName in printerArray do
		write "(Local) " &amp; printName;
	endforeach;

epilog

	delete printerArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="listProcesses" id="cc149bb9-e053-4b5b-95a3-7451d1495f86">
        <source>listProcesses();

vars
	theNodes : NodeDict;
	theProcesses : ProcessDict; 
	aNode : Node;	
	aProcess : Process;
	invalidNode : Boolean;
	invalidProcess	: Boolean;
	nodeDesc : String;
	type : String;
	str	: String;	
begin
	on Exception do app.handleDeletedObject(exception, aNode, invalidNode);
	on Exception do app.handleDeletedObject(exception, aProcess, invalidProcess);
	theNodes := system.nodes.cloneSelf(true);
	
	foreach aNode in theNodes do
		// Clone the nodes collection of processes
		delete theProcesses;
		theProcesses := aNode.processes.cloneSelf(true);
		
		// If we had an exception accessing the node, then skip it
		if invalidNode then
			continue;
		endif;
		
		foreach aProcess in theProcesses do
		
			str := aProcess.persistentApp.name;			
			if invalidProcess then
				continue;
			endif;
			write aProcess.persistentApp.name;
			if aProcess.persistentApp.name = "InternalAPIService" then
				write aProcess.persistentApp.String;
			//		system.forceOffUser(aProcess.node, aProcess);
			endif;
		endforeach;
	endforeach;

end;
</source>
    </JadeMethod>
    <JadeMethod name="listRecentClassChanges" id="9c91f285-ac86-4e99-9dfd-d6f0515bdf21">
        <source>listRecentClassChanges();
// write all changed class entities in the given class since a given date
//  optionally by a given user
vars
	schemas : SchemaColl;
	scm : Schema;
	cls : Class;
	startTS : TimeStamp;
	modifiedBy,
	userId	: String;
	mth : Method;
	cnst : Constant;
	prop : Property;

begin

	startTS := "2011/08/22 10:32:00".TimeStamp;
	userId := "";
	scm := rootSchema.getSchema("UiCommonSchema");
	cls := scm.getClass("CM_ContainerEnqFormNEW");
	write CrLf &amp; scm.name &amp; " " &amp; cls.name &amp; " changes since " &amp; startTS.String;

	write " Class " &amp; cls.getName() &amp; "    " &amp; cls.getModifiedTimestamp.date.String &amp; "    " &amp; modifiedBy;
		
	foreach cnst in cls.getConstsProperty do
		if cnst.getModifiedTimestamp &gt;= startTS then
			modifiedBy := cnst.getModifiedByJMT();
			if userId &lt;&gt; null and
			   modifiedBy &lt;&gt; null and
			   modifiedBy &lt;&gt; userId then
				continue;
			endif;
			write " ClassConstant " &amp; cnst.qualifiedNameJMT() &amp; "    " &amp; cnst.getModifiedTimestamp.date.String &amp; "    " &amp; modifiedBy;
		endif;
	endforeach;

	foreach prop in cls.getPropertiesProperty do
		if prop.getModifiedTimestamp &gt;= startTS then
			modifiedBy := prop.getModifiedByJMT();
			if userId &lt;&gt; null and
			   modifiedBy &lt;&gt; null and
			   modifiedBy &lt;&gt; userId then
				continue;
			endif;
			write " Property " &amp; prop.qualifiedNameJMT() &amp; "    " &amp; prop.getModifiedTimestamp.date.String &amp; "    " &amp; prop.getModifiedByJMT();
		endif;
	endforeach;

	foreach mth in cls.getMethodsProperty do
		if mth.getModifiedTimestamp &gt;= startTS then
			modifiedBy := mth.getModifiedByJMT();
			if userId &lt;&gt; null and
			   modifiedBy &lt;&gt; null and
			   modifiedBy &lt;&gt; userId then
				continue;
			endif;
			write " Method " &amp; mth.qualifiedName() &amp; "    " &amp; mth.getModifiedTimestamp.date.String &amp; "    " &amp; mth.getModifiedByJMT();
		endif;
	endforeach;

	write "END";

epilog
	delete schemas;
end;
</source>
    </JadeMethod>
    <JadeMethod name="listRecentSchemaChanges" id="87e5d272-4978-44f9-88d7-380ca9bac14c">
        <source>listRecentSchemaChanges();
// write all changed schema entities in PortSchema and all sub-schemas since a given date
//  optionally by a given user
vars
	schemas : SchemaColl;
	scm : Schema;
	cls : Class;
	startTS : TimeStamp;
	modifiedBy,
	userId	: String;
	mth : Method;
	cnst : Constant;
	gcnst : Constant;
	prop : Property;
	prim : PrimType;

begin
	scm := rootSchema.getSchema("PortSchema");
	startTS := "2014/07/01 00:00:00".TimeStamp;
	userId := "cnwjre1";

	//startTS := "2011/08/01 00:00:00".TimeStamp;
	//userId := "";
	//scm := rootSchema.getSchema("UiCommonSchema");
	write CrLf &amp; scm.name &amp; " and sub-schema changes since " &amp; startTS.String &amp; " by " &amp; userId;

	create schemas transient;
	schemas.add(scm);
	// to list for the schema only, comment out the next line, otherwise all sub-schemas as well
	scm.allSubschemas(schemas);
	foreach scm in schemas do
		write CrLf &amp; "SCHEMA " &amp; scm.name;
		
		
		foreach gcnst in scm.getConstants do
			if gcnst.getModifiedTimestamp &gt;= startTS then
				modifiedBy := gcnst.getModifiedByJMT();
				if userId &lt;&gt; null and
				   modifiedBy &lt;&gt; null and
				   modifiedBy &lt;&gt; userId then
					continue;
				endif;
				write " GlobalConstant " &amp; gcnst.getName() &amp; "    " &amp; gcnst.getModifiedTimestamp.date.String &amp; "    " &amp; modifiedBy;
			endif;
		endforeach;
		
		foreach cls in scm.getClassesProperty do
			if cls.getModifiedTimestamp &gt;= startTS then
				modifiedBy := cls.getModifiedByJMT();
				if userId &lt;&gt; null and
				   modifiedBy &lt;&gt; null and
				   modifiedBy &lt;&gt; userId then
					continue;
				endif;
				write " Class " &amp; cls.getName() &amp; "    " &amp; cls.getModifiedTimestamp.date.String &amp; "    " &amp; modifiedBy;
			endif;
			
			foreach cnst in cls.getConstsProperty do
				if cnst.getModifiedTimestamp &gt;= startTS then
					modifiedBy := cnst.getModifiedByJMT();
					if userId &lt;&gt; null and
					   modifiedBy &lt;&gt; null and
					   modifiedBy &lt;&gt; userId then
						continue;
					endif;
					write " ClassConstant " &amp; cnst.qualifiedNameJMT() &amp; "    " &amp; cnst.getModifiedTimestamp.date.String &amp; "    " &amp; modifiedBy;
				endif;
			endforeach;

			foreach prop in cls.getPropertiesProperty do
				if prop.getModifiedTimestamp &gt;= startTS then
					modifiedBy := prop.getModifiedByJMT();
					if userId &lt;&gt; null and
					   modifiedBy &lt;&gt; null and
					   modifiedBy &lt;&gt; userId then
						continue;
				endif;
					write " Property " &amp; prop.qualifiedNameJMT() &amp; "    " &amp; prop.getModifiedTimestamp.date.String &amp; "    " &amp; prop.getModifiedByJMT();
				endif;
			endforeach;

			foreach mth in cls.getMethodsProperty do
				if mth.getModifiedTimestamp &gt;= startTS then
					modifiedBy := mth.getModifiedByJMT();
					if userId &lt;&gt; null and
					   modifiedBy &lt;&gt; null and
					   modifiedBy &lt;&gt; userId then
						continue;
					endif;
					write " Method " &amp; mth.qualifiedName() &amp; "    " &amp; mth.getModifiedTimestamp.date.String &amp; "    " &amp; mth.getModifiedByJMT();
				endif;
			endforeach;

		endforeach;
		
		foreach prim in scm.getPrimitivesProperty do
			foreach cnst in prim.getConstsProperty do
				if cnst.getModifiedTimestamp &gt;= startTS then
					modifiedBy := cnst.getModifiedByJMT();
					if userId &lt;&gt; null and
					   modifiedBy &lt;&gt; null and
				       modifiedBy &lt;&gt; userId then
						continue;
					endif;
					write " ClassConstant " &amp; cnst.qualifiedNameJMT() &amp; "    " &amp; cnst.getModifiedTimestamp.date.String &amp; "    " &amp; cnst.getModifiedByJMT();
				endif;
			endforeach;

			foreach mth in prim.getMethodsProperty do
				if mth.getModifiedTimestamp &gt;= startTS then
					modifiedBy := mth.getModifiedByJMT();
					if userId &lt;&gt; null and
				       modifiedBy &lt;&gt; null and
				       modifiedBy &lt;&gt; userId then
						continue;
					endif;
					write " Method " &amp; mth.qualifiedName() &amp; "    " &amp; mth.getModifiedTimestamp.date.String &amp; "    " &amp; mth.getModifiedByJMT();
				endif;
			endforeach;
		endforeach;
		
	endforeach;
	write "END";

epilog
	delete schemas;
end;
</source>
    </JadeMethod>
    <JadeMethod name="loadEntTableDefsFromConstant" id="61534397-d28d-4a95-8109-355728cf930a">
        <source>loadEntTableDefsFromConstant();
//--------------------------------------------------
// Created:	05 July 2005 By: cnwgd1
//--------------------------------------------------
vars
	deRef : Any;
	entTblAgent	: EntTableAgent;
	tmpArray : StringArray;
	agent : CM_TranslationAgent;
begin

	app.initialize();
	create entTblAgent transient;
	create agent transient;
	entTblAgent.myEntTableDataRoot := app.myRoot.myEntTableDataRoot;
	
	create tmpArray transient;
	
	// Add the EntTableGroups, EntTableDefs and/or EntTableRows
	// constant names for add/update to tmpArray. Note dependencies.

	// ################################
	// Example:
	// ################################

/*	// All groups first as rows and defs are dependant on group
	deRef := ETGrp_AATestGroup; //&lt;&lt;-- reference global constant for extract
	tmpArray.add('ETGrp_AATestGroup'); //&lt;-- add constant name to array

	// All rows second as rows are dependant on group and defs are dependant on rows
	deRef := ETRow_AATestRow; //&lt;&lt;-- reference global constant for extract
	tmpArray.add('ETRow_AATestRow'); //&lt;-- add constant name to array
	
	// All Defs last as defs are dependant on rows and groups
	deRef := ETDef_AATestDef; //&lt;&lt;-- reference global constant for extract	
	tmpArray.add('ETDef_AATestDef'); //&lt;-- add constant name to array
*/

	// ################################
	// ### ACTUAL PARS
	// ################################
//CCMS1743/1764 STARTS HERE	
	//cnwrd1 10.11.08 CCMS JMT 1743/1764 
	// All groups first as rows and defs are dependant on group
	/*OperatorMaint
	TrackedItemDetails
	GateReceivals
	deRef := ETGrp_OperatorMaint; //&lt;&lt;-- reference global constant for extract
	tmpArray.add('ETGrp_OperatorMaint'); //&lt;-- add constant name to array
	
	deRef := ETGrp_TrackedItemDetails; //&lt;&lt;-- reference global constant for extract
	tmpArray.add('ETGrp_TrackedItemDetails'); //&lt;-- add constant name to array
	
	deRef := ETGrp_GateReceivals; //&lt;&lt;-- reference global constant for extract
	tmpArray.add('ETGrp_GateReceivals'); //&lt;-- add constant name to array	

	// All rows second as rows are dependant on group and defs are dependant on rows
	/*
	ETRow_RequiresExpOperatorNo
	ETRow_RequiresImpOperatorPIN
	ETRow_RequiresImpFF
	ETRow_ExportReleaseNumber
	ETRow_ImportReleasePIN
	ETRow_OperatorImportReleasePIN
	

	deRef := ETRow_RequiresExpOperatorNo; //&lt;&lt;-- reference global constant for extract
	tmpArray.add('ETRow_RequiresExpOperatorNo'); //&lt;-- add constant name to array
	
	deRef := ETRow_RequiresImpOperatorPIN; //&lt;&lt;-- reference global constant for extract
	tmpArray.add('ETRow_RequiresImpOperatorPIN'); //&lt;-- add constant name to array
	
	deRef := ETRow_RequiresImpFF; //&lt;&lt;-- reference global constant for extract
	tmpArray.add('ETRow_RequiresImpFF'); //&lt;-- add constant name to array
	
	deRef := ETRow_ExportReleaseNumber; //&lt;&lt;-- reference global constant for extract
	tmpArray.add('ETRow_ExportReleaseNumber'); //&lt;-- add constant name to array
	
	deRef := ETRow_ImportReleasePIN; //&lt;&lt;-- reference global constant for extract
	tmpArray.add('ETRow_ImportReleasePIN'); //&lt;-- add constant name to array
	
	deRef := ETRow_OperatorImportReleasePIN; //&lt;&lt;-- reference global constant for extract
	tmpArray.add('ETRow_OperatorImportReleasePIN'); //&lt;-- add constant name to array
	
	// All Defs last as defs are dependant on rows and groups
	/*ETDef_OperatorMaint
	ETDef_StatusData
	ETDef_FullReleaseMain
	ETDef_FullReleaseThumb
	ETDef_OutMain
	
	deRef := ETDef_OperatorMaint; //&lt;&lt;-- reference global constant for extract	
	tmpArray.add('ETDef_OperatorMaint'); //&lt;-- add constant name to array
	
	deRef := ETDef_StatusData; //&lt;&lt;-- reference global constant for extract	
	tmpArray.add('ETDef_StatusData'); //&lt;-- add constant name to array
	
	deRef := ETDef_FullReleaseMain; //&lt;&lt;-- reference global constant for extract	
	tmpArray.add('ETDef_FullReleaseMain'); //&lt;-- add constant name to array
	
	deRef := ETDef_FullReleaseThumb; //&lt;&lt;-- reference global constant for extract			
	tmpArray.add('ETDef_FullReleaseThumb'); //&lt;-- add constant name to array
	
	deRef := ETDef_OutMain; //&lt;&lt;-- reference global constant for extract	
	tmpArray.add('ETDef_OutMain'); //&lt;-- add constant name to array

	deRef := ETDef_InExtra; //&lt;&lt;-- reference global constant for extract	
	tmpArray.add('ETDef_InExtra'); //&lt;-- add constant name to array
	
	deRef := ETDef_PreNoteThumb; //&lt;&lt;-- reference global constant for extract	
	tmpArray.add('ETDef_PreNoteThumb'); //&lt;-- add constant name to array
	
	deRef := ETDef_ContainerData; //&lt;&lt;-- reference global constant for extract	
	tmpArray.add('ETDef_ContainerData'); //&lt;-- add constant name to array*/
//CCMS1743/1764 ENDS HERE	
	
//	//CCMS1765 - Discrepancy reports for weight and seals - GDANSK 24/11/2008
//	deRef := ETDef_TransactionDiscrepancy;
//	tmpArray.add('ETDef_TransactionDiscrepancy');

	//deRef := ETDef_EDITIBookingRef;
	//tmpArray.add('ETDef_EDITIBookingRef');
	deRef := IsShipLanderSealCheck;
	deRef := ETRow_IsShipLanderSealCheck;
	tmpArray.add('ETRow_CooFreeDays');
	
	// Do update/add Entry Table global constants
	entTblAgent.trxUpdateFromConstant(tmpArray);
	app.finalize();
epilog
	delete entTblAgent;
	delete tmpArray;
end;







</source>
