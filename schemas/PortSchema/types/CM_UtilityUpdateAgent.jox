	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realISOTypeGroup, true);
	endif;
	
	if _passport.noErrors then
		if realISOTypeGroup.colour &lt;&gt; pProxyISOTypeGroup.colour then
			codeChanged := true;
		endif;
		realISOTypeGroup.setForUpdate(pProxyISOTypeGroup);
	endif;

	if _passport.noErrors then
		if codeChanged then
			eventStr := eventStr &amp;  "&lt;" &amp; GridXML_ColourCode &amp; "&gt;" &amp; realISOTypeGroup.code  &amp; "&lt;/" &amp; GridXML_ColourCode &amp; "&gt;";
			eventStr := eventStr &amp;  "&lt;" &amp; GridXML_Colour &amp; "&gt;" &amp; realISOTypeGroup.colour.String  &amp; "&lt;/" &amp; GridXML_Colour &amp; "&gt;";
			realISOTypeGroup.causeEvent(EVENT_CODE_COLOUR_CHANGE, false, eventStr);
		endif;
		self.myUpdateAuditAgent.audUpdateGeneric(realISOTypeGroup, false);
