    <JadeMethod name="trxCreateTruckSealCheckTrans" id="634cdb5e-bd32-4117-a675-d7671ffa3ab2">
        <updating/>
        <source>trxCreateTruckSealCheckTrans(_pxySealCheckDetails : CM_SealCheckDetailSet; _vvr : CM_VehicleVisitRecord input; _allSealsToUpdate : CM_SealObjectBySealTypeDict; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 April 2023		jlizm1	Initial creation TFS 57098 EUP Seal numbers on trucks
01 Apr 2025			navah1	Story 34454: MTN - Deferred Updates For Event - For Create And Update Truck Seals
*/

vars
	vvrd : CM_VehicleVisitRecordDetail;
	seal : CM_SealObject;
	pxyTruckSeal : CM_TruckSeal;
	realTruckSeal : CM_TruckSeal;
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false); 
	_passport.useEventDeferUpdate := true; //01.04.2025 navah1 #34454
	
	// Start the transaction
	beginTransaction;
	
	vvrd := _vvr.createVisitRecordDetail(VisitRecord_SealCheck, null, null);
	
	if vvrd &lt;&gt; null and _pxySealCheckDetails &lt;&gt; null then
		if vvrd.myEvent &lt;&gt; null and vvrd.myEvent.isKindOf(CMEVT_TruckEvent) then
			vvrd.myEvent.CMEVT_TruckEvent.setTruckSealCheckDetails(_pxySealCheckDetails);
		endif;
	endif;

	if app.myPassport.hasErrorsOrWarnings then
		return;
	endif;
		
	if _allSealsToUpdate &lt;&gt; null and not _allSealsToUpdate.isEmpty then
		
		foreach seal in _allSealsToUpdate do
			pxyTruckSeal := seal.CM_TruckSeal;
			realTruckSeal := _vvr.allTruckSeals.getTruckSeal(pxyTruckSeal.getMySealTypeObj);

			app.myUtilityUA.utlUpdateTruckSeal(pxyTruckSeal, realTruckSeal, app.myPassport);
		
			if app.myPassport.hasErrorsOrWarnings then
				return;
			endif;
		endforeach;
	
	endif;
	
	if _passport.noErrors then //01.04.2025 navah1 #34454 
		app.myPassport.doDeferredUpdates();  
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_pxySealCheckDetails" type="CM_SealCheckDetailSet"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord" usage="input"/>
        <Parameter name="_allSealsToUpdate" type="CM_SealObjectBySealTypeDict"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateTug" id="83af67c5-2843-4a44-9fb0-18650e2637df">
