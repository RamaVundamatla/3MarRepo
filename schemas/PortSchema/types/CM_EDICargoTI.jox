    <JadeMethod name="verifySalesOrderNbr" id="7c2f3f0c-5af1-4298-a76a-12c61c616e6b">
        <updating/>
        <source>verifySalesOrderNbr() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 28/11/2013	cnwdap1		Initial creation PAR #33019 CCMS DPH 2285 New BOL Fields
// 09/12/2013	cnwdap1		PAR #33149 Pass self through to exception so error in EDI form is double-clickable
// 31/08/2023	navdap1		TFS 60205 EUP | FR 53824 - Client Ref / Sales Order Number Validation
//
vars
	value : String;

begin
	value := self.getSalesOrderNbr();
	// TFS 60205 numeric validation is not required for clientRef / salesOrderNumber in Euroports-related EDI formats
	if self.myEDIData.isCallOffRelated or self.myEDIData.isTransportManifestRelated then
		return;
	endif;
	// TFS 60205 end
	
	if value &lt;&gt; null and not value.cnIsNumeric then
		//app.raiseCMException2(ERR_FIELD_SALESORDERNBR, value, "Sales Order Nbr", "salesOrderNbr", null);	// PAR #33149
		app.raiseCMException2(ERR_FIELD_SALESORDERNBR, value, "Sales Order Nbr", "salesOrderNbr", self);	// PAR #33149
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="verifySelf" id="948829aa-3e78-4c1f-b12d-bd5e9e76f57f">
        <updating/>
        <source>verifySelf() updating;
/*
----------   ----------  --------------------------------------------------
Created:	02 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
30 Jan 2012	cnwrs1	Par 29024
14 Aug 2013	cnwdap1	PAR #32123 validate colour if config option set
20 Sep 2013 cnwdap1	PAR #32215 CCMS DPH 2290 New Car Attributes
27 Nov 2013	cnwdap1	PAR #33019 CCMS DPH 2285 new BOL Fields
04 Feb 2014 cnwah9  Par 33402
08 Dec 2014 cnwdb2	PAR 35364
08 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks
15 Jan 2018	jlgrs1	TFS 36636 STW Cargo By Site to be partial loading
04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
02 Oct 2020 cnwma1  ChangeRequest 50112: ASPA - GCI Stevedores
04 Aug 2022	navma1	ChangeRequest 54219: EUP - Cargo Group to be mandatory
22 Sep 2022 navvt20 Bug 54653: MTN - EDI - Using Internal CargoOnSite format allowing Cargo Type defined with 'Allow Duplicate Ids' set to false to have a Total Quantity &gt; 1
29 Nov 2022	jlika1	TFS 55586 HS Code User Defined EDI
19 Jun 2023	navdap1	TFS 56747 EUP Manifest Processing - Internal (Zimmer) - Create
23 Jun 2023	navdap1	TFS 58813 EUP - Manifest Instructions
04 Sep 2023	jlirs1	TFS 59148 (57770) IFCSUM Port of Origin BOP
15 Feb 2024 navhn30	ChangeRequest 61657: EUP | FR 53824 Transport Manifest - Shipping Line Should Be Validated For a Data Item
01/04/2025	navcs2	MTN-34491 EUP FR | 53824 - No errors when weights and quantities are zero
*/
vars
	terminal			: CM_Terminal;
	voyage				: CM_Voyage;
	existingItem		: CM_TrackedItem;
	site				: Integer;
	trxStateEntered		: Boolean;
	skipOnsiteCheck		: Boolean;
	allowDupPrenotes	: Boolean;
begin
	terminal := self.getMyTerminal();

	if terminal = null then
		app.raiseCMException1(Err_InvalidTerminal, 'null', null, null);
		return;
	endif;
	allowDupPrenotes := terminal.getConfig(AllowDuplicatePreNotes).Boolean;	//02.Nov.2023 navsp1 TFS 61067
	if id.trimBlanks = null then
		app.raiseCMException2(ERR_FIELD_ID,id, 'ID', ETRow_Id, self);
	endif;
	
	if self.isTransportManifestRelated then
		if self.totalQuantity &lt; 1 then																												// 01/04/2025	navcs2	MTN-34491
			app.raiseCMException1(Must_greater_than_zero, app.getErrorString(CM_Total_Quantity), app.getErrorString(CM_Total_Quantity), self);		// 01/04/2025	navcs2	MTN-34491
		endif;																																		// 01/04/2025	navcs2	MTN-34491
		
		if self.getTotalWeight &lt;= 0 then																											// 01/04/2025	navcs2	MTN-34491
			app.raiseCMException1(Must_greater_than_zero, app.getErrorString(Total_weight), app.getErrorString(Total_weight), self);				// 01/04/2025	navcs2	MTN-34491
		endif;																																		// 01/04/2025	navcs2	MTN-34491
		
		if self.myCargoType.isTrackByVolume then																									// 01/04/2025	navcs2	MTN-34491
			if self.volume &lt;= 0 then																												// 01/04/2025	navcs2	MTN-34491
				app.raiseCMException1(Must_greater_than_zero, app.getErrorString(Volume), app.getErrorString(Volume), self);						// 01/04/2025	navcs2	MTN-34491
			endif;																																	// 01/04/2025	navcs2	MTN-34491
		endif;																																		// 01/04/2025	navcs2	MTN-34491
	endif;																																			// 01/04/2025	navcs2	MTN-34491
	
	//cnwmc5 - 11 Dec 2013 - PAR 33088
	if self.id.length &gt; 20 then
		app.raiseCMException2(ContainerIdToLong, self.id, '20', ETRow_Id, self);
	endif;
	
	//cnwmc5 - 2 May 2014 - PAR 34057
	if self.messageMode = CM_EDITrackedItem.EDI_ACTION_MODIFY then
		return;
	endif;
	
	//No need to verify all the values if it's a "Cancel" request for the transport manifest.					//25.Jan.24 navsp1 TFS 62193
	if self.myEDIData.isTransportManifestRelated and self.messageMode = CM_EDITrackedItem.EDI_ACTION_DELETE then
		return;
	endif;
	
	skipOnsiteCheck := false;
	if CM_EDIDataCargo.hasInstance(self.myEDIData) then
		site := self.myEDIData.CM_EDIDataCargo.createToSite;
	elseif CM_EDIDataDeckPlan.hasInstance(self.myEDIData) or (self.myEDIData.isTransportManifestRelated and CM_EDIDataShipManifest.hasInstance(self.myEDIData)) then	//02.Nov.2023 navsp1 TFS 61067
		site := TI_SITE_ONSHIP;
	elseif CM_EDIDataCargoOnSite.hasInstance(self.myEDIData) and self.myEDIData.isTransportManifestRelated then	// TFS 56747
		site := TI_SITE_ONSITE;																					// TFS 56747
		skipOnsiteCheck := true;		//04.Oct.2023 navsp1 TFS 58058 - Skippin the onsite check as this format need to process the update/cancel message for the same set of TIs.
	endif;
	//th2 for PAR13553 - can already be in transaction state if the user
	//clicks on the 'save and verify' button
	if (not process.isInTransactionState) then
		trxStateEntered := true;
		beginTransaction;	//par 13451 cnwrs1 Feb 2007 this should not be necassary as verifies should be non updating
	endif;

	self.verifyCargoType();
	self.verifyISOType();
	self.verifyCarrier();
	self.verifyCommodity();
	self.verifyConsignee();
	self.verifyConsignor();
	self.verifyIMEXStatus(terminal);
	self.verifyPorts(terminal);
	self.verifyDestination();		//04 Sep 2023	jlirs1	TFS 59148 (57770) IFCSUM Port of Origin BOP
	self.verifyPortOfOrigin();		//04 Sep 2023	jlirs1	TFS 59148 (57770) IFCSUM Port of Origin BOP	
	self.verifyHazards();
	self.verifyCompany(terminal);
	self.verifyOperator();
	self.verifyProduct();
	self.verifyVolume();
	self.verifyWeight();
	self.verifyTemperature();
	self.verifyAvailabilityGrade();	// cnwrl1 03/02/2010 PAR 21758
	self.verifyTrailerType(); 		// PAR 22476 cnwgb1 26.2.2010
	self.verifyCustomsAgent();		//31 Oct 2012	NDL	Par 30645
	self.verifyTransportMode();		//31 Oct 2012	NDL	Par 30645
	self.verifyAlternateId();		//06 May 2013	NDL	Par 31506
	self.verifyColour();			//14 Aug 2013	DMP Par 32123
	self.verifyVehicleMake();		//20 Sep 2013	DMP Par 32215
	self.verifyVehicleModel();		//20 Sep 2013	DMP Par 32215
	self.verifyVehicleType();		//20 Sep 2013	DMP Par 32215
	self.verifySalesOrderNbr();		//27 Nov 2013	DMP Par 33019
	self.verifyReceiveStevedore();  //02.10.2020 cnwma1 TFS #50112
	self.verifyReleaseStevedore();  //02.10.2020 cnwma1 TFS #50112
	self.verifyCargoGroup();		//04.08.2022 navma1 #54219
	self.verifyHSCode();
	self.verifySortingMethod();		// TFS 56747
	self.verifyInstructionType();	// TFS 58813
	self.verifyShippingLineCodeForTI();		//	15.02.24	navhn30		TFS #61657
	
	if not self.cargoTypeAllowsDuplicates and self.totalQuantity  &gt; 1		// navvt20 22 Sept 2022 TFS 54653
	and not self.cargoTypeIsCargoGroup then								// TFS 58813
		app.raiseCMException(ERR_TOT_QUAN_ONE,"",self);						// navvt20 22 Sept 2022 TFS 54653
	endif;																	// navvt20 22 Sept 2022 TFS 54653
	voyage := self.verifyVoyage(terminal, self.site);
	self.verifyLocation(terminal, voyage, site, false);	// 30 Jan 2012	cnwrs1	Par 29024
	if trxStateEntered then
		commitTransaction;
	endif;
	
	if site = TI_SITE_ONSITE then
		if not skipOnsiteCheck then										//04.Oct.2023 navsp1 TFS 58058
			existingItem := terminal.allOnsiteTIsByCargoTypeId[self.cargoType, self.id];
			if existingItem &lt;&gt; null then
				app.raiseCMException1(ERR_DUP_ONSITE_TI, self.id, ETRow_Id, self);
			endif;
		endif;
	elseif site = TI_SITE_ONSHIP then
		voyage := terminal.lookupVoyage(self.getVoyageCode(), null, false);
		if voyage &lt;&gt; null then
			existingItem := voyage.allOnshipTIsByCargoTypeId[self.cargoType, self.id];
			if existingItem &lt;&gt; null and not allowDupPrenotes then						//02.Nov.2023 navsp1 TFS 61067
				app.raiseCMException2(Ship_already_exists, self.id, self.getVoyageCode(), ETRow_Id, self); // cnwdb2 PAR 35364
				
			endif;
		endif;
	elseif site = TI_SITE_TBA then
		existingItem := terminal.allNotifiedTIsByCargoTypeId[self.cargoType, self.id];
		if existingItem &lt;&gt; null then
			app.raiseCMException1(ERR_DUP_NOTIFIED_TI, self.id, ETRow_Id, self);
		endif;
	endif;
	self.verifyParentage(terminal);
	
	self.verifyCountryOfOrigin(); //jlier1 TFS 54846 30/9/22
end;</source>
    </JadeMethod>
    <JadeMethod name="verifySelfDeckPlan" id="d8ae72c1-7526-4656-bffe-2bab7740d88b">
        <updating/>
        <source>verifySelfDeckPlan(_isLocalId : Boolean) updating;
/*
----------   ----------  --------------------------------------------------
Created:	02 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
30 Jan 2012	cnwrs1	Par 29024
14 Aug 2013	cnwdap1	PAR #32123 validate colour if config option set
20 Sep 2013 cnwdap1	PAR #32215 CCMS DPH 2290 New Car Attributes
27 Nov 2013	cnwdap1	PAR #33019 CCMS DPH 2285 new BOL Fields
04 Feb 2014 cnwah9  Par 33402
08 Dec 2014 cnwdb2	PAR 35364
// 08 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/
vars
	terminal			: CM_Terminal;
	voyage				: CM_Voyage;
	existingItem		: CM_TrackedItem;
	site				: Integer;
	trxStateEntered		: Boolean;
begin
	terminal := self.getMyTerminal();
	if terminal = null then
		app.raiseCMException1(Err_InvalidTerminal, 'null', null, null);
		return;
	endif;
	
	if id.trimBlanks = null then
		app.raiseCMException2(ERR_FIELD_ID,id, 'ID', ETRow_Id, self);
	endif;
	//cnwmc5 - 11 Dec 2013 - PAR 33088
	if self.id.length &gt; 20 then
		app.raiseCMException2(ContainerIdToLong, self.id, '20', ETRow_Id, self);
	endif;
	
	//cnwmc5 - 2 May 2014 - PAR 34057
	if self.messageMode = CM_EDITrackedItem.EDI_ACTION_MODIFY then
		return;
	endif;
	
	if CM_EDIDataCargo.hasInstance(self.myEDIData) then
		site := self.myEDIData.CM_EDIDataCargo.createToSite;
	elseif CM_EDIDataDeckPlan.hasInstance(self.myEDIData) then
		site := TI_SITE_ONSHIP;
	endif;
	//th2 for PAR13553 - can already be in transaction state if the user
	//clicks on the 'save and verify' button
	if (not process.isInTransactionState) then
		trxStateEntered := true;
		beginTransaction;	//par 13451 cnwrs1 Feb 2007 this should not be necassary as verifies should be non updating
	endif;
	
	self.verifyCargoType();
	self.verifyISOType();
	self.verifyCarrier();
	self.verifyCommodity();
	self.verifyConsignee();
	self.verifyConsignor();
	self.verifyIMEXStatus(terminal);
	self.verifyPorts(terminal);
	self.verifyHazards();
	self.verifyCompany(terminal);
	self.verifyOperator();
	self.verifyProduct();
	self.verifyVolume();
	self.verifyTemperature();
	self.verifyAvailabilityGrade();	// cnwrl1 03/02/2010 PAR 21758
	self.verifyTrailerType(); 		// PAR 22476 cnwgb1 26.2.2010
	self.verifyCustomsAgent();	//31 Oct 2012	NDL	Par 30645
	self.verifyTransportMode();	//31 Oct 2012	NDL	Par 30645
	self.verifyAlternateId();	//06 May 2013	NDL	Par 31506
	self.verifyColour();		//14 Aug 2013	DMP Par 32123
	self.verifyVehicleMake();	//20 Sep 2013	DMP Par 32215
	self.verifyVehicleModel();	//20 Sep 2013	DMP Par 32215
	self.verifyVehicleType();	//20 Sep 2013	DMP Par 32215
	
	self.verifySalesOrderNbr();	//27 Nov 2013	DMP Par 33019
	
	voyage := self.verifyVoyage(terminal, self.site);
	self.verifyLocation(terminal, voyage, site, _isLocalId);	// 30 Jan 2012	cnwrs1	Par 29024
	if trxStateEntered then
		commitTransaction;
	endif;
	
	if site = TI_SITE_ONSITE then
		existingItem := terminal.allOnsiteTIsByCargoTypeId[self.cargoType, self.id];
		if existingItem &lt;&gt; null then
			app.raiseCMException1(ERR_DUP_ONSITE_TI, self.id, ETRow_Id, self);
		endif;
	elseif site = TI_SITE_ONSHIP then
//		voyage := terminal.lookupVoyage(self.voyageCode, null, false);	// cnwrl1 09/06/2010 PAR 24299 - what it was
		voyage := terminal.lookupVoyage(self.getVoyageCode(), null, false);
		if voyage &lt;&gt; null then
			existingItem := voyage.allOnshipTIsByCargoTypeId[self.cargoType, self.id];
			if existingItem &lt;&gt; null then
//				app.raiseCMException3(ERR_DUPLICATE_KEY, self.id, ' on ship ' &amp; self.voyageCode, null, ETRow_Id, self);	// cnwrl1 09/06/2010 PAR 24299 - what it was
				app.raiseCMException2(Ship_already_exists, self.id, self.getVoyageCode(), ETRow_Id, self); // cnwdb2 PAR 35364
				
			endif;
		endif;
	elseif site = TI_SITE_TBA then
		existingItem := terminal.allNotifiedTIsByCargoTypeId[self.cargoType, self.id];
		if existingItem &lt;&gt; null then
			app.raiseCMException1(ERR_DUP_NOTIFIED_TI, self.id, ETRow_Id, self);
		endif;
	endif;
	
end;
</source>
        <Parameter name="_isLocalId" type="Boolean"/>
    </JadeMethod>
