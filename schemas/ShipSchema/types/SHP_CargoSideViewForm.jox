    <JadeMethod name="doBtnUnplanReleaseClick" id="e7eea149-0198-4dd2-ac92-b3ab55c37ee9">
        <source>doBtnUnplanReleaseClick();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 December 2012	cnwrd1	Initial creation

*/

vars

	anObj : Object;
	tmpWLE : CM_WorkListEntry;
	aTI : CM_TrackedItem;
	str : String;
	idx : Integer;
	ls : Boolean;
	tmpSlots : CM_LCArray;
	aReq	: CM_RORORequest;
begin
	if self.myROROLocnDrawingController.allSelectedObjects.isEmpty then
		return;
	endif;

	create tmpSlots transient;
	
	foreach anObj in self.myROROLocnDrawingController.allSelectedObjects do
	
		if anObj.isKindOf( CM_VoyageROROController)	then
			aReq := anObj.CM_VoyageROROController.myRORORequestLoad.CM_RORORequest;
			
			if aReq.myBulkReleaseReserveDetail &lt;&gt; null then
				tmpSlots.add(anObj.CM_VoyageROROController);
			endif;
		endif;
	endforeach;

	// PAR 18695
	
	if tmpSlots.isEmpty() then
		app.msgBox("Please select some cargo to unplan.","Problem",MsgBox_OK_Only);
		return;
	else
		if app.msgBox(app.getErrorString(Unplan_GC) &amp; str &amp; "?", app.getErrorString(SHP_Confirm_Unplan_Cargo),MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			global.beep;
			return;
		endif;
	endif;
	
	app.cmsBeginLoad(ls);
	self.myROROPlanningForm.doUnplanBulkReleases(tmpSlots);
epilog
	delete tmpSlots;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBuildMenuCargo" id="3e6b2037-8d83-4f3a-8f59-386d346ec565">
        <updating/>
        <source>doBuildMenuCargo(_theTI : CM_TrackedItem input) updating;
/*
Date		    Who			Reason
29 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars

begin
	self.mnuRemarks.userObject := _theTI;
	self.mnuRemarks.caption := app.getErrorString(Remarks_GC) &amp; _theTI.id;
	
	//epr par 32261 19/8/13
	self.myAssistant.menuSetGradeBuild(self.mnuCargoSetGrade,self.mnuCargoSetGradeSub,_theTI);
	
	self.doBuildUnplanMenu(self.mnuCargoUnplan,self.mnuCargoUnqueue, _theTI);
	
	if self.canAccessTodoTasksAddRemove then		
		self.doBuildMnuTasksAdd(_theTI);																			
	endif;																				

	if self.canAccessTodoTasksComplete then		
		self.doBuildMnuTasksComplete(_theTI);	
	endif;
	
	if self.canAccessTodoTasksAddRemove then
		self.doBuildMnuTasksRemove(_theTI);	
	endif;	
	
	self.mnuStops.userObject := _theTI;	
	

epilog
	
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuTasksAdd" id="d523f8dc-8aaf-4dbb-be09-fb31bf527fbd">
        <updating/>
        <source>doBuildMnuTasksAdd(_theTI : CM_TrackedItem input) updating;
/*
Date		    Who			Reason
29 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars

	dynaDict			: DynaDictionary;
	obj					: Object;
	taskDesc			: CM_ToDoTaskDesc;
	mnuChild,mnuMaster	: MenuItem;
	taskDict			: CM_ToDoTaskDescByCode;
	useTaskForm 		: Boolean;
	
begin

	//07 Oct 2015	NDL	Par 37011
	useTaskForm := self.myTerminal.getConfig(UseTaskFormCount).Boolean;
	if useTaskForm then
		self.mnuTaskAdd.visible := false;
		self.mnuCargoTaskAdd.visible := true;
		self.mnuCargoTaskAdd.userObject := _theTI;
		return;
	endif;
	
	create taskDict transient;
	app.myPassport.myUser.getToDoTasksAddRemoveForTerm(self.myTerminal, taskDict);
	if taskDict.isEmpty then
		// no permission to add any tasks
		self.mnuTaskAdd.visible := false;
		return;
	endif;

	// ##############################################
	// Build up menu of ToDo Tasks that can be set
	mnuMaster := self.mnuTaskAdd;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	mnuMaster.caption :=  app.getErrorString(Tasks_ADDDDdd); 	//"Add Tasks";
	self.mnuTaskAddSub.visible := true;
	// 36868 sort menu items by sortKey then description, so that if there is no sort key or it is not unique then the description becomes the main sort field
	create dynaDict transient;
	dynaDict.setMembership(CM_ToDoTaskDesc);
	dynaDict.addMemberKey("sortKey", false, true);
	dynaDict.addMemberKey("description", false, true);
	dynaDict.endKeys(true);
	foreach taskDesc in taskDict do
		dynaDict.add(taskDesc);
	endforeach;

	foreach obj in dynaDict do
		taskDesc := obj.CM_ToDoTaskDesc;
		// Always delete the tasks to complete menu
		mnuChild := mnuTaskComplete.getMenuItem(taskDesc.code); // check if the menu is already cloned
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;
		mnuChild := mnuTaskRemove.getMenuItem(taskDesc.code); // check if the menu is already cloned
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;

		if taskDesc.description = null then 
			continue;
		endif;
		
			// DVB added to screen for cargo type.
		if not taskDesc.isAvailableForCargoType(_theTI.cargoType) then
			continue;
		endif;
		
		// Par 17775. ccms1045. APM - Yard Ops, new generator Types. August 2008
		if not taskDesc.isValidForGenSet( _theTI ) then
			mnuChild := mnuMaster.getMenuItem(taskDesc.code); // check if the menu is already cloned
			if mnuChild &lt;&gt; null then
				delete mnuChild;
			endif;
			continue;
		endif;

		// add each todo task type into the add menu
		mnuChild := mnuMaster.getMenuItem(taskDesc.code); // check if the menu is already cloned
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;
		self.mnuTaskAddSub.visible := false;
		mnuChild := mnuMaster.loadSubMenu(taskDesc.code); // Clone menu
		mnuChild.caption := taskDesc.description;
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.helpKeyword := taskDesc.description;
		mnuChild.userObject := _theTI;
	endforeach;

epilog
	delete taskDict;
	delete dynaDict;
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuTasksComplete" id="9726baa4-4a32-45c8-9d33-6cdcd8c6303c">
        <updating/>
        <source>doBuildMnuTasksComplete(_theTI : CM_TrackedItem input) updating;
/*
Date		    Who			Reason
29 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/


vars

	task	: CM_ToDoTask;
	taskDesc	: CM_ToDoTaskDesc;
	idx	: Decimal[3,1];
	lFactor : Real;
	lIndex,lMoveMode : Integer;
	lCaption	: String;
	mnuChild,mnuMaster	: MenuItem;
	mnuIndex 	: Integer;
	lPicture : Picture;
	root : CM_Root;
	taskDict		: CM_ToDoTaskDescByCode;
	useTaskForm : Boolean;

begin

	//07 Oct 2015	NDL	Par 37011
	useTaskForm := self.myTerminal.getConfig(UseTaskFormCount).Boolean;
	if useTaskForm then
		self.mnuTaskComplete.visible := false;
		self.mnuCargoTaskComplete.visible := true;
		self.mnuCargoTaskComplete.userObject := _theTI;
		self.mnuCargoTaskRemarks.visible := true;
		self.mnuCargoTaskRemarks.userObject := _theTI;
		return;
	endif;


	taskDict := app.myPassport.myUser.getToDoTasksCompleteForTerm(self.myTerminal);
	if taskDict.isEmpty then
		// no permission to complete any tasks
		self.mnuTaskComplete.visible := false;
		return;
	endif;

	// ##############################################
	// Build up menu of ToDo Tasks that have been set, but are uncomplete
	mnuMaster := self.mnuTaskComplete;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	mnuMaster.caption := "Complete Tasks";
	self.mnuTaskCompleteSub.visible := true;
	self.mnuTaskCompleteSub.caption := "No Tasks";
	
	foreach task in _theTI.allToDoTasksToDo do
	
		// Hide the todo tasks inthe add menu that we already have to do
		mnuChild := self.mnuTaskAdd.getMenuItem(task.toDoTaskDescCode); // check if the menu is already cloned
		if mnuChild &lt;&gt; null then
			mnuChild.visible := false;
		endif;
		
		if (not taskDict.includes(task.toDoTaskDesc)) then
			// user does not have permission to complete this task
			continue;
		endif;
		
		if task.toDoTaskDesc.isForGenSetAttachDetach() then	//Par17775. ccms 1045. Attach / detach generator cannot be completed manually
			continue;
		endif;

		// create a list of the todo tasks that we have to do
		mnuChild := mnuMaster.getMenuItem(task.toDoTaskDescCode); // check if the menu is already cloned
		// always delete as this is different for each TI
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;
		self.mnuTaskCompleteSub.visible := false;
		mnuChild := mnuMaster.loadSubMenu(task.toDoTaskDescCode); // Clone menu
		mnuChild.caption := task.toDoTaskDescDesc;
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.helpKeyword := task.toDoTaskDescDesc;
		mnuChild.userObject := _theTI;
	endforeach;

	
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doBuildMnuTasksRemove" id="2bd4e65e-3523-41ff-a4d1-a0284c58f715">
        <updating/>
        <source>doBuildMnuTasksRemove(_theTI : CM_TrackedItem input) updating;
/*
Date		    Who			Reason
29 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars

	task	: CM_ToDoTask;
	taskDesc	: CM_ToDoTaskDesc;
	idx	: Decimal[3,1];
	lFactor : Real;
	lIndex,lMoveMode : Integer;
	lCaption	: String;
	mnuChild,mnuMaster	: MenuItem;
	mnuIndex 	: Integer;
	lPicture : Picture;
	root : CM_Root;
	taskDict		: CM_ToDoTaskDescByCode;
	useTaskForm : Boolean;

begin

	//07 Oct 2015	NDL	Par 37011
	useTaskForm := self.myTerminal.getConfig(UseTaskFormCount).Boolean;
	if useTaskForm then
		self.mnuTaskRemove.visible := false;
		self.mnuCargoTaskRemove.visible := true;
		self.mnuCargoTaskRemove.userObject := _theTI;
		return;
	endif;
	create taskDict transient;
	app.myPassport.myUser.getToDoTasksAddRemoveForTerm(self.myTerminal, taskDict);
	if taskDict.isEmpty then
		// no permission to remove any tasks
		self.mnuTaskRemove.visible := false;
		return;
	endif;

	// ##############################################
	// Build up menu of ToDo Tasks that have been set, but are uncomplete
	mnuMaster := self.mnuTaskRemove;
	mnuMaster.visible := true;
	mnuMaster.enabled := true;
	mnuMaster.caption := "Remove Tasks";
	self.mnuTaskRemoveSub.visible := true;
	self.mnuTaskRemoveSub.caption := "No Tasks";
	
	foreach task in _theTI.allToDoTasksToDo do
	
		// Hide the todo tasks inthe add menu that we already have to do
		mnuChild := self.mnuTaskAdd.getMenuItem(task.toDoTaskDescCode); // check if the menu is already cloned
		if mnuChild &lt;&gt; null then
			mnuChild.visible := false;
		endif;
		
		if (not taskDict.includes(task.toDoTaskDesc)) then
			// user does not have permission to add/remove this task
			continue;
		endif;
		
		// create a list of the todo tasks that we have to do
		mnuChild := mnuMaster.getMenuItem(task.toDoTaskDescCode); // check if the menu is already cloned
		// always delete as this is different for each TI
		if mnuChild &lt;&gt; null then
			delete mnuChild;
		endif;
		self.mnuTaskRemoveSub.visible := false;
		mnuChild := mnuMaster.loadSubMenu(task.toDoTaskDescCode); // Clone menu
		mnuChild.caption := task.toDoTaskDescDesc;
		mnuChild.visible := true;
		mnuChild.enabled := true;
		mnuChild.helpKeyword := task.toDoTaskDescDesc;
		mnuChild.userObject := _theTI;
	endforeach;

epilog
	delete taskDict;
	
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doCargoContextMenuBuild" id="5e1d85a3-4adc-48b0-bea6-57c62a6d9414">
        <updating/>
        <source>doCargoContextMenuBuild(conwin: Window input; mouse: Boolean; x: Integer; y: Integer) updating;
/*
Date		    Who			Reason
29 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	obj : CM_Object;
	aReq : CM_RORORequest;
	ti 	: CM_TrackedItem;
begin

	obj := self.myROROLocnDrawingController.allSelectedObjects.first.CM_Object;
	self.mnuUnplanCargo.visible := false;
	self.mnuAutoplanSelected.visible:=false;
	self.mnuReturnCargo.visible := false; // PAR 29306
	self.mnuCargoErase.visible := false;
	self.mnuCargo.visible := false;
	self.mnuAssignRelease.visible := false;
	self.mnuUnplanRelease.visible := false; //cnwrd1 par 30807 ccms 1310
	
	
	self.mnuCargoEditSelected.visible := false;
	self.mnuCargoEditAll.visible:= false;
	self.mnuLinkMain.visible:= false;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;
	
	self.mnuCargoEditAll.visible:= true;
	self.mnuLinkMain.visible:= true;
	
	//cwnmc5 - 1 August 2013 - PAR 31651
	if self.myParentForm.isKindOf(SHP_ROROPlanningForm) then
		self.myParentForm.SHP_ROROPlanningForm.setupLinkContextMenus(self.mnuLinkMain, self.mnuLinkDoLink, self.mnuLinkRelink, self.mnuLinkDelink);
	endif;
	
	if obj.isKindOf(CM_VoyageROROController) then
		// PAR 30018
		if self.myROROLocnDrawingController.modeView = ShpDisplayMode_Actual then
			ti := obj.CM_VoyageROROController.allTrackedItems.first;
			if ti &lt;&gt; null then
				self.mnuReturnCargo.visible := true; // PAR 29306
				self.mnuCargoErase.visible := true;
				self.mnuCargoErase.userObject := ti;
				self.mnuCargoErase.caption := app.getErrorString(Erase_selected); 
				
				self.mnuCargo.visible := true;
				self.doBuildMenuCargo(ti);
			endif;
			
		else
			if self.myROROLocnDrawingController.modeView = ShpDisplayMode_ColCodeLoad then
				aReq := obj.CM_VoyageROROController.myRORORequestLoad.CM_RORORequest;
			else
				aReq := obj.CM_VoyageROROController.myRORORequestDischarge.CM_RORORequest;
			endif;
			if aReq &lt;&gt; null then
				ti := aReq.getTrackedItem();
				self.mnuUnplanCargo.visible := ((self.myROROLocnDrawingController.modeView = ShpDisplayMode_ColCodeLoad or self.myROROLocnDrawingController.modeView = ShpDisplayMode_ColCodeDisch) 
															and (ti &lt;&gt; null and ti.isPlanned(REAL_MODE)));
				self.mnuUnplanCargo.userObject := aReq;
				self.mnuUnplanCargo.caption :=  app.getErrorString(Unplan_GC) &amp; " "  &amp; aReq.getAllocationName();
				self.mnuAutoplanSelected.visible:=(self.myROROLocnDrawingController.modeView = ShpDisplayMode_ColCodeDisch and (ti &lt;&gt; null and not ti.isPlanned(REAL_MODE)) );
				
				
				self.mnuCargoErase.visible := true;
				self.mnuCargoErase.userObject := aReq;
				self.mnuCargoErase.caption := app.getErrorString(Erase_selected); 
				
				
				if self.myROROPlanningForm.modeWork = self.myROROPlanningForm.WorkMode_Plan then //ccms 1310 
				
					if aReq.CM_RORORequest.myBulkReleaseReserveDetail &lt;&gt; null then
						//self.doBuildUnplanMenu(self.mnuCargoUnplan,self.mnuCargoUnqueue, null);
						self.mnuUnplanRelease.visible := true;						
					else					
						self.doContextMenuAssignRelease(aReq.CM_RORORequest);
					endif;
				endif;
				
				
			endif;
		endif;
	endif;
	
	
epilog

end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doClearRemarks" id="c47834aa-2c74-42fd-9cdf-aaae2bfae969">
        <updating/>
        <source>doClearRemarks() updating, protected;
/*
Date		Who		Reason
21 Aug 2012	cnwcs5	Initial creation - par 29124:2
*/
vars

begin 
	self.allRemarksControls.purge;
	
	self.lastIndexForRemarks	:= 0;
	self.haveCreatedRemarks		:= false;
epilog

