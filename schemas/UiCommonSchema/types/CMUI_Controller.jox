    <JadeMethod name="getEntTableErrorReturnString" id="4628c148-f3a4-4013-bada-f93ef86fe095">
        <source>getEntTableErrorReturnString(pGrpName, pField : String) : String;
// ---------------------------------------------------------------------------
// Created:     19 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	entTableGrp	: EntTableGroup;
	theField	: String;
	
begin

	entTableGrp := app.myRoot.myEntTableDataRoot.allEntTableGroups[pGrpName];
	
//	if entTableGrp = null then
//		// load into transients
//		self.loadEntTableGroup(pGrpName);
//		entTableGrp := app.myController.allEntTableGroups[pGrpName];
//	endif;

	if entTableGrp &lt;&gt; null then
		theField := entTableGrp.getNameFromErrorReturnString(pField);
	endif;
	
	return theField;

end;</source>
        <Parameter name="pGrpName" type="String"/>
