    <JadeMethod name="getPrinterName" id="e30c2714-5641-4730-b667-905182b5a60a">
        <source>getPrinterName():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 January 2019	jlgndl1	Initial creation	TFS 40479

*/

vars

begin

	if self.myPrinter &lt;&gt; null then
		return self.myPrinter.physicalPrinterName;
	else
		return null;
	endif;

epilog

end;</source>
