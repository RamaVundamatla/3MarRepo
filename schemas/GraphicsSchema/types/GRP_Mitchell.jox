    <JadeMethod name="writePointsInEDIFormat" id="c2ca729f-41a3-42ab-9b0d-ce1589f15c7f">
        <source>writePointsInEDIFormat(_pa : PointArray; _num : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2013	cnwmc5	Initial creation

*/

vars
	pos		: String;
	count	: Integer;
	
	point	: Point;
begin
	pos := "00" &amp; _num.String;
	count := 1;

	write "L;A;D1" &amp; pos &amp; "G;S;;;;";
	foreach point in _pa do
		self.convertPixelsToMetres(point);
		write "P;D1" &amp; pos &amp; "G;" &amp; count.String &amp; "; " &amp; point.x.String &amp; "; " &amp; point.y.String &amp; ";";
		count := count + 1;
	endforeach;
epilog

end;</source>
        <Parameter name="_pa" type="PointArray"/>
        <Parameter name="_num" type="Integer"/>
    </JadeMethod>
</GUIClass>
