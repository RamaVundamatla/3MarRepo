    <JadeMethod name="addToolbarControls" id="07a580b9-6885-47b5-9129-96b18fec8205">
        <updating/>
        <source>addToolbarControls() updating, protected;
// ---------------------------------------------------------------------------
// Created:     01 June 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	toolbarObj	: CMUI_Toolbar;
	
begin

	toolbarObj	:=	self.frmToolbar;	
	toolbarObj.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbarObj.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="cmbOrganisation_click" id="a61deb93-1fee-438d-8a24-6c66678e71c6">
        <controlMethod name="CMUI_ComboBoxObject::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbOrganisation_click(combobox: ComboBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 July 2015	cnwndl1	Initial creation	Par 36588
31 Dec 2018	NDL	TFS 42699 - Bish says don't show any addresses until org selected.

*/

vars

	org : CM_Organisation;
	
begin

	org := cmbOrganisation.listObject.CM_Organisation;
	if org = null then
		self.mulNotifyEmails.setAvailable( null, true );
		self.mulNotifyEmails.setSelected( null );
	else
		self.mulNotifyEmails.setAvailable( org.allSelectedEmailAddresses, true );
		self.mulNotifyEmails.setSelected( null );
	endif;
	
epilog

end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
