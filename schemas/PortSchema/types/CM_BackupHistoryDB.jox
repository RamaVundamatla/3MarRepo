<Class name="CM_BackupHistoryDB" id="6f7118ab-8dde-42b3-9cc0-46b41b295984">
    <superclass name="CM_BackupHistory"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="backup"/>
    <PrimAttribute name="finishDateTime" id="955c9bfd-3907-4f19-b11b-80d3245dfff3">
        <embedded/>
        <type name="TimeStamp"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="setProxy" id="fdefb2d7-e9cc-47cf-bc5f-d184ab77669d">
        <updating/>
        <source>setProxy(_dateTime: TimeStamp) updating;
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.dateTime := _dateTime;
end;</source>
        <Parameter name="_dateTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setStatus" id="fc511d84-17ce-4d36-9872-3dd986d4a4ef">
        <updating/>
        <source>setStatus(_status: Integer) updating;
//
// CCMS1150 cnwrs1 04 July 2011
//
vars

begin
	if _status = BackupStatus_Abort or
	   _status = BackupStatus_Failed or
	   _status = BackupStatus_Completed or
	   _status = BackupStatus_Restarted then
		finishDateTime := app.actualTimeServer();
	endif;
	inheritMethod(_status);
end;
</source>
        <Parameter name="_status" type="Integer"/>
    </JadeMethod>
</Class>
