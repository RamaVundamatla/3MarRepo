    <JadeMethod name="getIMEXStatus" id="f3cabd75-2700-4442-8b6f-3dcf283c1c05">
        <source>getIMEXStatus():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Oct 2023 navhl20 ChangeRequest 60033: EUP | Ship Operations in DD - [54176.010] - [Receive] Ship Job List 
25 Mar 2024 navhl20 ChangeRequest 62300: EUP | 53729 - Delivery Dispatch Screen - outstanding issues - 2
29 Mar 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work
10 Apr 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work - 1
20 May 2024 navhl20 Bug 64191: EUP - Lock and Freeze issue
*/

vars
	ti 		: CM_TrackedItem;
	resDtl	: CM_ReserveDetail;
	relReq	: CM_BulkRelease;
	req		: CM_Request;
	objSet	: ObjectSet;
begin
	ti := self.getFirstTrackedItem();
	if ti &lt;&gt; null then
		return app.imexStatusEnumToString(ti.getImExStatus());
	endif;
	
	req := self.allRequests.first;
	if req &lt;&gt; null then
		resDtl := req.myReserveDetail;
	endif;
	if resDtl &lt;&gt; null and resDtl.isKindOf(CM_ReserveSelection) then
		create objSet transient;
		resDtl.CM_ReserveSelection.getMatchingCriteria(objSet,YACriteriaType_ImexStatus);
		if objSet &lt;&gt; null then
			return objSet.listStringNoDuplicate(Comma,CM_IMEXStatus::abbreviation.name);
		endif;
	
		if resDtl.myCargoGroup &lt;&gt; null then								//29.03.2024 navhl20 #63251
			return app.imexStatusEnumToString(resDtl.myCargoGroup.getImExStatus());
		endif;
	endif;
	
	return null;
epilog
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getIncompleteWLEForTI" id="dfef4a94-38d2-44cd-9818-d43efee7877f">
        <source>getIncompleteWLEForTI(_ti : CM_TrackedItem;					
						_isReceival : Boolean) : CM_WorkListEntry;
/*

Date		Who		Reason
11 March 2016	cnwer1	Initial creation PAR

*/

vars
	wle : CM_WorkListEntry;
	
begin
	foreach wle in self.workListEntries  discreteLock do
		 if _isReceival then
			 if  not wle.isReceipt then
				continue;
			endif;
		else
			if wle.isReceipt then
				continue;
			endif;
		endif;
		if wle.myTrackedItem &lt;&gt; _ti then
			continue;
		endif;
		if wle.status = WLE_COMPLETED  then
			continue;
		endif;
		return wle;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_isReceival" type="Boolean"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="getIncompleteWleTi" id="4c9e7336-01a9-474b-bdac-fb6a8b9c05e9">
        <source>getIncompleteWleTi():CM_WorkListEntry;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Oct 2024 navhl20 Bug 33146: EUP | Release cargo workorder completing early when split across multiple Vehicle Bookings

*/

vars
	wle		: CM_WorkListEntry;
begin
	foreach wle in self.workListEntries discreteLock where wle.status &lt;&gt; WLE_COMPLETED and wle.myTrackedItem &lt;&gt; null do
		return wle;
	endforeach;
	return null;
epilog

end;</source>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="getInstruction" id="71053e03-0807-4262-80df-b59b8cde5a7e">
        <source>getInstruction():String;
/*

Purpose:
Returns instruction type description in the following priority
WorkOrder&gt;WorkOrderDetail&gt;bulkRelease/BOL/Booking &gt;	reserveDetail/BOLDetail/BookingItem &gt; trackedItem

Parameters:			

Return Value:		

Date		Who		Reason
05 Jun 2023	navhl20	ChangeRequest 57762: EUP - Delivery Dispatch – Pack/UnPack
16 Oct 2023 navhl20 Bug 60863: EUP - Delivery Dispatch Remedial [1]
25 Jan 2023 navhl20 ChangeRequest 62166: EUP | 53729 - Delivery Dispatch Screen - outstanding issues
18 Apr 2024 navhl20 ChangeRequest 63511: FR | 53891 - Mobile App changes for Delivery Dispatch - Remedial
17 May 2024 navhl20 Bug 64191: EUP - Lock and Freeze issue
06 Mar 2025	navah1	Bug 34283: EUP | Additional Operational Instructions - further issues
08 Apr 2025	navbs1	Bug MTN-34396: EUP | Additional Operational Instructions - more issues (part 2)
*/

vars
	wod 		: CM_WorkOrderDtl;
	instruction : CM_InstructionsIssued;
	relReq		: CM_BulkRelease;
	resDtl		: CM_ReserveDetail;
	book		: CM_BookingRef;
	bookDtl		: CM_BookingRefItem;
	bol			: CM_BOL;
	bolDtl		: CM_BOLDtl;
begin

    instruction := self.getFirstInstFromWODtl(wod);			//17.04.2025 navbs1 #34396
	
	if instruction &lt;&gt; null then
		return instruction.getInstructionDesc();
	endif;
	
	if wod &lt;&gt; null then									//25.01.2023 navhl20 #62166
		if wod.isKindOf(CM_WodRelease) then
			relReq := wod.CM_WodRelease.myReleaseRequest;
			resDtl := wod.CM_WodRelease.myReserveDetail;
			book	:= wod.CM_WodRelease.myBookingRef;
			bookDtl	:= wod.CM_WodRelease.myBookingRefItem;
		elseif wod.isKindOf(CM_WodReceive) then
			book := wod.CM_WodReceive.myBookingRef;
			bookDtl	:= wod.CM_WodReceive.myBookingRefItem;
			bol	:= wod.CM_WodReceive.myBillOfLading;
			bolDtl := wod.CM_WodReceive.myBillOfLadingDtl; 
		endif;
		if relReq &lt;&gt; null then
			instruction := relReq.getInstructions();
			if instruction &lt;&gt; null then
				//return instruction.internalInstructions; //10.03.2025 navah1 #34283
				return instruction.getInstructionDesc();   //10.03.2025 navah1 #34283
			endif;
		endif;

		if book &lt;&gt; null then
			instruction := book.getInstructions();
			if instruction &lt;&gt; null then
				//return instruction.internalInstructions; //10.03.2025 navah1 #34283
				return instruction.getInstructionDesc();   //10.03.2025 navah1 #34283
			endif;
		endif;
		
		if bol &lt;&gt; null then
			instruction := bol.getInstructions();
			if instruction &lt;&gt; null then
				//return instruction.internalInstructions; //10.03.2025 navah1 #34283
				return instruction.getInstructionDesc();   //10.03.2025 navah1 #34283
			endif;
		endif;

		
		if resDtl &lt;&gt; null then
			instruction := resDtl.getInstructions();
			if instruction &lt;&gt; null then
				//return instruction.internalInstructions; //10.03.2025 navah1 #34283
				return instruction.getInstructionDesc();   //10.03.2025 navah1 #34283
			endif;
		endif;
		
		if bookDtl &lt;&gt; null then
			instruction := bookDtl.getInstructions();
			if instruction &lt;&gt; null then
				//return instruction.internalInstructions; //10.03.2025 navah1 #34283
				return instruction.getInstructionDesc();   //10.03.2025 navah1 #34283
			endif;
		endif;
		
		if bolDtl &lt;&gt; null then
			instruction := bolDtl.getInstructions();
			if instruction &lt;&gt; null then
				//return instruction.internalInstructions; //10.03.2025 navah1 #34283
				return instruction.getInstructionDesc();   //10.03.2025 navah1 #34283
			endif;
		endif;
	endif;
	
   instruction := self.getFirstInstFromTIs();				//17.04.2025 navbs1 #34396
   	
	if instruction &lt;&gt; null then
		return instruction.getInstructionDesc();
	endif;

	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
