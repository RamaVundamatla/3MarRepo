    <JadeMethod name="doSetReadOptions" id="5aa4c70d-f622-4e32-b20c-abb8b1e0ef08">
        <source>doSetReadOptions(pOptions: Integer) protected;
//	set bit 1 = collection headers to be tracked
//	set bit 2 = exclude registered classes
begin
	if pOptions = 2 or pOptions = 3 then
		self.myJadeAuditAccess.setFilterExcludes(true);
	else
		self.myJadeAuditAccess.setFilterExcludes(false);
	endif;

//	call setOptions(self.journalHandle, pOptions);
end;</source>
        <access>protected</access>
        <Parameter name="pOptions" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doSetReadOptionsSE" id="0aa82566-88c8-4bd7-9f86-8fb4e66eb951">
        <executionLocation>server</executionLocation>
        <source>doSetReadOptionsSE(pOptions: Integer) protected, serverExecution;
//	set bit 1 = collection headers to be tracked
//	set bit 2 = exclude registered classes
begin
	if pOptions = 2 or pOptions = 3 then
		self.myJadeAuditAccess.setFilterExcludes(true);
	else
		self.myJadeAuditAccess.setFilterExcludes(false);
	endif;

//	call setOptions(self.journalHandle, pOptions);
end;</source>
        <access>protected</access>
        <Parameter name="pOptions" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getChangeUserData" id="911366a2-afc6-4ec1-ba51-811c0853f6fa">
        <source>getChangeUserData(_serverExecution : Boolean;
				  _userName : String output;
				  _index : Integer output;
				  _byUserName : String output;
