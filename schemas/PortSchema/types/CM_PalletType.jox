<Class name="CM_PalletType" id="4bd7709f-33d8-470b-b3a2-45932182c6b1">
    <superclass name="CM_HandlingSubType"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="pallet"/>
    <PrimAttribute name="heatTreated" id="ed99121d-7dcd-415d-af02-785fad2b6692">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="create" id="3805cee6-3931-4f03-9a8c-85ba429b4fe4">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2017	cnwndl1	Initial creation	TFS 4314

*/

vars

begin

	self.myHandlingType := app.myRoot.allHandlingTypes.getAtKey(TI_HandlingType_Pallets);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getHandlingTypeDisplay" id="769ecd31-350a-4fd5-9ab3-abe2941ee7d2">
        <source>getHandlingTypeDisplay(_includeExtras: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 April 2017	cnwndl1	Initial creation	TFS 3424

*/

vars

	str : String;

begin

	str := inheritMethod(_includeExtras);
	
	if _includeExtras and self.heatTreated then
		str := str &amp; ", " &amp; app.getErrorString(Heat_treated);
	endif;
	
	return str;

epilog

end;</source>
        <Parameter name="_includeExtras" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
