    <JadeMethod name="value" id="fa9a2355-87d5-4676-9bb2-498d2026a597">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>value(set: Boolean; val: Boolean io) updating, mapping, clientExecution;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/06/2024	navkc1 CR 63736 Task 63737: Jade - New Filter Control

*/

vars
	btn	:CMUI_ToolbarButtonTblFilter;
begin
	inheritMethod(set, val);
	
	if set then
		btn := self.myToolbarButtonTblFilter;
		
		if btn &lt;&gt; null then
			btn.resetButtonState(val);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="val" type="Boolean" usage="io"/>
    </JadeMethod>
