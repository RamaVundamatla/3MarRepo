    <JadeMethod name="getPermissionName" id="7b8d0838-df9b-4ffb-84fb-117c113606d6">
        <source>getPermissionName(_permission : Integer) : String;

/*

Purpose:			Get the current locale translation for the passed in Permission

Parameters:			

Return Value:		String name of the permission


Date		Who		Reason
29 Jan 2009	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars
	permission		: XLAT_Translation;
	
begin
	permission := self.zGetTranslatedText(XLAT_Permissions, _permission);
	if permission &lt;&gt; null then
		if app.useShortErrorMsg and permission.shortText &lt;&gt; null then
			return permission.shortText;
		endif;
		return permission.text;	
	endif;
	
	return "Unknown permission";
	
end;</source>
        <Parameter name="_permission" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPermissionNames" id="a00da881-5df3-4baa-97b1-0a80144e659b">
        <source>getPermissionNames(sa : StringArray input);
// ---------------------------------------------------------------------------
// Created:     30 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
constants
//	TagDescription = "{Description}";
//	TagCategory = "{Category}";
// changed 1/03/06 as was not working with above HG
	TagDescription = "&lt;Description&gt;";
	TagEndDescription = "&lt;/Description&gt;";
	
vars
	appScm : Schema;
	category : ConstantCategory;
	const : Constant;
	permNumber, descPos, descEndPos, catPos : Integer;
	lenTagDescription, lenTagEndDescription, len : Integer;
	desc : String;

begin
	if sa = null then
		return;
	endif;
	
	sa.clear;

	appScm := rootSchema.getSchema(PortSchemaName);
	if appScm = null then
		return;
	endif;
	
	category := appScm.getCategory(XLAT_Permissions);
	if category = null then
		return;
	endif;

	lenTagDescription := TagDescription.length;
	lenTagEndDescription := TagEndDescription.length;
	
	foreach const in category.getConstants do
		permNumber := const.GlobalConstant.valueAsInteger;
		if permNumber &lt; 1 then
			continue;
		endif;

		descPos := const.text.pos(TagDescription, 1);
//		catPos := const.text.pos(TagCategory, 1);
		descEndPos  := const.text.pos(TagEndDescription, 1);

//		if descPos &lt; 1 or catPos &lt; 1 or descPos &gt;= catPos then
		if descPos &lt; 1 or descEndPos  &lt; 1 or descPos &gt;= descEndPos then
			continue;
		endif;

//		desc := const.text[descPos + lenTagDescription : catPos - (descPos + lenTagDescription)].trimBlanks;
		desc := const.text[(descPos + lenTagDescription) : descEndPos - (descPos + lenTagDescription)].trimBlanks;
		
		len := desc.length;
		if len &gt;= 2 and desc[len - 1 : end] = CrLf then
			desc := desc[1 : len - 2].trimBlanks;
		endif;

		sa[permNumber] := desc.truncatedAt(60);
	endforeach;
	
end;</source>
        <Parameter name="sa" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getPicLogoPort" id="9e835ba7-a6e2-464f-87ac-fc54df011fdd">
        <updating/>
        <source>getPicLogoPort(): Binary updating;
vars
	picBinary	: Binary;
	tmpRoot		: CM_Root;
begin

	// we will add the ports logo access from config latter, for now AND if the ports logo is null use the Jade logo
	// TRY the terminal
	if app.myPassport &lt;&gt; null and app.myPassport.myTerminal &lt;&gt; null then
		picBinary := app.myPassport.myTerminal.getConfig(PortLogoPic).Binary;
	endif;
	
	tmpRoot := app.myRoot;
	if tmpRoot = null then
		return picBinary;
	endif;
	
	// TRY the Root
	if picBinary = null then
		picBinary := tmpRoot.getConfig(PortLogoPic).Binary;
	endif;
	
	// USE The Jade Logo
	if picBinary = null then
		picBinary := tmpRoot.getConfig(PicAppLogoJade100X080).Binary;
	endif;

	return picBinary;
epilog
end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
