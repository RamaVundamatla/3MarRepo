<Class name="WS_Vessel" id="ecb34912-b832-4e85-97d1-ecc0692936e2">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Represents all vessels defined in the system</text>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="code" id="602be517-b260-40b9-92f7-367a57c0aff4">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Vessel Code ex: AMA</text>
    </PrimAttribute>
    <PrimAttribute name="comboboxDescription" id="67183ba9-8935-45a5-916a-1badf4547359">
        <length>61</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Concatenated code and name of the vessel ex: AMA APL NORWAY</text>
    </PrimAttribute>
    <PrimAttribute name="name" id="851496a9-a751-4770-b07b-ec8a917021f6">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
        <text>Vessel Name ex: APL NORWAY</text>
    </PrimAttribute>
    <PrimAttribute name="numBaysDefined" id="31faae3e-8843-40d2-bf61-f9c401fca7f1">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
        <text>Number of bays defined for this vessel</text>
    </PrimAttribute>
    <PrimAttribute name="trade" id="59eeea71-cf30-4638-89c3-5c86725d4bb3">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setComboboxDescription" id="72a73876-da7e-400a-b952-9378ad11be82">
        <updating/>
        <source>setComboboxDescription(value : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 October 2021	jlier1	Initial creation 51963

*/

vars

begin
	self.comboboxDescription:=value;
epilog

end;</source>
        <Parameter name="value" type="String"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="cacdfbfb-4185-4c22-9e31-c523f498a9d5">
        <updating/>
        <source>setProxyFromObject(_object: CM_Vessel) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 March 2009	#cnwdz2	 

*/

vars

begin
	inheritMethod(_object);
	self.code	:= _object.code;
	self.name	:= _object.name;
	self.comboboxDescription := self.code &amp; Tab &amp; self.name;
	
	if  _object.myCellularVesselStructure &lt;&gt; null then
		if _object.myCellularVesselStructure.allBaysByOrdinal &lt;&gt; null then
			self.numBaysDefined := _object.myCellularVesselStructure.allBaysByOrdinal.size;
		endif;
	endif;
	//jlier1 TFS 52302 9/11/21
	if _object.myDefaultTrade &lt;&gt; null then
		self.trade:= _object.myDefaultTrade.description;
	endif;
	
epilog

end;</source>
        <Parameter name="_object" type="CM_Vessel"/>
    </JadeMethod>
</Class>
