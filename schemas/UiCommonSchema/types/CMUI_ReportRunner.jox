    <JadeMethod name="createEmail" id="154da957-23d5-420b-be55-56da5f1d09d5">
        <source>createEmail(_email : CM_EmailTemplate) protected;
// -------------------------------------------
// Created 26 August 2003 by cnwdvb1
// -------------------------------------------
vars

	sender : String;

begin

	sender := app.myRoot.getConfig(AutoSendersEmailAddress).String;
			
	app.myTrxCA.trxCreateEmailSendRequest(app.getErrorString(Reports),_email.getAllToAddressesOrNames(false), sender, _email.getAllCCAddressesOrNames(false), _email.getAllBCCAddressesOrNames(false), _email.subject,
												_email.body, _email.allAttachedFilePaths, null, null, null, EmailSource_Reports,null, app.myPassport);
	if not app.myPassport.trxCompletedOK then
		app.showErrorsAsMsgBox(app.myPassport.allErrorWarnings, app.myPassport.noErrors);
	endif;
	return;
end;</source>
        <access>protected</access>
        <Parameter name="_email" type="CM_EmailTemplate"/>
    </JadeMethod>
    <JadeMethod name="createReportController" id="5d8139d7-7894-4478-873a-0ca6a7ac5614">
        <updating/>
        <source>createReportController() protected, updating;
// ---------------------------------------------------------------------------
// Created:     04 September 2002 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	tmpClass			: Class;
	schema				: Schema;
begin

	if self.myReportAgent.myQryReport = null then
		delete self.myReportController;
		return;
	endif;
	
	tmpClass := self.myReportAgent.myQryReport.myReportControllerClass;	
	if tmpClass = null then
		delete self.myReportController;
		return;
	endif;
	
	// need to get class for self.myReportDef.reportControllerClass

	if self.myReportController &lt;&gt; null and
	   self.myReportController.class &lt;&gt; tmpClass then
	   	delete self.myReportController;
	endif;
	
	if self.myReportController = null then
		create self.myReportController as tmpClass transient;
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="createTemplateFileType" id="8fdecffd-1d09-48f0-9bf3-f9b6f950e913">
        <updating/>
        <source>createTemplateFileType(
	_filter 		: CMQF_FilterReports; 
	_extraDetail 	: CM_ExtraDetail;
	_profName 		: String) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     27 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	newUserReport			: CM_MenuUserReport;
	printerName				: String;
	doEmail					: Boolean;
	emailTemplate			: CM_EmailTemplate;
	outputDest				: Integer;
	pxyReportTemplate		: CM_ReportTemplate;
	newReportTemplate		: CM_ReportTemplate;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
	ftpEntity               : CM_FTPEntity;		
begin
	if self.cmbPrinter.listObject &lt;&gt; null then
		printerName := self.cmbPrinter.listObject.CM_PrinterDef.physicalPrinterName;  //epr TFS 2401 21/7/16
	endif;
	
	doEmail := self.tblPrintOptions.getValueByNameIfVisible(ETRow_DoEmail).Boolean;
	if doEmail then //should alwats be creating new template if this method called
		create emailTemplate transient;
		app.mousePointer := MousePointer_Default;
		if not self.doDisplayEmailForm(null, emailTemplate, true) then
			return false;
		endif;
		app.mousePointer := MousePointer_HourGlass; 
	endif;
	outputDest := self.cmbFormat.itemData[self.cmbFormat.listIndex];
	
    if self.cmbFTPEntity.listObject &lt;&gt; null then                            //MTN-36668
        ftpEntity   := self.cmbFTPEntity.listObject.CM_FTPEntity;           //MTN-36668
    endif; 
    
	create pxyReportTemplate transient;
	self.setReportTemplateProxy(pxyReportTemplate, _filter, _extraDetail, emailTemplate, outputDest, _profName, printerName, ftpEntity);//MTN-36668
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxCA.trxCreateReportTemplate(pxyReportTemplate, newReportTemplate, newUserReport, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.myMenuEntity := newUserReport;			
			self.lbReportTree.displayTree(true, null);
			self.lbReportTree.selectObject(self.myMenuEntity);
			statusLine.caption := app.getString( File_Type_Template_Created );
			return true;
		else
			theResult := app.showErrorWarningDialog( app.getString( Create_Item, app.getString( Template ) ), app.myPassport, ErrWarnMode_Update );
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		statusLine.caption := app.getString( Error_OccuredCreatingTemplate );
		return false;
		
	endwhile;
	
epilog	
	delete emailTemplate;
	delete pxyReportTemplate;
	
end;</source>
        <access>protected</access>
        <Parameter name="_filter" type="CMQF_FilterReports"/>
        <Parameter name="_extraDetail" type="CM_ExtraDetail"/>
        <Parameter name="_profName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createTemplateStandard" id="0782e7e3-54f5-4233-9507-ac52f8b782a6">
        <updating/>
        <source>createTemplateStandard(
	_filter 		: CMQF_FilterReports; 
	_extraDetail 	: CM_ExtraDetail; 
	_profName 		: String) : Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     27 August 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	newUserReport		: CM_MenuUserReport;
	printerName,
	networkFilepath		: String;
	doEmail				: Boolean;
	emailTemplate		: CM_EmailTemplate;
	pxyReportTemplate,
	newReportTemplate	: CM_ReportTemplate;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
	
begin
	if self.cmbPrinter.listObject &lt;&gt; null then
		printerName := self.cmbPrinter.listObject.CM_PrinterDef.physicalPrinterName; //epr TFS 2401 21/7/16
	endif;
	doEmail := self.tblPrintOptions.getValueByNameIfVisible(ETRow_DoEmail).Boolean;
	if doEmail then //should always be creating new when this method called
		create emailTemplate transient;
		app.mousePointer := MousePointer_Default;
		if not self.doDisplayEmailForm(null, emailTemplate, true) then
			return false;
		endif;
		app.mousePointer := MousePointer_HourGlass; 
	endif;
	
	networkFilepath := self.tblPrintOptions.getValueByNameIfVisible(ETRow_ServerFilePath).String;
	
	create pxyReportTemplate transient;
	self.setReportTemplateProxy(pxyReportTemplate, _filter, _extraDetail, emailTemplate, JadeReportWriterReport.PRINTER, _profName, printerName, null);//MTN-36668
	
	//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxCA.trxCreateReportTemplate(pxyReportTemplate, newReportTemplate, newUserReport, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			self.myMenuEntity := newUserReport;	
			self.lbReportTree.displayTree(true, null);
			self.lbReportTree.selectObject(self.myMenuEntity);
			statusLine.caption := app.getString( StandardPrinterTemplateCreated );
			return true;
		else
			theResult := app.showErrorWarningDialog( app.getString( Create_Item, app.getString( Template ) ), app.myPassport, ErrWarnMode_Update );
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		statusLine.caption := app.getString( Error_OccuredCreatingTemplate );
		return false;
		
	endwhile;
	
epilog	
	delete emailTemplate;
	delete pxyReportTemplate;	
end;</source>
        <access>protected</access>
        <Parameter name="_filter" type="CMQF_FilterReports"/>
        <Parameter name="_extraDetail" type="CM_ExtraDetail"/>
        <Parameter name="_profName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displayDetail" id="e9ceb24f-1025-4efa-82ae-26f74b1d5bcc">
        <source>displayDetail(_user : CM_User) : String;
// -------------------------------------------
// Created 09 December 2004 by cnwdvb1
// -------------------------------------------
vars

begin
      //par no 16537---to  not to display all the   email addresses
      if _user.isNotAvailableForEntry    then
	    return null;
		endif;
	return _user.code &amp; Tab &amp; _user.userName;


end;</source>
        <Parameter name="_user" type="CM_User"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doBtnDeleteBGRClick" id="7cdee1c7-974f-44e5-b04e-afa66c615ba9">
        <updating/>
        <source>doBtnDeleteBGRClick() updating, protected;
// ---------------------------------------------------------------------------
// Created:     13 December 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	table			: CM_DataTable;
	menuEntity		: CM_MenuEntity;
	reportTemplate	: CM_ReportTemplate;
	menuSet			: CM_MenuUserItemSet;
	totalDelete		: Boolean;
	
begin
	app.mousePointer := MousePointer_HourGlass;
	
	if self.myReportAgent.state = self.myReportAgent.STATE_TEMPLATE_EDIT or
		self.myReportAgent.state = self.myReportAgent.STATE_BGR_EDIT then
		//we are just cancelling out of editing a template
		self.doTreeClick();
		return;
	endif;
	
	//first see if a menu entity is selected and if template then delete that, if not we must be deleting from the BGR Table
	menuEntity := self.lbReportTree.itemObject[self.lbReportTree.listIndex].CM_MenuEntity;
	create menuSet transient;
	
	if menuEntity &lt;&gt; null and menuEntity.isKindOf(CM_MenuUserReport) then
		reportTemplate := menuEntity.CM_MenuUserReport.myReportTemplate;
		// Having a user means it's a template rather than a current menu report.
		if reportTemplate.myUserToRunAs &lt;&gt; null and reportTemplate.allMenuUserReports.size &gt; 1 then
//			if app.msgBox('Do you wish to delete this template completely. Other users still have access', 'Delete', MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then	// cnwrl1 11/11/2009 PAR 19951 - what it was
//				if app.msgBox('Remove self from users who can edit template list', 'Delete', MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt; MsgBox_Return_Yes then	// cnwrl1 11/11/2009 PAR 19951 - what it was
			if app.msgBox(	app.getString( Delete_Template_Completely ),
							app.getString( Delete2 ),
							MsgBox_Yes_No + MsgBox_Question_Mark_Icon ) &lt;&gt; MsgBox_Return_Yes then
				if app.msgBox(	app.getString( Remove_Self_From_Edit_Template ),
								app.getString( Delete2 ),
								MsgBox_Yes_No + MsgBox_Question_Mark_Icon ) &lt;&gt; MsgBox_Return_Yes then
					return;
				endif;
			else
				// Just making it obvious.
				totalDelete := true;
			endif;
		else
//			if app.msgBox(app.getErrorString2(ConfirmDelete, 'report', menuEntity.CM_MenuUserReport.name),'Delete', MsgBox_OK_Cancel + MsgBox_Exclamation_Mark_Icon) &lt;&gt; MB_OK then
			if app.msgBox(	app.getString( ConfirmDelete, app.getString( Report ), menuEntity.CM_MenuUserReport.name ),
							app.getString( Delete2 ),
							MsgBox_OK_Cancel + MsgBox_Exclamation_Mark_Icon ) &lt;&gt; MsgBox_Return_OK then
				return;
			else
				// Just making it obvious.
				totalDelete := true;
			endif;
		endif;
	
		menuSet.add(menuEntity.CM_MenuUserReport);
		app.myTrxDA.trxDeleteMenuUserReport(menuSet, totalDelete, app.myPassport);
		if not app.myPassport.trxCompletedOK() then
			app.showErrorsAsMsgBox(app.myPassport.allErrorWarnings, app.myPassport.noErrors);
		else
			self.lbReportTree.displayTree(true, null);
		endif;
	else
		table := self.tblBGPReports;
		if table.visible = false then
//			app.msgBox('You may not delete this item','Not Allowed', 0);	// cnwrl1 11/11/2009 PAR 19951 - what it was
			app.msgBox( app.getString( Delete_This_Item ), app.getString( NotAllowed ), MsgBox_OK_Only );
			return;
		elseif table.allSelectedObjects.isEmpty then
//			app.msgBox('Please selected something to delete','Nothing Selected', 0);
			app.msgBox(	app.getString( Please_Select_Something_First, app.getString( Delete ) ),
						app.getString( Nothing_Selected ),
						MsgBox_OK_Only );
			return;
		endif;
		
//		if app.msgBox(app.getErrorString2(ConfirmDelete, 'all selected', 'reports'),'Are you sure', MsgBox_OK_Cancel) &lt;&gt; MsgBox_Return_OK then	// cnwrl1 11/11/2009 PAR 19951 - what it was
		if app.msgBox(	app.getString( ConfirmDelete, app.getString( All_Selected ), app.getString( Reports ) ),
						app.getString( Are_You_Sure ),
						MsgBox_OK_Cancel ) &lt;&gt; MsgBox_Return_OK then
			return;
		endif;
		
		//copy into a collection that doesn't care about being updated during iteration
		table.allSelectedObjects.copy(menuSet);
		//kill
		app.myTrxDA.trxDeleteMenuUserReport(menuSet, false, app.myPassport);
		if not app.myPassport.trxCompletedOK() then
			app.showErrorsAsMsgBox(app.myPassport.allErrorWarnings, app.myPassport.noErrors);
		endif;

		self.myBGPReport := null;
		self.doTreeClick();
		self.tblBGPReports.row := 1;
	endif;
	
epilog
	delete menuSet;
	app.mousePointer := MousePointer_Default;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnEditClick" id="8125eaac-ed68-46b3-b564-2ef976bcd4f4">
        <updating/>
