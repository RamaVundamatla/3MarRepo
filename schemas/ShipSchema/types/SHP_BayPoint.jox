    <JadeMethod name="drawAttribute" id="aba7e936-bb8f-4431-a1a9-caa7a552e7a4">
        <source>drawAttribute(_theAttColour : Integer; _theAttribute : String;_theAttributePosition : Integer io;_theFrame: CMUI_GridAreaFrame input) ;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 09/01/2012	cnwmh5		PAR #30990 - remove code for rehandle icon	
// ---------------------------------------------------------------------------

vars
	theLabel : String;
	theDrawingAttribute : CM_DrawingAttribute;
	index,theX, theY, tmpX, tmpY,theAttributePosition, theColour, theInverseColour : Integer;
	theFontName : String;
	theDrawTextAlign : Integer;
	theFontSize, theScale : Real;
	theString,aString : CM_String;
	theCharacter : Character;
	theBayArea : SHP_BayArea;
	backEndPadding : Integer;
	configDraw40BackEndAttrib,found : Boolean;
	theFrame: CMUI_GridAreaFrame;
begin
	
	//if _theAttribute = PicTIIsRehandle then				// 01/09/2013 cnwmh5 #30990 - removed
	//	return;
	//endif;
	
	configDraw40BackEndAttrib := false; // add this into config to either draw a big cross or the back end attribute
	theFrame := _theFrame;
	theScale := self.myGridArea.scaleXFactor;
	
	
	theBayArea := self.myGridArea.SHP_BayArea;
	if theBayArea.displayMode &lt;&gt; ShpDisplayMode_Defn
	and theBayArea.displayMode &lt;&gt; ShpDisplayMode_ColCodeLoad then
		if self.tiInfo40 and self.tiInfo40BackEnd and configDraw40BackEndAttrib = false then
			return;
		endif;
	endif;

	if theBayArea.displayMode = ShpDisplayMode_EDI then
		if _theAttribute = PicTIPlanned then
			return;
		endif;
		if _theAttribute = PicTIActual then
			return;
		endif;
	endif;
	
	// PAR 5935 do not show these on actual view
	if theBayArea.displayMode = ShpDisplayMode_Actual then
		if _theAttribute = PicTIInteg then
			return;
		endif;
		if _theAttribute = PicTIReefer then
			return;
		endif;
	endif;

	theDrawingAttribute := theBayArea.mySDF.allDrawingAttributes[_theAttribute];
	if theDrawingAttribute = null then
		return;
	endif;
	theX := (self.x1 + ((self.x2 - self.x1) / 2)).Integer + 2;
	theY := (self.y1 + ((self.y2 - self.y1)/ 2)).Integer - 5;
	
	// ################################
	// LEGEND LEGEND

	// Only do this is we are in VESSEL definition OR PRINTING
	if theBayArea.displayMode = ShpDisplayMode_Defn or self.amPrinting then
		if theBayArea.mySDF.allGridAreasByRowColumn.size &lt;= 2  or self.amPrinting then
		
			if self.amPrinting then
				if not theBayArea.mySDF.allAttributeCodes.includes(_theAttribute.trimBlanks) then
					theBayArea.mySDF.allAttributeCodes.add(_theAttribute.trimBlanks);
				endif;
			else
				// add each attribute drawn into the collection so that we can print a legend
				create theString transient;
				theString.string := _theAttribute.trimBlanks;
//				theBayArea.allAttributesUsed.removeInvalidObjects();
//				if theBayArea.allAttributesUsed[theString.string] = null  then
//					theBayArea.allAttributesUsed.add(theString);
//				else
//					delete theString;
//				endif;
				found := false;
				foreach aString in theBayArea.allAttributesUsed do
					if global.isValidObject(aString) then
						if aString.string = theString.string then
							found := true;
							break;
						endif;
					endif;
				endforeach;
				if found then 
					delete theString;
				else
					theBayArea.allAttributesUsed.add(theString);
				endif;
			endif;
		endif;
	endif;

	// #######################
	
	if theBayArea.displayMode = ShpDisplayMode_Defn then
		// Attribute position - 1,2,3,4,5 or 6 - 9
		theAttributePosition := self.getAttributePosition(_theAttribute,_theAttributePosition);
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " . " &amp; _theAttribute &amp; " pos "  &amp; theAttributePosition.String);
		if theAttributePosition = _theAttributePosition then
			_theAttributePosition := theAttributePosition + 1;
			if _theAttributePosition &gt; 9 then
				return;
			endif;
		endif;
		self.drawAttributeXYBayDefn( tmpX,tmpY,theAttributePosition);
		if tmpX = 0 then
			return;
		endif;
	elseif theBayArea.displayMode = ShpDisplayMode_ColCodeLoad then
		// Attribute position - 1,2,3 or 4
		_theAttributePosition := _theAttributePosition + 1;
		if _theAttributePosition &gt; 4 then
			return;
		endif;
		self.drawAttributeXYColCodeLoad( tmpX,tmpY,_theAttributePosition);
		if tmpX = 0 then

			return;
		endif;
	elseif theBayArea.displayMode = ShpDisplayMode_ColCodeDisch then
		// Attribute position - 1,2,3 or 4
		_theAttributePosition := _theAttributePosition + 1;
		if _theAttributePosition &gt; 4 then
			return;
		endif;
		self.drawAttributeXYColCodeDisch( tmpX,tmpY,_theAttributePosition);
		if tmpX = 0 then

			return;
		endif;
	// ############
	// ##&gt;&gt;&gt;&gt;&gt; ACTUAL/PROPOSED/EDI
	// ############
	elseif theBayArea.displayMode = ShpDisplayMode_Actual or 
	       theBayArea.displayMode = ShpDisplayMode_Proposed or
	       theBayArea.displayMode = ShpDisplayMode_EDI then
		// backend of a 40 footer
		if self.tiInfo40 and self.tiInfo40BackEnd and _theAttribute = PicTI40Footer  then
			theDrawingAttribute := theBayArea.mySDF.allDrawingAttributes[PicTI40FooterBackEnd];
			if theDrawingAttribute = null then
				return;
			endif;
		endif;
		
		// Attribute position - 1,2,3 or 4
		_theAttributePosition := _theAttributePosition + 1;
		if _theAttributePosition &gt; 4 then
			return;
		endif;
		self.drawAttributeXYBayAct( tmpX,tmpY,_theAttributePosition);
		if tmpX = 0 then
			return;
		endif;
	endif;

	if theDrawingAttribute = null then
		theFrame.drawFontName := "Verdana";
	else
		theFrame.drawFontName := theDrawingAttribute.fontName;
	endif;
	if theBayArea.displayMode = ShpDisplayMode_Defn and self.amPrinting then
		if theScale = SHP_BayArea.PrintScaleSmall then
			theFrame.drawFontSize := 8;
		elseif theScale = SHP_BayArea.PrintScaleMedium then
			theFrame.drawFontSize := 6;
		else
			theFrame.drawFontSize := 8;
		endif;
	elseif theScale = 1.5 then
		if theBayArea.displayMode = ShpDisplayMode_Defn then
		endif;
	elseif theScale = 1 then
		if theBayArea.displayMode = ShpDisplayMode_Defn then
			theFrame.drawFontSize := 8;
		endif;
	elseif theScale = 2 then
		if theBayArea.displayMode = ShpDisplayMode_Actual 
		or theBayArea.displayMode = ShpDisplayMode_Proposed 
		or theBayArea.displayMode = ShpDisplayMode_ColCodeDisch
		or theBayArea.displayMode = ShpDisplayMode_ColCodeLoad 
		or theBayArea.displayMode = ShpDisplayMode_EDI then
			theFrame.drawFontSize := 7;
		else
			theFrame.drawFontSize := 12;
		endif;
	elseif theScale = 3 then
		if theBayArea.displayMode = ShpDisplayMode_Actual
		or theBayArea.displayMode = ShpDisplayMode_Proposed 
		or theBayArea.displayMode = ShpDisplayMode_ColCodeDisch
		or theBayArea.displayMode = ShpDisplayMode_ColCodeLoad 
		or theBayArea.displayMode = ShpDisplayMode_EDI then
			theFrame.drawFontSize := 8;
		else
			theFrame.drawFontSize := 9;
		endif;
	elseif theScale = 4 then
		if theBayArea.displayMode = ShpDisplayMode_Actual
		or theBayArea.displayMode = ShpDisplayMode_Proposed 
		or theBayArea.displayMode = ShpDisplayMode_ColCodeDisch
		or theBayArea.displayMode = ShpDisplayMode_ColCodeLoad  
		or theBayArea.displayMode = ShpDisplayMode_EDI then
			theFrame.drawFontSize := 10;
		else
			theFrame.drawFontSize := 10;
		endif;
	elseif theScale = 6 then
		if theBayArea.displayMode = ShpDisplayMode_Actual
		or theBayArea.displayMode = ShpDisplayMode_Proposed 
		or theBayArea.displayMode = ShpDisplayMode_ColCodeDisch
		or theBayArea.displayMode = ShpDisplayMode_ColCodeLoad  
		or theBayArea.displayMode = ShpDisplayMode_EDI then
			theFrame.drawFontSize := 16;
		else
			theFrame.drawFontSize := 20;
		endif;
	elseif theScale = 9 then
		if theBayArea.displayMode = ShpDisplayMode_Actual
		or theBayArea.displayMode = ShpDisplayMode_Proposed 
		or theBayArea.displayMode = ShpDisplayMode_ColCodeDisch
		or theBayArea.displayMode = ShpDisplayMode_ColCodeLoad  
		or theBayArea.displayMode = ShpDisplayMode_EDI then
			theFrame.drawFontSize := 20;
		else
			theFrame.drawFontSize := 24;
		endif;
	endif;
	
	
	// #######################
	// DRAW THE CHARACTER. First draw in white to highlight it
	
	if theBayArea.displayMode = ShpDisplayMode_Defn then
		theFrame.drawTextAlign := Frame.DrawTextAlign_Center; //Frame.DrawTextAlign_Left; //DrawTextAlign_Center;
		theFrame.drawTextAlign := Frame.DrawTextAlign_Left; 
	else
		theFrame.drawTextAlign := Frame.DrawTextAlign_Left; 
	endif;
	theCharacter := theDrawingAttribute.fontCharacter.Character;
//	theInverseColour := theColour.getInverseColour;
	
	if _theAttColour &lt; 0 then
		theColour := theDrawingAttribute.colour;
	else	
		theColour := _theAttColour;
	endif;

	theFrame.drawTextAt(theCharacter, tmpX,tmpY,theColour);
		
	if _theAttributePosition = 0 or _theAttributePosition = theAttributePosition then
		_theAttributePosition := theAttributePosition + 1;
	endif;
end;</source>
        <Parameter name="_theAttColour" type="Integer"/>
        <Parameter name="_theAttribute" type="String"/>
        <Parameter name="_theAttributePosition" type="Integer" usage="io"/>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawAttributeXYBayAct" id="73dc31b0-e8c9-4750-8cbc-cad68e45055a">
        <source>drawAttributeXYBayAct(_theX : Integer io; _theY : Integer io; _theAttributePosition : Integer) ;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		works out the X and Y for the attribute 'icon'
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theX, theY, tmpX, tmpY,theAttributePosition : Integer;
	scalefactor : Real;
begin
	theX := (self.x1 + ((self.x2 - self.x1) / 2)).Integer + 2;
	theY := (self.y1 + ((self.y2 - self.y1)/ 2)).Integer - 5;
	theAttributePosition := _theAttributePosition;
	scalefactor := self.myGridArea.scaleXFactor;
	
	if scalefactor = 9 then
		tmpY := (self.y2 - 35).Integer;
		if theAttributePosition = 1 then
			tmpX :=  self.x1.Integer + 2;
		elseif theAttributePosition = 2 then
			tmpX :=  self.x1.Integer +22;
		elseif theAttributePosition = 3 then
			tmpX :=  self.x1.Integer + 42;
		elseif theAttributePosition = 4 then
			tmpX :=  self.x1.Integer + 62;
		else
			tmpX := 0;
			tmpY := 0;
		endif;
	elseif scalefactor = 6 then
		tmpY := (self.y2 - 24).Integer;
		if theAttributePosition = 1 then
			tmpX :=  self.x1.Integer + 2;
		elseif theAttributePosition = 2 then
			tmpX :=  self.x1.Integer + 20;
		elseif theAttributePosition = 3 then
			tmpX :=  self.x1.Integer + 38;
		else
			tmpX := 0;
			tmpY := 0;
			
			
		endif;
	elseif scalefactor = 4 then
		tmpY := (self.y2 - 24).Integer;
		if theAttributePosition = 1 then
			tmpX :=  self.x1.Integer + 2;
		elseif theAttributePosition = 2 then
			tmpX :=  self.x1.Integer + 15;
		elseif theAttributePosition = 3 then
			tmpX :=  self.x1.Integer + 28;
		else
			tmpX := 0;
			tmpY := 0;
		endif;
	elseif scalefactor = 3 then
		tmpY := (self.y2 - 15).Integer;
		if theAttributePosition = 1 then
			tmpX :=  self.x1.Integer + 2;
		elseif theAttributePosition = 2 then
			tmpX :=  self.x1.Integer + 15;
		else
			tmpX := 0;
			tmpY := 0;
		endif;
	else
		if theAttributePosition = 1 then
			tmpX := self.x1.Integer + 1;
			theY := (self.y1 + ((self.y2 - self.y1)/ 3) * 2).Integer - 4;
			tmpY := theY;
		elseif theAttributePosition = 2  then
			tmpX := theX.Integer;
			theY := (self.y1 + ((self.y2 - self.y1)/ 3) * 2).Integer - 4;
			tmpY := theY.Integer;
/*
		elseif theAttributePosition = 3 then
			tmpX := self.x1.Integer + 1;
			theY := (self.y1 + ((self.y2 - self.y1)/ 3)).Integer - 4;
			tmpY := theY.Integer;
		elseif theAttributePosition = 4 then
			tmpX := theX;
			theY := (self.y1 + ((self.y2 - self.y1)/ 3) ).Integer - 4;
			tmpY := theY.Integer;
*/
		else
			tmpX := 0;
			tmpY := 0;
		endif;
	endif;

	if scalefactor = 4 and tmpY &gt; 0 then
		tmpY := tmpY + 3;			
	endif;

	_theX := tmpX;
	_theY := tmpY;
end;</source>
        <Parameter name="_theX" type="Integer" usage="io"/>
        <Parameter name="_theY" type="Integer" usage="io"/>
        <Parameter name="_theAttributePosition" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawAttributeXYBayDefn" id="176021a1-0a0f-4caa-a41d-a27d0b92b221">
        <source>drawAttributeXYBayDefn(_theX : Integer io; _theY : Integer io; _theAttributePosition : Integer) ;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		works out the X and Y for the attribute 'icon'
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theX, theY, tmpX, tmpY,theAttributePosition : Integer;
	theScale : Real;
begin
	theScale := self.myGridArea.scaleXFactor;
	// if 2 columns use this
//	theX := (self.x1 + ((self.x2 - self.x1) / 2)).Integer + 2;
//	theY := (self.y1 + ((self.y2 - self.y1)/ 2)).Integer - 5;
	// if 3 columns use this
	theX := ((self.x2 - self.x1) / 3).Integer + 2;
	theY := ((self.y2 - self.y1) / 3).Integer - 2;
//	theY := (self.y1 + ((self.y2 - self.y1)/ 3)).Integer - 5;
	theAttributePosition := _theAttributePosition;
	
	if self.amPrinting() then
		if theScale = SHP_BayArea.PrintScaleSmall then
			if theAttributePosition = 1 then
				tmpX := self.x1.Integer;
				tmpY := self.y1.Integer;
			else
				tmpX := 0;
				tmpY := 0;
			endif;
		elseif theScale = SHP_BayArea.PrintScaleMedium then
			if theAttributePosition = 1 then
				tmpX := self.x1.Integer + 2;
				tmpY := self.y1.Integer + 1;
			elseif theAttributePosition = 2 then
				tmpX := self.x1.Integer + 10;
				tmpY := self.y1.Integer + 1;
			elseif theAttributePosition = 3 then
				tmpX := self.x1.Integer + 2;
				tmpY := self.y1.Integer + 8;
			elseif theAttributePosition = 4 then
				tmpX := self.x1.Integer + 10;
				tmpY := self.y1.Integer + 8;
			else
				tmpX := 0;
				tmpY := 0;
			endif;
		else
		
		endif;
	elseif theScale = 1 then
		if theAttributePosition = 1 then
			tmpX := self.x1.Integer + 2;
			tmpY := self.y1.Integer + 1;
			
		else
			tmpX := 0;
			tmpY := 0;
		endif;
	elseif theScale = 1.5 then
		if theAttributePosition = 1 then
			tmpX := self.x1.Integer + 3;
			tmpY := self.y1.Integer + 1;
			
		else
			tmpX := 0;
			tmpY := 0;
		endif;
	elseif theScale = 2 then
		if theAttributePosition = 1 then
			tmpX := self.x1.Integer + 3;
			tmpY := self.y1.Integer + 1;
			
		else
			tmpX := 0;
			tmpY := 0;
		endif;
	else	
		if theAttributePosition = 1 then
			tmpX := self.x1.Integer + 2;
			tmpY := self.y1.Integer;
		elseif theAttributePosition = 2 then
			tmpX := self.x1.Integer + theX;
			tmpY := self.y1.Integer;
		elseif theAttributePosition = 3 then
			tmpX := self.x1.Integer + theX + theX - 2;
			tmpY := self.y1.Integer;
		elseif theAttributePosition = 4 then
			tmpX := self.x1.Integer + 2;
			tmpY := self.y1.Integer + theY;
		elseif theAttributePosition = 5 then
			tmpX := self.x1.Integer + theX;
			tmpY := self.y1.Integer + theY;
		elseif theAttributePosition = 6 then
			tmpX := self.x1.Integer + theX + theX - 2;
			tmpY := self.y1.Integer + theY;
		elseif theAttributePosition = 7 then
			tmpX := self.x1.Integer + 2;
			tmpY := self.y1.Integer + theY+ theY;
		elseif theAttributePosition = 8 then
			tmpX := self.x1.Integer + theX;
			tmpY := self.y1.Integer + theY+ theY;
		elseif theAttributePosition = 9 then
			tmpX := self.x1.Integer + theX + theX - 2;
			tmpY := self.y1.Integer + theY+ theY;
		else
			tmpX := 0;
			tmpY := 0;
		endif;
	endif;
	
	_theX := tmpX;
	_theY := tmpY;
end;</source>
        <Parameter name="_theX" type="Integer" usage="io"/>
        <Parameter name="_theY" type="Integer" usage="io"/>
        <Parameter name="_theAttributePosition" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawAttributeXYColCodeDisch" id="be830e92-3ad4-4a0d-b2f2-e119c23e1d21">
        <source>drawAttributeXYColCodeDisch(_theX : Integer io; _theY : Integer io; _theAttributePosition : Integer) ;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		works out the X and Y for the attribute 'icon'
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	theX, theY, tmpX, tmpY,theAttributePosition : Integer;
	theOffSet : Integer;
begin
	theX := (self.x1 + ((self.x2 - self.x1) / 2)).Integer + 2;
	theY := (self.y1 + ((self.y2 - self.y1)/ 2)).Integer - 5;
	theAttributePosition := _theAttributePosition;

	theOffSet := 8;
	
	if self.myGridArea.scaleXFactor = 4 then
		theOffSet := 6;
		if theAttributePosition &gt;= 3 then
			theOffSet := 2;
		endif;
	endif;
	if self.myGridArea.scaleXFactor = 3 then
		theX := (self.x1 + ((self.x2 - self.x1) / 2)).Integer + 2;
		theY := (self.y1 + ((self.y2 - self.y1)/ 2)).Integer ;
		if theAttributePosition = 1 then
			tmpX :=  (self.x1.Integer + 3);
			tmpY := theY.Integer;
		elseif theAttributePosition = 2 then
			tmpX := theX.Integer;
			tmpY := theY.Integer;
		else
			tmpX := 0;
			tmpY := 0;
		endif;
	elseif self.myGridArea.scaleXFactor = 2 or (self.amPrinting and self.myGridArea.scaleXFactor = SHP_BayArea.PrintScaleMedium) then
		theX := (self.x1 + ((self.x2 - self.x1) / 2)).Integer;
		theY := (self.y1 + ((self.y2 - self.y1)/ 2)).Integer - 1;
		if theAttributePosition = 1 then
			tmpX :=  (self.x1.Integer + 2);
			tmpY := theY.Integer;
		elseif theAttributePosition = 2 then
			tmpX := theX.Integer;
			tmpY := theY.Integer;
		else
			tmpX := 0;
			tmpY := 0;
		endif;
	else
		theY := (self.y1 + ((self.y2 - self.y1)/ 3) * 2).Integer - theOffSet;
		if theAttributePosition = 1 then
			tmpX := self.x1.Integer + 4;
			tmpY := theY;
		elseif theAttributePosition = 2 then
			tmpX := (self.x1 + ((self.x2 - self.x1)/ 3)).Integer ;
			tmpY := theY.Integer;
		elseif theAttributePosition = 3 then
			tmpX := (self.x1 + ((self.x2 - self.x1)/ 3) * 2).Integer ;
			tmpY := theY.Integer;
		else
			tmpX := 0;
			tmpY := 0;
		endif;
	endif;

 	if self.myGridArea.scaleXFactor = 4 and tmpY &gt; 0 then
		tmpY := tmpY ;  //+ 3;			
	endif;

	_theX := tmpX;
	_theY := tmpY;
end;</source>
        <Parameter name="_theX" type="Integer" usage="io"/>
        <Parameter name="_theY" type="Integer" usage="io"/>
        <Parameter name="_theAttributePosition" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawAttributeXYColCodeLoad" id="7a8417c7-4db2-4904-b826-4e293434ae05">
        <source>drawAttributeXYColCodeLoad(_theX : Integer io; _theY : Integer io; _theAttributePosition : Integer) ;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		works out the X and Y for the attribute 'icon'
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theX, theY, tmpX, tmpY,theAttributePosition : Integer;
	theOffSet : Integer;
begin
	theX := (self.x1 + ((self.x2 - self.x1) / 2)).Integer + 2;
	theY := (self.y1 + ((self.y2 - self.y1)/ 2)).Integer - 5;
	theAttributePosition := _theAttributePosition;

	theOffSet := 2;
	
	if self.myGridArea.scaleXFactor = 4 then
		theOffSet := 4;
		if theAttributePosition &gt;= 3 then
			theOffSet := 2;
		endif;
	endif;
	if self.myGridArea.scaleXFactor = 3 then
		theX := (self.x1 + ((self.x2 - self.x1) / 2)).Integer + 2;
		theY := (self.y1 + ((self.y2 - self.y1)/ 2)).Integer ;
		if theAttributePosition = 1 then
			tmpX :=  (self.x1.Integer + 3);
			tmpY := theY.Integer;
		elseif theAttributePosition = 2 then
			tmpX := theX.Integer;
			tmpY := theY.Integer;
		else
			tmpX := 0;
			tmpY := 0;
		endif;
	elseif self.myGridArea.scaleXFactor = 2 then
		theX := (self.x1 + ((self.x2 - self.x1) / 2)).Integer;
		theY := (self.y1 + ((self.y2 - self.y1)/ 2)).Integer - 1;
		if theAttributePosition = 1 then
			tmpX :=  (self.x1.Integer + 2);
			tmpY := theY.Integer;
		elseif theAttributePosition = 2 then
			tmpX := theX.Integer;
			tmpY := theY.Integer;
		else
			tmpX := 0;
			tmpY := 0;
		endif;
	else
		if theAttributePosition = 1 then
			tmpX := self.x1.Integer + 2;
			theY := (self.y1 + ((self.y2 - self.y1)/ 3) * 2).Integer - theOffSet;
			tmpY := theY;
		elseif theAttributePosition = 2 then
			tmpX := theX.Integer;
			theY := (self.y1 + ((self.y2 - self.y1)/ 3) * 2).Integer - theOffSet;
			tmpY := theY.Integer;
		elseif theAttributePosition = 3 then
			tmpX := self.x1.Integer + 2;
			theY := (self.y1 + ((self.y2 - self.y1)/ 3)).Integer - theOffSet;
			tmpY := theY.Integer;
		elseif theAttributePosition = 4 then
			tmpX := theX;
			theY := (self.y1 + ((self.y2 - self.y1)/ 3) ).Integer - theOffSet;
			tmpY := theY.Integer;
		else
			tmpX := 0;
			tmpY := 0;
		endif;
	endif;

 	if self.myGridArea.scaleXFactor = 4 and tmpY &gt; 0 then
		tmpY := tmpY + 3;			
	endif;

	_theX := tmpX;
	_theY := tmpY;
end;</source>
        <Parameter name="_theX" type="Integer" usage="io"/>
        <Parameter name="_theY" type="Integer" usage="io"/>
        <Parameter name="_theAttributePosition" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawBackend" id="699c40ee-aa81-4f08-8d60-1a2f0a92646c">
        <source>drawBackend() :Boolean;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	myBayArea : SHP_BayArea;
	drawBackEnd,iAMPrinting : Boolean;
	aSlotRequest : CM_SlotRequest;
begin
	myBayArea := self.myGridArea.SHP_BayArea;
	iAMPrinting := self.amPrinting;
	drawBackEnd := true;
	// do not draw the backend unless we want it
	if myBayArea.displayMode = ShpDisplayMode_Defn or  self.bayDefnUnavailable then
		drawBackEnd := false;
	// if there is Load CC here for a 2o do not show the actual TIs back end
	elseif myBayArea.displayMode = ShpDisplayMode_ColCodeLoad then
		if myBayArea.myJobSeqSheet = null then 
			if not  iAMPrinting and self.colLoadDischPortCode = null then // colLoadDischPortCode &lt;&gt; null this means that we have LOAD CC here which over rides any DISCHARGE DLR SOB stuff
				drawBackEnd := self.tiInfo40BackEnd;
			elseif self.colLoadFortyFoot and self.bayIsForward and self.bayIsAft then
				aSlotRequest :=  self.myLocationsController.CM_SlotController.mySlotRequestLoad;
				if aSlotRequest &lt;&gt; null then
					drawBackEnd := aSlotRequest.fortyBack; // THIS CONTROLLER IS NOT USED ANYMORE
				endif;
			elseif self.bayIsForward then
				drawBackEnd := false;
			elseif not (self.colLoadFortyFoot) then
				drawBackEnd := false;
			elseif self.colLoadDischPortCode &lt;&gt; null and self.colLoadFortyFoot = false then
				drawBackEnd := false;
			
			elseif iAMPrinting and self.colLoadFortyFoot = false then
				drawBackEnd := false;
			endif;
		elseif self.bayIsForward then
			drawBackEnd := false;
		elseif myBayArea.myJobSeqSheet &lt;&gt; self.colLoadMyJob then
			drawBackEnd := false;
		elseif myBayArea.myJobSeqSheet = self.colLoadMyJob then
			if not (self.colLoadFortyFoot and self.bayIsAft) then
				drawBackEnd := false;
			endif;
			
		endif;
	elseif myBayArea.displayMode = ShpDisplayMode_ColCodeDisch then
		if myBayArea.myJobSeqSheet &lt;&gt; null then // for sequence sheet
			if myBayArea.myJobSeqSheet &lt;&gt; self.colDischMyJob then
				drawBackEnd := false;
			else
				if self.bayIsForward then
					drawBackEnd := false;
				elseif not self.colDischFortyFoot then
					drawBackEnd := false;
				endif;
			endif;
		else
			if not  iAMPrinting and self.colDischDischPortCode = null then
				if myBayArea.useTransitColour then // PAR 8161 added
					drawBackEnd := false; // PAR 8161 added
				else // PAR 8161 added
					drawBackEnd := self.tiInfo40BackEnd;
					if self.colLoadDischPortCode &lt;&gt; null and not drawBackEnd then
						drawBackEnd := (self.colLoadFortyFoot and self.bayIsAft);
					endif;
				endif;
			elseif self.colDischFortyFoot and self.bayIsForward and self.bayIsAft then
				aSlotRequest :=  self.myLocationsController.CM_SlotController.mySlotRequestDischarge;
				if aSlotRequest &lt;&gt; null then
					drawBackEnd := aSlotRequest.fortyBack;
				endif;
			elseif self.bayIsForward then
				drawBackEnd := false;
			elseif not (self.colDischFortyFoot) then
				drawBackEnd := false;
			elseif myBayArea.myJobSeqSheet = null then 
				if (iAMPrinting and self.colDischFortyFoot and self.bayIsForward) then
					drawBackEnd := false;
				endif;
			elseif myBayArea.myJobSeqSheet &lt;&gt; self.colDischMyJob then
				drawBackEnd := false;
			endif;
		
		endif;

	elseif not (self.tiInfo40 and self.tiInfo40BackEnd) then
		drawBackEnd := false;
	elseif self.bayDefnUnavailable then
		drawBackEnd := false;
	endif;


	if iAMPrinting then
		if myBayArea.displayMode = ShpDisplayMode_Proposed then
			if myBayArea.imexMode = SHP_VoyageAreaForm2.ImexMode_Exports and (not self.bayProIsExport) then
				drawBackEnd := false;
			endif;
			if myBayArea.imexMode = SHP_VoyageAreaForm2.ImexMode_Imports and (not self.bayProIsImport) then // PAR 8267
				drawBackEnd := false; // PAR 8267
			endif;
		elseif myBayArea.displayMode = ShpDisplayMode_Actual then // PAR 8267
			if myBayArea.imexMode = SHP_VoyageAreaForm2.ImexMode_Exports and (not self.bayActIsExport) then // PAR 8267
				drawBackEnd := false; // PAR 8267
			endif;
			if myBayArea.imexMode = SHP_VoyageAreaForm2.ImexMode_Imports and (not self.bayActIsImport) then // PAR 8267
				drawBackEnd := false; // PAR 8267
			endif;

		endif;
	
	endif;
	return drawBackEnd;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawBayAct" id="f320c49b-d5d7-40d9-96f2-6e66ea67d75a">
        <updating/>
        <source>drawBayAct(_theFrame: CMUI_GridAreaFrame input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theFrame: CMUI_GridAreaFrame;
	iAMPrinting : Boolean;
	theLabel : String;
	theGridAttributes : CMUI_GridAttributes;
	theX, theY, tmpX, tmpY,theAttribCount : Integer;
	theFontName : String;
	theDrawTextAlign : Integer;
	theFontSize : Real;
	tmpBayArea : SHP_BayArea;
	theTI : CM_TrackedItem;
	tm_x2, tm_x1,tm_y1,tm_y2	: Real;
	theImexMode,
	lOuterColourUpper,
	lOuterColourLower, 
	theViewMode,
	tmpDrawFillColor	: Integer;
	myX2, myX1, myY1, myY2	: Real;
	smallOutput,drawTI : Boolean;
begin


	if self.bayDefnUnavailable then
		return;
	endif;
	myX1 := self.x1;
	myX2 := self.x2;
	myY1 := self.y1;
	myY2 := self.y2;
	drawTI := true;
	iAMPrinting := self.amPrinting();
	theFrame := _theFrame;
	theFontName := theFrame.drawFontName;
	theFontSize := theFrame.drawFontSize;
	theFrame.setDefaultFont();

	theDrawTextAlign := theFrame.drawTextAlign;
	tmpBayArea := self.myGridArea.SHP_BayArea;
	smallOutput := (iAMPrinting and tmpBayArea.scaleXFactor = SHP_BayArea.PrintScaleSmall);
	theViewMode := tmpBayArea.mySDF.viewMode;
	theImexMode	:= tmpBayArea.imexMode;

	// if I am selected then draw highlighted
	if  self.bayDefnUnavailable then
		tmpDrawFillColor := Black; //DarkGray;
	elseif self.drawBackend then
		tmpDrawFillColor := White;
	else
		// if this TI is not part of the selection then draw white
		if (not self.allTrackedItems.isEmpty) and
		   (not tmpBayArea.mySDF.allSelectorTIs.isEmpty) and
		   (not tmpBayArea.mySDF.allSelectorTIs.includes(self.allTrackedItems.first)) then
			tmpDrawFillColor := White;

		elseif theImexMode = SHP_VoyageAreaForm2.ImexMode_Imports and (not self.bayActIsImport) then
			if iAMPrinting then
				drawTI := false;
			endif;
			tmpDrawFillColor := White;

		elseif theImexMode = SHP_VoyageAreaForm2.ImexMode_Exports and (not self.bayActIsExport) then
			if iAMPrinting then
				drawTI := false;
			endif;
			tmpDrawFillColor := White;

		else
			if self.displayColoursACT.isEmpty then
				tmpDrawFillColor := White;
			else
				tmpDrawFillColor := self.displayColoursACT[theViewMode];
				if tmpDrawFillColor &lt; 0 then
					tmpDrawFillColor := White;
				endif;
			endif;
		endif;
	endif;

	if (iAMPrinting and self.showNoColours()) then
		tmpDrawFillColor := White;
	elseif tmpDrawFillColor = NullColour then
		tmpDrawFillColor := White;
	endif;
	// only draw the unavailable slots in bay definition
	// else always draw the slot
	tm_y1 := myY1;
	tm_x2 := myX2;

	tm_x2 := tm_x2 - 1;
	tm_y2 := myY2 - 1;

	if self.myGridArea.allSelectedPoints.includes(self) then
		lOuterColourUpper := DarkGray;
		lOuterColourLower := White;
		theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
		theFrame.drawStyle := Frame.DrawFillStyle_Solid;
		theFrame.drawWidth := 1;
		tmpDrawFillColor := Gray;

	elseif self.myGridArea.allSelectedPointsAlt.includes(self) then
		lOuterColourUpper := DarkGray;
		lOuterColourLower := White;
		theFrame.drawStyle := Frame.DrawFillStyle_Solid;
		theFrame.drawFillStyle := Frame.DrawFillStyle_Solid; //DrawFillStyle_DiagonalCross;
		theFrame.drawWidth := 1;
		tmpDrawFillColor := DarkGray;
	elseif not iAMPrinting then
		lOuterColourLower := DarkGray;
		theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
		theFrame.drawStyle := Frame.DrawFillStyle_Solid;
		theFrame.drawWidth := 1;
		if tmpBayArea.displayMode = ShpDisplayMode_Defn or iAMPrinting then
			lOuterColourUpper := Gray;
		else
			lOuterColourUpper := White;
		endif;
	endif;
	
	self.theDrawFillColor := tmpDrawFillColor;
	theFrame.drawFillColor := tmpDrawFillColor;
	

	if smallOutput then // printing small
		theFrame.drawFilledRectangle(myX1, myY1, myX2, myY2, DarkGray); 
	else
		theFrame.drawFilledRectangle(myX1, myY1, myX2, myY2, Black); 
	
		theFrame.drawLine(myX1, tm_y1, tm_x2 + 1, tm_y1,  lOuterColourUpper);
		theFrame.drawLine(myX1, tm_y1, myX1, tm_y2,  lOuterColourUpper);
		theFrame.drawLine(tm_x2, tm_y1 + 1, tm_x2, tm_y2 + 1,  lOuterColourLower);
		theFrame.drawLine(myX1, tm_y2, tm_x2, tm_y2,  lOuterColourLower);
	endif;
	if drawTI then
		self.drawTI(theFrame, null, theGridAttributes, myX1, myY1, myX2, myY2);
	endif;
end;</source>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawBayActSAVE_RJS" id="c849350b-c5cc-47a1-92fc-3a9e3c33be86">
        <updating/>
        <source>drawBayActSAVE_RJS(_theFrame: CMUI_GridAreaFrame input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theFrame: CMUI_GridAreaFrame;
	theLabel : String;
	theGridAttributes : CMUI_GridAttributes;
	theX, theY, tmpX, tmpY,theAttribCount : Integer;
	theFontName : String;
	theDrawTextAlign : Integer;
	theFontSize : Real;
	tmpBayArea : SHP_BayArea;
	theTI : CM_TrackedItem;
	tm_x2, tm_x1,tm_y1,tm_y2	: Real;
	lOuterColourUpper,
	lOuterColourLower, 
	theViewMode,
	tmpDrawFillColor	: Integer;
begin

	if self.bayDefnUnavailable then
		return;
	endif;
	theFrame := _theFrame;
	
	theFontName := theFrame.drawFontName;
	theFontSize := theFrame.drawFontSize;
	theFrame.setDefaultFont();

	theDrawTextAlign := theFrame.drawTextAlign;
	tmpBayArea := myGridArea.SHP_BayArea;
	theViewMode := tmpBayArea.mySDF.viewMode;

	// if I am selected then draw highlighted
	if self.bayDefnUnavailable then
		theFrame.drawFillColor := Black; //DarkGray;
	else
		// if this TI is not part of the selection then draw white
		if (not self.allTrackedItems.isEmpty) and
		   (not tmpBayArea.mySDF.allSelectorTIs.isEmpty) and
		   (not tmpBayArea.mySDF.allSelectorTIs.includes(self.allTrackedItems.first)) then
			theFrame.drawFillColor := White;

		elseif theViewMode &lt;&gt; VIEW_IMPORT and theViewMode &lt;&gt; VIEW_EXPORT then
			if self.displayColoursACT.isEmpty then
				theFrame.drawFillColor := White;
			else
				theFrame.drawFillColor := self.displayColoursACT[theViewMode];
			endif;
		endif;
	endif;

	self.theDrawFillColor := theFrame.drawFillColor;

	if theViewMode = VIEW_IMPORT then
		if not self.bayActIsImport then
			theFrame.drawFillColor := White;
		else
			theFrame.drawFillColor := self.theDrawFillColor;
		endif;
	endif;

	if theViewMode = VIEW_EXPORT then
		if (not self.bayActIsExport) then
			theFrame.drawFillColor := White;
		else
			theFrame.drawFillColor := self.theDrawFillColor;
		endif;

	endif;
	
	if theFrame.drawFillColor &lt; 0 then
		theFrame.drawFillColor := White;
	endif;
	// only draw the unavailable slots in bay definition
	// else always draw the slot
	tm_y1 := self.y1;
	tm_x2 := self.x2;

	tm_x2 := tm_x2 - 1;
	tm_y2 := self.y2 - 1;

	self.theDrawFillColor := theFrame.drawFillColor;
	if self.myGridArea.allSelectedPoints.includes(self) then

		lOuterColourUpper := DarkGray;
		lOuterColourLower := White;
		theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
		theFrame.drawStyle := Frame.DrawFillStyle_Solid;
		theFrame.drawWidth := 1;
		theFrame.drawFillColor := Gray;
	elseif self.myGridArea.allSelectedPointsAlt.includes(self) then

		lOuterColourUpper := DarkGray;
		lOuterColourLower := White;
		theFrame.drawStyle := Frame.DrawFillStyle_Solid;
		theFrame.drawFillStyle := Frame.DrawFillStyle_Solid; //DrawFillStyle_DiagonalCross;
		theFrame.drawWidth := 1;
		theFrame.drawFillColor := DarkGray;
	else
		lOuterColourLower := DarkGray;
		theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
		theFrame.drawStyle := Frame.DrawFillStyle_Solid;
		theFrame.drawWidth := 1;
		if tmpBayArea.displayMode = ShpDisplayMode_Defn or self.amPrinting then
			lOuterColourUpper := Gray;
		else
			lOuterColourUpper := White;
		endif;
	endif;
	
	self.theDrawFillColor := theFrame.drawFillColor;
	theFrame.drawFilledRectangle(self.x1, self.y1, self.x2, self.y2, Black); 

	theFrame.drawLine(self.x1, tm_y1, tm_x2 + 1, tm_y1,  lOuterColourUpper);
	theFrame.drawLine(self.x1, tm_y1, self.x1, tm_y2,  lOuterColourUpper);
	theFrame.drawLine(tm_x2, tm_y1 + 1, tm_x2, tm_y2 + 1,  lOuterColourLower);
	theFrame.drawLine(self.x1, tm_y2, tm_x2, tm_y2,  lOuterColourLower);
	
	self.drawTI(theFrame, null, theGridAttributes, self.x1, self.y1, self.x2, self.y2);

end;</source>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawBayDefn" id="46807c79-56e8-4d5b-b255-1f389994c8d9">
        <updating/>
        <source>drawBayDefn(_theFrame: CMUI_GridAreaFrame input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theFrame: CMUI_GridAreaFrame;
	theLabel : String;
	theDrawingAttribute : CM_DrawingAttribute;
	theX, theY, tmpX, tmpY,theAttribCount : Integer;
	theFontName : String;
	theDrawTextAlign : Integer;
	theFontSize : Real;
	theAftBay : CM_Bay;
	myBayArea : SHP_BayArea;

	tm_x2, tm_x1,tm_y1,tm_y2	: Real;
	lOuterColourUpper,	lOuterColourLower, theViewMode : Integer;
	myX2, myX1, myY1, myY2	: Real;
begin
	myX1 := self.x1;
	myX2 := self.x2;
	myY1 := self.y1;
	myY2 := self.y2;
	theFrame := _theFrame;
	theFontName := theFrame.drawFontName;
	theFontSize := theFrame.drawFontSize;
	theDrawTextAlign := theFrame.drawTextAlign;
	myBayArea := myGridArea.SHP_BayArea;
	theViewMode := myBayArea.mySDF.viewMode;
	
	if self.bayDefnUnavailable then
		theFrame.drawFillColor := Black; //DarkGray;
	else
		theFrame.drawFillColor := White;
	endif;
	
	// only draw the unavailable slots in bay definition
	// else always draw the slot
	tm_y1 := myY1;
	tm_x2 := myX2;

	tm_x2 := tm_x2 - 1;
	tm_y2 := myY2 - 1;

//	if not self.bayDefnUnavailable or (self.bayDefnUnavailable and myBayArea.mode = SHP_BayArea.Mode_BayDefn) then
		self.theDrawFillColor := theFrame.drawFillColor;
		if self.myGridArea.allSelectedPoints.includes(self) then

			lOuterColourUpper := DarkGray;
			lOuterColourLower := White;
			theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
			theFrame.drawStyle := Frame.DrawFillStyle_Solid;
			theFrame.drawWidth := 1;
			theFrame.drawFillColor := Gray;
		elseif self.myGridArea.allSelectedPointsAlt.includes(self) then

			lOuterColourUpper := DarkGray;
			lOuterColourLower := White;
			theFrame.drawStyle := Frame.DrawFillStyle_Solid;
			theFrame.drawFillStyle := Frame.DrawFillStyle_Solid; //DrawFillStyle_DiagonalCross;
			theFrame.drawWidth := 1;
			theFrame.drawFillColor := DarkGray;
		else
			lOuterColourLower := DarkGray;
			theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
			theFrame.drawStyle := Frame.DrawFillStyle_Solid;
			theFrame.drawWidth := 1;
			if myBayArea.displayMode = ShpDisplayMode_Defn or self.amPrinting then
				lOuterColourUpper := Gray;
			else
				lOuterColourUpper := White;
			endif;
		endif;
		
		self.theDrawFillColor := theFrame.drawFillColor;
		theFrame.drawFilledRectangle(myX1, myY1, myX2, myY2, Black); 

		//	theFrame.drawFilledRectangle(myX1, tm_y1, tm_x2, tm_y2,  theFrame.drawFillColor); 
		theFrame.drawLine(myX1, tm_y1, tm_x2 + 1, tm_y1,  lOuterColourUpper);
		theFrame.drawLine(myX1, tm_y1, myX1, tm_y2,  lOuterColourUpper);
		theFrame.drawLine(tm_x2, tm_y1 + 1, tm_x2, tm_y2 + 1,  lOuterColourLower);
		theFrame.drawLine(myX1, tm_y2, tm_x2, tm_y2,  lOuterColourLower);
//	endif;

	if self.myGridArea.scaleXFactor &lt;= 1 and not self.amPrinting() then
		return;
	endif;
	theAttribCount := 1;
	
	if self.myGridArea.SHP_BayArea.showSeqNum or self.myGridArea.SHP_BayArea.showSeqNum40 then
		// ###########
		// UNAVAILABLE	
		if self.bayDefnUnavailable then
			self.drawAttribute(-1,PicTIUnavail,theAttribCount,theFrame);
		else
			if not self.myGridArea.SHP_BayArea.showSeqNum40 then
				theFrame.drawFontSize := 7;
				theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
				theFrame.drawTextAt(self.mySlotDefn.sequenceNumPortDis.String,myX1 + 3, myY1 + 2, Green);
				theFrame.drawTextAt(self.mySlotDefn.sequenceNumPortLoad.String,myX1 + 3, myY1 + 12, Blue);
		
				theFrame.drawTextAlign := Frame.DrawTextAlign_Right;
				theFrame.drawTextAt(self.mySlotDefn.sequenceNumStarDis.String,myX2 - 3, myY1 + 2, Green);
				theFrame.drawTextAt(self.mySlotDefn.sequenceNumStarLoad.String,myX2 -3, myY1 + 12, Blue);
			else
				theFrame.drawFontSize := 7;
				theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
				theFrame.drawTextAt(self.mySlotDefn.sequenceNumPortDis40.String,myX1 + 3, myY1 + 2, Green);
				theFrame.drawTextAt(self.mySlotDefn.sequenceNumPortLoad40.String,myX1 + 3, myY1 + 12, Blue);
		
				theFrame.drawTextAlign := Frame.DrawTextAlign_Right;
				theFrame.drawTextAt(self.mySlotDefn.sequenceNumStarDis40.String,myX2 - 3, myY1 + 2, Green);
				theFrame.drawTextAt(self.mySlotDefn.sequenceNumStarLoad40.String,myX2 -3, myY1 + 12, Blue);
			endif;
		endif;
		return;
	endif;
	// ###########
	// UNAVAILABLE	
	if self.bayDefnUnavailable then
		self.drawAttribute(-1,PicTIUnavail,theAttribCount,theFrame);
		return;
	endif;

	// ###########
	// DOORS 20
	if self.bayDefnDoorDirection20 then
		self.drawAttribute(-1,PicTIDoorsAft,theAttribCount,theFrame);
	else
		self.drawAttribute(-1,PicTIDoorsFwd,theAttribCount,theFrame);
	endif;
	// ###########
	// DOORS 40
	if self.bayDefnDoorDirection40 then
		self.drawAttribute(-1,PicTIDoorsAft40,theAttribCount,theFrame);
	else
		self.drawAttribute(-1,PicTIDoorsFwd40,theAttribCount,theFrame);
	endif;

	// ###########
	// FORTYFOOT
	if self.bayDefnFortyFoot then
		/* PAR 14712
		if self.bayIsAft then
			self.drawAttribute(-1,PicTI40FooterBackEnd,theAttribCount,theFrame);
		else
			self.drawAttribute(-1,PicTI40Footer,theAttribCount,theFrame);
		endif;
		*/
		if self.bayIsForward then
			self.drawAttribute(-1,PicTI40Footer,theAttribCount,theFrame);
		else
			self.drawAttribute(-1,PicTI40FooterBackEnd,theAttribCount,theFrame);
		endif;
	endif;

	// PAR 16415 CCMS 1029
	// ###########
	// THIRTYFOOT
	if self.bayDefnThirtyFoot then
		if self.bayIsForward then
			self.drawAttribute(-1,PicTI30Footer,theAttribCount,theFrame);
		else
			self.drawAttribute(-1,PicTI30FooterBE,theAttribCount,theFrame);
		endif;
	endif;

	// PAR 16415 CCMS 1029
	// ###########
	// FIFTY THREE FOOT
	if self.bayDefnFiftyThreeFoot then
		if self.bayIsForward then
			self.drawAttribute(-1,PicTI53Footer,theAttribCount,theFrame);
		else
			self.drawAttribute(-1,PicTI53FooterBE,theAttribCount,theFrame);
		endif;
	endif;

	// PAR 16882 CCMS 1055
	// ###########
	// FORTY FIVE FOOT
	if self.bayDefnFortyFive then
		if self.bayIsForward then
			self.drawAttribute(-1,PicTI45Footer,theAttribCount,theFrame);
		else
			self.drawAttribute(-1,PicTI45FooterBackEnd,theAttribCount,theFrame);
		endif;
	endif;

	// ###########
	// REEFER
	if self.bayDefnReefer then
		self.drawAttribute(-1,PicTIReefer,theAttribCount,theFrame);
	endif;

	// ###########
	// POWERED
	if self.bayDefnPowered then
		self.drawAttribute(-1,PicTIConnected,theAttribCount,theFrame);
	endif;
	

	// ###########
	// WATERCOOLED	
	if self.bayDefnWaterCooled then
		self.drawAttribute(-1,PicTIWaterCooled,theAttribCount,theFrame);
	endif;

	// ###########
	// MTs ONLY
	if self.bayDefnMtOnly then
		self.drawAttribute(-1,PicTIMTOnly,theAttribCount,theFrame);
	endif;

	// ###########
	// HEAVY
	if self.bayDefnHeavy then
		self.drawAttribute(-1,PicTIHeavy,theAttribCount,theFrame);
	endif;

	// ###########
	// VOLTAGE TYPE
	if self.bayDefnVoltage &gt; 0 then
		if self.bayDefnVoltage = 1 then
			self.drawAttribute(-1,PicTIVoltageSingle,theAttribCount,theFrame);
		elseif self.bayDefnVoltage = 2 then
			self.drawAttribute(-1,PicTIVoltageDual,theAttribCount,theFrame);
		endif;
	endif;

	// #############
	// Leave these motor forward calls last

	// ###########
	//  MOTOR 20
	if  self.bayDefnMotorDirection20 then
		self.drawAttribute(-1,PicTIMotorAft,theAttribCount,theFrame);
	else
		self.drawAttribute(-1,PicTIMotorFwd,theAttribCount,theFrame);
	endif;
	// ###########
	//  MOTOR 20
	if  self.bayDefnMotorDirection40 then
		self.drawAttribute(-1,PicTIMotorAft40,theAttribCount,theFrame);
	else
		self.drawAttribute(-1,PicTIMotorFwd40,theAttribCount,theFrame);
	endif;

end;</source>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawBayPro" id="346661a0-a61c-4201-99f0-be23d31e95fc">
        <updating/>
        <source>drawBayPro(_theFrame: CMUI_GridAreaFrame input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theFrame: CMUI_GridAreaFrame;
	theLabel : String;
	theDrawingAttribute : CMUI_GridAttributes;
	theX, theY, tmpX, tmpY,theAttribCount : Integer;
	theFontName : String;
	theDrawTextAlign : Integer;
	theFontSize : Real;
	myBayArea : SHP_BayArea;
	theTI : CM_TrackedItem;
	tm_x2, tm_x1,tm_y1,tm_y2	: Real;
	theImexMode,
	tmpDrawFillColor,
	lOuterColourUpper,	lOuterColourLower, theViewMode : Integer;
	myX2, myX1, myY1, myY2	: Real;
	smallOutput,iAMPrinting,drawTI : Boolean;
begin

	if self.bayDefnUnavailable then
		return;
	endif;

	myX1 := self.x1;
	myX2 := self.x2;
	myY1 := self.y1;
	myY2 := self.y2;
	drawTI := true;
	theFrame := _theFrame;
	theFontName := theFrame.drawFontName;
	theFontSize := theFrame.drawFontSize;
	theDrawTextAlign := theFrame.drawTextAlign;
	myBayArea := myGridArea.SHP_BayArea;
	theViewMode := myBayArea.mySDF.viewMode;
	theImexMode	:= myBayArea.imexMode;
	iAMPrinting := self.amPrinting();
	smallOutput := (iAMPrinting and myBayArea.scaleXFactor = SHP_BayArea.PrintScaleSmall);
	
	// if I am selected then draw highlighted
	if  self.bayDefnUnavailable then
		tmpDrawFillColor := Black; //DarkGray;
	elseif self.drawBackend then
		tmpDrawFillColor := White;
	else
		if theImexMode = SHP_VoyageAreaForm2.ImexMode_Imports and (not self.bayProIsImport) then
			if iAMPrinting then
				drawTI := false;
			endif;
			tmpDrawFillColor := White;

		elseif theImexMode = SHP_VoyageAreaForm2.ImexMode_Exports and (not self.bayProIsExport) then
			if iAMPrinting then
				drawTI := false;
			endif;
			tmpDrawFillColor := White;

		else
			if self.displayColoursPRO.isEmpty then
				tmpDrawFillColor := White;
			else
				tmpDrawFillColor := self.displayColoursPRO[theViewMode];
				if tmpDrawFillColor &lt; 0 then
					tmpDrawFillColor := White;
				endif;
			endif;
		endif;
	endif;
	if (iAMPrinting and self.showNoColours()) then
		tmpDrawFillColor := White;
	elseif tmpDrawFillColor = NullColour then
		tmpDrawFillColor := White;
	endif;
	
	// only draw the unavailable slots in bay definition
	// else always draw the slot
	tm_y1 := myY1;
	tm_x2 := myX2;

	tm_x2 := tm_x2 - 1;
	tm_y2 := myY2 - 1;

	if (not self.bayDefnUnavailable)  then
		self.theDrawFillColor := tmpDrawFillColor;
		if self.myGridArea.allSelectedPoints.includes(self) then

			lOuterColourUpper := DarkGray;
			lOuterColourLower := White;
			theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
			theFrame.drawStyle := Frame.DrawFillStyle_Solid;
			theFrame.drawWidth := 1;
			tmpDrawFillColor := Gray;
		elseif self.myGridArea.allSelectedPointsAlt.includes(self) then

			lOuterColourUpper := DarkGray;
			lOuterColourLower := White;
			theFrame.drawStyle := Frame.DrawFillStyle_Solid;
			theFrame.drawFillStyle := Frame.DrawFillStyle_Solid; //DrawFillStyle_DiagonalCross;
			theFrame.drawWidth := 1;
			tmpDrawFillColor := DarkGray;
		else
			lOuterColourLower := DarkGray;
			theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
			theFrame.drawStyle := Frame.DrawFillStyle_Solid;
			theFrame.drawWidth := 1;
			if myBayArea.displayMode = ShpDisplayMode_Defn or self.amPrinting then
				lOuterColourUpper := Gray;
			else
				lOuterColourUpper := White;
			endif;
		endif;
		
		self.theDrawFillColor := tmpDrawFillColor;
		theFrame.drawFillColor := tmpDrawFillColor;
		if smallOutput then // printing small
			theFrame.drawFilledRectangle(myX1, myY1, myX2, myY2, DarkGray); 
		else
			theFrame.drawFilledRectangle(myX1, myY1, myX2, myY2, Black); 

			//	theFrame.drawFilledRectangle(myX1, tm_y1, tm_x2, tm_y2,  theFrame.drawFillColor); 
			theFrame.drawLine(myX1, tm_y1, tm_x2 + 1, tm_y1,  lOuterColourUpper);
			theFrame.drawLine(myX1, tm_y1, myX1, tm_y2,  lOuterColourUpper);
			theFrame.drawLine(tm_x2, tm_y1 + 1, tm_x2, tm_y2 + 1,  lOuterColourLower);
			theFrame.drawLine(myX1, tm_y2, tm_x2, tm_y2,  lOuterColourLower);
		endif;
	else
		theFrame.drawFillColor := tmpDrawFillColor;
	endif;

	if drawTI then
		self.drawTI(theFrame, null, theDrawingAttribute, myX1, myY1, myX2, myY2);
	endif;
end;</source>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawColCodeDisch" id="45b84bd6-76fa-43f1-a8fd-72e2fdc5fabd">
        <updating/>
        <source>drawColCodeDisch(_theFrame: CMUI_GridAreaFrame input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theFrame: CMUI_GridAreaFrame;
	theLabel : String;
	theDrawingAttribute : CM_DrawingAttribute;
	theX, theY, tmpX, tmpY,theAttribCount,theColour : Integer;
	theFontName : String;
	theDrawTextAlign : Integer;
	theFontSize : Real;
	myBayArea : SHP_BayArea;
	theNeighborPoint,aPoint : CMUI_GridPoint;
	dlrWidth,offset,offsetY : Integer;
	lOuterColourUpper,	lOuterColourLower : Integer;
	pLocn,iAmPrinting : Boolean;
	tm_x2, tm_x1,tm_y1,tm_y2	: Real;
	myDischPort : CM_Port;
	smallOutput,is40BackEnd,mediumOutput,largeOutput : Boolean;
	myX2, myX1, myY1, myY2	: Real;
	scalefactor : Real;
	useTransitColour : Boolean;
	
	doDrawBackEnd : Boolean;
begin
	doDrawBackEnd := self.drawBackend();



	if self.bayDefnUnavailable then
		return;
	endif;
	myX1 := self.x1;
	myX2 := self.x2;
	myY1 := self.y1;
	myY2 := self.y2;
	if self.colDischFortyFoot then
		is40BackEnd := self.drawBackend();
//		if self.bayIsAft then // PAR 7899 removed
//			is40BackEnd := true;
//		endif;
	endif;


	myDischPort := self.colDischMyDischPort;
	iAmPrinting := self.amPrinting();
	theFrame := _theFrame;
	theFontName := theFrame.drawFontName;
	theFontSize := theFrame.drawFontSize;
	theDrawTextAlign := theFrame.drawTextAlign;
	myBayArea := myGridArea.SHP_BayArea;
	scalefactor := myBayArea.scaleXFactor;
	smallOutput := (iAmPrinting and scalefactor = SHP_BayArea.PrintScaleSmall);	
	mediumOutput := (iAmPrinting and scalefactor = SHP_BayArea.PrintScaleMedium);	
	largeOutput := (iAmPrinting and scalefactor = SHP_BayArea.PrintScaleLarge);	
	useTransitColour := myBayArea.useTransitColour();
	
	if myDischPort = null then
		theFrame.drawFillColor := White;
		theFrame.drawFilledRectangle(myX1, myY1, myX2, myY2, White); 
	endif;	
	// if I am selected then draw highlighted
	if (iAmPrinting and self.showNoColours()) then
		theFrame.drawFillColor := White;
	elseif (iAmPrinting and myBayArea.myJobSeqSheet &lt;&gt; null) then
		theFrame.drawFillColor := White;
		
	elseif myDischPort &lt;&gt; null then
		theFrame.drawFillColor := self.colDischDischPortColour; //myDischPort.colour;
	else
		if self.displayColoursACT.isEmpty then
			theFrame.drawFillColor := White;
		else
			if useTransitColour and self.colLoadDischPortCode = null  then
				theFrame.drawFillColor := White; //myBayArea.getTransitColour();
			elseif useTransitColour and self.colLoadDischPortCode &lt;&gt; null then
				theFrame.drawFillColor := White;
			else
				theFrame.drawFillColor := self.displayColoursACT[VIEW_DISPORT];
			endif;
		endif;
	endif;

	if theFrame.drawFillColor = NullColour then
		theFrame.drawFillColor := White;
	endif;
	// only draw the unavailable slots in bay definition
	// else always draw the slot
	tm_y1 := myY1;
	tm_x2 := myX2;

	tm_x2 := tm_x2 - 1;
	tm_y2 := myY2 - 1;

	if self.myGridArea.allSelectedPoints.includes(self) then
		if self.myGridArea.allSelectedPointsAlt.includes(self) then
			lOuterColourUpper := DarkGray;
			lOuterColourLower := White;
			theFrame.drawFillColor := Red;
		else
			lOuterColourUpper := DarkGray;
			lOuterColourLower := White;
			theFrame.drawFillColor := Gray;
		endif;
	elseif self.myGridArea.allSelectedPointsAlt.includes(self) then
		lOuterColourUpper := DarkGray;
		lOuterColourLower := White;
		theFrame.drawFillColor := DarkGray;
	elseif doDrawBackEnd   then
		theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
		theFrame.drawFillColor := White;
		lOuterColourLower := DarkGray;
		lOuterColourUpper := White;
	elseif not smallOutput then
		lOuterColourLower := DarkGray;
		if myBayArea.displayMode = ShpDisplayMode_Defn or iAmPrinting then
			lOuterColourUpper := Gray;
		else
			lOuterColourUpper := White;
		endif;
	endif;
	theFrame.drawWidth := 1;
	theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
	theFrame.drawStyle := Frame.DrawFillStyle_Solid;
	// I am in DISCHARGE Colour Code mode. There is a TI in this point but it is not coded for discharge so draw non solid
	if myDischPort = null then
		if self.allTrackedItems.isEmpty = false then
			if not (self.colDischDLR or self.colDischSOB) then
				if iAmPrinting then
					theFrame.drawFillColor := White;
				elseif not useTransitColour then
					theFrame.drawFillStyle := Frame.DrawFillStyle_DiagonalCross;
				endif;
			endif;
		else
			// the slot has no discharge colour coding but it has load colour coding, so show it
			if self.colLoadDischPortCode &lt;&gt; null 
			and not iAmPrinting 
			and not useTransitColour // PAR 8161 added
			and not doDrawBackEnd then
				theFrame.drawFillStyle := Frame.DrawFillStyle_Cross; //DrawFillStyle_VertLine; //DrawFillStyle_DownDiagonal;

//				if useTransitColour then // PAR 8161 removed
//					theFrame.drawFillColor := White; // PAR 8161 removed
//				else // PAR 8161 removed
					theFrame.drawFillColor := self.colLoadDischPortColour;
//				endif; // PAR 8161 removed
			endif;
		endif;
	endif;
	
	self.theDrawFillColor := theFrame.drawFillColor;
	theColour := self.theDrawFillColor.getInverseColour(); 
	if smallOutput then // printing small
		theFrame.drawFilledRectangle(myX1, myY1, myX2, myY2, DarkGray); 
	else
		theFrame.drawFilledRectangle(myX1, myY1, myX2, myY2, Black); 
	
		//	theFrame.drawFilledRectangle(myX1, tm_y1, tm_x2, tm_y2,  theFrame.drawFillColor); 
		theFrame.drawLine(myX1, tm_y1, tm_x2 + 1, tm_y1,  lOuterColourUpper);
		theFrame.drawLine(myX1, tm_y1, myX1, tm_y2,  lOuterColourUpper);
		theFrame.drawLine(tm_x2, tm_y1 + 1, tm_x2, tm_y2 + 1,  lOuterColourLower);
		theFrame.drawLine(myX1, tm_y2, tm_x2, tm_y2,  lOuterColourLower);
	endif;
	if myBayArea.myJobSeqSheet = null then // only if not printing SeqSheet Report
	if (self.colDischDLR or self.colDischSOB) and not doDrawBackEnd then // or (self.colDischMyJob &lt;&gt; null and self.colDischMyJobIsComplete) then
//		if  (self.colDischMyJob &lt;&gt; null and self.colDischMyJobIsComplete) then
//			theFrame.drawFillColor := Black;
		if self.colDischDLR then
			theFrame.drawFillColor := COLOUR_DLR; //Green;
		elseif self.colDischSOB then
			theFrame.drawFillColor := COLOUR_SOB; //Blue;
		endif;
		
		theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
		if self.myGridArea.scaleXFactor = 1 then
			dlrWidth := ((myX2 - myX1) / 3).Integer;
		else
			dlrWidth := ((myX2 - myX1) / 3).Integer;
		endif;


		if self.myGridArea.allSelectedPoints.includes(self) then
			lOuterColourUpper := White;
			lOuterColourLower := DarkGray;
		else
			lOuterColourUpper := DarkGray;
			lOuterColourLower := White;
		endif;
		theFrame.drawFilledRectangle(myX1 + dlrWidth , myY1 + dlrWidth, myX2 - dlrWidth, myY2 - dlrWidth, White); 
//		self.theDrawFillColor := theFrame.drawFillColor;
		
		theFrame.drawLine(myX1 + dlrWidth, myY1 + dlrWidth, myX2 - dlrWidth, myY1 + dlrWidth,  lOuterColourUpper);
		theFrame.drawLine(myX1 + dlrWidth, myY1 + dlrWidth, myX1 + dlrWidth, myY2 - dlrWidth,  lOuterColourUpper);
		theFrame.drawLine(myX2 - dlrWidth - 1, myY1 + dlrWidth + 1, myX2 - dlrWidth - 1,  myY2 - dlrWidth - 1,  lOuterColourLower);
		theFrame.drawLine(myX1 + dlrWidth,  myY2 - dlrWidth, myX2 - dlrWidth,  myY2 - dlrWidth,  lOuterColourLower);
	endif;
	endif;
	// are we linked?
	if self.colDischDLR or self.colDischSOB   then
		if self.colDischReqLinked and myBayArea.myJobSeqSheet = null then
			self.drawMark(theFrame,LightGreen,1,iAmPrinting,scalefactor);
		endif;
	endif;

	if  (self.colDischMyJob &lt;&gt; null and self.colDischMyJobIsComplete) then
		if iAmPrinting and myBayArea.myJobSeqSheet &lt;&gt; null then
			if self.colDischMyJob = myBayArea.myJobSeqSheet then
				self.drawMark(theFrame,Black,2,iAmPrinting,scalefactor);
			endif;
		else
			self.drawMark(theFrame,Black,2,iAmPrinting,scalefactor);
//process.debug;
app.writeStatement( class.name &amp; '::' &amp; method.name &amp; 
		' self.colDischMyJob = ' &amp; self.colDischMyJob.String &amp;
		'  self.colDischMyJobIsComplete = ' &amp; self.colDischMyJobIsComplete.asStringJMT);

		endif;
	endif;

	if myBayArea.myJobSeqSheet = null then
		if  smallOutput  then
			if myDischPort &lt;&gt; null then
				if myDischPort.ccodePrint.trimBlanks &lt;&gt; null then
					theLabel := myDischPort.ccodePrint[1:1];
				else
					theLabel := myDischPort.code[1:1];
				endif;
				theFrame.setDefaultFont();
				theFrame.drawFontSize := 6;
				theFrame.drawTextAt(theLabel,myX1,myY1,Black);
			endif;
		elseif self.myGridArea.scaleXFactor &gt;= 2 or mediumOutput then
			// only draw the actual TI info in the point if we have colour coded the point for discharge
			if myDischPort &lt;&gt; null and not myBayArea.workingMode = SHP_VoyageAreaForm2.WorkMode_CustomSeq then
			if not self.drawBackend then	
				if mediumOutput or largeOutput then
					theLabel := self.colDischDischPortCode.trimBlanks;
				else
					theLabel := self.colDischCommodityGroupCode.trimBlanks;
				endif;
				if  myBayArea.workingMode = SHP_VoyageAreaForm2.WorkMode_Plan then
					if scalefactor = 2  or scalefactor = SHP_BayArea.PrintScaleMedium  then
					elseif scalefactor = 3 then
						tm_y1 := myY1 + 6;
					elseif scalefactor = 4 then
						tm_y1 := myY1 + 8;
					elseif scalefactor = 6 then
						tm_y1 := myY1 + 14;
					elseif scalefactor = 9 then
						tm_y1 := myY1 + 22;
					endif;
				else
					tm_y1 := myY1;
				endif;
				self.drawColCodeLabel(theFrame, theColour,smallOutput, iAmPrinting,myX1, tm_y1,scalefactor,theLabel);
//				self.drawTI(theFrame, null, null, myX1, myY1, myX2, myY2);
			endif;
			endif;
		endif;	
	endif;

	if myBayArea.myJobSeqSheet = null then
		if iAmPrinting then
			self.drawColCodeDischViewModeLegend();
		endif;
	endif;
	if doDrawBackEnd then
		return;
	endif;
	// ###############
	// DRAW THE JOB BOUNDARY
	if not iAmPrinting
	or (iAmPrinting and myBayArea.myJobSeqSheet &lt;&gt; null and  myBayArea.myJobSeqSheet = self.colDischMyJob) then
		self.drawJobBoundary(theFrame);	
	endif;
	
	if scalefactor &lt; 2 and not mediumOutput then
		return;
	endif;

	theFrame.drawWidth := 1;
	// ###################
	// SEQUENCE NUMBER
	self.drawSequenceNumber();
	
//	return;
	
	
	
	
	
	
	
	
	
	if   myBayArea.workingMode = SHP_VoyageAreaForm2.WorkMode_CustomSeq then
		return;
	endif;
	if (iAmPrinting and myBayArea.myJobSeqSheet &lt;&gt; null) then
		return;
	endif;
	if scalefactor &lt; 2 and not mediumOutput   then
		return;
	endif;
	
	// ###########
	// FORTYFOOT
	if self.colDischFortyFoot then
		if is40BackEnd then
			self.drawAttribute(theColour,PicTI40FooterBackEnd,theAttribCount,theFrame);
		else
			self.drawAttribute(theColour,PicTI40Footer,theAttribCount,theFrame);
		endif;
	endif;
	// PAR 7959 FROM HERE 
	if  self.colDischMyCargoType &lt;&gt; null then 
		// ###########
		// BREAKBULK
		if self.colDischMyCargoType.id = TI_CargoType_BreakBulk then
			self.drawAttribute(theColour,PicTIBreakBulk,theAttribCount,theFrame);
		endif;
		// ###########
		// TIMBER
		if self.colDischMyCargoType.id = TI_CargoType_Timber then
			self.drawAttribute(theColour,PicTITimber,theAttribCount,theFrame);
		endif;
	endif;	
	// PAR 7959 TO HERE 
	// ###########
	// POWERED
	if self.colDischPower then
		self.drawAttribute(theColour,PicTIConnected,theAttribCount,theFrame);
	endif;
	// ###########
	// HAZARD
	if self.colDischIsHazardous then
		self.drawAttribute(theColour,PicTIHazard,theAttribCount,theFrame);
	endif;
	
	// ###########
	// OVERSIZED
	if self.colDischOverDimensioned then
		self.drawAttribute(theColour,PicTIOversized,theAttribCount,theFrame);
	endif;
	
	
	// ###########
	// HIGH CUBED	
	if self.colDischHiCube then
		self.drawAttribute(theColour,PicTIHiCube,theAttribCount,theFrame);
	endif;

	// ###########
	// REEFER
	if self.colDischReefer then
		self.drawAttribute(theColour,PicTIReefer,theAttribCount,theFrame);
	endif;


	// ###########
	// WATERCOOLED	
	if self.colDischWaterCooled then
		self.drawAttribute(theColour,PicTIWaterCooled,theAttribCount,theFrame);
	endif;

	// ###########
	// MTs ONLY
	if self.colDischEmpty then
		self.drawAttribute(theColour,PicTIEmpty,theAttribCount,theFrame);
	endif;
	theFrame.drawWidth := 1;
	
epilog
end;</source>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawColCodeDischViewModeLegend" id="8d8acf9d-1112-4b90-8688-4d08f0852d9f">
        <source>drawColCodeDischViewModeLegend();
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theCode : String;
	theViewMode : Integer;
	theSDF : CMUI_ScrollableDrawingFrame;
begin
	theSDF := self.myGridArea.mySDF;

	if self.colDischMyDischPort &lt;&gt; null then
		theCode := self.colDischMyDischPort.code;
	endif;
	if theCode = null then
		return;
	endif;	

	if theSDF &lt;&gt; null then
		if not theSDF.myViewModeAttribute.allDisplayIcons.includes(theCode) then
			theSDF.myViewModeAttribute.allDisplayIcons.add(theCode);
			theSDF.myViewModeAttribute.allDisplayColors.add(self.theDrawFillColor);
		endif;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="drawColCodeLabel" id="12e8334f-434d-4a3a-a44a-913f80df4da2">
        <source>drawColCodeLabel(_theFrame : CMUI_GridAreaFrame input;
					 _theColour : Integer;
					_smallOutput, _iAmPrinting : Boolean;
					_myX1, _myY1,_scalefactor : Real; 
					_theLabel : String);
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tmpX, tmpY : Integer;
	theLabel : String;
begin
		theLabel := _theLabel;
		tmpX := (_myX1 + 3).Integer;
		tmpY := (_myY1 + 2).Integer;
		if _smallOutput then
			_theFrame.drawFontSize := 6;
			_theFrame.drawFontBold := true;
			tmpX := (_myX1 + 1).Integer;
			tmpY := (_myY1).Integer;
		elseif _scalefactor = 1 then // only when printing
			_theFrame.drawFontSize := 6;
			tmpY := (_myY1 + 1).Integer;
		elseif _scalefactor = 1.5 then // only when printing
			_theFrame.drawFontSize := 8;
			tmpY := (_myY1 + 1).Integer;
		elseif _scalefactor = 2  or (amPrinting and _scalefactor = SHP_BayArea.PrintScaleMedium)   then
			if _iAmPrinting then
				tmpX := (_myX1 + 1).Integer;
				tmpY := (_myY1).Integer;
				_theFrame.drawFontSize := 6;
			else
				_theFrame.drawFontSize := 6;
			endif;
			theLabel := theLabel[1:3];
		elseif _scalefactor = 3 then
			if _iAmPrinting then
				tmpY := (_myY1).Integer;
				_theFrame.drawFontSize := 8;
			else
				_theFrame.drawFontSize := 7;
			endif;
		elseif _scalefactor = 4 then
			if _iAmPrinting then
				tmpY := (_myY1 + 3).Integer;
				_theFrame.drawFontSize := 10;
			else
			_theFrame.drawFontSize := 9;
			endif;
			tmpX := (_myX1 + 4).Integer;
		elseif _scalefactor = 6 then
			_theFrame.drawFontSize := 14;
			tmpX := (_myX1 + 5).Integer;
		elseif _scalefactor = 9 then
			_theFrame.drawFontSize := 18;
			tmpX := (_myX1 + 5).Integer;
		endif;
		_theFrame.drawTextAt(theLabel, tmpX, tmpY,_theColour);
		_theFrame.drawFontBold := false;

end;</source>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="_theColour" type="Integer"/>
        <Parameter name="_smallOutput" type="Boolean"/>
        <Parameter name="_iAmPrinting" type="Boolean"/>
        <Parameter name="_myX1" type="Real"/>
        <Parameter name="_myY1" type="Real"/>
        <Parameter name="_scalefactor" type="Real"/>
        <Parameter name="_theLabel" type="String"/>
    </JadeMethod>
    <JadeMethod name="drawColCodeLoad" id="c78364cd-f203-45bd-87eb-12d38eea184e">
        <updating/>
        <source>drawColCodeLoad(_theFrame: CMUI_GridAreaFrame input) updating;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theFrame: CMUI_GridAreaFrame;
	theLabel : String;
	theAttribCount, theColour : Integer;
	theFontName : String;
	theDrawTextAlign : Integer;
	theFontSize : Real;
	 dlrWidth,lOuterColourUpper,lOuterColourLower : Integer;
	myBayArea : SHP_BayArea;
	iAmPrinting, is40BackEnd : Boolean;
	tm_x2, tm_y1,tm_y2, scalefactor	: Real;
	smallOutput : Boolean;
	myX2, myX1, myY1, myY2	: Real;
	useTransitColour : Boolean;
	doDrawBackEnd : Boolean;
begin
	doDrawBackEnd := self.drawBackend();


	if self.bayDefnUnavailable then
		return;
	endif;
	myX1 := self.x1;
	myX2 := self.x2;
	myY1 := self.y1;
	myY2 := self.y2;

	theFrame := _theFrame;
	iAmPrinting := self.amPrinting();
	myBayArea := self.myGridArea.SHP_BayArea;
	theFontName := theFrame.drawFontName;
	theFontSize := theFrame.drawFontSize;
	theDrawTextAlign := theFrame.drawTextAlign;
	smallOutput := (iAmPrinting and myBayArea.scaleXFactor = SHP_BayArea.PrintScaleSmall);	
	useTransitColour := myBayArea.useTransitColour();
	if self.colLoadFortyFoot then
		is40BackEnd := self.drawBackend();
		
//		if self.bayIsAft then // PAR 7899 removed
//			is40BackEnd := true;
//		endif;
	endif;

	scalefactor := myBayArea.scaleXFactor;
	theFrame.drawFillColor := White;

	// if I am selected then draw highlighted
	if (iAmPrinting and self.showNoColours()) then
		theFrame.drawFillColor := White;
	elseif (iAmPrinting and myBayArea.myJobSeqSheet &lt;&gt; null) then
		theFrame.drawFillColor := White;
		
	elseif self.colLoadDischPortColour &gt; NullColour then //and not (self.colDischDLR or self.colDischSOB)  then
		theFrame.drawFillColor := self.colLoadDischPortColour;
	else
		if self.allTrackedItems.isEmpty then
			theFrame.drawFillColor := White;
		elseif not  iAmPrinting then

			// we are going to draw an actual TI where we have no Load Colour coding. We will not draw in solid colour so we need to draw a white backgrnd first
			theFrame.drawFillColor := White;
			theFrame.drawFilledRectangle(myX1, myY1, myX2, myY2, White); 
			
			if self.displayColoursACT.isEmpty then
				theFrame.drawFillColor := White;
			elseif useTransitColour and self.colDischMyDischPort = null then
				if  myBayArea.workingMode = SHP_VoyageAreaForm2.WorkMode_Job 
				or  myBayArea.workingMode = SHP_VoyageAreaForm2.WorkMode_CustomSeq 
				or  myBayArea.workingMode = SHP_VoyageAreaForm2.WorkMode_Plan then
					theFrame.drawFillColor := White;
				else
					theFrame.drawFillColor := myBayArea.getTransitColour();
				endif;
			elseif useTransitColour and self.colDischMyDischPort &lt;&gt; null then
				theFrame.drawFillColor := White;
			else
				theFrame.drawFillColor := self.displayColoursACT[VIEW_DISPORT];
			endif;
		endif;
	endif;
	if theFrame.drawFillColor = NullColour then
		theFrame.drawFillColor := White;
	endif;
	// only draw the unavailable slots in bay definition
	// else always draw the slot
	tm_y1 := myY1;
	tm_x2 := myX2;

	tm_x2 := tm_x2 - 1;
	tm_y2 := myY2 - 1;

	self.theDrawFillColor := theFrame.drawFillColor;
	if myBayArea.allSelectedPoints.includes(self) then

		lOuterColourUpper := DarkGray;
		lOuterColourLower := White;
		theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
		theFrame.drawStyle := Frame.DrawFillStyle_Solid;
		theFrame.drawWidth := 1;
		theFrame.drawFillColor := Gray;
	elseif myBayArea.allSelectedPointsAlt.includes(self) then

		lOuterColourUpper := DarkGray;
		lOuterColourLower := White;
		theFrame.drawStyle := Frame.DrawFillStyle_Solid;
		theFrame.drawFillStyle := Frame.DrawFillStyle_Solid; //DrawFillStyle_DiagonalCross;
		theFrame.drawWidth := 1;
		theFrame.drawFillColor := DarkGray;
	elseif doDrawBackEnd then //and self.colLoadDischPortCode = null then
		theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
		theFrame.drawFillColor := White;
		lOuterColourLower := DarkGray;
		lOuterColourUpper := White;
	elseif not smallOutput then
		lOuterColourLower := DarkGray;
		theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
		theFrame.drawStyle := Frame.DrawFillStyle_Solid;
		theFrame.drawWidth := 1;
		if  self.amPrinting then
			lOuterColourUpper := Gray;
		else
			lOuterColourUpper := White;
		endif;
	endif;
	
	self.theDrawFillColor := theFrame.drawFillColor;

	theFrame.drawWidth := 1;
	theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
	theFrame.drawStyle := Frame.DrawFillStyle_Solid;

	// I am in LOAD Colour Code mode. There is a TI in this point but there is no load colour coding. Show the actual TI  non solid
	if not  iAmPrinting and self.colLoadDischPortCode = null then // colLoadDischPortCode &lt;&gt; null this means that we have LOAD CC here which over rides any DISCHARGE DLR SOB stuff
		// we are in LOAD CC mode, but we have a TI here and it is DISCH CC for DLR or SOB
		if (self.colDischDLR or self.colDischSOB) 
		and not useTransitColour
		and not self.allTrackedItems.isEmpty then
			theFrame.drawFillStyle := Frame.DrawFillStyle_Cross; 
		elseif self.colLoadDischPortCode = null and self.allTrackedItems.isEmpty = false then
			// the slot has actual cargo that is colour coded for discharge sho different from no load actual TI
			if self.colDischMyDischPort &lt;&gt; null and not useTransitColour then

				theFrame.drawFillStyle := Frame.DrawFillStyle_Cross; //DrawFillStyle_HorzLine; //DrawFillStyle_DiagonalCross;
			elseif useTransitColour then
				theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
			else
				theFrame.drawFillStyle := Frame.DrawFillStyle_DiagonalCross; //DrawFillStyle_UpDiagonal;
			endif;
		endif;
	endif;

	if smallOutput then // printing small
		theFrame.drawFilledRectangle(myX1, myY1, myX2, myY2, DarkGray); 
	else
		theFrame.drawFilledRectangle(myX1, myY1, myX2, myY2, Black); 
		// ### 3D Effects
		theFrame.drawLine(myX1, tm_y1, tm_x2 + 1, tm_y1,  lOuterColourUpper);
		theFrame.drawLine(myX1, tm_y1, myX1, tm_y2,  lOuterColourUpper);
		theFrame.drawLine(tm_x2, tm_y1 + 1, tm_x2, tm_y2 + 1,  lOuterColourLower);
		theFrame.drawLine(myX1, tm_y2, tm_x2, tm_y2,  lOuterColourLower);
	endif;
	theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
	// ### indicate the Discharge CC SOB or DLR with a square
	if not  iAmPrinting and not doDrawBackEnd then
		if (self.colDischDLR or self.colDischSOB) 
		and not self.allTrackedItems.isEmpty 
		and self.colLoadDischPortCode = null 
		and not useTransitColour then
			dlrWidth := ((myX2 - myX1) / 3).Integer;
			if self.colDischDLR then
				theFrame.drawFillColor := COLOUR_DLR; //Green;
			elseif self.colDischSOB then
				theFrame.drawFillColor := COLOUR_SOB; //Blue;
			endif;
			theFrame.drawFilledRectangle(myX1 + dlrWidth , myY1 + dlrWidth, myX2 - dlrWidth, myY2 - dlrWidth, Black); 
		endif;
	endif;
	// ### indicate the Load CC SOB or DLR with a square
	if not (iAmPrinting and myBayArea.myJobSeqSheet &lt;&gt; null) and not doDrawBackEnd then
		if self.colLoadDLR or self.colLoadSOB then //or (self.colLoadMyJob &lt;&gt; null and self.colLoadMyJobIsComplete) then
			if self.colLoadDLR then
				theFrame.drawFillColor := COLOUR_DLR; //Green;
			elseif self.colLoadSOB then
				theFrame.drawFillColor := COLOUR_SOB; //Blue;
			endif;
			theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;
			if scalefactor = 1 then
				dlrWidth := ((myX2 - myX1) / 3).Integer;
			else
				dlrWidth := ((myX2 - myX1) / 3).Integer;
			endif;
			if myBayArea.allSelectedPoints.includes(self) then
				lOuterColourUpper := White;
				lOuterColourLower := DarkGray;
			else
				lOuterColourUpper := DarkGray;
				lOuterColourLower := White;
			endif;
	
			theFrame.drawFilledRectangle(myX1 + dlrWidth , myY1 + dlrWidth, myX2 - dlrWidth, myY2 - dlrWidth, White); 
			if not iAmPrinting then
				// ### 3D Effects
				theFrame.drawLine(myX1 + dlrWidth, myY1 + dlrWidth, myX2 - dlrWidth, myY1 + dlrWidth,  lOuterColourUpper);
				theFrame.drawLine(myX1 + dlrWidth, myY1 + dlrWidth, myX1 + dlrWidth, myY2 - dlrWidth,  lOuterColourUpper);
				theFrame.drawLine(myX2 - dlrWidth - 1, myY1 + dlrWidth + 1, myX2 - dlrWidth - 1,  myY2 - dlrWidth - 1,  lOuterColourLower);
				theFrame.drawLine(myX1 + dlrWidth,  myY2 - dlrWidth, myX2 - dlrWidth,  myY2 - dlrWidth,  lOuterColourLower);
			endif;
		endif;
//		endif;
	endif;
	if self.colLoadDLR or self.colLoadSOB  then
		if self.colLoadReqLinked  and myBayArea.myJobSeqSheet = null then
			self.drawMark(theFrame,LightGreen,1,iAmPrinting,scalefactor);
		endif;
	endif;

	if  (self.colLoadMyJob &lt;&gt; null and self.colLoadMyJobIsComplete) then
		if iAmPrinting and myBayArea.myJobSeqSheet &lt;&gt; null then
			if self.colLoadMyJob = myBayArea.myJobSeqSheet then
				self.drawMark(theFrame,Black,2,iAmPrinting,scalefactor);
			endif;
		else
			self.drawMark(theFrame,Black,2,iAmPrinting,scalefactor);
		endif;
	endif;

	if iAmPrinting then
		self.drawColCodeLoadViewModeLegend();
	endif;

	if doDrawBackEnd then
		return;
	endif;
	// ###############
	// DRAW THE JOB BOUNDARY
	if not iAmPrinting 
	or (iAmPrinting and myBayArea.myJobSeqSheet &lt;&gt; null and  myBayArea.myJobSeqSheet = self.colLoadMyJob) then
		self.drawJobBoundary(theFrame);
	endif;
	if (scalefactor &lt; 2 and not iAmPrinting) 
	or is40BackEnd then
		return;
	endif;
	
	
	
	// ####################
	// COMMODITY &amp; DISCHARGE PORT
	theColour := self.theDrawFillColor.getInverseColour(); //self.colLoadMyDischPort.colour.getInverseColour();
	theFrame.drawFontName := "Helvetica";
	
	if iAmPrinting and self.colLoadMyDischPort &lt;&gt; null then
		if smallOutput then
			if self.colLoadMyDischPort.ccodePrint.trimBlanks &lt;&gt; null then
				theLabel := self.colLoadMyDischPort.ccodePrint[1:1];
			else
				theLabel := self.colLoadDischPortCode[1:1];
			endif;
		else
			theLabel := self.colLoadDischPortCode[1:3];
		
		endif;
	else
		theLabel := self.colLoadCommodityGroupCode.trimBlanks;
	endif;
	if myBayArea.inPlaningOrSequenceMode 
	or (iAmPrinting and myBayArea.myJobSeqSheet &lt;&gt; null) then
		// ###################
		// SEQUENCE NUMBER
		self.drawSequenceNumber();
	else	 
		self.drawColCodeLabel(theFrame, theColour,smallOutput, iAmPrinting,myX1, myY1,scalefactor,theLabel);
	endif;	
	
	if   myBayArea.workingMode = SHP_VoyageAreaForm2.WorkMode_CustomSeq then
		return;
	endif;
	if (iAmPrinting and myBayArea.myJobSeqSheet &lt;&gt; null) then
		return;
	endif;
	if scalefactor &lt; 2 and not (amPrinting and scalefactor = SHP_BayArea.PrintScaleMedium)   then
		return;
	endif;
	// ###########
	// FORTYFOOT
	if self.colLoadFortyFoot then
		if is40BackEnd then
			self.drawAttribute(theColour,PicTI40FooterBackEnd,theAttribCount,theFrame);
		else
			self.drawAttribute(theColour,PicTI40Footer,theAttribCount,theFrame);
		endif;
	endif;
	// PAR 7959 FROM HERE 
	if  self.colLoadMyCargoType &lt;&gt; null then
		// ###########
		// BREAKBULK
		if self.colLoadMyCargoType.id = TI_CargoType_BreakBulk then
			self.drawAttribute(theColour,PicTIBreakBulk,theAttribCount,theFrame);
		endif;
		// ###########
		// TIMBER
		if self.colLoadMyCargoType.id = TI_CargoType_Timber then
			self.drawAttribute(theColour,PicTITimber,theAttribCount,theFrame);
		endif;
	endif;	
	// PAR 7959 FROM HERE 
	// ###########
	// WATERCOOLED	
	if self.colLoadWaterCooled then
		self.drawAttribute(theColour,PicTIWaterCooled,theAttribCount,theFrame);
	endif;

	// ###########
	// POWERED
	if self.colLoadPower then
		self.drawAttribute(theColour,PicTIConnected,theAttribCount,theFrame);
	endif;
	// ###########
	// HAZARD
	if self.colLoadIsHazardous then
		self.drawAttribute(theColour,PicTIHazard,theAttribCount,theFrame);
	endif;
	
	// ###########
	// OVERSIZED
	if self.colLoadIsOverDimensioned then
		self.drawAttribute(theColour,PicTIOversized,theAttribCount,theFrame);
	endif;
	
	
	// ###########
	// UNAVAILABLE	
	if self.colLoadUnavailable then
		self.drawAttribute(theColour,PicTIUnavail,theAttribCount,theFrame);
		return;
	endif;
	
	// ###########
	// HIGH CUBED	
	if self.colLoadHiCube then
		self.drawAttribute(theColour,PicTIHiCube,theAttribCount,theFrame);
	endif;

	// ###########
	// HALF HEIGHT	
	if self.colLoadHalfHeight then
		self.drawAttribute(theColour,PicTIHalfHeight,theAttribCount,theFrame);
	endif;

	// #############
	// MOTOR DIRECTION
	if  self.colLoadMotorDirection20 = Motor_Forward then
		self.drawAttribute(theColour,PicTIMotorFwd,theAttribCount,theFrame);
	elseif  self.colLoadMotorDirection20 = Motor_Aft then
		self.drawAttribute(theColour,PicTIMotorAft,theAttribCount,theFrame);
	elseif  self.colLoadMotorDirection40 = Motor_Aft then
		self.drawAttribute(theColour,PicTIMotorAft40,theAttribCount,theFrame);
	elseif  self.colLoadMotorDirection40 = Motor_Forward then
		self.drawAttribute(theColour,PicTIMotorFwd40,theAttribCount,theFrame);
	// DOOR DIRECTION
	elseif  self.colLoadDoorDirection20 = TI_DOORSDIRN_FWD then
		self.drawAttribute(theColour,PicTIDoorsFwd,theAttribCount,theFrame);
	elseif  self.colLoadDoorDirection20 = TI_DOORSDIRN_AFT then
		self.drawAttribute(theColour,PicTIDoorsAft,theAttribCount,theFrame);
	elseif  self.colLoadDoorDirection40 = TI_DOORSDIRN_AFT then
		self.drawAttribute(theColour,PicTIDoorsAft40,theAttribCount,theFrame);
	elseif  self.colLoadDoorDirection40 = TI_DOORSDIRN_FWD then
		self.drawAttribute(theColour,PicTIDoorsFwd40,theAttribCount,theFrame);
	endif;

	// ###########
	// PORTHOLE
	if self.colLoadPortHole then
		self.drawAttribute(theColour,PicTIReefer,theAttribCount,theFrame);
	endif;


	// ###########
	// MTs ONLY
	if self.colLoadEmpty then
		self.drawAttribute(theColour,PicTIEmpty,theAttribCount,theFrame);
	endif;
	theFrame.drawWidth := 1;

epilog
end;</source>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawColCodeLoadViewModeLegend" id="23734b2d-8fe5-419e-8c95-6f86af5802b9">
        <source>drawColCodeLoadViewModeLegend();
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theCode : String;
	theViewMode : Integer;
	theSDF : CMUI_ScrollableDrawingFrame;
begin
	theSDF := self.myGridArea.mySDF;

	if self.colLoadMyDischPort &lt;&gt; null then
		theCode := self.colLoadMyDischPort.code;
	endif;
	if theCode = null then
		return;
	endif;	

	if theSDF &lt;&gt; null then
		if not theSDF.myViewModeAttribute.allDisplayIcons.includes(theCode) then
			theSDF.myViewModeAttribute.allDisplayIcons.add(theCode);
			theSDF.myViewModeAttribute.allDisplayColors.add(self.theDrawFillColor);
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="drawJobBoundary" id="1fc9dab1-ce4d-484c-b286-35f8bd3164dd">
        <updating/>
        <source>drawJobBoundary(_theFrame: CMUI_GridAreaFrame input) updating;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theFrame: CMUI_GridAreaFrame;
	theLabel : String;
	theDrawingAttribute : CM_DrawingAttribute;
	theX, theY, tmpX, tmpY,theAttribCount, theColour : Integer;
	theFontName : String;
	theDrawTextAlign : Integer;
	theFontSize : Real;
	theAftBay : CM_Bay;
	myBayArea : SHP_BayArea;
	theNeighborPoint,aPoint : CMUI_GridPoint;
	offset1, offset2,dlrWidth,lOuterColourUpper,lOuterColourLower,jobColour : Integer;
	myJob, neighbourJob : CM_VoyageJob;
	inLoadMode, isComplete : Boolean;
begin
	theFrame := _theFrame;
	// ###############
	// DRAW THE JOB BOUNDARY
	inLoadMode := self.myGridArea.SHP_BayArea.displayMode = ShpDisplayMode_ColCodeLoad;
	
	if inLoadMode then
		myJob := self.colLoadMyJob;
	else
		myJob := self.colDischMyJob;
	endif;
	if myJob &lt;&gt; null then
//		isComplete := myJob.isJobComplete; // add later this will slow down
//		if isComplete then
//			jobColour := Gray;
//		else
//			jobColour := Black;
//		endif;
		jobColour := Black;
		myBayArea := self.myGridArea.SHP_BayArea;
		if self.myGridArea.scaleXFactor &lt; 2 then
			theFrame.drawWidth := 2;
		elseif self.myGridArea.scaleXFactor = 2 then
			theFrame.drawWidth := 2;
		elseif self.myGridArea.scaleXFactor &lt; 6 then
			theFrame.drawWidth := 2;
		else
			theFrame.drawWidth := 3;
		
		endif;
		offset1 := 1;
		offset2 := 1;
		if self.myGridArea.scaleXFactor = 2 then
			offset2 := 1;
		endif;
		// ############
		// LEFT hand side
		theNeighborPoint := myBayArea.allGridPoints[self.row, self.column - 1];
		if self.drawJobBoundaryCheck(inLoadMode,theNeighborPoint) then
			theFrame.drawLine(self.x1 + offset1,self.y1,self.x1 + offset1,self.y2,jobColour);
		endif;
		// ############
		// RIGHT hand side
		theNeighborPoint := myBayArea.allGridPoints[self.row, self.column + 1];
		if self.drawJobBoundaryCheck(inLoadMode,theNeighborPoint) then
			theFrame.drawLine(self.x2 - offset2,self.y1,self.x2 - offset2,self.y2,jobColour);
		endif;
		// ############
		// TOP hand side
		theNeighborPoint := myBayArea.allGridPoints[self.row - 1, self.column];
		if self.drawJobBoundaryCheck(inLoadMode,theNeighborPoint) then
			theFrame.drawLine(self.x1,self.y1 + offset1,self.x2,self.y1 + offset1,jobColour);
		endif;
		// ############
		// BOTTOM hand side
		theNeighborPoint := myBayArea.allGridPoints[self.row + 1, self.column];
		if self.drawJobBoundaryCheck(inLoadMode,theNeighborPoint) then
			theFrame.drawLine(self.x1,self.y2 - offset2,self.x2,self.y2 - offset2,jobColour);
		endif;
	endif;	
epilog
	theFrame.drawWidth := 1;
end;</source>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawJobBoundaryCheck" id="000021e7-ae48-4965-b7c8-56857fd8c4ad">
        <source>drawJobBoundaryCheck(_inLoadMode : Boolean; __theNeighbour : CMUI_GridPoint) : Boolean;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	myJob, neighbourJob : CM_VoyageJob;

begin
	if __theNeighbour = null then
		return true;
	endif;
	if not __theNeighbour.isKindOf(SHP_BayPoint) then
		return true;
	endif;

	if _inLoadMode then
		myJob := self.colLoadMyJob;
	else
		myJob := self.colDischMyJob;
	endif;

	if _inLoadMode then
		if myJob &lt;&gt; __theNeighbour.SHP_BayPoint.colLoadMyJob then
			return true;
		endif;
	else
		if myJob &lt;&gt; __theNeighbour.SHP_BayPoint.colDischMyJob then
			return true;
		endif;
	endif;

	return false;

end;</source>
        <Parameter name="_inLoadMode" type="Boolean"/>
        <Parameter name="__theNeighbour" type="CMUI_GridPoint"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawMark" id="f789c5f9-bfb6-4678-959f-10076d97d92a">
        <source>drawMark(_theFrame : CMUI_GridAreaFrame input; _markColour : Integer; _markPosition : Integer; _amPrinting : Boolean; _scale : Real);
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
constants
	MARK_WIDTH = 6;
	MARK_GAP = 2;
vars
	myX2, myY2	: Real;

begin
	if _markPosition &gt; _scale then
		return;
	endif;
	
	if _amPrinting then
		return;
	endif;

	myY2 := self.y2;
	myX2 := self.x2 - ((MARK_WIDTH + MARK_GAP) * (_markPosition - 1));

	_theFrame.drawFillColor := _markColour;
	_theFrame.drawFilledRectangle(myX2 - 1, myY2 - MARK_WIDTH, myX2 - MARK_WIDTH, myY2 - 1,_markColour);

end;</source>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="_markColour" type="Integer"/>
        <Parameter name="_markPosition" type="Integer"/>
        <Parameter name="_amPrinting" type="Boolean"/>
        <Parameter name="_scale" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawSelf" id="da522a71-b149-47fb-bc15-4f63b0a7f497">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>drawSelf(_theFrame: CMUI_GridAreaFrame input) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		December 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theFrame: CMUI_GridAreaFrame;
	theFontName : String;
	theDrawTextAlign : Integer;
	theFontSize : Real;
	myBayArea : SHP_BayArea;
	backEndPadding, theColour : Integer;
	configDraw40BackEndAttrib : Boolean;
begin
//_theFrame.drawFilledRectangle(self.x1, self.y1, self.x2, self.y2, Black); 
//return;

	myBayArea := myGridArea.SHP_BayArea;
	theFrame := _theFrame;
	
	if not myBayArea.drawMe then
		return;
	endif;
	
	configDraw40BackEndAttrib := false;
	theFontName := theFrame.drawFontName;
	theFontSize := theFrame.drawFontSize;
	theDrawTextAlign := theFrame.drawTextAlign;
//	theViewMode := myBayArea.mySDF.viewMode;

	
	if myBayArea.displayMode = ShpDisplayMode_Defn then
		self.drawBayDefn(theFrame);
	elseif myBayArea.displayMode = ShpDisplayMode_Actual 
	or myBayArea.displayMode = ShpDisplayMode_GetAll
	or myBayArea.displayMode = ShpDisplayMode_EDI then
		self.drawBayAct(theFrame);
	elseif myBayArea.displayMode = ShpDisplayMode_Proposed then
		self.drawBayPro(theFrame);
	elseif myBayArea.displayMode = ShpDisplayMode_ColCodeLoad then
		self.drawColCodeLoad(theFrame);
	elseif myBayArea.displayMode = ShpDisplayMode_ColCodeDisch then
		self.drawColCodeDisch(theFrame);
	else
		app.raiseCMException2(ERR_INVALID_VALUE,"Drawing Mode", "Drawing Mode " &amp; myBayArea.displayMode.String &amp; " Is Invalid, it must be reset",null,null);
		return;
	endif;

	// backend of a 40 footer
	if self.drawBackend() then
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 2.myBayArea.myJobSeqSheet " &amp; myBayArea.myJobSeqSheet.String &amp; " self.colLoadMyJob " &amp; self.colLoadMyJob.String);

		if not configDraw40BackEndAttrib then
			if myBayArea.scaleXFactor &lt;= 1.5 then
				backEndPadding := 1;
				theFrame.drawWidth := 1;
			else
				backEndPadding := 5;
				theFrame.drawWidth := 2;
			endif;
			if myBayArea.displayMode = ShpDisplayMode_ColCodeDisch then
				if  self.colDischDischPortCode = null then 
					theColour := Grey;
				else
					theColour := Black;
				endif;
			elseif myBayArea.displayMode = ShpDisplayMode_ColCodeLoad then
				if  self.colLoadDischPortCode = null then 
					theColour := Grey;
				else
					theColour := Black;
				endif;
			else
				theColour := self.theDrawFillColor.getInverseColour;
			endif;
			theFrame.drawLine(self.x1 + backEndPadding,y1 + backEndPadding,x2 - backEndPadding,y2 - backEndPadding,theColour);
			theFrame.drawLine(self.x2 - backEndPadding,y1 + backEndPadding,x1 + backEndPadding,y2 - backEndPadding,theColour);
			theFrame.drawWidth := 1;
			return;
		endif;
	endif;
	
	
epilog
	// Reset to how it was before drawing attributes
	theFrame.drawFontName := theFontName;
	theFrame.drawFontSize := theFontSize;
	theFrame.drawTextAlign := theDrawTextAlign;
	theFrame.drawFillStyle := Frame.DrawFillStyle_Solid;

end;</source>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawSequenceNumber" id="82e3c375-f664-4e10-a078-cdfb476d5a5b">
        <source>drawSequenceNumber();
// ---------------------------------------------------------------------------
// Created:		April 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theX, theY, tmpX, tmpY,theAttribCount,theColour : Integer;
	myBayArea : SHP_BayArea;
	theLabel : String;
	chopped,pLocn : Boolean;
	theFrame: CMUI_GridAreaFrame;
	dlrWidth,offset,offsetY, thePos,secondLineOffset : Integer;
	noZeroFillSeqNum,dishDLRSOB,amCustSeq : Boolean;
	scaleFactor : Real;
	theWLE : CM_WorkListEntry;
	theRequest : CM_SlotRequest;
begin
	myBayArea := myGridArea.SHP_BayArea;
	theFrame := myBayArea.myGridAreaFrame;
	theColour := self.theDrawFillColor.getInverseColour();
	noZeroFillSeqNum := myBayArea.zeroFilleSeqNum;
	amCustSeq := myBayArea.workingMode = SHP_VoyageAreaForm2.WorkMode_CustomSeq; // PAR 7532 AKB2004FEB added
	dishDLRSOB :=  false; // (self.tiInfoPlannedLocation.trimBlanks &lt;&gt; null and (self.colDischDLR or self.colDischSOB)) ;
	scaleFactor := myBayArea.scaleXFactor;
	if scaleFactor &gt;= 2 or scaleFactor = SHP_BayArea.PrintScaleMedium then
		theLabel := null;
		if myBayArea.inPlaningOrSequenceMode 
		and self.colDischMyJob &lt;&gt; null 
		and myBayArea.displayMode = ShpDisplayMode_ColCodeDisch 
		or (myBayArea.myJobSeqSheet &lt;&gt; null and self.amPrinting and myBayArea.displayMode = ShpDisplayMode_ColCodeDisch ) then
			if self.tiInfoPlannedLocation.trimBlanks &lt;&gt; null 
			and myBayArea.myJobSeqSheet = null 
			and not amCustSeq then  // PAR 7532 AKB2004FEB added
				theLabel := self.tiInfoPlannedLocation.trimBlanks;
				if theLabel.length &gt; 6 then
					theLabel := "PLN";
				else
					theLabel := theLabel[1 :6];
				endif;
				pLocn := true;

			else
				if myBayArea.myJobSeqSheet &lt;&gt; null then
					if self.colDischMyJob = myBayArea.myJobSeqSheet then // we are printing the sequence sheet DISCHARGE
						if self.bayIsAft and self.colDischFortyFoot then
						else
							if myBayArea.seqNumKey = null then
								if noZeroFillSeqNum then
									theLabel := self.colDischSeqNum.asStringJMT;
								else
									theLabel := self.colDischSeqNum.String.padLeadingZeros(3);
								endif;
							else
								theRequest := self.myLocationsController.CM_SlotController.mySlotRequestDischarge;
								if theRequest &lt;&gt; null then
									theWLE := theRequest.allWorkListEntries.first;
									theLabel := theWLE.getDisplayStringForAttribute(myBayArea.seqNumKey,false);
								endif;
							endif;
						endif;			
					endif;
				else
					if noZeroFillSeqNum then
						theLabel := self.colDischSeqNum.asStringJMT;
					else
						theLabel := self.colDischSeqNum.String.padLeadingZeros(3);
					endif;
				endif;
				pLocn := false;
			endif;
		endif;
		if myBayArea.inPlaningOrSequenceMode 
		and myBayArea.displayMode = ShpDisplayMode_ColCodeLoad 
		or (myBayArea.myJobSeqSheet &lt;&gt; null and self.amPrinting) then
			if (self.colLoadMyJob &lt;&gt; null or dishDLRSOB) 
			and myBayArea.myJobSeqSheet = null  
			and not amCustSeq then  // PAR 7532 AKB2004FEB added

				// the TI is planned here
				if self.colLoadHasPlanned or dishDLRSOB then 
/*
					if scaleFactor &lt; 3 then
						theLabel := "PLN";
					elseif scaleFactor = 3 then
						theLabel := "PL";
					else
						theLabel := "PLND";
					endif;
*/
					theLabel := "P";
					pLocn := true;
				endif;
			endif;
			if not pLocn and self.colLoadMyJob &lt;&gt; null 
			or (myBayArea.myJobSeqSheet &lt;&gt; null and self.amPrinting) then
				if myBayArea.myJobSeqSheet &lt;&gt; null 
				and self.colLoadMyJob &lt;&gt; myBayArea.myJobSeqSheet then
				else // we are printing the sequence sheet LOAD
					if myBayArea.seqNumKey = null then
						if noZeroFillSeqNum then
							theLabel := self.colLoadSeqNum.asStringJMT;
						else
							theLabel := self.colLoadSeqNum.String.padLeadingZeros(3);
						endif;
					else
						theRequest := self.myLocationsController.CM_SlotController.mySlotRequestLoad;
						if theRequest &lt;&gt; null then
							theWLE := theRequest.allWorkListEntries.first;
							theLabel := theWLE.getDisplayStringForAttribute(myBayArea.seqNumKey,false);
						endif;
					endif;
					if self.colLoadHasTemp and scaleFactor &gt;= 3 and not self.amPrinting then
						theLabel := theLabel &amp; "!";
					endif;
				endif;
				pLocn := false;
			endif;
		endif;
			
		if theLabel &lt;&gt; null then
			theFrame.setDefaultFont();
			if scaleFactor = 2  or scaleFactor = SHP_BayArea.PrintScaleMedium  then
				if pLocn then
					theFrame.drawFontSize := 6;
					offsetY := 1;
					offset := 2;
				else
					theFrame.drawFontSize := 7;
					offsetY := 1;
					offset := 3;
				endif;
				tmpY := (self.y1 + offsetY).Integer;
			elseif scaleFactor = 3 then
				if dishDLRSOB then
					offsetY := -1;
				else
					offsetY := 0;
				endif;
				if pLocn then
					if chopped then
						theFrame.drawFontSize := 6;
					else
						theFrame.drawFontSize := 7;
					endif;
					offset := 2;
				else
					theFrame.drawFontSize := 7;
					offset := 3;
				endif;
				tmpY := (self.y1 + offsetY).Integer;
				secondLineOffset := 8;
			elseif scaleFactor = 4 then
				if pLocn then
					if chopped then
						theFrame.drawFontSize := 7;
					else
						theFrame.drawFontSize := 7;
					endif;
					offset := 2;
					offsetY := 1;
				else
					theFrame.drawFontSize := 9;
					offsetY := 1;
					offset := 2;
				endif;
				tmpY := (self.y1 + offsetY).Integer;
				secondLineOffset := 12;
			elseif scaleFactor = 6 then
				if pLocn then
					theFrame.drawFontSize := 11;
					tmpY := (self.y1 + 2).Integer;
					offset := 3;
				else
					theFrame.drawFontSize := 14;
					tmpY := (self.y1 + 1).Integer;
					offset := 3;
				endif;
				secondLineOffset := 16;
			elseif scaleFactor = 9 then
				if pLocn then
					theFrame.drawFontSize := 16;
					tmpY := (self.y1 + 2).Integer;
					offset := 3;
				else
					theFrame.drawFontSize := 22;
					tmpY := (self.y1 ).Integer;
					offset := 3;
				endif;
				secondLineOffset := 24;
			endif;
			
			theFrame.drawTextAt(theLabel,self.x1 + offset, tmpY,theColour); // &lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;&lt;

			if myBayArea.displayMode = ShpDisplayMode_ColCodeLoad and scaleFactor &gt; 2 then
				theLabel := self.colLoadCommodityGroupCode;
				theFrame.drawTextAt(theLabel,self.x1 + offset, tmpY + secondLineOffset,theColour);
			endif;
			
			if myBayArea.inPlaningOrSequenceMode 
			and self.colLoadMyJob &lt;&gt; null 
			and myBayArea.displayMode = ShpDisplayMode_ColCodeLoad 
			and scaleFactor &gt; 2
			and pLocn then
				if scaleFactor = 2 then
					offset := -2;
				endif;
				theFrame.drawTextAlign := Frame.DrawTextAlign_Right;
				theLabel := self.colLoadPlannedTIWeight.asStringJMT;
				theFrame.drawTextAt(theLabel,self.x2- 2, tmpY ,theColour);
				theFrame.drawTextAlign := Frame.DrawTextAlign_Left;
			endif;
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="drawTI" id="050d589c-3a94-4ed9-bc59-47a48e7a3d21">
        <source>drawTI(	_theFrame:CMUI_GridAreaFrame input;
		_theTI:CM_TrackedItem;
		_theGridAttributes:CMUI_GridAttributes input;
		_x1:Real;
		_y1:Real;
		_x2:Real;
		_y2:Real) protected;
// ---------------------------------------------------------------------------
// Created:		January  2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theFrame			: CMUI_GridAreaFrame;
	lTIColour			: Integer;
	theInverseColour	: Integer;
	theCharacterWidth	: Integer;
	tm_x2				: Real;
	tm_x1				: Real;
	tm_y1				: Real;
	tm_y2				: Real;
	lDisplayMode		: Integer;
	idx					: Integer;
	lViewMode			: Integer;
	theAtt				: Integer;
	lFactor				: Real;
	theMainCode			: String;
	theSDF				: CMUI_ScrollableDrawingFrame;
	theBayArea			: SHP_BayArea;
	theMode				: Integer;
	aPort				: CM_Port;
	theTI				: CM_TrackedItem;
	iAmPrinting			: Boolean;
	doDrawBackEnd		: Boolean;
	
begin
	if self.tiInfoTIID = null then
		return;
	endif;
	
	doDrawBackEnd := self.drawBackend();

	theFrame := _theFrame;
	theSDF := self.myGridArea.mySDF;
	theBayArea := self.myGridArea.SHP_BayArea;
	theMode := theBayArea.displayMode;
	iAmPrinting := self.amPrinting();
	
	lFactor := self.myGridArea.scaleXFactor;
	lDisplayMode := theSDF.displayMode;
	lViewMode := theSDF.viewMode;
	theFrame.setDefaultFont();
	
	if not theBayArea.inPlaningOrSequenceMode then
		if  (iAmPrinting and lFactor = SHP_BayArea.PrintScaleLarge) then
			if lDisplayMode = DISPLAY_MODE_ACTUAL then
				theTI := self.allTrackedItems.first;
			else
				theTI := self.allPlannedTrackedItems.first;
			endif;
			
			if theTI = null then
				app.writeStatement( self.class.name &amp; "::" &amp; method.name &amp; " Null TI. ");
				//return;
			endif;
		endif;
	endif;

	tm_y1 := _y1;
	tm_x2 := _x2;

	tm_x2 := tm_x2 - 1;
	tm_y2 := _y2 - 1;

	lTIColour := self.theDrawFillColor;
	
/*		// this is handled by the SDF.myDrawingAttrController now.
	
	// this adds the code and the colour being used to an array to be used to draw the legend
	if not (iAmPrinting and theBayArea.displayMode = ShpDisplayMode_ColCodeDisch) then
//		self.drawTIAddViewModeLegend(null);
	endif;
*/
	theInverseColour := lTIColour.getInverseColour();
	theFrame.drawFillColor := lTIColour;
	
	// #############
	if lFactor &lt; 2 and not iAmPrinting then
		return;
	endif;

	if lViewMode = VIEW_COMMODITY then

		theMainCode := self.tiInfoCommodityGroupCode;
	elseif lViewMode = TI_ColourMode_Status  then
		theMainCode := self.tiInfoStatus;
	elseif lViewMode = TI_ColourMode_ISOTypeGroup  then
		theMainCode := self.tiInfoISOTypeGroup;
	elseif lViewMode = VIEW_OPERATOR then
		theMainCode := self.tiInfoOperatorCode;
	elseif lViewMode = VIEW_DISPORT then
		theMainCode := self.tiInfoDischargePort;
	elseif lViewMode = VIEW_LOADPORT then
		theMainCode := self.tiInfoLoadPort;
	elseif lViewMode = VIEW_WEIGHT then
		theMainCode := self.tiInfoWeight;
	elseif lViewMode = VIEW_TEMPERATURE then
		theMainCode := self.tiInfoReeferTemp;
	else
		theMainCode := self.tiInfoCommodityGroupCode;
	endif;	

	if not theBayArea.inPlaningOrSequenceMode and not doDrawBackEnd then
		if  (iAmPrinting and lFactor = SHP_BayArea.PrintScaleLarge) then
			theFrame.drawFontName := "Helvetica";
			theFrame.drawFontSize := 6;
			
			if theTI = null then
				theFrame.drawTextAt(tiInfoISOTypeGroup &amp; "   " &amp; self.tiInfoOperatorCode,_x1 + 2, tm_y1 + 1, theInverseColour);
			else
				theFrame.drawTextAt(theTI.getISOType() &amp; "   " &amp; self.tiInfoOperatorCode,_x1 + 2, tm_y1 + 1, theInverseColour);
			endif;
			
			theFrame.drawFontSize := 6;
			theFrame.drawTextAt(self.tiInfoTIID,_x1 + 2, tm_y1 + 8,theInverseColour);
			theFrame.drawFontSize := 6;
			
			if self.tiInfoReeferTemp &lt;&gt; null then
				theFrame.drawTextAt(self.tiInfoCommodity,_x1 + 2, tm_y1 + 15, theInverseColour);
				theFrame.drawTextAt(self.tiInfoReeferTemp,_x1 + 35, tm_y1 + 15, theInverseColour);
			else
				theFrame.drawTextAt(self.tiInfoCommodityGroupCode,_x1 + 2, tm_y1 + 15, theInverseColour);
			endif;
			
			if tiInfoDischargePort &lt;&gt; null then
				theFrame.drawTextAt(self.tiInfoDischargePort &amp; " X " &amp; self.tiInfoLoadPort &amp; "   " &amp; self.tiInfoWeight,_x1 + 2 , tm_y1 + 22, theInverseColour);
			endif;
			
		elseif lFactor = 9  then
			theFrame.drawFontName := "Helvetica";
			theFrame.drawFontSize := 8;
			theFrame.drawTextAt(self.tiInfoISOTypeGroup &amp; "   " &amp; self.tiInfoOperatorCode,_x1 + 4, tm_y1 + 2, theInverseColour);
			theFrame.drawTextAt(self.tiInfoTIID,_x1 + 2, tm_y1 + 15,theInverseColour);
			
			if self.tiInfoReeferTemp &lt;&gt; null then
				theFrame.drawTextAt(self.tiInfoCommodity,_x1 + 2, tm_y1 + 30, theInverseColour);
				theFrame.drawTextAt(self.tiInfoReeferTemp,_x1 + 35, tm_y1 + 30, theInverseColour);
			else
				theFrame.drawTextAt(self.tiInfoCommodityGroupCode,_x1 + 2, tm_y1 + 30, theInverseColour);
			endif;
			
			if tiInfoDischargePort &lt;&gt; null then
				theFrame.drawTextAt(self.tiInfoDischargePort &amp; " X " &amp; self.tiInfoLoadPort &amp; "   " &amp; self.tiInfoWeight,_x1 + 2 , tm_y1 + 45, theInverseColour);
			endif;
			
		elseif lFactor = 6 then
			theFrame.drawFontName := "Helvetica";
			theFrame.drawFontSize := 8;
			theFrame.drawTextAt(self.tiInfoISOTypeGroup &amp; " " &amp; self.tiInfoOperatorCode,_x1 + 4, tm_y1 + 2, theInverseColour);
			
			if self.tiInfoTIID &lt;&gt; null then
				theFrame.drawTextAt(self.tiInfoTIID[1:4],_x1 + 2, tm_y1 + 15,theInverseColour);
				theFrame.drawTextAt("- " &amp; self.tiInfoTIID[5:end],_x1 + 5, tm_y1 + 27,theInverseColour);
			endif;
			
		elseif lFactor = 4 then
			theFrame.drawFontName := "Helvetica";
			
			if lViewMode = VIEW_WEIGHT and not iAmPrinting then
				theFrame.drawFontSize := 12;
			else
				theFrame.drawFontSize := 8;
			endif;
			
			theFrame.drawTextAt(theMainCode,_x1 + 2, tm_y1 + 2, theInverseColour);
			
		elseif lFactor = 3 then
			theFrame.drawFontName := "Helvetica";
			
			if lViewMode = VIEW_WEIGHT and not iAmPrinting then
				theFrame.drawFontSize := 10;
			else
				theFrame.drawFontSize := 7;
			endif;
			
			theFrame.drawTextAt(theMainCode,_x1 + 2, tm_y1 + 2, theInverseColour);
			
		elseif (amPrinting and lFactor = SHP_BayArea.PrintScaleSmall) then
			theFrame.setDefaultFont();
			theFrame.drawFontSize := 6;
			
			if lViewMode = VIEW_DISPORT or lViewMode = VIEW_LOADPORT then
				theMainCode := self.tiInfoDischargePort;
				//aPort := app.myRoot.allPorts[self.tiInfoDischargePort.trimBlanks];
				aPort := app.myRoot.allPorts[self.tiInfoDischargePort.trimBlanks];
				
				if aPort &lt;&gt; null then
					if aPort.ccodePrint.trimBlanks &lt;&gt; null then
						theMainCode := aPort.ccodePrint.trimBlanks;
					endif;
				endif;
			endif;
			
			theFrame.drawTextAt(theMainCode[1:1],_x1 + 1, tm_y1, theInverseColour);
			
		elseif lFactor = 2 or (amPrinting and lFactor = SHP_BayArea.PrintScaleMedium)  then
			theFrame.setDefaultFont();
			
			if iAmPrinting then
				theFrame.drawFontSize := 5.5;
			else
				theFrame.drawFontSize := 6;
			endif;
			
			if theMainCode.length &gt;= 3 then
				theFrame.drawTextAt(theMainCode[1:3],_x1 + 1, tm_y1 + 1 , theInverseColour);
//				theFrame.drawTextAt(theMainCode[3:end],_x1 + 6, tm_y1 + 10, theInverseColour);
			else
				theFrame.drawTextAt(theMainCode,_x1 + 4, tm_y1 + 2, theInverseColour);
			endif;
		endif;
	endif;
	
	if not amPrinting and self.tiInfoNumTI &gt; 1 then
		self.drawMark(theFrame,Red,1,iAmPrinting,lFactor);
	endif;

	// work out the width of the rectangle and split up, to get the even width for the attribute characters
	theCharacterWidth := ((tm_x2 - _x1) / 3 ).Integer;

	// #############
	if lFactor &lt; 2 and not (lFactor = SHP_BayArea.PrintScaleMedium and iAmPrinting) then
		return;
	endif;
	
	tm_x1 := _x1 + (theCharacterWidth / 2).Integer;
	tm_y1 := _y2;
	idx := 1;
	
	if  (iAmPrinting and lFactor = SHP_BayArea.PrintScaleLarge) then
		return;
	endif;
	
	if doDrawBackEnd then
		return;
	endif;
	
	if lDisplayMode = DISPLAY_MODE_ACTUAL then
		if self.bayActAttribute1 &lt;&gt; null then
			self.drawAttribute(theInverseColour,self.bayActAttribute1,theAtt,theFrame);
		endif;
		if self.bayActAttribute2 &lt;&gt; null then
			self.drawAttribute(theInverseColour,self.bayActAttribute2,theAtt,theFrame);
		endif;
		if self.bayActAttribute3 &lt;&gt; null then
			self.drawAttribute(theInverseColour,self.bayActAttribute3,theAtt,theFrame);
		endif;
		if self.bayActAttribute4 &lt;&gt; null then
			self.drawAttribute(theInverseColour,self.bayActAttribute4,theAtt,theFrame);
		endif;
		if self.bayActAttribute5 &lt;&gt; null then
			self.drawAttribute(theInverseColour,self.bayActAttribute5,theAtt,theFrame);
		endif;
		if self.bayActAttribute6 &lt;&gt; null then
			self.drawAttribute(theInverseColour,self.bayActAttribute6,theAtt,theFrame);
		endif;
//if app.getMyUserCode = 'CNWRS2' then
//process.debug;
//endif;

	elseif lDisplayMode = DISPLAY_MODE_PLAN then
		if self.bayProAttribute1 &lt;&gt; null then
			self.drawAttribute(theInverseColour,self.bayProAttribute1,theAtt,theFrame);
		endif;
		if self.bayProAttribute2 &lt;&gt; null then
			self.drawAttribute(theInverseColour,self.bayProAttribute2,theAtt,theFrame);
		endif;
		if self.bayProAttribute3 &lt;&gt; null then
			self.drawAttribute(theInverseColour,self.bayProAttribute3,theAtt,theFrame);
		endif;
		if self.bayProAttribute4 &lt;&gt; null then
			self.drawAttribute(theInverseColour,self.bayProAttribute4,theAtt,theFrame);
		endif;
		if self.bayProAttribute5 &lt;&gt; null then
			self.drawAttribute(theInverseColour,self.bayProAttribute5,theAtt,theFrame);
		endif;
		if self.bayProAttribute6 &lt;&gt; null then
			self.drawAttribute(theInverseColour,self.bayProAttribute6,theAtt,theFrame);
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_theFrame" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_theGridAttributes" type="CMUI_GridAttributes" usage="input"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawTIAddViewModeLegend" id="5d852301-01d4-4702-8cf6-8fb0e260dea8">
        <source>drawTIAddViewModeLegend(_theGridAttributes : CMIF_GridAttributes);
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theCode : String;
	theViewMode : Integer;
	theSDF : CMUI_ScrollableDrawingFrame;
begin
	theSDF := self.myGridArea.mySDF;
	theViewMode := theSDF.viewMode;
	if theSDF.displayMode = DISPLAY_MODE_ACTUAL  then
		if theViewMode &lt;= self.myAttributesActual.allDisplayCodes.size then
			theCode := self.myAttributesActual.allDisplayCodes[theViewMode];
		endif;
	else
		if theViewMode &lt;= self.myAttributesProposed.allDisplayCodes.size then
			theCode := self.myAttributesProposed.allDisplayCodes[theViewMode];
		endif;
	endif;	
/*
	if theViewMode = VIEW_COMMODITY then
		theCode := self.tiInfoCommodityGroupCode;
//	elseif theViewMode = VIEW_ISOTYPE then
//		theCode := self.tiInfoISOCode;
	elseif theViewMode = VIEW_OPERATOR then
		theCode := self.tiInfoOperatorCode;
	elseif theViewMode = VIEW_DISPORT then
		theCode := self.tiInfoDischargePort;
	elseif theViewMode = VIEW_LOADPORT then
		theCode := self.tiInfoLoadPort;
	else
		return;
	endif;	
*/
	if theCode = null then
		return;
	endif;
	if not theSDF.myViewModeAttribute.allDisplayIcons.includes(theCode) then
		theSDF.myViewModeAttribute.allDisplayIcons.add(theCode);
		theSDF.myViewModeAttribute.allDisplayColors.add(self.theDrawFillColor);
	endif;

end;</source>
        <Parameter name="_theGridAttributes" type="CMIF_GridAttributes"/>
    </JadeMethod>
    <JadeMethod name="getAttributeArray" id="969c1bce-a626-43c4-81d2-9aa3680aea96">
        <source>getAttributeArray() : CMUI_GridAttributesArray;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theDrawingAttribute : CM_DrawingAttribute;
	theAttributes : CMUI_GridAttributesArray;
	myBayArea : SHP_BayArea;
	theAftBay : CM_Bay;
	aGridAttributes : CMUI_GridAttributes;
begin
	myBayArea := myGridArea.SHP_BayArea;

	create theAttributes transient;
	create aGridAttributes transient;
	theAttributes.add(aGridAttributes);

	if myBayArea.displayMode = ShpDisplayMode_ColCodeLoad then
	
		// ###########
		// HAZARD
		if self.colLoadIsHazardous then
			aGridAttributes.allDisplayIcons.add(PicTIHazard);
		endif;
		
		// ###########
		// OVERSIZED
		if self.colLoadIsOverDimensioned then
			aGridAttributes.allDisplayIcons.add(PicTIOversized);
		endif;
		
		// ###########
		// POWERED
		if self.colLoadPower then
			aGridAttributes.allDisplayIcons.add(PicTIConnected);
		endif;
		
		// ###########
		// UNAVAILABLE	
		if self.colLoadUnavailable then
			aGridAttributes.allDisplayIcons.add(PicTIUnavail);
		endif;
		// ###########
		// HICUBE	
		if self.colLoadHiCube then
			aGridAttributes.allDisplayIcons.add(PicTIHiCube);
		endif;
		// ###########
		// HALF HEIGHT	
		if self.colLoadHalfHeight then
			aGridAttributes.allDisplayIcons.add(PicTIHalfHeight);
		endif;
	
		// ###########
		// MOTOR FORWARD
		if  self.colLoadMotor20 then
			aGridAttributes.allDisplayIcons.add(PicTIMotorFwd);
		elseif not  self.colLoadMotor20 then
			aGridAttributes.allDisplayIcons.add(PicTIMotorAft);
		elseif  self.colLoadMotor40 then
			aGridAttributes.allDisplayIcons.add(PicTIMotorFwd40);
		elseif  not self.colLoadMotor40 then
			aGridAttributes.allDisplayIcons.add(PicTIMotorAft40);
		endif;
		if  self.colLoadDoorDirection20 = TI_DOORSDIRN_FWD then
			aGridAttributes.allDisplayIcons.add(PicTIDoorsFwd);
		elseif  self.colLoadDoorDirection20 = TI_DOORSDIRN_AFT then
			aGridAttributes.allDisplayIcons.add(PicTIDoorsAft);
		elseif  self.colLoadDoorDirection40 = TI_DOORSDIRN_FWD then
			aGridAttributes.allDisplayIcons.add(PicTIDoorsFwd40);
		elseif  self.colLoadDoorDirection40 = TI_DOORSDIRN_AFT then
			aGridAttributes.allDisplayIcons.add(PicTIDoorsAft40);
		endif;
	
		// ###########
		// FORTYFOOT
		if self.colLoadFortyFoot then
			theAftBay := self.myBay.myAftBay.CM_Bay;
			if theAftBay &lt;&gt; null  and theAftBay.canHandle4045() and theAftBay.idBay40.trimBlanks &lt;&gt; null then
				aGridAttributes.allDisplayIcons.add(PicTI40FooterBackEnd);
			else
				aGridAttributes.allDisplayIcons.add(PicTI40Footer);
			endif;
		endif;
	
		// ###########
		// PORTHOLE
		if self.colLoadPortHole then
			aGridAttributes.allDisplayIcons.add(PicTIReefer);
		endif;
	
	
		// ###########
		// WATERCOOLED	
		if self.colLoadWaterCooled then
			aGridAttributes.allDisplayIcons.add(PicTIWaterCooled);
		endif;
	
		// ###########
		// MTs ONLY
		if self.colLoadEmpty then
			aGridAttributes.allDisplayIcons.add(PicTIEmpty);
		endif;
	elseif myBayArea.displayMode = ShpDisplayMode_Defn then
	
		// ###########
		// POWERED
		if self.bayDefnPowered then
			aGridAttributes.allDisplayIcons.add(PicTIConnected);
		endif;
		
		// ###########
		// UNAVAILABLE	
		if self.bayDefnUnavailable then
			aGridAttributes.allDisplayIcons.add(PicTIUnavail);
		endif;
	
	
		// ###########
		// DOORS	
		if self.bayDefnDoorDirection20 then
			aGridAttributes.allDisplayIcons.add(PicTIDoorsAft);
		endif;
		if not self.bayDefnDoorDirection20 then
			aGridAttributes.allDisplayIcons.add(PicTIDoorsFwd);
		endif;

		// ###########
		// MOTORs
		if self.bayDefnMotorDirection20 then
			aGridAttributes.allDisplayIcons.add(PicTIMotorFwd);
		endif;
// do these later when we have a 40 icon
//		if self.bayDefnMotor40 then
//			aGridAttributes.displayIcons.add(PicTIMotorFwd);
//		endif;
		if not self.bayDefnMotorDirection20 then
			aGridAttributes.allDisplayIcons.add(PicTIMotorAft);
		endif;
//		if not self.bayDefnMotor40 then
//			aGridAttributes.displayIcons.add(PicTIMotorAft);
//		endif;
	
		// ###########
		// FORTYFOOT
		if self.bayDefnFortyFoot then
//			theAftBay := self.myBay.myAftBay.CM_Bay;
//			if theAftBay &lt;&gt; null  and theAftBay.fortyFootBay and theAftBay.idBay40.trimBlanks &lt;&gt; null then
			if self.bayIsAft then
				aGridAttributes.allDisplayIcons.add(PicTI40FooterBackEnd);
			else
				aGridAttributes.allDisplayIcons.add(PicTI40Footer);
			endif;
		endif;
		
		// PAR 18682
		// ###########
		// FORTY FIVE FOOT
		if self.bayDefnFortyFive then
			if self.bayIsAft then
				aGridAttributes.allDisplayIcons.add(PicTI45FooterBackEnd);
			else
				aGridAttributes.allDisplayIcons.add(PicTI45Footer);
			endif;
		endif;
	
		// PAR 16415 CCMS 1029
		// ###########
		// THIRTY FOOT
		if self.bayDefnThirtyFoot then
			if self.bayIsAft then
				aGridAttributes.allDisplayIcons.add(PicTI30FooterBE);
			else
				aGridAttributes.allDisplayIcons.add(PicTI30Footer);
			endif;
		endif;
	
		// PAR 16415 CCMS 1029
		// ###########
		// FIFTY THREE FOOT
		if self.bayDefnFiftyThreeFoot then
			if self.bayIsAft then
				aGridAttributes.allDisplayIcons.add(PicTI53FooterBE);
			else
				aGridAttributes.allDisplayIcons.add(PicTI53Footer);
			endif;
		endif;
	
		// ###########
		// REEFER
		if self.bayDefnReefer then
			aGridAttributes.allDisplayIcons.add(PicTIReefer);
		endif;
	
	
		// ###########
		// WATERCOOLED	
		if self.bayDefnWaterCooled then
			aGridAttributes.allDisplayIcons.add(PicTIWaterCooled);
		endif;
	
		// ###########
		// MTs ONLY
		if self.bayDefnMtOnly then
			aGridAttributes.allDisplayIcons.add(PicTIMTOnly);
		endif;

		// ###########
		// HEAVY
		if self.bayDefnHeavy then
			aGridAttributes.allDisplayIcons.add(PicTIHeavy);
		endif;
		// ###########
		// VOLTAGE
		if self.bayDefnVoltage = 1 then
			aGridAttributes.allDisplayIcons.add(PicTIVoltageSingle);
		endif;
		if self.bayDefnVoltage = 2 then
			aGridAttributes.allDisplayIcons.add(PicTIVoltageDual);
		endif;
	endif;

	return theAttributes;
end;</source>
        <ReturnType type="CMUI_GridAttributesArray"/>
    </JadeMethod>
    <JadeMethod name="getAttributePosition" id="bf04e1c1-29fe-427c-b0d7-9cda11125326">
        <source>getAttributePosition(_theAttribute : String;_theAttributePosition : Integer io) : Integer;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theAttributePosition : Integer;
begin
//app.writeStatement( "AKB " &amp; self.class.name &amp; "::" &amp; method.name &amp; " 1. " &amp; _theAttribute);
	if _theAttribute = PicTI40FooterBackEnd then
		theAttributePosition := 5;
	elseif _theAttribute = PicTI40Footer then
		theAttributePosition := 5;
	 // PAR 16415 CCMS 1029
	elseif _theAttribute = PicTI30Footer then
		theAttributePosition := 8;
	elseif _theAttribute = PicTI30FooterBE then
		theAttributePosition := 8;
	elseif _theAttribute = PicTI53Footer then
		theAttributePosition := 9;
	elseif _theAttribute = PicTI53FooterBE then
		theAttributePosition := 9;

	elseif _theAttribute = PicTI45Footer then
		theAttributePosition := 9;
	elseif _theAttribute = PicTI45FooterBackEnd then
		theAttributePosition := 9;
		
		
	elseif _theAttribute = PicTIUnavail then
		theAttributePosition := 1;
	elseif _theAttribute = PicTIMotorFwd then // 20 MOTOR
		theAttributePosition := 1;
	elseif _theAttribute = PicTIMotorAft then // 20 MOTOR
		theAttributePosition := 1;
	elseif _theAttribute = PicTIDoorsAft then // 20 DOOR
		theAttributePosition := 3;
	elseif _theAttribute = PicTIDoorsFwd then // 20 DOOR
		theAttributePosition := 3;


	elseif _theAttribute = PicTIMotorFwd40 then // 40 MOTOR
		theAttributePosition := 2;
	elseif _theAttribute = PicTIMotorAft40 then // 40 MOTOR
		theAttributePosition := 2;
	elseif _theAttribute = PicTIDoorsAft40 then // 40 DOOR
		theAttributePosition := 4;
	elseif _theAttribute = PicTIDoorsFwd40 then // 40 DOOR
		theAttributePosition := 4;



	elseif _theAttribute = PicTIReefer then
		theAttributePosition := 6;
	elseif _theAttribute = PicTIWaterCooled then
		theAttributePosition := 6;
	elseif _theAttribute = PicTIMTOnly or _theAttribute = PicTIEmpty then
		theAttributePosition := 6;
	elseif _theAttribute = PicTIHeavy then
		theAttributePosition := 6;
	elseif _theAttribute = PicTIVoltageSingle or _theAttribute = PicTIVoltageDual then
		theAttributePosition := 9;
	elseif _theAttribute = PicTIConnected then
		theAttributePosition := 7;
	elseif _theAttribute = PicTIOversized then
		theAttributePosition := 8;
	elseif _theAttribute = PicTIHazard then
		theAttributePosition := 9;
	endif;

return theAttributePosition;
end;</source>
        <Parameter name="_theAttribute" type="String"/>
        <Parameter name="_theAttributePosition" type="Integer" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoForPoint" id="ca4b0dd1-124f-42b1-924f-3e2cb772f219">
        <source>getExtraInfoForPoint(x: Real; y: Real; _dataContainer : CM_DataContainer) : Object;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25 June 2003 sgp			Use CM_DataContainer to hold data
// ---------------------------------------------------------------------------

vars
	theTI,tmpTI	: CM_TrackedItem;
	tmpYPos	: Real;
	numTIs,
	idx, theBayAreaMode		: Integer;
	aString : String;
	mySlotController, myNeighbour : CM_SlotController;
	tmpSC : CM_LocationsController;
	useCellTier,amInEDIMode : Boolean;
	myBayArea :SHP_BayArea;
	theTIs : CM_TIArray;
	aSlotRequest : CM_SlotRequest;
	linkedReq : CM_Request;
	theReturnObject : Object;
	block : CM_DataContainerBlock;
	bBlock : CM_DataContainerBlock;
	theWLE : CM_WorkListEntry;

begin
	myBayArea := self.myGridArea.SHP_BayArea;
	theBayAreaMode := myBayArea.displayMode;
	amInEDIMode := (myBayArea.displayMode = ShpDisplayMode_EDI);
	mySlotController := self.myLocationsController.CM_SlotController;
	theTI := self.getTI(x, y);
	theReturnObject := theTI;
	
	if theBayAreaMode = ShpDisplayMode_Actual or 
	   theBayAreaMode = ShpDisplayMode_EDI or
	   theBayAreaMode = ShpDisplayMode_Proposed then
		if amInEDIMode then
			if theTI &lt;&gt; null then	
				theTI.getExtraInfo(_dataContainer);
			endif;
		else
			self.getExtraInfoTI(x ,y, _dataContainer);
		endif;
	elseif theBayAreaMode = ShpDisplayMode_Defn then

	elseif theBayAreaMode = ShpDisplayMode_ColCodeDisch then
		aSlotRequest := mySlotController.mySlotRequestDischarge;
		theReturnObject := aSlotRequest;
		if aSlotRequest &lt;&gt; null then
			create theTIs transient;
			aSlotRequest.getAllTrackedItems(theTIs);
			if theTIs.size &gt; 1 then
				aString := null;
				idx := 0;
				foreach theTI in theTIs do
					idx := idx + 1;
					aString := aString &amp; theTI.id &amp; ", ";
					if idx mod 2 = 0 then
						aString := aString &amp; Cr;
					endif;
				endforeach;
				aString := aString[1 : aString.reversePos(",") - 1];
				block := _dataContainer.addNewBlock;
				block.addNewItem("Multi Cargo CC", DC_Label, 1, null);
				block.addNewItem(aString, DC_Data, 1, null);
			
			endif;
			
			
			linkedReq := aSlotRequest.getLinkedRequest(true); // PAR 28968 
// PAR 28968 			if aSlotRequest.mySlotRequestDLRSOBLoad &lt;&gt; null then
			if linkedReq &lt;&gt; null then
				tmpSC := linkedReq.getLC();
				if tmpSC &lt;&gt; null then
					block := _dataContainer.addNewBlock;
					block.addNewItem("LINKED CC Load ", DC_Label, 1, null);
//					block.addNewItem(aSlotRequest.mySlotRequestDLRSOBLoad.mySlotController.getFullId, DC_Data, 1, null);
					block.addNewItem(tmpSC.getFullId, DC_Data, 1, null);
				endif;
			endif;		
		endif;
		if self.colDischMyJob &lt;&gt; null then
			aString := null;
			if theTI &lt;&gt; null then	
				aString := theTI.getShipReceiveJobsString();
			endif;
			if aString = null then
				aString := self.colDischMyJob.jobId;
				if self.colDischMyJob.isJobComplete then
					aString := aString &amp; " COMPLETE";
				endif;
			endif;
			block := _dataContainer.addNewBlock;
			block.addNewItem("Discharge Job ", DC_Label, 1, null);
			block.addNewItem(aString, DC_Data, 1, null);
			// ###################
			// SEQUENCE NUMBER
			if myBayArea.workingMode = SHP_VoyageAreaForm2.WorkMode_Plan then
				aString := self.colDischSeqNum.String.padLeadingZeros(3);
				if aString &lt;&gt; null then
					block := _dataContainer.addNewBlock;
					block.addNewItem("Sequence Number ", DC_Label, 1, null);
					block.addNewItem(aString, DC_Data, 1, null);
				endif;
			endif;
		endif;
		if self.colDischMyDischPort &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem("Destination ", DC_Label, 1, self.colDischMyDischPort);
			block.addNewItem(self.colDischMyDischPort.code.trimBlanks &amp; " - " &amp; self.colDischMyDischPort.description.trimBlanks,
					DC_Data, 1, null);
		endif;
		if self.colDischDLR then
			block := _dataContainer.addNewBlock;
			block.addNewItem("Double Lift Re-Stow ", DC_Label, 1, null);
			block.addNewItem("Yes", DC_Data, 1, null);
		endif;
		if self.colDischSOB then
			block := _dataContainer.addNewBlock;
			block.addNewItem("Shift On Board ", DC_Label, 1, null);
			block.addNewItem("Yes", DC_Data, 1, null);
		endif;

		self.getExtraInfoTI(x ,y, _dataContainer);
	elseif theBayAreaMode = ShpDisplayMode_ColCodeLoad then
		aSlotRequest := mySlotController.mySlotRequestLoad;
		theReturnObject := aSlotRequest;
		if aSlotRequest &lt;&gt; null then
			linkedReq := aSlotRequest.getLinkedRequest(false); // PAR 28968 
// PAR 28968 			if aSlotRequest.mySlotRequestDLRSOBDischarge &lt;&gt; null then
			if linkedReq &lt;&gt; null then
// PAR 28968				tmpSC := aSlotRequest.mySlotRequestDLRSOBDischarge.mySlotController;
				tmpSC := linkedReq.getLC();
				if tmpSC &lt;&gt; null then
					block := _dataContainer.addNewBlock;
					block.addNewItem("LINKED CC Discharge ", DC_Label, 1, null);
					tmpTI := tmpSC.allTrackedItems.first;
					if tmpTI &lt;&gt; null then
						block.addNewItem(tmpSC.getFullId &amp; " (" &amp; tmpTI.id &amp; ")", DC_Data, 1, null);
					else
						block.addNewItem(tmpSC.getFullId , DC_Data, 1, null);
					endif;
				endif;
			endif;

			// MOTORS
			block := _dataContainer.addNewBlock;
			block.addNewItem("Motor Direction ", DC_Label, 1, null);
			if aSlotRequest.motorDirection = Motor_Forward then	
				block.addNewItem("Forward", DC_Data, 1, null);
			elseif aSlotRequest.motorDirection = Motor_Aft then	
				block.addNewItem("Aft", DC_Data, 1, null);
			else
				block.addNewItem("N/A", DC_Data, 1, null);
			endif;			

			 // DOORS
			block := _dataContainer.addNewBlock;
			block.addNewItem("Door Direction ", DC_Label, 1, null);
			if aSlotRequest.doorsDirection = TI_DOORSDIRN_FWD then	
				block.addNewItem("Forward", DC_Data, 1, null);
			elseif aSlotRequest.doorsDirection = TI_DOORSDIRN_AFT then	
				block.addNewItem("Aft", DC_Data, 1, null);
			else
				block.addNewItem("N/A", DC_Data, 1, null);
			endif;			
		endif;
		if self.colLoadHasPlanned then //mySlotController.hasTIsOfMode(PLANNING_MODE) then
			create theTIs transient;
			mySlotController.getTIs(theTIs,PLANNING_MODE, true); // PAR 27749
			foreach theTI in theTIs do
				block := _dataContainer.addNewBlock;
				block.addNewItem("Planned Cargo ", DC_Label, 1, theTI);
				block.addNewItem(theTI.id &amp; " (" &amp; theTI.getPrimaryLocationId(REAL_MODE) &amp; ") W:" &amp; theTI.totalWeight.asStringWeightJMT(), DC_Data, 1, theTI);
			endforeach;
		endif;
		if self.colLoadMyJob &lt;&gt; null then
			aString := null;
			if theTI &lt;&gt; null then	
				aString := theTI.getShipReleaseJobsString();
			endif;
			if aString = null then
				aString := self.colLoadMyJob.jobId;
				if self.colLoadMyJob.isJobComplete then
					aString := aString &amp; " COMPLETE";
				endif;
			endif;
			block := _dataContainer.addNewBlock;
			block.addNewItem("Load Job ", DC_Label, 1, null);
			block.addNewItem(aString, DC_Data, 1, null);

			// ###################
			// SEQUENCE NUMBER
			if myBayArea.workingMode = SHP_VoyageAreaForm2.WorkMode_Plan then
				aString := self.colLoadSeqNum.String.padLeadingZeros(3);
				if aString &lt;&gt; null then
					block := _dataContainer.addNewBlock;
					block.addNewItem("Sequence Number ", DC_Label, 1, null);
					block.addNewItem(aString, DC_Data, 1, null);
				endif;
			endif;
		endif;
		if self.colLoadMyCargoType &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem("Cargo Type ", DC_Label, 1, self.colLoadMyCargoType);
			block.addNewItem(self.colLoadMyCargoType.description, DC_Data, 1, self.colLoadMyCargoType);
		endif;
		if self.colLoadMyDischPort &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem("Destination ", DC_Label, 1, self.colLoadMyDischPort);
			block.addNewItem(self.colLoadMyDischPort.code.trimBlanks &amp; " - " &amp; self.colLoadMyDischPort.description.trimBlanks,
					DC_Data, 1, self.colLoadMyDischPort);
		endif;
		if self.colLoadMyCommodityGroup &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem("Commodity ", DC_Label, 1, self.colLoadMyCommodityGroup);
			block.addNewItem(self.colLoadMyCommodityGroup.code.trimBlanks &amp; " - " &amp; self.colLoadMyCommodityGroup.description.trimBlanks,
					DC_Data, 1, self.colLoadMyCommodityGroup);
		endif;
		if self.colLoadDLR then
			block := _dataContainer.addNewBlock;
			block.addNewItem("Double Lift Re-Stow ", DC_Label, 1, null);
			block.addNewItem("Yes", DC_Data, 1, null);
		endif;
		if self.colLoadSOB then
			block := _dataContainer.addNewBlock;
			block.addNewItem("Shift On Board ", DC_Label, 1, null);
			block.addNewItem("Yes", DC_Data, 1, null);
		endif;
		self.getExtraInfoTI(x ,y, _dataContainer);
		if aSlotRequest &lt;&gt; null then
//			aSlotRequest.getExtraInfo(_dataContainer);
		endif;
	endif;

	// ############################
	// always show this stuff
	if self.mySlotDefn.myBay.isKindOf(CM_BayVoyage) then
		useCellTier := self.mySlotDefn.myBay.CM_BayVoyage.myCellularVoyageStructure.useBayCellTierNumbering;
	endif;
	
	block := _dataContainer.addNewBlock;
	block.addNewItem("Position" , DC_Label, 1, null);
	
	aString := "[" &amp; self.mySlotDefn.myBay.myHold.ordinalHold.String.padLeadingZeros(2) &amp; "]";
	aString := aString &amp; " (" &amp;  self.mySlotDefn.myBay.id &amp; ")";
	if self.mySlotDefn.myBay.idBay40 &lt;&gt; null then
	aString := aString &amp; " {" &amp;  self.mySlotDefn.myBay.idBay40 &amp; "}";
	endif;
	 if self.myGridArea.isKindOf(SHP_BayAreaAboveDeck) then
	 	if useCellTier then
			aString := aString &amp; " " &amp; self.mySlotDefn.myBay.allCellsOnDeckByOrdinal[self.mySlotDefn.ordinalCell].id;
			aString := aString &amp; " " &amp; self.mySlotDefn.myBay.allTiersOnDeck[self.mySlotDefn.ordinalTier].id;
		else
			aString := aString &amp; " " &amp; self.mySlotDefn.myBay.allTiersOnDeck[self.mySlotDefn.ordinalTier].id;
			aString := aString &amp; " " &amp; self.mySlotDefn.myBay.allCellsOnDeckByOrdinal[self.mySlotDefn.ordinalCell].id;
		endif;
	else
	 	if useCellTier then
			aString := aString &amp; " " &amp; self.mySlotDefn.myBay.allCellsUnderDeckByOrdinal[self.mySlotDefn.ordinalCell].id;
			aString := aString &amp; " " &amp; self.mySlotDefn.myBay.allTiersUnderDeck[self.mySlotDefn.ordinalTier].id;
		else
			aString := aString &amp; " " &amp; self.mySlotDefn.myBay.allTiersUnderDeck[self.mySlotDefn.ordinalTier].id;
			aString := aString &amp; " " &amp; self.mySlotDefn.myBay.allCellsUnderDeckByOrdinal[self.mySlotDefn.ordinalCell].id;
		endif;
		bBlock := _dataContainer.addNewBlock;
		bBlock.addNewItem("Cell Height" , DC_Label, 1, null);
		bBlock.addNewItem(self.myGridColumn.SHP_BayColumn.myCell.getHeightStatsString(),
				DC_Data, 1, null);
	endif;

	block.addNewItem(aString, DC_Data, 1, null);

	if mySlotController &lt;&gt; null then
		// ####### AFT SLOT
		myNeighbour := mySlotController.myAftSlot;
		if myNeighbour &lt;&gt; null then
			if theBayAreaMode = ShpDisplayMode_Actual or 
			   theBayAreaMode = ShpDisplayMode_EDI then
				theTI := myNeighbour.getTIAtIndex(REAL_MODE,1);
			elseif theBayAreaMode = ShpDisplayMode_Proposed 	then
				theTI := myNeighbour.getTIAtIndex(PLANNING_MODE,1);
			endif;
			block := _dataContainer.addNewBlock;
			block.addNewItem("Aft Slot", DC_Label, 1, myNeighbour);
			if theTI &lt;&gt; null  then
				block.addNewItem(myNeighbour.mySlotDefnVoyage.myBay.myHold.ordinalHold.String.padLeadingZeros(2) &amp; " " &amp; myNeighbour.getStowageId(theTI) &amp; " (" &amp; theTI.id &amp;  ")",
						DC_Data, 1, myNeighbour);
			else
				block.addNewItem(myNeighbour.mySlotDefnVoyage.myBay.myHold.ordinalHold.String.padLeadingZeros(2) &amp; " " &amp; myNeighbour.getStowageId(null),
						DC_Data, 1, myNeighbour);
			endif;
		endif;
		// ####### FORWARD SLOT
		myNeighbour := mySlotController.myForwardSlot; //;
		if myNeighbour &lt;&gt; null then
			if theBayAreaMode = ShpDisplayMode_Actual or theBayAreaMode = ShpDisplayMode_EDI then
				theTI := myNeighbour.getTIAtIndex(REAL_MODE,1);
			elseif theBayAreaMode = ShpDisplayMode_Proposed 	then
				theTI := myNeighbour.getTIAtIndex(PLANNING_MODE,1);
			endif;
			block := _dataContainer.addNewBlock;
			block.addNewItem("Forward Slot", DC_Label, 1, myNeighbour);
			
			if theTI &lt;&gt; null then
				block.addNewItem(myNeighbour.mySlotDefnVoyage.myBay.myHold.ordinalHold.String.padLeadingZeros(2) &amp; " " &amp;  myNeighbour.getStowageId(theTI)&amp; " (" &amp; theTI.id &amp;  ")",
						DC_Data, 1, myNeighbour);
			else
				block.addNewItem(myNeighbour.mySlotDefnVoyage.myBay.myHold.ordinalHold.String.padLeadingZeros(2) &amp; " " &amp; myNeighbour.getStowageId(null),
						DC_Data, 1, myNeighbour);
			endif;
		endif;
	endif;

	if app.isSpecial then
		block := _dataContainer.addNewBlock;
		block.addNewItem("Bay Point", DC_Label, 1, self);
		block.addNewItem(self.String, DC_Data, 1, self);

		 if mySlotController.CM_SlotController.mySlotRequestLoad &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem("Load Request", DC_Label, 1, mySlotController.CM_SlotController.mySlotRequestLoad);
			block.addNewItem(mySlotController.CM_SlotController.mySlotRequestLoad.String, DC_Data, 1,
					mySlotController.CM_SlotController.mySlotRequestLoad);
			foreach theWLE in mySlotController.CM_SlotController.mySlotRequestLoad.allWorkListEntries do
				block := _dataContainer.addNewBlock;
				block.addNewItem("Load WLE", DC_Label, 1,theWLE );
				block.addNewItem(theWLE.String, DC_Data, 1, theWLE);
			endforeach;

		endif;
		 if mySlotController.CM_SlotController.mySlotRequestDischarge &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem("Discharge Request", DC_Label, 1, mySlotController.CM_SlotController.mySlotRequestDischarge);
			block.addNewItem(mySlotController.CM_SlotController.mySlotRequestDischarge.String, DC_Data, 1,
					mySlotController.CM_SlotController.mySlotRequestDischarge);
			foreach theWLE in mySlotController.CM_SlotController.mySlotRequestDischarge.allWorkListEntries do
				block := _dataContainer.addNewBlock;
				block.addNewItem("Discharge WLE", DC_Label, 1,theWLE );
				block.addNewItem(theWLE.String, DC_Data, 1, theWLE);
			endforeach;
		endif;

		block := _dataContainer.addNewBlock;
		block.addNewItem("Slot Controller", DC_Label, 1, mySlotController);
		block.addNewItem(mySlotController.String, DC_Data, 1, mySlotController);

		block := _dataContainer.addNewBlock;
		block.addNewItem("Bay", DC_Label, 1, self.myBay);
		block.addNewItem(self.myBay.String, DC_Data, 1, self.myBay);

		block := _dataContainer.addNewBlock;
		block.addNewItem("Slot Definition", DC_Label, 1, self.mySlotDefn);
		block.addNewItem(self.mySlotDefn.String, DC_Data, 1, self.mySlotDefn);
	endif;
	return theReturnObject;

epilog
	delete theTIs;
end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoObject" id="c9ccb45f-0185-4dcc-81c0-caac00e83a57">
        <source>getExtraInfoObject(): Object;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	idx, theBayAreaMode		: Integer;
	myBayArea :SHP_BayArea;
	aSlotRequest : CM_SlotRequest;
	theSlotController : CM_SlotController;
begin
	myBayArea := self.myGridArea.SHP_BayArea;
	theBayAreaMode := myBayArea.displayMode;
	theSlotController := self.myLocationsController.CM_SlotController;

	if theBayAreaMode = ShpDisplayMode_ColCodeDisch then
		aSlotRequest := theSlotController.mySlotRequestDischarge;
	elseif theBayAreaMode = ShpDisplayMode_ColCodeLoad then
		aSlotRequest := theSlotController.mySlotRequestLoad;
	endif;	
	if aSlotRequest &lt;&gt; null then
		return aSlotRequest;
	else
		return self;
	endif;

end;</source>
        <ReturnType type="Object"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoTI" id="b57da304-c466-4d52-84df-046c7f7e144b">
        <source>getExtraInfoTI(x: Real; y: Real; _dataContainer : CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25 June 2003 sgp			Use CM_DataContainer to hold data
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------

vars
	theTI	: CM_TrackedItem;
	numTIs,
	idx		: Integer;
	mySlotController : CM_SlotController;
	block : CM_DataContainerBlock;
	theTIs : CM_TIArray;
	theBayAreaMode : Integer;
begin
	theBayAreaMode := self.myGridArea.SHP_BayArea.displayMode;
	
	if self.myLocationsController &lt;&gt; null then
		mySlotController := self.myLocationsController.CM_SlotController;
		
		if theBayAreaMode = ShpDisplayMode_Actual or  theBayAreaMode = ShpDisplayMode_EDI then
			theTIs := mySlotController.allTrackedItems;
	   	elseif theBayAreaMode = ShpDisplayMode_Proposed then
	   		create theTIs transient;
			 mySlotController.getAllPlannedTrackedItems(theTIs, true, false);
		endif;
		if theTIs &lt;&gt; null then
			numTIs := theTIs.size;
			if numTIs = 1 then
				theTI := theTIs.first;
				if theTI &lt;&gt; null then	
					theTI.getExtraInfo(_dataContainer);
				endif;
			else
				foreach theTI in theTIs do
					if theTI &lt;&gt; null then	
						idx := idx + 1;
						theTI.getExtraInfo(_dataContainer);
						if numTIs &lt;&gt; idx then
							block := _dataContainer.addNewBlock;
							block.addNewItem(GridPointStringMoreCargo, DC_MoreInfo, 1, null);
						endif;
					endif;
				endforeach;
			endif;
	   	
	   	endif;
	else
		theTI := self.getTI(x, y);
		if theTI &lt;&gt; null then	
			theTI.getExtraInfo(_dataContainer);
		endif;
	endif;
epilog
	if theBayAreaMode = ShpDisplayMode_Proposed then
		delete theTIs;
	endif;

end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getMatching40Point" id="2ae5fa55-4c67-4548-ba76-508a288749d1">
        <source>getMatching40Point(_drawHoldVertical : Boolean;_matchingBayArea : CMUI_GridArea output;_getAftPoint : Boolean) : SelfType;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	matchingPoint : CMUI_GridPoint;
	matchingBayArea : CMUI_GridArea;
	numRows,numCols : Integer;
	theGridArea : CMUI_GridArea;
	theSDF : CMUI_ScrollableDrawingFrame;
begin
	theGridArea := self.myGridArea;
	theSDF := theGridArea.mySDF;
	
//	if self.myBay.bayType &gt;= BAY_TYPE_TWIN then
	if self.bayType &gt;= BAY_TYPE_TWIN then
		numRows := theSDF.getTotalsRows();
		numCols := theSDF.getTotalColumns();
		
		if _getAftPoint then
			if _drawHoldVertical then
				if theGridArea.row &gt;= (numRows - 1) then
					return null;
				endif;
				matchingBayArea := theSDF.allGridAreasByRowColumn[theGridArea.row + 2,theGridArea.column];
			else
				if theSDF.drawInReverse then // PAR 7951
					if theGridArea.column = 1 then // PAR 7951
						return null; // PAR 7951
					endif;
					matchingBayArea := theSDF.allGridAreasByRowColumn[theGridArea.row,theGridArea.column - 1]; // PAR 7951
				else
					if theGridArea.column = numCols then
						return null;
					endif;
					matchingBayArea := theSDF.allGridAreasByRowColumn[theGridArea.row,theGridArea.column + 1];
				endif;
			endif;
		else
			if _drawHoldVertical then
				if theGridArea.row &lt;= 2 then
					return null;
				endif;
				matchingBayArea := theSDF.allGridAreasByRowColumn[theGridArea.row - 2,theGridArea.column];
			else
				if theGridArea.column = 1 then
					return null;
				endif;
				matchingBayArea := theSDF.allGridAreasByRowColumn[theGridArea.row,theGridArea.column - 1];
			endif;
		endif;
		
		if matchingBayArea &lt;&gt; null then
			_matchingBayArea := matchingBayArea;
			matchingPoint := matchingBayArea.allGridPoints[self.row,self.column];
			return matchingPoint.SHP_BayPoint;
		endif;
		_matchingBayArea := null;
	endif;

	return null;	
end;</source>
        <Parameter name="_drawHoldVertical" type="Boolean"/>
        <Parameter name="_matchingBayArea" type="CMUI_GridArea" usage="output"/>
        <Parameter name="_getAftPoint" type="Boolean"/>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="getName" id="a9093bc2-bb8a-4ac9-826e-08594e0fa549">
        <source>getName(): String;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.myLocationsController = null then
		return "N/A";
	else
		return self.myLocationsController.CM_SlotController.getStowageId(null);
	endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSequenceNumber" id="6736a2cb-5e32-4f55-8863-84940b14a560">
        <source>getSequenceNumber() : String;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		NOT USED now local attributes
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theLabel : String;
	theDrawingAttribute : CM_DrawingAttribute;
	theX, theY, tmpX, tmpY,theAttribCount, theColour : Integer;
	theFontName : String;
	theDrawTextAlign : Integer;
	theFontSize : Real;
	theAftBay : CM_Bay;
	theNeighborPoint,aPoint : CMUI_GridPoint;
	offset, dlrWidth,lOuterColourUpper,lOuterColourLower : Integer;
	theSlotController : CM_SlotController;
	theSeqParams : 	CMIF_SeqParams;
	theSlotReq : CM_SlotRequest;
//	myBayArea : SHP_BayArea;

begin
	create theSeqParams;
	if self.myLocationsController &lt;&gt; null then
		theSlotController := self.myLocationsController.CM_SlotController;
		if self.myGridArea.SHP_BayArea.displayMode = ShpDisplayMode_ColCodeLoad then
			if theSlotController.mySlotRequestLoad &lt;&gt; null then
				theSeqParams.isDischarge := false;
				theSlotReq := theSlotController.mySlotRequestLoad;
			else
				return null;
			endif;
		elseif self.myGridArea.SHP_BayArea.displayMode = ShpDisplayMode_ColCodeDisch then
			if theSlotController.mySlotRequestDischarge &lt;&gt; null then
				theSeqParams.isDischarge := true;
				theSlotReq := theSlotController.mySlotRequestDischarge;
			else
				return null;
			endif;
		else
			return null;
		endif;
		
		theSeqParams.isStarBoard := theSlotController.myVoyage.starboardBerthed;
		theSeqParams.showWithSuffix := false;
		theSeqParams.isForty := theSlotReq.getAttrIs40();
		theLabel := theSlotReq.getSeqNumString(theSeqParams);
	endif;

	return theLabel;
epilog
	delete theSeqParams;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTI" id="198f709f-0295-4b6c-bd32-264210c3a202">
        <source>getTI(x: Real; y: Real): CM_TrackedItem;
// ---------------------------------------------------------------------------
// Created:		January 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	theTI, theLTI, theDTI	: CM_TrackedItem;
	rtnStr	: String;
	tmpYPos	: Real;
	numTIs,
	theReturn,idx		: Integer;
	lDisplayMode : Integer;
	mySC : CM_SlotController;
	theTIs: CM_TIArray;
begin
	// ###############
	lDisplayMode := self.myGridArea.mySDF.displayMode;
	// planning in load colour coding
	if (self.myGridArea.SHP_BayArea.displayMode = ShpDisplayMode_ColCodeLoad
	and self.myGridArea.SHP_BayArea.workingMode = SHP_VoyageAreaForm2.WorkMode_Plan) then
		mySC := self.myLocationsController.CM_SlotController;

		// it is possible to have discharge CC for a SOB AND load CC for an export, in the same slot.
		// the user is allowed to drag drop either, so if we have both then ask which one to use
		if mySC.mySlotRequestLoad &lt;&gt; null 
		and mySC.mySlotRequestLoad.moveType &lt;&gt; NULL_MOVETYPE then
			create theTIs transient;
			mySC.getAllPlannedTrackedItems(theTIs, true, false);
			if not theTIs.isEmpty then
				theLTI := theTIs.first;
			endif;
		endif;

		// only get the TI from the discharge CC if it is SOB and the job is incomplete, else get the ti for the load
		if mySC.mySlotRequestDischarge &lt;&gt; null then
			if mySC.mySlotRequestDischarge.moveType = SOB_MOVETYPE then
				if not self.allTrackedItems.isEmpty then
					theDTI := self.allTrackedItems[1];
				endif;
			endif;
		endif;


		if theLTI &lt;&gt; null and theDTI &lt;&gt; null then
			theReturn := app.msgBox("Do you want the SOB cargo (" &amp; theDTI.id &amp; ") for this move?","Confirm Drag Drop",MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
			if theReturn = MsgBox_Return_Yes then
				theTI := theDTI;
			else
				theTI := theLTI;
			endif;
		elseif theDTI &lt;&gt; null then
			theTI := theDTI;
		else
			theTI := theLTI;
		endif;
		
		return theTI;		
	elseif lDisplayMode = DISPLAY_MODE_PLAN then
		if self.allPlannedTrackedItems.isEmpty then
			return null;
		endif;
		theTI := self.allPlannedTrackedItems[1];
		return theTI;
	elseif lDisplayMode = DISPLAY_MODE_ACTUAL then
		if self.allTrackedItems.isEmpty then
			return null;
		endif;
		theTI := self.allTrackedItems[1];
		return theTI;
	
	endif;

epilog
	delete theTIs;

end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="populatControllerAttribute" id="7ca08a9d-e9b1-4347-b8d6-754008be00aa">
        <updating/>
        <source>populatControllerAttribute( _attrib : String) updating ;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.bayActAttribute1 = null then
		self.bayActAttribute1 := _attrib;
	elseif self.bayActAttribute2 = null then
		self.bayActAttribute2 := _attrib;
	elseif self.bayActAttribute3 = null then
		self.bayActAttribute3 := _attrib;
	elseif self.bayActAttribute4 = null then
		self.bayActAttribute4 := _attrib;
	elseif self.bayActAttribute5 = null then
		self.bayActAttribute5 := _attrib;
	elseif self.bayActAttribute6 = null then
		self.bayActAttribute6 := _attrib;
	endif;
end;</source>
        <Parameter name="_attrib" type="String"/>
    </JadeMethod>
    <JadeMethod name="populateController" id="ea633c9d-9e7f-4f75-b334-5d4be32afb7e">
        <updating/>
        <source>populateController(_slotController : CM_SlotController; _isAft : Boolean; _isFwd : Boolean; _bayType : Integer; _theBay : CM_BayVoyage;
				 _row,_col : Integer;  _bayArea : SHP_BayArea; _bayFwdID : String; _bayAftID : String) updating;
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theBay : CM_BayVoyage;
begin
	theBay := _theBay;


	self.setForCreateSuperClass(_bayArea, _row, _col);
	self.myLocationsController := _slotController;





/*
	self.bayIsAft := theBay.isAftBay;
	self.bayIsForward := not self.bayIsAft;
	self.bayType := theBay.bayType;
	self.myBay := theBay;	
*/
	self.bayIsAft := _isAft;
	self.bayIsForward := _isFwd;
	self.bayType := _bayType;
	self.myBay := theBay;	
	self.bayAftID := _bayAftID;
	self.bayFwdID := _bayFwdID;
	
	self.mySlotDefn := _slotController.mySlotDefnVoyage;

	self.populateControllerDefn(self.mySlotDefn);
	self.populateControllerAct(_slotController);
//	self.populateControllerPro(_slotController);
	self.populateControllerCCLoad(_slotController);
	self.populateControllerCCDischarge(_slotController);


end;</source>
        <Parameter name="_slotController" type="CM_SlotController"/>
        <Parameter name="_isAft" type="Boolean"/>
        <Parameter name="_isFwd" type="Boolean"/>
        <Parameter name="_bayType" type="Integer"/>
        <Parameter name="_theBay" type="CM_BayVoyage"/>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_col" type="Integer"/>
        <Parameter name="_bayArea" type="SHP_BayArea"/>
        <Parameter name="_bayFwdID" type="String"/>
        <Parameter name="_bayAftID" type="String"/>
    </JadeMethod>
    <JadeMethod name="populateControllerAct" id="b21b2119-1942-43b6-869a-65a89f26df1b">
        <updating/>
        <source>populateControllerAct(_slotController : CM_SlotController) updating;
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars

	theTI, theDTI : CM_TrackedItem;
	aGridAttributes : SHP_GridAttributes;
	
	
begin
	self.clearAttributes(REAL_MODE);

	create aGridAttributes transient;
	self.myAttributesActual := aGridAttributes;

	theTI := _slotController.getTIAtIndex(REAL_MODE, 1);
	if theTI &lt;&gt; null then
		
		self.tiInfoNumTI := _slotController.allTrackedItems.size;
		self.populateControllerTI(theTI);
	endif;


end;</source>
        <Parameter name="_slotController" type="CM_SlotController"/>
    </JadeMethod>
    <JadeMethod name="populateControllerAddColours" id="274eca75-6cd0-4ba6-81e3-ed82d4ae1911">
        <updating/>
        <source>populateControllerAddColours(_theColour : Integer; _theCode : String; _theObject : Object; _viewModeIndex : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.displayColoursACT[_viewModeIndex] := _theColour;
	self.displayIconsACT[_viewModeIndex] := _theCode;
	self.myAttributesActual.allDisplayCodes[_viewModeIndex] := _theCode;
