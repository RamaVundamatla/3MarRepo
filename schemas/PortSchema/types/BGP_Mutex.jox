    <JadeMethod name="setForUpdate" id="afe70847-031c-4db0-bf84-729bf6fa798e">
        <updating/>
        <source>setForUpdate(_proxyBGPMutex : BGP_Mutex input) updating;
//
// 03 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 2
//
vars

begin
	self.primaryKey := _proxyBGPMutex.primaryKey;
	self.primaryKeyName := _proxyBGPMutex.primaryKeyName;
	self.secondaryKey := _proxyBGPMutex.secondaryKey;
	self.secondaryKeyName := _proxyBGPMutex.secondaryKeyName;
	self.tertiaryKey := _proxyBGPMutex.tertiaryKey;
	self.tertiaryKeyName := _proxyBGPMutex.tertiaryKeyName;
epilog

end;</source>
        <Parameter name="_proxyBGPMutex" type="BGP_Mutex" usage="input"/>
    </JadeMethod>
    <JadeMethod name="update" id="0dedf2e0-4e7a-4693-811d-82c57ef64f57">
        <updating/>
        <source>update(_primaryKey : Integer; _primaryName : String; _secondaryKey : Integer; _secondaryKeyName : String; _tertiaryKey : CM_Object; _tertiaryKeyName : String) updating;
//
// Assign values
//
// 03 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded Stage 2
//
vars

begin
	self.primaryKey       := _primaryKey;
	self.primaryKeyName   := _primaryName;
	self.secondaryKey     := _secondaryKey;
	self.secondaryKeyName := _secondaryKeyName;
	self.tertiaryKey := _tertiaryKey;
	self.tertiaryKeyName := _tertiaryKeyName;
epilog

end;</source>
        <Parameter name="_primaryKey" type="Integer"/>
        <Parameter name="_primaryName" type="String"/>
        <Parameter name="_secondaryKey" type="Integer"/>
        <Parameter name="_secondaryKeyName" type="String"/>
        <Parameter name="_tertiaryKey" type="CM_Object"/>
        <Parameter name="_tertiaryKeyName" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="519a93cc-0b56-4625-95fc-8d372f76ccb4">
        <source>validateForCreate();
//
// 18 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
//
vars
	mutex : BGP_Mutex;
	foundMutex : BGP_Mutex;
begin
	foreach mutex in BGP_Mutex.instances do
		if mutex.primaryKey = self.primaryKey and
		   mutex.secondaryKey = self.secondaryKey and
		   mutex.tertiaryKey = self.tertiaryKey then
			foundMutex := mutex;
			break;
		endif;
	endforeach;
	if foundMutex &lt;&gt; null then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.primaryKeyName, null, null);
	endif;

epilog

end;</source>
    </JadeMethod>
</Class>
