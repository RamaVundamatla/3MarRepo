    <JadeMethod name="pickerWindowForObject" id="aa563544-e1c7-48af-a4aa-47d1a5e54039">
        <source>	pickerWindowForObject(pObjects : ObjectArray):CM_Object;
// ---------------------------------------------------------------------------
// Created:     10 March 2008 by cnwaer1
//	15 Mar 2017	NDL	TFS 3758 - Make use EntTables
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	pickWin		: CMUI_Picker;
	obj, brItem	: Object;
	objSelected : CM_Object;
	bookRef		: CM_BookingRef;
	bookRefItem : CM_BookingRefItem;
	bulkRelease : CM_BulkRelease;
	ti          : CM_TrackedItem;
	logDocketData	: CM_LogDocketData;
	reserve		: CM_ReserveSelection;
	allObjects 	: CM_ObjectArrayActual;
	
begin
	
	create allObjects transient;
	
	foreach obj in pObjects do
		if obj.isKindOf(CM_BookingRef)then
			bookRef := obj.CM_BookingRef;
			if bookRef.status &lt;&gt; BOOKING_REF_ACTIVE then
				continue;
			endif;
			foreach brItem in bookRef.allBookingRefItems do
				bookRefItem := brItem.CM_BookingRefItem;
				allObjects.add(bookRefItem);
			endforeach;
		elseif obj.isKindOf(CM_BulkRelease)then
			bulkRelease := obj.CM_BulkRelease;
			allObjects.add(bulkRelease);
		elseif obj.isKindOf(CM_ReserveSelection)then	
			reserve		:= obj.CM_ReserveSelection;
			bulkRelease := reserve.myReserveHeader;
			allObjects.add(reserve);
		elseif obj.isKindOf(CM_TrackedItem) then
			ti := obj.CM_TrackedItem;
			if ti.state = TI_STATE_TRANSFER or ti.state = TI_STATE_NOTIFIED then
				allObjects.add(ti);
			endif;
		elseif obj.isKindOf(CM_LogDocketData) then
			logDocketData := obj.CM_LogDocketData;
			allObjects.add(logDocketData);
		endif;	
	endforeach;
	
	create pickWin transient;

	pickWin.setListTableUsingEntTable( allObjects, ETDef_GateInOut, 600, true);
	if pickWin.showModal() = MsgBox_Return_OK then
		// get selected object
		objSelected := pickWin.selectedObject.CM_Object;
	else 
		objSelected := null;
	endif;
	
	return objSelected;
	
epilog
	delete allObjects;
end;</source>
        <Parameter name="pObjects" type="ObjectArray"/>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="populateTAs" id="4bfd7c55-b23a-49ac-8830-47a72656d7d6">
        <source>populateTAs(_cargoBOLType : CM_CargoBOLType);
// ---------------------------------------------------------------------------
// Created:     13 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	termAreaSet		: CM_TerminalAreaSet;
	termArea		: CM_TerminalArea;
begin

	self.cmbTermArea.clear();
	termAreaSet := _cargoBOLType.allTerminalAreas;
	self.cmbTermArea.listCollection(termAreaSet, true, 0);
	termArea := termAreaSet.first;
	cmbTermArea.listObject := termArea;
	
end;</source>
        <Parameter name="_cargoBOLType" type="CM_CargoBOLType"/>
    </JadeMethod>
    <JadeMethod name="populateWithProductDefaults" id="14602472-203a-4121-ad7b-6a60022b412c">
        <source>populateWithProductDefaults(_comboProduct : ComboBox input);
//-----------------------------------------------------------------------
//	Created:	25 May 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
// 20/11/2009	cnwmh5		PAR21492 - Show the Type row in the extra table
//-----------------------------------------------------------------------
vars
	entRow			: EntTableRow;
	prodAttr		: CM_ProductAttr;
	pro				: CM_Product;
	attrStr			: String;
	table			: CM_EntryTable;
	cargoType		: CM_CargoType;
	entRowArray		: EntTableRowArray;	
	sheet			: GTE_Sheet;
begin
	sheet := self.topSheet;
	if sheet = null then
		return;
	endif;
	table := sheet.myTblExtra;
	entRowArray := table.myEntTableDef.allEntTableRows;
	
	pro := _comboProduct.listObject.CM_Product;
	if pro = null then
		foreach  entRow in entRowArray do // cnwrd1 21/7/2008 par 17558 setting attribute values when no product exists
			attrStr := entRow.name;		
			self.setProductValueByName( null, attrStr );	
		endforeach;
		return;
	endif;
	cargoType := pro.myCargoType;

	foreach entRow in entRowArray do
		prodAttr := pro.getProdAttrFromName(entRow.name);
		if prodAttr = null then
			continue;
		endif;
		attrStr := entRow.name;
		if (cargoType.allAttributesOnProduct.includes(attrStr)) and (prodAttr.isViewable) or
				attrStr = ETRow_MyType then						// 20/11/2009 cnwmh5 PAR21492
			//th2 don't overwrite existing values
			//PAR 17372---inorder to  reflect Product dimenshions  according to product selected in combo box
			//if table.getValueByName(attrStr) = null then
				table.showRowByName(attrStr, false);
				//table.setValueByName(attrStr, prodAttr.getDisplayValueString());
				self.setProductValueByName( prodAttr, attrStr );	//Par 17524		11/07/2008
				table.setCellText(table.accessedRow.row, table.ColumnHeading, prodAttr.displayName);	
			//endif;
		else
			table.hideRowByName(attrStr, false);
		endif;
	endforeach;

end;</source>
        <Parameter name="_comboProduct" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="queryUnload" id="c2834809-6fdb-478b-baf8-ac8d3ff3454a">
        <controlMethod name="Form::queryUnload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>queryUnload(cancel: Integer io; reason: Integer) updating;
/* AA 29/6/01: If adding or editing then ask user if they want to abandon edits.
This happens when the form itself is closed or the MDI frame is closed. When the
MDI frame is closed, the user gets a message box for each window being edited.

*/
constants
	MSG_STR = "You are currently adding an item that has not been saved. Do you want to abandon your changes ?";
	CANCEL_UNLOAD = 1;
vars
	result : Integer;
begin
	if topSheet &lt;&gt; null then		//at least one sheet apart from the truck sheet
		if reason = QueryUnload_User or reason = QueryUnload_MdiChild then
			result := app.msgBox(MSG_STR, self.caption &amp; " Window Closing !", MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
			if result = MsgBox_Return_No then
				cancel := CANCEL_UNLOAD;	//Do not close form
			endif;			
		endif;
	endif;
end;</source>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="removeTransferRow" id="12a2c702-1dc1-40a6-9bfe-3ea9cd8e29ed">
        <source>removeTransferRow(_ti: CM_TrackedItem);
//----------------------------------------------------------------
//	Created:	29 July 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	idx	: Integer;
begin

	if self.tblTransfers.findObjectInRow(_ti, idx) then
		self.tblTransfers.removeItem(idx);
	endif;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
