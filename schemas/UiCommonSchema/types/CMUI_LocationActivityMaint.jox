    <JadeMethod name="addToolbarControls" id="6f13f6bd-94cc-4179-a0ac-7ef6ecc7d079">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 April 2021	navndl1	Initial creation	TFS 50906

*/

vars

	toolbar	: CMUI_Toolbar;

begin
	
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
