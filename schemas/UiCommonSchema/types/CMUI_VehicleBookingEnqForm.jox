    <JadeMethod name="buildCmbVehicle" id="285760e5-8ae8-4e58-935a-a14e5228f64b">
        <source>buildCmbVehicle();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2022	navhl20	ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen
*/

vars
	vehicle : CM_Vehicle;
	iter : Iterator;
	driver : CM_DriverDetails;
	idx : Integer;
begin
	self.cmbVehicle.clear();
	self.cmbVehicle.addItem(Empty_String);
	driver := self.cmbDriver.getCurrentItemObject.CM_DriverDetails;
	if driver &lt;&gt; null then
		self.cmbVehicle.enabled := true;
		iter := driver.allVehicleMachines.createIterator;
		while iter.next( vehicle ) do
			idx := self.cmbVehicle.addItem( vehicle.regNumber );
			self.cmbVehicle.itemObject[idx] := vehicle;
		endwhile;
	endif;
epilog
	delete iter;
end;</source>
