    <JadeMethod name="translateForm" id="aaf60a8f-3e5f-4d89-9173-8a69d7c27e7a">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 17 March 2025 09:29:25.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018100, locale);
	btnAdd315.translateCaption(Xlat_0020680, locale);
	btnAddCoparn.translateCaption(Xlat_0018101, locale);
	btnAddCoprar.translateCaption(Xlat_0022099, locale);
	btnAddCoreor.translateCaption(Xlat_0022060, locale);
	btnAddCuscar.translateCaption(Xlat_0019728, locale);
	btnAddIFCSUM.translateCaption(Xlat_0021335, locale);
	btnAddIFCSUMDet.translateCaption(Xlat_0023062, locale);		                               // jlgka1 TFS 39187 39185
	btnAddIFCSUMHS.translateCaption(Xlat_0026972, locale);
	btnAddIFTMCS.translateCaption(Xlat_0019156, locale);
	btnAddQatar.translateCaption(Xlat_0020739, locale);
	btnBrowse.translateCaption(Xlat_0026997, locale);
	btnCancel.translateCaption(Xlat_0018102, locale);
	btnDelete315.translateCaption(Xlat_0020681, locale);
	btnDeleteCoparn.translateCaption(Xlat_0018103, locale);
	btnDeleteCoprar.translateCaption(Xlat_0022100, locale);
	btnDeleteCoreor.translateCaption(Xlat_0022061, locale);
	btnDeleteCuscar.translateCaption(Xlat_0019729, locale);
