    <JadeMethod name="createFilteredFeatureCol" id="02e78cb6-ca56-4b74-a7b6-59d33490c5c2">
        <source>createFilteredFeatureCol(_featureDict : Collection):Collection;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2010	#cnwdz2	 24641
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks
23 Nov 2017	jlgdap1	TFS 7511 Allow duplicate attribute names in subclasses to be extracted - only show one entry for any duplicates
*/

vars
	iter : Iterator;
	obj  : Object;
	feature : CM_DataDumpFeature;
	filteredCol : CM_ObjectArray;
	lastFeature : String;						// TFS 7511
begin
	create filteredCol transient;
	
	iter := _featureDict.createIterator();
	while iter.next(obj) do 
		if not obj.isKindOf(CM_DataDumpFeature) then
			continue;
		endif;
		
		feature := obj.CM_DataDumpFeature;
		if feature.isRestrictedToExpose() then
			continue;
		endif;
		if feature.featureName = lastFeature then			// TFS 7511
			continue;										// TFS 7511
		endif;												// TFS 7511
		
		filteredCol.add(feature);
		lastFeature := feature.featureName;					// TFS 7511
	endwhile;
	
	return filteredCol;

epilog
	delete iter;		// PAR #26678
	
end;</source>
        <Parameter name="_featureDict" type="Collection"/>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="displayEntryFeature" id="2d992114-230e-42aa-b723-cca9701bbefe">
        <source>displayEntryFeature(_feature : CM_DataDumpFeature) : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2010	#cnwdz2	 24641

*/

vars

begin
	if _feature &lt;&gt; null then
		return _feature.featureName;
	endif;
epilog

end;</source>
        <Parameter name="_feature" type="CM_DataDumpFeature"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="1ae09dd4-ba38-47a1-9cfd-b899e0731890">
        <updating/>
        <source>doOK() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 April 2010	#cnwdz2	 24641

*/

vars
	idx,
	listCount		: Integer;
	listBox			: CMUI_ListBox;
	feature			: CM_DataDumpFeature;
	allFeatures		: CM_DataDumpFeatureArray;
begin
	app.mousePointer	:=	Busy;
	
	listBox := self.mulFeatureSelect.mySelectedListBox;
	listCount := listBox.listCount;
	create allFeatures transient;
	foreach idx in 1 to listCount do
		feature := listBox.itemObject[idx].CM_DataDumpFeature;
		if feature &lt;&gt; null then
			allFeatures.add(feature);
		endif;
	endforeach;
	self.myDelegate.initSelectedFeatures(allFeatures);
	delete allFeatures;

	inheritMethod();

epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="initMulFeatures" id="ca8d9dec-a11e-4959-acae-cec1379fb011">
        <updating/>
        <source>initMulFeatures() updating, protected;
// ---------------------------------------------------------------------------
// Created:     19/04/2010	cnwdz2 24641
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	
begin
	self.mulFeatureSelect.multiSelect := CMUI_ListBox.MultiSelect_Extended;
	self.mulFeatureSelect.availableHeading := app.getErrorString(Available_features);
	self.mulFeatureSelect.selectedHeading := app.getErrorString(Included_features);
	self.mulFeatureSelect.myAvailableListBox.sorted := false;
	self.mulFeatureSelect.mySelectedListBox.sorted := false;
	
	self.mulFeatureSelect.userInputEnabled := true;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateExtractFeatures" id="9ffedd4e-ec5d-4a21-9e44-9627998d7ef9">
        <source>populateExtractFeatures();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2010	#cnwdz2	 24641

*/

vars
	numRows,
	row					: Integer;
	tbl					: CM_DataTable;
	sysFeatureDict		: CM_DataDumpFeatureByNameDict;
	sysFeature			: CM_DataDumpFeature;
	filteredCol			: Collection;
begin
	if self.myDataDumpExtractClass = null then
		self.mulFeatureSelect.setAvailable(null, true);
		self.mulFeatureSelect.setSelected(null);
		return;
	endif;
	
	if self.myDataDumpExtractClass.myDataDumpClass &lt;&gt; null then
		sysFeatureDict := self.myDataDumpExtractClass.myDataDumpClass.allDataDumpFeatures;
	elseif self.myDataDumpClass &lt;&gt; null then
		sysFeatureDict := self.myDataDumpClass.allDataDumpFeatures;
	endif;
	self.mulFeatureSelect.formDisplayEntryMethodName := 'displayEntryFeature';
	filteredCol := self.createFilteredFeatureCol(sysFeatureDict);
	self.mulFeatureSelect.setAvailable(filteredCol, true);
	self.mulFeatureSelect.setSelected(self.myDataDumpExtractClass.allDataDumpFeatures);
epilog
	delete filteredCol;
end;</source>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="9b8e7012-43b9-47df-a55b-28508a6218a4">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2010	#cnwdz2	 24641

*/

vars
	tmpBackColor	: Integer;
begin
	inheritMethod(_colorControl);
	
	tmpBackColor := self.backColor;
	self.mulFeatureSelect.backColor := tmpBackColor;
epilog

end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="7ee8bc20-d535-44a0-a88e-a42f8314cc27">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 April 2010	#cnwdz2	 24641

*/

vars

begin
	inheritMethod();
	
	self.mulFeatureSelect.left := 0;
	self.mulFeatureSelect.top := 0;
	self.mulFeatureSelect.stretchHeight := true;
	self.mulFeatureSelect.stretchWidth := true;
	self.initMulFeatures();
	self.populateExtractFeatures();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="dd1de6ca-2894-4d4a-b92d-a3209dd53fb4">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0014924, locale);
end;</source>
    </JadeMethod>
</GUIClass>
