    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <PrimAttribute name="isDisplayByName" id="0317a313-e5eb-4347-90d5-8df187832995">
        <embedded/>
        <type name="Boolean"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="displayEntry" id="0a21e27f-da42-4c34-a7c8-0db691d984f4">
        <updating/>
        <source>displayEntry(combobox: ComboBox input; _operator: CM_Operator; lstIndex: Integer): String updating;
// ---------------------------------------------------------------------------
// Created:     24 October 2003 by cnwrs2
//
// Purpose:     
//
// Changed On	Changed By	Reason
// ---------------------------------------------------------------------------
// 08/06/2022	navdap1		TFS 53362 EUP Master Data interface customers between TOS and ERP
vars
	tmpPassport	: CM_Passport;
	failedDAC  :CM_DataAccessController;
	
begin
	if _operator = null then
		return null;
	endif;

	if _operator.isNotAvailableForEntry then
	  	if self.myObject &lt;&gt; _operator then
			return null;
		else
			self.hasDirtyObject := true;
		endif;
	endif;
	
	tmpPassport := app.myPassport;
	if tmpPassport &lt;&gt; null and
	   (not _operator.canUserAccessSelf(null, failedDAC, tmpPassport)) then
		return null;
	endif;
	
	if self.isDisplayByName then		// TFS 53362
		return _operator.description;	// TFS 53362
	else								// TFS 53362
		return _operator.code &amp; Tab &amp; _operator.description;
	endif;								// TFS 53362
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCollectionJMT" id="71cd289c-68e9-4eeb-9b19-184c5e559bc3">
        <source>getCollectionJMT(): Collection protected;
// ---------------------------------------------------------------------------
// Created:     28 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	return app.myRoot.allOperators;

end;</source>
        <access>protected</access>
        <ReturnType type="Collection"/>
    </JadeMethod>
    <JadeMethod name="init" id="ab469b87-d555-4de3-901b-f5f5327be2ee">
        <updating/>
        <source>init() updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09/06/2022	navdap1		Initial creation TFS 53362 EUP Master Data interface customers between TOS and ERP
//
vars

begin
	self.isDisplayByName := app.myRoot.getConfig(ComboByNameOperator).Boolean;
	
	inheritMethod();
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resetCollectionForVoyage" id="c404feed-23b8-41fe-802d-f4482c0e6a7f">
        <updating/>
        <source>resetCollectionForVoyage(_voyage : CM_Voyage)updating;
// ---------------------------------------------------------------------------
// Created:     27 May 2005	cnwhjg1
//
// Purpose:     
// 03/08/2022   navds20     Bug 54202: EUP - Combo Boxes not adhereing to configuration (operator and Stevedore)
// ----------   ----------  --------------------------------------------------
vars
	coll		: Collection;
	idx			: Integer;
	saveText	: String;
begin

	if _voyage = null or 
	   _voyage.isNullVoyage or
	   _voyage.allOperators.isEmpty then	
		coll := app.myRoot.allOperators;
	else
		coll := _voyage.allOperators;
	endif;

// rest of code same as in init method. 

	if coll = null then
		return;
	endif;

	// save the current text and as calling listCollection, clears the current text
	saveText := self.text;
	self.isDisplayByName := app.myRoot.getConfig(ComboByNameOperator).Boolean; //03/08/2022 navds20	TFS 54202
	self.listCollection(coll, true, 0);

	self.selLength := 1000;			
	idx := self.findString(1, saveText);

	if idx &gt; 0 then
		self.listIndex := idx;
		self.text := saveText;
	endif;

	self.amInitialised := true;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
