    <JadeMethod name="getJobCranesXYs" id="6cec9fc5-0708-47ed-8a8f-8713800660fb">
        <source>getJobCranesXYs(_crane : CM_Crane;
				_job : CM_VoyageJob;
				_x1,
				_y1,
				_x2,
				_y2 : Real io);
/*

Purpose:			


Return Value:		


Date		Who		Reason
02 February 2007	cnwer1	Initial creation - PAR#xxxx

