<Class name="CM_RemoteTransferExtra" id="d49bb0fd-1579-437f-9766-9123e8d2aec2">
    <superclass name="CM_RemoteDataExtra"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="remoteDataProcessing"/>
    <Constant name="NNDetailHeading" id="a5f35abe-1417-4a04-a6c1-ad5f107b08a1">
        <source>'Old No Number Detail'</source>
        <type name="String"/>
    </Constant>
    <CompAttribute name="allNNTis" id="4faff473-be92-47d3-a33c-6384771778a4">
        <type name="StringArray"/>
        <access>readonly</access>
    </CompAttribute>
    <PrimAttribute name="grade" id="8653e013-d859-4aba-9dbc-40b4c4b21d84">
        <length>11</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="length" id="8fa6e561-eeaa-4cbc-a571-7d76eb0e43f8">
        <length>11</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="operator" id="1cc21dc3-7a7c-4c4b-bf0b-8b67dff52ce6">
        <length>5</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="species" id="f38d9e02-7df0-4753-990d-86e388a92f3c">
        <length>11</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="treatment" id="ea3c90b1-b118-45b2-9e1f-5d0ff5f6f473">
        <length>11</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="type" id="b7f3500e-e988-4edc-84b0-c45c74f97616">
        <length>11</length>
