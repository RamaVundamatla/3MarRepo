    <JadeMethod name="clear" id="708d991e-a289-446a-b2d1-2088c392d33f">
        <updating/>
        <source>clear() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	frame : Frame;

begin
	self.myVoyage := null;
	self.allGCControllers.clear;

	foreach frame in self.allBulkDrawingFramesById do
		frame.visible := false;
	endforeach;

	self.allBulkDrawingFramesById.clear();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="clearUpDragDrop" id="f3b6e7e0-4efc-4af4-877f-9291a5b70c47">
        <source>clearUpDragDrop();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 15 February 2016	cnwdap1		Initial creation PAR #
//
vars
	frame : SHP_BulkDrawingFrame;
	
begin
	foreach frame in self.allBulkDrawingFramesById do
		frame.dragMode := Window.DragMode_None;
	endforeach;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="create" id="fd79b90c-f106-445f-8ddf-d95b3c1fd17f">
        <updating/>
        <source>create() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars

begin
	self.displayMode := ShpDisplayMode_Actual;
	self.isSelectObjectsEnabled := true;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doHoldColourCargo" id="0b061a9e-ee5d-4152-b685-e41f94751c22">
        <source>doHoldColourCargo(	_lc: CM_LocationsController;
					_theFrame : SHP_BulkDrawingFrame io;
					_x1: Real;
					_y1: Real;
					_x2: Real;
					_y2: Real	) : Integer;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	startingFillColour : Integer;
	form : SHP_BulkVoyagePlanningForm;
	iter : Iterator;
	ti : CM_TrackedItem;
	colour : Integer;
	colourArray : IntegerArray;
	numberArray : IntegerArray;
	index : Integer;
	size : Real;
	countBulk : Integer;
	totalHeight : Real;
	top : Real;
	start : Real;
	height : Real;
	bottom : Real;
	left : Integer;
	right : Integer;
	totalWeight : Decimal[14,4];
	isByWeight : Boolean;
	drawColour : Integer;
	voyageStats : CMIF_VoyageStats;
	jobSheet : CMIF_JobSheetStats;
	voyage : CM_Voyage;
	maxWeight, remWeight : Decimal [14,4];

begin
	startingFillColour := _theFrame.drawFillColor;

	if self.myVoyagePlanningForm &lt;&gt; null then
		form := self.myVoyagePlanningForm;
	endif;
	if form = null or _lc.allTrackedItems.isEmpty then
		return NullColour;
	endif;
	
	// get a collection of the colours to use, and how many cargo items to be associated with each colour
	iter := _lc.allTrackedItems.createIterator;	
	
	foreach ti in  _lc.allTrackedItems do
		if self.imexMode &lt;&gt; null and self.imexMode &lt;&gt; ti.getImExStatus then
			continue;
		endif;
		//write _lc.getID &amp; Tab &amp; ti.id &amp; Tab &amp; ti.getImexStatusStrDesc &amp; Tab &amp; ti.cargoTypeDescr &amp; Tab &amp; ti.totalQuantity.String &amp; Tab &amp; ti.totalWeight.String;
		size := size + ti.totalQuantity.max(1);
		totalWeight := totalWeight + ti.totalWeight;
		if ti.isBulkCargo then
			countBulk := countBulk  + 1;
		endif;
	endforeach;
	
	//if the majority of cargo is bulk ratio by weight
	//if countBulk &gt; (_lc.allTrackedItems.size/2).Integer then
		isByWeight := true;
		size := totalWeight;
	//endif;
	
	create colourArray transient;
	create numberArray transient;
	
	// calculate the proportion of the location controller's maximum weight that has been used up
	if _lc.isKindOf(CM_GeneralCargoController) then
		maxWeight := _lc.CM_GeneralCargoController.maxWeight * 1000;
	endif;
	if maxWeight &gt; 0 and maxWeight &gt; totalWeight then
		remWeight := maxWeight - totalWeight;
		colourArray.add(White);
		numberArray.add(remWeight.Integer);
		totalWeight := maxWeight;
		size := totalWeight;
	endif;
	
	while iter.next( ti ) do
		if self.imexMode &lt;&gt; null and self.imexMode &lt;&gt; ti.getImExStatus then
			continue;
		endif;
		colour := self.getFillColourForTI(ti);
		if colour = NullColour then
			colour := White;
		endif;
		if colourArray.isEmpty then
			// add the first colour
			colourArray.add( colour );
			if isByWeight then
				numberArray.add(ti.totalWeight.Integer  );
			else
				numberArray.add( 1 ); 
			endif;
		else
			// find the colour in our collection
			index := colourArray.indexOf(colour);
			if index &lt; 1 then
				// we don't have it yet, add it.
				colourArray.add( colour );
				if isByWeight then
					numberArray.add(ti.totalWeight.Integer  );
				else
					numberArray.add( 1 );  
				endif;
			else
				
				if isByWeight then
					numberArray[index] := numberArray[index] + ti.totalWeight.Integer;
				else
					// we found it, increment the count for this colour
					numberArray[index] := numberArray[index] +  1;
				endif;
			endif;
		endif;
	endwhile;
 	
	left := _x1.Integer + 1;	// left hand edge of the coloured rectangle we will draw
	right := _x2.Integer - 1;	// right hand edge of the coloured rectangle we will draw
	totalHeight := (_y2 - _y1) - 2; // total height for all colours in the block stack drawing
	start := _y1 + 1;	//starts is at the top of the area we can use.
	
	if size = 0 then	// 22/09/2014 cnwar2 #34924
		size := 1;		// protect against division by zero below
	endif;
	
	drawColour := NullColour;
	foreach index in 1 to colourArray.size do
		top := start;	// top edge of this colours rectangle
		
		height := ( ( totalHeight * numberArray[index] ) / size ); // height of this colour i.e. percentage of the total height.
		bottom := start + height; // botom edge of this colours rectangle
		_theFrame.drawFillColor := colourArray[index];	// colour to use.
		_theFrame.drawFilledRectangle(left, top.Integer, right, bottom.Integer,  colourArray[index] ); // draw it.
		//write "drawn some cargo at " &amp; left.String &amp; Tab &amp; top.String &amp; Tab &amp; right.String &amp; Tab &amp; bottom.String;
		if bottom &gt; 16 and drawColour = NullColour then
			drawColour := _theFrame.drawFillColor;
		endif;
		start := bottom; // set the start position for the next colour.
	endforeach;
	
	return drawColour;
epilog
	delete iter;
	delete colourArray;
	delete numberArray;
	_theFrame.drawFillColor := startingFillColour;
end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_theFrame" type="SHP_BulkDrawingFrame" usage="io"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doHoldColourCargoOperations" id="825b2c72-0116-41c1-aca6-72e11fa666bf">
        <source>doHoldColourCargoOperations(	_lc: CM_LocationsController;
								_theFrame : SHP_BulkDrawingFrame io;
								_x1: Real;
								_y1: Real;
								_x2: Real;
								_y2: Real	) : Integer;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	startingFillColour : Integer;
	form : SHP_BulkVoyagePlanningForm;
	iter : Iterator;
	ti : CM_TrackedItem;
	colour : Integer;
	colourArray, numberArray : IntegerArray;
	index : Integer;
	sizeToMove, sizeDone : Real;
	countBulkToMove, countBulkDone : Integer;
	totalHeight, top, start, height, bottom : Real;
	left, right : Integer;
	totalWeightToMove, totalWeightDone : Decimal[14,4];
	totalVolumeToMove, totalVolumeDone : Decimal[14,4];
	isByWeight : Boolean;
	drawColour : Integer;
	voyage : CM_Voyage;
	str : String;
	move : CM_FutureMove;
	allPlannedTIs, allQueuedTIs : CM_TIArray;
	toDo, done : Boolean;
	maxWeight : Integer;
	otherVoyageDone : Integer;
	idx : Integer;

begin
	startingFillColour := _theFrame.drawFillColor;

	if self.myVoyagePlanningForm &lt;&gt; null then
		form := self.myVoyagePlanningForm;
	endif;
	if form = null or (_lc.allTrackedItems.isEmpty and _lc.allPlannedFutureMoves.isEmpty and _lc.allQueuedFutureMoves.isEmpty) then
		return White;
	endif;
	str := _lc.getID;
	//if self.imexMode = TI_IMEX_STATUS_EXPORT then
	//	write str &amp; Tab &amp; "EXPORT";
	//else
	//	write str &amp; Tab &amp; "IMPORT";
	//endif;
	
	// get a collection of the colours to use, and how many cargo items to be associated with each colour
	if self.actPlanQueMode = ShpDisplayMode_Proposed then
		// for planned mode, EXPORTS include all Export cargo planned to the hold AND all EXP and ROB cargo in the hold already
		// for planned mode, IMPORTS include all Import cargo NOT planned out of the hold
		create allPlannedTIs transient;
		if self.imexMode = TI_IMEX_STATUS_EXPORT then
			// PLANNED Exports 
			foreach move in _lc.allPlannedFutureMoves discreteLock do
				if move.CM_FutureMovePlanned.myTrackedItem &lt;&gt; null then
					//write Tab &amp; "EXPORT" &amp; Tab &amp; "added" &amp; move.CM_FutureMovePlanned.myTrackedItem.id &amp; Tab &amp; move.CM_FutureMovePlanned.myTrackedItem.cargoTypeDescr &amp; Tab &amp; "PLANNED";
					allPlannedTIs.add(move.CM_FutureMovePlanned.myTrackedItem);
					if move.CM_FutureMovePlanned.myTrackedItem.myVoyage &lt;&gt; self.myVoyage then
						otherVoyageDone := otherVoyageDone + move.CM_FutureMovePlanned.myTrackedItem.totalWeight.Integer;
					endif;
				endif;
			endforeach;
			// EXP and ROB already on board
			foreach ti in _lc.allTrackedItems where ti.getImExStatus.isOneOf(TI_IMEX_STATUS_EXPORT, TI_IMEX_STATUS_REMAINONBOARD) do
				//write Tab &amp; "EXPORT" &amp; Tab &amp; "added" &amp; ti.id &amp; Tab &amp; ti.cargoTypeDescr &amp; Tab &amp; ti.getImexStatusStrDesc;
				allPlannedTIs.add(ti);
			endforeach;
		else
			// IMPORTS, planned future moves 
			foreach ti in _lc.allTrackedItems where ti.getImExStatus = TI_IMEX_STATUS_IMPORT and ti.myPrimaryPlannedLocation = null do
				//write Tab &amp; "IMPORT" &amp; Tab &amp; "added" &amp; ti.id &amp; Tab &amp; ti.cargoTypeDescr &amp; Tab &amp; "PLANNED";
				allPlannedTIs.add(ti);
			endforeach;
		endif;
		iter := allPlannedTIs.createIterator;
	elseif self.actPlanQueMode = ShpDisplayMode_Queued then
		// for queued mode, EXPORTS include all Export cargo queued to the hold AND all EXP and ROB cargo in the hold already
		// for queued mode, IMPORTS include all Import cargo NOT queued out of the hold
		create allQueuedTIs transient;
		if self.imexMode = TI_IMEX_STATUS_EXPORT then
			// QUEUED Exports
			foreach move in _lc.allQueuedFutureMoves discreteLock do
				if move.CM_FutureMoveQueued.myTrackedItem &lt;&gt; null then
					allQueuedTIs.add(move.CM_FutureMoveQueued.myTrackedItem);
				endif;
			endforeach;
			// EXP and ROB already on board
			foreach ti in _lc.allTrackedItems where ti.getImExStatus.isOneOf(TI_IMEX_STATUS_EXPORT, TI_IMEX_STATUS_REMAINONBOARD) do
				allQueuedTIs.add(ti);
			endforeach;
		else
			// IMPORTS, queued future moves
			foreach ti in _lc.allTrackedItems where ti.myPrimaryQueuedLocation = null do
				allQueuedTIs.add(ti);
			endforeach;
		endif;
		iter := allQueuedTIs.createIterator;
	else
		// ACTUAL mode - just show what's on board for both IMPORT and EXPORT
		iter := _lc.allTrackedItems.createIterator;
	endif;
	
	create colourArray transient;
	create numberArray transient;
	
	isByWeight := self.workingMode = self.myVoyagePlanningForm.WorkMode_Weight;
	voyage := self.myVoyage;
	// We need to find the total weight / number of items on site and on ship for the imex status we're displaying
	// Onship TIs
	// 		1. Actual mode IMPORT = to do if imex is IMP
	//		2. Actual mode EXPORT = done if imex is EXP or ROB
	//		3. Planned mode IMPORT = to do if not planned and imex is IMP
	//							   = done if planned and imex is IMP
	//		4. Planned mode EXPORT = done if imex=EXP or ROB
	// Queued same rules as Planned
	//write Tab &amp; "ONSHIP";
	foreach ti in voyage.allOnshipTIsByCargoTypeId discreteLock where ti.myPrimaryActualLocation = _lc do 
		toDo := false; done := false;
		if self.actPlanQueMode = ShpDisplayMode_Actual then 
			// Actual mode IMPORT - to do if imex is IMP or TSH on import voyage
			if (ti.getImExStatus = TI_IMEX_STATUS_IMPORT or ti.isTranshipInbound) and self.imexMode = TI_IMEX_STATUS_IMPORT then
				toDo := true;
			endif;
			// Actual mode EXPORT = done if imex is EXP or ROB
			if ti.getImExStatus.isOneOf(TI_IMEX_STATUS_EXPORT, TI_IMEX_STATUS_REMAINONBOARD) and self.imexMode = TI_IMEX_STATUS_EXPORT then
				done := true;
			endif;
		
		elseif self.actPlanQueMode = ShpDisplayMode_Proposed then
			//Planned mode IMPORT = to do if not planned and imex is IMP
			//					  = done if planned and imex is IMP
			if ti.getImExStatus = TI_IMEX_STATUS_IMPORT and self.imexMode = TI_IMEX_STATUS_IMPORT and ti.myPrimaryPlannedLocation = null then
				toDo := true;
			elseif ti.getImExStatus = TI_IMEX_STATUS_IMPORT and self.imexMode = TI_IMEX_STATUS_IMPORT and ti.myPrimaryPlannedLocation &lt;&gt; null then
				done := true;
				
			// Planned mode EXPORT = done if imex=EXP or ROB
			elseif ti.getImExStatus.isOneOf(TI_IMEX_STATUS_EXPORT, TI_IMEX_STATUS_REMAINONBOARD) and self.imexMode = TI_IMEX_STATUS_EXPORT then
				done := true;
			endif;
			
		elseif self.actPlanQueMode = ShpDisplayMode_Queued then
			// queued same as planned
			if ti.getImExStatus = TI_IMEX_STATUS_IMPORT and self.imexMode = TI_IMEX_STATUS_IMPORT and ti.myPrimaryQueuedLocation = null then
				toDo := true;
			elseif ti.getImExStatus = TI_IMEX_STATUS_IMPORT and self.imexMode = TI_IMEX_STATUS_IMPORT and ti.myPrimaryQueuedLocation &lt;&gt; null then
				done := true;
				
			// Planned mode EXPORT = done if imex=EXP or ROB
			elseif ti.getImExStatus.isOneOf(TI_IMEX_STATUS_EXPORT, TI_IMEX_STATUS_REMAINONBOARD) and self.imexMode = TI_IMEX_STATUS_EXPORT then
				done := true;
			endif;
		endif;
		
		if toDo then
			//write Tab &amp; Tab &amp; "toDo " &amp; Tab &amp; ti.id &amp; Tab &amp; ti.cargoTypeDescr &amp; Tab &amp; ti.totalQuantity.String &amp; Tab &amp; ti.totalWeight.String;
			sizeToMove := sizeToMove + ti.totalQuantity.max(1);
			totalWeightToMove := totalWeightToMove + ti.totalWeight;
			totalVolumeToMove := totalVolumeToMove + ti.totalVolume.max(1);
			if ti.isBulkCargo then
				countBulkToMove := countBulkToMove + 1;
			endif;
		elseif done then
			//write Tab &amp; Tab &amp; "done " &amp; Tab &amp; ti.id &amp; Tab &amp; ti.cargoTypeDescr &amp; Tab &amp; ti.totalQuantity.String &amp; Tab &amp; ti.totalWeight.String;
			sizeDone := sizeDone + ti.totalQuantity.max(1);
			totalWeightDone := totalWeightDone + ti.totalWeight;
			totalVolumeDone := totalVolumeDone + ti.totalVolume.max(1);
			if ti.isBulkCargo then
				countBulkDone := countBulkDone + 1;
			endif;
		endif;
		
	endforeach;
	
	// Onsite TIs
	// 		1. Actual mode IMPORT = done if imex is IMP
	//		2. Actual mode EXPORT = to do if imex is EXP
	//		3. Planned mode IMPORT = done if imex is IMP
	//		4. Planned mode EXPORT = done if planned and imex is EXP
	// Queued same rules as Planned
	//write Tab &amp; "ONSITE";
	foreach ti in voyage.allOnsiteTIsByCargoTypeId discreteLock do
		toDo := false; done := false;
		if self.actPlanQueMode = ShpDisplayMode_Actual then
			// 1. Actual mode IMPORT = done if imex is IMP
			if self.imexMode = TI_IMEX_STATUS_IMPORT and ti.getImExStatus = TI_IMEX_STATUS_IMPORT then
				done := true;
			// 2. Actual mode EXPORT = to do if imex is EXP
			elseif self.imexMode = TI_IMEX_STATUS_EXPORT and ti.getImExStatus = TI_IMEX_STATUS_EXPORT then
				//toDo := true;
			endif;
		
		elseif self.actPlanQueMode = ShpDisplayMode_Proposed then
			// 3. Planned mode IMPORT = done if imex is IMP
			if self.imexMode = TI_IMEX_STATUS_IMPORT and ti.getImExStatus = TI_IMEX_STATUS_IMPORT then
				done := true;
			// 4. Planned mode EXPORT = done if planned and imex is EXP
			elseif self.imexMode = TI_IMEX_STATUS_EXPORT and ti.getImExStatus = TI_IMEX_STATUS_EXPORT then
				foreach move in ti.allPlannedFutureMoves where move.getPrimaryLocation = _lc do
					done := true;
				endforeach;
			endif;
			
		elseif self.actPlanQueMode = ShpDisplayMode_Queued then
			// Queued rules same as planned
			if self.imexMode = TI_IMEX_STATUS_IMPORT and ti.getImExStatus = TI_IMEX_STATUS_IMPORT then
				done := true;
			elseif self.imexMode = TI_IMEX_STATUS_EXPORT and ti.getImExStatus = TI_IMEX_STATUS_EXPORT then
				foreach move in ti.allQueuedFutureMoves where move.getPrimaryLocation = _lc do
					done := true;
				endforeach;
			endif;
		endif;
	
		if toDo then
			//write Tab &amp; Tab &amp; "toDo" &amp; Tab &amp; ti.id &amp; Tab &amp; ti.cargoTypeDescr &amp; Tab &amp; ti.totalQuantity.String &amp; Tab &amp; ti.totalWeight.String;
			sizeToMove := sizeToMove + ti.totalQuantity.max(1);
			totalWeightToMove := totalWeightToMove + ti.totalWeight;
			totalVolumeToMove := totalVolumeToMove + ti.totalVolume.max(1);
			if ti.isBulkCargo then
				countBulkToMove := countBulkToMove + 1;
			endif;
		elseif done then
			//write Tab &amp; Tab &amp; "done" &amp; Tab &amp; ti.id &amp; Tab &amp; ti.cargoTypeDescr &amp; Tab &amp; ti.totalQuantity.String &amp; Tab &amp; ti.totalWeight.String;
			sizeDone := sizeDone + ti.totalQuantity.max(1);
			totalWeightDone := totalWeightDone + ti.totalWeight;
			totalVolumeDone := totalVolumeDone + ti.totalVolume.max(1);
			if ti.isBulkCargo then
				countBulkDone := countBulkDone + 1;
			endif;
		endif;
		
	endforeach;
		
	// add an entry to the array for what's been done (in import mode) and what's to do (in export mode)
	totalWeightDone := totalWeightDone + otherVoyageDone;
	colourArray.add(White);
	//write Tab &amp; "totalWeightToMove is " &amp; totalWeightToMove.String &amp; Tab &amp; "totalWeightDone is " &amp; totalWeightDone.String;
	/*if self.actPlanQueMode = ShpDisplayMode_Actual then
		if self.imexMode = TI_IMEX_STATUS_IMPORT then 
			//write Tab &amp; "totalWeightDone added to array" &amp; Tab &amp; totalWeightDone.String;
			if isByWeight then
				numberArray.add(totalWeightDone.Integer);
			else
				numberArray.add(totalVolumeDone.Integer);
			endif;
		else
			//write Tab &amp; "totalWeightToMove added to array" &amp; Tab &amp; totalWeightToMove.String;
			if isByWeight then
				numberArray.add(totalWeightToMove.Integer);
			else
				numberArray.add(totalVolumeToMove.Integer);
			endif;
		endif;
	else*/
		// for planning/queuing mode, use the hold's capacity as the maximum size - so the "still to do" amount is
		// (capacity - what's already been planned)
		if _lc.isKindOf(CM_GeneralCargoController) and _lc.CM_GeneralCargoController.maxWeight &lt;&gt; null then
			maxWeight := _lc.CM_GeneralCargoController.maxWeight*1000;
		endif;
		if self.imexMode = TI_IMEX_STATUS_EXPORT then
			if isByWeight then
				if totalWeightDone &lt; maxWeight then
					//write _lc.getFullId &amp; Tab &amp; "adding " &amp; maxWeight.String &amp; " - " &amp; totalWeightDone.String &amp; " to numberArray";
					numberArray.add((maxWeight - totalWeightDone).Integer);
					totalWeightToMove := maxWeight - totalWeightDone;
				else
					numberArray.add(null);
				endif;
			else
				numberArray.add(totalVolumeToMove.Integer);
			endif;
		else
			if isByWeight then
				if totalWeightToMove &lt; maxWeight then
					//write _lc.getFullId &amp; Tab &amp; "adding " &amp; maxWeight.String &amp; " - " &amp; totalWeightDone.String &amp; " to numberArray";
					numberArray.add((maxWeight - totalWeightToMove).Integer);
					totalWeightDone := maxWeight - totalWeightToMove;
				else
					numberArray.add(null);
				endif;
			else
				numberArray.add(totalVolumeDone.Integer);
			endif;
		endif;
	//endif;
	//else
	//	if self.imexMode = TI_IMEX_STATUS_IMPORT then
	//		numberArray.add(totalVolumeDone.Integer);
	//	else
	//		numberArray.add(totalVolumeToMove.Integer);
	//	endif;
	//endif;
	
	while iter.next( ti ) do
		if self.imexMode &lt;&gt; null and self.imexMode &lt;&gt; ti.getImExStatus then
			// Remain on Board treated as Imports
			if self.imexMode = TI_IMEX_STATUS_EXPORT and ti.getImExStatus = TI_IMEX_STATUS_REMAINONBOARD then
			else
				continue;
			endif;
		endif;
		
		colour := self.getFillColourForTI(ti);
		if colour = NullColour then
			colour := White;
		endif;
		//write Tab &amp; "added " &amp; ti.id &amp; Tab &amp; colour.String &amp; Tab &amp; ti.totalVolume.max(1).String;
		if colourArray.isEmpty then
			// add the first colour
			colourArray.add(colour);
			if isByWeight then
				numberArray.add(ti.totalWeight.Integer  );
			else
				numberArray.add(ti.totalVolume.max(1).Integer); 
			endif;
		else
			// find the colour in our collection
			index := colourArray.indexOf(colour);
			if index &lt; 1 then
				// we don't have it yet, add it.
				colourArray.add(colour);
				if isByWeight then
					numberArray.add(ti.totalWeight.Integer);
				else
					numberArray.add(ti.totalVolume.max(1).Integer);  
				endif;
			else
				// we found it, increment the count for this colour
				if isByWeight then
					numberArray[index] := numberArray[index] + ti.totalWeight.Integer;
				else
					numberArray[index] := numberArray[index] + ti.totalVolume.max(1).Integer;
				endif;
			endif;
		endif;
	endwhile;
 	
	//foreach idx in 1 to colourArray.size do
	//	write _lc.getFullId &amp; Tab &amp; "colour " &amp; colourArray[idx].String &amp; Tab &amp; "number " &amp; numberArray[idx].String;
	//endforeach;
	
	left := _x1.Integer + 1;	// left hand edge of the coloured rectangle we will draw
	right := _x2.Integer - 1;	// right hand edge of the coloured rectangle we will draw
	totalHeight := (_y2 - _y1) - 2; // total height for all colours in the block stack drawing
	start := _y1 + 1;	//starts is at the top of the area we can use.
	
	if isByWeight and totalWeightDone + totalWeightToMove = 0 then	
		totalWeightDone := 1;		// protect against division by zero below
	elseif not isByWeight and totalVolumeDone + totalVolumeToMove = 0 then
		totalVolumeDone := 1;		// protect against division by zero below
	endif;
	
	//write "totalHeight " &amp; totalHeight.String &amp; Tab &amp; "totalWeightToMove " &amp; totalWeightToMove.String &amp; Tab &amp; "totalWeightDone " &amp; totalWeightDone.String;
	drawColour := NullColour;
	foreach index in 1 to colourArray.size do
		top := start;	// top edge of this colours rectangle
		
		if isByWeight then
			height := ( ( totalHeight * numberArray[index] ) / (totalWeightToMove + totalWeightDone) ); // height of this colour i.e. percentage of the total height.
			//write Tab &amp; "height: " &amp; height.String &amp; Tab &amp; "totalHeight: " &amp; totalHeight.String &amp; Tab &amp; "numberArray[index]: " &amp; numberArray[index].String &amp; Tab &amp; "totalWeightToMove: " &amp; totalWeightToMove.String &amp; Tab &amp; "totalWeightDone: " &amp; totalWeightDone.String;
		else
			height := ( ( totalHeight * numberArray[index] ) / (totalVolumeToMove + totalVolumeDone).Integer ); // height of this colour i.e. percentage of the total height.
			//write _lc.getFullId &amp; Tab &amp; "height: " &amp; height.String &amp; Tab &amp; "totalHeight: " &amp; totalHeight.String &amp; Tab &amp; "numberArray[index]: " &amp; numberArray[index].String &amp; Tab &amp; "totalVolumeToMove: " &amp; totalVolumeToMove.String &amp; Tab &amp; "totalVolumeDone: " &amp; totalVolumeDone.String;
		endif;
		bottom := start + height; // botom edge of this colours rectangle
		_theFrame.drawFillColor := colourArray[index];	// colour to use.
		_theFrame.drawFilledRectangle(left, top.Integer, right, bottom.Integer,  colourArray[index] ); // draw it.
		//write _lc.getFullId &amp; Tab &amp; "drawn some cargo at " &amp; left.String &amp; Tab &amp; top.String &amp; Tab &amp; right.String &amp; Tab &amp; bottom.String;
		if bottom &gt; 16 and drawColour = NullColour then
			drawColour := _theFrame.drawFillColor;
		endif;
		start := bottom; // set the start position for the next colour.
	endforeach;
	
	return drawColour;
epilog
	delete iter;
	delete colourArray;
	delete numberArray;
	_theFrame.drawFillColor := startingFillColour;
end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_theFrame" type="SHP_BulkDrawingFrame" usage="io"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawCurrentObject" id="de198e1c-aec8-4352-bcc0-0c532df058c0">
        <updating/>
        <source>drawCurrentObject(_frame: SHP_BulkDrawingFrame input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	frame : SHP_BulkDrawingFrame;
	textAlign, backEndPadding, colour : Integer;

begin
	frame := _frame;
	textAlign := frame.drawTextAlign;
	
	if self.displayMode = ShpDisplayMode_Actual then 
		self.drawHoldActual(frame);
	elseif self.displayMode = ShpDisplayMode_Ops then
		self.imexMode := self.myVoyagePlanningForm.ImexMode_Imports;
		colour := self.drawHoldOperations(frame, true);
		self.imexMode := self.myVoyagePlanningForm.ImexMode_Exports;
		self.drawHoldOperations(frame, false);
		frame.drawFontSize := self.defaultFontSizeForAttributes;
		if self.y2 - self.y1 &gt; 30 then		// TFS 2229 if many hold locations draw the text at the top of the frame so it shows
			frame.drawTextAt(frame.myHold.getID, self.x1+10, self.y1+10, colour);
		else
			frame.drawTextAt(frame.myHold.getID, self.x1+10, self.y1, colour);
		endif;
		self.setDefaultFont(frame);
	else
		app.raiseCMException2(ERR_INVALID_VALUE, "Drawing Mode", "Drawing Mode " &amp; self.displayMode.String &amp; " Is Invalid, it must be reset", null, null);
		return;
	endif;

epilog
	// Reset to how it was before drawing attributes
	frame.drawTextAlign := textAlign;
	frame.drawFillStyle := Frame.DrawFillStyle_Solid;
end;</source>
        <Parameter name="_frame" type="SHP_BulkDrawingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawHold" id="7ea52397-eb15-4abc-b742-f194f17fe8e8">
        <updating/>
        <source>drawHold(_hold : CM_ObjectArray; _holdX, _holdY, _colour : Integer; _holdNbr : Integer io) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	form : SHP_BulkVoyagePlanningForm;
	frame : SHP_BulkDrawingFrame;

begin
	form := self.myVoyagePlanningForm;
	
	frame := form.getBulkDrawingFrame(_holdNbr);
	frame.init(_hold, _holdX, _holdY, self.holdDrawWidth, self.holdHeight-10, _colour, self, false);
	frame.drawSelf(self, true, true);
	frame.visible := true;
epilog

end;</source>
        <Parameter name="_hold" type="CM_ObjectArray"/>
        <Parameter name="_holdX" type="Integer"/>
        <Parameter name="_holdY" type="Integer"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_holdNbr" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="drawHoldActual" id="6f34094b-6ef7-46df-bce3-3a521222cebd">
        <updating/>
        <source>drawHoldActual(_frame : SHP_BulkDrawingFrame input) updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
// 08/07/2022	navkc1		#53918: Change Crane text
// 23/04/2024	jlika1		TFS 55125 MTN - On-ship Crane Names
vars
	frame: SHP_BulkDrawingFrame;
	attribCount : Integer;
	hold : CM_LocationsController;

	outerColourUpper,	
	outerColourLower, 
	vMode,
	drawFillColour : Integer;
	myX2, myX1, myY1, myY2	: Real;
	
	smallOutput	: Boolean;	
	textColour : Integer;
	left, right, top, bottom, loop: Integer;
	craneChar: CM_DrawingAttribute;
	
	craneTextToDraw : String;
begin
	craneChar := CM_Root.firstInstance.allDrawingAttributes["PicTACrane"];
	frame := _frame;
	vMode := self.viewMode;
	hold := frame.myHold;
	smallOutput := (self.printOutputStyle = PrintOutput_Small);

	myX1 := self.x1;
	myX2 := self.x2;
	myY1 := self.y1;
	myY2 := self.y2;

	left := myX1.Integer + 1;
	right := myX2.Integer - 1;
	top := myY1.Integer + 1;
	bottom := myY2.Integer - 1;
	
	drawFillColour := White;

	self.setDrawStyleAndColors(hold, frame, drawFillColour, outerColourUpper, outerColourLower);
	self.drawRectangle(frame, myX1, myY1, myX2, myY2, outerColourUpper, outerColourLower, self.amPrinting, smallOutput);
	// draw colours for the TIs in the location controller (not if we're drawing a selected hold though
	textColour := self.doHoldColourCargo(self.myHold, frame, myX1, myY1, myX2, myY2);
	// 8/7/16 cnwmp6 TFS 1601 - Still draw TIs their colour, put a border round the selected ones
	if self.allSelectedObjects.includes(hold) then
		foreach loop in 0 to 4 do
			frame.drawLine(left, top + loop, right, top + loop, Red);
			frame.drawLine(right - loop, top, right - loop, bottom, Red);
			frame.drawLine(right, bottom - loop, left, bottom - loop, Red);
			frame.drawLine(left + loop, bottom, left + loop, top, Red);
		endforeach;
	endif;
	if textColour = NullColour then
		textColour := White;
	endif;

	if self.scaleFactor &lt;= ScaleFactor_1 and (not self.amPrinting) then
		return;
	endif;
	
	frame.drawFontSize := self.defaultFontSizeForAttributes;
	frame.drawTextAlign := Frame.DrawTextAlign_Left;
	if myY2 - myY1 &gt; 30 then	// TFS 2229 if many hold locations draw the text at the top of the frame so it shows
		frame.drawTextAt(hold.getID, myX1+10, myY1+5, textColour.getInverseColour);
		if self.workingMode = self.myVoyagePlanningForm.WorkMode_Volume then		// 22/7/16 cnwmp6 TFS 1601
			if hold.totalVolume &lt;&gt; null then
				frame.drawTextAt(hold.totalVolume.String &amp; M3, myX1+10, myY1+15, textColour.getInverseColour);
			endif;
		else
			if hold.totalWeightTonnes &lt;&gt; null then
				frame.drawTextAt(hold.totalWeightTonnes.truncated.String &amp; "MT", myX1+10, myY1+15, textColour.getInverseColour);
			endif;
		endif;
		if hold.isKindOf(CM_GeneralCargoController) and (hold.CM_GeneralCargoController.onShipCrane &gt; 0) then		// 18/7/16 cnwmp6 TFS 1601			
			craneTextToDraw := hold.CM_GeneralCargoController.getOnShipCraneDescription;
			frame.drawFontName := craneChar.fontName;				
			//frame.drawTextAt(craneChar.fontCharacter.Character, myX1 + 10, myY1 + 25, craneChar.colour); // #53918, navkc1, 08/07/2022
			frame.drawTextAt(craneTextToDraw, myX1 + 10, myY1 + 25, textColour.getInverseColour);
		endif;
	else
		frame.drawTextAt(hold.getID, myX1+10, myY1, textColour.getInverseColour);
		if self.workingMode = self.myVoyagePlanningForm.WorkMode_Volume then		// 22/7/16 cnwmp6 TFS 1601
			if hold.totalVolume &lt;&gt; null then
				frame.drawTextAt(hold.totalVolume.String &amp; M3, myX1+10, myY1+9, textColour.getInverseColour);
			endif;
		else
			if hold.totalWeightTonnes &lt;&gt; null then
				frame.drawTextAt(hold.totalWeightTonnes.truncated.String &amp; "MT", myX1+10, myY1+9, textColour.getInverseColour);
			endif;
		endif;
		if hold.isKindOf(CM_GeneralCargoController) and (hold.CM_GeneralCargoController.onShipCrane &gt; 0) then		// 18/7/16 cnwmp6 TFS 1601
			craneTextToDraw := hold.CM_GeneralCargoController.getOnShipCraneDescription;
			frame.drawFontName := craneChar.fontName;				
			//frame.drawTextAt(craneChar.fontCharacter.Character, myX1 + 10, myY1 + 18, craneChar.colour); // #53918, navkc1, 08/07/2022
			frame.drawTextAt(craneTextToDraw, myX1 + 10, myY1 + 18, textColour.getInverseColour);
		endif;
	endif;

	// reset the font and size
	self.setDefaultFont(frame);
epilog
	
end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="SHP_BulkDrawingFrame" usage="input"/>
    </JadeMethod>
    <JadeMethod name="drawHoldOperations" id="f3bd8ef7-3176-4ef3-bd1a-6fe0e5f34262">
        <updating/>
        <source>drawHoldOperations(_frame : SHP_BulkDrawingFrame input; _drawImport : Boolean) : Integer updating, protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 24/09/2015	cnwdap1		Initial creation PAR #36766 Graphical Representation of Bulk
//
vars
	frame : SHP_BulkDrawingFrame;
	hold : CM_LocationsController;
	myX1, myX2, myY1, myY2 : Real;
	outerColourUpper,	
	outerColourLower, 
	vMode,
	drawFillColour : Integer;
	smallOutput	: Boolean;	
	textColour : Integer;
	priorImexMode : Integer;
	holdName : String;
	colour,
	loop: Integer;
	weightImp,
	weightExp: Decimal[14, 4];
	ti: CM_TrackedItem;

begin
	// in Operations mode, we draw one rectangle for imports and one rectangle for exports - the
	// two rectangles are as wide in total as the "Actual" rectangle is, and coloured for remaining
	// import / export movements. Import colour starts off full, and ends up empty. Export colour 
	// starts off empty and ends up full
	priorImexMode := self.imexMode;
	frame := _frame;
	hold := frame.myHold;
	colour := frame.borderColorSingle;
	
	if _drawImport then
		myX1 := self.x1;
		myX2 := (self.x2 - self.x1) / 2;
	else
		myX1 := (self.x2 - self.x1) / 2;
		myX2 := self.x2;
	endif;
	myY1 := self.y1;
	myY2 := self.y2;
	
	drawFillColour := White;
	
	self.setDrawStyleAndColors(hold, frame, drawFillColour, outerColourUpper, outerColourLower);
	self.drawRectangle(frame, myX1, myY1, myX2, myY2, outerColourUpper, outerColourLower, self.amPrinting, smallOutput);
	//write "drawn the hold at " &amp; myX1.String &amp; Tab &amp; myY1.String &amp; Tab &amp; myX2.String &amp; Tab &amp; myY2.String &amp; Tab &amp; "_drawImport " &amp; _drawImport.cnEcGetYesNo;
	// set imex mode to define whether we're doing imports or exports
	if _drawImport then
		self.imexMode := self.myVoyagePlanningForm.ImexMode_Imports;
	else
		self.imexMode := self.myVoyagePlanningForm.ImexMode_Exports;
	endif;
	holdName := hold.getFullId;

	textColour := self.doHoldColourCargoOperations(self.myHold, frame, myX1, myY1, myX2, myY2);

	if self.allSelectedObjects.includes(hold) then
		foreach loop in 0 to 4 do
			frame.drawLine(myX1 + 1, myY1 + 1 + loop, myX2 - 1, myY1 + 1 + loop, Red);
			frame.drawLine(myX2 - 1 - loop, myY1 + 1, myX2 - 1 - loop, myY2 - 1, Red);
			frame.drawLine(myX2 - 1, myY2 - 1 - loop, myX1 + 1, myY2 - 1 - loop, Red);
			frame.drawLine(myX1 + 1 + loop, myY2 - 1, myX1 + 1 + loop, myY1 + 1, Red);
		endforeach;
	endif;
	
	if self.scaleFactor &lt;= ScaleFactor_1 and (not self.amPrinting) then
		return colour;
	endif;
	
	frame.drawFontSize := self.defaultFontSizeForAttributes;
	frame.drawTextAlign := Frame.DrawTextAlign_Left;
	if myY2 - myY1 &gt; 30 then		// TFS 2229 if many hold locations, frame may be too small so don't draw this
		foreach ti in hold.allTrackedItems do
			if ti.getImExStatus() = TI_IMEX_STATUS_EXPORT then
				weightExp := weightExp + ti.weightDeclared;
			endif;
			if ti.getImExStatus() = TI_IMEX_STATUS_IMPORT then
				weightImp := weightImp + ti.weightDeclared;
			endif;
		endforeach;
		if _drawImport then
			frame.drawTextAt("Imp", myX1+10, myY1+20, textColour.getInverseColour);
			if (self.workingMode &lt;&gt; self.myVoyagePlanningForm.WorkMode_Volume) and (weightImp &lt;&gt; null) then
				frame.drawTextAt((weightImp / 1000).truncated.String &amp; "MT", myX1+10, myY1+31, textColour.getInverseColour);
			endif;
		else
			frame.drawTextAt("Exp", myX1+10, myY1+20, textColour.getInverseColour);
			if (self.workingMode &lt;&gt; self.myVoyagePlanningForm.WorkMode_Volume) and (weightExp &lt;&gt; null) then
				frame.drawTextAt((weightExp / 1000).truncated.String &amp; "MT", myX1+10, myY1+31, textColour.getInverseColour);
			endif;
		endif;
	endif;
	colour := textColour.getInverseColour;

	// reset the font and size
	self.setDefaultFont(frame);
epilog
	self.imexMode := priorImexMode;
	return colour;
end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="SHP_BulkDrawingFrame" usage="input"/>
        <Parameter name="_drawImport" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawHoldVolume" id="f266c00b-4caf-451c-831a-01a89dd302d1">
        <source>drawHoldVolume(_frame : SHP_BulkDrawingFrame input; _volume, _maxVolume : Decimal; _isOverVolume : Boolean; _x, _y : Real);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 July 2016	cnwmp6	Initial creation

*/


vars
	textColor : Integer;
	volumeStr : String;
	maxVolumeStr : String;
	remVolumeStr : String;
	stringToDraw : String;				// PAR #37640
	newY : Real;						// PAR #37640
	
begin
	textColor := Black;
	if _isOverVolume then
		textColor := Red;
	endif;
	
	//blank out existing	10 Apr 2017	NDL	TFS 4058
	_frame.drawFillColor := _frame.parent.backColor;
	_frame.drawFilledRectangle(0, _y-12, _frame.width, _y + 12, _frame.drawFillColor);

	volumeStr := _volume.String;
	//if _volume &lt; 0 then	
	//	_frame.drawTextAlign := Frame.DrawTextAlign_Left;
	//else
		_frame.drawTextAlign := Frame.DrawTextAlign_Center;
	//endif;
	if _frame.myHold.isKindOf(CM_ShipBlockController) then	// 13/7/16 cnwmp6 TFS 1601
		maxVolumeStr := volumeStr;
	else
		maxVolumeStr := _maxVolume.String;
	endif;
	if _volume &gt; _maxVolume then
		remVolumeStr := "0";
	else
		remVolumeStr := (_maxVolume - _volume).String;
	endif;
	
	_frame.drawFontSize := self.defaultFontSizeForAttributes;
	
	stringToDraw := volumeStr &amp; " of " &amp; maxVolumeStr &amp; M3 &amp; Space &amp; Left_Round_Bracket &amp; remVolumeStr &amp; Right_Round_Bracket;		// PAR #37640
	if _frame.getTextExtent(stringToDraw) &gt; _frame.width then																		// PAR #37640
		newY := _y - 12;																											// PAR #37640
		_frame.drawTextAt(volumeStr &amp; " of " &amp; maxVolumeStr &amp; M3, (_frame.width-10)/2, newY, textColor);							// PAR #37640
		_frame.drawTextAt(Left_Round_Bracket &amp; remVolumeStr &amp; Right_Round_Bracket, (_frame.width-10)/2, newY+12, textColor);		// PAR #37640
	else																															// PAR #37640
		//_frame.drawTextAt(volumeStr &amp; " of " &amp; maxVolumeStr &amp; "MT" &amp; Space &amp; Left_Round_Bracket &amp; remVolumeStr &amp; Right_Round_Bracket, _x, _y, textColor);	// PAR #37640
		_frame.drawTextAt(stringToDraw, (_frame.width-10)/2, _y, textColor);														// PAR #37640
	endif;																															// PAR #37640
	
	// reset the font and size
	self.setDefaultFont(_frame);
epilog

end;</source>
        <Parameter name="_frame" type="SHP_BulkDrawingFrame" usage="input"/>
        <Parameter name="_volume" type="Decimal"/>
        <Parameter name="_maxVolume" type="Decimal"/>
        <Parameter name="_isOverVolume" type="Boolean"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawHoldWeight" id="1b0fc9e7-668c-4efa-9155-3513efa846b7">
        <source>drawHoldWeight(_frame : SHP_BulkDrawingFrame input; _weight, _maxWeight : Integer; _isOverweight : Boolean; _x, _y : Real);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
// 16/03/2016	cnwdap1		PAR #37640 For large hold weights, spread text over two lines
//
vars
	textColor : Integer;
	weightStr : String;
	maxWeightStr : String;
	remWeightStr : String;
	stringToDraw : String;				// PAR #37640
	newY : Real;						// PAR #37640
	
begin
	textColor := Black;
	if _isOverweight then
		textColor := Red;
	endif;
	
	//blank out existing	10 Apr 2017	NDL	TFS 4058
	_frame.drawFillColor := _frame.parent.backColor;
	_frame.drawFilledRectangle(0, _y-12, _frame.width, _y + 12, _frame.drawFillColor);

	weightStr := _weight.String;
	//if _weight &lt; 0 then	
	//	_frame.drawTextAlign := Frame.DrawTextAlign_Left;
	//else
		_frame.drawTextAlign := Frame.DrawTextAlign_Center;
	//endif;
	if _frame.myHold.isKindOf(CM_ShipBlockController) then	// 13/7/16 cnwmp6 TFS 1601
		maxWeightStr := weightStr;
	else
		maxWeightStr := _maxWeight.String;
	endif;
	if _weight &gt; _maxWeight then
		remWeightStr := "0";
	else
		remWeightStr := (_maxWeight - _weight).String;
	endif;
	
	_frame.drawFontSize := self.defaultFontSizeForAttributes;
	
	
	stringToDraw := weightStr &amp; " of " &amp; maxWeightStr &amp; "MT" &amp; Space &amp; Left_Round_Bracket &amp; remWeightStr &amp; Right_Round_Bracket;		// PAR #37640
	if _frame.getTextExtent(stringToDraw) &gt; _frame.width then																		// PAR #37640
		newY := _y - 12;																											// PAR #37640	
		_frame.drawTextAt(weightStr &amp; " of " &amp; maxWeightStr &amp; "MT", (_frame.width-10)/2, newY, textColor);							// PAR #37640
		_frame.drawTextAt(Left_Round_Bracket &amp; remWeightStr &amp; Right_Round_Bracket, (_frame.width-10)/2, newY+12, textColor);		// PAR #37640
	else																															// PAR #37640
		//_frame.drawTextAt(weightStr &amp; " of " &amp; maxWeightStr &amp; "MT" &amp; Space &amp; Left_Round_Bracket &amp; remWeightStr &amp; Right_Round_Bracket, _x, _y, textColor);	// PAR #37640
		_frame.drawTextAt(stringToDraw, (_frame.width-10)/2, _y, textColor);														// PAR #37640
	endif;																															// PAR #37640
	
	// reset the font and size
	self.setDefaultFont(_frame);
epilog

end;</source>
        <Parameter name="_frame" type="SHP_BulkDrawingFrame" usage="input"/>
        <Parameter name="_weight" type="Integer"/>
        <Parameter name="_maxWeight" type="Integer"/>
        <Parameter name="_isOverweight" type="Boolean"/>
        <Parameter name="_x" type="Real"/>
        <Parameter name="_y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawMinature" id="14304186-0f7c-4ed2-ae4f-525923102134">
        <source>drawMinature(_frame: Frame input; _scale: Integer);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
constants
	OFFSET = 4;
	ANGLE = 6;
	WIDTH = 35;
	HEIGHT = 25;
	
vars
	tmpDrawingFrame : SHP_BulkDrawingFrame;
	tmpHold : CM_LocationsController;
	lastLeft, lastTop,
	tmpLeft, tmpTop,
	theHatchY,
	theX1, theY1,
	theX2, theY2 : Real;
	thePoly : RealArray;
	colNum,
	rowNum : Integer;

begin
	_frame.drawFillColor := 16764573;
	_frame.drawFontSize := 8;
	_frame.drawFontName := Font_MicrosoftSansSerif;
	_frame.drawTextAlign := Frame.DrawTextAlign_Center;

	create thePoly transient;

	foreach tmpDrawingFrame in self.allBulkDrawingFramesById do
		tmpHold := tmpDrawingFrame.myHold;
		tmpLeft := tmpDrawingFrame.left;
		tmpTop := tmpDrawingFrame.top;
		if _scale &gt; 0 then
			theX1 := (tmpLeft / _scale).Real;
			theX2 := ((tmpLeft + tmpDrawingFrame.width) / _scale).Real;
			theY1 := (tmpTop / _scale).Real;
			theY2 := ((tmpTop + tmpDrawingFrame.height) / _scale).Real;
		else
			if tmpLeft &gt; lastLeft then
				colNum := colNum + 1;
			else
				colNum := 1;
			endif;
			if tmpTop &gt; lastTop then
				rowNum := rowNum + 1;
			endif;
			theX1 := ((colNum) * WIDTH);
			theX2 := theX1 + WIDTH;
			theY1 := ((rowNum - 1) * HEIGHT);
			theY2 := theY1 + HEIGHT;
			
			lastLeft := tmpLeft;
			lastTop := tmpTop;
		endif;

		if tmpHold = null then
			// this should never happen but if it does
			// we still want to do the above to set the
			// row/col numbers
			continue;
		endif;

		theX1 := theX1  + OFFSET;
		theX2 := theX2  - OFFSET;
		theY1 := theY1  + OFFSET;
		theY2 := theY2  - OFFSET;
		
		theHatchY := theY1 + ((theY2 - theY1) / 2) - 2;
		
		//if tmpBay.allCellsOnDeck.size &gt; 0 then
			thePoly.clear;
			_frame.drawFilledRectangle(theX1, theY1, theX2, theHatchY, Blue);
			_frame.drawTextAt(tmpHold.getID,((theX2 - theX1) / 2) + theX1 , theY1 + 2, Black);
		//endif;

		//if tmpBay.allCellsUnderDeck.size &gt; 0 then
			thePoly.clear;
			theHatchY := theHatchY + 2;
			// draw the underdeck (if any)
			thePoly.add(theX1); thePoly.add(theHatchY); // 1
			thePoly.add(theX2); thePoly.add(theHatchY); // 2
			thePoly.add(theX2); thePoly.add(theY2 - ANGLE); // 3
			thePoly.add(theX2 - ANGLE); thePoly.add(theY2); // 4
			thePoly.add(theX1 + ANGLE); thePoly.add(theY2); // 5
			thePoly.add(theX1); thePoly.add(theY2 - ANGLE); // 6
			thePoly.add(theX1); thePoly.add(theHatchY); // 7
			
			_frame.drawFilledPolygon(thePoly,Blue);
		//endif;
		
	endforeach;
	
epilog
	delete thePoly;
end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_scale" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawObject" id="f13aa63c-c74d-4b08-af36-b1deeda1f64b">
        <updating/>
        <source>drawObject(_frame: CMUI_GridAreaDrawingFrame input; _obj: Object) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	hold : CM_LocationsController;
	otherHold : Object;
	frame : SHP_BulkDrawingFrame;

begin
	if _obj = null then
		return;
	endif;
	
	if CM_VoyageController.hasInstance(_obj) then
		hold := _obj.CM_VoyageController;
	else
		return;
	endif;
	
	foreach frame in self.allBulkDrawingFramesById do
		foreach otherHold in frame.allObjectsOnDeck do
			if otherHold = hold then
				frame.drawObject(_obj, self);
				return;
			endif;
		endforeach;
		foreach otherHold in frame.allObjectsUnderDeck do
			if otherHold = hold then
				frame.drawObject(_obj, self);
				return;
			endif;
		endforeach;
	endforeach;
epilog

end;</source>
        <Parameter name="_frame" type="CMUI_GridAreaDrawingFrame" usage="input"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="drawRectangle" id="638aeae6-90a8-4a35-b9e2-b59cc9f1873e">
        <source>drawRectangle(_frame : Frame input; x1, y1, x2, y2 : Real; _outerColourUpper, _outerColourLower : Integer; _amPrinting, _smallOutput : Boolean) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	tmpColor : Integer;
	parent : Control;

begin
	if _amPrinting then
		if _smallOutput then
			tmpColor := DarkGray;
		else
			tmpColor := Black;
		endif;
		_frame.drawFilledRectangle(x1 - 1, y1 - 1, x2, y2, tmpColor);
	else
		_frame.drawFilledRectangle(x1, y1, x2, y2, Black);
		_frame.drawLine(x1, y1, x2, y1, _outerColourUpper);
		_frame.drawLine(x1, y1, x1, y2 - 1, _outerColourUpper);
		_frame.drawLine(x2 - 1, y1 + 1, x2 - 1, y2, _outerColourLower);
		_frame.drawLine(x1, y2 - 1, x2 - 1, y2 - 1, _outerColourLower);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="x1" type="Real"/>
        <Parameter name="y1" type="Real"/>
        <Parameter name="x2" type="Real"/>
        <Parameter name="y2" type="Real"/>
        <Parameter name="_outerColourUpper" type="Integer"/>
        <Parameter name="_outerColourLower" type="Integer"/>
        <Parameter name="_amPrinting" type="Boolean"/>
        <Parameter name="_smallOutput" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawSelf" id="9ed0c1be-a027-4319-bba3-6f2a5a6d3770">
        <updating/>
        <source>drawSelf(_clearSelected: Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	obj : Object;
	hold : CM_LocationsController;
	holdX, holdY,	maxX, maxY,
	holdWidth, holdHeight, numColumns,
	st, et, holdNbr : Integer;
	bayDrawn : Boolean;
	form : SHP_BulkVoyagePlanningForm;
	drawingController : SHP_BulkDrawingController;
	frame : Frame;
	str : String;
	processStackArray : ProcessStackArray;
	methodCallDesc : MethodCallDesc;
	lastHatch : Integer;
	count : Integer;									//cnwndl1	29 Apr 2016	TFS1922
	
begin
	if self.myVoyage = null then
		// no need for error here as this can be called when initialising
		return;
	endif;

	create processStackArray transient;
	process.currentStack(processStackArray);

	if processStackArray.size &gt; 2 then
		methodCallDesc := processStackArray[3];
		str := methodCallDesc.method.qualifiedName;
	else
		str := method.qualifiedName;
	endif;
	
	self.cnStartTransaction(str[1:50]);

	st := app.clock;

	inheritMethod(_clearSelected);

	form := self.myVoyagePlanningForm;
	drawingController := self;
	
	foreach frame in drawingController.allBulkDrawingFramesById do
		frame.visible := false;
	endforeach;

	drawingController.allBulkDrawingFramesById.clear();

	drawingController.setFontDefaults();
	drawingController.setFontSizeForAttribute();
	drawingController.setDrawingPositions();
	
	numColumns := self.getNumHoldColumns();
	
	if self.isStarboardBerthed then
		holdX := self.sideDrawingMargin;
	else
		//holdX := (self.myVoyagePlanningForm.picSternRev.left - self.holdDrawWidth - 1).Integer;
		holdX := (self.myVoyagePlanningForm.frmScrollBackgrd.width - self.holdDrawWidth + 5).Integer;
		//holdX := (600).Integer;
	endif;
	holdY := 0;
	holdWidth := self.holdDrawWidth;
	holdHeight := self.holdDrawHeight;

	bayDrawn := true;
	
	if (self.myVoyage.myShipBlockStack &lt;&gt; null) and (self.myVoyagePlanningForm.includeShipBlockStack) then		// 20/7/16 cnwmp6 TFS 1601
		self.drawShipBlockStack(self.allHoldsInDrawingOrder.first.CM_ObjectArray, holdX, holdY, colour, holdNbr);
	endif;

//	TFS 1922 NDL 27 May 2016
//  Undo the 29 Apr 2016 changes... Now Steve wants everything reversed not just the forward to aft order..
// This is done in "SHP_BulkDarwingController::init"
//	count := 0;																	//cnwndl1	29 Apr 2016	TFS1922
	foreach obj in self.allHoldsInDrawingOrder do								//cnwndl1	29 Apr 2016	TFS1922
//	foreach obj in self.allHoldsInDrawingOrder reversed do						//cnwndl1	29 Apr 2016	TFS1922
//		count := count + 1;														//cnwndl1	29 Apr 2016	TFS1922
		hold := obj.CM_ObjectArray.first.CM_LocationsController;
		
//		if count = 1 then														//cnwndl1	29 Apr 2016	TFS1922
//			if self.isStarboardBerthed then										//cnwndl1	29 Apr 2016	TFS1922
//				holdX := holdX + holdWidth + 1;									//cnwndl1	29 Apr 2016	TFS1922
//			else																//cnwndl1	29 Apr 2016	TFS1922
//				holdX := holdX - holdWidth - 1;									//cnwndl1	29 Apr 2016	TFS1922
//			endif;																//cnwndl1	29 Apr 2016	TFS1922
//		endif;																	//cnwndl1	29 Apr 2016	TFS1922
		
		// we have a new hold so change the column
		if hold.isKindOf(CM_ShipBlockController) 
		or (hold.isKindOf(CM_GeneralCargoController) and hold.CM_GeneralCargoController.hatch &lt;&gt; lastHatch and lastHatch &lt;&gt; null) then
			if self.isStarboardBerthed then	
				holdX := holdX + holdWidth + 1;
			else
				holdX := holdX - holdWidth - 1;
			endif;
			holdY := 0;
		endif;
		if hold = null or hold.isKindOf(CM_ShipBlockController)  then		// hold is null = no ship block stack
			continue;
		endif;

		self.drawHold(obj.CM_ObjectArray, holdX, holdY, colour, holdNbr);
		
		maxX := (holdX + holdWidth).max(maxX);
		maxY := (holdY + holdHeight).max(maxY);
		if hold.isKindOf(CM_GeneralCargoController) then
			lastHatch := hold.CM_GeneralCargoController.hatch;
		endif;
	endforeach;

	form.dkbGridArea.resizeScrollingFrame(maxX, maxY);

	et := app.clock;
	form.frmStatusLine.myFrameCaption.caption := ((et - st) / 1000).Integer.String &amp; " seconds to draw";

epilog
	if processStackArray &lt;&gt; null then
		processStackArray.purge;
		delete processStackArray;
	endif;
		
	if str &lt;&gt; null then
		self.cnEndTransaction();
	endif;
end;</source>
        <Parameter name="_clearSelected" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="drawShipBlockStack" id="48f66120-f6ba-434e-bc9f-375ac213a7ee">
        <updating/>
        <source>drawShipBlockStack(_hold : CM_ObjectArray; _holdX, _holdY, _colour : Integer; _holdNbr : Integer io) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	form : SHP_BulkVoyagePlanningForm;
	frame : SHP_BulkDrawingFrame;

begin
	form := self.myVoyagePlanningForm;
	
	frame := form.getBulkDrawingFrame(_holdNbr);
	frame.init(_hold, _holdX, _holdY, self.holdDrawWidth, self.holdHeight-10, _colour, self, false);
	frame.drawShipBlockStack(self);
	frame.visible := true;
epilog

end;</source>
        <Parameter name="_hold" type="CM_ObjectArray"/>
        <Parameter name="_holdX" type="Integer"/>
        <Parameter name="_holdY" type="Integer"/>
        <Parameter name="_colour" type="Integer"/>
        <Parameter name="_holdNbr" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllSelectedTIs" id="015728bf-7dff-4ff2-97c1-882338793236">
        <updating/>
        <source>getAllSelectedTIs(_tis: CM_TIArray input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02 September 2015	cnwdap1		Initial creation PAR #
//
vars
	obj : Object;
	lc : CM_LocationsController;

begin
	if _tis = null then
		return;
	endif;
	
	foreach obj in self.allSelectedObjects discreteLock do
		lc := obj.CM_LocationsController;
		lc.allTrackedItemsById.copy(_tis);
	endforeach;

epilog

end;</source>
        <Parameter name="_tis" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getColumnForGCController" id="bcb23b3f-571b-42bb-9aaa-b9d33e5ba4f9">
        <source>getColumnForGCController(_hold : CM_LocationsController) : Integer;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	obj : Object;
	array : CM_ObjectArray;
	count : Integer;

begin
	foreach obj in self.allHoldsInDrawingOrder do
		count := count + 1;
		array := obj.CM_ObjectArray;
		if array.includes(_hold) then
			return count;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_hold" type="CM_LocationsController"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getFrameForLocation" id="ff5d0eb8-d46b-4536-bbe0-26c0caafa429">
        <source>getFrameForLocation(_lc : CM_LocationsController) : SHP_BulkDrawingFrame;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 31/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	frame : SHP_BulkDrawingFrame;

begin
	if _lc = null then
		return null;
	endif;
	
	foreach frame in self.allBulkDrawingFramesById do
		if frame.allHoldsOnDeck.includes(_lc) then
			return frame;
		elseif frame.allHoldsUnderDeck.includes(_lc) then	//10 Apr 2017	NDL	TFS 4058
			return frame;
		elseif frame.allObjectsOnDeck.includes(_lc) then	//10 Apr 2017	NDL	TFS 4058
			return frame;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <ReturnType type="SHP_BulkDrawingFrame"/>
    </JadeMethod>
    <JadeMethod name="getFrameWidthForHold" id="f41f5627-238f-44ac-80f5-fc222c69501b">
        <source>getFrameWidthForHold(_maxCells, _colWidth : Integer) : Integer;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars

begin
	return self.sideDrawingMargin + (_maxCells * _colWidth) + self.sideDrawingMargin;
epilog

end;</source>
        <Parameter name="_maxCells" type="Integer"/>
        <Parameter name="_colWidth" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getHatchWidth" id="5d39e730-8dbd-4b14-99a3-bf67ce38d28d">
        <source>getHatchWidth() : Integer;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars

begin
	return (self.holdDrawWidth /* self.allHoldsInDrawingOrder.size).Integer*/);
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getHoldFrameFromXY" id="aa14866e-e928-4402-8998-261f02617ece">
        <source>getHoldFrameFromXY(x : Real; y : Real) : SHP_BulkDrawingFrame;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	frame : SHP_BulkDrawingFrame;
	fLeft, fTop, fWidth, fHeight : Real;
	
begin
	foreach frame in self.allBulkDrawingFramesById do
		fLeft := frame.left;
		fWidth := (frame.clientWidth + fLeft);
		fTop := frame.top;
		fHeight := (frame.clientHeight + fTop);
		
		if x &gt;= fLeft and x &lt;= fWidth
		and y &gt;= fTop and y &lt;= fHeight then
			return frame;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="SHP_BulkDrawingFrame"/>
    </JadeMethod>
    <JadeMethod name="getHoldHeight" id="170fc090-1954-43a0-a60b-8c870069545b">
        <source>getHoldHeight() : Integer;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	largestHold : Integer;
	object : Object;
	array : CM_ObjectArray;
	returnHeight : Integer;

begin
	foreach object in self.allHoldsInDrawingOrder do
		array := object.CM_ObjectArray;
		largestHold := array.size.max(largestHold);
	endforeach;
	
	returnHeight := (self.holdDrawHeight / 2 / largestHold).Integer;
	// now subtract the allowances for text / hatch/ etc
	returnHeight := returnHeight - 29;
	return returnHeight;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getHoldHeightOnUnderDeck" id="37e56496-30b9-4f7c-a551-098a231efd23">
        <source>getHoldHeightOnUnderDeck(_onDeck : Boolean; _hatch : Integer) : Integer;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	holds : Integer;
	object : Object;
	array : CM_ObjectArray;
	arrayObj : Object;
	returnHeight : Integer;
	hold : CM_GeneralCargoController;
	drawHeight : Integer;

begin
	foreach object in self.allHoldsInDrawingOrder do
		array := object.CM_ObjectArray;
		foreach arrayObj in array do
			if arrayObj.isKindOf(CM_GeneralCargoController) then
				hold := arrayObj.CM_GeneralCargoController;
				if _onDeck and hold.isOnDeck and hold.hatch = _hatch then
					holds := holds + 1;
				elseif not _onDeck and not hold.isOnDeck and hold.hatch = _hatch then
					holds := holds + 1;
				endif;
			endif;
		endforeach;
	endforeach;
	
	if _onDeck then
		drawHeight := self.yDeckPos - self.yOnDeckPos - 20;
	else
		drawHeight := self.yUnderDeckEndPos - self.yUnderDeckPos - 20;
	endif;
	if holds &lt;&gt; null then
		returnHeight := (drawHeight / holds).Integer;
	else
		returnHeight := (drawHeight).Integer;
	endif;
	return returnHeight;
epilog

end;</source>
        <Parameter name="_onDeck" type="Boolean"/>
        <Parameter name="_hatch" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMoveModeFromDisplayMode" id="32841c59-3268-4571-9492-53a143a81129">
        <source>getMoveModeFromDisplayMode(): Integer;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 15/02/2016	cnwdap1		Initial creation PAR #36766 Bulk Graphical Representation
//
vars

begin
	if self.actPlanQueMode = ShpDisplayMode_Actual then
		return REAL_MODE;
	elseif self.actPlanQueMode = ShpDisplayMode_Proposed then
		return PLANNING_MODE;
	elseif self.actPlanQueMode = ShpDisplayMode_Queued then
		return QUEUE_MODE;
	endif;
	
	return REAL_MODE;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNumHoldColumns" id="bb4b4164-06fb-4628-831a-c57ef3a1c4b3">
        <source>getNumHoldColumns() : Integer protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	hold : CM_GeneralCargoController;
	columns, lastCol : Integer;

begin
	foreach hold in self.allGCControllers do
		if hold.hatch &lt;&gt; lastCol then
			columns := columns + 1;
		endif;
		lastCol := hold.hatch;
	endforeach;
	
	// add 1 on for the ship block stack if we have one
	if (self.myVoyage.myShipBlockStack &lt;&gt; null) and self.myVoyagePlanningForm.includeShipBlockStack then	// 20/7/16 cnwmp6 TFS 1601
		columns := columns + 1;
	endif;
	
	return columns;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSideDrawingMargin" id="abceab88-3414-4c84-b4c4-103b0d99d8bc">
        <source>getSideDrawingMargin() : Integer;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 04/02/2016	cnwdap1		Initial creation PAR #36766 Bulk Graphical Representation
//
vars

begin
	if self.isStarboardBerthed then
		return self.myVoyagePlanningForm.picStern.width.Integer;
	else
		return self.myVoyagePlanningForm.picBowRev.width.Integer;
	endif;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getYDrawingPositions" id="55036a2b-0dc7-433f-ac96-70aee184a050">
        <source>getYDrawingPositions(	_textHeight : Integer; 
						_topMargin, 
						_hatchPos,
						_onDeckPos, 
						_underDeckEndPos, 
						_underDeckPos : Integer output	) protected;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
// 16/03/2016	cnwdap1		PAR #37640 Increase top margin to allow for 2 lines of hold weight
//
/*
The drawing positions are:

           portPosOD                                starboardPosOD
yOnDeckPos     +------------------------------------------+
               |                                          |
               |               on deck holds              |
               |                                          |
               +------------------------------------------+

yDeckPos	   |-------------- hatch line ------------------|

          portPosUD                                starboardPosUD
yUnderDeckPos  +------------------------------------------+
               +-+                                      +-+
                 +-+          under deck holds        +-+
                   +-+                              +-+
yUnderDeckEndPos     +------------------------------+

*/
vars
	theTopMargin	: Integer;
	theScaleFactor	: Real;
	theHoldHeight,
	theHoldWidth,
	thePrintStyle	: Integer;

begin
	theScaleFactor 	:= self.scaleFactor;
	//theHoldHeight	:= (self.holdHeight / 2).Integer;
	theHoldWidth	:= self.holdWidth - (self.SideMargin * 2);
	thePrintStyle 	:= self.printOutputStyle;

	if self.amPrinting then
		if thePrintStyle = PrintOutput_Small then
			theTopMargin := 2; // no bay id and no cell ids PAR 9034 chanegd from 0 to 2
		else
			theTopMargin := 15; // no bay id but has cell ids
		endif;
	elseif theScaleFactor = ScaleFactor_1 then	
		theTopMargin := 25;
	else
		theTopMargin := self.TopMargin;
	endif;

	//_onDeckPos := theTopMargin;						// PAR #37640
	_onDeckPos := theTopMargin + 12;					// PAR #37640
	
	if theScaleFactor = ScaleFactor_1 or thePrintStyle = PrintOutput_Small then
		// at this scale we don't draw the pile weights or cell labels
		_hatchPos	:= self.holdDrawHeight - (theTopMargin + 20);
		_underDeckPos := _hatchPos + 15;
	elseif thePrintStyle = PrintOutput_Medium then
		_hatchPos	:= theTopMargin + theHoldHeight + 5;
		_underDeckPos := _hatchPos + 25;
	else
		//_hatchPos := self.holdDrawHeight - (theTopMargin + _textHeight + 20);
		_hatchPos := (self.holdDrawHeight / 2).Integer;
		_underDeckPos := _hatchPos + _textHeight + 15;
	endif;
	
	_underDeckEndPos := self.holdDrawHeight - _textHeight;
	if (_underDeckEndPos - _underDeckPos) mod 2 = 1 then
		_underDeckEndPos := _underDeckEndPos - 1;
	endif;
	if (_hatchPos - _onDeckPos) mod 2 = 1 then
		_hatchPos := _hatchPos - 1;
	endif;
	
	/*if thePrintStyle = PrintOutput_Small then
		// at this scale we don't draw the pile weights or cell labels
		_holdHeight	:= _underDeckEndPos + SHP_BulkDrawingFrame.HeadingGraphicHeight + 5;
	elseif thePrintStyle = PrintOutput_Medium then
		_holdHeight	:= _underDeckEndPos + _textHeight + SHP_BulkDrawingFrame.HeadingGraphicHeight + 5;
	elseif theScaleFactor = ScaleFactor_1 then
		// at this scale we don't draw the pile weights
		_holdHeight	:= _underDeckEndPos + SHP_BulkDrawingFrame.HeadingGraphicHeight + 20;
	else
		_holdHeight	:= _underDeckEndPos + _textHeight + SHP_BulkDrawingFrame.HeadingGraphicHeight + 20;
	endif;	*/
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_textHeight" type="Integer"/>
        <Parameter name="_topMargin" type="Integer" usage="output"/>
        <Parameter name="_hatchPos" type="Integer" usage="output"/>
        <Parameter name="_onDeckPos" type="Integer" usage="output"/>
        <Parameter name="_underDeckEndPos" type="Integer" usage="output"/>
        <Parameter name="_underDeckPos" type="Integer" usage="output"/>
    </JadeMethod>
