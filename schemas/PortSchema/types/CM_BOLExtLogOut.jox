    <JadeMethod name="setAverageSED" id="9be5b807-e975-467c-8fc6-f7f2b87278a1">
        <updating/>
        <source>setAverageSED() updating;
//--------------------------------------------------------------
//Created: 30 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	seds,
	lens		: DecimalArray;
	items		: IntegerArray;
	tmpTISet	: CM_TISet;
	log			: CM_Log;
	ti			: CM_TrackedItem;
	prodCode	: String;
begin

	if self.mySOHLocation &lt;&gt; null then
		self.averageSED := self.mySOHLocation.myExtension.CM_SOHLocationExtLog.averageSED;
		if self.averageSED = 0 then
			self.averageSED := NULL_UNSCALED_LOG_SED;
		endif;
		return;
	endif;
	
	tmpTISet := self.myBOL.allTrackedItems;
	if tmpTISet.isEmpty then
		//PAR 17929  inorder to accept 'N' for No Number
		self.averageSED := NULL_UNSCALED_LOG_SED;	// PAR 17929
		return;
	endif;
	
	create lens transient;
	create seds transient;
	create items transient;
	
	prodCode := self.getProductCode();

	foreach ti in tmpTISet where ti.productCode = prodCode and (not ti.CM_Log.isUnscaled) do
		if ti.isKindOf(CM_LogNoNumber) then
			continue;
		endif;
		log := ti.CM_Log;
		lens.add(log.length);
		seds.add(log.sedMean);
		items.add(1);
	endforeach;

	self.averageSED := global.calcAverageSEDMeanMixed(lens, seds, items);

	if self.averageSED = 0 then
		self.averageSED := NULL_UNSCALED_LOG_SED;
	endif;
			
epilog
	delete lens;
	delete seds;
	delete items;
end;</source>
    </JadeMethod>
    <JadeMethod name="setFromProxy" id="f10715d3-b7e8-446a-98c7-fbac0a37171c">
        <updating/>
        <source>setFromProxy(_proxyBOLOut : CM_BOLExtLogOut) updating, protected;
//--------------------------------------------------------------
//Created: 13 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	stevedore : CM_Stevedore;
	bolOut : CM_BOLOut;
begin

	inheritMethod(_proxyBOLOut);
	self.hatch 				:= _proxyBOLOut.hatch;
	self.loadDateTime		:= _proxyBOLOut.loadDateTime;
	self.myLogLot 			:= _proxyBOLOut.myLogLot;
	self.place 				:= _proxyBOLOut.place;
	self.reqdVolume			:= _proxyBOLOut.reqdVolume;	
	self.unitOfMeasure 		:= _proxyBOLOut.unitOfMeasure;
	
	self.logGradeCode 		:= _proxyBOLOut.logGradeCode;
	self.logSpeciesCode 	:= _proxyBOLOut.logSpeciesCode;
	self.logTreatmentCode 	:= _proxyBOLOut.logTreatmentCode;
	self.logTypeCode 		:= _proxyBOLOut.logTypeCode;
	self.lengthCode 		:= _proxyBOLOut.lengthCode;
	
	self.numberOfNoNumbers	:= _proxyBOLOut.numberOfNoNumbers;	
	self.averageSED			:= _proxyBOLOut.averageSED;
	self.mySOHLocation		:= _proxyBOLOut.mySOHLocation;
	
//	self.myLogVoyageNotLoaded := _proxyBOLOut.myLogVoyageNotLoaded;
	self.myLogVoyageStructNotLoaded := _proxyBOLOut.myLogVoyageStructNotLoaded;
end;</source>
        <access>protected</access>
        <Parameter name="_proxyBOLOut" type="CM_BOLExtLogOut"/>
    </JadeMethod>
    <JadeMethod name="setIsFullyLoaded" id="fa85da77-c8ff-43b9-bc59-3fed6587980e">
        <updating/>
        <source>setIsFullyLoaded(_value : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     20 June 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if _value then
		if (not self.isInError) then
			self.isFullyLoaded := _value;
		endif;
	else
		self.isFullyLoaded := _value;
	endif;
	
	if _value then
		self.setMyLogVoyageIfInError();
	endif;

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setLogsToLoadOut" id="511ae070-1e26-48c6-8638-287308bc4534">
        <updating/>
        <source>setLogsToLoadOut(_tiToLoadOutSet : CM_TISet input; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 19 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	ti 				: CM_TrackedItem;
	tiDict			: CM_TISet;
	bol 			: CM_BOLOut;
//	loadError 		: CM_LogLoadError;
	toLocn 			: CM_LocationsController;
	transMode		: Integer;	
	rtValue,
	firstTime 		: Boolean;
	theLogVoyage	: CM_Voyage;
	currentLocn		: CM_LocationsController;	
	logVoyStructure	: CM_LogVoyageStructure;
	
begin

	bol 			:= self.myBOL.CM_BOLOut;
	toLocn 			:= bol.myPlannedLocation;
	theLogVoyage 	:= bol.myVoyage.CM_Voyage;
	tiDict 			:= bol.allTrackedItems;
	transMode		:= self.myBOL.transportMode;
	logVoyStructure	:= self.myBOL.CM_BOLOut.myVoyage.myLogVoyageStructure;	//PAR 21916 Dec 2009
	
	firstTime 		:= true;
	
	foreach ti in tiDict do
	
		exclusiveLock(ti);
		//if ti.getPrimaryLocation(REAL_MODE) = toLocn then	//Already loaded
		// as ti may have already have been moved to another location on the ship
		if ti.site = TI_SITE_ONSHIP then
			continue;
		endif;
		
		if ti.CM_Log.getLoadOutErrors(false, false) then
			// there are no errors so ok to load out
			ti.changeVoyage(theLogVoyage, _passport); 
			_tiToLoadOutSet.add(ti);
			
			// put the location into lcSet	PAR 21916 Dec 2009
			currentLocn 	:= ti.getPrimaryLocation(REAL_MODE);
			if currentLocn &lt;&gt; null and (not logVoyStructure.allLoadedLogLocations.includes(currentLocn.CM_LogController)) then
				logVoyStructure.allLoadedLogLocations.add(currentLocn.CM_LogController);
			endif;
			
		elseif firstTime then
			if transMode = TI_TRANSMODE_SHIP then
//				if self.myBOL.CM_BOLOut.myVoyage.isKindOf(CM_LogVoyage) then
				if self.myBOL.CM_BOLOut.myVoyage.myLogVoyageStructure &lt;&gt; null then 
//					self.myLogVoyageIfInError := self.myBOL.CM_BOLOut.myVoyage.CM_LogVoyage;
					self.myLogVoyageStructIfInError := logVoyStructure;
				endif;
			elseif transMode = TI_TRANSMODE_ROAD then
				//Work in progress
			elseif transMode = TI_TRANSMODE_RAIL then
				//Not implemented yet
			endif;
			firstTime := false;
			
		endif;
		
	endforeach;
	
//	self.myLogVoyageNotLoaded := null;
	self.myLogVoyageStructNotLoaded := null;
	
epilog


end;</source>
        <Parameter name="_tiToLoadOutSet" type="CM_TISet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyLogVoyageIfInError" id="fd7a769f-852c-4cd4-955f-a70596996962">
        <updating/>
        <source>setMyLogVoyageIfInError() updating;
//--------------------------------------------------------------
//Created: August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	bolOut : CM_BOLOut;
begin

	bolOut := self.myBOL.CM_BOLOut;
	if bolOut.transportMode &lt;&gt; TI_TRANSMODE_SHIP then
		return;
	endif;
	if self.allLogLoadErrors.isEmpty and self.isFullyLoaded then
//		self.myLogVoyageIfInError := null;
		self.myLogVoyageStructIfInError:= null;
//	elseif bolOut.myVoyage &lt;&gt; null and bolOut.myVoyage.isKindOf(CM_LogVoyage) then
	elseif bolOut.myVoyage &lt;&gt; null and bolOut.myVoyage.myLogVoyageStructure &lt;&gt; null then
//		self.myLogVoyageIfInError := bolOut.myVoyage.CM_LogVoyage;
		self.myLogVoyageStructIfInError := bolOut.myVoyage.myLogVoyageStructure ;

	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setPartiallyLoaded" id="5fbc1826-e5c0-4b99-bc54-a2cbca5d3366">
        <updating/>
        <source>setPartiallyLoaded()updating;
//--------------------------------------------------------------
//Created: 11 September 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpVoyage : CM_Voyage;
begin
	if self.isInError then
		self.isPartiallyLoaded := true;
	else
		self.isPartiallyLoaded := false;
	endif;

	//Always becomes null even if no logs loaded
//	self.myLogVoyageNotLoaded := null;
	self.myLogVoyageStructNotLoaded := null;
	
	self.causeTerminalEvent(LogVoyageOps_Update_Event);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setPxyFromCMIF_BOL" id="c0f4bece-e8d1-460f-96e9-769a2ecd68eb">
        <updating/>
        <source>setPxyFromCMIF_BOL(_bolOut : CMIF_BOLOut) updating;
//--------------------------------------------------------------
//Created: 13 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	
begin
	self.averageSED			:= _bolOut.averageSED;
	self.hatch 				:= _bolOut.hatch;
	self.myLogLot 			:= _bolOut.myLogLot;
	self.place 				:= _bolOut.place;
	self.unitOfMeasure 		:= _bolOut.unitOfMeasure;
	self.logGradeCode 		:= _bolOut.logGradeCode;
	self.logSpeciesCode 	:= _bolOut.logSpeciesCode;
	self.logTreatmentCode 	:= _bolOut.logTreatmentCode;
	self.logTypeCode 		:= _bolOut.logTypeCode;
	self.lengthCode 		:= _bolOut.length;
	if self.lengthCode = null then
		self.lengthCode 		:= _bolOut.lengthRandom;		
	endif;
	self.loadDateTime		:= _bolOut.loadStartDT;
	self.numberOfNoNumbers	:= _bolOut.numberOfNoNumbers;
	self.mySOHLocation		:= _bolOut.mySOHLocation;
	self.reqdVolume			:= _bolOut.reqdAmount;
	
	if _bolOut.myVoyage.myLogVoyageStructure &lt;&gt; null then 
//		self.myLogVoyageNotLoaded := _bolOut.myVoyage.CM_LogVoyage;
		self.myLogVoyageStructNotLoaded := _bolOut.myVoyage.myLogVoyageStructure;
	endif;
	
	
end;</source>
        <Parameter name="_bolOut" type="CMIF_BOLOut"/>
    </JadeMethod>
    <JadeMethod name="setTIReleaseFromID" id="ce4349c5-f6b0-47a0-aa4a-10e7ecb356dc">
        <updating/>
        <source>setTIReleaseFromID(_tiId : String; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: June 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	voy				: CM_Voyage;
	bolOut 			: CM_BOLOut;
	tmpTI 			: CM_TrackedItem;
	terminal 		: CM_Terminal;
begin

	bolOut 		:= self.myBOL.CM_BOLOut;
	terminal 	:= bolOut.myTerminal;
	voy 		:= bolOut.myVoyage;
	
	tmpTI := terminal.lookupTrackedItem(_tiId, TI_CargoType_Log, TI_STATE_NORMAL, null, false);
		
	if tmpTI &lt;&gt; null then
		if tmpTI.myReleaseBOL = null then
				//epr TFS 5282 6/10/17 - logging
			if (bolOut &lt;&gt; null) then
				app.writeLog(method.qualifiedName &amp; " setting release BOL for log" &amp; tmpTI.id,  LogINFO);	
			endif;
			tmpTI.setMyReleaseBOL(bolOut);
		else // Don't set the myLog reference for this error
			self.addLogLoadError(tmpTI.id, null, 'Already on docket ' &amp; tmpTI.myReleaseBOL.number, ERR_DUPLICATE_CHILD);
		endif;
	else //Road and Rail releases dont have a voyage.
		if voy &lt;&gt; null then
			tmpTI := voy.lookupTrackedItem(_tiId, TI_CargoType_Log, false);
		endif;
		if tmpTI = null then
			// Check any non archived voyages as well
	   		tmpTI := terminal.lookupOnShipTrackedItem(_tiId, TI_CargoType_Log);					
		endif;
		
		if tmpTI &lt;&gt; null then
			// Don't set the myLog reference for this error
			self.addLogLoadError(_tiId, null, 'Already loaded onto vessel ' &amp; tmpTI.myVoyage.vesselName, ERR_TI_ONSHIP);
		else // Don't set the myLog reference for this error
			self.addLogLoadError(_tiId, null, 'Not found on site', LogNotFound);
		endif;
	endif;	

end;</source>
        <Parameter name="_tiId" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTIsFromCMIF_BOL" id="c85f5f09-88a1-4276-aec6-a5ac380c6daa">
        <updating/>
        <source>setTIsFromCMIF_BOL(_intFaceBOL: CMIF_BOLOut; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 27 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	self.setTIsFromIDArray(_intFaceBOL.allLogIds, _passport);
	if (not _passport.noErrors) then
		return;
	endif;		
	self.setTIsFromEDITIs(_intFaceBOL.allEDILogsById, _passport);
	if (not _passport.noErrors) then
		return;
	endif;	
	self.setMyLogVoyageIfInError();
	if (not _passport.noErrors) then
		return;
	endif;		
	//self.setJasVolume(_passport.myTerminal);
	self.setJasVolume(_intFaceBOL.myTerminal);			// #25482 20/10/2010
	
end;</source>
        <Parameter name="_intFaceBOL" type="CMIF_BOLOut"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTIsFromEDITIs" id="90c9ffb9-aa86-4b2f-b010-34bd05fc0fc6">
        <updating/>
        <source>setTIsFromEDITIs(_ediLogs : CM_EDILogByIdDict; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 27 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpID			: String;
	ediLog 			: CM_EDIBOLOutLogTI;
	tmpEDILogDict 	: CM_EDILogByIdDict;
begin

	if _ediLogs.isEmpty then
		return;
	endif;
	
	create tmpEDILogDict transient;

	foreach ediLog in _ediLogs do
		tmpID := ediLog.id.toUpper;
		if tmpID = 'N' or tmpID[1:2] = 'N-' then
			tmpEDILogDict.add(ediLog);
			continue;
		endif;
	
		self.setTIReleaseFromID(tmpID, _passport);
	endforeach;

	self.addNoNumLogsByEDILogsNN(tmpEDILogDict, _passport);

epilog
	delete tmpEDILogDict;
end;</source>
        <Parameter name="_ediLogs" type="CM_EDILogByIdDict"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTIsFromIDArray" id="ce0197ba-23fe-4ea5-8940-5a385c65b2ca">
        <updating/>
        <source>setTIsFromIDArray(_idArray: StringArray; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 22 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	id : String;
begin

	foreach id in _idArray do
	
		if id.toUpper = 'N' then
			self.numberOfNoNumbers := self.numberOfNoNumbers + 1;
			continue;
		endif;
		
		self.setTIReleaseFromID(id, _passport);
	endforeach;
	
	//ID array may have some N Number to create as well
	self.addNoNumberLogsByNumOfNN(self.numberOfNoNumbers, _passport);
	
end;</source>
        <Parameter name="_idArray" type="StringArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateFromCM_BOLOutHeader" id="28eeccde-1d79-4c65-b9fa-2a8f0241331a">
        <updating/>
        <source>updateFromCM_BOLOutHeader(_bolOutHeader: CM_BOLOutHeader; _passport : CM_Passport input): Boolean updating;
//--------------------------------------------------------------
//Created: 24 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	
	if (not inheritMethod(_bolOutHeader, _passport)) then
		return false;
	endif;

	self.setTIsFromIDArray(_bolOutHeader.allTrackedItemIDs, _passport);
	//self.setJasVolume(_passport.myTerminal);
	self.setJasVolume(_bolOutHeader.myTerminal);			// #25482 20/10/2010

epilog
	return _passport.noErrors();
end;</source>
        <Parameter name="_bolOutHeader" type="CM_BOLOutHeader"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="5158805c-af86-4931-b249-7eb0f97c3706">
        <source>validateForCreate(pTiUpdCntrl: CMIF_TIUpdateController; _passport : CM_Passport input);
//--------------------------------------------------------------
//Created: 14 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	bolOut	: CM_BOLOut;
	tmpBol	: CM_BOL;
	opTerm	: CM_OperatorTerminal;

begin
	inheritMethod(pTiUpdCntrl, _passport);
	
	if _passport.noErrors then
		bolOut := self.myBOL.CM_BOLOut;
		opTerm := bolOut.myOperator.getOperatorTerminal(bolOut.myTerminal, false);

		if bolOut.transportMode = TI_TRANSMODE_SHIP then
			tmpBol := bolOut.myStevedore.allBOLOutByNumberVoyage[bolOut.number, bolOut.myVoyage];

		elseif bolOut.transportMode = TI_TRANSMODE_ROAD then
			if opTerm &lt;&gt; null then
				tmpBol := opTerm.allBOLByTypeNumber[bolOut.bolType, bolOut.number, bolOut.dateTime];	
				if tmpBol &lt;&gt; null and tmpBol.isKindOf(CM_BOLOut) and
				   tmpBol.CM_BOLOut.myTerminalIfUnmatched &lt;&gt; null then	
					tmpBol := null;
				endif;
			endif;

		elseif bolOut.transportMode = TI_TRANSMODE_RAIL then
			if opTerm &lt;&gt; null then
				tmpBol := opTerm.allBOLByTypeNumber[bolOut.bolType, bolOut.number, bolOut.dateTime];		
			endif;
		endif;
		if tmpBol &lt;&gt; null then
			app.raiseCMException2(ERR_Duplicate_BOL, 'Log Docket ', bolOut.number,
								  ETRow_BolNumber, pTiUpdCntrl.myUserObject);
		endif;		
	endif;
end;</source>
        <Parameter name="pTiUpdCntrl" type="CMIF_TIUpdateController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="b837018b-c90b-48a5-aa7e-9c4c83e991b9">
        <source>validateForDelete();
//--------------------------------------------------------------
//Created: 28 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	ti : CM_TrackedItem;
	strCode : String;
begin
	if self.isPartiallyLoaded then
//		app.raiseCMException2(BOLExtLogOutPartiallyLoaded, self.myBOL.number, self.myLogVoyageIfInError.code, null, null);		
		if self.myLogVoyageStructIfInError &lt;&gt; null then 
			strCode :=  self.myLogVoyageStructIfInError.myVoyage.code;
		endif;
		app.raiseCMException2(BOLExtLogOutPartiallyLoaded, self.myBOL.number, strCode, null, null);		

	endif;
	foreach ti in self.myBOL.allTrackedItems do
		if ti.site = TI_SITE_ONSHIP then
			app.raiseCMException2(StockOrderLoadedToShip, 'Docket ' &amp; self.myBOL.number.String, 'Ship', null, null);
			break;
		endif;
	endforeach;	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateMe" id="fdaf39d1-8c09-4cf0-ac15-b9d8bdea6dda">
        <source>validateMe(pControl: CMIF_TIUpdateController; _passport : CM_Passport input) protected;
//--------------------------------------------------------------
//Created: 14 June 2002 By: cnwgd1
//--------------------------------------------------------------
// 15/12/2014  cnwdb2	PAR 35364

vars

begin

	inheritMethod(pControl, _passport);
		
/*
	if self.logGradeCode = null then
		app.raiseCMException1(REQUIRED_FIELD, 'Log Grade', ETRow_LogGradeCode, pControl.myUserObject);
	endif;
	
	if self.logSpeciesCode = null then
		app.raiseCMException1(REQUIRED_FIELD, 'Log Species', ETRow_LogSpeciesCode, pControl.myUserObject);
	endif;

	self.validateTypeTreatment(pControl);

	if self.lengthCode = null then
		app.raiseCMException1(REQUIRED_FIELD, 'Length', ETRow_LogLengthCode, pControl.myUserObject);
	endif;
*/
	
	if self.myBOL.transportMode = TI_TRANSMODE_SHIP then			
		if self.hatch = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Hatch', null, null);	
			app.raiseCMException(Input_required_field_hatch, null, null);	 // cnwdb2	PAR 35364


		endif;
		if self.place = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Place', null, null);	
			app.raiseCMException(Input_required_field_place, null, null);	// cnwdb2	PAR 35364


		endif;	
		if self.unitOfMeasure = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Unit of Measure', null, null);	
			app.raiseCMException(Input_required_field_UntOfMeas, null, null);	// cnwdb2	PAR 35364

		endif;		
		
		if self.myLogLot = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Lot No.', null, null);
			app.raiseCMException(Input_required_field_lotNo, null, null);// cnwdb2	PAR 35364


		else
			self.myLogLot.validateAmount(self);
		endif;
		if self.numberOfNoNumbers &gt; 0 then
			if self.mySOHLocation = null then
			//	app.raiseCMException1(REQUIRED_FIELD, 'SOH Location', null, pControl.myUserObject);
				app.raiseCMException(Input_required_field_SOHLoc, null, pControl.myUserObject);
				
			endif;
		endif;
		if self.myBOL.myPlannedLocation = null then
//			app.raiseCMException1(REQUIRED_FIELD, 'Planned Location', null, null);	
			app.raiseCMException(Input_required_field_plandLoca, null, null);	// cnwdb2	PAR 35364
		endif;
	elseif self.myBOL.transportMode = TI_TRANSMODE_ROAD then
	
	elseif self.myBOL.transportMode = TI_TRANSMODE_RAIL then	
	
	endif;	
/*	
	if self.unitOfMeasure = BOL_UOM_WEIGHT then
		if self.myBOL.weightNet &lt;&gt; self.myBOL.getTotalTIWeight() then
			app.raiseCMWarning(LogNotEnoughStock, null, null, null);		
		endif;
	elseif self.unitOfMeasure = BOL_UOM_VOLUME then
		if self.reqdVolume &lt;&gt; self.myBOL.getTotalTIVolume() then
			app.raiseCMWarning(LogNotEnoughStock, null, null, null);		
		endif;
	elseif self.myBOL.allTrackedItems.size &lt;&gt; self.myBOL.numItems then
		app.raiseCMWarning(LogNotEnoughStock, null, null, null);		
	endif; 
*/
end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateNumTIs" id="ebe705aa-b473-40b2-a68d-8c7f697fe611">
        <source>validateNumTIs();
//--------------------------------------------------------------
//Created: 29 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	bol : CM_BOL;
begin
	inheritMethod();
	bol := self.myBOL;
	if bol.allTrackedItems.isEmpty and (not self.isInError) then
		app.raiseCMException1(BOLOutMissingTI, bol.number, null, null);
	endif;

end;</source>
    </JadeMethod>
</Class>
