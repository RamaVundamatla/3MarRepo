    <JadeMethod name="doSave" id="fd12bd23-ebec-4e39-b484-f1222f2383c5">
        <updating/>
        <source>doSave(): Boolean updating;
//
//22 May 2013	cnwrs1	Par 31483 Ftp connect not always connecting
//
//11 Jun 2014	cnwrs1	Par 34062 add useProxy to FTP Get/Put
//20 Aug 2015	cnwrs1	Par 36795 enable a file to be read and deleted in one session
//24 Aug 2015	cnwrs1	Par 36815 enable FTP get to continue after a failed file delete by saving off the fileNames
vars
	errObj : CM_Error;
	ignoreWarnings : Boolean;
	rtnValue : Boolean;
	proxyFTPEntity : CM_FTPEntity;
	lDestinationDirectory, lId, lPassword, lServerName, lSourceDirectory, lUserId : String;
	lIsPassive : Boolean;
	lUseProxy : Boolean;
	lSingleFileCopy : Boolean;
	lSaveUndeletedFilesList : Boolean;
	lMode, lServerGMTBias, lServerType : Integer;
	theForm	: SOP_TableMaintForm;
	tbl : CM_EntryTable;
	msg : String;
begin
	theForm := self.myForm; 
	tbl := theForm.tblInput1;
//	lFTPEntity := theForm.tblInput1.getValueByName(ETDef_FtpEntity).String.trimWhiteSpace;
	lId := theForm.tblInput1.getValueByName(ETRow_Id).String;
 	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_FTPEntity transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;

	proxyFTPEntity := theForm.myProxyObject.CM_FTPEntity;
	tbl.setObjectFromTable(proxyFTPEntity, null, false);
/*	//25 Aug 2021	NDL	TFS 51632
	//07 Jul 2017	NDL	TFS 5235
	if theForm.enteredPassword.length &gt; 30 then
		msg := app.getErrorString2( ERR_STRING_TO_LONG, app.getErrorString(Password), '30');
		app.msgBox("FTP " &amp; msg, app.getErrorString(Error), MsgBox_OK_Only );
		return false;
	endif; */
	proxyFTPEntity.setPassword(theForm.enteredPassword);
//	proxyFTPEntity.setProxy(lDestinationDirectory, lId, lPassword, lServerName, lSourceDirectory, lUserId, lIsPassive, lMode, lServerGMTBias, lServerType);
	lUseProxy := theForm.tblInput1.getValueByName(ETRow_UseProxy).Boolean;
	proxyFTPEntity.setUseProxy(lUseProxy);
	lSingleFileCopy := theForm.tblInput1.getValueByName(ETRow_SingleFileCopy).Boolean;
	lSaveUndeletedFilesList := theForm.tblInput1.getValueByName(ETRow_SaveUndeletedFilesList).Boolean;
	proxyFTPEntity.setSingleFileCopy(lSingleFileCopy);
	proxyFTPEntity.setSaveUndeletedFilesList(lSaveUndeletedFilesList);
	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateFTPEntity(proxyFTPEntity, theForm.myCurrentObject.CM_FTPEntity, app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateFTPEntity(proxyFTPEntity, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, ' Invalid mode (' &amp; theForm.mode.String &amp; ')');
	endif;
	
	return app.myPassport.trxCompletedOK;
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getCollection" id="a179c849-da77-4a74-9928-9464b03bf316">
        <source>getCollection(): Collection;
//
// 19 Sep 2019	cnwrs1	TFS 46087 SFTP
//
vars
	ftpEntity : CM_FTPEntity;
begin
	foreach ftpEntity in app.myRoot.allFTPEntities do
		if not ftpEntity.isSFTP and
		   not self.list.includes(ftpEntity) then
			self.list.add(ftpEntity);
		endif;
	endforeach;
epilog
	return self.list;
end;
</source>
        <ReturnType type="Collection"/>
    </JadeMethod>
