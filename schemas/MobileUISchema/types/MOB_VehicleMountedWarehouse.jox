    </JadeMethod>
    <JadeMethod name="setupDirectorTable" id="65d12871-45ea-4493-a077-350f4cbe2af3">
        <source>setupDirectorTable() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2010	cnwer1	Initial creation

*/

vars

begin

	self.tblDirector.fontSize:=app.myVMAgent.getMyRTVehicleConfig.tableFontSize;
	self.tblDirector.fixedRows:=1;
	self.tblDirector.fixedColumns:=0;
	self.tblDirector.accessRow(1).backColor:=app.myVMAgent.getMyScreenMode.screenBackColour;
	app.myVMAgent.setupTableHeadings(self.tblDirector);
	
	self.tblDirector.selectMode := Table.SelectMode_None;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="50fb2f15-0901-4032-8ef9-7c1f49cd3a40">
        <updating/>
        <source>setupForm() updating, protected;
/*

Date		Who		Reason
05 August 2014	cnwer1	Initial creation PAR

*/

vars
	taskDetailsWidth : Integer;
	tmpUserWindow	: CM_UserWindow;
begin
	inheritMethod();
	
	if app.isOnDevice() then
		self.windowState := self.WindowState_Maximized;		
	endif;
	self.setVehicleMountedScreenSize();
	//app.myVMAgent.isWarehouseVMT:=true;
	app.myVMAgent.setShowingTaskList(true);
	
	tmpUserWindow := app.getUserWindow(self.name, true);
	taskDetailsWidth:= tmpUserWindow.xmlInfo.cnEcGetTagValueOfName(XMLTag_TaskDetailsWidth).Integer;
	if taskDetailsWidth &gt; 0 then
		self.dkcTaskDetails.width:=taskDetailsWidth;
	endif;
	self.dkcTaskDetails.left:=0;
	self.dkcTasks.left:=self.dkcTaskDetails.width;
	
	self.setupTaskTable(self.tblSelectTasks);

	app.myVMAgent.myMachQEntryTableSynchAgent.purgeEntries;
	app.myVMAgent.initTable(self.tblSelectTasks);
	
	self.setupTaskTable(self.tblWorkingTasks);
	
	app.myVMAgent.setupTableHeadings(self.tblWorkingTasks);
	app.myVMAgent.loadRTTaskTable(self.tblWorkingTasks,null);
	
	//self.setupDirectorTable();
	
	if self.myVMAgent.myMachine.allCurrentQueueTasks.size &gt; 0 then
		self.showWorkingTasks(true);
	else
		self.showSelectTasks();
		
	endif;
	
	self.setCaption();
		
	self.doResize();
	
	
epilog
	app.myVMAgent.startNotes();	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTaskTable" id="b9ca2891-e747-40e5-af8d-734dddd1e5e7">
        <source>setupTaskTable(_table : Table input);
/*

Date		Who		Reason
06 August 2014	cnwer1	Initial creation PAR

*/

vars

begin
	self.clearTableData(_table);
	_table.parentAspect:=Table.ParentAspect_StretchBoth;
	_table.selectMode := Table.SelectMode_None;
	_table.alignment := Table.Alignment_Center_Top;
	_table.accessSheet(1).marginRight:=5;
	_table.accessSheet(1).marginLeft:=5;
	_table.accessRow(1).backColor:=app.myVMAgent.getMyScreenMode().screenBackColour;
	_table.fontSize:=app.myVMAgent.getMyRTVehicleConfig.tableFontSize;
epilog

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showDirectorFrame" id="83e05769-ef43-4681-a592-624d20ecee92">
        <source>showDirectorFrame();
/*

Date		Who		Reason
14 August 2014	cnwer1	Initial creation PAR

*/

vars
	margin : Integer;
begin
	margin:=20;
	self.frmDirector.move(margin,margin,self.clientWidth - (margin*2),self.clientHeight - (margin*2));
	
	self.frmBody.enabled:=false;
	self.frmTaskDetails.enabled:=false;
	self.frmTop.enabled:=false;
	self.frmBottom.enabled:=false;
	self.frmTopDirector.enabled:=true;
	self.frmDirector.visible:=true;
	self.frmDirector.zOrder(1);

	self.tblDirector.height:= self.frmDirector.clientHeight - self.frmTopDirector.clientHeight - (self.btnPickupDir.clientHeight + (margin* 2));
	self.tblDirector.width:=self.frmDirector.clientWidth;
	
	self.tblDirector.rows:=1;
	self.tblDirector.tag:=null; 
	
	self.clearTableData(self.tblDirector);
	self.setupDirectorTable();
	
	self.txtSearchDir.setFocus();
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="showSelectTasks" id="41017b5a-638a-43f9-9e95-02869ac4b923">
        <updating/>
        <source>showSelectTasks() updating;
/*

Date		Who		Reason
05 August 2014	cnwer1	Initial creation PAR

*/

vars
	
begin
	self.tblSelectTasks.visible:=true;
	self.deselectVMTableRows(self.tblWorkingTasks);
	//self.dkcTasks.borderStyle:=JadeDockContainer.BorderStyle_Single;
	//self.dkcTasks.borderColorSingle:=Red;
	self.grpAccept.zOrder(1);
	self.grpAccept.visible:=self.tblSelectTasks.visible;
	self.grpWorking.visible:=self.tblWorkingTasks.visible;
	self.btnSetdownAll.visible:=false;
	self.btnPickupAll.visible:=false;
	self.tblWorkingTasks.visible:=false;
	self.dkcTaskDetails.visible:=false;
	self.tblSelectTasks.width:=self.dkcTasks.clientWidth;
	self.btnWorking.visible:=self.myVMAgent.myMachine.allCurrentQueueTasks.size &gt; 0;
	self.btnSearchMode.visible :=app.myVMAgent.getMyRTVehicleConfig.allowCargoSearch;
	
	if btnSearchMode.visible then
		self.btnSearch.left:=self.btnSearchMode.left + self.btnSearchMode.clientWidth + 5;
		self.btnSearchReset.left:=self.btnSearch.left + self.btnSearch.clientWidth + 5;
	endif;
	self.searchMode:=self.SEARCH_TASKS;
	self.setSearchModeText();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showWorkingTasks" id="ad341db3-5135-4c1c-9778-d0c80cb70ca8">
        <updating/>
        <source>showWorkingTasks(_selectFirstTask : Boolean) updating;
/*

Date		Who		Reason
05 August 2014	cnwer1	Initial creation PAR

*/

vars

begin
	self.tblSelectTasks.visible:=false;
	self.tblWorkingTasks.visible:=true;
	self.deselectVMTableRows(self.tblSelectTasks);
	self.dkcTaskDetails.visible:=true;

	self.grpAccept.visible:=self.tblSelectTasks.visible;
	self.grpWorking.visible:=self.tblWorkingTasks.visible;
	self.refreshWorkingButtons();
	
	self.btnSearchMode.visible:=false;
	self.btnSearch.left:=self.txtSearch.left + self.txtSearch.clientWidth + 5;
	self.btnSearchReset.left:=self.btnSearch.left + self.btnSearch.clientWidth + 5;
	self.searchMode:=SEARCH_TASKS;
	self.setSearchModeText();
	if _selectFirstTask and self.tblWorkingTasks.rows &gt; 1 then
		self.tblWorkingTasks.row:=2;
		self.tblWorkingTasks.click(self.tblWorkingTasks);
	endif;
	
	self.fldTaskDetails.topSheet:=self.shtTask;
epilog

end;</source>
        <Parameter name="_selectFirstTask" type="Boolean"/>
    </JadeMethod>
