    </JadeMethod>
    <JadeMethod name="loadBookingRefItem" id="5b6ebfb1-81ba-48e3-bd1a-a40d79511703">
        <updating/>
        <source>loadBookingRefItem() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 November 2008	cnwer1	Initial creation
08 September 2009	cnwjo3	LengthText was not getting correctly populated.  density not getting populated. par 20615
11 September 2009	cnwjo3	fixed some more issues, par 20644
14/01/2010			cnwmh5	PAR 22033 - change loading of commodity object
08/02/2010			cnwcs5	par 22672 - handle null product
260/04/2010			cnwmh5	PAR 23849 - Change so iso type combo is loaded based on what is set in iso group
25/03/2013			cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
13/08/2013			cnwdap1	PAR #32123 Colour picker - show colour details
12/11/13			cnwer1	par 32951 measurements not defaulting correctly from cargo type/subtype
16/09/2014			cnwdap1	PAR #33944 Restore Purchase Order and Service Order numbers
21/03/2016			cnwdap1	PAR #37606 "Not available for entry" iso types
11/02/2020          cnwma1	Bug 48514: PNL - Hazardous Flashpoint Information at Port Nelson
13/12/2022			jlika1	TFS 55590 HS Codes to Column Organizers
*/

vars
	resDetail 	: CM_ReserveDetail;
	availGrade 	: CM_MTGrade;
	product 	: CM_Product;
	commodity 	: CM_Commodity;				// 14/01/2010 cnwmh5 #22033
	strArray 	: StringArray;
	spLift 		: CM_SpecialLift;
	str 		: String;
	volumeType,								// PAR #31155
	displaceType,							// PAR #31155
	weightType	: String;					// PAR #31155
	colorVisible 	: Boolean;
	isoType 	: CM_ISOType; 				// PAR #37606
	idx 		: Integer;					// PAR #37606
	hsCode		: CM_HarmonizedSystem;
begin
	volumeType   := app.getDefaultMeasurementForType(Type_Volume).shortName;					// PAR #31155
	displaceType := app.getDefaultMeasurementForType(Type_Displacement).shortName;				// PAR #31155
	weightType   := app.getDefaultMeasurementForType(Type_Weight).shortName;					// PAR #31155
	
	// Quantity
	self.txtTotalUnits.text := self.myProxyBookingRefItem.quantity.String;
	
	if self.myProxyBookingRefItem.isKindOf(CM_BRefItemContainer) then
				
		//Iso Group
		self.cmbIsoGroup.setObject(app.myRoot.allISOTypeGroups[self.myProxyBookingRefItem.isoTypeGroup]);
				
		// ISOType
		self.cmbIsoGroup.lostFocus(self.cmbIsoGroup);		
		// 26/04/2010 cnwmh5 par23849
		self.cmbIsoType.setIndexFromObject( app.myRoot.allISOTypes[self.myProxyBookingRefItem.isoType]);
		// for bookings created with an iso type that is now not available for entry, add an entry in	// PAR #37606
		isoType := app.myRoot.allISOTypes[self.myProxyBookingRefItem.isoType];							// PAR #37606
		if isoType &lt;&gt; null and isoType.isNotAvailableForEntry then										// PAR #37606
			idx := self.cmbIsoType.addItemObject(isoType.code &amp; Tab &amp; isoType.description, isoType);	// PAR #37606
			self.cmbIsoType.listIndex := idx;															// PAR #37606
		endif;																							// PAR #37606
			
		// Temp
		if self.myProxyBookingRefItem.CM_BRefItemContainer.getTemperature() &lt;&gt;  NULL_TEMPERATURE  then
			if self.optFahr.value then																												// PAR #31155
				self.txtTemperature.text := app.temperatureConversion(true, self.myProxyBookingRefItem.CM_BRefItemContainer.getTemperature).String;	// PAR #31155
			else																																	// PAR #31155
				self.txtTemperature.text	:= self.myProxyBookingRefItem.CM_BRefItemContainer.getTemperature.String;
			endif;																																	// PAR #31155
		endif;
		
		self.chkIsClean.value := self.myProxyBookingRefItem.clean;
		
		// Humidity
		if self.myProxyBookingRefItem.CM_BRefItemContainer.getHumidity &lt;&gt; NULL_HUMIDITY then
			self.txtHumidity.text 		:= self.myProxyBookingRefItem.CM_BRefItemContainer.getHumidity.String;
		endif;
		
		// Ventilation
		if self.myProxyBookingRefItem.CM_BRefItemContainer.getVentilation &lt;&gt; NULL_VENTILATION then
			self.tblVentilation.setValues(app.convertMeasurementForDisplay(displaceType, self.myProxyBookingRefItem.CM_BRefItemContainer.getVentilation) &amp; Space &amp; displaceType);	// PAR #31155
		endif;
		
		self.chkControlAtmo.value:= self.myProxyBookingRefItem.CM_BRefItemContainer.isControlledAtmosphere;
		self.chkControlAtmo.click(self.chkControlAtmo);
		
		//Carbon Dioxide
		if self.myProxyBookingRefItem.CM_BRefItemContainer.getCarbonDioxide &lt;&gt; NULL_CARBON_DIOXIDE then
			self.txtCO2.text			:= self.myProxyBookingRefItem.CM_BRefItemContainer.getCarbonDioxide.String;
		endif;
		// Oxygen
		if self.myProxyBookingRefItem.CM_BRefItemContainer.getOxygen &lt;&gt; NULL_OXYGEN then
			self.txtO2.text 			:= self.myProxyBookingRefItem.CM_BRefItemContainer.getOxygen.String;
		endif;

		self.chkCurtainsIn.value    := self.myProxyBookingRefItem.CM_BRefItemContainer.getCurtainsIn;
		self.chkPreTripInspec.value := self.myProxyBookingRefItem.inspected;
		
		resDetail := self.myProxyBookingRefItem.myReserveDetail;
		if resDetail &lt;&gt; null then
			self.txtMaxRel.text 		:= resDetail.maxToRelease.asStringJMT;
			
				// Availability Grade
			if resDetail.isKindOf(CM_ReserveSelection) then
				if resDetail.CM_ReserveSelection.allAvailabilityGrades.size() &gt; 0 then
					availGrade := app.myRoot.allAvailableAvailabilityGrades[resDetail.CM_ReserveSelection.allAvailabilityGrades.first];
					if availGrade &lt;&gt;  null then
						self.cmbAvalGrade.listObject:=availGrade;
					endif;
				endif;	
				
				self.chkHeavy.value:=resDetail.CM_ReserveSelection.heavyRated;
			endif;
		endif;	

	endif;
		
		
	self.cmbSpecialStow.listObject := self.myProxyBookingRefItem.mySpecialStow;

	commodity := app.myRoot.allCommodities[self.myProxyBookingRefItem.commodity];
	self.cmbCommodity.setIndexFromObject (commodity);	//setObject(commodity);
	
	self.enabledDisableReeferDetails();
	
	self.txtRemarks.text 		:= self.myProxyBookingRefItem.remarks;
	
	self.tblVolume.setValues(self.myProxyBookingRefItem.getWeightDisplay);	
	if self.myProxyBookingRefItem.isBulkMulti then
		self.tblWeight.setValues(self.myProxyBookingRefItem.getWeightDisplay);
	else
		self.tblWeight.setValues(app.convertMeasurementForDisplay(weightType, self.myProxyBookingRefItem.weight) &amp; Space &amp; weightType);		// PAR #31155
	endif;
	// Max. to release
	self.cmbGeneratorType.setObject(app.myRoot.allGeneratorTypes[self.myProxyBookingRefItem.generatorType]);
	self.cmbTrailerType.setObject(app.myRoot.allTILCTypes[null, self.myProxyBookingRefItem.trailerType]);
	
	//Special Lift
	create strArray transient;
	foreach spLift in self.myProxyBookingRefItem.allSpecialLifts do
		strArray.add(spLift.code);
	endforeach;
	self.myAssistant.setListTableSpecialLift(self.lstSpecialLift, strArray);
	str := self.lstSpecialLift.getSelectedString('code');
	if str.length &gt; 30 then
		self.txtSpecialLift.text := str[1:29]&amp; '...';
	else
		self.txtSpecialLift.text := str;
	endif;

	self.lstHazards.loadHazardObjects;
	if self.isNewItem then
		//self.lstHazards.setSelectedFromObject(self.myProxyBookingRefItem.myBookingReference);  // 11.02.2020 cnwma1 #48514
		self.lstHazards.setSelectedFromObject(null);                                             // 11.02.2020 cnwma1 #48514
		//special stow isn't currently saved on the BookingRef
		self.cmbSpecialStow.listObject := self.myProxyBookingRefItem.myBookingReference.mySpecialStow;
	else
		// Hazards
		self.lstHazards.setSelectedFromObject(self.myProxyBookingRefItem);
	endif;
	self.closeLstAndDisplayTxtHazards();
	
	
	self.txtDescription.text := self.myProxyBookingRefItem.description;
	
	product := self.myProxyBookingRefItem.myProduct;	// par 22672
	
	if not app.isValidObject (product) then	// par 22672
		product := null;					// par 22672
	endif;									// par 22672
	
	self.cmbProduct.setObject(product);
										// PAR #31155
	// epr par 32951 
	self.tblCDVolume.setValues(self.getMesurementTypeValues(Type_Volume));
	self.tblCDWeight.setValues(self.getMesurementTypeValues(Type_Weight));
	self.tblCDLength.setValues(self.getMesurementTypeValues(Type_Length));
	self.tblCDWidth.setValues(self.getMesurementTypeValues(Type_Width));
	self.tblCDHeight.setValues(self.getMesurementTypeValues(Type_Height));
	self.txtCDWidthText.text  := self.getMesurementTypeValues(ETRow_MyWidthString);
	self.txtCDHeightText.text := self.getMesurementTypeValues(ETRow_MyHeightString);
	self.txtCDLengthText.text := self.getMesurementTypeValues(ETRow_MyLengthString);
	self.txtCDQuantity.text   := self.getMesurementTypeValues(ETRow_MyQuantity);
	self.tblCDDensity.setValues(self.getMesurementTypeValues(Type_Density));	// PAR #31155
	
	self.txtCDType.text 	:= self.getMesurementTypeValues(ETRow_MyType); 
	self.cmbCDType.setIndex(self.cmbCDType.findString(1,self.txtCDType.text));
	
	self.txtId.text 		:= self.myProxyBookingRefItem.id;
	self.txtMarks.text 		:= self.myProxyBookingRefItem.shippingMarks;
	self.txtMarkNumber.text := self.myProxyBookingRefItem.markNumber;

	colorVisible := self.txtColour.visible;
	self.myAssistant.setColourDetails(self.myProxyBookingRefItem.colour, self.lstColour, self.txtColour);	// PAR #32123
	self.txtColour.visible := colorVisible;
	
	self.txtPurchaseOrder.text := self.myProxyBookingRefItem.purchaseOrder;			// PAR #33944
	self.txtServiceOrder.text  := self.myProxyBookingRefItem.serviceOrder;			// PAR #33944
	
	//14 Sep 2016	NDL	TFS 2644 / 2001
	if self.myProxyBookingRefItem.myBookingRefItemActions &lt;&gt; null then
		self.txtDocStopAction.text := self.myProxyBookingRefItem.myBookingRefItemActions.getStopsList(", ",false).trimBlanks;
		self.txtDocTaskAction.text := self.myProxyBookingRefItem.myBookingRefItemActions.getTaskList(", ",false).trimBlanks;
	else
		self.txtDocStopAction.text := null;
		self.txtDocTaskAction.text := null;
	endif;
	
	if self.myProxyBookingRefItem.CM_BookingRefItem.hsCode &lt;&gt; null then
		hsCode := app.myRoot.allHSCodesActive[self.myProxyBookingRefItem.CM_BookingRefItem.hsCode];
		
		if hsCode &lt;&gt; null then
			self.cmbHsCode.listObject := hsCode;
		endif;
	endif;	
	
epilog
	delete strArray;		// PAR #18009
	
end;</source>
    </JadeMethod>
    <JadeMethod name="loadCombos" id="e6e28033-35c0-4de0-bece-77c91e07875c">
        <updating/>
        <source>loadCombos(_cargoType : CM_CargoType) updating;
//-----------------------------------------
//
// Created : by cnwaer1 26 August 2008
//-----------------------------------------
// Changed On	By			Reason
// ----------	--------	---------------------------------------------------------
// 25/03/2013	cnwdap1		PAR #31155 CCMS SFW 1321 Imperial Measurements
// 12/08/2013	cnwdap1		PAR #32123 Colour picker
// 15/03/2016	cnwdap1		PAR #37606 "Not available for entry" iso types
vars
	str : String;
	isoType : CM_ISOType;									// PAR #37606
begin
	// load Hazards List
	self.lstHazards.loadHazardObjects;
	self.myAssistant.resetHazardListTable(self.lstHazards);
	
	// load combo Ventilatio Units
	//self.myAssistant.comboBoxVentilationUnits(self.cmbVentUnits);				// PAR #31155
	//load combo Grades
	self.myAssistant.comboBoxMTGrade(self.cmbAvalGrade, null);
	
	//load special stow combo
	self.myAssistant.comboSpecialStow(self.cmbSpecialStow);
	
	//load special lift combo
	self.myAssistant.listTableSpecialLift(self.lstSpecialLift);
	
	//load commodity combo
	self.loadCommodityCombo (_cargoType);	// par 22562
	
	//isoType
	//self.cmbIsoType.listCollection(app.myRoot.allISOTypes, true, 0);						// PAR #37606
	foreach isoType in app.myRoot.allISOTypes discreteLock do								// PAR #37606
		if isoType.isNotAvailableForEntry then												// PAR #37606
			continue;																		// PAR #37606
		endif;																				// PAR #37606
		self.cmbIsoType.addItemObject(isoType.code &amp; Tab &amp; isoType.description, isoType);	// PAR #37606
	endforeach;																				// PAR #37606
	
	// Colour												// PAR #32123
	self.myAssistant.listTableColour(self.lstColour);		// PAR #32123
	
	self.loadHSCodeCombo();
	
	self.loadMatchModeCombo();								//navra1 - CR 63764/Task 64227 - 22nd May 2024
end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="loadCommodityCombo" id="0b69c5f6-5ac2-4cf7-b888-4e3011b19b26">
        <source>loadCommodityCombo(_cargoType : CM_CargoType);
//13 October 2009	cnwml2
//14/03/2017	jlgrh7 TFS #37566	C3 - Default Commodities

vars
	defaultCommo :	 CM_Commodity; 																																										//+TFS37566	
begin 
	if _cargoType &lt;&gt; null then																																															//+TFS37566	Begins
		if self.cmbProduct.myObject.CM_Product &lt;&gt;null and self.cmbProduct.myObject.CM_Product.defaultCommodityCode &lt;&gt; null then			//Looking default commodity from Cargo's Subtype
			defaultCommo := app.myRoot.allCommodities[self.cmbProduct.myObject.CM_Product.defaultCommodityCode];
		endif;
		if defaultCommo = null  and _cargoType.defaultCommodityCode &lt;&gt; null then																														//Not found then looking for commodity from Cargo Type
			if not _cargoType.allCommodities.isEmpty then
				defaultCommo := _cargoType.allCommodities[_cargoType.defaultCommodityCode ];
			else
				defaultCommo := app.myRoot.allCommodities[_cargoType.defaultCommodityCode ];
			endif;
		endif;
		self.myAssistant.comboBoxCommodityCargoType(defaultCommo, self.cmbCommodity, _cargoType);
	else
		self.cmbCommodity.clear;// par 22562
		return;					// par 22562
//		*** if they changed the cargo type since the form was opened the proxy does not get updated !!!!!!!!! ***
		self.myAssistant.comboBoxCommodityCargoType(self.cmbCommodity.listObject.CM_Commodity, self.cmbCommodity, self.myProxyBookingRefItem.myCargoType);
	endif;
epilog

end;</source>
        <Parameter name="_cargoType" type="CM_CargoType"/>
    </JadeMethod>
    <JadeMethod name="loadHSCodeCombo" id="587a66dd-9734-4dad-815f-f73f4b5bd8d9">
        <source>loadHSCodeCombo();
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 12 December 2022
TFS#		: 55590
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	hsCode : CM_HarmonizedSystem;
begin
	self.cmbHsCode.clear();
	
	self.cmbHsCode.addItem("");
	
	foreach hsCode in app.myRoot.allHSCodesActive do
			self.cmbHsCode.itemObject[self.cmbHsCode.addItem(hsCode.getDisplayString())] := hsCode;		
	endforeach;

end;</source>
    </JadeMethod>
    <JadeMethod name="loadMatchModeCombo" id="1976c2d1-5db3-4d53-8369-e3e76297afd3">
        <updating/>
        <source>loadMatchModeCombo() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2024	navra1	Initial creation for //navra1 - CR 63764/Task 64227 - 22nd May 2024

*/

vars
	userWindow : CM_UserWindowForOpen;
	mode : Integer;
begin
	self.cmbMatchMode.clear();	
	
	self.cmbMatchMode.addItemWithData(self.BASIC_MATCH_STR, 0);
	self.cmbMatchMode.addItemWithData(self.STRICT_MATCH_STR, 1);
	
	if self.myBookingItem &lt;&gt; null then
		if self.myBookingItem.matchMode = self.myBookingItem.STRICT_MATCH then
			self.cmbMatchMode.listIndex := 2;
		else
			self.cmbMatchMode.listIndex := 1;			
		endif;
	else
		if self.savedMatchMode = null or self.savedMatchMode = 1 then	//nothing was saved or it was saved as BASIC_MODE
			self.cmbMatchMode.listIndex := 1;
		elseif self.savedMatchMode = 2 then
			self.cmbMatchMode.listIndex := 2;
		endif;
	endif;
	
	if self.cmbMatchMode.listIndex = 2 then
		self.txtMatchModeDetails.text := app.getErrorString(Strict_match_desc);		
	else		
		self.txtMatchModeDetails.text := app.getErrorString(Basic_match_desc);
	endif;
	
epilog

end;</source>
    </JadeMethod>
