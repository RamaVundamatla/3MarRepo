    <JadeMethod name="addObjectsToTable" id="0925588f-01ef-42ff-9c24-76f2597caff1">
        <updating/>
        <source>addObjectsToTable(_numItems: Integer io) updating;
// ---------------------------------------------------------------------------
// Created:     10 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 05/10/15 	cnwer1 PAR 37018 reafactoring so can be used in web service
vars
	terminal : CM_Terminal;
	passport : CM_Passport;
	cmifLogRowQuery : CMIF_LogRowQuery;
	taId,
	rowId,
	logGrade,
	logSpecies,
	logTreat,
	logType,
	operator,
	isCheckScaled,
	isDocketChecked,
	isFumigated,
	isInspected,
	lengthRawData : String;
	statusString : String;
	startDateFrom,
	startDateTo : Date;
	logLC : CM_LocationsController;
	breakOut : Boolean;
	errMsg : String;
	error : CM_Error;
begin
	terminal := self.myTerminal;
	if terminal = null then
		return;
	endif;

	lengthRawData := self.tblSearch.getValueByNameIfVisible(ETRow_FiltLength).String;
	isCheckScaled := self.tblSearch.getValueByNameIfVisible(ETRow_FiltCheckScaled).String;
	isDocketChecked:= self.tblSearch.getValueByNameIfVisible(ETRow_FiltDocketChecked).String;
	isFumigated:= self.tblSearch.getValueByNameIfVisible(ETRow_FiltFumigated).String;
	isInspected:= self.tblSearch.getValueByNameIfVisible(ETRow_FiltInspected).String;
	logGrade := self.tblSearch.getValueByNameIfVisible(ETRow_FiltGrade).String.toUpper[1:30];
	logSpecies := self.tblSearch.getValueByNameIfVisible(ETRow_FiltSpecies).String.toUpper[1:30];
	logTreat := self.tblSearch.getValueByNameIfVisible(ETRow_FiltTreatment).String.toUpper[1:30];
	logType := self.tblSearch.getValueByNameIfVisible(ETRow_FiltType).String.toUpper[1:30];
	rowId := self.tblSearch.getValueByNameIfVisible(ETRow_FiltRowId).String.toUpper[1:30];	
	operator := self.tblSearch.getValueByNameIfVisible(ETRow_FiltSupplier).String;
	taId:= self.tblSearch.getValueByNameIfVisible(ETRow_Block).String;
	statusString:= self.tblSearch.getValueByNameIfVisible(ETRow_FiltStatus).String;
	
	startDateFrom:=null;
	startDateTo :=null;
	if self.tblSearch.isRowVisible(ETRow_StatusDateFrom) then
		startDateFrom :=	self.tblSearch.getValueAsDate(ETRow_StatusDateFrom);
	endif;
	if self.tblSearch.isRowVisible(ETRow_StatusDateTo) then
		startDateTo :=	self.tblSearch.getValueAsDate(ETRow_StatusDateTo);
	endif;
	
	create cmifLogRowQuery transient;
	
	on CM_Exception do app.validationExHandler(exception,app.myPassport);
	app.setContinueCMExceptions(true);
	app.myPassport.clearErrorsWarnings;
	cmifLogRowQuery.setDetails(terminal.code,
								taId,
								rowId,
								null,
								operator,
								statusString,isDocketChecked,isCheckScaled,isInspected,isFumigated,
								null,null,
								logSpecies,
								logGrade,
								logType,
								logTreat,
								lengthRawData,
								startDateFrom,startDateTo,
								app.myPassport);
								
	if app.myPassport.hasErrors then
		errMsg:= "Length value used in filtering must be numeric"  &amp; CrLf
						&amp; "and maybe preceded by one of the following operators:" &amp; CrLf
						&amp; " =,  &lt;,  &gt;,  &gt;=,  &lt;=  or  &lt;&gt;." &amp; CrLf
						&amp; "No operator implies equal to." &amp; CrLf
						&amp; "Examples:" &amp; CrLf
						&amp; "    &lt;=5.0 (less than or equal to 5)" &amp; CrLf
						&amp; "    &gt;5      (greater than 5)" &amp; CrLf
						&amp; "    =6.4  (equals 6.4)" &amp; CrLf
						&amp; "    &lt;&gt;4   (not equal to 4)";
		error:=app.myPassport.allErrors.first;	
		app.msgBox(errMsg, app.getErrorString(Error) &amp; " [" &amp; error.getDetailsAsStringNoCode &amp; "]",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon );	
		return;
	endif;
															
	cmifLogRowQuery.doQuery(app.myPassport);
	
	foreach logLC in cmifLogRowQuery.allFoundLCs discreteLock do
		if (not logLC.isKindOf(CM_LogController)) then
			continue;
		endif;
		
		self.addObjectToTable(logLC,_numItems,breakOut);
		if breakOut then
			break;
		endif;
	endforeach;
	
epilog
	delete cmifLogRowQuery;
end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="cb191e50-70ac-44f6-a444-7844111f40ec">
        <source>addToolbarControls() protected;
// ---------------------------------------------------------------------------
// Created:     25 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	toolbar	: CMUI_Toolbar;
begin
	inheritMethod();
	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnArchive, CMUI_Toolbar.Control_Alignment_Left);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="allowArchive" id="c7e757c5-3e14-4379-ab9a-afe90979b29e">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>allowArchive(set: Boolean; _value: Boolean io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:      20 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------

begin
	if set then
		if _value and self.mode = Mode_View then
			btnArchive.visible := true;
		else
			btnArchive.visible := false;
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
