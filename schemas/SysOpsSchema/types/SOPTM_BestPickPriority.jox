    <JadeMethod name="getCriteriaAllCMIF" id="7b6afe9f-063c-4288-9486-8c522abff437">
        <source>getCriteriaAllCMIF(_cmifArray : CMIF_Array input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2025	jlier1	Initial creation  JIRA-35632

*/

vars
	obj				: Object;
	cmifCriteria 	: CMIF_YACriteriaPriority;
	cmifObject 		: CMIF_Object;
	criteria 		: CM_YABestPickCriteria;
	invalidObj		: Boolean;

begin
	//  Create transient maintenance objects for all existing criteria and mark for delete action
	obj := self.myForm.myCurrentObject;
	on Exception do app.handleDeletedObject(exception, obj, invalidObj);
	
	if obj &lt;&gt; null then
		foreach criteria in obj.CM_BestPickPriority.allCriteria do
			if invalidObj then
				break;
			endif;
			cmifCriteria := criteria.getTransient();
			cmifCriteria.setFlag(false, false, true);	
			_cmifArray.add(cmifCriteria);
		endforeach;
	endif;

	//  For each criteria in selected list - update/add transient maintenance object
	foreach cmifObject in self.allCriteria do
		criteria := cmifObject.CMIF_YACriteriaPriority.myProxy.CM_YABestPickCriteria;
		self.getCriteriaSingleCMIF( _cmifArray, criteria.myYACriteriaType, criteria.myYAData.getDataValue() );
	endforeach;
	

epilog

end;</source>
        <Parameter name="_cmifArray" type="CMIF_Array" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaSingleCMIF" id="0a634fad-ecf0-433b-adba-ceff4a49e743">
        <source>getCriteriaSingleCMIF(_cmifArray : CMIF_Array input; _criteriaType : CM_YACriteriaType; _value : Any);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2025	jlier1	Initial creation  JIRA-35632

*/

vars
	cmifCriteria 	: CMIF_YACriteriaPriority;
	cmifObject 		: CMIF_Object;
	itemCode 		: String;
	proxyCriteria	: CM_YABestPickCriteria;

begin
	//  Check if maintenance object already exists.
	//  If so, it will have a delete action.  Convert it to a change request.
	if self.myForm.myProxyObject &lt;&gt; null then
		foreach cmifObject in _cmifArray do
			cmifCriteria := cmifObject.CMIF_YACriteriaPriority;
			proxyCriteria := cmifCriteria.myProxy.CM_YABestPickCriteria;
			if proxyCriteria.myYACriteriaType = _criteriaType and cmifCriteria.isDeleted then
				//  Change value of existing criteria
				proxyCriteria.setProxy(proxyCriteria.myYACriteriaType, _value, proxyCriteria.code);
				cmifCriteria.setFlag(false, true, false);
				return;
			endif;
		endforeach;
	endif;
	
	// Create an Add Criteria request
	create proxyCriteria transient;
	itemCode := _criteriaType.description.cnEcUpto(CM_YACriteriaPriority::code.length -1);
	proxyCriteria.setProxy(_criteriaType, _value, itemCode);
	cmifCriteria := proxyCriteria.getTransient();
	cmifCriteria.setFlag(true, false, false);
	_cmifArray.add(cmifCriteria);

epilog

end;</source>
        <Parameter name="_cmifArray" type="CMIF_Array" usage="input"/>
        <Parameter name="_criteriaType" type="CM_YACriteriaType"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaText" id="37db33fd-bab6-4c45-86b0-19981ad36db4">
        <source>getCriteriaText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 August 2025	jlier1	Initial creation  JIRA-35632

*/

vars
	cmifCriteria : CMIF_Object;
	text : String;
	criteria : CM_YABestPickCriteria;
begin
	foreach cmifCriteria in self.allCriteria do
		criteria 	:= cmifCriteria.CMIF_YACriteriaPriority.myProxy.CM_YABestPickCriteria;
		text 		:= text &amp; criteria.getListDisplay &amp; " ";
	endforeach;
		
	return text;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
