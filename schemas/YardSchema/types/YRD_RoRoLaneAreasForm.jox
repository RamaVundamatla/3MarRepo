    <JadeMethod name="setMyCurrentDrawingController" id="36d0bbaa-13fd-4609-8462-594b5594b269">
        <updating/>
        <source>setMyCurrentDrawingController(_newController : CMUI_GridDrawingController input; _redraw : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	
	db			: YRD_ContainerGridAreaDockBar;
	anObject	: Object;
	gridArea	: CM_RoRoLaneArea;
begin
	
//	app.setPassBackExceptions(false, false);
//	on Exception do app.generalExceptionHandler(exception) global;

	self.myPreviousDrawingController := self.myCurrentDrawingController;
	self.myCurrentDrawingController := _newController.YRD_RoRoLaneDrawingController;	
				
	if myCurrentDrawingController &lt;&gt; null then
		gridArea := self.myCurrentDrawingController.myTerminalArea.CM_RoRoLaneArea;
		if not global.isValidObject(gridArea) then
			self.myCurrentDrawingController.init(null);
			return;	
		endif;	
	endif;
	
	if _redraw then
			
		foreach anObject in self.allDockBars do
			db := anObject.YRD_ContainerGridAreaDockBar;
			db.myDrawingFrame.changeRoRoBackColor(self.defYardBackColUnselected);
		endforeach;
		self.myCurrentDrawingController.changeBackColor(self.defYardBackColSelected);	
	endif;
end;</source>
        <Parameter name="_newController" type="CMUI_GridDrawingController" usage="input"/>
        <Parameter name="_redraw" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setSelector" id="a2a57930-000a-45f5-9c0a-92343e9be38a">
        <updating/>
        <source>setSelector(_theSelector : CMUI_Selector input) updating, protected;
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	critLine		: CM_SelectorCriteriaLine;
	taSet			: ObjectSet;

begin
	
	_theSelector.myTerminal := self.myTerminal;
	_theSelector.myEnquiryCollectionClass := CM_TIArray;
	_theSelector.defaultSiteStr := TI_SITE_ONSITE_str;


	_theSelector.myQDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.TrackedItem_Query_Type, TI_CargoType_Container];
	_theSelector.disableMnuEnquiry := false;
	//check to see if a previous query in this session contained terminal areas criteria, and if so
	//populate that criteria line with the currently displayed areas, other wise set the
	//allDefaultTerminalAreas collection on the form and that will build a new criteria line for this property
	critLine := self.allSelectorCriteria['myTerminalArea','CM_Container'];
	if critLine &lt;&gt; null and CM_QReferenceIsOneOf.hasInstance(critLine.myQueryOperator) then
		taSet := critLine.myQueryOperator.CM_QReferenceIsOneOf.allSelectionValues;
	else
		taSet := _theSelector.allDefaultTerminalAreas;
	endif;
	
	taSet.clear;
	self.allTerminalAreas.copy(taSet);


end;</source>
        <access>protected</access>
        <Parameter name="_theSelector" type="CMUI_Selector" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTableDataFromOrganiser" id="52ba03c6-9854-41cd-bedb-7e198940be55">
        <updating/>
