    <JadeMethod name="findYABlock" id="cdf623ef-0b33-4542-9232-0fa933d6b616">
        <source>findYABlock(_locationText : String; _topLeftLC, _bottomRightLC : CM_LocationsController output; _taViewPos : CM_TerminalAreaViewPosition) : Boolean;

/*

Purpose:			
