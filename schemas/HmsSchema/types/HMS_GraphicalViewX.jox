    <JadeMethod name="showSearchSelect" id="ef11b0e8-a035-4502-bf6d-ac904e841c6b">
        <source>showSearchSelect() protected;
//-----------------------------------------
// Created: August 2003 By: cnwgd1
//-----------------------------------------
vars
	searchSelectForm : HMS_SearchSelectVisit;
begin
	searchSelectForm := app.loadForm(HMS_SearchSelectVisit, HMS_Assistant, false, false, false, self.myTerminal, self.myMasterMenuAction).HMS_SearchSelectVisit;
	
	if searchSelectForm = null then
		return;
	endif;
	
	if self.myCurrentWorkingMovement &lt;&gt; null then
		searchSelectForm.currentVoyage := self.myCurrentWorkingMovement.myWorkingVoyage;
	endif;

	searchSelectForm.show;
end;</source>
