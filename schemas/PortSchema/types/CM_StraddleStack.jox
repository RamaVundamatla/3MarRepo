    <JadeMethod name="setForUpdateInUse" id="6294a7a7-772c-4812-a1b4-0a231fd5f6d9">
        <updating/>
        <source>setForUpdateInUse(_proxy: CM_StraddleStack; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		02 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// cnwcs5	21/07/2009	ccms 1061 - change method signature to use procy instead of controller

vars

begin
	inheritMethod(_proxy, _passport);
	
end;</source>
        <Parameter name="_proxy" type="CM_StraddleStack"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setGridObjectsForDecking" id="9538972f-52d9-4b03-a5f8-70666dfafd91">
        <source>setGridObjectsForDecking(_passport: CM_Passport input);
//----------------------------------------------------------------
//	Created:	02 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	gridRow : CM_GridObject;
	pDO		: CM_YADeckingOptionsRow;
begin

	foreach gridRow in self.allGridRowsByLabel do
		if gridRow.myDeckingOptions = null then
			create pDO transient;
			pDO.setProxy(false, true, gridRow);
			pDO.setProxyRules(DeckingRule_Default, DeckingRule_Default);
		else
			pDO := gridRow.myDeckingOptions.pxyCreateUpdateProxy;
			pDO.allYALocationCellsIn.clear;
			pDO.allYALocationCellsOut.clear;
		endif;
		
		//update it
		app.myUtilityUA.utlUpdateDeckOptionsApplyRules(pDO, DeckingLevel_Row, _passport);
		
		if app.isValidObject(pDO) then		// OK, this is transient
			delete pDO;
		endif;
		
		if _passport.hasErrors then
			return;
		endif;
		
	endforeach;	 

epilog
	if app.isValidObject(pDO) then		// OK, this is transient
		delete pDO;
	endif;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="3a97968c-6b5f-4515-9686-42b4c1447971">
        <updating/>
        <source>setProxy(_id, _comment		: String; 
		 _type 				: Integer;
		 _rows 				: Integer;
		 _cols 				: Integer;
		 _height 			: Integer;
		 _actAsReleasePoint : Boolean;
		 _terminal			: CM_Terminal;
		 _tmpAutoRestriction,
		 _stockControlled,
		 _hideFromOverView : Boolean;
		 _deckingStartType : Integer;
		 _noLeft, _noRight,
		 _snapLeft, _goRight, _snapStrict : Boolean;
		 _allInterchangeAreas	:CM_InterchangeAreaArray;	// par 24292
		_defaultInterchangeArea: CM_InterchangeArea;
		 _useSideAccessRules : Boolean;
		 _use40ftIds		: Boolean;
		 _leftlabel, 
		 _rightLabel, 
		 _topLabel, 
		 _bottomLabel : String) updating;
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	04/11/2009	cnwphb1		PAR 21532 CCMS SFW 1025 - add _useSideAccessRules
// 26/05/2010		cnwcs5	par 24292 - change _allInterchangeAreas parameter from set to array
// 14/7/2010	cnwer1		par 24463
begin
	self.raiseExceptionIfNotTransient(method);
	self.setGridAreaProxy(_id, 
					 _comment,
					_type, 
					_rows, 
					_cols, 
					_height,
					_actAsReleasePoint, 
					_terminal,
					_tmpAutoRestriction,
					_stockControlled,
					_hideFromOverView,
					_deckingStartType,
					_noLeft, _noRight, _snapLeft, _goRight, _snapStrict,
					_allInterchangeAreas,_defaultInterchangeArea, _use40ftIds, _useSideAccessRules,
					//20/06/2011 cnwdz2 27732
					_leftlabel,_rightLabel,_topLabel,_bottomLabel); //
	
	
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_rows" type="Integer"/>
        <Parameter name="_cols" type="Integer"/>
        <Parameter name="_height" type="Integer"/>
        <Parameter name="_actAsReleasePoint" type="Boolean"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_tmpAutoRestriction" type="Boolean"/>
        <Parameter name="_stockControlled" type="Boolean"/>
        <Parameter name="_hideFromOverView" type="Boolean"/>
        <Parameter name="_deckingStartType" type="Integer"/>
        <Parameter name="_noLeft" type="Boolean"/>
        <Parameter name="_noRight" type="Boolean"/>
        <Parameter name="_snapLeft" type="Boolean"/>
        <Parameter name="_goRight" type="Boolean"/>
        <Parameter name="_snapStrict" type="Boolean"/>
        <Parameter name="_allInterchangeAreas" type="CM_InterchangeAreaArray"/>
        <Parameter name="_defaultInterchangeArea" type="CM_InterchangeArea"/>
        <Parameter name="_useSideAccessRules" type="Boolean"/>
        <Parameter name="_use40ftIds" type="Boolean"/>
        <Parameter name="_leftlabel" type="String"/>
        <Parameter name="_rightLabel" type="String"/>
        <Parameter name="_topLabel" type="String"/>
        <Parameter name="_bottomLabel" type="String"/>
    </JadeMethod>
    <JadeMethod name="testIfFull" id="f21a20da-2673-49cd-a558-a49baa3ea888">
        <source>testIfFull(_autoMovePlan: CMIF_AutoMovePlan input; _lc : CM_LocationsController): Boolean;
// ---------------------------------------------------------------------------
// Created:		29 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	numPlanTIs	:	Integer;
	numRealTIs	:	Integer;
	accessLocn,
	numQueueTIs	:	Integer;
	locnId : String;
begin

	numRealTIs	:= _lc.numTIs;
	numPlanTIs	:= _lc.numPlannedTIs;
	numQueueTIs	:= _lc.numQueuedTIs;
	locnId	:= _lc.getFullId();
	
	//Always check for actual TI's in area 1st
	if _autoMovePlan.iteration &lt;= numRealTIs then
		//_autoMovePlan.addVerboseLogEntry("Position " &amp; _autoMovePlan.iteration.String &amp; " of " &amp; locnId &amp; " is occupied.", IsForLogging);
		_autoMovePlan.updateController(null);	//The height is full
		return false;
	endif;
	//Now, check for planned TIs
	if _autoMovePlan.iteration &lt;= numPlanTIs then
		if numPlanTIs &gt; 0 then	
			//Irrespective of where we are trying to go, if there is something planned
			//here. skip it.
			//_autoMovePlan.addVerboseLogEntry(locnId &amp; " has a planned TI in it, skipping.", IsForLogging);
			_autoMovePlan.updateController(null);
			return false;
		endif;
	endif;

	return inheritMethod(_autoMovePlan, _lc);

end;</source>
        <Parameter name="_autoMovePlan" type="CMIF_AutoMovePlan" usage="input"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testIfRequirePower" id="83684302-01b4-4c8e-bde9-ba50e00620a3">
        <source>testIfRequirePower(_autoMovePlan: CMIF_AutoMovePlan input; _lc: CM_LocationsController): Boolean;
// ---------------------------------------------------------------------------
// Created:		29 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	yc : CM_YardController;
	locnId : String;
begin
	if not  _lc.isKindOf(CM_YardController) then
		return false;
	endif;
	
	yc := _lc.CM_YardController;
	locnId := yc.getFullId();
	
	if yc.power = false then
		if not _autoMovePlan.testAnyHavePower() then // PAR 18682 CCMS SFW 1055
			//No power!
			//_autoMovePlan.addVerboseLogEntry(locnId &amp; " has no Power available.", IsWarning); //- cnwmd1, Par 20524
			_autoMovePlan.addVerboseLogEntry(app.getErrorString1(Power_available,locnId), IsWarning, Power_available);
		endif;
	endif;
	if yc.powerDamaged = true then
		if not _autoMovePlan.testAnyHavePower() then // PAR 18682 CCMS SFW 1055
			//No power!
			//_autoMovePlan.addVerboseLogEntry(locnId &amp; ": Power is damaged.", IsWarning);
			_autoMovePlan.addVerboseLogEntry(app.getErrorString1(Power_damaged,locnId), IsWarning, Power_damaged);
		endif;
	endif;
	
	return inheritMethod(_autoMovePlan, _lc);

end;</source>
        <Parameter name="_autoMovePlan" type="CMIF_AutoMovePlan" usage="input"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testIfRequirePowerYA" id="2552e71a-319a-4e9e-8ac3-c4d2e2d2255f">
        <source>testIfRequirePowerYA(_yaAgent : CM_YAAutoplanAgent input; _lc: CM_LocationsController): Boolean;
// ---------------------------------------------------------------------------
// Created:		29 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	yc : CM_YardController;
	locnId : String;
begin
	if not  _lc.isKindOf(CM_YardController) then
		return false;
	endif;
	
	yc := _lc.CM_YardController;
	locnId := yc.getFullId();

	if yc.power = false then
		//No power!
		_yaAgent.addLogEntry(AP_Log_YA_Default,locnId &amp; " has no Power available.", true);
		return true;
	endif;
	if yc.powerDamaged = true then
		//No power!
		_yaAgent.addLogEntry(AP_Log_YA_Default,locnId &amp; ": Power is damaged.", true);
		return true;
	endif;
	
	return inheritMethod(_yaAgent, _lc);

end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testIsCellBlockedYA" id="f3a9cb28-dc12-45ff-bb62-a8a6cd1ec1b4">
        <source>testIsCellBlockedYA(_yaAgent : CM_YAAutoplanAgent input; _gridObject : CM_GridObject; _cell : CM_YALocationCell): Boolean;
// -------------------------------------------
// Created 08 June 2005 by cnwdvb1
// -------------------------------------------
constants

	Huge_Column = 200;
	
vars

	yardControllerFound,	
	backEnd				: CM_GridController;
	yardController		: CM_YardController;
	isAfterHeigher,
	isBeforeHeigher,
	isAfterLower,
	isBeforeLower,
	max					: Integer;
	gridRow				: CM_GridRow;
	

	myColumn,
	theHeight		: Integer;

begin

	if self.heightOfStack &gt; CM_YABlock.Max_Straddle_Lift then
		return false;
	endif;
	
	max := CM_YABlock.Max_Straddle_Lift;
	
	yardControllerFound := _cell.myYardController.CM_GridController;
	
	if _yaAgent.numControllers &gt; 1 then
		backEnd := yardControllerFound.getNextControllerOfType(CM_GridController);
	endif;
	
	myColumn := yardControllerFound.column;
	
	isAfterHeigher := Huge_Column;
	isAfterLower := Huge_Column;	

	gridRow := _gridObject.CM_GridRow;//block.CM_YABlockStraddle.getGridRow();
	
	if gridRow = null then
		return true;
	endif;
	
	foreach yardController in gridRow.allControllersByColumn discreteLock where (yardControllerFound &lt;&gt; yardController) and (yardController &lt;&gt; backEnd) do
		theHeight := (yardController.numTIs + yardController.numQueuedTIs);
		if not yardController.isKindOf(CM_StackController) or not yardController.CM_StackController.isAvailable(-1, null) then // PAR 17886
			continue;
		endif;
		if  theHeight &gt;= max then
			if yardController.CM_GridController.column &lt; myColumn then
				isBeforeHeigher := yardController.CM_GridController.column.max(isBeforeHeigher);
			else
				isAfterHeigher := yardController.CM_GridController.column.min(isAfterHeigher);
			endif;
		else
			if yardController.CM_GridController.column &lt; myColumn then
				isBeforeLower := yardController.CM_GridController.column.max(isBeforeLower);
			else
				isAfterLower := yardController.CM_GridController.column.min(isAfterLower);
			endif;
		endif;
	endforeach;
	
	if (isBeforeHeigher &lt; myColumn and isBeforeHeigher &lt;&gt; 0) and (isAfterHeigher &gt; myColumn and isAfterHeigher &lt;&gt; Huge_Column) then
		_yaAgent.addLogEntry(AP_Log_YA_Default,'Can not get box there as is blocked at column ' &amp; isBeforeHeigher.String &amp; ' and ' &amp; isAfterHeigher.String, true);
		return true;
	endif;
	

	if not (_cell.height &gt;= CM_YABlock.Max_Straddle_Lift) then
		return false;
	endif;
	
	if (isBeforeHeigher &lt; isBeforeLower) and (isBeforeHeigher &lt;&gt; 0 and isBeforeLower &lt;&gt; 0) then
		_yaAgent.addLogEntry(AP_Log_YA_Default,'Before - Blocking boxes at column ' &amp; isBeforeHeigher.String, true);
		return true;
	endif;
	
	if (isAfterHeigher &gt; isAfterLower) and (isAfterLower &lt;&gt; Huge_Column and isAfterHeigher &lt;&gt; Huge_Column) then
		_yaAgent.addLogEntry(AP_Log_YA_Default,'After - Blocking at column ' &amp; isAfterHeigher.String, true);
		return true;
	endif;

	return false;
end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <Parameter name="_gridObject" type="CM_GridObject"/>
        <Parameter name="_cell" type="CM_YALocationCell"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testLocationsForOverstow" id="15b07fdf-45ba-4841-955a-9f5d42de154b">
        <source>testLocationsForOverstow(_yaAgent : CM_YAAutoplanAgent input) : Boolean;
// -------------------------------------------
// Created 15 September 2005 by cnwdvb1
// -------------------------------------------
vars

	ti 					: CM_TrackedItem;
	previousController,
	nextController,
	controller			: CM_GridController;
	nextRow,
	prevRow,
	row					: CM_GridRow;
	iterNext,
	iterPrev			: Iterator;
	stopNext,
	stopPrev			: Boolean;

begin

	ti := _yaAgent.getMyCurrentTrackedItem();
	
	//cnwrd1 par 29065 3.2.2012
	if self.myTerminal.testYAOverstowTI(ti) then
		return false;
	endif;
	
	// Where is this ti currently situated. 
	controller := ti.getPrimaryLocation(REAL_MODE).CM_GridController;
	
	// Which row.
	row 	:= controller.myGridRow;
	
	// Set next and previous pointers to starting point.
	nextController		:= controller;
	previousController	:= controller;
	
	// Do the following 8,6,4,2,xxx,1,3,5,7
	// Don't bother checking for free spaces as we are moving within the same row.
	while true do
		// Get next controller.
		if nextController &lt;&gt; null then
			nextController := nextController.getMyNextController(CM_StackController);
		endif;
		
		// Do we have a next controller to evaluate and is it suitable.
		if nextController &lt;&gt; null and nextController.testForOverstowYA(_yaAgent, nextController.myGridRow) then
			return true;
		else
			// Get previous controller.
			if previousController &lt;&gt; null then
				previousController := previousController.getMyPreviousController(CM_StackController);
			endif;
			
			// Is previous controller suitable?
			if previousController &lt;&gt; null and previousController.testForOverstowYA(_yaAgent, previousController.myGridRow) then
				return true;
			endif;
		endif;
		// Nothing more to check so stop.
		if nextController = null and previousController = null then
			break;
		endif;
	endwhile;
	
	// We have reached the end of the row so can't have found a ground position.
	// Any last resorts?
	if not _yaAgent.myCurrentCMIFYAAutoPlan.allLCsLastResort.isEmpty() then
		return true;
	endif;
	
	// Moving on from first row. Rules change.
	iterNext := self.allGridRows.createIterator();
	iterPrev := self.allGridRows.createIterator();
	
	// Set start points.
	iterNext.startAtObject(row);
	iterPrev.startAtObject(row);
	
	// Increment pointers.
	stopNext := not iterNext.next(nextRow);
	stopPrev := not iterPrev.back(prevRow);

	// Now it's time for alternate ascending rows and descending rows with ascending columns.
	while true do : outerLoop
		if not stopNext and iterNext.next(nextRow) then
			// Move through each controller in the row.
			if nextRow.testForFreeSpaceYA(_yaAgent) then
				foreach nextController in nextRow.allControllersByColumn discreteLock do
			 		if nextController.testForOverstowYA(_yaAgent, nextController.myGridRow) then
			 			return true;
			 		endif;
			 	endforeach;
			endif;
		else
			// We get here if we have no more rows to process.
			if stopPrev then
				// All finished so break.
		 		break;
		 	endif;
		 	stopNext := true;
		endif;
		
		// We have reached the end of the row so can't have found a ground position.
		// Any last resorts? 
		if not _yaAgent.myCurrentCMIFYAAutoPlan.allLCsLastResort.isEmpty() then
			return true;
		endif;
	
		// Looking through previous row.			 
		if not stopPrev and iterPrev.back(prevRow) then
			// Move through each controller in row.
			if prevRow.testForFreeSpaceYA(_yaAgent) then
				foreach previousController in prevRow.allControllersByColumn discreteLock do
					if previousController.testForOverstowYA(_yaAgent, previousController.myGridRow) then
				 		return true;
				 	endif;
				endforeach;
			endif;
		else
			// We get here if we have no more rows to process.
			if stopNext then
				// All finished so break.
				break;
			endif;
			stopPrev := true;
		endif;
		
		// We have reached the end of the row so can't have found a ground position.
		// Any last resorts? 
		if not _yaAgent.myCurrentCMIFYAAutoPlan.allLCsLastResort.isEmpty() then
			return true;
		endif;
	endwhile;
	
	// We have reached the end of the row so can't have found a ground position.
	// Any last resorts? 
	if not _yaAgent.myCurrentCMIFYAAutoPlan.allLCsLastResort.isEmpty() then
		return true;
	endif;
	_yaAgent.addLogEntry(AP_Log_YA_Default,'Failed to find suitable overstow location', false);
	_yaAgent.setHadError(true);
	return false;

epilog

	delete iterPrev;
	delete iterNext;

end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testTowerRequired" id="86d54d12-64da-4eea-9fa8-efe338328e3d">
        <source>testTowerRequired(_autoMovePlan : CMIF_AutoMovePlan input; _lc : CM_LocationsController): Boolean;
// ---------------------------------------------------------------------------
// Created:		29 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	towerHeight	: Integer;
	tower				: CM_Tower;
	tTower				: CM_TrackedItem;
	tCont : CM_LocationsController;
	tc					: CM_TowerController;
	isPrevious 	: Boolean;
	commodity 	: CM_Commodity;
	ph 					: CM_TrackedItem;
	nextLC			:	CM_StackController;
	alert				:	CM_SystemAlert;
	qSize				:	Integer;
	aSize				:	Integer;
	pSize				:	Integer;
	towerId			:	String;
begin

	_autoMovePlan.updateController(null);
	if _autoMovePlan.myTrackedItem.isAttributeTrue(TI_Attrib_RequiresTemperature) = false then
		//----------------
		//TI does NOT require temperature monitoring
		//----------------
		_autoMovePlan.updateController(_lc);
		return true;
	endif;
	if _autoMovePlan.myTrackedItem.isAttributeTrue(TI_Attrib_IsIntegral) or 
		_autoMovePlan.myTrackedItem.isAttributeTrue(TI_Attrib_HasCOU) then
		//Integrals/TI's with COUs dont need tower.
		_autoMovePlan.updateController(_lc);	
		return true;
	endif;
	//----------------
	//TI does require tower services
	//----------------
	//Determine at which height to stack...
	//Its safe to assume if we are connecting to a TOWER, then they are full height objects.
	tCont := _lc.CM_GridController.getNextControllerOfType(CM_TowerController).CM_TowerController;
	if tCont = null then
		tCont := _lc.CM_GridController.getPreviousControllerOfType(CM_TowerController).CM_TowerController;
		isPrevious := true;
	endif;		
	if tCont = null then
		//NO TOWER CONTROLLERS in this Straddle Stack!
		//_autoMovePlan.addVerboseLogEntry("No Refrigeration tower controllers in area.", IsWarning); //- cnwmd1, Par 20524
		_autoMovePlan.addVerboseLogEntry(app.getErrorString(Refrige_tower_control_area), IsWarning, Refrige_tower_control_area);
		return false;
	endif;
	tc := tCont.CM_TowerController;

// took this out as is raises an error if not in autoplan mode	- AKB2003APRIL
//	_autoMovePlan.addVerboseLogEntry("Info Tower controller is previous : " &amp; isPrevious.String);

	//Add 1 to towerheight, we are looking for a tower at height
	//we want to stack to. If numTI's is 0, then we want to check
	//at height 1
	if _lc.numTIs &lt; 0 then	//Funnily enough, some LC's have -1 as numTI's!!!
		towerHeight := 1;
	else
		if _autoMovePlan.moveMode = REAL_MODE then
			towerHeight := _lc.numTIs +1;
		else
			//----------------
			//For other modes, we need to aggregate the totals to get the appropriate height
			//----------------
			aSize := _lc.numTIs;
			pSize := _lc.numPlannedTIs;
			qSize := _lc.numQueuedTIs;
			if _autoMovePlan.moveMode = PLANNING_MODE then
				towerHeight := aSize + pSize +1;
			else
				towerHeight := aSize + qSize +1;
			endif;
		endif;
	endif;
	//-------------
	//Get Tower @ height
	//-------------
	tc.getTIAtHeight(tTower, towerHeight, REAL_MODE);
	if tTower = null then
		//NO TOWER at this height
		//_autoMovePlan.addLogEntry("No Refrigeration tower at height " &amp; towerHeight.String, IsWarning); //- cnwmd1, Par 20524
		_autoMovePlan.addLogEntry(app.getErrorString1(Refrigerat_tower_height,towerHeight.String), IsWarning, Refrigerat_tower_height);
		return false;
	endif;
	tower := tTower.CM_Tower;
	towerId := tower.id.trimRight;
	//---------------
	//Ensure these is no TI in spot we want
	//---------------
	if isPrevious then
		ph := tower.nextPortHole;	//AJA 2/9/99: Swap next and previous references:
	else																	//we want to check THIS side of the tower !
	 	ph := tower.prevPortHole;
	endif;
 	if ph &lt;&gt; null then
		//Already has a TI connected
		//_autoMovePlan.addVerboseLogEntry("Tower " &amp; towerId &amp; " already has Container " &amp; ph.id.trimRight &amp; " at height " &amp; towerHeight.String, IsWarning); //- cnwmd1, Par 20524
		_autoMovePlan.addVerboseLogEntry(app.getErrorString3(Tower_already_contain_height,towerId, ph.id.trimRight, towerHeight.String), IsWarning, Tower_already_contain_height);
		return false;
 	endif;
 	//----------------------
 	//Ask the tower to validate itself
 	//----------------------
	tower.validateMoveTo(_autoMovePlan);
	if _autoMovePlan.getController = null then
		return false;
	endif;
	//--------------
	//Check location on other side of tower is Available (new 31 March 1999 DWQ)
	//--------------
	if isPrevious then
		tCont := _lc.CM_GridController.getPreviousControllerOfType(CM_StackController);
	else
		tCont := _lc.CM_GridController.getNextControllerOfType(CM_StackController);
	endif;
 	if tCont &lt;&gt; null then
 		nextLC := tCont.CM_StackController;
		//_autoMovePlan.addLogEntry("Testing Location on other side of tower " &amp; towerId);
 		nextLC.testIsControllerAvailable(_autoMovePlan);
 		if _autoMovePlan.getController() = null then
 			//--------------------
 			//Create an ALERT, the Tower SHOULD BE Set non-operational
 			//--------------------
 			create alert;
			//alert.details := "Reefer Tower" &amp; towerId &amp; " in location " &amp; tower.locationId &amp; " is sitting beside a disabled location, the tower is STILL operational! (it shouldnt be!)";
			alert.details := app.getErrorString2(Reefe_tower_locat_sitti_besid_,towerId, tower.locationId);
			alert.setSeverity(SEVERE_WARNING);
			//-----------
			//Tell alert to add itself to system
			//-----------
			alert.add;
			return false;
		endif;
 	endif;
	//--------------
	//Check temperature compatibility
	//--------------
	commodity := app.myRoot.allCommodities[_autoMovePlan.myTrackedItem.commodity];

	if (not commodity.hasTemp) then
	  	//-------------------
	  	//No temperature, TI can still go here.
	  	//-------------------
		_autoMovePlan.updateController(_lc);
		return true;
  endif;

	if isPrevious then
		ph := tower.prevPortHole;
	else
		ph := tower.nextPortHole;
	endif;

	if ph = null then
	  	//-------------------
	  	//No TI on other side that is CONNECTED, test to see if there
	  	//is one there BUT NOT connected
	  	//-------------------
		nextLC.getTIAtHeight(ph, towerHeight, REAL_MODE);
  		if ph = null then
	  		//-------------
	  		//Fine, no container there..
	  		//-------------
			_autoMovePlan.updateController(_lc);
			return true;
		endif;
	endif;
	if _autoMovePlan.isTestToBeDone(TI_Test_TowerCmdtyGrp, _lc) = true then
	 	//----------------	
		//They wish to test for the opposing Tracked item having the SAME COMMODITY GROUP
		//----------------	
		if _autoMovePlan.myTrackedItem.hasSameUnderStowAttribute(ph, TI_Test_CommodityGroup) = false then
			//_autoMovePlan.addLogEntry("Other Container's (" &amp; ph.id.trimRight &amp; ") Commodity group (" &amp;  ph.commodityGroup.trimRight &amp; ") is NOT the same as current of " &amp; _autoMovePlan.myTrackedItem.commodityGroup.trimRight, IsWarning); //- cnwmd1, Par 20524
			_autoMovePlan.addLogEntry(app.getErrorString3(Other_conta_commo_group_same_c, ph.id.trimRight, ph.commodityGroup.trimRight, _autoMovePlan.myTrackedItem.commodityGroup.trimRight), IsWarning, Other_conta_commo_group_same_c);
			return false;
		endif;
	endif;
	//-------------
	//Check prospective TI's temperature against the
	//temperature of the commodity on the other side of the tower
	//-------------
	if _autoMovePlan.isTestToBeDone(TI_Test_TowerTemperature, _lc) = true then
		//----------------
		//Specific temperature test.
		//----------------
		if _autoMovePlan.myTrackedItem.hasSameUnderStowAttribute(ph, TI_Test_Temperature) = false then
			//_autoMovePlan.addLogEntry("Tower: Other Container's (" &amp; ph.id.trimRight &amp; ") SPECIFIC temperature test has failed because its temperature is not exactly the same as " &amp;_autoMovePlan.myTrackedItem.id &amp; "'s, Skipping", IsWarning); //- cnwmd1, Par 20524
			_autoMovePlan.addLogEntry(app.getErrorString2(Tower_other_conta_speci_tempe_, ph.id.trimRight, _autoMovePlan.myTrackedItem.id), IsWarning, Tower_other_conta_speci_tempe_);
			return false;
	  	endif;
	else  
		if _autoMovePlan.myTrackedItem.hasSameUnderStowAttribute(ph, TI_Test_CmdtyTemp) = false then
			//----------------
			//Normal temperature test on a tower.
			//----------------
			//_autoMovePlan.addLogEntry("Tower: Other Container's (" &amp; ph.id.trimRight &amp; ") temperature is incompatible, Skipping", IsForLogging); //- cnwmd1, Par 20524
			_autoMovePlan.addLogEntry(app.getErrorString1(Tower_other_conta_tempe_incom_, ph.id.trimRight), IsForLogging, Tower_other_conta_tempe_incom_);
			return false;
		endif;
	endif;
	//-----------------
	//If they want to test the VOYAGE on the OTHER side of the tower is ok...
	//-----------------
	if _autoMovePlan.isTestToBeDone(TI_Test_TowerVoyage, _lc) = true then
	  	if _autoMovePlan.myTrackedItem.hasSameUnderStowAttribute(ph, TI_Test_Voyage) = false then
			//_autoMovePlan.addLogEntry("Tower: Other Container's (" &amp; ph.id.trimRight &amp; ") Voyage is incompatible, Skipping", IsForLogging); //- cnwmd1, Par 20524
			_autoMovePlan.addLogEntry(app.getErrorString1(Tower_other_conta_voyag_incom_, ph.id.trimRight), IsForLogging, Tower_other_conta_voyag_incom_);
			return false;
		endif;	
	endif;



	return inheritMethod(_autoMovePlan, _lc);

end;</source>
        <Parameter name="_autoMovePlan" type="CMIF_AutoMovePlan" usage="input"/>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="1c7d889d-58f7-4d5f-bec0-1d2a30668b8a">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:		July 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin

	inheritMethod();

end;</source>
    </JadeMethod>
    <JadeMethod name="yaBuildBlocksOLD" id="e23f1e97-7d00-431f-a72a-2dc4025eb8f4">
        <source>yaBuildBlocksOLD(	pYardAllocationObj:CM_YardAllocation;
				pAllControllersObj: CM_LCArray;
				pAllBlocksInObj: CM_YABlockArray input;
				pAllBlocksOutObj:CM_YABlockArray input):Boolean;
// ---------------------------------------------------------------------------
// Created:     19 April 2005 by cnwrs2
//
// Purpose:     Refer to superclass implementation.
// ---------------------------------------------------------------------------
vars
	blockObj			: CM_YABlock;
	gridRowObj			: CM_GridRow;
	controllerObj		: CM_LocationsController;
	gridControllerObj	: CM_GridController;
	controllerSetObj	: CM_LCArray;
	deleteBlockSet		: CM_YABlockSet;
	doDelete			: Boolean;
	
begin
	// *** Do not inherit any behaviour ***
	//inheritMethod(pAllControllersObj, pAllBlocksObj);
	
	// Need to split by row.
	
	create controllerSetObj transient;
	create deleteBlockSet transient;
	
	foreach blockObj in pAllBlocksInObj where blockObj.myTerminalArea = self do
		deleteBlockSet.add(blockObj);
	endforeach;
	
	blockObj := null;
	foreach controllerObj in pAllControllersObj do
	
		if pYardAllocationObj = null or pYardAllocationObj.getBlockMode() = CM_YardAllocation.ROW_MODE then
			doDelete := true;
		endif;
		
		if (not CM_GridController.hasInstance(controllerObj)) then
			// This should not ever happen!!
			continue;
		endif;
		
		gridControllerObj	:=	controllerObj.CM_GridController;
		gridRowObj			:=	gridControllerObj.myGridRow;
		
		// Find a YA Block for the Grid Row in pAllBlocksObj.
		// Note that whilst we only look up a YA Block from the "In" collection, we will
		// add any new blocks to both the "In" and "Out" collections. This is because
		// both the "In" and the "Out" collections contain the same objects, the only
		// difference is that they may be in a different order.
		
		if pYardAllocationObj = null or pYardAllocationObj.getBlockMode() = CM_YardAllocation.ROW_MODE then
			blockObj	:=	pAllBlocksInObj.getGridRowBlock(gridRowObj);
		endif;
		
		if blockObj &lt;&gt; null and deleteBlockSet.includes(blockObj) then
			// Need to clear out controllers for first time.
			blockObj.allYardControllers.clear();
			deleteBlockSet.remove(blockObj);
		endif;
		
		controllerSetObj.add(controllerObj);
		
		// If a YA Block wasn't found for the Grid Row, one will be created here.
		
		self.yaAddControllersToBlock(pYardAllocationObj, controllerSetObj, blockObj, pAllBlocksInObj, pAllBlocksOutObj);
		controllerSetObj.clear();
	endforeach;
	
	if doDelete then

		foreach blockObj in deleteBlockSet do
			if pAllBlocksInObj.includes(blockObj) then
				pAllBlocksInObj.remove(blockObj);
				pAllBlocksOutObj.remove(blockObj);
			endif;
		endforeach;
		deleteBlockSet.purge();
	endif;
	
	return true;
epilog
	delete controllerSetObj;
	delete deleteBlockSet;
end;</source>
        <Parameter name="pYardAllocationObj" type="CM_YardAllocation"/>
        <Parameter name="pAllControllersObj" type="CM_LCArray"/>
        <Parameter name="pAllBlocksInObj" type="CM_YABlockArray" usage="input"/>
        <Parameter name="pAllBlocksOutObj" type="CM_YABlockArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="yaGetBlockType" id="8c104d9e-d0eb-41f4-8cfc-e3428f41a926">
        <source>yaGetBlockType(): Class;
// --------------------------------------------------------------------------------
// Created:		15 April 2005 by cnwdad1:2
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return CM_YABlockStraddle;
end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
