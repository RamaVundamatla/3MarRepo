    <JadeMethod name="columnTable_change" id="6b652f23-b819-40f8-95f8-04b0ce0dbc8f">
        <controlMethod name="Table::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>columnTable_change(table: Table input) updating;

begin
	columnTable.setCellText(1, columnTable.column, convertToCrLf(columnTable.getCellText(2, columnTable.column)));
	columnHeading.caption := columnTable.getCellText(2, columnTable.column);
	
	transientTable.columnHeadingArray[columnTable.column] := columnHeading.caption;
	if columnTable.columnWidth[columnTable.column] &lt; columnHeading.getTextExtent(columnHeading.caption) + 10 then
		columnTable.columnWidth[columnTable.column] := columnHeading.getTextExtent(columnHeading.caption) + 10;
	endif;
	
	self.columnTable.refresh();
	self.columnTableResize();
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="columnTable_mouseDown" id="28f9a08c-2e2c-463f-82d4-aef6294c23f4">
        <controlMethod name="Table::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>columnTable_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;

begin
	clickColumn := 0;
	if columnTable.mousePointer = Control.MousePointer_NS or columnTable.mousePointer = Control.MousePointer_WE then
		return;
	endif;
	if app.mousePointer = Control.MousePointer_NS or app.mousePointer = Control.MousePointer_WE then
		return;
	endif;
	if button = 1 then
//		columnTable.autoRedraw := true;
		columnTable.drawStyle := columnTable.DrawStyle_Dot;
		mouseIsDown := true;
		mouseDownDrawSize := self.drawSize;
		mouseDownX := x;
		mouseDownY := y;
		if y &lt; columnTable.rowHeight[1] then
			clickColumn := convertPositionToColumn(x);
		endif;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="columnTable_mouseMove" id="14f878cc-8495-4c28-b154-da3064d220e2">
        <controlMethod name="Table::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>columnTable_mouseMove(table : Table input; button : Integer; shift : Integer; x : Real; y : Real) updating;

vars
	formX					: Real;
	formY					: Real;
	halfWidth				: Real;
	halfHeight				: Real;
	arrowX					: Real;
	arrowY					: Real;
begin
	if mouseIsDown then
	    if (x - mouseDownX).abs &gt; 2 then
	    	if clickColumn &lt; 1 or clickColumn &gt; columnTable.columns then
	    		return;
	    	endif;
			halfWidth := (columnTable.columnWidth[clickColumn] / 2);
			halfHeight := (columnTable.rowHeight[1] / 2);
	    	columnTable.drawUndo(mouseDownDrawSize);
//			self.controlToForm(columnTable.hwnd, formX, formY);
			formX := formX + x;
			formY := formY + y;
			if (formY - halfHeight) &lt; 0 then
				formY := halfHeight;
			endif;
			if (formY + columnTable.rowHeight[1]) &gt; columnTable.height then
				formY := columnTable.height - columnTable.rowHeight[1];
			endif;
			if (formX - halfWidth) &lt; 0 then
				if columnTable.leftColumn &gt; 1 then
					columnTable.leftColumn := columnTable.leftColumn - 1;
				endif;
			endif;
			if (formX + halfWidth) &gt; columnTable.width then
				if columnTable.leftColumn &lt; columnTable.columns then
					columnTable.leftColumn := columnTable.leftColumn + 1;
				endif;
			endif;
	    	columnTable.drawRectangle(formX - halfWidth,
	    							formY - halfHeight,
	    							formX + halfWidth,
	    							formY + halfHeight,
	    							DarkBlue);
//			arrow down &amp; to the right
			columnTable.drawLine(	formX + (halfWidth / 2), formY + halfHeight,
								formX + (halfWidth / 2), formY + (halfHeight * 1.5),
								DarkBlue);
			arrowX := formX + halfWidth;
			arrowY := formY + (halfHeight * 1.5);
			columnTable.drawLine(	formX + (halfWidth / 2), formY + (halfHeight * 1.5),
								arrowX, arrowY,
								DarkBlue);
//			draw right arrow head
			columnTable.drawLine(	arrowX, arrowY, arrowX - 6, arrowY - 3, DarkBlue);
			columnTable.drawLine(	arrowX - 6, arrowY - 3, arrowX - 4, arrowY, DarkBlue);
			columnTable.drawLine(	arrowX - 4, arrowY, arrowX - 6, arrowY + 3, DarkBlue);
			columnTable.drawLine(	arrowX - 6, arrowY + 3, arrowX, arrowY, DarkBlue);
//			arrow down &amp; to the left
			columnTable.drawLine(	formX - (halfWidth / 2), formY + halfHeight,
								formX - (halfWidth / 2), formY + (halfHeight * 1.5),
								DarkBlue);
			arrowX := formX - halfWidth;
			arrowY := formY + (halfHeight * 1.5);
			columnTable.drawLine(	formX - (halfWidth / 2), formY + (halfHeight * 1.5),
								arrowX, arrowY,
								DarkBlue);
//			draw left arrow head
			columnTable.drawLine(	arrowX, arrowY, arrowX + 6, arrowY - 3, DarkBlue);
			columnTable.drawLine(	arrowX + 6, arrowY - 3, arrowX + 4, arrowY, DarkBlue);
			columnTable.drawLine(	arrowX + 4, arrowY, arrowX + 6, arrowY + 3, DarkBlue);
			columnTable.drawLine(	arrowX + 6, arrowY + 3, arrowX, arrowY, DarkBlue);
	    endif;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="columnTable_mouseUp" id="cca364c1-7128-44f8-986d-d7acfb42bf55">
        <controlMethod name="Table::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>columnTable_mouseUp(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;

vars
	loopIndex					: Integer;
	dropColumn					: Integer;
	dragDrop					: Boolean;
begin
	if button = 1 then
//	columnTable.autoRedraw := false;
		mouseIsDown := false;
		if columnTable.drawSize &gt; mouseDownDrawSize then
			dragDrop := true;
 		   	columnTable.drawUndo(mouseDownDrawSize);
		endif;
		if clickColumn &gt; 0 then

			if y &lt; columnTable.rowHeight[1] then
				dropColumn := convertPositionToColumn(x);
				if dropColumn &lt;&gt; clickColumn then
					columnTable.moveColumn(clickColumn, dropColumn);
					self.moveColumn(clickColumn, dropColumn);
					return;
				endif;
//			if we drew something, then we went into column move mode, so don't do the column sort
				if dragDrop then
					return;
				endif;
			endif;


		endif;
	endif;

	transientTable.columnHeight := table.rowHeight[1];

	attributeTable.setCellText(2, 2, columnTable.columnWidth[columnTable.column].String);
	loopIndex := columnTable.columns;
	
	while loopIndex &gt; 0 do
		transientTable.columnWidthArray[loopIndex] := columnTable.columnWidth[loopIndex];
		loopIndex := loopIndex - 1;
	endwhile;
	
	columnTable.refresh();
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="columnTable_rowColumnChg" id="26f56775-9b5e-497e-810c-054d6b4798b2">
        <controlMethod name="Table::rowColumnChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>columnTable_rowColumnChg(table: Table input) updating;

begin
	self.currentColumn.text := self.columnTable.column.String;
	self.setColumnAttributes();
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="convertPositionToColumn" id="f208d41a-4804-4c96-b73e-2048aec2324e">
        <updating/>
        <source>convertPositionToColumn(xPos : Real) : Integer updating;
//
//	return the table column who's left &amp; width position covers the x coordinate passed
//
vars
	originalColumn		: Integer;
	loopIndex			: Integer;
	rightMostPos		: Real;
	rightMost			: Integer;
begin
	originalColumn := columnTable.column;

	if columnTable.fixedColumns &gt; 0 then
		loopIndex := 1;
		while loopIndex &lt;= columnTable.fixedColumns do
			columnTable.column := loopIndex;
			if columnTable.positionLeft &lt;= xPos then
				if xPos &lt;= (columnTable.positionLeft + columnTable.columnWidth[loopIndex]) then
					columnTable.column := originalColumn;
					return(loopIndex);
				endif;
			endif;
			if columnTable.positionLeft &gt; rightMostPos then
				rightMostPos := columnTable.positionLeft;
				rightMost := loopIndex;
			endif;
			loopIndex := loopIndex + 1;
		endwhile;
		rightMostPos := 0;
		rightMost := 0;
	endif;

	loopIndex := columnTable.leftColumn;
	while loopIndex &lt;= columnTable.columns do
		columnTable.column := loopIndex;
		if columnTable.positionLeft &lt;= xPos then
			if xPos &lt;= (columnTable.positionLeft + columnTable.columnWidth[loopIndex]) then
				columnTable.column := originalColumn;
				return(loopIndex);
			endif;
		endif;
		if columnTable.positionLeft &gt; rightMostPos then
			rightMostPos := columnTable.positionLeft;
			rightMost := loopIndex;
		endif;
		loopIndex := loopIndex + 1;
	endwhile;
	if rightMost = 0 then
		rightMost := 1;
	endif;

	columnTable.column := originalColumn;
	return(rightMost);
end;</source>
        <Parameter name="xPos" type="Real"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="convertToCrLf" id="34367202-4267-47f0-8eaf-28f525bcd70c">
        <source>convertToCrLf(textIn : String) : String;

vars
	headingText				: String;
	pos						: Integer;
begin
	headingText := textIn;
	pos := headingText.pos('|',1);
	while pos &gt; 0 do
		if pos &lt; headingText.length then
 			headingText := headingText[1:pos-1] &amp; CrLf &amp; headingText[pos+1:end];
 		else
 			headingText := headingText[1:pos-1] &amp; CrLf;
 		endif;
		pos := headingText.pos('|',1);
	endwhile;
	return(headingText);
end;</source>
        <Parameter name="textIn" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="currentColumn_change" id="e54e3554-edd2-4be3-963d-5259d3799a19">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>currentColumn_change(textbox: TextBox input) updating;

vars
	col					: Integer;
begin
	col := currentColumn.text.Integer;

	if col &gt; 0 and col &lt; columnTable.columns then
		columnTable.column := col;
	else
		currentColumn.text := columnTable.column.String;
	endif;
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initTable" id="2e470733-2e1f-4ee7-87ab-3a9eb70be1a2">
        <updating/>
        <source>initTable() updating;

begin
//
//	initialise the attribute table layout and options
//
	attributeTable.rows 	:= 5;
	attributeTable.columns  := 2;

	attributeTable.columnWidth[1] := 150;
	attributeTable.columnWidth[2] := 150;

	attributeTable.rowHeight[1] := 21;
	attributeTable.rowHeight[2] := 21;
	attributeTable.rowHeight[3] := 21;
	attributeTable.rowHeight[4] := 21;
	attributeTable.rowHeight[5] := 21;

	attributeTable.setCellText(1,1,'Visible');
	attributeTable.setCellText(2,1,'Width');
	attributeTable.setCellText(3,1,'Row 1 Height');
	attributeTable.setCellText(4,1,'Max Length');
	attributeTable.setCellText(5,1,'Picture');

	attributeTable.accessMode := Table.AccessMode_Column;
	attributeTable.row := 1;
	attributeTable.column := 1;
	attributeTable.alignment := Table.Alignment_Center;
	attributeTable.column := 2;
	attributeTable.alignment := Table.Alignment_Center;

	attributeTable.accessMode := Table.AccessMode_Cell;

	attributeTable.column := 2;
	attributeTable.row := 1;
	attributeTable.inputType := Table.InputType_ComboBox;
	attributeTable.comboList := '0 - False' &amp; Tab &amp; '1 - True';
	attributeTable.row := 2;
	attributeTable.inputType := Table.InputType_TextNumeric;
	attributeTable.row := 3;
	attributeTable.inputType := Table.InputType_TextNumeric;
	attributeTable.row := 4;
	attributeTable.inputType := Table.InputType_TextNumeric;
	attributeTable.row := 5;
	attributeTable.inputType := Table.InputType_ComboBox;
	attributeTable.comboList := '0 - False' &amp; Tab &amp; '1 - True';

	attributeTable.accessMode := Table.AccessMode_Sheet;
//
//	initialise the column table layout
//
	columnTable.show3D := transientTable.show3D;
	columnTable.borderStyle := transientTable.borderStyle;
	columnTable.columns := transientTable.columnHeadingArray.size();
	columnTable.accessMode := Table.AccessMode_Sheet;
	columnTable.inputType := Table.InputType_TextBox;
//
	columnTable.fontName		:=	transientTable.fontName;
	columnTable.fontSize		:=	transientTable.fontSize;
	columnTable.fontBold		:=	transientTable.fontBold;
	columnTable.fontItalic		:=	transientTable.fontItalic;
	columnTable.fontStrikethru	:=	transientTable.fontStrikethru;
	columnTable.fontUnderline	:=	transientTable.fontUnderline;
//
	columnHeading.fontName			:=	transientTable.fontName;
	columnHeading.fontSize			:=	transientTable.fontSize;
	columnHeading.fontBold			:=	transientTable.fontBold;
	columnHeading.fontItalic		:=	transientTable.fontItalic;
	columnHeading.fontStrikethru	:=	transientTable.fontStrikethru;
	columnHeading.fontUnderline		:=	transientTable.fontUnderline;
//
//	size form so that the columnTable is the same size as the actual table
//
	self.width := transientTable.width + (columnTable.left * 2) + 2;
	if self.width &lt; 480 then
		self.width := 480;
	endif;
	columnTable.width := transientTable.width;
	barLabel.width := self.clientWidth - (columnTable.left * 2);
end;</source>
    </JadeMethod>
    <JadeMethod name="initialiseMenuItems" id="dab5109b-6eb3-4df8-abca-f5aa48cbaed8">
        <updating/>
        <source>initialiseMenuItems() updating;

vars
	mi					: MenuItem;
	loopIndex			: Integer;
	s					: String;
begin
	loopIndex := 2;
	mi := mShowColumn.getMenuItem(loopIndex);
	while mi &lt;&gt; null do
		delete mi;
		loopIndex := loopIndex + 1;
		mi := mShowColumn.getMenuItem(loopIndex);
	endwhile;
//
	loopIndex := transientTable.columns;
	while loopIndex &gt; 1 do
		mi := mShowColumn.loadMenu(loopIndex);

		s:=transientTable.getCellText(1,loopIndex);
		s.replaceChar(Cr, ' ');
		s.replaceChar(Lf, ' ');		
		mi.caption := s;

		mi.visible := true;
		mi.checked := transientTable.columnVisible[loopIndex];
		loopIndex := loopIndex - 1;
	endwhile;
end;</source>
    </JadeMethod>
    <JadeMethod name="load" id="d2b2597b-37ce-4fd6-8c4c-206eddca8952">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

begin
	if self.transientTable.isInPainter() then
		centreWindow();

		alignControlArray.add(bAlignDefault);
		alignControlArray.add(bAlignLeft);
		alignControlArray.add(bAlignRight);
		alignControlArray.add(bAlignCentre);

		alignControlHeaderArray.add(bAlignDefaultH);
		alignControlHeaderArray.add(bAlignLeftH);
		alignControlHeaderArray.add(bAlignRightH);
		alignControlHeaderArray.add(bAlignCentreH);

		inputControlArray.add(bInputNone);
		inputControlArray.add(bInputCheckBox);
		inputControlArray.add(bInputTextBox);
		inputControlArray.add(bInputComboBox);
		inputControlArray.add(bInputNumericBox);

		self.initTable();
		self.loadTable();
//
		columnTable.row := 2;
		columnTable.column := 1;
		columnTable.rowColumnChg(columnTable);

	else

		self.resize();
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadTable" id="6b38e065-9ffa-4126-8e11-ad9a761ed12a">
        <updating/>
        <source>loadTable() updating;

vars
	loopIndex				: Integer;
	maxIndex				: Integer;
	format					: String;
	pos						: Integer;
begin
	maxIndex := transientTable.columnHeadingArray.size();
	loopIndex := 1;
	while loopIndex &lt;= maxIndex do
		columnTable.setCellText(1, loopIndex, convertToCrLf(transientTable.columnHeadingArray[loopIndex]));
		columnTable.setCellText(2, loopIndex, transientTable.columnHeadingArray[loopIndex]);

		columnTable.columnWidth[loopIndex] := transientTable.columnWidthArray[loopIndex];
		columnTable.column := loopIndex;
		columnTable.accessMode := Table.AccessMode_Column;
		if transientTable.columnVisibleArray[loopIndex][1:1] = '0' then
			columnTable.foreColor := Blue;
		else
			columnTable.foreColor := Black;
		endif;
		format := transientTable.columnAlignmentArray[loopIndex];
		pos := 1;
		transientTable.columnAlignmentArray[loopIndex] := format.cnEcNextDelimitedField('\',pos);
		columnTable.alignment := transientTable.columnAlignmentArray[loopIndex][1:1].Integer;
		columnTable.maxLength := transientTable.columnLengthArray[loopIndex];
		columnTable.accessMode := Table.AccessMode_Sheet;

		headerAlignmentArray.add(format.cnEcNextDelimitedField('\',pos));
		headerBoldArray.add(format.cnEcNextDelimitedField('\',pos) = 'true');
		if headerAlignmentArray[loopIndex][1:1].Integer &gt; 0 then
			columnTable.row := 1;
			columnTable.accessMode := Table.AccessMode_Cell;
			columnTable.alignment := headerAlignmentArray[loopIndex][1:1].Integer;
			columnTable.accessMode := Table.AccessMode_Sheet;
		endif;
		if headerBoldArray[loopIndex] then
			columnTable.row := 1;
			columnTable.accessMode := Table.AccessMode_Cell;
			columnTable.fontBold := true;
			columnTable.accessMode := Table.AccessMode_Sheet;
		endif;

		loopIndex := loopIndex + 1;
	endwhile;
	self.columnTable.column := 1;
	self.columnTable.rowHeight[1] := transientTable.columnHeight;
	self.columnTableResize();
end;</source>
    </JadeMethod>
    <JadeMethod name="mAlignCentre_click" id="78729bf4-55c9-4a7e-91f2-b876c7fa58de">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
