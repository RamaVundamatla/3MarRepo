	theRow	: Integer;

begin
	tbl 	:= self.getEditTableForSheet(self.fldEdit.topSheet.CMUI_Sheet);
	theRow 	:= tbl.getRowByControlName(textbox.name);
	tbl.setValue(theRow, textbox.text);
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
