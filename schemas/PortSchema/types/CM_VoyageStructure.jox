    <JadeMethod name="validateMe" id="4e4832d9-bcc9-4737-b151-0be3e49031c7">
        <source>validateMe(_passport : CM_Passport input);
//--------------------------------------------------
// Created:	01 February 2006 By: cnwgd1
// 
//27 Mar 2013	PJS		PAR # 31232
//--------------------------------------------------
vars

begin
	if self.myVoyage = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Voyage', null, null);
		app.raiseCMException(Input_required_field_voyage, null, null); // cnwdb2	PAR 35364
	endif;	

	/*    31232
	if self.type &lt;= StructureTypeNull
	or self.type &gt;= StructureTypeMax then
		app.raiseCMException1(REQUIRED_FIELD, 'Type', null, null);
	endif;	
	*/
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
