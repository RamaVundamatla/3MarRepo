    <JadeMethod name="btnClearAll_click" id="4fe433bf-0b89-4f49-a331-70f02bf1d1b4">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnClearAll_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		24 April 2009 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	chkAllSchemas.cnEcSet(false);
	chkSchemaText.cnEcSet(false);
	chkStrings.cnEcSet(false);
	chkPrimitives.cnEcSet(false);
	chkGlbConstants.cnEcSet(false);
	chkClassText.cnEcSet(false);
	chkMethodText.cnEcSet(false);
	chkPropertyText.cnEcSet(false);
	chkConstants.cnEcSet(false);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
