    <JadeMethod name="setComboValues" id="5c273c50-35e8-485f-8995-d815272cb63f">
        <source>setComboValues(_combo : ComboBox input; _params : CM_QueryCriteriaLineHolder; _queryOperator : CM_QueryOperator; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     06 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	comm			: CM_Commodity;
	commDict		: CM_CommodityByCodeDict;
begin
	_combo.clear();
	commDict := app.myRoot.allCommodities;
	
	foreach comm in commDict do
		_combo.itemObject[_combo.addItem(comm.code &amp; Tab &amp; comm.description)] := comm;
	endforeach;

	if CM_QStringLookup.hasInstance(_queryOperator) then
		_combo.listObject := commDict[_queryOperator.CM_QStringLookup.selectionValue];
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		_combo.listObject := commDict[_queryOperator.CM_QStringLookupNotEqual.selectionValue];	
	endif;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="28820b6f-e393-426d-8465-d740651d3ba0">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QStringIsOneOf; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	Bug 60595: Selector criteria built up incorrectly from release request

*/

vars
	comm			: CM_Commodity;
	commDict		: CM_CommodityByCodeDict;
	idx,
	selectionValue	: Integer;
begin
	
	_tbl.rows := _tbl.fixedRows;
	commDict := app.myRoot.allCommodities;
	
	foreach comm in commDict do
		selectionValue := 0;
		if _operator &lt;&gt; null and _operator.allSelectionValues.includes(comm.code) then
			selectionValue := 1;
		endif;
		idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; comm.code &amp; " - " &amp; comm.description);
		_tbl.accessRow(idx).itemObject := comm;
		_tbl.row := idx;
		_tbl.change(_tbl);
	endforeach;	
	
epilog

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QStringIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="b25f5cef-7c3b-4d07-9eab-ee0045d8d922">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/09/2023	navkc1	Bug 60595: Selector criteria built up incorrectly from release request

*/

vars
	comm	: CM_Commodity;
	str		: String;
	numRows,
	idx		: Integer;
	sa		: StringArray;
begin
	
	create sa transient;

	numRows := _tbl.rows;
	
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			comm := _tbl.accessRow(idx).itemObject.CM_Commodity;
			sa.add(comm.code);
		endif;
	endforeach;
	
	_op.setSearchValue(sa);
	
epilog
	delete sa;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="3382199d-ec80-430f-8b90-0f1e51934b6f">
        <source>translateToDisplayValue(_value: Any): String;
// ---------------------------------------------------------------------------
// Created:     06 March 2003		cnwth2	
//
// Purpose:  
// 32/02/2023	navkc1		Bug 56486: EUP - 1086 Error (Class of object is invalid in this context) when using "Commodity" as Search Criteria in the Selector part.   		 
// ----------   ----------  --------------------------------------------------
vars

begin
	if _value.isKindOf(CM_Commodity) then
		if _value &lt;&gt; null then
			return _value.CM_Commodity.code;
		else
			return null; 
		endif;
	else
		return _value.String; //23/02/2023	navkc1	#56486
	endif;
	return null;

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="2403586c-b19a-46db-8be8-806c3a7a5a47">
        <source>translateToSearchValue(_value: Any): Any;
// ---------------------------------------------------------------------------
// Created:     06 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
06 Oct 2008	cnwkpd1	PAR #18099 - Correct Selector query processing
22 Oct 2008	cnwkpd1	PAR #18348 - Prevent 1002 exceptions in Selector query processing with isOneOf

*/

vars
	invalidObj 		: Boolean;
	object			: CM_Commodity;
	returnVal		: String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			// PAR #18348
			return _value;
		endif;

		if _value.isKindOf(CM_Commodity) then
			object := _value.CM_Commodity;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.code;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="48905c45-830b-4f77-a649-a43a1728dc2b">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	commodity : CM_Commodity;

begin
	if _value.isKindOf(String) then
		commodity := app.myRoot.allCommodities[_value.String];
		if commodity &lt;&gt; null then
			return commodity.code;
		endif;
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
