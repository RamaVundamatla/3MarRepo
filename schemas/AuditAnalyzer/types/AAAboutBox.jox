    <JadeMethod name="btnOK_click" id="2eb6205b-d3cf-4038-bdd0-8c9230554264">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOK_click(btn: Button input) updating;

vars

begin
	unloadForm;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="3e86da35-e6fc-4d93-9339-4f0e6c295674">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;

vars

begin
	if keyCode = J_key_Escape then
		unloadForm;
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="load" id="52af75fc-b448-4b2c-996e-e354a2be5634">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
begin
	lblAppName.caption := "Audit Analyzer";
	lblDbPath.caption := app.dbPath;
	lblTitleLine2.caption := 'Release ' &amp; app.getSystemVersion;
	lblUserName.caption := app.userName;
	lblServer.caption := 'Server Platform is' &amp; CrLf &amp; node._getPlatformDetail;
	
	if IsUnicodeSystem then
		lblUnicodeOrAnsi.caption := 'Unicode Version';
	else
		lblUnicodeOrAnsi.caption := 'ANSI Version';
	endif;
	if app.isMultiUser
	and process.isUsingThinClient then
		lblUnicodeOrAnsi.caption := lblUnicodeOrAnsi.caption &amp; CrLf &amp; 'Multi User, ThinClient';
	elseif app.isMultiUser then
		lblUnicodeOrAnsi.caption := lblUnicodeOrAnsi.caption &amp; CrLf &amp; 'Multi User';
	elseif process.isUsingThinClient then
		lblUnicodeOrAnsi.caption := lblUnicodeOrAnsi.caption &amp; CrLf &amp; 'Thin Client';
	endif;

	lblLicenseInfo.caption := app._getCompanyName;

	centreWindow;
end;</source>
    </JadeMethod>
    <JadeMethod name="mskClose_click" id="93f7771a-d84d-4578-bd68-f78d200652fc">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
