    <JadeMethod name="getProposedVisiblity" id="d7c19c0e-e21e-433c-bd41-da108030b196">
        <source>getProposedVisiblity(_colour : Integer output): Boolean;
/*
Purpose:			
Date		Who		Reason
21 September 2011	cnwab1	Initial creation
*/

vars
	req : CM_RORORequest;
	slotLC : CM_ROROGCController;
	theTI : CM_TrackedItem;
begin
	_colour := White;

	slotLC := self.myGCController;
	foreach theTI in slotLC.allTrackedItems discreteLock do
		// if Load Rehandle or Export etc then show me
		if theTI.getImExStatus() &lt;&gt; TI_IMEX_STATUS_IMPORT then
			// PAR 31096 - DO not show discharge rehandles in proposed
			if (theTI.isRehandle or theTI.isSOB)	
			and not theTI.hasBeenLoadedToShip() then // PAR 31805 do show loaded rehandles in proposed.
				return false;
			endif;
					
			if theTI.isTranshipItem then
				if slotLC.myRORORequestDischarge &lt;&gt; null then
					if slotLC.myRORORequestDischarge.getTIofMode(REAL_MODE) = theTI then
					return false;
					endif;
				endif;
			endif;
			_colour := theTI.getDrawingColour(TI_ColourMode_DischargePort);
			return true;
		endif;
	endforeach;
	

	// Is colour coded and planned for load
	if not self.myGCController.allRequestsLoad.isEmpty()  then
		return self.myGCController.allRequestsLoad.first.getProposedVisiblity(_colour);
	endif;
	return false; // do not show is for an IMPORT

epilog

end;</source>
        <Parameter name="_colour" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getROROPlanningRemarks" id="b76dc199-99e6-4194-8aec-164be3c879da">
        <source>getROROPlanningRemarks(_isLoad :Boolean): String;
/*
Date		Who		Reason
01 Aug 2012	cnwcs5	Initial creation - par 29124
*/
vars
	lc		:CM_ROROGCController;
	request	:CM_RORORequest;
	layout	:CM_DeckItemLayout;
begin 
	lc := self.myGCController;
	
	if _isLoad then
		request := lc.myRORORequestLoad;
	else
		request := lc.myRORORequestDischarge;
	endif;
	
	if request = null then
		return null;
	endif;
	
	layout := request.myLayout;
	
	if layout = null then 
		return null;
	endif;
	
	return layout.remarks;	
epilog

end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="handleAllWLEsComplete" id="b54784f3-ed70-4eca-ab5c-ce07ca8763f3">
        <source>handleAllWLEsComplete(_isLoad : Boolean) : Boolean;
/*
Purpose:			Are ALL the WLES on this location completed?
Date				Who			Reason
November 2012		CNWAB1		Initial creation
*/


vars
	theReq : CM_RORORequest;
begin
	if _isLoad then
		theReq := self.myGCController.myRORORequestLoad;
	else
		theReq := self.myGCController.myRORORequestDischarge;
	endif;
	
	if theReq &lt;&gt; null then
		if theReq.isComplete then
			return true;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasColourCoding" id="bc41835f-fc60-4dd1-9104-41614dc2170a">
        <source>hasColourCoding(_type: Integer): CM_RORORequest;
/*
Purpose:			
Date		Who		Reason
27 September 2011	cnwab1	Initial creation
*/

vars

begin
	if _type = LOAD_MOVETYPE then
		return self.myGCController.myRORORequestLoad;
	elseif _type = DISCHARGE_MOVETYPE then
		return self.myGCController.myRORORequestDischarge;
	endif;
	
	return inheritMethod(_type);

epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="CM_RORORequest"/>
    </JadeMethod>
    <JadeMethod name="hasCompletedWLE" id="0392fdfb-c510-4af4-9e02-4a072982bced">
        <source>hasCompletedWLE(_isLoad: Boolean): Boolean;
/*
Purpose:			
Date		Who		Reason
20 June 2012	cnwab1	Initial creation
*/

vars

begin
	if _isLoad then
		if self.myGCController.myRORORequestLoad &lt;&gt; null then
//	PAR 30954		if self.myGCController.myRORORequestLoad.isComplete then
			if self.myGCController.myRORORequestLoad.hasWLEsOfMode(WLE_COMPLETED) then
			
				return true;
			endif;
		endif;
	else
		if self.myGCController.myRORORequestDischarge &lt;&gt; null then
			if self.myGCController.myRORORequestDischarge.isComplete then
				return true;
			endif;
		endif;
	endif;
	
	
	return false;

epilog

end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
