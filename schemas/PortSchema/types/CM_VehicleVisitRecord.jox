Return Value:		

Date		Who		Reason
27 August 2015	cnwndl1	Initial creation	Par 36777

*/

vars

	result : Date;
	vvrd : CM_VehicleVisitRecordDetail;
	
begin

	result	:= null;
	
	foreach vvrd in self.allVehicleVisitRecordDetails do
		if vvrd.recordType = VisitRecord_WayBillPrint then
			result	:= vvrd.timeStart.Date;
			break;
