        <source>btnSave_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:     29 July 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	prof     : JadeProfiler;
	folder   : String;
begin
	if process.isMohamed or process.isNavdap1 then
		folder := global.getJadeInstallDirServer().replace( CN_C_BIN, CN_C_MISC );
		prof   := process.profiler;	
		prof.methodCount := 20;
		if process.isMohamed then
			prof.fileName := folder&amp;"\MA" &amp; '\'  &amp;" - Road Gate - " &amp; app.actualTimeServer.getNumeralString() &amp; ".txt";
		elseif process.isNavdap1 then
			prof.fileName := folder&amp;"\DMP" &amp; '\'  &amp;"Road Gate - " &amp; app.actualTimeServer.getNumeralString() &amp; ".txt";
		endif;
		prof.clearMethodCache();
		prof.start;

	endif;
	
	// ### TFS  CR 64297 TASK 64299 28MAY2024 NAVAB1 self.doSave();
	self.doBaseFormSave(); // ### TFS  CR 64297 TASK 64299 28MAY2024 NAVAB1
epilog
	if prof &lt;&gt; null then
		prof.report();
	endif;

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
