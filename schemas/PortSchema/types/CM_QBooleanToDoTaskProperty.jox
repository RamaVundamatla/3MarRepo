<Class name="CM_QBooleanToDoTaskProperty" id="3623426f-ff68-48a6-9f2a-5b10fd8333f4">
    <superclass name="CM_QBooleanProperty"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <Constant name="PREFIX_NICE_NAME" id="db2df916-e840-4af9-ae34-3f19b45d5a89">
        <source>"ToDo- "</source>
        <type name="String"/>
    </Constant>
    <Constant name="PREFIX_PROPERTY_NAME" id="45da55d4-aaaa-4686-9985-f758d3f5b0a0">
        <source>'toDo- '</source>
        <type name="String"/>
    </Constant>
    <PrimAttribute name="toDoTaskCode" id="4ce43816-095b-4a47-9243-4621f6a7236c">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="getValueForObject" id="7cce636f-2747-4e19-bbb5-5f9a0abbfc5d">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Any;
// ---------------------------------------------------------------------------
// Created:     08 July 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	toDoArray			: CM_ToDoTaskArray;
	toDoTask			: CM_ToDoTask;
begin
	toDoArray := _obj.CM_TrackedItem.allToDoTasksToDo;
	foreach toDoTask in toDoArray do
		if toDoTask.toDoTaskDescCode = self.toDoTaskCode then
			return true;
		endif;
	endforeach;

	return false;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="isToDoTaskProperty" id="a788dd81-95fd-43a1-871e-e5a4f120d133">
        <source>isToDoTaskProperty():Boolean;
/*
Date		Who		Reason
09 November 2011	cnwcs5	Initial creation - par 28574
*/
vars

begin
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setup" id="86615de7-a376-4100-b917-ebf4c5ae1db7">
        <updating/>
        <source>setup(_task :CM_ToDoTaskDesc; _className :String)updating;
/*
Date		Who		Reason
09 November 2011	cnwcs5	Initial creation - PAR 28574
*/
vars
	strDesc	:String;
	intCode	:Integer;
begin
	strDesc := _task.shortDescription;
	intCode	:= _task.code;

	// don't let niceName property get to &gt; 30 characters
	// not sure why this is as the property length may be up to 50
	if strDesc.length &gt;= 24 then
		strDesc := _task.shortDescription[1:21] &amp; '...';
	endif;
	
	self.set(self.PREFIX_NICE_NAME &amp; strDesc, self.PREFIX_PROPERTY_NAME &amp; intCode.String, _className);
	
	if self.toDoTaskCode &lt;&gt; intCode then
		self.toDoTaskCode := intCode;
	endif;
	
	self.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
		
epilog

end;</source>
        <Parameter name="_task" type="CM_ToDoTaskDesc"/>
        <Parameter name="_className" type="String"/>
    </JadeMethod>
</Class>
