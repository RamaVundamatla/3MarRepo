	foreach idy in cgSuffix to cgSuffix + 3 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		
		if idy = 100 then
			ti1 := ti;
		elseif idy = 101 then
			ti2 := ti;
		elseif idy = 102 then
			ti3 := ti;
			restOfTIs.add(ti);
		else
			restOfTIs.add(ti);
		endif;
	endforeach;
	
	// ### All cargo should already have stops applied due to the stop criteria, Custom Status should be FREE
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(ti.hasStopOfType(stop),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied(1) - Should have stop " &amp; stop.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Customs), cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Applied(1) - Custom Status is Wrong, should be Customs");
	endforeach;

	// ### Now we cancel all stops from all cargo
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		beginLoad;
			pxyTI := ti.pxyCreateUpdateProxy();
		endLoad;
		allStops := pxyTI.getAllStops();
		pxyTI.setCustomsReference("UT_CLEAR");
		foreach pxyStop in allStops do
			delete pxyStop;
		endforeach;
		app.myTrxUA.trxUpdateTrackedItem(pxyTI, null,TI_UPDMODE_NORMAL, null, app.myPassport);
		delete pxyTI;
	endforeach;
	
	// ### Custom Status should be FREE
	foreach ti in cargoGroup1.allAssignedTrackedItems discreteLock do
		self.assertTrueMsg(not ti.hasStopOfType(stop),cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Cancel(1) - Should have stop " &amp; stop.code);
		self.assertTrueMsg(ti.getCustomsStatus() = app.getErrorString(CustomsStatus_Cleared), cargoGroup1.id &amp; "/" &amp; ti.id &amp; " Cancel(1) - Custom Status is Wrong, should be CLEARED");
	endforeach;
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteStopsTable(STOPID);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
epilog
	delete allTerminalArea;
	delete restOfTIs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tShippingLineStatus" id="e8eee3e0-5604-45ca-83d3-87b61c1b9bc7">
        <source>tShippingLineStatus();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//08/08/2023	navkc1	CR 59571   Task 59587: Jade - CustDocs Shipping Line Status UT

*/

constants
	ShipLineStatusID = "UTSHIPLINESTATUS";
	ShipLineStatusDesc = "UT Shipping Line Status Description";
	ShipLineStatusDescUpdate = "Updated UT Shipping Line Status Description";
	
vars
	pxyShipLineStatus,
	realShipLineStatus 		: CM_ShippingLineStatus;
	terminal				: CM_Terminal;
	type					: Integer;
	pxyShipLineStatCrit,
	realShipLineStatCrit	: CM_ShippingLineStatusCriteria;
	allCriteria 			: CMIF_Array;
	yaPurge 				: CM_ObjectSet;
	cmifCriteria 			: CMIF_YACriteriaPriority;
	yaCriteria 				: CM_YACriteria;
	criteriaType			: CM_YACriteriaType;
	cargoType				: CM_CargoType;
begin
	
	terminal := self.getMyTerminal();
	self.assertNotNull(terminal);
	
	// ======================================
	// Delete existing Shipping Line Status
	// ======================================
	realShipLineStatus := terminal.allShippingLineStatus[ShipLineStatusID];
	if realShipLineStatus &lt;&gt; null then
		self.deleteShipLineStatus(realShipLineStatus);
		realShipLineStatus := terminal.allShippingLineStatus[ShipLineStatusID];
		self.assertNullMsg(realShipLineStatus, "Shipping Line Status not deleted");
	endif;
	
	create pxyShipLineStatus transient;
	
	create yaPurge transient;
	create allCriteria transient;
	create yaCriteria transient;
	create pxyShipLineStatCrit transient;
	
	yaPurge.add(allCriteria);
	yaPurge.add(yaCriteria);
	yaPurge.add(pxyShipLineStatCrit);
	yaPurge.add(pxyShipLineStatus);
	
	// ======================================
	// Create Shipping Line Status Criteria
	// ======================================
	cargoType := app.myRoot.getCargoTypeFromAbbrev("CONT");
	
	cmifCriteria:= self.createYACriteria(YACriteriaType_CargoType, cargoType);
	
	yaPurge.add(cmifCriteria);
	allCriteria.add(cmifCriteria);

	
	// ======================================
	// Create Shipping Line Status
	// ======================================
	pxyShipLineStatCrit.setProxy(allCriteria, 999);
	pxyShipLineStatCrit.setProxyBaseData(terminal, pxyShipLineStatus);
	pxyShipLineStatus.setProxy(ShipLineStatusID, ShipLineStatusDesc, false, CM_ShippingLineStatus.Type_Exempt, pxyShipLineStatCrit, terminal);
	
	realShipLineStatus := self.addShippingLineStatus(pxyShipLineStatus);
	
	self.assertNotNullMsg(realShipLineStatus, "Shipping Line Status not created");
	self.assertEqualMsg(realShipLineStatus.code, ShipLineStatusID, "Shipping Line status Code not correct");
	self.assertEqualMsg(realShipLineStatus.description, ShipLineStatusDesc, "Shipping Line status Description not correct");
	self.assertEqualMsg(realShipLineStatus.myTerminal, terminal, "Shipping Line status Terminal not correct");
	self.assertEqualMsg(realShipLineStatus.notAvailForEntry, false, "Shipping Line status Not available for entry not correct");
	self.assertEqualMsg(realShipLineStatus.type, CM_ShippingLineStatus.Type_Exempt, "Shipping Line status Type not correct");
	
	realShipLineStatCrit := realShipLineStatus.myCriteria;
	self.assertNotNullMsg(realShipLineStatCrit, "Shipping Line Status criteria not created");
	self.assertEqualMsg(realShipLineStatCrit.myShippingLineStatus, realShipLineStatus, "Criteria myShippingLineStatus not correct");
	self.assertEqualMsg(realShipLineStatCrit.myTerminal, terminal, "Criteria myTerminal not correct");
	
	delete pxyShipLineStatCrit;
	delete pxyShipLineStatus;
	
	// ======================================
	// Create Shipping Line Status Duplicate ID
	// ======================================
	
	create pxyShipLineStatus transient;
	create pxyShipLineStatCrit transient;
	
	pxyShipLineStatus.setProxy(ShipLineStatusID, ShipLineStatusDesc, false, CM_ShippingLineStatus.Type_Exempt, pxyShipLineStatCrit, terminal);
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(ShipLineStatusCodeInUsed); 
	
	self.addShippingLineStatus(pxyShipLineStatus);
	
	self.assertEqualMsg(self.checkErrorWarningHasOccurred(), true, "Unexpected Shipping Line Status error");
	self.clearExpectedTrxErrors();
	
	delete pxyShipLineStatCrit;
	delete pxyShipLineStatus;
	
	// ======================================
	// Update Shipping Line Status
	// ======================================
	
	beginLoad;
	pxyShipLineStatus := realShipLineStatus.pxyCreateUpdateProxy();
	endLoad;
	
	// Remove all criteria
	pxyShipLineStatCrit := pxyShipLineStatus.myCriteria;
	delete pxyShipLineStatCrit;
	
	pxyShipLineStatus.setProxy(ShipLineStatusID, ShipLineStatusDescUpdate, true, CM_ShippingLineStatus.Type_NotExempt, pxyShipLineStatCrit, terminal);
	
	self.updateShippingLineStatus(pxyShipLineStatus);
	
	realShipLineStatus := self.getShippingLineStatus(ShipLineStatusID);
	self.assertNotNullMsg(realShipLineStatus, "Shipping Line Status is null");
	self.assertEqualMsg(realShipLineStatus.code, ShipLineStatusID, "Update Shipping Line status Code not correct");
	self.assertEqualMsg(realShipLineStatus.description, ShipLineStatusDescUpdate, "Update Shipping Line status Description not correct");
	self.assertEqualMsg(realShipLineStatus.myTerminal, terminal, "Update Shipping Line status Terminal not correct");
	self.assertEqualMsg(realShipLineStatus.notAvailForEntry, true, "Update Shipping Line status Not available for entry not correct");
	self.assertEqualMsg(realShipLineStatus.type, CM_ShippingLineStatus.Type_NotExempt, "Update Shipping Line status Type not correct");
	
	realShipLineStatCrit := realShipLineStatus.myCriteria;
	self.assertNullMsg(realShipLineStatCrit, "Shipping Line Status criteria should be null");
	
	// ======================================
	// Delete Shipping Line Status
	// ======================================
	
	self.deleteShipLineStatus(realShipLineStatus);
	realShipLineStatus := self.getShippingLineStatus(ShipLineStatusID);
	self.assertNullMsg(realShipLineStatus, "Shipping Line Status not deleted");
	
epilog
	if yaPurge &lt;&gt; null then
		yaPurge.purge();
		delete yaPurge;
	endif;
	
	delete pxyShipLineStatCrit;
	delete pxyShipLineStatus;

end;</source>
    </JadeMethod>
    <JadeMethod name="uCustDocs1000" id="ae47e7ed-18ad-4676-ba24-8c09e434910a">
        <updating/>
        <source>uCustDocs1000()updating;
/*
Purpose:			

Date		Who		Reason
08AUG2023	NAVAB1	 CR 56094 TASK 59616
*/

constants
	DODELETE = false; //  if TRUE this will purge all ownerships
	COOTOCREATE = 3;
	DTLTOCREATE = 5;
	IdPREFIX = "KLW";
	CGPrefix = "KM";
	BLKSTK = "OWN1";
	INCO = "abcd";
	CONTRACTID = "";
	VESSEL = "KLW";
	VOYAGE1 = "LW230804";
vars
	dateTimeCD,cdDT: TimeStamp;
	terminal : CM_Terminal;
	realCustDoc : CM_CustomDocument;
	realCustDocDetail : CM_CustomDocumentDetail;
	clearedWeight, clearedVolume, totalWeight, totalVolume : Decimal[23,4];
	clearedQuantity, totalQuantity : Integer;
	doDelete : Boolean;
	idx, idy,contractSeq : Integer;
	refrenceNum : String;
	ti	: CM_TrackedItem;
	cargoType : CM_CargoType;
	bs : CM_BlockStack;
	cargoId : String;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cargoOp : CM_Operator;
	opCode : String;
	tis : CM_TISet;
	cgId : String;
	cargoGroup : CM_CargoGroup;
begin
	
	terminal := self.getTerminal();

	doDelete := DODELETE;
	dateTimeCD.setFromYYYYMMDDHHmm("202307091215");
	cargoType := self.getCargoType("PULPPAPER"); // ALIG CANNON PULPPAPER
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	clearedWeight := totalWeight;
	clearedVolume := totalVolume;
	clearedQuantity := totalQuantity;
	bs := self.addBlockStack(BLKSTK, 999999, null);
	self.assertNotNull(bs);
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE1, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	
	if doDelete then
		self.deleteCustDocsForTerm();
	endif;
		

	cdDT := app.actualTimeAppServer();
	
	foreach idx in 1 to COOTOCREATE do
		contractSeq := idx;
		refrenceNum :=IdPREFIX &amp; dateTimeCD.date.year.String[3:2] &amp; dateTimeCD.date.month.String &amp; dateTimeCD.date.day.String &amp; contractSeq.padLeadingWith("0",2);
		
		if idx mod 50 = 0 then
			write refrenceNum;
		
		endif;
		// create cust doc
		realCustDoc := self.createCustDocHeader(refrenceNum);
		create tis transient;
		
		foreach idy in 1 to DTLTOCREATE do
			cargoId := IdPREFIX &amp; dateTimeCD.date.year.String[3:2] &amp; dateTimeCD.date.month.String &amp; dateTimeCD.date.day.String &amp; contractSeq. String &amp; "-" &amp; idy.padLeadingWith("0",2);
			
			ti := self.createGCOnVoyage(doDelete, CONTRACTID, cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, null);
			assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
			
			realCustDocDetail := self.createCustDocDetail(clearedWeight,clearedVolume,clearedQuantity,true,realCustDoc,ti);
			assertTrueMsg(realCustDocDetail &lt;&gt; null, "Cust Detail is null, Cust Detail not created");

			tis.add(ti);
		
		
		endforeach;
		
		// ### TFS CR 59942 TASK 59943 23AUG2023 NAVAB1
		cgId := CGPrefix &amp; dateTimeCD.date.year.String[3:2] &amp; dateTimeCD.date.month.String &amp; dateTimeCD.date.day.String &amp; contractSeq.padLeadingWith("0",2);
		self.deleteCargoGroup(cgId);
		cargoGroup := self.addCargoGroup(cgId,tis);
		delete tis;
	endforeach;
epilog
	
	delete tis;
end;</source>
    </JadeMethod>
    <JadeMethod name="updateCustDocStatus" id="7cdb1761-bba5-4a86-b56e-9d9195b8db31">
        <source>updateCustDocStatus(_custDocHeader : CM_CustomDocument input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2023 navmv20 CR 60425 Task 60987: Jade - Cust Doc Cancellation TRX

*/

vars

begin
	app.myTrxUA.trxUpdateCustDocCancellation(_custDocHeader,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(_custDocHeader.status,CM_CustomDocument.Status_Cancelled);
epilog

end;</source>
