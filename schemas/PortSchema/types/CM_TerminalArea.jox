    <JadeMethod name="hasAvailableMatchingTI" id="2a2a0f00-dd2a-4f2a-ae15-10d0f18a79b8">
        <source>hasAvailableMatchingTI( _yaRequest : CMIF_YARequest) : Boolean;

/*

Purpose:	To find a matching free box to the _yaRequest parameters	
1. We get all the tracked items in the terminal area.
2. Remove those that are already queued	
3. Then step through all the queued unactioned director tasks in allRTQueueTasks removing matches
4. Test those left against the CMIF if we find a match then were all good.

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwrd1	Initial creation

*/

vars
	result 			: Boolean;
	tiSet,
	tiSetNFM		: CM_TIArray;
	ti 				: CM_TrackedItem;
	iter 			: Iterator;
	rtqTask			: CM_RTQueueTask;
	aRequest		: CM_Request;
	agent  			: CM_YAAutoplanAgent;
	tmpRequest 		: CMIF_YARequest;
	rtEntry 		: CM_RTQueueEntry;
	invalidTI 		: Boolean; 
	removedStr		: String;
	yareq 			: CMIF_YARequest;
begin
	
	on Exception do app.handleDeletedObject(exception, ti, invalidTI);  // nuts but needed in dev.

	result := false; //I know but lets set it anyhow.
	
	create tiSet transient;
	create tiSetNFM transient;
	yareq :=_yaRequest;
	
	agent := app.myYAAgent;
	if agent = null then
		// have to create... !?!		
	endif;
	
	//19 Jan 2011	NDL	Par 26779
	if agent.myCurrentCMIFYAAutoPlan = _yaRequest then
		agent.setCurrentYAAutoPlanToNull();	// so it doesn't get deleted when tmpRequest is set there
	endif;
	
	create tmpRequest transient;
	//if we are looking at the whole TA:	// should be only doig this here now	
	// get allt he ti's for the TA
	self.getTIs(tiSet, REAL_MODE);		
	
	foreach ti in tiSet do	
		if not ti.isQueued then	
			if _yaRequest.operatorCode = null or _yaRequest.operatorCode = ti.operatorCode  then
				if ti.releaseRequest &lt;&gt; null and ti.releaseRequest &lt;&gt; _yaRequest.myDeliveryRequest then  //make sure we are not on another release request!
					continue;
				endif;
				tiSetNFM.add(ti); //add them to the collecton
			endif;
		endif;
		
	endforeach;

	//now look through our allRTQueueTasks dict and find all unactioned director tasks	
	iter :=self.allRTQueueTasks.createIterator;	
	self.allRTQueueTasks.startKeyGeq( TASK_DIRECTOR, TASK_UNACTIONED ,iter);
	while iter.next(rtqTask) do
	
		if rtqTask.status &lt;&gt; TASK_UNACTIONED or rtqTask.taskType &lt;&gt; TASK_DIRECTOR then
			break;
		endif;
		//due to machine rules we may have more than one rtq task per move so we need to filter out some
		rtEntry := rtqTask.myEntry;	
		if rtEntry.getPreviousRelatedEntry() &lt;&gt; null then //epr par 35702 CCMS 2457 17/2/15
			// we are not the first part of the move so we can skip
			continue;
		endif;
		
		// should be processing unactioned director tasks here.
		
		// for each one we try to find a matching cargo item in tiSetNFM and if so we remove it.
		
		aRequest := rtqTask.myEntry.getMyRequest();	
		//if aRequest = null or not aRequest.isKindOf(CM_DeliveryRequest) then  // do we care what kind of request it is here? for YArequest?
		if aRequest = null or (not aRequest.isKindOf(CM_DeliveryRequest) and not aRequest.isKindOf(CM_SlotRequest)) then		// 03/08/2010 cnwmh5 #25169
		//if aRequest = null then
			// no request, or not delivery request so pass on
			continue;
		endif;
		
		// ok need to find and remove the first matching ti in tiSetNFM
		
		tmpRequest.clear();
		// 03/08/2010 cnwmh5 #25169 - Start
		if aRequest.isKindOf(CM_DeliveryRequest) then
			tmpRequest.initializeFromDeliveryRequest(aRequest.myTerminal, aRequest.CM_DeliveryRequest);		
		elseif aRequest.isKindOf(CM_SlotRequest) and aRequest.isBulkRelease then
			tmpRequest.initializeFromBulkRelease(aRequest.myTerminal, aRequest);		
		endif;
			
		agent.setCurrentYAAutoPlan(tmpRequest);  	
		foreach ti in tiSetNFM do
							
			if ti.testAutoPlanRequestYA(agent) then
				//found a match
				tiSetNFM.remove(ti);
				removedStr := removedStr &amp; CrLf &amp; ti.id &amp; 
					" is not available as it has already been allocated to a Director Task (" &amp; rtqTask.tiId &amp; ") on queue - " &amp; rtqTask.queueId;  // 23/12/2010 cnwmh5 - logging
				break;
			endif;		
		endforeach;
		
	endwhile;

	on Exception do app.handleDeletedObject(exception, tmpRequest, invalidTI); //+cnwas3 -&gt; follow up on "07 Jan 2011 NDL -unit test leak"
	// now we have all the ti's that are left available , need to find one that matches the CMIF
//	agent.initialise();
	agent.setCurrentYAAutoPlan(_yaRequest);   // this all I need to do?
	if removedStr &lt;&gt; null then	//16 Jun 2015	NDL	Par 36338
		agent.addLogEntry(AP_Log_YA_Default,removedStr &amp; CrLf, false);			// 23/12/2010 cnwmh5 - logging
	endif;
	
	foreach ti in tiSetNFM do			
		if ti.testAutoPlanRequestYA(agent) then
			//found a match		
			result := true;	
			// cnwrd1 if we are using best pic autop[lan we want to find out if we havea ti grid object and set it so we reserve at a go level.
			if _yaRequest.myGridObject = null and ti.myTerminal.isAutoPlanUseBestPickDirector then		
				yareq.myGridObject := ti.getMyCurrentGridObject();
			endif;
			break;
		endif;		
	endforeach;

	return result;
	
epilog
	delete iter;
	delete tiSet;
	delete tiSetNFM;
	delete tmpRequest;	// 07 Jan 2011	NDL	-unit test leak;
end;</source>
        <Parameter name="_yaRequest" type="CMIF_YARequest"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
