    <JadeMethod name="moveTrackedItemTarget" id="9cc15325-2435-42d4-903e-135f2b468de1">
        <updating/>
        <source>moveTrackedItemTarget(pToLocation : CM_LocationsController) updating; 
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
29/07/2015			cnwdap1		PAR #36589 If TI is a Rehandle, set the move controller as a rehandle move
21/05/2019			jlgzm1		TFS 42840 MSL Direct Release between Voyages and Rail
05/07/2019			jlgzm1		TFS 42863 MSL Direct Release between Voyages and Rail - BreakBulk
30/07/2019			jlgzm1		TFS 42863 MSL Direct Release between Voyages and Rail - BreakBulk
*/

vars
	moveController	: CMIF_MoveController;
	theSource, theTarget : CM_LocationsController;
	theSlotController : CM_VoyageROROController;
	theSlotRequest : CM_RORORequest;
	result,theSize, theSelected	: Integer;
	additionalLocations : CM_LCArray;
	theWLE 	: CM_WorkListEntry;
	theTI	: CM_TrackedItem;
	yWLE 	: CM_YardWLE; // tfs42840
	origWLE : CM_WorkListEntry; // TFS 42863
begin
	self.mousePointer := Window.MousePointer_HourGlass;

	moveController := app.myMoveController;

	if moveController = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'app.myMoveController = null');
		return;
	endif;
	theTI := moveController.myTrackedItem;
	if theTI = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'app.myMoveController.myTrackedItem = null');
		return;
	endif;
	
	if theTI.myTerminal &lt;&gt; self.myTerminal then
		app.raiseCMException2(ERR_TERMINAL_TRANSFER, theTI.myTerminal.code, self.myTerminal.code, null, null);
		return;	
	endif;
	
	moveController.setMyToPrimaryLocation(pToLocation);
	if not self.moveTrackedItemTargetValidate(moveController,pToLocation) then
		return;
	endif;

	if moveController.myWorkListEntry &lt;&gt; null then					//tfs42863
		// this method is only called after a drag drop to this form
		// if the form has been passed a WLE, then assume we must
		// be a direct release move then
		moveController.isDirectReleaseMove := true;					//tfs42863
		
		if moveController.myWorkListEntry.isKindOf(CM_YardWLE) then	//tfs42840
			yWLE := moveController.myWorkListEntry.CM_YardWLE;		//tfs42840
			// if TI is splittable, then need to determine how much to move
			if theTI.canMergeBreakBulk and							//tfs42863
		       moveController.moveMode = PLANNING_MODE then			//tfs42863
				if not self.myAssistant.showMoveAmountForm(moveController) then //tfs42863
					return;											//tfs42863
				endif;
			endif;
		endif;
	endif;
	
	theSlotRequest := moveController.myVoyageRequest.CM_RORORequest;
	// save these away incase this is a ship DLR that is auto linked
	if theSlotRequest &lt;&gt; null then
		//if theSlotRequest.isRehandle then																		// PAR #36589
		if theSlotRequest.isRehandle or theTI.isRehandle or theTI.isROBPlannedBackToShip(moveController) then	// PAR #36589
			theTarget := moveController.myOriginatingLocation;
			theSource := moveController.myToPrimaryLocation;
			moveController.isRehandleMove := true; // see CMIF_MoveController::setMyToSecondaryLocations
		else
			if moveController.isMoveAnExportRePlan() then
				if moveController.isDirectReleaseMove and
				   moveController.myWorkListEntry &lt;&gt; null and
				   moveController.myWorkListEntry.getDRLinkedWLE = null then
					// TI thought is was a replan, but WLE says otherwise
					theWLE := theSlotRequest.getFirstUnusedWLE();
					if theWLE = null then // PAR 16341
						app.msgBox(This_move_cannot_confir_please.String &amp; " " &amp; app.getErrorString(This_move_cannot_confir_please),app.getErrorString(Move_problem), MsgBox_OK_Only);
						return;
					endif;
					moveController.isReplanAnExport := false; 
					moveController.isReplan := false; 
					moveController.setMyWorkListEntry(theWLE);
					moveController.myDDWorkListEntry := yWLE;						//tfs42840
			    
			    else 
					theWLE := theSlotRequest.getWLEForTI(theTI);
					if theWLE = null then // PAR 16341
						//check for direct release wle
						if moveController.isDirectReleaseMove then
							if moveController.myWorkListEntry.isKindOf(CM_VoyageWLE) then
								theWLE := moveController.myWorkListEntry;
							else
								theWLE := moveController.myWorkListEntry.getDRLinkedWLE;
							endif;
						else
							app.msgBox(This_move_cannot_confir_please.String &amp; " " &amp; app.getErrorString(This_move_cannot_confir_please),app.getErrorString(Move_problem), MsgBox_OK_Only);
							return;
						endif;
						
					else	//09 Dec 2019	NDL	TFS 46875
						if theTI.myCargoType.allowDuplicates then
							app.raiseCMException3(TI_Already_QueudPlanned_Here, theTI.id,app.getErrorString(Planned), moveController.myToPrimaryLocation.getID, null, theTI);
							return;	
						endif;
					
					endif;
					// switch the slot req to the one on the target so that the TI will be added to the correct job
					theSlotRequest := moveController.myToPrimaryLocation.CM_VoyageROROController.myRORORequestLoad;
					moveController.myVoyageRequest := theSlotRequest;
					moveController.isReplanAnExport := true; 
					moveController.isReplan := true; 
					moveController.setMyWorkListEntry(theWLE); // AKB2004AUG. As part of this we need this to be the 'old' wle so that later we can unassign from it
					moveController.setMoveIndex(theTI.allPlannedFutureMoves.indexOf(theWLE.myFutureMove)); // AKB2004AUG
					moveController.setMyOriginatingLocation(theTI.getPrimaryLocation(PLANNING_MODE)); // AKB2004AUG
				endif;
			else
				theWLE := theSlotRequest.getFirstUnusedWLE();
				if theWLE = null then // PAR 16341
					app.msgBox(This_move_cannot_confir_please.String &amp; " " &amp; app.getErrorString(This_move_cannot_confir_please),app.getErrorString(Move_problem), MsgBox_OK_Only);
					return;
				endif;
				moveController.isReplanAnExport := false; 
				moveController.isReplan := false; 
				moveController.setMyWorkListEntry(theWLE);
				moveController.myDDWorkListEntry := yWLE;						//tfs42840
			endif;		
		endif;
		
	endif;

	origWLE := moveController.myWorkListEntry; // TFS 42863 
	while true do
		app.myTrxUA.trxMoveTrackedItemAssignToJob(moveController, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Move_it), app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				moveController.allOtherWLEs.clear(); // PAR 21148 if get warning from TRX then extra WLEs from a multi break bulk move are left as invalid objects.
				
				// trxMoveTrackedItemAssignToJob used to reset myWorkListEntry in epilog
				// have had to move it up a level in case wle gets deleted during transaction
				if origWLE &lt;&gt; null then							// TFS 42863
					moveController.setMyWorkListEntry(origWLE);	// TFS 42863
				endif;											// TFS 42863
				
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		break;
	endwhile;
	
epilog
	delete additionalLocations;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="pToLocation" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="moveTrackedItemTargetValidate" id="8a6ee41e-78d5-422d-9127-6507400480cf">
        <source>moveTrackedItemTargetValidate(_moveController: CMIF_MoveController input; _toLocation : CM_LocationsController): Boolean;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/

vars
	additionalLocations : CM_LCArray;
	theSelected, result, theSize : Integer;
	tmpObj				: Object;
	tmpDrawController	: SHP_ROROPlanDrawingController;
begin

	tmpDrawController := self.myROROPlanDrawController;

	create additionalLocations transient;
	foreach tmpObj in tmpDrawController.allSelectedObjects do
		if (not tmpObj.isKindOf(CM_VoyageROROController)) then
			continue;
		endif;
		additionalLocations.add(tmpObj.CM_VoyageROROController);
	endforeach;
	theSelected := additionalLocations.size;
	theSize := _moveController.allOtherTrackedItems.size;
	theSize := theSize + 1;

	// more than 1 TI to move
	if theSize &gt; 1 then
	

		result := app.msgBox(app.getErrorString2(Want_move_items_cargo_single,theSize.String,_toLocation.getFullId),app.getErrorString(Confirm_multi_move_single), MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		if result = MsgBox_Return_No then
			return false;		
		endif;
	else
		// this is used for BREAK BULK. 1 Break bulk item in yard to many slots on ship
		if theSelected &gt; 1 and theSize = 1 then
			_moveController.setMyToSecondaryLocations(additionalLocations);
		endif;
	endif;

	return true;

epilog
	delete additionalLocations;

end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_toLocation" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
