    <JadeMethod name="getKPICounter" id="5b1b42d5-60d9-4102-8517-602a5c39e8f7">
        <updating/>
        <source>getKPICounter() updating, protected;
/*

Date		Who		Reason
09 July 2015	cnwer1	Initial creation PAR 36624

*/

vars
	startMonth 	: TimeStamp;
	endMonth 	: TimeStamp;
	date  : Date;
	time : Time;
begin

	if self.myKPICounter &lt;&gt; null then
		delete self.myKPICounter;
	endif;

	date.setDate(1, self.referenceTimeStamp.month,self.referenceTimeStamp.year);
	time:= null;
	startMonth.setDate(date);
	startMonth.setTime(time);
	
	endMonth:=startMonth;
	endMonth:=endMonth.addMonths(self.monthsSpan);

	create self.myKPICounter transient;
	self.myKPICounter.setDetails(self.myTerminal, startMonth,endMonth,self.cargoTypes );
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getKPITotalsPerDays" id="1953855c-c769-42b4-a011-b039fad19000">
        <source>getKPITotalsPerDays(_day : TimeStamp; 
					_cargoType : CM_CargoType;
					_idxDay : Integer);
/*

Date		    Who			Reason
04 October 2010	cnwas3	  Initial creation

*/


vars	
	kpiDay 					: CMIF_KPICounterDay;
	kpiCargoType 			: CMIF_KPICounterCargoType;
	kpiMonth 				: CMIF_KPICounterMonth;
begin	
	//epr par 36624 16/4/15
	kpiCargoType:=self.myKPICounter.allKPICounterCargoTypes[_cargoType];
	if kpiCargoType = null then
		return;
	endif;
	kpiMonth:=kpiCargoType.allKPICounterMonths[_day.date.year,_day.date.month];
	if kpiMonth = null then
		return;
	endif;
	kpiDay:=kpiMonth.allKPICounterDays[_day.date.day];
	if kpiDay = null then
		return;
	endif;
	
	if  _cargoType.isContainer then
		self.setKPICargoTypeStatsCont(kpiDay,_idxDay);	
	else
		self.setKPICargoTypeStatsGC(kpiDay,_idxDay);
	endif;
epilog
	
end;</source>
        <Parameter name="_day" type="TimeStamp"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_idxDay" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getKPITotalsPerMonths" id="d2dd310d-456d-478d-a265-debe7bb25f21">
        <source>getKPITotalsPerMonths(	_month : TimeStamp; 
						_cargoType : CM_CargoType;
						_idxMonth : Integer);
/*

Date		Who		Reason
30 Sep 2010	cnwas3	Initial creation
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars	
	kpiCargoType 			: CMIF_KPICounterCargoType;
	kpiMonth 				: CMIF_KPICounterStat;
begin	
	kpiCargoType:=self.myKPICounter.allKPICounterCargoTypes[_cargoType];
	if kpiCargoType = null then
		return;
	endif;
	kpiMonth:=kpiCargoType.allKPICounterMonths[_month.date.year,_month.date.month];
	if kpiMonth = null then
		return;
	endif;
	
	if  _cargoType.isContainer then
		self.setKPICargoTypeStatsCont(kpiMonth,_idxMonth);
	else
		self.setKPICargoTypeStatsGC(kpiMonth,_idxMonth);
	endif;	
	
epilog
		
end;</source>
        <Parameter name="_month" type="TimeStamp"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_idxMonth" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSelectedCellsTIs" id="56b6cb77-2215-4e95-8efd-f07ccec937ec">
        <source>getSelectedCellsTIs(_tiSet : ObjectArray input);
/*

Date		    Who			Reason
10 October 2010	cnwas3	  Initial creation

*/

vars
	numRows,numCols,i,j : Integer;
	cell 				: JadeTableCell;
	rowHeader,contHeader: String;
	index 				: Integer;
	contLength			: Integer;
	obj 				: Object;
begin
	if _tiSet = null then 
		return;
	endif;
	
	_tiSet.clear();

	numRows := self.tblCargoCounter.rows;
	numCols := self.tblCargoCounter.columns - 1;

	foreach i in 2 to numRows do
		rowHeader:=self.tblCargoCounter.accessCell(i,1).text;
		foreach j in 2 to numCols do
			cell := self.tblCargoCounter.accessCell(i,j);
			if not cell.selected then
				continue;
			endif;
			if cell.text = null then
				continue;
			endif;
			obj:=cell.itemObject;
			if obj = null then
				continue;
			endif;		
			//epr par 36624 16/4/15
			if obj.isKindOf(CMIF_KPICounterStat) then
				if obj.CMIF_KPICounterStat.isForContainer then
					index:=1;
					contHeader := rowHeader.cnEcGetNextWord(index);
					if contHeader = app.getErrorString(Other) then
						contLength := NULL_INTEGER;
					else					 
						contLength :=rowHeader[1:2].asIntegerJMT();
					endif;
					obj.CMIF_KPICounterStat.getAllTIsForLength(contLength,_tiSet);
				else
					obj.CMIF_KPICounterStat.allTIs.copy(_tiSet);
					
				endif;
			endif;
		endforeach;
	endforeach;
epilog

end;</source>
        <Parameter name="_tiSet" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="f2fa7206-266b-488f-a2ac-6d0bd58f2deb">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Date		    Who			Reason
09 November 2010	cnwas3	  Initial creation

*/

vars
	theXML 				: String;
	
begin
	theXML := inheritMethod();
	theXML := theXML &amp; global.formatAsXML(XML_CTYPE,self.xmlColourCargoType.asStringJMT());
	theXML := theXML &amp; global.formatAsXML(XML_CTOT,self.xmlColourTotals.asStringJMT());
	theXML := theXML &amp; global.formatAsXML(XML_RC,self.xmlColourRowColour.asStringJMT());
	theXML := theXML &amp; global.formatAsXML(XML_ARC,self.xmlColourAltRow.asStringJMT());	
	
	return theXML;

epilog
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSetup" id="804afe24-9f65-425a-8044-0ff3f4fbb734">
        <updating/>
        <source>getXMLSettingsForSetup() updating;
/*

Date		    Who			Reason
09 November 2010	cnwas3	  Initial creation

*/

vars
	userWindow		: CM_UserWindow;
	theXML, xmlValue : String;
begin

	userWindow := app.getUserWindow(self.name, false);
	
	if userWindow = null then
		self.xmlColourTotals := 10461087;			//cnwas3 par 27658
		self.xmlColourCargoType := 15000538;
		self.xmlColourRowColour := 13232616;
		self.xmlColourAltRow := 14155775;
		return;
	endif;
	theXML := userWindow.xmlInfo;
	
	if self.xmlColourTotals = null then
		xmlValue := theXML.cnEcGetTagValueOfName(XML_CTOT);	
		if xmlValue &lt;&gt; null then
			self.xmlColourTotals := xmlValue.asIntegerJMT();
		else
			self.xmlColourTotals := 10461087;
		endif;
	endif;
	
	
	if self.xmlColourCargoType = null then
		xmlValue := theXML.cnEcGetTagValueOfName(XML_CTYPE); 
		if xmlValue &lt;&gt; null then
			self.xmlColourCargoType := xmlValue.asIntegerJMT();
		else
			self.xmlColourCargoType := 15000538;
		endif;
	endif;
	
		
	if self.xmlColourRowColour = null then
		xmlValue := theXML.cnEcGetTagValueOfName(XML_RC); 
		if xmlValue &lt;&gt; null then
			self.xmlColourRowColour := xmlValue.asIntegerJMT();
		else
			self.xmlColourRowColour := 13232616;
		endif;
	endif;
	
	
	if self.xmlColourAltRow = null then
		xmlValue := theXML.cnEcGetTagValueOfName(XML_ARC); 
		if xmlValue &lt;&gt; null then
			self.xmlColourAltRow := xmlValue.asIntegerJMT();
		else
			self.xmlColourAltRow := 14155775;
		endif;	
	endif;
 
epilog
	
end;</source>
    </JadeMethod>
