    <JadeMethod name="setForUpdateStructure" id="e9abd476-a364-4540-a4dd-1d19b525b072">
        <updating/>
        <source>setForUpdateStructure(_deleteStructure : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		July 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
//modified : cnwas3 par23950 29/04/2010
// 07/07/2011	cnwcs5	CCMS MES 2084/par 27317 - remove unused parameters/local variables
