    </JadeMethod>
    <JadeMethod name="is40FooterForReports" id="b436d07b-160d-4723-bf44-e60d4711f38f">
        <source>is40FooterForReports() : Boolean;
// ---------------------------------------------------------------------------
// Created:		26 May 2008 By cnwvu1
//
// Purpose:		Defines whether 40 and 30,45,53 footers should be included for
//				the CM_VoyageJobSeq[Med/Large/LargeLandscape] reports.
//					for 40' returns true;
//					for 30', 45' and 53' - considers as 40' and returns true 
//						if they haven't got	their own column 
//						or aren't included as part in the Other column
// ---------------------------------------------------------------------------

vars
	isOwn : Boolean;
	
begin

	if self.getAttrIs40() then
		return true;
	endif;
	
	if self.getAttrIs30() and not app.is30IncludedForReportsAsColumn( isOwn ) then
		return true; // it has no own/other column, so include into the 40' column
	endif;

	if self.getAttrIs45() and not app.is45IncludedForReportsAsColumn( isOwn ) then
		return true; // it has no own/other column, so include into the 40' column
	endif;

	if self.getAttrIs53() and not app.is53IncludedForReportsAsColumn( isOwn ) then
		return true; // it has no own/other column, so include into the 40' column
	endif;
	
	return false;
	
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
