// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.validateMe;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="c5445293-84a9-4334-9831-d7f8660be1b6">
        <source>validateForDelete();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theString : String;
begin
	if self.allVoyageHatchLidJobs.isEmpty = false then
		if self.allBays.isEmpty = false then
			theString := ' Hatch Lid ' &amp; self.allBays.first.allHatchLids.indexOf(self).String ;
		else
			theString := ' The Hatch Lid ';
		endif;
		if self.allVoyageHatchLidJobs.size = 1 then
			theString := theString &amp; " Has A Hatch Lid Job. Remove this First";
		else
			theString := theString &amp; " Has " &amp; self.allVoyageHatchLidJobs.size.String &amp; " Hatch Lid Jobs. Remove these First";
		endif;
		app.raiseCMException1(ERR_DELHATCHLID, theString, null, null);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="12c59a10-d08e-450f-943e-a7dbe6528555">
        <source>validateForUpdate();
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
