    <JadeMethod name="addVesselTank" id="183086d8-f5e5-4c08-82f8-a0bddd5eb19a">
        <source>addVesselTank(_vesselStructure :  CM_VesselStructuralElements; _code : String; _type : CM_VesselTankContentsType) : CM_VesselTank;
// ---------------------------------------------------------------------------
// Created:     27 January 2014 by NAVAB1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	
	pxyTank, realTank : CM_VesselTank;
	
	description,
	remarks  :String;

begin
	create pxyTank as CM_VesselTankVessel transient ;
	

	description :="Tank description";
	remarks:="Some Tank remarks blah blah blah";
	
	pxyTank.setProxy(_code,description,remarks,0,_type);

	pxyTank.CM_VesselTankVessel.setMyVesselStructElements(_vesselStructure);
	
	app.myTrxCA.trxCreateVesselTank(pxyTank,realTank,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNullMsg(realTank,"realTank is null");
	self.assertTrueMsg(realTank.isKindOf(CM_VesselTankVessel), "realTank is kindOf CM_VesselTankVessel");
	

	

	
	return realTank;
epilog
	delete pxyTank;
end;</source>
