<Class name="CM_TCPInterfaceController" id="11ab6001-423a-4468-9a39-67a7eaf14fa5">
    <superclass name="CM_InterfaceController"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>CCMS JMTCP01 1024 - Voice Recognition

This class implements the initiator application for the TCP listener service.

Will examine command line for jade.exe, and initiate the required number of workers.</text>
    <DbClassMap file="mobileServer"/>
    <ImplicitInverseRef name="myInterfaceDefinition" id="ff37a17e-547b-49be-bc5f-350c214e95e8">
        <embedded/>
        <type name="CM_TCPInterfaceDefinition"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="start" id="30f2668d-6a34-462e-b23c-7af5bde5856d">
        <updating/>
        <source>start() updating;

/*

Purpose:			Start up the TCP Listener initiator application.
					Will interrogate the command line and start the required number of 
					TCP Worker apps

Parameters:			None

Return Value:		None


Date		Who		Reason
03 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

constants
	TerminalString	= "Terminal='";
	InterfaceString	= "Interface='";
	
vars
	terminalName,
	interfaceName,
	userData		: String;
	pos,
	noCopies,
	i				: Integer;
	
	terminal		: CM_Terminal;
	interface		: CM_InterfaceDefinition;
	
begin
	inheritMethod();

	userData := app.getUserCommandLine(true);
	
	app.writeLog('Initializing ' &amp; app.name &amp; ' with (' &amp; userData &amp; ')', LogINFO);	//25 Nov 2019	NDL	TFS 47053

    pos := userData.pos(TerminalString, 1);
	if pos = 0 then
		app.writeLog('Error - "' &amp; TerminalString &amp; '" not found on command line (' &amp; userData &amp; ')', LogFATAL);	//26 Nov 2019	NDL	TFS 47053
		terminate;
		return;
	endif;
	
	pos := pos + TerminalString.length;
	if pos &lt;= userData.length then
		terminalName := userData.scanUntil("'", pos).trimBlanks;
	endif;
	if terminalName = null then
		app.writeLog('Error - Terminal name is null (' &amp; userData &amp; ')', LogFATAL);	//26 Nov 2019	NDL	TFS 47053
		terminate;
		return;
	endif;
	
	terminal := app.myRoot.allTerminals[terminalName];
	if terminal = null then
		app.writeLog('Error - Terminal not found (' &amp; terminalName &amp; ')', LogFATAL);	//26 Nov 2019	NDL	TFS 47053
		terminate;
		return;
	endif;
	
    pos := userData.pos(InterfaceString, 1);
	if pos = 0 then
		app.writeLog('Error - "' &amp; InterfaceString &amp; '" not found on command line (' &amp; userData &amp; ')', LogFATAL);	//26 Nov 2019	NDL	TFS 47053
		terminate;
		return;
	endif;
	
	pos := pos + InterfaceString.length;
	if pos &lt;= userData.length then
		interfaceName := userData.scanUntil("'", pos).trimBlanks;
	endif;
	if interfaceName = null then
		app.writeLog('Error - Interface name is null (' &amp; userData &amp; ')', LogFATAL);	//26 Nov 2019	NDL	TFS 47053
		terminate;
		return;
	endif;
	
	interface := terminal.allInterfaceDefinitions[interfaceName];
	if interface = null then
		app.writeLog('Error - Interface not found for Terminal ' &amp; terminalName &amp; ' (' &amp; interfaceName &amp; ')', LogFATAL);	//26 Nov 2019	NDL	TFS 47053
		terminate;
		return;
	endif;

	if not interface.isKindOf(CM_TCPInterfaceDefinition) then
		app.writeLog('Error - Interface ' &amp; interface.name &amp; ' is not a TCP interface', LogFATAL);	//26 Nov 2019	NDL	TFS 47053
		terminate;
		return;
	endif;
	
	self.myInterfaceDefinition := interface.CM_TCPInterfaceDefinition;
	
	// Set up application environmental stuff from the interface
	app.setMyTerminal(self.myInterfaceDefinition.myTerminal);
	app.setLocale(self.myInterfaceDefinition.myLocale);	
	
	// Got to here, then we have a valid Terminal and Interface
	noCopies := self.myInterfaceDefinition.applicationCopies.max(1);
	
	app.writeLog('Starting ' &amp; noCopies.String &amp; ' copies of JMTTCPListenerWorker app for Terminal ' &amp; terminal.displayForXlation(true) &amp;
										 ', Interface ' &amp; self.myInterfaceDefinition.name, LogINFO);	//25 Nov 2019	NDL	TFS 47053
				   
	foreach i in 1 to noCopies do
		app.startApplicationWithParameter('MobileServerSchema', 'JMTTCPListenerWorker', self.myInterfaceDefinition);
	endforeach;
	

epilog

end;</source>
    </JadeMethod>
</Class>
