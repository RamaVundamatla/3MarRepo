    <JadeMethod name="getAuditText" id="8df90f81-7715-409f-bde6-92be943ca1b3">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
12 April 2023		jlizm1	Initial creation

*/

vars
	txt 		: String;
	tmpStr 		: String;
	cargoType 	: CM_CargoType;
	wagonClass	: CM_WagonClass;
	
begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();

	foreach cargoType in self.allCargoTypes do
		if tmpStr = null then
			tmpStr := cargoType.description;
		else
			tmpStr := tmpStr &amp; ", " &amp; cargoType.description;
		endif;
	endforeach;
	
	txt := txt &amp; "Cargo Types Selected: " &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;
	foreach wagonClass in self.allWagonClasses do
		if tmpStr = null then
			tmpStr := wagonClass.code;
		else
			tmpStr := tmpStr &amp; ", " &amp; wagonClass.code;
		endif;
	endforeach;
	
	txt := txt &amp; "Wagon Classes Selected: " &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="a888d43b-c95d-41fe-9d6b-d101a674bbaa">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//16 August 2010	cnwml2
//+cnwml2 PAR23715 SFW CCMS 1131

vars

begin

	if _attrName = ETRow_Code then	
		return self.sealType;
	elseif _attrName = ETRow_Description then
		return self.description;
	elseif _attrName = ETRow_AllowMultipleSealNo then
		return self.allowMultipleSealNums.getYesNo;
	elseif _attrName = ETRow_ShowSealIfPres then
		return self.showSealOnCheck.getYesNo;
	elseif _attrName = ETRow_NotAvailableForEntry then
		return self.notAvailableForEntry.getYesNo;
	elseif _attrName = ETRow_SavePreviousSeal then
		return self.savePreviousSeal.getYesNo;
	elseif _attrName = ETRow_TruckSeal then	// TFS 57098 jlizm1 17/03/2023
		return self.useForTrucks.getYesNo;
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTextForAuditStrOnCargoType" id="5be57b7a-0f95-422a-90b6-47fe3f081376">
        <source>getTextForAuditStrOnCargoType() : String;
/*

Purpose:			Returns Audit Text for Cargo Type

Parameters:			NONE

Return Value:		String:	Audit text to use for Cargo Type

Date		Who		Reason
03 June 2022	navpw1	Initial creation TFS: 53752

*/
	
begin
	return self.sealType &amp; "/" &amp; self.description &amp; Cr;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isSystemSealType" id="97f92b25-1f17-4adc-8259-88d999d19a1e">
        <source>isSystemSealType():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 September 2010	cnwndl1	Initial creation	Par 25608
// 07 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
*/

vars

begin

	if self.sealType = SealType_Customs
	or self.sealType = SealType_Operator
	or self.sealType = SealType_Shipper
	or self.sealType = SealType_Vent
	or self.sealType = SealType_TerminalOperator
	or self.sealType = SealType_Unknown
	then
		return true;
	else
		return false;
	endif;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
