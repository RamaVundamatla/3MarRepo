    <JadeMethod name="displayDebtor" id="70b6f36e-cced-423a-9bb3-a97fe6c618c1">
        <source>displayDebtor(_theObject : Object) : String;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if _theObject = null then
