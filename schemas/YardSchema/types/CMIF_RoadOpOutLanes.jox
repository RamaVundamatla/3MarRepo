    <JadeMethod name="reloadDataTable" id="17a572fa-086a-4565-b894-6a5408989b60">
        <source>reloadDataTable();
/*
Purpose:			
Return Value:		

Date			Who		Reason
23 April 2008	cnwer1	Initial creation - PAR#16584
11/09/2009		cnwcs5	ccms 1061 - optimised table clear
19/03/2010		cnwcs5	par 23193 - tracked item notifications
*/
vars

begin
	inheritMethod;	// par 23193
	return;			// par 23193
	
	// Much more efficient to just set number of rows
	// rather than deleting each row individually
	self.myDataTable.rows := self.myDataTable.fixedRows;

	self.loadDataTable();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="removeTIFromDataTable" id="ffdad57c-21d2-4113-a7f6-8862129b23b9">
        <source>removeTIFromDataTable(_vehicle: CM_Vehicle input)protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
20 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

	job: CM_Job;
	ti : CM_TrackedItem;
	vvr : CM_VehicleVisitRecord;
	row : Integer;
	tableRow : JadeTableRow;
	
begin

	self.removeDataTableObject(_vehicle);
	//at this point the vehicles road jobs will of been deleted so have to get them off the last vehicle visit record

	row:=self.myDataTable.fixedRows + 1 ;
	while row &lt;= self.myDataTable.rows do
		tableRow:=self.myDataTable.accessRow(row);
		if not global.isValidObject(tableRow.itemObject) then
			self.myDataTable.removeItem(row);
		else
			row:=row+1;
		endif;
	endwhile;
	
	//27 Dec 2018	NDL	TFS 42113
	if _vehicle.myPrimaryActualLocation &lt;&gt; null and _vehicle.myPrimaryActualLocation.isYardLocation then
		//truck moving from outward lane back into the yard
		if self.allVehicles.includes(_vehicle) then
			self.allVehicles.remove(_vehicle);
		endif;
		self.myDataTable.rows := self.myDataTable.fixedRows;
		self.loadDataTable();
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_vehicle" type="CM_Vehicle" usage="input"/>
    </JadeMethod>
    <JadeMethod name="selectTableRowForVehicle" id="a5c996a4-7cfc-4640-ac58-f19e0915c8a2">
        <source>selectTableRowForVehicle(_vehicle: CM_Vehicle input) : Boolean;
/*

Purpose:			


Return Value:		


Date		Who		Reason
21 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	row 			: Integer;
	tableObjects 	: ObjectArray;
	obj 			: Object;
	isFirst			: Boolean; //cnwmc5 - par 29716
begin
	if not inheritMethod(_vehicle) then
		return false;
	endif;

	self.myDataTable.clearAllSelected;
	
	create tableObjects transient;
	
	self.getTableObjects(_vehicle,tableObjects);
	
	isFirst := true; //cnwmc5 par 29716
	
	foreach obj in tableObjects do
		//cnwmc5 - par 29716 - changed this if statement to work correctly
		if self.myDataTable.findObjectInRowReversed(obj, row) then	 //self.myDataTable.findObjectInRow(obj, row) then
			self.myDataTable.selectRow(row, false);
			
			//cnwmc5 - par 29716
			if isFirst = true then
				self.myDataTable.topRow:= row;
			endif;
			
			isFirst := false;
		endif;
	endforeach; 
epilog
	if tableObjects &lt;&gt; null then
		delete tableObjects;
	endif;
end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
