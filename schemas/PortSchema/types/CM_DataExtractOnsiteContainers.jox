    <JadeMethod name="initDataExtractFields_CustNum" id="3437e3c3-bae1-4e78-ba1a-8159f6251499">
        <source>initDataExtractFields_CustNum(_fields : CM_DataExtractFieldSet input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2011	cnwkpd1	PAR #27436 - CCMS DCT 2073 - Product Transition Services
25 May 2011 cnwdz2  PAR #27598 Reviewed.
*/

vars
	fieldName	 : String;
	childField   : CM_DataExtractField; 
    colField     : CM_DataExtractCollectionField;
begin
	
	fieldName := CM_Container::allCustomsEntryNumbers.name;
	colField  := self.initDataExtractCollectionField(_fields, CM_Container, fieldName, "Customs Entry Number Details");
	
	fieldName := CM_Container.name&amp;"CustEntry";
	childField := self.initDataExtractField(null, String.name, null, fieldName, STRING, "Customs Entry Number", "Customs entry number", STRING, "Comma-separated customs entry numbers");	
	colField.extractOrder.add(fieldName);
	colField.allChildFields.add(childField);
	
epilog

end;</source>
        <Parameter name="_fields" type="CM_DataExtractFieldSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initDataExtractFields_Damage" id="4b9ca291-4a97-4174-9444-77ff968bce5e">
        <source>initDataExtractFields_Damage(_fields : CM_DataExtractFieldSet input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2011	cnwkpd1	PAR #27436 - CCMS DCT 2073 - Product Transition Services
25 May 2011 cnwdz2  PAR #27598 Reviewed.
//13 Oct 2022	navak20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
*/

vars
	fieldName		: String;
	childField   : CM_DataExtractField; 
    colField     : CM_DataExtractCollectionField;
begin
	
	fieldName := CM_Container::allDamageInstances.name;
	colField  := self.initDataExtractCollectionField(_fields, CM_DamageInstance, fieldName, "Damage Details");
	
	fieldName := CM_DamageInstance::getDamageDescrForLoc.name;
	childField := self.initDataExtractField(null, CM_DamageInstance.name, null, fieldName, STRING, "Damage Position", "Position of Damage", STRING, "One of the following: All, Left, Right, Bottom, Top, Back, Front");	
	colField.extractOrder.add(fieldName);
	colField.allChildFields.add(childField);
	
	fieldName := CM_DamageInstance::getDefCode.name;
	childField := self.initDataExtractField(null, CM_DamageInstance.name, null, fieldName, STRING, "Code", "Code of Damage", STRING, "No more than 10 characters and/or digits");	
	colField.extractOrder.add(fieldName);
	colField.allChildFields.add(childField);
	
	//fieldName := CM_DamageInstance::severity.name;	// 13.10.2022 navak20 TFS 53862
	fieldName := CM_DamageInstance::getSeverityLevel.name;	// 13.10.2022 navak20 TFS 53862
	childField := self.initDataExtractField(null, CM_DamageInstance.name, null, fieldName, INTEGER, "Severity", "Severity of Damage", INTEGER, INTEGER_POSSIBLEVAL);	
	colField.extractOrder.add(fieldName);
	colField.allChildFields.add(childField);
