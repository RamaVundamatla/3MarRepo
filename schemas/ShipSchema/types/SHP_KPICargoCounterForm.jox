    <JadeMethod name="updateStatus" id="53000b92-51de-4106-84b9-77f478b27611">
        <source>updateStatus();
/*

Date		    Who			Reason
04 October 2010	cnwas3	  Initial creation

*/

vars
	sum : String;
begin

	sum := self.tblCargoCounter.getSelectedCellsSumAsString();
	if sum &lt;&gt; null then
		self.statusLine.caption := app.getErrorString(Total_count) &amp; sum;
	else
		self.statusLine.caption := null;
	endif;
end;</source>
    </JadeMethod>
