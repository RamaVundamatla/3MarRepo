    <JadeMethod name="doCheckKeyDownSpecial" id="c4c62c48-7c3a-4789-a0ed-f10bbedcc239">
        <updating/>
        <source>doCheckKeyDownSpecial(_keyCode : Integer; _tableCellInputReadyMethod : String) : Boolean updating;
/*
Purpose:			Do any special keyDown checking before the controls on your form (especially tables)
					get hold of the keyDown event. 

Parameters:			_keyDown - the keyDown parameter from the keyDown event
					_tableCellInputReadyMethod - call-back method to handle aany CMUI_MeasurementTable controls on the calling form

Return Value:		true if some special processing here, false if nothing happened

Date		Who		Reason
13 February 2013	cnwdap1	Initial creation
*/
vars
	control 		: Control;
	table			: CM_EntryTable;
	row				: Integer;
	cellTbl			: CMUI_MeasurementTable;
	cell			: JadeTableCell;
	resetKeyCode	: Boolean;
	hazTbl			: CMUI_HazardsListTable;
	l, t, w, h		: Real;

begin
	if _keyCode = J_key_Tab and not app.isControlKeyDown and not app.isAltKeyDown then
		control := app.activeControl;
		if control.name[1:1] = "_" or control.parent.isKindOf(CMUI_MeasurementTable) then
			control := control.parent.Control;
		endif;
		if control.isKindOf(CM_EntryTable) then
			table := control.CM_EntryTable;
			if not app.isShiftKeyDown then
				row := table.row + 1;
			else
				row := table.row - 1;
			endif;
			
		elseif control.isKindOf(CMUI_MeasurementTable) then
			cellTbl := control.CMUI_MeasurementTable;
			table := cellTbl.parent.CM_EntryTable;
			if app.isShiftKeyDown then
				if cellTbl.column = cellTbl.columns then
					cellTbl.column := 1;
					cellTbl.setFocus;
					resetKeyCode := true;
				elseif cellTbl.column = 1 then
					table := cellTbl.parent.CM_EntryTable;
					row := table.row - 1;
				endif;
			else
				if cellTbl.column = 1 then
					cell := cellTbl.accessCell(1, cellTbl.ColumnUnit);
					if cellTbl.accessCell(1, cellTbl.ColumnUnit).comboList = null then
						cellTbl.lostFocus(cellTbl);
						table := cellTbl.parent.CM_EntryTable;
						row := table.row + 1;
					else
						cellTbl.column := cellTbl.columns;
						cellTbl.setFocus;
						resetKeyCode := true;
					endif;
				elseif cellTbl.column = cellTbl.columns then
					table := cellTbl.parent.CM_EntryTable;
					row := table.row + 1;
				endif;
			endif;
			
/*		elseif control.isKindOf(CMUI_HazardsListTable) then
			hazTbl := control.CMUI_HazardsListTable;
			table := hazTbl.parent.CM_EntryTable;
			if app.isShiftKeyDown then
				if hazTbl.column = hazTbl.columns then
					hazTbl.column := 1;
					hazTbl.setFocus;
					resetKeyCode := true;
				elseif hazTbl.column = 1 then
					table := hazTbl.parent.CM_EntryTable;
					row := table.row - 1;
				endif;
			else
				if hazTbl.column = hazTbl.columns then
					if hazTbl.row = hazTbl.rows then
						table := hazTbl.parent.CM_EntryTable;
						row := table.row + 1;
					else
						hazTbl.row := hazTbl.row + 1;
						hazTbl.column := 1;
						resetKeyCode := true;
					endif;
				else
					if hazTbl.column = 1 then
						hazTbl.column := 4;
					elseif hazTbl.column = 4 then
						hazTbl.column := hazTbl.columns;
					endif;
					resetKeyCode := true;
				endif;
			endif;	*/
		endif;
		
		// we're changing rows, see if next row to move to is a "special" one
		// double check to see if we're tabbing out of the table
		if table &lt;&gt; null and row &gt; table.rows then
			row := null;
		endif;
		if table &lt;&gt; null and row &lt;&gt; null and not resetKeyCode then
			if table.accessCell(row, table.ColumnValue).cellControl &lt;&gt; null and table.accessCell(row, table.ColumnValue).cellControl.isKindOf(CMUI_MeasurementTable) then
				cellTbl := table.accessCell(row, table.ColumnValue).cellControl.CMUI_MeasurementTable;
				if _tableCellInputReadyMethod &lt;&gt; null then
					self.sendMsgWithParams(_tableCellInputReadyMethod, table, cellTbl, l, t, w, h);
				endif;
				if app.isShiftKeyDown then
					cellTbl.column := cellTbl.ColumnUnit;
				else
					cellTbl.column := cellTbl.ColumnValue;
				endif;
				table.accessRow(table.row).selected := false;
				table.row := row;
				table.column := table.ColumnValue;
				table.setFocus;
				resetKeyCode := true;
			endif;
		endif;
	endif;
	
	return resetKeyCode;
	
epilog

end;</source>
        <Parameter name="_keyCode" type="Integer"/>
        <Parameter name="_tableCellInputReadyMethod" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
