    <JadeMethod name="trxUpdateHMSResourcesUsed" id="6ccb70ed-85e2-4577-b2d4-68851cdd131a">
        <updating/>
        <source>trxUpdateHMSResourcesUsed(	_allPxyResourceUsed : HMS_ResourceUsedSet ; 
							_voyage : CM_Voyage input;
							_voyExternalCode : String;
							_voyageStatus : Integer;
							_berth : HMS_Berth input;
							_occursOnDT : TimeStamp;
							_towingVoyage : CM_Voyage input;
							_nextStatus : CM_VoyageStatus;
							_bowMarkTo : Decimal;
							_draftAft : Decimal;
							_draftFwd : Decimal;
							_hasRamp : Boolean;
							_starboardberthed : Boolean;
							_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 April 2018	jlger1	Initial creation 37665
18 July	2018 	jlger1	tfs 39737 only create resources that have been passed in
11 Sep 2018 	jlger1	tfs 40629 rest api - create work order with no voyage just external voy code
11 Oct 2021		jlier1	TFS 51963 removed inaportnet
24 Mar 2023 	navhl20 ChangeRequest 57301:[57303] EUP - [Framework] - Improve Audits on Work orders
*/

vars
	pxyHMSResourceUsed : HMS_ResourceUsed;
	nextStatus,
	voyageStatus : CM_VoyageStatus;
	movement : HMS_VoyageMovement;
	allWODtlsToDelete : ObjectSet;
	realWorkOrderDtl : CM_WorkOrderDtl;
	marineService : CM_WodMarineServiceDetail;
	pxyWorkOrder : CM_WorkOrderVoyage;
	pxyWorkOrderVoyageDtl : CM_WorkOrderVoyageDtl;
	realWorkOrder  : CM_WorkOrder; 
	terminal : CM_Terminal;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	if _voyage = null and _voyExternalCode = null then
		app.raiseCMException(Input_required_field_movement,null,null);
		return;
	endif;
	
	if _voyage &lt;&gt; null and _voyage.myHMSVoyageData = null then
		app.raiseCMException1(Harbo_detai_requi_voyag_create,_voyage.code,null,null);
		return;
	endif;
		
	if _voyageStatus &lt;&gt; 0 then
		voyageStatus := app.myRoot.allVoyageStatuses[_voyageStatus];
	else
		if _voyage &lt;&gt; null then
			voyageStatus := app.myRoot.allVoyageStatuses[_voyage.status];
		endif;
	endif;
	if  voyageStatus = null then
		app.raiseCMException(Voyag_statu_requi_creat_marine,null,null);
		return;
	endif;
	
	if _voyage &lt;&gt; null then
		terminal:=_voyage.myTerminal;
	else
		terminal :=_passport.myTerminal;
	endif;
	
	if voyageStatus.isInitialMarineService then
		//get arrival movement
		if _voyage &lt;&gt; null then
		
			movement:=_voyage.myHMSVoyageData.getMovementForMoveType(HMSMovementTypeArrival);
			realWorkOrderDtl := _voyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_MARINEINITIAL);	
		endif;
	else
		//get departure movement
		if _voyage &lt;&gt; null then
			movement:=_voyage.myHMSVoyageData.getMovementForMoveType(HMSMovementTypeDeparture);	
			realWorkOrderDtl := _voyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_MARINEDEPART);		
		endif;
	endif;
	
	if movement = null and _voyage &lt;&gt; null  then
			//raise exception 
		return;
	endif;
	
	
	beginTransaction;
	
	
	
	if realWorkOrderDtl &lt;&gt; null then
		realWorkOrder:=realWorkOrderDtl.myParent;
		create allWODtlsToDelete transient;
		realWorkOrderDtl.CM_WorkOrderVoyageDtl.getAllMarineServiceDetails.copy(allWODtlsToDelete);
	endif;
	
	foreach pxyHMSResourceUsed in _allPxyResourceUsed discreteLock do
	
		pxyHMSResourceUsed.setMyVoyageMovement(movement);
		app.myUtilityUA.utlUpdateWorkOrderMarine(_voyage,_voyExternalCode,voyageStatus.isInitialMarineService,pxyHMSResourceUsed,realWorkOrderDtl,_occursOnDT,_towingVoyage,
							_berth,_bowMarkTo,
							_draftAft,
							_draftFwd,
							_hasRamp,
							_starboardberthed,_passport);
		
		if allWODtlsToDelete &lt;&gt; null then
				if voyageStatus.isInitialMarineService then					
					realWorkOrderDtl := realWorkOrder.getWorkOrderDetailOfType(WO_TASK_MARINEINITIAL);	
				elseif voyageStatus.isDepartureMarineService then					
					realWorkOrderDtl := realWorkOrder.getWorkOrderDetailOfType(WO_TASK_MARINEDEPART);
				endif;
				if realWorkOrderDtl &lt;&gt; null then
					marineService:=realWorkOrderDtl.CM_WorkOrderVoyageDtl.getMarineServiceDtlForResource(pxyHMSResourceUsed.myResource);
					if marineService &lt;&gt; null then
						allWODtlsToDelete.removeIfPresent(marineService);
					endif;
				endif;
		endif;
		
	endforeach;
	
	
	if _passport.noErrors then
		if allWODtlsToDelete &lt;&gt; null then
			allWODtlsToDelete.purge;
		endif;
	endif;
	
	if _voyage = null then
		return;
	endif;
	
	
	if _passport.hasErrors then
		return;
	endif;
		
	if voyageStatus.isInitialMarineService then					
		realWorkOrderDtl := _voyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_MARINEINITIAL);		
	else		
		realWorkOrderDtl := _voyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_MARINEDEPART);	
	endif;	
		
	if realWorkOrderDtl = null then
		//always create the work order 
		create pxyWorkOrder transient;
		pxyWorkOrder.setProxy(null,null,false,app.actualTimeAppServer,app.myPassport.myUser,null,null,terminal,
												null,null,null, WO_STATUS_PENDING);
		pxyWorkOrder.setMyVoyage(_voyage);
		
		if voyageStatus.isInitialMarineService then
			create pxyWorkOrderVoyageDtl  as CM_WodMarineServicesInitial transient;
			pxyWorkOrderVoyageDtl.setTowingVoyage(_towingVoyage);
			// TFS 40236 pxyWorkOrderVoyageDtl.CM_WodMarineServicesInitial.setMyBerth(_berth);
			
			// TFS 40236 POPULATE PARAMS FROM WEB SERVICE
			pxyWorkOrderVoyageDtl.CM_WodMarineServicesInitial.setPxyMarineDetails(_berth, 
						_draftAft,_draftFwd, _bowMarkTo, _hasRamp, _starboardberthed); // TFS 40236 
			
		//	pxyWorkOrderVoyageDtl.setProxy(null,_occursOnDT,false);
			//pxyWorkOrderVoyageDtl.setProxy(_occursOnDT,null,false);//	19 Sep 2018	NDL	TFS 40810					//24.3.2023 navhl20	#57301[57303]
			pxyWorkOrderVoyageDtl.setProxyReqByDT(_occursOnDT);														//24.3.2023 navhl20	#57301[57303]
		else
			create pxyWorkOrderVoyageDtl  as CM_WodMarineServicesDepart transient;
			
			pxyWorkOrderVoyageDtl.CM_WodMarineServicesDepart.setPxyMarineDetails( _draftAft,_draftFwd, _bowMarkTo);//	19 Sep 2018	NDL	TFS 40810
			//pxyWorkOrderVoyageDtl.setProxy(_occursOnDT,null,false);//	19 Sep 2018	NDL	TFS 40810					//24.3.2023 navhl20	#57301[57303]
			pxyWorkOrderVoyageDtl.setProxyReqByDT(_occursOnDT);														//24.3.2023 navhl20	#57301[57303]
			pxyWorkOrderVoyageDtl.setTowingVoyage(_towingVoyage);//20 Sep 2018	NDL	TFS 40810
			
		endif;
		pxyWorkOrderVoyageDtl.setParent(pxyWorkOrder);
		app.myUtilityCA.utlCreateWorkOrder(pxyWorkOrder,realWorkOrder,_passport);
		
		if  _passport.hasErrors then
			return;
		endif;
		realWorkOrderDtl:=realWorkOrder.allWoDtls.first;
	endif;
		
	if  _passport.hasErrors then
		return;
	endif;
	
	if _nextStatus &lt;&gt; null then
		nextStatus:=_nextStatus;
	else
		//epr TFS 41539
		if realWorkOrderDtl &lt;&gt; null then 
			if realWorkOrderDtl.detailType = WO_TASK_MARINEINITIAL then
				if _voyage.isMTNWOVoyageProcess then
					nextStatus:=app.myRoot.allVoyageStatuses[Voyage_Status_InitSerRequested];		
				endif;					
			elseif realWorkOrderDtl.detailType = WO_TASK_MARINEDEPART then
				if _voyage.isMTNWOVoyageProcess then
					nextStatus:=app.myRoot.allVoyageStatuses[Voyage_Status_DepServRequested];
				endif;
			endif;	
		endif;	
		
	endif;
	
	if nextStatus &lt;&gt; null then
		_voyage.setStatusFromObject(nextStatus);
	endif;	
	
	
	
epilog
	
	delete allWODtlsToDelete;
		
	
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_allPxyResourceUsed" type="HMS_ResourceUsedSet"/>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_voyExternalCode" type="String"/>
        <Parameter name="_voyageStatus" type="Integer"/>
        <Parameter name="_berth" type="HMS_Berth" usage="input"/>
        <Parameter name="_occursOnDT" type="TimeStamp"/>
        <Parameter name="_towingVoyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_nextStatus" type="CM_VoyageStatus"/>
        <Parameter name="_bowMarkTo" type="Decimal"/>
        <Parameter name="_draftAft" type="Decimal"/>
        <Parameter name="_draftFwd" type="Decimal"/>
        <Parameter name="_hasRamp" type="Boolean"/>
        <Parameter name="_starboardberthed" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
