    <JadeMethod name="isInAnyLOBExcluding" id="1129e269-e676-4902-b289-3efbcb073466">
        <source>isInAnyLOBExcluding( _labourWorkArea : CM_LabourWorkArea ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 April 2014	cnwndl1	Initial creation	Par 33995

*/

vars

	terminalArea : CM_TerminalArea;

begin

	if self.myLabourWorkArea &lt;&gt; null then
		return self.myLabourWorkArea &lt;&gt; _labourWorkArea;
	endif;
	
	terminalArea := self.getGridArea;
	if terminalArea &lt;&gt; null then
		if terminalArea.myLabourWorkArea &lt;&gt; null then
			return terminalArea.myLabourWorkArea &lt;&gt; _labourWorkArea;
		endif;
	endif;
	
	return false; 

epilog

end;</source>
        <Parameter name="_labourWorkArea" type="CM_LabourWorkArea"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isInAnySubTermExcluding" id="52bd3780-e6ff-4e42-b1f3-d483d294bcfd">
        <source>isInAnySubTermExcluding( _subTermAreaDef : CM_SubTerminalAreaDef ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 November 2014	cnwndl1	Initial creation	Par 35295

*/

vars

	subTermAreaDef : CM_SubTerminalAreaDef;

begin

	subTermAreaDef := self.getMySubTerminalAreaDef;
	if subTermAreaDef &lt;&gt; null then
		return subTermAreaDef &lt;&gt; _subTermAreaDef;
	endif;
	
	return false;

epilog

end;</source>
        <Parameter name="_subTermAreaDef" type="CM_SubTerminalAreaDef"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
