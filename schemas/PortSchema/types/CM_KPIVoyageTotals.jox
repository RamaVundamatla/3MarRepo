    <JadeMethod name="setNumLids" id="b492e87c-f4fe-44e2-8c77-3041f5c3658a">
        <updating/>
        <source>setNumLids() updating;
// ---------------------------------------------------------------------------
// Created:     30 August 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	kpi : CM_KPI;
begin
	foreach kpi in self.myVoyage.allVoyageKPIEntities discreteLock where kpi.type = KPI_Type_VoyageCraneShift   do
		self.movesLid := self.movesLid + kpi.CM_KPIVoyageCraneShift.movesLid;
	endforeach;
epilog

end;</source>
    </JadeMethod>
