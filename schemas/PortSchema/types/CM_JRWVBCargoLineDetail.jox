    <JadeMethod name="myCargoType" id="9218c0af-021e-40c3-b967-530ec0c5f0d4">
        <methodInvocation>mapping</methodInvocation>
        <source>myCargoType(set : Boolean; _value : CM_CargoType io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 August 2014	cnwndl1	Initial creation	CCMS Penn 2399

*/

vars

	str : String;

begin

	if not set and _value = null then
		str := self.getCargoType;
		if str &lt;&gt; null and str.isInteger then
			_value := app.myRoot.allCargoTypesById.getAtKey( str.Integer );
		endif;
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_CargoType" usage="io"/>
    </JadeMethod>
