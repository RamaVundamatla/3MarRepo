        <source>setupForm() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 August 2010	cnwndl1	Initial creation	Par 25215

*/

vars

begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;

