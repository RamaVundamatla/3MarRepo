    <JadeMethod name="setComboValues" id="af054c82-8fbe-4cc5-9a66-4860fb452bfa">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2022	jlier1	Initial creation 54700

*/

vars

begin
	_combo.clear;
	_combo.addItem(app.trailerCategoryEnumToString(TRAILER_CATEGORY_TRAILER));
	_combo.addItem(app.trailerCategoryEnumToString(TRAILER_CATEGORY_MAFI));
	
	if CM_QIntegerLookupEqual.hasInstance(_queryOperator) then
		_combo.text := app.trailerCategoryEnumToString(_queryOperator.CM_QIntegerLookupEqual.searchValue);
	elseif CM_QIntegerLookupNotEqual.hasInstance(_queryOperator) then
		_combo.text := app.trailerCategoryEnumToString(_queryOperator.CM_QIntegerLookupNotEqual.searchValue);
	endif;


epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="37161765-4d63-4510-b06a-74eadb8dacb0">
        <source>translateStringToSearchValue(_value: Any; _criteriaLine: CM_SelectorCriteriaLine): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2022	jlier1	Initial creation 54700

*/

vars
	intCategory	: Integer;
	
begin
	if _value.String.isInteger then
		return _value;
	endif;
	
	intCategory := app.trailerCategoryStringToEnum(_value.String);
		
	return intCategory;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="c51420a4-fe6a-4ec5-8e26-5e479b155ee7">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2022	jlier1	Initial creation 54700

*/

vars

begin
	return app.trailerCategoryEnumToString(_value.Integer);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="31cd4c1a-e9a4-4db0-bd10-181d341a4f25">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2022	jlier1	Initial creation 54700

*/

vars

begin
	if _value.isKindOf(IntegerArray) then
		return _value;
	elseif _value.isKindOf(Integer) then	
		return _value.String;
	endif;
	
	return app.trailerCategoryStringToEnum(_value.String);


epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
