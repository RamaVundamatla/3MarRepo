    <JadeMethod name="utlCompleteRTQueueTask" id="ab763c0d-b441-457b-be63-5ea088475377">
        <updating/>
        <source>utlCompleteRTQueueTask(	_task : CM_RTQueueTask input; 
						_taskMachine,
						_imvMachine : CM_Machine input;
						_moveQuantity : Integer;
						_moveWeight : Decimal;
						_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 February 2011	cnwer1	Initial creation
26/10/2011			cnwmh5 #28501 - If Voyage release job then do received / wharfage txns
13 Jun 2013 cnwer1	PAR 31743 - don't need to create receive ship trx here and was issue doing setdown for machine offline
11/08/14	cnwer1	CCMS 1391 - refactored - imv stuff now done in body of machine pickupSingleTask
*/

vars
	rtEntry , prevEntry, nextEntry : CM_RTQueueEntry;
	wle : CM_WorkListEntry;
	 rtTask , pickupTask: CM_RTQueueTask;
	machine,imvMachine : CM_Machine;
	ti : CM_TrackedItem;
	invalidObj,invalidWLE		: Boolean;
	moveController	: CMIF_MoveController;
	terminal : CM_Terminal;
	foundLC 	: CM_LocationsController;
	foundHeight : Integer;
	voyageWLE		: CM_VoyageWLE;
	plannedFutureMove	: CM_FutureMovePlanned;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(false);
	
	if _task = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'RT Queue Entry', null, null);
		app.raiseCMException(Input_required_field_rtQueEnt, null, null); // cnwdb2	PAR 35364
		return;
	endif;

	rtTask:=_task;
	on Exception do app.handleDeletedObject(exception, rtTask, invalidObj);
	on Exception do app.handleDeletedObject(exception, wle, invalidWLE);
	rtEntry:=rtTask.myEntry;
	
	if invalidObj then															// PAR #16738
		app.raiseCMException(Object_Deleted, 'RT Queue Entry', null);
		return;
	endif;
	
	//should never have a move task passed in 
	if rtTask.isMove then
		app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, self.class.name, method.name," Cannot complete move tasks", null, null);
		return;
	endif;
	
	wle:=rtEntry.myWorkListEntry;
	ti :=wle.myTrackedItem;
	if ti = null then
		return;
	endif;
	
	prevEntry:=rtEntry.getPreviousRelatedEntry(); //epr par 35702 CCMS 2457 17/2/15
	
	if prevEntry &lt;&gt; null then 
		if prevEntry.machineTypeGroup = MACHINETYPEGRP_IMV then
			if prevEntry.getPreviousRelatedEntry() &lt;&gt; null and prevEntry.getPreviousRelatedEntry().status &lt;&gt; ENTRY_COMPLETE then
				app.raiseCMException1(Multi_machine_task_complete,ti.id,null,null);
			endif;
		else
			if prevEntry.status &lt;&gt; ENTRY_COMPLETE then
				//raise exception can not complete this task until the previous entry has been completed
				app.raiseCMException1(Multi_machine_task_complete,ti.id,null,null);
			endif;		
		endif;			 
	endif;
	
	
	_passport.useTITransactionDeferUpdate := true; // ## PAR 10352

	if rtTask.isPickUp then
		pickupTask:=rtTask;
		machine:=_taskMachine;
	elseif	rtTask.isSetDown then
		machine	:= rtTask.machine;	
		
		if machine = null then
			machine := rtTask.intendedMachine;
		endif;
		
		//we have no setdown machine yet i.e. completing the setdown and pickup at the same time
		if machine = null then
			machine:=_taskMachine;
			
			pickupTask:=rtEntry.getDirectorOrPickupTask();
		endif;
	endif;
	
	if pickupTask &lt;&gt; null  then		
		if rtTask.machine &lt;&gt; machine  then
			if  rtTask.machine &lt;&gt; null then
				rtTask.setMachine(null);
			endif;
			self.utlChangeTaskStatus(pickupTask,machine,TASK_ACCEPTED,_passport);
		endif;
		//11/08/14	cnwer1	CCMS 1391 - refactored - imv stuff now done in body of machine pickupSingleTask
		self.utlMachinePickupTask(machine,null, _moveQuantity , _moveWeight);
	endif;
	
	if 	rtTask.isSetDown then
		nextEntry:=rtEntry.getNextRelatedEntry();
		if nextEntry &lt;&gt; null and nextEntry.machineTypeGroup = MACHINETYPEGRP_IMV then
			imvMachine:=_imvMachine;
			if imvMachine = null then
			//	app.raiseCMException1(REQUIRED_FIELD, 'IMV', null, null);
				app.raiseCMException(Input_required_field_IMV, null, null); // cnwdb2	PAR 35364
				return;
			endif;
			if rtTask.targetLocation &lt;&gt; imvMachine.myMachineController then
				rtTask.setTargetLocation(imvMachine.myMachineController);
			endif;
		else
			imvMachine:=null;
		endif;
		
		//epr 31743 13/6/13 if machine is offline need to restore the status otherwise the executeSetDownTask will not find the task
		if rtTask.status =  TASK_MACH_OFFLINE then
			rtTask.restoreStatus();
		endif;
		
		//epr par 36986 16/11/15
		if rtTask.ti &lt;&gt; null and  rtTask.isVoyageLoadToCTA then
		
			create moveController transient;
			moveController.setMoveMode(QUEUE_MODE);
			moveController.setMyTrackedItem(rtTask.ti);
			moveController.updatePassportAndUser(app.myPassport);
			moveController.isRadioTelemetryMove := true;
			
			terminal:= rtTask.getMyTerminal();
			if terminal &lt;&gt; null then
				terminal.findLocationFromString(rtTask.targetLocationId,true,foundLC,foundHeight);
				moveController.setMyToPrimaryLocation(foundLC);
				if foundLC &lt;&gt; null then
					if wle.isKindOf(CM_VoyageWLE) then
						voyageWLE:=wle.CM_VoyageWLE;
						plannedFutureMove:= voyageWLE.myFutureMove.CM_FutureMoveQueued.myFutureMovePlanned;
						 voyageWLE.myFutureMove.CM_FutureMoveQueued.setMyFutureMovePlanned(null);
					endif;
					
					rtTask.changeTargetLocation(moveController,false);
				endif;
			endif;
		endif;
		
		machine.executeSetDownTask(null,null);
		
		if voyageWLE &lt;&gt; null and plannedFutureMove &lt;&gt; null then
			plannedFutureMove.setMyWorkListEntry(voyageWLE,false);
		endif;
		
	endif;
	
	
	_passport.doDeferredUpdates(); // ## PAR 10352
	
epilog
	delete moveController;
end;</source>
        <Parameter name="_task" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_taskMachine" type="CM_Machine" usage="input"/>
        <Parameter name="_imvMachine" type="CM_Machine" usage="input"/>
        <Parameter name="_moveQuantity" type="Integer"/>
        <Parameter name="_moveWeight" type="Decimal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCompleteRelease" id="cf9d32a6-b379-4ce1-aea5-4052914a5487">
        <source>utlCompleteRelease(_historyMaster : CnEcReleaseHistoryMaster input; 
				   _root : CM_Root input;
				   _versionString,
				   _patchNumber : String;
				   _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     12 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.initialiseActivity();

	app.setContinueCMExceptions(false);

	exclusiveLock(_root);

	if _passport.noErrors then
		self.utlUpdateVersion(_root, _versionString, _patchNumber, _passport);
	endif;

	if _passport.noErrors then
		_historyMaster.setReleaseNumber(_versionString);
		_historyMaster.setPatchNumber(_patchNumber);
	endif;

end;</source>
        <Parameter name="_historyMaster" type="CnEcReleaseHistoryMaster" usage="input"/>
        <Parameter name="_root" type="CM_Root" usage="input"/>
        <Parameter name="_versionString" type="String"/>
        <Parameter name="_patchNumber" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCompleteToDoTasks" id="f3867923-e21f-47fa-8d53-3a674f62e87e">
        <updating/>
        <source>utlCompleteToDoTasks(_ti : CM_TrackedItem input; _allTasks : CMIF_TiToDoTasksArray; _passport : CM_Passport input)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Sep 2019	cnwma1	ChangeRequest 46185: PNL - Tasks, Grades and Marks via REST API

*/

vars
	taskDesc    : CM_ToDoTaskDesc;
	cmifToDo    : CMIF_TiToDoTasks;
	todoTask    : CM_ToDoTask;
begin
	self.initialiseActivity();
	
	exclusiveLock(_ti);
	
	foreach  cmifToDo in _allTasks do
		
		taskDesc := cmifToDo.myToDoTaskDesc;
		todoTask := _ti.getToDoTaskToDoWithCode(taskDesc.code);
		
	 	_ti.setToDoTaskComplete(taskDesc.code, _passport);
			
		_passport.doPostUpdateAutoPlansFor( _ti );
		
		if not  _passport.hasErrors then
			
			if cmifToDo.remarks &lt;&gt; null then
				if todoTask &lt;&gt; null then
					todoTask.setRemarks(cmifToDo.remarks);
				endif;
			endif;
			
			if cmifToDo.completeDT.isValid() then
				_ti.updateToDoTaskLastCompletedTs(taskDesc.code, cmifToDo.completeDT, _passport);
			endif;
		endif;
	endforeach;
	

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_allTasks" type="CMIF_TiToDoTasksArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlConsolidateDebtorTermTrans" id="dff7ee88-1dae-4f2e-b6e9-79756ea754fe">
        <updating/>
        <source>utlConsolidateDebtorTermTrans(_realDebtorTerminal : CM_DebtorTerminal input; _endDate : Date input; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	if _realDebtorTerminal = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_DebtorTerminal.name, null, null);
		return;
	endif;

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(_realDebtorTerminal);
	
	if _passport.noErrors then
		_realDebtorTerminal.doConsolidateCashTransactions( _endDate );
	endif;

end;</source>
        <Parameter name="_realDebtorTerminal" type="CM_DebtorTerminal" usage="input"/>
        <Parameter name="_endDate" type="Date" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlConvertWOTransportToBol" id="cc09cc17-6f47-468b-89df-07771e65bea8">
        <source>utlConvertWOTransportToBol(_bol: CM_BOL io; _myWorkorderDtl	: CM_WorkOrderDtl;_newId, _newTransport : String; _transport : CM_Object; _tiArr : ObjectArray; _term : CM_Terminal; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2023	navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes
13 Dec 2023 naviv1	ChangeRequest 61543: EUP - Transport  Mode Change should create a new Work Order 
12 Jan 2023 navhl20 Defect 62032: EUP - Error when confirming the cargo using the Cargo Scanning app
30 Jan 2024 navlc30 Bug 62217: MTN - 1090 exception when changing the transport mode from Rail to Ship
*/

vars
	booking				: CM_BookingRef;
	pxyBol				: CM_BOLIn; 
	bolDtl				: CM_BOLDtl;
	voyage				: CM_Voyage;
	ti,pxyTi			: CM_TrackedItem;
	bookingItem			: CM_BookingRefItem;
	bolTrem				: CM_BOLTerminal;
	allNewBOLDtlProxies : CM_ObjectArrayActual;
	proxy 				: CM_Object;
	control 			: CMIF_MoveController;
begin
	
	self.initialiseActivity();
	
	// do any pre-validation locks

	app.setContinueCMExceptions(true);
	
	app.myValUA.valWOTransportModeChange(_tiArr, _newTransport, _transport);							//30.01.2024 navlc30 #62217

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	if _myWorkorderDtl &lt;&gt; null then
		booking := _myWorkorderDtl.CM_WodReceive.myBookingRef;
	endif;
	bolTrem := _term.allBOLTermsByTypeNum[BOLType_GeneralBillOfLading,_newId];
	if bolTrem &lt;&gt; null then
		_bol := bolTrem.myBOL;
	endif;
	voyage := _transport.CM_Voyage;
	if _bol &lt;&gt; null then
		pxyBol := app.createUpdateProxy(_bol).CM_BOLIn;
	else
		if booking &lt;&gt; null then
			create pxyBol transient;
			pxyBol.populatePxyFromBooking(booking);
		endif;
	endif;
	if pxyBol &lt;&gt; null then
		if _bol = null then
			if _newId &lt;&gt; null then
				pxyBol.setNumber(_newId);
			endif;
			if voyage &lt;&gt; null then
				pxyBol.setMyVoyage(voyage);
			endif;
			if _tiArr.size &gt; 0 then
				pxyBol.allTrackedItems.clear();
				_tiArr.copyNoDups(pxyBol.allTrackedItems);
			endif;
		else
			if _tiArr.size &gt; 0 then	
				foreach ti in _tiArr as CM_TrackedItem do
					pxyBol.allTrackedItems.addNoDuplicates(ti,false);
				endforeach;
			endif;
		endif;
		if _bol &lt;&gt; null then
			app.myUtilityUA.utlUpdateBOLIn(pxyBol, _passport);
		else
			create allNewBOLDtlProxies transient;
			app.myUtilityCA.utlCreateBOL(pxyBol, _passport, null, _bol, allNewBOLDtlProxies);
			if _passport.noErrors then
				app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(_bol);
			endif;
		endif;
	endif;
	
	if _passport.noErrors then
		foreach ti in _tiArr as CM_TrackedItem do
			// ### TFS 62217 22Feb2024 NAVPW1
			if ti.locationId &lt;&gt; null and ti.myPrimaryActualLocation.isWagon then
				create control transient;
				control.setMoveMode(REAL_MODE);	
				control.isSystemMove := true;
				control.isForcedMove := true;
				control.isWoChangeOfTransportRelShip := true;
				control.transferType := VESSEL_TYPE_LOLO;
				
				self.exclusiveLock(ti);
				control.setMyTrackedItem(ti);
				if voyage &lt;&gt; null then
					control.setMyToPrimaryLocation(voyage.myShipBlockStack);
				endif;	
				app.myUtilityUA.utlUpdateMoveTrackedItem(control, _passport);
				delete control;
			endif;
			// ### TFS 62217 22Feb2024 NAVPW1
			
			if _passport.noErrors then													// ### TFS 62217 22Feb2024 NAVPW1
				pxyTi := app.myProxyManager.getProxyObject(ti).CM_TrackedItem;			//13.12.2023 naviv1 #61543
				if pxyTi = null then
					pxyTi := ti.pxyCreateUpdateProxy().CM_TrackedItem;
				endif;
				pxyTi.setTifromTransChange(true,null,null,voyage);
				pxyTi.changeState(TI_STATE_ONSHIP,_passport);
				pxyTi.setImExStatus(TI_IMEX_STATUS_IMPORT);								//12.01.2023 navhl20 #62032
				app.myUtilityUA.utlUpdateTrackedItem( pxyTi, null, TI_UPDMODE_NORMAL, null, null, null, _passport );
			endif;
			
			if _passport.noErrors and ti.locationId = null then						//12.01.2023 navhl20 #62032
				create control transient;
				control.setMoveMode(REAL_MODE);	
				control.isSystemMove := true;
				control.isWoChangeOfTransportRelShip := true;
				control.transferType := VESSEL_TYPE_LOLO;
				
				self.exclusiveLock(ti);
				control.setMyTrackedItem(ti);
				if voyage &lt;&gt; null then
					control.setMyToPrimaryLocation(voyage.myShipBlockStack);
				endif;	
				app.myUtilityUA.utlUpdateMoveTrackedItem(control, _passport);
				delete control;
			endif;
			delete pxyTi;
		endforeach;
	endif;
	
	if _passport.noErrors then
		_passport.doDeferredUpdates();
	endif;
epilog
	if pxyBol &lt;&gt; null then
		pxyBol.allBOLDtls.purge;
		delete pxyBol;
	endif;
	delete pxyTi;
	delete control;
	if allNewBOLDtlProxies &lt;&gt; null then
		//these proxies have not been committed yet so if there was an exception then need to remove proxy link
		foreach proxy in allNewBOLDtlProxies do
			app.myProxyManager.deleteProxyLink(proxy);
		endforeach;
		
		delete allNewBOLDtlProxies;
	endif;
end;</source>
        <Parameter name="_bol" type="CM_BOL" usage="io"/>
        <Parameter name="_myWorkorderDtl" type="CM_WorkOrderDtl"/>
        <Parameter name="_newId" type="String"/>
        <Parameter name="_newTransport" type="String"/>
        <Parameter name="_transport" type="CM_Object"/>
        <Parameter name="_tiArr" type="ObjectArray"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlConvertWOTransportToBook" id="215a62ef-3c2b-4572-892a-01393742b8b0">
        <source>utlConvertWOTransportToBook(_booking : CM_BookingRef io; _pxyWorkorderDtl : CM_WorkOrderDtl; _newId, _newTransport : String; _transport : CM_Object; _tiArr : ObjectArray; _term : CM_Terminal; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 May 2023	navhl20	ChangeRequest 56631:[56185] EUP - Transport Mode change - UI Changes
20 Jul 2023	navdap1	TFS 58923 EUP CallOff EDI Data Type / Data Load
29 Aug 2023	navma1 Bug 60135: MTN - Error 1090 when using Transport Mode Change
30 Aug 2023 navhl20 Bug 60135: MTN - Error 1090 when using Transport Mode Change
13 Dec 2023 naviv1	ChangeRequest 61543: EUP - Transport  Mode Change should create a new Work Order
04 Jan 2024 navlc30 ChangeRequest 59997: EUP | Work Order Transport Mode change - Rail Receive 
30 Jan 2024 navlc30 Bug 62217: MTN - 1090 exception when changing the transport mode from Rail to Ship 
*/

vars
	pxyBooking			: CM_BookingRef;
	bol					: CM_BOL;
	quantity			: Integer;
	voyage				: CM_Voyage;
	release				: CM_BulkRelease;
	bookingItem			: CM_BookingRefItem;
	product				: CM_Product;
	pxyBulkRelease		: CM_BulkRelease;
	proxyColl			: CM_ObjectArrayActual;
	proxy				: CM_Object;
	edition				: Integer;
	ti, pxyTi			: CM_TrackedItem;
	bolDtl				: CM_BOLDtl;
	wodReleaseRequest	: CM_BulkRelease;
	tiSet				: CM_TISet;
	reserveDetailArr	: ObjectSet;
	reserveDetail		: CM_ReserveDetail;
	isExact				: Boolean;
	
begin
	
	self.initialiseActivity();
	
	// do any pre-validation locks

	app.setContinueCMExceptions(true);
	
	app.myValUA.valWOTransportModeChange(_tiArr, _newTransport, _transport);									//30.01.2024 navlc30 #62217

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	if _transport.isKindOf(CM_Voyage) then														//04.01.2024 navlc30 #59997
		voyage := _transport.CM_Voyage;
	endif;
	
	// ### TFS 59411 (61855) 26Jan2024 NAVPW1 - Commented Out
	//The code below has the potential to cause issues if _pxyWorkorderDtl is null. Also assumes we have a CM_WodReceive
	//if _pxyWorkorderDtl &lt;&gt; null then
	//	bol := _pxyWorkorderDtl.CM_WodReceive.myBillOfLading;
	//endif;
	// ### TFS 59411 (61855) 26Jan2024 NAVPW1 - Commented Out
	
	if _pxyWorkorderDtl.isWodReceive then //If receival set bol
		bol := _pxyWorkorderDtl.CM_WodReceive.myBillOfLading;
		
	elseif _pxyWorkorderDtl.isWodRelease then //If release then set release request
		wodReleaseRequest := _pxyWorkorderDtl.CM_WodRelease.myReleaseRequest;
		
	endif;
	
	/*
	** Stage 1 - Create Booking/Release Request
	*/
	
	_booking := _term.allBookingRefsByRef[_newId];
	
	if _booking = null then
		if bol &lt;&gt; null then
			create pxyBooking transient;
			pxyBooking.populatePxyFromBoL(bol);
		// ### TFS 59411 (61855) 26Jan2024 NAVPW1	
		elseif wodReleaseRequest &lt;&gt; null then
			//Create booking from release request
			create tiSet transient;
			_tiArr.copy(tiSet);
			create pxyBooking transient;
			pxyBooking.populatePxyFromBulkRelease(wodReleaseRequest, tiSet);
			delete tiSet;
		endif;
	else
		pxyBooking := app.createUpdateProxy(_booking).CM_BookingRef;
	endif;
	
	if pxyBooking &lt;&gt; null then
		if _booking = null then
			if _newId &lt;&gt; null then
				pxyBooking.setBookingReference(_newId);
			endif;
			if voyage &lt;&gt; null then
				pxyBooking.setMyVoyage(voyage);
			endif;
		endif;
		
		if _pxyWorkorderDtl.isWodReceive then	// ### TFS 59411 (61855) 30Jan2024 NAVPW1 - We do not need to do this for a release as booking items are created correctly in pxyBooking.populatePxyFromBulkRelease based on the tis we are splitting
			foreach bookingItem in pxyBooking.allBookingRefItems do
				if bookingItem.myProduct = null then
					product := _tiArr.first.CM_TrackedItem.myProduct;
					bookingItem.setMyProduct(product);
				endif;
			endforeach;
			
			bookingItem := pxyBooking.allBookingRefItems.first;
			
			if bookingItem.quantity &lt; (bookingItem.allTIs.size + _tiArr.size) then
				quantity := (bookingItem.allTIs.size + _tiArr.size) - bookingItem.quantity;
				bookingItem.increaseItemQuantity(quantity);
			endif;
		endif;
		
		if _booking = null then
			create proxyColl transient;

			app.myUtilityCA.utlCreateWOBookingRef(pxyBooking, _passport, null, _booking, bol, _tiArr, voyage, proxyColl);

			pxyBulkRelease :=	pxyBooking.allReleaseRequests.first.CM_BulkRelease;

			if  not _passport.hasErrors and pxyBulkRelease &lt;&gt; null  then									//30.8.2023 navhl20 #60135
				app.myUtilityCA.utlCreateBulkRelease(pxyBulkRelease, release,  _booking, null, null, null, _passport);		// TFS 58923
			endif;
			
			if  not _passport.hasErrors and _booking &lt;&gt; null then	//could be null if there were warnings	//30.8.2023 navhl20 #60135
				app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(_booking);
			endif;
		else
			create proxyColl transient;

			app.myUtilityUA.utlUpdateWOBookingRef(pxyBooking, _tiArr, voyage, _passport, proxyColl);
			
			pxyBooking.pxyGetRealObjectAndEdition(_booking, edition);
			
			pxyBulkRelease:=pxyBooking.allReleaseRequests.first.CM_BulkRelease;
			
			if _passport.noErrors() then
			
				if pxyBulkRelease = null then
					release := _booking.allReleaseRequests.first.CM_BulkRelease;
					
					if release &lt;&gt; null then
						app.myUtilityDA.utlDeleteBulkRelease(release, _passport);
					endif;
				else
					pxyBulkRelease.pxyGetRealObjectAndEdition(release, edition);
					
					if release = null then
						app.myUtilityCA.utlCreateBulkRelease(pxyBulkRelease, release,  _booking, null, null, null, _passport);		// TFS 58923
					else
						app.myUtilityUA.utlUpdateBulkRelease(pxyBulkRelease, _booking, true, null, null, _passport);				// TFS 58923
					endif;
				endif;
			endif;
		endif;
	endif;
	
	/*
	** Stage 1.1 - Update original Release Request and remove redundant items.
	*/
	//Update Release request if this is a wod release
	if _pxyWorkorderDtl.isWodRelease then
		if wodReleaseRequest &lt;&gt; null then
			pxyBulkRelease := app.createUpdateProxy(wodReleaseRequest).CM_BulkRelease;	//Create Proxy
			create reserveDetailArr transient;											//Create a reserve detail array to stop updates while looping errors
			pxyBulkRelease.allReserveDetails.copy(reserveDetailArr);					//Copy all reserve details to array
			foreach ti in _tiArr as CM_TrackedItem do : tiLoop							//Loop the ti's
				foreach reserveDetail in reserveDetailArr as CM_ReserveDetail do		//Loop ther reserve details
					if not reserveDetail.doesTIMatchForRelease(ti, isExact) then		//If the ti's in the set do not match the reserve detail then continue loop
						continue;
					endif;
					
					pxyBulkRelease.allReserveDetails.remove(reserveDetail);				//Otherwise remove the reserve detail from the release request
					pxyBulkRelease.allTrackedItemsAssigned.remove(ti);					//Remove ti from the bulk release
					continue tiLoop;													//Then continue the ti loop
				endforeach;
			endforeach;
			app.myUtilityUA.utlUpdateBulkRelease(pxyBulkRelease, null, true, null, null, _passport);	//Update the bulk release
			reserveDetailArr.purge;														//Purge the reserve details as we will have the ones removed in here
			delete pxyBulkRelease;														//Delete the proxy release request
			delete reserveDetailArr;													//Delete the array used to hold the reserve details
		endif;
	endif;
	
	/*
	** Stage 2 - Update Tracked Item
	*/
	if not _passport.hasErrors then																			//30.8.2023 navhl20 #60135
		if bol &lt;&gt; null then																					//04.01.2024 navlc30 #59997
			foreach bolDtl in bol.allBOLDtls do
				if _booking &lt;&gt; null then
					foreach bookingItem in _booking.allBookingRefItems do
						if bookingItem.description = bolDtl.description then
							foreach ti in _tiArr as CM_TrackedItem do									//13.12.2023 naviv1 #61543
								pxyTi := app.myProxyManager.getProxyObject(ti).CM_TrackedItem;			//13.12.2023 naviv1 #61543
								if pxyTi = null then
									pxyTi := ti.pxyCreateUpdateProxy().CM_TrackedItem;
								endif;
								pxyTi.setTifromTransChange(false,_booking,bookingItem,voyage);
								pxyTi.changeState(TI_STATE_NOTIFIED,_passport);
								pxyTi.setImExStatus(TI_IMEX_STATUS_EXPORT);									//13.12.2023 naviv1 #61543
								app.myUtilityUA.utlUpdateTrackedItem( pxyTi, null, TI_UPDMODE_NORMAL, null, null, null, _passport );
								delete pxyTi;
							endforeach;
						endif;
					endforeach;
				endif;
			endforeach;
		elseif _pxyWorkorderDtl.isWodRelease and wodReleaseRequest &lt;&gt; null and _booking &lt;&gt; null then
			foreach ti in _tiArr as CM_TrackedItem do
				pxyTi := ti.pxyCreateUpdateProxy().CM_TrackedItem;
				foreach bookingItem in _booking.allBookingRefItems do :bookingItems
					if not bookingItem.doesTIMatchMe(ti, false) then
						continue;
					endif;
					pxyTi.setTifromTransChange(false, _booking, bookingItem, voyage);
					break bookingItems;
				endforeach;
				pxyTi.setImExStatus(TI_IMEX_STATUS_EXPORT);
				app.myUtilityUA.utlUpdateTrackedItem(pxyTi, null, TI_UPDMODE_NORMAL, null, null, null, _passport);
				delete pxyTi;
			endforeach;
		endif;
	endif;
epilog
	if pxyBooking &lt;&gt; null then					//29.08.2023 navma1 #60135
		pxyBooking.allBookingRefItems.purge;
		delete pxyBooking;
	endif;
	delete pxyTi;
	if proxyColl &lt;&gt; null then
		//these proxies have not been committed yet so if there was an exception then need to remove proxy link
		foreach proxy in proxyColl do
			app.myProxyManager.deleteProxyLink(proxy);
		endforeach;
		
		delete proxyColl;
	endif;
end;</source>
        <Parameter name="_booking" type="CM_BookingRef" usage="io"/>
        <Parameter name="_pxyWorkorderDtl" type="CM_WorkOrderDtl"/>
        <Parameter name="_newId" type="String"/>
        <Parameter name="_newTransport" type="String"/>
        <Parameter name="_transport" type="CM_Object"/>
        <Parameter name="_tiArr" type="ObjectArray"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlConvertWOTransportToRelease" id="46e9eb04-5eea-4225-8bfc-b7e5e251ecc8">
        <source>utlConvertWOTransportToRelease(_releaseRequest			: CM_BulkRelease io; 
								_pxyWorkOrderDtl		: CM_WorkOrderDtl;
								_newId, _newTransport	: String;
								_transport				: CM_Object;
								_objArr					: ObjectArray;
								_term					: CM_Terminal;
								_passport				: CM_Passport input;
								_quantityIfWle			: Integer);
/*

Purpose:			

Parameters:			_releaseRequest		CM_BulkRelease	
					_pxyWorkOrderDtl	CM_WorkOrderDtl	
					_newId				String			
					_newTransport		String			
					_transport			CM_Object		
					_objArr				ObjectArray		
					_term				CM_Terminal		
					_passport			CM_Passport		
					_quantityIfWle		Integer			

Return Value:		NONE

Date				Who		Reason
13 February 2024	navpw1	Initial creation TFS: 59411 (62272) - For Release By Type
16 February 2024	navpw1	TFS: 59411 (61867) - Added support for Release By Id
26 February 2024	navpw1	TFS: 59411 (61864) - Added support for changing transport mode from ship to road for Cargo Releases
15 April 2024		navpw1	TFS: 63647 (63670) - Added code to just update the transport mode of the release request for a release by type.
												Only if the entire wle has been selected. Instead of creating a new release request.
06 Dec 2024	navhl20 Bug MTN-33557: EUP | Change of Transport Mode for Release by Type not working for multiple Release Lines
*/

vars
	voyage					: CM_Voyage;
	wodRelease				: CM_WodRelease;
	wodReserveDetail,
	pxyWodReserveDetail		: CM_ReserveDetail;
	wodReserveSelection		: CM_ReserveSelection;
	wodReleaseRequest,
	pxyWodReleaseRequest,
	pxyReleaseRequest		: CM_BulkRelease;
	wodBookingRef,
	pxyWodBookingRef		: CM_BookingRef;
	wodBookingRefItem,
	bookingItem				: CM_BookingRefItem;
	wleArr					: CM_WLEArray;
	tiSet					: CM_TISet;
	wle						: CM_WorkListEntry;
	ti,
	pxyTi					: CM_TrackedItem;
	request					: CM_Request;
	reserveDetailArr		: ObjectSet;
	reserveSelection		: CM_ReserveSelection;
	reserveDetail			: CM_ReserveDetail;
	wleReserveDetail		: CM_ReserveDetail;
	wleReserveSelection		: CM_ReserveSelection;
	bookingItemArr			: CM_ObjectArrayActual;
	object					: Object;
	isExact					: Boolean;
	imexStatusChange		: Integer;
	wod						: CM_WorkOrder;
begin
	
	self.initialiseActivity();
	
	// do any pre-validation locks

	app.setContinueCMExceptions(true);
	
	app.myValUA.valWOTransportModeChange(_objArr, _newTransport, _transport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	if _transport.isKindOf(CM_Voyage) then
		voyage := _transport.CM_Voyage;
		
	endif;
	
	/*
	** Validation
	*/
	if _pxyWorkOrderDtl.isWodRelease then //If release then set release request
		wodRelease			:= _pxyWorkOrderDtl.CM_WodRelease;
		wodReleaseRequest	:= wodRelease.myReleaseRequest;
		wodReserveDetail	:= wodRelease.myReserveDetail;
		wodBookingRef		:= wodRelease.myBookingRef;
		wodBookingRefItem	:= wodRelease.myBookingRefItem;
		
		if wodReserveDetail &lt;&gt; null and wodReserveDetail.isReserveSelection then
			wodReserveSelection := wodReserveDetail.CM_ReserveSelection;
		endif;
		
	elseif _pxyWorkOrderDtl.isWodReceive then //If receival raise exception
		app.raiseUnexpectedProgramError(class.name, method.name, "Processing of 'CM_WodReceive' to create a release request is not supported");
		return;
		
	else
		app.raiseUnexpectedProgramError(class.name, method.name, "Processing of '" &amp; _pxyWorkOrderDtl.class.name &amp; "' to create a release request is not supported");
		return;
		
	endif;
	
	if wodReleaseRequest &lt;&gt; null and wodReleaseRequest.releaseByType then
		if wodReserveSelection.totalRequested - _quantityIfWle &lt; 0 then
			app.raiseCMException4(Quant_suppl_more_than_what_all, _quantityIfWle.String, wodReserveSelection.lineNumber.String,  wodReleaseRequest.code, wodReserveSelection.totalRequested.String, null, null);
			return;
		endif;
		
	endif;
	
	object := _objArr.first;
	if object.isKindOf(CM_WorkListEntry) then
		wle := object.CM_WorkListEntry; 
		if wle = null then
			app.raiseUnexpectedProgramError(class.name, method.name, "There was no wle passed into this method via _objArr, there needs to be one");
			return;
		endif;
	else
		if _objArr.isEmpty or not _objArr.first.isKindOf(CM_TrackedItem) then
			app.raiseUnexpectedProgramError(class.name, method.name, "There was no trackedItem passed into this method via _objArr, there needs to be at least one");
			return;
		endif;
	endif;
	
	/*
	** Stage 1 - Update Release By Id Release Request if this is a release by id
	** If this is done later causes the following error to be raised:
	** 85108: ERR_CARGO_MULTIPLE_REL
	*/
	if _pxyWorkOrderDtl.isWodRelease and wodReleaseRequest &lt;&gt; null and not wodReleaseRequest.releaseByType then
		//Release By Id
		pxyWodReleaseRequest := app.createUpdateProxy(wodReleaseRequest).CM_BulkRelease;				//Create Proxy
		create reserveDetailArr transient;																//Create a reserve detail array to stop updates while looping errors
		pxyWodReleaseRequest.allReserveDetails.copy(reserveDetailArr);									//Copy all reserve details to array
		create tiSet transient;
		_objArr.copy(tiSet);
		foreach ti in tiSet do : tiLoop
			foreach reserveDetail in reserveDetailArr as CM_ReserveDetail do : reserveDetailLoop		//Loop ther reserve details
				if not reserveDetail.doesTIMatchForRelease(ti, isExact) then							//If the ti's in the set do not match the reserve detail then continue loop
					continue reserveDetailLoop;
				endif;
				
				pxyWodReleaseRequest.allReserveDetails.remove(reserveDetail);							//Otherwise remove the reserve detail from the release request
				pxyWodReleaseRequest.allTrackedItemsAssigned.remove(ti);								//Remove ti from the bulk release
				continue tiLoop;																		//Then continue the ti loop
				
			endforeach;
		endforeach;
		
		app.myUtilityUA.utlUpdateBulkRelease(pxyWodReleaseRequest, null, true, null, null, _passport);	//Update the bulk release
		delete tiSet;
		
	elseif _pxyWorkOrderDtl.isWodRelease and wodBookingRef &lt;&gt; null then
		create tiSet transient;
		_objArr.copy(tiSet);
		
		foreach ti in tiSet do
			pxyTi := ti.pxyCreateUpdateProxy();
			pxyTi.setMyBooking(null, null);
			pxyTi.setBookingReference(null);
			//create tiExtraParams transient;
			//tiExtraParams.useSelectedBookingItem := true;
			app.myUtilityUA.utlUpdateTrackedItem(pxyTi, null, TI_UPDMODE_NORMAL, null, null, null, _passport);
			delete pxyTi;
			//delete tiExtraParams;
		endforeach;
		
		delete tiSet;
		
	endif;
	
	/*
	** Stage 2 - Create Release Request
	*/
	_releaseRequest := _term.getBulkReleaseFromCode(_newId);
	
	if _releaseRequest = null and wodReleaseRequest &lt;&gt; null then
		// ### TFS 63652 (63671) 08May2024 NAVPW1
		if wodReleaseRequest &lt;&gt; null and 
			wodReleaseRequest.releaseByType and 
			wodReserveDetail &lt;&gt; null and 
			wodReserveDetail.totalRequested = _quantityIfWle
		then
			//If counts match/splitting entire thing then update wodReleaseRequest with the new transport mode
			pxyWodReleaseRequest := app.createUpdateProxy(wodReleaseRequest).CM_BulkRelease;
			
			if pxyWodReleaseRequest.code &lt;&gt; _newId then
				pxyWodReleaseRequest.setCode(_newId);
			endif;
			
			if _newTransport = TI_TRANSMODE_SHIP_STR then
				pxyWodReleaseRequest.setType(BR_TYPE_SHIP);
				
			elseif _newTransport = TI_TRANSMODE_RAIL_STR then
				pxyWodReleaseRequest.setType(BR_TYPE_RAIL);
				
			elseif _newTransport = TI_TRANSMODE_ROAD_STR then
				pxyWodReleaseRequest.setType(BR_TYPE_ROAD);
				
			endif;
			
			if wodReleaseRequest.allReserveDetails.size &gt; 1 then												//06.12.2024 navhl20 #33557
				foreach reserveDetail in pxyWodReleaseRequest.allReserveDetails do
					if reserveDetail.getDescription &lt;&gt; wodReserveDetail.getDescription() then
						pxyWodReleaseRequest.allReserveDetails.remove(reserveDetail);
						delete reserveDetail;
					endif;
				endforeach;
				if wodReleaseRequest.code &lt;&gt; pxyWodReleaseRequest.code then
					pxyWodReleaseRequest.setContext(RelReqContext_None);
					app.myUtilityCA.utlCreateBulkRelease(pxyWodReleaseRequest, _releaseRequest, null, null, null, null, _passport);
				endif;
			else
				//Call utl to update bulk release then return
				app.myUtilityUA.utlUpdateBulkRelease(pxyWodReleaseRequest, null, true, null, null, _passport);	//Update the bulk release
				_releaseRequest := wodReleaseRequest; //As _releaseRequest is null as we couldn't find it on terminal. We need to return the old one out. (Update the old one)
			endif;
			/*
			//06.12.2024 navhl20 #33557
			//Call utl to update bulk release then return
			app.myUtilityUA.utlUpdateBulkRelease(pxyWodReleaseRequest, null, true, null, null, _passport);	//Update the bulk release
			_releaseRequest := wodReleaseRequest; //As _releaseRequest is null as we couldn't find it on terminal. We need to return the old one out. (Update the old one)
			*/
			return;
			
		// ### TFS 63652 (63671) 08May2024 NAVPW1
		elseif wodReleaseRequest &lt;&gt; null and wodReleaseRequest.releaseByType then
			//Create release Request by type from release request
			create wleArr transient;
			_objArr.copy(wleArr);
			
			create pxyReleaseRequest transient;
			pxyReleaseRequest.populatePxyFromBulkRelease(wodReleaseRequest, wleArr, null, _quantityIfWle, _newTransport);
			pxyReleaseRequest.setCode(_newId);
			pxyReleaseRequest.setMyVoyage(voyage);
			delete wleArr;
			
		else
			//Create release Request by id from release request
			create tiSet transient;
			_objArr.copy(tiSet);
			
			create pxyReleaseRequest transient;
			pxyReleaseRequest.populatePxyFromBulkRelease(wodReleaseRequest, null, tiSet, _quantityIfWle, _newTransport);
			pxyReleaseRequest.setCode(_newId);
			pxyReleaseRequest.setMyVoyage(voyage);
			delete tiSet;
		endif;
		
	elseif _releaseRequest = null and 
		wodBookingRef &lt;&gt; null
	then
		//Create release Request by id from booking
		create tiSet transient;
		_objArr.copy(tiSet);
		
		create pxyReleaseRequest transient;
		pxyReleaseRequest.populatePxyFromBookingPartial(wodBookingRef, tiSet, _newTransport);
		pxyReleaseRequest.setCode(_newId);
		pxyReleaseRequest.setMyVoyage(voyage);
		delete tiSet;
		
	else
		//app.raiseUnexpectedProgramError(class.name, method.name, "Expecting release request to not exist."); //Expecting release request to not exist
		//return;
		// ### TFS 63647 (63670) 15Apr2024 NAVPW1
		if wodReleaseRequest &lt;&gt; null and wodReleaseRequest.releaseByType and wodReserveDetail &lt;&gt; null and wodReserveDetail.totalRequested = _quantityIfWle then
			//If counts match/splitting entire thing then update wodReleaseRequest with the new transport mode
			
			pxyWodReleaseRequest := app.createUpdateProxy(wodReleaseRequest).CM_BulkRelease;
			if _newTransport = TI_TRANSMODE_SHIP_STR then
				pxyWodReleaseRequest.setType(BR_TYPE_SHIP);
				
			elseif _newTransport = TI_TRANSMODE_RAIL_STR then
				pxyWodReleaseRequest.setType(BR_TYPE_RAIL);
				
			elseif _newTransport = TI_TRANSMODE_ROAD_STR then
				pxyWodReleaseRequest.setType(BR_TYPE_ROAD);
				
			endif;
			
			//Call utl to update bulk release then return
			app.myUtilityUA.utlUpdateBulkRelease(pxyWodReleaseRequest, null, true, null, null, _passport);	//Update the bulk release
			return;
			
		else
			app.raiseUnexpectedProgramError(class.name, method.name, "Expecting release request to not exist."); //Expecting release request to not exist
			return;
			
		endif;
		// ### TFS 63647 (63670) 15Apr2024 NAVPW1
	endif;
	
	if pxyReleaseRequest &lt;&gt; null then
		if voyage &lt;&gt; null then
			pxyReleaseRequest.setMyVoyage(voyage);
		endif;
		
		app.myUtilityCA.utlCreateBulkRelease(pxyReleaseRequest, _releaseRequest, null, null, null, null, _passport);
		
	endif;
	
	/*
	** Stage 3 - Update original Release Request/Booking and remove redundant items.
	*/
	//Update Release request if this is a wod release
	if _pxyWorkOrderDtl.isWodRelease and wodReleaseRequest &lt;&gt; null and wodReleaseRequest.releaseByType then
		//Release By Type
		request := wle.myRequest;
		if request = null then
			app.raiseUnexpectedProgramError(class.name, method.name, "Request on wle should not be null");
			return;
		endif;
		
		if not request.isWOReleaseCargoRequest then
			app.raiseUnexpectedProgramError(class.name, method.name, "Request should be of type CM_WOReleaseCargoRequest");
			return;
		endif;
		
		wleReserveDetail := request.CM_WOReleaseCargoRequest.myReserveDetail;
		
		if not wleReserveDetail.isReserveSelection then
			app.raiseUnexpectedProgramError(class.name, method.name, "Reserve Detail associated with the wle should be a CM_ReserveSelection");
			return;
		endif;
		
		wleReserveSelection := wleReserveDetail.CM_ReserveSelection;
		
		pxyWodReleaseRequest := app.createUpdateProxy(wodReleaseRequest).CM_BulkRelease;	//Create Proxy
		create reserveDetailArr transient;											//Create a reserve detail array to stop updates while looping errors
		pxyWodReleaseRequest.allReserveDetails.copy(reserveDetailArr);					//Copy all reserve details to array
		foreach reserveSelection in reserveDetailArr as CM_ReserveSelection do		//Loop ther reserve details
			if not reserveSelection.isMatch(wleReserveSelection) then		//If the ti's in the set do not match the reserve detail then continue loop
				continue;
			endif;
			
			if wleReserveSelection.totalRequested - _quantityIfWle &lt; 0 then	//If we are left with a quantity less than 0 this is an error
				app.raiseUnexpectedProgramError(class.name, method.name, "The quantity to split cannot be less than what is requested on the work order detail. Total Requested (On Parent Work order): '" &amp; wleReserveSelection.totalRequested.String &amp; "' | Amount to Split: '" &amp; _quantityIfWle.String &amp; "'");
				return;
			endif;
			
			reserveSelection.setTotalRequested(wleReserveSelection.totalRequested - _quantityIfWle);
			
		endforeach;
		
		app.myUtilityUA.utlUpdateBulkRelease(pxyWodReleaseRequest, null, true, null, null, _passport);	//Update the bulk release
		
	elseif _pxyWorkOrderDtl.isWodRelease and wodBookingRef &lt;&gt; null then
		//Booking
		pxyWodBookingRef := app.createUpdateProxy(wodBookingRef).CM_BookingRef;							//Create Proxy
		
		create bookingItemArr transient;																//Create a booking item array to stop updates while looping errors
		pxyWodBookingRef.allBookingRefItems.copy(bookingItemArr);										//Copy all booking items to array
		
		create tiSet transient;
		_objArr.copy(tiSet);
		
		foreach ti in tiSet do : tiLoop
			foreach bookingItem in bookingItemArr as CM_BookingRefItem do : bookingItemLoop				//Loop the booking items
				if not bookingItem.doesTIMatchMe(ti, isExact) then										//If the ti's in the set do not match the booking item then continue loop
					continue bookingItemLoop;
				endif;
				
				if bookingItem.quantity &gt; 0 then
					bookingItem.decreaseItemQuantity(1);												//Lower the booking item quantity as this ti will be removed.
				endif;
				
				if bookingItem.quantity = 0 then														//If the booking item has a quantity that is less than 1
					pxyWodBookingRef.allBookingRefItems.remove(bookingItem);							//Remove the booking item from the booking
				endif;
				
				continue tiLoop;
				
			endforeach;
		endforeach;
		
		app.myUtilityUA.utlUpdateBookingRef(pxyWodBookingRef, _passport, bookingItemArr);				//Update the booking
		delete tiSet;
		
	endif;
	
	/*
	** Stage 4 - Update Tracked Item (Ony for release by ID)
	*/
	if not _passport.hasErrors then
		if _pxyWorkOrderDtl.isWodRelease and 
			wodReleaseRequest &lt;&gt; null and _releaseRequest &lt;&gt; null and not wodReleaseRequest.releaseByType
		then
			imexStatusChange := TI_IMEX_STATUS_EXPORT;
			
		elseif _pxyWorkOrderDtl.isWodRelease and _releaseRequest &lt;&gt; null and wodBookingRef &lt;&gt; null then
			imexStatusChange := TI_IMEX_STATUS_IMPORT;
			
		endif;
		
		if imexStatusChange &gt; 0 then
			create tiSet transient;
			_objArr.copy(tiSet);
			
			foreach ti in tiSet do
				pxyTi := ti.pxyCreateUpdateProxy();
				pxyTi.setImExStatus(imexStatusChange);
				app.myUtilityUA.utlUpdateTrackedItem(pxyTi, null, TI_UPDMODE_NORMAL, null, null, null, _passport);
				delete pxyTi;
			endforeach;
			
			delete tiSet;
		endif;
		
	endif;
	
epilog
	delete pxyReleaseRequest;
	if reserveDetailArr &lt;&gt; null then
		reserveDetailArr.purge;														//Purge the reserve details as we will have the ones removed in here
		delete reserveDetailArr;													//Delete the array used to hold the reserve details
	endif;
	if bookingItemArr &lt;&gt; null then
		bookingItemArr.purge;														//Purge the bookingItems as we will have the ones removed in here
		delete bookingItemArr;														//Delete the set used to hold the booking items
	endif;
	if pxyWodReleaseRequest &lt;&gt; null then
		pxyWodReleaseRequest.allReserveDetails.purge();									//18.12.2024 navhl20 #33557
	endif;
	delete pxyWodReleaseRequest;													//Delete the proxy release request
	delete pxyWodBookingRef;														//Delete the proxy booking
	delete tiSet;
	delete wleArr;
	
end;</source>
        <Parameter name="_releaseRequest" type="CM_BulkRelease" usage="io"/>
        <Parameter name="_pxyWorkOrderDtl" type="CM_WorkOrderDtl"/>
        <Parameter name="_newId" type="String"/>
        <Parameter name="_newTransport" type="String"/>
        <Parameter name="_transport" type="CM_Object"/>
        <Parameter name="_objArr" type="ObjectArray"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_quantityIfWle" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="utlCopyEnquiryConfig" id="808e640b-9bf5-4a6c-907b-ebe6f233f6f2">
        <updating/>
        <source>utlCopyEnquiryConfig(_fromUser : CM_User; _toUsers : CM_UserSet; _cargoTypes : CM_CargoBOLTypeArray; _passport : CM_Passport input) updating;
/*

Purpose:	To copy the user enquiry config to the fromUser to each to the toUsers, for each cargo type in the list		
			CCMS 1776
Parameters:			

Return Value:		


Date		Who		Reason
22 Aug 2011	cnwjre1	Initial creation

*/

vars
	cargoType	: CM_CargoBOLType;
	fromConfig,
	toConfig	: CM_UserConfigCargoType;
	toUser		: CM_User;
begin
	self.initialiseActivity();

	app.setContinueCMExceptions(false);
	
	foreach cargoType in _cargoTypes do
		fromConfig := _fromUser.allUserCargoTypes[_fromUser, cargoType];
		foreach toUser in _toUsers do
			toConfig := toUser.allUserCargoTypes[toUser, cargoType];
			// always delete the existing target config - if from user is default (no instance) this sets the target as default as well
			//  and for a copy it forces the new target to be a full copy of the from user config
			if toConfig &lt;&gt; null then
				toConfig.erase(NORMAL_ERASE);
			endif;
			if fromConfig &lt;&gt; null then
				create toConfig persistent;
				toConfig.copyFrom(fromConfig, toUser, true);
			endif;
		endforeach;
	endforeach;
	
epilog
end;</source>
        <Parameter name="_fromUser" type="CM_User"/>
        <Parameter name="_toUsers" type="CM_UserSet"/>
        <Parameter name="_cargoTypes" type="CM_CargoBOLTypeArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCopyTerminalAreaView" id="5daa64f2-be62-4e83-89f2-e6c3524e9574">
        <updating/>
        <source>utlCopyTerminalAreaView(_taViewToCopy : CM_TerminalAreaView;newTAArea : CM_TerminalAreaView output; _newName : String; _privateUser : CM_User; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 November 2010	cnwer1	Initial creation

*/

vars
	pxyTAArea  : CM_TerminalAreaView;
begin
	self.initialiseActivity();

	app.setContinueCMExceptions(false);
	pxyTAArea:=_taViewToCopy.copyTAView();
	pxyTAArea.setName(_newName);
	pxyTAArea.setUser(_privateUser);

	app.myUtilityCA.utlCreateTerminalAreaView(pxyTAArea,newTAArea,_passport);
	
	
epilog
	delete pxyTAArea;
end;</source>
        <Parameter name="_taViewToCopy" type="CM_TerminalAreaView"/>
        <Parameter name="newTAArea" type="CM_TerminalAreaView" usage="output"/>
        <Parameter name="_newName" type="String"/>
        <Parameter name="_privateUser" type="CM_User"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateOutturns" id="c670f714-4244-4fd9-af65-c425c84c2a63">
        <source>utlCreateOutturns( _bolSet : CM_BOLSet; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 October 2017	jlgndl1	Initial creation	TFS 6940

*/

vars
	
	bol : CM_BOL;
	voyEvent : CMEVT_VoyageEvent;
	cmifEventCtrl : CMIF_VoyageEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
begin
	
	foreach bol in _bolSet do
		
		/* //17/02/2025	navkc1 JIRA Bug MTN-33582
		voyEvent := app.createEvent(EVT_VoyBolOutturnReq, app.actualTimeServer, bol.myTerminal, app.myPassport.userCode, false, false,0).CMEVT_VoyageEvent;
		if voyEvent &lt;&gt; null then
			voyEvent.setMyVoyage( bol.getMyVoyage );
			voyEvent.setMyBol( bol );
		endif;
		*/
		
		//17/02/2025	navkc1 JIRA Bug MTN-33582 - Start
		delete cmifEventCtrl;
		create cmifEventCtrl transient;
		cmifEventCtrl.type := EVT_VoyBolOutturnReq;
		cmifEventCtrl.dateTime := app.actualTimeServer();
		cmifEventCtrl.myTerminal := bol.myTerminal;
		cmifEventCtrl.userCode := app.myPassport.userCode;
		cmifEventCtrl.myVoyage := bol.getMyVoyage();
		cmifEventCtrl.myBOL := bol;
		
		voyEvent := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_VoyageEvent;
		//17/02/2025	navkc1 JIRA Bug MTN-33582 - End
		
		if _passport.hasErrors then
			break;
		endif;
		
	endforeach;
	
epilog
	delete cmifEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
end;</source>
        <Parameter name="_bolSet" type="CM_BOLSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCustomsStatusMessageAction" id="3824b173-d8c4-451b-a76d-c33e9b4ddb97">
        <source>utlCustomsStatusMessageAction(_customsMessage : CM_CustomsStatusMessage input; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:	01 October 2008 By Graeme Black cnwgb1
// Purpose:	 CCMS SFW 1012 PAR 17931)
// ---------------------------------------------------------------------------
//6/11/2019	JLGNS1	ChangeRequest 46721: PEN - CAMIR Message Processing
vars
	ediAction : CM_EDIAction;
	ediActionCode : String;
	iter : Iterator;
	theBOL : CM_BOLIn;
	stopType : CM_StopsTable;
	actionString : String;
	cleared : Boolean;
	stopExists : Boolean;
	tmpEDIFileType	: CM_EDIFileType;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(false);

	theBOL := _customsMessage.myBOL;
	if theBOL = null then
		//error
		return;
	endif;

	//tmpEDIFileType := app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileTypeX12_350_4010, null);
	tmpEDIFileType := app.myRoot.allEDIFileTypes.getAtKeyGeq(EDIFileTypeCAMIR_CustomsStatus, null);
	
	//if tmpEDIFileType = null or tmpEDIFileType.type &lt;&gt; EDIFileTypeX12_350_4010 then
	//	app.raiseUnexpectedProgramError(class.name, method.name, 'EDI File Type X12_350_4010 not found');
	//	return;
	//endif;

	// The following code needs to be changed to allow for a dict on CM_EDIAction.keyword - refer PAR 21436
	iter := tmpEDIFileType.allEDIActions.createIterator();
	ediActionCode := _customsMessage.dispositionCode;
	
	while iter.next(ediAction) do

		if ediAction.keyword &lt;&gt; ediActionCode then
			continue;
		endif;
		
		if not ediAction.actionType.isOneOf(EDIAction_None,						//ChangeRequest 46721
											EDIAction_PlaceHold,				//ChangeRequest 46721
											EDIAction_RemoveHolds,				//ChangeRequest 46721
											EDIAction_SetEntries,				//ChangeRequest 46721
											EDIAction_SetReleased,				//ChangeRequest 46721
											EDIAction_SubtractFromEntries,		//ChangeRequest 46721
											EDIAction_SubtractFromRelease) then	//ChangeRequest 46721
			continue;															//ChangeRequest 46721
		endif;
		
		if ediAction.actionType = null then
			app.raiseCMException1(ERR_CustomsActionDefined, ediAction.keyword &amp; ' ' &amp; ediAction.name , ETRow_ActionType, ediAction);
			return;
		endif;
		
		if ediAction.actionType = EDIAction_None then
			continue;
			
		elseif ediAction.actionType = EDIAction_SetEntries then
			if actionString = null then
				actionString := ediAction.actionType;
			else
				actionString := actionString &amp; ", " &amp; ediAction.actionType;
			endif;
			theBOL.setCustomsEntries( _customsMessage.quantity );
			
		elseif ediAction.actionType = EDIAction_SetReleased then
			if actionString = null then
				actionString := ediAction.actionType;
			else
				actionString := actionString &amp; ", " &amp; ediAction.actionType;
			endif;
			theBOL.setCustomsReleased( _customsMessage.quantity );
			
		elseif ediAction.actionType = EDIAction_SubtractFromEntries then
			if actionString = null then
				actionString := ediAction.actionType;
			else
				actionString := actionString &amp; ", " &amp; ediAction.actionType;
			endif;
			theBOL.subtractCustomsEntries( _customsMessage.quantity );
			
		elseif ediAction.actionType = EDIAction_SubtractFromRelease then
			if actionString = null then
				actionString := ediAction.actionType;
			else
				actionString := actionString &amp; ", " &amp; ediAction.actionType;
			endif;
			theBOL.subtractCustomsReleased( _customsMessage.quantity );
			
		elseif ediAction.actionType = EDIAction_PlaceHold then
			stopType := ediAction.myActionObject.CM_StopsTable;
			if stopType = null then
				//error 
				return;
			endif;
			theBOL.createAStop(stopType, false, _passport );
			if actionString = null then
				actionString := app.getErrorString(Placed) &amp; " " &amp; stopType.heading;
			else
				actionString := actionString &amp; ", " &amp; app.getErrorString(Placed) &amp; " " &amp; stopType.heading;
			endif;
			
		elseif ediAction.actionType = EDIAction_RemoveHolds then
			stopType := ediAction.myActionObject.CM_StopsTable;
			if stopType = null then
				//error
				return;
			endif;
			theBOL.removeAStop(stopType, false, _passport );
			if actionString = null then
				actionString := app.getErrorString(Removed) &amp; " " &amp; stopType.heading;
			else
				actionString := actionString &amp; ", " &amp; app.getErrorString(Removed) &amp; " " &amp; stopType.heading;
			endif;
		//cnwmc5 - 11 July 2014 - CCMs 2353 PEN
		/*elseif ediAction.actionType = EDIAction_DeleteBOL then
			//set the bol ext to be deleted.
			bolExt.setAction(EDIX12AmendmentDelete);
			if actionString = null then
				actionString := "Deleted";
			else
				actionString := actionString &amp; ", " &amp; "Deleted";
			endif;
			
		elseif ediAction.actionType = EDIAction_AddBOL then
			bolExt.setAction(EDIX12AmendmentAdd);
		*/
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled actionType (' &amp; ediAction.actionType &amp; ')');
			return;
		endif;
	endwhile;
	
	//cnwmc5 - 17 July 2014 - CCMS 2353 PEN
	//Check to see if the Customs Stop(s) should be removed or re-applied.
	if theBOL.customsQuantityReleased &gt;= theBOL.customsQuantityEntered then
		stopType := _passport.myTerminal.getConfig(EdiCustomsStopsTable).CM_StopsTable;
		
		if stopType &lt;&gt; null then
			if theBOL.hasStopOfType(stopType) then
				theBOL.removeAStop(stopType, false, _passport );
				
				if actionString = null then
					actionString := app.getErrorString(Removed) &amp; " " &amp; stopType.heading;
				else
					actionString := actionString &amp; ", " &amp; app.getErrorString(Removed) &amp; " " &amp; stopType.heading;
				endif;
			endif;
		endif;
	else
		stopType := _passport.myTerminal.getConfig(EdiCustomsStopsTable).CM_StopsTable;
		
		if not theBOL.hasStopOfType(stopType) then
			theBOL.createAStop(stopType, false, _passport );
			
			if actionString = null then
				actionString := app.getErrorString(Placed) &amp; " " &amp; stopType.heading;
			else
				actionString := actionString &amp; ", " &amp; app.getErrorString(Placed) &amp; " " &amp; stopType.heading;
			endif;
		endif;
	endif;

	//_customsMessage.updateStatus();
	
	if actionString = null then
		_customsMessage.setActionTaken( EDIAction_None );
	else
		_customsMessage.setActionTaken( actionString );
	endif;

epilog
	delete iter; //cnwrs1 20 May 2010 unit test leakage
    
end;</source>
        <Parameter name="_customsMessage" type="CM_CustomsStatusMessage" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteBOLGeneralCargo" id="b978fd46-b3d6-417a-ab79-980f3b036501">
        <updating/>
        <source>utlDeleteBOLGeneralCargo(_deletionController : CMIF_BOLOutDeletionController;
						_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     27 February 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	realChildTI		: CM_TrackedItem;
	txnCtrl			: CMIF_PackTransController;
	moveController	: CMIF_MoveController;
	bolOut			: CM_BOLOut;
	parentTI		: CM_TrackedItem;
	isSubTerminalOn,
	doUnpack		: Boolean;
begin
	self.initialiseActivity();
	
	bolOut := _deletionController.myBOLOut;
	
	if bolOut = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No BOLOut was associated with the deletion controller');
		return;
	endif;
	
	if _deletionController.myToLocation = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'The unpack To Location is null');
		return;
	endif;
	
	parentTI := bolOut.myMasterTI;
	doUnpack := (bolOut.processOption = Process_Pack and parentTI &lt;&gt; null);

	isSubTerminalOn := app.isSubTerminalsOn(bolOut.myTerminal);

	create txnCtrl transient;
	txnCtrl.dateTime		:= app.actualTimeServer;
	txnCtrl.operatorCode	:= bolOut.myOperator.code;
	txnCtrl.myTerminal		:= bolOut.myTerminal;
	txnCtrl.userId			:= app.getMyUserCode;	
	txnCtrl.userGenerated	:= true;
	
	create moveController transient;
	moveController.setMoveMode(REAL_MODE);
	moveController.isSystemMove := true;
	moveController.isForcedMove := true;//don't complain if TIs arn't in from location - this is because they were packed
	moveController.setMyToPrimaryLocation(_deletionController.myToLocation);
	
	app.setContinueCMExceptions(true);
	if doUnpack then
		//unpack/detach
		//the master TI's collection of children should always be the same as the 
		//BOL's.allTrackedItems, but if it's not this doesn't really matter, just unpack what we can
		//parentTI.getAllChildren(children);//PAR 22954
		foreach realChildTI in parentTI.allChildren do //PAR 25103 - cnwsh3 allChildren is now unprotected so we reference it directly. Reverses PAR22954.
			parentTI.detachChild(realChildTI);
		endforeach;
		
		if _deletionController.createUnpackTxns then
			// UnPack the TIs.  This transaction is invoiceable.
			txnCtrl.noCharge := (not _deletionController.createUnpackCharges);
			txnCtrl.type := TRANS_TYPE_UNPACK;
			
			foreach realChildTI in bolOut.allTrackedItems do
				if not _passport.noErrors then
					break;
				endif;
				
				txnCtrl.myTrackedItem := realChildTI;
				txnCtrl.myOtherTrackedItem := parentTI;
				realChildTI.createTransaction(txnCtrl, _passport);
			endforeach;
		endif;
	endif;
	
	if not _passport.noErrors then
		return;
	endif;
	
	if _deletionController.createReceivalTxns then
		// UnPack the TIs.  This transaction is invoiceable.
		txnCtrl.noCharge := (not _deletionController.createReceiveCharges);
		txnCtrl.type := TRANS_TYPE_RECEIVE;
		
		foreach realChildTI in bolOut.allTrackedItems do
			if not _passport.noErrors then
				break;
			endif;
			
			txnCtrl.myTrackedItem := realChildTI;
			realChildTI.createTransaction(txnCtrl, _passport);
			
// cnwdad1 25/08/2009 - CCMS 1875.
			if isSubTerminalOn and realChildTI.mySubTerminal &lt;&gt; null then
				txnCtrl.type := app.getSubTerminalReceiveTxnType(realChildTI.mySubTerminal.type, TI_TRANSMODE_INTERNAL);
				realChildTI.createTransaction(txnCtrl, _passport);
				txnCtrl.type := TRANS_TYPE_RECEIVE;
			endif;
		endforeach;
	endif;

	if not _passport.noErrors then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	moveController.setMyTrackedItem(bolOut.allTrackedItems.first);
	
	foreach realChildTI in bolOut.allTrackedItems do
		if realChildTI = moveController.myTrackedItem then
			continue;
		endif;
		
		realChildTI.changeState(TI_STATE_NORMAL, _passport);	
		moveController.allOtherTrackedItems.add(realChildTI);
	endforeach;

	app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
		
	if not _passport.noErrors then
		return;
	endif;
	
	if bolOut.myStockOrderHeader &lt;&gt; null then
		bolOut.myStockOrderHeader.doUnmatch(bolOut, _passport);
	endif;
	
	bolOut.erase(NORMAL_ERASE);
	
epilog
	delete moveController;
	delete txnCtrl;
end;</source>
        <Parameter name="_deletionController" type="CMIF_BOLOutDeletionController"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteRateEntry" id="b9ea200a-9fc4-445c-a2d5-420502bd5426">
        <source>utlDeleteRateEntry(_proxyRateEntry:CM_RateEntry; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	realRateEntry:CM_RateEntry;
	expectedEdition:Integer;
	codeChanged:Boolean;
	eventStr : String;
	theTerminal : CM_Terminal;
	
begin

	self.initialiseActivity();

	_proxyRateEntry.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxyRateEntry.pxyGetRealObjectAndEdition(realRateEntry, expectedEdition);
	
	if realRateEntry = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_RateEntry.name, null, null);
		return;
	endif;

	app.myValDA.valRateEntry( _proxyRateEntry);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realRateEntry);

	if _passport.noErrors and realRateEntry.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'RateEntry', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realRateEntry, true);
	endif;
	
	if _passport.noErrors then
		realRateEntry.setForUpdate(_proxyRateEntry);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realRateEntry, false);
	endif;

end;</source>
        <Parameter name="_proxyRateEntry" type="CM_RateEntry"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDetachChildrenAndMove" id="50945989-a792-4b3f-a279-3cc2b77596e7">
        <updating/>
        <source>utlDetachChildrenAndMove(_parentTI : CM_TrackedItem input; _passport : CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/05/2024	navdap1		Initial creation TFS 63619 CUX | FR - POST and PUT /Cargo not saving Customs References for Onboard Cargo
// 07/08/2024	navdap1		TFS 65549 CUX - Updating Trailer via PUT /cargo Changes Onboard Cargo to Child Cargo
//
vars
	children : CM_TISet;
	child : CM_TrackedItem;
	moveController : CMIF_MoveController;

begin
	self.initialiseActivity();
	app.setContinueCMExceptions(false);
	
	if not _parentTI.isMAFI() and not _parentTI.isTrailer() then	// TFS 65549
		return;
	endif;
	if _parentTI.allChildren.isEmpty then
		return;
	endif;
	
	// detach all child cargo items, and move them to the parent location controller instead
	create children transient;
	_parentTI.allChildren.copy(children);
	_parentTI.detachChildren();
	
	create moveController transient;
	moveController.setMyToPrimaryLocation(_parentTI.CM_TILC.allLCs.first);
	foreach child in children do
		moveController.setMyTrackedItem(child);
		app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
		
		if  _passport.noErrors() then
			if moveController.myToPrimaryLocation.myTerminalArea &lt;&gt; null then
				app.myEventManager.createSingleObjInfoNoteEvt(moveController.myToPrimaryLocation.myTerminalArea,
					_passport.myTerminal.getTerminalEvent(EVENT_TI_MOVE), moveController.myToPrimaryLocation);
			elseif moveController.myToPrimaryLocation.isKindOf(CM_VoyageController) then
				app.myEventManager.createSingleObjInfoNoteEvt(moveController.myToPrimaryLocation.CM_VoyageController.myVoyage,
					_passport.myTerminal.getTerminalEvent(EVENT_TI_MOVE), moveController.myToPrimaryLocation);
			endif;
		endif;
	endforeach;
	
epilog
	delete children;
	delete moveController;
end;</source>
        <Parameter name="_parentTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDetachTIsFromBOLDtl" id="c2d12313-3d69-461e-bec0-1f8c518c2dd5">
        <source>utlDetachTIsFromBOLDtl(_tis : CM_TISet input; _passport : CM_Passport input);
vars
	ti : CM_TrackedItem;
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(false);
	
	foreach ti in _tis do
		ti.createBOLTransfers( ti.myReceivalBOL, null, _passport );	//28 Apr 2016	NDL	TFS 1903
		ti.setBOLDtl(null);
		ti.setMyReceivalBOL(null);		//cnwmc5 - 1 May 2014 - PAR 34074
		ti.setBOL(null);				//cnwmc5 - 6 May 2014 - PAR 34074
	endforeach;
end;
</source>
        <Parameter name="_tis" type="CM_TISet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDisassembleLogs" id="7f065ebb-be56-4af9-aee7-df9f60bfff5f">
        <source>utlDisassembleLogs(_oldLog : CM_Log input; _logRegradeArray : CMIF_LogRegradeArray; 
		_residualLength, _residualVolume : Real; 
		_reason, _recovery, _comment : String;
		_passport : CM_Passport input);

vars
	cancelSave				: Boolean;
	newLog					: CM_Log;
	tmpLogRegrade			: CMIF_LogRegrade;
	location, 
	newLocation				: CM_LocationsController;
	updCntrl,
	updCntrl2				: CMIF_TIUpdateController;
	moveController			: CMIF_MoveController;
	//logSet					: CM_TISet;
	//txnParams				: CMIF_TITransactionController;
	//transaction				: CM_Reassembly;
	startingLocation		: CM_LocationsController;
	//rejectTrxn				: CM_Reject;
//	reassemblySet			: CM_ReassemblySet;
	newLogLength			: Decimal[14,4];
	newLogVolume			: Decimal[12,4];
	newLogWeight			: Decimal[14,4];
		
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	// Validate transaction.
	app.myValUA.valDisassembleLogs(_oldLog, _logRegradeArray, _residualLength, _residualVolume, _reason, _recovery, _passport.userCode);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	updCntrl := app.createTIUpdateControl(TI_UPDMODE_RECEIPT, _passport.userCode, null);
	updCntrl.transactionType := TRANS_TYPE_REASSEMBLY;	

	// Initialise move controller parameters.
	create moveController transient;
	moveController.setMoveMode(REAL_MODE);
	moveController.isSystemMove := true;

	// Process each new log.
	foreach tmpLogRegrade in _logRegradeArray do
		// Get cloned copy of old log.
		newLog := _oldLog.cloneSelf(false);
		
		//moved to setFromCMIFDisassembly. One call does all.
		// Set new id.	
		//newLog.changeId(tmpLogRegrade.id);		
		// Clone log references and do initial move.
		//newLog.cloneReferences(_oldLog, updCntrl);
		// Set new attributes and references.
		moveController.setMyToPrimaryLocation(_oldLog.myPrimaryActualLocation);
		newLog.setFromCMIFDisassembly(tmpLogRegrade, _oldLog, updCntrl, moveController, _passport);
		if (not _passport.noErrors) then
			break;
		endif;
		updCntrl2 := app.createTIUpdateControl(TI_UPDMODE_NORMAL, _passport.userCode, null);
		newLog.validateTrackedItem(updCntrl2, _passport);
		if (not _passport.noErrors) then
			break;
		endif;
		newLogLength := newLogLength + newLog.length;
		newLogVolume := newLogVolume + newLog.getMyTotalVolume;
		newLogWeight := newLogWeight + newLog.totalWeight;		// PAR 25560 01/09/2010
		
		/*txnParams.myTrackedItem := newLog;
		transaction := newLog.createTransaction(txnParams).CM_Reassembly;
		reassemblySet.add(transaction);*/
		startingLocation := newLog.getPrimaryLocation(REAL_MODE);
		//newLog.createStockMovementForMove(null, startingLocation, StkMove_MoveOut, StkMove_Reassembly, app.serverTimestampAtTrxStart.date, transaction);

		if startingLocation &lt;&gt; tmpLogRegrade.myLocation then
			// Set new location if it is not the same as the old location
			moveController.setMyTrackedItem(newLog);
			moveController.setMyToPrimaryLocation(tmpLogRegrade.myLocation);
			//logSet.clear;
			//logSet.add(newLog);
			//app.myUtilityUA.utlUpdateMoveTrackedItems(logSet, moveController, cancelSave);
			app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);			
		endif;
		
		if (not _passport.noErrors) then
			break;
		endif;
	endforeach;

	if _passport.noErrors then
		//use the same updCntrl as it will have all the reassembly transaction from above set
		updCntrl.transactionType 	:= TRANS_TYPE_DISASSEMBLY;
		updCntrl.comment 			:= _comment;
		updCntrl.reasonCode 		:= _reason;		
		updCntrl.recoveryCode 		:= _recovery;	
		updCntrl.residualLength 	:= _oldLog.length - newLogLength;		
		updCntrl.residualVolume 	:= _oldLog.getMyTotalVolume - newLogVolume;		
		updCntrl.residualWeight 	:= _oldLog.totalWeight - newLogWeight;		// PAR 25560	01/09/2010	
		
		_oldLog.rejectTrackedItem(updCntrl, _passport);
		//self.rejectTrackedItem(_oldLog, TRANS_TYPE_DISASSEMBLY, _reason, _recovery, _comment, _userCode);
		//rejectTrxn.CM_Disassembly.setExtraDetails(_oldLog.length - newLogLength,
		//										  _oldLog.volume - newLogVolume,
		//										  reassemblySet);

	endif;

epilog
	delete moveController;
	delete updCntrl;
	delete updCntrl2;
end;</source>
        <Parameter name="_oldLog" type="CM_Log" usage="input"/>
        <Parameter name="_logRegradeArray" type="CMIF_LogRegradeArray"/>
        <Parameter name="_residualLength" type="Real"/>
        <Parameter name="_residualVolume" type="Real"/>
        <Parameter name="_reason" type="String"/>
        <Parameter name="_recovery" type="String"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDischargeCargoAutoPlan" id="8fe285e0-e221-44a9-a8dd-5da59395a461">
        <updating/>
        <source>utlDischargeCargoAutoPlan(_machine : CM_Machine input;
							_ti : CM_TrackedItem input;
							_quantity : Integer;
							_weight : Decimal;
							_job	: CM_VoyageJob output;
							_wle  	: CM_WorkListEntry output;							
							_passport : CM_Passport input) updating;
/*

Date			Who		Reason
19 Mar 2015		cnwer1	Initial creation PAR 35893
09 Sep 2015		cnwma1	PAR #36211 Voyage Side Profile Crane Moves
07 Jun 2019		jlgzm1	TFS 42840 MSL - Direct Delivery Between LOLO RORO Voyages and Rail
06 Nov 2024		navdap1	MTN-18897 EUP | FR 53485 EUP - Warehouse Yard Allocation
*/

vars
	nwnp		: Boolean;
	currentLocation,tmpLocn	: CM_LocationsController;
	terminal : CM_Terminal;
	job				: CM_VoyageJob;
	futureMovePlanned : CM_FutureMove;
	wle : CM_WorkListEntry;
	moveController : CMIF_MoveController;
	machineTypeGrp : CM_MachineTypeGroup;
	plannedtoGCArea : Boolean;			// MTN-18897
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(false);
	
	self.raiseExceptionIfNull(_ti, "Tracked Item");
	
	currentLocation := _ti.getPrimaryLocation(REAL_MODE);
	nwnp:=currentLocation.canBeDischargedNWNP();
	
	terminal:=_ti.myTerminal;
	job := _ti.getFirstAvailableDischargeJob();
	wle := _ti.getVoyageWLEUnactioned(false);
	
	if currentLocation.requiresJob then	
		if wle = null then
			app.raiseCMException(Not_found_worklis_entry,null, null);
			return;
		endif;
		if wle.isKindOf(CM_VoyageWLE) and not wle.CM_VoyageWLE.isLoadedToOperations() then
			app.raiseCMException1(Voyag_been_loade_voyag_opera_c, wle.job.jobId,null,null );
		endif;
	endif;
	//already queued return 
	if _ti.getPrimaryLocation(QUEUE_MODE) &lt;&gt; null then     //09/09/2015 cnwma1 PAR #36211
		//epr tfs 1809
		if  nwnp and wle &lt;&gt; null then
			if wle &lt;&gt; null then
				job:=wle.job.CM_VoyageJob;
			endif;
		endif;
		
		_job:=job;
		_wle:=wle;
		return;
	endif;
	
	create moveController transient;
	moveController.setMyTrackedItem(_ti);
	moveController.setMyOriginatingLocation(currentLocation);
	moveController.setMoveMode(QUEUE_MODE);	
	
	//epr par 35862 13/3/15
	moveController.setQuantity(_quantity);
	moveController.setWeight(_weight);
	
	if _machine &lt;&gt; null then
		machineTypeGrp:=_machine.getMachineTypeGroup;
		if machineTypeGrp &lt;&gt; null then
			moveController.machineTypeGrp := machineTypeGrp.type;
		endif;
	endif;
	
	//if nwnp if not nwnp job re queue it
	if nwnp and _ti.getVoyageWLEUnactionedNonRORO(false) = null  then
		if _ti.myPrimaryPlannedLocation &lt;&gt; null then
			tmpLocn := _ti.myPrimaryPlannedLocation;
		else
			//auto plan
			tmpLocn := app.autoPlanJobTiYA(terminal, null,null,null, _ti, null, false, null, plannedtoGCArea);		// MTN-18897
			if app.myYAAgent &lt;&gt; null then
				_ti.createInfomationTransaction(YardAllocationLogging, app.myYAAgent.getLoggingArray(true), null, _passport);
			endif;
		endif;
		//	moveController.transferType := VESSEL_TYPE_RORO; // CNWAB1 MAY17 1; // 0 = LOLO 1 = RORO  TFS 4435
			moveController.setTransferTypeFromJob( job, VESSEL_TYPE_RORO );	//12 Mar 2018	NDL	TFS 37444
			moveController.isNonCraneVoyageMove := true; 
	else
			//already planned check can just convert to queued
		if _ti.getPrimaryLocation(PLANNING_MODE) &lt;&gt; null then

			futureMovePlanned := _ti.getFutureMovePlanned(false);
			if futureMovePlanned &lt;&gt; null then
				tmpLocn:=futureMovePlanned.CM_FutureMovePlanned.allLocationsControllers.first;
				// tfs42840 start
				if futureMovePlanned.myWorkListEntry.isKindOf(CM_VoyageWLE) then
					wle := futureMovePlanned.myWorkListEntry;
				elseif futureMovePlanned.myWorkListEntryDR.isKindOf(CM_VoyageWLE) then
					wle := futureMovePlanned.myWorkListEntryDR;
				endif;
				// tfs42840 end
			endif;
		else
			tmpLocn:= app.autoPlanJobTiYA(terminal, null,null,null, _ti, job, false, null, plannedtoGCArea);		// MTN-18897
			if app.myYAAgent &lt;&gt; null then
				_ti.createInfomationTransaction(YardAllocationLogging, app.myYAAgent.getLoggingArray(true), null, _passport);
			endif;
			if job &lt;&gt; null then
				wle := job.getWLEForTI(_ti);
			endif;
		endif;
		moveController.setJobForMove(job);
		
		moveController.hazardSegregationValidated := true;
		moveController.setMyWorkListEntry(wle);
		moveController.isRehandleMove := _ti.isRehandle;
		//For Queue and Planned moves
		moveController.setMyOriginatingLocation(_ti.myPrimaryActualLocation);
		moveController.isForcedMove := true;
		moveController.isPlannedToFullGCArea := plannedtoGCArea;		// MTN-18897
	endif;

	if tmpLocn = null then
		return;
	endif;
	
	moveController.setMyToPrimaryLocation(tmpLocn);
	//ignore warnings
	app.myPassport.setWarningsIgnored(true);
	self.utlUpdateMoveTrackedItem(moveController, _passport);	
		
	if _passport.hasErrors then
		return;
	endif;
	
	if moveController.myWorkListEntry &lt;&gt; null then
		_wle := moveController.myWorkListEntry;
		_job := _wle.job.CM_VoyageJob;
	endif;

		
epilog
	delete moveController;
end;</source>
        <Parameter name="_machine" type="CM_Machine" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_job" type="CM_VoyageJob" usage="output"/>
        <Parameter name="_wle" type="CM_WorkListEntry" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDutyDocApprovalProcessing" id="cb4d3572-d40c-4eb4-b7ec-f8ef2e83828c">
        <updating/>
        <source>utlDutyDocApprovalProcessing(_dutyDoc : CM_DutyDoc; _passport : CM_Passport input) updating;
/*
When a Duty Doc is approved the following processing is actioned
  1. Remove all the Customs Stops from the cargo
  2. Create the Duty Invoice Lines
  3. Release a Road Release for imports
  
  CCMS 2189 Duty Doc for Ajman
  31 July     2014    cnwma1 PAR 34408 Credit Customer current charges
*/
//10 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type
vars
	ti: CM_TrackedItem;
	tis: CM_TISet;
	dutyDocCharged: Boolean;
	release: CM_BulkRelease;
	txn: CM_TITransaction;
	manController : CMIF_InvoiceLineManual;
	now: Date;
	time: Time;
	invLine: CM_InvoiceLine;
	invoiceLineDesc : CM_InvoiceLineDesc;
	businessUnit: CM_Bank;
	debtor: CM_Debtor;
	invLineType : CM_InvoiceLineDesc;
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);

	create tis transient;
	_dutyDoc.getTIsFor(_dutyDoc.allDutyDocItems, tis);
	
	businessUnit := _dutyDoc.getBank;
	invoiceLineDesc := businessUnit.invoiceLineDescriptors["Duty Documentation"];
	if invoiceLineDesc = null then
		app.raiseCMException1(Inv_line_type_not_set_up,"Duty Documentation",null,null);
		return;
	endif;
	
	foreach ti in tis do
		if ti.companyOid &lt;&gt; null then
			businessUnit := ti.companyOid;
		endif;
		/*app.myUtilityCA.utlCreateDutyDocChargeTrans(_dutyDoc,ti, _dutyDoc.getDutyCharge(ti), _dutyDoc.dutyDeposit &lt;&gt; 0, txn, _passport); // 31-JUL-2014 cnwma1 PAR 34408 Credit Customer current charges
		if not _passport.noErrors then
			break;
		endif;*/ 																														   // 31-JUL-2014 cnwma1 PAR 34408 Credit Customer current charges
		//removeCustomsStops(ti);
	endforeach;
	
	if not _passport.noErrors then
		return;
	endif;
	
	// Create the Duty Documentation charge against the current invoice;
	if businessUnit &lt;&gt; null then   // PAR 31516
		debtor := _dutyDoc.getMyDebtor();
		create manController transient;
		manController.quantity := 1;
		manController.chargeTime.setDate(now);
		manController.chargeTime.setTime(time);
		manController.remarks := _dutyDoc.id.String; // ### JIRA 33007 10DEC2024 NAVAB1
		//10 March 2023  navmv20 TFS 56128 Task 56129 - START
		//manController.myInvoiceLineType := businessUnit.invoiceLineDescriptors["Duty Documentation"]; 
		invLineType := businessUnit.invoiceLineDescriptors["Duty Documentation"];
		manController.allInvoiceLineTypes.add(invLineType);
		//manController.myInvoice := businessUnit.getAutoInvoice(manController.myInvoiceLineType.getInvoiceType(debtor), manController.myInvoiceLineType, null, debtor, false);
		manController.myInvoice := businessUnit.getAutoInvoice(manController.allInvoiceLineTypes.first.getInvoiceType(debtor), manController.allInvoiceLineTypes.first, null, debtor, false);
		//10 March 2023  navmv20 TFS 56128 Task 56129 - END
		app.myUtilityCA.utlCreateInvoiceLineManual(manController, invLine, app.myPassport);
		if not _passport.noErrors then
			return;
		endif;
	endif;
	
	if _dutyDoc.isImport then  // cnwma1 31/07/2014 PAR 34408
		//app.myUtilityCA.utlCreateDutyDocRoadRelease(_dutyDoc, tis, release, _passport); // cnwma1 31/07/2014 PAR 34408
		app.myUtilityCA.utlCreateDutyDocRoadReleaseID(_dutyDoc, tis, release, _passport); // cnwma1 31/07/2014 PAR 34408
	endif;

epilog
	delete tis;
	delete manController;
end;</source>
        <Parameter name="_dutyDoc" type="CM_DutyDoc"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDutyDocDutyCharge" id="f9a3e60c-ca59-41df-90d9-6e218006b7a3">
        <updating/>
        <source>utlDutyDocDutyCharge(_dutyDocItem : CM_DutyDocItem; _passport : CM_Passport input) updating;
/* 31 July     2014    cnwma1 PAR 34408 Credit Customer current charges

*/
vars

	txn: CM_TITransaction;
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
		//app.myUtilityCA.utlCreateDutyDocChargeTrans(_dutyDocItem.myDutyDoc,_dutyDocItem.getMyTrackedItem(), _dutyDocItem.myDutyDoc.getDutyCharge(_dutyDocItem.getMyTrackedItem()), false, txn, _passport);
		app.myUtilityCA.utlCreateDutyDocChargeTrans(_dutyDocItem.myDutyDoc,_dutyDocItem.getMyTrackedItem(), _dutyDocItem.duty, false, txn, _passport);
	if not _passport.noErrors then
		return;
	endif;
	
epilog
end;</source>
        <Parameter name="_dutyDocItem" type="CM_DutyDocItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlEDIIgnoreEDITrackedItem" id="de7d6450-53cc-47e3-b4f8-c38bd52fa4dc">
        <source>utlEDIIgnoreEDITrackedItem(_coll :CM_EDITISet);
/*
Date		Who		Reason
18 Aug 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
// 07 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
*/
vars
	ediTI		:CM_EDITrackedItem;
	ediData		:CM_EDIData;
	terminal	:CM_Terminal;
	coll		:ObjectSet;
	obj			:Object;
	newStatus	:Integer;
begin
	self.initialiseActivity();
	
	create coll transient;
	
	foreach ediTI in _coll do
		if ediTI.status &lt;&gt; CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X then
			app.raiseUnexpectedProgramError (self.class.name, method.name, 'Invalid status for Ignore EDI Item');
		endif;
		// audit before 
		self.myUpdateAuditAgent.audUpdateGeneric(ediTI, true);
		
		// set status to unprocessed (?verify errors?)
		ediTI.setStatus (CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING);
		// just incase this flag was set (shouldn't be)
		ediTI.setIsToBeProcessed (false);
		
		ediData := ediTI.myEDIData;
		// audit after
		self.myUpdateAuditAgent.audUpdateGeneric(ediTI, false);
		
		coll.addNoDuplicates (ediData, false);
		
		terminal := ediData.getMyTerminal();
		
		if terminal &lt;&gt; null then
			// EDI form expect terminal to cause event not EDI TI :-(
			terminal.causeEvent(terminal.getTerminalEvent(EVENT_EDI_EDITI_UPDATE), false, ediTI);
		endif;

	endforeach;	
	
	// now since we have changed the status of an EDI TI we need to figure out the new status
	foreach obj in coll do
		ediData := obj.CM_EDIData;
		
		if ediData.canGetStatusFromEDITrackedItem then
			newStatus := ediData.getStatusFromEDITrackedItems(false);
			
			if newStatus &lt;&gt; ediData.status then
				// audit before
				self.myUpdateAuditAgent.audUpdateGeneric(ediData, true);
				ediData.setStatus (newStatus);
				// audit after
				self.myUpdateAuditAgent.audUpdateGeneric(ediData, false);
			endif;
		endif;
	endforeach;
epilog
	delete coll;
end;</source>
        <Parameter name="_coll" type="CM_EDITISet"/>
    </JadeMethod>
    <JadeMethod name="utlEDILeaveMyContainers" id="e126eaf9-e874-4a47-8bce-995cb3805a40">
        <source>utlEDILeaveMyContainers(_bayPlan :CM_EDIDataBayPlan input);
// ---------------------------------------------------------------------------
// Created:     04 May 2010 by cnwcs5
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_bayPlan, 'Bay Plan');

	app.setContinueCMExceptions(true);
	
	// do updates
	_bayPlan.removeOthers;
end;</source>
        <Parameter name="_bayPlan" type="CM_EDIDataBayPlan" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlEDIProcessEDITrackedItem" id="c33b82c2-e6f3-4629-b4aa-1bc0d0286150">
        <source>utlEDIProcessEDITrackedItem(_coll :CM_EDITISet; _passport :CM_Passport);
/*
Date		Who		Reason
12 Aug 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
// 07 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
*/
vars
	ediTI		:CM_EDITrackedItem;
	coll		:ObjectSet;
	ediData		:CM_EDIData;
	terminal	:CM_Terminal;
	obj			:Object;
	newStatus	:Integer;
begin
	self.initialiseActivity();
	
	create coll transient;
	
	foreach ediTI in _coll do
		// make sure validation was done :-)
		if ediTI.status &lt;&gt; CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING and
			ediTI.status &lt;&gt; CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X then
			app.raiseUnexpectedProgramError (self.class.name, method.name, 'Invalid status for Process EDI Item');
		endif;
		// audit before 
		self.myUpdateAuditAgent.audUpdateGeneric(ediTI, true);
		
		// set status to unprocessed (?verify errors?)
		ediTI.setStatus (CM_EDITrackedItem.EDI_STATUS_UNPROCESSED);
		// we don't want to keep existing errors for this EDITI
		ediTI.setKeepPersistentErrors (false);
		// the user has said we should process this ediTI so don't do any blocked checking
		ediTI.setIsToBeProcessed (true);
		
		// audit after
		self.myUpdateAuditAgent.audUpdateGeneric(ediTI, false);		
		
		ediData := ediTI.myEDIData;
		
		coll.addNoDuplicates (ediData, false);
		
		terminal := ediData.getMyTerminal();
		
		if terminal &lt;&gt; null then
			// EDI form expect terminal to cause event not EDI TI :-(
			terminal.causeEvent(terminal.getTerminalEvent(EVENT_EDI_EDITI_UPDATE), false, ediTI);
		endif;
	endforeach;	
	
	// now since we have changed the status of an EDI TI we need to figure out the new status
	foreach obj in coll do
		ediData := obj.CM_EDIData;
		
		if ediData.canGetStatusFromEDITrackedItem then
			newStatus := ediData.getStatusFromEDITrackedItems(false);
			
			if newStatus &lt;&gt; ediData.status then
				// audit before
				self.myUpdateAuditAgent.audUpdateGeneric(ediData, true);
				ediData.setStatus (newStatus);
				// audit after
				self.myUpdateAuditAgent.audUpdateGeneric(ediData, false);
			endif;
		endif;
	endforeach;
epilog
	delete coll;
end;</source>
        <Parameter name="_coll" type="CM_EDITISet"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="utlExportAsXMLDoc" id="c6f7c57c-3c44-4431-944b-e73e02afb4cf">
        <source>utlExportAsXMLDoc(_exportObject : CM_Object; _fileName : String;	_passport : CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 April 2011	cnwer1	Initial creation

*/

vars
	theXMLFile : File;	
	xmlString : String;
begin
	self.raiseExceptionIfNull(_exportObject,"Export object");
	
	if _fileName = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "File Name", null, null);
		app.raiseCMException(Input_required_field_fileName, null, null); 
	endif;
	
	if _passport.hasErrors then
		return;
	endif;
	
	//get fileName
	create theXMLFile;
	theXMLFile.fileName := _fileName;
	theXMLFile.mode:=File.Mode_Output;

	
	theXMLFile.writeLine('&lt;?xml version="1.0"?&gt;');
	theXMLFile.writeLine(J_key_LessThan.Character &amp; _exportObject.class.name &amp; " " &amp; 'type="' &amp;  _exportObject.class.name &amp; '"'&amp;J_key_GreaterThan.Character);
	_exportObject.exportAsXMLDoc(theXMLFile);
	theXMLFile.writeString(self.formatAsXMLSuffix( _exportObject.class.name));
	
epilog
	delete theXMLFile;

end;</source>
        <Parameter name="_exportObject" type="CM_Object"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="utlFixupStockOnHandLC" id="f3e51e1d-94c6-4969-8353-cf1c137fab5e">
        <source>utlFixupStockOnHandLC(_lc : CM_LocationsController input; _comment : String; 
					_passport : CM_Passport input;
				    _cmifMonitor : CMIF_Monitor input);
//-----------------------------------------
//Created: October 2002 By: cnwgd1
//-----------------------------------------
vars
	fixupHdr	: CM_SOHFixupHdr;
	tmpTerminal	: CM_Terminal;
	msgStr		: String;

begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	tmpTerminal := _lc.myTerminal;
	
	if tmpTerminal &lt;&gt; null and _lc.myTerminalArea &lt;&gt; null then
		msgStr := tmpTerminal.code &amp; '/' &amp; _lc.myTerminalArea.id &amp; '/' &amp; _lc.ident;
	else
		msgStr := _lc.getFullId();
	endif;
	
	app.writeLog('Fixup Stock-On-Hand (' &amp; msgStr &amp; '): start', LogINFO);

	create fixupHdr persistent;
	fixupHdr.init(_passport.userCode, tmpTerminal);

	if _passport.noErrors then
		_lc.fixupStockOnHand(_passport, _comment, fixupHdr, _cmifMonitor);
		if _cmifMonitor &lt;&gt; null and _cmifMonitor.monitorReturnValue = _cmifMonitor.MonitorReturnValue_Cancel then
			app.writeLog('Fixup Stock-On-Hand (' &amp; msgStr &amp; '): user aborted', LogINFO);
			app.raiseCMException(UserAbortedAction, null, null);
		endif;
	endif;
	
	app.writeLog('Fixup Stock-On-Hand (' &amp; msgStr &amp; '): complete', LogINFO);

end;</source>
        <Parameter name="_lc" type="CM_LocationsController" usage="input"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlFixupStockOnHandTA" id="1c58bba9-a995-4f85-a184-3c16dd3dbf42">
        <source>utlFixupStockOnHandTA(_terminalArea : CM_TerminalArea input; _comment : String; 
					_passport : CM_Passport input;
				    _cmifMonitor : CMIF_Monitor input);
//-----------------------------------------
//Created: October 2002 By: cnwgd1
//-----------------------------------------
vars
	fixupHdr	: CM_SOHFixupHdr;
	tmpTerminal	: CM_Terminal;
	msgStr		: String;

begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	tmpTerminal := _terminalArea.myTerminal;
	msgStr := tmpTerminal.code &amp; '/' &amp; _terminalArea.id;
	
	app.writeLog('Fixup Stock-On-Hand (' &amp; msgStr &amp; '): start', LogINFO);

	create fixupHdr persistent;
	fixupHdr.init(_passport.userCode, tmpTerminal);

	if _passport.noErrors then
		_terminalArea.fixupStockOnHand(_passport, _comment, fixupHdr, _cmifMonitor, false);
		if _cmifMonitor &lt;&gt; null and _cmifMonitor.monitorReturnValue = _cmifMonitor.MonitorReturnValue_Cancel then
			app.writeLog('Fixup Stock-On-Hand (' &amp; msgStr &amp; '): user aborted', LogINFO);
			app.raiseCMException(UserAbortedAction, null, null);
		endif;
	endif;
	
	app.writeLog('Fixup Stock-On-Hand (' &amp; msgStr &amp; '): complete', LogINFO);


end;</source>
        <Parameter name="_terminalArea" type="CM_TerminalArea" usage="input"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlFixupStockOnHandVoyage" id="913e50dc-5d0a-41a2-86cb-9d878f06d7df">
        <source>utlFixupStockOnHandVoyage(_voyage : CM_Voyage input;
						  _comment : String; 
						  _passport : CM_Passport input;
					      _cmifMonitor : CMIF_Monitor input);
//-----------------------------------------
//Created: June 2003 By: cnwgd1
//-----------------------------------------
vars
	fixupHdr	: CM_SOHFixupHdr;
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	app.writeLog('Fixup Voyage Stock-On-Hand (' &amp; _voyage.code &amp; '): start', LogINFO);

	create fixupHdr persistent;
	fixupHdr.init(_passport.userCode, _voyage.myTerminal);

	if _passport.noErrors then
		_voyage.fixupStockOnHand(_passport, _comment, fixupHdr, _cmifMonitor);
		if _cmifMonitor &lt;&gt; null and _cmifMonitor.monitorReturnValue = _cmifMonitor.MonitorReturnValue_Cancel then
			app.writeLog('Fixup Voyage Stock-On-Hand (' &amp; _voyage.code &amp; '): user aborted', LogINFO);
			app.raiseCMException(UserAbortedAction, null, null);
		endif;
	endif;
	
	app.writeLog('Fixup Voyage Stock-On-Hand (' &amp; _voyage.code &amp; '): complete', LogINFO);

epilog
	if fixupHdr &lt;&gt; null then
		// if no fixup transactions done then delete
		if fixupHdr.allSOHTransactions.isEmpty then
			delete fixupHdr;
		endif;
	endif;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlForceTrackedItemWeigh" id="205cfccc-108a-4ab4-8705-d417255d378e">
        <source>utlForceTrackedItemWeigh(_rtTask : CM_RTQueueTask);
// -------------------------------------------
// Created 14 July 2004 by cnwdvb1
// -------------------------------------------
vars

	ti	: CM_TrackedItem;

begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	if _rtTask.taskType &lt;&gt; TASK_PICKUP and _rtTask.status &lt;&gt; TASK_UNACTIONED then
		app.raiseCMException(Task_must_unacti_pickup_task, null, null);
	endif;
	
	ti := _rtTask.ti;
	
	if ti = null then
		app.raiseCMException1(ERR_NO_OBJECT, null, null, null);
		return;
	endif;
	
	if not ti.myCargoType.isWeighable then
		app.raiseCMException(Cargo_type_able_weighed, null, null);
		return;
	endif;
	
	ti.setWeighStatus(WEIGH_STATUS_FORCED);
end;</source>
        <Parameter name="_rtTask" type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="utlITSInterfaceMessageComplete" id="7489c0c7-8a84-4567-9f67-cd7cb1ffa832">
        <source>utlITSInterfaceMessageComplete(_realMessage : CM_ITSInterfaceMessage input; _processedTS : TimeStamp; _passport : CM_Passport input);

/*

Purpose:			Remove ITS Interface Response from To Send queue.
					Remove Internal Queue Entry Request and ITS Acknowledgements from To Action queue.

Parameters:			Completed ITS Message and time completed.

Return Value:		None


Date		Who		Reason
30 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);

	if _realMessage.processedTS = null then
		_realMessage.setProcessed(_processedTS);
	endif;
	
epilog

end;</source>
        <Parameter name="_realMessage" type="CM_ITSInterfaceMessage" usage="input"/>
        <Parameter name="_processedTS" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlITSInterfaceReset" id="fb2b74a5-7b41-4ed6-93b5-619d0f6b3597">
        <source>utlITSInterfaceReset(_interfaceDefinition : CM_ITSInterfaceDefinition input; _passport : CM_Passport input);

/*

Purpose:			Reset ITS Interface.

Parameters:			Interface to reset.

Return Value:		None


Date		Who		Reason
01 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars
	machine			: CM_Machine;
	message			: CM_ITSInterfaceMessage;
	resetIntface	: CM_ITSInterfaceReqResetIntface;
	resetMachine	: CM_ITSInterfaceReqResetMach;

begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	exclusiveLock(_interfaceDefinition);
	
	foreach message in _interfaceDefinition.allResponsesWaitingAck do
		message.reset();
	endforeach;

	foreach message in _interfaceDefinition.allResponsesToSend do
		message.reset();
	endforeach;
	
	foreach message in _interfaceDefinition.allRequestsToAction do
		message.reset();
	endforeach;

	create resetIntface persistent;
	resetIntface.set(_passport.myUser, _interfaceDefinition);

	foreach machine in _interfaceDefinition.allMachinesLoggedOn do
		create resetMachine persistent;
		resetMachine.set(machine, _passport.myUser, _interfaceDefinition);
	endforeach;

	_interfaceDefinition.allMachinesLoggedOn.clear();
	
	_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(Event_ITS_ResetTcpConnection), false, null);
	
epilog

end;</source>
        <Parameter name="_interfaceDefinition" type="CM_ITSInterfaceDefinition" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlITSInterfaceResetMachineDo" id="a4c4ebda-824f-4b96-a0b3-d26ea30080f4">
        <source>utlITSInterfaceResetMachineDo(_request : CM_ITSInterfaceReqResetMach input; _passport : CM_Passport input);

/*

Purpose:			Do processing of reset machine request for the ITS Interface.

Parameters:			Reset machine request.

Return Value:		None


Date		Who		Reason
01 Dec 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface
// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);

	exclusiveLock(_request.myMachine);
	
	_request.setProcessed(app.actualTimeServer);// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	// The reset is done up to the time the request was created so that any subsequently received requests
	// will trigger a log on needed response.
	_request.myITSInterfaceDefinition.resetInterfaceForMachine(_request.myMachine, _request.createdTS);


	
epilog

end;</source>
        <Parameter name="_request" type="CM_ITSInterfaceReqResetMach" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlITSInterfaceResponseTimeout" id="b2ce92a2-b07e-4a84-a943-051ad71c39ac">
        <updating/>
        <source>utlITSInterfaceResponseTimeout(_realResponse : CM_ITSInterfaceResponse input; _passport : CM_Passport input) updating;

/*

Purpose:			Timeout response that has not been acknowledged by ITS.

Parameters:			Timed out response.

Return Value:		None


Date		Who		Reason
30 Nov 2009	consw1	PAR #21593 - Development of CCMS MES 1014 - RDT ITS Interface

*/

vars

begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	_realResponse.doTimeout();
	
epilog

end;</source>
        <Parameter name="_realResponse" type="CM_ITSInterfaceResponse" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlImportFullSegMatrix" id="ae453dbf-5537-4ecd-827a-430665f4ae9f">
        <source>utlImportFullSegMatrix(_segMatrixAgent : CMIF_SegregationMatrixAgent; _passport : CM_Passport input);
/*
----------   ----------  --------------------------------------------------
Created:	24 August 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	matrixTrans			: CM_SegregationMatrixTrans;
	condition			: CM_SegregationCondition;
	newRule,
	updatedRule,
	deletedRule			: CM_SegregationRule;
	allDeletedRules		: CM_ObjectSet;
	
begin

	self.initialiseActivity();

	app.myValUA.valSegregationMatrix(_segMatrixAgent, _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	foreach condition in app.myPassport.myTerminal.allSegregationConditions do
		if condition.type = _segMatrixAgent.ruleType then
			condition.allSegregationRules.purge();
		endif;
	endforeach;
	
	create allDeletedRules transient;
	
	foreach matrixTrans in _segMatrixAgent.allSegMatrixTransByRowCol do
		if matrixTrans.myPxySegregationRule = null then
			//has not been edited, and there is no existing rule at this juncture
			continue;
		else
			create newRule persistent;
			newRule.setForUpdate(matrixTrans.myPxySegregationRule);
		endif;
		
		if not self.checkValidationWithPassport(_passport) then
			return;
		endif;
	endforeach;
	
	_passport.myTerminal.refreshHazardMoveDetails(_segMatrixAgent.ruleType);
	
	
epilog
	delete allDeletedRules;
end;
</source>
        <Parameter name="_segMatrixAgent" type="CMIF_SegregationMatrixAgent"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlImportXMLDocRORODeck" id="7649f3e2-2761-48d8-bccf-ec6ddf88b14d">
        <source>utlImportXMLDocRORODeck( _roroVessel : CM_ROROVesselStructure input;
						 _proxyDeck : CM_DeckVessel input;
						 _passport : CM_Passport input);
/*

Purpose:	Passed in roro Deck and a proxy deck that was created from the XML file	

Parameters:			


Date		Who		Reason
06 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	lastDeck : CM_DeckVessel;
	newOrdinal : Integer;
	realDeck : CM_DeckVessel;
begin
	
	self.initialiseActivity();
	
	app.myValCA.valROROVesselDeck(_roroVessel,_proxyDeck);
	
	if _passport.hasErrors then
		return;
	endif;
	
	create realDeck persistent;
	realDeck.setMyROROStructure(_roroVessel);
	realDeck.setForCreateImport(_proxyDeck,_passport);
	
epilog

end;</source>
        <Parameter name="_roroVessel" type="CM_ROROVesselStructure" usage="input"/>
        <Parameter name="_proxyDeck" type="CM_DeckVessel" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlImportXMLDocROROVessel" id="d69de328-a09a-4042-812a-089f956a240f">
        <updating/>
        <source>utlImportXMLDocROROVessel(	_roroVessel : CM_ROROVesselStructure input; 
							_pxyRoroVessel : CM_ROROVesselStructure;
							_passport : CM_Passport input) updating;
/*

Purpose:		Import XML file and load the ROROVesselStructure
				will wipe all existing roroVesselStructure details create a new from the file	

Parameters:			

Date		Who		Reason
06 April 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	proxyDeck,realDeck		: CM_DeckVessel;
begin

	self.initialiseActivity();
	
	self.raiseExceptionIfNull(_roroVessel, " RORO Vessel Structure is Null" );
	
	//starting a fresh delete all the decks
	_roroVessel.allDecks.purge;
	
	//create the decks from the proxies 

	foreach proxyDeck in _pxyRoroVessel.allDecks discreteLock do
		//cnwmc5 - PAR 30103 - 10 July 2013
		proxyDeck.validateForXMLImport();
		
		create realDeck persistent;
		realDeck.setMyROROStructure(_roroVessel);
		realDeck.setForCreateImport(proxyDeck,_passport);	
	
		if _passport.hasErrors then
			return;
		endif;
		
	endforeach;
epilog

	
end;</source>
        <Parameter name="_roroVessel" type="CM_ROROVesselStructure" usage="input"/>
        <Parameter name="_pxyRoroVessel" type="CM_ROROVesselStructure"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlIncrementCreditExportCount" id="9ceb8faf-7315-4375-9b11-a7e6c5ad1ed2">
        <updating/>
        <source>utlIncrementCreditExportCount(_credit : CM_CashCredit input; _passport : CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		Feb 2016 cnwjre1 TFS 985 cash credit export
//
// Purpose:		Increment the credit exportedCount following an export of this credit
//
// Parameters:	_credit  - a reference to the credit to update	
//				_passport - a reference to the session's user passport object.

begin
	app.setContinueCMExceptions(true);
	self.raiseExceptionIfNull(_credit, 'Cash Credit');
	
	self.exclusiveLock(_credit);
	
	_credit.exportedCount := _credit.exportedCount + 1;
end;</source>
        <Parameter name="_credit" type="CM_CashCredit" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlIncrementInvoiceExportCount" id="20e5fab1-844a-4b4a-9056-69d01998dd47">
        <updating/>
        <source>utlIncrementInvoiceExportCount(_invoice : CM_Invoice input;_ignoreVoided : Boolean; _passport : CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		Sep 2010 by cnwjre1 for par 23855 - code moved out of the export methods
//
// Purpose:		Increment the invoice exportedCount following an export of this invoice
//
// Parameters:	_invoice  - a reference to the invoice to update	
//				_passport - a reference to the session's user passport object.
// 22 July 2019	cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
vars
	invLine : CM_InvoiceLine;
begin
	app.setContinueCMExceptions(true);
	self.raiseExceptionIfNull(_invoice, 'Invoice');
	
	self.exclusiveLock(_invoice);
	
	app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(_invoice, true);				// 11/5/18 MAP TFS37718
	
	_invoice.exportedCount := _invoice.exportedCount + 1;
	
	//22.07.2019 cnwma1 TFS #45577
	foreach invLine in _invoice.invoiceLines do 
		if not _ignoreVoided then
			if invLine.voided then
				if not _invoice.isReverseCredit then
					continue;
				endif;
			endif;
		endif;
		invLine.incrementExportCount();
	endforeach;
	app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(_invoice, false);				// 11/5/18 MAP TFS37718
end;</source>
        <Parameter name="_invoice" type="CM_Invoice" usage="input"/>
        <Parameter name="_ignoreVoided" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlIncrementReceiptExportCount" id="b8159c5e-11be-49f6-a671-4787a5dad4ae">
        <updating/>
        <source>utlIncrementReceiptExportCount(_receipt : CM_CashReceipt input; _passport : CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		Feb 2016 cnwjre1 TFS 985 cash receipt export
//
// Purpose:		Increment the cash receipt exportedCount following an export of this receipt or its associated invoice
//
// Parameters:	_receipt  - a reference to the receipt to update	
//				_passport - a reference to the session's user passport object.

begin
	app.setContinueCMExceptions(true);
	self.raiseExceptionIfNull(_receipt, 'Cash Receipt');
	
	self.exclusiveLock(_receipt);
	
	app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(_receipt, true);				// 11/5/18 MAP TFS37718
	_receipt.exportedCount := _receipt.exportedCount + 1;
	app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(_receipt, false);				// 11/5/18 MAP TFS37718
end;</source>
        <Parameter name="_receipt" type="CM_CashReceipt" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlInterTerminalMove" id="6480da96-09e3-41dd-bf27-6ed3e88ca183">
        <source>utlInterTerminalMove(_ta : CM_InterTerminalTransferArea; _tiSet : CM_TISet input; _passport : CM_Passport input);
// -------------------------------------------
// Created 23 July 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	_ta.releaseAndReceivedTIs(_tiSet, _passport);

end;</source>
        <Parameter name="_ta" type="CM_InterTerminalTransferArea"/>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlInvoiceGeneration" id="0ae45cb9-5874-4a19-ab83-b7e90130fe3d">
        <source>utlInvoiceGeneration( _invoiceGenerationAgent : CM_InvoiceGenerationAgent input; _passport : CM_Passport input );
/* ---------------------------------------------------------------------------
Created:	17 September 2008	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	realObject		: CM_TrxTestObject;
	expectedEdition	: Integer;

begin

	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	self.raiseExceptionIfNull(_invoiceGenerationAgent, 'invoiceGenerationAgent');

	app.setContinueCMExceptions(true);
	
	app.myValUA.valInvoiceGenerationAgent(_invoiceGenerationAgent);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
/*	realObject := self.getRealObjectAndEditionCheck(_pxyObject, 'Test Object', _passport).CM_TrxTestObject;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, true);
	endif;*/

	if _passport.noErrors then
		// do updates
		_invoiceGenerationAgent.invoiceGeneration();
	endif;

/*	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, false);
	endif;
*/
end;</source>
        <Parameter name="_invoiceGenerationAgent" type="CM_InvoiceGenerationAgent" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlInvoiceRecalculate" id="f81a6b9f-c127-4928-9d17-c9cafc249462">
        <updating/>
        <source>utlInvoiceRecalculate(_invoice : CM_Invoice input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     May 2012 by cnwjre1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.initialiseActivity();
	
	// do updates
	_invoice.recalculate();
end;</source>
        <Parameter name="_invoice" type="CM_Invoice" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlLoadFileCustDocExtRef" id="20879d70-9f47-4895-b0e6-44e81b09a68d">
        <updating/>
        <source>utlLoadFileCustDocExtRef(_file : File; _terminal : CM_Terminal; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/09/2023	navkc1	CR 60347  Task 60348: Jade - TRX to Accept CSV File For Updating Ext Ref on Custom Document

*/

vars
	line		: String;
	lineNumber	: Integer;
	stringArray	: StringArray;
	custDocCode	: String;
	extRef		: String;
	date		: Date;
	ts			: TimeStamp;
	realCustDoc : CM_CustomDocument;
	pxyCustDoc	: CM_CustomDocument;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	create stringArray transient;
	
	_file.open();
	
	while not _file.endOfFile() do
		
		stringArray.clear();		
		line := _file.readLine();
		line.csvToStringArray(stringArray, ",");
		
		lineNumber += 1;
		
		// Line 1 is header
		if lineNumber = 1 then
			continue;
		endif;
			
		if stringArray.isEmpty() then
			continue;
		endif;
		
		// Need to have 3 columns - Code, Ext Ref, Date
		if stringArray.size() &lt;&gt; 3 then
			app.raiseCMWarning2(Line_failed_invali_field_file,  lineNumber.String, "invalid number of columns", null, null, null);
			continue;
		endif;
		
		// [1] = Custom Document Code
		// [2] = External Reference
		// Both are mandatory fields
		if stringArray[1] = null or stringArray[2] = null then
			if stringArray[1] = null then
				app.raiseCMWarning2(Line_failed_invali_field_file, lineNumber.String, "invalid Custom Document Code", null, null, null);
			else
				app.raiseCMWarning2(Line_failed_invali_field_file, lineNumber.String, "invalid External Reference", null, null, null);
			endif;
			continue;
		endif;
		
		custDocCode := stringArray[1];
		extRef := stringArray[2];
		date := stringArray[3].Date.formatAsYYMMDD().Date;
		ts.setDate(date);
		
		if ts.isValid() then
			realCustDoc := _terminal.allCustomDocuments.getAtKeyGeq(custDocCode, ts);
		else
			realCustDoc := _terminal.allCustomDocuments.getAtKeyGeq(custDocCode, null);
		endif;
		
		// No Custom document found
		if realCustDoc = null or realCustDoc.code &lt;&gt; custDocCode then
			app.raiseCMWarning2(Line_faile_custo_docum_not_fou, lineNumber.String, custDocCode, null, null, null);
			continue;
		endif;
		
		// Get proxy and update the external reference
		pxyCustDoc := app.createUpdateProxy(realCustDoc).CM_CustomDocument;
		pxyCustDoc.setUpdateExternalReference(extRef);
		
		app.myUtilityUA.utlUpdateCustDocExtRef(pxyCustDoc, app.myPassport);		
		
		delete pxyCustDoc;
	endwhile;
	_file.close();
epilog
	delete stringArray;
end;</source>
        <Parameter name="_file" type="File"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlLocationActBalanceRecalc" id="42bfef3d-937b-4ca8-82c5-87405dc04246">
        <updating/>
        <source>utlLocationActBalanceRecalc(_la : CMEVT_LocationActivity input;  _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 April 2021	navndl1	Initial creation	TFS 50906

*/

vars
	
	expectedEdition	: Integer;

begin

	self.initialiseActivity();
	
	// do any pre-validation locks
	
	if _la = null or not _la.isLocationBalance then
		return;
	endif;

	app.setContinueCMExceptions(true);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_la, true);
	endif;

	if _passport.noErrors then
		// do updates
		_la.recalculateBalance();
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_la, false);
	endif;

end;</source>
        <Parameter name="_la" type="CMEVT_LocationActivity" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlLocationActivityNeedsRecalc" id="48b3cd2a-35c6-4522-965b-b67cd6d11a63">
        <updating/>
        <source>utlLocationActivityNeedsRecalc(_la : CMEVT_LocationActivity input;  _reCalcBalanceSet : CMEVT_LocationActivityByDate input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 April 2021	navndl1	Initial creation	TFS 50906

*/

vars
	
	expectedEdition	: Integer;

begin

	self.initialiseActivity();
	
	// do any pre-validation locks
	
	if _la = null or not _la.isLocationBalance then
		return;
	endif;

	app.setContinueCMExceptions(true);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_la, true);
	endif;

	if _passport.noErrors then
		// do updates
		_la.setNeedsRecalculating( true, _reCalcBalanceSet );
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_la, false);
	endif;

end;</source>
        <Parameter name="_la" type="CMEVT_LocationActivity" usage="input"/>
