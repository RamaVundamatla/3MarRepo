    <JadeMethod name="isReallyAvailable" id="ba46dd35-66cc-48e7-9b80-ead66f7c89fe">
        <source>isReallyAvailable(_intendedTi: CM_TrackedItem; _otherLc: CM_LocationsController input; _atPosInStack: Integer; _intendedIsoType: CM_ISOType; _intendedIsoTypeGroup: CM_ISOTypeGroup): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 December 2020	jlgndl1	Initial creation	TFS 50164

*/

vars

	tiArray : CM_TIArray;
	workArray : CM_TIArray; 
	ti : CM_TrackedItem;
	combinedWeight : Decimal [16,4];
	maxWeight : Decimal [16,4];
	intendedTi : CM_TrackedItem;
	
begin


	// get a collection of every ti that is actually in this position or is planned or queued to this position
	// if the wagon is confirmed (in) (i.e already arrived in the yard ) then don't include ti's that are coming off
	// the wagon, because we wil be planning the outward journey..
	create tiArray transient;
	foreach ti in self.allTrackedItems do
		if self.myWagon.confirmed then
			if not self.myWagon.isTIOutward(ti) then
				continue;
			endif;
		endif;
		tiArray.add(ti);
	endforeach;
	
	create workArray transient; 
	self.getAllQueuedTrackedItems(workArray, true);
	foreach ti in workArray where not tiArray.includes(ti) do
		tiArray.add(ti);
	endforeach;
	
	self.getAllPlannedTrackedItems(workArray, true, false);
	foreach ti in workArray where not tiArray.includes(ti) do
		tiArray.add(ti);
	endforeach;
	
	// if the collection includes the one being passed in remove it from the collection,
	// cos clearly we are considering moving it. 
	if _intendedTi &lt;&gt; null then 
		if tiArray.includes(_intendedTi) then
			tiArray.remove(_intendedTi);
		endif;
	endif;

	// if there are no ti(s) in this position at this point on the code, its available.
	if tiArray.size = 0 then
		return true;
	endif;
	
	combinedWeight := self.myWagon.myWagonClass.tareWeight;
	maxWeight := self.myWagon.myWagonClass.maxLoadWeight;
	foreach ti in tiArray do
		combinedWeight := combinedWeight + ti.totalWeight;
		if combinedWeight &gt; maxWeight then
			return false;
		endif;
	endforeach;
	
	return true;
	
epilog

	delete tiArray;
	delete workArray;
	
end;</source>
        <Parameter name="_intendedTi" type="CM_TrackedItem"/>
        <Parameter name="_otherLc" type="CM_LocationsController" usage="input"/>
        <Parameter name="_atPosInStack" type="Integer"/>
        <Parameter name="_intendedIsoType" type="CM_ISOType"/>
        <Parameter name="_intendedIsoTypeGroup" type="CM_ISOTypeGroup"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
