    <JadeMethod name="noOutputReturned" id="204563fe-bcd3-48ea-ba95-64b3e516f094">
        <source>noOutputReturned(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2020	jlgndl1	Initial creation	TFS 47780

*/

vars

begin

	if not self.allEventTransactions.isEmpty() then
		return false;
	endif;
	
	inheritMethod();

epilog

end;</source>
        <ReturnType type="Boolean"/>
