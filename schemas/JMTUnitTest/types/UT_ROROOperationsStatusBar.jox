    <JadeMethod name="tCheckGetCargoDetailsCorrect" id="149d7684-2132-4c8c-8278-96c5e7a72ba1">
        <updating/>
        <source>tCheckGetCargoDetailsCorrect() updating;

/*

Purpose:		This test checks that the details in the status bar are correct after each step	


Date			Who		Reason
14/05/2013		cnwmh5	Initial creation

*/
constants

	VesselId							: String = "DIAM";
	VoyageId							: String = "UT_MDHVOY11";
	
vars

	operator							: CM_Operator;

begin

	app.writeLog("Creating voyage.  Please wait...", LogINFO);
	
	operator := app.myRoot.allOperators["UTOP"];
	self.assertNotNullMsg(operator, "Null Operator");

	// Create the voyage
	self.deleteVoyage(VoyageId);
	self.myVoyage := self.addVoyageWithConRORO(VoyageId, VesselId, operator.code, "UTSL", "Chief Tasman", 0, false, true);
	self.assertNotNullMsg(self.myVoyage, 'Add voyage failed');
	self.assertNotNullMsg(self.myVoyage.myROROStructure, "RORO Structure is null");

	self.myDeck := self.myVoyage.myROROStructure.allDecksByCode["4"];
	self.assertNotNullMsg(self.myDeck, "Deck not found");
	
	cargoCountId := 0;

	/*******************************************************************************
		Step 1: Create discharge cargo including OOTLs and check that status bar details are correct
	********************************************************************************/
	self.xGCDCStatusBarStep1();
	
	/*******************************************************************************
		Step 2: Colour code discharge slots and check that status bar details are correct
	********************************************************************************/
	self.xGCDCStatusBarStep2();

	/*******************************************************************************
		Step 3: Put into a discharge job and check that status bar details are correct
	********************************************************************************/
	self.xGCDCStatusBarStep3();
	
	/*******************************************************************************
		Step 4: Plan items to discharge job and check that status bar details are correct
	********************************************************************************/
	self.xGCDCStatusBarStep4();
	
	/*******************************************************************************
		Step 5: Discharge cargo and check that status bar details are correct
	********************************************************************************/
	self.xGCDCStatusBarStep5();
	
	/*******************************************************************************
		Step 6: Color code load jobs and check that status bar details are correct
	********************************************************************************/
	self.xGCDCStatusBarStep6();
	
	/*******************************************************************************
		Step 7: Create the jobs for the load colour coding and check that status bar details are correct
	********************************************************************************/
	self.xGCDCStatusBarStep7();
		
	/*******************************************************************************
		Step 8: Plan load items and check that status bar details are correct
	********************************************************************************/
	self.xGCDCStatusBarStep8();
	
epilog

end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
