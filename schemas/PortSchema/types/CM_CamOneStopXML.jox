    </JadeMethod>
    <JadeMethod name="generateFileName" id="922daf44-a8f4-4d3b-bd7d-c65fc4745c47">
        <source>generateFileName( _camAgent : CM_CamControllerAgent; _protocol : CM_CamProtocol ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 February 2017	cnwndl1	Initial creation	TFS 3454 / 2946

Doc attached to TFS 2946 simply says...

CARGO_GATEIN_XXXX.xml
CARGO_GATEOUT_XXXX.xml
CARGO_DISCHARGE_XXXX.xml
CARGO_LOAD_XXXX.xml
XXXX denotes a 4-digit running number e.g CARGO_GATEIN_0001.xml

13 Mar 2017  TFS 3630....  More changes

If its NOT a container then
BB_CARGO_GATEIN_XXXX.xml
BB_CARGO_GATEOUT_XXXX.xml
BB_CARGO_DISCHARGE_XXXX.xml
BB_CARGO_LOAD_XXXX.xml

04 Aug 2017 NDL TFS 5679 

Add 
CARGO_REMOVE_XXXX.xml
BB_CARGO_REMOVE_XXXX.xml

*/

vars

	fileName : String;
	intForFileName : Integer;
	camTaskHistory : CM_CamTaskHistory;
	rawString : String;
	offSet : Integer;
	startPos : Integer;
	endPos : Integer;
	eventTypeString : String;
	cargoTypeStr : String;

begin

	camTaskHistory := _protocol.taskHistoryByProtocolSeq[ _protocol, _camAgent.processSeqNumber ];
	if camTaskHistory &lt;&gt; null then
		rawString := camTaskHistory.getRawDataString();
		if rawString &lt;&gt; null then
		
			offSet := ("&lt;" &amp; self.XMLTag_EventType &amp; "&gt;").String.length;
			startPos := rawString.pos("&lt;" &amp; self.XMLTag_EventType &amp; "&gt;", 1);
			startPos := startPos + offSet;
			endPos := rawString.pos("&lt;/" &amp; self.XMLTag_EventType &amp; "&gt;", 1);
			
			eventTypeString := rawString[ startPos : ( endPos - startPos ) ];
			
			intForFileName :=  _camAgent.processSeqNumber mod 10000;  // max of 4 digit value.
		
			fileName := "CARGO_" &amp; eventTypeString &amp; "_" &amp; intForFileName.padLeadingWith("0",4) &amp; ".xml";
			
			//13 Mar 2017	NDL TFS 3730 - Extra rules for non container cargo
			offSet := ("&lt;" &amp; self.XMLTag_CargoType &amp; "&gt;").String.length;
			startPos := 0;
			startPos := rawString.pos("&lt;" &amp; self.XMLTag_CargoType &amp; "&gt;", 1);
			if startPos &gt; 0 then
				startPos := startPos + offSet;
				endPos := rawString.pos("&lt;/" &amp; self.XMLTag_CargoType &amp; "&gt;", 1);
				cargoTypeStr := rawString[ startPos : ( endPos - startPos ) ];
				// if its there C= container, N= everything else
				if cargoTypeStr = "N" then
					fileName := "BB_" &amp; fileName;
				endif;
			endif;
			
		endif;
	endif;
	
	return fileName;

epilog

end;</source>
        <Parameter name="_camAgent" type="CM_CamControllerAgent"/>
