    <JadeMethod name="utlCreateYATemplates" id="c5368694-e590-4005-8e1d-533465795966">
        <source>utlCreateYATemplates(_isCopyToTerminal : Boolean; _group : CM_YATemplateGroup; _yaSet : CM_YardAllocationSet input; _passport : CM_Passport input);

// Created by cnwdvb1 on 07 August 2006

vars

begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	app.myValCA.valYASnapshot(_isCopyToTerminal, _group, _yaSet, _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	if _isCopyToTerminal then
		_group.buildCurrentAllocations(_yaSet, _passport.myTerminal);
	else
		_group.addAllocationsToGroup(_yaSet);
	endif;
	
end;</source>
        <Parameter name="_isCopyToTerminal" type="Boolean"/>
        <Parameter name="_group" type="CM_YATemplateGroup"/>
        <Parameter name="_yaSet" type="CM_YardAllocationSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateYardActivity" id="13cb1ad9-a7f1-47e1-88f8-02f8f6be6931">
        <source>utlCreateYardActivity(	_ti : CM_TrackedItem input;
						_proxyClass : Class;
						_actionTime : TimeStamp;
						_realYardActivity : CM_YardActivity output;
						_passport : CM_Passport input
						);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 Jul 2020	jlgndl1	Initial creation	TFS 49581
19 Jan 2021	jlgdap1	TFS 50648 MTN Reefer App Issue (4)
*/

vars

	proxyYardActivity, realActivity : CM_YardActivity;
	
begin

	self.initialiseActivity();

	create proxyYardActivity as _proxyClass transient;
	proxyYardActivity.setProxyData( _actionTime, _ti );
	proxyYardActivity.validateForCreate();
	// TFS 50648 check for duplicates and return if we're a web app
	// - don't want to raise the exception from validateForCreate in web apps
	
	// ### TFS 51300 only one reefer job of each kind per TI
	if proxyYardActivity.isReeferJob() then
		realActivity := _ti.allYardActivities.getAtKeyGeq(proxyYardActivity.type, null, _ti);
		if realActivity &lt;&gt; null 
		and realActivity.myTrackedItem = _ti
		and realActivity.type = proxyYardActivity.type
		and realActivity.status = CM_YardActivity.Status_Unactioned then  // ### TFS 51455 09JUL2021 NAVAB1 Reefer Monitor jobs are set to Actioned in the DoAction() that called this method
			return;			 
		endif;
	
	else
		if _ti.allYardActivities[proxyYardActivity.type, _actionTime, _ti] &lt;&gt; null then
			return;
		endif;
	endif;
	

	// TFS 50648 end

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	
	app.setContinueCMExceptions(false);
	
	// Update the Yard Allocation object.
	
	create _realYardActivity as _proxyClass persistent;
	_realYardActivity.setForCreate( proxyYardActivity );
	
epilog

	delete proxyYardActivity;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_proxyClass" type="Class"/>
        <Parameter name="_actionTime" type="TimeStamp"/>
        <Parameter name="_realYardActivity" type="CM_YardActivity" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateYardAllocation" id="583bf54d-f472-46a8-aba1-94eff9563a06">
        <source>utlCreateYardAllocation(pProxyObj:CM_YardAllocation;
						pAllTransientCriteriaObj:CMIF_Array;
						pYardAllocationObj:CM_YardAllocation output;
						_passport : CM_Passport input);
// --------------------------------------------------------------------------------
// Created:		27 April 2005 by cnwdad1
//
// Purpose:		Creates a new Yard Allocation object.
//
// Parameters:	pProxyObj - A reference to the proxy YA object.
//				pYardAllocationObj - A reference to the new YA object.
//				pAllTransientCriteriaObj - A collection of transient objects which
//					contain the receiver's Criteria information.
//				_passport - A reference to the user's "passport".
//
// Returns:		A reference parameter to the new YA object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 17/06/2020	jlgdap1		TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
// 10/12/2020	jlgdap1		TFS 50110 APSA General Cargo Allocation Row - Label
// 10/03/2021	navdap1		TFS 50889 PRP Yard Allocation Performance Improvement
// --------------------------------------------------------------------------------
vars
	blockObj			: CM_YABlock;
	proxyBlockObj		: CM_YABlock;
	deckingOptionsObj	: CM_YADeckingOptions;
	aTA : CM_TerminalArea;
	tmpTerm : CM_Terminal;
	pxyTA : CM_TerminalArea;			// TFS 49453
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	app.myValCA.valYardAllocation(null, pProxyObj);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	// Update the Yard Allocation object.
	
	create pYardAllocationObj persistent;
	pYardAllocationObj.setForCreate(pProxyObj);
	
	// Persist the YA Criteria.
	
	if _passport.noErrors() then
		pYardAllocationObj.persistCriteria(pAllTransientCriteriaObj, _passport);
		pYardAllocationObj.terminalMarkDictAdd();									// TFS 50889
	endif;
	
	// Finally, persist the YA Blocks and update the Decking Options for the inward
	// and outward Blocks.
	
	if _passport.noErrors() and not pYardAllocationObj.isYATemplate() then
		self.myCreateAuditAgent.audCreateGeneric(pYardAllocationObj);
		
		// ### NOTES
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(Event_YardAllocationCreate),false,pYardAllocationObj);
		foreach aTA in pYardAllocationObj.allTerminalAreas do
			aTA.causeEvent(aTA.myTerminal.getTerminalEvent(EVENT_REFRESH_GRID_AREA),false,aTA);
		endforeach;
	endif;
	
	// TFS 49453 if the terminal area is a General Allocation area, we need to update the terminal area as well
	if _passport.noErrors and not pYardAllocationObj.isYATemplate then
		foreach aTA in pYardAllocationObj.allTerminalAreas where aTA.isGeneralCargoAllocArea do
			//app.myUtilityUA.utlUpdateGCAllocTAFromYA(aTA, pYardAllocationObj, _passport);				// TFS 50110
			app.myUtilityUA.utlUpdateGCAllocTAFromYA(aTA, pYardAllocationObj, null, null, _passport);	// TFS 50110
		endforeach;
		pYardAllocationObj.setCargoMinMaxFromProjectedGC();	//08 Apr 2021	NDL	TFS 49912
	endif;
	// TFS 49453 end
end;</source>
        <Parameter name="pProxyObj" type="CM_YardAllocation"/>
        <Parameter name="pAllTransientCriteriaObj" type="CMIF_Array"/>
        <Parameter name="pYardAllocationObj" type="CM_YardAllocation" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
