    <JadeMethod name="getDictForDecking" id="dda0d3c8-b5e1-47da-b83a-7a62612073dc">
        <source>getDictForDecking(_ruleType: Integer): CM_MemberKeyDictionary;
//----------------------------------------------------------------
//	Created:	13 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	
	if _ruleType = Height_Then_Next_Col_Pos
	or _ruleType = Height_Then_Prev_Col_Pos
	or _ruleType = Layer_Then_First_Col_Pos
	or _ruleType = Layer_Then_Last_Col_Pos then
		return self.allGridColumns;
	elseif _ruleType = DeckingRule_Default
	or _ruleType = Height_Then_Next_Row_Pos
	or _ruleType = Height_Then_Prev_Row_Pos
	or _ruleType = Layer_Then_First_Row_Pos
	or _ruleType = Layer_Then_Last_Row_Pos then
		return self.allGridRows;
	else
		//must be custom or null
		return null;
	endif;

end;</source>
        <Parameter name="_ruleType" type="Integer"/>
        <ReturnType type="CM_MemberKeyDictionary"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="d2d2f174-d147-4968-9c08-657d83e815f6">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2009	cnwer1	Initial creation

*/

vars

begin
	if _attrName = ETRow_Rows then
		return self.numberOfRows.asStringJMT;
	elseif _attrName = ETRow_Cols or
		_attrName = ETRow_Bays then
		return self.numberOfColumns.asStringJMT;
	elseif _attrName = ETRow_Height then
		return self.heightOfStack.asStringJMT;
	elseif _attrName = 	ETRow_IsAlignRight then
		return self.isAlignRight.asStringJMT;
	elseif _attrName = 	ETRow_IsSnapToBackend then
		return self.isSnapToBackend.asStringJMT;
	elseif _attrName =	ETRow_NoAccessLeft then
		return self.noAccessLeft.asStringJMT;
	elseif _attrName = ETRow_NoAccessRight then
		return self.noAccessRight.asStringJMT;
	elseif _attrName =  ETRow_IsAlignRight then
		return self.isAlignRight.asStringJMT;
	elseif _attrName = ETRow_Use40ftIds then
		return self.use40ftIds.asStringJMT;
	elseif _attrName = ETRow_UseSideAccessRules then	// PAR 21532 CCMS SFW 1025 
		return self.useSideAccessRules.asStringJMT;
	elseif _attrName = ETRow_PreviousLaneArea then
		return null;
	elseif _attrName = ETRow_NextLaneArea then
		return null;
	elseif _attrName = ETRow_DecColNums then
		return self.areColumnsDecreasing.asStringJMT;
		
	elseif _attrName = ETRow_ColStartNum then
		if self.allGridColumns.size = 0 then
			return null;
		endif;
		return self.allGridColumns.first.label.Integer.asStringJMT;
	elseif _attrName = ETRow_RowStartNum then
			if self.allGridRows.size = 0 then
			return null;
		endif;
		return self.allGridRows.first.label.Integer.asStringJMT;
		// 27198 Apr 2011 RMG height in feet
	elseif _attrName = ETRow_MaxHeight then
		return self.maxHeight.asStringJMT;
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
