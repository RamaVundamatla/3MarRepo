		'Cargo,'&amp;MapName&amp;',UTSLO| UTSLO Desc,(Default),(Default),Import,(Default),(Default),Received - Ship,,(Default),(Default) ›,(Default),All,UT_LineTypeContractVB' &amp; CrLf &amp;
		'Cargo,'&amp;MapName&amp;',CONT| ISO Container,(Default),(Default),Import,(Default),(Default),Received - Ship,,(Default),(Default) ›,(Default),All,UT_LineTypeContractVB' &amp; CrLf;
	
