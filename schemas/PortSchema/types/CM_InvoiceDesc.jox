    <JadeMethod name="setForUpdate" id="4288e413-8fba-4d67-badf-f984b5366b52">
        <updating/>
        <source>setForUpdate(_pxyInvoiceDesc : CM_InvoiceDesc) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// 15/06/2023	navcs2	ChangeRequest 58434: [58452]: EUP | TAS Invoicing - Invoice Type Configuration
// ---------------------------------------------------------------------------

vars

begin

	self.accrualType := _pxyInvoiceDesc.accrualType;
	self.arrNarrationDesc.clear;
	_pxyInvoiceDesc.arrNarrationDesc.copy(self.arrNarrationDesc);
	self.description := _pxyInvoiceDesc.description;
	self.invoiceKey := _pxyInvoiceDesc.invoiceKey;
	self.invoiceType := _pxyInvoiceDesc.invoiceType;
	self.printSingleLineForDayType := _pxyInvoiceDesc.printSingleLineForDayType;
	self.myFinancialPeriodEnd := _pxyInvoiceDesc.myFinancialPeriodEnd;
	self.myInvTermsOfTrade := _pxyInvoiceDesc.myInvTermsOfTrade;
	self.triggerOnAction	:= _pxyInvoiceDesc.triggerOnAction;
	self.invoiceGenerationDateFrom	:= _pxyInvoiceDesc.invoiceGenerationDateFrom;
	self.invoiceGenerationDateTo	:= _pxyInvoiceDesc.invoiceGenerationDateTo;
	self.invoiceGenerationStatus	:= _pxyInvoiceDesc.invoiceGenerationStatus;
	self.externalReference := _pxyInvoiceDesc.externalReference;  //cms 1970 par 25387
	self.isNotAvailableForEntry := _pxyInvoiceDesc.isNotAvailableForEntry;
	self.company := _pxyInvoiceDesc.company;		// 35872
	self.useForApiCn  := _pxyInvoiceDesc.useForApiCn; 		// 15.06.2023	navcs2	#58434:[58452]
	self.useForApiInv := _pxyInvoiceDesc.useForApiInv;  	// 15.06.2023	navcs2	#58434:[58452]
	self.allowManualEditExternalRef := _pxyInvoiceDesc.allowManualEditExternalRef; //08/12/2025	navkc1 JIRA 36262
end;</source>
        <Parameter name="_pxyInvoiceDesc" type="CM_InvoiceDesc"/>
    </JadeMethod>
    <JadeMethod name="setInvTermsOfTrade" id="bbcb9608-6eca-4fbf-9990-3745b38eec2c">
