    <JadeMethod name="setComboValues" id="e145a8af-6346-496e-9207-c714dbecc1d2">
        <source>setComboValues(_combo : ComboBox input; _params : CM_QueryCriteriaLineHolder; _queryOperator : CM_QueryOperator; _passport : CM_Passport);
// ---------------------------------------------------------------------------
// Created:     06 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	transitStatus			: CM_TransitStatus;
begin
	_combo.clear();
	
	transitStatus := app.myRoot.allTransitStatuses[TI_TransitStatusNull];
	_combo.itemObject[_combo.addItem(transitStatus.description)] := transitStatus;
	
	transitStatus := app.myRoot.allTransitStatuses[TI_TransitStatusDLR];
	_combo.itemObject[_combo.addItem(transitStatus.description)] := transitStatus;
	
	transitStatus := app.myRoot.allTransitStatuses[TI_TransitStatusSOB];
	_combo.itemObject[_combo.addItem(transitStatus.description)] := transitStatus;
	
	
	if CM_QIntegerLookupEqual.hasInstance(_queryOperator) then
		_combo.text := app.myRoot.allTransitStatuses[_queryOperator.CM_QIntegerLookupEqual.searchValue].description;
	elseif CM_QIntegerLookupNotEqual.hasInstance(_queryOperator) then
		_combo.text := app.myRoot.allTransitStatuses[_queryOperator.CM_QIntegerLookupNotEqual.searchValue].description;
	endif;
	
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="ad2722a5-1cab-4c60-825a-8839eef635a4">
        <source>translateStringToSearchValue(_value: Any; _criteriaLine : CM_SelectorCriteriaLine ): Any;
// ----------------------------------------------------------------------
// Created 12 May 2008 by cnwvu1
//
// Purpose:	Gets value as String from RT screen and returns value
//			 into criteriaLineLine for running a query
// ----------------------------------------------------------------------

vars
	transitStatus	: CM_TransitStatus;
	codeDict		: CM_TransitStatusByCodeDict;
	tmpDescription	: String;
	
begin
	
	if _value.isKindOf( CM_TransitStatus ) then
		return _value;
	endif;
	
	tmpDescription	:= _value.String.toUpper();
	codeDict := app.myRoot.allTransitStatuses;
	
	foreach transitStatus in codeDict discreteLock do
		if tmpDescription = transitStatus.description.toUpper() then
			return transitStatus.code;
		endif;
	endforeach;

		// when not found. Par 17092	cnwvu1, June 2008
	inheritMethod( _value, _criteriaLine );
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="31715578-9438-4256-b10b-1f9f45728daa">
        <source>translateToDisplayValue(_value: Any): String;
// ---------------------------------------------------------------------------
// Created:     05 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	return app.myRoot.allTransitStatuses[_value.Integer].description;

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="4ab92fa5-c8b4-4739-82ab-2a540e3c8705">
        <source>translateToSearchValue(_value: Any): Any;
// ---------------------------------------------------------------------------
// Created:     05 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
/*

Date		Who		Reason
06 Oct 2008	cnwkpd1	PAR #18099 - Correct Selector query processing
22 Oct 2008	cnwkpd1	PAR #18348 - Prevent 1002 exceptions in Selector query processing with isOneOf

*/

vars
	invalidObj 		: Boolean;
	object			: CM_TransitStatus;
	returnVal		: Integer;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			// PAR #18348
			return _value;
		endif;

		if _value.isKindOf(CM_TransitStatus) then
			object := _value.CM_TransitStatus;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.code;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="8745dfa9-0651-4c2c-b7d0-cec98f3db574">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query parameters
//
vars
	transit : CM_TransitStatus;

begin
	if _value.isKindOf(Integer) then
		transit := app.myRoot.allTransitStatuses[_value.Integer];
		if transit &lt;&gt; null then
			return transit.description;
		endif;
	elseif _value.isKindOf(String) then
		if not _sending then
			return app.transitStatusString2Enum(_value.String);
		endif;
		
		return _value.String;
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
