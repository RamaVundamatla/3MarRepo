<Class name="CM_RemoteScaleTruckHdr">
    <JadeMethod name="loadRemoteTable" id="a171d10d-e8b5-42a5-ad0e-f3d3f3963496">
        <updating/>
        <source>loadRemoteTable(_table: CM_EntryTable io) updating;

vars
	tmpRow	: Integer;
	detail	: CM_RemoteDataDtl;

begin
	inheritMethod(_table);
	
	foreach detail in self.allRemoteDataDtl where not detail.isProcessed do
		self.addRemoteRow(_table, 'Docket ' &amp; detail.CM_RemoteScaleTruckDtl.docketId, Click, detail);
	endforeach;
end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="io"/>
    </JadeMethod>
</Class>
