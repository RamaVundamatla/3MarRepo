    <JadeMethod name="create" id="cc4e6e94-ab1a-47f0-a3f8-7b6af758c9cd">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     14 May 2002 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	self.scaleXFactor	:=	1;
	self.scaleYFactor	:=	1;
end;</source>
    </JadeMethod>
    <JadeMethod name="drawGridArea" id="f148a23a-680a-494c-8578-cc17ef1919f7">
        <updating/>
        <source>drawGridArea() updating, protected;
// ---------------------------------------------------------------------------
// Created:     28 December 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	gridPoint	: CMUI_GridPoint;
	gridFrame	: CMUI_GridAreaFrame;
	
begin
	gridFrame	:=	self.myGridAreaFrame;
	
	if gridFrame &lt;&gt; null then
		gridFrame.clearGraphics();
		self.drawSpecialBefore();	
		
		foreach gridPoint in self.allGridPoints do
			if gridPoint.myLocationsController &lt;&gt; null and not global.isValidObject(gridPoint.myLocationsController) then	// PAR4239 AKB2002NOV
				delete gridPoint;
			else
				gridPoint.drawSelf(gridFrame);
			endif;
		endforeach;
		
		self.drawSpecialAfter();
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="drawSelf" id="e5251589-f763-4c5a-94da-2500f97ce4a7">
        <updating/>
