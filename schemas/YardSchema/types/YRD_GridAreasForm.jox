        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuAuditYardAllocation_click(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		May 2006 cnwrs1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	app.viewAuditForm(self.mnuAuditYardAllocation.userObject.CM_YardAllocation, self.myAssistant.class, self.myTerminal);

