    <JadeMethod name="doCmbDataSourceClick" id="ffe973f4-c2de-4f2a-9788-70b4b0ed6b5b">
        <source>doCmbDataSourceClick();
/*
----------   ----------  --------------------------------------------------
Created:	10 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin

	if self.cmbDataSource.text = HMS_TidalDataSource_File and
	   self.mode &lt;&gt; self.Mode_View then
		self.btnLoadTidalData.enabled := true;
		self.tblInput1.hideRowByName(ETRow_LowestValue, false);
		self.tblInput1.hideRowByName(ETRow_HighestValue, false);
	else
		self.btnLoadTidalData.enabled := false;
		if self.cmbDataSource.text = HMS_TidalDataSourceGetTideFile then //CCMS1640 cnwrs1 jan 2009
			self.tblInput1.showRowByName(ETRow_LowestValue, false); //par 19108 cnwrs1 mar 2009
			self.tblInput1.showRowByName(ETRow_HighestValue, false);
		else
			self.tblInput1.showRowByName(ETRow_LowestValue, false);
			self.tblInput1.showRowByName(ETRow_HighestValue, false);
		endif;
	endif;
	if self.cmbDataSource.text = HMS_TidalDataSourceGetTideFile then //CCMS1640 cnwrs1 jan 2009
		self.tblInput1.showRowByName(ETRow_GetTideFileName, false);
	else
		self.tblInput1.hideRowByName(ETRow_GetTideFileName, false);
	endif;
	if self.cmbDataSource.text &lt;&gt; HMS_TidalDataSource_File and //par 19560 cnwrs1 Apr 2009
	   self.cmbDataSource.text &lt;&gt; HMS_TidalDataSourceGetTideFile then
	endif;
end;


</source>
    </JadeMethod>
    <JadeMethod name="doCmbDataTypeClick" id="08d3cf31-3fc8-4ce1-adfe-30056f379bc7">
        <source>doCmbDataTypeClick() protected;
/*
----------   ----------  --------------------------------------------------
Created:	09 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	cmb					: CMUI_ComboBox;
	dataType			: Integer;
	
	numDraftLabels,
	numCurrentLabels,
	idx					: Integer;
begin
	cmb := self.cmbDataSource;
	cmb.automaticCellControl := true;
	cmb.clear();
	cmb.sorted := false;
	if self.cmbDataType.listIndex &lt; 1 then
		return;
	endif;
	
	on Exception do app.rvTideLibraryExceptionHandler(exception);
	
	dataType := self.cmbDataType.itemData[self.cmbDataType.listIndex];
	
	cmb.addItem(HMS_TidalDataSource_File);
	cmb.addItem(HMS_TidalDataSourceGetTideFile); //CCMS1640 cnwrs1 jan 2009
	

	//epr par 16927 16/6/08
	if  dataType = HMS_TidalDataType_Current or dataType =  HMS_TidalDataType_Height then
		app.myHMSRvTide.xGetNumPredictions(numDraftLabels, numCurrentLabels);	
	endif;
	
	if dataType = HMS_TidalDataType_TimeGap then
		//cmb.addItem('No Daylight IDs Defined');
		
	elseif dataType = HMS_TidalDataType_Current then
		foreach idx in 1 to numCurrentLabels do
			cmb.addItem(app.myHMSRvTide.xGetCurrentLabel(idx));
		endforeach;
		
	elseif dataType = HMS_TidalDataType_Height then
		foreach idx in 1 to numDraftLabels do
			cmb.addItem(app.myHMSRvTide.xGetGaugeLabel(idx));
		endforeach;
		
	elseif dataType = HMS_TidalDataType_HiLo then
		//no dll data for this in tauranga's dll??
	endif;
	
	
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDelete" id="245447e3-d43b-4d9a-81a9-3cf8a9f8641c">
        <updating/>
        <source>doDelete(): Boolean updating;
/*
----------   ----------  --------------------------------------------------
Created:	09 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin

	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteTidalModelDef(self.myCurrentObject.HMS_TidalModelDefinition, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			app.setMyCurrentCargoType(null);
			return true;
		else
			theResult := app.showErrorWarningDialog('Tidal Model Definition', app.myPassport, ErrWarnMode_Delete);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;

end;


</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLoadTidalData" id="1d86fa05-31bd-4f41-9479-d07d807881c5">
        <updating/>
        <source>doLoadTidalData() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	09 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	pxyTidalModelDef	: HMS_TidalModelDefinition;
	frm					: HMS_TidalDataLoadForm;
	tidalData			: HMS_TidalData;
	idx					: Integer;
	dataType			: Integer;
begin
	if self.mode = self.Mode_View then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid mode for loading tidal data - must be in edit mode.');
		return;
	endif;
	
	create frm transient;
	pxyTidalModelDef := self.myProxyObject.HMS_TidalModelDefinition;
	
	if pxyTidalModelDef = null then
		create pxyTidalModelDef transient;
		self.myProxyObject := pxyTidalModelDef;	
	endif;
	
	frm.createMyAssistant(HMS_Assistant);
	frm.myPxyTidalModelDef := pxyTidalModelDef;
	
	if self.cmbDataType.listIndex &lt; 1 then
		dataType := null;
	else
		dataType := self.cmbDataType.itemData[self.cmbDataType.listIndex];	
	endif;

	frm.loadFileTypes(dataType); //par # 12852
	
	frm.showModal;
	
	if frm.tidalDataFileType &lt;&gt; null then
		pxyTidalModelDef.setFileType(frm.tidalDataFileType);
	endif;
	
	tidalData := pxyTidalModelDef.allHMSTidalData.first;
	if tidalData &lt;&gt; null then
		idx := self.cmbDataType.findString(1, app.tidalFileTypeEnumToString(tidalData.getDataType()));
		if idx &gt; 0 then
			self.cmbDataType.listIndex := idx;
			self.tblInput1.setValueByName(ETRow_DataType, self.cmbDataType.text);
		endif;
	endif;
	
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSave" id="f0da9ead-d7e3-4049-b4b2-93d5da7d75f7">
        <updating/>
        <source>doSave(): Boolean updating;

vars
	pxyTidalModelDef,
	newTidalModelDef	: HMS_TidalModelDefinition;
	result				: Integer;

begin
	
	pxyTidalModelDef := self.myProxyObject.HMS_TidalModelDefinition;
	
	if pxyTidalModelDef = null then
		create pxyTidalModelDef transient;
		self.myProxyObject := pxyTidalModelDef;	
	endif;
	
	self.setTidalModelDef(pxyTidalModelDef);
	
	while true do
		if self.mode = self.Mode_Add then
			app.myTrxCA.trxCreateTidalModelDef(pxyTidalModelDef, newTidalModelDef, app.myPassport);
			self.myCurrentObject := newTidalModelDef;
		elseif self.mode = self.Mode_Update then
			app.myTrxUA.trxUpdateTidalModelDef(pxyTidalModelDef, app.myPassport);
		endif;
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			return true;
		else
			result := app.showErrorWarningDialog('Tidal Model Definition update', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;

			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		endif;
		
		return false;
	endwhile;
	
	return true;
	

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getHiLoTidesForTime" id="83e2021c-53c8-438f-b8c1-16ce3a2d28af">
        <updating/>
        <source>getHiLoTidesForTime(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 August 2009	cnwer1	Initial creation
//22 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	tidalModelDef : HMS_TidalModelDefinition;
	inputDate : Date;
	inputTime : Time;
	timeToCheck,
	endTS,startTS: TimeStamp;
	timeArray : TimeStampArray;
	draughtArray : RealArray;
	draught,
	lowD, prevDraft,
	highD: Real;
	isFlood : Boolean;
begin
	if tblData.index &lt; 0 then
		return;
	endif;
	
	tidalModelDef:=self.tblData.accessedRow.itemObject.HMS_TidalModelDefinition;
	
	if tidalModelDef = null then
		return;
	endif;
	
	if tidalModelDef.dataSource &lt;&gt; HMS_TidalDataSourceGetTideFile then
		write "Tidal Model data source needs to be Get Tide nml file";
		return;
	endif;

	
	create timeArray transient;
	//22 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	inputTime := app.actualTimeServer().time();
	inputTime.setTime(inputTime.hour,inputTime.minute,0,0);
	timeToCheck.setTime(inputTime);
	timeToCheck.setDate("7/8/2009".Date);
	startTS:=timeToCheck.addHours(-12);
	write startTS;
	endTS:=timeToCheck.addHours(12);
	write endTS;
	//minute intervals
	timeToCheck:=startTS;
	while timeToCheck &lt;= endTS do
		timeArray.add(timeToCheck);
		timeToCheck:=timeToCheck.addMinutes(1);
	endwhile;
		
	create draughtArray transient;
	app.myHMSRvTide.getFloodCurrent(tidalModelDef, timeArray, draughtArray);
	
	
	foreach draught in draughtArray do
		if prevDraft  &lt;&gt; null then
			if draught &gt; prevDraft then
				if not isFlood then
					write "LW = " &amp; draught.String &amp; " @ " &amp; timeArray[draughtArray.indexOf(draught)].String;
				endif;
				isFlood:=true;
			elseif  draught &lt; prevDraft then
				if isFlood then
					write "HW = " &amp; draught.String &amp; " @ " &amp; timeArray[draughtArray.indexOf(draught)].String;
				endif;
				isFlood:=false;
				
			endif;
		endif;
	
		prevDraft:=draught;
	endforeach;
epilog
	delete timeArray;
	delete draughtArray;
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getMaxDraughtFromDate" id="3a41f37f-d688-43d9-bb37-ceeeec330024">
        <updating/>
        <source>getMaxDraughtFromDate(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 August 2008	cnwer1	Initial creation

*/

vars

	tidalModelDef : HMS_TidalModelDefinition;
	inputDecimal,outputDraft : Decimal[16,2];
	inputDate : Date;
	timeToCheck,
	maxTS: TimeStamp;
	
begin
	if tblData.index &lt; 0 then
		return;
	endif;
	
	tidalModelDef:=self.tblData.accessedRow.itemObject.HMS_TidalModelDefinition;
	
	if tidalModelDef = null then
		return;
	endif;
	
	app.writeStatement( "Enter date from");
	read inputDate;
	if not inputDate.isValid then
		app.writeStatement( "invalid date");
		return;
	endif;
	
	outputDraft:=null;
	timeToCheck.setDate(inputDate);
	app.writeStatement( tidalModelDef.getMaxDraughtFromDate(timeToCheck,maxTS,outputDraft).String);
	app.writeStatement(  maxTS.String);
	app.writeStatement(  outputDraft.String);
epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getPreviousHiLo" id="ab3133ff-d106-4dfa-9429-1d3508908a44">
        <updating/>
        <source>getPreviousHiLo(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 August 2009	cnwer1	Initial creation
//22 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars
	tidalModelDef : HMS_TidalModelDefinition;
	inputDate : Date;
	inputTime : Time;
	timeToCheck : TimeStamp;
	timeArray : TimeStampArray;
	draughtArray : RealArray;
	draught : Real;
	iter : Iterator;
begin
	if tblData.index &lt; 0 then
		return;
	endif;
	
	tidalModelDef:=self.tblData.accessedRow.itemObject.HMS_TidalModelDefinition;
	
	if tidalModelDef = null then
		return;
	endif;
	
	if tidalModelDef.dataSource &lt;&gt; HMS_TidalDataSourceGetTideFile then
		write "Tidal Model data source needs to be Get Tide nml file";
		return;
	endif;
	//22 Apr 2016	cnwns1	TFS 488 - Multi Timezone Support
	timeToCheck := app.actualTimeServer();
	/*app.writeStatement( "Enter date from");
	read inputDate;
	if not inputDate.isValid then
		app.writeStatement( "invalid date");
		return;
	endif;
	timeToCheck.setDate(inputDate);
	app.writeStatement( "Enter time from");
	read inputTime;
	if inputTime.isValid then
		timeToCheck.setTime(inputTime);
	endif;*/
	
	create timeArray transient;
	
	app.myHMSRvTide.populateTimestampArray(timeToCheck, timeArray);
	
	create draughtArray transient;
	app.myHMSRvTide.getFloodCurrent(tidalModelDef, timeArray, draughtArray);
	
	//0iter:=
	foreach draught in draughtArray do
		app.writeStatement(draught.String);
	endforeach;
epilog
	delete timeArray;
	delete draughtArray;


end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="includeObject" id="128ac9ed-da44-4dc0-ae13-f4dbcc29ae75">
        <updating/>
        <source>includeObject(_tidalRestrict : HMS_TidalModelDefinition; _passport: CM_Passport): Boolean updating;
// ---------------------------------------------------------------------------
// Created:     30 August 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	pos : Integer;
	include : Boolean;
begin
	pos := 1;
	include := true;
	
	if (self.filterCode &lt;&gt; null) and (_tidalRestrict.code.pos(self.filterCode, pos)) &lt; 1 then
		include := false;
	endif;
	
	pos := 1;
	//if (self.filterDescr &lt;&gt; null and _tidalRestrict.description &lt;&gt; self.filterDescr) then
	if (self.filterDescr &lt;&gt; null) and (_tidalRestrict.description.pos(self.filterDescr, pos)) &lt; 1 then
		include := false;
	endif;
	
	return include;

end;</source>
        <Parameter name="_tidalRestrict" type="HMS_TidalModelDefinition"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
