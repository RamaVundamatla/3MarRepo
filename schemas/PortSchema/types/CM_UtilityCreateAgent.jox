    <JadeMethod name="utlCreateGate" id="bbe61050-fd6e-4071-9467-ad1ae21cf6ec">
        <source>utlCreateGate(_proxy :CM_Gate; _passport :CM_Passport input):CM_Gate;
// ---------------------------------------------------------------------------
// Created:     12 June 2009 by concms1
// Purpose:     Par 
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	12/10/2009	cnwcs5		par 20774 - 1090 when creating gate as part of terminal creation
// ---------------------------------------------------------------------------
vars
	newGate	:CM_Gate;
begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	
	app.myValCA.valCM_Object(_proxy, _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return null;
	endif;
	
	app.setContinueCMExceptions(false);
	
	create newGate persistent;
	
	newGate.setForCreate (_proxy);
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(newGate);	
		// par 20774 - use the terminal reference on the gate to get the terminal event
		// if gate is being created as part of a new terminal create then the terminal
		// reference on _passport will be null
		newGate.myTerminal.causeEvent(newGate.myTerminal.getTerminalEvent(EVENT_GATE_CREATE), false, newGate);	// par 20774
	endif;	

	return newGate;
epilog

end;</source>
        <Parameter name="_proxy" type="CM_Gate"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="CM_Gate"/>
    </JadeMethod>
    <JadeMethod name="utlCreateGateLaneControllers" id="1edf0a07-7506-4594-bccc-c764a3e8329a">
        <source>utlCreateGateLaneControllers(	_realVTA  : CM_VehicleTransferArea input;
								_allGateLaneControllers : CM_GateLaneControllerArray;
								_passport : CM_Passport input);
/*

Purpose:			


Return Value:		


Date		Who		Reason
02 August 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	pNewGateLaneController,
	realGateLaneController,
	glc : CM_GateLaneController;
	edition : Integer;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	
	foreach pNewGateLaneController in _allGateLaneControllers do
		create realGateLaneController persistent;
		realGateLaneController.setForCreate(pNewGateLaneController,_realVTA);
	endforeach;
	


epilog

end;</source>
        <Parameter name="_realVTA" type="CM_VehicleTransferArea" usage="input"/>
        <Parameter name="_allGateLaneControllers" type="CM_GateLaneControllerArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
