    <JadeMethod name="xAddToDoTaskTrain" id="fa1d8b50-9d88-44e1-a022-36de10d82c53">
        <source>xAddToDoTaskTrain(): CM_ToDoTaskDesc;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who			Reason
01 Aug 2023 navhl20 ChangeRequest 58158: EUP | [Framework] - Delivery Dispatch Garbage Collection

*/

constants
	ToDoTaskCode			             : String = "UT_1020T";
	Type								 : Integer = TODO_TYPE_GROUP_TRAIN;
	ShortDesc                            : String = "Train ToDo";
	TaskRemarks                          : String = "UT Remarks";
vars
	ti                                   : CM_TrackedItem;
	operator	                         : CM_Operator;
	tiSet                                : CM_TISet;
	toDoTask                             : CM_ToDoTaskDesc;
	proxyToDoTask                        : CM_ToDoTaskDesc;
	tiUpdateCntrlr						 : CMIF_TIUpdateController;
begin
    
    toDoTask := app.myRoot.allToDoTaskDescsByShortDesc[ToDoTaskCode];
	if toDoTask &lt;&gt; null then
		self.deleteToDoTaskDescription(toDoTask);
	endif;
    
	
	self.opts.purge();
	self.opts.addAssoc("RequiresExtraInfo", "Weight");
	self.opts.addAssoc(ETRow_TransactionToCreate, TRANS_TYPE_WEIGH);
	self.opts.addAssoc("Type", Type);
	
	toDoTask := self.createToDoTaskDesc(ToDoTaskCode);
	self.assertEqual(toDoTask.type, Type);
    
	return toDoTask;
epilog
    delete proxyToDoTask;
	delete tiSet;
	delete tiUpdateCntrlr;
end;</source>
        <ReturnType type="CM_ToDoTaskDesc"/>
    </JadeMethod>
    <JadeMethod name="xApproveWorkOrder" id="ded147ca-766d-4bce-baf7-27e58ee560c7">
        <source>xApproveWorkOrder(_wo : CM_WorkOrder io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Aug 2023 navhl20 ChangeRequest 58158: EUP | [Framework] - Delivery Dispatch Garbage Collection
02 May 2024 navhl20 ChangeRequest 63971: FR | 54176 - Ship operations in Delivery Dispatch screen
*/

vars
	errors : String;
begin
	
	app.myTrxUA.trxUpdateWOApproved(_wo,false,null,null, app.myPassport);		//02.05.2024 navhl20 #63971
	
	if app.myPassport.hasErrors then
		errors := app.myPassport.getErrorsAsString;
		self.assertTrueMsg(false ,
						  'Error : Failed Approving Work order : ' 			  &amp;   _wo.id 	  &amp; CrLf &amp; 
						  'Trx Errors: '						 		 	  &amp;    errors  );
	endif;
	
epilog

end;</source>
