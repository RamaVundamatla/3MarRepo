    <JadeMethod name="clearAllTextForMethods" id="c1d70614-7408-4388-83ee-8f835c82a443">
        <source>clearAllTextForMethods();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 March 2014	cnwmc5	Initial creation

*/

vars
	mthDict			: MethodNDict;
	allLines		: HugeStringArray;
	
	cls 			: Class;
	mth				: Method;
	
	source			: String;
	line			: String;
	lineToWrite		: String;
	foundPurpose	: Boolean;
begin
	cls := currentSchema.getClass("JMTUserInterfaceService");
	
	//Setup
	create mthDict transient;
	create allLines transient;
	cls.getMethods(mthDict);
	
	foreach mth in mthDict do
		write mth.name;
		write "Before:" &amp; Tab &amp; mth.text;
		beginTransaction;
		mth.cnEcSetText(null);
		commitTransaction;
		write "After:" &amp; Tab &amp; mth.text;
		write CrLf;
	endforeach;
epilog
	//Clean up
	delete mthDict;
	delete allLines;
end;</source>
    </JadeMethod>
    <JadeMethod name="displayAllText" id="161f482b-9fb3-4ab9-b520-3865cf72d041">
        <source>displayAllText();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2014	cnwmc5	Initial creation

*/

vars
	allMths				: MethodSet;
	scm 				: Schema;
	cls 				: Class;
	mth					: Method;
	prop				: Property;
	
begin
	scm := currentSchema;
	
	create allMths transient;
	foreach cls in scm.allClasses do
		if cls.schema &lt;&gt; scm then
			continue;
		endif;
		
		allMths.clear();
		write "Class" &amp; Tab &amp; cls.name &amp; Tab &amp; cls.text;
		foreach prop in cls.allProperties do
			if prop.text &lt;&gt; null then
				write "Property" &amp; Tab &amp; prop.name &amp; Tab &amp; prop.text;
			endif;
		endforeach;
		cls.allMethods(allMths);
		foreach mth in allMths do
			if mth.text &lt;&gt; null then
				write "Method" &amp; Tab &amp; mth.name &amp; Tab &amp; mth.text;
			endif;
		endforeach;
	endforeach;
	
epilog
	delete allMths;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="dpiGetWorkOrderVoyageByType" id="ed713325-3b74-41ac-8929-9328ea5edde1">
        <source>dpiGetWorkOrderVoyageByType();
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		TFS		Reason
15 January 2020	jlgdi1				Initial creation
*/

vars
	voyage : CM_Voyage;
	wodQueryRequest : WS_WorkOrderDetailQueryRequest;
	workOrderDetail : CM_WorkOrderVoyageDtl;
	workOrder : CM_WorkOrder;
	response : WS_WorkOrderDetailResponse;
	allCargoRequests : CM_WodCargoRequestSet;
	
begin
	app.initialize;
	app.myPassport.setMyUserFromCode("JLGDI1");
	app.myPassport.setMyTerminal(app.myRoot.allTerminals["T02"]);
	voyage:="4480.1347636".asOid.CM_Voyage;
	
	app.msgBox(CM_ConsigneeConsignor.name, "", 0); 
	
	allCargoRequests := voyage.getAllWodCargoRequests();
	
	app.msgBox(allCargoRequests.size.asStringJMT(), "", 0); 
	
	create wodQueryRequest transient;
	wodQueryRequest.type := WO_TASK_CARGOINITIAL;
	
	workOrderDetail := wodQueryRequest.getWOVoyageDtlType(voyage);

	if workOrderDetail = null then
		app.msgBox("Work Order is Null","",0);
		return;
	else
		app.msgBox(workOrderDetail.taskID,"",0);
	endif;
	
	create response transient;
	
	if workOrderDetail &lt;&gt; null  then
		workOrder := workOrderDetail.getMyParent.CM_WorkOrder;
		if wodQueryRequest.checkWorkOrder(workOrderDetail,  null) then 
			response.createWsWorkOrderDtl(workOrder, wodQueryRequest, 1);
		endif;
	endif;	
	
epilog
	delete wodQueryRequest;
end;</source>
    </JadeMethod>
