    <JadeMethod name="setFrmFindRCntrlsTopLeftHeight" id="aa1fe73b-16ed-432a-9c9f-c4c4e559fe87">
        <source>setFrmFindRCntrlsTopLeftHeight();

/*

Purpose:		Set the top, left, height details for
				frmFindReplace

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2009	cnwmh5	Initial creation #21651
*/

vars
	tableTop	: Real;
	tableHeight	: Real;
begin

	self.frmFindRToolBar.showCaptions := self.frmToolbar.showCaptions;	
	tableTop := self.frmFindRToolBar.height;
	tableHeight	:= self.frmFindReplace.clientHeight - tableTop;
	self.tblFindReplace.top := tableTop;
	self.tblFindReplace.left := 0;
	self.tblFindReplace.height := tableHeight;
	
	self.tblMultiReplace.top := tableTop;
	self.tblMultiReplace.width := self.frmFindReplace.clientWidth - self.tblMultiReplace.left;
	self.tblMultiReplace.height := tableHeight;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setFrmLoadFileCntrlsTop" id="b0649d16-386e-4319-9925-e7edd921a6ab">
        <source>setFrmLoadFileCntrlsTop();

/*

Purpose:		Set the controls top for frame frmLoadFile controls		

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2009	cnwmh5	Initial creation #21651

*/

vars
	
	tmpControl	: Control;
	numControls,
	i			: Integer;
	tmpParent	: Window;
	
	currentHeight	: Real;
	newHeight		: Real;
	heightDiff		: Real;
	
begin

	// get the current height
	currentHeight := self.frmLoadFileTool.height;
	
	// set whether show captions is set
	self.frmLoadFileTool.showCaptions := self.frmToolbar.showCaptions;

	// get the new height
	newHeight := self.frmLoadFileTool.height;
	
	// get the difference in heights
	heightDiff := newHeight - currentHeight;
	
	// check so if initial load resizes correclty
	if heightDiff = 0 and optAutoType.top &lt; self.frmLoadFileTool.height then
		heightDiff := 17;		
	endif;
	
	// read through the controls and if parent is frmLoadFile then update top by heightDiff
	numControls := self.controlCount;
	
	foreach i in 1 to numControls do
		tmpControl := self.controls(i);
		tmpParent := tmpControl.parent;
		if tmpParent.name &lt;&gt; self.frmLoadFile.name or tmpControl.isKindOf(CMUI_Toolbar)then
			continue;
		endif;
		
		// add heightDiff to controls top
		tmpControl.top := tmpControl.top + heightDiff;
		
	endforeach;
	
	// change frmLoadFile height by the difference
	self.frmLoadFile.height := self.frmLoadFile.height + heightDiff;
	
epilog
	
end;</source>
    </JadeMethod>
