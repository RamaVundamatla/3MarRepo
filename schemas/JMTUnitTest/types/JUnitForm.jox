    <JadeMethod name="lbxTests_dblClick" id="a188ec02-8520-4680-a3d9-fdd6cd54e237">
        <controlMethod name="ListBox::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lbxTests_dblClick( listbox : ListBox input ) updating;

vars

	object : Object;
	
begin
	app.mousePointer	:=	Busy;
	// if the listbox is already expanded then collapse it else expand it and child branches.
	if listbox.itemExpanded[ listbox.listIndex ] then
		listbox.itemExpanded[ listbox.listIndex ]	:= false;
	else
		listbox.cnEcExpandItem( listbox.listIndex, true );
	endif;
	
	object := listbox.itemObject[ listbox.listIndex  ];
	if object &lt;&gt; null then
		if object.isKindOf(JadeMethod) then
			self.btnRun.click(self.btnRun);
		endif;
	endif;
	
epilog
	app.mousePointer	:=	Idle;
	
end;
</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lbxTests_keyUp" id="0e8deb95-9ab3-4d43-90b3-2625f8876e3c">
        <controlMethod name="ListBox::keyUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lbxTests_keyUp(listbox: ListBox input; keyCode: Integer io; shift: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
26 May 2023		navmd1	Initial creation

*/

vars
	rowIdx,
	myLevel,
	i			: Integer;
begin
	rowIdx := listbox.listIndex;
	if keyCode = J_key_LeftArrow then
		if listbox.itemExpanded[rowIdx] then
			// collapse 'current row'
			listbox.itemExpanded[rowIdx] := false;
		else
			if rowIdx &gt; 1 then
				// collopase 'parent row'
				myLevel := listbox.itemLevel[rowIdx];
				foreach i in rowIdx-1 to 0 step -1 do
					if listbox.itemLevel[i] &lt; myLevel then
						listbox.listIndex := i;
						listbox.itemExpanded[i] := false;
						break;
					endif;
				endforeach;
			endif;
		endif;
	elseif keyCode = J_key_RightArrow then
		//expand
		 listbox.itemExpanded[listbox.listIndex] := true;
	endif;
epilog

end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
