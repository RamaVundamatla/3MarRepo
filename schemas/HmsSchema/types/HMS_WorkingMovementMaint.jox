    <JadeMethod name="initTblResources" id="80870659-1035-4efc-b34f-612a01b1ee5f">
        <updating/>
        <source>initTblResources()updating, protected;
//--------------------------------------------------
// Created:	24 February 2005 By: cnwgd1
// 27-Jun-2025	naviv1	MTN-35261 : 14050 Error when adding Movement Shift in Harbour Management
//--------------------------------------------------
vars
	tmpTable : CM_DataTable;
begin
	if app.myCurrentUserCan(self.myTerminal, Mod_Invoicing) then
		tmpTable := self.tblResources;
		self.shtWharfServices.visible := false;
		self.shtResources.visible := true;	
		tmpTable.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_HMSResourceUsed));	
		self.setColumnIndex();
		tmpTable.userInputEnabled := true;
		tmpTable.tabKey := J_key_Tab;
		if self.aColQtyUnits &lt;&gt; null then	//MTN-35261
			tmpTable.accessColumn(self.aColQtyUnits).enabled := false;
		endif;
		if self.aColUnitsUsed &lt;&gt; null then	//MTN-35261
			tmpTable.accessColumn(self.aColUnitsUsed).alignment := Table.Alignment_Right;
		endif;
			//tmpTable.accessColumn(self.colCreateCharge).enabled := false;
			//tmpTable.accessColumn(self.colPartOfContract).enabled := false;	
		if self.aColInvNo &lt;&gt; null then	//MTN-35261
			tmpTable.accessColumn(self.aColInvNo).enabled := false;
		endif;		
		
		self.setColorsForTable(tmpTable);		
	else
		self.shtWharfServices.visible := true;
		self.shtResources.visible := false;		
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="keyDown" id="efe7ec5a-57fa-4fea-af4d-6debeb2e44ab">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
//--------------------------------------------------
// Created:	25 February 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpTable : CM_DataTable;
begin
	tmpTable := self.tblResources;
	
	if self.fldMovements.topSheet = self.shtResources
	and tmpTable.userInputEnabled
	and tmpTable.row &gt; tmpTable.fixedRows
	and tmpTable.accessRow(tmpTable.row).enabled
	and app.isControlKeyDown()
	and not app.isAltKeyDown()
	and not app.isShiftKeyDown()
	and keyCode = J_key_Delete
	then
		tmpTable.removeItem(tmpTable.row);
	else
		inheritMethod(keyCode, shift);
	endif;
end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadAddMovement" id="0f76f6f9-412d-46cb-80f2-b4b448679cbc">
        <updating/>
        <source>loadAddMovement() updating, protected;
//06 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
//30 Apr 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
//16/09/2022	navgm20 ChangeRequest 54739: EUP - PLAN - Berth planning by bollards
//10/07/2024	navcs2	Bug 64769: MSL- IMT- Unable to manage the movements in Harbor management
//30/10/2024	navdap1	MTN-12358 EUP* | FR 54107 - Berth planning by bollards - part II

vars
	departMove			: CMIF_HMS_WorkingMovement;
	newMovement			: CMIF_HMS_WorkingMovement;
	movementPrev		: CMIF_HMS_WorkingMovement;
	defaultDTForMove	: TimeStamp;
	defaultTideClass	: HMS_TidalClass;  // Modified by Russell 29/03/99
	harbour				: HMS_Harbour;
	defBerthObj			: HMS_Berth;
	
begin
 	// Set harbour and terminal references
 	harbour := self.myTerminal.myHarbour;
 	if harbour = null then
 		return;
 	endif;

	// Notify controller that a movement is being added or edited - delay any database updates until user finishes this action
	self.aMyViewController.set_AddEditMovementActiveState(true);
	
	// Clone working voyage and movement
	if self.aMySelectedVoyage.ofClonedVoyage = null then
		// voyage is not yet cloned - do this now
		self.aMySelectedVoyage.createClone;
		self.aMySelectedVoyage := self.aMySelectedVoyage.myClone;
	else
		self.aMode := self.Mode_Update;			
	endif;
	
	departMove := self.aMySelectedVoyage.allClonedMovements.last.CMIF_HMS_WorkingMovement;
	movementPrev := departMove.getMovementPrevious();
	defaultDTForMove := movementPrev.occursOnDT.changeByXXHours((movementPrev.occursOnDT.differenceInHours(departMove.occursOnDT)/2).Integer);

	// ADD mode: Create new movement
	create newMovement transient;
	newMovement.newMovementAsClone(self.aMySelectedVoyage, HMSMovementTypeShift, defaultDTForMove, self.aMyViewController);
	self.aMySelectedMovement := newMovement;
    aAddMode := true;
      
	defaultTideClass := self.aMySelectedMovement.myMoveTidalClass;
  	//movementPrev := self.mySelectedMovement.getMovementPrevious();

	self.myTxtMoveOnDate.setDate(self.aMySelectedMovement.occursOnDT.date);
 	self.myTxtMoveOnTime.setTime(self.aMySelectedMovement.occursOnDT.Time);
	
	// Set default properties on form
 	self.txtMoveVoyageCod.text := self.aMySelectedVoyage.code;
 	self.txtMoveShipName.text := self.aMySelectedVoyage.myHMSVoyageData.vesselName;
	self.txtLOA.text := self.aMySelectedVoyage.myHMSVoyageData.dim_LengthOverall.asStringJMT();		// MTN-12358
	self.txtMoveShipName1.text := self.txtMoveShipName.text;	
 	
	// 16/09/2022 navgm20	TFS 54739- Start
	self.cmbBowMarkBollard.listIndex	:= self.cmbBowMarkBollard.findObject(self.aMySelectedMovement.myBowBollard);
	self.cmbSternMarkBollard.listIndex	:= self.cmbSternMarkBollard.findObject(self.aMySelectedMovement.mySternBollard);
	self.cmbBridgeMarkBollard.listIndex	:= self.cmbBridgeMarkBollard.findObject(self.aMySelectedMovement.myBridgeBollard);
	self.txtBowMarkMeter.text	:=	self.aMySelectedMovement.bowToBollard.asStringJMT;						// 10/07/2024	navcs2	Bug 64769
	self.txtSternMarkMeter.text	:=	self.aMySelectedMovement.sternToBollard.asStringJMT;					// 10/07/2024	navcs2	Bug 64769
	self.txtBridgeMarkMeter.text	:=	self.aMySelectedMovement.bridgeToBollard.asStringJMT;				// 10/07/2024	navcs2	Bug 64769
	// 16/09/2022 navgm20	TFS 54739- End
	
	// loadCollections
	self.loadCollections();

	//self.txtDraftAft.text := "0.0";
	//self.txtDraftFwd.text := "0.0";
	self.txtDraftAft.text := "0.0".Decimal.asStringJMT();	// 05/02/2013 cnwar2 #29580
	self.txtDraftFwd.text := "0.0".Decimal.asStringJMT();	// 05/02/2013 cnwar2 #29580

	// Load "Default Tidal Class" for this ship
  	// Modified by Russell 29/03/99
  	// --------------------------------------------------------------------
  	if defaultTideClass &lt;&gt; null then
  		self.txtDefaultTidal.text := defaultTideClass.description;
  	else
  		self.txtDefaultTidal.text := "";
  	endif;
  	// --------------------------------------------------------------------

  	if movementPrev = null then
		defBerthObj	:=	harbour.defaultDepartBerth;
		
 		// Arrival from sea
		if defBerthObj = null then  //06.10.2017	cnwma1  TFS #7257
				self.txtBerthFrom.text	:=	null;	 	
			else
				self.txtBerthFrom.text	:=	defBerthObj.description;
		endif;
 		self.txtAftClearFrom.text := app.getErrorString(NotApplicable);
 		self.txtForeClearFrom.text := app.getErrorString(NotApplicable);
 		self.txtBowMarkFrom.text := app.getErrorString(NotApplicable);
 		self.txtSternMarkFrom.text := app.getErrorString(NotApplicable);
 		self.txtOrientFrom.text := app.getErrorString(NotApplicable);
	else
		// Load berth details for previous movement
		
		if movementPrev.myBerth &lt;&gt; null then  //06.10.2017	cnwma1  TFS #7257
			self.txtBerthFrom.text := movementPrev.myBerth.description;
		endif;

		// If berth.ofWharf is logical, then set marks and clearances to N/A
		if movementPrev.isLogicalBerth() then
			self.txtAftClearFrom.text := app.getErrorString(NotApplicable);
 			self.txtForeClearFrom.text := app.getErrorString(NotApplicable);
 			self.txtBowMarkFrom.text := app.getErrorString(NotApplicable);
 			self.txtSternMarkFrom.text := app.getErrorString(NotApplicable);
 			self.txtOrientFrom.text := app.getErrorString(NotApplicable);
 		else
			if movementPrev.aftClearanceTo = ClearanceUnbounded then
 	 			self.txtAftClearFrom.text := app.getErrorString(Unlimited);
 	 		else 
 	 			self.txtAftClearFrom.text := movementPrev.aftClearanceTo.asStringJMT();	//#24363 18/06/2010
 			endif;

 			if movementPrev.foreClearanceTo = ClearanceUnbounded then
 	 			self.txtForeClearFrom.text := app.getErrorString(Unlimited);
 	 		else 
 				self.txtForeClearFrom.text := movementPrev.foreClearanceTo.asStringJMT();	//#24363 18/06/2010
 			endif;
			self.txtBowMarkFrom.text := movementPrev.bowMarkTo.asStringJMT();		//#24363 18/06/2010
 			self.txtSternMarkFrom.text := movementPrev.sternMarkTo.asStringJMT();	//#24363 18/06/2010
 			if movementPrev.sideTo = OrientPortSideTo then
 				self.txtOrientFrom.text := app.getErrorString(PortSideTo);
 			else
 				self.txtOrientFrom.text := app.getErrorString(StarboardSideTo);
 			endif;	
   		endif;
 	endif;

	if self.aMySelectedMovement.sideTo = OrientPortSideTo then 
		self.cmbOrientTo.listIndex := OrientPortSideTo;
		self.cmbOrientTo.text := self.cmbOrientTo.itemText[self.cmbOrientTo.listIndex];
	else
		self.cmbOrientTo.listIndex := OrientStarboardSideTo;
		self.cmbOrientTo.text := self.cmbOrientTo.itemText[self.cmbOrientTo.listIndex];
 	endif;

	if self.aMySelectedMovement.myBerth &lt;&gt; null then
		// Set default 'To Berth'
		self.myCmbBerthTo.listIndex := self.myCmbBerthTo.findObject(self.aMySelectedMovement.myBerth);	  		  				
		
		if (not self.aMySelectedMovement.isBerthVisibleOnView()) then
 		//if self.mySelectedMovement.isLogicalBerth() then
  		   	// Departure to sea (or other logical berth)
 			self.txtAftClearTo.text := app.getErrorString(NotApplicable);
 			self.txtForeClearTo.text := app.getErrorString(NotApplicable);

 			self.txtBowMarkTo.text := app.getErrorString(NotApplicable);
 			self.txtSternMarkTo.text := app.getErrorString(NotApplicable);
 			self.txtBridgeMarkTo.text := app.getErrorString(NotApplicable); 			 			
 		else
 			
 			if self.aMySelectedMovement.bowMarkTo &lt;&gt; null then
 				self.txtBowMarkTo.text := self.aMySelectedMovement.bowMarkTo.asStringJMT();	//#24363 18/06/2010
 				self.setMeterMarksTo(self.txtBowMarkTo, false); 			
 			else
 				self.setMeterMarksTo(null, false);
 			endif;
  		  	
  		  	self.aLastValidBowMark := self.aMySelectedMovement.bowMarkTo;
	    	self.aLastValidSternMark := self.aMySelectedMovement.sternMarkTo;
	    	self.aLastValidForeClearance := self.aMySelectedMovement.foreClearanceTo;
			self.aLastValidAftClearance := self.aMySelectedMovement.aftClearanceTo;
			self.aMyLastValidBerth := self.aMySelectedMovement.myBerth;
			self.aLastValidOrientation := self.aMySelectedMovement.sideTo;
			
			aMyOriginalBerth := self.aMyLastValidBerth;
	 		
	 		if self.aLastValidAftClearance=ClearanceUnbounded then
	 			self.txtAftClearTo.text:=app.getErrorString(Unlimited);
	 		else 
	 			self.txtAftClearTo.text:=aLastValidAftClearance.asStringJMT();		//#24363 18/06/2010
	 		endif;
	 		if self.aLastValidForeClearance=ClearanceUnbounded then
	 			self.txtForeClearTo.text:=app.getErrorString(Unlimited);
	 		else 
	 			self.txtForeClearTo.text:=aLastValidForeClearance.asStringJMT();	//#24363 18/06/2010
	 		endif;
	 		
	 		self.txtBowMarkTo.text := self.aLastValidBowMark.asStringJMT();		//#24363 18/06/2010
	 		self.txtSternMarkTo.text := self.aLastValidSternMark.asStringJMT();		//#24363 18/06/2010
 			self.txtBridgeMarkTo.text := self.aMySelectedMovement.getBridgeMarkTo().asStringJMT();	//#24363 18/06/2010
 			 				 		
		endif;
	endif;

	// Load Tidal Window Details
	self.calcClosestTidalWindow();

	// Load Resources ListBox
	self.loadResourceList();

	// setDefaultOrderTimes
	self.setDefaultRelOrderTimes();

   	self.txtLineCrewReqd.text := self.aMySelectedMovement.numLineCrewRequired.String;
	self.setDefaultActOrderTimes();

	// Modified by Russell 07/04/99
	// -------------------------------------------------------------
	self.setPLaunchReqdStatus();
	// -------------------------------------------------------------

	if self.aMySelectedMovement.pilotExempt then
		self.chkPilotExempt.value := true;
		self.chkPilotExempt.click(self.chkPilotExempt);
	endif;

	// Set "Shipping Line"
	if self.aMySelectedMovement.myShippingLine &lt;&gt; null then
		self.cmbShippingLine.listIndex := self.cmbShippingLine.findObject(self.aMySelectedMovement.myShippingLine);
	endif;

	// Set "Agent"
	if self.aMySelectedMovement.myShippingAgent &lt;&gt; null then
		self.cmbShippingAgent.listIndex := self.cmbShippingAgent.findObject(self.aMySelectedMovement.myShippingAgent);
	endif;

	if self.aMySelectedMovement.isAgentDefault then
		self.optAgent.value:=true;
	else
		self.optAgent.value:=false;
	endif;

	self.loadContactsList();

	self.setMoveVoyageNum(harbour);

 	self.setMoveStatus();
 	// --------------------------------------------------------------------------
 	
 	
 	// Lorcan 11330 Load the comboboxes now populated because of 11330
 	// Load Master
 	self.cmbMaster.listIndex := self.cmbMaster.findObject(self.aMySelectedMovement.myMaster);
 	self.cmbMaster.click(cmbMaster);
 	// Load Pilot
//	self.cmbPilot.listIndex := self.cmbPilot.findObject(self.aMySelectedMovement.myPilot);
	//30 Oct 2018	NDL	TFS 41662
	/*self.lstPilots.setSelected(null); // --&gt; TFS 44438
	foreach movementPilotDetails in self.aMySelectedMovement.allMovementPilotDetails do											
		if self.lstPilots.findObject(movementPilotDetails.myPilot, row) then
			self.lstPilots.setRowSelect(row, true);
		else
			self.lstPilots.accessRow(self.lstPilots.addItem(Tab &amp; self.myAssistant.displayEntryHMSPilot(movementPilotDetails.myPilot))).itemObject := movementPilotDetails.myPilot;
			self.lstPilots.setRowSelect(self.lstPilots.accessedRow.row, true);
		endif;
	endforeach;	// &lt;-- TFS 44438
	/*foreach pilot in self.aMySelectedMovement.allPilots do // --&gt; TFS 44438									
		if self.lstPilots.findObject(pilot, row) then
			self.lstPilots.setRowSelect(row, true);
		else
			self.lstPilots.accessRow( self.lstPilots.addItem( Tab &amp; self.myAssistant.displayEntryHMSPilot(pilot) ) ).itemObject := pilot;
			self.lstPilots.setRowSelect(self.lstPilots.accessedRow.row, true);
		endif;
	endforeach;*/ // &lt;-- TFS 44438
	// Load Pilot Launch
	self.cmbPilotLaunch.listIndex := self.cmbPilotLaunch.findObject(self.aMySelectedMovement.myPilotLaunch);
	// Load Line Company
	self.cmbLineCo.listIndex := self.cmbLineCo.findObject(self.aMySelectedMovement.myLineCompany);



end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadCancelledMovement" id="d9438a6f-91de-4f61-8b06-5d72e3e87a06">
        <updating/>
        <source>loadCancelledMovement() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Nov 2018	jlgndl1	Initial creation	TFS 42043
30 Oct 2024	navdap1	MTN-12358 EUP* | FR 54107 - Berth planning by bollards - part II
*/

vars

	harbour				: HMS_Harbour;
	defaultTideClass	: HMS_TidalClass;
	movementPrev		: CMIF_HMS_WorkingMovement;
	defBerthObj			: HMS_Berth;
	pilot : HMS_Pilot;
	row: Integer;
	cbxPosn				: Integer;

begin

	harbour := self.myTerminal.myHarbour;
 	if harbour = null then
 		return;
 	endif;

	self.aMyDefaultDepartBerth := harbour.defaultDepartBerth;
	
	if self.aMySelectedMovement = null then
		return;
	endif;
	
	self.lblGeneral.caption := "Cancelled Movement - View only inthis form.    Maintenance available via Voyage Maintenance";
	
	self.loadCollections();
	
 	self.txtMoveType.text		:=	self.aMySelectedMovement.moveType;
	self.txtMoveType.width := ( self.txtMoveType.width * 1.5 );
 	self.txtMoveType_1.text		:=	txtMoveType.text;
	self.lblOccursOn.caption := app.getErrorString( CM_Was_For );

	self.myTxtMoveOnDate.setDate(self.aMySelectedMovement.occursOnDT.date);
 	self.myTxtMoveOnTime.setTime(self.aMySelectedMovement.occursOnDT.Time);
	
	self.txtRemarks.text	:=  self.aMySelectedMovement.remarks;
	
 	self.txtMoveVoyageCod.text := self.aMySelectedVoyage.code;
 	self.txtMoveShipName.text := self.aMySelectedVoyage.myHMSVoyageData.vesselName;
	self.txtLOA.text := self.aMySelectedVoyage.myHMSVoyageData.dim_LengthOverall.asStringJMT();	// MTN-12358
 	self.txtMoveShipName1.text := self.txtMoveShipName.text;	 	

	self.txtDraftAft.text := self.aMySelectedMovement.draftAft.asStringJMT();	
	self.txtDraftFwd.text := self.aMySelectedMovement.draftFwd.asStringJMT();	

	chkPilotExempt.value	:=	self.aMySelectedMovement.pilotExempt;
	chkPilotExempt.click(chkPilotExempt);
	
	
	if self.aMySelectedMovement.moveType = HMSMovementTypeCanceledDepart then
 		// Cancelled Departure movement
 		defaultTideClass	:=	self.aMySelectedVoyage.myHMSVoyageData.myTidalClassDept;
 	else
  		// Cancelled Arrival or Cancelled Shift movement 
  		defaultTideClass	:=	self.aMySelectedVoyage.myHMSVoyageData.myTidalClass;
  	endif;
	if defaultTideClass &lt;&gt; null then
  		self.txtDefaultTidal.text := defaultTideClass.description;
  	else
  		self.txtDefaultTidal.text := "";
  	endif;
	
	chkChargeMove.value		:=	(not self.aMySelectedMovement.chargeForMove);
	txtLineCrewReqd.text	:=	self.aMySelectedMovement.numLineCrewRequired.asStringJMT();
	txtShipsMaster.text		:=	self.aMySelectedMovement.shipsMaster;


	movementPrev :=  self.aMySelectedVoyage.allWorkingMovements.getAtKeyLss(self.aMySelectedMovement.occursOnDT);
  	if movementPrev = null then
		defBerthObj	:=	harbour.defaultDepartBerth;
		
 		// Arrival from sea
		if defBerthObj = null then
				self.txtBerthFrom.text	:=	null;	 	
			else
				self.txtBerthFrom.text	:=	defBerthObj.description;
		endif;
 		self.txtAftClearFrom.text := app.getErrorString(NotApplicable);
 		self.txtForeClearFrom.text := app.getErrorString(NotApplicable);
 		self.txtBowMarkFrom.text := app.getErrorString(NotApplicable);
 		self.txtSternMarkFrom.text := app.getErrorString(NotApplicable);
 		self.txtOrientFrom.text := app.getErrorString(NotApplicable);
	else
		// Load berth details for previous movement
		if movementPrev.myBerth &lt;&gt; null then
			self.txtBerthFrom.text := movementPrev.myBerth.description;
		endif;

		if movementPrev.isLogicalBerth() then
			self.txtAftClearFrom.text := app.getErrorString(NotApplicable);
 			self.txtForeClearFrom.text := app.getErrorString(NotApplicable);
 			self.txtBowMarkFrom.text := app.getErrorString(NotApplicable);
 			self.txtSternMarkFrom.text := app.getErrorString(NotApplicable);
 			self.txtOrientFrom.text := app.getErrorString(NotApplicable);
 		else
			if movementPrev.aftClearanceTo = ClearanceUnbounded then
 	 			self.txtAftClearFrom.text := app.getErrorString(Unlimited);
 	 		else 
 	 			self.txtAftClearFrom.text := movementPrev.aftClearanceTo.asStringJMT();
 			endif;

 			if movementPrev.foreClearanceTo = ClearanceUnbounded then
 	 			self.txtForeClearFrom.text := app.getErrorString(Unlimited);
 	 		else 
 				self.txtForeClearFrom.text := movementPrev.foreClearanceTo.asStringJMT();
 			endif;
			self.txtBowMarkFrom.text := movementPrev.bowMarkTo.asStringJMT();		
 			self.txtSternMarkFrom.text := movementPrev.sternMarkTo.asStringJMT();
 			if movementPrev.sideTo = OrientPortSideTo then
 				self.txtOrientFrom.text := app.getErrorString(PortSideTo);
 			else
 				self.txtOrientFrom.text := app.getErrorString(StarboardSideTo);
 			endif;	
   		endif;
 	endif;

	if self.aMySelectedMovement.sideTo = OrientPortSideTo then 
		self.cmbOrientTo.listIndex := OrientPortSideTo;
		self.cmbOrientTo.text := self.cmbOrientTo.itemText[self.cmbOrientTo.listIndex];
	else
		self.cmbOrientTo.listIndex := OrientStarboardSideTo;
		self.cmbOrientTo.text := self.cmbOrientTo.itemText[self.cmbOrientTo.listIndex];
 	endif;

	if self.aMySelectedMovement.myBerth &lt;&gt; null then
		// Set default 'To Berth'
		self.myCmbBerthTo.listIndex := self.myCmbBerthTo.findObject(self.aMySelectedMovement.myBerth);	  		  				
		
		if (not self.aMySelectedMovement.isBerthVisibleOnView()) then
  		   	// Departure to sea (or other logical berth)
			
			self.cmbOrientTo.listIndex := self.cmbOrientTo.addItem(app.getErrorString(NotApplicable));
			self.cmbOrientTo.itemText[cmbOrientTo.listIndex] := app.getErrorString(NotApplicable);
		
 			self.txtAftClearTo.text := app.getErrorString(NotApplicable);
 			self.txtForeClearTo.text := app.getErrorString(NotApplicable);

 			self.txtBowMarkTo.text := app.getErrorString(NotApplicable);
 			self.txtSternMarkTo.text := app.getErrorString(NotApplicable);
 			self.txtBridgeMarkTo.text := app.getErrorString(NotApplicable); 			 			
 		else
 			
 			if self.aMySelectedMovement.bowMarkTo &lt;&gt; null then
 				self.txtBowMarkTo.text := self.aMySelectedMovement.bowMarkTo.asStringJMT();
 				self.setMeterMarksTo(self.txtBowMarkTo, false); 			
 			else
 				self.setMeterMarksTo(null, false);
 			endif;
  		  	
  		  	self.aLastValidBowMark := self.aMySelectedMovement.bowMarkTo;
	    	self.aLastValidSternMark := self.aMySelectedMovement.sternMarkTo;
	    	self.aLastValidForeClearance := self.aMySelectedMovement.foreClearanceTo;
			self.aLastValidAftClearance := self.aMySelectedMovement.aftClearanceTo;
			self.aMyLastValidBerth := self.aMySelectedMovement.myBerth;
			self.aLastValidOrientation := self.aMySelectedMovement.sideTo;
			
			aMyOriginalBerth := self.aMyLastValidBerth;
	 		
	 		if self.aLastValidAftClearance=ClearanceUnbounded then
	 			self.txtAftClearTo.text:=app.getErrorString(Unlimited);
	 		else 
	 			self.txtAftClearTo.text:=aLastValidAftClearance.asStringJMT();
	 		endif;
	 		if self.aLastValidForeClearance=ClearanceUnbounded then
	 			self.txtForeClearTo.text:=app.getErrorString(Unlimited);
	 		else 
	 			self.txtForeClearTo.text:=aLastValidForeClearance.asStringJMT();
	 		endif;
	 		
	 		self.txtBowMarkTo.text := self.aLastValidBowMark.asStringJMT();	
	 		self.txtSternMarkTo.text := self.aLastValidSternMark.asStringJMT();	
 			self.txtBridgeMarkTo.text := self.aMySelectedMovement.getBridgeMarkTo().asStringJMT();
 			 				 		
		endif;
	endif;

	// Load Tidal Window Details
	self.calcClosestTidalWindow();
	
	self.cmbMoveTidalClas.listIndex :=  self.cmbMoveTidalClas.findObject(aMySelectedMovement.myMoveTidalClass);	
	if self.cmbMoveTidalClas.listIndex = -1 and aMySelectedMovement.myMoveTidalClass &lt;&gt; null then
			cbxPosn := cmbMoveTidalClas.addItem(self.aMySelectedMovement.myMoveTidalClass.description);
			cmbMoveTidalClas.itemObject[cbxPosn] := aMySelectedMovement.myMoveTidalClass;
			self.cmbMoveTidalClas.listIndex := cbxPosn;
	endif;

	// Load Resources ListBox
	self.loadResourceList();

	// setDefaultOrderTimes
	self.setDefaultRelOrderTimes();

   	self.txtLineCrewReqd.text := self.aMySelectedMovement.numLineCrewRequired.String;
	self.setDefaultActOrderTimes();

	self.setPLaunchReqdStatus();

	if self.aMySelectedMovement.pilotExempt then
		self.chkPilotExempt.value := true;
		self.chkPilotExempt.click(self.chkPilotExempt);
	endif;

	// Set "Shipping Line"
	if self.aMySelectedMovement.myShippingLine &lt;&gt; null then
		self.cmbShippingLine.listIndex := self.cmbShippingLine.findObject(self.aMySelectedMovement.myShippingLine);
	endif;

	// Set "Agent"
	if self.aMySelectedMovement.myShippingAgent &lt;&gt; null then
		self.cmbShippingAgent.listIndex := self.cmbShippingAgent.findObject(self.aMySelectedMovement.myShippingAgent);
	endif;

	if self.aMySelectedMovement.isAgentDefault then
		self.optAgent.value:=true;
	else
		self.optAgent.value:=false;
	endif;

	self.loadContactsList();

	self.txtMoveVoyageNum.text := self.aMySelectedVoyage.code;

 	self.txtMoveStatus.text := app.getErrorString(Cancelled_At_Gate);
 	
 	// Load Master
 	self.cmbMaster.listIndex := self.cmbMaster.findObject(self.aMySelectedMovement.myMaster);
 	self.cmbMaster.click(cmbMaster);
 	// Load Pilot

	self.lstPilots.setSelected(null);
	foreach pilot in self.aMySelectedMovement.allPilots do											
		if self.lstPilots.findObject(pilot, row) then
			self.lstPilots.setRowSelect(row, true);
		else
			self.lstPilots.accessRow( self.lstPilots.addItem( Tab &amp; self.myAssistant.displayEntryHMSPilot(pilot) ) ).itemObject := pilot;
			self.lstPilots.setRowSelect(self.lstPilots.accessedRow.row, true);
		endif;
	endforeach;
	// Load Pilot Launch
	self.cmbPilotLaunch.listIndex := self.cmbPilotLaunch.findObject(self.aMySelectedMovement.myPilotLaunch);
	// Load Line Company
	self.cmbLineCo.listIndex := self.cmbLineCo.findObject(self.aMySelectedMovement.myLineCompany);
	
	self.btnTimings.enabled := false;


epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadCollections" id="8dbb81e4-951d-43ff-96c6-8a81b33c6e22">
        <updating/>
        <source>loadCollections() updating, protected;
// 03/07/2014   cnwma1		CCMS SFW1328  HMS Not Available For Entry  
// 06 Oct 2017	cnwma1  	TFS #7257 JMT - Refactoring - Commodity Planning
// 17/04/2018	jlgdap1		TFS 39685 PEL1 Pilots vs Harbours
//	17/10/2022 	navgm20 	ChangeRequest 55112: EUP - Filtered Drop-downs and Lists PAINTER
vars
	root			: CM_Root;
	cbxPosn			: Integer;
	harbour			: HMS_Harbour;
//	region			: HMS_HarbourRegion;
//	berth			: HMS_Berth;
	tug				: HMS_Tug;
//	listPointer		: Integer;
	idx				: Integer; 				// cnwma1  3/7/2014   CCMS SFW 1328
	lineCompany		: HMS_LineCompany;		// cnwma1  3/7/2014   CCMS SFW 1328
	pilot			: HMS_Pilot;			// cnwma1  3/7/2014   CCMS SFW 1328
	moveTidalClass  : HMS_TidalClass;		// cnwma1  3/7/2014   CCMS SFW 1328
	pilotLunch		: HMS_PilotLaunch;		// cnwma1  3/7/2014   CCMS SFW 1328
	
begin
 	// Set harbour and terminal references
 	harbour := self.myTerminal.myHarbour;
 	if harbour = null then
 		return;
 	endif;
	
	self.aMyDefaultDepartBerth := harbour.defaultDepartBerth;
	
	root := app.myRoot;
	// Load all comboboxes and listboxes

	// Load Default Movement Type
	txtMoveType.text	:=	HMSMovementTypeShift;
	txtMoveType_1.text	:=	HMSMovementTypeShift;
	self.myAssistant.comboBoxHMSBerth(self.myCmbBerthTo, harbour, null, true);

	//self.cmbLineCo.listCollection(root.allLineCompanies, true, 0);												// cnwma1  3/7/2014   CCMS SFW 1328
	foreach lineCompany in app.myRoot.allLineCompanies discreteLock where not lineCompany.isNotAvailableForEntry do // cnwma1  3/7/2014   CCMS SFW 1328
		//idx := cmbLineCo.ComboBox.addItem(lineCompany.description);	//17/10/2022 navgm20 TFS 55112
		idx := cmbLineCo.addItem(lineCompany.description);	//17/10/2022 navgm20 TFS 55112
		cmbLineCo.itemObject[idx] := lineCompany;
	endforeach;

	// Load "Pilot" combo box
	// Par 10455 do not default to first in list
	//self.cmbPilot.listCollection(root.allPilots, true, 0);									  					// cnwma1  3/7/2014   CCMS SFW 1328
	foreach pilot in app.myRoot.allPilots discreteLock where not pilot.isNotAvailableForEntry do  					// cnwma1  3/7/2014   CCMS SFW 1328
		if self.myTerminal.myHarbour &lt;&gt; pilot.myCurrentHarbour then			// TFS 39685
			continue;														// TFS 39685
		endif;																// TFS 39685
	//	idx := cmbPilot.ComboBox.addItem(pilot.description);
	//	cmbPilot.itemObject[idx] := pilot;
		self.lstPilots.accessRow( self.lstPilots.addItem( Tab &amp; pilot.description ) ).itemObject := pilot;//30 Oct 2018	NDL	TFS 41662
	endforeach;
	self.cmbMaster.listCollection(harbour.allMasters, true, 0);

	// Load "Pilot Launch" combo box
	// Par 10455 do not default to first in list
	//self.cmbPilotLaunch.listCollection(root.allPilotLaunches, true, 0);											// cnwma1  3/7/2014   CCMS SFW 1328
	foreach pilotLunch in app.myRoot.allPilotLaunches discreteLock where not pilotLunch.isNotAvailableForEntry do   // cnwma1  3/7/2014   CCMS SFW 1328
		if self.myTerminal.myHarbour &lt;&gt; pilotLunch.myCurrentHarbour then	// TFS 39685
			continue;														// TFS 39685
		endif;																// TFS 39685
		//idx := cmbPilotLaunch.ComboBox.addItem(pilotLunch.description);	//17/10/2022 navgm20 TFS 55112
		idx := cmbPilotLaunch.addItem(pilotLunch.description);	//17/10/2022 navgm20 TFS 55112
		cmbPilotLaunch.itemObject[idx] := pilotLunch;
	endforeach;
// cnwdad1 06/04/2006 - PAR #11490.
	// If there is only one Pilot Launch, then default to that one.
	if cmbPilotLaunch.listCount() = 1 then
//		cmbPilotLaunch.listIndex	:=	1;
	endif;

	// Load To Orientation combobox
	cmbOrientTo.addItem(app.getErrorString(StarboardSideTo));
	cmbOrientTo.addItem(app.getErrorString(PortSideTo));
	// Set default orientation;
	cmbOrientTo.listIndex:=1;
	cmbOrientTo.text:=cmbOrientTo.itemText[1];

  	// Load movement service location comboboxes
	cmbLaunchPosn.addItem(app.getErrorString(LocationAS));
	cmbLaunchPosn.addItem(app.getErrorString(On_Station));
	cmbTugPosn.addItem(app.getErrorString(LocationAS));
	cmbTugPosn.addItem(app.getErrorString(On_Station));

	// Set default movement service location;
	cmbLaunchPosn.listIndex:=1;
	cmbLaunchPosn.text:=cmbLaunchPosn.itemText[1];
	cmbTugPosn.listIndex:=1;
	cmbTugPosn.text:=cmbTugPosn.itemText[1];

	// Load "Movement Tidal Class" combo box
	if root.allTidalClasses.size&gt;0 then
		//cmbMoveTidalClas.listCollection(root.allTidalClasses,true,0);											  // cnwma1  3/7/2014   CCMS SFW 1328
		foreach moveTidalClass in app.myRoot.allTidalClasses  where not moveTidalClass.isNotAvailableForEntry do  // cnwma1  3/7/2014   CCMS SFW 1328
		//cbxPosn := cmbMoveTidalClas.ComboBox.addItem(moveTidalClass.description);	//17/10/2022 navgm20 TFS 55112
		cbxPosn := cmbMoveTidalClas.addItem(moveTidalClass.description);	//17/10/2022 navgm20 TFS 55112
		cmbMoveTidalClas.itemObject[cbxPosn] := moveTidalClass;
		endforeach;
	
		// Set "Movement Tidal Class" default to default tidal class for the ship
		//cbxPosn:=cbxMoveTidalClass.findObject(selectedVoyage.ofVessel.tidalClass);
		// Modified by Russell 29/03/99
  		// --------------------------------------------------------------------
  		if aMySelectedMovement &lt;&gt; null then
  			if aMySelectedMovement.moveType=HMSMovementTypeDeparture then
  				// Departure movement
  				cbxPosn:=cmbMoveTidalClas.findObject(aMySelectedMovement.myMoveTidalClass);
	  		else
  				// Arrival or shift movement
  				cbxPosn:=cmbMoveTidalClas.findObject(aMySelectedMovement.myMoveTidalClass);
  			endif;
  		endif;
  		// --------------------------------------------------------------------
		
		if cbxPosn&gt;0 then
			cmbMoveTidalClas.listIndex:=cbxPosn;
			cmbMoveTidalClas.text:=cmbMoveTidalClas.itemText[cbxPosn];
		elseif self.cmbMoveTidalClas.listCount &gt; 0 then
			self.cmbMoveTidalClas.listIndex:=1;
			self.cmbMoveTidalClas.text:=cmbMoveTidalClas.itemText[1];
		endif;
	endif;

    // Load "Tugs Required" listbox
    /*if harbour.allTugs.size&gt;0 then
		self.lstTugsReq.displayCollection( harbour.allTugs, true, 0, null );
    endif;*/
	foreach tug in self.myTerminal.myHarbour.allTugs where not tug.isNotAvailableForEntry   do	 		// 08/05/2008 cnwar2 #16702  // cnwma1  3/7/2014   CCMS SFW 1328
		self.lstTugsReq.accessRow(self.lstTugsReq.addItem(Tab &amp; tug.description &amp; ' (' &amp; tug.code &amp; ')')).itemObject := tug;
	endforeach;

    // Set default enabled state for agents and shippinglines
    self.cmbShippingAgent.enabled := true;
    self.optAgent.value := true;

    self.cmbShippingLine.enabled := false;
    self.optShippingLine.value := false;

    // Modified by Russell 06/04/99
    // --------------------------------------------------------------------
    // Set default voyage number to invalid
 	txtMoveVoyageNum.text:=app.getErrorString(ShipVoyageCodeInvalid);
 	// --------------------------------------------------------------------
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadContactsList" id="117f552e-6ba5-4205-9d3d-5347ed353c4b">
        <updating/>
        <source>loadContactsList() updating, protected;

vars
 	selectedAgent:			CM_ShippingAgent;
 	selectedShippingLine:	CM_ShippingLine;
begin
   	self.cmbContact.clear;
	self.btnViewContact.enabled := false;
	self.cmbContact.enabled := false;	   	
 	// Set enabled state for agents and shippinglines
    if optAgent.value=true then
    	//cbxAgents.enabled:=true;
    	self.cmbShippingAgent.enabled := true;
    	self.optAgent.value := true;
    	self.cmbShippingLine.enabled := false;
    	//cbxShippingLines.enabled:=false;
    	self.optShippingLine.value := false;
    	// Load Contact list for selectedAgent
    	/*if cbxAgents.listIndex&gt;0 then
    		selectedAgent:=cbxAgents.itemObject[cbxAgents.listIndex].CM_ShippingAgent;
    	endif;*/
    	selectedAgent := self.cmbShippingAgent.listObject.CM_ShippingAgent;

    	if selectedAgent&lt;&gt;null then
    		// See if selectedAgent has any contacts
    		if selectedAgent.allContacts.size&gt;0 then
    			// Load contacts list and default to first contact
    			cmbContact.listCollection(selectedAgent.allContacts,true,0);
    			//cbxContact.listIndex:=1;
    			//cbxContact.text:=cbxContact.itemText[cbxContact.listIndex];
    		endif;
    	endif;	
    else
    	//cbxAgents.enabled:=false;
    	self.cmbShippingAgent.enabled := false;
    	self.optAgent.value := false;
    	//cbxShippingLines.enabled:=true;
    	self.cmbShippingLine.enabled := true;
    	self.optShippingLine.value := true;
    	// Load Contact list for selectedShippingLine
    	/*if cbxShippingLines.listIndex&gt;0 then
    		selectedShippingLine:=cbxShippingLines.itemObject[cbxShippingLines.listIndex].CM_ShippingLine;
    	endif;*/
    	selectedShippingLine := self.cmbShippingLine.listObject.CM_ShippingLine;
    	if selectedShippingLine&lt;&gt;null then
    		// See if selectedShippingLine has any contacts
    		if selectedShippingLine.allContacts.size&gt;0 then
    			// Load contacts list and default to first contact
    			cmbContact.listCollection(selectedShippingLine.allContacts,true,0);
    			//cbxContact.listIndex:=1;
    			//cbxContact.text:=cbxContact.itemText[cbxContact.listIndex];
    		endif;
    	endif;
    endif;

	// Set "Contact"
	if self.aMySelectedMovement &lt;&gt; null then
		if self.aMySelectedMovement.myContact &lt;&gt; null then
			self.cmbContact.listIndex := self.cmbContact.findObject(self.aMySelectedMovement.myContact);
//			self.cbxContact.text := self.cbxContact.itemText[self.cbxContact.listIndex];
		endif;
	endif;
	// No contacts - disable 'Contact Details...' button
	if cmbContact.listCount &gt; 0 then
		self.btnViewContact.enabled := true;
		self.cmbContact.enabled := true;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="ea300acb-4674-4da6-ba34-bbc4b0f228e4">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//--------------------------------------------------
// Created:	20 December 2004 By: cnwgd1
//--------------------------------------------------
// 16 May 2019	jlgsl4	TFS 44438 - PEL1 - Multiple Pilot Launches for one movement
// 28 Feb 2020	jlgdap1	TFS 48708 PNL Adding Movement Resource Error
vars
	
begin
	inheritMethod();
	
	self.cmbShippingAgent.initialise(false);
	self.cmbShippingLine.initialise(false);
	self.aCanEdit := app.myCurrentUserCan(self.myTerminal, self.permissionMaint);
	self.aCanUpdateFull := app.myCurrentUserCan(self.myTerminal, PmHMSResUsedFull); // ### PAR 10579
	self.aCanUpdatePartial := app.myCurrentUserCan(self.myTerminal, PmHMSResUsedPartial); // ### PAR 10579
	self.aCanViewOnly := app.myCurrentUserCan(self.myTerminal, PmHMSResUsedView); // ### PAR 10579
	
	if self.aCanEdit then
		self.aCanEdit := self.aMySelectedVoyage.voyageStatus &lt;&gt; HMS_VoyageIsLocked;
	endif;
						
	if self.aMySelectedMovement = null then
		if self.aCanEdit then
	 	    self.loadAddMovement();
		endif;		
	else
		self.loadCollections();
		if self.aMySelectedMovement.isCancelled then	//20 Nov 2018	NDL	TFS 42043
			self.aCanEdit := false;
			self.loadCancelledMovement();
		
		else
			self.loadEditMovement();
			
			if self.aMySelectedMovement.myClonedVoyage.voyageStatus = HMS_VoyageIsLocked then
				self.aCanEdit := false;
			endif;
		endif;
	endif;
	self.aAllClonedControls.purge(); // TFS 44438
	self.aNewIndex := 0; // TFS 44438	
	self.displayResourceUsed();
	//self.aNewIndex := 0; // TFS 44438					// TFS 48708
	self.aNewPilotIndex := 0; // TFS 44438				// TFS 48708
	self.displayMvmntPilotDetails(); // TFS 44438
	self.setFormReadOnly();	
	self.setNavigatorHeading(self.caption);
	if self.aMode = self.Mode_Update then
		self.btnApply.visible := false;
	endif;	
	
	self.enableMovementCancelBtns();	//20 Nov 2018	NDL	TFS 42043
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadEditMovement" id="e8358fae-2444-4ba8-be0e-3b7c01d32f54">
        <updating/>
        <source>loadEditMovement() updating, protected;

/*

Date		Who		Reason
29 Mar 2008	cnwkpd1	PAR #16118 - Standardise display of from berth when no previous movement is found
					If theer is no previous movement, then display the default sea harbour region details
20 Jan 2014	cnwdap1	PAR #33337 CCMS PTR 2214 HMS Enhancements
19 Jun 2914	cnwdap1	PAR #34175 resubmit - correct calculation of fore/aft clearances
03 JUL 2014 cnwma1	CCMS SFW1328  HMS Not Available For Entry  
06 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
17 Jan 2019	jlgdap1	TFS 42987 Correct the finding of tugs in the tug list
23 Sep 2022	navsj20 ChangeRequest 54739: EUP - PLAN - Berth planning by bollards
22 Mar 2023	navdap1	TFS 56593 EUP - Show Bollard+Meters in all instances
10 Jul 2024	navcs2	Bug 64769: MSL- IMT- Unable to manage the movements in Harbor management
30 Oct 2024	navdap1	MTN-12358 EUP* | FR 54107 - Berth planning by bollards - part II
*/

vars
  	posn				: Integer;
  	cbxPosn				: Integer;
  	editMovement		: CMIF_HMS_WorkingMovement;
  	movePrev			: CMIF_HMS_WorkingMovement;
  	currWorkVoyage		: CMIF_HMS_WorkingVoyage;
  	tug					: HMS_Tug;
  	defaultTideClass	: HMS_TidalClass;  			// Modified by Russell 29/03/99
	harbour				: HMS_Harbour;	
	defBerthObj			: HMS_Berth;
	regionObj			: HMS_HarbourRegion;
	realMovePrev 		: HMS_VoyageMovement;
	seaHarbourRegion	: HMS_HarbourRegion;		// PAR #16118
	fore, aft			: Real;						// PAR #34175 resubmit
	upWharf, downWharf	: CMIF_HMS_WorkingMovement;	// PAR #34175 resubmit
	idx					: Integer;					// cnwma1  3/7/2014   CCMS SFW 1328
	row					: Integer;					// cnwma1  3/7/2014   CCMS SFW 1328
	pilot : HMS_Pilot;
	
begin
 	// Set harbour and terminal references
 	harbour	:=	self.myTerminal.myHarbour;
	
 	if harbour = null then
 		return;
 	endif;
	
	self.aMyDefaultDepartBerth := harbour.defaultDepartBerth;
	
	if self.aMySelectedMovement = null then
		return;
	endif;

	self.aHasSavedChanges := false;	
	// Clone working voyage and movement
	if self.aMySelectedVoyage &lt;&gt; null then
		if self.aMySelectedVoyage.ofClonedVoyage = null then
			// voyage is not yet cloned - do this now
			self.aMySelectedMovement.myWorkingVoyage.createClone();
			self.aMySelectedVoyage		:=	self.aMySelectedMovement.myWorkingVoyage.myClone;
			self.aMySelectedMovement	:=	self.aMySelectedMovement.myClone;
		else
			self.aMode	:=	self.Mode_Update;			
		endif;
	endif;


	// Load selectedMovement properties onto form.
	// ------------------------------------------------------------------------------------------------------- 

	if	self.aMySelectedMovement.sideTo = OrientPortSideTo then 
		cmbOrientTo.listIndex	:=	OrientPortSideTo;
		cmbOrientTo.text		:=	cmbOrientTo.itemText[cmbOrientTo.listIndex];
	else
		cmbOrientTo.listIndex	:=	OrientStarboardSideTo;
		cmbOrientTo.text		:=	cmbOrientTo.itemText[cmbOrientTo.listIndex];
 	endif;
	
 	txtMoveType.text		:=	self.aMySelectedMovement.moveType;
 	txtMoveType_1.text		:=	txtMoveType.text;
 	self.myTxtMoveOnDate.setDate(self.aMySelectedMovement.occursOnDT.date);
 	self.myTxtMoveOnTime.setTime(self.aMySelectedMovement.occursOnDT.time);
 	txtMoveVoyageCod.text	:=	self.aMySelectedMovement.myClonedVoyage.code;
 	txtMoveShipName.text	:=	self.aMySelectedMovement.myClonedVoyage.myHMSVoyageData.vesselName;
	self.txtLOA.text		:=	self.aMySelectedMovement.myClonedVoyage.myHMSVoyageData.dim_LengthOverall.asStringJMT();	// MTN-12358
 	txtMoveShipName1.text	:=	txtMoveShipName.text;
 	txtLineCrewReqd.text	:=	self.aMySelectedMovement.numLineCrewRequired.asStringJMT();
	
	self.txtRemarks.text	:=  self.aMySelectedMovement.remarks;					// PAR #33337

	txtDraftFwd.text		:=	self.aMySelectedMovement.draftFwd.asStringJMT();	//4.1.1 Draft enhancements
	txtDraftAft.text		:=	self.aMySelectedMovement.draftAft.asStringJMT();

	// Set pilot exempt state
	chkPilotExempt.value	:=	self.aMySelectedMovement.pilotExempt;
	chkPilotExempt.click(chkPilotExempt);

	chkChargeMove.value		:=	(not self.aMySelectedMovement.chargeForMove);
	txtLineCrewReqd.text	:=	self.aMySelectedMovement.numLineCrewRequired.asStringJMT();
	txtShipsMaster.text		:=	self.aMySelectedMovement.shipsMaster;

	movePrev	:=	self.aMySelectedMovement.getMovementPrevious;
	
 	if movePrev = null then
		seaHarbourRegion := app.myRoot.getSeaHarbourRegion();			// PAR #16118
		if seaHarbourRegion &lt;&gt; null then
			defBerthObj	:= seaHarbourRegion.getArrivalBerth();
		endif;
		
 		// Arrival from sea
		if defBerthObj = null then   //06.10.2017	cnwma1  TFS #7257
	 		txtBerthFrom.text	:=	null;	 	
		else
//	 		txtBerthFrom.text	:=	harbour.defaultDepartBerth.description;
//	 		txtBerthFrom.text	:=	harbour.defaultArrvBerth.description; // dh 18/3/2008 par 16203 - removed PAR #16118
			txtBerthFrom.text	:=	defBerthObj.description;	// PAR #16118
	 	endif;
		
 		txtAftClearFrom.text	:=	app.getErrorString(NotApplicable);
 		txtForeClearFrom.text	:=	app.getErrorString(NotApplicable);
 		txtBowMarkFrom.text		:=	app.getErrorString(NotApplicable);
 		txtSternMarkFrom.text	:=	app.getErrorString(NotApplicable);
 		txtOrientFrom.text		:=	app.getErrorString(NotApplicable);
	else
	
		//26 May 2014	NDL	Par 34174
		//movePrev.check_Clearances(false, false);												// PAR #34175 resubmit
		if self.aMySelectedMovement.myPersistentMovement &lt;&gt; null then							// PAR #34175 resubmit
			self.aMySelectedMovement.myPersistentMovement.calcClearancesAtMoveTime(fore, aft);	// PAR #34175 resubmit
		else																					// PAR #34175 resubmit
			self.aMySelectedMovement.calc_Clearances(upWharf, downWharf);						// PAR #34175 resubmit
		endif;																					// PAR #34175 resubmit
			
	
		// Load berth position details for the "From Berth"
		defBerthObj	:=	movePrev.myBerth;
		
		if defBerthObj &lt;&gt; null then  //06.10.2017	cnwma1  TFS #7257
			txtBerthFrom.text	:=	defBerthObj.description;
		else
			txtBerthFrom.text	:=	self.aMySelectedMovement.myBerth.description;
		endif;
		
		// Load berth details for previous movement
		// If berth.ofWharf is logical, then set marks and clearances to N/A
		if movePrev.isLogicalBerth() then
			txtAftClearFrom.text	:=	app.getErrorString(NotApplicable);
 			txtForeClearFrom.text	:=	app.getErrorString(NotApplicable);
 			txtBowMarkFrom.text		:=	app.getErrorString(NotApplicable);
 			txtSternMarkFrom.text	:=	app.getErrorString(NotApplicable);
 			txtOrientFrom.text		:=	app.getErrorString(NotApplicable);
 		else
			//if movePrev.aftClearanceTo = ClearanceUnbounded then						// PAR #34175 resubmit
			if aft = ClearanceUnbounded then											// PAR #34175 resubmit
				txtAftClearFrom.text	:=	app.getErrorString(Unlimited);
			else 
	 	 		//txtAftClearFrom.text	:=	movePrev.aftClearanceTo.asStringJMT();		// PAR #34175 resubmit
	 	 		txtAftClearFrom.text	:=	aft.asStringJMT();							// PAR #34175 resubmit
			endif;
			//if movePrev.foreClearanceTo = ClearanceUnbounded then						// PAR #34175 resubmit
			if fore = ClearanceUnbounded then											// PAR #34175 resubmit
				txtForeClearFrom.text	:=	app.getErrorString(Unlimited);
			else 
				//txtForeClearFrom.text	:=	movePrev.foreClearanceTo.asStringJMT();		// PAR #34175 resubmit
				txtForeClearFrom.text	:=	fore.asStringJMT();							// PAR #34175 resubmit
			endif;
 			txtBowMarkFrom.text		:=	movePrev.bowMarkTo.asStringJMT();
 			txtSternMarkFrom.text	:=	movePrev.sternMarkTo.asStringJMT();
			
 			if movePrev.sideTo = OrientPortSideTo then
 				txtOrientFrom.text	:=	app.getErrorString(PortSideTo);
 			else
 				txtOrientFrom.text	:=	app.getErrorString(StarboardSideTo);
 			endif;	
   		endif;
	endif;

	if (not self.aMySelectedMovement.isBerthVisibleOnView()) then			    
		//if self.mySelectedMovement.isLogicalBerth() then
	   	// Departure to sea (or other logical berth)
	   	aMyLastValidBerth		:=	self.aMySelectedMovement.myBerth;
		aMyOriginalBerth		:=	self.aMyLastValidBerth;
		//AJA 28/03/00: Make text n/a even though disabled
	   	//cbxOrientTo.clear;
	   	cmbOrientTo.listIndex	:=	cmbOrientTo.addItem(app.getErrorString(NotApplicable));
	   	cmbOrientTo.itemText[cmbOrientTo.listIndex] := app.getErrorString(NotApplicable);
	   	cmbOrientTo.enabled		:=	false;
		txtAftClearTo.text		:=	app.getErrorString(NotApplicable);
		txtForeClearTo.text		:=	app.getErrorString(NotApplicable);

		txtBowMarkTo.text		:=	app.getErrorString(NotApplicable);
		txtSternMarkTo.text		:=	app.getErrorString(NotApplicable);
		txtBridgeMarkTo.text	:=	app.getErrorString(NotApplicable); 			
	else
		if self.aMySelectedMovement.myPersistentMovement &lt;&gt; null then							// PAR #34175 resubmit
			self.aMySelectedMovement.myPersistentMovement.calcClearancesAtMoveTime(fore, aft);	// PAR #34175 resubmit
		else																					// PAR #34175 resubmit
			self.aMySelectedMovement.calc_Clearances(upWharf, downWharf);						// PAR #34175 resubmit
		endif;																					// PAR #34175 resubmit
		cmbOrientTo.enabled		:=	true;
	  	aLastValidBowMark		:=	self.aMySelectedMovement.bowMarkTo;
    	aLastValidSternMark		:=	self.aMySelectedMovement.sternMarkTo;
    	//aLastValidForeClearance	:=	self.aMySelectedMovement.foreClearanceTo;			// PAR #34175 resubmit
		//aLastValidAftClearance	:=	self.aMySelectedMovement.aftClearanceTo;			// PAR #34175 resubmit
    	aLastValidForeClearance	:=	fore;													// PAR #34175 resubmit
		aLastValidAftClearance	:=	aft;													// PAR #34175 resubmit
		aMyLastValidBerth		:=	self.aMySelectedMovement.myBerth;
		aLastValidOrientation	:=	self.aMySelectedMovement.sideTo;
		aMyOriginalBerth		:=	aMyLastValidBerth;
		
 		if self.aLastValidAftClearance = ClearanceUnbounded then
 			txtAftClearTo.text	:=	app.getErrorString(Unlimited);
 		else 
 			txtAftClearTo.text	:=	self.aLastValidAftClearance.asStringJMT();
 		endif;
		
 		if self.aLastValidForeClearance = ClearanceUnbounded then
 			txtForeClearTo.text	:=	app.getErrorString(Unlimited);
 		else 
 			txtForeClearTo.text	:=	self.aLastValidForeClearance.asStringJMT();
 		endif;
				 		
 		txtBowMarkTo.text		:=	self.aLastValidBowMark.asStringJMT();
 		txtSternMarkTo.text		:=	self.aLastValidSternMark.asStringJMT();
		txtBridgeMarkTo.text	:=	self.aMySelectedMovement.getBridgeMarkTo().asStringJMT(); 	
			
	endif;

 	// Load "Default Tidal Class" for this ship
 	// tbxDefaultTidal.text:=selectedMovement.ofClonedVoyage.ofVessel.tidalClass.className;
    // Modified by Russell 29/03/99
    // ---------------------------------------------------------------------------
	if self.aMySelectedMovement.moveType = HMSMovementTypeDeparture then
 		// Departure movement
 		defaultTideClass	:=	self.aMySelectedMovement.myClonedVoyage.myHMSVoyageData.myTidalClassDept;
 	else
  		// Arrival or shift movement 
  		defaultTideClass	:=	self.aMySelectedMovement.myClonedVoyage.myHMSVoyageData.myTidalClass;
  	endif;
	
  	if defaultTideClass &lt;&gt; null then
  		txtDefaultTidal.text	:=	defaultTideClass.description;
  	else
  		txtDefaultTidal.text	:=	"";
  	endif;
  	// --------------------------------------------------------------------

 	// Set "Movement Tidal Class" 
 	/*if self.aMySelectedMovement.myMoveTidalClass &lt;&gt; null then								// cnwma1  3/7/2014   CCMS SFW 1328
 		cbxPosn	:=	cmbMoveTidalClas.findObject(self.aMySelectedMovement.myMoveTidalClass);
		
		if cbxPosn&gt;0 then
			cmbMoveTidalClas.listIndex	:=	cbxPosn;
			cmbMoveTidalClas.text		:=	cmbMoveTidalClas.itemText[cbxPosn];
		else		
			cmbMoveTidalClas.listIndex	:=	1;
			cmbMoveTidalClas.text		:=	cmbMoveTidalClas.itemText[1];	
		endif;
	endif;
	*/
	self.cmbMoveTidalClas.listIndex :=  self.cmbMoveTidalClas.findObject(aMySelectedMovement.myMoveTidalClass);	// cnwma1  3/7/2014   CCMS SFW 1328
	if self.cmbMoveTidalClas.listIndex = -1 and aMySelectedMovement.myMoveTidalClass &lt;&gt; null then
			cbxPosn := cmbMoveTidalClas.addItem(self.aMySelectedMovement.myMoveTidalClass.description);
			cmbMoveTidalClas.itemObject[cbxPosn] := aMySelectedMovement.myMoveTidalClass;
			self.cmbMoveTidalClas.listIndex := cbxPosn;
	endif;
	
	// setDefaultOrderTimes
	self.setDefaultRelOrderTimes();

	// Load specific relative times for movement services
    if self.aMySelectedMovement.relativeOrderTimeLines&gt;-1 then
    	txtLineRelative.text	:=	"+" &amp; self.aMySelectedMovement.relativeOrderTimeLines.asStringJMT();
    else
    	txtLineRelative.text	:=	self.aMySelectedMovement.relativeOrderTimeLines.asStringJMT();
	endif;
	
	if self.aMySelectedMovement.relativeOrderTimePlaunch &gt; -1 then
		txtLaunchRel.text	:=	"+" &amp; self.aMySelectedMovement.relativeOrderTimePlaunch.asStringJMT();
	else
		txtLaunchRel.text	:=	self.aMySelectedMovement.relativeOrderTimePlaunch.asStringJMT();
	endif;
	
	if self.aMySelectedMovement.relativeOrderTimeTugs &gt; -1 then 
		txtTugRelative.text	:=	"+" &amp; self.aMySelectedMovement.relativeOrderTimeTugs.asStringJMT();
	else
		txtTugRelative.text	:=	self.aMySelectedMovement.relativeOrderTimeTugs.asStringJMT();
	endif; 

	// setDefaultOrderTimes
	self.setDefaultActOrderTimes();

	// Modified by Russell 07/04/99
	// -------------------------------------------------------------
	self.setPLaunchReqdStatus();
	// -------------------------------------------------------------

    // Set list and combobox items
    if self.aMySelectedMovement.locationPilotLaunch &gt; 0 then
    	cmbLaunchPosn.listIndex	:=	self.aMySelectedMovement.locationPilotLaunch;
		cmbLaunchPosn.text		:=	cmbLaunchPosn.itemText[cmbLaunchPosn.listIndex];
	endif;
	
	if self.aMySelectedMovement.locationTug &gt; 0 then
    	cmbTugPosn.listIndex	:=	self.aMySelectedMovement.locationTug;
		cmbTugPosn.text			:=	cmbTugPosn.itemText[cmbTugPosn.listIndex];
	endif;

	// Load Master/Pilot
//	self.cmbPilot.listIndex		:=	self.cmbPilot.findObject(self.aMySelectedMovement.myPilot);
//	if self.cmbPilot.listIndex = -1 and aMySelectedMovement.myPilot &lt;&gt; null then			// cnwma1  3/7/2014   CCMS SFW 1328
//			idx := cmbPilot.addItem(aMySelectedMovement.myPilot.description);
//			cmbPilot.itemObject[idx] := aMySelectedMovement.myPilot;
//			self.cmbPilot.listIndex := self.cmbPilot.findObject(aMySelectedMovement.myPilot);
//	endif;
	//30 Oct 2018	NDL	TFS 41662
	self.lstPilots.setSelected(null);
	foreach pilot in self.aMySelectedMovement.allPilots do											
		if self.lstPilots.findObject(pilot, row) then
			self.lstPilots.setRowSelect(row, true);
		else
			self.lstPilots.accessRow( self.lstPilots.addItem( Tab &amp; self.myAssistant.displayEntryHMSPilot(pilot) ) ).itemObject := pilot;
			self.lstPilots.setRowSelect(self.lstPilots.accessedRow.row, true);
		endif;
	endforeach;
	
	self.cmbMaster.listIndex	:=	self.cmbMaster.findObject(self.aMySelectedMovement.myMaster);
	self.cmbMaster.click(cmbMaster);


	// Load Pilot Launch
	self.cmbPilotLaunch.listIndex	:=	self.cmbPilotLaunch.findObject(self.aMySelectedMovement.myPilotLaunch);
	// 35065 Oct 2014 null test was myPilot not myPilotLaunch
	if self.cmbPilotLaunch.listIndex = -1 and aMySelectedMovement.myPilotLaunch &lt;&gt; null then		// cnwma1  3/7/2014   CCMS SFW 1328
			idx := cmbPilotLaunch.addItem(aMySelectedMovement.myPilotLaunch.description);
			cmbPilotLaunch.itemObject[idx] := aMySelectedMovement.myPilotLaunch;
			self.cmbPilotLaunch.listIndex := self.cmbPilotLaunch.findObject(aMySelectedMovement.myPilotLaunch);
	endif;
	
	// Load Line Company
	self.cmbLineCo.listIndex	:=	self.cmbLineCo.findObject(self.aMySelectedMovement.myLineCompany);
	if self.cmbLineCo.listIndex = -1 and aMySelectedMovement.myLineCompany &lt;&gt; null then		// cnwma1  3/7/2014   CCMS SFW 1328
			idx := cmbLineCo.addItem(aMySelectedMovement.myLineCompany.description);
			cmbLineCo.itemObject[idx] := aMySelectedMovement.myLineCompany;
			self.cmbLineCo.listIndex := self.cmbLineCo.findObject(aMySelectedMovement.myLineCompany);
	endif;
	

	// Load tugs used
	row := null;							// TFS 42987
	//self.lstTugsReq.setSelected(self.aMySelectedMovement.allTugsUsed);					// cnwma1  3/7/2014   CCMS SFW 1328
	foreach tug in self.aMySelectedMovement.allTugsUsed do									// cnwma1  3/7/2014   CCMS SFW 1328
		if self.lstTugsReq.findObject(tug, row) then
				self.lstTugsReq.setRowSelect(row, true);
		else
			self.lstTugsReq.addItemObject(tug.description &amp; "(" &amp; tug.code &amp; ")", tug);
			self.lstTugsReq.findObjectInRow(tug, row);
			self.lstTugsReq.setRowSelect(row, true);
		endif;
	endforeach;																				// cnwma1  3/7/2014   CCMS SFW 1328
	


	// Load "To Berth"
	if self.aMySelectedMovement.myBerth &lt;&gt; null then
		posn	:=	self.myCmbBerthTo.findObject(self.aMySelectedMovement.myBerth);
		
		if posn &gt; 0 then
			self.myCmbBerthTo.listIndex	:=	posn;
			self.myCmbBerthTo.text		:=	self.myCmbBerthTo.itemText[self.myCmbBerthTo.listIndex];
		endif;
		
		// START 23 Sep 2022	navsj20	TFS 54739
		self.cmbBowMarkBollard.clear;
		self.cmbBridgeMarkBollard.clear;
		self.cmbSternMarkBollard.clear;
		self.cmbToBerth.listObject	:=	self.aMySelectedMovement.myBerth;
		cmbToBerth_click(self.cmbToBerth);
		self.cmbBowMarkBollard.listIndex := self.cmbBowMarkBollard.findObject(self.aMySelectedMovement.myBowBollard);
		self.cmbBridgeMarkBollard.listIndex := self.cmbBridgeMarkBollard.findObject(self.aMySelectedMovement.myBridgeBollard);
		self.cmbSternMarkBollard.listIndex := self.cmbSternMarkBollard.findObject(self.aMySelectedMovement.mySternBollard);
		self.txtBowMarkMeter.text := self.aMySelectedMovement.bowToBollard.Integer.asStringJMT;			// TFS 56593		// 10/07/2024	navcs2	Bug 64769
		self.txtBridgeMarkMeter.text := self.aMySelectedMovement.bridgeToBollard.Integer.asStringJMT;	// TFS 56593		// 10/07/2024	navcs2	Bug 64769
		self.txtSternMarkMeter.text := self.aMySelectedMovement.sternToBollard.Integer.asStringJMT;		// TFS 56593		// 10/07/2024	navcs2	Bug 64769
		//23 Sep 2022	navsj20	TFS 54739
	endif;

	// -------------------------------------------------------------------------------------------------------

	// Load Tidal Window Details
	self.calcClosestTidalWindow();

	// Load Resources ListBox
	self.loadResourceList();

	// Set "Shipping Line"
	self.cmbShippingLine.listIndex := self.cmbShippingLine.findObject(self.aMySelectedMovement.myShippingLine);

	// Set "Agent"
	self.cmbShippingAgent.listIndex := self.cmbShippingAgent.findObject(self.aMySelectedMovement.myShippingAgent);	

	if self.aMySelectedMovement.isAgentDefault=true then
		optAgent.value:=true;
	else
		optAgent.value:=false;
	endif;

	self.loadContactsList();

	self.checkShipLOA();

	self.setMoveVoyageNum(harbour);

 	self.setMoveStatus();
 	// --------------------------------------------------------------------------
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadResourceList" id="bf19a5e1-01b6-407c-b584-58182bc2a608">
        <updating/>
        <source>loadResourceList() updating, protected;

vars
	resourceType:	HMS_ResourceType;
	resource:		HMS_Resource;
	harbour:		HMS_Harbour;	
begin
 	// Set harbour and terminal references
 	harbour:= self.myTerminal.myHarbour;
 	if harbour = null then
 		return;
 	endif;
 	
 	if self.shtWharfServices.visible = false then
 		return;
 	endif;

 	lstResourceList.clear;
 	lstResourceList.hasPictures:=false;

 	foreach resourceType in app.myRoot.allResourceTypes discreteLock 
 		where resourceType.isNotAvailableForEntry = false  do // CCMS1350
 		
 		lstResourceList.addItem(resourceType.description);
 		lstResourceList.itemObject[lstResourceList.newIndex]:=resourceType;
		lstResourceList.itemLevel[lstResourceList.newIndex]:=1;
		lstResourceList.itemPicture[lstResourceList.newIndex]:=resourceType.iconUpState;
		lstResourceList.itemExpanded[lstResourceList.newIndex]:=true;
		foreach resource in resourceType.allResources discreteLock 
 			where resource.isNotAvailableForEntry = false  do // CCMS1350
 			
			lstResourceList.addItem(resource.description);
 			lstResourceList.itemObject[lstResourceList.newIndex]:=resource;
			lstResourceList.itemLevel[lstResourceList.newIndex]:=2;
			lstResourceList.itemExpanded[lstResourceList.newIndex]:=false;
		endforeach;
	endforeach;

	// Select resources that have been selected for use
	setResourcesUsed;



end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="lstResourceList_click" id="f97ed558-6cc0-44df-a54d-c7ff11372e83">
        <controlMethod name="ListBox::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>lstResourceList_click(listbox: ListBox input) updating;

vars

begin
	if lstResourceList.itemObject[lstResourceList.listIndex].isKindOf(HMS_ResourceType)=true then
		// Deselect this parent item
		lstResourceList.itemSelected[lstResourceList.listIndex]:=false;
	endif;
	// Set parent used backColours
 	setResourceParent;
end;</source>
