    <JadeMethod name="comboBoxPowerRequirements" id="187e3390-4433-4d65-baf7-d4dd2a8e5e22">
        <source>comboBoxPowerRequirements(pTbl : CM_EntryTable input; pAttrName : String; pCode : String; pIncludeGen : Boolean);
// ---------------------------------------------------------------------------
// Created:     02 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theRow	: Integer;
	str		: String;
	
begin

	theRow := pTbl.getRow(pAttrName);

	str := POWER_NONE &amp; Tab &amp;
		   POWER_COU;
		   
	if pIncludeGen then
		str := str &amp; Tab &amp; POWER_GEN &amp; Tab &amp; POWER_BOTH;	
	endif;

	pTbl.setComboValues(theRow, str);
	pTbl.setValue(theRow, pCode);

end;</source>
        <Parameter name="pTbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="pAttrName" type="String"/>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pIncludeGen" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="comboBoxPrinterDefs" id="98665f14-5569-4c2a-85b9-ad558020447f">
        <source>comboBoxPrinterDefs(_cmb : CMUI_ComboBox input; _canAdd :Boolean; _val : String);
// ---------------------------------------------------------------------------
// Created:     02 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/07/2009	cnwcs5		ccms 1061 - Added _canAdd parameter
// ---------------------------------------------------------------------------
vars
	idx		: Integer;
	lstIdx	: Integer;
	//str		: String;
	printer	: CM_PrinterDef;	
begin

	_cmb.clear;
	_cmb.addItem("");
	
	if _canAdd then
		_cmb.addItem(app.getErrorString(NewPrinter));
	endif;
	
	foreach printer in app.myRoot.allPrinterDefsByLogicalName do
		idx := _cmb.addItemObject(printer.description, printer);
		if printer.description = _val then
			lstIdx := idx;
		endif;
	endforeach;
	
	if lstIdx &lt;&gt; 0 then
		_cmb.listIndex := lstIdx;
	endif;
	
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_canAdd" type="Boolean"/>
        <Parameter name="_val" type="String"/>
    </JadeMethod>
    <JadeMethod name="comboBoxPrintersLocal" id="93da790d-71f3-476a-aa7d-6730530a6e18">
        <source>comboBoxPrintersLocal(_combo : CMUI_ComboBox input; _defaultPrinterName : String);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 June 2013	cnwndl1	Initial creation	Par 31842

*/

vars

	printerArray : CnStringArray;		// 32305 Aug 2013 was StringArray, to allow for long printer names
	printerName : String;
	existingPrinter : String;
	selectedPrinterName : String;

begin

	_combo.clear;
	
	// find all available printers
	create printerArray transient;
	app.printer.getAllPrinters(printerArray);
	
	// find what the existing value is set to
	existingPrinter := app.printer.getPrinterName();
	if _defaultPrinterName = null or not printerArray.includes(_defaultPrinterName) then
		//no default supplied or  value passed in not found.
		//Set the printer to null to get the default windows printer name
		printerName := null;
		app.printer.setPrinter(printerName);
		selectedPrinterName := app.printer.getPrinterName();
		//now reset it to what it was
		app.printer.setPrinter(existingPrinter);
	else
		//passed in value was OK use that
		selectedPrinterName := _defaultPrinterName;
	endif;
	
	// populate teh combo
	foreach printerName in printerArray do
		_combo.addItem(printerName);
	endforeach;
	
	//prefill with the selected one.
	if selectedPrinterName &lt;&gt; null and _combo.listCount &gt; 0 then
		_combo.listIndex := _combo.findStringExact( 1, selectedPrinterName );
	endif;

epilog

	delete printerArray;

end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_defaultPrinterName" type="String"/>
    </JadeMethod>
    <JadeMethod name="comboBoxProcessOption" id="f81a6d7f-e6ca-4bd5-9f4f-1eb952eface7">
        <source>comboBoxProcessOption(_cmb : CMUI_ComboBox input; _processOption : Integer);
// ---------------------------------------------------------------------------
// Created:     01 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	_cmb.clear();
	_cmb.sorted := false;
	
	_cmb.itemData[_cmb.addItem(Process_Direct_Loadout_str)] := Process_Direct_Loadout;
	_cmb.itemData[_cmb.addItem(Process_Pack_str)] := Process_Pack;
	
	_cmb.text := app.processOptionEnumToString(_processOption);
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_processOption" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="comboBoxProdAttributeCodes" id="5b428018-b718-4641-a4f0-c6aadf0db231">
        <source>comboBoxProdAttributeCodes(_cmb : CMUI_ComboBox input; 
						_prodAttr : CM_ProductAttr;
						_code : String);
// ---------------------------------------------------------------------------
// Created:     13 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	code			: CM_ProductAttributeCode;
	found			: Boolean;
begin
	_cmb.clear();
	if _cmb = null or
	   _prodAttr = null then
		return;
	endif;

	foreach code in _prodAttr.allCodes do
		_cmb.itemObject[_cmb.addItem(code.code)] := code;
		if _code = code.code then
			found := true;
		endif;
	endforeach;
	
	if found then
		_cmb.text := _code;
	endif;
	
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_prodAttr" type="CM_ProductAttr"/>
        <Parameter name="_code" type="String"/>
    </JadeMethod>
    <JadeMethod name="comboBoxProduct" id="a39179ec-454b-4430-9ce0-3adcf0fa9dc4">
        <source>comboBoxProduct(_cmb : CMUI_ComboBox input; 
				_cargoType : CM_CargoType; 
				_opRestrict : CM_Operator;
				_product : CM_Product);
// ---------------------------------------------------------------------------
// Created:     06 April 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	pro				: CM_Product;
	found			: Boolean;
begin
	_cmb.clear();
	
	if _cargoType = null then
		return;
	endif;	

	foreach pro in _cargoType.allProducts do
		//epr TFS 1846 18/4/16
		if pro.isNotActive then
			continue;
		endif;
		
		if (_opRestrict &lt;&gt; null) and 
		   (_opRestrict &lt;&gt; pro.myOperator) then
			continue;
		endif;
	
		if pro = _product then
			found := true;
		endif;
		
		_cmb.itemObject[_cmb.addItem(pro.code &amp; '  ' &amp; pro.description)] := pro;

	endforeach;	
	
	if found then
		_cmb.listObject := _product;
	endif;
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_opRestrict" type="CM_Operator"/>
        <Parameter name="_product" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="comboBoxProductType" id="6d50c4d9-db39-4b7c-a257-af4fb68c88ca">
        <source>comboBoxProductType(_cmb : CMUI_ComboBox input );
/*
Purpose:			

Return Value:		

Date		Who		Reason
03/04/2007	cnwer1	Initial creation - PAR#xxxx
*/
vars

begin
	_cmb.clear;
	_cmb.addItemWithData(ProductType_PieceBreakBulkStr,ProductType_PieceBreakBulk );
	_cmb.addItemWithData(ProductType_BreakBulkStr,ProductType_BreakBulk );
	_cmb.addItemWithData(ProductType_BulkStr,ProductType_Bulk);
	_cmb.addItemWithData(ProductType_TrailerStr,ProductType_Trailer);
	_cmb.addItemWithData(ProductType_VehicleStr,ProductType_Vehicle);	//New cargo Type. CCMS 1080 (PAR19704). July 2009
	
	if app.isCargoGroupEnabled then	//27 May 2015	NDL	Par 36338
		_cmb.addItemWithData(ProductType_CargoGroupStr,ProductType_CargoGroup);
	endif;
	
epilog

end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="comboBoxProductTypeSystemNames" id="b8c87df5-f361-4427-a10e-1eeb8874362b">
        <source>comboBoxProductTypeSystemNames(_cmb : ComboBox input; _cargoType : CM_CargoType; _productType : CM_Product; _currentProdAttr : CM_ProductAttr);
/* ---------------------------------------------------------------------------
Created:	27 May 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	entRowName	: String;
	allAttribNamesForProdType : StringArray;
	prodAttr	: CM_ProductAttr;
	idx, currentIdx	: Integer;
	
begin

	create allAttribNamesForProdType transient;

	self.getAllAttribNamesForProductTyp(_cargoType, allAttribNamesForProdType);

	_cmb.clear;
	idx := 0;
	foreach entRowName in allAttribNamesForProdType do
		idx := idx + 1;
		prodAttr := _productType.getProdAttrFromName(entRowName);
		_cmb.addItem(prodAttr.getDisplayStringForAttribute(ETRow_SystemName, true));
		if prodAttr = _currentProdAttr then
			currentIdx := idx;
		endif;
	endforeach;
	
	//setting current item
	if not allAttribNamesForProdType.isEmpty() then
		if currentIdx &gt; 0 then
			_cmb.listIndex := currentIdx;
		else
			_cmb.listIndex := 1;
		endif;
	endif;
	
epilog
	delete allAttribNamesForProdType;

end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_productType" type="CM_Product"/>
        <Parameter name="_currentProdAttr" type="CM_ProductAttr"/>
    </JadeMethod>
