    <JadeMethod name="doMnuRestrictionsClick" id="76f55d54-f9ce-48f4-ac10-46cdfba6f487">
        <updating/>
        <source>doMnuRestrictionsClick(theMenuItem : MenuItem) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theTerminalArea : CM_TerminalArea;
	aForm 	: Form;
	menuAction 		: CMUI_MenuAction;
begin
	if theMenuItem.userObject &lt;&gt; null then
		if theMenuItem.userObject.isKindOf(CM_TerminalArea) then
			theTerminalArea := theMenuItem.userObject.CM_TerminalArea;

			menuAction := app.myController.createMenuAction(PmAdmPadeditView, null, self.myMasterMenuAction, self.myTerminal);
			if menuAction = null then
				return;
			endif;
			
			aForm := menuAction.goToObject(null, null, false, null); 
			if aForm = null then
				return;
			endif;
			
			aForm.sendMsgWithParams(CMUI_DeckingOptions::setInitializeWithObject.name,theTerminalArea,1,null,false,false);
			aForm.show;	
		endif;
	endif;

end;</source>
        <Parameter name="theMenuItem" type="MenuItem"/>
    </JadeMethod>
