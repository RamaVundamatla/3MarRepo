    <JadeMethod name="handleWeightICException" id="dda492d3-ac80-4154-b6cb-a9e1db3bfd5a">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_TCPWeightCallerInterface::handleWeightICException"/>
        </interfaceImplements>
        <source>handleWeightICException(_exceptionCode : Integer; _exceptionData : String);

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements for the IF_TCPWeightCallerInterface interface 
	*/
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 June 2019	jlger1	Initial creation

*/

vars

	extra : String;

begin

	extra := CrLf &amp; app.getErrorString( Please_again_enter_value_manua );
	
	app.msgBox(_exceptionData,app.getErrorString(Warning),MsgBox_OK_Only);
	
	/*if global.cnwer1 then
	executeWhen JMTDevelopmentEnvironment;
		if self.myWeighBridge &lt;&gt; null and self.myWeighBridge.isTwoReadings then
			if self.myTrackedItem = null or not self.myTrackedItem.isOnTruck then
				self.IF_TCPWeightCallerInterface.sendWeight(22400 -6500);
			else
				self.IF_TCPWeightCallerInterface.sendWeight(22400 );
			endif;
			
		else
			self.IF_TCPWeightCallerInterface.sendWeight(0);
			return;
		endif;
	endExecuteWhen; 
	endif;*/
	
	self.allowManualScaleEntry( true, _exceptionData   );
	self.tblScaleWeight.setFocus();
epilog

end;</source>
        <Parameter name="_exceptionCode" type="Integer"/>
