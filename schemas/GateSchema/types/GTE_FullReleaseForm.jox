    <JadeMethod name="doBtnDeletePin" id="d00fa909-ef59-4ab5-bde4-930007d1fa90">
        <updating/>
        <source>doBtnDeletePin() updating, protected;
/* ---------------------------------------------------------------------------
Created:	05 February 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	obj				: Object;
	tiSet 			: CM_TISet;
	user			: CM_User;
	tmpEmailDef,
	termEmailDef	: CM_PINObjectDefaultEmail;
	ti				: CM_TrackedItem;
	updateEmail		: Integer;
	canUpdate		: Boolean;
	carrier			: CM_Carrier;
	
begin
	if (not self.allowGeneratePin) then
		app.msgBox(app.getErrorString1(NoPermission, 'delete a PIN'), 'Error', MsgBox_OK_Only);
		return;
	endif;

	create tiSet transient;
	foreach obj in self.tblData.allSelectedObjects do
		if CM_TrackedItem.hasInstance(obj) then
			tiSet.add(obj.CM_TrackedItem);
		endif;
	endforeach;
	
	user := app.myPassport.myUser;
//	termEmailDef := self.myTerminal.getCarrierEmailDefaultsForType(PINEmail_CargoRelease);	// cnwrl1 30/07/2009 PAR 20349 - what it was
	termEmailDef := self.myTerminal.getEmailDefaultsSettings( PINEmail_CargoRelease );
	
	if user &lt;&gt; null
	and tiSet.size = 1
	and termEmailDef.enabled then
		ti := tiSet.first;
		canUpdate := user.canDo(self.myTerminal, PmAdmPINEmailDefUpdate) or user.canDo(self.myTerminal, PmAdmPINEmailDefMaint);
		if canUpdate
		and ti.myPinNo &lt;&gt; null then
			updateEmail := app.msgBox(app.getErrorString(Info_updateCarrierEmail), app.getErrorString(Info_PinEmail), MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		endif;
	elseif (not app.msgBox(app.getErrorString(Ques_deletePinForSelectedItems), app.getErrorString(Info_DeletePin), MsgBox_Yes_No+MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes) then
		return;
	
	endif;

	if (not tiSet.isEmpty) then
		if updateEmail = MsgBox_Return_Yes then	//can and wants to update the email
			tmpEmailDef := termEmailDef.cloneSelf(true);
			
			carrier 	:= tiSet.first.getCarrierRelease();
			
//			if carrier = null and self.myTerminal.getConfig(DefaultCarrierEmail).Boolean then	// cnwrl1 30/07/2009 PAR 20349 - what it was
			if carrier = null and termEmailDef.sendToCarrier then
				app.msgBox(app.getErrorString(Info_NeedToSetCarrieEmail), app.getErrorString(Info_EmailOptions),null);
				return;
			endif;
	
//			tmpEmailDef.setAddresses(self.myTerminal, carrier, null);	// cnwrl1 30/07/2009 PAR 20349 - what it was
			tmpEmailDef.setAddresses( self.myTerminal, carrier, null, PINEmail_CargoRelease );
			
			modalResult := self.myAssistant.showCarrierEmailOptions(carrier, tmpEmailDef, true, null);
	 		
	 		if modalResult &lt;&gt; IDOK then
	 			//take the cancel as a sign to bail out
	 			app.msgBox(app.getErrorString(Info_PinNotGenerated), app.getErrorString(Info_EmailOptions), MsgBox_OK_Only + MsgBox_Information_Icon);
				return;
			endif;
		endif;
		app.mousePointer := MousePointer_HourGlass;

		//DELETE THE PIN
		self.doDeletePin(tiSet, tmpEmailDef);
	endif;

epilog
	if tmpEmailDef &lt;&gt; null then
		delete tmpEmailDef.myEmailController;
		delete tmpEmailDef;
	endif;
	delete tiSet;
	app.mousePointer := MousePointer_Default;	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnGeneratePin" id="c8e38b7a-8d0b-4f43-9925-440716fd0d2b">
        <updating/>
        <source>doBtnGeneratePin()updating;
//--------------------------------------------------
// Created:	04 December 2003 By: cnwgd1
//--------------------------------------------------
// Date			Who		Reason
// 01 Oct 2008	consw1	Par 17090 Replace app.getMyTerminal with self.myTerminal
vars
	obj				: Object;
	tiSet 			: CM_TISet;
	updateEmail		: Integer;
	canUpdate		: Boolean;
	user			: CM_User;
	tmpEmailDef,
	termEmailDef	: CM_PINObjectDefaultEmail;
	carrier			: CM_Carrier;
	ti				: CM_TrackedItem;
	
begin
	if (not self.allowGeneratePin) then
		return;
	endif;
	create tiSet transient;
	foreach obj in self.tblData.allSelectedObjects do
		if CM_TrackedItem.hasInstance(obj) then
			tiSet.add(obj.CM_TrackedItem);
		endif;
	endforeach;
	
	user := app.myPassport.myUser;
//	termEmailDef := self.myTerminal.getCarrierEmailDefaultsForType(PINEmail_CargoRelease);	// cnwrl1 30/07/2009 PAR 20349 - what it was
	termEmailDef := self.myTerminal.getEmailDefaultsSettings( PINEmail_CargoRelease );
	
	if user &lt;&gt; null
	and tiSet.size = 1
	and termEmailDef.enabled then
		ti := tiSet.first;
		canUpdate := user.canDo(self.myTerminal, PmAdmPINEmailDefUpdate) or user.canDo(self.myTerminal, PmAdmPINEmailDefMaint);
		if canUpdate
		and ti.isValidForPINGeneration then
			updateEmail := app.msgBox(app.getErrorString(Info_updateCarrierEmail), app.getErrorString(Info_PinEmail), MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		endif;
	endif;
	
	if (not tiSet.isEmpty) then
		if updateEmail = MsgBox_Return_Yes then	//can and wants to update the email
			tmpEmailDef := termEmailDef.cloneSelf(true);
			carrier := tiSet.first.getCarrierRelease();
			
//			if carrier = null and self.myTerminal.getConfig(DefaultCarrierEmail).Boolean then	// cnwrl1 30/07/2009 PAR 20349 - what it was
			if carrier = null and termEmailDef.sendToCarrier then
				app.msgBox(app.getErrorString(Info_NeedToSetCarrieEmail), app.getErrorString(Info_EmailOptions), null);
				return;
			endif;
			
//			tmpEmailDef.setAddresses(self.myTerminal,carrier, null);	// cnwrl1 30/07/2009 PAR 20349 - what it was
			tmpEmailDef.setAddresses( self.myTerminal,carrier, null, PINEmail_CargoRelease );
			
			modalResult := self.myAssistant.showCarrierEmailOptions(carrier, tmpEmailDef, true, null);
	 		
	 		if modalResult &lt;&gt; IDOK then
	 			//take the cancel as a sign to bail out
	 			app.msgBox(app.getErrorString(Info_PinNotGenerated),app.getErrorString(Info_EmailOptions),MsgBox_OK_Only + MsgBox_Information_Icon);
				return;
			endif;
		endif;
		app.mousePointer := MousePointer_HourGlass;
	
		//GENERATE THE PIN
		self.doGeneratePin(tiSet, tmpEmailDef);
	endif;
	
epilog
	if tmpEmailDef &lt;&gt; null then
		delete tmpEmailDef.myEmailController;
		delete tmpEmailDef;
	endif;
	delete tiSet;
	app.mousePointer := MousePointer_Default;	
end;</source>
    </JadeMethod>
    <JadeMethod name="doCancel" id="4d9e4cfb-db36-49e5-8e7b-6acf68cdb9e7">
        <updating/>
        <source>doCancel(): Boolean updating;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 24 September 2003
//
//-----------------------------------------------------------------------

vars

begin
	//PAR 5846 23092003 CNWSH3
	//Added to include changeMode on CM_Entry tables which is set in init methods (ie. initExtraTable)
	//Has been set to ChangeMode_FirstOnly
	if (self.tblExtra.hasChanged) or
		(self.tblMain.hasChanged) then
		self.confirmCancel(app.getErrorString(The_Current_Item));
	endif;
	
	return inheritMethod();

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDeletePin" id="771f3b3c-7116-4921-b957-a2f1bc30b54e">
        <updating/>
        <source>doDeletePin( _tiSet : CM_TISet; _carrierEmail: CM_PINObjectDefaultEmail ) updating, protected;
/* ---------------------------------------------------------------------------
Created:	03 February 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	result : Integer;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
begin

	if (not self.allowGeneratePin) then
		// User can't have permisiont generate pin
		app.msgBox(app.getErrorString1(NoPermission, 'generate a PIN'), 'Error', MsgBox_OK_Only);
		return;
	endif;
	
	self.generatingPIN := true; // not to generate Object_Update_Event in the sysNotify for bulk PIN deletion

	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateRemovePinReleaseImp(_tiSet, _carrierEmail, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Import Release', app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;

epilog
	self.generatingPIN := false;
	
end;</source>
        <access>protected</access>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <Parameter name="_carrierEmail" type="CM_PINObjectDefaultEmail"/>
    </JadeMethod>
    <JadeMethod name="doGeneratePin" id="72b7c55b-d8dd-44cc-bdc0-2ae081f23ffc">
        <updating/>
        <source>doGeneratePin(_tiSet : CM_TISet; _carrierEmail: CM_PINObjectDefaultEmail)updating;
//--------------------------------------------------
// Created:	04 December 2003 By: cnwgd1
//--------------------------------------------------
vars
	result : Integer;
begin
	if (not self.allowGeneratePin) then
		// User can't have permisiont generate pin
		app.msgBox(app.getErrorString1(NoPermission, 'generate a PIN'), 'Error', MsgBox_OK_Only);
		return;
	endif;

	while true do
		app.myTrxUA.trxUpdateGeneratePin(_tiSet, _carrierEmail, app.myPassport);
		if (not app.myPassport.trxCompletedOK) then
			result := app.showErrorWarningDialog('Full Release Generate Pin', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
				result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
		else
			self.clearErrorWarnings();
			break;
		endif;
		break;
	endwhile;	
epilog
	self.generatingPIN := false;
end;</source>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <Parameter name="_carrierEmail" type="CM_PINObjectDefaultEmail"/>
    </JadeMethod>
