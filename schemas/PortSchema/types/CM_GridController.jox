    <JadeMethod name="isSideAccessRestricted" id="859cac8b-5caf-4b06-97cf-27661672c255">
        <source>isSideAccessRestricted(	_sideAccess : Integer;
						_currentQueueEntry : CM_RTQueueEntry) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 Dec 2009	cnwer1	Initial creation
11 Feb 2022 jlier1	TFS 52822
*/

vars
	currentCol : Integer;
	currentGridCol	: CM_GridColumn;
	iter,tiIter 		: Iterator;
	gridController : CM_GridController;
	canAccessFront,
	canAccessBack : Boolean;
	checkQueuedOut,
	isQueuedOut: Boolean;
	queue :	CM_RadioTelemetryQueue;
	currentQueueIndex : Integer;
	ti : CM_TrackedItem;
	usuage : Integer;
begin
	if _currentQueueEntry &lt;&gt; null then
		checkQueuedOut:= true;
		queue:=_currentQueueEntry.myQueue;
		currentQueueIndex:=queue.allEntries.indexOf(_currentQueueEntry);
	endif;
	canAccessFront:=true;
	canAccessBack:=true;
	currentCol:=self.column;
	
	currentGridCol:=self.myGridArea.allGridColumns[self.column];
	iter:=currentGridCol.allControllersByRow.createIterator;
	currentGridCol.allControllersByRow.startKeyGeq(self.row,iter);
	if _sideAccess = CM_YABlock.SideAccess_Front or 
		_sideAccess = CM_YABlock.SideAccess_Both then
		while iter.next(gridController) do
			if gridController = self then
				continue;
			endif;
			usuage:=gridController.getUsage();
			if  usuage = LIGHT_TOWER_USE or usuage = BUILDING_USE then
				canAccessFront:= false;
				break;
			endif;
			if gridController.numTIs  &gt; 0 then
				if checkQueuedOut then
					delete tiIter;
					tiIter:=gridController.allTrackedItems.createIterator;
					while tiIter.next(ti) do
						isQueuedOut:=false;
						//have to iter through all tis
						isQueuedOut:= ti.allQueuedFutureMoves.hasQueuedEntriesBeforeIndex(queue,currentQueueIndex);
						if not 	isQueuedOut then
							break;
						endif;
					endwhile;
					if not 	isQueuedOut then
						canAccessFront:= false;
						break;
					endif;
						
				else	
					canAccessFront:= false;
					break;
				endif;
			endif;
		endwhile;
	endif;
	
	if _sideAccess = CM_YABlock.SideAccess_Back or 
		_sideAccess = CM_YABlock.SideAccess_Both then 
		while iter.back(gridController) do
			if gridController = self then
				continue;
			endif;
			usuage:=gridController.getUsage();
			if  usuage = LIGHT_TOWER_USE or usuage = BUILDING_USE then
				canAccessBack:= false;
				break;
			endif;
		
			if gridController.numTIs  &gt; 0  then
				if checkQueuedOut then
					delete tiIter;
					tiIter:=gridController.allTrackedItems.createIterator;
					while tiIter.next(ti) do
						isQueuedOut:=false;
						//have to iter through all tis
						isQueuedOut:= ti.allQueuedFutureMoves.hasQueuedEntriesBeforeIndex(queue,currentQueueIndex);
						if not 	isQueuedOut then
							break;
						endif;
						
					endwhile;
					if not 	isQueuedOut then
						canAccessBack:= false;
						break;
					endif;
				else		
					canAccessBack:= false;
					break;
				endif;
			endif;
	
		endwhile;
	endif;
	
	//write self.getFullId; 
	//write yaBlock.getDisplayDetails(false);
	if _sideAccess = CM_YABlock.SideAccess_Front then
	//	write sideAccess.String &amp; " " &amp; canAccessFront.String;
		return not canAccessFront;
	elseif _sideAccess = CM_YABlock.SideAccess_Back then
	//	write sideAccess.String &amp; " " &amp; canAccessBack.String;
		return not canAccessBack;
	elseif _sideAccess = CM_YABlock.SideAccess_Both then
		//write sideAccess.String &amp; " " &amp; (canAccessFront or canAccessBack).String;
		return not (canAccessFront or canAccessBack);
	endif;
	
	return false;
epilog
	delete iter;
	delete tiIter;

end;</source>
        <Parameter name="_sideAccess" type="Integer"/>
        <Parameter name="_currentQueueEntry" type="CM_RTQueueEntry"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isStackFull" id="ba53253a-33f0-4b13-9bea-9fe43355e6e8">
        <source>isStackFull(obj : CMIF_AutoMovePlan input);
//Test to see if this area can accept the container passed in.
//14 Aug 2013  cnwer1  par 31492

vars
	maxHeight : Integer;
	nextLC : CM_GridController;
	heightOfThisTI	:	Integer;
	totalInThisStack	:	Integer;
	totalInNextStack	:	Integer;
	totalPlanInThisStack	:	Integer;
	totalPlanInNextStack	:	Integer;
	totalQueueInThisStack	:	Integer;
	totalQueueInNextStack	:	Integer;
	iterStr	:	String;
	locnId	:	String;
	nextId	:	String;
	numControllers : Real;
	tempTI, 
	oTI,
	theCurrentTI: CM_TrackedItem;
	currentMaxHeightForPad : Integer;	//24 Sep 2020	NDL	TFS 49984
	reason : String;	//24 Sep 2020	NDL	TFS 49984
	griddedStackHeight : CM_GriddedTAStackHeight;	//24 Sep 2020	NDL	TFS 49984
	firstTi: CM_TrackedItem;	//24 Sep 2020	NDL	TFS 49984
begin
	obj.updateController(null);
	iterStr := obj.iteration.String;
	
	theCurrentTI:=obj.myTrackedItem;
	maxHeight := self.getMaxStackingHeight() * 2;

	theCurrentTI:=obj.myTrackedItem;
	heightOfThisTI := theCurrentTI.getHeightOfTI;	
	
	// PAR 17793
	foreach oTI in  obj.allOtherTrackedItems  discreteLock do
		heightOfThisTI := heightOfThisTI + oTI.getHeightOfTI();	
	endforeach;
	
	//----------------
	//Test for full in REAL mode FIRST.
	//----------------
	totalInThisStack := self.getStackHeightOfTIs(REAL_MODE, theCurrentTI);
	locnId := self.getFullId;
	if totalInThisStack + heightOfThisTI &gt; maxHeight then
		//Its already full, or us going into it will bust it
		
		obj.addVerboseLogEntry(app.getErrorString1(Move_WillBeOverCap, locnId &amp; iterStr), obj.getLogType, Move_WillBeOverCap);
		if obj.isAutoPlanMove then
			return;	
		endif;
	endif;

	nextLC := self.getMyNextController(self.class);
	
	numControllers := self.calculateMoveLCs(theCurrentTI);
	//-----------------
	//If the TI needs more than 1 controller, then check next location.
	//-----------------
	if not obj.isShiftMove // PAR 18682
	and numControllers &gt; 1 and not obj.checkingSecondary then // AKB2002JULY added checkingSecondary
		if self.myNextController = null then // AKBJULY2002 removed not
			//epr par 31492 14/8/13
			obj.addVerboseLogEntry(app.getErrorString(Next_positi_contai_longer_than), IsError, Next_positi_contai_longer_than);// PAR 17386 
			return;	//No next position. 40' cannot go here.
		endif;
		if self.myNextController.isSuitableForTI(obj) = false then
			//epr par 31492 14/8/13 give error or warning depending on move mode
			if self.myNextController.isKindOf(CM_GapController) then              //  14/09/2015 cnwma1 PAR #36437
				obj.addVerboseLogEntry(app.getErrorString1(Suitab_contai_longer_than_foot,self.getFullId),IsError, Suitab_contai_longer_than_foot);  //  14/09/2015 cnwma1 PAR #36437
			else
				obj.addVerboseLogEntry(app.getErrorString1(Suitab_contai_longer_than_foot,self.getFullId), obj.getLogType, Suitab_contai_longer_than_foot);  // PAR 5723 PAR 17386 
			endif;
			return;
		endif;
		nextId := myNextController.getFullId;
		totalInNextStack := self.myNextController.getStackHeightOfTIs(REAL_MODE, theCurrentTI);

		if totalInNextStack &lt;&gt; totalInThisStack then
			//stacks are not at same height, 40' cannot go here!	
			obj.addVerboseLogEntry(app.getErrorString2(Move_StackHeight40, nextId &amp; iterStr, self.getFullId), obj.getLogType, Move_StackHeight40);
			if obj.isAutoPlanMove then
				return;	
			endif;
		endif;
		if totalInNextStack + heightOfThisTI &gt; maxHeight then
			obj.addVerboseLogEntry(app.getErrorString1(Move_WillBeOverCap, nextId &amp; iterStr), obj.getLogType, Move_WillBeOverCap);
			if obj.isAutoPlanMove then
				return;	
			endif;
		endif;
 	endif;
 	
	if totalInThisStack	&gt; 0 then
		if self.allTrackedItems.last.isOverStowable(theCurrentTI,null,null) = false then //10 May 2010	NDL Par 24064
			obj.addVerboseLogEntry(app.getErrorString1(Conta_diffe_lengt_there_canno_, locnId), obj.getLogType, Conta_diffe_lengt_there_canno_);
			if obj.isAutoPlanMove then
				return;	
			endif;
		endif;
		if theCurrentTI.isAttributeTrue(TI_Attrib_IsForty) then
			if self.testMyNextController(self.class) then
				tempTI := self.myNextController.allTrackedItems.first;
				if tempTI &lt;&gt; null and tempTI.isOverStowable(theCurrentTI,null,null) = false then//10 May 2010	NDL Par 24064
					obj.addVerboseLogEntry(app.getErrorString1(Conta_diffe_lengt_there_canno_, self.myNextController.getFullId), obj.getLogType, Conta_diffe_lengt_there_canno_);
					if obj.isAutoPlanMove then
						return;	
					endif;
				endif;
			endif;
		endif;
	endif;
	
	if obj.moveMode = REAL_MODE then
		//Return now if we are in real mode.
		obj.updateController(self);
		return;
	endif;
	//--------------------
	//OK, we've validate that there IS space here in this stack in REAL mode. We now have to
	//check the other modes as well
	//--------------------
	totalPlanInThisStack	:= self.getStackHeightOfTIs(PLANNING_MODE, null);
	totalQueueInThisStack	:= self.getStackHeightOfTIs(QUEUE_MODE, theCurrentTI);

	if totalPlanInThisStack	&gt; 0 then
		tempTI := self.getTIAtIndex(PLANNING_MODE, self.allPlannedFutureMoves.size);
	//	if tempTI.isOverStowable(theCurrentTI,null,null) = false then//10 May 2010	NDL Par 24064
		if tempTI &lt;&gt; null and tempTI.isOverStowable(theCurrentTI,null,null) = false then	//10 Nov 2017	NDL	TFS 7635
			obj.addVerboseLogEntry(app.getErrorString1(Conta_diffe_lengt_plann_there_, locnId), IsError, Conta_diffe_lengt_plann_there_);
			return;
		endif;
	endif;
	
	if totalQueueInThisStack &gt; 0 then
		tempTI := self.getTIAtIndex(QUEUE_MODE, self.allQueuedFutureMoves.size);
	//	if tempTI.isOverStowable(theCurrentTI,null,null) = false then//10 May 2010	NDL Par 24064
		if tempTI &lt;&gt; null and tempTI.isOverStowable(theCurrentTI,null,null) = false then	//10 Nov 2017	NDL	TFS 7635
			obj.addVerboseLogEntry(app.getErrorString1(Conta_diffe_lengt_queue_there_, locnId), IsError, Conta_diffe_lengt_queue_there_);
			return;
		endif;
	endif;

	if numControllers &gt; 1 then
		//epr par 15880 16/7/08 - 40 foot container was planned (drag dropped) to a gap 
		if nextLC = null then
			return; //should be handled in code somewhere in subclass
		endif;
		totalPlanInNextStack	:= nextLC.getStackHeightOfTIs(PLANNING_MODE, theCurrentTI);
		totalQueueInNextStack :=	nextLC.getStackHeightOfTIs(QUEUE_MODE, theCurrentTI);
	endif;

	if obj.moveMode = PLANNING_MODE and  (totalPlanInThisStack + heightOfThisTI &gt; maxHeight) then
		obj.addVerboseLogEntry(app.getErrorString1(Plann_alrea_full_will_over_cap, locnId &amp; iterStr), obj.getLogType, Plann_alrea_full_will_over_cap);
		if obj.isAutoPlanMove then
			return;
		endif;
	endif;	
	if obj.moveMode = QUEUE_MODE and  totalQueueInThisStack + heightOfThisTI &gt; maxHeight then
		obj.addVerboseLogEntry(app.getErrorString1(Queue_alrea_full_will_over_cap, locnId &amp; iterStr), obj.getLogType, Queue_alrea_full_will_over_cap);		
		if obj.isAutoPlanMove then
			return;
		endif;
	endif;
	
	//24 Sep 2020	NDL	TFS 49984
	if not self.getMyTerminalArea.allGriddedTAStackHeights.isEmpty then
		currentMaxHeightForPad := self.getCurrentMaxHeightForPad( reason );
		if currentMaxHeightForPad &lt;&gt; 0 then
			if obj.moveMode = PLANNING_MODE and currentMaxHeightForPad &lt; totalPlanInThisStack then
				griddedStackHeight := self.getGriddedStackHeightObj( firstTi );
				if griddedStackHeight &lt;&gt; null then
					reason := app.getErrorString2(Height_restri_positi_becuas_fi, griddedStackHeight.name, firstTi.id );
					obj.addVerboseLogEntry(app.getErrorString1(Plann_alrea_full_will_over_cap, locnId &amp; iterStr &amp; Cr &amp; reason &amp; Cr), obj.getLogType, Plann_alrea_full_will_over_cap);
					if obj.isAutoPlanMove then
						return;
					endif;
				endif;
				
			elseif obj.moveMode = QUEUE_MODE and currentMaxHeightForPad &lt; totalQueueInThisStack then
				griddedStackHeight := self.getGriddedStackHeightObj( firstTi );
				if griddedStackHeight &lt;&gt; null then
					reason := app.getErrorString2(Height_restri_positi_becuas_fi, griddedStackHeight.name, firstTi.id );
					obj.addVerboseLogEntry(app.getErrorString1(Queue_alrea_full_will_over_cap, locnId &amp; iterStr &amp; Cr &amp; reason &amp; Cr), obj.getLogType, Queue_alrea_full_will_over_cap);
					if obj.isAutoPlanMove then
						return;
					endif;
				endif;
				
			endif;
		endif;
	endif;

	if numControllers &gt; 1 then
		//------------------
		//40 foot processing
		//------------------
		totalPlanInThisStack := self.getStackHeightOfTIs(PLANNING_MODE, theCurrentTI);
		nextId := nextLC.getFullId;
		if totalPlanInNextStack &lt;&gt; totalPlanInThisStack then
//			//stacks are not at same height, 40' cannot go here!
			obj.addVerboseLogEntry(app.getErrorString2(Stack_same_heigh_inten_targe_p, nextId &amp; iterStr, locnId), obj.getLogType, Stack_same_heigh_inten_targe_p);
			if obj.isAutoPlanMove then
				return;	
			endif;
		endif;
		if totalQueueInNextStack &lt;&gt; totalQueueInThisStack then
			//stacks are not at same height, 40' cannot go here!
			obj.addVerboseLogEntry(app.getErrorString2(Stack_same_heigh_inten_targe_q, nextId &amp; iterStr, locnId), obj.getLogType, Stack_same_heigh_inten_targe_q);
			if obj.isAutoPlanMove then
				return;
			endif;
		endif;
		if obj.moveMode = PLANNING_MODE and  totalPlanInNextStack + heightOfThisTI &gt; maxHeight then
			obj.addVerboseLogEntry(app.getErrorString1(Next_plann_alrea_full_will_ove, nextId &amp; iterStr), obj.getLogType, Next_plann_alrea_full_will_ove);
			if obj.isAutoPlanMove then
				return;
			endif;
		endif;
		if obj.moveMode = QUEUE_MODE and  totalQueueInNextStack + heightOfThisTI &gt; maxHeight then
			obj.addVerboseLogEntry(app.getErrorString1(Next_queue_alrea_full_will_ove, nextId &amp; iterStr), obj.getLogType, Next_queue_alrea_full_will_ove); //- cnwmd1, Par 20524
			if obj.isAutoPlanMove then
				return;
			endif;
		endif;
	endif;
	//----------------
	//We are happy, we are not full!!
	//----------------
	obj.updateController(self);
end;</source>
        <Parameter name="obj" type="CMIF_AutoMovePlan" usage="input"/>
    </JadeMethod>
    <JadeMethod name="isStackFullYA" id="3479b93c-49b6-4277-86b7-07877202ce64">
        <source>isStackFullYA(_yaAgent : CM_YAAutoplanAgent input) : Boolean;
//Test to see if this area can accept the container passed in.
vars

	nextLC						: CM_GridController;
	heightOfThisTI				: Integer;
	totalInThisStack			: Integer;
	totalInNextStack			: Integer;
	totalPlanInThisStack		: Integer;
	totalPlanInNextStack		: Integer;
	totalQueueInThisStack		: Integer;
	totalQueueInNextStack		: Integer;
	iterStr						: String;
	locnId						: String;
	nextId						: String;
	tempTI2,
	tempTI,
	theCurrentTI: CM_TrackedItem;
	maxHeight,
	maxHeightFork				: Integer;
	backEnd				: CM_GridController;
	
begin

	if not self.isSuitableForTIYA(_yaAgent) then
		_yaAgent.addLogEntry(AP_Log_YA_Default,"Not suitable for container", true);
		return true;
	endif;
	
	theCurrentTI:=_yaAgent.myCurrentCMIFYAAutoPlan.getMyTrackedItem;
	maxHeight := self.getMaxStackingHeight() * Ti_Full_Height;
	
	maxHeightFork := self.myGridArea.getMaxHeightGridAreaYA(_yaAgent.myCurrentCMIFYAAutoPlan) * Ti_Full_Height;
	
	maxHeight := maxHeight.min(maxHeightFork);

	iterStr := _yaAgent.iteration.String;

	heightOfThisTI := _yaAgent.myCurrentCMIFYAAutoPlan.getHeightOfTi();	
	//----------------
	//Test for full in REAL mode FIRST.
	//----------------
	totalInThisStack := self.getStackHeightOfTIs(REAL_MODE, null);

	locnId := self.getFullId;
	if totalInThisStack + heightOfThisTI &gt; maxHeight then
		if self.isForkLiftController() and maxHeightFork &lt;=0 then
			_yaAgent.addLogEntry(AP_Log_YA_Default,app.getErrorString1(Move_WillBeOverCap , locnId &amp; iterStr) &amp; " Check max stack height settings in Terminal Area Definition.", true);
		else
			_yaAgent.addLogEntry(AP_Log_YA_Default,app.getErrorString1(Move_WillBeOverCap , locnId &amp; iterStr), true);
		endif;
		return true;	//Its already full, or us going into it will bust it
	endif;

	nextLC := self.getNextControllerOfType(self.class); //self.getMyNextController(CM_StackController).CM_StackController;
	
	//-----------------
	//If the TI needs more than 1 controller, then check next location.
	//-----------------
		
	if _yaAgent.numControllers &gt; 1  then 
		if nextLC = null then 
			_yaAgent.addLogEntry(AP_Log_YA_Default,"No next position for container longer than 20 foot", true);// PAR 17386
			return true;	//No next position. 40' cannot go here.
		endif;
		
		//epr par 19645 - when  planning overstow moves CM_YAAutoplanAgent::searchForOverstowLocation the allocation will be null as 
		// it just checks for space in the TA row for the current ti
		if _yaAgent.myCurrentAllocation &lt;&gt; null then
			// CCMS 1030 - Check the backend is within the ya block
			backEnd := self.getBackEndController(theCurrentTI);
			if backEnd = null or not _yaAgent.myCurrentAllocation.allYardControllers.includes(backEnd) then
				_yaAgent.addLogEntry(AP_Log_YA_Default,"Container backend is not within the allocation block", true);
				return true;	
			endif; 
		endif;

		if not nextLC.isSuitableForTIYA(_yaAgent) then
			_yaAgent.addLogEntry(AP_Log_YA_Default,"Not suitable for a container longer than 20'", true);// PAR 17386
			return true;
		endif;
			
		nextId := nextLC.getFullId;
		totalInNextStack := self.myNextController.getStackHeightOfTIs(REAL_MODE, null);

		if totalInNextStack &lt;&gt; totalInThisStack then
			_yaAgent.addLogEntry(AP_Log_YA_Default,app.getErrorString2(Move_StackHeight40, nextId &amp; iterStr, locnId), true);
			return true;	
		endif;

		if totalInNextStack + heightOfThisTI &gt; maxHeight then
			_yaAgent.addLogEntry(AP_Log_YA_Default,app.getErrorString1(Move_WillBeOverCap, nextId &amp; iterStr), true);
			return true;	//Its already full, or us going into it will bust it
		endif;
 	endif;
 	
	if totalInThisStack	&gt; 0 then
		tempTI := self.allTrackedItems.last;
		//if tempTI.isOverStowable(theCurrentTI,null) = false then
		if tempTI.isOverStowable(theCurrentTI,null,null) = false then//10 May 2010	NDL Par 24064
			_yaAgent.addLogEntry(AP_Log_YA_Default,app.getErrorString2(Move_Overstow, locnId, "length"), true);
			return true;
		endif;
		if _yaAgent.myCurrentCMIFYAAutoPlan.isAttributeTrue(TI_Attrib_IsForty) then
			if self.testMyNextController(self.class) then
				tempTI2 := self.myNextController.allTrackedItems.last;
				if tempTI2 &lt;&gt; null and (tempTI2 &lt;&gt; tempTI) then
					_yaAgent.addLogEntry(AP_Log_YA_Default,app.getErrorString2(Move_Overstow, self.myNextController.getFullId, "length"), true);
					return true;
				endif;
			endif;
		endif;
	endif;

	//ccms 1025 26/1/09 when checking best location we will only be concerned at real cargo
	if _yaAgent.isOnlyCheckRealCargo then
		return false;
	endif;
	
	//--------------------
	//OK, we've validate that there IS space here in this stack in REAL mode. We now have to
	//check the other modes as well
	//--------------------
	totalPlanInThisStack	:= self.getStackHeightOfTIs(PLANNING_MODE, null);

	totalQueueInThisStack	:= self.getStackHeightOfTIs(QUEUE_MODE, null);

	if totalPlanInThisStack	&gt; 0 then
		tempTI := self.getTIAtIndex(PLANNING_MODE, self.allPlannedFutureMoves.size);
		//if tempTI.isOverStowable(theCurrentTI,null) = false then
	//	if tempTI.isOverStowable(theCurrentTI,null,null) = false then//10 May 2010	NDL Par 24064
		if tempTI &lt;&gt; null and tempTI.isOverStowable(theCurrentTI,null,null) = false then//10 Nov 2017	NDL	TFS 7635
			_yaAgent.addLogEntry(AP_Log_YA_Default,app.getErrorString2(Move_Overstow, locnId, "length (planned)"), true);
			return true;
		endif;
	endif;
	
	if totalQueueInThisStack &gt; 0 then
		tempTI := self.getTIAtIndex(QUEUE_MODE, self.allQueuedFutureMoves.size);
		//if tempTI.isOverStowable(theCurrentTI,null) = false then
	//	if tempTI.isOverStowable(theCurrentTI,null,null) = false then//10 May 2010	NDL Par 24064
		if tempTI &lt;&gt; null and tempTI.isOverStowable(theCurrentTI,null,null) = false then//10 Nov 2017	NDL	TFS 7635
			_yaAgent.addLogEntry(AP_Log_YA_Default,app.getErrorString2(Move_Overstow, locnId, "length (queued)"), true);
			return true;
		endif;
		
		if _yaAgent.myCurrentCMIFYAAutoPlan.isAttributeTrue(TI_Attrib_IsForty) then
			if self.testMyNextController(self.class) then
				tempTI2 := self.myNextController.getTIAtIndex(QUEUE_MODE, self.allQueuedFutureMoves.size);
				if tempTI2 &lt;&gt; null and (tempTI &lt;&gt; tempTI2) then
					_yaAgent.addLogEntry(AP_Log_YA_Default,app.getErrorString2(Move_Overstow, self.myNextController.getFullId, "length"), true);
					return true;
				endif;
			endif;
		endif;
	endif;

	//Nice message of how many are actually here
	//----------------------
	
	//18 Jul 2013	NDL	Par 32049
	totalPlanInThisStack := totalPlanInThisStack + _yaAgent.getTestPlannedCargoHeightFor( self );
	
	if (totalInThisStack + totalQueueInThisStack + heightOfThisTI + totalPlanInThisStack) &gt; maxHeight then
		_yaAgent.addLogEntry(AP_Log_YA_Default,app.getErrorString1(Move_WillBeOverCap, locnId &amp; iterStr &amp; " (Queued &amp; Real &amp; Plan)"), true);
		return true;	//Its already full, or us going into it will bust it
	endif;

	if _yaAgent.numControllers &gt; 1 and nextLC &lt;&gt; null then
		totalPlanInNextStack	:= nextLC.getStackHeightOfTIs(PLANNING_MODE, null);
		totalPlanInNextStack := totalPlanInNextStack + _yaAgent.getTestPlannedCargoHeightFor( nextLC );	//18 Jul 2013	NDL	Par 31899
		totalQueueInNextStack :=	nextLC.getStackHeightOfTIs(QUEUE_MODE, null);
	endif;


	

	if _yaAgent.numControllers &gt; 1  and nextLC &lt;&gt; null then
		//------------------
		//40 foot processing
		//------------------
		nextId := nextLC.getFullId;
		if totalPlanInNextStack &lt;&gt; totalPlanInThisStack then
//			//stacks are not at same height, 40' cannot go here!
			_yaAgent.addLogEntry(AP_Log_YA_Default,app.getErrorString2(Move_StackHeight40, nextId &amp; iterStr,"plan " &amp; locnId), true);
			return true;
		endif;
		if totalQueueInNextStack &lt;&gt; totalQueueInThisStack then
			//stacks are not at same height, 40' cannot go here!
			_yaAgent.addLogEntry(AP_Log_YA_Default,app.getErrorString2(Move_StackHeight40, nextId &amp; iterStr, "queued " &amp; locnId), true);
			return true;
		endif;
		
		if (totalQueueInNextStack + totalPlanInNextStack + totalInNextStack) &lt;&gt; (totalQueueInThisStack + totalPlanInThisStack + totalInThisStack) then	
			_yaAgent.addLogEntry(AP_Log_YA_Default,app.getErrorString2(Move_StackHeight40, nextId &amp; iterStr, "EveryThing " &amp; locnId), true);
			return true;
		endif;

		if totalQueueInNextStack + heightOfThisTI &gt; maxHeight then
			_yaAgent.addLogEntry(AP_Log_YA_Default,app.getErrorString1(Move_WillBeOverCap, nextId &amp; iterStr &amp; " (next, Queued)"), true);
			return true;	//Its already full, or us going into it will bust it
		endif;
		
		if (totalInNextStack + totalQueueInNextStack + heightOfThisTI + totalPlanInNextStack) &gt; maxHeight then
			_yaAgent.addLogEntry(AP_Log_YA_Default,app.getErrorString1(Move_WillBeOverCap, locnId &amp; iterStr &amp; " (Queued &amp; Real &amp; Plan)"), true);
			return true;	//Its already full, or us going into it will bust it
		endif;
	endif;

	return false;
end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
