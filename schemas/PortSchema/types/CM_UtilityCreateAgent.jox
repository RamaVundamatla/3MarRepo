	//navsp1 03Jun2022 TFS#53104
	if _passport.isOpsViewEnabled(_realWorkPoint.getMyTerminal()) then
		_realWorkPoint.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,
								 BGP_OpsViewWSRequest.OPS_TYPE_MACHINE,
								 _realWorkPoint);
	endif;

epilog

