        <source>mnuRemoveItems_click(menuItem: MenuItem input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 February 2012	cnwndl1	Initial creation	Par 29195

*/

vars

	objArray : ObjectArray;
	obj : Object;
	rowIndex : Integer;

begin

	if not self.tblSelectedCargo.allSelectedObjects.isEmpty then
	
		create objArray transient;
		self.tblSelectedCargo.allSelectedObjects.copy( objArray );
		
		foreach obj in objArray do
			self.tblSelectedCargo.removeItemObject(obj);
			self.removeNotableTi( obj.CM_TrackedItem );
		endforeach;
		
		self.refreshTable( self.tblSelectedCargo, false );
		self.clearWouldPlanAndFailed();
		
	endif;

epilog

	delete objArray;

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuRemovePlanned_click" id="09b443de-f807-4e4e-946a-f4f11fbe6975">
