    <JadeMethod name="doDeleteFaultQuestion" id="824ef5ad-c93b-4ea3-8b99-48d739582e23">
        <source>doDeleteFaultQuestion();
/*

Purpose:			


Return Value:		


Date		Who		Reason
05 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	theForm : SOP_TableMaintForm;
	rtnValue : Boolean;
	faultQuestion : CM_FaultQuestion;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815

begin
	theForm := self.myForm;
	if (theForm.myCurrentObject = null) then
		return;
	endif;
	if (theForm.myCurrentObject.isKindOf(CM_MachineType) = false) then
		return;
	endif;
	
	if theForm.lstSingleSelect1.listIndex &lt; 0 then
		return;
	endif;
	faultQuestion:=theForm.lstSingleSelect1.itemObject[theForm.lstSingleSelect1.listIndex].CM_FaultQuestion;
	if faultQuestion = null then
		return;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxDA.trxDeleteFaultQuestion(faultQuestion,app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Fault Questions', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
	//18 Sep 2017	NDL	TFS 6984
	theForm.lstSingleSelect1.listCollection(theForm.myCurrentObject.CM_MachineType.allFaultQuestions,true,0);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doEditFaultQuestion" id="5c30172f-9e04-4195-b106-3e15f27101d6">
        <source>doEditFaultQuestion();
/*

Purpose:			


Return Value:		


Date		Who		Reason
05 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	theForm	: SOP_TableMaintForm;
	faultQuestionForm : SOP_FaultQuestionForm;
	faultQuestion : CM_FaultQuestion;
	modalResult : Integer;
begin
	theForm := self.myForm;
	if (theForm.myCurrentObject = null) then
		return;
	endif;
	if (theForm.myCurrentObject.isKindOf(CM_MachineType) = false) then
		return;
	endif;
	if(theForm.lstSingleSelect1.listObject = null) then
		return;
	else
		faultQuestion := theForm.lstSingleSelect1.listObject.CM_FaultQuestion;
	endif;
	faultQuestionForm := app.loadForm(SOP_FaultQuestionForm, theForm.myAssistant.class, false, false ,true ,self.myForm.myTerminal, null).SOP_FaultQuestionForm;
	if faultQuestionForm = null then
		return;
	endif;
	
	faultQuestionForm.init(theForm.myCurrentObject.CM_MachineType, faultQuestion);
	modalResult:=faultQuestionForm.showModal;
	if modalResult = IDOK then
		theForm.lstSingleSelect1.listCollection(theForm.myCurrentObject.CM_MachineType.allFaultQuestions,true,0);
		theForm.lstSingleSelect1.listObject := faultQuestionForm.myFaultQuestion;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMoveFaultQuestion" id="70f828e4-8129-4aa4-b4fc-2a8abccaa327">
        <source>doMoveFaultQuestion(_up : Boolean);
/*

Purpose:			


Return Value:		


Date		Who		Reason
11 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	theForm : SOP_TableMaintForm;
	rtnValue : Boolean;
	faultQuestion : CM_FaultQuestion;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	
begin
	theForm := self.myForm;
	if (theForm.myCurrentObject = null) then
		return;
	endif;
	if (theForm.myCurrentObject.isKindOf(CM_MachineType) = false) then
		return;
	endif;

	if theForm.lstSingleSelect1.listCount = 1 then
		return;
	endif;
	
	if theForm.lstSingleSelect1.listIndex &lt; 0 then
		return;
	endif;
	faultQuestion:=theForm.lstSingleSelect1.itemObject[theForm.lstSingleSelect1.listIndex].CM_FaultQuestion;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxMoveFaultQuestion( faultQuestion, _up, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog('Fault Questions', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
	theForm.lstSingleSelect1.listCollection(theForm.myCurrentObject.CM_MachineType.allFaultQuestions,true,0);
	theForm.lstSingleSelect1.listObject := faultQuestion;
	
epilog

end;</source>
        <Parameter name="_up" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doNewFaultQuestion" id="86f0cb80-760f-46fb-b11d-d52a4ac5beb0">
        <source>doNewFaultQuestion();
/*

Purpose:			


Return Value:		


Date		Who		Reason
05 September 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

	theForm	: SOP_TableMaintForm;
	faultQuestionForm : SOP_FaultQuestionForm;
	modalResult : Integer;
begin
	theForm := self.myForm;
	if (theForm.myCurrentObject = null) then
		return;
	endif;
	if (theForm.myCurrentObject.isKindOf(CM_MachineType) = false) then
		return;
	endif;

	faultQuestionForm := app.loadForm(SOP_FaultQuestionForm, theForm.myAssistant.class, false, false ,true ,self.myForm.myTerminal, null).SOP_FaultQuestionForm;
	if faultQuestionForm = null then
		return;
	endif;
	
	faultQuestionForm.init(theForm.myCurrentObject.CM_MachineType, null);
	modalResult :=faultQuestionForm.showModal;
	if modalResult = IDOK then
		theForm.lstSingleSelect1.listCollection(theForm.myCurrentObject.CM_MachineType.allFaultQuestions,true,0);
		theForm.lstSingleSelect1.listObject := faultQuestionForm.myFaultQuestion;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="aca6fc94-e344-4c7e-9c3c-9828683cd28b">
        <updating/>
        <source>doSave(): Boolean updating;

vars
	errObj					: CM_Error;
	idx						: Integer;
	tmpListBox				: ListBox;
	ignoreWarnings,rtnValue	: Boolean;
	proxyMachineType		: CM_MachineType;
	lType					: Integer;
	lDescription			: String;
	theForm					: SOP_TableMaintForm;
	pCargoTypes,
	pTerminalAreas			: ObjectArray;
	damagePositions,
	damageCodesSet			: CM_ObjectSet;
begin
    theForm := self.myForm; 

	lType := theForm.tblInput1.getValueByName(ETRow_Code).Integer;
	lDescription := theForm.tblInput1.getValueByName(ETRow_Description).String;

	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_MachineType transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	create pTerminalAreas transient;
	create pCargoTypes transient;
	theForm.mulSelect1.getSelected(pTerminalAreas);
    theForm.mulSelect2.getSelected(pCargoTypes);    
	
	create damagePositions transient;
	theForm.mulSelect3.getSelected(damagePositions);
	
	create damageCodesSet transient;
	theForm.mulSelect6.getSelected(damageCodesSet);
	
	proxyMachineType := theForm.myProxyObject.CM_MachineType;
	proxyMachineType.setProxy(lType, lDescription, pCargoTypes, pTerminalAreas, damagePositions, damageCodesSet);

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateMachineType(proxyMachineType, theForm.myCurrentObject,app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateMachineType(proxyMachineType, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	return app.myPassport.trxCompletedOK;

epilog
  if pCargoTypes &lt;&gt; null then
  	delete pCargoTypes;
  endif;
  if pTerminalAreas &lt;&gt; null then
 	delete pTerminalAreas;
  endif;
  delete damagePositions;
  delete damageCodesSet;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
