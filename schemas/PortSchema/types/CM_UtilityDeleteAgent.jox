    <JadeMethod name="utlDeleteStopBOLsBulk" id="deeb71ec-cc3e-4921-bca1-23bbec32946c">
        <updating/>
        <source>utlDeleteStopBOLsBulk(_bolSet : CM_BOLSet; _stopTable : CM_StopsTable; _theCENumber : String; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     15 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 20 Oct 2022	navsj20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
// ---------------------------------------------------------------------------
vars
	bol	: CM_BOL;
	user : CM_User;
	stop : CM_Stops;
	
begin
	self.initialiseActivity();
	
	// do the validation here
	self.raiseExceptionIfNull(_stopTable, 'The Stop');
	self.raiseExceptionIfNull(_bolSet, 'Cargo Set');	

	if _bolSet.isEmpty() then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No Cargo Items selected');
	endif;	
	
	user := _passport.myUser;
	if (user &lt;&gt; null) and (not user.canUpdateStop(_passport.myTerminal, _stopTable)) then
		app.raiseCMException1(NoPermission, app.getErrorString1(Remove_The_Stop, _stopTable.heading), null, null);
	endif;
	
	//CCMS1200 Can't add a CEDO stop or customs stop to a child as it may interfere with the parent discharge.
	if _stopTable.requiresInfo and _theCENumber.trimBlanks = null then
		// cannot remove stop without extra info this is required so raise exception
	//	app.raiseCMException1(REQUIRED_FIELD, 'Customs Entry Number', 'Customs Entry Number', self);
		app.raiseCMException(Input_required_field_custEnt, 'Customs Entry Number', self); // cnwdb2	PAR 35364
	endif;
	
	app.setContinueCMExceptions(true);
	
	foreach bol in _bolSet do
		stop := bol.allStops[_stopTable.id];
		if stop = null then
			app.raiseCMWarning1(WARN_STOPS_REMOVE, 'Item ' &amp; bol.number.String &amp; ' does not have a ' &amp; _stopTable.heading &amp; ' stop pending and so will not be removed', null, null, bol);
			continue; //don't assign CEDO number is the stop is not going to be removed
		endif;
		
		//if (not _stopTable.isValidForCargoType(bol.bolType)) then	//20.10.2022	navsj20	TFS 53862
		if stop &lt;&gt; null and (not _stopTable.isValidForStopCriteria(stop.myTrackedItem)) then	//20.10.2022	navsj20	TFS 53862
			//app.raiseCMWarning1(WARN_STOPS_REMOVE, 'Stop type ' &amp; _stopTable.heading &amp; ' does not apply to the cargo type of item ' &amp; bol.number.String &amp; ' and so will not be removed', null, null, bol);		//20.10.2022	navsj20	TFS 53862
			app.raiseCMWarning1(WARN_STOPS_REMOVE, 'Stop type ' &amp; _stopTable.heading &amp; ' does not apply to the tracked item of item ' &amp; stop.myTrackedItem.id.String &amp; ' and so will not be removed', null, null, bol);	//20.10.2022	navsj20	TFS 53862
		//TH2 6th June - remove it anyway incase somehow it got incorrectly applied automatically by another piece of code (this happened) 
		//	continue;
		endif;
		bol.removeAStop(_stopTable, true, _passport ); // cnwgb1 CCMS SFW 1012 PAR 17931 8.10.08

	endforeach;
		
epilog
	
end;
</source>
        <Parameter name="_bolSet" type="CM_BOLSet"/>
        <Parameter name="_stopTable" type="CM_StopsTable"/>
        <Parameter name="_theCENumber" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteStopOverriddenReason" id="b26613f7-649f-4f0d-b9a0-82ef90369c70">
        <updating/>
        <source>utlDeleteStopOverriddenReason(
	_stopOverriddenReason	: CM_StopOverridenReason io;
	_passport				: CM_Passport input ) updating;
	
/*
Date			Who		Reason
20 August 2010	cnwrl1	Initial creation as part of PAR 23697 - CCMS 1097 - Stop Expiry - retain info after expiry.
*/
	
vars
	
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions( false );		// stop after first error save time!
	
	app.myValDA.valStopOverriddenReason( _stopOverriddenReason );
	
	if not self.checkValidationWithPassport( _passport ) then
		// Show any Errors and Warnings in a list
		return;
	endif;
	
	app.setContinueCMExceptions( false );
	
	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric( _stopOverriddenReason );
	endif;
	
	if _passport.noErrors then
		_stopOverriddenReason.erase( NORMAL_ERASE );
	endif;
	
epilog
	
end;
</source>
        <Parameter name="_stopOverriddenReason" type="CM_StopOverridenReason" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteStopTIMastsBulk" id="08a12107-bf23-4aa2-8179-aab613705f69">
        <updating/>
        <source>utlDeleteStopTIMastsBulk(_tiSet : CM_TIMasterSet; _stopTable : CM_StopsTable;  _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 September 2008	cnwrd1	Initial creation
12 Oct 2016	cnwkpd1	TFS 2815 - JADE 7.1.08 causeEvent changes

*/

vars
	now 			: TimeStamp;
	ti				: CM_TIMaster;
//	txnParams 		: CMIF_TITransactionController; //cnwrs1 par 12897 nov 2006
//	tiTransaction 	: CM_TITransaction;
	user			: CM_User;
	tiStop			: CM_StopsTable;
begin

	self.initialiseActivity();
	
	// do the validation here
	self.raiseExceptionIfNull(_stopTable, 'The Stop');
	self.raiseExceptionIfNull(_tiSet, 'Cargo Set');	

	if _tiSet.isEmpty() then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No Cargo Items selected');
	endif;	
	
	/*
	user := _passport.myUser;
	if (user &lt;&gt; null) and (not user.canUpdateStop(_passport.myTerminal, _stopTable)) then
		app.raiseCMException1(NoPermission, app.getErrorString1(Remove_The_Stop, _stopTable.heading), null, null);
	endif;
	*/
	
	
	app.setContinueCMExceptions(true);

	foreach ti in _tiSet do
		tiStop := ti.allStopsNew[_stopTable.id];
		if tiStop = null then
			app.raiseCMWarning1(WARN_STOPS_REMOVE, 'Item ' &amp; ti.id &amp; ' does not have a ' &amp; _stopTable.heading &amp; ' stop pending and so will not be removed', null, null, ti);
			continue; //don't assign CEDO number is the stop is not going to be removed
		endif;
		
		if (not _stopTable.isValidForCargoType(ti.cargoType)) then
			app.raiseCMWarning1(WARN_STOPS_REMOVE, 'Stop type ' &amp; _stopTable.heading &amp; ' does not apply to the cargo type of item ' &amp; ti.id &amp; ' and so will not be removed', null, null, ti);
		//TH2 6th June - remove it anyway incase somehow it got incorrectly applied automatically by another piece of code (this happened) 
		//	continue;
		endif;
		ti.allStopsNew.removeIfPresent ( tiStop ) ;
		
//		ti.causeEvent(Object_Update_Event, false, self);
		self.updateObjectEdition(ti);
	endforeach;
		
epilog
 	//delete txnParams;
end;</source>
        <Parameter name="_tiSet" type="CM_TIMasterSet"/>
        <Parameter name="_stopTable" type="CM_StopsTable"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteStopTIsBulk" id="57773b52-da54-4252-8e0b-8c29019f889c">
        <updating/>
        <source>utlDeleteStopTIsBulk(_tiSet : CM_TISet; _stopTable : CM_StopsTable; _theCENumber : String; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     15 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 14/06/2010	cnwcs5	par 24342 - changed parameter type for updateChildStops method call
// 01/07/2011	cnwmh5	Add HandleDeleteObject
// 12 Oct 2016	cnwkpd1	TFS 2815 - JADE 7.1.08 causeEvent changes
// 25/09/2018	jlgrh7 TFS #40481 MSL - stop removing from Children
// 20 Oct 2022	navsj20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details
// ---------------------------------------------------------------------------
vars
	ti				: CM_TrackedItem;
	txnParams 		: CMIF_TITransactionController; //cnwrs1 par 12897 nov 2006
	tiTransaction 	: CM_TITransaction;
	user			: CM_User;
	tiStop			: CM_Stops;
	tempStr			: String;
	invalidObject	: Boolean;
	tistops : CM_StopsByIdDict;
begin

	on Exception do app.handleDeletedObject( exception, tiStop, invalidObject );
	
	self.initialiseActivity();
	
	// do the validation here
	self.raiseExceptionIfNull(_stopTable, 'The Stop');
	self.raiseExceptionIfNull(_tiSet, 'Cargo Set');	

	if _tiSet.isEmpty() then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No Cargo Items selected');
	endif;	
	
	user := _passport.myUser;
	if (user &lt;&gt; null) and (not user.canUpdateStop(_passport.myTerminal, _stopTable)) then
		app.raiseCMException1(NoPermission, app.getErrorString1(Remove_The_Stop, _stopTable.heading), null, null);
	endif;
	
	//CCMS1200 Can't add a CEDO stop or customs stop to a child as it may interfere with the parent discharge.
	if _stopTable.requiresInfo and _theCENumber.trimBlanks = null then
	
		if app.isGarbageCollectionProcess and app.isJMTUnitTest then	//01 Jul 2015	NDL	Par 36543
			//trying to clean-up during Unit testing, don't error
		else
			// cannot remove stop without extra info this is required so raise exception
			//cnwrd1 4.11.08 CCMS JMT 1743/1764 
			if _stopTable.requiresInfoType = ImportReleasePIN then			
			//	app.raiseCMException1(REQUIRED_FIELD,'Import Release PIN', 'Import Release PIN', self);
				app.raiseCMException(Input_required_field_importRel, 'Import Release PIN', self); // cnwdb2	PAR 35364
			elseif _stopTable.requiresInfoType = ExportReleaseNumber then
			//	app.raiseCMException1(REQUIRED_FIELD, 'Export Release Number', 'Export Release Number', self);
				app.raiseCMException(Input_required_field_expRelNum, 'Export Release Number', self); // cnwdb2	PAR 35364
			// cnwrl1 04/05/2009 PAR 19574 - CCMS 1791 - start of coding
			elseif _stopTable.requiresInfoType = DeliveryRelease then
				tempStr	:= app.getErrorString( Delivery_Release_Number );
			//	app.raiseCMException1( REQUIRED_FIELD, tempStr, tempStr, self );
				app.raiseCMException1( Input_required_field_Required, tempStr, tempStr, self ); // cnwdb2	PAR 35364
			// cnwrl1 04/05/2009 PAR 19574 - CCMS 1791 - end of coding
			
			elseif _stopTable.requiresInfoType = CustomsReference then	//30 Jun 2015	NDL	Par 36543
				tempStr	:= app.getErrorString( Customs_reference );
				app.raiseCMException1( Input_required_field_Required, tempStr, tempStr, self );
				
			else//cnwrd1 4.11.08 CCMS JMT 1743/1764
			//	app.raiseCMException1(REQUIRED_FIELD, 'Customs Entry Number', 'Customs Entry Number', self);
				app.raiseCMException(Input_required_field_customEnt, 'Customs Entry Number', self); // cnwdb2	PAR 35364
			endif;		//cnwrd1 4.11.08 CCMS JMT 1743/1764
		
		endif;
		
	endif;
	
	if _stopTable.requiresInfo and _theCENumber.length &lt;&gt; 6 
		//	and ( _stopTable.requiresInfoType = ImportReleasePIN or _stopTable.requiresInfoType = ExportReleaseNumber )  then		
			and ( _stopTable.requiresInfoType = ImportReleasePIN  )  then		//ccms 1798 stop checking max length=6 for export release number
			app.raiseCMException1(VB_INVALID_NUM, _theCENumber , 'Release Number', self);
	endif;
	
	app.setContinueCMExceptions(true);
	
	create txnParams transient;
	txnParams.userId := _passport.userCode;
	
	foreach ti in _tiSet do
//		tiStop := ti.getAllStops()[_stopTable.id];	// cnwrl1 14/12/2009 PAR 21889 - what it was
// ### TFS CR 60424 TASK 60549 17OCT2023 NAVAB1		tiStop := ti.getStopByIDAsAtDate( _stopTable.id, null );
		tistops := ti.getAllStops(); // ### TFS CR 60424 TASK 60549 17OCT2023 NAVAB1 - this is a delete so just get the stops. getStopByIDAsAtDate() will not return stops cleared by clearance expiry or cust docs and then get crash.
		tiStop := tistops[_stopTable.id]; // ### TFS CR 60424 TASK 60549 17OCT2023 NAVAB1
		if tiStop = null then
			app.raiseCMWarning1(WARN_STOPS_REMOVE, 'Item ' &amp; ti.id &amp; ' does not have a ' &amp; _stopTable.heading &amp; ' stop pending and so will not be removed', null, null, ti);
			continue; //don't assign CEDO number is the stop is not going to be removed
		endif;

		// CCMS 1696 - If the parent and child has the stop, then not allowed to remove from child
		if ti.myParent &lt;&gt; null 
		and ti.myParent.hasStopOfType(_stopTable)	
		and _stopTable.isStopProcess(StopProcessCopyToChild, ti.myTerminal) then
			app.raiseCMException3(Stop_cannot_remove_while_child, _stopTable.heading, ti.id, ti.myParent.id, null, self);
			return;
		endif;
	
		//if (not _stopTable.isValidForCargoType(ti.cargoType)) then		//20.10.2022	navsj20	TFS 53862
		if (not _stopTable.isValidForStopCriteria(ti)) then			//20.10.2022	navsj20	TFS 53862
			//app.raiseCMWarning1(WARN_STOPS_REMOVE, 'Stop type ' &amp; _stopTable.heading &amp; ' does not apply to the cargo type of item ' &amp; ti.id &amp; ' and so will not be removed', null, null, ti);			//20.10.2022	navsj20	TFS 53862
			app.raiseCMWarning1(WARN_STOPS_REMOVE, 'Stop type ' &amp; _stopTable.heading &amp; ' does not apply to the tracked item of item ' &amp; ti.id &amp; ' and so will not be removed', null, null, ti);		//20.10.2022	navsj20	TFS 53862
		//TH2 6th June - remove it anyway incase somehow it got incorrectly applied automatically by another piece of code (this happened) 
		//	continue;
		endif;
		
		txnParams.myTrackedItem := ti;
		txnParams.myStop := tiStop;
		txnParams.urNumber := "1";
			
		if _stopTable.requiresInfo and
		   ( _stopTable.requiresInfoType = CustomsEntryNumber or
			 _stopTable.requiresInfoType = CustomsReference or
		     _stopTable.requiresInfoType = DeliveryRelease or
		     _stopTable.requiresInfoType = CEDO ) then
//		   ( _stopTable.requiresInfoType = CustomsEntryNumber or _stopTable.requiresInfoType = CEDO ) then	// cnwrl1 04/05/2009 PAR 19574 - CCMS 1791 - what it was
			//cnwrd1 4.11.08 CCMS JMT 1743/1764 
			//create transactions first
			txnParams.type	:= TRANS_TYPE_CUSTSTOP_CLRD;
			tiTransaction	:= ti.createTransaction( txnParams, _passport );
			
			// cnwrl1 05/05/2009 PAR 19574 - CCMS 1791
			if _stopTable.requiresInfoType = CustomsEntryNumber or _stopTable.requiresInfoType = CEDO then
				if CM_CustomStopClear.hasInstance( tiTransaction ) then
					tiTransaction.CM_CustomStopClear.setCustomsDetails( _theCENumber.trimBlanks, null );
				endif;
			endif;
			
			if _stopTable.requiresInfoType = CustomsEntryNumber then
				ti.setCustomsEntryNumber( _theCENumber.trimBlanks );
			elseif _stopTable.requiresInfoType = DeliveryRelease then
				ti.setDeliveryRelease( _theCENumber.trimBlanks );
			elseif _stopTable.requiresInfoType = CEDO then
				ti.setCEDO( _theCENumber.trimBlanks );
				
			elseif _stopTable.requiresInfoType = CustomsReference then	//30 Jun 2015	NDL	Par 36543
				ti.setCustomsReference( _theCENumber.trimBlanks );
				
			endif;
		endif;
		
		if _stopTable.isToBeProcessed(StopProcessCustomsInspect, ti) then
			txnParams.type := TRANS_TYPE_INSPECT;
			txnParams.noCharge := false;
			tiTransaction := ti.createTransaction(txnParams, _passport);
			txnParams.noCharge := true;	// TFS 3844 THIS METHOD IS ONLY CALLED BY UNIT TESTS
		endif;
		// CCMS 1585
		if _stopTable.isToBeProcessed(StopProcessCustomsScanInspect, ti) then
			txnParams.type := TRANS_TYPE_CSC_INSPECT;
			txnParams.noCharge := false;
			tiTransaction := ti.createTransaction(txnParams, _passport);
			txnParams.noCharge := true;		// TFS 3844 THIS METHOD IS ONLY CALLED BY UNIT TESTS
		endif;
		
		//cnwrd1 4.11.08 CCMS JMT 1743/1764 start
		if _stopTable.isToBeProcessed(StopProcessOpExpReleaseNo, ti) and _stopTable.requiresInfoType = ExportReleaseNumber then
			txnParams.type := TRANS_TYPE_EDIT;
			txnParams.dateTime := app.serverTimestampAtTrxStart;
			txnParams.noCharge := false;	//charge by default					
			txnParams.urNumber := "";
			tiTransaction := ti.createTransaction(txnParams, _passport);								
		//	tiTransaction.CM_Edit.fieldsValues.add( ti.formatAuditText(OperatorExportReleaseNumber, _theCENumber.trimBlanks  ));						
			tiTransaction.CM_Edit.fieldsValues.add( OperatorExportReleaseNumber &amp; " =&gt; " &amp; _theCENumber.trimBlanks );						
			
			txnParams.noCharge := true;		// TFS 3844 THIS METHOD IS ONLY CALLED BY UNIT TESTS
			
			ti.setOperatorExpReleaseNo(_theCENumber.trimBlanks);		
		endif; 
		
		if _stopTable.isToBeProcessed(StopProcessOpImpReleasePIN, ti) and _stopTable.requiresInfoType = ImportReleasePIN then
			txnParams.type := TRANS_TYPE_EDIT;
			txnParams.dateTime := app.serverTimestampAtTrxStart;
			txnParams.noCharge := false;	//charge by default		
			txnParams.urNumber := "";
			tiTransaction := ti.createTransaction(txnParams, _passport);								
			//tiTransaction.CM_Edit.fieldsValues.add( ti.formatAuditText(OperatorImportReleasePIN, _theCENumber.trimBlanks  ));						
			tiTransaction.CM_Edit.fieldsValues.add( OperatorImportReleasePIN &amp; " =&gt; " &amp; _theCENumber.trimBlanks );						
			
			txnParams.noCharge := true;		// TFS 3844 THIS METHOD IS ONLY CALLED BY UNIT TESTS

			ti.setOperatorImportReleasePIN( _theCENumber.trimBlanks ) ;			
		endif; 
		//cnwrd1 4.11.08 CCMS JMT 1743/1764 end
		
		txnParams.type := TRANS_TYPE_STOPCLEAR;
		tiTransaction := ti.createTransaction(txnParams, _passport);
		
		//ccms 1473
	//	ti.createCEDORemovedAlert(tiStop, _passport); //cnwrd1 par 18643 23.1.09 - removed because alert should be raised on removal of the CEDO not the CEDO STOP
		
		delete tiStop;
		
		ti.updateChildStops(_stopTable, CM_Stops.Action_Clear,null);  // 14/06/2010 cnwcs5 par 24342 // CCMS 1696 //+TFS40481
	
		// CCMS 1285: check for event notification processing	
		//ti.actionStopTaskEventRequests(app.getErrorString(AvailableForRelease), null, _passport);
		ti.actionStopTaskEventRequests(CM_EventRequestNotification.Event_Type_IsAvailable, CM_EventRequestNotification.Event_Type_IsAvailable, false, _passport);
//		ti.causeEvent(Object_Update_Event, false, self);
		self.updateObjectEdition(ti);
	endforeach;
	
epilog
 	delete txnParams;
	
end;</source>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <Parameter name="_stopTable" type="CM_StopsTable"/>
        <Parameter name="_theCENumber" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteStops" id="2c1787db-047c-4828-9965-68aefdb5aa0c">
        <updating/>
        <source>utlDeleteStops(_theTI : CM_TrackedItem input; _theStops : IntegerArray; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     15 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30 Aug 2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition 
// ---------------------------------------------------------------------------
vars
	aStop 			: Integer;
	user			: CM_User;
	stopsTable		: CM_StopsTable;	
begin

	self.initialiseActivity();

	if _theStops.size = 0 then
		app.raiseCMWarning2(WARN_NO_STOPS, _theTI.id, "", 'allStops', null, _theTI);
	endif;
	
	foreach aStop in _theStops do
		stopsTable := app.myRoot.allStopsTable[aStop];
		if stopsTable = null then
			app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid Stop');
		else
			user := _passport.myUser;
			if (user &lt;&gt; null)
			and (not user.canUpdateStop(_passport.myTerminal, stopsTable)) then
				app.raiseCMException1(NoPermission, app.getErrorString1(Remove_The_Stop, stopsTable.heading), null, null);
			endif;
		endif;
	endforeach;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	_theTI.deleteStops(false, _theStops, false, _passport);

	if _passport.noErrors then
		// bump the edition to cause an update note to go out
		self.updateObjectEdition(_theTI);	// par 30292
	endif;
		

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_theStops" type="IntegerArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteStopsTable" id="f2b000b0-a498-4f97-a739-3503805aaa73">
        <source>utlDeleteStopsTable(_stopTable : CM_StopsTable io; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	yaType : CM_YATypeStops;

begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valStopsTable(_stopTable);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;


	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_stopTable);
	endif;
	
	//remove stop from selector
	if _passport.noErrors then
		app.myRoot.stopQueryPropertyRemove(_stopTable, _passport);
	endif;
	
	if _passport.noErrors then
		yaType := CM_YATypeStops.firstInstance;
		if yaType &lt;&gt; null then
			yaType.removeMyDataObject(_stopTable);
		endif;
		_stopTable.erase(NORMAL_ERASE);
	endif;
epilog
	return;

end;</source>
        <Parameter name="_stopTable" type="CM_StopsTable" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteStorageConfig" id="8cb1f022-0e8e-4f53-b213-59dacdd4626b">
        <updating/>
        <source>utlDeleteStorageConfig(_storageConfig : CM_StorageConfig input; _passport : CM_Passport input) updating;
// 13 September 2012	cnwjre1	CCMS SFW 1295 Free Storage Days
// 17 Oct 2017    jlgrh7 TFS #7228 ADP - Storage Configuration Validation and Auditing
vars
	terminal : CM_Terminal;
begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valStorageConfig(_storageConfig);

	if not self.checkValidationWithPassport(_passport) then
	endif;

	app.setContinueCMExceptions(false);

	terminal:= _storageConfig.myTerminal;																								//+TFS7228
	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_storageConfig);
	endif;

	if _passport.noErrors then
		_storageConfig.erase(NORMAL_ERASE);
	endif;

	terminal.causeEvent(terminal.getTerminalEvent(EVENT_STORAGECONFI_DELETE),false,_storageConfig);				//+TFS7228
end;</source>
        <Parameter name="_storageConfig" type="CM_StorageConfig" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteStorageDetail" id="5ccfd014-f47b-4eaf-9795-74b6f3a52e69">
        <updating/>
        <source>utlDeleteStorageDetail(_storageDetail : CM_StorageDetail input; _passport : CM_Passport input) updating;
// 13 September 2012	cnwjre1	CCMS SFW 1295 Free Storage Days
vars
	terminal : CM_Terminal;
begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valStorageDetail(_storageDetail);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	terminal:=_storageDetail.myStorageConfig.myTerminal;

	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_storageDetail);
	endif;

	if _passport.noErrors then
		_storageDetail.erase(NORMAL_ERASE);
	endif;
	terminal.causeEvent(terminal.getTerminalEvent(EVENT_STORAGE_CRITERIA_DELETE),false,_storageDetail);
end;
</source>
        <Parameter name="_storageDetail" type="CM_StorageDetail" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteSubTerminal" id="fedfe376-2163-4866-811b-3e63b55b0112">
        <source>utlDeleteSubTerminal(_proxySubTerminal:CM_SubTerminal io; _passport : CM_Passport input);
/*
----------   ----------  --------------------------------------------------
Created:	08 April 2009 By cnwdz2

Purpose:	CCMS1735: 

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valSubTerminal(_proxySubTerminal);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;

	app.setContinueCMExceptions(false);

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_proxySubTerminal);
	endif;

	if _passport.noErrors then
		_proxySubTerminal.erase(NORMAL_ERASE);
	endif;

epilog
	return;

end;</source>
        <Parameter name="_proxySubTerminal" type="CM_SubTerminal" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteSystemAlert" id="cdc275cc-d51f-4b1d-9994-d5dd40363daa">
        <source>utlDeleteSystemAlert(_alert :CM_SystemAlert io; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     12 August by David Barr

// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 14/05/2012	cnwcs5		par 29450 - split alert delete into &gt; 1 transaction
// ---------------------------------------------------------------------------
vars

begin
	// I do not call self.initialiseActivity because I want the calling method to decide whether
	// to set app.continueCMExceptions
	self.raiseExceptionIfNotInTranState(method);
	self.raiseExceptionIfNull(_alert, 'System Alert');

	if not self.exclusiveLockObjectToDelete(_alert) then
	    return;
	endif;
		
	_alert.erase(NORMAL_ERASE);
epilog

end;</source>
        <Parameter name="_alert" type="CM_SystemAlert" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteTI" id="32fc725c-3d51-4789-8c94-93166a489f90">
        <source>utlDeleteTI(pTI : CM_TrackedItem; _confirmDelete: Boolean; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     13 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 08/12/2014   cnwdb2      PAR 35364
// 09/11/2022	navkc1		Bug 55382: MTN - Cargo Group Details recalculated after each change to TI when bulk editing
// ---------------------------------------------------------------------------
vars
	toDelete	: CM_TrackedItem;
	theLocationController : CM_LocationsController;
	tmpEvent	: Integer;
	cargoGroup : CM_CargoGroup; //TFS 53390
	cargoGroupSiteTrxAction : CMIF_TrxActionCargoGroup; //TFS 53390
	
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(false);	
	pTI.validateForDelete();
	toDelete := pTI;

	if not self.exclusiveLockObjectToDelete(toDelete) then
	    // toDelete is null, invalid or has already been deleted
	    return;
	endif;
	
	if _confirmDelete then
	//	app.raiseCMWarning2(CONF_DELETE, 'TrackedItem', pTI.id, null, null, toDelete);
		app.raiseCMWarning1(Sure_want_delete35364g, pTI.id, null, null, toDelete); 	//cnwdb2 PAR 35364	

	endif;
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(toDelete);
	endif;
	
	// Issue notifications of delete of object (note this is done BEFORE the
	// delete as the object is gone after the delete)
	theLocationController := toDelete.getPrimaryLocation(REAL_MODE);
	
	if toDelete.state = TI_STATE_NOTIFIED and toDelete.myTerminal &lt;&gt; null then
		tmpEvent := toDelete.myTerminal.getTerminalEvent(TIEvent_PreNote_Delete);
		toDelete.causeEvent(tmpEvent, false, null);
	endif;

	cargoGroup := toDelete.myCargoGroup; //TFS 53390	
	
	if toDelete.isCargoGroupItem then						//28.Nov.2023 navsp1 TFS 61244
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_CARGOGROUP_DELETE), true, toDelete.CM_TrackedItem); //22.Mar.24 navsp1 TFS 61223
	endif;
	
	toDelete.erase(NORMAL_ERASE);
		
	if _passport.hasErrors then
		return;
	endif;
	
	//TFS 53390
	if _passport.noErrors() and cargoGroup &lt;&gt; null then
		
		CMIF_TrxActionCargoGroup@createAction(null, cargoGroup, _passport); 
		
		/* // navkc1	09/11/2022	#55382 - Moved to CMIF_TrxActionCargoGroup@createAction
		create cargoGroupSiteTrxAction transient;
		//cargoGroupSiteTrxAction.setMyCargoGroup(toDelete.myCargoGroup,CM_TrxControlAgent.Trx_Delete);
		cargoGroupSiteTrxAction.setMyCargoGroup(cargoGroup);
		_passport.addTrxPostAction(cargoGroupSiteTrxAction);
		*/ // navkc1	09/11/2022	#55382
		
	endif;
	
	if theLocationController &lt;&gt; null then

		if theLocationController.isKindOf(CM_SlotController) then
			// ################################
			// This will update the display on screen of this slot
			theLocationController.CM_SlotController.myBayVoyage.myCellularVoyageStructure.myVoyage.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA), 
				false, theLocationController);
		endif;
	endif;

epilog
	
end;</source>
        <Parameter name="pTI" type="CM_TrackedItem"/>
        <Parameter name="_confirmDelete" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteTIDamage" id="b668810b-3bdf-4c92-93ca-60227e624cab">
        <source>utlDeleteTIDamage(_damageObj:CM_DamageInstance io; _passportObj:CM_Passport input);
// --------------------------------------------------------------------------------
// Created:		18 June 2008 by cnwdad1
//
// Purpose:		Deletes the specified TI Damage Instance object.
//
// Parameters:	_damageObj - A reference to the object to delete.
//				_passportObj - A reference to the session passport object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	app.myValDA.valTIDamage(_damageObj);
	
	if (not self.checkValidationWithPassport(_passportObj)) then // Show any Errors and Warnings in a list.
		return;
	endif;

	app.setContinueCMExceptions(false);

	if _passportObj.noErrors() then
		self.myDeleteAuditAgent.audDeleteGeneric(_damageObj);
	endif;

	if _passportObj.noErrors() then
		_damageObj.erase(NORMAL_ERASE);
	endif;
end;</source>
        <Parameter name="_damageObj" type="CM_DamageInstance" usage="io"/>
        <Parameter name="_passportObj" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteTIMaster" id="e37287c8-c207-4179-b500-732a6a68eeb1">
        <source>utlDeleteTIMaster(_tiMasterCont : CM_TIMaster io; _passportObj:CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 September 2008	cnwrd1	Initial creation

*/

vars

begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	app.myValDA.valTIMaster(_tiMasterCont);
	
	if (not self.checkValidationWithPassport(_passportObj)) then // Show any Errors and Warnings in a list.
		return;
	endif;

	app.setContinueCMExceptions(false);

	if _passportObj.noErrors() then
		self.myDeleteAuditAgent.audDeleteGeneric(_tiMasterCont);
	endif;

	if _passportObj.noErrors() then
		_tiMasterCont.erase(NORMAL_ERASE);
	endif;
epilog

end;
</source>
        <Parameter name="_tiMasterCont" type="CM_TIMaster" usage="io"/>
        <Parameter name="_passportObj" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteTITba" id="48381fd1-a17f-4400-ba2d-c1b2455e881d">
        <source>utlDeleteTITba(pTI : CM_TrackedItem; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		October  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	toDelete	: CM_TrackedItem;
	tmpEvent	: Integer;

begin

	self.initialiseActivity();

	toDelete := pTI;

	if not self.exclusiveLockObjectToDelete(toDelete) then
	    // toDelete is null, invalid or has already been deleted
	    return;
	endif;

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(toDelete);
	endif;
	
	if _passport.noErrors then
		// Issue notifications of delete of object (note this is done BEFORE the
		// delete as the object is gone after the delete)
		toDelete.breakTBAMatch();
		if _passport.noErrors then
			if toDelete.state = TI_STATE_NOTIFIED and toDelete.myTerminal &lt;&gt; null then
				tmpEvent := toDelete.myTerminal.getTerminalEvent(TIEvent_PreNote_Delete);
				toDelete.causeEvent(tmpEvent, false, null);
			endif;
			
			toDelete.erase(NORMAL_ERASE);
		endif;
	endif;

epilog
	return;
	
end;</source>
        <Parameter name="pTI" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteTITransaction" id="6a7d5ba1-5658-4e84-ac6b-7f53dc9c3179">
        <updating/>
        <source>utlDeleteTITransaction(_txn : CM_TITransaction input; 
						_reason: String;
						_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     25 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

	theTI : CM_TrackedItem;
begin

	self.initialiseActivity();
	//no validation required for delete at this stage
	app.setContinueCMExceptions(false);

	if not app.isGarbageCollectionProcess then								// 3/12/18 MAP TFS42307
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(_txn, true);	// 15/10/18 MAP TFS41191
	endif;

	theTI := _txn.myTrackedItem;
	theTI.deleteTransaction(_txn, _reason, _passport);						// 12/10/18 MAP TFS41191
	
	if not app.isGarbageCollectionProcess then								// 3/12/18 MAP TFS42307
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(_txn, false);	// 15/10/18 MAP TFS41191
	endif;
end;</source>
        <Parameter name="_txn" type="CM_TITransaction" usage="input"/>
        <Parameter name="_reason" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
