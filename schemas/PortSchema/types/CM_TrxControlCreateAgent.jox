    <JadeMethod name="trxCreateInvoiceForSplitLines" id="9116acc7-1848-495d-99ae-87f8fcf909a5">
        <updating/>
        <source>trxCreateInvoiceForSplitLines(	pCopyInvoice : CM_Invoice input;
								pNewInvoice : CM_Invoice output;
								_controller : CMIF_InvoiceLineMove input;
								_passport : CM_Passport input
								) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 Decemeber 2012	cnwndl1	Initial creation	Par 30685
22 July 2019		cnwma1	ChangeRequest 45577: ASPA - JMT Interface to AR Oracle
26 April 2023	navmk20	Bug 57663: EUP - Incorrect Statuses Available when copying an invoice
23 May 2023 navtnr20 	Bug 58089: FR | EUP 54086 - Invoicing - Maintenance Enhancements - 070.b
14/08/2023	navkc1	Bug 59803: FR | EUP 53978 - Invoicing - Configuration Enhancements - Invoice Update - missing items
*/
vars

	pxyInvoice : CM_Invoice;
	termOfTrade: CM_InvoiceTermsOfTrade;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	termOfTrade := app.myRoot.myRootCompany.allInvoiceTermsOfTrade[pCopyInvoice.termsOfTradeCode]; //14/08/2023	navkc1	Bug 59803
	
	create pxyInvoice transient;
	pxyInvoice.setProxyForCreate(	pCopyInvoice.bank,					//_theBank			: CM_Bank; 
									pCopyInvoice.debtor,				//_theDebtor		: CM_Debtor; 
									pCopyInvoice.myBillingAddress,		//22.07.2019 cnwma1 TFS #45577
									pCopyInvoice.myVoyage,				//_theVoyage		: CM_Voyage; 
									pCopyInvoice.invoiceType,			//_theType			: CM_InvoiceDesc; 
									//false,							//_isStatusSuspense	: Boolean; // 26.4.2023 navmk20 TFS 57663
									CM_Invoice.INVOICE_PENDING, 		//_invoiceStatus 	: String	// 26.4.2023 navmk20 TFS 57663
									pCopyInvoice.isManual,				//_isManual			: Boolean;
									pCopyInvoice.myTrackedItem,			//_ti				: CM_TrackedItem
									pCopyInvoice.myBOL,					//_bol				: CM_BOL			// ### TFS 54565 (54384) 03Oct2022 NAVPW1
									pCopyInvoice.myBookingRef,			//_booking			: CM_BookingRef		// ### TFS 54565 (54384) 03Oct2022 NAVPW1
									pCopyInvoice.myCargoGroup,			//_cargoGroup		: CM_CargoGroup		// ### TFS 54565 (54384) 03Oct2022 NAVPW1
									pCopyInvoice.myReleaseRequest,		//_releaseRequest	: CM_BulkRelease	// ### TFS 54565 (54384) 03Oct2022 NAVPW1
									pCopyInvoice.category,
									pCopyInvoice.purchaseOrderNumber,  // ### BUG 56925 07MAR2023 NAVAB1
									pCopyInvoice.bank.myInvoiceProcess,	// 26.4.2023 navmk20 TFS 57663
									pCopyInvoice.allWorkOrders,	//navtnr20 23-05-2023 BUG 58089
									pCopyInvoice.narration,	//14/08/2023	navkc1	Bug 59803
									termOfTrade,
									pCopyInvoice.debtorReference,	//14/08/2023	navkc1	Bug 59803
									pCopyInvoice.myCurrencyType,	//14/08/2023	navkc1	Bug 59803
									pCopyInvoice.myLocale,			//14/08/2023	navkc1	Bug 59803
									pCopyInvoice.myAlternativeAddress//14/08/2023	navkc1	Bug 59803
									);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	// Perform the operation
	app.myUtilityCA.utlCreateInvoiceManual(pxyInvoice, pNewInvoice, _passport);
	
	if app.myPassport.hasErrors then
		return;
	endif;
	
	_controller.myInvoice := pNewInvoice;
	app.myUtilityUA.utlUpdateInvoiceLineMove( _controller, _passport);
	
	if app.myPassport.hasErrors then
		return;
	endif;
	
	app.myUtilityUA.utlUpdateInvoiceSplitDetails( pCopyInvoice, pNewInvoice, _passport);
	
epilog
	delete pxyInvoice;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="pCopyInvoice" type="CM_Invoice" usage="input"/>
        <Parameter name="pNewInvoice" type="CM_Invoice" usage="output"/>
        <Parameter name="_controller" type="CMIF_InvoiceLineMove" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
