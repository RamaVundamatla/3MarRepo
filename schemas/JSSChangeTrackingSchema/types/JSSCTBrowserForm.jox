        <updating/>
        <source>cmbChangeClasses_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
/*
*/
begin
	return (obj.JSSCTChangeTrackingClass.className);
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
