    <JadeMethod name="mpdTestEmail" id="6183f731-5a5f-4d05-ba4b-c7d1f267d04f">
        <source>mpdTestEmail();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
03 February 2023	navmd1	Initial creation

*/

vars
	request					: BGP_EmailSendRequest;
	previousValues			: CM_AssociationDict;
	temp					: String;
	agent					: CMIF_EmailArchitect;
begin
	app.initialize();
	app.myPassport.setMyUserFromCode("NAVMD1");
	app.myPassport.setMyTerminal(app.myRoot.allTerminals["MPD"]);
	app.changeLogLevel(LogTRACE);
	
	create agent transient;
	
	// Remember to add any new config changes to the epilog too!
	create previousValues transient;
	previousValues.addAssoc(AutoEmailSoftware, app.myRoot.getConfig(AutoEmailSoftware).Integer);
	previousValues.addAssoc(EmailLicenseType, app.myRoot.getConfig(EmailLicenseType).Integer);
	previousValues.addAssoc(AutoOutwardAccount, app.myRoot.getConfig(AutoOutwardAccount).String);
	previousValues.addAssoc(AutoOutwardPassword, app.myRoot.getConfig(AutoOutwardPassword).String);
	previousValues.addAssoc(AutoSendersEmailAddress, app.myRoot.getConfig(AutoSendersEmailAddress).String);
	previousValues.addAssoc(AutoSmtpServer, app.myRoot.getConfig(AutoSmtpServer).String);
	previousValues.addAssoc(AutoSmtpServerPort, app.myRoot.getConfig(AutoSmtpServerPort).String);
	previousValues.addAssoc(AutoInwardSSLUsage, app.myRoot.getConfig(AutoInwardSSLUsage).Integer);
	previousValues.addAssoc(AutoAuthType, app.myRoot.getConfig(AutoAuthType).Integer);
	
	
	// Via BGP
//	app.myTrxCA.trxCreateEmailSendRequest("Masons Test Email Alert", "mason.drew@navis.com", app.myRoot.getConfig(AutoSendersEmailAddress).String,
//	 null, null, "Test Email", "This is a test message.", null, null, null, null, EmailSource_System, null, app.myPassport);
	 
	// Directly via EA POP/IMAP TLS
	/*beginTransaction;
	app.myRoot.setConfig(AutoEmailSoftware, 3, false);	// EmailArchitect
	app.myRoot.setConfig(EmailLicenseType, EmailLicenseType_3, false);
	app.myRoot.setConfig(AutoOutwardAccount, "mdrew@mtn.navis.com", false);
	app.myRoot.setConfig(AutoOutwardPassword, app.pwEnCode("qzhjgjhzmkcmqhxp"), false);		// This is an "App Passowrd"
	app.myRoot.setConfig(AutoSendersEmailAddress, "JadescriptMPD@jadeworld.com", false);
	app.myRoot.setConfig(AutoSmtpServer, "smtp.outlook.com", false);						// However, this still doesn't work. [Message: 535 5.7.139 Authentication unsuccessful, SmtpClientAuthentication is disabled for the Tenant. Visit https://aka.ms/smtp_auth_disabled for more information.]
	app.myRoot.setConfig(AutoSmtpServerPort, "587", false);
	app.myRoot.setConfig(AutoInwardSSLUsage, BGP_EmailSendRequest.SSL_STARTTLS, false);
	app.myRoot.setConfig(AutoAuthType, BGP_EmailSendRequest.AUTH_NONE, false);
	commitTransaction;
	
	temp := "Pause...";
	//read temp;
	
	 create request transient;
	 request.setEmailRequest(null, null, "mason.drew@kaleris.com", null, "mdrew@mtn.navis.com", "mason.drew@page81.net", "Testing email send", "Hello World!", app.getMyUser(), app.myPassport.getMyTerminal(), null, null, null, null, EmailSource_System);
	 request.sendMsgWithParams(BGP_EmailSendRequest::sendEATls.name, agent);
	
	if app.myPassport.hasErrorsOrWarnings then
		app.myPassport.inspectModal;
	endif;*/

	// Directly via EA OAuth EWS
	beginTransaction;
	app.myRoot.setConfig(AutoEmailSoftware, 4, false);	// OAuth
	app.myRoot.setConfig(AutoOutwardAccount, "mdrew@mtn.navis.com", false);
	app.myRoot.setConfig(AutoSendersEmailAddress, "mdrew@mtn.navis.com", false);
	app.myRoot.setConfig(AutoSmtpServer, "smtp.office365.com", false);
	commitTransaction;
	 
	create request transient;
	request.setEmailRequest(null, null, "mason.drew@kaleris.com;mdrew@mtn.navis.com;mason.drew@page81.net", null, "", "", "Testing email send", "Hello World!", app.getMyUser(), app.myPassport.myTerminal, null, null, null, null, EmailSource_System);
	request.sendMsgWithParams(BGP_EmailSendRequest::sendOAuth.name, agent);
	
	if app.myPassport.hasErrorsOrWarnings then
		app.myPassport.inspectModal;
	endif;
	 
epilog
	if previousValues &lt;&gt; null then
		beginTransaction;
			app.myRoot.setConfig(AutoEmailSoftware, previousValues.int(AutoEmailSoftware), false);
			app.myRoot.setConfig(EmailLicenseType, previousValues.int(EmailLicenseType), false);
			app.myRoot.setConfig(AutoOutwardAccount, previousValues.str(AutoOutwardAccount), false);
			app.myRoot.setConfig(AutoOutwardPassword, previousValues.str(AutoOutwardPassword), false);
			app.myRoot.setConfig(AutoSendersEmailAddress, previousValues.str(AutoSendersEmailAddress), false);
			app.myRoot.setConfig(AutoSmtpServer, previousValues.str(AutoSmtpServer), false);
			app.myRoot.setConfig(AutoSmtpServerPort, previousValues.str(AutoSmtpServerPort), false);
			app.myRoot.setConfig(AutoInwardSSLUsage, previousValues.int(AutoInwardSSLUsage), false);
			app.myRoot.setConfig(AutoAuthType, previousValues.int(AutoAuthType), false);
		commitTransaction;
		previousValues.purge();
	endif;

	delete request;
	delete agent;
end;
</source>
    </JadeMethod>
