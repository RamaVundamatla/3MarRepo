    <JadeMethod name="setDetailsOnCMIF" id="897d0327-4224-422c-8c64-06f3b7576189">
        <source>setDetailsOnCMIF(_cmifDebtor : CMIF_DebtorNode input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 14/04/2022	navdap1		Initial creation TFS 53362 EUP Master Data interface customers between TOS and ERP
// 04/08/2022	jlizm1		TFS 54039 EUP Extra Fields For Customer Data Interface
//
vars

begin
	_cmifDebtor.longName := self.legalEntityName;
	_cmifDebtor.code := self.ptyCode;
	_cmifDebtor.name := self.ptyName;
	_cmifDebtor.additionalInformation1 := self.custAccSiteContactEmail;
	_cmifDebtor.badDebtor := self.badCredit;	// TFS 54039
	_cmifDebtor.isSuspended := self.suspended;	// TFS 54039
	
	// address
	if self.ptySiteAddressLine1 &lt;&gt; null then
		_cmifDebtor.billingAddress := self.ptySiteAddressLine1;
	endif;
	if self.ptySiteAddressLine2 &lt;&gt; null then
		if _cmifDebtor.billingAddress = null then
			_cmifDebtor.billingAddress := self.ptySiteAddressLine2;
		else
			_cmifDebtor.billingAddress := _cmifDebtor.billingAddress &amp; CrLf &amp; self.ptySiteAddressLine2;
		endif;
	endif;
	if self.ptySiteAddressLine3 &lt;&gt; null then
		if _cmifDebtor.billingAddress = null then
			_cmifDebtor.billingAddress := self.ptySiteAddressLine3;
		else
			_cmifDebtor.billingAddress := _cmifDebtor.billingAddress &amp; CrLf &amp; self.ptySiteAddressLine3;
		endif;
	endif;
	if self.ptySiteCity &lt;&gt; null then
		if _cmifDebtor.billingAddress = null then
			_cmifDebtor.billingAddress := self.ptySiteCity;
		else
			_cmifDebtor.billingAddress := _cmifDebtor.billingAddress &amp; CrLf &amp; self.ptySiteCity;
		endif;
	endif;
	if self.ptySiteState &lt;&gt; null then
		if _cmifDebtor.billingAddress = null then
			_cmifDebtor.billingAddress := self.ptySiteState;
		else
			_cmifDebtor.billingAddress := _cmifDebtor.billingAddress &amp; CrLf &amp; self.ptySiteState;
		endif;
	endif;
	if self.ptySitePostCode &lt;&gt; null then
		if _cmifDebtor.billingAddress = null then
			_cmifDebtor.billingAddress := self.ptySitePostCode;
		else
			_cmifDebtor.billingAddress := _cmifDebtor.billingAddress &amp; CrLf &amp; self.ptySitePostCode;
		endif;
	endif;
	if self.ptySiteCountry &lt;&gt; null then
		if _cmifDebtor.billingAddress = null then
			_cmifDebtor.billingAddress := self.ptySiteCountry;
		else
			_cmifDebtor.billingAddress := _cmifDebtor.billingAddress &amp; CrLf &amp; self.ptySiteCountry;
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_cmifDebtor" type="CMIF_DebtorNode" usage="input"/>
    </JadeMethod>
</Class>
