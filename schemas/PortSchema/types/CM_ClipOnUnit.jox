    <JadeMethod name="validateAttachedCOU" id="598672f9-4bac-4ae6-819b-2ce17b8edef4">
        <updating/>
        <source>validateAttachedCOU(pControl: CMIF_TIUpdateController) updating;

vars

begin
	self.validateId(pControl);
	self.validateCouType(pControl);
	self.validateISOType(pControl);
end;</source>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
    </JadeMethod>
    <JadeMethod name="validateCouType" id="2e338a24-3c33-42a7-bae2-ee832bc3a2d8">
        <updating/>
        <source>validateCouType(pControl: CMIF_TIUpdateController) updating, protected;

vars

begin

	if pControl.mode = TI_UPDMODE_RECEIPT or
	   pControl.mode = TI_UPDMODE_BOOKINGREF then
		if self.couType &lt;&gt; null then
			if self.couType &lt; COU_TYPE_SHORT or self.couType &gt; COU_TYPE_LAND then
				app.raiseCMException1(ERR_INVALID_COUTYPE, self.couType.String, 'couType', pControl.myUserObject);
			endif;
		else
			// required
		//	app.raiseCMException1(REQUIRED_FIELD, 'COU Type', 'couType', pControl.myUserObject);
			app.raiseCMException(Input_required_field_CouFld, 'couType', pControl.myUserObject); // cnwdb2	PAR 35364
		endif;
	endif;	
end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
    </JadeMethod>
    <JadeMethod name="validateISOType" id="d18c8183-4244-484f-a319-7150a96a388c">
        <source>validateISOType(pControl: CMIF_TIUpdateController) protected;
// ---------------------------------------------------------------------------
// Created:     14 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/12/2014   cnwdb2	    PAR 35364
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(pControl);
	
	if self.isoType = null then
		// ISO Type required.
	//	app.raiseCMException1(REQUIRED_FIELD, 'COU ISO Type', 'isoType', pControl.myUserObject);
		app.raiseCMException(Input_required_field_couISO, 'isoType', pControl.myUserObject); // cnwdb2	PAR 35364
	endif;	

end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
    </JadeMethod>
