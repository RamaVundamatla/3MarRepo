    <JadeMethod name="utlUpdateRailClearRake" id="6246ac67-a0a3-4295-9dc4-ec062353d974">
        <updating/>
        <source>utlUpdateRailClearRake(_cmifRakeRegion : CMIF_RakeRegion input; _passport : CM_Passport input) updating;
//-----------------------------------------
// Created: April 2003 By: cnwgd1
// Date				Who			Reason
// 16 Dec 2013		cnwrs1		Par 33035 - add CamsDateTime to CM_EventTransaction
// 10 Jun 2025		jlizm1		MTN 34547 Clear rake warnings being redisplayed after each wagon
//-----------------------------------------
vars
	trainDepartEvent : CMEVT_TrainTransaction;
	train			 : CM_Train;
	oldWarninsIgnored : Boolean;
	
begin
	oldWarninsIgnored := _passport.warningsIgnored;
	app.setContinueCMExceptions(false);

	train := _cmifRakeRegion.myTrain;
	
	if train &lt;&gt; null then				// Mar 2011 JRE 27148 returned wagon is stopping departure processing
		if not train.isNullTrain then	//10 Dec 2009	NDL	Par 21923
			train.departureProcess( _cmifRakeRegion, trainDepartEvent);	
		endif;
	endif;
	
	// warnings were being raised multiple times, afer each wagon was processed
	// ignore warnings so they can all be collected at checked/acknowledged at the end
	_passport.setWarningsIgnored(true);
	_cmifRakeRegion.clearWagonsFromRake(trainDepartEvent, _passport);
	_passport.setWarningsIgnored(oldWarninsIgnored);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	if trainDepartEvent &lt;&gt; null then	//16 Dec 2013	cnwrs1	Par 33035 - add CamsDateTime to CM_EventTransaction
		trainDepartEvent.setCAMSTimeStamp(app.actualTimeServer);	
	endif;
end;</source>
        <Parameter name="_cmifRakeRegion" type="CMIF_RakeRegion" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRailSettings" id="99e46600-a305-41ea-a096-690bdc7ac811">
        <updating/>
        <source>utlUpdateRailSettings(railSettings : CMIF_RailSettings;	_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     September 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 22/10/2010		cnwdap1			PAR #23794 added Show Release Requests on Rail Load List setting
// 25/07/2022		jlika1			TFS 54050 EUP  - Max Wagon Payload
// ---------------------------------------------------------------------------

vars
	realObject		: CM_TrxTestObject;
	expectedEdition	: Integer;

begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);//cnwas3 par 22983
	
	app.myValUA.valRailSettings(railSettings);
	
	if _passport.hasErrors then
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(railSettings.myTerminal, true);
	endif;
		
	app.setContinueCMExceptions(false);		//cnwas3 par 22983 end
	
	// ### CONFIGURATION
	railSettings.myTerminal.setConfig(TrainAutoNumber, railSettings.trainAutoNumber);
	railSettings.myTerminal.setConfig(TrainAutoNumberPrefix, railSettings.trainAutoNumberPrefix);
	railSettings.myTerminal.setConfig(RailPostDepartVisHrs, railSettings.railPostDepartVisHrs);	// 05 Nov 2009	NDL	Par 21519
	railSettings.myTerminal.setConfig(TrainManifestReportIn, railSettings.trainManifestReportIn);
	railSettings.myTerminal.setConfig(TrainManifestReportOut, railSettings.trainManifestReportOut);
	railSettings.myTerminal.setConfig(UseOutwardRailConfirm, railSettings.useOutwardRailConfirm);
	railSettings.myTerminal.setConfig(RailNoTwinLiftMoves, railSettings.noTLMovesToWagons);
	railSettings.myTerminal.setConfig(DefRailOpsArea, railSettings.defRailOpsArea);//par 20917 begin
	railSettings.myTerminal.setConfig(DefRailCarrier, railSettings.defRailCarrier);
	railSettings.myTerminal.setConfig(DefWagonClass, railSettings.defWagonClass);//par 20917 end
	railSettings.myTerminal.setConfig(CustomsEDIonTrain, railSettings.customsEDIonTrain);	//01 Dec 2009	NDL Par 21519
	railSettings.myTerminal.setConfig(AllowWagonWeightsToBeUpd, railSettings.allowWagonWeightsToBeUpd);
	railSettings.myTerminal.setConfig(RaiseErrorMaxLoadWeight, railSettings.raiseErrorMaxLoadWeight);
	
	//16 Apr 2010	NDL	Par 23787
	railSettings.myTerminal.setConfig(RailHHAlwaysCargoFullID, railSettings.hHAlwaysCargoFullID);
	railSettings.myTerminal.setConfig(RailHHCargoMustPrenote, railSettings.hHCargoMustPrenote);
	railSettings.myTerminal.setConfig(RailHHWarnPrenoteHazDiffer, railSettings.hHWarnPrenoteHazDiffer);
	railSettings.myTerminal.setConfig(RailHHAlwaysWagonFullID, railSettings.hHAlwaysWagonFullID);
	railSettings.myTerminal.setConfig(RailHHWagonUseReversedID, railSettings.hHWagonUseReversedID);
	
	// PAR #23794
	railSettings.myTerminal.setConfig(ShowRelReqOnRailLoadList, railSettings.showRelReqOnRailLoadList);
	railSettings.myTerminal.setConfig(RailDisallowOutwardQueue, railSettings.railDisallowOutwardQueue); // PAR 25526
	
	railSettings.myTerminal.setConfig(RailTrackClearErr, railSettings.railTrackClearErr);// 24 Nov 2010	NDL	Par 23883
	railSettings.myTerminal.setConfig(RailAutoSwitch, railSettings.railAutoSwitch);// 25 Nov 2010	NDL	Par 25422
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(railSettings.myTerminal, false);
	endif;


end;</source>
        <Parameter name="railSettings" type="CMIF_RailSettings"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRateEntry" id="5b24ad50-3765-46ac-987b-d4047d797ab6">
        <source>utlUpdateRateEntry(_proxyRateEntry:CM_RateEntry; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 03/07/2018	jlgmd1	TFS 38937 - STWO Performance changes
// 09 Dec 2025 	navhl20 Bug MTN-35943: POL - Importing Rates from CSV takes too long
vars
	realRateEntry:CM_RateEntry;
	childRate:CM_RateEntry;
	expectedEdition:Integer;
	codeChanged:Boolean;
	eventStr : String;
	theTerminal : CM_Terminal;
	
begin

	self.initialiseActivity();

	_proxyRateEntry.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxyRateEntry.pxyGetRealObjectAndEdition(realRateEntry, expectedEdition);
	
	if realRateEntry = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_RateEntry.name, null, null);
		return;
	endif;

	app.myValUA.valRateEntry( _proxyRateEntry);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realRateEntry);

	if _passport.noErrors and realRateEntry.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'RateEntry', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realRateEntry, true);
	endif;
	
	if _passport.noErrors then
		realRateEntry.setForUpdate(_proxyRateEntry);
		if _passport.noErrors then
			_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_RATEENTRY_UPDATE),false,realRateEntry);
			
			//18 Sep 2012	NDL	Par 30375
			foreach childRate in realRateEntry.rate.allDerivedRateEntries do
				_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_RATEENTRY_UPDATE),false,childRate);
			endforeach;
			
			if realRateEntry.startTimestamp &lt; app.actualTimeAppServer then				//09.12.2025 navhl20 #35943
				realRateEntry.rate.updateCharges(realRateEntry.getMyDebtorNode);		// CCMS 1264
			endif;
		endif;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realRateEntry, false);
	endif;

end;</source>
        <Parameter name="_proxyRateEntry" type="CM_RateEntry"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRateEntryCSV" id="8626c40a-9913-41a0-993a-3cd683e0a582">
        <source>utlUpdateRateEntryCSV(_bank : CM_Bank; _allFileRows:ObjectArray; _passportObj:CM_Passport input);
// --------------------------------------------------------------------------------
// Created:		11 December 2008 by cnwdad1
//
// Purpose:		Updates multiple Rate Entries that have been read from a CSV file
//				(in the same format as the Rate Table extract).
//
// Parameters:	_allFileRows - An object array of file rows (each one being a HugeStringArray).
//				_passportObj - A reference to the current user's Passport object.
//				_bank	added 35872 
//
// Returns:		Nothing
//
//				NOTE: The last item in _allFileRows array has to be the row number
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//	May 2010	cnwjre1		23582 add expiry date 
// 16/10/2012	cnwmh5		#30549 - Change the order of the last 3 items (columnCount = 15).  rowNum needs to be last item
//  27/03/2024	jlika1		TFS 56073 56072 | MTN - Rate Table CSV Upload
// 10 Jan 2025  navrv30 JIRA 19179 and JIRA 33230 MTN - User can inadvertently fix debtor rates/expiry dates
//												  MTN - Export/Import of Rate table not as expected
// 11 Dec 2025 	navhl20 Bug MTN-35943: POL - Importing Rates from CSV takes too long
// --------------------------------------------------------------------------------
vars
	object				: Object;
	allRowFields		: HugeStringArray;
	bankObj				: CM_Bank;
	rootDebtorObj		: CM_DebtorNode;
	debtorObj			: CM_DebtorNode;
	serviceObj			: CM_Service;
	debtorRateObj		: CM_DebtorRate;
	rateEntry,
	rateEntryObj		: CM_RateEntry;
	proxyEntryObj		: CM_RateEntry;
	currentRateObj		: CM_RateEntry;
	effectiveTS			: TimeStamp;
	expiryTS			: TimeStamp;
	costPerUnitLabels	: StringArray;
	cpuPointer			: Integer;
	userObj				: CM_User;
	userCode			: String;
	columnCount			: Integer;
	createCount			: Integer;
	updateCount			: Integer;
	
	// The following are the file field values.
	
	rowType				: String;
	debtorName			: String;
	debtorCode			: String;
	override			: String;
	serviceName			: String;
	effectiveDate		: Date;
	effectiveTime		: Time;
	expiryDate			: Date;
	expiryTime			: Time;
	cpuName				: String;
	tempName			: String;
	costPerUnit			: Real;
	glCode				: String;
	rowNum				: String;
	adjustToBase		: Real;
	percentOfBase		: Real;
	adjustToBaseDecimal	: Decimal [12,6];
	percentOfBaseDecimal: Decimal [8,4];
	parentRateEntryObj	: CM_RateEntry;
	rootDebtorGroup : CM_RootDebtorGroup;
	
	// 17/10/2012 cnwmh5 #30549
	debtorCodeNameServiceName : String;
	combinedDbtCodeNameServName : String;
	originalCostPerUnit	: Real;
	
	calculationType : CM_CalculationType;	//29 Jun 2018	NDL	TFS 39338
	calcType : Integer;	//29 Jun 2018	NDL	TFS 39338
	subTerm : CM_SubTerminal;	//29 Jun 2018	NDL	TFS 39338
	tidalClass : HMS_TidalClass;	//29 Jun 2018	NDL	TFS 39338
	obj : CM_Object;	//29 Jun 2018	NDL	TFS 39338
	objType : String;
	
begin
	self.initialiseActivity();
	
	createCount		:=	0;
	updateCount		:=	0;
	userObj			:=	app.getMyUser();
	userCode		:=	userObj.code;
	bankObj			:=	_bank;
	rootDebtorObj	:=	bankObj.rootDebtorGroup;
	create costPerUnitLabels transient;
	
	foreach object in _allFileRows do
		allRowFields	:=	object.HugeStringArray;
		columnCount := allRowFields.size;
		// Get the field values.
		
		rowType			:=	allRowFields[1];
		debtorName		:=	allRowFields[2];
		debtorCode		:=	allRowFields[3];
		override		:=	allRowFields[4];
		serviceName		:=	allRowFields[5];
		combinedDbtCodeNameServName := debtorCode &amp; debtorName &amp; serviceName;
		effectiveDate	:=	allRowFields[6].Date;
		effectiveTime	:=	allRowFields[7].Time;
		// 23582 added expiry date/time
		if columnCount = 15 then
			// 18 Sep 2012	NDL	Par 30375
			expiryDate	:=	allRowFields[8].Date;
			expiryTime	:=	allRowFields[9].Time;
			cpuName			:=	allRowFields[10]; // this is allowed to be null, multi line rates (there are 2 HMS invoice rates that allow 2 or more rates, a populated cpuName = multiline rate)
			costPerUnit		:=	allRowFields[11].Real;		// *** Leave as a cast - no English users will be importing their own formatted data ***
			glCode			:=	allRowFields[12];
			adjustToBase	:=	allRowFields[13].Real;		
			percentOfBase	:=	allRowFields[14].Real;
			rowNum			:=	allRowFields[15];				// NOTE: This has to be the last item in _allFileRows array 
			
			adjustToBaseDecimal	:= adjustToBase.Decimal;
			percentOfBaseDecimal := percentOfBase.Decimal;
		elseif columnCount = 16 then         //10 Jan 2025 navrv30 JIRA 19179 and JIRA 33230
			// 18 Sep 2012	NDL	Par 30375
			expiryDate	:=	allRowFields[8].Date;
			expiryTime	:=	allRowFields[9].Time;
			cpuName			:=	allRowFields[10]; // this is allowed to be null, multi line rates (there are 2 HMS invoice rates that allow 2 or more rates, a populated cpuName = multiline rate)
			costPerUnit		:=	allRowFields[11].Real;		// *** Leave as a cast - no English users will be importing their own formatted data ***
			glCode			:=	allRowFields[12];
			adjustToBase	:=	allRowFields[13].Real;		
			percentOfBase	:=	allRowFields[14].Real;
			objType	:=	allRowFields[15];
			rowNum			:=	allRowFields[16];				// NOTE: This has to be the last item in _allFileRows array 
			
			adjustToBaseDecimal	:= adjustToBase.Decimal;
			percentOfBaseDecimal := percentOfBase.Decimal;
		elseif columnCount = 13 then
			expiryDate	:=	allRowFields[8].Date;
			expiryTime	:=	allRowFields[9].Time;
			cpuName			:=	allRowFields[10]; // this is allowed to be null, multi line rates (there are 2 HMS invoice rates that allow 2 or more rates, a populated cpuName = multiline rate)
			costPerUnit		:=	allRowFields[11].Real;		// *** Leave as a cast - no English users will be importing their own formatted data ***
			glCode			:=	allRowFields[12];
			rowNum			:=	allRowFields[13];				// NOTE: This has to be the last item in _allFileRows array 
		else
			expiryDate		:= null;
			expiryTime 		:= null;
			cpuName			:=	allRowFields[8]; // this is allowed to be null, multi line rates (there are 2 HMS invoice rates that allow 2 or more rates, a populated cpuName = multiline rate)
			costPerUnit		:=	allRowFields[9].Real;		// *** Leave as a cast - no English users will be importing their own formatted data ***
			glCode			:=	allRowFields[10];
			rowNum			:=	allRowFields[11];				// NOTE: This has to be the last item in _allFileRows array 
		endif;
		
		effectiveTS.setDate(effectiveDate);
		effectiveTS.setTime(effectiveTime);
		expiryTS.setDate(expiryDate);
		expiryTS.setTime(expiryTime);
		
		// 17/10/2012 cnwmh5 #30549
		// setup the originalCostPerUnit
		if debtorCodeNameServiceName = null or debtorCodeNameServiceName &lt;&gt; combinedDbtCodeNameServName then
			debtorCodeNameServiceName := combinedDbtCodeNameServName;
			originalCostPerUnit := costPerUnit;
		endif;
		
		// Now process the data.
		
		//if costPerUnit &gt; 999999.999999 then
		if costPerUnit &gt; 9999999999.999999 then	//21 May 2018	NDL	TFS 38528
			app.raiseCMException1(	Cost_Per_Unit_Too_Large,
									rowNum,
									null,
									null);
		endif;
		
		// Get the Debtor and Service.
		
		debtorObj	:=	rootDebtorObj.allChildDebtorNodes[debtorName];
		
		if debtorObj = null then
			debtorObj	:=	app.myRoot.myRootCompany.debtorNodes[debtorName];
		endif;
		
		if debtorObj = null then
			app.raiseCMException2(	Debtor_Not_Found,
									debtorName,
									rowNum,
									null,
									null);
			return;
		endif;
		
		if rootDebtorGroup = null then
			rootDebtorGroup := debtorObj.bank.getRootDebtorGroup;
		endif;
		
		serviceObj		:=	bankObj.services[serviceName];
		
		if serviceObj = null then
			app.raiseCMException2(	Service_Not_Found,
									serviceName,
									rowNum,
									null,
									null);
			return;
		endif;
		
		//29 Jun 2018	NDL	TFS 39338
		calculationType := serviceObj.myCalculationType;
		if calculationType &lt;&gt; null then
			calcType := calculationType.calculationType;
		endif;
		
		// Now check whether the rate has to be changed.  If not, do nothing.
		
		currentRateObj	:=	null;
		// 23055 getServiceTimeRate got the rate effective at this time, but for correct maintenance we want
		//  the entry if any with the actual effective date
		//currentRateObj	:=	debtorObj.getServiceTimeRate(serviceObj, effectiveTS);
		currentRateObj := debtorObj.getServiceRateAtTime(serviceObj, effectiveTS);
		if objType[1] = 'D' and currentRateObj &lt;&gt; null and currentRateObj.getRawCostPerUnit = costPerUnit then    //10 Jan 2025 navrv30 JIRA 19179 and JIRA 33230	//11.12.2025 navhl20 #35943
			continue;
		endif;
		
		costPerUnitLabels.clear();
		cpuPointer	:=	0;
		
		if currentRateObj &lt;&gt; null then
			if cpuName = null then
				//I do believe we need to check other fields too not just the costPerUnit jlika1 TFS 56073
				if columnCount = 15 then
					if currentRateObj.getRawCostPerUnit = costPerUnit 
						and currentRateObj.expiryTimestamp = expiryTS 
						and currentRateObj.adjustmentToBase = adjustToBaseDecimal
						and currentRateObj.percentageOfBase = percentOfBaseDecimal 
						then
							continue;
					endif;						
				else 
					if currentRateObj.getRawCostPerUnit = costPerUnit 
					and currentRateObj.expiryTimestamp = expiryTS 
					then
						continue;
					endif;
				endif;
				cpuPointer := 1;	// 23055, single-line rates can also have an entry in allCostPerUnits
			else
				// This is one line of a multi-line Rate Table, so find out which line to update
				// based upon the line's Cost Per Unit label.
				currentRateObj.getCostPerUnitLabels(costPerUnitLabels);
				
				if calcType = INV_CALC_TYPE_DAYSINCE_SUBTERM or calcType = INV_CALC_TYPE_TIDAL_CLASS then	//29 Jun 2018	NDL	TFS 39338
					
					cpuPointer	:=	costPerUnitLabels.indexOf(cpuName);
					
					if cpuPointer = 0 then
						app.raiseCMException4(	Cost_Per_Unit_Label_Not_Found,
												cpuName,
												debtorName,
												serviceName,
												rowNum,
												null,
												null);
						return;
					endif;
					
					if calcType = INV_CALC_TYPE_DAYSINCE_SUBTERM then	
						obj := currentRateObj.getMyTerminal.allSubTerminals.getMatchingDesc( cpuName );
					elseif calcType = INV_CALC_TYPE_TIDAL_CLASS then	
						obj := app.myRoot.allTidalClasses.getMatchingDesc( cpuName );
					endif;
					
					if obj = null then
						app.raiseCMException4(	Cost_Per_Unit_Not_Found,
												cpuName,
												debtorName,
												serviceName,
												rowNum,
												null,
												null);
						return;
					endif;
					
					if currentRateObj.getCPUforObject( obj ) = costPerUnit then
						continue;
					endif;
						
				elseif costPerUnitLabels.size() = 1 and currentRateObj.allCostPerUnits.isEmpty() then
					if currentRateObj.getRawCostPerUnit = costPerUnit then
						continue;
					endif;
					
				else
					cpuPointer	:=	costPerUnitLabels.indexOf(cpuName);
					
					//07 Jun 2019	NDL	TFS 45010
					while currentRateObj.allCostPerUnits.size() &lt; cpuPointer  do
						// converting an existing rate from single cpu rate to multiple rate, i.e. Ramp, or Movement
						currentRateObj.allCostPerUnits.add(0.0);
					endwhile;
										
					if cpuPointer = 0 then
						app.raiseCMException4(	Cost_Per_Unit_Label_Not_Found,
												cpuName,
												debtorName,
												serviceName,
												rowNum,
												null,
												null);
						return;
						
					elseif currentRateObj.allCostPerUnits.size() &lt; cpuPointer then
						app.raiseCMException4(	Cost_Per_Unit_Not_Found,
												cpuName,
												debtorName,
												serviceName,
												rowNum,
												null,
												null); 
						
						return;
					endif;
					
					if currentRateObj.allCostPerUnits[cpuPointer] = costPerUnit then
						continue;
					endif;
				endif;
			endif;
		else
			app.writeStatement("Current Rate Entry for " &amp; debtorName &amp; "/" &amp; serviceName &amp; " of '" &amp; costPerUnit.numberFormat() &amp; ".");
		endif;
		
		// 23055 skip file entries with no rate 
		if currentRateObj = null and costPerUnit = 0 then
			continue;
		endif;
		
		// Now change the rate by updating an existing one, or create a new one.
		
		debtorRateObj	:=	serviceObj.debtorNodeRates[debtorObj];
		
		//18 Sep 2012	NDL	Par 30375
		if ( adjustToBaseDecimal &lt;&gt; 0 or percentOfBaseDecimal &lt;&gt; 0 ) and debtorObj &lt;&gt; rootDebtorGroup then
			parentRateEntryObj := rootDebtorGroup.getServiceTimeRate( serviceObj, effectiveTS );
		else
			parentRateEntryObj := null;
		endif;
		
		if debtorRateObj = null then
			create debtorRateObj transient;
			debtorRateObj.setProxy(serviceObj, debtorObj);
		else
			// PAR 18650 rateEntryObj	:=	debtorRateObj.rateEntries[effectiveTS]; 
			rateEntryObj := currentRateObj; // PAR 18650 
		endif;
		
	//	if rateEntryObj = null then
		if rateEntryObj = null or ( rateEntryObj.rate.isKindOf(CM_DebtorRate) and rateEntryObj.rate.CM_DebtorRate.debtorNode &lt;&gt; debtorObj) then // 26 Sep 2019	NDL	TFS 46727 - We didn't find one OR its for a different debtor
			// 36490 delete the default rate for the root debtor if applicable
			if debtorObj = rootDebtorObj then
				foreach rateEntry in debtorRateObj.rateEntries do
					if effectiveTS &lt; rateEntry.createdTime then
						if rateEntry.createdTime = serviceObj.createdTime then
							delete rateEntry;
							break;
						endif;
					endif;
				endforeach;
			endif;

			create proxyEntryObj transient;
			
			//proxyEntryObj.setProxyFromCSV(cpuPointer, costPerUnit, debtorRateObj, userCode, effectiveTS, expiryTS, adjustToBaseDecimal, percentOfBaseDecimal,  parentRateEntryObj );
			proxyEntryObj.setProxyFromCSV(cpuPointer, costPerUnit, originalCostPerUnit, debtorRateObj, userCode, effectiveTS, expiryTS, adjustToBaseDecimal, percentOfBaseDecimal,  parentRateEntryObj );  // 17/10/2012 cnwmh5 #30549
			
			costPerUnitLabels.clear();
			proxyEntryObj.getCostPerUnitLabels(costPerUnitLabels);
			
			// PAR 22074 WAS if costPerUnitLabels.size() &gt; 0 then
			// PAR 22074 NOW from here 
			if costPerUnitLabels.size() = 1 then // PAR 22074 // ordinary single line rate
				cpuPointer := 1;
				proxyEntryObj.allCostPerUnits[1]	:=	costPerUnit;// PAR 22074 // ordinary single line rate
			
			elseif costPerUnitLabels.size() &gt; 1 then
			// PAR 22074 NOW to here 
				cpuPointer	:=	0;
				
				foreach tempName in costPerUnitLabels do
					cpuPointer	:=	cpuPointer + 1;
					
					if tempName = cpuName then
						proxyEntryObj.allCostPerUnits[cpuPointer]	:=	costPerUnit;
					else
						proxyEntryObj.allCostPerUnits[cpuPointer]	:=	0;
					endif;
				endforeach;
			endif;
			
			app.myUtilityCA.utlCreateRateEntry(proxyEntryObj, rateEntryObj, _passportObj);
			createCount	:=	createCount + 1;
			app.writeStatement("Created Rate Entry for " &amp; debtorName &amp; "/" &amp; serviceName &amp; " of '" &amp; costPerUnit.numberFormat() &amp; ".");
		else
			//if costPerUnit &lt;&gt; rateEntryObj.getRawCostPerUnit then // no need to check again already checked above jlika1 TFS 56073
				proxyEntryObj	:=	app.createUpdateProxy(rateEntryObj).CM_RateEntry;
				//proxyEntryObj.setProxyFromCSV(cpuPointer, costPerUnit, debtorRateObj, userCode, effectiveTS, expiryTS, adjustToBaseDecimal, percentOfBaseDecimal,  parentRateEntryObj );
				proxyEntryObj.setProxyFromCSV(cpuPointer, costPerUnit, originalCostPerUnit, debtorRateObj, userCode, effectiveTS, expiryTS, adjustToBaseDecimal, percentOfBaseDecimal,  parentRateEntryObj );  // 17/10/2012 cnwmh5 #30549
				self.utlUpdateRateEntry(proxyEntryObj, _passportObj);
				updateCount	:=	updateCount + 1;
				app.writeStatement("Updated Rate Entry for " &amp; debtorName &amp; "/" &amp; serviceName &amp; " of '" &amp; costPerUnit.numberFormat() &amp; ".");
			//endif; // no need to check again already checked above jlika1 TFS 56073
		endif;
		
		delete proxyEntryObj;		// We always need to delete this (does nothing if hasn't been created).
		
		if debtorRateObj.isTransient() then
			delete debtorRateObj;	// If we created this, then we need to delete it now.
		endif;
		
		rateEntryObj	:=	null;	// Need to reset this otherwise the next loop may try to update it.
	endforeach;
epilog
	delete proxyEntryObj;
	delete costPerUnitLabels;
	
	app.writeStatement("Created " &amp; createCount.cnEcNumberFormat() &amp; " Rate Tables.");
	app.writeStatement("Updated " &amp; updateCount.cnEcNumberFormat() &amp; " Rate Tables.");
end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_allFileRows" type="ObjectArray"/>
        <Parameter name="_passportObj" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateReEvalFreeStorageDate" id="83f97d84-4d53-4af2-acb0-a25a4cd0749c">
        <updating/>
        <source>utlUpdateReEvalFreeStorageDate(_pxyObject : CM_TrackedItem; _passport : CM_Passport input) updating;
/*
Purpose - 	
Who - NAVAB1
Date - 09OCT2023
ADO - BUG 60548 
28 May 2024 navma1	Bug 64224: MTN - DeadLocks Caused by Future Actors
*/

vars
	realObject		: CM_TrackedItem;
begin

	self.initialiseActivity();
	
	// do any pre-validation locks
	
	// do validation
	self.raiseExceptionIfNull(_pxyObject, 'TrackedItem');

	app.setContinueCMExceptions(true);
	
	if _pxyObject.pxyIsProxy() then
		realObject := self.getRealObjectAndEditionCheck(_pxyObject, 'TrackedItem', _passport).CM_TrackedItem;
	else
		realObject := _pxyObject;
	endif;
	
	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, true);
	endif;

	if _passport.noErrors then
		// do updates
		realObject.evaluateFreeStorageDays(null,true);				//28.05.2024 navma1 #64224
	endif;

	if _passport.noErrors then
		// This is only required if the class is being auditted
		self.myUpdateAuditAgent.audUpdateGeneric(realObject, false);
	endif;

end;</source>
        <Parameter name="_pxyObject" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRealCashRecPayStatus" id="9de5c407-ad53-435a-8e4e-7d37346d7d41">
        <updating/>
        <source>utlUpdateRealCashRecPayStatus( _realCashReceipt : CM_CashReceipt input; _paymentStatus : Integer; _passport : CM_Passport input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 June 2019	jlgndl1	Initial creation	TFS 45312 - Version using REAL object

*/

vars
	
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	if _realCashReceipt = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_CashReceipt.name, null, null);
		return;
	endif;

	if (not self.checkValidationWithPassport(_passport)) then
		return;	
	endif;

	app.setContinueCMExceptions(false);

	exclusiveLock(_realCashReceipt);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_realCashReceipt, true);
	endif;
	if _passport.noErrors then
		_realCashReceipt.setPaymentStatus(_paymentStatus);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_realCashReceipt, false);
		
		// UPDATE THE WORK ORDER ENQUIRY
		if _realCashReceipt.myWorkOrder &lt;&gt; null then // TFS 42401
			self.updateObjectEdition(_realCashReceipt.myWorkOrder); // TFS 42401
		endif;
		
	endif;

epilog
	
	
end;</source>
        <Parameter name="_realCashReceipt" type="CM_CashReceipt" usage="input"/>
        <Parameter name="_paymentStatus" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateRecRestrictionDef" id="d1d6f42e-11e4-4bbb-97b7-1efd2f946b86">
        <updating/>
        <source>utlUpdateRecRestrictionDef(	_pxyRecCutoffDef : CM_ReceivalCutoffTermDef;
							_allTransientCriteriaObj : CMIF_Array;
							_passport : CM_Passport input) updating;

/*
Date		Who		Reason
21 May 2009	cnwar2	Initial creation

*/
vars
	realRecCutoffDef	: CM_ReceivalCutoffTermDef;
	expectedEdition		: Integer;
	
begin
	self.initialiseActivity();

	_pxyRecCutoffDef.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyRecCutoffDef.pxyGetRealObjectAndEdition(realRecCutoffDef, expectedEdition);
	
	if realRecCutoffDef = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_ReceivalCutoffTermDef.name, null, null);
		return;
	endif;

	app.myValUA.valRecRestrictionDef(_pxyRecCutoffDef);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realRecCutoffDef);

	if _passport.noErrors and realRecCutoffDef.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'RecCutoffDef', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realRecCutoffDef, true);
	endif;
	
	if _passport.noErrors then
		realRecCutoffDef.setForUpdate(_pxyRecCutoffDef);
	endif;
	
	if _passport.noErrors() then
		realRecCutoffDef.persistCriteria(_allTransientCriteriaObj, _passport);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realRecCutoffDef, false);
	endif;

end;</source>
        <Parameter name="_pxyRecCutoffDef" type="CM_ReceivalCutoffTermDef"/>
        <Parameter name="_allTransientCriteriaObj" type="CMIF_Array"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateReceivalTemp" id="3a6a90d5-6d40-47db-a21c-42bc67d6facf">
        <updating/>
        <source>utlUpdateReceivalTemp(_temperature : Real; _gteReceival : CMGTE_Receival input; _passport : CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 29/04/2015	cnwdap1		Initial creation PAR #36094 CCMS SFW 1413 TFS 313 Cold Store Enhancements
//
vars

begin
	self.initialiseActivity();

	exclusiveLock(_gteReceival);

	_gteReceival.setReceivalTemperature(_temperature);
epilog

end;</source>
        <Parameter name="_temperature" type="Real"/>
        <Parameter name="_gteReceival" type="CMGTE_Receival" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateReeferAPILayout" id="4f06f5bb-9309-4c3d-805e-412839189f36">
        <updating/>
        <source>utlUpdateReeferAPILayout(_newText : String; _passport : CM_Passport input) updating;
/*
Purpose:			

Date			Who		Reason
05JUL2021		NAVAB1	TFS 51361
07 June 2023	navmd1	TFS 58491 - Fix 1090 when setting NReefer App Field layout
*/

vars

	entTblAgent : EntTableAgent;
	tmpArray : StringArray;

	portSchema 		: Schema;
	constantCategory : ConstantCategory;
	constDict 		: ConstantNDict;
	globalConst 	: GlobalConstant;
	
	safeText		: String;

begin



	self.initialiseActivity();
	
	if _newText = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(Input_required_field_Required, 'API Reefer Layout Configuration Text', null, null);
	endif;

	app.setContinueCMExceptions(true);
	

	if _passport.noErrors then
		// GET The text to place in the 'text' of the constant
		portSchema := rootSchema.getSchema("PortSchema");
		constantCategory := portSchema.getConstantCategory("EntTableDefs");
		create constDict transient;
		constantCategory.cnEcGetConstants.copy(constDict);

		// SET the text on the constant
		globalConst := constDict["ETDef_ReeferAPI"].GlobalConstant;  
		
		// TFS 58491
		// In the event that something has gone wrong and we've ended up with the entirety of the ETDef_ReeferAPIDefault text
		// correct it to at least make sure out ETDef generates correctly
		safeText := _newText.replace__("&lt;DefName&gt;reeferAPIDefault&lt;/DefName&gt;", "&lt;DefName&gt;reeferAPI&lt;/DefName&gt;", false);
		safeText := safeText.replace__("&lt;ConstantName&gt;ETDef_ReeferAPIDefault&lt;/ConstantName&gt;", "&lt;ConstantName&gt;ETDef_ReeferAPI&lt;/ConstantName&gt;", false);
		
		globalConst.cnEcSetText(safeText);
		
		app.myRoot.setConfig(ReeferAPILayout,safeText, false); // Save to state data so can access post upgrade to put back into ETRow text
		
		// GENERATE the new objects from the global constant
		create entTblAgent transient;
		entTblAgent.myEntTableDataRoot := app.myRoot.myEntTableDataRoot;
		
		create tmpArray transient;	
		tmpArray.add("ETDef_ReeferAPI");
		entTblAgent.trxUpdateFromConstant(tmpArray);	
	endif;


epilog
	delete constDict;
	delete entTblAgent;
	delete tmpArray;
end;</source>
        <Parameter name="_newText" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateReeferAlert" id="67edb5a6-bf86-4722-ae7a-94969998a624">
        <updating/>
        <source>utlUpdateReeferAlert(_reefer: CM_TrackedItem /*CM_Container*/; _severity: Integer; _offPowerDetail: String; _passport : CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	27 January 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 09/12/2009	cnwdap1		CCMS MES 1007 Any cargo type can now conecievably be a reefer - changed signature
//								from _reefer : CM_Container to _reefer : CM_TrackedItem
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 16/12/2014   cnwma1      PAR #35317 Reefer Alarm BGP not creating Time off Power Exceeded Alerts
vars
	terminal	: CM_Terminal;
	tempStr		: String;
	//theReefer	: CM_Container;		// CCMS 1007
	theReefer	: CM_TrackedItem;	// CCMS 1007
	alert		: CM_SystemAlert;
	alertDetail	: String;
	criteria : CM_ReeferJobCriteria;	//29 Jul 2020	NDL	TFS 49581
	newJob : CM_YardActivity;
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	theReefer := _reefer;
	
	terminal := theReefer.myTerminal;
	tempStr := theReefer.getDisplayTemperature(false, false);
	
	/*
	//erase old
	theReefer.eraseReeferSystemAlert;
	*/
	alert := null;
	alert := theReefer.getReeferAlert();
	if alert = null then
		//create new
		create alert persistent;
		alert.setMyTrackedItem(theReefer);
		alert.myTerminal := terminal;
		alert.add;
	endif;
	alert.setMySystemAlertType(app.myRoot.allSystemAlertTypes[EVENT_POWER_OFF_EXCEEDED]);  //16/12/2014 cnwma1 PAR #35317
	alert.setSeverity(_severity);
	alertDetail := theReefer.id &amp; " in " &amp; theReefer.locationId	&amp; " (Temp " &amp; tempStr 
					&amp; "), has been off power for " &amp; _offPowerDetail &amp; ". (Commodity - " &amp; theReefer.commodity.String;
	if theReefer.plannedLocnId &lt;&gt; null then
		alertDetail := alertDetail &amp; ", Planned - " &amp; theReefer.plannedLocnId &amp; ")";
	elseif theReefer.queuedLocnId &lt;&gt; null then
		alertDetail := alertDetail &amp; ", Queued - " &amp; theReefer.queuedLocnId &amp; ")"; 
	else
		alertDetail := alertDetail &amp; ")"; 
	endif;
	alert.details := alertDetail;
	
	//29 Jul 2020	NDL	TFS 49581
	criteria := theReefer.getMatchingReeferCriteria();
	if criteria &lt;&gt; null then
		if criteria.alarm then	
			newJob := theReefer.createReeferJob( CM_ReeferAlarmActivity, app.actualTimeAppServer, app.myPassport );
			theReefer.createReeferJobInformation(newJob,criteria,true ); // ### TFS 51300 07JUL2021 NAVAB1
		endif;
	endif;
	
	
end;</source>
        <Parameter name="_reefer" type="CM_TrackedItem"/>
        <Parameter name="_severity" type="Integer"/>
        <Parameter name="_offPowerDetail" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateReeferConnectList" id="58d1bcc8-d882-4b2d-84cd-5aac257c82b3">
        <source>utlUpdateReeferConnectList(_tis: CM_TISet; _passport: CM_Passport input);
//----------------------------------------------------------------
//	Created:	30 September 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	terminal	: CM_Terminal;
	ti			: CM_TrackedItem;
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	terminal := _passport.myTerminal;

	terminal.allReeferConnectTIs.clear();
	
	foreach ti in _tis do
		if ti.isPlannedVoyageHere
		and ti.isAboutToBeLoaded then
			continue;
		endif;
		terminal.allReeferConnectTIs.add(ti);	
	endforeach;
	
end;</source>
        <Parameter name="_tis" type="CM_TISet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateReeferDefrostAlert" id="6f0fcbc7-30b5-492a-a81e-1a38db43098e">
        <updating/>
        <source>utlUpdateReeferDefrostAlert(_reefer: CM_TrackedItem/*CM_Container*/; _severity: Integer; _defrostDetail: String; _passport : CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	CCMS 1551 July 2007 cnwrs1
//----------------------------------------------------------------
// 09/12/2009	cnwdap1		CCMS MES 1007 Any gtracked item could now be a reefer - changed method signature from 
//								_reefer : CM_Container to _reefer : CM_TrackedItem
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	terminal	: CM_Terminal;
	tempStr		: String;
	//theReefer	: CM_Container;		// CCMS 1007
	theReefer	: CM_TrackedItem;	// CCMS 1007
	alert		: CM_SystemAlert;
	alertDetail	: String;
	criteria : CM_ReeferJobCriteria;	//29 Jul 2020	NDL	TFS 49581
	newJob : CM_YardActivity;
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	
	theReefer := _reefer;
	
	terminal := theReefer.myTerminal;
	tempStr := theReefer.getDisplayTemperature(false, false);
	
	alert := null;
	alert := theReefer.getReeferAlert();
	if alert = null then
		//create new
		create alert persistent;
		alert.setMyTrackedItem(theReefer);
		alert.myTerminal := terminal;
		alert.add;
	endif;
	
	alert.setSeverity(_severity);
	alertDetail := theReefer.id &amp; " in " &amp; theReefer.locationId	&amp; " (Temp " &amp; tempStr 
					&amp; "), has been on defrost for " &amp; _defrostDetail &amp; ". (Commodity - " &amp; theReefer.commodity.String;
	if theReefer.plannedLocnId &lt;&gt; null then
		alertDetail := alertDetail &amp; ", Planned - " &amp; theReefer.plannedLocnId &amp; ")";
	elseif theReefer.queuedLocnId &lt;&gt; null then
		alertDetail := alertDetail &amp; ", Queued - " &amp; theReefer.queuedLocnId &amp; ")"; 
	else
		alertDetail := alertDetail &amp; ")"; 
	endif;
	alert.details := alertDetail;
	
	//29 Jul 2020	NDL	TFS 49581
	criteria := theReefer.getMatchingReeferCriteria();
	if criteria &lt;&gt; null then
		if criteria.alarm then	
			newJob := theReefer.createReeferJob( CM_ReeferAlarmActivity, app.actualTimeAppServer, app.myPassport );
			theReefer.createReeferJobInformation(newJob,criteria,true ); // ### TFS 51300 07JUL2021 NAVAB1
		endif;
	endif;
	
	
end;
</source>
        <Parameter name="_reefer" type="CM_TrackedItem"/>
        <Parameter name="_severity" type="Integer"/>
        <Parameter name="_defrostDetail" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateReeferWalkPath" id="0c572284-e310-4d5d-af8a-4d93147295a3">
        <source>utlUpdateReeferWalkPath( 	_pxyReeferBlock : CM_ReeferBlock;
							_reeferWalkPositionArray : CM_ReeferBlockPositionArray;
							_passport : CM_Passport input
							);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 July 2020	jlgndl1	Initial creation	TFS 49579

*/

vars

	realReeferBlock : CM_ReeferBlock;
	expectedEdition : Integer;
	ta : CM_TerminalArea;
	
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	_pxyReeferBlock.pxyGetRealObjectAndEdition(realReeferBlock, expectedEdition);
	
	if realReeferBlock = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_ReeferBlock.name, null, null);
		return;
	endif;

	app.myValUA.valReeferBlock(realReeferBlock, _pxyReeferBlock);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	ta := realReeferBlock.myTerminalArea;
	exclusiveLock(realReeferBlock);
	exclusiveLock(ta);

	if _passport.noErrors and realReeferBlock.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Reefer Block', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric( ta, true );
	endif;
	
	if _passport.noErrors then
		realReeferBlock.setForUpdate( _pxyReeferBlock, _reeferWalkPositionArray );
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric( ta, false );
	endif;

epilog
	
end;</source>
        <Parameter name="_pxyReeferBlock" type="CM_ReeferBlock"/>
        <Parameter name="_reeferWalkPositionArray" type="CM_ReeferBlockPositionArray"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateReleaseReqBlockEDI" id="31dbe8e7-c2e5-408e-be47-de4719e2c612">
        <source>utlUpdateReleaseReqBlockEDI(_value :Boolean; _coll : CM_BulkReleaseSet; _passport	: CM_Passport input );
/*
Date		Who		Reason
23/04/2012	cnwcs5	Initial creation - CCMS POL 2172 / par 29480 coparn release updates
*/
vars
	release	:CM_BulkRelease;
begin
	self.initialiseActivity();
	app.setContinueCMExceptions( true );
	
	// Do validation.
	self.raiseExceptionIfNull( _coll, 'list of Release Requests' );	// can not be nothing to change

	// don't worry about validation - not needed
	foreach release in _coll do
	

		if release.blockEDIUpdates = _value then	// par 29481 May 2012
			// nothing to do so save update, notifications, audit etc.
			continue;
		endif;
		
		if _passport.noErrors then //cnwrd1 par 31782
			self.myUpdateAuditAgent.audUpdateGeneric(release, true);
		endif;
	
	
		release.setBlockEDIUpdates (_value);
		
		if _passport.noErrors then //cnwrd1 par 31782
			self.myUpdateAuditAgent.audUpdateGeneric(release, false);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
        <Parameter name="_coll" type="CM_BulkReleaseSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateReleaseRequestsType" id="9925c7d8-005b-4776-a3a6-06019704902e">
        <source>utlUpdateReleaseRequestsType(_type	: Integer; _coll : CM_BulkReleaseSet; _passport	: CM_Passport input );
/*
Date		Who		Reason
28 Nov 2011	cnwcs5	Initial creation - CCMS POL 2122 / par 28696 - Empty Releases via COPARN
20/02/2012	cnwcs5	change to use setForUpdatePxy
29/07/2013	cnwcs5	CCMS POL 2221 / par 32094 - signature change
*/
vars
	release,
	proxy			: CM_BulkRelease;
	proxyColl		: CM_BulkReleaseSet;
	gotException	: Boolean;
	errorCount		: Integer;
	terminal		: CM_Terminal;
begin
	self.initialiseActivity();
	app.setContinueCMExceptions( true );
	
	// Do validation.
	self.raiseExceptionIfNull( _coll, 'list of Release Requests' );	// can not be nothing to change
	
	// must have supplied correct type to change to.
	if _type &lt;&gt; BR_TYPE_ROAD and
	   _type &lt;&gt; BR_TYPE_RAIL and
	   _type &lt;&gt; BR_TYPE_PACKING and
	   _type &lt;&gt; BR_TYPE_SHIP and
	   _type &lt;&gt; BR_TYPE_UNKNOWN then				// NOTE null = 0 = BOOKING_REF_PENDING
		// we expect the GUI to take care of this
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Invalid type');
	endif;
	
	if _passport.noErrors() then
		// OK do updating.
		create proxyColl transient;
		
		on Exception do app.handleDeletedObject (exception, release, gotException);
		
		// 	I need to do a first pass with just doing validation so I get all errors/warnings reported
		//	for all release request
		foreach release in _coll do
			if release.type = _type then
				// nothing to do
				continue;
			endif;
			
			proxy	:= release.pxyCreateUpdateProxy;	// does share lock on release request
			
			if not gotException then
				proxy.setType (_type);				
				proxyColl.add (proxy);
			
				errorCount := _passport.allErrorWarnings.size;

				app.myValUA.valBulkRelease (proxy, null, _passport);
				
				if errorCount &lt; _passport.allErrorWarnings.size then
					// new errors
					app.raiseCMWarning1 (Release_Requests_Errors, proxy.code, null, null, null);
				endif;
			else
				gotException := false;
			endif;
			
		endforeach;
		
		if not self.checkValidationWithPassport (_passport) then
			return;
		endif;
		
		// error free so do the updating
		
		foreach proxy in proxyColl do
			release	:= proxy.pxyGetRealObject;

			self.exclusiveLock (release);	// upgrading from share to exclusive
			
			if _passport.noErrors then
				self.myUpdateAuditAgent.audUpdateGeneric(release, true);
			endif;
			
			if _passport.noErrors then
				release.setForUpdateFromPxy(proxy);	// par 28756
			endif;
		
			if _passport.noErrors then
				self.myUpdateAuditAgent.audUpdateGeneric(release, false);
			endif;
		
			if not _passport.noErrors then
				// we don't expect to get errors because we did all the validation up front but if we do then
				// we need to stop here - the transaction will be aborted
				break;
			endif;
		endforeach;
		
		if _passport.noErrors then
			// send out notes now that we know everything has been updated.
			terminal := _passport.myTerminal;
			
			foreach proxy in proxyColl do
				release	:= proxy.pxyGetRealObject;
				
				if _passport.noErrors and terminal &lt;&gt; null and release &lt;&gt; null then
					global.causeEvent(terminal.getTerminalEvent(Event_BulkRelease_Update), false, release);
				endif;				
			endforeach;
		endif;
	endif;
epilog
	proxyColl.purge;
	delete proxyColl;
end;
</source>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_coll" type="CM_BulkReleaseSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateReleaseWLEQty" id="dd7d055a-4d1c-4d6a-bf65-a27c47230710">
        <updating/>
        <source>utlUpdateReleaseWLEQty(_deliveryRequest : CM_DeliveryRequest input; 
						_qty : Integer;
						_passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 23 November 2005 By: cnwgd1
//--------------------------------------------------------------
vars
	tmpJob : CM_Job;
begin
	
	self.initialiseActivity();
	self.raiseExceptionIfNull(_deliveryRequest, 'Delivery Request');
	
	tmpJob := _deliveryRequest.myJob;
	self.raiseExceptionIfNull(tmpJob, 'Job');	
	
	//epr par 34406 25/6/14
	if not _deliveryRequest.isBulkMulti then
		//cnwrd1 par 31428 properlly count the space on a bulk release reserve detail 
		if _deliveryRequest.myOriginatingBulkRelease &lt;&gt; null and _deliveryRequest.myReserveDetail &lt;&gt; null then
			_deliveryRequest.myOriginatingBulkRelease.canActionQTY( _qty,_deliveryRequest.myReserveDetail ); 
		elseif _deliveryRequest.myOriginatingBulkRelease &lt;&gt; null then
			if _deliveryRequest.myOriginatingBulkRelease.allReserveDetails.size &gt; 0 then
				if _qty &gt; _deliveryRequest.myOriginatingBulkRelease.getTotalOutstanding then
					app.raiseCMException1(MTRequestExceedsNumBulkRequest, _deliveryRequest.myOriginatingBulkRelease.code, null, null);
				endif;
			endif;
		endif;
	endif;

	if (not self.checkValidationWithPassport(_passport)) then
		return;
	endif;
		
	app.setContinueCMExceptions(false);

	//Add work list entry
	_deliveryRequest.addWLE(_qty);

	if _passport.noErrors then
		tmpJob.causeTerminalEvent(tmpJob.Event_Mode_Create);
	endif;

end;</source>
        <Parameter name="_deliveryRequest" type="CM_DeliveryRequest" usage="input"/>
        <Parameter name="_qty" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
