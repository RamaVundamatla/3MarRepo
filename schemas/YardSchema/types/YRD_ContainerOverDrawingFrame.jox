    <JadeMethod name="setRectFrameSlotCount" id="55d4f4e2-f6a4-452f-9592-361215019d01">
        <source>setRectFrameSlotCount(_rect : CMUI_ResizableRectFrame input ; _yaBlock: CM_YABlock; _ya: CM_YardAllocation);
/*
Date		Who		Reason
10 February 2009	cnwjk3	SFW1030
11/4/11     cnwdw1  CPL 2059 - need to cache the free space stats
*/
vars
	cmifYABlock : CMIF_YABlock;
	x1,y1,x2,y2	: Integer;
begin
		
		if _rect.myObject = null then
			create cmifYABlock transient;
			_rect.myObject := cmifYABlock;
			cmifYABlock.myYardAllocation := _ya;
			cmifYABlock.myYABlock := _yaBlock;
			if _yaBlock &lt;&gt; null and _yaBlock.myLocationStatistics &lt;&gt; null then
				cmifYABlock.myStatistics.c20Free := _yaBlock.myLocationStatistics.c20Free;
				cmifYABlock.myStatistics.c30Free := _yaBlock.myLocationStatistics.c30Free;
				cmifYABlock.myStatistics.c40Free := _yaBlock.myLocationStatistics.c40Free;
				cmifYABlock.myStatistics.c45Free := _yaBlock.myLocationStatistics.c45Free;
				cmifYABlock.myStatistics.c53Free := _yaBlock.myLocationStatistics.c53Free;
			endif;
		else
			cmifYABlock := _rect.myObject.CMIF_YABlock;
		endif;
		_rect.getIntPoints(x1, y1, x2, y2);
		cmifYABlock.numSlots := self.getNumberOfSlots(x1-2, y1-2, x2+2, y2+2);
		
epilog

end;</source>
        <Parameter name="_rect" type="CMUI_ResizableRectFrame" usage="input"/>
        <Parameter name="_yaBlock" type="CM_YABlock"/>
        <Parameter name="_ya" type="CM_YardAllocation"/>
    </JadeMethod>
    <JadeMethod name="setRowColumnPoints" id="a1b54bad-6482-4954-b972-904e6e776e1d">
        <source>setRowColumnPoints();
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
//10 Mar 2017 cnwer1 		removed references to trailer drawing controler
vars
	ydc : YRD_ContainerDrawingController;
begin
	
	ydc := self.getDrawingController();
	if ydc = null then
		return;
	endif;
	
	if ydc.allTerminalAreas.isEmpty then
		ydc.getRowColumnPoints(self.allRowPoints, self.allColumnPoints);
	else
		ydc.getRowColumnPointsALL(self.allRowPoints, self.allColumnPoints);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setYABlocks" id="e7f69bbc-0103-4a2c-9369-bd890e39e258">
        <updating/>
        <source>setYABlocks(_yas: ObjectArray) updating;
vars
	obj: Object;
	ya: CM_YardAllocation;
	invalid: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, obj, invalid);

	self.allYABlocks.clear();
	foreach obj in _yas discreteLock do
		if obj.isKindOf(CM_YABlock) then
			ya := obj.CM_YABlock.myYardAllocationIn;
		elseif obj.isKindOf(CM_YABlockGroup) then
			ya := obj.CM_YABlockGroup.myYardAllocationIn;
		else
			ya := obj.CM_YardAllocation;
		endif;
		if ya &lt;&gt; null then
			self.getYABlockPoints(ya, null);
		endif;
	endforeach;
end;</source>
        <Parameter name="_yas" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="setYardAllocations" id="e1913624-ebac-49bd-a63f-921325d2b5bd">
        <updating/>
        <source>setYardAllocations(_yas: ObjectArray) updating;
//04 November 2008	cnwdw1	
//
vars
	obj: Object;
	ya: CM_YardAllocation;
	invalid: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, obj, invalid);

	self.init();
	self.allObjects.clear;
	foreach obj in _yas discreteLock do
		if obj.isKindOf(CM_YABlock) then
			ya := obj.CM_YABlock.myYardAllocationIn;
		elseif obj.isKindOf(CM_YABlockGroup) then
			ya := obj.CM_YABlockGroup.myYardAllocationIn;
		else
			ya := obj.CM_YardAllocation;
		endif;
		if not invalid and ya &lt;&gt; null then
			self.getYardAllocationPoints(ya, null);
		endif;
	endforeach;
end;</source>
        <Parameter name="_yas" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="showLocationAndNumberOfSlots" id="3adf4600-104f-4f86-a9bd-c68a46981783">
        <source>showLocationAndNumberOfSlots(_x1, _y1, _x2, _y2 : Integer; _updateLocation : Boolean; _rect : CMUI_ResizableRectFrame);
/*
Date		Who		Reason
28 January 2009	cnwjk3	SFW1030
14/4/2011   cnwdw1  CCMS CPL 2052 - change to show the total free space available in all the ya blocks
*/
vars
	proxyYA 	: CM_YardAllocation;
	ya			: CM_YardAllocation;
	yaParser	: CM_YAParser;
	blocks		: ObjectArray;
	yaBlock 	: CM_YABlock;
	cmifYABlock : CMIF_YABlock;
	locations 	: CM_LCArray;
	yrdForm 	: YRD_SatelliteViewForm;
	locationText	: String;	
	statsAgent	: CMIF_StatisticsAgent;
	free20, free30, free40, free45, free53: Integer;
	rect: CMUI_ResizableRectFrame;
	right: Real;
begin
	if not self.inEditMode then		// PAR 27570
		return;
	endif;

	yrdForm := self.form.YRD_SatelliteViewForm;
	
	//ya := self.getSelectedYA();
	ya := self.getEdittedYA(); //cnwrd1 par 28438 20.10.2011 - we want to view stats for the current ya being eddited
	
	if ya = null then
		return;
	endif;
	
	//epr par 30613 24/10/12
	if _rect = null then
		return;
	endif;
	
	create locations transient;
	self.getDrawingController().allGridObjects.findObjectsInDict(_x1, _y1, _x2, _y2, locations, CM_LocationsController, false, false);
	if _rect &lt;&gt; null then
		cmifYABlock := _rect.myObject.CMIF_YABlock;
	endif;
	
	if locations.isEmpty then
		yrdForm.txtYALocation.text := null;
		yrdForm.lblYALocation.caption := null;
	else		
		if cmifYABlock &lt;&gt; null then // CCMS CPL 2059
			create statsAgent transient;
			self.updateFreeStats(cmifYABlock, locations);
			
			foreach rect in self.allRectFrames do
				yaBlock := self.allYABlocksByRectFrame[rect];
				// Only look at rects for the YA that is being editted
				// A rect without a yablock has just been added during this edit
				if yaBlock = null or yaBlock.myYardAllocationIn = ya then
					cmifYABlock := rect.myObject.CMIF_YABlock;
					if cmifYABlock = null then
						continue;
					endif;
					if yaBlock = null then  //cnwrd1 par 28438 20.10.2011 - if we dont have a yaBlock we should have a cmifYABlock that has which YA we are for, otherwise we add up all the new changes even if they are for other ya's
						if cmifYABlock.myYardAllocation &lt;&gt; ya then
							continue;
						endif;
					endif;

					free20 := free20 + cmifYABlock.myStatistics.c20Free;
					free40 := free40 + cmifYABlock.myStatistics.c40Free;
					free30 := free30 + cmifYABlock.myStatistics.c30Free;
					free45 := free45 + cmifYABlock.myStatistics.c45Free;
					free53 := free53 + cmifYABlock.myStatistics.c53Free;
				endif;
			endforeach;
			
			app.getErrorString2(SatelliteViewFree, free20.String, "20");
			locationText := app.getErrorString2(SatelliteViewFree, free20.String, "20")&amp; ", " &amp; 
							app.getErrorString2(SatelliteViewFree, free40.String, "40");
			right := yrdForm.btnYALocCancel.left + 	yrdForm.btnYALocCancel.width;
			if yrdForm.myTerminal.getConfig(Is30IncludedForReports).Integer = 1 then
				locationText := locationText &amp; ", " &amp;  app.getErrorString2(SatelliteViewFree, free30.String, "30");
				yrdForm.frmYALocation.width := right + 40;
				yrdForm.lblYALocation.width := right + 40;
			endif;
			if yrdForm.myTerminal.getConfig(Is45IncludedForReports).Integer = 1 then
				locationText := locationText &amp; ", " &amp;  app.getErrorString2(SatelliteViewFree, free45.String, "45");
				yrdForm.frmYALocation.width := right + 80;
				yrdForm.lblYALocation.width := right + 80;
			endif;
			if yrdForm.myTerminal.getConfig(Is53IncludedForReports).Integer = 1 then
				locationText := locationText &amp; ", " &amp;  app.getErrorString2(SatelliteViewFree, free53.String, "53");
				yrdForm.frmYALocation.width := right + 120;
				yrdForm.lblYALocation.width := right + 120;
			endif;
			
			yrdForm.lblYALocation.caption := locationText;
		endif;
		
		proxyYA := app.createUpdateProxy(ya).CM_YardAllocation;
		proxyYA.allYABlocksIn.purge();
		create yaParser transient;
		create blocks transient;
		blocks.add(locations);
		yaParser.createBlocks(proxyYA, blocks);
		proxyYA.setProxyGroupBlocks(yaParser.allYABlocksIn, yaParser.allYABlocksOut);
		yaBlock := proxyYA.allYABlocksIn.first;
		if _updateLocation and yaBlock &lt;&gt; null then
			if yaBlock.isKindOf(CM_YAIrregularBlock) then	//13 May 2016	NDL	TFS 1986/1909
				locationText := proxyYA.allYABlocksIn.getYAMDisplayFor();	//13 May 2016	NDL	TFS 1986/1909
			else
				locationText := yaBlock.getYAMDisplay(false);
			endif;
			yrdForm.txtYALocation.text := locationText;
		endif;
	endif;
	
epilog
	delete locations;
	delete statsAgent;
	delete blocks;
	delete yaParser;
	delete proxyYA;
end;</source>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
        <Parameter name="_updateLocation" type="Boolean"/>
        <Parameter name="_rect" type="CMUI_ResizableRectFrame"/>
    </JadeMethod>
    <JadeMethod name="showYALocationText" id="b6bf02cc-43c8-498a-b7e5-69172ec10f51">
        <source>showYALocationText();

/*

Purpose:			Refreshes the YA Locations frame with details from currently selected block

Parameters:			

Return Value:		


Date		Who		Reason
08 December 2008	consw1	Initial creation

*/

vars
	yrdForm 	: YRD_SatelliteViewForm;
	x1, y1,	x2, y2 : Integer;
	
begin
	yrdForm := self.form.YRD_SatelliteViewForm;
	yrdForm.txtYALocation.foreColor := Black;
	
	//ya := yrdForm.getSelectedYA();

	if self.origXPos.Integer &lt; self.lastMouseX then
		x1 := self.origXPos.Integer;
		x2 := self.lastMouseX;
	else
		x1 := self.lastMouseX;
		x2 := self.origXPos.Integer;
	endif;
	
	if self.origYPos.Integer &lt; self.lastMouseY then
		y1 := self.origYPos.Integer;
		y2 := self.lastMouseY;
	else
		y1 := self.lastMouseY;
		y2 := self.origYPos.Integer;
	endif;

	// cnwjk3 SFW1030
	self.showLocationAndNumberOfSlots(x1, y1, x2, y2, true, null);
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="slimGraphics" id="d010379b-bc9f-42ea-95cf-9c7d7effe117">
        <updating/>
        <source>slimGraphics() updating;
//14 August 2008	cnwdw1	
//
vars

begin
	self.grabberWidth := 3;
	self.frameWidth := 1;
end;</source>
    </JadeMethod>
    <JadeMethod name="snapRectPointsToGrid" id="0a4d4ae1-3e63-420c-9a9f-d9cd72dd8ba9">
        <source>snapRectPointsToGrid(_x1, _y1, _x2, _y2 : Integer io) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 Feb 2009	cnwjk3	SFW1030
04 May 2023	navdap1	TFS 57711 FR | 53485 EUP - Warehouse Yard Allocation - Satellite view location selection issues
*/

vars
	topleft, 
	bottomRight	: Point;
	location	: Object;
	classObj	: Class;				// TFS 57711
begin
	// Rectangle points will have been constrained to a bounding rectangle before this method is called
	// so we should always find a location controller
	//_rect.getIntPoints(x1, y1, x2, y2);

	if self.getForm.getMyTerminal.getAutoPlanAllowFullGCArea then	// TFS 57711
		classObj := CM_IrregularBlockController;					// TFS 57711
	endif;															// TFS 57711
	
	// Find LC for top left point of rectangle
	//location := self.getDrawingController.getObjectAndPointsForPosition(_x1+2, _y1+2, topleft, bottomRight,null);		// TFS 57711
	location := self.getDrawingController.getObjectAndPointsForPosition(_x1+2, _y1+2, topleft, bottomRight, classObj);	// TFS 57711
	if location = null and classObj &lt;&gt; null then																		// TFS 57711
		location := self.getDrawingController.getObjectAndPointsForPosition(_x1+2, _y1+2, topleft, bottomRight, null);	// TFS 57711
	endif;																												// TFS 57711
	if location &lt;&gt; null then 
		// Adjust the top left of the rectangle
		
		// If rect x1 &lt;= middle of the LC we snap to its left, otherwise we snap to its right
		if _x1 &lt;= topleft.x + ((bottomRight.x - topleft.x)/2) then
			_x1 := topleft.x;
		else
			_x1 := bottomRight.x;
		endif;

		// If rect y1 &lt;= middle of the LC we snap to its top, otherwise we snap to its bottom
		if _y1 &lt;= topleft.y + ((bottomRight.y - topleft.y)/2) then
			_y1 := topleft.y;
		else
			_y1 := bottomRight.y;
		endif;
	else
		return false;
	endif;
	
	// Find LC for bottom right point of rectangle
	//location := self.getDrawingController.getObjectAndPointsForPosition(_x2-2, _y2-2, topleft, bottomRight,null);		// TFS 57711
	location := self.getDrawingController.getObjectAndPointsForPosition(_x2-2, _y2-2, topleft, bottomRight,classObj);	// TFS 57711
	if location = null and classObj &lt;&gt; null then																		// TFS 57711
		location := self.getDrawingController.getObjectAndPointsForPosition(_x2-2, _y2-2, topleft, bottomRight,null);	// TFS 57711
	endif;																												// TFS 57711
	if location &lt;&gt; null then 
		// Adjust the bottom right of the rectangle
		
		// If rect x2 &lt;= middle of the LC we snap to its left, otherwise we snap to its right
		if _x2 &lt;= topleft.x + ((bottomRight.x - topleft.x)/2) then
			_x2 := topleft.x;
		else
			_x2 := bottomRight.x;
		endif;
		
		// If rect y2 &lt;= middle of the LC we snap to its top, otherwise we snap to its bottom
		if _y2 &lt;= topleft.y + ((bottomRight.y - topleft.y)/2) then
			_y2 := topleft.y;
		else
			_y2 := bottomRight.y;
		endif;		
	else
		return false;
	endif;
	
	// If the new width is less than the width of a LC, then make it the same width as a LC
	if _x2-_x1 &lt; bottomRight.x - topleft.x then
		_x1 := topleft.x;
		_x2 := bottomRight.x;
	endif;
	
	// If the new height is less than the width of a LC, then make it the same height as a LC
	if _y2-_y1 &lt; bottomRight.y - topleft.y then
		_y1 := topleft.y;
		_y2 := bottomRight.y;
	endif;

	return true;
	
epilog

end;</source>
        <Parameter name="_x1" type="Integer" usage="io"/>
        <Parameter name="_y1" type="Integer" usage="io"/>
        <Parameter name="_x2" type="Integer" usage="io"/>
        <Parameter name="_y2" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="snapRectPointsToRoRoLanes" id="c6134e51-83ae-4146-a028-3cd39c8ba737">
        <source>snapRectPointsToRoRoLanes(_x1, _y1, _x2, _y2 : Integer io) : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 February 2009	cnwjk3	SFW1030

*/

vars
	obj			: Object;
	objs		: ObjectArray;
	point1,
	point2		: Point;
	dc			: YRD_ContainerDrawingController;
	minX, maxX,
	minY, maxY	: Integer;
begin
	// Rectangle points will have been constrained to a bounding rectangle before this method is called
	// so we should always find a location controller
	//_rect.getIntPoints(x1, y1, x2, y2);
	create objs transient;
	dc := self.getDrawingController();
	
	// Find all the RoRo Lanes within the rectangle provided
	dc.allGridObjects.findObjectsInDict(_x1, _y1, _x2, _y2, objs, CM_RoRoController, true, false);
	
	// We now have the lanes which are within the bounding rectangle.  Now we need to calculate the size of the
	// rectangle which will completely encapsulate all of the lanes.
	foreach obj in objs do
		dc.allGridObjects.findObjectInDictGetXY(obj, point1, point2);
		
		// find minimum x pos
		if minX = 0 or point1.x &lt; minX then
			minX := point1.x;
		endif;
		// find maximum x pos		
		if point2.x &gt; maxX then
			maxX := point2.x;
		endif;		
		// find minimum y pos
		if minY = 0 or point1.y &lt; minY then
			minY := point1.y;
		endif;
		// find maximum y pos
		if point2.y &gt; maxY then
			maxY := point2.y;
		endif;
		
	endforeach;
	
	_x1 := minX;
	_y1 := minY;
	_x2 := maxX;
	_y2 := maxY;

	return true;
	
epilog
	delete objs;
end;</source>
        <Parameter name="_x1" type="Integer" usage="io"/>
        <Parameter name="_y1" type="Integer" usage="io"/>
        <Parameter name="_x2" type="Integer" usage="io"/>
        <Parameter name="_y2" type="Integer" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="snapToLocationCorner" id="58eb54c9-1cf5-456d-ad7a-d1fdc50d9a1d">
        <source>snapToLocationCorner(_x, _y: Integer; _cornerX, _cornerY: Integer output; _snapBack: Boolean);
//03 November 2008	cnwdw1	
//
vars
	topleft, bottomRight: Point;
	location: Object;
begin
	// Is the point in a TA
	location := self.getDrawingController.getObjectAndPointsForPosition(_x, _y, topleft, bottomRight,null);
	if location &lt;&gt; null then
		if not _snapBack then
			_cornerX := topleft.left;
			_cornerY := topleft.top;
		else
			_cornerX := bottomRight.right;
			_cornerY := bottomRight.bottom;
		endif;
	else
		_cornerX := _x; //self.lastMouseX.Integer;
		_cornerY := _y; //self.lastMouseY.Integer;
	endif;
end;</source>
        <Parameter name="_x" type="Integer"/>
        <Parameter name="_y" type="Integer"/>
        <Parameter name="_cornerX" type="Integer" usage="output"/>
        <Parameter name="_cornerY" type="Integer" usage="output"/>
        <Parameter name="_snapBack" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="c1b1ace4-2b05-4e3f-8581-7b01cf1b675a">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*
Purpose:	

Date		Who		Reason
10 July 2025	navab1	JIRA 35403
*/

vars

begin
	if eventTag = YRD_ContainerOverDrawingFrame.TimerBubbleHelp then
		self.bubbleHelp := "";
		self.endTimer(YRD_ContainerOverDrawingFrame.TimerBubbleHelp);
	endif;
epilog

end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="updateFreeStats" id="f0d1f8a0-5af5-475b-8f8b-a42c3a483a50">
        <source>updateFreeStats(_yaBlock: CMIF_YABlock io; _locations: CM_LCArray);
/*
Purpose:	Calculate the free space in the list of locations. Only looks at Gridded Areas		

Return Value:	The myStatistics object in _yaBlock is updated with the free stats.	

Date		Who		Reason
14 4 2011	cnwdw1	CCMS CPL 2052
*/
vars
	locations: CM_LCArray;
	statsAgent: CMIF_StatisticsAgent;
	sortedLocations: CM_GridControllersByRowColumn;
	minHeight, maxHeight, height: Integer;
	free20, free30, free40, free45, free53: Integer;
	ta: CM_TerminalArea;
begin
	create statsAgent transient;
	create locations transient;
	
	if _locations.first.isGridLocation then
	
		create sortedLocations transient;
		_locations.copy(sortedLocations);
		sortedLocations.copy(locations);
	
		ta := locations.first.myTerminalArea;
		
		// Par 27607 Use the heights from the range
		if _yaBlock.myYABlock &lt;&gt; null then
			minHeight := _yaBlock.myYABlock.getMinHeight();
			maxHeight := _yaBlock.myYABlock.getMaxHeight();
		else
			minHeight := 1;
			maxHeight := ta.getHeight();
		endif;
		
		free20 := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_20, locations, minHeight, maxHeight);
		free40 := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_40, locations, minHeight, maxHeight);
		if ta.myTerminal.getConfig(Is30IncludedForReports).Integer = 1 then
			free30 := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_30, locations, minHeight, maxHeight);
		endif;
		if ta.myTerminal.getConfig(Is45IncludedForReports).Integer = 1 then
			free45 := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_45, locations, minHeight, maxHeight);
		endif;
		if ta.myTerminal.getConfig(Is53IncludedForReports).Integer = 1 then
			free53 := statsAgent.calcFree(CMIF_StatisticsAgent.ContainerSize_53, locations, minHeight, maxHeight);
		endif;
	endif;
	
	_yaBlock.myStatistics.c20Free := free20;
	_yaBlock.myStatistics.c30Free := free30;
	_yaBlock.myStatistics.c40Free := free40;
	_yaBlock.myStatistics.c45Free := free45;
	_yaBlock.myStatistics.c53Free := free53;
	
epilog
	delete locations;
	delete sortedLocations;
	delete statsAgent;
end;</source>
        <Parameter name="_yaBlock" type="CMIF_YABlock" usage="io"/>
        <Parameter name="_locations" type="CM_LCArray"/>
    </JadeMethod>
    <JadeMethod name="updateYALocation" id="7226bb67-8048-41db-9485-6a47d86ab706">
        <updating/>
        <source>updateYALocation( _locationText : String; _keyCode : Integer ) updating;

/*

Purpose:			Update block display from YA Location text

Parameters:			Text from YA Location frame

Return Value:		


Date				Who		Reason
09 December 2008	consw1	Initial creation

*/

vars
	
	int				: Integer;
	topLeftLC		: CM_LocationsController;
	bottomRightLC	: CM_LocationsController;
	x1, y1, x2, y2	: Integer;
	selectedRect	: CMUI_ResizableRectFrame;
	selectedYA		: CM_YardAllocation;
	locText			: String;
	locations 		: CM_LCArray;
	taView 			: CM_TerminalAreaView;
begin
	
	if _locationText = "" then
		selectedRect := self.getSelectedRectFrame();
		if selectedRect &lt;&gt; null then
			selectedRect.visible := false;
			self.clearSelectedRectFrame();
			return;
		endif;
	endif;

	locText := _locationText;
	
	taView:=self.form.YRD_SatelliteViewForm.getTerminalAreaView;
	// PAR 19308
	//if self.form.CM_BaseForm.myTerminal.findYABlock(_locationText, topLeftLC, bottomRightLC ) then
	if self.form.CM_BaseForm.myTerminal.findYABlock(locText, topLeftLC, bottomRightLC, taView ) then
		
		
		self.form.YRD_SatelliteViewForm.txtYALocation.foreColor := Black;
	
		if not self.myContainerDrawingFrame.getPointsForObject(topLeftLC, x1, y1, int, int) then
			self.isRectSelected := false;
			return;
		endif;
	
		if not self.myContainerDrawingFrame.getPointsForObject(bottomRightLC, int, int, x2, y2) then
			self.isRectSelected := false;
			return;
		endif;
		
		// cnwjk3 ccms 1018 26/01/10
		if topLeftLC.isKindOf(CM_RoRoController) and bottomRightLC.isKindOf(CM_RoRoController) then
			self.adjustPointsForRoRoLanes(topLeftLC.CM_RoRoController, bottomRightLC.CM_RoRoController, x1, y1, x2, y2); 
		else
			// It's possible to get what appear to be the topLeft and botomRight location controllers given an invalid string
			// which is why we need this next check
			if topLeftLC &lt;&gt; bottomRightLC then
				create locations transient;
				self.getDrawingController().allGridObjects.findObjectsInDict(x1, y1, x2, y2, locations, CM_LocationsController, false, false);
				if locations.isEmpty() then 
					self.form.YRD_SatelliteViewForm.txtYALocation.foreColor := Red;
					return;
				endif;
			endif;
		endif;
		
		selectedRect := self.getSelectedRectFrame(); // could be null
		
		// See if the rectangle overlaps with another
		if self.checkRectOverlap(selectedRect, x1, y1, x2, y2) then
			self.form.YRD_SatelliteViewForm.txtYALocation.foreColor := Red;
			return;
		endif;
				
		
		// We have a valid location entered, which doesn't overlap existing rectangles
		// If we have a selected rectangle, we update it's size and position according to the location entered,
		// otherwise we allocate a brand new one and select it.
		if selectedRect = null then
			selectedYA := self.getEdittedYA();
			if selectedYA &lt;&gt;  null then 
				selectedRect := self.allocateAndDrawRectFrame(x1, y1, x2, y2, selectedYA);
				self.selectRectFrame(selectedRect, false);
				self.setRectFrameSlotCount(selectedRect, null, selectedYA);  // CCMS CPL 2052
			endif;
		else
			selectedRect.resizeByPoints(x1, y1, x2, y2);
		endif;

		// Show information for this location
		self.showLocationAndNumberOfSlots(x1, y1, x2, y2, false, selectedRect);		
		
		if _keyCode = CMUI_Key_Enter then
			self.clearSelectedRectFrame();
		else
			// A valid location has been entered
			self.isRectSelected := true;			
		endif;
	else
		self.form.YRD_SatelliteViewForm.txtYALocation.foreColor := Red;
	endif;
epilog
	delete locations;
end;</source>
        <Parameter name="_locationText" type="String"/>
        <Parameter name="_keyCode" type="Integer"/>
    </JadeMethod>
