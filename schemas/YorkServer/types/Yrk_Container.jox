    <JadeMethod name="attributes" id="a9707311-3c64-41f4-b6f3-44dfb12a867a">
        <source>attributes():String;

vars
	message: String;
begin
	message := self.tempString(self.tempExpSetpoint)&amp;
		self.tempString(self.tempActSetpoint)&amp;	
		self.tempString(self.tempSupply)&amp;	
		self.tempString(self.tempReturn)&amp;	
		//self.tempString(self.tempMin)&amp;	
		//self.tempString(self.tempMax)&amp;	
		self.tempString(self.tempMin)&amp;	
		self.tempString(self.tempMax)&amp;	
		self.hmcString(self.hmc)&amp;
		self.ventString(self.vent)&amp;
		self.drains&amp;
		self.bulbMode&amp;
		self.fanSet&amp;
		self.tempString(self.tempDefrost)&amp;
		self.intervalString(self.intervalDefrost)&amp;
		self.client&amp;
		self.sizeTypeString()&amp;
		self.facType&amp;
		"Y"&amp;//self.comMode&amp;
		"N"&amp;//self.alarm&amp;
		self.remark.padBlanks(80);
//	write message.length.String;
	return message;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hmcString" id="37c1357e-c5d7-4c9a-b69d-94aa3da6bd62">
        <source>hmcString(_hmc:Real):String;

vars
	message: String;
begin
	//message := (_hmc.userNumberFormat($CM_Temperature)&amp;"%").String.padLeftBlanks(9);
	//AER Par 14632
	message := (_hmc.asStringJMTWithPrecision(PRECISION_TEMPERATURE, false)&amp;"%").String.padLeftBlanks(9);
	return message[1:9];
end;</source>
        <Parameter name="_hmc" type="Real"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="ident" id="bf780e0b-d408-455c-9143-b134044842aa">
        <source>ident():String;

vars
	message: String;
begin
	message := self.id[1:4]&amp;" "&amp;self.id[5:7]&amp;"  ";
	return message;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="intervalString" id="fc8bab9c-a7ff-4f4b-864b-dd056b1ab7a9">
        <source>intervalString(_interval:Real):String;

vars
	message: String;
begin
	if _interval = 0 then
		message := "         ";
	else
	//	message := (_interval.userNumberFormat($CM_Temperature)&amp;"H").String.padLeftBlanks(9);
	//	AER Par 14632
		message := (_interval.asStringJMTWithPrecision(PRECISION_TEMPERATURE, false)&amp;"H").String.padLeftBlanks(9);
	endif;
	return message[1:9];
end;</source>
        <Parameter name="_interval" type="Real"/>
        <ReturnType type="String"/>
    </JadeMethod>
