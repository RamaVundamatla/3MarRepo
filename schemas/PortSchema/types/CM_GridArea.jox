    <JadeMethod name="applyAdvancedDeckingRules" id="273dd250-0220-4421-88fa-3b6b010628b3">
        <source>applyAdvancedDeckingRules(_rule: CM_YADeckingRule; _isIn: Boolean; _locations: CM_LCArray; _offset: Integer);
//31 December 2008	cnwdw1	
// Apply Advannce decking rules to the Terminal Area
// We no longer build the order arrays, and only need to make sure that there
// are enough YALocationCells on all the Yard Locations

//^^^^20 Jul 2010 cnwjo3, old code has been resurrected.
/*

Date		Who		Reason
20 Mar 2009	cnwkpd1	PAR #18994 - Factored code out to fixupYALocationCells
20 Jul 2010 cnwjo3	PAR #24157 - Yard Allocations incorrect so overstow calculations becoming incorrect aswell.
*/

vars
//	location		: CM_LocationsController;
//	yardLocation	: CM_YardController;
//	yaLocnCell		: CM_YALocationCell;
//	height			: Integer;
	sequencer: CMIF_DeckingSequenceService;
	rows, stacks, tiers: Integer;
	row, stack, index, tier, void, seq: Integer;
	location: CM_LocationsController;
	gridLocation: CM_GridController;
	height: Integer;
	yaLocnCells: CM_YALocationCellArray;
	
	gridRow : CM_GridRow;
	yaCell : CM_YALocationCell;	//14 Sep 2017	NDL	TFS 6969
	tempCellArray : CM_YALocationCellArray;	//14 Sep 2017	NDL	TFS 6969
	
begin
	self.fixupYALocationCells();
	
/*	PAR #18994

	// Make sure all the Location Controllers have the correct number of YALocationCells
	// This can happen when the height of a gridded area is increased
	foreach location in self.allLocationsControllers do
		if location.isKindOf(CM_YardController) then
			yardLocation := location.CM_YardController;
			while yardLocation.allYAYardLocationCells.size &lt; self.heightOfStack do
				create yaLocnCell persistent;
				yardLocation.allYAYardLocationCells.add(yaLocnCell);
				yaLocnCell.setForCreate(yardLocation.allYAYardLocationCells.size);		// PAR #18994
			endwhile;
		endif;
	endforeach;
*/	

	//cnwjo3 par 24157
	rows := self.numberOfDeckingRows;
	stacks := self.numberOfDeckingStacks;
	tiers := self.numberOfDeckingTiers;
	
	create sequencer transient;
	sequencer.onCreate(_rule.areaRule);
	sequencer.setExtent(stacks, rows, tiers);
	sequencer.setRules(_rule.stackRule, _rule.rowRule, _rule.patternRule);

	if _isIn then
		yaLocnCells := self.myYADeckingOptions.allYALocationCellsIn;
	else
		yaLocnCells := self.myYADeckingOptions.allYALocationCellsOut;
	endif;

	if _offset = 0 then
		yaLocnCells.clear;
	endif;
	
	create tempCellArray transient;	//14 Sep 2017	NDL	TFS 6969
	foreach row in 1 to rows do
		//11 Feb 2011	NDL error during testing 24181 when create a gap Row in RTG area.
		gridRow := allGridRows[row].CM_GridRow;
		if gridRow = null then	//19 Sep 2011	NDL	Par 28195
			continue;
		endif;
		if not gridRow.isDeckable then
			continue;
		endif;
		
		foreach stack in 1 to stacks do
			index := index + 1;
			gridLocation := _locations[index].CM_GridController;
		//	if gridLocation.allYAYardLocationCells.size &lt;&gt; tiers then
		//	endif;	
			foreach tier in 1 to tiers do
				seq := sequencer.getStackingSequence(stack, row, tier);
			//	yaLocnCells[seq+_offset] := gridLocation.allYAYardLocationCells[tier];
				//14 Sep 2017	NDL	TFS 6969
				yaCell := gridLocation.allYAYardLocationCells[tier];
				if yaCell &lt;&gt; null then
					tempCellArray[seq+_offset] := yaCell;
				endif;
			endforeach;
		endforeach;
	endforeach;
	
	//14 Sep 2017	NDL	TFS 6969
	//tempCellArray is in teh right order but can still have gaps.
	// retain the order but skip the spaces.
	foreach yaCell in tempCellArray where yaCell &lt;&gt; null do
		yaLocnCells.add(yaCell);
	endforeach;
	
epilog
	delete sequencer;
	delete tempCellArray;
end;</source>
        <Parameter name="_rule" type="CM_YADeckingRule"/>
        <Parameter name="_isIn" type="Boolean"/>
        <Parameter name="_locations" type="CM_LCArray"/>
        <Parameter name="_offset" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="applyDeckingRulesToCellOrder" id="b6a0bddb-2581-40a3-9dc8-14982ffb96a9">
        <source>applyDeckingRulesToCellOrder();
//----------------------------------------------------------------
//	Created:	12 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
constants
	IN = true;
	OUT = false;
vars
	rule		: CM_YADeckingRule;
	index		: Integer;
	locations: CM_LCArray;
begin
	create locations transient;

	index := 0;
	//IN
	foreach rule in self.myYADeckingOptions.allDeckingRulesIn do
		if rule.isAdvancedRule then
			self.deckingLocations(locations);
			self.applyAdvancedDeckingRules(rule, IN, locations, 0);
		else	
			self.applyInRule(rule, index);
		endif;
	endforeach;
	
	index := 0;
	//OUT
	foreach rule in self.myYADeckingOptions.allDeckingRulesOut do
		if rule.isAdvancedRule then
			self.deckingLocations(locations);
			self.applyAdvancedDeckingRules(rule, OUT, locations, 0);
		else	
			self.applyOutRule(rule, index);
		endif;
	endforeach;
epilog
	delete locations;
end;</source>
    </JadeMethod>
    <JadeMethod name="applyInRule" id="f3411bda-b6b9-48d6-b9b7-d13961dbaee9">
        <source>applyInRule(_rule: CM_YADeckingRule; _gridAreaIndex: Integer io) protected;
//----------------------------------------------------------------
//	Created:	13 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	theRuleType				: Integer;
	gridObjectDict,
	gridCntrlDict			: CM_MemberKeyDictionary;
	gridObj					: Object;
	gridController			: Object;
	locnCell				: CM_YALocationCell;	
	startFromLast			: Boolean;
begin

	theRuleType := _rule.deckingRuleType;

	startFromLast := self.defaultDeckingStartType = self.DefaultDeckingFromLast;

	gridObjectDict := self.getDictForDecking(theRuleType);
	
	if gridObjectDict = null then
		//null or custom decking
		return;
	endif;
	
	if startFromLast then
		foreach gridObj in gridObjectDict reversed do
			gridObj.CM_GridObject.applyDeckingRuleIn(_rule, _gridAreaIndex, self.myYADeckingOptions.allYALocationCellsIn);
		endforeach;
	else
		foreach gridObj in gridObjectDict do
			gridObj.CM_GridObject.applyDeckingRuleIn(_rule, _gridAreaIndex, self.myYADeckingOptions.allYALocationCellsIn);
		endforeach;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_rule" type="CM_YADeckingRule"/>
        <Parameter name="_gridAreaIndex" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="applyOutRule" id="462adce4-c515-418a-8237-d74d55c6151c">
        <source>applyOutRule(_rule: CM_YADeckingRule; _gridAreaIndex: Integer io) protected;
//----------------------------------------------------------------
//	Created:	13 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	theRuleType				: Integer;
	gridObjectDict,
	gridCntrlDict			: CM_MemberKeyDictionary;
	gridObj					: Object;
	gridController			: Object;
	locnCell				: CM_YALocationCell;	
	startFromLast			: Boolean;
begin

	theRuleType := _rule.deckingRuleType;

	if _rule.myYADeckingOptions.useReverseOfIn
	or theRuleType = DeckingRule_Default then
		_rule.myYADeckingOptions.setOutDeckingReverseOfIn();
		return;
	endif;
	
	//reverse of in
	startFromLast := self.defaultDeckingStartType = self.DefaultDeckingFromFirst;

	gridObjectDict := self.getDictForDecking(theRuleType);
	
	if gridObjectDict = null then
		//null or custom decking
		return;
	endif;
		
	if startFromLast then
		foreach gridObj in gridObjectDict reversed do
			gridObj.CM_GridObject.applyDeckingRuleOut(_rule, _gridAreaIndex, self.myYADeckingOptions.allYALocationCellsOut);
		endforeach;
	else
		foreach gridObj in gridObjectDict do
			gridObj.CM_GridObject.applyDeckingRuleOut(_rule, _gridAreaIndex, self.myYADeckingOptions.allYALocationCellsOut);
		endforeach;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_rule" type="CM_YADeckingRule"/>
        <Parameter name="_gridAreaIndex" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="areColumnsDecreasing" id="3625081a-1dd9-4e62-882b-e6253bdb2a16">
        <source>areColumnsDecreasing() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 September 2009	cnwer1	Initial creation

*/

vars

begin
	if self.allGridColumns.first.CM_GridColumn.label.isInteger
			and self.allGridColumns.last.CM_GridColumn.label.isInteger then
			//decreasing 
			return (self.allGridColumns.first.CM_GridColumn.label.Integer
			&gt; self.allGridColumns.last.CM_GridColumn.label.Integer);
	else
		return false;
	endif;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="areLocationIdsColThenRow" id="d191e456-8ef1-41af-a1a4-8dc5f772a7b4">
        <source>areLocationIdsColThenRow() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 September 2009	cnwer1	Initial creation

*/

vars

begin
	return self.type = TA_TYPE_FORK_LIFT_STACK or self.myType.isGantryAreaType;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
