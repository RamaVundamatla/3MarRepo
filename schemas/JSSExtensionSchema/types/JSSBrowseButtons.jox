    </JadeMethod>
    <JadeMethod name="delete" id="3378ad03-4a34-4813-a7bd-e2385549f73e">
        <updating/>
        <source>delete() updating;
// --------------------------------------------------------------------------------
// Created:		10 February 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
