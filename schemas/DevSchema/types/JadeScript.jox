    <JadeMethod name="mAGetVoyage" id="110c7b45-a9fd-4e40-b9a0-1f28ebde36d0">
        <source>mAGetVoyage();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 November 2019	jlgma1	Initial creation

*/

vars
	term 		: CM_Terminal;
	voyageSet   : CM_VoyageSet;
	user        : CM_User;
	voyage      : CM_Voyage;
	str : String;
	ts :TimeStamp;
begin
	app.initialize();
	
	create voyageSet transient;
	user := app.myRoot.allUsers["CNWMA1"];
	app.myPassport.setMyUser(user);
	
	term := app.myRoot.allTerminals["CASH"];
	
	term.getAllCurrentVoyages(voyageSet,true,true,false); 
	
	foreach voyage in voyageSet discreteLock do
		if voyage.isNullVoyage then
			continue;
		endif;
		write voyage.code &amp; Tab  &amp; voyage.arrivedDT.asStringJMT; 
	
	endforeach;
	
	ts := str.cnConvertStringToTimeStamp();
epilog
	delete voyageSet;
end;</source>
    </JadeMethod>
