Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 October 2018	jlgndl1	Initial creation	TFS 41404

*/

vars

	processTerminal : CM_ProcessTerminal;

begin

	if self.myVoyageProcess &lt;&gt; null then
		processTerminal := self.myVoyageProcess.allProcessTerminals.getAtKey( self.myVoyageProcess, self.getMyTerminal );
