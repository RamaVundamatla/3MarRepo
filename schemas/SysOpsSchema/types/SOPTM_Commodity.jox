    <JadeMethod name="doSave" id="6f3233b1-844c-45a1-b118-6c67bd9716a2">
        <updating/>
        <source>doSave(): Boolean updating;
//
// Changed On	By			Reason
// ----------	--------	--------------------------------------------
// 25/03/2015	cnwdap1		PAR #35895 CCMS PNL 2461 Added isUsedForPacking attribute to commodity
// 09/10/2017	jlgdap1		TFS 7204 STWR Correct real handling for non-standard locales
vars
	errObj							: CM_Error;
	idx								: Integer;
	tmpListBox						: ListBox;
	ignoreWarnings,rtnValue,
	lHasTemp,lRequiresPower,
	blnRequiresPackDetails,
	isNotAvailableForEntry, isEmpty	: Boolean;
	proxyCommodity					: CM_Commodity;
	lCode,lDescription,
	lShortDesc,lBayplanPrintAs		: String;
	lColour							: Integer;
	lMaxTemp,lMinTemp				: Real;
	lCommodityGroup					: CM_CommodityGroup;	
	theForm							: SOP_TableMaintForm;
	specialStow						: CM_SpecialStow;
	selectedCargoTypes				: ObjectArray;
	isUsedForPacking				: Boolean;						// PAR #35895
	requiresWeighing : Boolean;	//05 Jul 2019	NDL	TFS 44965

begin
    theForm := self.myForm; 
	lCode := theForm.tblInput1.getValueByName(ETRow_Code).String;
	lDescription := theForm.tblInput1.getValueByName(ETRow_Description).String;
	lBayplanPrintAs := theForm.tblInput1.getValueByName(ETRow_BayplanPrintAs).String;
	lHasTemp := theForm.tblInput1.getValueByName(ETRow_HasTemp).Boolean;
	lRequiresPower := theForm.tblInput1.getValueByName(ETRow_RequiresPower).Boolean;
	lColour := theForm.tblInput1.getValueByName(ETRow_Colour).Integer;
	//lMaxTemp := theForm.tblInput1.getValueByName(ETRow_MaxTemp).Real;				// TFS 7204
    //lMinTemp := theForm.tblInput1.getValueByName(ETRow_MinTemp).Real;				// TFS 7204
	lMaxTemp := theForm.tblInput1.getValueByName(ETRow_MaxTemp).String.asRealJMT;	// TFS 7204
    lMinTemp := theForm.tblInput1.getValueByName(ETRow_MinTemp).String.asRealJMT;	// TFS 7204
    lCommodityGroup := theForm.cmbCommodityGrp.myObject.CM_CommodityGroup;
    isNotAvailableForEntry := theForm.tblInput1.getValueByName(ETRow_IsNotAvailableForEntry).Boolean;
    blnRequiresPackDetails := theForm.tblInput1.getValueByName(ETRow_RequiresPackInfo).Boolean;
   	lShortDesc := theForm.tblInput1.getValueByName(ETRow_ShortDescription).String;
	isEmpty := theForm.tblInput1.getValueByName(ETRow_IsEmpty).Boolean;
   	specialStow :=theForm.cmbSpecialStow.listObject.CM_SpecialStow;
	isUsedForPacking := theForm.tblInput1.getValueByName(ETRow_IsUsedForPacking).Boolean;			// PAR #35895
	requiresWeighing := theForm.tblInput1.getValueByName(ETRow_RequiresWeighing).Boolean;	//05 Jul 2019	NDL	TFS 44965
	if theForm.myProxyObject = null then
		if theForm.mode = theForm.Mode_Add then
			create theForm.myProxyObject as CM_Commodity transient;
		else
			app.raiseUnexpectedProgramError(class.name, method.name, 'Proxy object is null for update');
			return false;
		endif;
	endif;
	
	//PAR 19704, CCMS 1080 May 2009
	create selectedCargoTypes transient;
	theForm.mulSelect1.getSelected(selectedCargoTypes);
	
	proxyCommodity := theForm.myProxyObject.CM_Commodity;
	//proxyCommodity.setProxy(lCode, lDescription, lShortDesc, lBayplanPrintAs, lHasTemp, lRequiresPower, blnRequiresPackDetails, isNotAvailableForEntry, isEmpty, lColour, lMaxTemp, lMinTemp, lCommodityGroup,specialStow, selectedCargoTypes);					// PAR #35895
	proxyCommodity.setProxy(lCode, lDescription, lShortDesc, lBayplanPrintAs, lHasTemp, lRequiresPower, blnRequiresPackDetails, isNotAvailableForEntry, isEmpty, lColour, lMaxTemp, lMinTemp, lCommodityGroup,specialStow, isUsedForPacking, selectedCargoTypes, requiresWeighing);	// PAR #35895

	if theForm.mode = theForm.Mode_Add then
		app.myTrxCA.trxCreateCommodity(proxyCommodity, theForm.myCurrentObject,app.myPassport);
	elseif theForm.mode = theForm.Mode_Update then
		app.myTrxUA.trxUpdateCommodity(proxyCommodity, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; theForm.mode.String &amp; ')');
		return false;
	endif;
	
	return app.myPassport.trxCompletedOK();
	
epilog
	delete selectedCargoTypes;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
