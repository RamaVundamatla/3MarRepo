    <JadeMethod name="isCMIFDataMatch" id="bfee9dfd-e047-4883-ac89-bd4b472b3e8f">
        <source>isCMIFDataMatch(_cmifAutoPlan: CMIF_YAAutoPlan; _yaData: CM_YADataBoolean): Boolean;
// -------------------------------------------
// Created 10 May 2005 by cnwdvb1
// -------------------------------------------
begin
	return _cmifAutoPlan.isHazardOrLimitedBoolean_Match(_yaData);
end;</source>
        <Parameter name="_cmifAutoPlan" type="CMIF_YAAutoPlan"/>
        <Parameter name="_yaData" type="CM_YADataBoolean"/>
