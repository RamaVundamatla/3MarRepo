<Class name="WS_DamageCode" id="386e4005-ae6d-49f8-97a3-6647473a1211">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Damage code that can be applied to cargo</text>
    <DbClassMap file="webservice"/>
    <ImplicitInverseRef name="allCargoTypes" id="01a227b1-94b7-439b-8bb5-e0fd98b9c52a">
        <memberTypeInverse/>
        <type name="WS_CargoTypeArray"/>
        <text>The list of cargo types that this damage code applies to</text>
    </ImplicitInverseRef>
    <PrimAttribute name="code" id="284d27a3-bbf3-4510-b936-2d8ad022eec1">
        <length>11</length>
        <embedded/>
        <type name="String"/>
        <text>Damage code ex.SCR</text>
    </PrimAttribute>
    <PrimAttribute name="description" id="dfdd2939-1470-4dbd-bac1-a052b7acbf49">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <text>Damage code desciption ex.Scratch</text>
    </PrimAttribute>
    <JadeMethod name="delete" id="ff379011-70f3-46ba-ae81-c6a562caa206">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 October 2011	cnwndl1	Initial creation	Par 28303

*/

vars

begin

	if not self.allCargoTypes.isEmpty then
		self.allCargoTypes.purge();
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setAllCargoTypes" id="9a865098-7576-421c-bd7e-88151a203a51">
        <updating/>
        <source>setAllCargoTypes( _object : CM_DamageDefinitionCode ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2022	jlier1	Initial creation 53971

*/

vars
	cargoType : CM_CargoType;
	wsCargoType : WS_CargoType;
begin
	foreach cargoType in _object.allCargoTypes discreteLock do
		create wsCargoType transient;
		wsCargoType.setProxyFromObject( cargoType );
		wsCargoType.description := cargoType.abbreviation;
		self.allCargoTypes.add( wsCargoType );
	endforeach;
epilog

end;</source>
        <Parameter name="_object" type="CM_DamageDefinitionCode"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="dba17a64-db2b-451c-b23d-c0ae887e0836">
        <updating/>
        <source>setProxyFromObject( _object : CM_DamageDefinitionCode ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 October 2011	cnwndl1	Initial creation	Par 28303

*/

vars

	
begin

	inheritMethod(_object);
	
	self.code := _object.code;
	self.description := _object.description;
	

epilog

end;</source>
        <Parameter name="_object" type="CM_DamageDefinitionCode"/>
    </JadeMethod>
</Class>
