<CollClass name="CM_OOWCreationByOrdinal" id="5141a0ea-5663-46c9-a0d7-d2fb65838a3d">
    <loadFactor>66</loadFactor>
    <memberType name="CM_OOWCreationDetail"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="voyages"/>
    <MemberKey>
        <property name="CM_OOWCreation::order"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_OOWCreation::orderType"/>
    </MemberKey>
    <PrimAttribute name="isReversed" id="9faa5ed1-9894-4a1a-8756-09418a9b47e2">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <JadeMethod name="getTotalItems" id="6694e239-383c-4ed0-81b0-704c4b765cc6">
        <source>getTotalItems() : Integer;
// ---------------------------------------------------------------------------
// Created:		10 August 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	oow : CM_OOWCreationDetail;
	tot : Integer;
begin

	foreach oow in self discreteLock do
		tot := tot + oow.getTotalItems();
	endforeach;

	return tot;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
</CollClass>
