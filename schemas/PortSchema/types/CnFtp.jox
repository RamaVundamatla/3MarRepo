<Class name="CnFtp">
    <JadeMethod name="createDirectory" id="9b94e5c7-39ea-47a9-b12f-604a27f581e4">
        <source>createDirectory(_directory : String) : String;
//
//22 May 2013	cnwrs1	Par 31483 Ftp connect not always connecting
//
vars
	resultInt : Integer;
	result : String;
begin
	resultInt := self.emFtpCreateDirectory(self.connectionHandle, _directory);
	if resultInt &lt;&gt; 0 and 
	   resultInt &lt;&gt; 12003 then	// directory already exists, dont care its there
		result := "CnFtp::createDirectory for " &amp; _directory &amp; " : " &amp; self.cnGetInternetError(resultInt);
	else
		result := CN_OK;
	endif; 
	return result;
end;
</source>
        <Parameter name="_directory" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jmtGetFileModifiedDateTime" id="a253ba45-d40c-420a-94f0-05c78556aecb">
        <source>jmtGetFileModifiedDateTime(_fileInfo : Binary; _lastModified : TimeStamp output ) : String;
//
//26 May 2014 	ccms 34183 process files in created date time
//
vars
	result : Integer;
	fileSize : Integer;
	attributes: String; 
	creationDate: Integer; 
	creationTime: Integer; 
	accessDate: Integer; 
	accessTime: Integer; 
	updateDate: Integer; 
	updateTime: Integer;
	fileName : String;
	date : Date;
	time : Time;
	ts : TimeStamp;
begin
	result := self.emGetFileInfo(_fileInfo, fileName, attributes, fileSize, creationDate, creationTime,
								accessDate, accessTime, updateDate, updateTime);
    if result = 1 then
    	return method.cnGetMethodName() &amp; " : fileInfo packet is too small for emGetFileInfo";
		
    elseif result = 2 then
    	return method.cnGetMethodName() &amp; " : fileInfo packet is empty in emGetFileInfo";
    endif;

	if fileSize &lt; 0 or
	   fileSize &gt; Max_Integer then
		return "CnFtp::cnGetFileInfo file " &amp; fileName &amp; " appears to exceed 2GB, suggest using CnFtp64 class";
	endif;
	
	fileSize := fileSize.Integer;
	date.setDate (updateDate mod 100 , 					// day                
					(updateDate div 100) mod 100 , 		// month 
					 updateDate div 10000  				// year
                  ) ;
   	time.setTime (updateTime div 10000 , 					// hour
                   (updateTime div 100) mod 100 , 		// minute
                    updateTime mod 100 ,     			// seconds
                    0                    				// millisecs
                  ) ;

    ts.setTime(time);
    ts.setDate(date);
    _lastModified := ts;
    return CN_OK;
end;</source>
        <Parameter name="_fileInfo" type="Binary"/>
        <Parameter name="_lastModified" type="TimeStamp" usage="output"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
