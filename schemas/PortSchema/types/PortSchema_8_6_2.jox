    <JadeMethod name="clearNonYardAllocsFromTermColl" id="b8ecfef0-d4f2-4769-9dc3-111975c63d14">
        <source>clearNonYardAllocsFromTermColl(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 July 2021	navndl1	Initial creation	TFS 49952

*/

vars

	ya : CM_YardAllocation;
	countTerm : Integer;
	class : Class;
	classes : ClassColl;
	obj : Object;

begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	app.writeLog(method.qualifiedName &amp; " Clearing Non 'Yard Allocations' from the allYardAllocations collection on Terminal", LogINFO);
	
	create classes transient;
	
	classes.add( CM_InvoiceAllocation );
	classes.add( CM_InvoiceCargoAllocation );
	classes.add( CM_InvoiceInventoryAllocation );

	beginTransaction;
	foreach class in classes do
		countTerm := 0;
		foreach obj in class.instances do
			ya := obj.CM_YardAllocation;
			if ya.myTerminal &lt;&gt; null then	
				ya.setTerminal(null);
				countTerm := countTerm + 1;
			endif;
		endforeach;
		if countTerm &gt; 0 then
			app.writeLog(method.qualifiedName &amp; " Cleared 'myTerminal' for " &amp; countTerm.String &amp; " " &amp; class.name &amp; " objects", LogINFO);
		else
			app.writeLog(method.qualifiedName &amp; " no " &amp; class.name &amp; " objects found that required 'myTerminal' to be cleared", LogINFO);
		endif;
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Clearing Non 'Yard Allocations' from the allYardAllocations collection on Terminal - Complete", LogINFO);
	self.addScriptRun(method.name);
	
epilog

	delete classes;

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="clearOffSiteFuturePlans" id="e1c11eda-9952-4061-9a85-dae655f91466">
        <source>clearOffSiteFuturePlans( _updController : CnEcReleaseController );
/*

Purpose:			

Parameters:			Cargo on Trains and Trucks could previously be moved off-site while
					they were still planned to on-site yard locations.
					Subsequent attempts to change the on-site Terminal Area definition were
					then thwarted by these planned mopves that could not be deleted by the users.
					Warnings are now issued, during Wagon departing and Gating out, and if ignored
					the planned future moves are deleted during the off-site move.
					
					This method is to find and clean up the pre-existing instances of this.

Return Value:		

Date		Who		Reason
30 June 2021	navndl1	Initial creation	TFS 51421

*/

vars

	offSitePlanned : CM_TISet;
	objArray : ObjectArray;
	lcIter : Iterator;
	lcObj : Object;
	lc : CM_LocationsController;
	fmIter : Iterator;
	fm : CM_FutureMove;
	ti : CM_TrackedItem;

begin

	if self.hasScriptBeenRunAtAll(method.name, _updController) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Clearing Furture Planned Moves for Off-site Cargo", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Clearing Furture Planned Moves for Off-site Cargo") ;	
	endif;

	create offSitePlanned transient;
	create objArray transient;
	
	CM_YardController.allInstances( objArray, 0, true );
	
	lcIter := objArray.createIterator;
	while lcIter.next( lcObj ) do
		lc := lcObj.CM_LocationsController;
		fmIter := lc.allPlannedFutureMoves.createIterator;
		while fmIter.next( fm ) do
			ti := fm.getTrackedItem;
			if ti = null or not ti.isOffSite then
				continue;
			endif;
			offSitePlanned.addNoDuplicates( ti, false );
		endwhile;
		delete fmIter;
	endwhile;
	
	foreach ti in offSitePlanned do
		app.myPassport.setMyTerminal( ti.myTerminal );
		beginTransaction;
		ti.allPlannedFutureMoves.purge;
		commitTransaction;
	endforeach;
	
	app.writeLog(method.qualifiedName &amp; " Clearing Furture Planned Moves for Off-site Cargo complete", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Clearing Furture Planned Moves for Off-site Cargo complete") ;	
	endif;
	
	self.addScriptRun(method.name);

epilog

	delete lcIter;
	delete fmIter;
	delete objArray;
	delete offSitePlanned;

end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertAllMutexes" id="e2d0cabe-86ad-43f5-b1b6-fcbcee8ba303">
        <source>convertAllMutexes(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2021	navndl1	Initial creation	TFS 51142

*/

vars

	objArray : ObjectArray;
	root : CM_Root;
	term : CM_Terminal;

begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Convert BGP Mutexes", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Convert BGP Mutexes") ;	
	endif;
	
	create objArray transient;
	BGP_Mutex.allInstances( objArray, 0, true );
	
	root := app.myRoot;
	
	beginTransaction;
	if not objArray.isEmpty then
		objArray.purge();
	endif;
	
	root.addUpdateRootMutexes();
	
	foreach term in root.allTerminals do
		term.addUpdateTerminalMutexes();
	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " all BGP Mutexes converted", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" all BGP Mutexes converted") ;
	endif;
	
	self.addScriptRun(method.name);

epilog

	delete objArray;

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertInvRoundLineTotalConfig" id="8b3a527c-6993-4e71-ab7e-a3b0efb6127d">
        <source>convertInvRoundLineTotalConfig(_controller: CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 Mar 2021 cnwma1 ChangeRequest 50925: ASPA - New Total Column in Invoice Form

*/

vars
	term : CM_Terminal;
begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; "Converting 'InvoiceRoundLineTotal' From Boolean to Integer", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Converting 'InvoiceRoundLineTotal' From Boolean to Integer'") ;	
	endif;
	
	beginTransaction;
	foreach term in app.myRoot.allTerminals do
		if term.getConfig(InvoiceRoundLineTotal).Boolean then
			term.setConfig(InvoiceRoundLineTotal, CMIF_ConfigTerminal.InvLineRound_Value_Zero );	// InvLineRound_Value_Zero   = 0
		else
			term.setConfig(InvoiceRoundLineTotal, CMIF_ConfigTerminal.InvLineRound_Value_NoRound );	//InvLineRound_Value_NoRound = 6
		endif;
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; "Converting 'InvoiceRoundLineTotal' From Boolean to Integer Complete",LogINFO );
	if _controller &lt;&gt; null then
		_controller.logEntry("Converting 'InvoiceRoundLineTotal' From Boolean to Integer Complete") ;	
	endif;
	self.addScriptRun(method.name);
	
epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertOldStyleTBAsToRRPs" id="3a2b3e1f-675d-48b3-a714-fe90d43f39d4">
        <source>convertOldStyleTBAsToRRPs(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2020	jlgndl1	Initial creation	TFS 47004

*/

vars

	tbaS : CM_TISet;
	term : CM_Terminal;
	tba : CM_TrackedItem;
	processedTbaS : CM_TISet;
	deleteTBAs : CM_TISet; 

begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Convert Old Stype TBAs to RRPs", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Convert Old Stype TBAs to RRPs") ;	
	endif;
	
	create tbaS transient;
	create processedTbaS transient;
	create deleteTBAs transient;
	
	foreach term in CM_Terminal.instances do
		term.allTbaTIsByIdCargoType.copy( tbaS );
	endforeach;
	
	beginTransaction;
	
	foreach tba in tbaS do	
		if tba.convertTBA( deleteTBAs ) then
			processedTbaS.add(tba);
		endif;	
	endforeach;
	
	deleteTBAs.purge();
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Convert Old Stype TBAs to RRPs " &amp; processedTbaS.size.String &amp; " of " &amp; tbaS.size.String &amp; " Completed", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Convert Old Stype TBAs to RRPs " &amp; processedTbaS.size.String &amp; " of " &amp; tbaS.size.String &amp; " Completed") ;
	endif;
	
	self.addScriptRun(method.name);

epilog

	delete tbaS;
	delete processedTbaS;
	delete deleteTBAs;

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertOperatorCarriers" id="9f9d9474-7a48-44b1-94dc-1bbadeb012be">
        <source>convertOperatorCarriers(_controller : CnEcReleaseController);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22/08/2019	jlgdap1		Initial creation TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
//
vars
	operator : CM_Operator;
	iter : Iterator;
	cargoTypeKey : Integer;
	cargoType : CM_CargoType;
	carrierSet : CM_CarrierSet;
	criterionType : CM_YACriteriaType;
	obj : Object;
	criteria : CMIF_Array;
	proxyCriterion : CM_YACriteria;
	cmifCriterion : CMIF_YACriteriaPriority;
	itemCode : String;
	value : Any;
	proxy : CM_OperatorCarrierCriteria;
	realCriteria : CM_ObjectMatchCriteria;

begin
	if self.hasScriptBeenRunAtAll(method.name, null) then
		return;
	endif;
	app.writeLog(method.qualifiedName &amp; " Convert CM_Operator::allCarriersByCargoTypeId info to CM_OperatorCarrierCriteria", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(method.qualifiedName &amp; " Convert CM_Operator::allCarriersByCargoTypeId info to CM_OperatorCarrierCriteria");
	endif;
	
	criterionType := app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType];
	create criteria transient;
	
	beginTransaction;
	foreach operator in CM_Operator.instances do
		if operator.allCarriersByCargoTypeId.isEmpty then
			continue;
		endif;
		if not operator.allOperatorCarrierCriteria.isEmpty then
			continue;
		endif;
		
		iter := operator.allCarriersByCargoTypeId.createIterator;
		while iter.next(obj) do
			operator.allCarriersByCargoTypeId.getIteratorKeys(cargoTypeKey, iter);
			cargoType := app.myRoot.allCargoTypesById[cargoTypeKey];
			if cargoType = null then
				continue;
			endif;
			
			carrierSet := obj.CM_CarrierSet;
			
			// set up the proxy criteria details
			create proxyCriterion transient;
			itemCode := "Cargo Type";
			value := cargoType.getYAIdentifier;
			
			proxyCriterion.setProxy(criterionType, value, itemCode);
			cmifCriterion := proxyCriterion.getTransient();
			criteria.add(cmifCriterion);
			
			// create a proxy CM_OperatorCarrierCriteria object
			create proxy transient;
			proxy.setProxy(criteria, null);
			proxy.setAllCarriers(carrierSet);
			proxy.setMyOperator(operator);
			
			app.myUtilityCA.utlCreateObjMatchCrit(proxy, realCriteria, app.myPassport);
			if app.myPassport.hasErrorsOrWarnings then
				// log an error
				app.writeLog(method.qualifiedName &amp; " Conversion for Operator " &amp; operator.code &amp; " cargo Type " &amp; value.String &amp; " has FAILED *********", LogINFO);
				app.writeLog(method.qualifiedName &amp; app.myPassport.getErrorsAndWarningsAsString, LogINFO);
				if _controller &lt;&gt; null then
					_controller.logEntry(method.qualifiedName &amp; " Conversion for Operator " &amp; operator.code &amp; " cargo Type " &amp; value.String &amp; " has FAILED *********");
					_controller.logEntry(method.qualifiedName &amp; app.myPassport.getErrorsAndWarningsAsString);
				endif;
			endif;
			
			// tidy up transients
			delete proxy;
			delete proxyCriterion;
			delete cmifCriterion;
			criteria.clear;
		endwhile;
		delete iter;
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Convert CM_Operator::allCarriersByCargoTypeId info to CM_OperatorCarrierCriteria", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(method.qualifiedName &amp; " Convert CM_Operator::allCarriersByCargoTypeId info to CM_OperatorCarrierCriteria");
	endif;
	self.addScriptRun(method.name);
	
epilog
	delete criteria;
	delete iter;
	delete proxy;
	delete proxyCriterion;
	delete cmifCriterion;
end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertRelReqValConfig" id="4bd8a68f-f774-428a-8eeb-2cb228cdef9a">
        <source>convertRelReqValConfig(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 August 2021	navndl1	Initial creation	TFS 51785

*/

vars

	root : CM_Root;
	term : CM_Terminal;
	convValue : Integer;

begin

	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Convert 'Selected Cargo Not Matching Release is OK With Warning' config to 'Road Gate Release Request Validation'", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Convert 'Selected Cargo Not Matching Release is OK With Warning' config to 'Road Gate Release Request Validation'") ;	
	endif;

	root := CM_Root.firstInstance;

	beginTransaction;
	foreach term in root.allTerminals do
		if term.getConfig( AllowReleaseMisMatch ) = null then
			//Its never been set so no warning and no error i.e. behaviour from a couple of releases back.
			convValue := 2;
		else
			if term.getConfig( AllowReleaseMisMatch ).Boolean then
				//set to true - show warning only
				convValue := 1;
			else
				//set to false- they want an error - ( The new default behviour as well ).
				convValue := 0;
			endif;
		endif;
		term.setConfig( RoadGateRelReqVal, convValue );
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " config 'Road Gate Release Request Validation' populated", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" config 'Road Gate Release Request Validation' populated") ;
	endif;
	
	self.addScriptRun(method.name);

epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="convertToUseStorageConfig" id="960097ba-63c8-4b4d-aee9-975ad39c8b7d">
        <source>convertToUseStorageConfig( _controller : CnEcReleaseController );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 July 2019	jlgndl1	Initial creation	TFS 45574

*/

vars

	terminal : CM_Terminal;
	storageConfig : CM_StorageConfig;
	criteriaTypes : CM_YACriteriaTypeArray;
	firstDayTimeCutoff	: Time;
	triggersIntArray : IntegerArray;
	includeFirstDay : Boolean;
	
	allPxyTriggers : CM_StorageTriggerByType;
	triggerInt : Integer;
	pxyStorageTrigger : CM_StorageTrigger;
	proxyStorageConfig : CM_StorageConfig;
	
	realStorageConfig : CM_StorageConfig;
	operatorTerminal : CM_OperatorTerminal;
	tempOperTerminals : CM_OperatorTermByOperatorDict;

begin

	//Have we run it before
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;	
	
	app.writeLog( method.qualifiedName &amp; " Convert all Terminals to use 'Storage Config'", LogINFO);
	
	if _controller &lt;&gt; null then
		_controller.logEntry(" Convert all Terminals to use 'Storage Config'") ;	
	endif;
	
	firstDayTimeCutoff := "00:00".Time;
	
	create criteriaTypes transient;
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_CargoType]);
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_OperatorItem]);
	criteriaTypes.add(app.myRoot.allYACriteriaTypes[YACriteriaType_ContentsStatus]);
	
	create triggersIntArray transient;
	triggersIntArray.add( StorageDebtor );
	triggersIntArray.add( IMEX_EX_TO_IM );
	triggersIntArray.add( IMEX_EX_TO_ST );
	triggersIntArray.add( IMEX_IM_TO_EX );
	triggersIntArray.add( IMEX_IM_TO_ST );
	triggersIntArray.add( IMEX_IM_TO_TR );
	triggersIntArray.add( IMEX_ST_TO_EX );
	triggersIntArray.add( IMEX_ST_TO_IM );
	triggersIntArray.add( IMEX_TR_TO_EX );
	triggersIntArray.add( IMEX_TR_TO_IM );
	triggersIntArray.add( IMEX_TR_TO_ST );
	triggersIntArray.add( SubTerminal );
	triggersIntArray.add( VoyageChange );
	
	create tempOperTerminals transient;
	
	foreach terminal in app.myRoot.allTerminals discreteLock do
		storageConfig := terminal.myStorageConfig;
		if terminal.myStorageConfig &lt;&gt; null then
			app.writeLog( method.qualifiedName &amp; " " &amp; terminal.code &amp; " already using 'Storage Config'", LogINFO );
			if _controller &lt;&gt; null then
				_controller.logEntry( " " &amp; terminal.code &amp; " already using 'Storage Config'" ) ;	
			endif;
		else
		
			tempOperTerminals.clear();
			foreach operatorTerminal in terminal.allOperatorTerminals do
				if operatorTerminal.emptyFreeStorageDays &gt; 0
				or operatorTerminal.freeStorageDays &gt; 0
				or operatorTerminal.fullFreeStorageDays &gt; 0
				then
					tempOperTerminals.add( operatorTerminal );
				endif;
			endforeach;
		
			create allPxyTriggers transient;
			foreach triggerInt in triggersIntArray do
				create pxyStorageTrigger transient;
				pxyStorageTrigger.setProxy( triggerInt, false, null);
				allPxyTriggers.add(pxyStorageTrigger);
			endforeach;
			
			includeFirstDay := terminal.getConfig(InvStorageDaysInclusive).Boolean;
		
			create proxyStorageConfig transient;
			proxyStorageConfig.setProxy(criteriaTypes,	//_criteria : CM_YACriteriaTypeArray; 
										allPxyTriggers,	//_triggers : CM_StorageTriggerByType;
										firstDayTimeCutoff,	//_firstDayTimeCutoff : Time;
										includeFirstDay,	//_includeFirstDay : Boolean;
										true,	//_includeLastDay : Boolean; 
										terminal,	//_terminal : CM_Terminal;
										CM_StorageConfig.ShipReceivalActualDischarge,	//_shipReceivalType : Integer;
										CM_StorageConfig.ShipReleaseActualLoad,	//_shipReleaseType : Integer;
										null,	//_calendar : CM_Calendar;
										null,	//_compulsory : CM_Calendar
										-1,		//_roadReceivalType : Integer;
										-1,		//_railReceivalType : Integer;
										-1		//_unpackReceivalType : Integer;
										);
			
			app.myTrxCA.trxConvertToNewStorageConfig( proxyStorageConfig, realStorageConfig, tempOperTerminals, app.myPassport );
			
			if not app.myPassport.trxCompletedOK then
				app.writeLog( method.qualifiedName &amp; " Convert all Terminals to use 'Storage Config' - Error " &amp; app.myPassport.getErrorsAndWarningsAsString, LogINFO);
				if _controller &lt;&gt; null then
					_controller.logEntry(" Convert all Terminals to use 'Storage Config' - Error " &amp; app.myPassport.getErrorsAndWarningsAsString) ;	
				endif;
				return;
			endif;
			
			if allPxyTriggers &lt;&gt; null then
				if not allPxyTriggers.isEmpty then
					allPxyTriggers.purge();
				endif;
				delete allPxyTriggers;
			endif;
			delete proxyStorageConfig;
			
			app.writeLog( method.qualifiedName &amp; " " &amp; terminal.code &amp; " now using 'Storage Config'", LogINFO );
			if _controller &lt;&gt; null then
				_controller.logEntry( " " &amp; terminal.code &amp; " now using 'Storage Config'" ) ;	
			endif;
			
			foreach operatorTerminal in tempOperTerminals where operatorTerminal.myOperator &lt;&gt; null do
				app.writeLog( method.qualifiedName &amp; " - added storage detail for " &amp; terminal.code &amp; "/" &amp; operatorTerminal.myOperator.code, LogINFO );
				if _controller &lt;&gt; null then
					_controller.logEntry( " - added storage detail for " &amp; terminal.code &amp; "/" &amp; operatorTerminal.myOperator.code ) ;	
				endif;
			endforeach;

		endif;
	endforeach;
	
	
	app.writeLog( method.qualifiedName &amp; " Convert all Terminals to use 'Storage Config' - Complete", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Convert all Terminals to use 'Storage Config' - Complete") ;	
	endif;	
	// Log that it already ran.
	self.addScriptRun(method.name);

epilog

	delete criteriaTypes;
	delete triggersIntArray;
	if allPxyTriggers &lt;&gt; null then
		if not allPxyTriggers.isEmpty then
			allPxyTriggers.purge();
		endif;
		delete allPxyTriggers;
	endif;
	delete proxyStorageConfig;
	
	delete tempOperTerminals;

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="createBOLCalcTypes" id="14737b35-8b87-4ee1-b3f7-c628a14da0e5">
        <source>createBOLCalcTypes(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 October 2019	jlgndl1	Initial creation	TFS 47100

*/

vars

begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	app.writeLog(method.qualifiedName &amp; " Create new BOL Calculation Types", LogINFO);

	beginTransaction;
	app.myRoot.createInvoiceCalcTypes();
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Create new BOL Calculation Types - Complete", LogINFO);
	self.addScriptRun(method.name);
epilog

end;</source>
