    <JadeMethod name="setNumForEventType" id="9c8da0e4-da7a-47ca-9c2c-5a6c6a4b0543">
        <updating/>
        <source>setNumForEventType(_eventType : Integer; _num : Integer; _userCode : String) updating, protected;
/* ---------------------------------------------------------------------------
Created:     01 July 2010 by cnwrs2

Purpose:     
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars
	event		: CM_EventTransaction;
	totNum		: Integer;
	cmifEventCtrl : CMIF_VoyageEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
	
begin

	self.raiseExceptionIfTransient(method);
	
	if _eventType &lt;&gt; EVT_VoyCageMove and
	   _eventType &lt;&gt; EVT_VoyExtraMove and
	   _eventType &lt;&gt; EVT_VoyLashingBinMove and
	   _eventType &lt;&gt; EVT_VoyNumLashings and
	   _eventType &lt;&gt; EVT_VoyNumUnlashings then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unhandled event type ' &amp; _eventType.String);
		return;
	endif;

	event := self.allEventTransactionsByType.getAtKeyGeq(_eventType, null);
	if event &lt;&gt; null and event.type &lt;&gt; _eventType then
		event := null;
	endif;
	
	if event &lt;&gt; null then
		if event.isKindOf(CMEVT_VoyageEvent) then
			event.CMEVT_VoyageEvent.setMyVoyage(self);
			event.setAmount(_num);  //epr par 36902 14/6/15
			// PAR 25719
			//event.createCharge(app.myPassport);
			app.myPassport.addEventTransactionForDeferUpd(event,app.myPassport.myTerminal); // ### JIRA 33567 03DEC2024 NAVAB1
		endif;
		return; //17/02/2025	navkc1 JIRA Bug MTN-33582
	endif;	
	
	/* //17/02/2025	navkc1 JIRA Bug MTN-33582
	if event = null then
		event := app.createEvent(_eventType, app.serverTimestampAtTrxStart,	self.myTerminal, _userCode, false, false,0);
	endif;
	*/
	
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - Start
	create cmifEventCtrl transient;
	cmifEventCtrl.type := _eventType;
	cmifEventCtrl.dateTime := app.serverTimestampAtTrxStart;
	cmifEventCtrl.myTerminal := self.myTerminal;
	cmifEventCtrl.userCode := _userCode;
	cmifEventCtrl.myVoyage := self;
	
	event := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_VoyageEvent;
	//17/02/2025	navkc1 JIRA Bug MTN-33582 - End
	
epilog
	delete cmifEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
end;</source>
        <access>protected</access>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_num" type="Integer"/>
        <Parameter name="_userCode" type="String"/>
    </JadeMethod>
