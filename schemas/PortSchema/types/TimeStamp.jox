    </JadeMethod>
    <JadeMethod name="addDecimalDays" id="6635c892-cef3-4204-ac83-f6f441f9f5a4">
        <source>addDecimalDays( _days : Decimal) : TimeStamp;
/*

Purpose:	e.g. can add 3.5 days and will and 3 days 12 hours 		

Parameters:			

Return Value:		

Date		Who		Reason
13 April 2018	jlger1	Initial creation

*/

vars
	endTS : TimeStamp;
	mins,
	hours : Decimal[14,4];
begin
	endTS:=self.addDays(_days.Integer);
	hours:= (_days - _days.Integer) * 24;
	endTS:=endTS.addHours(hours.Integer);
	mins:=(hours - hours.Integer) * 60;
	endTS:=endTS.addMinutes(mins.Integer);
	
	return endTS;
epilog

end;</source>
        <Parameter name="_days" type="Decimal"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
