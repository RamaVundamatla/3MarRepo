    <JadeMethod name="updateStatusWoWLE" id="98026543-e762-46a6-b0ac-5512bb6ec2bc">
        <source>updateStatusWoWLE(_status : Integer;
				  _vvr     : CM_VehicleVisitRecord);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/11/2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/

vars
	woJob	:	CM_Job;
	wle		:	CM_WorkListEntry;
begin
	foreach woJob in self.allJobs do
		if woJob &lt;&gt; null then
			foreach wle in woJob.workListEntries do
					if wle.CM_WOVehicleVisitToDoWLE.myVehicleVisit &lt;&gt; _vvr then
						continue;
					endif;
					if wle.status = JOB_COMPLETE then
						continue;
					endif;
					wle.setStatus(_status);
				endforeach;
			endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_status" type="Integer"/>
        <Parameter name="_vvr" type="CM_VehicleVisitRecord"/>
    </JadeMethod>
    <JadeMethod name="validate" id="a38fa640-5c72-4903-b06a-5e89fa0f75bf">
        <source>validate()protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
04 October 2022	navcs2  ChangeRequest 54344: EUP - VAS Work Orders - Jobs
28 Dec 2022		navhl20	Task 56057(54344): WodToDoDetail validation
*/

vars

begin
	//Start 28.12.2022 navhl20 TFS 56057(54344)
	inheritMethod();
	if self.allVehicleVisits.isEmpty() then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Vehicle_visits), null, null); 
	endif;
	//End 28.12.2022 navhl20 TFS 56057(54344)
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
