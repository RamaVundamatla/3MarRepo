    <JadeMethod name="getMaximumColumn" id="cf2d7062-a7ce-4477-86f0-58c90f9e1be6">
        <source>getMaximumColumn(_sdf : CMUI_ScrollableDrawingFrame) : Integer;
// ---------------------------------------------------------------------------
// Created:     June 2009 - form cloned from YRD_RailOpsForm and YRD_GridAreasForm
