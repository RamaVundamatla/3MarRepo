    <JadeMethod name="setPEL1AutoPostPrePay" id="3d90ee60-e3a8-4146-b7d0-5f0586fc3d85">
        <updating/>
        <source>setPEL1AutoPostPrePay()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 April 2019	jlgndl1	Initial creation	TFS 44248

*/

vars

	invLine : CM_InvoiceLine;
	invStatus : CMIF_InvoiceStatus;

begin

	foreach invLine in self.invoiceLines discreteLock do
		if not invLine.externalTS05.date.isValid() then
			//we still have unsent lines, don't mark as posted yet.
			return;
		endif;
	endforeach;
	
	create invStatus transient;
	invStatus.newStatus := CM_Invoice.INVOICE_POSTED;
	invStatus.myInvoice := self;
	if self.toDT.isValid() then
		invStatus.toDT := self.toDT;
	else
		invStatus.toDT := app.actualTimeServer;
	endif;

	self.setForUpdateStatus(invStatus, false);

epilog

	delete invStatus;

end;</source>
    </JadeMethod>
    <JadeMethod name="setPaginationCellColour" id="f8c6a1d7-36c9-4053-b06f-c0c319eb1b4c">
        <source>setPaginationCellColour(table: Table input; _rows: EntTableRowArray; obj: Object; theRow: Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 August 2025	navsaa30	Initial creation
// 13 Aug 2025  navsaa30 	35313 MTN | Pagination - Invoice List
*/

vars
etrow : EntTableRow;
idx, backClr : Integer;
begin
	idx := 0;
	foreach etrow in _rows do
		if etrow.name = ETRow_Status then
			idx := _rows.indexOf(etrow);
			break;
		endif;
	endforeach;


	if idx &gt; 0 then
		backClr := self.getStatusColor();
		table.accessCell(theRow, idx).backColor := backClr;
		table.accessCell(theRow, idx).foreColor := backClr.getInverseColour();
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="_rows" type="EntTableRowArray"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
    </JadeMethod>
