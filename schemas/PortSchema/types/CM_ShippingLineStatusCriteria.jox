    <JadeMethod name="pxyCreateUpdateProxy" id="6454d538-cd1a-4c99-9050-f08df59ad412">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/08/2023	navkc1	CR 59580	Task 59586: Jade - CustDocs Shipping Line Status TRX

*/

vars
	pxySelf	: SelfType;
begin
	pxySelf := inheritMethod();
	
	pxySelf.myShippingLineStatus := self.myShippingLineStatus;
	pxySelf.myTerminal := self.myTerminal;
	
	return pxySelf;

epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
