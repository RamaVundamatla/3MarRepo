    <JadeMethod name="getCustomStatus" id="db950972-0ce4-4f85-b142-0760a801d2dd">
        <source>getCustomStatus() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27/09/2023	navkc1	CR 60428 Task 60701: UI - Customs Status on Transport UI

*/

vars
	ti		: CM_TrackedItem;
	str,
	messStr	: String;
	tis		: CM_TISet;
begin
	
	create tis transient;
	
	self.getAllTrackedItems(tis);
	
	foreach ti in tis do
		
		str := ti.getCustomsStatus();
		
		if str = null then
			continue;
		endif;
		
		/*
		if messStr = null then
			messStr := str;
		elseif messStr.pos(str, 1) = 0 then
			messStr := messStr &amp; "," &amp; str;
		endif;
		*/
		
		messStr.addStringToList(str, ","); //04/04/2025	navkc1 JIRA Story MTN-33940
	endforeach;
	
	return messStr;
	
epilog
	delete tis;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCutoffDT" id="3d659bce-85a2-4472-966f-849bebdb38c0">
        <source>getCutoffDT(_recCutoffCode : String; _operator : CM_Operator): TimeStamp;

/*
Date			Who		Reason
10 June 2009	cnwar2	Initial creation

*/
vars
	recCutoffDef 	: CM_ReceivalCutoffTermDef;
	recCutoff		: CM_ReceivalCutoffVoyage;
	
begin
	recCutoff := self.allReceivalCutoffs[_recCutoffCode, _operator];
	
	if recCutoff &lt;&gt; null then
		return recCutoff.cutoffDateTime;
	endif;
	
	return null;
end;</source>
        <Parameter name="_recCutoffCode" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getCutoffDTForCode" id="9f2a6164-c049-4e59-b7ae-bc89c86cde15">
        <source>getCutoffDTForCode( _code : String ): TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 November 2017	jlgndl1	Initial creation	TFS 7888

*/

vars

	termCutoff : CM_ReceivalCutoffTermDef;
	earliestTS : TimeStamp;
	cutoffTS : TimeStamp;
	voyCutoff : CM_ReceivalCutoffVoyage;

begin

	if self.overrideDefaults then
		voyCutoff := self.allReceivalCutoffs.getAtKey( _code, null );
		if voyCutoff &lt;&gt; null then
			return voyCutoff.cutoffDateTime;
		endif;
		
	else
		termCutoff := self.myTerminal.allReceivalCutoffDefs[ _code ];
		if termCutoff &lt;&gt; null then
			termCutoff.getCutoffsForVoyage( self, earliestTS, cutoffTS );
			return cutoffTS;
		endif;
		
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getCutoffDTForCodeLocalTZ" id="2a0e0e98-6d3d-470e-80cc-be4baf0d60ba">
        <source>getCutoffDTForCodeLocalTZ( _code : String ): TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 November 2017	jlgndl1	Initial creation	TFS 7888

*/

vars
	
	dbTs : TimeStamp;
	
begin
	
	dbTs := self.getCutoffDTForCode( _code );
	
	if dbTs &lt;&gt; null then
		return self.systemToLocalTime( dbTs );
	else
		return	null;
	endif;

epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getCutoffDTLocalTZ" id="1705e458-dd63-46fe-88f0-1d4e2f501c9a">
        <source>getCutoffDTLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2016	cnwns1	Initial creation
// 07 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	if self.cutOffDT &lt;&gt; null then
		return self.systemToLocalTime(self.cutOffDT);
	else
		return	null;
	endif;
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getCutoffPreNoteDT" id="d4f977e8-e151-42ba-b329-4cfb48856b02">
        <source>getCutoffPreNoteDT(_recCutoffCode : String; _operator : CM_Operator): TimeStamp;

/*
Date			Who		Reason
04/03/2025	navkc1 JIRA Story MTN-34227: MTN | Prenote Voyage Cut Offs - TRX Code changes for Prenote Cutoffs

*/
vars
	recCutoffDef 	: CM_ReceivalCutoffTermDef;
	recCutoff		: CM_ReceivalCutoffVoyage;
	
begin
	recCutoff := self.allReceivalCutoffs[_recCutoffCode, _operator];
	
	if recCutoff &lt;&gt; null then
		return recCutoff.cutoffDateTimePN;
	endif;
	
	return null;
end;</source>
        <Parameter name="_recCutoffCode" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
