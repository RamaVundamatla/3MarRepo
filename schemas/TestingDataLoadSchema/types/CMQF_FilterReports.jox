<Class name="CMQF_FilterReports">
    <JadeMethod name="getValueFromOpts" id="6c410a71-a4cb-4d35-82c8-b9d20ceec5ef">
        <source>getValueFromOpts(_name : String; _opts : CM_AssociationDict) : Any;

vars
	upperKey : String;
	assoc		: CM_Association;
	theValue	: Any;
begin

	upperKey := _name.toUpper();
	assoc := _opts[upperKey];

	if assoc &lt;&gt; null then
		theValue := assoc.getValue();
	else
		theValue := null;
	endif;

	return theValue;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_opts" type="CM_AssociationDict"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="isInOpts" id="ea95f6d0-f358-4f12-81c2-e9246ae3bff9">
        <source>isInOpts(_name : String; _opts : CM_AssociationDict) : Boolean;

vars
	upperKey : String;
	assoc		: CM_Association;
begin
	upperKey := _name.toUpper();
	assoc := _opts[upperKey];

	return (assoc &lt;&gt; null);
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_opts" type="CM_AssociationDict"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromOpts" id="95a8c679-edda-4bdb-b074-ea6d021fe417">
        <updating/>
        <source>setFromOpts(_terminal : CM_Terminal; _opts : CM_AssociationDict) updating;
// see UiCommonSchema method setFromAgent
vars

begin

	self.allTerminals.clear();
	self.allTerminals.add(_terminal);

	self.startDate := self.getValueFromOpts(ETRow_StartDate, _opts).Date;
	self.endDate := self.getValueFromOpts(ETRow_EndDate, _opts).Date;
	self.baseDate := self.getValueFromOpts(ETRow_BaseDate, _opts).Date;
		
	if self.isInOpts(ETRow_Operator, _opts) then
		self.myOperator := self.getValueFromOpts(ETRow_Operator, _opts).CM_Operator;
	endif;

	self.locationComment := self.getValueFromOpts(ETRow_LocationComment, _opts).String;
	
	if self.isInOpts(ETRow_AgeType, _opts) then
		self.ageType := self.getValueFromOpts(ETRow_AgeType, _opts).String;
	else
		self.ageType := TI_AGE_RECEIVEDDT;
	endif;
/*	
