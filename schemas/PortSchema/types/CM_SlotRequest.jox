    <JadeMethod name="setPxyFortyFoot" id="e577a0c8-a6d7-4041-a43a-bdb488cf0627">
        <updating/>
        <source>setPxyFortyFoot(_fortyFoot : Boolean; _slotController : CM_SlotController) updating;
// ---------------------------------------------------------------------------
// Created:     29 March 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	is40 : Boolean; //cnwas3 PAR 24273
begin

	self.raiseExceptionIfNotTransient(method);
	
	if _slotController = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_slotController', null, null);
		return;
	endif;

	is40 := self.getAttrIs40();		//cnwas3 PAR 24273
	if is40 then					//cnwas3 PAR 24273
		// currently defined as a forty so need to delete
		if self.fortyBack then
			// this is an erase
			// also need to update forward slot to self.fortyFront = false 
		elseif is40 then			//cnwas3 PAR 24273
			// need to erase aft request
			self.fortyFront := false;
		endif;
	else
		self.fortyFront := true;
	endif;

end;</source>
        <Parameter name="_fortyFoot" type="Boolean"/>
        <Parameter name="_slotController" type="CM_SlotController"/>
    </JadeMethod>
    <JadeMethod name="setPxyWeight" id="9bb9d198-3232-4c6b-9470-a8423efc8bc4">
