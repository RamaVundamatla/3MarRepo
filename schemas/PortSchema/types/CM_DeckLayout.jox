        <source>setProxy(_code, _desc, _remarks : String; _deck : CM_Deck) updating;
// ---------------------------------------------------------------------------
// Created:     24 March 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.code := _code;
	self.description := _desc;
	self.remarks := _remarks;
	self.myDeck := _deck;
	
epilog

end;</source>
        <Parameter name="_code" type="String"/>
