    <JadeMethod name="validateGrouping" id="5b10f728-695b-4ed0-bbe0-571a09de8f64">
        <source>validateGrouping() : Boolean protected;

/*

Purpose:			

Parameters:			

Return Value:		true if no errors other false


Date		Who		Reason
20 November 2012	cnwjre1	Initial creation

*/

vars
	i, j, l	: Integer;
	key		: Integer;
	methodIndex	: Integer;
	lastKey		: Integer;
	first		: Boolean;
	result		: Boolean;
	methodName	: String;
	theTable	: Table;
	mapType		: CM_TranMapInvoiceLineGroupType;
	groupByKey	: CMIF_GroupingByKey;
	object		: Object;
	dynaDict	: DynaDictionary;
	oa			: ObjectArray;
	colAfterCheckBoxes: Integer;
	showTransType,
	showVesselCat: Boolean;
begin
	theTable := self.tblLines;
	if self.myTranMapForm.myCurrentMapServiceBroker.isKindOf(CM_ResourceServiceBroker) then				// 18/6/18 MAP TFS38899
		showTransType := true;
		showVesselCat := true;
		colAfterCheckBoxes := 1;
	elseif self.myTranMapForm.myCurrentMapServiceBroker.isKindOf(CM_TransServiceBroker) then
		if (self.myTranMapForm.myCurrentMapServiceBroker.CM_TransServiceBroker.className = CM_ReceiveShip.name
		or self.myTranMapForm.myCurrentMapServiceBroker.CM_TransServiceBroker.className = CM_ReleaseShip.name
		or self.myTranMapForm.myCurrentMapServiceBroker.CM_TransServiceBroker.className = CM_WorkOrderExtraTI.name) then // TFS 42221
			colAfterCheckBoxes := theTable.columns - 2;
			showTransType := true;
		else
			colAfterCheckBoxes := theTable.columns - 1;
		endif;
	endif;

	create dynaDict transient;
	dynaDict.setMembership(CMIF_GroupingByKey);
	dynaDict.addMemberKey(CMIF_GroupingByKey::keyValue.name, false, true);
	dynaDict.endKeys(true);
	
	i := 2;
	while i &lt;= theTable.rows do
		theTable.row := i;
		j := 1 + showVesselCat.Integer;
		methodIndex := 1;
		key := 0;
		while j &lt; colAfterCheckBoxes do		// 22/3/18 MAP TFS37555

			methodIndex := self.getMethodIndex(j);
			theTable.column := j;
			if theTable.text &lt;&gt; "0" then
				methodName := self.allMethods[methodIndex];
				l := self.doSBMapGetMethodPos(self.myCurrentMapQuantityRange.allRegisteredMethods, methodName);
				key := key.bitOr(2^(l-1));
			endif;
			j := j + 1;
		endwhile;
		mapType := theTable.accessCell(i, theTable.columns - 1).itemObject.CM_TranMapInvoiceLineGroupType;
		create groupByKey transient;
		groupByKey.keyValue := key;
		groupByKey.index := i;
		groupByKey.myGroupingType := mapType;
		dynaDict.add(groupByKey);
		
		i := i + 1;
	endwhile;
	
	create oa transient;
	first := true;
	lastKey := -1;
	foreach object in dynaDict do
		groupByKey := object.CMIF_GroupingByKey;
		if first or
		   groupByKey.keyValue = lastKey then
			oa.add(groupByKey);
		else
			result := self.checkGrouping(oa);
			if not result then
				return result;
			endif;
			oa.clear();
			oa.add(groupByKey);
		endif;
		first := false;
		lastKey := groupByKey.keyValue;
	endforeach;
	// last grouping
	result := self.checkGrouping(oa);
	
	return result;
epilog
	if dynaDict &lt;&gt; null then
		dynaDict.purge();		// the CMIF_GroupingByKey instances
		delete dynaDict;
	endif;
	delete oa;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
