<Class name="CMIF_HMSResourceUsedProforma" id="9114fa31-933d-4722-8468-d410dd1e3da0">
    <superclass name="CMIF_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="hmsTrans"/>
    <ImplicitInverseRef name="allResUsed" id="f2f30762-88d0-4975-84ba-062ec69df4f6">
        <memberTypeInverse/>
        <type name="ObjectArray"/>
    </ImplicitInverseRef>
    <PrimAttribute name="berthageNoShift" id="119d6a44-a740-4491-a13f-686acf02de14">
        <embedded/>
        <type name="Boolean"/>
