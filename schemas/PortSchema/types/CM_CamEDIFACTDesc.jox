        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_type" type="String"/>
        <Parameter name="_ref" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeSGPSegment" id="3c63c3e2-35e7-4078-8757-b9dc7b8d11fe">
        <source>makeSGPSegment(_protocol :CM_CamProtocol; _group :HugeStringArray input; _id :String; _packages :Integer):String protected;
/*
Purpose:	Make a SGP segment

Date		Who		Reason
09 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
constants
	MESSAGE	= "SGP";
vars
	msg, count			:String;
	plus, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	if _packages &gt; 0 then
		count := _packages.asStringJMT;
	endif;
	
	msg := MESSAGE &amp; plus &amp; _id;
	
	if count &lt;&gt; null then
		msg := msg &amp; plus &amp; count;
	endif;
	
	msg := msg &amp; singleQuote;
	
	if _group &lt;&gt; null then
		_group.add (msg);
	endif;
	
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_id" type="String"/>
        <Parameter name="_packages" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeTDT10Segment" id="a0707fef-a4dc-44d8-a29b-ed7f2578b14a">
        <source>makeTDT10Segment(	_protocol :CM_CamProtocol; 
					_group :HugeStringArray input; 
					_ref,
					_mode,
					_means,
					
					_carrier,
					_carrierQual,
					_carrierAgency,
					
					_direction, 
					_excess, 
					_transportMeansID,
					_transportQual,
					_transportAgency,
					_transportID :String ) :String protected;
//
// 25 May 2017	cnwrs1	TFS 4465
// 22 Jan 2018	jlgrs1	TFS 36713 SNO Structure error in COARRI
// 25 Sep 2018	jlggb1	TFS 40947 SNO Correction to 36713
constants
	MESSAGE	= "TDT";
	STAGE = "10";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	msg := MESSAGE &amp; plus &amp; 
			STAGE;
			
	if _ref = null and _mode = null and _means = null and 
		_carrier = null and _carrierQual = null and _carrierAgency = null and
		_direction = null and _excess = null and 
		_transportMeansID = null and _transportQual = null and _transportAgency = null and _transportID = null then
		// because the TDT+10 must be the firs segment in group 5 we need to allow for a dummy segment
		// TDT+10'
		msg := msg &amp; singleQuote;
	else
		msg := 	msg &amp; plus &amp; 
				_ref &amp; plus &amp;
				_mode &amp; plus &amp; 
				_means &amp; plus &amp;
				_carrier;
				
		if _carrierQual &lt;&gt; null then
			msg := msg &amp; colon &amp; _carrierQual;
		endif;
	
		if _carrierQual &lt;&gt; null and _carrierAgency &lt;&gt; null then
			msg := msg &amp; colon &amp; _carrierAgency;
		endif;
		
		msg :=  msg &amp; plus &amp; 
				_direction &amp; plus &amp;
				_excess &amp; plus &amp;
				_transportMeansID;
				
		if _transportQual &lt;&gt; null then
			msg := msg &amp; colon &amp; _transportQual &amp; colon &amp; _transportAgency &amp; colon &amp; _transportID;
		endif;
		
		msg := msg &amp; singleQuote;
	endif;
	
	if _group &lt;&gt; null then
		//_group.add (msg[1:62]);
		_group.add(msg);	//26 May 2020	NDL	TFS 49370
	endif;
	
	return msg;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_protocol" type="CM_CamProtocol"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_ref" type="String"/>
        <Parameter name="_mode" type="String"/>
        <Parameter name="_means" type="String"/>
        <Parameter name="_carrier" type="String"/>
        <Parameter name="_carrierQual" type="String"/>
        <Parameter name="_carrierAgency" type="String"/>
        <Parameter name="_direction" type="String"/>
        <Parameter name="_excess" type="String"/>
        <Parameter name="_transportMeansID" type="String"/>
        <Parameter name="_transportQual" type="String"/>
        <Parameter name="_transportAgency" type="String"/>
        <Parameter name="_transportID" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="makeTDT1Segment" id="23a089ed-9460-47f1-8b53-b3bac143127a">
        <source>makeTDT1Segment(_protocol :CM_CamProtocol; _group :HugeStringArray input; 
				_ref, _mode, _means, 
				_carrier, _carrierQual, _carrierAgency, 
				_direction, _excess, 
				_transportMeansID, _transportQual, _transportAgency, _transportID :String):String protected;
/*
Purpose:	Make a TDT+1 segment
Parameters:	_ref	- conveyance reference number
			_mode 	- mode of transport
			

Date		Who		Reason
09 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
01 Jun 2011 cnwrs1  Par 27653 - create TDT+1' for sub terminal internal transfer ie local packs
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
// 08 Dec 2016	cnwrs1	TFS 3072 restrict the Transhop id to 9 chars
//12 July 2017	jlgrs1	TFS 4465 SNO standard Codedo/Coarri
constants
	MESSAGE	= "TDT";
	STAGE = "1";
vars
	msg	:String;
	plus, colon, singleQuote	:Character;
begin
	plus		:= _protocol.elementSeparator;
	colon		:= _protocol.subElementSeparator;
	singleQuote	:= _protocol.segmentTerminator;
	
	msg := MESSAGE &amp; plus &amp; 
			STAGE;
	if _ref = null and _mode = null and _means = null and 
		_carrier = null and _carrierQual = null and _carrierAgency = null and
		_direction = null and _excess = null and 
		_transportMeansID = null and _transportQual = null and _transportAgency = null and _transportID = null then
		// because the TDT+30 must be the firs segment in group 5 we need to allow for a dummy segment
		// TDT+30'
		msg := msg &amp; singleQuote;
	else
		msg := msg &amp; plus &amp; 
				_ref &amp; plus &amp;
				_mode &amp; plus &amp; 
				_means &amp; plus &amp;
				_carrier;
			
		if _carrierQual &lt;&gt; null then
			msg := msg &amp; colon &amp; _carrierQual;
		endif;
	
		if _carrierAgency &lt;&gt; null then
			msg := msg &amp; colon &amp; _carrierAgency;
		endif;
		
		msg := msg &amp; plus &amp; 
				_direction &amp; plus &amp;
				_excess &amp; plus &amp;
				_transportMeansID[1:9];
	
		if _transportQual &lt;&gt; null then
			if _transportID &lt;&gt; null then
				msg := msg &amp; colon &amp; _transportQual &amp; colon &amp; _transportAgency &amp; colon &amp; _transportID;
			else
				msg := msg &amp; colon &amp; _transportQual &amp; colon &amp; _transportAgency;
			endif;
		endif;
		msg := msg &amp; singleQuote;
	endif;
	
	if _group &lt;&gt; null then
		_group.add (msg);
	endif;
	
	msg := msg &amp; singleQuote;
			
	return msg;
epilog

end;</source>
        <access>protected</access>
