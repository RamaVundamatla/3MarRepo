    <JadeMethod name="initializeForActivity" id="b76fb21c-07c5-4bf2-86bf-57a925c0809e">
        <updating/>
        <source>initializeForActivity(_any: Any; _ewsOpsView: CM_EWSActivityOpsview) updating;
/*
Purpose:	_any = CM_VehicleVisitRecord			

Date		Who		Reason
27 August 2021	navab1	TFS 51853
*/

vars
	vvr : CM_VehicleVisitRecord;
begin
	inheritMethod(_any, _ewsOpsView);
	
	self.tableName 			:= self.Road_truck_visit_details;
	
	
	if _ewsOpsView.dataAction = BGP_OpsViewWSRequest.OPS_ACTION_DELETE then
		self.gkey := self.generateFullGKey(_any, "");
		return;
	endif;

	vvr:= _any.CM_VehicleVisitRecord; // ### TFS 53569 09MAY2022 NAVAB1
	vvr.initializeForActivity(_ewsOpsView, self); // ### TFS 53569 09MAY2022 NAVAB1
	

epilog

end;</source>
        <Parameter name="_any" type="Any"/>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
    </JadeMethod>
</Class>
