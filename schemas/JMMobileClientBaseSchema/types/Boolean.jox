<PrimType name="Boolean">
    <JadeMethod name="getYesNo" id="f746395a-5f85-4b18-8f74-8ff4d4b52713">
        <source>getYesNo() : String;
/*

Purpose:			


Return Value:		


Date		Who		Reason
14 September 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if self then
		return "yes";
	else
		return "No";
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="mbFormat" id="cd2c5ec9-e110-43a9-ae4d-f992b2f31e6a">
        <source>mbFormat(_trueValue:String; _falseValue:String):String;
// --------------------------------------------------------------------------------
// Created:		23 January 2006 by cnwdad1
//
// Purpose:		Returns the string appropriate for the cuurent true/false value of self.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	trueString	: String;
	falseString	: String;

begin
	// If no values supplied use default.

	if _trueValue.trimBlanks = null then
		trueString	:=	self.String;
	else
		trueString	:=	_trueValue;
	endif;

	if _falseValue.trimBlanks = null then
		falseString	:=	self.String;
	else
		falseString	:=	_falseValue;
	endif;

	if self	then
		return trueString;
	else
		return falseString;
	endif;
end;</source>
        <Parameter name="_trueValue" type="String"/>
        <Parameter name="_falseValue" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
