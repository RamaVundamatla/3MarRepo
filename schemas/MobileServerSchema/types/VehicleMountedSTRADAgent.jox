    <JadeMethod name="loadRTTaskTable" id="6cbd7467-f3d2-423a-bad2-c2e75ad54f3c">
        <updating/>
        <source>loadRTTaskTable(_table: Table input; _startRTQueueEntry : CM_RTQueueEntry input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2009	cnwer1	Initial creation

*/

vars
	task : CM_RTQueueTask;
	rtQueueEntry : CM_RTQueueEntry;
	invalidTask : Boolean;
	order : Integer;
	iter : Iterator;
	hasAccepted: Boolean;
begin

	self.currentTaskType:=NULL_INTEGER;
	
	if not self.myMachine.hasWorkingTasks then	
		inheritMethod(_table,_startRTQueueEntry);
	else
	
		on NormalException do app.handleDeletedObject(exception,task,invalidTask);
		iter := self.myMachine.allCurrentWorkingQueueTasks.createIterator;
		self.myMachine.allCurrentWorkingQueueTasks.startKeyGeq(TASK_ACCEPTED,iter);
		hasAccepted:=false;
		while iter.next(task) do
			if task.status = TASK_ACCEPTED then
				hasAccepted:=true;
			endif;
			if hasAccepted and task.status &lt;&gt; TASK_ACCEPTED then
				break;
			endif;
			
			
			self.currentTaskType:=task.taskType;
			
			rtQueueEntry:=task.myEntry;
			if invalidTask then
				invalidTask:=false;
				continue;
			endif;
			self.loadRTTaskTableQTask(task,_table,order);
		endwhile;
		_table.resort;
	endif;
epilog
	delete iter;
end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_startRTQueueEntry" type="CM_RTQueueEntry" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadRTTaskTableEntry" id="eaaf08d0-9af5-48ac-9807-75b713aa8857">
        <source>loadRTTaskTableEntry(_rtEntry: CM_RTQueueEntry input; _table: Table input; _order : Integer) protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
06 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	rtTask: CM_RTQueueTask;
begin
	rtTask:=_rtEntry.allTasks.first;
	self.loadRTTaskTableQTask(rtTask,_table,_order);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rtEntry" type="CM_RTQueueEntry" usage="input"/>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_order" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadRTTaskTableQTask" id="f15e7b27-ffe4-4818-882a-517e9d697424">
        <source>loadRTTaskTableQTask(_rtTask: CM_RTQueueTask input; _table: Table input; _order : Integer);
/*

Purpose:			


Return Value:		


Date		Who		Reason
06 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
constants 
	TwinCol = 3;
vars

	type : String;
	jobNum : String;
	doorDirection : String;
	containerId : String;
	time  : String;
	vehicleId : String;
	ti : CM_TrackedItem;
	job : CM_Job;
	row : JadeTableRow;
	index : Integer;
	wle : CM_WorkListEntry;
	tableLine,twinStr : String;
	relatedTask: CM_RTQueueTask;
	source, target : String;
	rtEntry		: CM_RTQueueEntry;
	twinFlag,twinCol : Integer;
	twinCell : JadeTableCell;
	twinLiftDraw,
	twinLiftNextDraw,
	twinLiftPrevDraw 		: CM_DrawingAttribute;
begin
	rtEntry:=_rtTask.myEntry;
	job:=rtEntry.myJob;
	wle:=rtEntry.myWorkListEntry;
	twinFlag:=rtEntry.getTwinCarryFlag;
	if wle &lt;&gt; null then
		jobNum:= job.id;
		type:=job.getJobTypeForWLE(wle);
		ti:=wle.myTrackedItem;
		if wle.myRequest &lt;&gt; null then
			doorDirection:=wle.myRequest.getDoorDirectionDescription(wle.getTargetLocation(), wle.myTrackedItem);
		endif;
		
		relatedTask:=rtEntry.getPreviousEntryFirstTask;
		if relatedTask = null then
			relatedTask:=rtEntry.getNextEntryFirstTask;
		endif;
		if relatedTask &lt;&gt; null then
			if relatedTask.machine &lt;&gt; null then
				vehicleId:=relatedTask.machine.code;
			endif;
		endif;
		
		
		source:=ti.getPrimaryLocationId(REAL_MODE);
	//	source:=wle.getLocationIdForMode(REAL_MODE);

		target:=wle.getLocationIdForMode(QUEUE_MODE);
		target:=_rtTask.targetLocationId;
		
		
		time:=self.getElapsedTimeInMins(_rtTask);
		
		containerId:=null;
		
		if ti &lt;&gt; null then
			containerId:=ti.id;
		endif;	
	endif;
	
	tableLine:=Tab &amp; type &amp; Tab &amp;  Tab  &amp; vehicleId &amp; Tab &amp; containerId &amp; Tab &amp; source &amp; Tab &amp; target &amp; Tab &amp;  time  &amp; Tab &amp; doorDirection;
	
	index:=_table.addItem(tableLine);
	row:=_table.accessRow(index);
	if row &lt;&gt; null then
		row.itemObject:=_rtTask;
	endif;

	twinLiftDraw:=app.myRoot.allDrawingAttributes[PicTATwinLiftArrows];
	twinLiftNextDraw:=app.myRoot.allDrawingAttributes[PicTATwinLiftNext];
	twinLiftPrevDraw:=app.myRoot.allDrawingAttributes[PicTATwinLiftPrev];
	

	if twinFlag &lt;&gt; null then
		twinCell:=_table.accessCell(index, TwinCol);
		twinCell.fontName:=twinLiftDraw.fontName;
		twinStr:=twinLiftDraw.fontCharacter.Character.String;
		if twinFlag = CM_RTQueueEntry.TWIN_NEXT then
			twinStr:=twinStr &amp; twinLiftNextDraw.fontCharacter.Character;
		elseif  twinFlag = CM_RTQueueEntry.TWIN_PREV then
			twinStr:=twinLiftPrevDraw.fontCharacter.Character &amp; twinStr; 
		elseif  twinFlag = CM_RTQueueEntry.TWIN_BOTH then
			twinStr:=  twinLiftPrevDraw.fontCharacter.Character &amp;  twinStr &amp; twinLiftNextDraw.fontCharacter.Character;
		endif;
		twinCell.text:=twinStr;
	endif;
	
epilog

end;</source>
        <Parameter name="_rtTask" type="CM_RTQueueTask" usage="input"/>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_order" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="moveTI" id="bf5cc373-f694-459d-b532-d12c76290326">
        <updating/>
        <source>moveTI(_locId : String; _tiId : String; _dto : DTO_EnquiryGradingTasks input; _errorMsgs: DTO_HandHeldGateErrorDict input) : Boolean updating;
/*
Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
16 June 2008	concms1	PAR 17123 (ccms 1671) DCT Gdansk RDT Screen to relocate
23 June 2008 	concms1	PAR 17123 - extra parameter for forced move
*/
vars
	passport	: CM_Passport;
	ti			: CM_TrackedItem;
	toLocation	: CM_LocationsController;
begin

	passport := app.myPassport;
	self.initialiseForNewRequest(_errorMsgs);
	
	toLocation:=self.findLocationFromString(_locId);
	
	if toLocation = null then
		self.addError(ERR_INVALID_LOCN,app.getErrorString1(ERR_INVALID_LOCN,_locId),_errorMsgs);
		return false;
	endif;
	
	
	app.myTrxRT.trxRTGMoveTI(self.myMachine, self.myMediator.myCurrentTi, null, toLocation, false, false, null, null, null, null,null, passport); // extra parameter

	if 	self.createErrorsFromPassport(_errorMsgs) then
		return false;
	endif;
	
	_dto.setFromTI(self.myMediator.myCurrentTi);
	
	return true;

end;</source>
        <Parameter name="_locId" type="String"/>
        <Parameter name="_tiId" type="String"/>
        <Parameter name="_dto" type="DTO_EnquiryGradingTasks" usage="input"/>
        <Parameter name="_errorMsgs" type="DTO_HandHeldGateErrorDict" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
