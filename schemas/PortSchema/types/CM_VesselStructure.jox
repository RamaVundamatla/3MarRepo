    <JadeMethod name="cloneMySelf" id="9101460d-83c5-471d-9cca-719e96f522de">
        <source>cloneMySelf(_transient : Boolean): SelfType;
//--------------------------------------------------
// Created:	30 January 2006 By: cnwgd1
//--------------------------------------------------
vars
	newVessel : CM_VesselStructure;
begin
	newVessel := self.cloneSelf(_transient);
	newVessel.myRoot := self.myRoot;
	return newVessel;
end;</source>
