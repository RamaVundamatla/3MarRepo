			_myGCVesselStructure : CM_GeneralCargoVesselStructure
			) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09/07/2013	cnwndl1	Initial creation	Par 31965
27/08/2015	cnwdap1	PAR #36766 CCMS SFW 1334 Bulk Graphical Representation - new parameters
*/

vars

begin

	self.hatch := _hatch;
	self.name := _name;
	self.place := _place;
	self.isOnDeck := _isOnDeck;								// PAR #36766
	self.maxWeight := _maxWeight;							// PAR #36766
	self.maxVolume := _maxVolume;							// 13/7/16 cnwmp6 TFS 1601
	self.maxHeight := _maxHeight;	//07 Feb 2017 NDL TFS 3216
	self.onShipCrane := _onShipCrane;						// 13/7/16 cnwmp6 TFS 1601
	self.myGCVesselStructure := _myGCVesselStructure;

epilog

end;</source>
