<Class name="CMQF_DangerousGoodsManifest" id="15dcb45e-c98b-4cca-8243-1502cbb5a433">
    <superclass name="CMQF_TrackedItem"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="filterObjects" id="187a10c0-9b06-4888-ac0e-63ef48ec1099">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 April 2013	cnwer1	Initial creation CCMS DPH 2280

*/

vars
	voyage : CM_Voyage;
	iter : Iterator;
	ti, childTI : CM_TrackedItem;
	operator : CM_Operator;
	breakOut			: Boolean;
begin
	
	
	voyage:= self.getMyVoyage;
	operator:=self.myOperator;
	
	iter := voyage.allOnshipTIsByCargoTypeId.createIterator;
	while iter.next(ti) do
		if operator &lt;&gt; null then
			if ti.myOperator &lt;&gt; operator then
				continue;
			endif;
		endif;
		
		
		if ti.getHazardousUNDGFirst &lt;&gt; null then
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
				//cnwmc5 - 8 Jan 2013 - PAR 33267
				if not _collection.includes(ti) then
					_collection.add(ti);
				endif;
			endif;
		endif;
		
		if breakOut then
			return;
		endif;

		foreach childTI in ti.allChildren do
			if childTI.getHazardousUNDGFirst &lt;&gt; null then
				if self.checkStatusIncludesObject(ti, _passport, breakOut) then
					if not _collection.includes(childTI) then
						_collection.add(childTI);		//cnwmc5 - 8 Jan 2013 - PAR 33267
					endif;
				endif;
				
				if breakOut then
					return;
				endif;
			endif;
		endforeach;
	endwhile;
	
	delete iter;
	
	iter:=voyage.allOnsiteTIsByCargoTypeId.createIterator;
	while iter.next(ti) do
		if operator &lt;&gt; null then
			if ti.myOperator &lt;&gt; operator then
				continue;
			endif;
		endif;
		
		
		if ti.getHazardousUNDGFirst &lt;&gt; null then
			if self.checkStatusIncludesObject(ti, _passport, breakOut) then
				//cnwmc5 - 8 Jan 2013 - PAR 33267
				if not _collection.includes(ti) then
					_collection.add(ti);
				endif;
			endif;
		endif;
		
		if breakOut then
			return;
		endif;
		
		foreach childTI in ti.allChildren do
			if childTI.getHazardousUNDGFirst &lt;&gt; null then
				if self.checkStatusIncludesObject(ti, _passport, breakOut) then
					if not _collection.includes(childTI) then
						_collection.add(childTI);		//cnwmc5 - 8 Jan 2013 - PAR 33267
					endif;
				endif;
				
				if breakOut then
					return;
				endif;
				
			endif;
		endforeach;
	endwhile;
	
	//inheritMethod(_collection, _passport);

epilog
	delete iter;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="includesObject" id="3739c1d6-1a39-42d1-a400-52791dcf39fe">
        <updating/>
