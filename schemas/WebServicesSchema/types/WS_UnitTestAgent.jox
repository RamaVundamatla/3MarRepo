    <JadeMethod name="wsRESTGetCustomsStatus" id="f6d54c2c-0752-4c73-bf60-baffe6705acf">
        <source>wsRESTGetCustomsStatus(_operator: String; _queryParamString: String; _pathParamString: String; _expectFailure: Boolean; _response: String io): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 July 2024	navhn30	Initial creation	ChangeRequest 64906: CUX | EDBIC Stop type information on GET/ customs status

*/

vars
	webService			: MasterTerminalAPIService;
	response 			: WS_Response;
	ref 				: String;
	cargoType,
	cargoId,
	state				: String;
	pos					: Integer;
	dict 				: WS_QueryStringParamDict;
	jsonHelper 			: JMTJadeJson;
begin
	create webService transient;	
	// Login Request
	self.loginRestWithOperator(webService, _operator);
	webService.qsData.parseNameValuePair(_queryParamString);

	// set up the WS_Request object
	webService.setPropertyValue(WS_RestWebServiceProvider::requestPath.name, "/cargo");
	pos := 2;											
	_pathParamString.scanUntil('/', pos);				
	pos += 1;											
	cargoId := _pathParamString.scanUntil('/', pos);	
	pos += 1;											
	cargoType := _pathParamString.scanUntil('/', pos);	
	pos += 1;	
	state := _pathParamString.scanUntil('?', pos);

	response := webService.getCustomsStatus(cargoId, cargoType, state.Integer);
	create jsonHelper transient;
	_response := jsonHelper.generateJson(response.WS_Response, JadeJson.Format_Json_Microsoft);	
	
	// If we're expecting to fail, then return early
	if _expectFailure then
		if webService.httpStatusCode = HttpResponseOK then
			return "Failure expected, got 200 OK";
		endif;
		return response.WS_Response.allErrors.first.text;
	endif;
	
	if webService.httpStatusCode &lt;&gt; HttpResponseOK then
		if response.allErrors.size &gt; 0 then
			app.writeLog(response.allErrors.first.text, LogERROR);
		endif;
		return method.qualifiedName &amp; " Bad Response Code, expecting 200 OK, got " &amp; webService.httpStatusCode.String &amp; ". Check UnitTest runner logs for more details" &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	endif;
	
	return null;
	
	// Not used,just here to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsRESTGetCustomsStatus.name;

epilog
	if webService.objectsToBeDeleted.isNotEmpty then
		webService.objectsToBeDeleted.purge;
	endif;
	dict := webService.qsData;
	dict.purge();
	delete webService;
	delete jsonHelper;
end;</source>
