    <JadeMethod name="initFromUserWindow" id="7ccf7040-386f-4fc7-8d32-6a31fcaaa431">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
//25 August 2009	cnwml2


vars
	xml : String;
begin
	inheritMethod(_userWindow);
	
	xml := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.tblBookingItems.XMLTag_Table &amp; self.tblBookingItems.name);
	if xml &lt;&gt; null then
		self.xmlStrTblText := global.formatAsXMLPrefix(self.tblBookingItems.XMLTag_Table &amp; self.tblBookingItems.name) &amp; 
								  xml &amp;
								  global.formatAsXMLSuffix(self.tblBookingItems.XMLTag_Table &amp; self.tblBookingItems.name);
	endif;

epilog

end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
