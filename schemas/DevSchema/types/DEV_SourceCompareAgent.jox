							_constantCategoryName,
							_documentationTextStr	: String; 
							_devConstantsSection 	: DEV_SchemaConstantsSection io) protected;
/*

Purpose:			Creates a DEV_GlobalConstantCategory

Parameters:			_devConstantCategory:		DEV_GlobalConstantCategory		The global constant category we have created
					_constantCategoryName:		String							The global constant category name
					_documentationTextStr:		String							The documentation text on the global constant category
					_devConstantsSection:		DEV_SchemaConstantsSection		The global constant section to add the global constant category to

Return Value:		

Date		Who		Reason
27 October 2021	navpw1	Initial creation TFS: 52202

*/

begin
	_devConstantCategory := create DEV_GlobalConstantCategory(_constantCategoryName, _documentationTextStr, -1, null, _devConstantsSection) transient;
	
