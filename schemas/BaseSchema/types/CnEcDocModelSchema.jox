    <JadeMethod name="createDocClass" id="5a821dad-b47b-4471-8771-43a3109dd3e3">
        <source>createDocClass(pClassObj:Class; pAlias:String):CnEcDocModelClass;
// --------------------------------------------------------------------------------
// Created:		01 November 2002 by cnwdad2
//
// Purpose:		Create a Documentation Class object, and return it to the caller.
//
// Parameters:	pClassObj - The Class object to be represented by the Documentation
//					Class object.
//				pAlias - The alias name of the class.
//
// Returns:		The newly created object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 23/01/2003	cnwdad1		Added support for an alias of the receiver's name.
// 12/03/2003	cnwdad1		Added check for duplicate classes.
// --------------------------------------------------------------------------------
vars
	docClassObj	: CnEcDocModelClass;
	
begin
	if self.allDocClasses[pClassObj.name] &lt;&gt; null then
		CnEcBaseSchemaException.raise_(CNEC_X_03001, "Duplicate class: " &amp; pClassObj.name);
	endif;
	
	if self.isTransient() then
		create docClassObj transient;
	else
		create docClassObj;
	endif;
	
	docClassObj.updateMe(pClassObj, pAlias, self);
	
	return docClassObj;
end;</source>
        <Parameter name="pClassObj" type="Class"/>
        <Parameter name="pAlias" type="String"/>
        <ReturnType type="CnEcDocModelClass"/>
    </JadeMethod>
    <JadeMethod name="resolveSuperclassAliases" id="0250f685-2d18-4d04-a4e3-b87529e2f09b">
        <source>resolveSuperclassAliases();
// --------------------------------------------------------------------------------
// Created:		24 January 2003 by cnwdad1
//
// Purpose:		Sets the superclass alias for each of the Doc Model Class objects.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	docClassObj			: CnEcDocModelClass;
	docSuperclassObj	: CnEcDocModelClass;
	superclassObj		: Class;
	
begin
	foreach docClassObj in self.allDocClasses do
		superclassObj		:=	docClassObj.myClass.getSuperclass();
		docSuperclassObj	:=	self.allDocClasses[superclassObj.name];
		
		if docSuperclassObj &lt;&gt; null then
			docClassObj.setSuperclassAlias(docSuperclassObj.alias);
		endif;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="updateMe" id="6361f2c2-76e5-4599-9a5d-5e2d2aa5aa20">
        <updating/>
        <source>updateMe(pSchemaObj:Schema; pDocListObj:CnEcDocModelList) updating;
// --------------------------------------------------------------------------------
// Created:		01 November 2002 by cnwdad2
//
// Purpose:		Update the receiver's details.
//
// Parameters:	pSchemaObj - The schema which this Documentation schema object represents.
//				pDocListObj - The owner of this Documentation Schema.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.mySchema	:=	pSchemaObj;
	self.schemaName	:=	pSchemaObj.name;
	self.myDocList	:=	pDocListObj;
end;</source>
        <Parameter name="pSchemaObj" type="Schema"/>
        <Parameter name="pDocListObj" type="CnEcDocModelList"/>
    </JadeMethod>
</Class>
