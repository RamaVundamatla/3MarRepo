<CollClass name="CM_VoyageByInwardCodeAutoDict" id="4450d840-97c6-45b2-8814-bf26c32febff">
    <loadFactor>66</loadFactor>
    <memberType name="CM_Voyage"/>
    <superclass name="CM_MemberKeyDictionary"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="voyages"/>
    <MemberKey>
        <property name="CM_Voyage::inwardCodeAuto"/>
    </MemberKey>
    <MemberKey>
        <property name="CM_Voyage::vesselCode"/>
    </MemberKey>
    <JadeMethod name="getAllVoyages" id="98351519-e16a-4c10-9c77-a340e0ac1bdb">
        <lockReceiver/>
        <source>getAllVoyages(_voyageCode : String; _voyageSet : CM_VoyageSet input) lockReceiver;
/*
;
Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
15 September 2025	navlw1	JIRA-35882: Support External Voyage Code

*/

vars
	iter 		: Iterator;
	startVoy,
	voyage		: CM_Voyage;
begin
	iter := self.createIterator;
	startVoy := self.getAtKeyGeq(_voyageCode, null);

	if startVoy = null or startVoy.inwardCodeAuto &lt;&gt; _voyageCode then
		return;
	endif;
	
	// forward loop
	iter.startAtObject(startVoy);
	while iter.next(voyage) do
		if voyage.inwardCodeAuto &lt;&gt; _voyageCode then
			break;
		endif;
		_voyageSet.addNoDuplicates(voyage, false);
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_voyageSet" type="CM_VoyageSet" usage="input"/>
    </JadeMethod>
</CollClass>
