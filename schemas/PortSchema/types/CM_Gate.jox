    <JadeMethod name="getSealCheckTypeForContext" id="b6f4cf19-b9f1-4c27-9682-8e99f5de3747">
        <source>getSealCheckTypeForContext( _context : Integer ): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 September 2010	cnwndl1	Initial creation	Par 23715

*/

vars

	returnType : Integer;
	
begin

	if _context = CARGO_CHECK_CONTEXT_GATE_REC
	or  _context = CARGO_CHECK_CONTEXT_ROAD_REC	//07 May 2014	NDL	Par 34076
	then
		returnType := self.sealCheckReceival;
		
	elseif _context = CARGO_CHECK_CONTEXT_GATE_REL
	or  _context = CARGO_CHECK_CONTEXT_ROAD_REL	//19 Nov 2019 NDL	TFS 47568
	then
		returnType := self.sealCheckRelease;
	endif;
	
	return returnType;

epilog

end;</source>
        <Parameter name="_context" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTroubleInUsage" id="86e766aa-3ec2-47eb-b9e3-320cc71b351d">
        <source>getTroubleInUsage():CM_GateAreaUsage;
// ---------------------------------------------------------------------------
// Created:     04 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	usage	:CM_GateAreaUsage;
begin
	foreach usage in self.allGateAreas_IN do
		if usage.isTrouble then
			return usage;	// only expect 1
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_GateAreaUsage"/>
    </JadeMethod>
    <JadeMethod name="getTroubleLocation" id="32cc8b5d-2a4b-41ab-a762-441d9a6145ca">
        <source>getTroubleLocation( _out : Boolean ):CM_LocationsController;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 January 2013	cnwndl1	Initial creation	Par 31102

*/

vars

	usage : CM_GateAreaUsage;
	gateArea : CM_GateArea;

begin

	if not _out then
		usage := self.getTroubleInUsage();
	else
		usage := self.getTroubleOutUsage();
	endif;
	
	if usage &lt;&gt; null then
		gateArea := usage.myGateArea;
		if gateArea &lt;&gt; null then
			return gateArea.getFirstAvailalableLane();
		endif;
		
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_out" type="Boolean"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
