    <JadeMethod name="updateMeasurementInCargoType" id="25d154a7-0c0f-4695-ae32-62a24205f7ba">
        <source>updateMeasurementInCargoType( _controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 March 2022	navsp1	Initial creation TFS#52718

*/

vars
	cargotype			: CM_CargoType;						
	systemSubType 		: CM_Product;						
	prodAttr 			: CM_ProductAttr;					
	measurementType 	: CM_MeasurementType;
	defWeightType 		: CM_MeasurementType;
	defVolumeType 		: CM_MeasurementType;
	defDensityType 		: CM_MeasurementType;
	defLinearType 		: CM_MeasurementType;
	defStowageFactorType: CM_MeasurementType;
		
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;

	app.writeLog( method.qualifiedName &amp; 'Update measurement type changes in cargotype ', LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Update measurement type changes in cargotype ") ;
	endif;
	
	beginTransaction;
	
	defWeightType	 	:= app.getDefaultMeasurementForType(Type_Weight);	
	defVolumeType 		:= app.getDefaultMeasurementForType(Type_Volume);
	defDensityType 		:= app.getDefaultMeasurementForType(Type_Density);
	defLinearType 		:= app.getDefaultMeasurementForType(Type_Linear);
	defStowageFactorType:= app.getDefaultMeasurementForType(Type_StowageFactor);
	
		foreach cargotype in app.myRoot.allCargoTypesById do
			if cargotype.mySystemProductType &lt;&gt; null then
				systemSubType := cargotype.mySystemProductType;
					if defWeightType &lt;&gt; null and systemSubType.getMyWeight &lt;&gt; null 
					and systemSubType.getMyWeight.myMeasurementType &lt;&gt; defWeightType then
						prodAttr := systemSubType.getMyWeight;
						prodAttr.setMyMeasurementType(defWeightType);
					endif;
					
					if defVolumeType &lt;&gt; null and systemSubType.getMyVolume &lt;&gt; null 
					and systemSubType.getMyVolume.myMeasurementType &lt;&gt; defVolumeType then
						prodAttr := systemSubType.getMyVolume;
						prodAttr.setMyMeasurementType(defVolumeType);
					endif;
					
					if defDensityType &lt;&gt; null and systemSubType.getMyDensity &lt;&gt; null 
					and systemSubType.getMyDensity.myMeasurementType &lt;&gt; defDensityType then
						prodAttr := systemSubType.getMyDensity();
						prodAttr.setMyMeasurementType(defDensityType);
					endif;	
					
					if defLinearType &lt;&gt; null then
						if systemSubType.getMyHeight &lt;&gt; null
						and systemSubType.getMyHeight.myMeasurementType &lt;&gt; defLinearType then
							prodAttr := systemSubType.getMyHeight();
							prodAttr.setMyMeasurementType(defLinearType);
						endif;
						if systemSubType.getMyWidth &lt;&gt; null
						and systemSubType.getMyWidth.myMeasurementType &lt;&gt; defLinearType then
							prodAttr := systemSubType.getMyWidth();
							prodAttr.setMyMeasurementType(defLinearType);
						endif;
						if systemSubType.getMyLength &lt;&gt; null
						and systemSubType.getMyLength.myMeasurementType &lt;&gt; defLinearType then
							prodAttr := systemSubType.getMyLength();
							prodAttr.setMyMeasurementType(defLinearType);
						endif;
					endif;
					
					if defStowageFactorType &lt;&gt; null and systemSubType.getMyStowageFactor() &lt;&gt; null
					and systemSubType.getMyStowageFactor.myMeasurementType &lt;&gt; defStowageFactorType then
						prodAttr := systemSubType.getMyStowageFactor();
						prodAttr.setMyMeasurementType(defStowageFactorType);
					endif;	
					
			endif;
		endforeach;
		
	
	commitTransaction;
	
	app.writeLog( method.qualifiedName &amp; 'Update measurement type changes in cargotype ', LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry('Update measurement type changes in cargotype ') ;	
	endif;
	
	self.addScriptRun(method.name);
	
epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="updateOperator" id="d371df2c-89db-44f7-87ec-b367f6201107">
        <source>updateOperator(_controller : CnEcReleaseController);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 November 2022	navhl20	ChangeRequest 55087: PNL - Booking Discrepancies - Can 'CA Curtains and Curtains' be renamed?

*/

vars
	operator	: CM_Operator;
	desc : String;
	isAvail : Boolean;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;

	app.writeLog( method.qualifiedName &amp; 'Update Booking Discrepancies in Operator ', LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry("Update Booking Discrepancies in Operator ") ;
	endif;
	
	beginTransaction;
	foreach operator in CM_Operator.instances do
		foreach desc in operator.allAttribForBookingRefDiscrep do
			if desc = "Controlled Atmosphere and Curtains In" then
				isAvail := true;
			endif;
		endforeach;
		if isAvail then
			operator.allAttribForBookingRefDiscrep.remove("Controlled Atmosphere and Curtains In");
			operator.allAttribForBookingRefDiscrep.add("Curtains In");
			operator.allAttribForBookingRefDiscrep.add("CO2");
			operator.allAttribForBookingRefDiscrep.add("O2");
			isAvail := false;
		endif;
	endforeach;
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Update Booking Discrepancies in Operator", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Update Booking Discrepancies in Operator") ;	
	endif;
	
	self.addScriptRun(method.name);
epilog

end;</source>
        <Parameter name="_controller" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="updateReserveMarkNumber" id="81f1752a-2d1e-4400-969b-01d3e0be5fc9">
        <source>updateReserveMarkNumber(_controller: CnEcReleaseController);
/*

Purpose:			Converting from Integer to String results in null values becomming "0"
					This will convert them back to null

Parameters:			

Return Value:		

Date				Who		Reason
19 July 2023		jlizm1	Initial creation TFS 58461 Change release mark number to string

*/

vars
	reserve : CM_ReserveSelection;
	
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Update Release Request Mark Number", LogINFO);
	
	if _controller &lt;&gt; null then
		_controller.logEntry("Update Release Request Mark Number ") ;	
	endif;
	
	beginTransaction;
	
		foreach reserve in CM_ReserveSelection.instances do
			if reserve.markNumber = "0" then
				reserve.setPropertyValue(CM_ReserveSelection::markNumber.name, null);
			endif;
		endforeach;

