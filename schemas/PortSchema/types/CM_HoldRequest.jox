    <JadeMethod name="createWLEForTI" id="4d36a191-ae8b-41cb-bd42-7754d9d6d6a7">
        <updating/>
        <source>createWLEForTI(_ti : CM_TrackedItem):CM_WorkListEntry updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 09/02/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operatinos Enhancements
//
vars
	wle : CM_WorkListEntry;
	
begin
	if self.allWorkListEntries.isEmpty then
		create wle as CM_VoyageWLE;
		wle.setForCreate(self.myJob, self);
		wle.setMyTrackedItem(_ti);
		wle.setQuantity(_ti.totalQuantity.max(1));
		wle.setWeight(_ti.totalWeight);
		
		if self.isDischarge then // ### TFS 53105 16JUN2022 NAVAB1
			if _ti.myPrimaryActualLocation.isKindOf(CM_GeneralCargoController) then // ### TFS 53105 16JUN2022 NAVAB1
				self.myHoldControllerDischarge := _ti.myPrimaryActualLocation.CM_GeneralCargoController; // ### TFS 53105 16JUN2022 NAVAB1
			endif;
		else
			if _ti.myPrimaryPlannedLocation.isKindOf(CM_GeneralCargoController) then // ### TFS 53105 16JUN2022 NAVAB1
				self.myHoldControllerLoad := _ti.myPrimaryPlannedLocation.CM_GeneralCargoController; // ### TFS 53105 16JUN2022 NAVAB1
			endif;
			
		endif;
		
		
		/* // ### TFS 53105 16JUN2022 NAVAB1
		if _ti.isCar() then // ### TFS 50669 24AUG2021 NAVAB1
			if app.myPassport.isOpsViewEnabled(wle.getMyTerminal()) then
				wle.createOpsViewEWSActivity(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_WLE, wle);
			endif;
		endif;
		*/
		return wle;	//23 Jun 2017	NDL	TFS 4948
	else
		foreach wle in self.allWorkListEntries where wle.job = null and wle.myTrackedItem = _ti do
			wle.setForCreate(self.myJob, self);
			wle.setQuantity(_ti.totalQuantity.max(1));
			wle.setWeight(_ti.totalWeight);
			return wle;	//23 Jun 2017	NDL	TFS 4948
		endforeach;
	endif;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="createWLEs" id="3a33725f-575a-4eaa-b829-5d264b6d2469">
        <updating/>
        <source>createWLEs() updating;
/*
Purpose:			
Date				Who		Reason
10 February 2017	cnwab1	Initial creation
28 October 2025		jlizm1	MTN 36255 Rotabox Assign Release To Vessel
*/

vars
	idx 		: Integer;
	qty 		: Integer;
	wle 		: CM_VoyageWLE;
	reserveSel 	: CM_ReserveSelection;
	
begin
	if self.myBulkReleaseReserveDetail &lt;&gt; null and self.myBulkReleaseReserveDetail.isKindOf(CM_ReserveSelection) then
		reserveSel := self.myBulkReleaseReserveDetail.CM_ReserveSelection;
		
	elseif	self.myReserveDetail &lt;&gt; null and self.myReserveDetail.isKindOf(CM_ReserveSelection) then
		reserveSel := self.myReserveDetail.CM_ReserveSelection;
	endif;
	
	if reserveSel &lt;&gt; null and reserveSel.myCargoType.id = TI_CargoType_Container then
		qty := self.quantity.Integer;
		if qty &lt; 1 then
			qty := 1;
		endif;
		
		foreach idx in 1 to qty do
			create wle;
			wle.setForCreate(self.myJob, self);
		endforeach;
		
	else
		create wle;
		wle.setForCreate(self.myJob, self);
		
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAllWLEs" id="c27577f0-7895-4e63-befc-87b1ae8f5518">
        <source>getAllWLEs(_wleArray: CM_WLEArray input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/09/021	navdap1		Initial creation TFS 51935 SAL Direct Loading of Prenotes from Truck to Vessel
// 16/11/2021	navdap1		TFS 52360 SAL Direct Prenote to Voyage Incorrect Job Values
// 06/12/2021	navdap1		TFS 52293 SAL Direct Laoding - Marking Job as Direct Delivery
//
vars
	wle : CM_WorkListEntry;

begin
	if self.myJob.isDirectDeliveryJob then								// TFS 52293
	//if self.myTerminal.getConfig(DirectTruck2VesselMult).Boolean then	// TFS 52293
		foreach wle in self.allWorkListEntries discreteLock do 
			if wle.showDirectDeliveryInHoldForms() then			// TFS 52360
				_wleArray.add(wle);
			endif;
		endforeach;
	else
		inheritMethod(_wleArray);
	endif;

epilog

end;</source>
        <Parameter name="_wleArray" type="CM_WLEArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getId" id="c0d26aa6-0d88-41ae-9a30-3fdc3dc1208e">
        <source>getId(): String;
/*
Purpose:			
Date		Who		Reason
22 February 2017	cnwab1	Initial creation
*/

vars
	ct : CM_CargoType;
begin
	if self.myBulkReleaseReserveDetail &lt;&gt; null then
		ct := self.myBulkReleaseReserveDetail.getCargoType();
		if ct &lt;&gt; null then
			return ct.abbreviation;
		endif;
	endif;
	return inheritMethod();

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
