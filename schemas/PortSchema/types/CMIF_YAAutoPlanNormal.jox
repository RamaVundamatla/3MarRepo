    <JadeMethod name="isDischargePort_Compare" id="eca7d8e7-3e08-4496-8759-d5cc39e38063">
        <source>isDischargePort_Compare(dischargePort: Object; port: String): Boolean;
begin
	// if passed in port string is 3 chars compare on the 3 char port code 
	if port.length = 3 then
		return dischargePort.CM_Port.portCode.trimBlanks() = port;
	else
		return dischargePort.CM_Port.code.trimBlanks() = port;
	endif;
end;</source>
        <Parameter name="dischargePort" type="Object"/>
        <Parameter name="port" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isDischargePort_Match" id="6da11437-076e-48e6-9fa3-93b3549816de">
        <source>isDischargePort_Match(_yaData: CM_YADataObjects): Boolean;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
// Updated 22 Nov 2010 by cnwjo3 - par 25881.
// -------------------------------------------
vars
	dischargePort	: Object;
	port			: String;
	portObj			: CM_Port;
	ti				: CM_TrackedItem;	
begin
	//port := self.myTrackedItem.dischargePort.trimBlanks();
	
	ti := self.myTrackedItem; 

	//if a cargo item is a tranship item then use its transhipDetails discharge port
	//when autoplanning.  once off the ship its myTranshipDetail.myDischragePort.code equals ti.dischargePort
	if ti.isTranshipItem then//and ti.isOnShip() then
		if ti.myTranshipDetail &lt;&gt; null then
			portObj := ti.myTranshipDetail.myDischargePort;
			if portObj &lt;&gt; null then							// PAR 28776
				port := portObj.code;
			endif;
		endif;
	else
		port := ti.dischargePort.trimBlanks();
	endif;	
	
	if port = null then
		return false;
	endif;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	return _yaData.visitObjectsUntilTrue(self, CMIF_YAAutoPlanNormal::isDischargePort_Compare, port);
end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
