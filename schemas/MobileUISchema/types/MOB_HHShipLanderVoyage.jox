    <JadeMethod name="doResizeControls" id="c3ee8e75-0812-426c-8975-56b0501fd1d4">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 February 2015	cnwndl1	Initial creation	Par 35604

*/

vars

	stdHeight : Real;

begin

	self.setResizeableMarginAndFontSize();
	stdHeight := self.getStdControlHeight;

	self.cmbVoyage.visible := true;
	self.cmbVoyage.move( self.resizedMargin,
						 self.resizedMargin,
						 self.clientWidth - self.resizedMargin - self.resizedMargin,
						 stdHeight );
						 
	
	self.cmbBOL.visible := true;
	self.cmbBOL.move( self.resizedMargin,
						 self.resizedMargin + self.cmbVoyage.height + self.cmbVoyage.top,
						 self.clientWidth - self.resizedMargin - self.resizedMargin,
						 stdHeight );
						 
	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="288a4c72-ef8a-4a12-aa0f-c9ffd9b4307e">
        <updating/>
        <source>handleBtnOne() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars
	voyage : CM_Voyage;
	bol : CM_BOL;
	errMess : String;
begin
	// user clicked 'Next'
	
	voyage := cmbVoyage.listObject.CM_Voyage;
	if voyage = null then
		return;
	endif;
	bol := cmbBOL.listObject.CM_BOL;
	
	self.myMobileGenericAgent.setMyVoyage(voyage);
	self.myMobileGenericAgent.setMyBOL(bol);
	self.myMobileGenericAgent.setChecksState(self.myMobileGenericAgent.Yard);

	self.gotoForm( MOB_HHShipLanderCargo, false );

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
