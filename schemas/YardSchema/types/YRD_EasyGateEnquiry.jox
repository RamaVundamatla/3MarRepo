        <source>doQuery() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2010	cnwrd1	Initial creation

*/

vars
    ls  : Boolean;
	tbl	: CM_DataTable;
	ok  : Boolean;
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	app.cmsBeginLoad(ls);

	self.tblInfo.rows := self.tblInfo.fixedRows;
	self.tblData.rows := self.tblData.fixedRows;
	self.tblData.clearAllSelected();
	
	tbl := self.tblData;
	
	ok := self.validateSelections;
	if ok = false then
		return;
	endif;
	self.displayTable();
//	self.setCaption(app.getErrorString(Work_order) &amp; " " &amp; app.getErrorString(Enquiry)); // &amp; " - " &amp; self.getQueryCaption());
	self.frmQuery.visible := (self.tblData.rows = self.tblData.fixedRows);	
epilog
	app.cmsEndLoad(ls);	
	self.mousePointer := Window.MousePointer_Default;
end;</source>
