<Class name="CMQF_VoyageColourCodeSummary">
    <JadeMethod name="setFromAgent" id="b2a8b529-c68e-471c-a03d-ffa4bb6d7130">
        <updating/>
        <source>setFromAgent(_agent : CMUI_ReportAgent input) updating;
// ---------------------------------------------------------------------------
// Created:     07 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod(_agent);
	if _agent.myQryReport.constantValue = CM_RepVoyColourCodeByDischarge then
		self.loadDischargeOption := self.MODE_OPT_DISCHARGE;
	elseif _agent.myQryReport.constantValue = CM_RepVoyColourCodeByLoad then
		self.loadDischargeOption := self.MODE_OPT_LOAD;
	endif;

end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
