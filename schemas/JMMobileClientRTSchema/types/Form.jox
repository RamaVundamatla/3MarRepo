<GUIClass name="Form">
    <JadeMethod name="doApplyScreenColors" id="21919924-6252-435b-9386-2ae561c407c2">
        <updating/>
        <source>doApplyScreenColors() updating, protected;
// --------------------------------------------------------------------------------
// Created:		24 January 2006 by cnwdad1
//
// Purpose:		Applies the background and foreground colors to the receiver.
//
//				This method should be reimplemented on subclasses to set the
//				colors of controls on those forms.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.backColor	:=	app.colorBackGeneral;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="mbShowGuiInfo" id="e0545340-f2ac-4242-8d23-b9d4f34804bf">
        <source>mbShowGuiInfo() protected;
// --------------------------------------------------------------------------------
// Created:		07 February 2006 by cnwdad1
//
// Purpose:		Displays the Current Active Form and Control and copies the Form
//				name to the clipboard.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	formName			: String;
	formSchemaName		: String;
	controlName			: String;
	controlTypeName		: String;
	controlSchemaName	: String;
	helpId				: String;
	controlHelp			: String;
	controlTab			: String;
	displayValue		: String;
	
begin
	if app.activeForm &lt;&gt; null then
		formName			:=	app.activeForm.name;
		formSchemaName		:=	app.activeForm.class.schema.name;
		app.copyStringToClipboard(formName);
		helpId				:=	app.activeForm.helpContextId.String;
	endif;
	
	if app.activeControl &lt;&gt; null then
		controlName			:=	app.activeControl.name;
		controlTypeName		:=	app.activeControl.class.name;
		controlSchemaName	:=	app.activeControl.class.schema.name;
		controlHelp			:=	app.activeControl.helpContextId.String;
		controlTab			:=	app.activeControl.tabIndex.String;
	endif;
	
	displayValue	:=	"Active Form = " &amp; formName  &amp; " (" &amp; formSchemaName &amp; ")" &amp; CrLf &amp;
						"Help Context Id = " &amp; helpId &amp; CrLf &amp; CrLf &amp;
						"Active Control = " &amp; controlName &amp; " (" &amp; controlSchemaName &amp; ":" &amp; controlTypeName &amp; ")" &amp; CrLf &amp;
						"Control Help Id = " &amp; controlHelp &amp; CrLf &amp;
						"Tab Index = " &amp; controlTab;
	
	app.msgBox(displayValue, "Active Form", MsgBox_OK_Only + MsgBox_Information_Icon);
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
