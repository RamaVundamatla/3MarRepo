<Class name="DTO_QueryCriteriaLineHolderRT" id="832e1b01-1c64-4d20-9cba-3331153a6b03">
    <superclass name="DTO_Object"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="mobileServer"/>
    <ExplicitInverseRef name="allCriteriaLines" id="76a8b174-cb2b-4ccb-aed6-ecdc2b6d12d9">
        <kind>parent</kind>
        <updateMode>automatic</updateMode>
        <type name="DTO_SelectorCriteriaLineArray"/>
        <access>readonly</access>
        <Inverse name="DTO_SelectorCriteriaLineRT::myQueryCriteriaLineHolder"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myQueryDefinition" id="509962df-4979-48e7-b605-557349286738">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="DTO_QueryDefinitionRT"/>
        <access>readonly</access>
        <Inverse name="DTO_QueryDefinitionRT::allQueryCriteriaLineHolders"/>
    </ExplicitInverseRef>
    <JadeMethod name="getAllCriteriaLinesValidForRT" id="522c139b-d64f-463f-a146-644fef8a8338">
        <source>getAllCriteriaLinesValidForRT(	_criteriaLineHolder : CM_QueryCriteriaLineHolder; 
								_criteriaLineSet : ObjectArray input );
// ------------------------------------------------------------------------------
// Created 08 may 2008 by cnwvu1
// ------------------------------------------------------------------------------

vars
	criteriaLine : CM_SelectorCriteriaLine;

begin
	
	_criteriaLineSet.clear();
	
	foreach criteriaLine in _criteriaLineHolder.allCriteriaLines do
		if self.validateCriteriaLineForRT( criteriaLine ) then
			_criteriaLineSet.add( criteriaLine );
		endif;
	endforeach;

end;
</source>
        <Parameter name="_criteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_criteriaLineSet" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="putSearchingValuesFromRT" id="3fe2f027-8a81-449d-a84b-82f7279a6b54">
        <source>putSearchingValuesFromRT( _criteriaLineHolder : CM_QueryCriteriaLineHolder input );
// --------------------------------------------------------------------------
// Created 08 may 2008 by cnwvu1
//
// Purpose:	Puts searching values from DTO criteriaLineHolder (RT screen)
//			 into criteriaLineHolder for running a query
// --------------------------------------------------------------------------

vars
	criteriaSetActualRT	: ObjectArray;
	dtoCriteriaLineLine	: DTO_SelectorCriteriaLineRT;
	criteriaLine		: CM_SelectorCriteriaLine;
	i : Integer;
	
begin
	
	create criteriaSetActualRT transient;
	self.getAllCriteriaLinesValidForRT( _criteriaLineHolder, criteriaSetActualRT );
	
	foreach dtoCriteriaLineLine in self.allCriteriaLines do
		i := i + 1;
		criteriaLine := criteriaSetActualRT[i].CM_SelectorCriteriaLine;
		dtoCriteriaLineLine.putSearchingValuesFromRT( criteriaLine );
		if app.myPassport.hasErrors() then
			return;
		endif;
	endforeach;
	
epilog
	delete criteriaSetActualRT;
	
end;
</source>
        <Parameter name="_criteriaLineHolder" type="CM_QueryCriteriaLineHolder" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForCreateForRT" id="799a9e93-1120-4d46-97f2-fd36729ac443">
        <updating/>
        <source>setForCreateForRT( _dtoQueryDef : DTO_QueryDefinitionRT; _criteriaLineHolder : CM_QueryCriteriaLineHolder ) updating;
// -------------------------------------------
// Created 07 may 2008 by cnwvu1
// -------------------------------------------

vars
	criteriaLine	: CM_SelectorCriteriaLine;
	dtoCriteriaLine	: DTO_SelectorCriteriaLineRT;
	dtoCriteriaLineBoolean		: DTO_CriteriaLineBoolean;
	dtoCriteriaLineString		: DTO_CriteriaLineString;
	dtoCriteriaLineStringFromTo	: DTO_CriteriaLineStringFromTo;
	
	searchValueA, searchValueB	: String;
	searchValueBoolean			: Boolean;
	isStringProperty, isStringBetweenProperty, isBooleanProperty : Boolean;
	
begin

	self.myQueryDefinition := _dtoQueryDef;
	
	foreach criteriaLine in _criteriaLineHolder.allCriteriaLines do
		// checking whether criteria is visible for users
		if self.validateCriteriaLineForRT( criteriaLine ) then	
		
			criteriaLine.myQueryOperator.getCriteriaLineDefinitionForRT( criteriaLine.myQueryProperty, searchValueA, searchValueB, searchValueBoolean, isStringProperty, isStringBetweenProperty, isBooleanProperty );
			
			if isBooleanProperty then
				create dtoCriteriaLineBoolean transient;
				dtoCriteriaLine := dtoCriteriaLineBoolean;
				
			elseif isStringProperty then
				create dtoCriteriaLineString transient;
				dtoCriteriaLine := dtoCriteriaLineString;
				
			elseif isStringBetweenProperty then
				create dtoCriteriaLineStringFromTo transient;
				dtoCriteriaLine := dtoCriteriaLineStringFromTo;
				
			else
				app.raiseUnexpectedProgramError( class.name, method.name, 'Wrong type of DTO Criteria Line object' );
				
			endif;
			
			dtoCriteriaLine.setForCreateForRT( self, criteriaLine, searchValueA, searchValueB, searchValueBoolean );
			
		endif;
		
	endforeach;

end;
</source>
        <Parameter name="_dtoQueryDef" type="DTO_QueryDefinitionRT"/>
        <Parameter name="_criteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
    </JadeMethod>
    <JadeMethod name="setForCreateFromRT" id="c2804b61-e2b9-4ba0-a8eb-f7f2c1373123">
        <updating/>
        <source>setForCreateFromRT( _dtoQueryDef : DTO_QueryDefinitionRT ) updating;
// -------------------------------------------
// Created 07 may 2008 by cnwvu1
// -------------------------------------------

vars

begin

	self.myQueryDefinition := _dtoQueryDef;
	
end;
</source>
        <Parameter name="_dtoQueryDef" type="DTO_QueryDefinitionRT"/>
    </JadeMethod>
    <JadeMethod name="validateCriteriaLineForRT" id="8b05f047-9c0f-439b-8aac-4c009611c201">
        <source>validateCriteriaLineForRT( _selectorCriteriaLine : CM_SelectorCriteriaLine ) : Boolean;
// ------------------------------------------------------------------------------------
// Created 08 may 2008 by cnwvu1
//
// Purpose:	Validates availablitity for users and also visibility for RT screen
// ------------------------------------------------------------------------------------

vars

begin

	if not _selectorCriteriaLine.isUnavailableAtRunTime and _selectorCriteriaLine.myQueryProperty.validateCriteriaLineVisibleRT() then
		return true;
	else
		return false;
	endif;
	
end;
</source>
        <Parameter name="_selectorCriteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForQueryRun" id="fcdf08de-7c73-4b74-9e8b-cf14312b4c87">
        <source>validateForQueryRun( _criteriaLineHolder : CM_QueryCriteriaLineHolder );
// -------------------------------------------
// Created 08 may 2008 by cnwvu1
// -------------------------------------------

vars
	i	: Integer;
	dtoCriteriaLineLine	: DTO_SelectorCriteriaLineRT;
	criteriaLine		: CM_SelectorCriteriaLine;
	criteriaSet			: ObjectArray;
	
begin

	// organizing criteria lines that are visible on RT screen
	create criteriaSet transient;
	self.getAllCriteriaLinesValidForRT( _criteriaLineHolder, criteriaSet );
	
	i := 0;
	foreach dtoCriteriaLineLine in self.allCriteriaLines do
		i := i + 1;
		criteriaLine := criteriaSet[i].CM_SelectorCriteriaLine;
		dtoCriteriaLineLine.validateForQueryRun( criteriaLine );
		if app.myPassport.hasErrors() then
			return;
		endif;
	endforeach;
	
epilog
	delete criteriaSet;
	
end;
</source>
        <Parameter name="_criteriaLineHolder" type="CM_QueryCriteriaLineHolder"/>
    </JadeMethod>
</Class>
