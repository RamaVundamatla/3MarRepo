    </ImplicitInverseRef>
    <JadeMethod name="create" id="0f4548ad-1bcd-4739-9cc9-4658172800a0">
        <updating/>
        <source>create() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 Mar 2024 navhl20 ChangeRequest 60097: EUP | Ship Operations in DD - [54176.060] - [Receive] Retrospective Operations

*/

vars

begin
	self.permissionView		:= PmAdmWorkOrderEnquiry;
	self.permissionMaint	:= PmAdmWorkOrderEnqMaint; 
	self.helpFileName 		:= HelpFile_Yard;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="39b96ed0-c482-4e67-8f94-366055b02015">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Mar 2024 navhl20 ChangeRequest 60097: EUP | Ship Operations in DD - [54176.060] - [Receive] Retrospective Operations

*/

vars
	retroDT : TimeStamp;
	result	: Integer;
begin
	retroDT.setDate(self.txtDate.getDate());
	retroDT.setTime(self.txtTime.getTime());
	
	if not retroDT.isValid then
		return;
	endif;
	
	if retroDT &gt; app.actualTimeServer then
		app.raiseCMException(Retrosp_datetim_not_future,null,null);
		return;
	endif;
	
	while true do
		app.myTrxUA.trxUpdateJobRetroDT(self.myJob,retroDT,app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			self.unloadForm();
			break;
		else
			result := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		return;
	endwhile;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setJob" id="71673dcf-3982-49e1-8d52-477d4112f762">
        <updating/>
        <source>setJob(_job : CM_Job)updating;
