    </JadeMethod>
    <JadeMethod name="addDiscrepancy" id="37214418-d0ca-4c26-b1d8-7365c2c73f5f">
        <updating/>
        <source>addDiscrepancy(discrep : CM_Discrepancy) updating;
// ---------------------------------------------------------------------------
// Created:     12 February 2001 by cnwdwq1
//
// Purpose:			Adds the passed in discrepancy to the terminal's collection of discreps
//	NOTE: The discrepancy can be ANY of the sub-classes.
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	termDiscrepancyArray:   CM_DiscrepancyArray;
	today:                  Date;
begin
	
	if discrep = null then
		app.setContinueCMExceptions(false);
		app.raiseCMException1(ERR_NO_OBJECT, "No Discrepancy", null, null);	
		return;
	endif;
	
	today := discrep.date.date();
	termDiscrepancyArray := self.discrepancies[today];
	if termDiscrepancyArray = null then
		create termDiscrepancyArray;
		self.discrepancies.putAtKey(today, termDiscrepancyArray);
	endif;
	termDiscrepancyArray.add(discrep);
end;</source>
        <Parameter name="discrep" type="CM_Discrepancy"/>
    </JadeMethod>
    <JadeMethod name="addOnePortStatus" id="a499709a-a263-4d04-9fb1-fa14c7a30525">
        <updating/>
        <source>addOnePortStatus(_nvPair : CM_NameValuePair) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/11/2025	navkc1 JIRA 36176 NSW | OnePort API - Change voyage creation criteria DB / UI / Process changes

*/

vars

begin
	self.allOnePortStatuses.add(_nvPair);
epilog

end;</source>
        <Parameter name="_nvPair" type="CM_NameValuePair"/>
    </JadeMethod>
    <JadeMethod name="addOrEditDBLoadOption" id="492f1ac4-5541-4384-820f-aeb050d8b79f">
        <source>addOrEditDBLoadOption(_pair : CM_NameValuePair);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 June 2023	navra1	Initial creation for 58278

*/

vars	
	existingPair, newPair : CM_NameValuePair;
begin
	
	//This method should be called only in transaction state
	if not process.isInTransactionState() then
		return;
	endif;
	
	//since the keys are unique for this use-case, just search with the key(name)
	existingPair := self.allDBLoadOptions[_pair.name];		
	
	//internally it does the same thing(remove and add a new one)
	if existingPair &lt;&gt; null then		
		self.allDBLoadOptions.remove(existingPair);	
	endif;
	
	create newPair persistent;
	newPair.createNewPair(_pair.name, _pair.value); 
	
	self.allDBLoadOptions.add(newPair);	
		
epilog

end;</source>
        <Parameter name="_pair" type="CM_NameValuePair"/>
    </JadeMethod>
    <JadeMethod name="addOrRemoveOnePortStatus" id="eb97ccb4-40d6-4f51-8d33-11e72ec0c410">
        <updating/>
        <source>addOrRemoveOnePortStatus(_statuses : CM_NameValuePairDict) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/11/2025	navkc1 JIRA 36176 NSW | OnePort API - Change voyage creation criteria DB / UI / Process changes

*/

vars
	existingNV,
	nvPair : CM_NameValuePair;
	
begin
	// If Terminal doesn't have one but it's in the list, create it
	foreach nvPair in _statuses do
		existingNV := self.allOnePortStatuses[nvPair.name];
		
		if existingNV = null then
			create existingNV persistent;
			existingNV.createNewPair(nvPair.name, nvPair.value);
			self.addOnePortStatus(existingNV);
		else
			existingNV.createNewPair(existingNV.name, nvPair.value); // Not really create but an update
		endif;
	endforeach;
	
	// If Terminal has one but it's not in the list, remove it
	foreach nvPair in self.allOnePortStatuses do
		existingNV := _statuses[nvPair.name];
		
		if existingNV = null then
			self.removeOnePortStatus(nvPair);
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_statuses" type="CM_NameValuePairDict"/>
    </JadeMethod>
    <JadeMethod name="addTerminalToInternalUser" id="3c0c6ae5-9e18-4a86-8b9c-ec6075a990e1">
        <source>addTerminalToInternalUser(_userCode : String);
/*

Purpose: Add the new terminal into Internal Users (SUPERUSER, JMTSUPPORT)

Parameters:			

Return Value:		

Date		Who		TFS		Reason
02 Sep 2019	jlgdi1	45802	Initial creation

*/

vars
	internalUser : CM_User;
	proxyUser : CM_User;
	securityRole : CM_SecurityRoleTerminal;
	userTerm : CM_UserTerminal;
	proxyUserTerminal : CM_UserTerminal;
	
begin
	internalUser := app.myRoot.allUsers[_userCode];
	if internalUser &lt;&gt; null then
		proxyUser := internalUser.pxyCreateUpdateProxy();
		securityRole := app.myRoot.allRoles['Terminal Root'].CM_SecurityRoleTerminal;
		
		create proxyUserTerminal transient;
		proxyUserTerminal.setForProxy(self, proxyUser, securityRole, null, null, null);
		
		create userTerm persistent;
		userTerm.setForCreate(proxyUserTerminal, internalUser);
	endif;
	
epilog
	delete proxyUserTerminal;
	delete proxyUser;	
end;</source>
        <Parameter name="_userCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="addToRailSortColl" id="468f1119-d8d6-4bef-ad0a-7d555616a091">
        <source>addToRailSortColl(request: CM_YardRequest);

vars
	sortedRequests:  CM_RequestArray;
begin
	sortedRequests := self.myRailJobSheet.sortedRequests;
	if sortedRequests.includes(request) then
		sortedRequests.remove(request);
	endif;
	sortedRequests.add(request);
end;</source>
        <Parameter name="request" type="CM_YardRequest"/>
    </JadeMethod>
    <JadeMethod name="addUpdateTerminalMutexes" id="c21ae0ec-4997-4689-b61c-7a810888949e">
        <source>addUpdateTerminalMutexes();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 September 2021	navndl1	Initial creation	TFS 51142

*/

vars

	terminalMutexContexts : IntegerArray;
	terminalMutexNames : StringArray;
	mutexContext : Integer;
	mutexName : String;
	mutexObj : CM_Mutex;
	index : Integer;
	pxyMutex : CM_Mutex;

begin

	create terminalMutexContexts transient;						create terminalMutexNames transient;
	terminalMutexContexts.add( Mutex_EDINewFiles );				terminalMutexNames.add( Mutex_EDINewFiles_String );
	terminalMutexContexts.add( Mutex_EDIDBPurge );				terminalMutexNames.add( Mutex_EDIDBPurge_String );
	terminalMutexContexts.add( Mutex_EDIDupEventReqPurge );		terminalMutexNames.add( Mutex_EDIDupEventReqPurge_Str );
	terminalMutexContexts.add( Mutex_EDIQueuedFiles );			terminalMutexNames.add( Mutex_EDIQueuedFiles_String );
	
	foreach index in 1 to terminalMutexContexts.size do
		mutexContext := terminalMutexContexts[index];
		mutexName := terminalMutexNames[index];
		mutexObj := self.allMutexes.getAtKey( mutexName, mutexContext );
		if mutexObj = null then
			//create One
			create pxyMutex transient;
			pxyMutex.setDetails(	null,	//_root : CM_Root;
									self,	//_term : CM_Terminal;
									mutexName,	//_name : String;
									mutexContext	//_context : Integer
									); 
			app.myUtilityCA.utlCreateMutex( pxyMutex, mutexObj, app.myPassport );
			delete pxyMutex;
		endif;
	endforeach;

epilog

	delete terminalMutexContexts;
	delete terminalMutexNames;
	delete pxyMutex;

end;</source>
    </JadeMethod>
    <JadeMethod name="addVoyageToDict" id="ea5f7171-acdc-46d6-805e-7c992143bf9b">
        <source>addVoyageToDict(pOldCode, pOldInwardCode : String; pVoyage : CM_Voyage);
// ---------------------------------------------------------------------------
// Created:     26 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpVoy	: CM_Voyage;
	oldKey	: String;

begin
/*
	voyCol := self.allVoyages;
	exclusiveLock(pVoyage);
	exclusiveLock(voyCol);

	oldKey := pOldCode.trimRight;
	
	if oldKey &lt;&gt; null then
		// Update rather than an add so need to remove the old code from the dict
		tmpVoy := voyCol[oldKey];
	
		if tmpVoy &lt;&gt; null and tmpVoy &lt;&gt; pVoyage and not app.isConverting then
			// The voyage in the dict with the current key is NOT self 
			app.raiseUnexpectedProgramError(class.name, method.name, 
											'Potential corruption in voyages dict for voyage (' &amp; oldKey &amp; 
											') on terminal (' &amp; self.name &amp; ')');
			return;
		elseif tmpVoy &lt;&gt; null then
			voyCol.removeKey(oldKey);
		endif;
	endif;

	oldKey := pOldInwardCode.trimRight;

	if oldKey &lt;&gt; null then
		// Update rather than an add so need to remove the old code from the dict
		tmpVoy := voyCol[oldKey];
	
		if tmpVoy &lt;&gt; null and tmpVoy &lt;&gt; pVoyage and not app.isConverting then
			// The voyage in the dict with the current key is NOT self 
			app.raiseUnexpectedProgramError(class.name, method.name, 
											'Potential corruption in voyages dict for voyage (' &amp; oldKey &amp; 
											') on terminal (' &amp; self.name &amp; ')');
			return;
		elseif tmpVoy &lt;&gt; null then
			voyCol.removeKey(oldKey);
		endif;
	endif;
	
	if pVoyage.code.trimRight &lt;&gt; null then
		voyCol.putAtKey(pVoyage.code.trimRight, pVoyage);
	endif;
	if pVoyage.inwardCode.trimRight &lt;&gt; null and 
	   pVoyage.code.trimRight &lt;&gt; pVoyage.inwardCode.trimRight then
		voyCol.putAtKey(pVoyage.inwardCode.trimRight, pVoyage);
	endif;
*/
	self.addVoyageToNewDict(pOldCode, pOldInwardCode, pVoyage.arrivedDT, pVoyage);
end;</source>
        <Parameter name="pOldCode" type="String"/>
        <Parameter name="pOldInwardCode" type="String"/>
        <Parameter name="pVoyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="addVoyageToNewDict" id="490f3dbc-f997-4347-9236-f1434f0a6aca">
        <source>addVoyageToNewDict(pOldCode, pOldInwardCode : String; oldArrivedDate : TimeStamp ;pVoyage : CM_Voyage);
// ---------------------------------------------------------------------------
// Created:     26 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12 Aug 2008	cnwkpd1		PAR #17719 - Change removeKey to removeKeyEntry to handle duplicate keys
// ---------------------------------------------------------------------------

vars
	voyCol	: CM_VoyageByCodeArrivalDTDict;
	tmpVoy	: CM_Voyage;
	oldKey	: String;

begin
	
	voyCol := self.allVoyagesNew;
	exclusiveLock(pVoyage);
	exclusiveLock(voyCol);

	oldKey := pOldCode.trimRight;
	
	if oldKey &lt;&gt; null then
		// Update rather than an add so need to remove the old code from the dict
		tmpVoy := voyCol[oldKey, oldArrivedDate];
	
		if tmpVoy &lt;&gt; null and tmpVoy &lt;&gt; pVoyage and not app.isConverting then
			// The voyage in the dict with the current key is NOT self 
			app.writeLog("Voyage not added due to potential corruption.", LogDEBUG);
			app.raiseUnexpectedProgramError(class.name, method.name, 
											'Potential corruption in voyages dict for voyage (' &amp; oldKey &amp; 
											') on terminal (' &amp; self.name &amp; ')');
			return;
		elseif tmpVoy &lt;&gt; null then
			voyCol.removeKeyEntry(oldKey, oldArrivedDate, tmpVoy);			// PAR #17719
		endif;
	endif;

	oldKey := pOldInwardCode.trimRight;

	if oldKey &lt;&gt; null then
		// Update rather than an add so need to remove the old code from the dict
		tmpVoy := voyCol[oldKey, oldArrivedDate];
	
		if tmpVoy &lt;&gt; null and tmpVoy &lt;&gt; pVoyage and not app.isConverting then
			// The voyage in the dict with the current key is NOT self 
			app.writeLog("Voyage not added due to potential corruption.", LogDEBUG);
			app.raiseUnexpectedProgramError(class.name, method.name, 
											'Potential corruption in voyages dict for voyage (' &amp; oldKey &amp; 
											') on terminal (' &amp; self.name &amp; ')');
			return;
		elseif tmpVoy &lt;&gt; null then
			voyCol.removeKeyEntry(oldKey, oldArrivedDate, tmpVoy);			// PAR #17719
		endif;
	endif;
	
	if pVoyage.code.trimRight &lt;&gt; null then
		voyCol.putAtKey(pVoyage.code.trimRight, pVoyage.arrivedDT, pVoyage);
	endif;
	
	if pVoyage.inwardCode.trimRight &lt;&gt; null and 
	   pVoyage.code.trimRight &lt;&gt; pVoyage.inwardCode.trimRight then
		voyCol.putAtKey(pVoyage.inwardCode.trimRight, pVoyage.arrivedDT, pVoyage);
	endif;
	
end;</source>
        <Parameter name="pOldCode" type="String"/>
        <Parameter name="pOldInwardCode" type="String"/>
        <Parameter name="oldArrivedDate" type="TimeStamp"/>
        <Parameter name="pVoyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="applyRoundingToValue" id="c093a282-6bcc-4ecb-8aaa-d99d17d8cf3f">
        <source>applyRoundingToValue( _valueToRound : Decimal ):Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 August 2018	jlgndl1	Initial creation	TFS 40500

*/

vars

	roundingHrs : Integer;
	rem : Decimal[3,2];
	retValue : Decimal[6,2];
	daysDec : Decimal[4,2];
	hrsInt : Integer;

begin

	
	roundingHrs := self.getConfig(TotDaysReqRoundedToHours).Integer; 
	// can be one of 1,2,3,4,6,8 or 12
	
	
	if roundingHrs = 0 then
		retValue := _valueToRound;
	else
		retValue := _valueToRound.Integer;
		rem := _valueToRound mod 1;
		
		if rem &gt; 0 then
			hrsInt := 24;
			while true do
				daysDec := (hrsInt / 24).Decimal; // The percentage of a day to round up
				hrsInt := hrsInt - roundingHrs; // the lowest hours we round up from.
				if ( rem * 24 ) &gt; hrsInt then
					retValue := retValue + daysDec;
					break;
				endif;
				if hrsInt &lt;= 0 then
					//should never get to here.
					break;
				endif;
			endwhile;
		endif;
	endif;
	
	return retValue;
	
epilog

end;</source>
        <Parameter name="_valueToRound" type="Decimal"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="archiveEmptyLocationsByType" id="e41f7906-d64c-451d-aeb2-f4838e1baf5c">
        <source>archiveEmptyLocationsByType(_taType : Integer; _numberOfHours : Integer; _overrideIgnore : Boolean; _errorSet : CM_ErrorSet input);
// ---------------------------------------------------------------------------
// Created:     09 January 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23 Dec 2010	cnwkpd1	PAR #26678 - Tidy up transient leaks
// ---------------------------------------------------------------------------
vars
	ta		: CM_TerminalArea;
	iter	: Iterator;
begin

	_errorSet.clear();
	iter := self.allTerminalAreasByTypeId.createIterator;
	self.allTerminalAreasByTypeId.startKeyGeq(_taType, null, iter);

	while iter.next(ta) do
		if ta.type &lt;&gt; _taType then
			break;
		endif;
		ta.archiveEmptyLocations(_numberOfHours, _overrideIgnore, _errorSet);
	endwhile;

epilog
	delete iter;		// PAR #26678
		
end;</source>
        <Parameter name="_taType" type="Integer"/>
        <Parameter name="_numberOfHours" type="Integer"/>
        <Parameter name="_overrideIgnore" type="Boolean"/>
        <Parameter name="_errorSet" type="CM_ErrorSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="auditClass" id="d7a00cac-7716-45e5-920c-6686d2c9b988">
