    <JadeMethod name="trxCreateProformaCriteria" id="cc799c2d-0738-4c9e-af13-fac1a04b40ce">
        <updating/>
        <source>trxCreateProformaCriteria(	_proformaCriteria : CM_ProformaTransactionCriteria input;
							_newProformaCriteria : CM_ProformaTransactionCriteria output;
							_passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2012	cnwndl1	Initial creation

*/

vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	// Perform the operation
	app.myUtilityCA.utlCreateProformaCriteria(_proformaCriteria, _newProformaCriteria, _passport);
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
