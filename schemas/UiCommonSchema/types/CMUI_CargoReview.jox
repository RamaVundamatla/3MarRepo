        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnAddtionalCols_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//02/10/2023	navkc1	CR 60423 Task 60764: UI - Cargo Review Cust Doc Summary

*/

vars

begin
	self.myAssistant.showMultiSelectForm(btn.caption, self.allAdditionalRowsAvailable, self.allAdditionalRows, true,true,self.allPerformanceRows);
	if self.frmToolbar.showCaptions then
		self.setEntRowsLabel(self.lblAdditional,self.allAdditionalRows,5);
	else
		self.setEntRowsLabel(self.lblAdditional,self.allAdditionalRows,2);
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
