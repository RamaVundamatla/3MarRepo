    <JadeMethod name="setTIFromTableSpecial" id="194935d7-0eda-4cc0-85d5-538fca757646">
        <source>setTIFromTableSpecial(_attrName : String io;
						_strValue : String;
						_obj : CM_TrackedItem input;
						_tbl : CM_EntryTable input) : Boolean protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 14 May 2007
//
//----------------------------------------------------------------------
/*

Date		Who		Reason
26 Jun 208	cnwkpd1	PAR #17183 - Ensure spaces are stripped from Customs Entry Numbers

*/

vars
	sa					: StringArray512;
	str					: String;

begin
	if _attrName = ETRow_CustomsEntryNumber then
		create sa transient;
		str := _strValue;
		str := str.replaceString(' ','');		// PAR #17183
		str.getTokensForDelimiter(',', sa);
		_obj.zSetPxyAllCustomsEntryNumbers(sa);
		return true;
	elseif _attrName = ETRow_BookingReference then		//+cnwml2 PAR26088
		_obj.setBookingReference(_strValue);
		return true;
	endif;
	return false;
	
	
epilog
	delete sa;
	
end;</source>
        <access>protected</access>
        <Parameter name="_attrName" type="String" usage="io"/>
        <Parameter name="_strValue" type="String"/>
        <Parameter name="_obj" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_tbl" type="CM_EntryTable" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="2d08156c-2725-4c7d-b9c1-dea90bc43d54">
        <updating/>
        <source>showThumbnailData(obj: Object) updating;
// ---------------------------------------------------------------------------
// Created:     10 January 2001 by cnwrs2
// ---------------------------------------------------------------------------
vars
	tiObj			: CM_TrackedItem;
	str				: String;
	hasHaz			: Boolean;
	showPIN			: Boolean;
	showOpImpPIN	: Boolean; //cnwrd1 10.11.08 CCMS JMT 1743/1764 
	allHeadingsObj	: HugeStringArray;
	allDataObj		: HugeStringArray;
	dataSize		: Integer;
	arrayPointer	: Integer;	
begin
	tiObj	:=	obj.CM_TrackedItem;
	
	if self.userPermissionMode = PmGteFullReleaseCarrierMaint 
	or self.userPermissionMode = PmGteFullReleaseForward
	or self.userPermissionMode = PmGteFullReleaseMaint
	then
	   	showPIN	:=	true;
	endif;
	
	self.setNavigatorHeading(tiObj.cargoTypeDescr &amp; ' (' &amp; tiObj.id &amp; ')');
	
	//cnwrd1 10.11.08 CCMS JMT 1743/1764 
	if self.userPermissionMode = PmGteFullReleaseOperatorMaint  then
		showOpImpPIN := true;
	else
		showOpImpPIN := false;
	endif;
	
	create allHeadingsObj transient;
	create allDataObj transient; 
	tiObj.showThumbnailData(allHeadingsObj, allDataObj, showPIN,showOpImpPIN, true);  //cnwrd1 10.11.08 CCMS JMT 1743/1764 
	tblThumb.rows	:=	0;

	if tiObj.isValidForPINGeneration then
		self.btnGeneratePin.enabled := true;
	else
		self.btnGeneratePin.enabled := false;
	endif;
	// Delete Pin button enabled?	Par 18856, Feb 2009
	if tiObj.myPinNo &lt;&gt; null then
		self.btnDeletePin.enabled	:= true;
	else
		self.btnDeletePin.enabled	:= false;
	endif;

	dataSize	:=	allDataObj.size();
	
	foreach str in allHeadingsObj do
		arrayPointer	:=	arrayPointer + 1;
		
		if arrayPointer &gt; dataSize then
			break;
		endif;
		
		if str &lt;&gt; null then
			hasHaz := false;
		endif;
		
		tblThumb.addItem(str &amp; Tab &amp; allDataObj[arrayPointer]);
		
		if str.pos("Hazardous",1) &gt; 0 or hasHaz then
			if allDataObj[arrayPointer] &lt;&gt; "None" then
				tblThumb.accessRow(arrayPointer).foreColor	:=	Red;
				hasHaz	:=	true;
			endif;
		endif;
	endforeach;
	
	self.btnSelectAllTV.enabled:= true;
	
epilog
	delete allHeadingsObj;
	delete allDataObj;
end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="sysNotify" id="8f79f9eb-7707-48d9-aaa9-1cb5d983143c">
        <controlMethod name="Form::sysNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>sysNotify(eventType: Integer; theObject: Object; eventTag: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     06 June 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpTI	: CM_TrackedItem;

begin

// do NOT do an inherit method here

	tmpTI := theObject.CM_TrackedItem;
	
	if eventType = Object_Delete_Event then
		self.zTblDataSysNotifyDelete(Object_Delete_Event, tmpTI, eventTag);

	elseif eventType = Object_Update_Event then
		if not self.generatingPIN then
			self.zTblDataSysNotifyUpdate(eventType, theObject, eventTag);
		endif;
	endif;

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblCustEntry_gotFocus" id="c213812e-e612-481f-9363-5d8aed2d8cb2">
        <controlMethod name="Table::gotFocus"/>
