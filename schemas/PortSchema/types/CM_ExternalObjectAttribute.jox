<Class name="CM_ExternalObjectAttribute" id="771f5de1-aa14-4955-80b4-ac69e692765e">
    <superclass name="CM_ExternalDatabaseTransient"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <PrimAttribute name="attributeName" id="c6bdc8da-d810-4654-beee-6b11741434ff">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="maxLength" id="4084ee79-79c0-4ea3-ae84-80bfd3afc923">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <ImplicitInverseRef name="myAttribute" id="121ce3fa-6e1b-4f82-981c-9db4f61f8d8f">
        <embedded/>
        <type name="ExternalPrimAttribute"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="setForCreate" id="7310b6b8-c300-462f-be15-56ad3ac35e5d">
        <updating/>
        <source>setForCreate(_attr: ExternalPrimAttribute) updating;
// ---------------------------------------------------------------------------
// Created:     03 July 2003 by cnwsb1
// ---------------------------------------------------------------------------
begin
	// eg. edb_Oid --&gt; oid
	self.attributeName := _attr.getName[CM_DataDumpClass.EDBAttrPrefix.length+1:end];
	self.attributeName[1] := self.attributeName[1].toLower;
	self.maxLength := _attr.getLength - 1;
	if self.maxLength &lt; 0 then
		self.maxLength := 0;
	endif;

	self.myAttribute := _attr;
end;</source>
        <Parameter name="_attr" type="ExternalPrimAttribute"/>
    </JadeMethod>
</Class>
