<Class name="WS_RoroLaneController" id="1291c964-9665-4d01-a323-7be9ba23cf67">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="laneId" id="09d273e2-96c0-495b-abe9-790010d1f29e">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="laneLength" id="a96cd836-30c9-4eb5-ad35-7e5254db81f9">
        <precision>12</precision>
        <embedded/>
        <type name="Decimal"/>
    </PrimAttribute>
    <PrimAttribute name="laneNumber" id="c7f5b237-9734-4162-9b03-1b74c6500aa3">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="numberingDirection" id="a247443e-8558-4fc6-8294-c1fdc5462483">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="startingDirection" id="b8eb7dfd-ad33-451a-a3cb-4d98ed21011c">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="setProxyFromObject" id="a582538f-b74d-4d0f-af1d-c9bcf3fc39d7">
        <updating/>
        <source>setProxyFromObject(_object:CM_RoRoController) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 July 2017	jlgam15	Initial creation

*/

vars

begin
	inheritMethod(_object);
	self.laneId 			:= _object.id;
	self.laneNumber 		:= _object.laneNumber;
	self.laneLength 		:= _object.length;
	self.numberingDirection := _object.numberingDirection;
	//epr TFS 7931 direction issue
	if _object.allTrackedItems.size &gt; 0 then	
		if _object.freedLength &gt; 0 then
		//start from = RIGHT to Left NUMBERING_DIRECTION_R_TO_L
			self.startingDirection:=CM_RoRoController.NUMBERING_DIRECTION_R_TO_L;
		else
			// startingFrom := LEFT to RIGHT NUMBERING_DIRECTION_L_TO_R
			self.startingDirection:=CM_RoRoController.NUMBERING_DIRECTION_L_TO_R;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_object" type="CM_RoRoController"/>
    </JadeMethod>
</Class>
