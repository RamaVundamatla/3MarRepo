    <JadeMethod name="doResize" id="2ff75744-7d4c-4711-9c11-13ff69ab7d82">
        <updating/>
        <source>doResize() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

begin

	inheritMethod();
	
	self.splTables.top := self.frmToolbar.top + self.frmToolbar.height + 2;
	self.splTables.left := self.frmToolbar.left;
	self.splTables.width := self.frmToolbar.width;
	self.splTables.height := self.clientHeight - self.splTables.top;
	
	self.splTables.cnEcResizeContents();
	self.splTables.repositionAfterResize();
	
	self.frmQuery.left := (self.clientWidth / 2) - (self.frmQuery.width / 2);
	self.frmQuery.top := (self.clientHeight / 2) - (self.frmQuery.height / 2);
	
	self.fldQuery.top := self.frmQueryToolbar.height; // ### TFS 50421 17SEP2021 NAVAB1

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doSelectDataCell" id="ddecb1d0-faad-4611-b3d2-c5a8fbd082ca">
        <source>doSelectDataCell();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 June 2011	cnwndl1	Initial creation

*/

vars

	dataTable : Table;
	row : Integer;
	col : Integer;
	tableCell : JadeTableCell;
	tableRow : JadeTableRow;
	
	userObject : Object;
	dataContainer : CM_DataContainer;
	block : CM_DataContainerBlock;
	br : CM_BulkRelease;
	ti : CM_TrackedItem;
	
	dataColumnWidth : Integer;
	entTableRow : EntTableRow;
	enquiryLine : CM_MTPoolingEnquiryLine;
	
	voyages : CM_VoyageSet;
	voyage : CM_Voyage;
	iter : Iterator;
	taskDesc : CM_ToDoTaskDesc;
	addCargoList : Boolean;
	rowHeading : String;
	
begin

	self.tblInfo.clear();
	self.tblInfo.fixedRows := 0;
	self.tblInfo.rows := 1;
	self.tblInfo.fixedColumns := 1;
	self.tblInfo.columns := 2;
	
	dataTable := self.tblData;
	row := dataTable.row;
	col := dataTable.column;

	if row &gt; dataTable.fixedRows and row &lt;= dataTable.rows then
		if col &gt; dataTable.fixedColumns and col &lt;= dataTable.columns then
			tableCell := dataTable.accessCell( row, col );
			tableRow := dataTable.accessRow( row );
		endif;
	endif;
	
	if tableCell = null then
		return;
	endif;
	
	userObject := tableCell.itemObject;
	
	if userObject = null or not app.isValidObject( userObject ) then
		return;
	endif;
	
	entTableRow := dataTable.CM_DataTable.allTblDataEntRows[col];
	enquiryLine := dataTable.accessRow( row ).itemObject.CM_MTPoolingEnquiryLine;
	
	create dataContainer transient;
	if userObject.isKindOf( CM_MTThreshold ) then
		block := dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(MT_Threshold), DC_Header, 1, self);
		userObject.CM_MTThreshold.getExtraInfo( dataContainer );
					
	elseif userObject.isKindOf( CM_TIArray ) then
	
		rowHeading := entTableRow.getHeading(null, null, app.myCurrentLocale) &amp; " ";
		
		if entTableRow.name = ETRow_PreTrip then
			addCargoList := true;
			block := dataContainer.addNewBlock;
			block.addNewItem( rowHeading &amp; app.getErrorString(Tasks), DC_Header, 1, self);
			iter := app.myRoot.allToDoTaskDescriptions.createIterator;
			while iter.next( taskDesc ) do
				if taskDesc.emptyReportColumn = MTReportTaskColumn_Pretrip then
					block := dataContainer.addNewBlock;
					block.addNewItem(app.getErrorString(Task), DC_Label, 1, self);
					block.addNewItem(taskDesc.description, DC_Data, 1, self);
				endif;
			endwhile;
			
		elseif entTableRow.name = ETRow_Wash then
			addCargoList := true;
			block := dataContainer.addNewBlock;
			block.addNewItem(rowHeading &amp; app.getErrorString(Tasks), DC_Header, 1, self);
			iter := app.myRoot.allToDoTaskDescriptions.createIterator;
			while iter.next( taskDesc ) do
				if taskDesc.emptyReportColumn = MTReportTaskColumn_Wash then
					block := dataContainer.addNewBlock;
					block.addNewItem(app.getErrorString(Task), DC_Label, 1, self);
					block.addNewItem(taskDesc.description, DC_Data, 1, self);
				endif;
			endwhile;
		
		elseif entTableRow.name = ETRow_Repair then
			addCargoList := true;
			block := dataContainer.addNewBlock;
			block.addNewItem(rowHeading &amp; app.getErrorString(Tasks), DC_Header, 1, self);
			iter := app.myRoot.allToDoTaskDescriptions.createIterator;
			while iter.next( taskDesc ) do
				if taskDesc.emptyReportColumn = MTReportTaskColumn_Repair then
					block := dataContainer.addNewBlock;
					block.addNewItem(app.getErrorString(Task), DC_Label, 1, self);
					block.addNewItem(taskDesc.description, DC_Data, 1, self);
				endif;
			endwhile;
		
		elseif entTableRow.name = ETRow_PtiRepair then
			addCargoList := true;
			block := dataContainer.addNewBlock;
			block.addNewItem(rowHeading &amp; app.getErrorString(Tasks), DC_Header, 1, self);
			iter := app.myRoot.allToDoTaskDescriptions.createIterator;
			while iter.next( taskDesc ) do
				if taskDesc.emptyReportColumn = MTReportTaskColumn_PTIRepair then
					block := dataContainer.addNewBlock;
					block.addNewItem(app.getErrorString(Task), DC_Label, 1, self);
					block.addNewItem(taskDesc.description, DC_Data, 1, self);
				endif;
			endwhile;
		
		elseif entTableRow.name = ETRow_Survey then
			addCargoList := true;
			block := dataContainer.addNewBlock;
			block.addNewItem(rowHeading &amp; app.getErrorString(Tasks), DC_Header, 1, self);
			iter := app.myRoot.allToDoTaskDescriptions.createIterator;
			while iter.next( taskDesc ) do
				if taskDesc.emptyReportColumn = MTReportTaskColumn_Survey then
					block := dataContainer.addNewBlock;
					block.addNewItem(app.getErrorString(Task), DC_Label, 1, self);
					block.addNewItem(taskDesc.description, DC_Data, 1, self);
				endif;
			endwhile;
		
		elseif entTableRow.name = ETRow_ShipReceivals then
			// cargo by voyage
			create voyages transient;
			foreach ti in userObject.CM_TIArray do
				voyages.addNoDuplicates( ti.myVoyage, false);	
			endforeach;
			foreach voyage in voyages do			
				block := dataContainer.addNewBlock;
				block.addNewItem(rowHeading &amp; ": " &amp; app.getErrorString(Voyage) &amp; Tab &amp; voyage.code, DC_Header, 1, self);				
				foreach ti in userObject.CM_TIArray where ti.myVoyage = voyage do
					block := dataContainer.addNewBlock;
					block.addNewItem(app.getErrorString(Container), DC_Label, 1, self);
					block.addNewItem(ti.id, DC_Data, 1, self);
				endforeach;
			endforeach;
			
		else
			addCargoList := true;
			
		endif;
		
		if addCargoList then
			// block of cargo only
			block := dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(CMQF_Empty_Containers), DC_Header, 1, self);
			foreach ti in userObject.CM_TIArray do
				block := dataContainer.addNewBlock;
				block.addNewItem(app.getErrorString(Container), DC_Label, 1, self);
				block.addNewItem(ti.id, DC_Data, 1, self);
			endforeach;
			
		endif;
	
	elseif userObject.isKindOf( CM_BulkReleaseSet ) then
		block := dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(LL_ReleaseRequestFull), DC_Header, 1, self);
		foreach br in userObject.CM_BulkReleaseSet do
			block := dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(Release_request), DC_Label, 1, self);
			block.addNewItem(br.getDescription(false) &amp; " [ x" &amp; br.getTotalStorageEmpties.String &amp; " items ]", DC_Data, 1, self);
		endforeach;
		
	else
		// object type not allowed for yet....
		
	endif;
	
	if not dataContainer.allBlocks.isEmpty then
		self.showExtraInformation(dataContainer, self.tblInfo, true, false, 4, 1, 4, 1, 1);			
		dataColumnWidth := ((self.tblInfo.width - 304) /2).Integer;
		self.tblInfo.accessColumn (1).width	:= 150;
		self.tblInfo.accessColumn (2).width	:= dataColumnWidth;
		self.tblInfo.accessColumn (3).width	:= 150;
		self.tblInfo.accessColumn (4).width	:= dataColumnWidth;
		
	else
		dataColumnWidth := (self.tblInfo.width - 154).Integer;
		self.tblInfo.accessColumn (1).width	:= 150;
		self.tblInfo.accessColumn (2).width	:= dataColumnWidth;
		
	endif;
	self.tblInfo.autoSize := self.tblInfo.AutoSize_Row;
	
epilog

	delete dataContainer;
	delete voyages;
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="doSetSearchDefaults" id="f0846f92-bc06-4602-80e1-2bfd61fcabba">
        <source>doSetSearchDefaults();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2011	cnwndl1	Initial creation	Par 27731
03 May 2016	cnwns1	TFS 488 - Multi Timezone Support
05 Sep 2019	jlgdi1	46124 Populate the values of sub terminal combo box, making the SubTerminal parameter
					visible if the terminal is configured for sub terminals
03/08/2022  navds20	Bug 54202: EUP - Combo Boxes not adhereing to configuration (operator and Stevedore)
*/

vars
	index : Integer;
	iter : Iterator;
	grade : CM_MTGrade;
	operator : CM_Operator;
	isoGroup : CM_ISOTypeGroup;
	today : Date;
	defaultDate : Date;
	subTerminal : CM_SubTerminal;
	isConfigureForSubTerm : Boolean;
	byName : Boolean;
	
begin
	//03 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	today := self.systemToLocalTime(app.actualTimeServer).date();
	
	self.cmbGrade.clear();
	self.cmbGrade.addItem( app.getErrorString(AnyString) );
	iter := app.myRoot.allAvailabilityGrades.createIterator;
	while iter.next( grade ) do
		index := self.cmbGrade.addItem( grade.code.String &amp; Tab &amp; grade.description );
		self.cmbGrade.itemObject[index] := grade;
	endwhile;
	self.cmbGrade.listIndex := 1;
	delete iter;
	
	byName := app.myRoot.getConfig(ComboByNameOperator).Boolean;
	self.cmbOperator.clear();
	self.cmbOperator.addItem( app.getErrorString(AnyString) );
	iter := app.myRoot.allOperators.createIterator;
	while iter.next( operator ) do
		//start 03/08/2022 navds20 TFS 54202
		if byName then
			index := self.cmbOperator.addItem( operator.description );
		else
			index := self.cmbOperator.addItem( operator.code.String &amp; Tab &amp; operator.description );
		endif;
		//end 03/08/2022 navds20 TFS 54202
			self.cmbOperator.itemObject[index] := operator;
	endwhile;
	self.cmbOperator.listIndex := 1;
	delete iter;
	
	self.cmbISOGroup.clear();
	self.cmbISOGroup.addItem( app.getErrorString(AnyString) );
	iter := app.myRoot.allISOTypeGroups.createIterator;
	while iter.next( isoGroup ) do
		index := self.cmbISOGroup.addItem( isoGroup.code.String &amp; Tab &amp; isoGroup.description );
		self.cmbISOGroup.itemObject[index] := isoGroup;
	endwhile;
	self.cmbISOGroup.listIndex := 1;
	delete iter;
	
	defaultDate := today + 5;
	txtReceivalDate.setDate( defaultDate );
	txtReleaseDate.setDate( defaultDate );
	
	// 46124 - Start
	self.cmbSubTerminal.clear();
	self.cmbSubTerminal.addItem(app.getErrorString(AnyString));
	iter := self.myTerminal.allSubTerminals.createIterator();
	while iter.next(subTerminal) do
		index := self.cmbSubTerminal.addItem(subTerminal.code.String &amp; Tab &amp; subTerminal.description);
		self.cmbSubTerminal.itemObject[index] := subTerminal;
	endwhile;
	self.cmbSubTerminal.listIndex := 1;
	delete iter;
	isConfigureForSubTerm := self.myTerminal.isSubTerminalsOn() and (self.myTerminal.allSubTerminals.size &gt; 0);
	self.cmbSubTerminal.visible := isConfigureForSubTerm;
	self.lblSubTerminal.visible := isConfigureForSubTerm;
	// 46124 - End
	
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="doShowSearcherClick" id="1e421d4b-486a-4cfe-bbe6-a84c570820bb">
        <source>doShowSearcherClick();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

begin

	self.frmQuery.visible := (not self.frmQuery.visible);
	if self.frmQuery.visible then
		self.frmQuery.zOrder(1);
