    <JadeMethod name="tRTvehicleConfig" id="a435778c-4b9f-44c1-96a4-986636318f64">
        <source>tRTvehicleConfig();
/*

Purpose:	Test Delete RT Vehicle Config

Date		Who		Reason
10/04/2014	cnwma1	Initial creation
22/04/2014	cnwma1	Update Machine Status
*/

vars
		rtg  : CM_Machine;
		 tas: StringArray;
		 rtgArea : CM_RTGArea;
begin

		//Delete Machine
	self.deleteMachine("126");
	
	// Delete Terminal Area
	deleteTerminalArea("550");
	

	// Add Terminal Area
	rtgArea := self.addRTGArea("550",6,40,5);
	self.assertNotNull(rtgArea);
	
	
	create tas transient;
	tas.add("950"); 
	
	// Create Machine 
	rtg:=self.addMachine(MACHINETYPE_RTG, "126", 91, tas, null);
	self.assertNotNull(rtg);
	
	//machineDefaultConfig(rtg);
//	self.assertNotNull(rtg.myRTVehicleConfig);
	
	// Delete Machine Config
	
	self.machineDeleteConfig(rtg);
	self.assertNull(rtg.myRTVehicleConfig);
	self.machineLogon(rtg);
	self.assertEqual(rtg.status.status,0);
	// Update Machine Status
	app.myTrxUA.trxUpdateMachineStatus(rtg,STATUS_OFFLINE,"",false,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(rtg.status.status,3);
	

	machineDefaultConfig(rtg);
	self.assertNotNull(rtg.myRTVehicleConfig);

epilog
	delete tas;
end;</source>
    </JadeMethod>
    <JadeMethod name="tScanReader" id="f3620909-9ffb-4275-84d1-ed6f43487462">
        <source>tScanReader();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
03 May 2022		navpw1	Initial creation TFS: 52773
28 July 2022	navmd1	TFS 52773 Tidy up/review code

*/

constants
	NAME 		: String	= "UT-111";
	CODE		: String	= "UT-112";
	DEVICEID 	: String	= "1";
	
	GATE		: String 	= "Single Gate";
	
	UPDCODE		: String	= "UT-113";
	UPDDEVICEID	: String	= "2";
	
vars
	terminal				: CM_Terminal;
	pxyScanReader, 
	realScanReader 			: CM_ScanReaderObj;
	error					: CM_Error;
	
	nameError,
	gateLaneError,
	deviceIdError, 
	timestampOffsetError 	: Boolean;
	
	gate					: CM_Gate;
	gateArea				: CM_GateArea;
	
begin
	//Terminal Checks
	terminal := app.myPassport.myTerminal;
	self.assertTrueMsg(app.myPassport.myTerminal &lt;&gt; null, "Terminal is null");
	self.assertTrueMsg(app.myPassport.myTerminal = self.getTerminal(), "Passport Terminal and Unit Test terminal do not match");
	
	/*
	** Check Gate
	*/
	gate := terminal.allGates[GATE];
	self.assertTrueMsg(gate &lt;&gt; null, "Could not find Gate ('" &amp; GATE &amp; "') in Terminal ('" &amp; terminal.code &amp; "')");
	
	if gate.allGateAreas_IN.size &gt; 0 then
		gateArea := gate.allGateAreas_IN.first.myGateArea;
		
	else
		self.assertTrueMsg(false, "Could not find Gate Areas in");
		
	endif;
	
	self.assertTrueMsg(gateArea &lt;&gt; null, "Could not find Gate Area");
	
	/*
	** Clean Up After Last test
	*/
	self.deleteScanReader(DEVICEID, terminal);
	self.deleteScanReader(UPDDEVICEID, terminal);
	
	/*
	**	Setup Test Create - Normal Happy Day Scenario
	*/
	self.assertTrueMsg(app.myPassport.myTerminal = self.getTerminal(), "Passport Terminal and Unit Test terminal do not match");
	
	/*
	**	Run Test Create - Normal Happy Day Scenario
	*/
	create pxyScanReader transient;
	pxyScanReader.setProxy(NAME, CODE, DEVICEID, terminal);
	app.myTrxCA.trxCreateScanReaderObj(pxyScanReader, realScanReader, app.myPassport);
	
	/*
	**	Assert Test Create - Normal Happy Day Scenario
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();

	//Check the new reference are not null
	self.assertTrueMsg(realScanReader.myTerminal &lt;&gt; null, "Scan Reader: Terminal Object is null");
	
	//Check the new reference is set to the correct objects
	self.assertTrueMsg(realScanReader.myTerminal = app.myPassport.myTerminal, "Scan Reader: Terminal has not been set to our Passport Terminal Object");
	
	//Check that new fields match their expected value/are set
	self.assertTrueMsg(realScanReader.name = NAME, "The name of the Scan Reader does not match expected value: " &amp; NAME);
	self.assertTrueMsg(realScanReader.code = CODE, "The code on the Scan Reader does not match expected value: " &amp; CODE);
	self.assertTrueMsg(realScanReader.deviceId = DEVICEID, "The device id on the Scan Reader does not match expected value: " &amp; DEVICEID);
	
	/*
	** Clean Up After Last test
	*/
	self.deleteScanReader(DEVICEID, terminal);
	self.deleteScanReader(UPDDEVICEID, terminal);
	
	/*
	**	Run Test Create - Name Not Entered
	*/
	delete pxyScanReader;
	pxyScanReader 	:= null;
	realScanReader 	:= null;
	
	create pxyScanReader transient;
	pxyScanReader.setProxy(null, null, null, terminal);
	app.myTrxCA.trxCreateScanReaderObj(pxyScanReader, realScanReader, app.myPassport);
	
	/*
	**	Assert Test Create - Name Not Entered
	*/
	//Check Trx has a required field exception
	if app.myPassport.allErrors.size &lt; 1 then
		self.assertTrueMsg(false, "Expected: This trx should result in an error | Actual: No error exists");
	endif;
	
	if app.myPassport.allErrors.size &lt;&gt; 3 then
		self.assertTrueMsg(false, "Expected: This trx should should return three errors | Actual: Count: " &amp; app.myPassport.allErrors.size.String);
	endif;
	
	error := app.myPassport.allErrors.first;
	self.assertTrueMsg(error.errorCode = Input_required_field_Required, "Expected Error Code:" &amp; Input_required_field_Required.String &amp; " | Actual: " &amp; error.errorCode.String); 	//Check Error Code Matches Expected
	self.assertTrueMsg(error.text.cnContains(app.getErrorString(Code)), "Expected: first error message to contain 'Code' | Actual: " &amp; error.text);
	
	//Check no new object has been set
	self.assertTrueMsg(realScanReader = null, "Scan Reader: Object should be null");

	/*
	** Clean Up After Last test
	*/
	self.deleteScanReader(DEVICEID, terminal);
	self.deleteScanReader(UPDDEVICEID, terminal);
	
	/*
	** Setup Up Test Create - Required Fields DeviceId &amp; GateLane
	*/
	delete pxyScanReader;
	pxyScanReader 	:= null;
	realScanReader 	:= null;
	
	/*
	**	Run Test Create - Required Fields DeviceId &amp; GateLane
	*/
	create pxyScanReader transient;
	pxyScanReader.setProxy(NAME, CODE, null, terminal);
	app.myTrxCA.trxCreateScanReaderObj(pxyScanReader, realScanReader, app.myPassport);
	
	/*
	**	Assert Test Create - Required Fields DeviceId &amp; GateLane
	*/
	//Check Trx has a required field exception
	if app.myPassport.allErrors.size &lt; 1 then
		self.assertTrueMsg(false, "Expected: This trx should result in an error | Actual: No error exists");
	endif;
	
	foreach error in app.myPassport.allErrors do
		if error.text.cnContains(app.getErrorString(Device_id)) then
			self.assertTrueMsg(error.errorCode = Input_required_field_Required, "Expected Error Code:" &amp; Input_required_field_Required.String &amp; " | Actual: " &amp; error.errorCode.String); 	//Check Error Code Matches Expected
			self.assertTrueMsg(error.text.cnContains(app.getErrorString(Device_id)), "Expected: error message to contain '" &amp; app.getErrorString(Device_id) &amp; "' | Actual: " &amp; error.text);												//Check Error Message Contains device-id
			deviceIdError := true;
		
		//elseif error.text.cnContains(app.getErrorString(Gate_lane)) then
		//	self.assertTrueMsg(error.errorCode = Input_required_field_Required, "Expected Error Code:" &amp; Input_required_field_Required.String &amp; " | Actual: " &amp; error.errorCode.String); 	//Check Error Code Matches Expected
		//	self.assertTrueMsg(error.text.cnContains(app.getErrorString(Gate_lane)), "Expected: error message to contain '" &amp; app.getErrorString(Gate_lane) &amp; "' | Actual: " &amp; error.text);												//Check Error Message Contains device-id
		//	gateLaneError := true;
			
		endif;
		
	endforeach;
	
	if not deviceIdError then
		self.assertTrueMsg(deviceIdError, "Expected: error to be raised for required field ('" &amp; app.getErrorString(Device_id) &amp; "') | Actual: No Error Raised"); 		//Check Error Code Matches Expected
		
	//elseif not gateLaneError then
		//self.assertTrueMsg(gateLaneError, "Expected: error to be raised for required field ('" &amp; app.getErrorString(Gate_lane) &amp; "') | Actual: No Error Raised"); 		//Check Error Code Matches Expected
		
	endif;
	
	//Check no new object has been set
	self.assertTrueMsg(realScanReader = null, "Scan Reader: Object should be null");
	
	/*
	** Clean Up After Last test
	*/
	self.deleteScanReader(DEVICEID, terminal);
	self.deleteScanReader(UPDDEVICEID, terminal);
	
	/*
	**	Setup Test Update - Normal Happy Day Scenario
	*/
	delete pxyScanReader;
	pxyScanReader 	:= null;
	realScanReader 	:= null;
	
	create pxyScanReader transient;
	pxyScanReader.setProxy(NAME, CODE, DEVICEID, terminal);
	app.myTrxCA.trxCreateScanReaderObj(pxyScanReader, realScanReader, app.myPassport);
	
	/*
	**	Run Test Update - Normal Happy Day Scenario
	*/
	delete pxyScanReader;
	
	beginLoad;
		pxyScanReader := realScanReader.pxyCreateUpdateProxy();
	endLoad;
	
	pxyScanReader.setProxy(NAME, UPDCODE, UPDDEVICEID, terminal);
	
	app.myTrxUA.trxUpdateScanReaderObj(pxyScanReader, app.myPassport);
	
	/*
	**	Assert Test Update - Normal Happy Day Scenario
	*/
	//Check Trx has no errors
	self.assertNoTrxErrorsOrWarnings();
	
	//Check that new fields match their expected value/are set
	//Check the new reference are not null
	self.assertTrueMsg(realScanReader.myTerminal &lt;&gt; null, "Scan Reader: Terminal Object is null");
	
	//Check the new reference is set to the correct objects
	self.assertTrueMsg(realScanReader.myTerminal = app.myPassport.myTerminal, "Scan Reader: Terminal has not been set to our Passport Terminal Object");
	
	//Check that new fields match their expected value/are set
	self.assertTrueMsg(realScanReader.name = NAME, "The name of the Scan Reader does not match expected value: " &amp; NAME);
	self.assertTrueMsg(realScanReader.code = UPDCODE, "The code on the Scan Reader does not match expected value: " &amp; UPDCODE);
	self.assertTrueMsg(realScanReader.deviceId = UPDDEVICEID, "The device id on the Scan Reader does not match expected value: " &amp; UPDDEVICEID);
	
	/*
	**	Setup Test Update - Name Not Entered
	*/
	delete pxyScanReader;
	pxyScanReader 	:= null;
	realScanReader 	:= null;
	
	self.deleteScanReader(DEVICEID, terminal);
	self.deleteScanReader(UPDDEVICEID, terminal);
	
	create pxyScanReader transient;
	pxyScanReader.setProxy(NAME, CODE, DEVICEID, terminal);
	app.myTrxCA.trxCreateScanReaderObj(pxyScanReader, realScanReader, app.myPassport);
	
	delete pxyScanReader;
	pxyScanReader := null;
	
	beginLoad;
		pxyScanReader := realScanReader.pxyCreateUpdateProxy();
	endLoad;
	
	/*
	**	Run Test Update - Name Not Entered
	*/
	pxyScanReader.setProxy(null, UPDCODE, UPDDEVICEID, terminal);
	
	app.myTrxUA.trxUpdateScanReaderObj(pxyScanReader, app.myPassport);
	
	/*
	**	Assert Test Update - Name Not Entered
	*/
	if app.myPassport.allErrors.size &lt; 1 then
		self.assertTrueMsg(false, "Expected: This trx should result in an error | Actual: No error exists");
	endif;
	
	if app.myPassport.allErrors.size &gt; 1 then
		self.assertTrueMsg(false, "Expected: This trx should should only return one error | Actual: Count: " &amp; app.myPassport.allErrors.size.String);
	endif;
	
	error := app.myPassport.allErrors.first;
	self.assertTrueMsg(error.errorCode = Input_required_field_Required, "Expected Error Code:" &amp; Input_required_field_Required.String &amp; " | Actual: " &amp; error.errorCode.String); 	//Check Error Code Matches Expected
	self.assertTrueMsg(error.text.cnContains(app.getErrorString(Name)), "Expected: error message to contain '" &amp; app.getErrorString(Name) &amp; "' | Actual: " &amp; error.text);
	
	/*
	**	Setup Test Update - Required Fields DeviceId &amp; GateLane
	*/
	delete pxyScanReader;
	pxyScanReader 	:= null;
	realScanReader 	:= null;
	
	self.deleteScanReader(DEVICEID, terminal);
	self.deleteScanReader(UPDDEVICEID, terminal);
	
	create pxyScanReader transient;
	pxyScanReader.setProxy(NAME, CODE, DEVICEID, terminal);
	app.myTrxCA.trxCreateScanReaderObj(pxyScanReader, realScanReader, app.myPassport);
	
	delete pxyScanReader;
	pxyScanReader := null;
	
	beginLoad;
		pxyScanReader := realScanReader.pxyCreateUpdateProxy();
	endLoad;
	
	/*
	**	Run Test Update - Required Fields DeviceId &amp; GateLane
	*/
	pxyScanReader.setProxy(NAME, null, null, terminal);
	
	app.myTrxUA.trxUpdateScanReaderObj(pxyScanReader, app.myPassport);
	
	/*
	**	Assert Test Update - Required Fields DeviceId &amp; GateLane
	*/
	if app.myPassport.allErrors.size &lt; 1 then
		self.assertTrueMsg(false, "Expected: This trx should result in an error | Actual: No error exists");
	endif;
	
	foreach error in app.myPassport.allErrors do
		if error.text.cnContains(app.getErrorString(Device_id)) then
			self.assertTrueMsg(error.errorCode = Input_required_field_Required, "Expected Error Code:" &amp; Input_required_field_Required.String &amp; " | Actual: " &amp; error.errorCode.String); 	//Check Error Code Matches Expected
			self.assertTrueMsg(error.text.cnContains(app.getErrorString(Device_id)), "Expected: error message to contain '" &amp; app.getErrorString(Device_id) &amp; "' | Actual: " &amp; error.text);												//Check Error Message Contains device-id
			deviceIdError := true;
		
		//elseif error.text.cnContains(app.getErrorString(Gate_lane)) then
		//	self.assertTrueMsg(error.errorCode = Input_required_field_Required, "Expected Error Code:" &amp; Input_required_field_Required.String &amp; " | Actual: " &amp; error.errorCode.String); 	//Check Error Code Matches Expected
		//	self.assertTrueMsg(error.text.cnContains(app.getErrorString(Gate_lane)), "Expected: error message to contain '" &amp; app.getErrorString(Gate_lane) &amp; "' | Actual: " &amp; error.text);												//Check Error Message Contains device-id
		//	gateLaneError := true;
			
		endif;
		
	endforeach;
	
	if not deviceIdError then
		self.assertTrueMsg(deviceIdError, "Expected: error to be raised for required field ('" &amp; app.getErrorString(Device_id) &amp; "') | Actual: No Error Raised"); 		//Check Error Code Matches Expected
		
	//elseif not gateLaneError then
		//self.assertTrueMsg(gateLaneError, "Expected: error to be raised for required field ('" &amp; app.getErrorString(Gate_lane) &amp; "') | Actual: No Error Raised"); 		//Check Error Code Matches Expected
		
	endif;
	
	self.deleteScanReader(DEVICEID, terminal);
	self.deleteScanReader(UPDDEVICEID, terminal);
	
epilog
	delete pxyScanReader;

end;</source>
    </JadeMethod>
    <JadeMethod name="tSubTerminal" id="7cc20d67-4aac-416d-83e9-891e17fb95c7">
        <source>tSubTerminal();
/*

Purpose:	1-Create SubTerminal 
			2- Update SubTerminal Options
			3- Check TrackedItem against it's SubTerminal


Date		Who		Reason
23/04/2013	cnwma1	Initial creation

*/
constants
	SubTerm : String = "UTSubTerm";
	
vars
	subTerminal					: CM_SubTerminal;
	terminalObj					: CM_Terminal;
	orginalStorageFull			: CM_SubTerminal;
	newStorageFull				: CM_SubTerminal;
	vvr							: CM_VehicleVisitRecord;
	gate						: CM_Gate;
	ti							: CM_TrackedItem;
	hasSetOriginalStorageFull	: Boolean;
	resetSubTermAreaDefined		: Boolean;
	isSubTerminalsOn			: Any;
	
begin
	isSubTerminalsOn := self.setTerminalConfig(IsSubTerminalsOn, true);
	
	if self.getTerminal().getConfig(IsSubTerminalAreaDefined).Boolean then
		resetSubTermAreaDefined := true;
		self.setSubTerminalAreaDefined(false);	
	endif;

	self.deleteVehicle("TRK888");
	self.deleteContainer("APZU5566441");
	
	// Delete SubTerminal
	 self.deleteSubTerminal(SubTerm);
	//Create SubTerminal
	subTerminal := self.addSubTerminal(SubTerm,1);
	self.assertNotNull(subTerminal);
	
	// Update SubTerminal
	self.opts.purge();
	self.opts.addAssoc("Description", "UTSubTerm_UP");
	self.updateSubTerminal(subTerminal);
   
   
   // Update Terminal
   terminalObj	:=	self.getTerminal;
   orginalStorageFull   :=terminalObj.getConfig(MySubTerminalForStorageFull).CM_SubTerminal;
   hasSetOriginalStorageFull := true;
   newStorageFull       := subTerminal;
   self.assertNotNull(newStorageFull);
  
   self.opts.purge();
   self.opts.addAssoc("StorageFull", newStorageFull);
   self.updateSubTerminalOptions();
   
    gate := self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString);  
   

	vvr := self.gateInContainer("TRK888","APZU5566441","2200","APL","GENL",gate.name.asStringJMT);
	self.assertNotNull(vvr);
	
	ti := self.getTrackedItem("APZU5566441");
	self.assertEqual(ti.mySubTerminal.code,SubTerm);
	///self.assertEqual(ti.mySubTerminal, null);
   
epilog
	self.setTerminalConfig(IsSubTerminalsOn, isSubTerminalsOn);
	
	if resetSubTermAreaDefined then
		self.setSubTerminalAreaDefined(true);
	endif;

	if hasSetOriginalStorageFull then
		self.opts.purge();
		self.opts.addAssoc("StorageFull", orginalStorageFull);
		self.updateSubTerminalOptions();
	endif;
	
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;fails02122014&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tSubTerminalAreaDefs" id="b3f8185c-9479-4770-b58e-6031b0b62e1d">
        <source>tSubTerminalAreaDefs();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 December 2014	cnwndl1	Initial creation	Par 35295 / 36181

*/

constants

	SubTerm1 = "UTSubT1";
	SubTerm2 = "UTSubT2";
	BS1 = "BSUT1";
	BS2 = "BSUT2";
	BS3 = "BSUT3";
	TI1 = "STTI0000111";
	TI2 = "STTI0000112";
	TI3 = "STTI0000113";
	MACHINE : String = "STFL";
	
vars

	terminal : CM_Terminal;
	oper : CM_Operator;
	subTerminal1 : CM_SubTerminal;
	subTerminal2 : CM_SubTerminal;
	bs1 : CM_BlockStack;
	bs2 : CM_BlockStack;
	bs3 : CM_BlockStack;
	subTerminalAreaDef : CM_SubTerminalAreaDef;
	selectedAreas : ObjectSet;
	ti1 : CM_TrackedItem;
	ti2 : CM_TrackedItem;
	ti3 : CM_TrackedItem;
	tiTrans : CM_TITransaction;
	load : Boolean;
	pxyTi : CM_TrackedItem;
	success : Boolean;
	defBank : CM_Bank;
	bank1 : CM_Bank;
	bank2 : CM_Bank;
	pxySubTerminalAreaDef : CM_SubTerminalAreaDef;
	areaTiSet : CM_TISet;
	bankParent : CM_Bank;
	
	wle : CM_WorkListEntry;
	forkLift : CM_Machine;
	qEntry : CM_RTQueueEntry;
	tiTrx : CM_TITransaction;
	tas: StringArray;

begin

	terminal := self.getTerminal();
	oper := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	bank1 := terminal.getDefaultCompanyBank();
	self.assertTrueMsg( bank1 &lt;&gt; null, "Default Bank not found");
	defBank := bank1;
	bank2 := self.addBank();
	self.assertTrueMsg( bank2 &lt;&gt; null, "Bank 'UTB3' not created");
	
	self.setTerminalConfig( FinancialsEnabled, false );
	self.setTerminalConfig(IsSubTerminalsOn,true);
	self.setTerminalConfig(IsSubTerminalAreaDefined,true);
	
	create selectedAreas transient;

	// clean up if necessary
	self.deleteContainer(TI1);
	self.deleteContainer(TI2);
	self.deleteContainer(TI3);
	self.deleteTerminalArea(BS1);
	self.deleteTerminalArea(BS2);
	self.deleteTerminalArea(BS3);
	self.deleteSubTerminal(SubTerm1);
	self.deleteSubTerminal(SubTerm2);
	
	//create two sub terminals and three block stacks, associate one block stack with each sub term, leaving one area with no sub term
	self.opts.purge();
	self.opts.addAssoc( "Bank", bank1 );
	subTerminal1 := self.addSubTerminal(SubTerm1,SubTermType_Depot_Int);
	self.assertTrueMsg( subTerminal1 &lt;&gt; null, "Sub Terminal 1 not created");
	self.assertTrueMsg( subTerminal1.getMyBank = bank1, "Sub Terminal 1 not linked to bank1");
	self.opts.purge();
	self.opts.addAssoc( "Bank", bank2 );
	subTerminal2 := self.addSubTerminal(SubTerm2,SubTermType_Marine_Int);
	self.assertTrueMsg( subTerminal2 &lt;&gt; null, "Sub Terminal 2 not created");
	self.assertTrueMsg( subTerminal2.getMyBank = bank2, "Sub Terminal 2 not linked to bank2");
	
	bs1 := self.addBlockStack( BS1, 10, null );
	self.assertTrueMsg( bs1 &lt;&gt; null, "Block Stack 1 not created");
	bs2 := self.addBlockStack( BS2, 10, null );
	self.assertTrueMsg( bs2 &lt;&gt; null, "Block Stack 2 not created");
	bs3 := self.addBlockStack( BS3, 10, null );
	self.assertTrueMsg( bs3 &lt;&gt; null, "Block Stack 3 not created");
	
	selectedAreas.clear();
	selectedAreas.add(bs1);
	subTerminalAreaDef := self.addSubTerminalWorkAreaDef( subTerminal1, selectedAreas );
	self.assertTrueMsg( subTerminalAreaDef &lt;&gt; null, "Block Stack 1 associated areas def not created");
	self.assertTrueMsg( subTerminalAreaDef = subTerminal1.mySubTerminalAreaDef, "Sub Terminal 1 'associated areas def' not set");
	self.assertTrueMsg( subTerminalAreaDef.allTerminalAreas.includes(bs1), "Block Stack 1 NOT in allTerminalAreas of Sub Term 1");
	
	selectedAreas.clear();
	selectedAreas.add(bs2);
	subTerminalAreaDef := self.addSubTerminalWorkAreaDef( subTerminal2, selectedAreas );
	self.assertTrueMsg( subTerminalAreaDef &lt;&gt; null, "Block Stack 2 associated areas def not create");
	self.assertTrueMsg( subTerminalAreaDef = subTerminal2.mySubTerminalAreaDef, "Sub Terminal 2 'associated areas def' not set");
	self.assertTrueMsg( subTerminalAreaDef.allTerminalAreas.includes(bs2), "Block Stack 2 NOT in allTerminalAreas of Sub Term 2");
	
	
	
	// create a cargo item and move between each block stacks
	// check subterm changes appropriately
	// check release and receive transactions created correctly
	// check no error when sub terminal null.
	
	ti1 := self.createContainer( TI1, "2200", "MT", oper, false );
	self.assertTrueMsg( ti1 &lt;&gt; null, TI1 &amp; " not created");
	ti2 := self.createContainer( TI2, "2200", "MT", oper, false );
	self.assertTrueMsg( ti2 &lt;&gt; null, TI2 &amp; " not created");
	ti3 := self.createContainer( TI3, "2200", "MT", oper, false );
	self.assertTrueMsg( ti3 &lt;&gt; null, TI3 &amp; " not created");
	
	self.move(ti1, bs1);
	self.assertTrueMsg( ti1.myPrimaryActualLocation = bs1.myLocationsController, TI1 &amp; " not moved to " &amp; BS1);
	self.assertTrueMsg( ti1.mySubTerminal = subTerminal1, TI1 &amp; " not in sub terminal " &amp; SubTerm1);
	tiTrans := ti1.allTransactions.getLastSubTermReceive();
	self.assertTrueMsg( tiTrans &lt;&gt; null, TI1 &amp; " sub terminal receive transaction for " &amp; SubTerm1 &amp; " not found.");
	self.assertTrueMsg( ti1.companyOid = bank1, TI1 &amp; " bank s/be " &amp; bank1.code &amp; ".");
	
	self.move(ti2, bs2);
	self.assertTrueMsg( ti2.myPrimaryActualLocation = bs2.myLocationsController, TI2 &amp; " not moved to " &amp; BS2);
	self.assertTrueMsg( ti2.mySubTerminal = subTerminal2, TI2 &amp; " not in sub terminal " &amp; SubTerm2);
	tiTrans := ti2.allTransactions.getLastSubTermReceive();
	self.assertTrueMsg( tiTrans &lt;&gt; null, TI2 &amp; " sub terminal receive transaction for " &amp; SubTerm2 &amp; " not found.");
	self.assertTrueMsg( ti2.companyOid = bank2, TI2 &amp; " bank s/be " &amp; bank2.code &amp; ".");
	
	self.move(ti3, bs3);
	self.assertTrueMsg( ti3.myPrimaryActualLocation = bs3.myLocationsController, TI3 &amp; " not moved to " &amp; BS3);
	if ti3.mySubTerminal &lt;&gt; null then
		self.assertTrueMsg( false, TI3 &amp; " should NOT be in sub terminal, but is in  " &amp; ti3.mySubTerminal.code);
	endif;
	tiTrans := ti3.allTransactions.getLastSubTermReceive();
	if tiTrans &lt;&gt; null then
		self.assertTrueMsg( false, TI3 &amp; " HAS a sub terminal receive transaction which was NOT expected." &amp; tiTrans.class.name &amp; " " &amp; tiTrans.getCompletedTaskString);
	endif;
	self.assertTrueMsg( ti3.companyOid = defBank, TI3 &amp; " bank s/be " &amp; defBank.code &amp; ".");
	
	
	self.move(ti1, bs2);
	self.assertTrueMsg( ti1.myPrimaryActualLocation = bs2.myLocationsController, TI1 &amp; " not moved to " &amp; BS2);
	self.assertTrueMsg( ti1.mySubTerminal = subTerminal2, TI1 &amp; " not moved to sub terminal " &amp; SubTerm2);
	tiTrans := ti1.allTransactions.getLastSubTermReceive();
	self.assertTrueMsg( tiTrans &lt;&gt; null and tiTrans.mySubTerminal = subTerminal2, TI1 &amp; " sub terminal receive transaction for " &amp; SubTerm2 &amp; " not found.");
	tiTrans := ti1.allTransactions.getLastSubTermRelease();
	if tiTrans = null or not tiTrans.isKindOf(CM_SubTerminalRelease) or  tiTrans.CM_SubTerminalRelease.mySubTerminal &lt;&gt; subTerminal1 then
	self.assertTrueMsg( false, TI1 &amp; " sub terminal release transaction for " &amp; SubTerm1 &amp; " not found.");
	endif;
	self.assertTrueMsg( ti1.companyOid = bank2, TI1 &amp; " bank s/be " &amp; bank2.code &amp; ".");
	
	
	self.move(ti1, bs3);
	self.assertTrueMsg( ti1.myPrimaryActualLocation = bs3.myLocationsController, TI1 &amp; " not moved to " &amp; BS3);
	if ti1.mySubTerminal &lt;&gt; null then
		self.assertTrueMsg( false, TI1 &amp; " should NOT be in sub terminal, but is in  " &amp; ti1.mySubTerminal.code);
	endif;
	tiTrans := ti1.allTransactions.getLastSubTermReceive();
	self.assertTrueMsg( tiTrans &lt;&gt; null and tiTrans.mySubTerminal = subTerminal2, TI1 &amp; " sub terminal receive transaction for " &amp; SubTerm2 &amp; " no longer the latest!!");
	tiTrans := ti1.allTransactions.getLastSubTermRelease();
	if tiTrans = null or not tiTrans.isKindOf(CM_SubTerminalRelease) or tiTrans.CM_SubTerminalRelease.mySubTerminal &lt;&gt; subTerminal2 then
	self.assertTrueMsg( false, TI1 &amp; " sub terminal release transaction for " &amp; SubTerm2 &amp; " not found.");
	endif;
	self.assertTrueMsg( ti1.companyOid = defBank, TI1 &amp; " bank s/be " &amp; defBank.code &amp; ".");
	
	//Try overriding sub-terminal, should just be ignored.
	
	app.cmsBeginLoad(load);
	pxyTi := ti2.pxyCreateUpdateProxy();
	app.cmsEndLoad(load);
	pxyTi.zSetPxySubTerminal( subTerminal1 );
	
	app.myTrxUA.trxUpdateTrackedItem( pxyTi, null, TI_UPDMODE_NORMAL, null, app.myPassport );
	self.assertTrueMsg( app.myPassport.noErrors, "Error attempting manual update of sub-terminal " &amp; app.myPassport.getErrorsAsString);
	self.assertTrueMsg( ti2.mySubTerminal = subTerminal2, TI2 &amp; " sub terminal should not have been able to be changed manually from " &amp; SubTerm2 &amp; " while using Sub Terminal Areas");
	self.assertTrueMsg( ti2.companyOid = bank2, TI2 &amp; " bank s/be " &amp; bank2.code &amp; ".");
	delete pxyTi;
	
	//update the area def1 to include bs3 - ti1  &amp;  ti3 should need updated sub t and coy as a result ()they are currently in bs3 )
	
	subTerminalAreaDef := subTerminal1.mySubTerminalAreaDef;
	create areaTiSet transient;
	subTerminalAreaDef.getAllTisInArea( areaTiSet );
	self.assertTrueMsg( areaTiSet.isEmpty, "Should not have found any cargo currently in Subterm 1.");
	
	//process.debug;
	
	app.cmsBeginLoad( load );
	pxySubTerminalAreaDef := subTerminalAreaDef.pxyCreateUpdateProxy();
	app.cmsEndLoad( load );
	selectedAreas.clear();
	selectedAreas.add(bs1);
	selectedAreas.add(bs3);
	pxySubTerminalAreaDef.setProxy(	subTerminal1.code,	//_code : String;
									subTerminal1.description,	//_description : String;
									false,	//_notAvailable : Boolean;
									selectedAreas,	//_allSelectedObjects : ObjectSet;
									subTerminal1,	//_mySubTerminal : CM_SubTerminal;
									terminal	//_myTerminal : CM_Terminal
									);
	app.myTrxUA.trxUpdateSubTerminalAreaDef(pxySubTerminalAreaDef, app.myPassport);
	self.assertTrueMsg( app.myPassport.noErrors, "Error attempting update of sub-terminal area definition " &amp; app.myPassport.getErrorsAsString);
	delete pxySubTerminalAreaDef;
	
	areaTiSet.clear();
	subTerminalAreaDef.getAllTisInArea( areaTiSet );
	self.assertTrueMsg( areaTiSet.size = 2, "Should have found 2 cargo items currently in Subterm 1.");
	
	//both should have incorrect subterm and coy.
	self.assertTrueMsg( ti1.companyOid = defBank, TI1 &amp; " bank should still be " &amp; defBank.code &amp; ".");
	self.assertTrueMsg( ti3.companyOid = defBank, TI3 &amp; " bank should still be " &amp; defBank.code &amp; ".");
	self.assertTrueMsg( ti1.mySubTerminal = null, TI1 &amp; " sub terminal should still be null.");
	self.assertTrueMsg( ti3.mySubTerminal = null, TI3 &amp; " sub terminal should still be null.");
	
	//now update those cargo items that need it...
	app.myTrxUA.trxUpdSubTermForCargoItems( false, false, subTerminalAreaDef, null, app.myPassport );
	
	self.assertTrueMsg( ti1.companyOid = subTerminalAreaDef.mySubTerminal.getMyBank, TI1 &amp; " bank should now be " &amp; subTerminalAreaDef.mySubTerminal.getMyBank.code &amp; ".");
	self.assertTrueMsg( ti3.companyOid = subTerminalAreaDef.mySubTerminal.getMyBank, TI3 &amp; " bank should now be " &amp; subTerminalAreaDef.mySubTerminal.getMyBank.code &amp; ".");
	self.assertTrueMsg( ti1.mySubTerminal = subTerminalAreaDef.mySubTerminal, TI1 &amp; " sub terminal should now be " &amp; subTerminalAreaDef.mySubTerminal.description &amp; ".");
	self.assertTrueMsg( ti3.mySubTerminal = subTerminalAreaDef.mySubTerminal, TI3 &amp; " sub terminal should now be " &amp; subTerminalAreaDef.mySubTerminal.description &amp; ".");
	
	
	//15 Oct 2019	NDL	TFS 47027
	//Get a machine to move cargo between 2 locations in the same sub-terminal.
	//This should NOT generate a release and receive for the sub-terminal even though the location of the cargo
	//moved to a location with no sub-terminal, i.e. the machine.
	
	//get rid of all 'CM_SubTerminalReceive' and 'CM_SubTerminalRelease' for TI1
	foreach tiTrx in ti1.allTransactions reversed do
		if tiTrx.isInternalReceive or tiTrx.isInternalRelease then
			beginTransaction;
			delete tiTrx;
			commitTransaction;
		endif;
	endforeach;
	
	self.moveQueued( ti1, bs1 );
	wle := ti1.allWorklistEntries.first;
	self.assertTrueMsg(wle &lt;&gt; null, ti1.id &amp; " not queued to BS1");
	
	self.deleteMachine(MACHINE);
	
	create tas transient;
	tas.add(bs1.id);
	tas.add(bs3.id);
	
	forkLift := self.addForkLift( MACHINE, 0, tas, wle.queueId);
	self.assertTrueMsg(forkLift &lt;&gt; null, MACHINE &amp; " forklift not created");
	
	qEntry := wle.allRTQueueEntries.first;
	app.isRTApp := true;  
	self.machineLogon(forkLift);
	
	//Accept
	self.machineAcceptSpecifiedTask( forkLift, qEntry );
	
	//Pick up
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	app.myTrxUA.trxMachinePickupTask( forkLift, 1, null, app.myPassport );
	tiTrx := ti1.getLastTransOfClass( CM_Pickup );
	self.assertTrueMsg( tiTrx &lt;&gt; null, ti1.id &amp; " pick up transaction not found." );
	self.assertTrueMsg( bs1.mySubTerminalAreaDef.mySubTerminal = ti1.mySubTerminal, ti1.id &amp; " sub terminal should not have changed during pickup." );
	
	//Set down
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	self.machineSetdown( forkLift, wle.myTrackedItem, forkLift.currentQueueTask.targetLocationId );	
	tiTrx := ti1.getLastTransOfClass( CM_SetDown );
	self.assertTrueMsg( tiTrx &lt;&gt; null, ti1.id &amp; " set down transaction not found." );
	foreach tiTrx in ti1.allTransactions reversed do
		if tiTrx.isInternalReceive or tiTrx.isInternalRelease then
			self.assertTrueMsg( not tiTrx.isInternalReceive, ti1.id &amp; " should not have an internal sub terminal receive." );
			self.assertTrueMsg( not tiTrx.isInternalRelease, ti1.id &amp; " should not have an internal sub terminal release." );
		endif;
	endforeach;
	
	
	//********************************************************************************************
	// set subterminal Areas OFF - leaving Subterminals On...  Sub terminals now compulsory
	//Try overriding sub-terminal, should just be allowed, but NOT allowed to be null.
	self.setSubTerminalAreaDefined(false);
	
	app.cmsBeginLoad(load);
	pxyTi := ti2.pxyCreateUpdateProxy();
	app.cmsEndLoad(load);
	pxyTi.zSetPxySubTerminal( null );
	
	app.myTrxUA.trxUpdateTrackedItem( pxyTi, null, TI_UPDMODE_NORMAL, null, app.myPassport );
	self.assertTrueMsg( app.myPassport.hasErrors, "No error attempting manual update of sub-terminal to null");
	self.assertTrueMsg(app.myPassport.allErrors.includesErrorCode(Input_required_field_Required), TI2 &amp; "should get " &amp; Input_required_field_Required.String &amp; " error when attempting to manually set set sub terminal to null when Sub Terminal 'ON' but Sub Terminal Areas 'OFF'");
	self.assertTrueMsg( ti2.companyOid = bank2, TI2 &amp; " bank s/be " &amp; bank2.code &amp; ". (should not change automatically from sub terminal when option off)");
	
	delete pxyTi;
	
	app.cmsBeginLoad(load);
	pxyTi := ti2.pxyCreateUpdateProxy();
	app.cmsEndLoad(load);
	pxyTi.zSetPxySubTerminal( terminal.allSubTerminals.first );
	
	app.myTrxUA.trxUpdateTrackedItem( pxyTi, null, TI_UPDMODE_NORMAL, null, app.myPassport );
	self.assertTrueMsg( app.myPassport.noErrors, "Error attempting manual update of sub-terminal " &amp; app.myPassport.getErrorsAsString);
	self.assertTrueMsg( ti2.mySubTerminal = terminal.allSubTerminals.first, TI2 &amp; " sub terminal should be changed to " &amp; terminal.allSubTerminals.first.code &amp; " when Sub Terminal 'ON' but Sub Terminal Areas 'OFF'");
	self.assertTrueMsg( ti2.companyOid = bank2, TI2 &amp; " bank s/be " &amp; bank2.code &amp; ". (should not change automatically from sub terminal when option off)");
	
	delete pxyTi;
	
	// move cargo item and between block stacks
	// check subterm NO LONGER changes because of move, but that it uses the method on Terminal which gets a default one ()
	self.move(ti2, bs1);
	self.assertTrueMsg( ti2.mySubTerminal = terminal.allSubTerminals.first , TI1 &amp; " not still sub terminal " &amp; terminal.allSubTerminals.first.code &amp; ", after move with Sub Terminal Areas OFF - " &amp; ti2.mySubTerminal.code);
	self.assertTrueMsg( ti2.companyOid = bank2, TI2 &amp; " bank s/be " &amp; bank2.code &amp; ". (should not change automatically from sub terminal when option off)");
	
	app.cmsBeginLoad(load);
	pxyTi := ti2.pxyCreateUpdateProxy();
	app.cmsEndLoad(load);
	pxyTi.zSetPxySubTerminal( subTerminal1 );
	
	app.myTrxUA.trxUpdateTrackedItem( pxyTi, null, TI_UPDMODE_NORMAL, null, app.myPassport );
	self.assertTrueMsg( app.myPassport.noErrors, "Error attempting manual update of sub-terminal " &amp; app.myPassport.getErrorsAsString);
	self.assertTrueMsg( ti2.mySubTerminal = subTerminal1, TI2 &amp; " sub terminal should be changed to " &amp; SubTerm1 &amp; " when Sub Terminal 'ON' but Sub Terminal Areas 'OFF'");
	self.assertTrueMsg( ti2.companyOid = bank2, TI2 &amp; " bank s/be " &amp; bank2.code &amp; ". (should not change automatically from sub terminal when option off)");
	
	delete pxyTi;
	
	success := true;

epilog

	app.isRTApp := false; 
	
	delete selectedAreas;
	delete pxyTi;
	delete pxySubTerminalAreaDef;
	delete areaTiSet;
	
	//delete created objects
	
	if success then
		self.deleteContainer(TI1);
		self.deleteContainer(TI2);
		self.deleteContainer(TI3);
		self.deleteTerminalArea(BS1);
		self.deleteTerminalArea(BS2);
		self.deleteTerminalArea(BS3);
		self.deleteSubTerminal(SubTerm1);
		self.deleteSubTerminal(SubTerm2);
		self.deleteMachine(MACHINE);
	endif;
	
	if bank2 &lt;&gt; null then
		app.myTrxDA.trxDeleteBank(bank2, app.myPassport);
	endif;
	bankParent := app.myRoot.myRootCompany.subCompanies[terminal,"UTST"];
	if bankParent &lt;&gt; null then
		app.myTrxDA.trxDeleteBank(bankParent, app.myPassport);
	endif;
	
	delete tas;

end;</source>
    </JadeMethod>
    <JadeMethod name="tSubTerminalNOAreas" id="943f8f71-56a4-4d57-92e9-a1b7367e3af7">
        <source>tSubTerminalNOAreas();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 May 2015	cnwndl1	Initial creation
25/07/2022    navgm20     ChangeRequest 54095: EUP - Outturn Remarks on BOL
*/

constants
	BaseSubTerminalName : String = "UTST_";
	BaseCargoName : String = "UTST0003";
vars

	terminal : CM_Terminal;
	subTStringArray : StringArray;
	subTString : String;
	subTcount : Integer;
	subTermId : String;
	subTerminal : CM_SubTerminal;
	subTermArray : CM_ObjectArray;
	oper : CM_Operator;
	cargoId : String;
	imexInt : Integer;
	tiArray : CM_TIArray;
	ti : CM_TrackedItem;
	cargoType : CM_CargoType;
	bs1: CM_BlockStack;
	bulkId : String;
	bulk : CM_BulkRelease;
	bulkArray : CM_BulkReleaseSet;
	realBOLIn	: CM_BOL;
	pxyBOLIn : CM_BOLIn;
	pxyBOLItemIn : CM_BOLDtl;
	realBOLOut	: CM_BOL;
	pxyBOLOut : CM_BOLIn;
	pxyBOLItemOut : CM_BOLDtl;
	subTermToUse : CM_SubTerminal;

begin

	terminal := self.getTerminal;
	bs1 := self.addBlockStack("UTBS1", 9999, null);

	self.setTerminalConfig(IsSubTerminalsOn,true);
	
	create subTStringArray transient;
	subTStringArray.add(MySubTerminalForExportFull);
	subTStringArray.add(MySubTerminalForExportMTY);
	subTStringArray.add(MySubTerminalForImportFull);
	subTStringArray.add(MySubTerminalForImportMTY);
	subTStringArray.add(MySubTerminalForStorageFull);
	subTStringArray.add(MySubTerminalForStorageMTY);
	subTStringArray.add(MySubTerminalForImportGen);
	subTStringArray.add(MySubTerminalForExportGen);
	subTStringArray.add(MySubTerminalForStorageGen);
	subTStringArray.add(MySubTerminalForOther);
	subTStringArray.add(MySubTerminalForSourceBulkRoad);
	subTStringArray.add(MySubTerminalForSourceBulkRail);
	subTStringArray.add(MySubTerminalForSourceBulkShip);
	subTStringArray.add(MySubTerminalForSourceBulkPack);
	subTStringArray.add(MySubTerminalForTargetBulk);
	subTStringArray.add(MySubTerminalForBOLIn);
	
	create subTermArray transient;
	create tiArray transient;
	create bulkArray transient;
	
	//create a new sub-terminal for each of the subterminal default values and set the config value.
	subTcount := 0;
	foreach subTString in subTStringArray do
		subTcount := subTcount + 1;
		subTerminal := null;
		subTermId := BaseSubTerminalName &amp; subTcount.String;
		self.deleteSubTerminal(subTermId);
		subTerminal := self.addSubTerminal(subTermId,1);
		self.assertTrueMsg(subTerminal &lt;&gt; null, "Failed to create sub terminal " &amp; subTermId &amp; " for " &amp; subTString &amp; ".");
		self.setTerminalConfig(subTString, subTerminal);
		subTermArray.add(subTerminal);
		subTerminal := terminal.getConfig(subTString).CM_SubTerminal;
		self.assertTrueMsg(subTerminal &lt;&gt; null, "Failed to set sub terminal " &amp; subTermId &amp; " for Terminal config" &amp; subTString &amp; ".");
	endforeach;
	
	subTcount := 0;
	imexInt := 0;
	oper := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	cargoType := app.myRoot.getCargoTypeFromAbbrev("UTREBAR");
	self.assertTrueMsg(cargoType &lt;&gt; null, "Failed to find cargo type UTREBAR.");
	
	foreach subTString in subTStringArray do
		subTcount := subTcount + 1;
		subTerminal := null;
		subTerminal := terminal.getConfig(subTString).CM_SubTerminal;
		self.assertTrueMsg(subTerminal &lt;&gt; null, "Failed to FIND sub terminal for Terminal config " &amp; subTString &amp; ".");
		cargoId := BaseCargoName &amp; subTcount.String;
		if subTcount = 1 then
			//MySubTerminalForExportFull
			imexInt := TI_IMEX_STATUS_EXPORT;
			self.opts.purge();
			self.opts.addAssoc(UTTI_IMEX,imexInt);
			ti := self.addContainer(cargoId, oper,"2200", "GENL", imexInt);
			self.assertTrueMsg(ti &lt;&gt; null, "Failed to create ti " &amp; cargoId &amp; ". " &amp; app.myPassport.getAllErrorsWarningsAsString);
			tiArray.add( ti );
			self.assertTrueMsg(ti.mySubTerminal = subTerminal, "Failed to set sub terminal corrrectly on ti for Terminal config " &amp; subTString &amp; "."); 
		elseif subTcount = 2 then
			//MySubTerminalForExportMTY
			imexInt := TI_IMEX_STATUS_EXPORT;
			self.opts.purge();
			self.opts.addAssoc(UTTI_IMEX,imexInt);
			ti := self.addContainer(cargoId, oper, "2200", "MT", imexInt);
			self.assertTrueMsg(ti &lt;&gt; null, "Failed to create ti " &amp; cargoId &amp; ". " &amp; app.myPassport.getAllErrorsWarningsAsString);
			tiArray.add( ti );
			self.assertTrueMsg(ti.mySubTerminal = subTerminal, "Failed to set sub terminal corrrectly on ti for Terminal config " &amp; subTString &amp; ".");
		elseif subTcount = 3 then
			//MySubTerminalForImportFull
			imexInt := TI_IMEX_STATUS_IMPORT;
			self.opts.purge();
			self.opts.addAssoc(UTTI_IMEX,imexInt);
			ti := self.addContainer(cargoId, oper,"2200", "GENL", imexInt);
			self.assertTrueMsg(ti &lt;&gt; null, "Failed to create ti " &amp; cargoId &amp; ". " &amp; app.myPassport.getAllErrorsWarningsAsString);
			tiArray.add( ti );
			self.assertTrueMsg(ti.mySubTerminal = subTerminal, "Failed to set sub terminal corrrectly on ti for Terminal config " &amp; subTString &amp; ".");
		elseif subTcount = 4 then
			//MySubTerminalForImportMTY
			imexInt := TI_IMEX_STATUS_IMPORT;
			self.opts.purge();
			self.opts.addAssoc(UTTI_IMEX,imexInt);
			ti := self.addContainer(cargoId, oper,"2200", "MT", imexInt);
			self.assertTrueMsg(ti &lt;&gt; null, "Failed to create ti " &amp; cargoId &amp; ". " &amp; app.myPassport.getAllErrorsWarningsAsString);
			tiArray.add( ti );
			self.assertTrueMsg(ti.mySubTerminal = subTerminal, "Failed to set sub terminal corrrectly on ti for Terminal config " &amp; subTString &amp; ".");
		elseif subTcount = 5 then
			//MySubTerminalForStorageFull
			imexInt := TI_IMEX_STATUS_STORAGE;
			self.opts.purge();
			self.opts.addAssoc(UTTI_IMEX,imexInt);
			ti := self.addContainer(cargoId, oper,"2200", "GENL", imexInt);
			self.assertTrueMsg(ti &lt;&gt; null, "Failed to create ti " &amp; cargoId &amp; ". " &amp; app.myPassport.getAllErrorsWarningsAsString);
			tiArray.add( ti );
			self.assertTrueMsg(ti.mySubTerminal = subTerminal, "Failed to set sub terminal corrrectly on ti for Terminal config " &amp; subTString &amp; ".");
		elseif subTcount = 6 then
			//MySubTerminalForStorageMTY
			imexInt := TI_IMEX_STATUS_STORAGE;
			self.opts.purge();
			self.opts.addAssoc(UTTI_IMEX,imexInt);
			ti := self.addContainer(cargoId, oper,"2200", "MT", imexInt);
			self.assertTrueMsg(ti &lt;&gt; null, "Failed to create ti " &amp; cargoId &amp; ". " &amp; app.myPassport.getAllErrorsWarningsAsString);
			tiArray.add( ti );
			self.assertTrueMsg(ti.mySubTerminal = subTerminal, "Failed to set sub terminal corrrectly on ti for Terminal config " &amp; subTString &amp; ".");
		elseif subTcount = 7 then
			//MySubTerminalForImportGen
			imexInt := TI_IMEX_STATUS_IMPORT;
			self.opts.purge();
			self.opts.addAssoc(UTTI_IMEX,imexInt);
			ti := self.addCargoOpts(cargoId, null, null, oper, cargoType.id);
			self.assertTrueMsg(ti &lt;&gt; null, "Failed to create ti " &amp; cargoId &amp; ". " &amp; app.myPassport.getAllErrorsWarningsAsString);
			tiArray.add( ti );
			self.assertTrueMsg(ti.mySubTerminal = subTerminal, "Failed to set sub terminal corrrectly on ti for Terminal config " &amp; subTString &amp; ".");
		elseif subTcount = 8 then
			//MySubTerminalForExportGen
			imexInt := TI_IMEX_STATUS_EXPORT;
			self.opts.purge();
			self.opts.addAssoc(UTTI_IMEX,imexInt);
			ti := self.addCargoOpts(cargoId, null, null, oper, cargoType.id);
			self.assertTrueMsg(ti &lt;&gt; null, "Failed to create ti " &amp; cargoId &amp; ". " &amp; app.myPassport.getAllErrorsWarningsAsString);
			tiArray.add( ti );
			self.assertTrueMsg(ti.mySubTerminal = subTerminal, "Failed to set sub terminal corrrectly on ti for Terminal config " &amp; subTString &amp; ".");
		elseif subTcount = 9 then
			//MySubTerminalForStorageGen
			imexInt := TI_IMEX_STATUS_STORAGE;
			self.opts.purge();
			self.opts.addAssoc(UTTI_IMEX,imexInt);
			ti := self.addCargoOpts(cargoId, null, null, oper, cargoType.id);
			self.assertTrueMsg(ti &lt;&gt; null, "Failed to create ti " &amp; cargoId &amp; ". " &amp; app.myPassport.getAllErrorsWarningsAsString);
			tiArray.add( ti );
			self.assertTrueMsg(ti.mySubTerminal = subTerminal, "Failed to set sub terminal corrrectly on ti for Terminal config " &amp; subTString &amp; ".");
		elseif subTcount = 10 then
			//MySubTerminalForOther - Export Bol...
			subTermToUse := terminal.getDefaultSubTerminal(	CM_SubTerminal.Type_BOL, 0, TI_IMEX_STATUS_EXPORT, null, false);
			create pxyBOLOut transient;	
			pxyBOLOut.setProxy(cargoId, null, oper, null, 4, BOLType_GeneralBillOfLading, terminal, subTermToUse, null, null, null, false, null, null, null,
																																						null);	//13/07/2022 navgm20 Tfs 54095
			pxyBOLOut.setPropertyValue("weightNet", 13784.Decimal);
			pxyBOLOut.setPropertyValue("weightGross", 13784.Decimal);
			create pxyBOLItemOut transient;
			pxyBOLItemOut.setProxy(pxyBOLOut, TI_CargoType_Container, "GENL", "colour", "mark", 4, 5, 6000, 200, 300, 400, "ACDG", "ACDG", "remarks");
			pxyBOLOut.allBOLDtls.add(pxyBOLItemOut);
			app.myTrxCA.trxCreateBOL(pxyBOLOut, realBOLOut, null, app.myPassport);
			self.assertTrueMsg(realBOLOut &lt;&gt; null, "Failed to create bol OUT " &amp; cargoId &amp; ". " &amp; app.myPassport.getAllErrorsWarningsAsString);
			self.assertTrueMsg(realBOLOut.mySubTerminal = subTerminal, "Failed to set sub terminal corrrectly on Bol OUT for Terminal config " &amp; subTString &amp; ".");
		elseif subTcount = 11 then
			//MySubTerminalForSourceBulkRoad
			bulkId := cargoId;
			self.opts.purge;
			self.opts.addAssoc("ISOType", "2200");
			self.opts.addAssoc("FullRelease", false);
			self.opts.addAssoc("CreateDeliveryRequest", true);
			bulk := self.addReleaseByTypeRequestOpts(bulkId, BR_TYPE_ROAD, TI_CargoType_Container);
			self.assertTrueMsg(bulk &lt;&gt; null, "Failed to create request " &amp; bulkId &amp; ". " &amp; app.myPassport.getAllErrorsWarningsAsString);
			bulkArray.add( bulk );
			self.assertTrueMsg(bulk.mySubTerminal = subTerminal, "Failed to set sub terminal corrrectly on Bulk Release for Terminal config " &amp; subTString &amp; ".");
		elseif subTcount = 12 then
			//MySubTerminalForSourceBulkRail
			bulkId := cargoId;
			self.opts.purge;
			self.opts.addAssoc("ISOType", "2200");
			self.opts.addAssoc("FullRelease", false);
			self.opts.addAssoc("CreateDeliveryRequest", true);
			bulk := self.addReleaseByTypeRequestOpts(bulkId, BR_TYPE_RAIL, TI_CargoType_Container);
			self.assertTrueMsg(bulk &lt;&gt; null, "Failed to create request " &amp; bulkId &amp; ". " &amp; app.myPassport.getAllErrorsWarningsAsString);
			bulkArray.add( bulk );
			self.assertTrueMsg(bulk.mySubTerminal = subTerminal, "Failed to set sub terminal corrrectly on Bulk Release for Terminal config " &amp; subTString &amp; ".");
		elseif subTcount = 13 then
			//MySubTerminalForSourceBulkShip
			bulkId := cargoId;
			self.opts.purge;
			self.opts.addAssoc("ISOType", "2200");
			self.opts.addAssoc("FullRelease", false);
			self.opts.addAssoc("CreateDeliveryRequest", true);
			bulk := self.addReleaseByTypeRequestOpts(bulkId, BR_TYPE_SHIP, TI_CargoType_Container);
			self.assertTrueMsg(bulk &lt;&gt; null, "Failed to create request " &amp; bulkId &amp; ". " &amp; app.myPassport.getAllErrorsWarningsAsString);
			bulkArray.add( bulk );
			self.assertTrueMsg(bulk.mySubTerminal = subTerminal, "Failed to set sub terminal corrrectly on Bulk Release for Terminal config " &amp; subTString &amp; ".");
		elseif subTcount = 14 then
			//MySubTerminalForSourceBulkPack
			bulkId := cargoId;
			self.opts.purge;
			self.opts.addAssoc("ISOType", "2200");
			self.opts.addAssoc("FullRelease", false);
			self.opts.addAssoc("CreateDeliveryRequest", true);
			bulk := self.addReleaseByTypeRequestOpts(bulkId, BR_TYPE_PACKING, TI_CargoType_Container);
			self.assertTrueMsg(bulk &lt;&gt; null, "Failed to create request " &amp; bulkId &amp; ". " &amp; app.myPassport.getAllErrorsWarningsAsString);
			bulkArray.add( bulk );
			self.assertTrueMsg(bulk.mySubTerminal = subTerminal, "Failed to set sub terminal corrrectly on Bulk Release for Terminal config " &amp; subTString &amp; ".");
		elseif subTcount = 15 then
			//MySubTerminalForTargetBulk
			// Nothing to test, only called directly from CM_Terminal.getConfig
		elseif subTcount = 16 then
			//MySubTerminalForBOLIn
			subTermToUse := terminal.getDefaultSubTerminal(	CM_SubTerminal.Type_BOL, 0, TI_IMEX_STATUS_IMPORT, null, false);
			create pxyBOLIn transient;	
			pxyBOLIn.setProxy(cargoId, null, oper, null, 4, BOLType_GeneralBillOfLading, terminal, subTermToUse, null, null, null, false, null, null, null,
																																					null);	//13/07/2022 navgm20 Tfs 54095
			pxyBOLIn.setPropertyValue("weightNet", 13784.Decimal);
			pxyBOLIn.setPropertyValue("weightGross", 13784.Decimal);
			create pxyBOLItemIn transient;
			pxyBOLItemIn.setProxy(pxyBOLIn, TI_CargoType_Container, "GENL", "colour", "mark", 4, 5, 6000, 200, 300, 400, "ACDG", "ACDG", "remarks");
			pxyBOLIn.allBOLDtls.add(pxyBOLItemIn);
			app.myTrxCA.trxCreateBOL(pxyBOLIn, realBOLIn, null, app.myPassport);
			self.assertTrueMsg(realBOLIn &lt;&gt; null, "Failed to create bol " &amp; cargoId &amp; ". " &amp; app.myPassport.getAllErrorsWarningsAsString);
			self.assertTrueMsg(realBOLIn.mySubTerminal = subTerminal, "Failed to set sub terminal corrrectly on Bol IN for Terminal config " &amp; subTString &amp; ".");
		endif;
	endforeach;
	

epilog

	delete pxyBOLOut;
	if realBOLOut &lt;&gt; null then
		self.deleteBOL(null, realBOLOut);
	endif;
	delete pxyBOLIn;
	if realBOLIn &lt;&gt; null then
		self.deleteBOL(null, realBOLIn);
	endif;
	if tiArray &lt;&gt; null then
		foreach ti in tiArray do
			self.deleteTrackedItem(ti, false);
		endforeach;
		delete tiArray;
	endif;
	if bulkArray &lt;&gt; null then
		foreach bulk in bulkArray do
			self.deleteReleaseRequest(bulk.code);
		endforeach;
		delete bulkArray;
	endif;
	foreach subTString in subTStringArray do
		subTcount := subTcount + 1;
		subTermId := BaseSubTerminalName &amp; subTcount.String;
		self.deleteSubTerminal(subTermId);
	endforeach;

	delete subTStringArray;
	delete subTermArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="tToDoDemplate" id="29140a7d-22a7-4742-b72e-b4a6194c940a">
        <source>tToDoDemplate();
/*

Purpose: create ToDo Template 			

Date		Who		Reason
10/04/2014	cnwma1	Initial creation

*/

vars
	toDoTemplate  : CM_ToDoTemplate;
begin


	 // Create ToDo Template
	toDoTemplate :=self.addToDoTemplate("UT Template");
	self.assertNotNull(toDoTemplate);
	
	// Update  TODO Template 
	
	self.updateToDoTemplate(toDoTemplate);
	self.assertEqual(toDoTemplate.operators.first.code,"MSK");
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tYAConfigMaint" id="cc8812df-340f-43ca-b153-278993a50228">
        <source>tYAConfigMaint();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Aug 2021	navndl1	Initial creation	Migrated portion of a test that otherwise
					achieved nothing and took 40 minutes to do it.
25 Aug 2025	navdap1	MTN-35615 ENS | Bulk Creation of Yard Allocations
*/

vars

	terminal : CM_Terminal;
	yaConfig : CM_YAConfig;
	pxyYAConfig : CM_YAConfig;
	configOpts : CMIF_YAConfig;
	searchCTColl : CM_YACriteriaTypeArray;
	templateCTColl : CM_YACriteriaTypeArray;
	rtCTColl : CM_YACriteriaTypeArray;

	autoPlanAllowLogging : Boolean;
	autoPlanEnabled : Boolean;
	autoPlanGenerateSwapForYardInt : Boolean;
	autoPlanGenerateSwapJob : Boolean;
	autoPlanPreNotiEmail : String;
	autoPlanPreNotifications : Boolean;
	autoPlanUseOverstowRules : Boolean;
	autoPlanOsIgnorePandQ : Boolean;	
	autoPlanUserRestrictions : Boolean;
	autoPlanYAGroupedBlocks : Boolean;
	fillOption : Integer;
	autoPlanMTReleaseStrategy : Integer;
	autoPlanUsePriorityLookup : Boolean;
	autoPlanUseBestPickDirector : Boolean;
	autoPlanOverstowRule : Integer;
	
	yaIMEXConfig : CM_YAIMEXConfig;
	opCriteria : CM_YACriteriaTypeArray;
	ct : CM_YACriteriaType;
	pxyYAIMEXConfig : CM_YAIMEXConfig;
	
begin

	terminal := self.getTerminal;
	
	self.assertTrueMsg(terminal &lt;&gt; null, "failed to find terminal - in setup");
	
	//capture the existing YA Config details
	create searchCTColl transient;
	create templateCTColl transient;
	create rtCTColl transient;
	if terminal.myYAConfig &lt;&gt; null then
		if not terminal.myYAConfig.allDefaultSearchCriteriaTypes.isEmpty then
			terminal.myYAConfig.allDefaultSearchCriteriaTypes.copy( searchCTColl );
		endif;
		if not terminal.myYAConfig.allDefaultCriteriaTypes.isEmpty then
			terminal.myYAConfig.allDefaultCriteriaTypes.copy( templateCTColl );
		endif;
	endif;
	autoPlanAllowLogging := terminal.isAutoPlanAllowLogging();
	autoPlanEnabled := terminal.isAutoPlanningEnabled();
	autoPlanGenerateSwapForYardInt := terminal.isAutoPlanGenSwapForYardInt();
	autoPlanGenerateSwapJob := terminal.isAutoPlanGenerateSwapJob();
	autoPlanPreNotiEmail := terminal.getAutoPlanPreNotifyEmail();
	autoPlanPreNotifications := terminal.isAutoPlanPreNotifications();
	autoPlanUseOverstowRules := terminal.isAutoPlanUseOverstowRules;
	autoPlanOsIgnorePandQ := terminal.isAutoPlanOsIgnorePandQ();
	autoPlanUserRestrictions := terminal.isAutoPlanUserRestrictions();
	autoPlanYAGroupedBlocks := terminal.isAutoPlanYAGroupedBlocks();
	fillOption := terminal.getFillOption();
	autoPlanMTReleaseStrategy := terminal.getAutoPlanMTReleaseStrategy();
	autoPlanUsePriorityLookup := terminal.isAutoPlanUsePriorityLookup();
	autoPlanUseBestPickDirector := terminal.isAutoPlanUseBestPickDirector();
	autoPlanOverstowRule := terminal.myYAConfig.autoPlanOverstowRule;
	if fillOption = 0 then
		fillOption := YAFillOption_InOrder;
	endif;		
	terminal.allRTAllocationCriteriaTypes.copy(rtCTColl);
	
//	foreach yaIMEXConfig in terminal.myYAConfig.allYAIMEXConfigs do
//write yaIMEXConfig.String;
//	endforeach;
	
	//Delete the existing YA Config.
	yaConfig := terminal.myYAConfig;
	app.myTrxDA.trxDeleteYAConfig(yaConfig, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertTrueMsg(terminal.myYAConfig = null, "failed to delete YA Config");
	
	//Create a new YA Config
	create pxyYAConfig transient;
	pxyYAConfig.setProxy(terminal, null, null, null, null);		// MTN-35615
	pxyYAConfig.setAutoPlanOverstowRule(autoPlanOverstowRule);
	
	create configOpts transient;
	configOpts.setFromTerminal(terminal);
	
	app.myTrxCA.trxCreateYAConfig(pxyYAConfig, yaConfig, configOpts, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertTrueMsg(yaConfig &lt;&gt; null, "failed to create YA Config");
	
	delete pxyYAConfig;
	delete configOpts;
	
	//Update existing YA Config back to what it was using teh values captured above.
	
	create configOpts transient;
	configOpts.autoPlanAllowLogging := autoPlanAllowLogging;
	configOpts.autoPlanEnabled := autoPlanEnabled;
	configOpts.autoPlanGenerateSwapForYardInt := autoPlanGenerateSwapForYardInt;
	configOpts.autoPlanGenerateSwapJob := autoPlanGenerateSwapJob;
	configOpts.autoPlanPreNotiEmail := autoPlanPreNotiEmail;
	configOpts.autoPlanPreNotifications := autoPlanPreNotifications;
	configOpts.autoPlanUseOverstowRules := autoPlanUseOverstowRules;
	configOpts.autoPlanOsIgnorePandQ :=autoPlanOsIgnorePandQ;
	
	configOpts.autoPlanUserRestrictions := autoPlanUserRestrictions;
	configOpts.autoPlanYAGroupedBlocks := autoPlanYAGroupedBlocks;
	configOpts.fillOption := fillOption;
	configOpts.autoPlanMTReleaseStrategy := autoPlanMTReleaseStrategy;
	configOpts.autoPlanUsePriorityLookup := autoPlanUsePriorityLookup;
	configOpts.autoPlanUseBestPickDirector := autoPlanUseBestPickDirector;		
	configOpts.allRTAllocationCriteriaTypes.clear;
	if not rtCTColl.isEmpty then
		rtCTColl.copy(configOpts.allRTAllocationCriteriaTypes);
	endif;
	
	
	beginLoad;
	pxyYAConfig := yaConfig.pxyCreateUpdateProxy();
	pxyYAConfig.setProxy(terminal, templateCTColl, searchCTColl, null, null);	// MTN-35615
	pxyYAConfig.setAutoPlanOverstowRule(autoPlanOverstowRule);
	endLoad;
	
	app.myTrxUA.trxUpdateYAConfig(pxyYAConfig, configOpts, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	//now put the operational criteria back
	create opCriteria transient;
	ct := CM_YATypeVoyageInbound.firstInstance;
	opCriteria.add(ct);
	ct := CM_YATypeVoyageOutbound.firstInstance;
	opCriteria.add(ct);
	
	foreach yaIMEXConfig in yaConfig.allYAIMEXConfigs do
		if(yaIMEXConfig.myIMEXStatus.code = TI_IMEX_STATUS_TRANSHIP) then
			pxyYAIMEXConfig := app.createUpdateProxy(yaIMEXConfig).CM_YAIMEXConfig;
			pxyYAIMEXConfig.setProxy(opCriteria, yaIMEXConfig.allGroupLabelCriteria, yaIMEXConfig.colour, yaIMEXConfig.allOpCriteria.first);
	
			app.myTrxUA.trxUpdateYAIMEXConfig(pxyYAIMEXConfig, app.myPassport);
			self.assertNoTrxErrorsOrWarnings();
			delete pxyYAIMEXConfig;
		endif;
	endforeach;
	delete opCriteria;
	
	create opCriteria transient;
	ct := CM_YATypeCargoType.firstInstance;
	opCriteria.add(ct);
	ct := CM_YATypeVoyage.firstInstance;
	opCriteria.add(ct);
	
	foreach yaIMEXConfig in yaConfig.allYAIMEXConfigs do
		if(yaIMEXConfig.myIMEXStatus.code = TI_IMEX_STATUS_EXPORT)
		or (yaIMEXConfig.myIMEXStatus.code = TI_IMEX_STATUS_STORAGE)
		then
			pxyYAIMEXConfig := app.createUpdateProxy(yaIMEXConfig).CM_YAIMEXConfig;
			pxyYAIMEXConfig.setProxy(opCriteria, yaIMEXConfig.allGroupLabelCriteria, yaIMEXConfig.colour, yaIMEXConfig.allOpCriteria.first);
	
			app.myTrxUA.trxUpdateYAIMEXConfig(pxyYAIMEXConfig, app.myPassport);
			self.assertNoTrxErrorsOrWarnings();
			delete pxyYAIMEXConfig;
		endif;
	endforeach;
	delete opCriteria;

epilog

	delete pxyYAConfig;
	delete configOpts;
	delete searchCTColl;
	delete templateCTColl;
	delete rtCTColl;
	delete opCriteria;
	delete pxyYAIMEXConfig;

end;</source>
    </JadeMethod>
    <JadeMethod name="uCreateDamageInstance" id="130b7e0a-b9ce-4cc1-9480-ec42af0d6844">
        <source>uCreateDamageInstance();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 October 2022	navak20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/
constants
	Id_WithIn_Length : String = "TestDI";
	CodeDS : String = "20";
	LevelDS : Integer = 20;
	DescriptionDS : String = "Damage twenty";
	IsNotAvailableForEntryDS : Boolean = false;
	CodeDP : String = "DP1";
	DescriptionDP : String = "Damage Party";
	CodeDL : String = "DL1";
	DescriptionDL : String = "Damage Location";
	CodeDR : String = "DR1";
	DescriptionDR : String = "Damage Reason";
vars
	operator : CM_Operator;
	cargotype : CM_CargoType;
	ti,tin : CM_TrackedItem;
	allDamageInstance : CM_DamageInstanceByDmgePos;
	damageInstance,di : CM_DamageInstance;
	severity : CM_DamageSeverity;
	party : CM_DamageParty;
	place : CM_DamagePlace;
	reason : CM_DamageReason;
	damageCode : CM_DamageDefinitionCode;
	position : CM_DamagePosition;
begin
	//self.deleteDamageSeverity(severity);
	//Creating cargo TI
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
    cargotype := app.myRoot.allCargoTypesById[TI_CargoType_BreakBulk];
    self.deleteCargo(Id_WithIn_Length, cargotype);
    ti := self.addCargoOpts(Id_WithIn_Length, "", 'TYRE', operator, cargotype.id);
	tin := app.createUpdateProxy(ti).CM_TrackedItem;
	severity := self.createDamageSeverity(CodeDS, DescriptionDS, IsNotAvailableForEntryDS, LevelDS);
	party := self.createDamageParty(CodeDP, DescriptionDP, IsNotAvailableForEntryDS);
	place := self.createDamagePlace(CodeDL, DescriptionDL, IsNotAvailableForEntryDS);
	reason := self.createDamageReason(CodeDR, DescriptionDR, IsNotAvailableForEntryDS);
	//damageCode := "Top".CM_DamageDefinitionCode;
	create allDamageInstance transient;
	create damageInstance transient;
	damageInstance.setProxy(tin, null, damageCode, position, "Testing", false, 1, severity, null, place, party, reason, null, null, null, 0, null, null);
	
	allDamageInstance.add(damageInstance);
	app.myTrxUA.trxUpdateTIandExtraInfo(tin, TI_UPDMODE_NORMAL, null, null, null, app.myPassport);
	self.assertEqual(tin.allDamageInstancesByPos.last.CM_DamageInstance.remarks, allDamageInstance.last.CM_DamageInstance.remarks);
epilog
	delete damageInstance;
	delete allDamageInstance;
	delete tin;
end;</source>
    </JadeMethod>
    <JadeMethod name="uCreateTerminal" id="751ac644-b2de-42f9-9be7-3e366a2e7c5b">
