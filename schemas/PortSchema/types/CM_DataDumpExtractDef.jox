    </JadeMethod>
    <JadeMethod name="getExtractClass" id="d8e54c58-41c8-4b35-aab5-afe20a21f0ba">
        <source>getExtractClass(_class: Class) : CM_DataDumpExtractClass;
// ---------------------------------------------------------------------------
// Created:     08 July 2003 by cnwsb1
//
// Purpose:		Returns the extract class for the given class, or its parent(s).
// ---------------------------------------------------------------------------
vars
	cls : Class;
	className : String;
	extrClass : CM_DataDumpExtractClass;

begin
	cls := _class;
	
	while extrClass = null and cls.getName &lt;&gt; Object.getName do
		extrClass := self.getExtractClassByName(cls.getName);
		if extrClass &lt;&gt; null then
			return extrClass;
		endif;
		
		cls := cls.getSuperclass;
	endwhile;
	
	return null;
end;</source>
        <Parameter name="_class" type="Class"/>
        <ReturnType type="CM_DataDumpExtractClass"/>
    </JadeMethod>
    <JadeMethod name="getExtractClassByName" id="63e2d701-4c76-4cc7-adbd-4309eb2909d0">
        <source>getExtractClassByName(_extractClassName: String) : CM_DataDumpExtractClass;
// ---------------------------------------------------------------------------
// Created:     30 May 2003 by cnwsb1
// ---------------------------------------------------------------------------
vars
	extractClass : CM_DataDumpExtractClass;

begin
	foreach extractClass in self.allDataDumpExtractClasses where
			extractClass.myDataDumpClass.className = _extractClassName do
		return extractClass;
	endforeach;
	
	return null;
end;</source>
        <Parameter name="_extractClassName" type="String"/>
        <ReturnType type="CM_DataDumpExtractClass"/>
    </JadeMethod>
