    <JadeMethod name="getTATranslationString" id="3434cedf-a3de-45a7-88b2-6362aa4d08e0">
        <source>getTATranslationString(_terminalArea : CM_TerminalAreaMaster;
					   _isSource : Boolean) : String;

/*

Purpose:			Get the interface description for the passed in Terminal Area

Parameters:			Terminal Area, and whether or not it is a source or a target

Return Value:		String Description


Date		Who		Reason
19 Sep 2008	cnwkpd1	PAR #17832 - Development of CCMS JMTCP01 1024 - Voice Recognition

*/

vars
	interfaceTrans	: CM_InterfaceTranslationTA;
	returnVal		: String;
	
begin
	if _terminalArea = null then
		return null;
	endif;
	
	// Default to niceName
	returnVal := _terminalArea.getNiceName;
	
	// Check for a translation of this TA
	interfaceTrans := self.allInterfaceTranslationTAs[_terminalArea];
	if interfaceTrans &lt;&gt; null then
		// If there is a source translation, and that's what we want
		if interfaceTrans.translationString &lt;&gt; null and _isSource then
			returnVal := interfaceTrans.translationString;
			
		// If there is a destination translation, and that's what we want
		elseif interfaceTrans.destinationTranslation &lt;&gt; null and not _isSource then
			returnVal := interfaceTrans.destinationTranslation;
		endif;
	endif;
	
	return returnVal;
	
	
epilog

end;</source>
        <Parameter name="_terminalArea" type="CM_TerminalAreaMaster"/>
        <Parameter name="_isSource" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
