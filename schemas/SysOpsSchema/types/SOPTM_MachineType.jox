	theForm.btnSingle1New.enabled:=true;
	theForm.btnSingle1Down.enabled:=true;
	theForm.btnSingle1Up.enabled:=true;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDefaults" id="be8c8e18-78da-414d-a47d-1b030d1042f9">
        <source>setupThumbnailDefaults();
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 29 January 2004
//
//********************************************************************
vars

begin
	inheritMethod();
	
//	Machine Types can't be added/deleted here... only edited.  Load them through the CM_Root::createMachineTypes Method.    
//	See MACHINE_TYPE_
	self.myForm.allowAdd := false;
	self.myForm.allowDelete := false;

	//tidies the buttons up
	self.myForm.frmToolbar.positionToolbarControls();
	

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="eeb8c409-9a58-49f5-9316-71d89b08c308">
        <source>setupThumbnailDetails();

vars
	theForm : SOP_TableMaintForm;

begin
  
  	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_MachineTypeTbl);
//	theForm.zAddColumn('Machine Type', 'code', Table.InputType_None, 30);
//	theForm.zAddColumn('Description', 'description', Table.InputType_None, 70);
//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Description, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_MachineTypeMaint);
	theForm.shtTblInput1.visible := true;

	theForm.btnSetDefault1.caption := 'Default To Machines';

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="86e48394-9fee-47f4-8c25-a37ed774f4c5">
        <updating/>
        <source>showThumbnail(pMachineType : CM_MachineType) updating;

vars

	theForm : SOP_TableMaintForm;
	port:CM_Port;
	first:Boolean;
	list:String;	
begin
  
  	theForm := self.myForm;
	theForm.tblInput1.clearValues;

	theForm.tblInput1.setValueByName(ETRow_Code, pMachineType.type);
	theForm.tblInput1.setValueByName(ETRow_Description,	pMachineType.description);
	theForm.mulSelect1.setSelected(pMachineType.allAllowedTATypes);
	theForm.mulSelect2.setSelected(pMachineType.allAllowedCargoTypes);	
	// cnwsh3 30/07/2009. CCMS SFW1066 PAR20321 - Recording Damage Details Changes.
	//Only need to show for wagon classes at this stage but this will most likely change if
	//damage is integrated to all machine types.  It wasn't included in the scope of development for 
	//7.7.3
	if pMachineType.isKindOf(CM_WagonMachineType) then
		theForm.shtMultiSelect3.visible := true;
		theForm.shtMultiSelect6.visible := true;
		theForm.mulSelect3.setSelected(pMachineType.allDamagePositions);	
		theForm.mulSelect6.setSelected(pMachineType.allDamageDefinitionCodes);	
	else
		theForm.shtMultiSelect3.visible := false;
		theForm.shtMultiSelect6.visible := false;
	endif;
		
	
	theForm.lstSingleSelect1.clear;
	theForm.lstSingleSelect1.listCollection(pMachineType.allFaultQuestions,false,0);	
	//self.disableMulSelect1Contents();
	
	
		// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(null, self.permissionMaint) then
		theForm.btnSetDefault1.enabled := false;
		theForm.lstSingleSelect1.enabled:=false;
		theForm.btnSingle1Edit.enabled:=false;
		theForm.btnSingle1Delete.enabled:=false;
		theForm.btnSingle1New.enabled:=false;
		theForm.btnSingle1Down.enabled:=false;
		theForm.btnSingle1Up.enabled:=false;
		

	endif;
	
end;</source>
        <Parameter name="pMachineType" type="CM_MachineType"/>
    </JadeMethod>
</Class>
