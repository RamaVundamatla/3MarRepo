    <JadeMethod name="btnCancel_click" id="02fb4e04-6205-4841-ac99-264ed4f4ec61">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancel_click(btn: Button input) updating;
/*
Purpose:	

Date			Who		Reason
09 July 2024	navab1	CR 64615 TASK 64646
02 Dec 2024		navlw1	Jira-14844: MTN - Refinement of EDI Issue Save
*/

vars
	table : CM_DataTable;
	msgText : String;
begin
	table := self.tblData;

	msgText := self.getMsgBoxText(); // navlw1 #Jira-14844
	if msgText &lt;&gt; null then
		if app.msgBox(msgText,app.getErrorString(Confirmation), MsgBox_Yes_No) = MsgBox_Return_Yes then
			table.deselectAll();
			table.selectObject(self.myCurrentEDIIssue, false);
			return;
		endif;
		
	endif;
	
	self.unloadForm();
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
