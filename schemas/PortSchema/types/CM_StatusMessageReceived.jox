        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getDisplayStringForAttribute" id="9129f69c-27a2-456a-b277-4217afb1af2c">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwndl1	Initial creation	Par 23498

*/

vars
	lDetail : String;
begin

	if _attrName = ETRow_Details  then
		if self.deleted then
			return self.getDeletedDetails();		// 15/10/18 MAP TFS41191
			
		else
			return app.getErrorString(TransType_109) &amp; ": " &amp; self.code;

			
		endif;
							
	else
		return inheritMethod(_attrName, _short);
	
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getEnquiryRow" id="2499f5c7-4d29-4f85-9e66-d26d022323d2">
        <source>getEnquiryRow(): String;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 07 May 2008
//
//----------------------------------------------------------------------

vars

begin
	return inheritMethod() &amp; app.getErrorString(TransType_109) &amp; ": " &amp; self.code;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTransmitDateLocalTZ" id="41026cbb-5009-4391-9ed3-95369e995514">
        <source>getTransmitDateLocalTZ(): TimeStamp;
/*

Purpose:			Return the local timezone version of the receiver's dateTime (for JRW)

Parameters:			None

Return Value:		

Date		Who		Reason
03 Jun 2016	cnwmp6	TFS 488 - Multi Timezone Support

*/
vars

begin
	return self.systemToLocalTime(self.transmitDate);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setFromEDICustomTI" id="70449925-8982-4d21-a181-3ac571b70df9">
        <updating/>
        <source>setFromEDICustomTI(_ediTI : CM_EDICustomStopTI) updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 07 May 2008
//
//----------------------------------------------------------------------

vars

begin
	if _ediTI = null then
		return;
	endif;
	
	self.isUSCustomsMessage := _ediTI.isUSCustomMessage;
	self.quantity := _ediTI.quantity;
	self.transmitDate := _ediTI.transmissionDate;
	self.code := _ediTI.responseStatus;
epilog

end;</source>
        <Parameter name="_ediTI" type="CM_EDICustomStopTI"/>
    </JadeMethod>
</Class>
