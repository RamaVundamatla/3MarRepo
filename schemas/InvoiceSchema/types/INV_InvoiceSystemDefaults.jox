    <JadeMethod name="skipToAttribute" id="20406693-f9da-461b-bc47-2eadbe69a2fc">
        <updating/>
        <source>skipToAttribute(_attributeName: String; _shtName: String) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 July 2012	cnwndl1	Initial creation

*/

vars

	tbl : CM_EntryTable;
	entRow : EntTableRow;
	row : Integer;

begin

	tbl := self.tblDataEntry;
	entRow := tbl.myEntTableDef.getEntTableRowByHeading(_attributeName);
	if entRow &lt;&gt; null then
		row := tbl.myEntTableDef.allEntTableRows.indexOf(entRow);
	endif;
	
	if row &gt; tbl.fixedRows and row &lt;= tbl.rows then
		tbl.accessRow(row).selected := true;
		tbl.topRow := row;
		self.selectedInvoiceRow := row; // TFS 52235 2NOV2021 NAVLW1
		tbl.accessRow(self.selectedInvoiceRow).selected := true; // TFS 52235 2NOV2021 NAVLW1
		tbl.cnEcSetCellBackColor(self.selectedInvoiceRow, 1, LightRed); // TFS 52235 2NOV2021 NAVLW1
	endif;
	
epilog

end;</source>
        <Parameter name="_attributeName" type="String"/>
        <Parameter name="_shtName" type="String"/>
    </JadeMethod>
    <JadeMethod name="tblDataEntry_mouseDown" id="4e9a707c-f3b0-41dd-9e57-2a55046ff6af">
        <controlMethod name="CM_EntryTable::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDataEntry_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2012	cnwndl1	Initial creation	Par 30682

*/

vars

	rowInTable	: Integer;
	text : String;

begin

	rowInTable := table.CM_EntryTable.getRow(ETRow_DotMatrixInvoiceRep);
	if table.row = rowInTable and rowInTable &gt; 0 then
		if button = 2 then
			text := table.getCellText(table.row,2).trimBlanks;
			app.printReportDotMatrixLineUp( text );
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
