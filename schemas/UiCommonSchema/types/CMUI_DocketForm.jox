    <JadeMethod name="setAllDockets" id="96dfbcfc-37b0-43b2-9fbd-943518c85c2a">
        <source>setAllDockets()protected;
//--------------------------------------------------------------
//Created: 22 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars
    docketDict	: CM_BOLByTypeNumberDTDict;
	docket		: CM_BOL;
	savePointer	: Integer;
	filter		: CM_QFDocket;
begin

	app.setStatusLineCaption('Loading Dockets');
	
	savePointer := app.mousePointer;
	app.mousePointer := Window.MousePointer_HourGlass;

	self.allDockets.clear;
	
//	docketDict := self.myTerminal.allDktsReceivedByTypeNumberDT;
	docketDict := self.myTerminal.allBOLsReceivedByTypeNumberDT;
	foreach docket in docketDict where docket.bolType = self.filterDocketType do
		self.allDockets.add(docket);
	endforeach;
	
	

	//Not doing releases at the moment
/*	docketDict := app.thisTerminal.allDktsReleasedByTypeNumberDT;
	foreach docket in docketDict where docket.docketType = self.filterDocketType do
		self.allDockets.add(docket);
	endforeach;
*/
epilog
	app.setStatusLineCaption('');
	app.mousePointer := savePointer;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setCaption" id="beb4fed7-1d4f-4fca-b33b-861e0a08e88a">
        <updating/>
        <source>setCaption(_caption: String) updating;
//14 January 2010	cnwml2


vars

begin
	if _caption = self.myMasterMenuAction.myMenuDtl.heading &amp; myTerminal.code then
		return;
	else
		inheritMethod(_caption);
	endif;

epilog

end;</source>
        <Parameter name="_caption" type="String"/>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="ed5df46d-8607-4189-9b0e-828fd2e1e210">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     07 December 2004	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod(_colorControl);

	self.setColorsForEntryTable(self.tblMain);
	self.tblBOLItems.backColor	:= self.colorControlBack;
end;</source>
