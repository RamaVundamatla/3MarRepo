                                _ftpEntity              : CM_FTPEntity; //MTN-36668
								_passport 				: CM_Passport input) : CM_ReportTemplate;
// -------------------------------------------
// Created 13 December 2004 by cnwdvb1
// -------------------------------------------
vars

	reportTemplate : CM_ReportTemplate;

begin

	create reportTemplate persistent;

	reportTemplate.createAndRunBackgroundRpt(	_isForPackage,
												_name,
												_description,
												_profileName,
												_printerName,
												_networkFilePath,
												_destination,
												_outputType,
