    </JadeMethod>
    <JadeMethod name="doRefreshTasks" id="ecfda1bb-556d-43b4-baca-2f863bcf210d">
        <source>doRefreshTasks();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Apr 2022 navma1  ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI  TFS 52351

*/

vars
	task : CM_WorkOrderDtl;			
begin
	
	if self.myPxyWorkOrder.allWoDtls.last &lt;&gt; null then
		task := self.myPxyWorkOrder.allWoDtls.last.CM_WorkOrderDtl;
		self.displayTasks(task);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResourceTypeSelected" id="86522881-c554-4e26-882a-38cf4a0750a3">
        <updating/>
        <source>doResourceTypeSelected() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
23 April 2022	navhl20 ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	resourceType : HMS_ResourceType;
	resource : HMS_Resource;
	harbour 	: HMS_Harbour;
begin
	if self.cmbResourceType.listObject = null then
		return;
	endif;
	resourceType := self.cmbResourceType.listObject.HMS_ResourceType;
	if self.myVoyage &lt;&gt; null and  self.myVoyage.myHMSVoyageData &lt;&gt;  null then
		harbour:= self.myVoyage.myHMSVoyageData.myHarbour;
	endif;
	
	// populate resources for this type
	self.cmbResource.clear;
	foreach resource in resourceType.allResources discreteLock do
		if resource.isNotAvailableForEntry then
			continue;
		endif;
		if harbour &lt;&gt; null and resource.myHarbour &lt;&gt; harbour then
			continue;
		endif;
		
		self.cmbResource.addItemObject(resource.code &amp; Tab &amp; resource.description, resource);
	endforeach;
	
	// make fields enabled/disabled depending on resource type requirements
	if resourceType.isQuantityRequired then
		self.txtUnitsUsed.enabled := true;
	else
		self.txtUnitsUsed.enabled := false;
	endif;
	if resourceType.isActionDateTimeRequired then
		self.txtFromDate.enabled := true;
		self.txtFromTime.enabled := true;
	else
		self.txtFromDate.enabled := false;
		self.txtFromTime.enabled := false;
	endif;
	if resourceType.isFromToDateTimeRequired then
		self.txtFromDate.enabled := true;
		self.txtFromTime.enabled := true;
		self.txtToDate.enabled := true;
		self.txtToTime.enabled := true;
	else
		if not resourceType.isActionDateTimeRequired then
			self.txtFromDate.enabled := false;
			self.txtFromTime.enabled := false;
		endif;
		self.txtToDate.enabled := false;
		self.txtToTime.enabled := false;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSaveBillingAdjustment" id="782a4754-247d-4335-aa01-f4b86e231c07">
        <source>doSaveBillingAdjustment(_wodtl : CM_WodBillingAdjustment input): Boolean  protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
28 April 2022	navgm20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars

begin
	_wodtl.setRemarks(self.txtBillingAdjReason.text);
	return true;
	
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_wodtl" type="CM_WodBillingAdjustment" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveCargoProxy" id="6c008c4c-de64-420b-8d36-e2d4d4cf4825">
        <updating/>
        <source>doSaveCargoProxy(): Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2022	navcs2	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
28 Dec 2022 navdp20 ChangeRequest 56661:[56012] - Add Transport Mode to Receive and Release work orders
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
25 Jan 2022 navhl20 ChangeRequest 55443:[54991] EUP - Receive Cargo Work Order - Enhancements
03 Feb 2023	navcs2	ChangeRequest 55440: EUP - Cargo Work Order Enhancements (54990)
07 Mar 2023 navhl20	ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
20 Mar 2023 navma1  Defect 57195: MTN - WO - Priority is showing some random number on the to do work orders on the yard operations form
24 Mar 2023 navhl20 ChangeRequest 57301:[57303] EUP - [Framework] - Improve Audits on Work orders
17 Apr 2023 navhl20 ChangeRequest 57322:[57323] EUP - VAS Task linked with Receive Cargo work Order
18 Apr 2023 navhl20 ChangeRequest 55442:[57629] EUP - Pack Cargo Work Order - Enhancement
28 Jun 2023 navlw1 	ChangeRequest 58730: EUP | Link bill of lading item to Receive work orders
04 Jul 2023	navma1	Bug 58952: MTN - Unable to add the tracked item when using the Export Booking for Release Cargo Work Order
05 Jul 2024 navhl20	ChangeRequest 61368: EUP* | Adding Pack Reserve Child to Packing Work order Release Request
30 Jul 2024 navhl20	ChangeRequest 65468: EUP -  VAS Mobile App - Enable Remarks for ToDo Tasks on Cargo Work Orders
*/

vars
	wodtl 					: CM_WorkOrderDtl;
	imexStatus  			: CM_IMEXStatus;
	commodity   			: CM_Commodity;
	imexStatusCode  		: Integer;
	commodityCode			: String;
	bookingRef				: CM_BookingRef;
	invalidWodDtl 			: Boolean; 
	todoSet 				: CM_ToDoTaskDescSet;
	int 					: Integer;							
	uniqueSuffix, 
	uniquePrefix 			: String;	
	transMode				: Integer;
	bulkReleae      		: CM_BulkRelease;
	bookingItem				: CM_BookingRefItem;
	edition					: Integer;
	term		    		: CM_Terminal;
	voyage 					: CM_Voyage;
	train 					: CM_Train;
	priority				: Integer;
	remarks					: String;
	noCharge				: Boolean;
	overrideCalcType		: Integer;
	overrideRate 			: Decimal [23,6];
	overridingDebtorType	: CM_DebtorType;
	calcType				: CM_CalculationType;
	contractid				: String;
	reserveDetail			: CM_ReserveDetail;
	transportObj			: CM_Object;
	wodTodo					: CM_WodToDo;
begin 
	on Exception do app.handleDeletedObject(exception, wodtl, invalidWodDtl); 
	
	wodtl := self.myPxyTask;
	
	if wodtl = null then
		return true; //No task selected - Form just loaded
	endif;
	
	edition := wodtl.edition;
	
	if invalidWodDtl then
		return true;
	endif;
	
	self.doSaveReqByDT(wodtl);																					//24.3.2023 navhl20	#57301[57303]
	
	//Set the proxy for the appropriate type
	if wodtl.isKindOf(CM_WodMove) then
		wodtl.CM_WodMove.setProxyMove(null, self.cmbTerminalArea.listObject.CM_TerminalArea, self.chkMoveAutoQueue.value, self.cmbYardLocation.listObject.CM_LocationsController);
	elseif wodtl.isKindOf(CM_WodToDo) then
		//wodtl.CM_WodToDo.setProxyWodToDo(self.cmbToDoTasks.listObject.CM_ToDoTaskDesc);						//7.3.2023 navhl20	#56614[56615]
		create todoSet transient;																				//7.3.2023 navhl20	#56614[56615]							
		self.mulToDoTasks.getSelected( todoSet );																//7.3.2023 navhl20	#56614[56615]
		if self.chkPriority.value then																			//17.03.2023	navcs2	#56842:[56843] //20.03.2023 navma1 #57195
			priority := CM_WorkOrder.WO_Priority_High;															//17.03.2023	navcs2	#56842:[56843]
		endif;																									//17.03.2023	navcs2	#56842:[56843]
		remarks 				:= self.txtToDoRemarks.text;													//17.03.2023	navcs2	#56842:[56843]
		noCharge 				:= self.chkNoCharge.value;														//17.03.2023	navcs2	#56842:[56843]
// ### TFS CR 56814 TASK 56813 06JUL2023 NAVAB1		overrideRate		    := self.txtSpecialRate.text.Decimal;											//17.03.2023	navcs2	#56842:[56843]
// ### TFS CR 56814 TASK 56813 06JUL2023 NAVAB1		overridingDebtorType	:= self.getSelectedChargeTo();													//17.03.2023	navcs2	#56842:[56843]
		contractid				:= self.txtInvContractId.text;			 										//17.03.2023	navcs2	#56842:[56843]

// ### TFS CR 56814 TASK 56813 06JUL2023 NAVAB1		calcType				:= self.getSelectedCalcType();													//17.03.2023	navcs2	#56842:[56843]
// ### TFS CR 56814 TASK 56813 06JUL2023 NAVAB1		if calcType &lt;&gt; null then																				//17.03.2023	navcs2	#56842:[56843]
// ### TFS CR 56814 TASK 56813 06JUL2023 NAVAB1			overrideCalcType := calcType.calculationType;														//17.03.2023	navcs2	#56842:[56843]
// ### TFS CR 56814 TASK 56813 06JUL2023 NAVAB1		endif;
		
		
		wodtl.CM_WodToDo.setPxyWoToDo(noCharge, remarks, priority, todoSet);									//17.03.2023	navcs2	#56842:[56843]						
		wodtl.CM_WodToDo.setProxySpecialRate(overrideCalcType,overrideRate,overridingDebtorType,contractid);	//17.03.2023	navcs2	#56842:[56843]
	elseif wodtl.isKindOf(CM_WodPack) then
		imexStatus := self.cmbPackImExStats.listObject.CM_IMEXStatus;
		if imexStatus &lt;&gt; null then
			imexStatusCode := imexStatus.code;
		endif;
		
		commodity := self.cmbPackCommodity.listObject.CM_Commodity;
		if commodity &lt;&gt; null then
			commodityCode := commodity.code;
		endif;
		
		if self.hasVasSubscription and self.cmbReleaseRequest.listObject &lt;&gt; null then
			bulkReleae := self.cmbReleaseRequest.listObject.CM_BulkRelease;
		endif;
		
		if self.hasVasSubscription and self.cmbReserveDetail.listObject &lt;&gt; null then							//05.07.2024 navhl20 #61368
			reserveDetail := self.cmbReserveDetail.listObject.CM_ReserveDetail;
		endif;
		
		wodtl.CM_WodPack.setProxyWodPack(wodtl.CM_WodPack.allPackingTIs,
				self.cmbPackBookRef.listObject.CM_BookingRef,
				self.cmbPackConsignee.listObject.CM_ConsigneeConsignor,
				self.cmbPackConsignor.listObject.CM_ConsigneeConsignor,
				self.cmbPackConStatus.listObject.CM_ContentsStatus,
				self.cmbPackDishPort.listObject.CM_Port,
				self.cmbPackOperator.listObject.CM_Operator,
				self.cmbPackSubTerm.listObject.CM_SubTerminal,
				self.cmbPackVoyage.listObject.CM_Voyage,
				commodityCode,
				imexStatusCode,
				bulkReleae,																							//18.4.2023 navhl20 #55442[57629]
				reserveDetail,																						//05.07.2024 navhl20 #61368
				true);
	elseif wodtl.isKindOf(CM_WodUnpack) then
		wodtl.CM_WodUnpack.setProxyWodUnpack(self.cmbUnpkToLocal.listObject.CM_TerminalArea);
	elseif wodtl.isWorkOrderForNullVoyage then												
		wodtl.CM_WodNullVoyage.setProxyWodNullVoyage(self.cmbVoyage.listObject.CM_Voyage);		
	elseif wodtl.isKindOf(CM_WodReceive) then													
		wodtl.CM_WodReceive.setProxyWodReceival(self.cmbBooking.listObject.CM_BookingRef,
												self.cmbBookingItem.listObject.CM_BookingRefItem,			//17.4.2023 navhl20 #57322[57323]
												self.cmbBol.listObject.CM_BOL,
												self.cmbBolItems.listObject.CM_BOLDtl,						//28.6.2023 navlw1 #58730
												self.txtCustomNumber.text,
												self.cmbTransport.listObject,
												app.transportModeStringToENum(self.cmbTransMode.text));     //27.1.2023 navhl20 #55443[54991]

	elseif wodtl.isKindOf(CM_WodRelease) then
		bookingRef   := self.cmbBooking.listObject.CM_BookingRef;				//04.07.2023 navma1 #58952
		bookingItem  := self.cmbBookingItem.listObject.CM_BookingRefItem;		//04.07.2023 navma1 #58952
		
		transportObj := self.cmbTransport.listObject.CM_Object;
		if transportObj.isKindOf(CM_Train) then
			train := transportObj.CM_Train;
		elseif transportObj.isKindOf(CM_Voyage) then
			voyage := transportObj.CM_Voyage;
		endif;
		
		transMode 		:= app.transportModeStringToENum(self.cmbTransMode.text);					 //28.12.2022 navdp20 #56661[56012]
		bulkReleae		:= self.cmbReleaseRequest.listObject.CM_BulkRelease;						 //28.12.2022 navdp20 #56661[56012]
		reserveDetail 	:= self.cmbReserveDetail.listObject.CM_ReserveDetail;						 //31.03.2023 navcs2  #55440[54990]
		
		wodtl.CM_WodRelease.setProxyWodRelease(bulkReleae,
											   transMode, 
											   voyage, 
											   train, 											 //03.02.2023 navcs2 # 55440[54990]
											   bookingRef,										 //04.07.2023 navma1 #58952
											   bookingItem,										 //04.07.2023 navma1 #58952
											   reserveDetail);									 //31.03.2023 navcs2 #55440[54990]	 
		wodtl.CM_WodRelease.setCustomsClearanceNumber(self.txtCustomsClearanceNo.text.trimBlanks);		
	
	elseif wodtl.isKindOf(CM_WodReleaseExtension) then
		wodtl.CM_WodReleaseExtension.setProxyWodReleaseExt(self.cmbRelExtWORel.listObject.CM_WodRelease);
	endif;
	
	
	//27.03.2023 navma1 #56614:[56615]
	if wodtl.isWorkOrderTIDtl then
		if wodtl.CM_WorkOrderTIDtl.canAddTodoTaskToCargoWO then
			create todoSet transient;									
			self.mulToDoTasks.getSelected( todoSet );
			wodtl.CM_WorkOrderTIDtl.setProxyAllToDoRequests( todoSet );
			if wodtl.CM_WorkOrderTIDtl.allToDoRequests.isNotEmpty() then					//30.07.2024 navhl20 #65468
				remarks := self.txtToDoRemarks.text;
				if self.chkPriority.value then
					priority := CM_WorkOrder.WO_Priority_High;
				endif;	
				wodTodo := wodtl.CM_WorkOrderTIDtl.allToDoRequests.first.CM_WodToDo;
				wodTodo.setToDoDetails(remarks,priority);
			endif;
		endif;
	endif;
	
	term         := self.myPxyWorkOrder.myTerminal;
	uniquePrefix := self.myPxyWorkOrder.id &amp; "-";
	
	int := 1;
	foreach wodtl in self.myPxyWorkOrder.allWoDtls do
		if term &lt;&gt; null then
			uniqueSuffix := term.getNextSuffix(int);
			wodtl.setTaskID(uniquePrefix &amp; uniqueSuffix);
			int := int + 1;
		endif;
	endforeach;
	
	return true;	
epilog
	delete todoSet;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveCargoRequest" id="22e3a580-4815-49e9-8b49-4f32a87486b3">
        <source>doSaveCargoRequest(_wodtl : CM_WodCargoRequest input): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 May 2022	navcs2	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	dischargePort : String;
	imexStatus, transferType : Integer;
	volume : Decimal [14, 4];
	totalWeight, tareWeight, cargoWeight : Decimal [14, 4];
	quantity : Integer;
	cargoSubType : CM_Product;
	cargoType : CM_CargoType;
	commodity : CM_Commodity;
	consignee, consignor, freightFwdr : CM_ConsigneeConsignor;
	location : CM_LocationsController;
	operator : CM_Operator;
	workPoint : CM_WorkPoint;
	allFiles : CM_FileDataSet;
	permitType : Integer;
	bolNumber : String;	
	loadPort : String;	
	estStartTS : TimeStamp;
	estEndTS : TimeStamp;	
	reqByTS : TimeStamp;	
	berth : HMS_Berth;	
	resourceUsedSet : HMS_ResourceUsedSet; 
	specialStow : CM_SpecialStow;	

begin
	create allFiles transient;
	
	cargoType := self.cmbCargoType.listObject.CM_CargoType;
	cargoSubType := self.cmbCargoSubType.listObject.CM_Product;
	commodity := self.cmbCommodity.listObject.CM_Commodity;
	operator := self.cmbOperator.listObject.CM_Operator;
	consignee := self.cmbConsignee.listObject.CM_ConsigneeConsignor;
	consignor := self.cmbConsignor.listObject.CM_ConsigneeConsignor;
	freightFwdr := self.cmbFreightFwdr.listObject.CM_ConsigneeConsignor;
	volume := self.txtTotalVolume.getConvertedValue;
	totalWeight := self.txtTotalWeight.getConvertedValue;
	tareWeight := self.txtTareWeight.getConvertedValue;
	cargoWeight := self.txtCargoWeight.getConvertedValue;
	specialStow := self.cmbSpecialStow.listObject.CM_SpecialStow;
	
	if self.cmbImexStatus.listIndex &gt; 0 then
		imexStatus := self.cmbImexStatus.listObject.CM_IMEXStatus.code;
	endif;
	if self.cmbDischargePort.listIndex &gt; 0 then
		dischargePort := self.cmbDischargePort.listObject.CM_Port.code;
	endif;
	if self.cmbWorkPoint.listIndex &gt; 0 then
		workPoint := self.cmbWorkPoint.listObject.CM_WorkPoint;
	endif;
	if self.cmbTransferType.listIndex &gt; 0 then
		transferType := self.cmbTransferType.listObject.CM_VoyageJobTransferType.id;
	endif;
	if self.cmbLocation.listIndex &gt; 0 then
		location := self.cmbLocation.listObject.CM_LocationsController;
	endif;
	if not self.txtTotalQuantity.enabled then
		quantity := 1;
	else
		quantity := self.txtTotalQuantity.text.asIntegerJMT;
	endif;
	if self.cmbPermitType.listIndex &gt; 0 then
		permitType := self.cmbPermitType.itemData[self.cmbPermitType.listIndex];
	else
		permitType := INV_WO_PERMIT_MANUALETMAL;
	endif;
	if _wodtl.myVoyageCargoRequest &lt;&gt; null then
		permitType := 0;
	endif;
	
	
	if self.cmbLoadPort.listIndex &gt; 0 then
		loadPort := self.cmbLoadPort.listObject.CM_Port.code;
	endif;
	
	bolNumber := self.txtBOLNumber.text.toUpper;
	
	estStartTS.setDate(self.txtEstStartDate.getDate());	
	estStartTS.setTime(self.txtEstStartTime.getTime());	
	estStartTS  := self.localToSystemTime(estStartTS);	
	
	estEndTS.setDate(self.txtEstEndDate.getDate());	
	estEndTS.setTime(self.txtEstEndTime.getTime());
	estEndTS := self.localToSystemTime(estEndTS);	
	
	create resourceUsedSet transient;
	if not self.createResourceUsedPxys( self.tblResources, resourceUsedSet ) then
		return false;
	endif;
	
	_wodtl.setProxyWodCargoRequest(	dischargePort,
									imexStatus,
									self.txtNumGangs.text.Integer,
									quantity,
									volume,
									totalWeight,
									transferType,
									cargoWeight,
									tareWeight,
									cargoSubType,
									cargoType,
									commodity,
									consignee,
									consignor,
									freightFwdr,
									location,
									operator,
									workPoint,
									allFiles,
									permitType,	
									loadPort,	
									bolNumber,	
									estStartTS,	
									estEndTS	
									);
									
	_wodtl.setSpecialStow( specialStow );
	if _wodtl.myVoyageCargoRequest &lt;&gt; null then
		berth := self.cmbBerthCR.listObject.HMS_Berth;
		_wodtl.myVoyageCargoRequest.setMyBerth( berth );
	endif;
	
	return true;
epilog
	delete allFiles;
	
	if not resourceUsedSet.isEmpty then
		resourceUsedSet.purge();
	endif;
	delete resourceUsedSet;
end;</source>
        <access>protected</access>
        <Parameter name="_wodtl" type="CM_WodCargoRequest" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveExtension" id="3a0cf401-b3d2-44e7-9e5c-7f86ff27c1b1">
        <source>doSaveExtension(_wodtl : CM_WodExtension input):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
28 April 2022	navgm20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	occursOn : TimeStamp;
	resourceUsedSet : HMS_ResourceUsedSet;

begin
	occursOn.setDate(self.txtMoveOnDateNew.getDate);
	occursOn.setTime(self.txtMoveOnTimeNew.getTime);					
	_wodtl.setProxyWodExtension(occursOn, self.chkHasRamp.value);			
	
	create resourceUsedSet transient;
	if not self.createResourceUsedPxys( self.tblResources, resourceUsedSet ) then
		return false;
	endif;
	
	_wodtl.setMarineDetsFromResourceUsed( resourceUsedSet );
	return true;
epilog

	if not resourceUsedSet.isEmpty then
		resourceUsedSet.purge();
	endif;
	delete resourceUsedSet;

end;</source>
        <access>protected</access>
        <Parameter name="_wodtl" type="CM_WodExtension" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveHMSRequestCancel" id="67024fbb-966c-43dd-bc95-b0039e4e57e3">
        <source>doSaveHMSRequestCancel(_wodtl : CM_WodHMSRequestCancel input):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
28 April 2022	navgm20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	workOrder : CM_WorkOrderVoyage;

begin
	workOrder := self.cmbWorkOrderC.listObject.CM_WorkOrderVoyage;
	
	_wodtl.setProxyWodHMSRequestCancel(workOrder);
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wodtl" type="CM_WodHMSRequestCancel" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveMarineDepart" id="ca3b4d7c-b16c-44b5-a804-936bf8fc2fbb">
        <source>doSaveMarineDepart( _wodtl : CM_WodMarineServicesDepart input ):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
28 April 2022	navgm20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	resourceUsedSet : HMS_ResourceUsedSet;
	reqByTS : TimeStamp;
	towingVoyage : CM_Voyage;

begin

	create resourceUsedSet transient;

	towingVoyage := self.cmbTowVoyageMD.listObject.CM_Voyage;	
	if towingVoyage &lt;&gt; null and towingVoyage = self.myVoyage then
		app.raiseCMException(Voyage_not_itself, null, null);
		return false;
	endif;
	
	if not self.createResourceUsedPxys( self.tblResources, resourceUsedSet ) then
		return false;
	endif;
	
	_wodtl.setMarineDetsFromResourceUsed( resourceUsedSet );
	
	_wodtl.setPxyMarineDetails( self.txtDraftAftMD.text.Decimal,	//_draftAft : Decimal;
								self.txtDraftFwdMD.text.Decimal,	//_draftFwd : Decimal;
								self.txtBowMarkToMD.text.Decimal	//_bowMarkTo : Decimal
								);
	
	_wodtl.setTowingVoyage(towingVoyage);
	return true;
epilog

	if not resourceUsedSet.isEmpty then
		resourceUsedSet.purge();
	endif;
	delete resourceUsedSet;
end;</source>
        <access>protected</access>
        <Parameter name="_wodtl" type="CM_WodMarineServicesDepart" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveMarineInitial" id="16c7657d-4eec-4d0b-908e-0294f98bd9f7">
        <source>doSaveMarineInitial( _wodtl : CM_WodMarineServicesInitial input ):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
28 April 2022	navgm20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	berth : HMS_Berth;
	resourceUsedSet : HMS_ResourceUsedSet;
	reqByTS : TimeStamp;
	wodVoyageCargoRequest : CM_WodVoyageCargoRequest;
	towingVoyage : CM_Voyage;

begin
	
	berth := self.cmbBerthMI.listObject.HMS_Berth;
	
	create resourceUsedSet transient;
	if not self.createResourceUsedPxys( self.tblResources, resourceUsedSet ) then
		return false;
	endif;
	
	//20 Sep 2018	NDL	TFS 40810
	towingVoyage := self.cmbTowVoyageMI.listObject.CM_Voyage;	
	if towingVoyage &lt;&gt; null and towingVoyage = self.myVoyage then
		app.raiseCMException(Voyage_not_itself, null, null);
		return false;
	endif;
	
	//31 Jul 2018	NDL	TFS 39930
	if self.myVoyage &lt;&gt; null then
		wodVoyageCargoRequest := self.myVoyage.allWorkOrders.getWorkOrderDetailOfType(WO_TASK_CARGOINITIAL).CM_WodVoyageCargoRequest;
	endif;
	
	
	_wodtl.setPxyMarineDetails(berth,
		self.txtDraftAftMI.text.Decimal,
		self.txtDraftFwdMI.text.Decimal,
		self.txtBowMarkToMI.text.Decimal,
		self.chkHasRampMI.value,
		self.optStarboardMI.value);

	_wodtl.setMarineDetsFromResourceUsed( resourceUsedSet );
		
	_wodtl.setTowingVoyage(towingVoyage);
	return true;
epilog

	if not resourceUsedSet.isEmpty then
		resourceUsedSet.purge();
	endif;
	delete resourceUsedSet;
end;</source>
        <access>protected</access>
        <Parameter name="_wodtl" type="CM_WodMarineServicesInitial" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSavePermitRequest" id="c6411531-e7cd-4268-a2f8-b564b1fabe74">
        <source>doSavePermitRequest(_wodtl : CM_WodPermitRequest input):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason 
28 April 2022	navgm20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	relatedWOD : CM_WorkOrderVoyageDtl;
	proxywod : CM_WodCargoRequest;
	job : CM_VoyageHoldJob;
	rowIndex, posUnit: Integer;
	cargo : CM_TrackedItem;
	ct			: CM_CargoType;
	weight : Decimal [14,4];
	quantity, trsfrTypeInt, gangs : Integer;
	trsfrTypeStr, unit: String;
	workPoint : CM_WorkPoint;
	measureType : CM_MeasurementType;
	weightStr : String;
begin
	if self.cmbRelatedWO.visible then
		relatedWOD:=self.cmbRelatedWO.listObject.CM_WorkOrderVoyageDtl;
	endif;
	
	_wodtl.setProxyPermitRequest(self.cmbPermitType.listData,self.cmbPermitFor.listData,self.cmbPermitOperator.listObject.CM_Operator,relatedWOD);
	
	_wodtl.myParent.setLengthOfTime(self.txtPermitTotalDays.text.Decimal);
	
	if _wodtl.allCargoDetails.isEmpty() then
		foreach rowIndex in 1 to self.tblOOWConfirm.rows do
			if rowIndex &lt;= self.tblOOWConfirm.fixedRows then
				continue;
			endif;
			job := self.tblOOWConfirm.accessRow( rowIndex ).itemObject.CM_VoyageHoldJob;
			
			if job = null then
				continue;
			endif;
			
			cargo:=job.workListEntries.first.myTrackedItem;
			
			if cargo = null then
				continue;
			endif;
			
			ct := cargo.myCargoType;
			
			create proxywod transient;
			if ct &lt;&gt; null and  ct.isBulkMulti then
				weightStr := self.tblOOWConfirm.accessCell( rowIndex, AmountCol ).text;
				quantity := 0;
				
				if ct.isBulkByWeight then
					measureType:=ct.myWeightMeasurementType;
				elseif ct.isBulkByVolume then
					measureType:=ct.myVolumeMeasurementType;
				endif;
				
				weight := weightStr.asDecimalJMT; // DEFAULT
				if measureType &lt;&gt; null then
					unit := measureType.shortName;
					posUnit := weightStr.pos(unit,1);
					if posUnit &gt; 0 then
						weight := weightStr[1:posUnit].trimBlanks.asDecimalJMT;
					endif;
					weight := weight * measureType.conversionRate;
				
				endif;
				
				
			else
				quantity := self.tblOOWConfirm.accessCell( rowIndex, AmountCol ).text.Integer;		
				weight := 0;
			endif;
			trsfrTypeStr := self.tblOOWConfirm.accessCell( rowIndex, TransferTypeCol ).text;
			trsfrTypeInt := app.vesselAccessTypeStrToEnum(trsfrTypeStr);
			workPoint :=  self.myTerminal.allWorkPointsByCode[self.tblOOWConfirm.accessCell( rowIndex, WPCol ).text].CM_WorkPoint; 
			gangs := self.tblOOWConfirm.accessCell( rowIndex, GangsCol ).text.Integer;

			proxywod.setProxyForPermit(weight,quantity,trsfrTypeInt,workPoint,gangs, cargo);
			_wodtl.allCargoDetails.add(proxywod);
			
		endforeach;	
	else // UPDATE EXISTING
		foreach proxywod in _wodtl.allCargoDetails	discreteLock do : outerloop
		
			foreach rowIndex in 1 to self.tblOOWConfirm.rows do
				if rowIndex &lt;= self.tblOOWConfirm.fixedRows then
					continue;
				endif;
				job := self.tblOOWConfirm.accessRow( rowIndex ).itemObject.CM_VoyageHoldJob;
				
				if job = null then
					continue;
				endif;
				
				cargo:=job.workListEntries.first.myTrackedItem;

				if cargo.id = proxywod.taskID then
					ct := cargo.myCargoType;

					if ct &lt;&gt; null and  ct.isBulkMulti then
						if ct.isBulkByWeight then // --&gt; TFS 45375
							measureType := ct.myWeightMeasurementType;
						elseif ct.isBulkByVolume then
							measureType := ct.myVolumeMeasurementType;
						endif; // &lt;-- TFS 45375
						weight := self.tblOOWConfirm.accessCell( rowIndex, AmountCol ).text.Decimal * measureType.conversionRate; // TFS 45375
						quantity := cargo.totalQuantity;
					else
						quantity := self.tblOOWConfirm.accessCell( rowIndex, AmountCol ).text.Integer;		
						weight := cargo.totalWeight;
					endif;
					
					trsfrTypeStr := self.tblOOWConfirm.accessCell( rowIndex, TransferTypeCol ).text;
					trsfrTypeInt := app.vesselAccessTypeStrToEnum(trsfrTypeStr);
					workPoint :=  self.myTerminal.allWorkPointsByCode[self.tblOOWConfirm.accessCell( rowIndex, WPCol ).text].CM_WorkPoint; 
					gangs := self.tblOOWConfirm.accessCell( rowIndex, GangsCol ).text.Integer;
		
					proxywod.setProxyForPermit(weight,quantity,trsfrTypeInt,workPoint,gangs, cargo);
					
					continue outerloop;
				endif;
				
			endforeach;
			
			
		endforeach;
	
	endif;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_wodtl" type="CM_WodPermitRequest" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveReqByDT" id="2b6bf2b9-dd8c-4754-84dd-42322cec1c6e">
        <source>doSaveReqByDT(_wodtl : CM_WorkOrderDtl input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 March 2023	navhl20	ChangeRequest 57301:[57303] EUP - [Framework] - Improve Audits on Work orders

*/

vars
	reqdDT 		: TimeStamp; 
begin
	if self.txtJobRequiredByDT.text.asDateJMT().isValid then						//24.01.2023 navma1 #56141 Task#56147
		reqdDT.setDate(self.txtJobRequiredByDT.text.asDateJMT());
		reqdDT.setTime(self.txtJobRequiredByTM.text.asTimeJMT());
		reqdDT := self.localToSystemTime(reqdDT);
	
	else
		reqdDT := null;
	endif;
	
	_wodtl.setProxyReqByDT(reqdDT);
epilog

end;</source>
        <Parameter name="_wodtl" type="CM_WorkOrderDtl" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSaveShiftMovement" id="e2beccd4-d2ae-4ac3-a470-a50836bb5bfd">
        <source>doSaveShiftMovement(_wodtl : CM_WodShiftMovement input): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
28 April 2022	navgm20	ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI

*/

vars
	occursOn : TimeStamp;
	serverOccursOn : TimeStamp;
	cargoRequests : CM_WodCargoRequestSet;
	prevMove : HMS_VoyageMovement;
	previousBerth,
	currentBerth	: HMS_Berth;
	seaHarbourRegion : HMS_HarbourRegion;
	seaHRArrivalBerth : HMS_Berth;
	towingVoyage : CM_Voyage;
	resourceUsedSet : HMS_ResourceUsedSet;	
	berthArrival : TimeStamp;	
	serverBerthArrival : TimeStamp;	

begin
	create cargoRequests transient;
	occursOn.setDate(self.txtMoveOnDate.getDate);
	occursOn.setTime(self.txtMoveOnTime.getTime);
	serverOccursOn := occursOn.localToSystemTimeUsingObject(self.myTerminal);
	if self.myMovement &lt;&gt; null then
		prevMove := self.myMovement.getMovementPrevious.HMS_VoyageMovement;
	endif;
	if prevMove &lt;&gt; null then
		previousBerth := prevMove.getMyBerth;
	else
		if self.myVoyage &lt;&gt; null then															
			prevMove := self.myVoyage.getMovementForDateTime(serverOccursOn);					
			if prevMove &lt;&gt; null then															
				previousBerth := prevMove.getMyBerth;											
			endif;																				
		endif;																					
		if previousBerth = null then															
			seaHarbourRegion := app.myRoot.getSeaHarbourRegion;
			if seaHarbourRegion &lt;&gt; null then
				seaHRArrivalBerth := seaHarbourRegion.getArrivalBerth();
				if seaHRArrivalBerth &lt;&gt; null then
					previousBerth := seaHRArrivalBerth;
				endif;
			endif;
		endif;																					
	endif;
	
	towingVoyage := self.cmbTowVoyage.listObject.CM_Voyage;	
	if towingVoyage &lt;&gt; null and towingVoyage = self.myVoyage then
		app.raiseCMException(Voyage_not_itself, null, null);
	endif;
	

	create resourceUsedSet transient;
	if not self.createResourceUsedPxys( self.tblResources, resourceUsedSet ) then
		return false;
	endif;
	
	
	berthArrival.setDate(self.txtBerthArrDate.getDate);
	berthArrival.setTime(self.txtBerthArrTime.getTime);
	serverBerthArrival := berthArrival.localToSystemTimeUsingObject(self.myTerminal);
	currentBerth		:= self.cmbToBerth.listObject.HMS_Berth;
	
	_wodtl.setProxyWodShiftMovement(self.txtBowMarkTo.text.Decimal,
									self.txtDraftAft.text.Decimal,
									self.txtDraftFwd.text.Decimal,
									serverOccursOn,
									self.txtLineRelative.text.Integer,
									self.txtLaunchRelative.text.Integer,
									self.txtTugRelative.text.Integer,
									self.txtSternMarkTo.text.Decimal,
									previousBerth,
									currentBerth,
									cargoRequests,
									towingVoyage,
									self.chkHasRampSM.value, 
									self.optStarboardSM.value,
									serverBerthArrival	
									);
									
	_wodtl.setMarineDetsFromResourceUsed( resourceUsedSet );
									
	return true;
epilog
	delete cargoRequests;
	if not resourceUsedSet.isEmpty then
		resourceUsedSet.purge();
	endif;
	delete resourceUsedSet;	
end;</source>
        <access>protected</access>
        <Parameter name="_wodtl" type="CM_WodShiftMovement" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveTask" id="98ff65bd-01ce-4a72-a327-b6bd08c3954c">
        <updating/>
        <source>doSaveTask():Boolean updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
21 Apr 2022	navcs2		ChangeRequest 52351: MTN - Work Order Maintenance Refactor - UI
24 Jan 2023	navma1  	ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
*/

vars

begin
	if self.workOrderType = WorkOrderMode_Cargo then
		if not self.doSaveCargoProxy() then
			return false;
 		endif;
	elseif self.workOrderType = WorkOrderMode_Voyage then
		if not self.doSaveVoyageProxy() then
			return false;
		endif;
	elseif self.workOrderType = WorkOrderMode_ToDo then
		if not self.doSaveToDoWorkOrderProxy() then
			return false;
		endif;
	endif;
	
	return true;
	
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveTimeChange" id="22d698ed-5e8f-49ec-ab5e-d4559d015683">
        <source>doSaveTimeChange(_wodtl : CM_WodTimeChange input):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 April 2022	navgm20	Initial creation  TFS 52351

*/

vars
	workOrder : CM_WorkOrderVoyage;
	occursOn  : TimeStamp;

begin
	occursOn.setDate(self.txtMoveOnDateTC.getDate);
	occursOn.setTime(self.txtMoveOnTimeTC.getTime);
	if self.cmbWorkOrder.listIndex &gt; 0 then
		workOrder := self.cmbWorkOrder.listObject.CM_WorkOrderVoyage;
	endif;
	
	_wodtl.setProxyWodTimeChange(occursOn, null, workOrder);
	return true;
epilog

end;</source>
