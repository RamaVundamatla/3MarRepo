<Class name="CM_CargoChainFunctionAgent" id="0dac1688-3787-47c9-b0be-35369e6c952f">
    <superclass name="CM_Agent"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <JadeMethod name="getCargoChainEventMap" id="231a6ca3-3a02-4e66-b890-2282ef9a804e">
        <source>getCargoChainEventMap(_eventName	: String; 
					  _terminal 	: CM_Terminal;
					  _baseEndPoint : String): CM_CargoChainEventMapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Nov 2019 cnwma1 ChangeRequest 45285: JMT - Cargo Chain API V2 - Process Events (AAT)

*/

vars
	extDef	  	    : CM_ExternalWebServiceDef;
	cargoChainMap   : CM_CargoChainEventMapping;
	cargoChainDef   : CM_CargoChainServiceDef;
begin
	if not _terminal.isCargoChainEnabled then
		return null;
	endif;
	
	foreach extDef in CM_CargoChainServiceDef.instances discreteLock do   
		if extDef.isKindOf(CM_CargoChainServiceDef) then
			if extDef.CM_CargoChainServiceDef.baseEndpoint = _baseEndPoint then
				cargoChainDef := extDef.CM_CargoChainServiceDef;
				break;
			endif;
		endif;
	endforeach;
	
	
	foreach cargoChainMap in cargoChainDef.allCargoChainEventMappings discreteLock do
		
			if cargoChainMap.myParameters &lt;&gt; null then
			
				if cargoChainMap.eventName = _eventName  then
					return cargoChainMap;
				endif;
				
			endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <Parameter name="_eventName" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_baseEndPoint" type="String"/>
        <ReturnType type="CM_CargoChainEventMapping"/>
    </JadeMethod>
</Class>
