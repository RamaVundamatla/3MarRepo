    <JadeMethod name="buildComboAreas" id="6b3a7ce0-d251-4028-835f-b6713eba0520">
        <source>buildComboAreas();
// ---------------------------------------------------------------------------
// Created:		December  2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lObj	: CM_Object;
	saveObj			: Object;
	idx				: Integer;
	lRailJobSheet	: CM_RailJobSheet;
	lRailJSIO			: CM_RailJSInOut;
	lRailJSIORake	: CM_RailJSInOutRake;
	lRail				: CM_TerminalArea;
	termAreaDict				: CM_TAByIdDict;
begin
	lRailJobSheet := self.myTerminal.myRailJobSheet;
	self.cmbRailArea.clear;
	termAreaDict := self.myTerminal.getAllTAsOfType(TA_TYPE_RAILWAY_TRACK);

	foreach lRail in termAreaDict do // RR1 RR2
		idx := self.cmbRailArea.addItem(lRail.id);
		self.cmbRailArea.itemObject[idx] := lRail;
	endforeach;
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="buildComboDestTerm" id="655270e2-a1e9-4c94-8ccd-4db120f5a333">
        <source>buildComboDestTerm();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 September 2016	cnwmp6	Initial creation

*/

vars
	term: CM_Terminal;
	idx: Integer;
	
begin

	self.cmbDestTerm.clear();
	
	if not app.isInterTerminalTransferEnabled then
		return;
	endif;
	
	if self.myTerminal.allTerminalsForRelease.isEmpty then
		return;
	endif;
	
	self.cmbDestTerm.addItem("");
	
	foreach term in self.myTerminal.allTerminalsForRelease do
		idx := self.cmbDestTerm.addItem(term.name);
		self.cmbDestTerm.itemObject[idx] := term;
	endforeach;

	if self.myCurrentWagon.myDestinationTerminal &lt;&gt; null then
		idx := self.cmbDestTerm.findObject(self.myCurrentWagon.myDestinationTerminal);
		if idx &gt; -1 then
			self.cmbDestTerm.listIndex := idx;
		endif;
	endif;

/*
	create validTerms transient;
	
	ti := self.myCurrentWagon.allReportTIsOutwards.first();
	if ti &lt;&gt; null then
		interRelease := ti.getInterTerminalBulkRelease();
		if interRelease &lt;&gt; null then
			config := interRelease.myInterTerminalConfig;
			if config &lt;&gt; null then
				config.getAllTargetTerminals(validTerms);
			endif;
		endif;
	else
		app.myRoot.allTerminals.copy(validTerms);
	endif;

	foreach term in validTerms do
		termId := term.name;
		idx := self.cmbDestTerm.addItem(termId);
		self.cmbDestTerm.itemObject[idx] := term;
				
		if self.myCurrentWagon.myDestinationTerminal = term then
			listIndex := idx;
		endif;
	endforeach;

	foreach listIndex in 1 to self.cmbDestTerm.listCount do
		if self.cmbDestTerm.itemObject[listIndex].display = self.myCurrentWagon.myDestinationTerminal.display then
			self.cmbDestTerm.listIndex := listIndex;
			break;
		endif;
	endforeach;
*/
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="buildComboPosition" id="5dc53259-afa5-4172-b755-f20fc89c3aa4">
        <updating/>
        <source>buildComboPosition(pRail : CM_Rail) updating;
// ---------------------------------------------------------------------------
// Created:		December  2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lRow, lCol,idx, listindex	: Integer;
	lID				: String;
	lRailLine	: CM_RailLine;
begin
	self.cmbRake.clear;
	if pRail = null then
		return;
	endif;
	
	foreach lRow in 1 to  pRail.allRailLinesByIndex.size do
		lRailLine := pRail.allRailLinesByIndex[lRow];
		foreach lCol in 1 to lRailLine.maximumWagons do
			lID := lRailLine.getIdString.trimBlanks &amp; ' ' &amp; lCol.String.padLeadingZeros(2);
			idx := self.cmbRake.addItem(lID);
			self.cmbRake.itemObject[idx] := lRailLine;
			self.cmbRake.itemData[idx] := lCol;
			
			if self.rakePos = lCol and lRailLine = self.myRailRake then
				listindex := idx;
			endif;
		endforeach;
	endforeach;
	
	if listindex &gt; 0 then
		self.cmbRake.listIndex := listindex;
	endif;
end;</source>
        <Parameter name="pRail" type="CM_Rail"/>
    </JadeMethod>
    <JadeMethod name="buildComboTrain" id="cebcbf4e-fb20-416e-a2ae-b1ce1f5dcba4">
        <source>buildComboTrain(_incoming : Boolean)protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 June 2009	cnwmd1	Initial creation

*/

vars
	combo : CMUI_ComboBox;
	train : CM_Train;
begin
	if _incoming then
		combo := self.cmbTrainIncoming;
		train := self.myCurrentTrain;
	else
		combo := self.cmbTrainOutgoing;
	endif;
	
	self.myAssistant.comboBoxTrain(combo, train, true, false, false);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_incoming" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="buildComboWagon" id="32d343fe-2761-4f9d-b637-f054ae988df9">
        <source>buildComboWagon()protected;
// ---------------------------------------------------------------------------
// Created:		December  2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 12 Oct 2016	cnwrs1	TFS 2829 Cams processing failure with Train Events
// ---------------------------------------------------------------------------

vars
	wagon : CM_Wagon;
	wagonSet : CM_WagonSet;
	invalidObject : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, self.myTrainForWagonCombo, invalidObject);

	self.cmbWagon.clear;

	if myTrainForWagonCombo &lt;&gt; null then
		create wagonSet transient;
		foreach wagon in self.myTrainForWagonCombo.allWagonsByIdInward do
			wagonSet.add(wagon);
		endforeach;
		foreach wagon in self.myTrainForWagonCombo.allWagonsByIdOutward do
			if not wagonSet.includes(wagon) then
				wagonSet.add(wagon);
			endif;
		endforeach;
		foreach wagon in wagonSet do
			self.cmbWagon.itemObject[self.cmbWagon.addItem(wagon.getDisplayDetails(false))] := wagon;
		endforeach;
	else
		foreach wagon in self.myTerminal.allWagons do
			self.cmbWagon.itemObject[self.cmbWagon.addItem(wagon.getDisplayDetails(false))] := wagon;
		endforeach;
	endif;
epilog
	delete wagonSet;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="buildComboWagonPrenote" id="87967973-f6e7-41c3-8165-37184ed535c0">
        <source>buildComboWagonPrenote();
// ---------------------------------------------------------------------------
// Created:		December  2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	wagon 			: CM_Wagon;
	idx, wagonIdx 	: Integer;
	wgnClass 		: CM_WagonClass;
	existingWagonId	: String;
	
begin
	existingWagonId := self.cmbWagonPrenote.text;	// 22/02/2010 cnwar2 #22416

	self.cmbWagonPrenote.clear;
	self.cmbWagonPrenote.style := ComboBox.Style_DropDown;
	self.cmbWagonPrenote.filterIgnore := true; // ### TFS 55105 17NOV2022 NAVAB1
	
	if self.cmbWagonClass.listObject &lt;&gt; null then
		wgnClass := self.cmbWagonClass.listObject.CM_WagonClass;
	endif;		
	
	if self.myCurrentTrain &lt;&gt; null then
		// unconfirmed prenote wagons
		foreach wagon in self.myTerminal.allWagons do
			if wagon.myRailLine = null then
				if wagon.myTrainInwards = null 
				or ( (wagon.myTrainInwards &lt;&gt; null) and (wagon.myTrainInwards = self.myCurrentTrain  or wagon.myTrainInwards.isNullTrain()) ) then // PAR 20408
					if self.checkWagonClass(wagon,wgnClass) then //cnwas3 par 21926
						idx := self.cmbWagonPrenote.addItem(wagon.id);
						self.cmbWagonPrenote.itemObject[idx] := wagon;
					endif;
				endif;
			endif;
		endforeach;
		
		if self.myCurrentWagon &lt;&gt; null then
			if self.cmbWagonPrenote.findObject(self.myCurrentWagon) &gt; 0 then
				self.cmbWagonPrenote.listObject := self.myCurrentWagon;
			else
				self.cmbWagonPrenote.addItemObject(self.myCurrentWagon.id, self.myCurrentWagon);
			endif;
		endif;
	else
		foreach wagon in self.myTerminal.allWagons do
			if wagon.myRailLine = null then // prenoted via TI prenote screen
				if self.checkWagonClass(wagon,wgnClass) then	//cnwas3 par 21926
						idx := self.cmbWagonPrenote.addItem(wagon.id);
						self.cmbWagonPrenote.itemObject[idx] := wagon;
				endif;
			else
				if self.myRailRake &lt;&gt; null and wagon.myRailLine &lt;&gt; null then
					if self.myRailRake &lt;&gt; wagon.myRailLine then
						continue;
					endif;
					if self.rakePos &lt;&gt; null then
						wagonIdx := self.myRailRake.allWagons.indexOf(wagon);
						if wagonIdx &lt;&gt; self.rakePos then
							continue;
						endif;
					endif;
					if self.checkWagonClass(wagon,wgnClass) then//cnwas3 par 21926
						idx := self.cmbWagonPrenote.addItem(wagon.id);
						self.cmbWagonPrenote.itemObject[idx] := wagon;
					endif;
				endif;			
			endif;
		endforeach;
	endif;
	
	if self.myCurrentWagon &lt;&gt; null then
		idx := self.cmbWagonPrenote.findObject(self.myCurrentWagon);
		if idx &gt; 0 then
			self.cmbWagonPrenote.setIndex(idx);
			self.cmbWagonPrenote.listObject := self.myCurrentWagon;
			self.cmbWagonPrenote.lostFocus(self.cmbWagonPrenote);
		endif;
		
	elseif existingWagonId &lt;&gt; null then					// 22/02/2010 cnwar2 #22416
		self.cmbWagonPrenote.text := existingWagonId;	// 22/02/2010 cnwar2 #22416
	endif;

end;</source>
    </JadeMethod>
