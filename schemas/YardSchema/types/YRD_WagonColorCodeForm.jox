*/
vars

begin
	self.unloadForm();

end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="7baf006b-b612-4b96-87f8-5bea652f7283">
        <updating/>
        <source>doBaseFormSave() updating, protected;
/*
----------   ----------  --------------------------------------------------
Created:	15 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	criteria					: CM_YACriteria;
	railAllocTemplate			: CM_RailAllocation;
	wagon						: CM_Wagon;
	result						: Integer;
	wagCode : String;
begin
	self.allWagons.rebuild();
	if self.allWagons.isEmpty then
		app.msgBox('The collection of wagons to colour-code is now empty. Another user may have cleared the associated train or rail line. Update cannot proceed.','Error: No Wagons to update', MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	wagon := self.allWagons.first;
	if wagon &lt;&gt; null then
		wagCode := wagon.id;
	endif;
	create railAllocTemplate transient;
	
	criteria := self.createCriteria(self.cmbFreightFoward, YACriteriaType_FreightForward);
	if criteria &lt;&gt; null then
		criteria.setYardAllocation(railAllocTemplate);
	endif;
	
	criteria := self.createCriteria(self.cmbDestination, YACriteriaType_DestinationPort);
	if criteria &lt;&gt; null then
		criteria.setYardAllocation(railAllocTemplate);
	endif;
	
	criteria := self.createCriteria(self.cmbReleaseNo, YACriteriaType_RailReleaseReq);
	if criteria &lt;&gt; null then
		criteria.setYardAllocation(railAllocTemplate);
	endif;
	
	criteria := self.createCriteria(self.cmbConsignee, YACriteriaType_Consignee); //19/05/2009, cnwmd1, CCMS 1067, Par 19710
	if criteria &lt;&gt; null then
		criteria.setYardAllocation(railAllocTemplate);
	endif;
	
	railAllocTemplate.setProxy(wagCode,'Rail Colour Coding',
								null,
								YAFillOption_InOrder,
								YAFillOption_InOrder,
								YAExpiryType_Never,
								null,
								self.clColour.getColor, 			//+ cnwmd1, CCMS 1067, Par 19710
								//0,//colour					//- cnwmd1, CCMS 1067, Par 19710
								null,  //cnwjo3 par 24145
								YAOverlap_Never,//allow others
								YANoLocation_Continue,
								null,
								0, //priority adjustment
								false,
								false,
								null,
								null,
								true,
								self.myTerminal);
								
								
	
	while true do
		app.myTrxUA.trxUpdateWagonRailAlloc(self.allWagons, railAllocTemplate, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			break;
		else
			result := app.showErrorWarningDialog('Wagon auto-allocation rules update', app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
	endwhile;
	
	self.unloadForm;
epilog
	delete railAllocTemplate;
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadCmbDestinationPort" id="a06072fb-dd8d-49f1-83e9-1f5851327acc">
        <source>loadCmbDestinationPort() protected;
/*
----------   ----------  --------------------------------------------------
Created:	14 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	cmb					: CMUI_ComboBox;
	destPort			: CM_Port;
begin
	cmb := self.cmbDestination;
	cmb.clear();
	cmb.sorted := false;
		
	if self.myRailAllocation &lt;&gt; null then
		destPort := self.myRailAllocation.getDestinationPort();
	endif;
	
	self.myAssistant.comboBoxDestination(cmb, destPort);
	
end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadCmbFreightForward" id="35b2dc60-1f96-4bc2-aa15-b1ab9b5fb6a1">
        <source>loadCmbFreightForward() protected;
/*
----------   ----------  --------------------------------------------------
Created:	14 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	
	consign		: CM_ConsigneeConsignor;
begin
	self.cmbFreightFoward.setType(FREIGHT_FORWARDER); //+ 19/05/2009, cnwmd1, CCMS 1067, Par 19710
	if self.myRailAllocation &lt;&gt; null then
		consign := self.myRailAllocation.getFreightForwarder();
		self.cmbFreightFoward.setObject(consign);
	endif;
epilog

end;


</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadCmbReleaseRequest" id="bade1cf8-c6ab-431d-a2f9-24d99580888f">
        <source>loadCmbReleaseRequest() protected;
/*
----------   ----------  --------------------------------------------------
Created:	14 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
14/07/2025		naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  		
----------   ----------  --------------------------------------------------
*/
vars
	cmb					: CMUI_ComboBox;
	defaultRelease,
	release				: CM_BulkRelease;
	dict				: CM_BulkReleaseByTypeStCodeDict;
	iter				: Iterator;
	typeKey,
	statusKey			: Integer;
	codeKey				: String;
	dateReqKey			: TimeStamp;
begin
	cmb := self.cmbReleaseNo;
	cmb.clear();
	cmb.sorted := false;
		
	if self.myRailAllocation &lt;&gt; null then
		defaultRelease := self.myRailAllocation.getReleaseRequest();
	endif;
	
	dict := self.myTerminal.allBulkReleaseByTypeByStByCd;
	iter := dict.createIterator;
	
	dict.startKeyGeq(BR_TYPE_RAIL,BR_PENDING,null,null, iter);
	
	while iter.next(release) do
		iter.getCurrentKeys(typeKey, statusKey, codeKey, dateReqKey);  //MTN-35226
		
		if typeKey &lt;&gt; BR_TYPE_RAIL then
			break;
		endif;
		
		if statusKey &lt;&gt; BR_PENDING and statusKey &lt;&gt; BR_ACTIVE then
			continue;
		endif;
		
		
		cmb.itemObject[cmb.addItem(self.myAssistant.displayEntryBulkRelease(release))] := release;		
	endwhile;
	
	cmb.listIndex := cmb.findObject(defaultRelease);
	
epilog
	delete iter;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadConsignee" id="ed7fb530-3a5c-4bb9-ab28-45f57e73fb85">
        <source>loadConsignee() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 May 2009	cnwmd1	Initial creation - CCMS 1067, Par 19710

*/

vars
	consign		: CM_ConsigneeConsignor;
begin
	self.cmbConsignee.setType(CONSIGNEE);
	if self.myRailAllocation &lt;&gt; null then
		consign := self.myRailAllocation.getConsignee();
		self.cmbConsignee.setObject(consign);
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
