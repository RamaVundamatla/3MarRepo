        <source>setDetails(_alarms, _connect, _disconnect, _jobs, _monitoring : Integer; _personInYard : Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/10/2020	jlgdap1		Initial creation TFS 49227 MTN Navis API - nReefer API
