    <JadeMethod name="create" id="3e13479a-4fd1-440d-9922-16e57f392ae9">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     26 November 2008 by concms1:1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26/07/2010	cnwcs5		ccms 1156 / par 23706 Show repeated row values
// ---------------------------------------------------------------------------
vars

begin
	self.permissionView  		:= PmSummaryDefView;
	self.permissionMaint 		:= PmSummaryDefMaint;	// do not really need this one.
	
	create self.myOutputFormatAgent transient;
	self.setHideRepeatedRowValues (true);				// ccms 1156 /par 23706
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="e69d1b80-acd2-4afb-96bd-6877c7e56b4c">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>delete() updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:     02 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	delete self.myOutputFormatAgent;
	
	if global.isValidObject( self.myProxyOutputFormat ) then
		delete self.myProxyOutputFormat;
	endif;
	
	//30 Nov 2009	NDL	CCMS 1028
	if not self.transientsToDelete.isEmpty then
		self.transientsToDelete.purge;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displaySelectorResults" id="2d5ef85c-8ecd-43b0-a296-eaab08c135cf">
        <updating/>
        <source>displaySelectorResults( _coll : Collection; _mode : Integer ) updating;
// ---------------------------------------------------------------------------
// Created:     03 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	// clear out existing display
	delete self.myOutputFormatAgent;	
	
	tblMain.rows 	:= 0;
	tblMain.columns	:= 0;
	
	// setup for new display
	create self.myOutputFormatAgent transient;
	self.myCollection.clear;
	
	_coll.copy( self.myCollection );
	
	self.doGenerateXTAB;		// add the defintion name to the form caption and generate the display.
	
epilog

end;</source>
        <Parameter name="_coll" type="Collection"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doBookingEnquiry" id="f0bbf686-8b6c-43cd-bb66-fbe71c25b58a">
        <source>doBookingEnquiry( _coll : Collection )protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 November 2009	cnwndl1	Initial creation	CCMS 1028

*/

vars

	subSys : CMUI_SubSystem;
	formCls,
	assistCls: Class;
	bookingForm : CM_TableViewForm;
	firstObject : CM_Object;
	collOfBookings : CM_BookingRefSet;
	collOfBookingItems : CM_BookingRefItemSet;
	
begin

	subSys := app.myController.allSubSystems['GateSchema'];
	if subSys &lt;&gt; null then
		subSys.getFormDetails('GTE_BookingRefMultiForm', formCls, assistCls);
	endif;
	if formCls = null or _coll = null or _coll.isEmpty then
		return;
	endif;
	bookingForm := app.loadForm(formCls, 
								assistCls, 
								false, 
								false,
								false, 
								app.myPassport.myTerminal,
								self.myMasterMenuAction ).CM_TableViewForm;	
								
	if bookingForm = null then
		return;
	endif;
	
	firstObject := _coll.first.CM_Object;
	if firstObject = null then
		return;
	endif;
	
	if firstObject.isKindOf(CM_BookingRef) then
		create collOfBookings transient;
		self.transientsToDelete.add(collOfBookings);	// so the transient gets deleted when the form closes.
		_coll.copy(collOfBookings);
		bookingForm.myCurrentObject := collOfBookings;
	elseif firstObject.isKindOf(CM_BookingRefItem) then
		create collOfBookingItems transient;
		self.transientsToDelete.add(collOfBookingItems);	// so the transient gets deleted when the form closes.
		_coll.copy(collOfBookingItems);
		bookingForm.myCurrentObject := collOfBookingItems;
	endif;
	
	bookingForm.show;
	
epilog

end;
</source>
        <access>protected</access>
        <Parameter name="_coll" type="Collection"/>
    </JadeMethod>
    <JadeMethod name="doBtnShowDefn" id="967b19a1-0156-4107-9130-b36703996ab9">
        <updating/>
        <source>doBtnShowDefn() updating, protected;

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
27 January 2009		cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)
16/12/2009			cnwcs5	ccms 1023 - snapshot summaries
*/
	
vars
	form	: CMUI_XTABDefinitionForm;
	format	: CM_OutputFormat_XTAB;
	cls		: Class;
begin

	while true do
		if self.myProxyOutputFormat.isSnapshotMode then
			cls := CMUI_XTABDefinitionFormModa_SS;
		else
			cls := CMUI_XTABDefinitionFormModal;
		endif;
		
		form	:= app.loadForm(cls,
								CMUI_Assistant,
								false,						// Maximized
								false,						// Show
								true,						// Modal
								self.myTerminal,
								null ).CMUI_XTABDefinitionForm;
		
		// set the collection and how to initially display the form
		format	:= self.myProxyOutputFormat.cloneSelf( true );
		
		form.initialise( self.myCollection, true );
		form.setOutputFormat( format, self.myRealOutputFormat, self.realFormatExpectedEdition );
		form.myParentForm := self;

		if form.showModal &lt;&gt; MsgBox_Return_OK then
			break;
		endif;
		
		// if run button on the summary definition has been pressed,
		// redisplay this form with the new proxy (which might have been changed)
		delete self.myProxyOutputFormat;
		
		self.myProxyOutputFormat	:= form.getMyProxyXTAB();
		
		self.setHideRepeatedRowValues (not self.myProxyOutputFormat.showRepeatedRowValues);	// 18/08/2010 cnwcs5 par 23706
		
		if self.doGenerateXTAB() then
			break;
		endif;
		
		// user pressed cancel during generation so redisplay defn form
		
	endwhile;
	
epilog
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doCargoEnquiry" id="bf6aa8b3-0883-4e6c-9a36-534050544eab">
        <source>doCargoEnquiry( _coll : Collection )protected;
// ---------------------------------------------------------------------------
// Created:     03 December 2008 by concms1
// Purpose:     CCMS SFW 1047 - Totals Only Lists
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
//	coll	: Collection;
	form 	: CM_ContainerEnqForm;
	ti		: CM_TrackedItem;
begin
	/*	The XTAb may be showing data from &gt; 1 terminal if the collection originated from the 
		selector.  When we open a cargo enquiry form, only data for one terminal will be displayed */
	
/*	coll := self.getCollectionForDrillDown;
	
	if coll = null or coll.isEmpty then
		return;
	endif; */
	
	ti := _coll.first.CM_TrackedItem;
	
	form := app.loadForm(CM_ContainerEnqForm, CMUI_Assistant, false, false, false, ti.myTerminal, null).CM_ContainerEnqForm;	
	
	if form = null then
		return;
	endif;
		
	form.setMyTerminal(ti.myTerminal);	
	
	form.show(); 
	form.setFilterCargoTypeId (true);
	form.displaySelectorResults(_coll, null);
end;</source>
        <access>protected</access>
        <Parameter name="_coll" type="Collection"/>
    </JadeMethod>
