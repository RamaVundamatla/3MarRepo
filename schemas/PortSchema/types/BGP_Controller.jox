    <JadeMethod name="setDisplayStringFromRequests" id="9185e01c-92a9-4c19-81c0-789bbc92ad98">
        <updating/>
        <source>setDisplayStringFromRequests() protected, updating;
// -------------------------------------------
// Created 09 September 2003 by cnwdvb1
// -------------------------------------------
// 28 Sep 2016	cnwrs1	TFS 2756 PAR38267 allow Cams to run per terminal
vars
	className,
	str,
	display		: String;
	class		: Class;
begin
	self.displayString := null;
	if not self.allRequestClassesToProcess.isEmpty then
		foreach className in self.allRequestClassesToProcess do
			class := self.getClass(className);
			if class &lt;&gt; null then
				display := class.text.cnEcGetTagValueOfName('displayShort');
				if display = null then
					display := class.text.cnEcGetTagValueOfName('display');
					if class = BGP_CamsRequest and self.BGP_GenericController.myTerminal &lt;&gt; null then
						display := display&amp;' ('&amp;self.BGP_GenericController.myTerminal.code&amp;')';
					endif;
				endif;
				if display &lt;&gt; null then
					str := str &amp; '/' &amp; display;
				endif;
			endif;
		endforeach;	
	endif;

	if str.length &gt; 1 then
		str := str[2:end];
		self.displayString := str;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
