    </ImplicitInverseRef>
    <ImplicitInverseRef name="inFile" id="e17e0ba3-e2a7-4cbe-9545-e258288841c2">
        <embedded/>
        <type name="File"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="outFile" id="e3bbbc0f-34f0-4a01-a992-f8c4d10e8d3a">
        <embedded/>
