    <JadeMethod name="valDebtorNode" id="600933bd-c23a-4351-b7ec-abac26825c4a">
        <source>valDebtorNode(pExistingDebtorNode,pProxyDebtorNode:CM_DebtorNode);
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 10/08/2018	jlgdap1		TFS 40092 PEL1 Adding Changes for Debtors
vars
	
begin
	self.raiseExceptionIfNull(pProxyDebtorNode, 'DebtorNode Proxy');
	self.raiseExceptionIfNull(pExistingDebtorNode, "DebtorNode Existing");
	pProxyDebtorNode.raiseExceptionIfNotProxy(method);
	
	pProxyDebtorNode.validateForUpdate();
	
/*	TFS 40092 Code here moved to validateForUpdate to avoid accidentally falling in to validateForCreate
	existingName := pExistingDebtorNode.name;
	newName := pProxyDebtorNode.name;

	//par 19354
	//found a debtor that has a CrLf as the last character
	if existingName[existingName.length-1:2] = CrLf then
		//new name is different (less characters)
		if existingName.length &gt; newName.length then
			//set existingName to existingName minus CrLf
			pos := existingName.length;
			crlfPos := pos;
			//remove multiple ending CrLfs.... yes, it could happen
			while crlfPos &lt;&gt; 0 do
				crlfPos := existingName.pos(CrLf,pos-2);
				if crlfPos &lt;&gt; pos then
					if crlfPos &lt;&gt; 0 then
						pos := crlfPos;
					endif;
				else
					crlfPos := 0;
				endif;
			endwhile;
			existingName := existingName[1:pos-1];
		endif;
	endif;
	
	//if pExistingDebtorNode.name = pProxyDebtorNode.name then
	//par 19354
	if existingName = newName then
		pProxyDebtorNode.validateForUpdate();
	else
		pProxyDebtorNode.validateForCreate();
	endif;*/

epilog
	
end;</source>
        <Parameter name="pExistingDebtorNode" type="CM_DebtorNode"/>
        <Parameter name="pProxyDebtorNode" type="CM_DebtorNode"/>
    </JadeMethod>
