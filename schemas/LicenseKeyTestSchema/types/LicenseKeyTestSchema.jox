<Class name="LicenseKeyTestSchema" id="c7ae4cf5-3cfe-4c50-b2d9-522184e2cdc2">
    <superclass name="JSSExtensionSchema"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <ImplicitInverseRef name="myLicense" id="482cacaa-9ddf-4bab-b44e-fde59ebf9fda">
        <embedded/>
        <type name="JSSLPublicInterface"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myTestData" id="09a0a034-ab15-4213-a2a5-d8a8976ea4bc">
        <embedded/>
        <type name="TestData"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="finalize" id="9eeab311-130a-4929-8dda-541ecaf9a485">
        <updating/>
        <source>finalize() updating;
// --------------------------------------------------------------------------------
// Created:		18 March 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	delete self.myLicense;
	
	inheritMethod();
end;</source>
    </JadeMethod>
    <JadeMethod name="initialize" id="b20e13e3-7dad-451c-addb-9d1560873ec1">
        <updating/>
        <source>initialize() updating;
// --------------------------------------------------------------------------------
// Created:		18 March 2003 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theTestData	: TestData;
	
begin
	inheritMethod();
	
	create self.myLicense transient;
	
	theTestData	:=	TestData.firstInstance();
	
	if theTestData = null then
		beginTransaction;
		create theTestData;
		commitTransaction;
	endif;
	
	self.myTestData	:=	theTestData;
	
	on Exception do self.xHandler(exception) global;
end;</source>
    </JadeMethod>
    <JadeMethod name="xHandler" id="1332cfe8-db9f-4aed-a8b8-52faca9f1644">
        <source>xHandler(pTheException:Exception):Integer;
// --------------------------------------------------------------------------------
// Created:		17 July 2002 by cnwdad1
//
// Purpose:		Exception handler to test for JSS File Manager exceptions.  If the
//				exception is not a JSS exception, then pass back to the next handler
//				in the stack (the general handler).
//
// Parameters:	pTheException - The exception to report upon.
//
// Returns:		The exception return value.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	errorCode		: Integer;
	errorMessage	: String;
	
begin
	if self.myLicense.isJSSException(pTheException) then
		errorCode		:=	pTheException.errorCode;
		errorMessage	:=	pTheException.extendedErrorText;
		
		app.msgBox(	errorMessage,
					"Error " &amp; errorCode.String,
					MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		
		return Ex_Abort_Action;
	else
		return Ex_Pass_Back;
	endif;
end;</source>
        <Parameter name="pTheException" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
