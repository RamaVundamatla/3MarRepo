    <JadeMethod name="validateForSave" id="fe1a1040-dfd2-4ff2-b5af-594cc7125edf">
        <source>validateForSave() : Boolean protected;
/* ---------------------------------------------------------------------------
Created:	15 February 2010	by cnwvu1

Purpose:	PAR 22189
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	errStr	: String;

begin

	//	Checking range and value in the range
	if not self.myProductType.validateProdAttrForRange(errStr) then
		//app.msgBox(app.getString(Enter_Codes),null, MsgBox_OK_Only);
		app.msgBox(errStr, null, MsgBox_OK_Only);
		return false;
	endif;
	
	return true;


end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
