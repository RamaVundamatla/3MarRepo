    <JadeMethod name="setMargins" id="d483195f-2794-4b76-b396-8b13ed31d536">
        <source>setMargins();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 February 2009	cnwer1	Initial creation

*/

vars
	i,
	numSheets	: Integer;
	tmpSheet	: JadeTableSheet;
begin
	
	numSheets := self.tblJobs.sheets;
	foreach i in 1 to numSheets do
		tmpSheet := self.tblJobs.accessSheet(i);
		tmpSheet.marginLeft := 2;
		tmpSheet.marginRight := 2;
		tmpSheet.marginTop := 1;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMode" id="5e81a61f-a604-4210-b98c-11e78f02b3ea">
        <updating/>
        <source>setMode() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
13 June 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	if app.myHandHeldGuiAgent.VehicleMountedGuiAgent.myVehicleMountedAgent.isRailRTQueue() then
		self.mode := self.Mode_Rail;
	else
		self.mode := self.Mode_Yard;
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupChangeQueue" id="d20c8130-62a1-4f9c-9514-b863c31646c6">
        <source>setupChangeQueue() protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
07 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	qType : Integer;
begin
	if self.isPrimaryQueue then
		lblChgQ.caption:="Change Primary Queue";
		qType:=0;
	else
		lblChgQ.caption:="Change To Secondary Queue";
		qType:=1;
	endif;
	self.cmbQueue.clear;
	app.myHandHeldGuiAgent.VehicleMountedGuiAgent.loadComboRTQueue(self.cmbQueue,qType);
	frmChgQueue.centreWindow;
	frmChgQueue.visible:=true;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="017429c0-218b-4d72-a399-4ddd927cc17e">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
30 October 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	inheritMethod();
	self.setMargins();
	self.borderStyle :=self.BorderStyle_None;
	
	//epr par 17413 2/7/08 make sure when we make these frames visible that we can see them
	// epr par 17507 15/7/08 can't open frames over textboxes jade par 48448 so only letting these frames show on shtJobs
	self.frmInfo.zOrder(1);
	self.frmInfo.parent:=self.shtJobs;
	self.frmChgQueue.zOrder(1);
	self.frmChgQueue.parent:=self.shtJobs;
	self.frmAccept.zOrder(1);
	self.frmAccept.parent:=self.shtJobs;
	
	create self.allErrorMsgs transient;
	
	self.beginNotification(app.myHandHeldGuiAgent.myNotesObj, Event_Delete_Queue_Entry, Response_Continuous , null);
	self.beginNotification(app.myHandHeldGuiAgent.myNotesObj, Event_Add_Queue_Entry, Response_Continuous , null);

	self.beginNotification(app.myHandHeldGuiAgent.myNotesObj, EVENT_MACH_BROADCAST_MSG, Response_Continuous , null);
	self.beginNotification(app.myHandHeldGuiAgent.myNotesObj, EVENT_MACHQUEUE_ALTERED, Response_Continuous , null);
	self.beginNotification(app.myHandHeldGuiAgent.myNotesObj, EVENT_RESET_MEDIATOR, Response_Continuous , null);

	//self.beginNotification(app.myHandHeldGuiAgent.myNotesObj, RTQueueEntry_Update_Event, Response_Continuous , null);	
	self.setMode();
epilog

end;</source>
    </JadeMethod>
