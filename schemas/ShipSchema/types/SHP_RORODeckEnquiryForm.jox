    <JadeMethod name="loadRoRoDeckTable" id="12dd15f9-7e59-490b-9187-df4f7cb204c5">
        <source>loadRoRoDeckTable() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 March 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	subDeck,
	deck : CM_Deck;
	iter ,subDeckIter: Iterator;
	subDeckCollection,
	deckCollection : Collection;
begin

	deckCollection:=self.getDeckCollection;
	iter:= deckCollection.createIterator;
	while iter.next(deck) do
		self.addTableItem(deck);
		subDeckCollection:=deck.getSubDeckCollection;
		delete subDeckIter;
		subDeckIter:=subDeckCollection.createIterator;
		while subDeckIter.next(subDeck) do
			self.addTableItem(subDeck);
		endwhile;
	endwhile;

epilog
	delete iter;
	delete subDeckIter;
end;</source>
        <access>protected</access>
    </JadeMethod>
