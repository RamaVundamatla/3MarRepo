    <JadeMethod name="getAuditText" id="45c32887-bc95-4fb2-a3c2-3431bf26299f">
        <source>getAuditText(): String;
// --------------------------------------------------------------------------------
// Created:		05 August 2008 by cnwdad1
//
// Purpose:		Standard method to return an audit string of the receiver properties.
//
// Parameters:	None
//
// Returns:		The audit string to record.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	auditString		: String;
	
begin
//	auditString	:=	inheritMethod();
	
	auditString	:=	auditString &amp; CM_Restriction::colour.name &amp; AuditStringSeparator &amp; self.colour.String.length().String &amp; AuditStringSeparator &amp; self.colour.String &amp; AuditStringSeparator;
	auditString	:=	auditString &amp; CM_Restriction::comment.name &amp; AuditStringSeparator &amp; self.comment.length().String &amp; AuditStringSeparator &amp; self.comment &amp; AuditStringSeparator;
	auditString	:=	auditString &amp; "Is Block Stack" &amp; AuditStringSeparator &amp; self.isBlockStack.String.length().String &amp; AuditStringSeparator &amp; self.isBlockStack.String &amp; AuditStringSeparator;
	auditString	:=	auditString &amp; "User Code" &amp; AuditStringSeparator &amp; self.userCode.length().String &amp; AuditStringSeparator &amp; self.userCode &amp; AuditStringSeparator;
	
	return auditString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="c4c7cae6-3e8f-434c-8ac1-d954caec9071">
        <source>getExtraInfo(_dataContainer : CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	block : CM_DataContainerBlock;

begin
	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_User_Code), DC_Label, 1, self);
	block.addNewItem(self.userCode, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(CM_Comment), DC_Label, 1, self);
	block.addNewItem(self.comment, DC_Data, 1, self);

	block := _dataContainer.addNewBlock;
	block.addNewItem(app.getErrorString(DateStr), DC_Label, 1, self);
	block.addNewItem(self.systemToLocalTime(self.createdTime).String, DC_Data, 1, self);	// 24/6/2016 cnwmp6 TFS 488 - Multi timezone support

end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getRestrictionAsString" id="74402aae-9e1e-4b18-b5be-80f50971a13c">
        <source>getRestrictionAsString() : String;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

begin
	return "Created " &amp; self.createdTime.shortCurrentLocaleFormat &amp; CrLf &amp; 'User ' &amp; self.userCode &amp; CrLf &amp; 'Comment: ' &amp; self.comment;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
