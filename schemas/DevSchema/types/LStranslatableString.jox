    <JadeMethod name="create" id="6ca06d55-93a8-4457-a381-086b1524f6a6">
        <updating/>
        <source>create() updating;

vars

begin
	create directMethodRefs transient;
	create indirectMethodRefs transient;
	create directScriptRefs transient;
	create indirectScriptRefs transient;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="delete" id="b784f25b-757d-4cf0-8797-32e33514ac77">
        <updating/>
