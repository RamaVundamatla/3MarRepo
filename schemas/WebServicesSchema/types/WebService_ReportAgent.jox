    <JadeMethod name="getSelectedCrane" id="95770478-eb18-4157-92e6-2f0acfc80e05">
        <source>getSelectedCrane(_jobType: Integer output; _craneId: String output);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 September 2008	cnwkao1	Initial creation - based on WebSchema implementation
12 Aug 2022 navtnr20 Bug 52451: MTN - WebServices not using getObjectOfTypeFromOid
*/

vars
	crane		: CM_Machine;
	tmpStr		: String;
	reportParam	: WS_ReportParameter;
	
begin

	reportParam := self.allWSReportParams.getAtKey(ETRow_Crane);
	if reportParam &lt;&gt; null then
		tmpStr := reportParam.value;
	endif;	
	
	//global.getExtraData(self.allQueryCriteria, ETRow_Crane, tmpStr);
		
	if tmpStr = '1' then 
		_jobType := CMQF_VoyageOrderOfWork.JobType_All; 
	elseif tmpStr = '2' then 
		_jobType := CMQF_VoyageOrderOfWork.JobType_Unallocated; 
	else
		_jobType := CMQF_VoyageOrderOfWork.JobType_Crane;
		//crane := tmpStr.asOid.CM_Machine;			//12.08.2022 navtnr20 52451
		crane 	:= app.myPassport.getObjectOfTypeFromOid(tmpStr, CM_Machine).CM_Machine;			//12.08.2022 navtnr20 52451
		if crane &lt;&gt; null then 
			_craneId := crane.id;
		endif;
	endif;
end;</source>
        <Parameter name="_jobType" type="Integer" usage="output"/>
        <Parameter name="_craneId" type="String" usage="output"/>
    </JadeMethod>
