    <JadeMethod name="getSingleAliasDesc" id="1ec38ead-e6c5-45ad-9578-37179990a50b">
        <source>getSingleAliasDesc() : String protected;
// ---------------------------------------------------------------------------
// Created:     28 July 2003 by cnwsb1
//
// Purpose:		Clearer logging - and to stop accidental release to production !!
// ---------------------------------------------------------------------------
begin
	if self.singleClassAlias = null then
		return null;
