    <JadeMethod name="listFlags" id="19ad09fc-10a1-4a33-835b-e3591b90ae7d">
        <source>listFlags(): String;
// ---------------------------------------------------------------------------
// Created:     Oct 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str: String;
begin
	str := str&amp;inheritMethod();
