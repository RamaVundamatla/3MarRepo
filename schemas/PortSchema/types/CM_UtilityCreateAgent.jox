    <JadeMethod name="utlCreateInvoiceLineManual" id="e4ec62fc-439a-498f-8f5d-61bcf468fe93">
        <source>utlCreateInvoiceLineManual(_theController : CMIF_InvoiceLineManual; _newInvoiceLine : CM_InvoiceLine output;	_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
15 Dec 2008	cnwkpd1	PAR #18652 - Change causeEvent inside trx to immediate false
24 Sep 2019	jlgzm1	TFS 46054 STWO - Adding Extra Details to Manual Invoice Lines
10 March 2023  navmv20 TFS 56128 Task 56129: UI - Manual Invoice Lines - Multi TI Invoice Line Type
03 May   2023  navmv20 Bug 57664: EUP - Copy function does not include overridden rates
*/

vars
	invLineType : CM_InvoiceLineDesc;
	theInvoice : CM_Invoice;
	calcType	: CM_CalculationType;			// TFS 46054
	transCtrl 	: CMIF_TITransactionController;	// TFS 46054
	transObj	: CM_TITransaction;				// TFS 46054
	ti 			: CM_TrackedItem; 				//10/03/2023  navmv20 TFS 56128 Task 56129
	usedContractQuantity : Boolean;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valInvoiceLineManual(_theController);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	theInvoice := _theController.myInvoice;
	
	//10/03/2023  navmv20 TFS 56128 Task 56129 - START
	foreach invLineType in _theController.allInvoiceLineTypes do
		if not _theController.allTrackedItems.isEmpty then
			foreach ti in _theController.allTrackedItems do
				_newInvoiceLine := invLineType.createManualInvoiceLine(_theController, ti, true); // ### JIRA 33007 03OCT2024 NAVAB1 - just use _theController
				
 // ### TFS BUG 59807 14AUG2023 NAVAB1				_newInvoiceLine.createManualInvLineTransaction(true); //03/05/2023 navmv20 Bug 57664 

				// ### TFS BUG 59807 15AUG2023 NAVAB1
				usedContractQuantity := _newInvoiceLine.usedContractCalcType;
			
				// ### TFS BUG 58787 22JUN2023 NAVAB1 - because we have a TI and the invoice line has a transaction we will use the calcuation type on the invoice line to calculate the quantity.
				if not usedContractQuantity // ### TFS BUG 59807 15AUG2023 NAVAB1
				and _theController.useCalcTypeForQuantity then
					_newInvoiceLine.setManual(false);
					_newInvoiceLine.calculateQuantity(); 
					_newInvoiceLine.setManual(true); // ### TFS BUG 59696 07AUG2023 NAVAB1 - resetTotalOnCharge() does nothing non manual lines
					_newInvoiceLine.resetTotalOnCharge();
					// ### TFS BUG 59696 07AUG2023 NAVAB1 _newInvoiceLine.setManual(true);
				endif;
				
				endforeach;
		 else
			_newInvoiceLine := invLineType.createManualInvoiceLine(_theController, ti, false); // ### JIRA 33007 03OCT2024 NAVAB1 just use _theController
		 endif;
			
	endforeach;
	//10/03/2023  navmv20 TFS 56128 Task 56129 - START
	 
	theInvoice.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, theInvoice);
epilog
	delete transCtrl; // TFS 46054
	
end;</source>
        <Parameter name="_theController" type="CMIF_InvoiceLineManual"/>
        <Parameter name="_newInvoiceLine" type="CM_InvoiceLine" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateInvoiceLineNarr" id="09e291c0-ee91-48e9-b810-cf622ba550c4">
        <source>utlCreateInvoiceLineNarr(_pxyInvoiceLineNarration: CM_InvoiceLineNarration input; _newInvoiceLineNarration: CM_InvoiceLineNarration output; _passport: CM_Passport input);
/*

Purpose:			Creates an Invoice Line Narration

Parameters:			_pxyInvoiceLineNarration	CM_InvoiceLineNarration	The proxy object to use to create a real object from
					_newInvoiceLineNarration	CM_InvoiceLineNarration	The real object to create
					_passport					CM_Passport				The passport to use to hold errors and other information

Return Value:		NONE

Date		Who		Reason
31 August 2022	navpw1	Initial creation TFS: 54564 (54379)

*/

begin
	self.initialiseActivity();
	
	_pxyInvoiceLineNarration.raiseExceptionIfNotTransient(method);
	
	app.setContinueCMExceptions(true);

	app.myValCA.valInvoiceLineNarr(_pxyInvoiceLineNarration);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	create _newInvoiceLineNarration persistent;
	_newInvoiceLineNarration.setForCreate(_pxyInvoiceLineNarration);
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_newInvoiceLineNarration);
	endif;

end;</source>
        <Parameter name="_pxyInvoiceLineNarration" type="CM_InvoiceLineNarration" usage="input"/>
        <Parameter name="_newInvoiceLineNarration" type="CM_InvoiceLineNarration" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateInvoiceLineWeb" id="0c2cce57-a596-4c23-aa0e-acda4b2153b1">
        <source>utlCreateInvoiceLineWeb(_pxyInvoiceLine : CM_InvoiceLine input ; _newInvoiceLine : CM_InvoiceLine output;	_passport : CM_Passport input);
/*

Purpose:			
	
	Utl method to create the new persistent invoice line and set its data from the proxy

Parameters:		

	_pxyInvoiceLine : The proxy invoice line to set the values for the real invoice line
	_newInvoiceLine	: The new real invoic linee to be set and created from the proxy invoice line
	_passport		: The passport	

Return Value:		

	None

Date		Who		Reason
07/06/2023	navcs2	ChangeRequest 56901: [58447]: TAS Invoicing Invoice Endpoint - JADE changes
28/08/2023	navcs2	Bug 59959: EUP | TAS Invoicing - Invoice API doesn't match whats defined in API spec
11/02/2025	navcs2	MTN-33895 GPHA - POST /invoice error 90275 
*/

vars
	theInvoice : CM_Invoice;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	theInvoice := _pxyInvoiceLine.invoice;
	//_pxyInvoiceLine.validateWebInvoiceLine();			 11/02/2025	navcs2	MTN-33895
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	// 28/08/2023	navcs2	Bug 59959 Start
	if _pxyInvoiceLine.manual then
		_newInvoiceLine := _pxyInvoiceLine.getInvoiceLineType.createManualInvoiceLineWeb(theInvoice, _pxyInvoiceLine.charges.first, _pxyInvoiceLine.remarks, _pxyInvoiceLine.chargeTime);
	else
		_newInvoiceLine := _pxyInvoiceLine.getInvoiceLineType.createInvoiceLineWeb(theInvoice.debtor, theInvoice, _pxyInvoiceLine.quantity, _pxyInvoiceLine.remarks);
	endif;
	_newInvoiceLine.setForUpdateWeb(_pxyInvoiceLine);
	// 28/08/2023	navcs2	Bug 59959 End
	
	// ### TFS BUG 59807 14AUG2023 NAVAB1 _newInvoiceLine.createManualInvLineTransaction(true); - moved to createManualInvoiceLine()
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_newInvoiceLine);
		theInvoice.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, theInvoice);
	endif;	
	
epilog
	
end;</source>
        <Parameter name="_pxyInvoiceLine" type="CM_InvoiceLine" usage="input"/>
        <Parameter name="_newInvoiceLine" type="CM_InvoiceLine" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateInvoiceListCopy" id="f9c3c996-ce5c-45b0-bd0f-01ac77ba2683">
        <source>utlCreateInvoiceListCopy(_cmifInvCopy : CMIF_InvoiceCopy io; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 APR 2023 navtnr20	TFS CR 55303 Task 55528: Jade - Invoice Copy Jade Code
03 May   2023  navmv20 Bug 57664: EUP - Copy function does not include overridden rates
06 June 2023 navmv20 Bug 58390: EUP - Copied Invoice Other Invoice
*/

vars
	invoice,pxyInvoice,newInvoice 			: CM_Invoice;
	firstInvDone			: Boolean;
	invoiceLine,
	newInvoiceLine			: CM_InvoiceLine;
	charge, newCharge 		: CM_Charge;
	pendingStatus			: Integer;
	allInvoiceToLink		: CM_InvoiceSet;
	controller          	: CMIF_InvoiceLineCopy;
	progressTS  			: TimeStamp;
	progess 				: TimeStampInterval;
	allInvoicesToNotifiy	: CM_InvoiceSet; //13/01/2025	navkc1 JIRA Bug MTN-33142
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	app.setContinueCMExceptions(false);
	create controller transient;
	
	pxyInvoice := _cmifInvCopy.myProxyInvoice; //13/01/2025	navkc1 JIRA Bug MTN-33142
	
	app.myUtilityCA.utlCreateInvoiceManual(pxyInvoice, newInvoice, _passport);
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	create allInvoicesToNotifiy transient; //13/01/2025	navkc1 JIRA Bug MTN-33142
	
	invoice := _cmifInvCopy.myInvoice; //11/10/2024	navkc1	JIRA 12538
	newInvoice.setMyOtherInvoice(invoice); //06/06/2023 navmv20 Bug 58390
	controller.setValues(false,false,false,newInvoice,null,null);
	controller.myInvoice := newInvoice;
	
	progressTS := app.actualTimeServer();// ### JIRA 19932 21OCT2024 NAVAB1
	
	foreach invoiceLine in _cmifInvCopy.myInvoice.invoiceLines discreteLock do
	
		// ### JIRA 19932 21OCT2024 NAVAB1
		progess := app.actualTimeServer() - progressTS;
		if progess.getMilliseconds &gt;= 2000 then
			
			commitTransaction;
			process.sleep(100);
			progressTS := app.actualTimeServer();
			beginTransaction;
			
		endif;
		
		newInvoiceLine := invoiceLine.cloneForCopy(controller,invoiceLine.trackedItem, false);
		//newInvoiceLine.createCharges();	//03/05/2023 navmv20 Bug 57664 
		newInvoiceLine.createManualInvLineTransaction(false); //03/05/2023 navmv20 Bug 57664
	endforeach;
	
	_cmifInvCopy.myInvoice := newInvoice; // pass back for checking
	
	allInvoicesToNotifiy.add(invoice); //13/01/2025	navkc1 JIRA Bug MTN-33142 - Notify all linked invoices
	newInvoice.allCreditInvoices.tryCopy(allInvoicesToNotifiy); //13/01/2025	navkc1 JIRA Bug MTN-33142  - Notify all linked invoices
	
	if _passport.noErrors() then
		self.myCreateAuditAgent.audCreateGeneric(newInvoice);
		//13/01/2025	navkc1 JIRA Bug MTN-33142 Notify all linked invoices
		foreach invoice in allInvoicesToNotifiy do
			//11/10/2024	navkc1	JIRA 12538 - Do notification on the source invoice
			if invoice &lt;&gt; null then
				invoice.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, invoice);
			endif;
		endforeach;
	endif;
	
epilog
	delete controller;
	delete allInvoicesToNotifiy;
end;</source>
        <Parameter name="_cmifInvCopy" type="CMIF_InvoiceCopy" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateInvoiceManual" id="a5b0bb8c-e671-4e00-babf-11b287183794">
        <source>utlCreateInvoiceManual(pProxyInvoice:CM_Invoice; pNewInvoice:CM_Invoice output; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
15 Dec 2008	cnwkpd1	PAR #18652 - Change causeEvent inside trx to immediate false

*/

vars

begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valInvoiceManual(pProxyInvoice);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	create pNewInvoice persistent;
	pNewInvoice.setForCreate(pProxyInvoice);

	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(pNewInvoice);
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceCreate), false, pNewInvoice);	// PAR #18652
	endif;
end;</source>
        <Parameter name="pProxyInvoice" type="CM_Invoice"/>
        <Parameter name="pNewInvoice" type="CM_Invoice" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateInvoiceNote" id="bf5695b4-ef0b-4fb6-a403-8bb199fad017">
        <source>utlCreateInvoiceNote(_pxyInvoiceNote: CM_InvoiceNote; _newInvoiceNote: CM_InvoiceNote output; _realInvoice : CM_Invoice input; _passport : CM_Passport input);
/*

Purpose:			Creates a new Invoice Note from Proxy object passed in and gives a new invoice note out
					Also Creates an Audit for our object

Parameters:			_pxyInvoiceNote	CM_InvoiceNote	Proxy invoice note to create real object from (Input meaning it gets passed in as a constant)
					_newInvoiceNote	CM_InvoiceNote	Real Invoice Note created (Output meaning it is passed outwards)
					_passport		CM_Passport		Passport to use for our Trx that holds errors and other useful data

Return Value:		NONE

Date		Who		Reason
03 February 2022	navpw1	Initial creation TFS: 52752

*/

begin
	self.initialiseActivity();
	
	_pxyInvoiceNote.raiseExceptionIfNotTransient(method);
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valInvoiceNote(_pxyInvoiceNote);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	create _newInvoiceNote persistent;
	_newInvoiceNote.setForCreate(_pxyInvoiceNote);

	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_newInvoiceNote);
		
	endif;

	if _passport.noErrors then
		_realInvoice.setInvoiceNote(_newInvoiceNote);
	endif;
	
	if _passport.noErrors and _passport.myTerminal &lt;&gt; null then
		_newInvoiceNote.myInvoice.causeEvent(_passport.myTerminal.getTerminalEvent(Event_InvoiceUpdate), false, _newInvoiceNote.myInvoice);
	endif;
	
end;</source>
        <Parameter name="_pxyInvoiceNote" type="CM_InvoiceNote"/>
        <Parameter name="_newInvoiceNote" type="CM_InvoiceNote" usage="output"/>
        <Parameter name="_realInvoice" type="CM_Invoice" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateInvoiceProcess" id="cebb63ea-b748-46d2-9838-562a0bd1354e">
        <source>utlCreateInvoiceProcess(_pxyInvoiceProcess : CM_InvoiceProcess; _newInvoiceProcess : CM_InvoiceProcess output; _passport : CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Jan 2019	jlgsl4	TFS 39618 - LNX - Initial creation

*/

vars

begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valInvoiceProcess(_pxyInvoiceProcess, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	create _newInvoiceProcess as _pxyInvoiceProcess.class persistent;
	_newInvoiceProcess.setForCreate(_pxyInvoiceProcess);
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_pxyInvoiceProcess);
	endif;
epilog

end;</source>
        <Parameter name="_pxyInvoiceProcess" type="CM_InvoiceProcess"/>
