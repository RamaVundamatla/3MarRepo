    <JadeMethod name="comboBoxTerminal" id="29387959-058b-465e-80ff-f52faf73d10d">
        <source>comboBoxTerminal(_combo : ComboBox input; _terminal : CM_Terminal; _harbour:HMS_Harbour);
//--------------------------------------------------------------
//Created: March 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	user			: CM_User;
	userTerminal	: CM_UserTerminal;
	terminal		: CM_Terminal;
	row				: Integer;

begin
	_combo.clear();
	
	user := app.getMyUser();
	
	foreach userTerminal in user.allUserTerminals do
		if _harbour &lt;&gt; null and not userTerminal.isMyHarbour(_harbour) then
			continue;
		endif;
		
		terminal	:=	userTerminal.getMyTerminal();
		row			:=	_combo.addItem(self.displayEntryTerminal(terminal));
		
		_combo.itemObject[row]	:=	terminal;
	endforeach;
	
	if _terminal &lt;&gt; null then
		_combo.listIndex	:=	_combo.findObject(_terminal);
	endif;
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
    </JadeMethod>
    <JadeMethod name="comboBoxTerminalAll" id="0e333b9c-0917-4298-9d22-1e2ae9aa5353">
        <source>comboBoxTerminalAll(_combo : CMUI_ComboBox input; _terminal : CM_Terminal);
/*
Date		Who		Reason
04 Apr 2013	cnwcs5	Initial Creation - CCMS POL 2097/par 31259
*/
vars
	terminal	:CM_Terminal;
begin
	foreach terminal in app.myRoot.allTerminals do
		_combo.addItemObject (terminal.displayEntryListbox, terminal);
	endforeach;

	if _terminal &lt;&gt; null then
		_combo.listIndex	:=	_combo.findObject(_terminal);
	endif;
epilog

end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="comboBoxTerminalArea" id="b0e06153-4c4a-4811-94d3-832ff5dad973">
        <source>comboBoxTerminalArea(pCmb : ComboBox input; pAreaType : Integer; pTerminalArea : CM_TerminalArea);
// ---------------------------------------------------------------------------
// Created:     20 December 2000 by cnwrs2

// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 10 Jun 2008	cnwkpd1		PAR #16753 - CCMS SFW 1003 - General Cargo Graphical Screens
// ---------------------------------------------------------------------------
// 11/09/2009	cnwcs5		ccms 1061 - removed VTA (road transfer area)
// 15 Jul 2013  cnwer1 		PAR 31985 removed trailer areas
// 09 Jun 2020	jlgdap1		TFS 49453 ASPA Satellite View Screen for Flexible Terminal Areas
// 08 Sep 2022	jlika1		TFS 54699 - CUX - MAFI Handling Enhancements - MAFI Heap Terminal Area
vars
	areaType 	: CM_TerminalAreaType;
	area 		: CM_TerminalArea;
	idx 		: Integer;
	str			: String;
	term		: CM_Terminal;
	areas		: CM_TerminalAreaSet;
	obj: Object;
begin

	pCmb.sorted := true;
	pCmb.clear();
	term := self.myTerminal;
	create areas transient;
	
	if pAreaType &lt;&gt; TA_TYPE_NULL then
		areaType := app.myRoot.allTerminalAreaTypes[pAreaType];
		if areaType &lt;&gt; null then
			areaType.getAreasForTerminal(areas, term);
			foreach area in areas do
				str :=  self.displayEntryTerminalArea(self.myTerminal, area);
				idx := pCmb.addItem(str);
				pCmb.itemObject[idx] := area;
			endforeach;
		endif;
	else
		//Add all Terminal Areas
		//Some types need to be removed in the future
		self.allOtherTerminalAreas.clear;
			
		areaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_BLOCK_STACK];
		if areaType &lt;&gt; null then
			areaType.getAreasForTerminal(self.allOtherTerminalAreas, term);
		endif;		
		areaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_BULK];
		if areaType &lt;&gt; null then
			areaType.getAreasForTerminal(self.allOtherTerminalAreas, term);
		endif;		
		areaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_CONT_PACK_REPACK];
		if areaType &lt;&gt; null then		
			areaType.getAreasForTerminal(self.allOtherTerminalAreas, term);
		endif;
		areaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_COU_CRIB_PACK_UNPACK];
		if areaType &lt;&gt; null then
			areaType.getAreasForTerminal(self.allOtherTerminalAreas, term);
		endif;
		areaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_COU_STORE_AREA];
		if areaType &lt;&gt; null then
			areaType.getAreasForTerminal(self.allOtherTerminalAreas, term);
		endif;
		areaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_CRANE_TRANS];
		if areaType &lt;&gt; null then
			areaType.getAreasForTerminal(self.allOtherTerminalAreas, term);
		endif;		
		areaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_DELETE];
		if areaType &lt;&gt; null then
			areaType.getAreasForTerminal(self.allOtherTerminalAreas, term);
		endif;
		areaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_DEPOT_LCL];
		if areaType &lt;&gt; null then
			areaType.getAreasForTerminal(self.allOtherTerminalAreas, term);
		endif;
		areaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_FORK_LIFT_STACK];
		if areaType &lt;&gt; null then
			areaType.getAreasForTerminal(self.allOtherTerminalAreas, term);
		endif;		
		areaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_FUMIGATION_AREA];
		if areaType &lt;&gt; null then
			areaType.getAreasForTerminal(self.allOtherTerminalAreas, term);
		endif;
		areaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_GATE_ROAD];
		if areaType &lt;&gt; null then
			areaType.getAreasForTerminal(self.allOtherTerminalAreas, term);
		endif;
		areaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_GENERATOR_STORE_AREA];
		if areaType &lt;&gt; null then
			areaType.getAreasForTerminal(self.allOtherTerminalAreas, term);
		endif;
		areaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_LOGAREA];
		if areaType &lt;&gt; null then
			areaType.getAreasForTerminal(self.allOtherTerminalAreas, term);
		endif;
		areaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_HIDE];
		if areaType &lt;&gt; null then
			areaType.getAreasForTerminal(self.allOtherTerminalAreas, term);
		endif;
		areaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_PTI];
		if areaType &lt;&gt; null then
			areaType.getAreasForTerminal(self.allOtherTerminalAreas, term);
		endif;
		areaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_RAILWAY_TRACK];
		if areaType &lt;&gt; null then
			areaType.getAreasForTerminal(self.allOtherTerminalAreas, term);
		endif;
		areaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_RAIL_TRANS];
		if areaType &lt;&gt; null then
			areaType.getAreasForTerminal(self.allOtherTerminalAreas, term);
		endif;
		areaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_RECTRANS];
		if areaType &lt;&gt; null then
			areaType.getAreasForTerminal(self.allOtherTerminalAreas, term);
		endif;
		areaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_RELTRANS];
		if areaType &lt;&gt; null then
			areaType.getAreasForTerminal(self.allOtherTerminalAreas, term);
		endif;
		areaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_REPAIR];
		if areaType &lt;&gt; null then
			areaType.getAreasForTerminal(self.allOtherTerminalAreas, term);
		endif;
		areaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_RTG];
		if areaType &lt;&gt; null then
			areaType.getAreasForTerminal(self.allOtherTerminalAreas, term);
		endif;
		
		//epr par 20/11/09 21673
		areaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_RMG];
		if areaType &lt;&gt; null then
			areaType.getAreasForTerminal(self.allOtherTerminalAreas, term);
		endif;
		
		areaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_STRADDLE_STACK];
		if areaType &lt;&gt; null then
			areaType.getAreasForTerminal(self.allOtherTerminalAreas, term);
		endif;
		areaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_SUBBLOCK_STACK];
		if areaType &lt;&gt; null then
			areaType.getAreasForTerminal(self.allOtherTerminalAreas, term);
		endif;				
		areaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_WASH_AREA];
		if areaType &lt;&gt; null then
			areaType.getAreasForTerminal(self.allOtherTerminalAreas, term);
		endif;
		areaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_IRREGULAR_BLOCK_AREA];		// was TA_TYPE_GENERAL_CARGO_AREA
		if areaType &lt;&gt; null then
			areaType.getAreasForTerminal(self.allOtherTerminalAreas, term);
		endif;	
		
		areaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_YARD_INTERCHANGE];
		if areaType &lt;&gt; null then
			areaType.getAreasForTerminal(self.allOtherTerminalAreas, term);
		endif;	

		areaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_RORO_LANE_AREA];	// cnwjk3 PAR 22961 12/03/2010
		if areaType &lt;&gt; null then												// cnwjk3 PAR 22961 12/03/2010
			areaType.getAreasForTerminal(self.allOtherTerminalAreas, term);		// cnwjk3 PAR 22961 12/03/2010
		endif;																	// cnwjk3 PAR 22961 12/03/2010
		
		areaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_WORKPOINT_INTERCHANGE]; // fixed in 8.1.1 only
		if areaType &lt;&gt; null then
			areaType.getAreasForTerminal(self.allOtherTerminalAreas, term);
		endif;
		
		areaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_GEN_CARGO_ALLOC_ROW];	// TFS 49453
		if areaType &lt;&gt; null then													// TFS 49453
			areaType.getAreasForTerminal(self.allOtherTerminalAreas, term);			// TFS 49453
		endif;																		// TFS 49453
		
		areaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_MAFI];
		if areaType &lt;&gt; null then
			areaType.getAreasForTerminal(self.allOtherTerminalAreas, term);
		endif;
		
		pCmb.listCollection(self.allOtherTerminalAreas, false, 0);
	endif;

	if pTerminalArea &lt;&gt; null then
		str :=  self.displayEntryTerminalArea(self.myTerminal, pTerminalArea);
		if str &lt;&gt; null then
			//pCmb.listObject := pTerminalArea;			// cnwdad1 14/10/2009 - PAR #21312.  This causes an exception if the combobox doesn't contain the object!
			//pCmb.cnEcSetObjectIndex(pTerminalArea);		// cnwdad1 14/10/2009 - PAR #21312.
			pCmb.listIndex := pCmb.findObject(pTerminalArea);
		endif;
	endif;
epilog
	delete areas;
end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="pAreaType" type="Integer"/>
        <Parameter name="pTerminalArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="comboBoxTerminalAreaRowLabels" id="9ee1d1b6-6b76-48fb-aaf7-37c8a2598bc9">
        <source>comboBoxTerminalAreaRowLabels(pCmb : ComboBox input; pTerminalArea : CM_TerminalArea);
//--------------------------------------------------------------
//Created: 10 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	rowLabels : CM_LabelArray;
begin

	pCmb.sorted := false;
	if pTerminalArea &lt;&gt; null then
		if pTerminalArea.type = TA_TYPE_STRADDLE_STACK then
			pCmb.listCollection(pTerminalArea.CM_StraddleStack.allGridRowsByLabel, true, 0);
		else 
			pCmb.enabled := false;
		endif;
	endif;
end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="pTerminalArea" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="comboBoxTerminalArea_GateArea" id="862ddc49-367a-40ec-a1a4-15953dfdceee">
        <source>comboBoxTerminalArea_GateArea(_combo :CMUI_ComboBox input; _areaType :Integer);
// ---------------------------------------------------------------------------
// Created:     22 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	areaType	: CM_TerminalAreaType;
	areas		: CM_TerminalAreaSet;
	area		: CM_TerminalArea;
	idx			: Integer;
begin
	_combo.sorted := true;
	_combo.clear();
	
	create areas transient;
	areaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_GATE_ROAD];
	
	if areaType &lt;&gt; null then
		areaType.getAreasForTerminal(areas, self.myTerminal);
		foreach area in areas do
			
			if not area.isGateArea then
				continue;
			endif;
			if area.CM_GateArea.areaType &lt;&gt; _areaType then 
				continue;
			endif;
			idx := _combo.addItem(area.id);
			_combo.itemObject[idx] := area;
		endforeach; 
	endif;
epilog
	delete areas;
end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_areaType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="comboBoxTerminalArea_RFIDAreas" id="c983e075-0257-4ab7-a31e-d3e91eea3ff7">
        <source>comboBoxTerminalArea_RFIDAreas(_combo :CMUI_ComboBox input; _area :CM_TerminalArea);
// ---------------------------------------------------------------------------
// Created:     22 July 2009 by cnwcs5
// Purpose:     CCMS 1061 - loads gate areas and yard interchange areas
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	areaType	: CM_TerminalAreaType;
	areas		: CM_TerminalAreaSet;
	area		: CM_TerminalArea;
	idx			: Integer;
begin
	_combo.sorted := true;
	_combo.clear();
	
	create areas transient;
	areaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_GATE_ROAD];
	
	if areaType &lt;&gt; null then
		areaType.getAreasForTerminal(areas, self.myTerminal);
	endif;
	
	areaType := app.myRoot.allTerminalAreaTypes[TA_TYPE_YARD_INTERCHANGE];
	
	if areaType &lt;&gt; null then
		areaType.getAreasForTerminal(areas, self.myTerminal);
	endif;
	
	foreach area in areas do	
		idx := _combo.addItem(area.id);
		_combo.itemObject[idx] := area;
		
		if area = _area then
			_combo.listIndex := idx;
		endif;
	endforeach; 
epilog
	delete areas;
end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_area" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="comboBoxTerminalForGlbVoyage" id="3f253f4f-63a0-4334-ba80-ceb1f8cccf66">
        <source>comboBoxTerminalForGlbVoyage(pCmb : ComboBox input; _globalVoyage : CM_VoyageGlobal; permissionMaint : Integer; _terminal : CM_Terminal input);
/*
----------   ----------  --------------------------------------------------
Created:	19 April 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	voyage : CM_Voyage;
	terminalName : String;
	terminal : CM_Terminal;
	rowPointer		: Integer;
	user : CM_User;
	allTerminals : CM_TerminalSet;
begin

		pCmb.clear();
		user := app.getMyUser();
		create allTerminals transient;
		if _globalVoyage &lt;&gt; null then
			
			foreach voyage in _globalVoyage.allVoyages where not voyage.archived do
				terminal := voyage.myTerminal;
				if not allTerminals.includes(terminal) then
					allTerminals.add(terminal);
					if terminal &lt;&gt; null and user.canDo(terminal, permissionMaint) then
						rowPointer	:=	pCmb.addItem(self.displayEntryTerminal(terminal));
						pCmb.itemObject[rowPointer]	:=	terminal;
						if _terminal = terminal then
							pCmb.listObject := terminal;
						endif;
					endif;
				endif;
			endforeach;	
		endif;
epilog
	delete allTerminals;
end;
</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="_globalVoyage" type="CM_VoyageGlobal"/>
        <Parameter name="permissionMaint" type="Integer"/>
        <Parameter name="_terminal" type="CM_Terminal" usage="input"/>
    </JadeMethod>
    <JadeMethod name="comboBoxTerminologyTypes" id="10b13334-e524-49c4-a3ac-325750960a8a">
        <source>comboBoxTerminologyTypes(_cmb : CMUI_ComboBox input; _termType : CM_TerminologyType);
// ---------------------------------------------------------------------------
// Created:     09 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	termType			: CM_TerminologyType;
	root				: CM_Root;
begin
	_cmb.clear();

	root := app.myRoot;
	foreach termType in root.allTerminologyTypes do
		_cmb.itemObject[_cmb.addItem(termType.name)] := termType;
	endforeach;
	
	if _termType &lt;&gt; null then
		_cmb.listObject := _termType;
	endif;
	
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_termType" type="CM_TerminologyType"/>
    </JadeMethod>
    <JadeMethod name="comboBoxTermnialStopsTable" id="005ac3af-f33a-4152-a0fe-a0e599c4191f">
        <source>comboBoxTermnialStopsTable(_cmb : ComboBox input; _customsStop : CM_StopsTable);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2014	cnwmc5	Initial creation

*/

vars
	stopsTable	: CM_StopsTable;
	idx		: Integer;
begin

	_cmb.clear;
	
	idx := _cmb.addItem("");
	_cmb.itemObject[idx] := null;
	
	foreach stopsTable in app.myRoot.allStopsTable do
		if stopsTable.isValidForTerminal(self.myTerminal) then
			idx := _cmb.addItem(stopsTable.heading);
			_cmb.itemObject[idx] := stopsTable;
		endif;
	endforeach;
	
	if _customsStop &lt;&gt; null then
		_cmb.listObject := _customsStop;
	endif;
	

end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_customsStop" type="CM_StopsTable"/>
    </JadeMethod>
    <JadeMethod name="comboBoxToDoTasks" id="3fd0cd1e-df3d-4962-a86e-c8e179aa0428">
        <source>comboBoxToDoTasks(_cmb : ComboBox input; _toDoTaskDesc : CM_ToDoTaskDesc);
// ---------------------------------------------------------------------------
// Created:		25 March 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	task	: CM_ToDoTaskDesc;
	idx		: Integer;
begin

	_cmb.clear;
	
	idx := _cmb.addItem("");
	_cmb.itemObject[idx] := null;
	
	foreach task in app.myRoot.allToDoTaskDescriptions 
		where task.type = TODO_TYPE_GROUP_TI do					 // ### TFS  #56634[54259] 22NOV2022 NAVAB1

		idx := _cmb.addItem(task.description);
		_cmb.itemObject[idx] := task;
	endforeach;
	if _toDoTaskDesc &lt;&gt; null then
		_cmb.listObject := _toDoTaskDesc;
	endif;
	

end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_toDoTaskDesc" type="CM_ToDoTaskDesc"/>
    </JadeMethod>
    <JadeMethod name="comboBoxToDoWorkOrderTasks" id="6f2dab1b-e558-4efe-9449-de8dcad4906e">
        <source>comboBoxToDoWorkOrderTasks(_combo : CMUI_ComboBox input; _terminal : CM_Terminal);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/12/2022	navcs2		ChangeRequest 56840:[54265] EUP - [Framework] - VAS Work Order Maintenance Sceen
//
vars
	workOrderDetail : CM_WorkOrderDetailType;
	root			: CM_Root;
begin
	
	_combo.clear;
	_combo.sorted := false;
	root    	  := app.myRoot;
	
	_combo.addItemWithData(root.getWorkOrderTaskDescByType(WorkOrderMode_ToDo,WO_TASK_ToDo_NONOPS), WO_TASK_ToDo_NONOPS);
	_combo.addItemWithData(root.getWorkOrderTaskDescByType(WorkOrderMode_ToDo,WO_TASK_ToDo_TRAIN),  WO_TASK_ToDo_TRAIN);
	_combo.addItemWithData(root.getWorkOrderTaskDescByType(WorkOrderMode_ToDo,WO_TASK_ToDo_TRUCK),  WO_TASK_ToDo_TRUCK);
	_combo.addItemWithData(root.getWorkOrderTaskDescByType(WorkOrderMode_ToDo,WO_TASK_ToDo_VBS),    WO_TASK_ToDo_VBS);
	_combo.addItemWithData(root.getWorkOrderTaskDescByType(WorkOrderMode_ToDo,WO_TASK_ToDo_VOYAGE), WO_TASK_ToDo_VOYAGE);
	_combo.addItemWithData(root.getWorkOrderTaskDescByType(WorkOrderMode_ToDo,WO_TASK_ToDo_WAGON),  WO_TASK_ToDo_WAGON);
	
	
epilog

end;</source>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="comboBoxTraceLevel" id="e472c062-a51b-4c28-957d-5071e21215b1">
        <source>comboBoxTraceLevel(pCmb : CMUI_ComboBox input; pTraceLevel : Integer);
// ---------------------------------------------------------------------------
// 14/03/2023	navmd1	TFS 57110 - Refactor CAMS Logging levels to match the new Log level formats
// ---------------------------------------------------------------------------
vars

begin
	if pCmb.itemData.size &lt;&gt; 4 then
		pCmb.sorted := false;
	 	pCmb.clear;
	 	/*
		pCmb.addItemWithData(global.getCAMSTraceLevelDescr(0), 0);
		pCmb.addItemWithData(global.getCAMSTraceLevelDescr(1), 1);
		pCmb.addItemWithData(global.getCAMSTraceLevelDescr(2), 2);
		pCmb.addItemWithData(global.getCAMSTraceLevelDescr(3), 3);
		*/
		pCmb.addItemWithData(global.getCAMSTraceLevelDescr(LogINFO), LogINFO);		// (INFO)  Level 0 - Compulsory System Messages Only
		pCmb.addItemWithData(global.getCAMSTraceLevelDescr(LogERROR), LogERROR);	// (ERROR) Level 1 - Optional Error Messages
	  	pCmb.addItemWithData(global.getCAMSTraceLevelDescr(LogWARN), LogWARN);		// (WARN)  Level 2 - Optional Warning Messages
		pCmb.addItemWithData(global.getCAMSTraceLevelDescr(LogTRACE), LogTRACE);	// (TRACE) Level 3 - Programming Debug Messages
	endif;

	pCmb.text := global.getCAMSTraceLevelDescr(pTraceLevel);

end;</source>
        <Parameter name="pCmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="pTraceLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="comboBoxTrackClearance" id="85175928-d42e-47cb-91c4-9be3e7008951">
        <source>comboBoxTrackClearance( _cmb : ComboBox input; _gaugeClearance : CM_TrackClearance);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 June 2009	cnwndl1	Initial creation

*/

vars
	trackClearance : CM_TrackClearance;
	index : Integer;
begin

	_cmb.clear();
	_cmb.addItem("     ");
	
	foreach trackClearance in app.myRoot.allTrackClearances where not trackClearance.isNotAvailableForEntry do
		index := _cmb.addItem( self.displayEntryTrackClearance(trackClearance) );
		_cmb.itemObject[index] := trackClearance;
	endforeach;

	if _gaugeClearance &lt;&gt; null then
		index := _cmb.findObject(_gaugeClearance);
		if index &lt; 1 then
			index := _cmb.addItem( self.displayEntryTrackClearance(_gaugeClearance) );
			_cmb.itemObject[index] := _gaugeClearance;
		endif;
		_cmb.listIndex := index;
	endif;
	
epilog

end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_gaugeClearance" type="CM_TrackClearance"/>
    </JadeMethod>
    <JadeMethod name="comboBoxTrackedItemCmb" id="89cb3bd4-207f-44df-9a5f-86f1b6902563">
        <updating/>
        <source>comboBoxTrackedItemCmb(pCmb : ComboBox input; pCargoType, pState : Integer; pTi : CM_TrackedItem) updating;
// ---------------------------------------------------------------------------
// Created:     20 December 2000 by cnwrs2
//
// Purpose:     Setups the TI id's for a combo box
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
// ---------------------------------------------------------------------------
vars
	ti		: CM_TrackedItem;
	dict	: CM_TIByCargoTypeIdDict;
	iter	: Iterator;
	tiId,
	idStr		: String;
	cargoType	: Integer;
	ls,
	maxCountExceeded,
	tiFound		: Boolean;
	count		: Integer;
begin
//	app.writeStatement(class.name &amp; ' pCargoType ' &amp; pCargoType.String &amp; ', pState ' &amp; pState.String);
	pCmb.clear;

	if pState = TI_STATE_NORMAL then
		dict := self.myTerminal.allOnsiteTIsByCargoTypeId;
	elseif pState = TI_STATE_NOTIFIED then
		dict := self.myTerminal.allNotifiedTIsByCargoTypeId;
	elseif pState = TI_STATE_TBA then
		dict := self.myTerminal.allTbaTIsByCargoTypeId;
		
	elseif pState = TI_STATE_PLACEHOLDER then	//13 Mar 2020	NDL	TFS 47004
		dict := self.myTerminal.allRRPTIsByCargoTypeId;
		
//	elseif pState = TI_STATE_OFFSITE then
//		dict := app.thisTerminal.offsiteTrackedItems[pTiType];
	endif;

	if dict = null then
		return;
	endif;
	
	if pTi &lt;&gt; null then
		tiId := pTi.id;
	endif;

	app.cmsBeginLoad(ls);
	iter := dict.createIterator;
	dict.startKeyGeq(pCargoType, null, iter);
	while iter.next(ti) do
		iter.getCurrentKeys(cargoType, idStr); //MTN-35226
		if cargoType &lt;&gt; pCargoType then
			break;
		endif;
		count := count + 1;
		if count &gt;= 29999 then
			//jade limit for a combo - this'll happen for 
			//logs every time - possibly other cargo types too
			maxCountExceeded := true;
			break;
		endif;
		
		pCmb.itemObject[pCmb.addItem(idStr)] := ti;				
		if idStr = tiId then
			tiFound := true;
		endif;
	endwhile;
	app.cmsEndLoad(ls);
	
	if maxCountExceeded then
		app.msgBox('There were more than 32,000 tracked items of selected type.' &amp; CrLf &amp;
					'Only the first 32,000 have been listed', ' Maximum entries exceeded', MsgBox_Exclamation_Mark_Icon);
	endif;
	
	if tiFound then
		pCmb.text := tiId;
	else
		pCmb.text := null;
	endif;


epilog
	delete iter;
	app.cmsEndLoad(ls);
end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="pCargoType" type="Integer"/>
        <Parameter name="pState" type="Integer"/>
        <Parameter name="pTi" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="comboBoxTrackedItemCmbPack" id="8626999a-8201-4c8c-b4c0-8aba5c49288b">
        <updating/>
        <source>comboBoxTrackedItemCmbPack(	pCmb : ComboBox input; 
							pCargoType/*, pState*/ : Integer; 					// PAR #31196
							pTi : CM_TrackedItem; 
							_booking : CM_BookingRef;
							_release : CM_BulkRelease ) updating;
//10 August 2010	cnwml2
//
// Changed On	By			Reason
// ----------	--------	------------------------------------------------------------
// 22/07/2013	cnwdap1		PAR #31196 Allow Tranships in Pack/Unpack based on config option
//							Remove irrelevant parameter from this method (why would you ever want to pack a prenote or TBA???)
// 11/12/2015	cnwjre1		37288 TFS 1199 add release for optional extra filtering by release criteria
//14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  	
vars
	ti		: CM_TrackedItem;
	dict	: CM_TIByCargoTypeIdDict;
	iter	: Iterator;
	tiId,
	idStr	: String;
	cargoType	: Integer;
	ls,
	maxCountExceeded,
	tiFound		: Boolean;
	count		: Integer;
	showTships	: Boolean;														// PAR #31196

begin
	pCmb.clear;
	// 37288 new method for release filtering
	if _release &lt;&gt; null then
		self.comboBoxTrackedItemCmbPack2(pCmb, pCargoType, pTi, _booking, _release);
		return;
	endif;

	//if pState = TI_STATE_NORMAL then											// PAR #31196
	dict := self.myTerminal.allOnsiteTIsByCargoTypeId;
	//elseif pState = TI_STATE_NOTIFIED then									// PAR #31196
	//	dict := self.myTerminal.allNotifiedTIsByCargoTypeId;					// PAR #31196
	//elseif pState = TI_STATE_TBA then											// PAR #31196
	//	dict := self.myTerminal.allTbaTIsByCargoTypeId;							// PAR #31196
	//endif;																	// PAR #31196
																				// PAR #31196
	//if dict = null then														// PAR #31196
	//	return;																	// PAR #31196
	//endif;																	// PAR #31196
	
	if pTi &lt;&gt; null then
		tiId := pTi.id;
	endif;

	showTships := self.myTerminal.getConfig(ShowTranshipInPackUnpack).Boolean;	// PAR #31196
	
	app.cmsBeginLoad(ls);
	iter := dict.createIterator;
	dict.startKeyGeq(pCargoType, null, iter);
	while iter.next(ti) do
		iter.getCurrentKeys(cargoType, idStr);  //MTN-35226
		if cargoType &lt;&gt; pCargoType then
			break;
		endif;
		
		//if ti.getImExStatus = TI_IMEX_STATUS_TRANSHIP then					// PAR #31196
		if ti.getImExStatus = TI_IMEX_STATUS_TRANSHIP and not showTships then	// PAR #31196
			continue;
		endif;
		
		if ti.isChild then //cnwrd1 par 28413 10.10.2011
			continue;
		endif;
		
		//no ti's attached to stock bookings
		//+cnwml2 PAR 23925 CCMS MSL 1076
		if ti.myBookingRef &lt;&gt; null and ti.myBookingRef.isStockBookingRef then
			continue;
		endif;
		
		//+cnwml2 PAR25679 CCMS MSL 1076
		if _booking &lt;&gt; null then
			if ti.myBookingRef &lt;&gt; _booking and ti.bookingReference &lt;&gt; null then
				continue;
			endif;
		endif;
		
		count := count + 1;
		if count &gt;= 29999 then
			//jade limit for a combo - this'll happen for 
			//logs every time - possibly other cargo types too
			maxCountExceeded := true;
			break;
		endif;
		
		pCmb.itemObject[pCmb.addItem(idStr)] := ti;				
		if idStr = tiId then
			tiFound := true;
		endif;
	endwhile;
	app.cmsEndLoad(ls);
	
	if maxCountExceeded then
		app.msgBox('There were more than 32,000 tracked items of selected type.' &amp; CrLf &amp;
					'Only the first 32,000 have been listed', ' Maximum entries exceeded', MsgBox_Exclamation_Mark_Icon);
	endif;
	
	if tiFound then
		pCmb.text := tiId;
	else
		pCmb.text := null;
	endif;


epilog
	delete iter;
	app.cmsEndLoad(ls);
end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="pCargoType" type="Integer"/>
        <Parameter name="pTi" type="CM_TrackedItem"/>
        <Parameter name="_booking" type="CM_BookingRef"/>
        <Parameter name="_release" type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="comboBoxTrackedItemCmbPack2" id="6eb9ca48-5307-4a44-8ade-f0217a0f647c">
        <updating/>
        <source>comboBoxTrackedItemCmbPack2(	pCmb : ComboBox input; 
							pCargoType : Integer;
							pTi : CM_TrackedItem; 
							_booking : CM_BookingRef;
							_release : CM_BulkRelease ) updating;
/* Changes
// copied from comboBoxTrackedItemCmbPack
Date		Name	TFS#			Description
============================================================================
11/12/2015	cnwjre1	37288 TFS 1199 	add release for optional extra filtering by release criteria
21/08/2019	jlgka1 	46218 			JMT - Stop the getProspectivePackingParents  to findMore when it is coming from Web.
============================================================================*/
vars
	ti		: CM_TrackedItem;
	tiArray : CM_TIArray;
	tiId,
	idStr	: String;
	maxCountExceeded,
	tiFound		: Boolean;
	count		: Integer;
	showTships	: Boolean;														// PAR #31196

begin
	pCmb.clear;

	if pTi &lt;&gt; null then
		tiId := pTi.id;
	endif;

	showTships := self.myTerminal.getConfig(ShowTranshipInPackUnpack).Boolean;	// PAR #31196
	
	create tiArray transient;
	_release.getProspectivePackingParents( tiArray, false );	//jlgka1 46218
	foreach ti in tiArray do
		if ti.cargoType &lt;&gt; pCargoType then
			continue;
		endif;
		if ti.getImExStatus = TI_IMEX_STATUS_TRANSHIP and not showTships then	// PAR #31196
			continue;
		endif;
		
		if ti.isChild then
			continue;
		endif;
		
		//no ti's attached to stock bookings
		if ti.myBookingRef &lt;&gt; null and ti.myBookingRef.isStockBookingRef then
			continue;
		endif;
		if _booking &lt;&gt; null then
			if ti.myBookingRef &lt;&gt; _booking and ti.bookingReference &lt;&gt; null then
				continue;
			endif;
		endif;

		count := count + 1;
		if count &gt;= 29999 then
			//jade limit for a combo - this'll happen for 
			//logs every time - possibly other cargo types too
			maxCountExceeded := true;
			break;
		endif;
		
		pCmb.itemObject[pCmb.addItem(ti.id)] := ti;				
		if idStr = tiId then
			tiFound := true;
		endif;
	endforeach;
	
	if maxCountExceeded then
		app.msgBox('There were more than 32,000 tracked items of selected type.' &amp; CrLf &amp;
					'Only the first 32,000 have been listed', ' Maximum entries exceeded', MsgBox_Exclamation_Mark_Icon);
	endif;
	
	if tiFound then
		pCmb.text := tiId;
	else
		pCmb.text := null;
	endif;


epilog
	delete tiArray;
end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="pCargoType" type="Integer"/>
        <Parameter name="pTi" type="CM_TrackedItem"/>
        <Parameter name="_booking" type="CM_BookingRef"/>
        <Parameter name="_release" type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="comboBoxTrackedItemForRepack" id="99ed1be6-911d-49b1-a80e-ac99db4919cd">
        <updating/>
        <source>comboBoxTrackedItemForRepack(_cmb : CMUI_ComboBox input; 
							_terminal : CM_Terminal; 
							_id : String) updating;
// ---------------------------------------------------------------------------
// Created:     20 December 2000 by cnwrs2
//
// Purpose:     Setups the TI id's for a combo box
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ls					: Boolean;
	taIter				: Iterator;
	emptyCommodity		: String;
	foundIdx,
	idx					: Integer;
	ti					: CM_TrackedItem;
	ta					: CM_TerminalArea;
	lc					: CM_LocationsController;
begin
	_cmb.clear();
	_cmb.sorted := true;
		
	if _terminal = null then
		return;
	endif;
	
	emptyCommodity := self.myTerminal.getDefaultEmptyCommodity();
	
	taIter := _terminal.allTerminalAreasByTypeId.createIterator;
	_terminal.allTerminalAreasByTypeId.startKeyGeq(TA_TYPE_CONT_PACK_REPACK, null, taIter);
	
	app.cmsBeginLoad(ls);
	
	while taIter.next(ta) do
		if ta.type &lt;&gt; TA_TYPE_CONT_PACK_REPACK then
			break;
		endif;
		
		foreach lc in ta.allLocationsControllers discreteLock do
			foreach ti in lc.allTrackedItemsById discreteLock where ti.isKindOf(CM_Container) do
				//no longer need to check the ti is an empty commodity 
				if (not ti.isKindOf(CM_Container)) then
					break;
				endif;
				
				//+cnwml2 PAR25306
				if ti.getImExStatus = TI_IMEX_STATUS_TRANSHIP then
					continue;
				endif;
				idx := _cmb.addItem(ti.id);
				_cmb.itemObject[idx] := ti;
				
				if ti.id = _id then
					foundIdx := idx;
				endif;
			endforeach;
		endforeach;
	endwhile;
	
	if foundIdx &gt; 0 then
		_cmb.listIndex := foundIdx;
		
	else
		_cmb.listIndex := -1;
	endif;
	_cmb.lostFocus(_cmb);
	
epilog
	app.cmsEndLoad(ls);
	delete taIter;
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_id" type="String"/>
    </JadeMethod>
    <JadeMethod name="comboBoxTrackedItemToPack" id="c6b3c4db-f604-48a0-adf9-d4dd2f816896">
        <source>comboBoxTrackedItemToPack(_cmb : CMUI_ComboBox input; 
						_cargoType : Integer;
						_state : Integer; 
						_idStr : String);
// ---------------------------------------------------------------------------
// Created:     05 April 2004	cnwth2
//
// Purpose:     
//	14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  		 
// ----------   ----------  --------------------------------------------------
vars
	ti			: CM_TrackedItem;
	dict		: CM_TIByCargoTypeIdDict;
	iter		: Iterator;
	idStr		: String;
	count,
	cargoType	: Integer;
	maxCountExceeded,
	ls,
	tiFound		: Boolean;
	
begin

	_cmb.clear;
	
	if _cargoType = null then
		return;
	endif;
	
	if _state = TI_STATE_NORMAL then
		dict := self.myTerminal.allOnsiteTIsByCargoTypeId;
	elseif _state = TI_STATE_NOTIFIED then
		dict := self.myTerminal.allNotifiedTIsByCargoTypeId;
	elseif _state = TI_STATE_TBA then
		dict := self.myTerminal.allTbaTIsByCargoTypeId;
	
	elseif _state = TI_STATE_PLACEHOLDER then	//13 Mar 2020	NDL	TFS 47004
		dict := self.myTerminal.allRRPTIsByCargoTypeId;
		
	endif;

	if dict = null then
		return;
	endif;
	
	app.cmsBeginLoad(ls);
	iter := dict.createIterator;
	dict.startKeyGeq(_cargoType, null, iter);
	while iter.next(ti) do
		iter.getCurrentKeys(cargoType, idStr);  //MTN-35226
		if cargoType &lt;&gt; _cargoType then
			break;
		endif;
		count := count + 1;
		if count &gt;= 29999 then
			//jade limit for a combo - this'll happen for 
			//logs every time - possibly other cargo types too
			maxCountExceeded := true;
			break;
		endif;
		
		if ti.myParent &lt;&gt; null or
		   ti.myStockOrderTILine &lt;&gt; null then
			continue;
		endif;
		
		_cmb.itemObject[_cmb.addItem(idStr)] := ti;
		if idStr = _idStr then
			tiFound := true;
		endif;
		
	endwhile;
	
	app.cmsEndLoad(ls);
	
	if maxCountExceeded then
		app.msgBox('There were more than 32,000 tracked items of selected type.' &amp; CrLf &amp;
					'Only the first 32,000 have been listed', ' Maximum entries exceeded', MsgBox_Exclamation_Mark_Icon);
	endif;
	
	if tiFound then
		_cmb.text := _idStr;
	else
		_cmb.text := null;
	endif;

epilog
	delete iter;
	app.cmsEndLoad(ls);
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_cargoType" type="Integer"/>
        <Parameter name="_state" type="Integer"/>
        <Parameter name="_idStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="comboBoxTrailer" id="f2b69219-b661-4e16-84ae-b40c57ed8afe">
        <source>comboBoxTrailer(_cmb : ComboBox input; _trailer : CM_TIMaster; _includeAnyOption, _onsiteOnly : Boolean; _offsiteOnly : Boolean; _terminal : CM_Terminal);
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 01 June 2007
//
//	Adds the TIMasters of any TIMasterTIs that are currently onsite.  
//  Get the current ti of the master item and 
//  Add the master tracked item to the combo box not the ti itself
//----------------------------------------------------------------------

vars
	tiMasterDict  : CM_TIByCargoTypeIdDict;
	iter : Iterator;
	str : String;
	tiMaster : CM_TIMaster;
	ti : CM_TrackedItem;
	startIdx : Integer;
	terminal : CM_Terminal;
	include : Boolean;
begin
	_cmb.clear();
	_cmb.sorted := false;
	_cmb.addItem(null);
	terminal := _terminal;
	
	foreach tiMaster in app.myRoot.allTiMasters discreteLock where tiMaster.isTILC and tiMaster.allTis.isNotEmpty do
		include := false;
		ti := tiMaster.getCurrentTi();
		if ti &lt;&gt; null then
			if _onsiteOnly and terminal &lt;&gt; null then
				if ti.isOnSite and ti.myTerminal = terminal then 
				//ti.myPrimaryActualLocation &lt;&gt; null and ti.myTerminal = terminal then
					include := true;
					//_cmb.itemObject[_cmb.addItem(self.displayEntryTrailer(tiMaster))] := tiMaster;
				endif;
			elseif _offsiteOnly then
				if ti.isOffSite then
					include := true;
				endif;
			else
				include := true;
				//_cmb.itemObject[_cmb.addItem(self.displayEntryTrailer(tiMaster))] := tiMaster;
			endif;
		endif;
		
		if include then
			_cmb.itemObject[_cmb.addItem(self.displayEntryTrailer(tiMaster))] := tiMaster;
		endif;
	endforeach;
		
	if _trailer &lt;&gt; null then
		startIdx := _cmb.findObject(_trailer);
	endif;
	
	if startIdx &gt; 0 then
		_cmb.listIndex := startIdx;
	elseif _includeAnyOption then
		_cmb.text := Any_String;
	endif;
		
epilog

end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_trailer" type="CM_TIMaster"/>
        <Parameter name="_includeAnyOption" type="Boolean"/>
        <Parameter name="_onsiteOnly" type="Boolean"/>
        <Parameter name="_offsiteOnly" type="Boolean"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="comboBoxTrailerCargoType" id="1ef54736-1373-4d0d-9e4e-cadff7888b98">
        <source>comboBoxTrailerCargoType(pCmb : ComboBox input; _dfltTrailerCargoType : Integer);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 August 2025	navsp1	Initial creation JIRA-35530 Solution Implementation - COPRAR Trailer Support

*/
vars
	cargoType,
	defCargoType: CM_CargoType;
	idx, tmpId  : Integer;
	terminal	: CM_Terminal;
begin
	terminal := self.myTerminal;
	pCmb.sorted := true;
	pCmb.clear();	
	
	foreach cargoType in app.myRoot.allCargoTypesById do
		if cargoType.isNotAvailableForEntry then
			continue;
		endif;
		
		if cargoType.productType &lt;&gt; ProductType_Trailer then
			continue;
		endif;
		
		if not cargoType.allTerminals.includes(terminal) then
			continue;
		endif;
        
        tmpId := cargoType.id;
		
		idx := pCmb.addItem(self.displayEntryCargoBolType(cargoType));
		pCmb.itemObject[idx] := cargoType;
        
        if tmpId = _dfltTrailerCargoType then
			defCargoType := cargoType;
		endif;
	endforeach;
    
 	if defCargoType &lt;&gt; null then
		pCmb.text := self.displayEntryCargoBolType(defCargoType);		
		pCmb.listIndex := pCmb.findObject(defCargoType);
	endif;   
end;</source>
        <Parameter name="pCmb" type="ComboBox" usage="input"/>
        <Parameter name="_dfltTrailerCargoType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="comboBoxTrailerType" id="7d5847c6-544d-4b24-b696-b556bcfc91d4">
        <source>comboBoxTrailerType(_cmb : ComboBox input;
					_cargoType : CM_CargoType;
					_trailerType : CM_TILCType;
					_terminal : CM_Terminal);

/*
Date			Who		Reason
23 February 2010	cnwar2	Initial creation
06 Dec 2012			cnwcs5	par 30852 - add isNotAvailableForEntry for trailer type 

*/
vars
	iter 		: Iterator;
	type 		: CM_TILCType;
	index, int	: Integer;
	
begin
	_cmb.clear();

	if _cargoType &lt;&gt; null then
		iter := _cargoType.allTILCTypes.createIterator;
	else
		iter := app.myRoot.allTILCTypes.createIterator;
	endif;
	
	while iter.next(type) do
		// always include _trailerType but exclude other
		// which are not available for entry
		if type.isNotAvailableForEntry  then
			continue;
		endif;
		
		//cnwmc5 - 14 March 2014 - PAR 33659
		//if _trailerType &lt;&gt; null and type &lt;&gt; _trailerType then
		//	continue;
		//endif;
	
		if not type.myCargoType.allTerminals.includes(_terminal) then
			continue;
		endif;
	
		index := _cmb.addItem(type.description);		
		_cmb.itemObject[index] := type;
	endwhile;
	
	if _trailerType &lt;&gt; null then 
		int := _cmb.findObject(_trailerType);
		_cmb.listIndex := int;
	endif;	

epilog
	delete iter;	
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_trailerType" type="CM_TILCType"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="comboBoxTrain" id="2ee49729-2dc6-41b2-8719-ffc1b3a00fca">
        <source>comboBoxTrain(_cmb 					: CMUI_ComboBox input; 
				_train 				: CM_Train; 
				_includeNull,
				_includeAnyOption,
				_includeDeparted	: Boolean);
/*
----------   ----------  --------------------------------------------------
Created:	07 November 2006 By cnwth2

Purpose:	

Changed On  Changed By  Reason
26/09/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
----------  ----------  --------------------------------------------------
*/
vars
	desc				: String;
	invalidTrain 		: Boolean;
	train				: CM_Train;
	trainDict			: CM_TrainByCodeDateDict;
	trainDepDict		: CM_TrainByCodeDepatureDTDict;
	foundIdx			: Integer;
	tmpTerm : CM_Terminal;
	
begin
	on Exception do app.handleDeletedObject(exception, train, invalidTrain);

	tmpTerm := self.myTerminal;
	if tmpTerm = null then
		if app.myPassport = null then
			return;
		endif;
		tmpTerm := app.myPassport.myTerminal;
	endif;
	if tmpTerm = null then
		return;
	endif;
	
	_cmb.clear();
	_cmb.sorted := false;
	
	if _includeAnyOption then
		_cmb.addItem("&lt;" &amp; app.getErrorString(GIVE_ME_ALL_DA_TRAINS_YO) &amp; "&gt;");
	endif;
	
	trainDict := tmpTerm.allTrainsOnTerminal;
	foreach train in trainDict do
		if not _includeNull and train.isNullTrain() then
			continue;
		endif;
		
		invalidTrain := false;
		desc := train.description;
		if not invalidTrain then
			_cmb.itemObject[_cmb.addItem(self.displayEntryTrain(train))] := train;
		endif;
	endforeach;
	
	if _includeDeparted then
		trainDepDict := tmpTerm.allTrainsDeparted;
		foreach train in trainDepDict do
			invalidTrain := false;
			desc := train.description;
			if not invalidTrain then
				_cmb.itemObject[_cmb.addItem(self.displayEntryTrain(train))] := train;
			endif;
		endforeach;
	endif;
	
	if _train &lt;&gt; null then
		foundIdx := _cmb.findObject(_train);
	endif;
	
	if foundIdx &gt; 0 then
		_cmb.listIndex := foundIdx;
		
	else
		if _train &lt;&gt; null then
			foundIdx := _cmb.addItem(self.displayEntryTrain(_train));
			_cmb.itemObject[foundIdx] := _train;
			_cmb.listIndex := foundIdx;
		endif;
		if _includeAnyOption then
			_cmb.text := "&lt;" &amp; app.getErrorString(GIVE_ME_ALL_DA_TRAINS_YO) &amp; "&gt;";
		endif;
	endif;
		
	
end;


</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_train" type="CM_Train"/>
        <Parameter name="_includeNull" type="Boolean"/>
        <Parameter name="_includeAnyOption" type="Boolean"/>
        <Parameter name="_includeDeparted" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="comboBoxTranshipToPort" id="ce8357c6-a068-4942-8c09-941ea4a54db7">
        <source>comboBoxTranshipToPort(_cmb : ComboBox input; _port : CM_Port);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 November 2009	cnwas3	Initial creation

*/

vars
	carrier			: CM_Carrier;
	carrierDict		: CM_CarrierByCodeDict;
	//portDict		: CM_PortsBy;
begin
	/*_cmb.clear();	
	carrierDict := app.myRoot.allCarriers;
	//app.myRoot.allPorts[dischargePort];
		
	foreach carrier in carrierDict do
		_cmb.itemObject[_cmb.addItem(self.displayEntryCarrier(carrier))] := carrier;
	endforeach;
	
	if _carrier &lt;&gt; null and _carrier.isRail and
	   app.myRoot.allCarriers.includes(_carrier) then
		_cmb.text := self.displayEntryCarrier(_carrier);
	   	_cmb.listObject := _carrier;
	endif;
	*/
end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_port" type="CM_Port"/>
    </JadeMethod>
    <JadeMethod name="comboBoxTransitStatus" id="68816a57-1ef6-4826-b30f-ce34898b22c8">
        <source>comboBoxTransitStatus(_cmb : ComboBox input; _transitStatus : Integer);
// ---------------------------------------------------------------------------
// Created:     10 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	transitDict				: CM_TransitStatusByCodeDict;
	transitStatus			: CM_TransitStatus;
begin
	_cmb.clear();
	transitDict := app.myRoot.allTransitStatuses;
	foreach transitStatus in transitDict do
		_cmb.itemObject[_cmb.addItem(transitStatus.description)] := transitStatus;
	endforeach;
	
	transitStatus := transitDict[_transitStatus];
	if transitStatus &lt;&gt; null then
		_cmb.listObject := transitStatus;
	endif;

end;</source>
        <Parameter name="_cmb" type="ComboBox" usage="input"/>
        <Parameter name="_transitStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="comboBoxTransportMode" id="c14fad27-568a-444a-ac2b-365d5276ea48">
        <source>comboBoxTransportMode(pTbl : CM_EntryTable input; pAttrName : String; pDefault : Integer);
// ---------------------------------------------------------------------------
// Created:     02 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	// may need to add a parameter in the future so can determine which values
	// to display (TI_TRANSMODE_SHIP has been deliberately left off here)

	pTbl.setComboValues(pTbl.getRow(pAttrName), 
						TI_TRANSMODE_ROAD_STR &amp; Tab &amp;
						TI_TRANSMODE_RAIL_STR &amp; Tab &amp;
						TI_TRANSMODE_SHIP_STR &amp; Tab &amp;
						TI_TRANSMODE_NULL_STR);
	
	// check that default value exists in the combolist
	if pDefault = TI_TRANSMODE_ROAD or
		pDefault = TI_TRANSMODE_RAIL or
		pDefault = TI_TRANSMODE_SHIP or
		pDefault = TI_TRANSMODE_NULL then
		pTbl.setValueByName(pAttrName, self.transModeToString(pDefault));
	endif;
						
end;</source>
        <Parameter name="pTbl" type="CM_EntryTable" usage="input"/>
        <Parameter name="pAttrName" type="String"/>
        <Parameter name="pDefault" type="Integer"/>
    </JadeMethod>
