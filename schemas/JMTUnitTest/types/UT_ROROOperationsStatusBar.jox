    <JadeMethod name="xPAR31367StatusBarStep9" id="91fda936-d887-4d8c-9c35-8e5ca8d3fbd3">
        <updating/>
        <source>xPAR31367StatusBarStep9() updating;

/*

Purpose:		Load the cargo to the voyage and check that status bar details are correct	

Date			Who		Reason
13/05/2013		cnwmh5	Initial creation

*/
vars

	realAlloc 							: CM_VoyageAllocation;
	lc									: CM_LocationsController;
	cargo								: CM_TrackedItem;
	
	str									: String;
	idx									: Integer;

begin

	app.writeLog("STEP 9", LogINFO);
	app.writeLog("Load the cargo to the voyage.  Please wait...", LogINFO);
	
	// load the rest of the items
	self.locationArray.clear();
	self.locationArray.add("D40131");
	self.locationArray.add("D40181");
	self.locationArray.add("D40182");
	self.locationArray.add("D40183");
	self.locationArray.add("D40184");
	
	self.roroLCs.clear();
	self.tisToPlanArray.clear();
	foreach str in self.locationArray do
		lc := self.myVoyage.getLocationByID(str);
		self.roroLCs.add(lc);
		lc.getTIs(self.tisToPlanArray, PLANNING_MODE, false);
	endforeach;
		
	foreach idx in 1 to self.roroLCs.size do
		cargo := self.tisToPlanArray[idx];
		self.moveAllCargoOnVoyage(self.myVoyage, REAL_MODE);
		self.assertNoTrxErrorsOrWarnings();
	endforeach;
	
	return;
	
	// check that the details of the status bar is correct - Planned 5 items
	app.writeLog("Checking Status Bar details are correct for 5 planned load items.  Please wait...", LogINFO);
	self.locationArray.clear();
	self.statusArray.clear();
	self.locationArray.add("D4018");
	self.statusArray.add("D4018 D4018 | Aft: D4013 | 2 x CONT ITGOA  U20G| 3 x CONT ITGOA  U40G | UT313670014, UT313670024, UT313670024, UT313670026, UT313670013 Job: 202");
	self.locationArray.add("D4003");
	self.statusArray.add("D4003 D4003 |  Fwd: D4008 | 2 x CONT NZLYT  U20G | UT313670009, UT313670010");
	
	self.xCheckStatusBarCorrect(ShpDisplayMode_Actual, ShpDisplayMode_ColCodeLoad, ShpDisplayModeSub_ExportsHide, method.qualifiedName, 1);


	// check that the details of the discharge status bar is correct - SHOW EXPORTS
	app.writeLog("Checking Status Bar (SHOW) details are correct.  Please wait...", LogINFO);
	self.locationArray.clear();
	self.statusArray.clear();
	self.locationArray.add("D4018");
	self.statusArray.add("D4018 D4018 | Aft: D4013  | 2 x CONT ITGOA U20G| 3 x CONT ITGOA U40G | UT313670014, UT313670024, UT313670025, UT313670026, UT313670013");
	self.locationArray.add("D4003");
	self.statusArray.add("D4003 D4003 |  Fwd: D4008 | 2 x CONT NZLYT  U20G | UT313670009, UT313670010");
	self.locationArray.add("D4005");
	self.statusArray.add("D4005 D4005 |  Fwd: D4010 | 1 x CONT NZLYT  U20G | UT313670019");
	self.locationArray.add("D4006");
	self.statusArray.add("D4006 D4006 |  Fwd: D4011 | 3 x CONT NZLYT  U20G | UT313670013, UT313670014, UT313670015");
	self.locationArray.add("D4033");
	self.statusArray.add("D4033 D4033 | Aft: D4028 | 3 x CONT NZLYT  U20G | UT313670016, UT313670017, UT313670018");
	
	self.xCheckStatusBarCorrect(ShpDisplayMode_Actual, ShpDisplayMode_ColCodeDisch, ShpDisplayModeSub_ExportsShow, method.qualifiedName, 2);
	
	// check that the details of the discharge status bar is correct - HIDE EXPORTS
	app.writeLog("Checking Status Bar (HIDE) details are correct.  Please wait...", LogINFO);
	self.locationArray.clear();
	self.statusArray.clear();
	self.locationArray.add("D4013");
	self.statusArray.add("D4013 D4013 |  Fwd: D4018 | 3 x CONT NZLYT  U20G| 1 x CONT NZAKA  U20G | UT313670001, UT313670002, UT313670003, UT313670004 Job: 200");
	self.locationArray.add("D4018");
	self.statusArray.add("D4018 D4018 | Aft: D4013 | 3 x CONT NZLYT  U20G| 1 x CONT NZAKA  U20G | UT313670005, UT313670006, UT313670007, UT313670008 Job: 200");
	self.locationArray.add("D4003");
	self.statusArray.add("D4003 D4003 |  Fwd: D4008 | 3 x CONT NZLYT  U20G| 1 x CONT NZAKA  U20G | UT313670009, UT313670010, UT313670011, UT313670012 Job: 201");
	self.locationArray.add("D4005");
	self.statusArray.add("D4005 D4005 |  Fwd: D4010 | 1 x CONT NZLYT  U20G | UT313670019");
	self.locationArray.add("D4006");
	self.statusArray.add("D4006 D4006 |  Fwd: D4011 | 3 x CONT NZLYT  U20G | UT313670013, UT313670014, UT313670015");
	self.locationArray.add("D4033");
	self.statusArray.add("D4033 D4033 | Aft: D4028 | 3 x CONT NZLYT  U20G | UT313670016, UT313670017, UT313670018");
	
	self.xCheckStatusBarCorrect(ShpDisplayMode_Actual, ShpDisplayMode_ColCodeDisch, ShpDisplayModeSub_ExportsHide, method.qualifiedName, 3);
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="xPAR31367StatusBarStepA1" id="6aa3c222-dad7-4bab-b7e9-2585fee4fb0e">
        <updating/>
        <source>xPAR31367StatusBarStepA1() updating;

/*

Purpose:		Create the cargo on the vaoyge and check that the status bar is correct

Date			Who		Reason
16/03/2013		cnwmh5	Initial creation

*/

constants

	ContainerPartialId					: String = 'UT31367';

vars

	port								: CM_Port;
	cargo								: CM_TrackedItem;
	theSlot								: CM_LocationsController;
	job 								: CM_VoyageJob;
	req 								: CM_RORORequest;
	locnDefnVoyage 						: CM_ROROLocnDefnVoyage;
	slotDefn 							: CM_ROROSlotDefn;
	slotLC 								: CM_ROROSlotController;
	

	strs								: StringArray;
	tmpStrArray							: StringArray;
	
	idCount								: Integer;
	idx									: Integer;
	index								: Integer;
	detailsToCheck						: String;
	detailsToCheckFromMethod			: String;

begin

	app.writeLog("STEP A1", LogINFO);
	app.writeLog("Creating containers on ship.  Please wait...", LogINFO);
	
	port := app.myRoot.allPorts["AUSYD"];
	
	// setup some containers
	self.opts.purge;
	self.opts.addAssoc("CENum", "123");
		
	create strs transient;
	strs.add("D40211");
	strs.add("D40212");
	strs.add("D40213");
	strs.add("D40214");
	strs.add("D40215");
	strs.add("D40603");
	strs.add("D40604");
	strs.add("D40605");
	strs.add("D40401");
	strs.add("D40402");
	strs.add("D40403");
	strs.add("D40404");
	strs.add("D40434");
	strs.add("D40435");
	strs.add("D40443");
	strs.add("D40444");
	strs.add("D40445");
	
	create tmpStrArray transient;
	foreach index in 1 to strs.size do
	
		tmpStrArray.clear();
		tmpStrArray.add(strs[index]);
		myVoyage.findLocation(tmpStrArray, false, theSlot, idx);
		self.cargoCountId := self.cargoCountId + 1;
		cargo := self.addContainerAtLocnDisch(ContainerPartialId &amp; self.cargoCountId.padLeadingWith("0", 4), "U40G", "GENL", TI_IMEX_STATUS_REMAINONBOARD, theSlot, port, self.myVoyage);
		self.assertNotNull(cargo);
		self.deleteStops(cargo);
	
	endforeach;

	
	strs.clear();
	strs.add("D40551");
	strs.add("D40552");
	strs.add("D40601");
	strs.add("D40602");
	strs.add("D40361");
	strs.add("D40362");
	strs.add("D40363");
	strs.add("D40364");
