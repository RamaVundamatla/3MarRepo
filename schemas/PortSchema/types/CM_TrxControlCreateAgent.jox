    <JadeMethod name="trxCreateRORODischargeCCs" id="665c9807-c859-4288-81c8-d6f6149cfb4a">
        <updating/>
        <source>trxCreateRORODischargeCCs(_lcs : CM_LCSet input; _passport : CM_Passport input) updating;
/*
Purpose:			
Date				Who			Reason
JUNE 2011		CNWAB1		Initial creation
*/

vars
	realROROController : CM_VoyageROROController;
	lc : CM_LocationsController;
	layout : CM_DeckItemLayout;
	layer : CM_DeckLayerLayout;
	theVoyage : CM_Voyage;
	theTerminal : CM_Terminal;
	theMaster, theCloneMaster : CM_ROROLocnDefn;
	allMasters : ObjectSet;
begin

// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	create allMasters transient;
	
	beginTransaction;
	foreach lc in _lcs discreteLock do
		realROROController := lc.CM_VoyageROROController;
		app.myUtilityCA.utlCreateROROSlotDischargeCC(realROROController, _passport);
		
		if _passport.hasErrorsOrWarnings() then
			return;
		endif;
		theVoyage := realROROController.myVoyage;
		theTerminal := theVoyage.myTerminal;
		app.myEventManager.createSingleObjInfoNoteEvt(
								theVoyage,
								theTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA),
								realROROController);

		// PAR 31110 - CCMS 1320
		theMaster := realROROController.getRotationMaster();
		if theMaster &lt;&gt; null and not theMaster.isOOTL() then
			allMasters.addNoDuplicates(theMaster, false);
		endif;
								
	endforeach;

	if _passport.hasErrorsOrWarnings() then
		return;
	endif;	
	
	// PAR 31110 - CCMS 1320 if everything in the rotated actual is colour coded for discharge then clone and unrotated the load view.
	app.myUtilityCA.utlCreateRORORotateSwitchLoad(allMasters, _passport);

epilog
	delete allMasters;

	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_lcs" type="CM_LCSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
