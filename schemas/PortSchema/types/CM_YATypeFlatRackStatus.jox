    <JadeMethod name="resolvePattern" id="2c0c2ffe-6f23-42c7-aef7-f611df4362d2">
        <source>resolvePattern(_pattern: String; _objectSet: ObjectSet input; _raiseException: Boolean);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/09/2020	jlgdap1		Initial creation TFS 49953 MTN Satellite View Criteria Search doesn't work for some criteria
//
vars

begin
	self.resolvePatternEx(_pattern, _objectSet);

epilog
	
end;</source>
        <Parameter name="_pattern" type="String"/>
        <Parameter name="_objectSet" type="ObjectSet" usage="input"/>
        <Parameter name="_raiseException" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="resolvePatternEx" id="d9651299-48dd-4fac-8387-b722b59351cb">
        <source>resolvePatternEx(_pattern: String; _objectSet: ObjectSet input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/09/2020	jlgdap1		Initial creation TFS 49953 MTN Satellite View Criteria Search doesn't work for some criteria
//
vars
	token: String;
	tokens: StringArray;
	pattern: CMIF_YAPattern;
	rackStatus: CMIF_FlatRackStatus;

begin
	create pattern transient;
	pattern.setPattern(_pattern, CMIF_YAPattern.YAPattern_Wildcard);
	
	create tokens transient;
	pattern.getTokens(pattern.pattern, tokens);
	foreach token in tokens do
		token.replace('!', '');
		create rackStatus transient;
		rackStatus.status := token;
		_objectSet.add(rackStatus);
	endforeach;

epilog
	delete tokens;
	delete pattern;
end;</source>
        <Parameter name="_pattern" type="String"/>
        <Parameter name="_objectSet" type="ObjectSet" usage="input"/>
    </JadeMethod>
</Class>
