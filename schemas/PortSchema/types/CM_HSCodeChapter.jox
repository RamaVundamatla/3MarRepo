    <JadeMethod name="pxyCreateUpdateProxy" id="8af2d9c5-1849-4065-ac81-ed914164124e">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
28 November 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars

	proxy 		: CM_HSCodeChapter;
	completedOK	: Boolean;
	
begin

	proxy := inheritMethod();
	
	proxy.myHSSection := self.myHSSection;

	completedOK := true;
	return proxy;
	
epilog

	if not completedOK then
		delete proxy;
	endif;
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
