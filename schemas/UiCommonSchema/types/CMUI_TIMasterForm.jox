    <JadeMethod name="displayExtraInfo" id="6056e655-1df0-476e-94df-fd9e8fea2a57">
        <source>displayExtraInfo()protected;
//--------------------------------------------------
// Created:	15 July 2005 By: cnwgd1
//--------------------------------------------------
vars

	dataContainer : CM_DataContainer;
	wle 		: CM_WorkListEntry;
	strArray	: HugeStringArray;
//	cargoType	: CM_CargoType;
	x1, x2, 
	y1, y2,
	tmpYOffset,
	scaleFactor	: Integer;
	graphic		: CM_TIBehaviourGraphic;
	
begin
	
	self.tblInfo.rows := 0;
	if self.myCurrentTiMaster = null then
		return;
	endif;
	
	create dataContainer transient;
	dataContainer.headerColour := self.colorHeadingColumn;
	dataContainer.valueColour := self.colorValueColumn;
	
	self.myCurrentTiMaster.getExtraInfo(dataContainer);

	self.tblInfo.userObject	:=	self.myCurrentTiMaster; // this is used to redraw this info
	self.showExtraInformation(dataContainer, self.tblInfo, true,false,4,1,4,1,1);
	scaleFactor := 1;
	//cargoType	:= self.myCurrentTiMaster.getCargoType();
	/*if cargoType &lt;&gt; null and cargoType.myTIBehaviourType.myGraphic &lt;&gt; null then
		graphic := cargoType.myTIBehaviourType.myGraphic;
		x1	:= 0;
		x2	:= self.frmPictureActual.width.Integer;
		y1	:= 0;
		y2	:= self.frmPictureActual.height.Integer;

		tmpYOffset := (y2 - (graphic.maxY * scaleFactor).Integer);
		graphic.drawGraphic(self.frmPictureActual, 0, scaleFactor, x1, tmpYOffset, false, 0, graphic.maxX, true, true,null, NullColour);

	endif;*/
	
//	self.tblInfo.fitColumnWidths();
	self.doResizeColumnWidths(self.tblInfo, true);
	
epilog
	delete dataContainer;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayTiMasters" id="8226b077-e06d-4ae6-918f-18a1f5266cf1">
        <updating/>
        <source>displayTiMasters(_col : CM_ObjectSet)updating, protected;
//--------------------------------------------------
// Created:	18 July 2005 By: cnwgd1
//--------------------------------------------------
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks
*/
vars
	master			: CM_TIMaster;
	obj				: Object;
	cnt,
	partsInJob,
	partsDone		: Integer;
	str				: String;
	records 		: Integer;
	iter			: Iterator;
	invalidObject 	: Boolean;
begin

	//self.myCurrentTiMaster := null;
	
	
	//self.tblData.resetColumns(true);

	app.mousePointer := self.MousePointer_HourGlass;				


	
	//self.tblData.rows := self.tblData.fixedRows;
	self.tblInfo.rows := 0;
//	self.picVessel.picture := null;
	self.tblData.clearAllSelected();
	self.tblData.clearAllData();
	
	if _col = null then
		self.loadNewData();
	else
		on Exception do app.handleDeletedObject(exception, obj, invalidObject);
		iter := _col.createIterator;
		while iter.next(obj) do
	
			// Otherwise, add it to the table
			self.tblDataDisplayRow(obj.CM_TIMaster);
	
		endwhile;
	endif;
//	self.doResizeColumnWidths(self.tblData, true);
	
	//self.tblData.resetColumns(true);
	if self.myCurrentTiMaster &lt;&gt; null then
		self.tblData.selectObject (  self.myCurrentTiMaster ,false) ;		
	endif;
	
	self.setStatusCaption();	
	app.mousePointer := self.MousePointer_Default;
	

	self.tblData.colourRows(self.colorRow1, self.colorRow2);
	if not self.tblData.selectObject( self.myCurrentTiMaster, false) then	//Par17776
		if self.tblData.rows &gt; self.tblData.fixedRows then
			self.tblData.selectRow(self.tblData.fixedRows + 1, false);		
			self.setCurrentTiMaster(self.tblData.accessRow(self.tblData.row).itemObject.CM_TIMaster);
		endif;
	endif;
	
	
	self.frmModalDialog.visible := false;	
	
epilog
	delete iter;		// PAR #26678
end;</source>
        <access>protected</access>
        <Parameter name="_col" type="CM_ObjectSet"/>
    </JadeMethod>
    <JadeMethod name="displayWagonMasters" id="4174f570-2e9f-49b2-ad55-fc4b81583d93">
        <updating/>
        <source>displayWagonMasters(_col : CM_ObjectSet)updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 July 2009	cnwndl1	Initial creation

*/

vars

	obj				: Object;
	iter			: Iterator;
	invalidObject 	: Boolean;
	
begin

	app.mousePointer := self.MousePointer_HourGlass;				

	self.tblInfo.rows := 0;
	self.tblData.clearAllSelected();
	self.tblData.clearAllData();
	
	if _col = null then
		self.loadNewWagonMasterData();
	else
		on Exception do app.handleDeletedObject(exception, obj, invalidObject);
		iter := _col.createIterator;
		while iter.next(obj) do
			self.tblDataDisplayRow(obj.CM_Object);
		endwhile;
	endif;

	if self.myCurrentWagonMaster &lt;&gt; null then
		self.tblData.selectObject (  self.myCurrentWagonMaster ,false) ;		
	endif;
	
	self.setStatusCaption();	
	app.mousePointer := self.MousePointer_Default;
	
	self.tblData.colourRows(self.colorRow1, self.colorRow2);
	if not self.tblData.selectObject( self.myCurrentWagonMaster, false) then
		if self.tblData.rows &gt; self.tblData.fixedRows then
			self.tblData.selectRow(self.tblData.fixedRows + 1, false);		
			self.setCurrentTiMaster(self.tblData.accessRow(self.tblData.row).itemObject.CM_WagonMaster);
		endif;
	endif;
		
	self.frmModalDialog.visible := false;	
	
epilog

	delete iter;
	
end;</source>
        <access>protected</access>
        <Parameter name="_col" type="CM_ObjectSet"/>
    </JadeMethod>
