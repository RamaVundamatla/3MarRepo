    </ImplicitInverseRef>
    <ImplicitInverseRef name="object2" id="c6536ff8-3abb-4bf9-89b3-d0bde47cf30d">
        <embedded/>
        <type name="Object"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="objects" id="8bf447c1-8402-4f2a-94fa-bf3ff7cd04fc">
