    <JadeMethod name="setupForm" id="bd9cdc3c-b62e-418a-b9e8-03f66525b857">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Jan 2023 navtnr20	TFS CR 55622 Task 55692: UI - Shipping Terms Maint
06 October 2023	navmv20 Bug 60635: FR | 54089 EUP -Invoice Contracts - Shipping Terms
*/

vars

begin
	inheritMethod();
	self.doPermissions();
	self.handleMenusForModalDisplay();
	if self.mode then
		self.populateShipterms();	
	endif;
	self.initTblShipMapping(ETDef_ShipMappingList);
