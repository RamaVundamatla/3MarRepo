    <JadeMethod name="populateEntDetailTable" id="4f5af7a6-e527-4e08-a0b4-d6809cfefa66">
        <updating/>
        <source>populateEntDetailTable() updating;
// ---------------------------------------------------------------------------
// Created:     02 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	tableDefObj		: EntTableDef;
	tableRowObj		: EntTableRow;
	productObj		: CM_Product;
	cargoType		: CM_CargoType;
	operatorObj		: CM_Operator;
	prodGroupObj	: CM_ProductGroup;
	handlingType	: CM_HandlingType;
	displayValue	: String;
	
begin

	tableDefObj	:=	self.getTblEntDetailDef;
	productObj	:=	self.myProxyObject.CM_Product;
	
	if self.mode = Mode_Add then
		foreach tableRowObj in tableDefObj.allEntTableRows do
			tblEntDetail.setValueByName(tableRowObj.name, null);		
		endforeach;
		//when adding, assume the user wishes to create a product of the same cargo type
		//operator and handling type as that by which he/she is filtering
		cargoType		:=	self.cmbFiltCargoType.listObject.CM_CargoType;
		operatorObj		:=	self.cmbFiltOperator.listObject.CM_Operator;
		prodGroupObj	:=	self.cmbProdGroup.listObject.CM_ProductGroup;
		
		if cargoType &lt;&gt; null then
			self.cmbEntCargoType.listObject := cargoType;
			self.tblEntDetail.setValueByName(ETRow_EntCargoType, cargoType.description); 
			handlingType := cargoType.myDefaultHandlingType;
			// This is the new one for after 7.4.1 release	
			//handlingType := cargoType.getAttributeValue(CM_CargoTypeExtBreakBulkGen::myDefaultHandlingType.name).CM_HandlingType;
		endif;
		
		if operatorObj &lt;&gt; null then
			self.cmbEntOperator.setObject(operatorObj);
			self.tblEntDetail.setValueByName(ETRow_EntOperator, operatorObj.code &amp; '   ' &amp; operatorObj.description);
		endif;
		
		if handlingType &lt;&gt; null then
			self.cmbEntHandling.listObject := handlingType;
			self.tblEntDetail.setValueByName(ETRow_EntHandling, handlingType.description); 
		endif;
		
		self.tblEntDetail.enableRowByName(ETRow_EntCargoType);
		self.tblEntDetail.enableRowByName(ETRow_EntOperator);
		
	elseif self.mode = Mode_Update then
		
		//set the combo list objects to correspondto product references, then the attributes
		self.cmbEntCargoType.listObject	:=	productObj.myCargoType;
		self.cmbEntOperator.setObject(productObj.myOperator);
		self.cmbEntHandling.listObject	:=	productObj.myHandlingType;
		//epr  10/10/06 par 12702
		self.cmbProdGroup.setIndexFromObject(productObj.myProductGroup);//cnEcSetObjectIndex(prodGroupObj);
		
		foreach tableRowObj in tableDefObj.allEntTableRows do
			displayValue	:=	productObj.getDisplayStringForAttribute(tableRowObj.name, false).String;
			tblEntDetail.setValueByName(tableRowObj.name, displayValue);		
		endforeach;
		
		//disable necessary rows
		self.tblEntDetail.disableRowByName(ETRow_EntCargoType);
		//self.tblEntDetail.disableRowByName(ETRow_EntOperator); epr par 30752 28/11/12 
		
	endif;
	
	self.populateHandlingSubTypes( productObj );	//31 Mar 2017	NDL	TFS 3414
	
	self.showHideDefaultCommodity();	//CCMS 1080 PAR19704. Showing / hiding default Commodity
	
end;</source>
    </JadeMethod>
    <JadeMethod name="populateHandlingSubTypes" id="63445195-e09a-4529-badd-35731b8cf995">
        <updating/>
        <source>populateHandlingSubTypes( _product : CM_Product )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 March 2017	cnwndl1	Initial creation	TFS 3414
13 Jun 2017	NDL	- Seesaw seesaw.... Olivier and the magic roundabout... Now we want no default

*/

vars

	handlingType : CM_HandlingType;
	handlingSubType : CM_HandlingSubType;

begin

	self.allHandlingSubTypes.clear();
	self.cmbSubHandl.clear();
	
	handlingType := self.cmbEntHandling.listObject.CM_HandlingType;
	
	if handlingType = null then
		//do nothing
	else
		handlingType.getValidSubTypes( self.allHandlingSubTypes, false );
	endif;
	
	if self.allHandlingSubTypes.isEmpty then
		self.tblEntDetail.hideRowByName(ETRow_HandlingSubType,false);
		self.tblEntDetail.setValueByName(ETRow_HandlingSubType, null);
	else
		self.tblEntDetail.showRowByName(ETRow_HandlingSubType,false);
		self.tblEntDetail.refresh;
		//self.cmbSubHandl.listCollection(self.allHandlingSubTypes, false, 0);
		self.myAssistant.comboBoxSubHandlingTypes( self.cmbSubHandl, handlingType );	//13 Jun 2017
		
		if _product &lt;&gt; null and _product.myHandlingSubType &lt;&gt; null then
			handlingSubType := _product.myHandlingSubType;
	//	else
	//		handlingSubType := handlingType.getDefaultSubHandlingType;
		endif;
		if handlingSubType &lt;&gt; null then
			self.cmbSubHandl.listObject := handlingSubType;
			self.tblEntDetail.setValueByName(ETRow_HandlingSubType, handlingSubType.description);
		else
			self.tblEntDetail.setValueByName(ETRow_HandlingSubType, null);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_product" type="CM_Product"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="54b7f3c5-de9f-478b-b79b-042ae3e919ef">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:     02 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
//	cargoType			: CM_CargoType;
//	op					: CM_Operator;
//	realPro,
	pxyProduct			: CM_Product;
	row					: Integer;
	clearCellText		: Boolean;
	
begin
	inheritMethod();
//	self.sptMain.setLeftToRightRatioAndResize(0);
	
	self.loadCombos();	//get the latest
	self.populateEntDetailTable();
	self.tblEntDetail.optimiseHeadingColumn();
	self.resize();
	self.isCloning := false; // to reset vaule if previously used
	
	if self.mode = Mode_Add then
		// btnCloneProduct has been moved here as can cause error if used when edit due to proxy object not being created
		self.btnCloneProduct.enabled := true; 
		//need to create proxy product object now, rather than at doSave as would be normal, because the 
		//allProductAttrs need to hang off it while editing the new product
		create self.myProxyObject as CM_Product transient;
		clearCellText := false;
		
		self.myProxyObject.CM_Product.setProductDefaults(self.cmbEntCargoType.listObject.CM_CargoType);
		pxyProduct := self.myProxyObject.CM_Product;
		
		//self.tblAttributes.userInputEnabled := true;
		self.tblEntDetail.setFocus;
		self.tblEntDetail.goToRowByName(ETRow_EntCargoType);
		
	elseif self.mode = Mode_Update then
		clearCellText := false;
		//create and set the proxy product attributes that hang off the proxy product
		//self.myProxyObject.CM_Product.setProxyProdAttributes(self.myCurrentObject.CM_Product);
		self.myProxyObject.CM_Product.createProductAttributes();
		self.myProxyObject.CM_Product.setForUpdate(self.myCurrentObject.CM_Product);
		
		self.tblEntDetail.setFocus;
		self.tblEntDetail.goToRowByName(ETRow_Code);
		
	endif;
	
	self.displayAttributes(self.myProxyObject.CM_Product);
		
	//self.tblAttributes.userInputEnabled := true;
	self.tblAttributes.userInputEnabled := false;	//tblAttributes is always readonly. ccms1080 PAR19704, July 2009
	self.tblAttributes.inputType := CM_DataTable.InputType_TextBox;
	
	foreach row in self.tblAttributes.fixedRows + 1 to self.tblAttributes.rows do
		self.disableProdAttrCells(row, clearCellText);
	endforeach;

	self.calculateDisplayValue();

	self.setDefaultCommodity();	// Setting cmbCommodity listObject as default from cargo type combobox. CCMS 1080, PAR 19704. July 2009

end;</source>
    </JadeMethod>
    <JadeMethod name="setControlsForView" id="65701bbe-c054-4bd1-b802-2c3916d6d2d6">
        <updating/>
        <source>setControlsForView() updating;
// ---------------------------------------------------------------------------
// Created:     02 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod();
	if self.mode = Mode_Add then
		if self.myProxyObject &lt;&gt; null then
			delete self.myProxyObject;
		endif;
	endif;
	self.tblEntDetail.enableRowByName(ETRow_CargoType);
	self.tblEntDetail.enableRowByName(ETRow_Operator);
	self.sptThumbEdit.showLeftControl(0, true);
	self.sptThumbEdit.showRightControl(0, true);
	self.sptThumbEdit.setLeftToRightRatioAndResize(35);
	self.sptMain.setLeftToRightRatioAndResize(40);
	self.frmDetailsBottom.width := self.sptThumbEdit.width;
	self.btnCloneProduct.enabled :=false;
	self.tblAttributes.width := self.sptThumbEdit.width;
	self.tblAttributes.rows := self.tblAttributes.fixedRows;
	self.tblAttributes.userInputEnabled := false;
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setDefaultCommodity" id="9ac5f2dc-cf13-4ec9-99ec-c9621de088c8">
        <source>setDefaultCommodity() protected;
/* ---------------------------------------------------------------------------
Created:	16 July 2009	by cnwvu1

Purpose:	CCMS 1080, PAR 19704. July 2009.
			Setting cmbCommodity listObject as default from cargo type combobox.
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	cargoType			: CM_CargoType;
	productType			: CM_Product;
	currentCommodity	: CM_Commodity;
	defaultCommodityCode: String;

begin
	
	cargoType := self.cmbEntCargoType.listObject.CM_CargoType;
	productType := self.myProxyObject.CM_Product;
	
	if cargoType &lt;&gt; null then	//cargo type can be null, when form has just started
	
		if not cargoType.isCommodityRequired then
			return;
		endif;

		if productType &lt;&gt; null then	// it can be null, when crating a ne wproduct type
			defaultCommodityCode := productType.defaultCommodityCode;
		else
			defaultCommodityCode := cargoType.defaultCommodityCode;
		endif;
		
		if not cargoType.allCommodities.isEmpty then
			currentCommodity := cargoType.allCommodities[defaultCommodityCode];
		else
			currentCommodity := app.myRoot.allCommodities[defaultCommodityCode];
		endif;
		
		// cmb can be not initialized. It happens, when the form has just started for the first time
		if self.cmbCommodity.itemData.size = 0 and currentCommodity &lt;&gt; null then
			self.myAssistant.comboBoxCommodityMultiSelected(self.cmbCommodity, cargoType.allCommodities, currentCommodity);
			self.cmbCommodity.setInitialised(true); // not to call getJMTCollection()- it gives all commodities
		endif;

		if currentCommodity &lt;&gt; null then
			self.cmbCommodity.listObject := currentCommodity;
		else
			self.cmbCommodity.text := defaultCommodityCode;
		endif;
		
	endif;


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setFilterDefaults" id="97e7da86-1416-4a63-8411-c0c4f4ae0d34">
        <updating/>
        <source>setFilterDefaults() updating;
// ---------------------------------------------------------------------------
// Created:     02 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
begin
//process.debug();
	inheritMethod();
	if self.cmbFiltCargoType.listObject &lt;&gt; null then
		self.myFilterCargoType := self.cmbFiltCargoType.listObject.CM_CargoType;
		self.tblSearch.setValueByName(ETRow_CargoType, self.myFilterCargoType.description);
	endif;
	
	if self.cmbFiltOperator.listObject &lt;&gt; null then
		self.myFilterOperator := self.cmbFiltOperator.listObject.CM_Operator;
		self.tblSearch.setValueByName(ETRow_Operator, self.myFilterOperator.code);
	endif;
	
	if self.cmbFiltHandling.listObject &lt;&gt; null then
		self.myFilterHandlingType := self.cmbFiltHandling.listObject.CM_HandlingType;
		self.tblSearch.setValueByName(ETRow_HandlingType, self.myFilterHandlingType.description);
	else
		self.tblSearch.setValueByName(ETRow_HandlingType, Any_String);
	endif;
	
	self.filterCode := null;
	self.tblSearch.setValueByName(ETRow_Code, null); 
	self.filterDescription := null;
	self.tblSearch.setValueByName(ETRow_Description, null);
end;</source>
    </JadeMethod>
    <JadeMethod name="setFilterValues" id="bd5164a6-22c8-4212-aa2e-e4ab6539a154">
