    <JadeMethod name="getVoyage" id="177b2932-3abc-416b-a9d4-e685cb878196">
        <source>getVoyage(_name: String): CM_Voyage;
/*
Purpose:	Get the voyage from current unit test terminal		

Date		Who		Reason
02 Oct 2014	cnwkpd1	Removed the check for Global Voyages, as this was resulting in cross over deletes into the 
					wrong terminal

*/
vars
	voyage	: CM_Voyage;
	voyageGlobal : CM_VoyageGlobal;
begin	
	voyage	:= self.getTerminal.allVoyagesByCode.getAtKeyGeq(_name, null);
	if voyage &lt;&gt; null and voyage.code = _name  then
		return voyage;
	endif;

	voyage	:= self.getTerminal.allVoyagesArchived.getAtKeyGeq(_name, null);
	if voyage &lt;&gt; null and voyage.code = _name  then
		return voyage;
	endif;
	
/*	// Look in global voyages
	voyageGlobal := self.getRoot.allVoyagesGlobal[_name];
	if voyageGlobal = null then	
		voyageGlobal	:= self.getRoot.allVoyagesGlobalArchived[_name];
	endif;
	
	if voyageGlobal &lt;&gt; null then
		return voyageGlobal.allVoyages.first;
	endif;
*/
	return null;
epilog

end;</source>
        <Parameter name="_name" type="String"/>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
