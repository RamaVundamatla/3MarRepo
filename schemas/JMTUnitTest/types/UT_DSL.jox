    <JadeMethod name="machineTaskRequestTwin" id="7aaa45ab-5965-4949-bdde-66886aef8521">
        <source>machineTaskRequestTwin(_machine: CM_Machine) : CM_RTQueueTask protected;
/*

Purpose:			Execute a get next task for the passed in machine, allowing twin
					tasks to be allocated if possible

Parameters:			Machine

Return Value:		First task found for the machine

Date		Who		Reason
21 Oct 2011	cnwkpd1	PAR #28383 - Allocating Held twin tasks to a machine

*/

vars
	mediator 		: CM_RadioTelemetryMediator;
	
begin
	create mediator transient;
	mediator.machine := _machine;
	mediator.canBeAllocatedTwinTasks := true;
	app.myTrxRT.trxRequestTask(mediator, null, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return mediator.task;
	
epilog
	delete mediator;
	
end;</source>
        <access>protected</access>
        <Parameter name="_machine" type="CM_Machine"/>
        <ReturnType type="CM_RTQueueTask"/>
    </JadeMethod>
    <JadeMethod name="machineZapTask" id="1f9b2d22-bb57-49f9-b3d8-1339d5708f0d">
        <source>machineZapTask(_machine: CM_Machine) protected;
// cnwdw1	
// Zap the RT queue entry for this machine
vars
	obj: Object;
	ti : CM_TrackedItem;
begin
	if _machine.currentQueueTask &lt;&gt; null then
		ti := _machine.currentQueueTask.ti;				// 23/05/2014 cnwmh5
		if ti &lt;&gt; null then
			self.unqueueTI(ti);
			self.unplanTI(ti);
		endif;	
		beginTransaction;
		if _machine.currentQueueTask &lt;&gt; null and _machine.currentQueueTask.myEntry &lt;&gt; null then		// 16/06/2014 cnwmh5
			obj := _machine.currentQueueTask.myEntry;
			delete obj;
		endif;
		commitTransaction;
	endif;
epilog
	abortTransaction;	
end;</source>
        <access>protected</access>
        <Parameter name="_machine" type="CM_Machine"/>
    </JadeMethod>
    <JadeMethod name="makeContainerId" id="caf04a07-1017-420f-bad3-815a19ce82dd">
        <source>makeContainerId(_ownerCode : String; _serialNumber : Integer) : String;
//
//10 June 2019	jlgrs1	Initial creation
//
vars
	ownerCode : String;
	containerId : String;
	containerIdFull : String;
	checkDigit : Integer;
	char : Character;
	idx : Integer;
	tmpValue : Integer;
	lValue : Integer;
	lPower2 : Integer;
	chkStr : String;
	chkStrLength : Integer;
begin
	if _ownerCode.length &lt; 3 then
		return null;
	endif;
	if _serialNumber &gt; 999999 then
		return null;
	endif;
	ownerCode := _ownerCode.toUpper;
	containerId := ownerCode[1:3]&amp;'U'&amp;_serialNumber.stringWithLeadingZeros(6);
	lPower2 := 1;
	foreach idx in 1 to 10 do
		char := containerId[idx];
		tmpValue := char.contIdWeighting*lPower2;
		lValue := lValue + tmpValue;
  		lPower2 := lPower2 * 2;
	endforeach;
	chkStr := (lValue mod ContainerID_Length).String;
	chkStrLength := chkStr.length;
	if chkStrLength &gt; 1 then
		chkStr := chkStr[chkStrLength:1];
	endif;
	containerIdFull := containerId&amp;chkStr;
epilog
	return containerIdFull;
end;</source>
        <Parameter name="_ownerCode" type="String"/>
        <Parameter name="_serialNumber" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
