    <JadeMethod name="hasLoadListsForComparison" id="4783a9fc-32fa-4e6e-89f7-da1687218288">
        <source>hasLoadListsForComparison() : Boolean;
/*

Date		Who		Reason
05 September 2016	cnwer1	Initial creation TFS

*/

vars
	loadLists: CM_EDIDataArray;
	loadList : CM_EDIDataLoadList;
	ediData : CM_EDIData;
begin
	create loadLists transient;
	
	self.getAllEDILoadLists(loadLists);
	
	foreach ediData in loadLists do
		loadList := ediData.CM_EDIDataLoadList;
		if loadList.status = CM_EDIFile.EDI_STATUS_VERIFIED or 
			loadList.status = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS then
			return true;
		endif;
	endforeach;
	return false;
epilog
	delete loadLists;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasMovementsInBerthAfterTS" id="2fe7bdb7-75de-4c08-8a0b-e7a72b5b7142">
        <source>hasMovementsInBerthAfterTS(_berth :HMS_Berth; _atTimeStamp : TimeStamp) : HMS_Movement;
/*

Purpose:			


Return Value:		


Date		Who		Reason
18 Apr 2008	cnwer1	Initial creation - PAR#xxxx
03 Sep 2008	cnwer1	par 17810 changed to return the movement	
*/
vars
	movement : HMS_Movement;
	iter : Iterator;
begin
	if self.myHMSVoyageData = null then
		return null;
	endif;
	
	iter :=self.myHMSVoyageData.allVoyageMovements.createIterator;
	self.myHMSVoyageData.allVoyageMovements.startKeyLeq(_atTimeStamp,iter);
	while iter.next(movement) do
		if movement.getMyBerth = _berth then
			return movement;
			break;
		endif;	
	endwhile;
	
	
	return null;
epilog
	delete iter;
end;</source>
        <Parameter name="_berth" type="HMS_Berth"/>
        <Parameter name="_atTimeStamp" type="TimeStamp"/>
        <ReturnType type="HMS_Movement"/>
    </JadeMethod>
    <JadeMethod name="hasNoStructureDefined" id="35b1f8ef-3374-46c7-8fa2-fa7d127a191c">
