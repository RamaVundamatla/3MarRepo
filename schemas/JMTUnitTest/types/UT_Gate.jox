    <JadeMethod name="tReceiveMTWithSTYA" id="e4bab61b-7897-440d-baa0-acd052f7c60e">
        <source>tReceiveMTWithSTYA();
// cnwdap1
// Dec 2010	cnwdw1	
// Gate in MT with a autoplan to yard based on the sub-terminal (par 25237)
//23 Apr 2024	navpw1 - Sub Terminals was turned off for the entire UT terminal. Added code to turn it on for this test
vars
	truck: CM_Vehicle;
	ti: CM_TrackedItem;
	ta: CM_GridArea;
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	lc : CM_LocationsController;
	subTerminalsOn : Boolean;
begin
	subTerminalsOn := self.setTerminalConfig(IsSubTerminalsOn, true).Boolean;
	
	self.setTerminalConfig(PrenoteUniqBooking, false);
	self.setSubTerminalAreaDefined(false);

	self.disableAllYA(true);
	deleteContainer("UUT12345678");
	deleteVehicle("UTTRUCK");
	
	deleteTerminalArea("UTSTRD");
	ta:= addStraddleStack("UTSTRD", 2, 2, 1);

	create locations transient;
	locations.add(ta.allGridControllersByRowColumn[1, 1]);
	locations.add(ta.allGridControllersByRowColumn[1, 2]);

	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_SubTerminal, "UT_Depot", locations);
	///ya := self.addYA1("UT", YACriteriaType_SubTerminal, self.getTerminal().allSubTerminals.first, locations);

	gateInContainer("UTTRUCK", "UUT12345678", "2200", operator.code, "MT", self.dualGate);
	ti := self.getTrackedItem("UUT12345678");
	assertNotNull(ti);
	lc := ti.getPrimaryLocation(QUEUE_MODE);
	assertNotNull(lc);
	assertEqualMsg(lc.myTerminalArea.id, "UTSTRD", "Queued container location");
	
epilog
	self.setTerminalConfig(IsSubTerminalsOn, subTerminalsOn);
	self.setSubTerminalAreaDefined(true);
	self.disableAllYA(false);
	delete locations;
end;</source>
    </JadeMethod>
    <JadeMethod name="tReceiveMTWithScrTAYA" id="1c434557-4f53-475a-af91-76db3a00d553">
