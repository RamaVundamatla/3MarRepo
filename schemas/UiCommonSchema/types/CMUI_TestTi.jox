    <JadeMethod name="doBaseFormSave" id="fad5c0c7-f39b-4395-93e8-f284fc995f47">
        <updating/>
        <source>doBaseFormSave() updating, protected;
// -------------------------------------------
// Created 10 November 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	app.mousePointer := MousePointer_HourGlass;
	if self.mySelectedTi &lt;&gt; null and self.chkForce.value  then
		self.myCaller.getData(self.mySelectedTi, self.type);
	endif;
	app.mousePointer := MousePointer_Default;
	self.unloadForm();
epilog
	app.mousePointer := MousePointer_Default;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="689001fe-a0c8-499c-8956-ba9c7ea0b046">
        <updating/>
        <source>doResize() updating;
// -------------------------------------------
// Created 07 November 2003 by cnwdvb1
// -------------------------------------------
vars

begin
			
	if self.lblDisplay.visible then
		self.lblDisplay.top 	:= self.frmToolbar.height;
	endif;
	inheritMethod();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doTiTest" id="15e2f9ba-d064-422c-8c97-15190cda8240">
        <updating/>
        <source>doTiTest(_ti : CM_TrackedItem) protected, updating;
// -------------------------------------------
// Created 10 November 2003 by cnwdvb1
// -------------------------------------------
vars
	
	request 	: CM_Request;
	isGood		: Boolean;
	error		: CM_Error;
	str			: String;
	passport	: CM_Passport;

begin

	passport := app.myPassport;
	request := self.myWle.myRequest;
	str := app.getErrorString(Is_Suitable);

	app.myTrxUA.trxCheckTiAgaintRequest(_ti, request, passport);
	if not passport.trxCompletedOK then
		str := CrLf;
		foreach error in passport.allErrorWarnings do
			if error.warningOnly then
				str := str &amp; 'Warning ' &amp; error.text &amp; CrLf &amp; CrLf;
			else
				str := str &amp; 'Error ' &amp; error.text &amp; CrLf &amp; CrLf;
			endif;
		endforeach;
	endif;
	self.lblDisplay3.caption := app.getErrorString(TrackedItem) &amp; ': ' &amp;  _ti.id &amp; str;
	self.mySelectedTi := _ti;
end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
