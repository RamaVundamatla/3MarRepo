	self.deleteContainer("GENU2077443");
	cargo := self.addContainerAtLocation("GENU2077443", self.myOperator, "2200", "GENL", TI_IMEX_STATUS_IMPORT, bs.myLocationsController);
	_containers.add(cargo);
	self.deleteContainer("GENU2077444");
	cargo := self.addContainerAtLocation("GENU2077444", self.myOperator, "2200", "GENL", TI_IMEX_STATUS_IMPORT, bs.myLocationsController);
	_containers.add(cargo);
	self.deleteContainer("GENU2077445");
	cargo := self.addContainerAtLocation("GENU2077445", self.myOperator, "2200", "GENL", TI_IMEX_STATUS_IMPORT, bs.myLocationsController);
	_containers.add(cargo);
	self.deleteContainer("GENU2077446");
	cargo := self.addContainerAtLocation("GENU2077446", self.myOperator, "2200", "GENL", TI_IMEX_STATUS_IMPORT, bs.myLocationsController);
	_containers.add(cargo);

	// ### 40 GENERALS
	self.deleteContainer("GENU4077441");
	cargo := self.addContainerAtLocation("GENU4077441", self.myOperator, "4200", "GENL", TI_IMEX_STATUS_IMPORT, bs.myLocationsController);
	_containers.add(cargo);
	self.deleteContainer("GENU4077442");
	cargo := self.addContainerAtLocation("GENU4077442", self.myOperator, "4200", "GENL", TI_IMEX_STATUS_IMPORT, bs.myLocationsController);
	_containers.add(cargo);
	self.deleteContainer("GENU4077443");
	cargo := self.addContainerAtLocation("GENU4077443", self.myOperator, "4200", "GENL", TI_IMEX_STATUS_IMPORT, bs.myLocationsController);
	_containers.add(cargo);
	self.deleteContainer("GENU4077444");
	cargo := self.addContainerAtLocation("GENU4077444", self.myOperator, "4200", "GENL", TI_IMEX_STATUS_IMPORT, bs.myLocationsController);
	_containers.add(cargo);
	self.deleteContainer("GENU4077445");
	cargo := self.addContainerAtLocation("GENU4077445", self.myOperator, "4200", "GENL", TI_IMEX_STATUS_IMPORT, bs.myLocationsController);
	_containers.add(cargo);
	self.deleteContainer("GENU4077446");
	cargo := self.addContainerAtLocation("GENU4077446", self.myOperator, "4200", "GENL", TI_IMEX_STATUS_IMPORT, bs.myLocationsController);
	_containers.add(cargo);

	// ### 20 REEFERS
	self.deleteContainer("REEF2077441");
	cargo := self.addContainerAtLocation("REEF2077441", self.myOperator, "2232", "REEF", TI_IMEX_STATUS_IMPORT, bs.myLocationsController);
	_containers.add(cargo);
	self.deleteContainer("REEF2077442");
	cargo := self.addContainerAtLocation("REEF2077442", self.myOperator, "2232", "REEF", TI_IMEX_STATUS_IMPORT, bs.myLocationsController);
	_containers.add(cargo);
	self.deleteContainer("REEF2077443");
	cargo := self.addContainerAtLocation("REEF2077443", self.myOperator, "2232", "REEF", TI_IMEX_STATUS_IMPORT, bs.myLocationsController);
	_containers.add(cargo);
	self.deleteContainer("REEF2077444");
	cargo := self.addContainerAtLocation("REEF2077444", self.myOperator, "2232", "REEF", TI_IMEX_STATUS_IMPORT, bs.myLocationsController);
	_containers.add(cargo);
	self.deleteContainer("REEF2077445");
	cargo := self.addContainerAtLocation("REEF2077445", self.myOperator, "2232", "REEF", TI_IMEX_STATUS_IMPORT, bs.myLocationsController);
	_containers.add(cargo);
	self.deleteContainer("REEF2077446");
	cargo := self.addContainerAtLocation("REEF2077446", self.myOperator, "2232", "REEF", TI_IMEX_STATUS_IMPORT, bs.myLocationsController);
	_containers.add(cargo);
	self.deleteContainer("REEF2077447");
	cargo := self.addContainerAtLocation("REEF2077447", self.myOperator, "2232", "REEF", TI_IMEX_STATUS_IMPORT, bs.myLocationsController);
	_containers.add(cargo);

	// ### 40 REEFERS
	self.deleteContainer("REEF4077441");
	cargo := self.addContainerAtLocation("REEF4077441", self.myOperator, "4332", "REEF", TI_IMEX_STATUS_IMPORT, bs.myLocationsController);
	_containers.add(cargo);
	self.deleteContainer("REEF4077442");
	cargo := self.addContainerAtLocation("REEF4077442", self.myOperator, "4332", "REEF", TI_IMEX_STATUS_IMPORT, bs.myLocationsController);
	_containers.add(cargo);
	self.deleteContainer("REEF4077443");
	cargo := self.addContainerAtLocation("REEF4077443", self.myOperator, "4332", "REEF", TI_IMEX_STATUS_IMPORT, bs.myLocationsController);
