<Class name="CM_KioskTranslation" id="b34f37d6-ac57-4e92-a41b-f0cfd2ecfb36">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="location"/>
    <ExplicitInverseRef name="myKioskObject" id="1e4b4d49-5dc0-460b-bb8e-accc1818816e">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="CM_KioskObject"/>
        <access>readonly</access>
        <Inverse name="CM_KioskAdditionalQuestion::allErrorMessages"/>
        <Inverse name="CM_KioskAdditionalQuestion::allQuestions"/>
        <Inverse name="CM_KioskPPEQuestion::allErrorMessages"/>
        <Inverse name="CM_KioskPPEQuestion::allQuestions"/>
        <Inverse name="CM_KioskTermsAndConditions::allTermsAndConditions"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myLocale" id="7c57ae20-477c-4332-93aa-10eb15dd0322">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Locale"/>
        <access>readonly</access>
        <Inverse name="CM_Locale::allKioskTranslations"/>
    </ExplicitInverseRef>
    <PrimAttribute name="text" id="f2c570fb-45b8-4986-b4fd-6531e26a1645">
