<Class name="HMS_VoyageArchived" id="8f1fc9cb-f980-43ac-b836-92f3c595194e">
    <superclass name="HMS_Transaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="hmsTrans"/>
    <JadeMethod name="createPropertyChanges" id="ea48d361-22b5-4807-81e5-b2db69735e9e">
        <updating/>
        <source>createPropertyChanges(_cmifTrans: CMIF_HMS_TransactionController) updating, protected;
//--------------------------------------------------------------
//Created: 29 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars
 	propertyChange:	HMS_PropertyChange;
begin
	inheritMethod(_cmifTrans);

	// This method creates a 'VoyageArchive' transaction for a voyage which has been archived
	create propertyChange;
	propertyChange.set(self, "Voyage Archived", null, null);

end;</source>
        <access>protected</access>
        <Parameter name="_cmifTrans" type="CMIF_HMS_TransactionController"/>
    </JadeMethod>
    <JadeMethod name="setTypeDetails" id="6037a7a4-5146-461f-b0e5-75d3e263766f">
        <updating/>
        <source>setTypeDetails() updating, protected;
//--------------------------------------------------------------
//Created: 25 July 2003 By: cnwgd1
//--------------------------------------------------------------
vars

begin
  	// Set type and typeString
	type:=TRANS_TYPE_HMSVoyageArchive;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validate" id="6683fd26-c813-4731-8f8d-2dce94a4f71e">
        <source>validate(_transController: CMIF_HMS_TransactionController): Boolean;
//--------------------------------------------------
// Created:	20 January 2005 By: cnwgd1
//--------------------------------------------------
vars
	rtnValue : Boolean;
begin
	rtnValue := inheritMethod(_transController);
	if (not rtnValue) then
		return rtnValue;
	endif;
	
	if _transController.myHMSVoyageData = null then
		app.raiseCMException2(InvalidAttrForUpdate, 'Voyage', 'Null', null, null);
		return false;
	endif;

	return rtnValue;
end;</source>
        <Parameter name="_transController" type="CMIF_HMS_TransactionController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
