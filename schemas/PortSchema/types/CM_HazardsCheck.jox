<Class name="CM_HazardsCheck" id="0a5a4790-56fc-4a36-8ff1-e9659d41d9a2">
    <superclass name="CM_TITransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transact"/>
    <ImplicitInverseRef name="allTIHazards" id="f775bc98-e526-46f4-b2d5-fbd36e9f3b15">
        <embedded/>
        <type name="CM_HazardByCodeDict"/>
    </ImplicitInverseRef>
    <JadeMethod name="getHazardsAsString" id="f464d6bd-0650-4e1b-85d2-ddec13bf32d8">
        <source>getHazardsAsString() : String;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 06 March 2023
TFS#		: 56882
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	str : String;
	haz : CM_Hazard;
begin

	if self.allTIHazards.isEmpty then
		return null;
	endif;

	foreach haz in self.allTIHazards do
		str := str &amp; haz.getTableDisplay(false, true) &amp; ", ";
	endforeach;
		
	str := str[1:str.length - 2];
	
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="9190f067-a046-4594-b1d1-01b8b3fbf164">
        <updating/>
        <source>setMyTrackedItem(pTI: CM_TrackedItem; _tiTransCntrl: CMIF_TITransactionController) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 06 March 2023
TFS#		: 56882
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	inheritMethod(pTI, _tiTransCntrl);
	self.allTIHazards := self.myTrackedItem.allTIHazards.cloneSelf(false);	
end;</source>
        <Parameter name="pTI" type="CM_TrackedItem"/>
        <Parameter name="_tiTransCntrl" type="CMIF_TITransactionController"/>
    </JadeMethod>
</Class>
