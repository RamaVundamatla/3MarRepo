	ta := taType.allTerminalAreasByTerminal.getAtKeyGeq(self.myTerminal, null).CM_TerminalArea;
	self.myAssistant.comboBoxTerminalArea(self.cmbTerminalArea, taType.type, ta);
	if ta &lt;&gt; null then
		self.myAssistant.comboBoxLocationControllers(self.cmbLocation, ta.allLocationsControllers, false);
	endif;
	
end;</source>
