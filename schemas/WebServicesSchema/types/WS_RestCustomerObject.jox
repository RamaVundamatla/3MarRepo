<Class name="WS_RestCustomerObject" id="8795d7db-b806-4aec-b5f6-456cabd9b1d6">
    <superclass name="WS_CustomerObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="accountCode" id="4fc0c641-7c83-4e3c-a369-0c91a3e4231c">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="additionalInfo1" id="50b58581-31db-4289-8f56-da455f8e1463">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="additionalInfo2" id="35e61e8f-3d41-4b23-a56f-e0be2af024f5">
        <type name="String"/>
    </PrimAttribute>
    <ImplicitInverseRef name="addresses" id="30773f6c-93dd-4985-9650-9462d053dc17">
        <memberTypeInverse/>
        <type name="WS_RestAddressesArray"/>
    </ImplicitInverseRef>
    <PrimAttribute name="badCredit" id="2ef80795-3fb5-42a6-8392-4c4a50d999a1">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="description" id="b55c1071-acfa-4548-affb-26efeace5be6">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="id" id="183c1ed1-e70a-4bd1-9ccd-be778269e919">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="name" id="ac05953e-275e-4397-9969-4581365943bd">
        <type name="String"/>
    </PrimAttribute>
    <ImplicitInverseRef name="relatedEntities" id="38902079-8f36-4fe0-a92f-332ffd3ff5be">
        <embedded/>
        <type name="WS_RestCustRelatedEntsObject"/>
    </ImplicitInverseRef>
    <PrimAttribute name="suspended" id="df5022a4-082b-4c85-ab3d-f4e2f6692e80">
