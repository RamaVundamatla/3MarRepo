// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	if self.mnuGridHideToolbar.caption = self.MNU_TOOLBAR_SHOW then
		self.mnuGridHideToolbar.caption := self.MNU_TOOLBAR_HIDE;
		self.mnuWorkDisplayHideTB.caption := self.MNU_TOOLBAR_HIDE;
		self.showHideToolbars(false);
	else
		self.mnuGridHideToolbar.caption := self.MNU_TOOLBAR_SHOW;
		self.mnuWorkDisplayHideTB.caption := self.MNU_TOOLBAR_SHOW;
		self.showHideToolbars(true);
	endif;

end;</source>
    </JadeMethod>
