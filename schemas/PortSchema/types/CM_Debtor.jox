<Class name="CM_Debtor" id="658055aa-cba9-42aa-bb32-ff8c5fc86c22">
    <superclass name="CM_DebtorNode"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Each debtor represents someone who owes money to the port for services done.
They may be a cash debtor who must pay before taking their cargo otherwise are a credit debtor who is charged
at some regular (e.g. monthly) period.</text>
    <DbClassMap file="invoice"/>
