<Class name="CMIF_JsonContainerOperatorEUP" id="3239d1d9-9ddc-4925-a136-78be2283053f">
    <superclass name="CMIF_JsonTransform"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="edi"/>
    <PrimAttribute name="code" id="104eb0aa-ae61-4d15-aed5-d1010db75dcf">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="name" id="b4282046-8bb8-4ba9-b75c-d0df2c31bdf2">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setFromOperator" id="c8d1be4b-4631-46e9-97ed-4b240dd930ef">
        <updating/>
        <source>setFromOperator(operatorTI : CM_Operator input;  _translationOperator : CM_Operator) updating;
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 23 June 2023
TFS#		: 58506
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
vars
	foundMatch : Boolean;
begin
	if operatorTI &lt;&gt; null then
		self.code := operatorTI.code;
		self.name := operatorTI.description;
		if  _translationOperator  &lt;&gt; null then
			self.code := operatorTI.getXlationForeignCode(self.code, XLATION_TYPE_OPERATOR_BYOP, foundMatch);		
		endif;
	endif;	
end;
</source>
        <Parameter name="operatorTI" type="CM_Operator" usage="input"/>
        <Parameter name="_translationOperator" type="CM_Operator"/>
    </JadeMethod>
</Class>
