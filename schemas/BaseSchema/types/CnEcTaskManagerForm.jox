        <source>load() updating;
// -----------------------------------------------------------------------------
// Created:		16 December 2001 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	app.mousePointer	:=	Busy;
	inheritMethod();
	self.doFormLoad();
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
