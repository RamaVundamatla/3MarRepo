    <JadeMethod name="doQuery" id="dc5af790-012f-4a29-9747-10af24b43c94">
        <updating/>
        <source>doQuery(_qDef: CM_QueryDefinition) updating;
/* ---------------------------------------------------------------------------
// Created:     18 March 2003		cnwth2	
//
// Purpose:     	
*** Changes ***
Date			Name		TFS#		Description
24/09/2018		jlgka1		40200		remove the code for "dateTime" as it is 
										causing a stackdump and date funtion works 
										well in the inherited method.
17 DEc 2019		jlger1		47132 		Tidy up so we have references to criteria
19 Oct 2022 	navcs2		55107		Populated the self.number for BOL from the user search
// ----------   ----------  --------------------------------------------------*/
vars
	crit			: CM_SelectorCriteriaLine;
	termSet			: CM_TerminalSet;
	operatorSet		: CM_OperatorSet;
	ut				: CM_UserTerminal;
	op				: CM_Operator;
	term			: CM_Terminal;
	operator		: CM_QueryOperator;
begin
	inheritMethod(_qDef);
	self.reset();
	
	crit := self.myCriteriaLineHolder.findCriteriaByName(CM_BOL::bolType.name);
	if crit &lt;&gt; null then
		self.bolType := crit.myQueryOperator.getSearchValue().Integer;
	endif;
	
	crit := self.myCriteriaLineHolder.findCriteriaByName(CM_BOL::isInward.name);
	if crit = null then
		self.bolFilterType := BOL_EITHER;
	elseif crit.myQueryOperator.getSearchValue().Boolean then
		self.bolFilterType := BOL_INWARDS;
	else
		self.bolFilterType := BOL_OUTWARDS;
	endif;
	
	create termSet transient;	
	crit := self.myCriteriaLineHolder.findCriteriaByName(CM_BOL::myTerminal.name);
	if crit &lt;&gt; null then
		crit.myQueryOperator.getSearchValueAsObjectSet(termSet);
	else
		foreach ut in app.myPassport.myUser.allUserTerminals do
			termSet.add(ut.getMyTerminal);
		endforeach;
	endif;

	create operatorSet transient;	
	crit := self.myCriteriaLineHolder.findCriteriaByName(CM_BOL::myOperator.name); 
	if crit &lt;&gt; null then
		crit.myQueryOperator.getSearchValueAsObjectSet(operatorSet);
	endif;
	
	/*
	** 19/10/2022 navcs2 55107 Changes Start
	*/
	crit := self.myCriteriaLineHolder.findCriteriaByName(CM_BOL::number.name); 
	if crit &lt;&gt; null then 
		operator := crit.myQueryOperator;
		if operator.isKindOf(CM_QueryStringOperators) or operator.isKindOf(CM_QStringStartsWith) then
			self.number := crit.myQueryOperator.getSearchValue().String;
		endif;
	endif;
	/*
	** 19/10/2022 navcs2 55107 Changes End
	*/


	if not operatorSet.isEmpty then
		foreach op in operatorSet do
			self.myOperator := op;
			self.doSearch;
		endforeach;
		return;
	elseif not termSet.isEmpty then
		foreach term in termSet do
			self.myTerminal := term;
			self.doSearch;
		endforeach;
	endif;
	
epilog
	endLoad;
	delete termSet;
	delete operatorSet;
end;</source>
        <Parameter name="_qDef" type="CM_QueryDefinition"/>
    </JadeMethod>
    <JadeMethod name="doSearch" id="bfd5f104-71d0-4458-8a47-89c4fa1ac8d8">
        <updating/>
        <source>doSearch() updating, protected;
// ---------------------------------------------------------------------------
// Created:     18 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	bolsByTypeNo				: CM_BOLByTypeNumberDTDict;
	bolsByDT					: CM_BOLByTypeDateTimeDict;
	bolsTypeNo					: CM_BOLTermByTypeNumDict; // ### TFS 54043 1Aug2022 NAVPW1
	haveType,
	haveNumber					: Boolean;
	passport					: CM_Passport;
	opTerm						: CM_OperatorTerminal;
	terminal					: CM_Terminal;
begin
	passport := app.myPassport;

	if self.myOperator &lt;&gt; null then
		if self.myTerminal = null then
			foreach terminal in app.myRoot.allTerminals do
				opTerm := self.myOperator.allOperatorTerminals[terminal];
				if opTerm = null then
					//return;
					continue;	//16731. When there is a new terminal, opTerm can be null until the first BOL is gated in (CM_OperatorTerminal is created automatically). cnwvu1 15 May 2008
				endif;
				bolsByTypeNo := opTerm.allBOLByTypeNumber;
				self.processBOLDict(bolsByTypeNo, self.bolType, self.number, self.dateTime, passport);
			endforeach;
		else
			opTerm := self.myOperator.allOperatorTerminals[self.myTerminal];
			if opTerm = null then
				return;
			endif;
			bolsByTypeNo := opTerm.allBOLByTypeNumber;
			self.processBOLDict(bolsByTypeNo, self.bolType, self.number, self.dateTime, passport);
		endif;
	else //off terminal
		if (not self.dateTime.isValid) then
			if self.bolFilterType = BOL_EITHER then//do both receive and release dicts off terminal
				bolsByTypeNo := self.myTerminal.allBOLsReceivedByTypeNumberDT;
				self.processBOLDict(bolsByTypeNo, self.bolType, self.number, self.dateTime, passport);
				bolsByTypeNo := self.myTerminal.allBOLsReleasedByTypeNumberDT;
				self.processBOLDict(bolsByTypeNo, self.bolType, self.number, self.dateTime, passport);
	
			elseif self.bolFilterType = BOL_INWARDS then
				//bolsByTypeNo := self.myTerminal.allBOLsReceivedByTypeNumberDT;								// ### TFS 54043 1Aug2022 NAVPW1
				//self.processBOLDict(bolsTypeNo, self.bolType, self.number, self.dateTime, passport);			// ### TFS 54043 1Aug2022 NAVPW1
				bolsTypeNo := self.myTerminal.allBOLTermsByTypeNum;												// ### TFS 54043 1Aug2022 NAVPW1
				self.processBOLTerminalDict(bolsTypeNo, self.bolType, self.number, self.myOperator, passport);	// ### TFS 54043 1Aug2022 NAVPW1
			
			elseif self.bolFilterType = BOL_OUTWARDS then
				bolsByTypeNo := self.myTerminal.allBOLsReleasedByTypeNumberDT;
				self.processBOLDict(bolsByTypeNo, self.bolType, self.number, self.dateTime, passport);
			endif;
		else
			if self.bolFilterType = BOL_EITHER then//do both receive and release dicts off terminal
				bolsByDT := self.myTerminal.allBOLsReceivedByDTType;
				self.processBOLDict(bolsByDT, self.bolType, self.number, self.dateTime, passport);
				bolsByTypeNo := self.myTerminal.allBOLsReleasedByTypeNumberDT;
				self.processBOLDict(bolsByTypeNo, self.bolType, self.number, self.dateTime, passport);
	
			elseif self.bolFilterType = BOL_INWARDS then
				bolsByDT := self.myTerminal.allBOLsReceivedByDTType;
				self.processBOLDict(bolsByDT, self.bolType, self.number, self.dateTime, passport);
			
			elseif self.bolFilterType = BOL_OUTWARDS then
				bolsByTypeNo := self.myTerminal.allBOLsReleasedByTypeNumberDT;
				self.processBOLDict(bolsByTypeNo, self.bolType, self.number, self.dateTime, passport);
			endif;
		endif;
	endif;
	
epilog
	endLoad;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="processBOLDict" id="bcd86bf8-27a2-489f-ba46-8852e499467a">
        <updating/>
        <source>processBOLDict(_dict : Collection input; 
				_bolType : Integer; 
				_number : String; 
				_timeStamp : TimeStamp;
				_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     18 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
// 19 Oct    2022 	navcs2	Bug 55107: PEN- Excessive amount of time when searching for a General BOL 
// 11/07/2025		naviv1	MTN-35226 : MTN - Usage of Iterator.getCurrentKeys  
vars
	iter					: Iterator;
	bol						: CM_BOL;
	keyBolType				: Integer;
	keyNumber				: String;
	keyTimeStamp			: TimeStamp;
	isByDT,
	breakOut				: Boolean;

begin
	
	iter := _dict.createIterator;
	isByDT := _dict.isKindOf(CM_BOLByTypeDateTimeDict);
	if isByDT then
		_dict.CM_BOLByTypeDateTimeDict.startKeyGeq(_bolType, _timeStamp, iter);
	else
		_dict.CM_BOLByTypeNumberDTDict.startKeyGeq(_bolType, _number, _timeStamp, iter);
	endif;
		
	while iter.next(bol) do
		if isByDT then
			iter.getCurrentKeys(keyBolType,keyTimeStamp); //MTN-35226
		else
			iter.getCurrentKeys(keyBolType,keyNumber,keyTimeStamp);  //MTN-35226
		endif;
		
		if _bolType &lt;&gt; null and bolType &lt;&gt; keyBolType then
			break;
		endif;
		
		if _number &lt;&gt; null and not keyNumber.startsWith__(_number) then  // 19/10/2022 navcs2 #55107
			break;
		endif;
		
		if self.endDateTime.isValid and keyTimeStamp &gt; self.endDateTime then
			break;
		endif;
		
		if self.includesObject(bol, breakOut, _passport) then
			self.addObjectToSet(bol);
		endif;
		
		if breakOut 
		or self.breakOutOfSearch then	// Par 17107	cnwvu1	June 2008
			break;
		endif;
	endwhile;

epilog
	delete iter;

end;</source>
        <Parameter name="_dict" type="Collection" usage="input"/>
        <Parameter name="_bolType" type="Integer"/>
        <Parameter name="_number" type="String"/>
        <Parameter name="_timeStamp" type="TimeStamp"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processBOLTerminalDict" id="e50c89c6-4a13-422d-8ba0-9b27fb1d0d17">
        <updating/>
        <source>processBOLTerminalDict(_dict 		: Collection input; 
						_bolType 	: Integer; 
						_number 	: String;
						_operator 	: CM_Operator;
						_passport 	: CM_Passport input) updating;
/*

Purpose:			Processes a collection of type CM_BOLTerminalDicts for filtering Cargo Enquiry Log Dockets

Parameters:			_dict		Collection	The collection to process
					_bolType	Integer		The bol type to use when processing the dictionary
					_number		String		The bol number to use when processing the dictionary
					_operator	CM_Operator	The operator to use when processing the dictionary
					_passport	CM_Passport The passport to use when processing the dictionary

Return Value:		NONE

Date			Who		Reason
01 August 2022	navpw1	Initial creation TFS: 54043
19 Oct    2022 	navcs2	Bug 55107: PEN- Excessive amount of time when searching for a General BOL 
11/07/2025		naviv1	MTN-35226 : MTN - Usage of Iterator.getCurrentKeys  
*/

vars
	iter					: Iterator;
	bol						: CM_BOLTerminal;
	keyBolType				: Integer;
	keyNumber				: String;
	keyOperator				: CM_Operator;
	breakOut				: Boolean;
	hasOp					: Boolean;
begin
	iter := _dict.createIterator;
	hasOp := _dict.isKindOf(CM_BOLTermByTypeOpNumDict);  // 19/10/2022 navcs2 #55107
	
	if hasOp then  // 19/10/2022 navcs2 #55107
		_dict.CM_BOLTermByTypeOpNumDict.startKeyGeq(_bolType, _operator, _number, iter);
	else
		_dict.CM_BOLTermByTypeNumDict.startKeyGeq(_bolType, _number, iter);
	endif;
	
	while iter.next(bol) do
		app.sendHeartbeatIfRequired();
		
		if hasOp then
			iter.getCurrentKeys(keyBolType,keyOperator,keyNumber);  //MTN-35226
		else
			iter.getCurrentKeys(keyBolType,keyNumber);  //MTN-35226
		endif;
		
		if _bolType &lt;&gt; null and bolType &lt;&gt; keyBolType then
			break;
		endif;
		
		if _number &lt;&gt; null and not keyNumber.startsWith__(_number) then  // 19/10/2022 navcs2 #55107
			break;
		endif;
		
		if self.includesObject(bol.myBOL, breakOut, _passport) then
			self.addObjectToSet(bol.myBOL);
		endif;
		
		if breakOut 
		or self.breakOutOfSearch then
			break;
		endif;
	endwhile;
	
	
epilog
	delete iter;
end;</source>
        <Parameter name="_dict" type="Collection" usage="input"/>
        <Parameter name="_bolType" type="Integer"/>
        <Parameter name="_number" type="String"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="reset" id="e27572d9-a92e-43be-980c-d42076531a25">
        <updating/>
        <source>reset() updating;
// ---------------------------------------------------------------------------
// Created:     18 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod();
	
	self.myOperator				:= null;
	self.myTerminal				:= null;
	self.bolFilterType			:= null;
	self.bolType				:= null;
	self.dateTime				:= null;
	self.isInwards				:= null;
	self.number					:= null;
	
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setMyFilterClass" id="03a104cd-f2b1-47b5-b633-41854533bcfc">
        <updating/>
        <source>setMyFilterClass() updating;
// ---------------------------------------------------------------------------
// Created:     14 March 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.myFilterClass := CM_BOL;


end;</source>
    </JadeMethod>
</Class>
