	opsviewtable.bin_level := opsviewtable.SpatialBinLevel_2; // ### TFS 51854 08FEB2022 NAVAB1
	opsviewtable.bin_subclass := "SBL";
	opsviewtable.block_type_enum := opsviewtable.n4BlockType(self);
	opsviewtable.internal_pos_name := self.id; // ### TFS 51854 08FEB2022 NAVAB1
	opsviewtable.label_scheme_full_position := self.id; // ### TFS 51854 08FEB2022 NAVAB1
	opsviewtable.life_cycle_state := opsviewtable.n4LifeCycleState(self); // ### TFS 51854 08FEB2022 NAVAB1
	opsviewtable.parent_bin_gkey := opsviewtable.generateFullGKey(self.myTerminal,""); // ### TFS 51854 08FEB2022 NAVAB1
	opsviewtable.yard_gkey := 0;  // ### TFS 53369 28APR2022 NAVAB1 only for the terminal - bin_level 1 //  opsviewtable.generateFullGKey(self.myTerminal, ""); // ### TFS 51854 08FEB2022 NAVAB1
	opsviewtable.z_index_last := 0; // not set at this level

epilog

end;</source>
