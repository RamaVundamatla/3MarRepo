    <JadeMethod name="getVisitTypeServiceTimeRate" id="d853606d-380f-496e-913c-eaac97c1f8d5">
        <source>getVisitTypeServiceTimeRate(_service : CM_Service; _ts : TimeStamp) : CM_RateEntry;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
07 Jun 2018 	cnwma1	ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types
23 Oct 2024		navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025		navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/

vars
	serviceRate : CM_VisitTypeRate;
	rateEntry : CM_RateEntry;
	canLogExtra	: Boolean;	//28.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();				//28.02.2025 navah1	#34141
	serviceRate := self.allServiceRates[_service];
	if serviceRate &lt;&gt; null then
		rateEntry := serviceRate.getTimeRate(_service.bank, _ts);
		if canLogExtra then	//28.02.2025 navah1	#34141
			if rateEntry &lt;&gt; null then
				app.invLog("Rate for " &amp; _service.name &amp; " derived from visit type '" &amp; self.description &amp; "' found", LogTRACE.String);
			else
				app.invLog("Rate for " &amp; _service.name &amp; " derived from visit type '" &amp; self.description &amp; "' NOT found", LogTRACE.String);
			endif;
		endif;
		return rateEntry;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_service" type="CM_Service"/>
        <Parameter name="_ts" type="TimeStamp"/>
        <ReturnType type="CM_RateEntry"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="88d0c866-c03f-4d4f-833c-e03019ec4ee7">
        <source>pxyCreateUpdateProxy(): SelfType;
// --------------------------------------------------------------------------------
// Created:		05 January 2006 by cnwdad1
//
// Purpose:		Instantiates a proxy object of the receiver and returns the reference.
//
// Parameters:	None
//
// Returns:		A reference to the proxy object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// --------------------------------------------------------------------------------
vars
	proxyObj	: SelfType;
	completedOK		: Boolean;
	
begin
	proxyObj			:=	inheritMethod();
	proxyObj.myRoot		:=	self.myRoot;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyObj;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyObj;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="c69baa6b-b36f-4e3d-a804-c7cd30e06271">
        <updating/>
        <source>setForUpdate(_pxyVisitType: HMS_VisitType; _passport: CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		05 January 2006 by cnwdad1
//
// Purpose:		Updates the receiver's properties from a proxy object.
//
// Parameters:	_pxyVisitType - A reference to the proxy object.
//				_passport - A reference to the user's passport object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(_pxyVisitType, _passport);
	
	// Set any non-key properties, and non-inverse references.
	
	self.description	:=	_pxyVisitType.description;
	
	// Set any key property values.
	
	self.code			:=	_pxyVisitType.code;
	
	// Set any inverse references.
	
	self.myRoot			:=	_pxyVisitType.myRoot;
end;</source>
        <Parameter name="_pxyVisitType" type="HMS_VisitType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="6b722971-93df-4610-9ca0-4812d9fd8273">
        <updating/>
        <source>setProxy(_code:String; _description:String; _rootObj:CM_Root) updating;
// --------------------------------------------------------------------------------
// Created:		05 January 2006 by cnwdad1
//
// Purpose:		Updates the receiver's properties - the receiver must be a transient
//				proxy object.
//
// Parameters:	_code - The Visit Type code.
//				_description - A description of the receiver.
//				_rootObj - A reference to the receiver's root object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.raiseExceptionIfNotTransient(method);
	
	self.description	:=	_description;
	self.code			:=	_code;
	self.myRoot			:=	_rootObj;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_rootObj" type="CM_Root"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="0be1b70f-c1a4-4085-a78c-82bdf4ee5622">
        <source>validateMe(_passport: CM_Passport input);
// --------------------------------------------------------------------------------
// Created:		05 January 2006 by cnwdad1
//
// Purpose:		Standard method to validate the receiver.
//
// Parameters:	_passport - A reference to the user passport object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	existingObj		: HMS_VisitType;
	originalObj		: HMS_VisitType;
	
begin
	inheritMethod(_passport);
	
	if self.code = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Code', ETRow_Code, null);
		app.raiseCMException(Input_required_field_code, ETRow_Code, null); // cnwdb2	PAR 35364
	endif;
	
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Description', ETRow_Description, null);
		app.raiseCMException(Input_required_field_Desc, ETRow_Description, null); // cnwdb2	PAR 35364
	endif;
	
	originalObj	:=	self.pxyGetRealObject();
	existingObj	:=	app.myRoot.allVisitTypes[self.code];
	
	if existingObj &lt;&gt; originalObj then
		app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
