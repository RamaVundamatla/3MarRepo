    <JadeMethod name="doTblDataContextMenu" id="36e8768a-4a82-453b-86ad-47a5d6537229">
        <updating/>
        <source>doTblDataContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theTI : CM_TrackedItem;
	theLocationsController : CM_LocationsController;
begin

	self.mnuLoadListPlanLoad.visible := false;

	if self.tblData.row &gt; self.tblData.fixedRows then
		theTI := self.tblData.accessRow(self.tblData.row).itemObject.CM_TrackedItem;
		
		// #####################
		// PLANNING FROM SHIP?
		// #####################
		if app.myMoveController &lt;&gt; null then
			if theTI &lt;&gt; null then
				if app.myMoveController.mySlotRequest &lt;&gt; null and app.myMoveController.mySlotRequest.myJob &lt;&gt; null then
					// YES!
					if app.myMoveController.mySlotRequest.isLoad then
						if theTI &lt;&gt; null then
							app.myMoveController.setMyTrackedItem(theTI);
						endif;
						theLocationsController := theTI.getPrimaryLocation(REAL_MODE);
						app.myMoveController.setMyOriginatingLocation(theLocationsController);
						self.mnuLoadListPlanLoad.caption := "Plan Load To " &amp; app.myMoveController.mySlotRequest.mySlotController.getFullId;
						self.mnuLoadListPlanLoad.userObject := theLocationsController;
						self.mnuLoadListPlanLoad.visible := true;
					endif;
				endif;
			endif;
		endif;
		
// TFS 45590		self.mnuUnassignTBA.visible := ( theTI.myMatchedTBA &lt;&gt; null ); // PAR 33695  // PAR 35574
		self.mnuUnassignTBA.visible := ( theTI.myMatchedActual &lt;&gt; null ); // TFS 45590
		self.mnuManualTBA.visible := ( theTI.myMatchedActual = null );
	endif;
	return inheritMethod(cntrl, conwin, mouse, x, y);
		
//	return self.showContextMenu(self.mnuContextTable,cntrl,conwin,mouse,x,y);

end;</source>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblDataDBClick" id="ccaee55b-d22c-4784-8bc8-bcd9275a4761">
        <updating/>
        <source>doTblDataDBClick(table: CM_DataTable input) updating;
// ---------------------------------------------------------------------------
// Created:		July 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theTI : CM_TrackedItem;
	theRow : Integer;
begin
	
	inheritMethod(table);
	
	if table.row &lt;= table.fixedRows then
		return;
	endif;
	
	theTI := table.accessRow(table.row).itemObject.CM_TrackedItem;
	if theTI &lt;&gt; null then
		self.myAssistant.showCargoEnquiryForm(theTI, self.myMasterMenuAction, true, false);	
	endif;

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblDataMouseMove" id="e1b00a80-fd91-4166-b01f-e628d5dab452">
        <updating/>
        <source>doTblDataMouseMove(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;

/*

Purpose:			TFS 45590

Parameters:			

Return Value:		


Date		Who		Reason
11 November 2019	jlgab1	Initial creation

*/

vars

	theTI		: CM_TrackedItem;
	lPicture : Picture;
	moveController : CMIF_MoveController;
begin
	if self.tblData.row &lt;= self.tblData.fixedRows 
	or y &lt;= table.accessRow(self.tblData.fixedRows).height then 
		self.origXPos := x;
		self.origYPos := y;
		return;
	endif;
	
	if button = Window.MouseButton_Left 
	and	app.dragDetected(x, y, self.origXPos, self.origYPos) 
	and self.origYPos &gt; 20  // ###  may be doing a column resize!
	and not shift.isControlKeyPressed()
	and not shift.isShiftKeyPressed()
	and not shift.isAltKeyPressed() then
		theTI := self.tblData.accessRow(self.tblData.row).itemObject.CM_TrackedItem;
		if theTI &lt;&gt; null then
			app.myDraggedTrackedItem := theTI;
			create moveController transient;
			
			moveController.setMyTrackedItem(theTI);
			delete app.myMoveController;
			app.myMoveController := moveController;
			app.isDragging := true;
			moveController.setMyOriginatingLocation(theTI.getPrimaryLocation(REAL_MODE));
			self.moveModeForm := REAL_MODE;
			moveController.setMoveMode(REAL_MODE);	
			table.dragMode := DragMode_Drag;
			create lPicture transient;
			self.setPictureDragCursor(lPicture);
			if lPicture.picture &lt;&gt; null then
				table.dragCursor := lPicture.picture;
			endif;

		endif;
	endif;
epilog
	if lPicture &lt;&gt; null then
		delete lPicture;
	endif;
	


end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="initQueryFrame" id="3c7c5e65-6c84-4eba-8111-20e50117a924">
