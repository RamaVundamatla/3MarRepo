    <JadeMethod name="pxyCreateUpdateProxy" id="b4667e13-7d3b-4c37-9a72-055cd72a7ed4">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	pxyMe : SelfType;
	pxyLayer : CM_DeckLayerLayout;
	pxyDeck : CM_Deck;
	pxyLayout : CM_DeckItemLayout;
	completedOK : Boolean;
begin
	pxyMe:= inheritMethod();

	if  self.myDeckLayerLayout &lt;&gt; null then
		pxyLayer := self.myDeckLayerLayout.pxyGetProxyObject();
	endif;
	
	pxyDeck := self.myDeck.pxyGetProxyObject();
	pxyLayout := self.myLayout.pxyGetProxyObject();
	
	pxyMe.myDeckLayerLayout := pxyLayer;
	pxyMe.myDeck := pxyDeck;
	pxyLayout.myDeckItem := pxyMe;// PAR 27528 
	
	completedOK := true;			
	return pxyMe;
epilog
	if not completedOK then			
		delete pxyMe;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreateImport" id="6bb8ad07-9adf-4846-9e55-02bcf6ee7d8b">
        <updating/>
        <source>setForCreateImport(_proxyDeckItem: SelfType; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 May 2011	cnwer1	Initial creation CCMS 1031

*/

vars

begin
	inheritMethod(_proxyDeckItem, _passport);
	
	self.myDeckLayerLayout:=self.myLayout.myDeckLayer;
epilog

end;</source>
