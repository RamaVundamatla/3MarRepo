        <source>setDetails(_message : String; _bol : String; _id : String; _sequence : String; _header : CMIF_SuzanoDeliveryHeader) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 09/03/2023	navdap1		Initial creation TFS 56796 PRP Suzano EDI Delivery Communication
// 24/04/2023	navdap1		TFS 57542 PRP - Suzano Delivery Communications File - Line Item Sales Order Item
