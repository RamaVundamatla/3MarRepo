    <JadeMethod name="updatePersistentObject" id="d48fbe49-b2c1-480a-9e60-71a910491bce">
        <source>updatePersistentObject(_terminal : CM_Terminal input; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     08 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 03 Feb 2017	cnwrs1	TFS 3247 not deleting emails at NXL
// 20 Feb 2018	jlgmd1	TFS 36954 SNO - Error in SCT2 Rate Table (Swap $CM_RateEntry.decimalPlaces for terminal config)
// 02 Dec 2019  cnwma1	ChangeRequest 47743: PEN - Field contents not fitting window
// 18/10/2021	jlier1	TFS 52213
//07 Jul 2022 navhl20 TFS 53697 EUP - VBS MTN - [1] - VBS Slot Types 
// ---------------------------------------------------------------------------

vars
	propCol	   : PropertyColl;
	prop	   : Property;
	keyStr	   : String;
	converted  : Boolean;
	nullVoyage : CM_Voyage;
	defVoyageProcess : String;
begin

	inheritMethod(_terminal, _passport);

	propCol := self.class.allPropertiesUpTo(CMIF_Config);
	
	foreach prop in propCol do
		if self.isPropertyToIgnore(prop) then
			continue;
		endif;

		if prop.name = CMIF_ConfigTerminal::allTerminalsForRelease.name then
			if not _terminal.validateTerminalsForRelease(self.allTerminalsForRelease) then // PAR 17132
				continue;
			endif;
			_terminal.allTerminalsForRelease.clear;
			self.allTerminalsForRelease.copy(_terminal.allTerminalsForRelease);
			continue;
		elseif prop.name = CMIF_ConfigTerminal::allTerminalsForVoyageInland.name then
			_terminal.allTerminalsForVoyageInland.clear;
			self.allTerminalsForVoyageInland.copy(_terminal.allTerminalsForVoyageInland);
			continue;
		elseif prop.name = CMIF_ConfigTerminal::myRoadProcess.name then	//02 Oct 2020	NDL	TFS 49189
			_terminal.setMyRoadProcess( self.myRoadProcess );
			continue;
		elseif prop.name = CMIF_ConfigTerminal::myVBSProcess.name then	//07 Jul 2022 navhl20 TFS 53697
			_terminal.setMyVBSProcess( self.myVBSProcess );
			continue; 
		endif;
		if prop.name = CMIF_ConfigTerminal::autoImapFlags.name then
			converted := _terminal.getExtensionObjectValue(Obj_Extn_terminalImapFlags).Boolean;
			if not converted then
				_terminal.setExtensionObjectValue(Obj_Extn_terminalImapFlags, true);
			endif;
		endif;
		
		keyStr := self.getKeyStringForProperty(prop.name);
		if keyStr &lt;&gt; null then
			if keyStr = DefCompany then	//18 Apr 2012	NDL	Par 29393
				_terminal.setDefaultCompanyBank( self.getPropertyValue(prop.name).CM_Bank );
			elseif keyStr = DefaultVoyageProcess then	//13 Dec 2018	NDL	TFS 42546
				defVoyageProcess:=self.getPropertyValue(prop.name).String;
				if defVoyageProcess = null then
					defVoyageProcess:=VoyageProcessDefault;
				endif;
				_terminal.setConfig(keyStr, defVoyageProcess);
				nullVoyage := _terminal.getNullVoyage;
				if nullVoyage &lt;&gt; null then
					nullVoyage.setVoyProcessFromTerm();
				endif;
			else
				_terminal.setConfig(keyStr, self.getPropertyValue(prop.name));
			endif;
		else
			// need to handle as a special
			executeWhen JMTDevelopmentEnvironment;
			app.writeStatement(class.name &amp; '::' &amp; method.name &amp; '&gt;&gt;&gt;&gt; special&gt;&gt;&gt; ' &amp; prop.name);
			endExecuteWhen;
		endif;
	endforeach;
	
	_terminal.setCalendar(self.myCalendar);

	//02.12.2019 cnwma1 #47743
	if self.roadGateCargoCheckOption =  CARGO_CHECK_NONE then      
		if _terminal.myRoadGateCargoCheckCriteria &lt;&gt; null then
			_terminal.myRoadGateCargoCheckCriteria.allCriteria.purge;
			delete _terminal.myRoadGateCargoCheckCriteria;
		endif;
	endif;
	
	//dPlaces := _terminal.getConfig(FinancialRateDPlaces).Integer;
	// ### $CM_RateMoney is a Currency Format edit in PortSchema Formats
	// No longer used, now we just reference the terminal config directly
	/*$CM_RateMoney.defineCurrencyFormat(dPlaces,
					$CM_RateMoney.decimalSeparator,
					$CM_RateMoney.thousandSeparator,
					$CM_RateMoney.positiveFormat,
					$CM_RateMoney.negativeFormat,
					$CM_RateMoney.showLeadingZeros,
					$CM_RateMoney.symbol);
	$CM_RateEntry.defineNumberFormat(dPlaces,
					$CM_RateEntry.decimalSeparator,
					$CM_RateEntry.thousandSeparator,
					$CM_RateEntry.negativeFormat,
					$CM_RateEntry.showLeadingZeros);*/
epilog
	delete propCol;
end;
</source>
        <Parameter name="_terminal" type="CM_Terminal" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateTerminal" id="aa3a7418-5e0e-4ea7-b4ad-ffa9cca6ba8e">
        <source>updateTerminal(_terminal : CM_Terminal);
// ---------------------------------------------------------------------------
// Created:     06 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	propCol	: PropertyColl;
	prop	: Property;
	
begin
	propCol := self.class.allPropertiesUpTo(CMIF_Config);
	
	foreach prop in propCol do
		// need to check if the prop.name is a valid constant =&gt; need a collection of the
		// constants in the category for this one.
		if self.allGlobalConstantValues.includes(prop.name) then
			_terminal.setConfig(prop.name, self.getPropertyValue(prop.name));
		else
			// need to handle as a special
		endif;
	endforeach;
epilog
	delete propCol;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="validateConfig" id="c16cbdb6-a1e2-4b0a-b8af-bd0bb4d44753">
        <source>validateConfig();

/*

Purpose:		Validate config data		

Parameters:			

Return Value:		


Date		Who		Reason
02 Dec 2009	cnwmh5	Initial creation #21655
23 Feb 2010	consw1	PAR #21156 - Gate Config Report Names
25 Feb 2014	cnwdap1	PAR #33582 Security Gate changes
21 Sep 2023	jlizm1	TFS 59576 Kiosk error advice report - gate config
*/

vars
	prefixStartSeqLength	: Integer;
	totalLength				: Integer;
	entTableDef1 : EntTableDef;
	entRow1 : EntTableRow;
	entTableDef2 : EntTableDef;
	entRow2 : EntTableRow;
begin
	
	prefixStartSeqLength := self.vehicleVisitNumPrefix.trimBlanks.length + self.vehicleVisitNumStartSeq.String.length;
	totalLength := prefixStartSeqLength + self.vehicleVisitNumLength;
	if totalLength &gt; 30 then
		app.raiseCMException1(ERR_VEHICLEVISITNUMBER, (30 - prefixStartSeqLength).String, null, null);
	endif;

	self.validateReport(self.gateCarterNoteReport);
	self.validateReport(self.gateDriverInstructionsReport);
	self.validateReport(self.gateRoadJobReceipt);
	self.validateReport(self.gateInterchangeReport);	//11 Jan 2019	NDL	TFS 40479
	self.validateReport(self.gateKioskErrorAdvice);
	self.validateReport(self.gateTicketJRWEquipment_REL);
	self.validateReport(self.gateTicketJRWEquipment_REC);
	self.validateReport(self.gateTicketJRWReefer);
	self.validateReport(self.gateTicketJRWEIR);
	self.validateReport(self.gateTicketJRWTrouble);
	self.validateReport(self.gateTicketJRWHaz);
	
	// PAR #33582 Known Truck Required must be ticked if Site Has Security Gate and Hide Bat Number		// PAR #33582
	// are both set - i.e. if Site has Security Gate, one of Bat Number or Known Truck must be able to 	// PAR #33582
	// be entered																						// PAR #33582
	if self.gateInOutHideBatNumber and self.siteHasSecurityGate and not self.knownTruckRequired then	// PAR #33582
		app.raiseCMException(KnownTruckConflictsBatNumber, null, null);									// PAR #33582
	endif;																								// PAR #33582
	
	//25 Oct 2019	NDL	TFS 47101
	if self.allowDuplicatePreNotes then
		if self.ediAlwaysProcPrenote then
			entTableDef1 := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_EDIConfig];
			entRow1 := entTableDef1.getEntTableRow(ETRow_EdiAlwaysProcPrenote);
			entTableDef2 := app.myRoot.myEntTableDataRoot.allEntTableDefs[ETDef_TerminalDefaultsConfig];
			entRow2 := entTableDef2.getEntTableRow(ETRow_AllowDuplicatePreNotes);
			app.raiseCMException2( Mutua_exclu_not_have_them_both, entRow1.getRawHeadingValue &amp; " [" &amp; entTableDef1.description &amp; " tab]", entRow2.getRawHeadingValue &amp; " [" &amp; entTableDef2.description &amp; " tab]", null, null );
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateReport" id="956c1364-8035-41d3-b46f-79dd5544d392">
        <source>validateReport(_reportName : String);

/*

Purpose:			Validate JRW Report name.  Null is valid.
					NOTE: If the the report name entered is the same as the default report name in global constants,
					then we aren't passing value to store.  Be aware of this if we change our minds about null being a valid 
					value as opposed to an exception.

Parameters:			Report name

Return Value:		None


Date		Who		Reason
23 Feb 2010	consw1	PAR #21156 - Gate Config Report Names
16 Mar 2010	consw1	PAR #22886 - Leaking report transients
14 Jul 2011 cnwjre1	PAR 27851 printing to lineflow, report names can have options delimited by '?'
*/

vars
	pos		: Integer;
	reportName	: String;
	jrwManager	: JadeReportWriterManager;
	jrwReport	: JadeReportWriterReport;
	dotMatrxReport : Class;
	
begin
	if _reportName = null then
		return;
	endif;

	// 27851 check for trailing options on the name
	reportName := _reportName;
	pos := _reportName.pos("?", 1);
	if pos &gt; 0 and pos &lt; _reportName.length then
		reportName := _reportName[1:pos-1];
	endif;
	jrwManager := app.createReportWriterManager();
	
	jrwReport  := jrwManager.getReport(reportName);
	
	if jrwReport = null then
		//12 Nov 2012	NDL	Par 30682
		dotMatrxReport := currentSchema.getSchema("UiCommonSchema").getClass(reportName);
		if dotMatrxReport &lt;&gt; null then
			return;
		endif;
		app.raiseCMException1(Report_not_found, reportName, null, null);
	endif;
	
epilog
	delete jrwReport;
	delete jrwManager;
end;</source>
        <Parameter name="_reportName" type="String"/>
    </JadeMethod>
</Class>
