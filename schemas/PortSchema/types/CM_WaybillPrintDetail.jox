        <updating/>
        <source>setContainerNumberStr( _containerSet : CM_TISet; _delim : String ) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2015	cnwndl1	Initial creation	Par 36777

*/

vars

	ti : CM_TrackedItem;
