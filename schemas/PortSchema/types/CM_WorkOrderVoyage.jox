    <JadeMethod name="validateForDelete" id="d0934323-bba8-440a-8d54-bee4003e55ee">
        <source>validateForDelete();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 06/07/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
//
vars

begin
	if self.taskStatus &gt; WO_STATUS_NOTAPPROVED 	then  //do not allow deleting of approved or on
		if self.getFirstTask &lt;&gt; null and self.getFirstTask.getTotalActioned() &gt; 0 then
			app.raiseCMException(Work_order_canno_delet_with_st, null, null);
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="95779350-e3a4-45cf-8ae4-8c65a846b598">
        <source>validateForUpdate();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 23/05/2018	jlgdap1		Initial creation TFS 38560 PEL1 Voyage Work Orders
// 14/07/2022	navcs2		ChangeRequest 53932: MTN - Jobs Changes
// 01/09/2022	jlizm1		TFS 54298 EUP - Simplified Voyage Work Order Process
vars

begin
	inheritMethod();

	if self.myVoyage = null and self.voyageCodeExternal = null then
		app.raiseCMException(Input_required_field_voyage, null, null);
		return;
	endif;
	
	// navcs2 53932 14/07/2022
	if self.myVoyage &lt;&gt; null then
		if not self.myVoyage.isMTNWOVoyageProcess and not self.myVoyage.isEUPDefaultVoyageProcess then
			app.raiseCMException(Voyage_wo_must_process , null, null);
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
</Class>
