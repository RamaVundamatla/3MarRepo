    <JadeMethod name="delete" id="5316dfb7-0dab-4906-94dc-6b366750466b">
        <source>delete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 December 2025	navcs2	MTN-36746 MTN | KPI REST APIs - Voyage [1]

*/

vars
begin
	self.allKPIVoyageDetails.purge();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="2b3730eb-61ff-4ba5-8114-1c0248035594">
        <updating/>
        <source>setProxyFromObject(_voyageKPI : CM_KPIVoyageEntity; includeDetails : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		WS_KPIVoyage
Date		Who		Reason
16 December 2025	navcs2	MTN-36746 MTN | KPI REST APIs - Voyage [1]

*/

vars
	wsKpiDTLCont	: WS_KPIVoyageDtl_Cont;
	wsKpiDTLGC		: WS_KPIVoyageDtl_GC;
	kpiDTLCont 		: CM_KPIVoyageMoveDtl_Container;
	kpiDTLGC		: CM_KPIVoyageMoveDtl_GC;
begin
	self.dateTime 				:= _voyageKPI.dateTime.asStringForWebInterface;
	self.hoursDelay 			:= _voyageKPI.hoursDelay;
	self.hoursDown				:= _voyageKPI.hoursDown;
	self.hoursGross 			:= _voyageKPI.hoursGross;
	self.hoursNet 				:= _voyageKPI.hoursNet;
	self.liftMaxPerHour 		:= _voyageKPI.liftMaxPerHour;
	self.liftMinPerHour 		:= _voyageKPI.liftMinPerHour;
	self.movesLid 				:= _voyageKPI.movesLid;
	self.movesTEU 				:= _voyageKPI.movesTEU;
	self.movesTI				:= _voyageKPI.movesTI;
	
	if includeDetails then
		foreach kpiDTLCont in _voyageKPI.allKPIVoyageMoveDtls_Container do
			create wsKpiDTLCont transient;
			wsKpiDTLCont.setProxy(kpiDTLCont);
			self.allKPIVoyageDetails.add(wsKpiDTLCont);
		endforeach;
		
		foreach kpiDTLGC in _voyageKPI.allKPIVoyageMoveDtls_GC do
			create wsKpiDTLGC transient;
			wsKpiDTLGC.setProxy(kpiDTLGC);
			self.allKPIVoyageDetails.add(wsKpiDTLGC);
		endforeach;
	endif;
epilog

end;</source>
        <Parameter name="_voyageKPI" type="CM_KPIVoyageEntity"/>
        <Parameter name="includeDetails" type="Boolean"/>
    </JadeMethod>
</Class>
