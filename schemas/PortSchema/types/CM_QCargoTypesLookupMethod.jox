<Class name="CM_QCargoTypesLookupMethod" id="1a583fe4-3a60-4b77-a595-098ca70f90c6">
    <superclass name="CM_QCargoTypeLookupMethod"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="a297aca2-d720-4f7e-a1be-525db335a918">
        <updating/>
        <source>create() updating;
// -----------------------------------------------------------------------------
// Created:		07 May 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
// 16 October 2023	navmv20	Bug 60677: FR | EUP 54086 - Invoicing Maintenance enhancements - Selector Query - Invoice mode
// -----------------------------------------------------------------------------
vars
	oper : CM_QueryOperator;

begin
	if self.isTransient then 
		return;
	endif;
	
	self.allAllowedOperators.clear;
	
	create oper as CM_QIntArrayLookupEqual persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QIntArrayLookupNotEqual persistent;
	self.allAllowedOperators.add(oper);
	
	create oper as CM_QIntegerArrIsOneOf persistent;
	self.allAllowedOperators.add(oper);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="cc73bbf8-096d-490f-a9ff-52c09138faa5">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2023	navmv20	Bug 60677: FR | EUP 54086 - Invoicing Maintenance enhancements - Selector Query - Invoice mode

*/

vars
	object 		: CM_CargoType;
	invalidObj 	: Boolean;
	returnVal	: String;
	cargoType : Integer;
	
begin
	if _value.isKindOf(Integer) then
		if _value.Integer &gt; 0 then
			object := app.myRoot.allCargoTypesById[_value.Integer];
			
			if object &lt;&gt; null then
				on Exception do app.handleDeletedObject(exception, object, invalidObj);
				
				returnVal := object.description;
			endif;
			
		endif;
	elseif _value.isKindOf(IntegerArray) then
		foreach cargoType in _value.IntegerArray do
			object := app.myRoot.allCargoTypesById[cargoType];
			if returnVal = null then
				returnVal := object.description;
			else
				returnVal := returnVal &amp; ", " &amp; object.description;
			endif;
		endforeach;
	endif;
	
	return returnVal;
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
