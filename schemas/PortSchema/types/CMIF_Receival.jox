    <JadeMethod name="getSealValue" id="52134ce7-4a33-4a6f-a313-21a5e138b975">
        <source>getSealValue(_sealType : CM_SealType): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 September 2010	cnwndl1	Initial creation

*/

vars

	seal : CM_SealTI;
	
begin

	foreach seal in self.allSeals do
		if seal.sealType = _sealType.sealType then
			return seal.getSealValueAsString;
		endif;
	endforeach;
	
	return null;
			
epilog

end;</source>
