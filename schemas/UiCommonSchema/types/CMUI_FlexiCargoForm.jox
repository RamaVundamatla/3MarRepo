    <JadeMethod name="initFromFlexiGateForm" id="f5122e96-d22f-49e4-b939-01cf1538df48">
        <updating/>
        <source>initFromFlexiGateForm(_flexiGateForm : CM_BaseForm; _tranNum : String; _copy : Boolean; _gteEntity : CMGTE_Entity; _bulkRelease : CM_BulkRelease; _reserve : CM_ReserveDetail; _ti : CM_TrackedItem; _brItem : CM_BookingRefItem; _bolDtl : CM_BOLDtl; _vehicleVisit : CM_VehicleVisitRecord; _itemIds : StringArray; _vbsti : CM_VehicleBookingTimeSlotItem) updating;
/* ---------------------------------------------------------------------------
Created:     05 May 2009 by cnwrs2

Purpose:     
        
Change Date	Who		Reason
24/03/2010	cnwdap1	PAR #23320 If editing an attachment while adding a gate receipt, we only have a proxy GTE Entity even though this is an Update
11/02/2011	cnwdap1	PAR #26929 bulk release passed in here could be an invalid object - protect against this
------------------------------------------------------------------------------*/
vars
	id		: String;
begin
	self.isFlexiGateForm		:= true;
	self.isPreNoteForm			:= false;
	self.setParentForm(_flexiGateForm);
	self.myMainForm 			:= _flexiGateForm;
	self.myCurrentVehicleVisit 	:= _vehicleVisit;
	self.currentTransNum 		:= _tranNum;
	self.myBulkRelease 			:= null;
	self.myReserveDetail 		:= null;
	self.myTI 					:= null;
	self.tiPrenoteEdition		:= 0;
	self.myBookingRefItem 		:= null;
	self.myCargoType			:= null;

	self.myPxyGTEEntity			:= null;
	self.myRealGTEEntity 		:= null;
	self.myRealGTEEntityToCopy	:= null;
	
	//06 Oct 2020	NDL	TFS 49189
	if _bolDtl &lt;&gt; null and self.myTerminal.roadProcessIsASPA then
		self.myBOLDtl := _bolDtl;	
		self.myBOL := _bolDtl.myBOL;
		if self.myBOL &lt;&gt; null then
			self.myVoyage := self.myBOL.getMyVoyage;
		endif;
	endif;
		
	if _gteEntity &lt;&gt; null then
		if _copy then
			self.myRealGTEEntityToCopy := _gteEntity;
		elseif _gteEntity.isTransient() then
			self.myPxyGTEEntity 	:= _gteEntity;
			self.myRealGTEEntity	:= _gteEntity.pxyGetRealObject();
		else
			self.myRealGTEEntity 	:= _gteEntity;
			self.myPxyGTEEntity		:= _gteEntity.pxyGetProxyObject();
			if self.myPxyGTEEntity = null then
				self.myPxyGTEEntity := app.createUpdateProxy(_gteEntity).CMGTE_Entity;
			endif;
			/*if self.isKindOf(CMUI_ReceiveCargoForm) then
				self.CMUI_ReceiveCargoForm.btnAdditionalDet.enabled := true;
			endif;//cnwas3*/
		endif;
	endif;
	
	if self.myRealGTEEntity = null then
		self.updateMode 		:= self.Mode_Add;
	else
		self.updateMode 		:= self.Mode_Update;
	endif;
	// PAR #23320 For attachments when adding a gate entity, we only have a proxy not a real, 
	// but it's still an update
	if app.isValidObject(myParentForm) and self.isKindOf(myParentForm.class) then
		// we're an attachment form, if we have a proxy GTE entity then we must be updating it
		if self.myPxyGTEEntity &lt;&gt; null then
			self.updateMode		:= self.Mode_Update;
		endif;
	endif;
	// PAR #23320 end

	//if _bulkRelease &lt;&gt; null and _reserve &lt;&gt; null then										// PAR #26929
	if _bulkRelease &lt;&gt; null and app.isValidObject(_bulkRelease) and _reserve &lt;&gt; null then	// PAR #26929
		// setupForm() will pick these up and set the fileds accordingly, after initilisation of combos etc.
		self.myBulkRelease 		:= _bulkRelease;
		self.myReserveDetail 	:= _reserve;
	endif;
	
	if _ti &lt;&gt; null then
		// setupForm() will pick this up and set the fields accordingly, after initilisation of combos etc.
		self.myTI 				:= _ti;
		self.tiPrenoteEdition	:= _ti.edition;
	endif;
	
	if _brItem &lt;&gt; null then 
		// setupForm() will pick this up and set the fields accordingly, after initilisation of combos etc.
		self.myBookingRefItem 	:= _brItem;
	endif;
	
	// 29287 Apr 2012 multi-select pre-notes in road gate	
	if _itemIds &lt;&gt; null and
	   self.isKindOf(CMUI_ReceiveCargoForm) then
		foreach id in _itemIds do
			self.CMUI_ReceiveCargoForm.cargoIDs.add(id);
		endforeach;
	endif;
	
	// ### TFS 61525 (61527) 15Jul2024 NAVPW1
	if self.isKindOf(CMUI_ReleaseCargoForm) then
		self.CMUI_ReleaseCargoForm.setVehicleBookingTimeSlotItem(_vbsti);
	endif;
	
epilog
 
end;</source>
        <Parameter name="_flexiGateForm" type="CM_BaseForm"/>
        <Parameter name="_tranNum" type="String"/>
        <Parameter name="_copy" type="Boolean"/>
        <Parameter name="_gteEntity" type="CMGTE_Entity"/>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
        <Parameter name="_reserve" type="CM_ReserveDetail"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_brItem" type="CM_BookingRefItem"/>
        <Parameter name="_bolDtl" type="CM_BOLDtl"/>
        <Parameter name="_vehicleVisit" type="CM_VehicleVisitRecord"/>
        <Parameter name="_itemIds" type="StringArray"/>
        <Parameter name="_vbsti" type="CM_VehicleBookingTimeSlotItem"/>
    </JadeMethod>
    <JadeMethod name="initFromOnshipForm" id="f619c6aa-37fc-41af-99ec-327b83294cd7">
        <updating/>
        <source>initFromOnshipForm(_onShipForm : CM_BaseForm; _bolDetail : CM_BOLDtl; _stowage : CM_Object; _trackedItem : CM_TrackedItem; _prenote : CMIF_PreNote; _voyage : CM_Voyage; _defaultLocation : CM_LocationsController) updating;
/*
Purpose:			

Parameters:		
_stowage is a place-holder for CM_Stowage (or whatever) in 7.8.2	

Return Value:		

Date		Who		Reason
16/01/2020	cnwjre1	Initial creation
19/12/2024	jlizm1	MTN 33241 Cannot edit attachments when creating cargo from voyage ops live
*/
vars

begin
	self.isOnshipForm 			:= true;
	self.isPreNoteForm			:= false;
	self.isFlexiGateForm		:= false;
	self.setParentForm(_onShipForm);
	self.myMainForm 			:= _onShipForm;
	self.myCurrentVehicleVisit 	:= null;
	self.myDefaultLocation := _defaultLocation; // TFS 3218
	self.currentTransNum 		:= null;
	self.myBulkRelease 			:= null;
	self.myReserveDetail 		:= null;
	self.myTI 					:= _trackedItem;
	self.myIntFacePreNote		:= _prenote;
	self.myBookingRefItem 		:= null;
	self.myCargoType			:= null;
	self.myBOLDtl				:= _bolDetail;
	self.myVoyage 				:= _voyage;
	
	if _trackedItem &lt;&gt; null then
		// from PAR #21827 Correct proxy/real ti handling for attachment editing
		if _trackedItem.isTransient then
			self.myTI				:= _trackedItem.pxyGetRealObject();
			self.myProxyTrackedItem	:= _trackedItem;
		else
			self.myTI			 	:= _trackedItem;
			self.myProxyTrackedItem := _trackedItem.pxyGetProxyObject();
			if self.myProxyTrackedItem = null then
				self.myProxyTrackedItem := app.createUpdateProxy(_trackedItem).CM_TrackedItem;
			endif;
		endif;
		self.updateMode 		:= self.Mode_Update;
	else
		self.updateMode 		:= self.Mode_Add;
		self.setIsGeneralCargo();
	endif;

end;</source>
        <Parameter name="_onShipForm" type="CM_BaseForm"/>
        <Parameter name="_bolDetail" type="CM_BOLDtl"/>
        <Parameter name="_stowage" type="CM_Object"/>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_prenote" type="CMIF_PreNote"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_defaultLocation" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="initFromOnsiteForm" id="919f1fa2-5696-4599-8ce3-d40fb09aba8e">
        <updating/>
        <source>initFromOnsiteForm(_onShipForm : CM_BaseForm; _bolDetail : CM_BOLDtl; _stowage : CM_Object; _trackedItem : CM_TrackedItem; _prenote : CMIF_PreNote; _voyage : CM_Voyage; _defaultLocation : CM_LocationsController) updating;
/*
Purpose:			
Date		Who			Reason
FEB 2107	CNWAB1		Initial creation
19/12/2024	jlizm1		MTN 33241 Cannot edit attachments when creating cargo from voyage ops live
*/

vars
	newId : String;
begin
	self.isOnshipForm 			:= false;
	self.isPreNoteForm			:= false;
	self.isFlexiGateForm		:= false;
	self.isOnsiteForm := true; // TFS 3218 create onsite
	self.setParentForm(_onShipForm);
	self.myMainForm 			:= _onShipForm;
	self.myCurrentVehicleVisit 	:= null;
	self.myDefaultLocation := _defaultLocation; // TFS 3218
	self.currentTransNum 		:= null;
	self.myBulkRelease 			:= null;
	self.myReserveDetail 		:= null;
	self.myTI 					:= _trackedItem;
	self.myIntFacePreNote		:= _prenote;
	self.myBookingRefItem 		:= null;
	self.myCargoType			:= null;
	self.myBOLDtl				:= _bolDetail;
	self.myVoyage 				:= _voyage;
	
	
	if _trackedItem &lt;&gt; null then
		// from PAR #21827 Correct proxy/real ti handling for attachment editing
		if _trackedItem.isTransient then
			self.myTI				:= _trackedItem.pxyGetRealObject();
			self.myProxyTrackedItem	:= _trackedItem;
		else
			self.myTI			 	:= _trackedItem;
			self.myProxyTrackedItem := _trackedItem.pxyGetProxyObject();
			if self.myProxyTrackedItem = null then
				self.myProxyTrackedItem := app.createUpdateProxy(_trackedItem).CM_TrackedItem;
			endif;
		endif;
		self.updateMode 		:= self.Mode_Update;
	else
		self.updateMode 		:= self.Mode_Add;
		self.setIsGeneralCargo();
	endif;

end;</source>
        <Parameter name="_onShipForm" type="CM_BaseForm"/>
        <Parameter name="_bolDetail" type="CM_BOLDtl"/>
        <Parameter name="_stowage" type="CM_Object"/>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_prenote" type="CMIF_PreNote"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_defaultLocation" type="CM_LocationsController"/>
    </JadeMethod>
