    <JadeMethod name="getRemarks" id="f82fb299-b00c-4092-a57d-3ce4bcc622b9">
        <source>getRemarks(): String;
// ---------------------------------------------------------------------------
// Created:     09 April 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	21/09/2010  cnwas3  par 25420
// May 2011		cnwjre1	27079 also pick up delivery request remarks themselves
// ---------------------------------------------------------------------------
vars
	str : String;
begin	
	if self.myReserveDetail &lt;&gt; null then						//cnwas3 par 25420
		str :=  self.myReserveDetail.remarks.trimRight();
		if str = null then
			if self.myOriginatingBulkRelease &lt;&gt; null then
				str := self.myOriginatingBulkRelease.cargoRemarks.trimRight();
				if str = null then
					str := self.remarks.trimRight();	// 27097
				endif;
				return str;
			endif;
		else
			return str;
		endif;	
	else
		return self.remarks.trimRight;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTargetTA" id="dbd90d66-a0ac-4c03-a39d-958b00797e89">
        <source>getTargetTA(): String;
// -------------------------------------------
// Created 25 May 2005 by cnwdvb1
// -------------------------------------------
// 08/03/2011	cnwmh5	PAR #27142 - Change to local variable rather than self for handleDeleteObject exception
vars
	invalidObject : Boolean;
	targetTA	: CM_TerminalArea;
begin
	
	on Exception do app.handleDeletedObject(exception,targetTA,invalidObject);
	
	targetTA := self.myTargetTA;
	if targetTA &lt;&gt; null then
		return targetTA.getID();
	endif;
	return inheritMethod();


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
