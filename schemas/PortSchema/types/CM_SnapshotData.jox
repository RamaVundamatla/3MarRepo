/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2009	cnwndl1	Initial creation - Migrated up

*/

vars

begin

	return app.myRoot.allQueryDefinitionObjects[self.type, self.mode];
	
epilog

end;</source>
        <ReturnType type="CM_QueryDefinition"/>
    </JadeMethod>
    <JadeMethod name="getQueryProperty" id="13d4e121-cd1a-4d81-948a-59f0b7ff9fbc">
        <source>getQueryProperty(_property: String): CM_QueryProperty;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 December 2009	cnwndl1	Initial creation - Migrated up

*/

vars
	queryDef				: CM_QueryDefinition;
	property				: CM_QueryProperty;
	coll					: CM_QueryPropertyDict;
	
begin
	queryDef 	:= self.getQueryDefinition;
	
	if queryDef = null then
		return null;
	endif;
	
	coll		:= queryDef.allQueryProperties;
	property	:= coll[ _property ];
	
	return property;
	
epilog
	
end;</source>
        <Parameter name="_property" type="String"/>
        <ReturnType type="CM_QueryProperty"/>
    </JadeMethod>
    <JadeMethod name="getRunDate" id="0eb93506-0070-4851-878e-2c990d8316ab">
