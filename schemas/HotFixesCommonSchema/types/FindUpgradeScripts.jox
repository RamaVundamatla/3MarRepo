    <JadeMethod name="butOpen_click" id="1625a1ba-c3d7-42b6-b333-10fe275ec883">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>butOpen_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 August 2010	cnwmd1	Initial creation

*/

vars
	args : StringArray;
	result : Integer;
	namePath : String;
	pos : Integer;
begin
	namePath := txtInstallFile.text;
	pos := namePath.reversePos('\');
	
	create args transient;
	args.add(namePath[pos+1:end]);
	
	node.createExternalProcess(namePath[1:pos-1],'notepad.exe', args, null, true, false, result);
epilog
	delete args;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="butOutput_click" id="b1dcdb5d-0ea2-4486-86e6-eb8b2cf355c3">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>butOutput_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 August 2010	cnwmd1	Initial creation

*/

vars
	outputFolder : FileFolder;
	path, tmpStr : String;
	ts : TimeStamp;
begin
	tmpStr := ts.literalFormat;
	tmpStr.replaceChar(':', ' ');
	
	create outputFolder transient;
	path := outputFolder.browseForFolder("Choose Output Folder", "F:\SETUP\782\JARI\772to782WorkingDir");
	if path &lt;&gt; null then
		txtOutputFolder.text := path &amp; "\" &amp; tmpStr &amp; ".csv";
	endif;
epilog
	delete outputFolder;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="butStart_click" id="acc435b1-cb79-4b78-931b-ada0d5735cdf">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>butStart_click(btn: Button input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 August 2010	cnwmd1	Initial creation

*/

vars
	js : JadeScript;
	record : String;
	fileName : String;
begin
	closeFiles;
	
	self.endProcessing := false;
	
	//create js transient;
	//fileName := js.gdkUpgradeScripts772to782();
	fileName := getUpgradeScripts;
	
	create myInputFile transient;
	myInputFile.kind := File.Kind_Unknown_Text;	// 1/3/16 cnwmp6 PAR 36286 unicode version
	myInputFile.fileName := fileName;
	myInputFile.mode := File.Mode_Input;
	myInputFile.open;
	record := myInputFile.readLine;
	app.writeLogMessage(record);
	
	create myOutputFile transient;
	myOutputFile.mode := File.Mode_Output;	// 1/3/16 cnwmp6 PAR 36286 unicode version
	myOutputFile.fileName := txtOutputFolder.text;//fileName[1:fileName.length - 4] &amp; '_complete.csv';
	populateControls(record);
	
epilog
	delete js;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="closeFiles" id="0c08624e-5cfc-44ae-b363-aed194586c93">
        <updating/>
        <source>closeFiles()updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 August 2010	cnwmd1	Initial creation

*/

vars

begin
	if myOutputFile &lt;&gt; null and myOutputFile.isOpen then
		myOutputFile.close;
		delete myOutputFile;
	endif;
	
	if myInputFile &lt;&gt; null and myInputFile.isOpen then
		myInputFile.close;
		delete myInputFile;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="endProcessing" id="00b0d3fd-4e3e-4b23-8264-f2d162ec7f93">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>endProcessing(set : Boolean; _value : Boolean io) mapping,updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 August 2010	cnwmd1	Initial creation

*/

vars

begin
	if set then
		if _value = true then
			self.caption := "Complete";
		else
			self.caption := "Working...";
		endif;
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getUpgradeScripts" id="0088333c-983a-41ac-8caa-29d4778cec64">
        <source>getUpgradeScripts() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 August 2010	cnwmd1	Initial creation

*/

constants
	Hotfixes_Folder : String = 'Hotfixes';
	JadeMaster_Folder : String = 'JadeMaster';
	Schemas_Folder : String = 'Schemas';
	Install_File : String = 'JMTInstall.txt';
	Cmd_Schema : String = 'SCM';
	Cmd_RunJade : String = 'RUNJADE';
	Cmd_SchemaCheck : String = 'SCMCHK';
	PortSchema : String = 'PortSchema';
	Delimeter : String = ',';
vars
	hotfixesFolder : FileFolder;
	fileNode, hotfixesNode, patchNode : FileNode;
	installFile, schemaFile, outputFile : File;
	indx, pos, numPatches, numScripts : Integer;
	cmdLine, release, hotfix, patch, par, portSchemaFileName, tmpStr : String;
begin
	create outputFile transient;
	outputFile.fileName := txtOutputFolder.text &amp; '.tmp';
	outputFile.mode := File.Mode_Output;
	
	create hotfixesFolder transient;
	
	foreach indx in 1 to lstHotfixes.listCount where lstHotfixes.itemSelected[indx] do
		fileNode := lstHotfixes.itemObject[indx].FileNode;
		release := fileNode.name;
		hotfixesFolder.fileName := fileNode.fileName &amp; '\' &amp; Hotfixes_Folder;
		if not hotfixesFolder.isAvailable() then 
			app.writeLogMessage('Aborting - Hotfixes Folder not available');
			return null; 
		endif;
		foreach hotfixesNode in hotfixesFolder.files where hotfixesNode.class = FileFolder do
			hotfix := hotfixesNode.name[hotfixesNode.name.pos('_', 1) + 1 : end];
			foreach patchNode in hotfixesNode.FileFolder.files where patchNode.class = FileFolder and patchNode.name &lt;&gt; JadeMaster_Folder and patchNode.name[1:3] &lt;&gt; release do
				patch := patchNode.name[1:3];
				par := patchNode.name[8:end];
				numPatches := numPatches + 1;
				create installFile transient;
				installFile.kind := File.Kind_Unknown_Text; // 3/3/16  cnwns1 PAR 36286 unicode version
				installFile.fileName := patchNode.fileName &amp; '\' &amp; JadeMaster_Folder &amp; '\' &amp; Install_File;
				installFile.mode := File.Mode_Input;
				installFile.open;
				while not installFile.endOfFile do
					cmdLine := installFile.readLine;
					if cmdLine[1:6] = Cmd_SchemaCheck then
						continue;
					elseif cmdLine[1:3] = Cmd_Schema then
						//pos := cmdLine.pos(release &amp; '_', 6); //pos sh'd be &gt; 0
						pos := cmdLine.pos('::', 1) + 2;
						tmpStr := cmdLine[pos : cmdLine.pos('::', pos) - pos];
						if tmpStr[1:10] = PortSchema then //appJadeScript will always be in portSchema file
							portSchemaFileName := tmpStr;
						endif;
					elseif cmdLine[1:7] = Cmd_RunJade then
						app.writeLogMessage('JadeScript for release/patch ' &amp; release &amp; '/' &amp; patch &amp; '    ' &amp; patchNode.fileName &amp; '\' &amp; JadeMaster_Folder &amp; '\' &amp; Schemas_Folder &amp; '\' &amp; portSchemaFileName &amp; '.scm');
						outputFile.writeLine(release &amp; Delimeter &amp; patch &amp; Delimeter &amp; par &amp; Delimeter &amp; hotfix &amp; Delimeter &amp; patchNode.fileName &amp; '\' &amp; JadeMaster_Folder &amp; '\' &amp; Schemas_Folder &amp; '\' &amp; portSchemaFileName &amp; '.scm');
						numScripts := numScripts + 1;
						//schema := cmdLine[10:cmdLine.pos('::', 10) - 10];
						/*create schemaFile transient;
						//schemaFile.fileName := patchNode.fileName &amp; '\' &amp; JadeMaster_Folder &amp; '\' &amp; Schemas_Folder &amp; '\' &amp; schema &amp; '_' &amp; release &amp; '_' &amp; patch &amp; '.scm';
						schemaFile.fileName := patchNode.fileName &amp; '\' &amp; JadeMaster_Folder &amp; '\' &amp; Schemas_Folder &amp; '\' &amp; portSchemaFileName;
						schemaFile.mode := File.Mode_Input;
						schemaFile.open;
						
						schemaFile.close;
						delete schemaFile;
						*/
					endif;
				endwhile;
				installFile.close;
				delete installFile;
			endforeach;
		endforeach;
	endforeach;
epilog
	return outputFile.fileName;
	delete hotfixesFolder;
	outputFile.close;
	delete outputFile;
	app.writeLogMessage('Number of Patches: ' &amp; numPatches.String);
	app.writeLogMessage('Number of Scripts: ' &amp; numScripts.String);
	app.writeLogMessage('Finish...');
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="load" id="cfdb4da8-d177-408b-ba12-08d0e8a3743f">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 August 2010	cnwmd1	Initial creation

*/
constants
	Base_Folder : String = 'F:\SETUP\';
vars
	fileNode : FileNode;
	//basefolder : FileFolder;
begin
	create myBaseFolder transient;
	myBaseFolder.usePresentationFileSystem := true;
	myBaseFolder.fileName := Base_Folder;
	
	foreach fileNode in myBaseFolder.files() do
		if fileNode.class = FileFolder and fileNode.name[1].isNumeric then
			lstHotfixes.itemObject[lstHotfixes.addItem(fileNode.name)] := fileNode;
		endif;
	endforeach;
	
	self.cmbType.addItem(self.Type_TableDef);
	self.cmbType.addItem(self.Type_Permissions);
	self.cmbType.addItem(self.Type_XLAT);
	self.cmbType.addItem(self.Type_Other);
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="populateControls" id="0d1ccb4d-fe81-4834-a36a-4e5338910e3a">
        <source>populateControls(_record : String);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 August 2010	cnwmd1	Initial creation

*/

constants
	Delim : String = ',';
vars
	pos : Integer;
begin
	pos := 1;
	txtRelease.text := _record.scanUntil(Delim, pos);
	pos := pos + 1;
	txtPatch.text := _record.scanUntil(Delim, pos);
	pos := pos + 1;
	txtPar.text := _record.scanUntil(Delim, pos);
	pos := pos + 1;
	txtHotfix.text := _record.scanUntil(Delim, pos);
	pos := pos + 1;
	txtInstallFile.text := _record.scanUntil(Delim, pos);
	txtOther.text := null;
epilog

end;</source>
        <Parameter name="_record" type="String"/>
    </JadeMethod>
    <JadeMethod name="unload" id="6ae13a9b-ed7b-46d6-87e3-1468a7eba44d">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 August 2010	cnwmd1	Initial creation

*/

vars

begin
	closeFiles;
	delete myBaseFolder;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="writeLine" id="6f0812b1-03c8-4510-986c-a573f2d1e800">
        <updating/>
        <source>writeLine(_ok : Boolean)updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 August 2010	cnwmd1	Initial creation

*/

vars
	comment : String;
	record : String;
begin
	if endProcessing then
		return;
	endif;
	comment := cmbType.text;
	if comment = self.Type_Other then
		comment := txtOther.text;
	endif;
	myOutputFile.writeLine(self.txtRelease.text &amp; ',' &amp; self.txtPatch.text &amp; ',' &amp; self.txtPar.text &amp; ',' &amp; self.txtHotfix.text &amp; ',' &amp; _ok.String &amp; ',' &amp; comment &amp; ',' &amp; txtInstallFile.text);
	
	if not myInputFile.endOfFile then
		record := myInputFile.readLine();
		populateControls(record);
	else
		self.endProcessing := true;
	endif;
epilog

end;</source>
        <Parameter name="_ok" type="Boolean"/>
    </JadeMethod>
</GUIClass>
