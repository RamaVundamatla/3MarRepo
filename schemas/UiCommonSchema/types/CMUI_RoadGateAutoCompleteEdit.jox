    <JadeMethod name="setFormData" id="691bb349-9643-4852-8771-942b5fb35c4b">
        <updating/>
        <source>setFormData() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
24th Jan 2024 	navra1  TFS 62081 - CUX | Auto-setdown of cargo that doesn't require a machine move
12 Jun 2024	jlier1  TFS 64018  

*/

vars
	currentCriteria : CM_RoadGateAutoComplete;
begin
	currentCriteria := self.myParentForm.CMUI_RoadGateAutoComplete.myCurrentCriteria;
	if currentCriteria &lt;&gt; null then
		self.txtDescr.text := currentCriteria.description;
		self.txtName.text := currentCriteria.name;		
		self.optTypeRelease.value:=currentCriteria.isRelease;
		self.optTypeReceive.value:=not currentCriteria.isRelease;
	endif;	
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setPreEditDetails" id="3426d9ec-b8eb-4ce7-af33-3c66e9cb189d">
        <updating/>
        <source>setPreEditDetails() updating;
/*

Purpose:			

