	self.doCmbTriggerOnActionBuild();
	beginClassNotification(CM_InvoiceDesc, false, Object_Create_Event, Response_Continuous, 0);
	
	self.frmTableFilter.setCallbackMethod(INV_InvoiceTypes::doFilterTable.name); //25/06/2024	navkc1 CR 64823 Task 64824
	
