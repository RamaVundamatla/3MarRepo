    <JadeMethod name="canDoEDIUpdateDelete" id="184f670b-aaff-4b49-8ff0-b603c876ae59">
        <source>canDoEDIUpdateDelete(realBulkRelease : CM_BulkRelease; _ediTI : CM_EDIRequestHeaderTI; _coparnRules : CM_EDIPartyCoparnRules;
					 _verifyOnly: Boolean; _passport : CM_Passport input) : Boolean protected;
//
//11 Dec 2015	cnwrs1	Par 37402 TFS 1192 MultiLine Release Request
// 25 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
//
vars
	isBlocked : Boolean;
	isDelete : Boolean;
	emailBlockedDelete : Boolean;
	emailBlockedUpdate : Boolean; 
	error : Integer;
	subject : String;
	emailFrom : String; 
	emailTo : String; 
	message : String;
begin 
	if not self.isCoparnFile(_ediTI.myEDIData) then													
		return true;																
	endif;																			
	
	if _ediTI.getIsToBeProcessed then 
		return true;
	endif;
	
	if _coparnRules &lt;&gt; null then
		emailBlockedDelete := _coparnRules.sendEmailForBlockedDel;					
		emailBlockedUpdate := _coparnRules.sendEmailForBlockedUpd;					
	endif;
	
	if _ediTI.messageMode = CM_EDITrackedItem.EDI_ACTION_DELETE then
		isBlocked := not realBulkRelease.canDoEDIDelete(_coparnRules, error);
		isDelete := true;
	else
		isBlocked := not realBulkRelease.canDoEDIUpdate(_coparnRules, error);
	endif;
	
	if isBlocked then
		if not _verifyOnly and
		   ((emailBlockedDelete and isDelete) or
		   (emailBlockedUpdate and not isDelete)) then
			emailTo := app.myRoot.getConfig(AutoSupportEmailAddress).String;
			emailFrom := app.myRoot.getConfig(AutoSendersEmailAddress).String;

			subject := app.getErrorString1(error, _ediTI.releaseRequestNumber);
						
			app.myTrxCA.trxCreateEmailSendRequest(app.getErrorString(BGP_Processing), emailTo, emailFrom, null, null, subject, message,
															null, null, null, null, EmailSource_System,  null, _passport);

			app.setContinueCMExceptions(true);
		endif;
		// record error for each edi tracked item 
		app.raiseCMException1(error, _ediTI.releaseRequestNumber, null, _ediTI);
					
		return false;
	endif;		
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="realBulkRelease" type="CM_BulkRelease"/>
        <Parameter name="_ediTI" type="CM_EDIRequestHeaderTI"/>
        <Parameter name="_coparnRules" type="CM_EDIPartyCoparnRules"/>
        <Parameter name="_verifyOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canGetStatusFromEDITrackedItem" id="5978e9f7-80b6-49ce-8a2a-ad29f307d7d9">
        <source>canGetStatusFromEDITrackedItem() : Boolean;
//
//11 Dec 2015	cnwrs1	Par 37402 TFS 1192 MultiLine Release Request
// 13 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
//
vars

begin
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="createWarningForReleaseByID" id="1383c04e-c6cb-4cf6-9caa-3a92bee5eb7a">
        <source>createWarningForReleaseByID(_ediHeaderTI : CM_EDIRequestHeaderTI; _ediDetailTI : CM_EDIRequestDetailTI) : Boolean;
//
// 08 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req

vars
	coparnRules : CM_EDIPartyCoparnRules;
	ediData : CM_EDIData;
begin	 
	if _ediHeaderTI.releaseByType then //cnwrd1 par 34035
		return false;
	endif;
	if _ediDetailTI.myEDIData = null then
		return false;
	endif;
	ediData := _ediDetailTI.myEDIData;
	if ediData.myEDIFile = null then
		return false;
	endif;
	if not ediData.myEDIFile.myEDIFileType.isKindOf(CM_EDIFileTypeCoparn) then
		return false;
	endif;
	
	coparnRules := ediData.getEDIPartyCoparnRules(_ediHeaderTI.senderCode);

	if coparnRules = null then
		return false;
	endif;
	return coparnRules.getRelByTypeOnly();
epilog

end;</source>
        <Parameter name="_ediHeaderTI" type="CM_EDIRequestHeaderTI"/>
        <Parameter name="_ediDetailTI" type="CM_EDIRequestDetailTI"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCallOffValidationTidyUp" id="fbe6782b-809e-49eb-86ad-83f9b3f9f728">
        <source>doCallOffValidationTidyUp(_verifyOnly : Boolean; _passport : CM_Passport io);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 18/07/2023	navdap1		Initial creation TFS 58923 EUP Calloff EDI Data Type / EDI Load
// 20 Jan 2025	navtr3		MTN 33750 MTN - EDI Unit Test Failure - Diameter &amp; Cargo Width renamed to include (cm) hardcoded
//
vars
	terminal : CM_Terminal;
	ediConfig : CM_EDIConfig;
	myEdiFile, ediFile, existingEDIFile, cancelledEDIFile : CM_EDIFile;
	iter : Iterator;
	messageMode : String;
	existingEDIData : CM_EDIData;
	requestNumber : String;
	workOrder : CM_WorkOrder;
	wleArray : CM_WLEArray;
	object : Object;
	bulkRelease : CM_BulkRelease;
	reserveDetail : CM_ReserveDetail;
	errorSet : CM_ErrorSet;
	
begin
	if self.myCallOffEDIData = null then
		return;
	endif;
	
	create errorSet transient;
	
	// Is there a previous CallOff EDI file with the same client ref as me?
	terminal :=	self.getMyTerminal();
	myEdiFile := self.myCallOffEDIData.myEDIFile;
	ediConfig := self.myCallOffEDIData.ediConfig;
	iter := ediConfig.allEDIFilesByEdiClientRef.createIterator;
	ediConfig.allEDIFilesByEdiClientRef.startKeyGeq(myEdiFile.ediClientRef, iter);
	while iter.next(ediFile) do
		if ediFile.ediClientRef &lt;&gt; myEdiFile.ediClientRef then
			continue;
		endif;
		
		// Ignore ourselves!
		if ediFile = myEdiFile then
			continue;
		endif;
		
		// Previous file has already been cancelled
		if ediFile.fileStatus = CM_EDIFile.EDI_STATUS_CANCELLED then
			cancelledEDIFile := ediFile;
			continue;
		endif;
		
		// Otherwise there can only be one EDI File in an "active" state
		existingEDIFile := ediFile;
		break;
	endwhile;
	
	// If this file is an Update, and there is a cancelled file, this is an error
	messageMode := self.myCallOffEDIData.statusString;
	if messageMode = CMIF_JsonHeaderEUP.Status_Replace and cancelledEDIFile &lt;&gt; null then
		app.raiseCMException1(CallOff_Previously_Cancelled, cancelledEDIFile.ediClientRef, null, null);
		return;
	endif;
	
	if existingEDIFile &lt;&gt; null then
		existingEDIData := existingEDIFile.ediData;
	endif;
	
	if existingEDIData &lt;&gt; null and existingEDIData.isKindOf(CM_EDIDataCallOff) and existingEDIData.CM_EDIDataCallOff.myRequestMultiLine &lt;&gt; null then //20.01.2025 navtr3 #MTN-33750
		foreach object in existingEDIData.CM_EDIDataCallOff.myRequestMultiLine.allEDITrackedItems do
			if object.isKindOf(CM_EDIRequestHeaderTI) then
				requestNumber := object.CM_EDIRequestHeaderTI.releaseRequestNumber;
				break;
			endif;
		endforeach;
		
		// Find a work order for the existing EDI data
		if requestNumber &lt;&gt; null then
			workOrder := terminal.allWorkOrders[requestNumber];
		endif;
	endif;
	
	// If an existing file has been DB Loaded, there are work order items with WLEs, and this file is a Create/Update, this is an error
	if existingEDIFile &lt;&gt; null 
	and existingEDIFile.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED 
	and messageMode.isOneOf(CMIF_JsonHeaderEUP.Status_Create, CMIF_JsonHeaderEUP.Status_Replace) then
		// is there an existing work order?
		if workOrder &lt;&gt; null then
			create wleArray transient;
			workOrder.getAllWLEs(wleArray);
			if not wleArray.isEmpty then
				app.raiseCMException1(CallOff_cannot_be_updated, existingEDIFile.ediClientRef, null, null);
				return;
			endif;
		endif;
	endif;
	
	if _verifyOnly then
		return;
	endif;
	
	// if there's an existing release request and work order, and this request is not a CANCEL
	//	1. delete release request
	//	2. delete work order
	if messageMode &lt;&gt; CMIF_JsonHeaderEUP.Status_Cancel then
		// find the release request
		if requestNumber &lt;&gt; null then
			bulkRelease := terminal.allBulkReleasesByCodeDate.getAtKeyGeq(requestNumber, null);
			if bulkRelease &lt;&gt; null and bulkRelease.code &lt;&gt; requestNumber then
				bulkRelease := null;
			endif;
			if bulkRelease &lt;&gt; null then
				// delete the request
				_passport.setWarningsIgnored(true);
				app.myTrxDA.trxDeleteBulkRelease(bulkRelease, _passport);
				if _passport.hasErrors() then
					_passport.moveErrorsToSet(errorSet);
				endif;
				_passport.setWarningsIgnored(false);
			endif;
		endif;
		
		// deal to the work order
		if workOrder &lt;&gt; null then
			_passport.setWarningsIgnored(true);
			app.myTrxDA.trxDeleteWorkOrder(workOrder, _passport);
			if _passport.hasErrors() then
				_passport.moveErrorsToSet(errorSet);
			endif;
			_passport.setWarningsIgnored(false);
		endif;
	endif;
	
epilog
	_passport.addErrorsFromSet(errorSet);
	delete errorSet;
	delete iter;
	delete wleArray;
end;</source>
        <Parameter name="_verifyOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doCompletedStatusReset" id="6087a5e3-4471-41bf-9679-6442e556b265">
        <source>doCompletedStatusReset(_proxy : CM_BulkRelease input) protected;
//
//11 Dec 2015	cnwrs1	Par 37402 TFS 1192 MultiLine Release Request
// 13 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
//
vars
	release	: CM_BulkRelease;
	reserve : CM_ReserveDetail;
	pxyReserve : CM_ReserveDetail;
	isNew : Boolean;
	ti : CM_TrackedItem;
begin
	// par 31185 - if they have added new items to a completed release we may need to reset the status to Active
	release := _proxy.pxyGetRealObject;

	if release = null or 
	   release.status &lt;&gt; BR_COMPLETE then
		return;
	endif;
	
	if _proxy.status = BR_ACTIVE then
		// already reset
		return;
	endif;
	
	if _proxy.getTotalRequested &gt; release.getTotalRequested then
		// total has increased we want to reset the status
		_proxy.setStatus(BR_ACTIVE, false, false);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_proxy" type="CM_BulkRelease" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUpdateProxyBulkRelease" id="b6273fa0-f53e-4b3a-89f2-4e9b74368aee">
        <source>doUpdateProxyBulkRelease(_proxy : CM_BulkRelease input; _ediTI : CM_EDIRequestHeaderTI; _defaultVoyage : CM_Voyage; _garbageColl : ObjectSet input) protected;
/* Changes

Date		Name	TFS#				Description
============================================================================
16/12/2015	cnwrs1	Par 37402 TFS 1192 	MultiLine Release Request
20/01/2016  cnwma1  PAR #37435 			[RELATED TO TFS1192] Cargo Subtype not updating while loading a Pack Request via EDI
08/11/2017	jlgrs1	TFS 5705  			SNO - EDIDataBooking Prenote release Req
12/12/2017	jlgrs1	TFS 8195 			SNO - EDI Release Comparison add support for ReleaseRequestMulti
18/04/2018	jlgrs1	TFS 8296 			add release req and prenotes to X12 301
27/06/2018	jlgrs1	TFS 38352 			SNO Invalid Consignor
10/07/2018	jlgrs1	TFS 38808 			JMT - Full and Partial loading not working correctly
24/01/2019	jlgka1	41708				As a result of the changes in the CM_BulkRelease.setProxy
										we also need to add myBOLIn here.
20/07/2023	navdap1	TFS 58923			EUP CallOff EDI Data Type / Data Load
09/10/2023	navdap1	TFS 58495			EUP | CallOff Processing - DB Load and Work Orders
27 Nov 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
23 Feb 2024	navlw1	Bug 62547 			EUP | String too long error in CallOff Carrier Party
============================================================================*/
vars
	root 					: CM_Root;
	terminal 				: CM_Terminal;
	realBulkRelease 		: CM_BulkRelease;
	operator 				: CM_Operator;
	booking					: CM_BookingRef;
	voyage 					: CM_Voyage;
	customsAgent 			: CM_CustomsAgent;
	ti, pxyTI 				: CM_TrackedItem;
	relTypeStr				: String;
	releaseType				: Integer;
	mtGradeArray 			: IntegerArray;
	allGradeCodes 			: HugeStringArray;
	availableGrade 			: Integer;
	gradeCode 				: String;
	dateRequested 			: TimeStamp;
	voyageCode 				: String;
	isInLoadState 			: Boolean;
	allEDIFiles				: CM_EDIFileArray;
	doPartial 				: Boolean;
	carrierId 				: String;
	subTerminal 			: CM_SubTerminal;
	deliveryReasonCode 		: Integer;
	statusBulkRelease 		: Integer;
	stopEDIUpdates 			: Boolean;
	allPackLocations 		: StringArray;
	transferToTerminal 		: CM_Terminal;
	estimatedRequiredDate 	: TimeStamp;
	bookingConfirmation 	: String;
	freightPayerCode 		: String;
	deliveryReleaseNumber 	: String;
	expiryTimeStamp 		: TimeStamp;	//13 Feb 2017	NDL	TFS 3368
	canBeHiLoCube 			: Boolean;
	ediTI 					: CM_EDITrackedItem;
	foundBooking 			: Boolean;
	bolIn					: CM_BOLIn; // jlgka1 TFS 41708
	consign : CM_ConsigneeConsignor;
begin 
	realBulkRelease := _proxy.pxyGetRealObject();
	root := app.myRoot;
	terminal := self.getMyTerminal();
	doPartial := terminal.getConfig(EdiReleaseAllowPartial).Boolean;
	
	if _ediTI.releaseRequestNumber = null then
		app.raiseCMException1(Input_required_field_Required, ETRow_ReleaseRequestNumber, ETRow_ReleaseRequestNumber, _ediTI);
		return;
	endif;
	
	// get voyage to use - the following method will validate voyage as well
	self.getVoyageForRelease(terminal, _ediTI, realBulkRelease, _defaultVoyage, voyage, voyageCode);

	//epr par 37090 23/10/15 CCMS 2538 EDI Admin Improvements
	if voyage &lt;&gt; null and voyage.hasDeparted  and  terminal.getConfig(EdiAddVoyageDepartError).Boolean then 
//		_skipProcessing:=true;
		app.raiseCMException1(Voyage_departed,voyage.code,"Voyage Code", _ediTI);
//		return;
	endif;
	// check voyage cutoffs if we have a valid voyage in the file.
	if voyage &lt;&gt; null and voyage &lt;&gt; _defaultVoyage then	
		// par 29402 check voyage cutoffs - only do this if the voyage in the file is valid
		_ediTI.myEDIData.checkEDICutoff(voyageCode, _ediTI.operatorCode, _ediTI);
	endif;
	
	estimatedRequiredDate := null;
	expiryTimeStamp := null;		//13 Feb 2017	NDL	TFS 3368
	if realBulkRelease &lt;&gt; null then	
		stopEDIUpdates	:= realBulkRelease.blockEDIUpdates;
		allPackLocations := realBulkRelease.allPackLocations;
		transferToTerminal := realBulkRelease.myTransferToTerminal;
		estimatedRequiredDate := realBulkRelease.dateEstimatedRequired;
		expiryTimeStamp := realBulkRelease.expiryTimeStamp;	//13 Feb 2017	NDL	TFS 3368
		bookingConfirmation := realBulkRelease.bookingConfirmation;
		freightPayerCode := realBulkRelease.freightPayerCode;
		deliveryReleaseNumber := realBulkRelease.deliveryReleaseNumber;
		canBeHiLoCube := realBulkRelease.canBeHiLoCube;
	endif;
	
	//13 Feb 2017	NDL	TFS 3368
	if _ediTI.expiryTimeStamp.Date.isValid then
		expiryTimeStamp := _ediTI.expiryTimeStamp;
	endif;
	
	if _ediTI.estimatedRequiredDate.Date.isValid then
		// they passed one in use that
		estimatedRequiredDate := _ediTI.estimatedRequiredDate;
	endif;
	
	if _ediTI.bookingConfirmation &lt;&gt; null then
		// they passed one in use that
		bookingConfirmation := _ediTI.bookingConfirmation;
	endif;
	if _ediTI.getCanBeHiLoCubeSet then
		canBeHiLoCube := _ediTI.canBeHiLoCube;
	endif;
	if _ediTI.getFreightPayerCode &lt;&gt; null then
		// they passed one in use that
		freightPayerCode := _ediTI.getFreightPayerCode;
	endif;
	if _ediTI.deliveryReleaseNumber &lt;&gt; null then
		// they passed one in use that
		deliveryReleaseNumber := _ediTI.deliveryReleaseNumber;
	endif;
	
	if _ediTI.usesDefaultValues() and realBulkRelease &lt;&gt; null then
		// default values are used for Coparn release requests when requests are added
		// we don't want to use these default values for updates in case the user has made their own changes
		statusBulkRelease := _proxy.status;
		releaseType := _proxy.type;
		carrierId := _proxy.carrierId;
		subTerminal := _proxy.mySubTerminal;
		deliveryReasonCode := _proxy.deliveryReasonCode;
		
		if _ediTI.requestDateDoUpdate then
			// there must have been a relevant DTM segemnt in the file
			dateRequested := _ediTI.requestDate;
		else
			// leave requested date as it was - there was nothing in the file :-(
			dateRequested := _proxy.dateRequested;
		endif;
		
		dateRequested := dateRequested.cnZeroSeconds();
	else
		statusBulkRelease := app.releaseStatusStringToEnum(_ediTI.statusBulkRelease.properCase);
		relTypeStr := _ediTI.releaseTypeStr;
		releaseType	:= app.releaseRequestTypeStringToEnum(relTypeStr);
		carrierId := _ediTI.carrierCode;
		if _ediTI.requestDate.isValid then
			dateRequested := _ediTI.requestDate;
			dateRequested := dateRequested.cnZeroSeconds();
		else
			dateRequested := null;
		endif;
		subTerminal := terminal.allSubTerminals[_ediTI.subTerminalCode];
		deliveryReasonCode := _ediTI.deliveryReason;
		
		// TFS 58923 default the release request status to active for CallOff
		if _ediTI.myEDIData &lt;&gt; null and _ediTI.myEDIData.isKindOf(CM_EDIDataRequestMultiLine) and _ediTI.myEDIData.CM_EDIDataRequestMultiLine.myEDIDataCallOff &lt;&gt; null then
			// TFS 58495 Except for Unknown, which needs to be Pending
			if releaseType = BR_TYPE_UNKNOWN then
				statusBulkRelease := BR_PENDING;
			else
				statusBulkRelease := BR_ACTIVE;
			endif;
		endif;
		// TFS 58923 end of this bit
	endif;
	if not dateRequested.isValid then
		dateRequested := null;
	endif;
	// Check that EDI Date statusBulkRelease is valid option
	if statusBulkRelease = BR_NOTSET then
		app.raiseCMException1(ERR_INVALID_StatusBulkRelease, _ediTI.statusBulkRelease.properCase(), ETRow_StatusBulkRelease, _ediTI);
	endif;
	
	if releaseType = BR_TYPE_INVALID then
		app.raiseCMException1(Invalid_Release_Request_Type, _ediTI.releaseTypeStr.display, ETRow_ReleaseType, _ediTI);
	endif;
	
	// Any port code supplied must be a valid port code
	if _ediTI.loadPort &lt;&gt; null and root.allPorts[_ediTI.loadPort] = null then
		app.raiseCMException1(ERR_INVALID_LOAD_PORT, _ediTI.loadPort, ETRow_LoadPort, _ediTI);
	endif;
	
	if _ediTI.dischargePort &lt;&gt; null and root.allPorts[_ediTI.dischargePort] = null then
		app.raiseCMException1(ERR_INVALID_DIS_PORT, _ediTI.dischargePort, ETRow_DischargePort, _ediTI);
	endif;
	
	if _ediTI.destinationPort &lt;&gt; null and root.allPorts[_ediTI.destinationPort] = null then
		if doPartial then
			app.raiseCMWarning1(ERR_INVALID_DEST_PORT, _ediTI.destinationPort, ETRow_DestinationPort, _ediTI, null);
		else
			app.raiseCMException1(ERR_INVALID_DEST_PORT, _ediTI.destinationPort, ETRow_DestinationPort, _ediTI);
		endif;
	endif;
	
	if _ediTI.businessUnit &lt;&gt; null and terminal.companies[_ediTI.businessUnit] = null then
		app.raiseCMException(ERR_INVALID_BUSINESS_UNIT, ETRow_BusinessUnit, _ediTI);
	endif;
	
	if _ediTI.destTerminal &lt;&gt; null and root.allTerminals[_ediTI.destTerminal] = null then
		app.raiseCMException1(Err_InvalidTerminal, _ediTI.destTerminal, ETRow_DestTerminal, _ediTI);
	elseif _ediTI.destTerminal &lt;&gt; null then	//22 Nov 2013	NDL	Par 32057	
		// they passed one in use that
		transferToTerminal := root.allTerminals[_ediTI.destTerminal];
	endif;
	
	if _ediTI.operatorCode &lt;&gt; null then
		operator := root.allOperators[_ediTI.operatorCode];
		
		if operator = null then
			app.raiseCMException1(ERR_INVALID_OPERATOR, _ediTI.operatorCode, ETRow_Operator, _ediTI);
		endif;
	endif;
	if _ediTI.operatorGroup &lt;&gt; null and app.myRoot.allOperatorGroups[_ediTI.operatorGroup] = null then
		app.raiseCMException1(ERR_INVALID_OPERATOR_GROUP, _ediTI.operatorGroup, ETRow_OperatorGroup, _ediTI);
	endif;
	
	if _ediTI.carrierCode &lt;&gt; null and root.allCarriers[_ediTI.carrierCode] = null then
		// #62547 navlw1 set carrierId back to empty if we hit an error otherwise continues and causes 1035
		carrierId := null;
		app.raiseCMException1(ERR_Carrier_Unknown, _ediTI.carrierCode, ETRow_Carrier, _ediTI);
	endif;
	
	if _ediTI.consignor &lt;&gt; null and root.allConsigneeConsignors[_ediTI.consignor] = null then
		if self.getMyTerminal.getConfig(EdiGateDocInvConsignor).Boolean then
			app.raiseCMException2(ERR_FIELD_CONSIGNOR, _ediTI.consignor, 'consignor', ETRow_Consignor, _ediTI);
		else
			app.raiseCMWarning2(ERR_FIELD_CONSIGNOR, _ediTI.consignor, 'consignor', ETRow_Consignor, _ediTI, _ediTI.myEDIData);
		endif;
	endif;
	
	//07 Sep 2021	NDL	TFS 51928
	if _ediTI.consignee &lt;&gt; null then
		consign := app.myRoot.allConsigneeConsignors.getAtKey( _ediTI.consignee );
		if consign &lt;&gt; null then
			_ediTI.verifyObjectAvailableForEntry( consign );
		endif;
	endif;
	//07 Sep 2021	NDL	TFS 51928
	if _ediTI.consignor &lt;&gt; null then
		consign := app.myRoot.allConsigneeConsignors.getAtKey( _ediTI.consignor );
		if consign &lt;&gt; null then
			_ediTI.verifyObjectAvailableForEntry( consign );
		endif;
	endif;
	
	if _ediTI.freightForwarder &lt;&gt; null and root.allConsigneeConsignors[_ediTI.freightForwarder] = null then
		app.raiseCMException1(ERR_INVALID_FreightForwarder, _ediTI.freightForwarder, ETRow_FreightForwarder, _ediTI);
	endif;
		
	if _ediTI.bookingRef &lt;&gt; null then
		// If the bookingRef is entered then, the operator and voyage must also be entered (and valid).
		if operator = null or voyage = null then
			app.raiseCMException3(	Booking_Requires_Oper_Voyage,
									_ediTI.bookingRef,
									_ediTI.operatorCode,
									voyageCode, 	// par 29402 May 2012
									ETRow_BookingRef,
									_ediTI);
		else
			booking	:= terminal.getBookingReference(operator.code, _ediTI.bookingRef, voyage);
			if booking = null then
				// lets see if we are also adding the booking
				foreach ediTI in _ediTI.myEDIData.allEDITrackedItems do
					if ediTI.isKindOf(CM_EDIBookingHeaderTI) and
					   ediTI.getOperatorCode = _ediTI.operatorCode and
					   ediTI.getVoyageCode = voyageCode and
					   ediTI.id = _ediTI.bookingRef then
						foundBooking := true;
					endif;
				endforeach;
				if not foundBooking then
				app.raiseCMException3(	Booking_DoesNotExist4_OpVoyage,
										_ediTI.bookingRef,
										_ediTI.operatorCode,
										voyageCode, 	// par 29402 May 2012
										ETRow_BookingRef,
										_ediTI);
				endif;
			endif;
		endif;
	endif;
	
	if _ediTI.customsAgent &lt;&gt; null then
		customsAgent := root.allCustomsAgents[_ediTI.customsAgent];
		
		if customsAgent = null then
			app.raiseCMException2(ERR_EDI_BR_FIELD, _ediTI.customsAgent, ETRow_CustomsAgent, ETRow_CustomsAgent, _ediTI);
		endif;
	endif;
	//jlgka1 TFS 41708 --&gt;
	if not _ediTI.releaseByType then
		bolIn := _proxy.myBOLIn;
	endif;
	//jlgka1 TFS 41708 &lt;--
	
	// TFS 58923 validate the VBS slot type and truck reg number
	if _ediTI.vbsSlotType &lt;&gt; null and terminal.allTerminalVBSSlotTypes[_ediTI.vbsSlotType] = null then
		app.raiseCMException1(VBS_type_invalid, _ediTI.vbsSlotType, null, null);
	endif;
	if _ediTI.regNumber &lt;&gt; null and terminal.vehicles[_ediTI.regNumber, null] = null then
		app.raiseCMException2(ERR_Truck_Unknown, _ediTI.regNumber, null, null, null);
	endif;
	// TFS 58923 end
	
	create allEDIFiles transient;
	self.ediFileArray.copy(allEDIFiles);	//07/11/2011	cnwrs1	CCMS POL 2122 / PAR 28696 - new property allEDIFiles

	// Finally, we can updarte the proxy Bulk Release.
	
	_proxy.setProxy(	_ediTI.releaseRequestNumber,
						releaseType,
						_ediTI.releaseByType,
						statusBulkRelease,
						mtGradeArray,
//						_proxy.bookingConfirmation, //bookingConfirmation 
						bookingConfirmation,
						carrierId,
						_ediTI.remarks,
						_ediTI.consignee[1:5],
						null,	//consigneeDesc	
						_ediTI.consignor[1:5],
						null,	//consignorDesc
						null, //rs _ediTI.getConsignorVoyage(),
						dateRequested,
						//_ediTI.estimatedRequiredDate,
						estimatedRequiredDate,
						deliveryReasonCode,	//deliveryReasonCode
						app.deliveryReasonEnumToString(deliveryReasonCode),
						//_ediTI.deliveryReleaseNumber,
						deliveryReleaseNumber,
						_proxy.doorsDirection,
						//_ediTI.getFreightPayerCode,
						freightPayerCode,
						booking,
						root.allPorts[_ediTI.loadPort],
						root.allPorts[_ediTI.destinationPort],
						root.allPorts[_ediTI.dischargePort],
						//_ediTI.freightForwarder,
						_ediTI.freightForwarder[1:5],
						//root.allTerminals[_ediTI.destTerminal],
						transferToTerminal,
						terminal,
						app.myRoot.allOperators[_ediTI.operatorCode],
						app.myRoot.allOperatorGroups[_ediTI.operatorGroup],
						voyage,
						terminal.companies[_ediTI.businessUnit],
// TFS 2686						_ediTI.removeStops,
						//null, //rs (not _ediTI.mtRelease), // cnwma1 20/01/2015 37435
						(not _ediTI.mtRelease), 			 // cnwma1 20/01/2015 37435
						//_proxy.allPackLocations,	
						allPackLocations,
						_proxy.myPoolPartner,
						_proxy.dispatchLocation,
						subTerminal,
						_proxy.mySubTerminalTarget,
						_proxy.myAssignedTrain,
						_ediTI.allowCargoMultiReleases,
						_ediTI.customsAgent,
						_ediTI.customsAssistance,
						canBeHiLoCube,
						_proxy.needsReview,	// needsReview	// needs to be set later for CCMS POL 2122
						stopEDIUpdates,
						allEDIFiles,
						expiryTimeStamp,	//13 Feb 2017	NDL	TFS 3368
						bolIn,				//jlgka1 TFS 41708
						_ediTI.context		// ### TFS 53953 27June2022 NAVPW1
						);
						
	_proxy.setRemarksAdditionals(	_ediTI.remarksAdditional1,	//_remAdd1 : String;
									_ediTI.remarksAdditional2	//_remAdd2 : String
									);
								
//rs	_proxy.setPropertyValue(CM_BulkRelease::totalRequested.name, _ediTI.quantity);
epilog
	delete mtGradeArray;
	delete allGradeCodes;
	delete allEDIFiles;
	app.cmsEndLoad(isInLoadState);
end;</source>
        <access>protected</access>
        <Parameter name="_proxy" type="CM_BulkRelease" usage="input"/>
        <Parameter name="_ediTI" type="CM_EDIRequestHeaderTI"/>
        <Parameter name="_defaultVoyage" type="CM_Voyage"/>
        <Parameter name="_garbageColl" type="ObjectSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUpdateProxyReserve" id="f2cfdb0d-e5db-45ae-91e9-07aed887af35">
        <source>doUpdateProxyReserve(	_bulkRelease : CM_BulkRelease input; 
						_pxyReserve : CM_ReserveDetail; 
						_ediHeaderTI : CM_EDIRequestHeaderTI; 
						_ediDetailTI : CM_EDIRequestDetailTI; 
						_garbageColl : ObjectSet input;
						_verifyOnly : Boolean	) : CM_ReserveDetail protected;		// TFS 58923 new parameter
/* Changes

Date		Name	TFS#			Description
============================================================================
16/12/2015	cnwrs1	Par 37402 TFS 1192 MultiLine Release Request
21/01/2015  cnwma1  PAR 37435 [RELATED TO TFS1192] Cargo Subtype not updating while loading a Pack Request via EDI
26/01/2016	cnwrs1	Par37456 move ID from header to detail
28/01/2016  cnwma1  PAR37438 [RELATED TO TFS1192] Error 70092 while loading EDI Release Request by Type
08/11/2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
24/01/2019	jlgka1	41708	As a result of the changes in the CM_ReseverTI.setProxy
							we also need to add two new attributes here.
21/06/2021	navdap1	TFS 51386 MTN Release request by type using EDI - don't set weightSelection, do set weightRequested
25/01/2022  jlika1	TFS 52472	  MSL - Best Pick field for EDI Release Request
14 Jun 2022 jlier1	TFS 53678
27 Jun 2022 navpw1  TFS 53953 EUP - EDI - Cargo Group Reservation via EDI
19 Jul 2022	navtnr20	ChangeRequest 53974: EUP - OUT - Additional Fields on Release Line Level
09 Aug 2022	jlizm1	TFS 54067 Additional Fields on Release Line Level EDI
28 June 2023 navmv20 CR 58410 Task 58411: UI - Cargo Review - Release Request
18 Jul 2023	navdap1	TFS 58923 EUP Calloff EDI Data Type / EDI Load
28 Aug 2023	navdap1	TFS 60115 EUP FR CallOff
30 Aug 2023	navdap1	TFS 60150 EUP | FR 53824 - Road Manifest IMPORT cargo
27 Oct 2023 navlw1	TFS 60874 MTN | Jade Upgrade - Unit Test Review
6/12/2023	navcs2	ChangeRequest 57537: EUP | Release Request By Type - with Weight
15 Jan 2024	jlirs1	TFS 61640 EUP Release Request by Type by Weight
19 Jun 2024 navsaa30 ChangeRequest 64127: EUP | FR 54084 - Itemized CallOff - Release Request by Type
26 Jul 2024	navdap1	TFS 65400 EUP | CallOff - Error 1300 - Array index out of bounds
04/11/2024  navcs2	MTN-33310 EUP | FR 53598 (32792) - Cargo Group Reservation via EDI - FR issue
// 02/12/2024	navcs2		MTN-33047 EUP - NTO-1000 - EUP - Additional Data Fields in EDI Operations
13 Jan 2025	navhl20 CR MTN-33695: TPT | Release Request Delivery Party Info for Unique IDs
10 Feb 2025	navhl20 Defect MTN-34036: MTN - Delivery Instructions and From/To date/time not set on the release request from the EDI file
============================================================================*/
vars
	root 						: CM_Root;
	terminal 					: CM_Terminal;
	pxyReserve 					: CM_ReserveDetail;
	ti 							: CM_TrackedItem;
	cargoType 					: CM_CargoType;
	product 					: CM_Product;
	operator 					: CM_Operator;
	voyage 						: CM_Voyage;
	bol							: CM_BOLIn;
	mtGradeArray 				: IntegerArray;
	maskArray 					: StringArray;
	maskString, 
	voyageCode,mask,id			: String;
	isNew 						: Boolean;
	quantity 					: Integer;
	isoType 					: CM_ISOType;
	isInLoadState 				: Boolean;
	allEDITiRequestCriterias 	: ObjectSet;
	obj 						: Object;
	releaseCriteria 			: CM_ReleaseByTypeCriteria;
	reservePackType,idx 		: Integer;
	reserveCargoType 			: CM_CargoType;
	reserveProduct 				: CM_Product;
	isPackingRequest 			: Boolean;
	resDetActions 				: CM_ReserveDetailActions;
	stopsToApply 				: ObjectSet;
	allEDITiTaskRemarks 		: ObjectSet;
	realBulkRelease 			: CM_ReserveDetail;
	markSelection 				: String;
	bestPick					: Boolean;
	deliveryParty				: CM_DeliveryParty; // ### TFS 53953 27June2022 NAVPW1
	deliveryPartyCode,
	deliveryPartyName			: String;			// ### TFS 53953 27June2022 NAVPW1
	deliveryAddress				: CM_Address;		// ### TFS 53953 27June2022 NAVPW1
	terminals					: CM_TerminalSet;			// TFS 58923
	pxyDeliveryParty			: CM_DeliveryParty;			// TFS 58923
	pxyDeliveryAddress			: CM_Address;				// TFS 58923
	deliveryAddressCode			: String;					// TFS 58923
	instructionType				: CM_InstructionType;		// TFS 58923
	pxyInstructions				: CM_InstructionsIssued;	// TFS 58923
	cargoGroup					: CM_CargoGroup;			// TFS 58923
	
begin
	root := app.myRoot;
	terminal := self.getMyTerminal();
	pxyReserve := _pxyReserve;
	isNew := pxyReserve = null;
	isPackingRequest := _ediHeaderTI.releaseTypeStr = BR_TYPE_PACKING_STR;
//	realBulkRelease := pxyReserve.pxyGetRealObject();
	
	if not _ediHeaderTI.releaseByType then
		//if _ediDetailTI.id = null or _ediHeaderTI.cargoType = null then  // 28/01/2015 cnwma1 PAR #37438
		if _ediDetailTI.id = null or _ediDetailTI.cargoType = null then    // 28/01/2015 cnwma1 PAR #37438
			app.raiseCMException2(ReleaseByID_RequiresMoreInform, _ediDetailTI.releaseRequestNumber, _ediDetailTI.releaseRequestNumber, ETRow_Id, _ediDetailTI);
			return null;
		else
		if self.createWarningForReleaseByID(_ediHeaderTI, _ediDetailTI) then
//			_skipProcessing := true;
			app.raiseCMException(Operat_coparn_party_rule_relea, null, _ediHeaderTI);			//cnwmc5 - 26 May 2014 - PAR 34164
			return null;
		endif;
			//ti := terminal.lookupTrackedItem(_ediDetailTI.id, _ediHeaderTI.cargoType, TI_STATE_UNDEFINED, null, false);  // 28/01/2015 cnwma1 PAR #37438
			ti := validateTI(_ediDetailTI.id,terminal,_ediHeaderTI,_ediDetailTI,_bulkRelease);     //19/6/24  navsaa30  #64127
			if ti = null then 
				return null;
			endif;
			// 3.8.2017 cnwma1 TFS #5209
			if ti &lt;&gt; null and ti.myConsignee &lt;&gt; null  then
				if ti.myConsignee.isRestricted then
//					_skipProcessing := true;
					app.raiseCMException1(ERR_TI_CONSIGNEE_RESTRICTED, ti.id ,null ,_ediHeaderTI);
					return null;
				endif;
			endif;

		// If the cargo id is already a proxy item then we are attempting to release it twice.  Need to check if the release allows for cargo to be on more than one release.
			validateProxyTI(ti,_ediHeaderTI,_ediDetailTI,_bulkRelease,_garbageColl,isInLoadState);	//19/6/24  navsaa30  #64127
			
			
		endif;
	endif;

	if isNew then
		if _ediHeaderTI.releaseByType then
			create pxyReserve as CM_ReserveSelection transient;
		else
			create pxyReserve as CM_ReserveTI transient;
		endif;
	endif;
	
	//cargoType := root.getCargoTypeForID(_ediHeaderTI.cargoType);  // 28/01/2015 cnwma1 PAR #37438
	  cargoType := root.getCargoTypeForID(_ediDetailTI.cargoType);  // 28/01/2015 cnwma1 PAR #37438
	if _ediHeaderTI.releaseByType then
		
		//if cargoType = null then - NDL 07 Jan 2016 Packing Bulk Release doesn't need a cargo type, only the parent and children do
		//if cargoType = null and ( _ediHeaderTI.cargoType &lt;&gt; 0 or not isPackingRequest ) then	// 28/01/2015 cnwma1 PAR #37438
		if cargoType = null and ( _ediDetailTI.cargoType &lt;&gt; 0 or not isPackingRequest ) then	// 28/01/2015 cnwma1 PAR #37438
			if _ediDetailTI.cargoGroupId = null then	// TFS 58923
				app.raiseCMException(ERR_INVALID_TI_TYPE, ETRow_CargoTypeDesc, _ediDetailTI);	// 28/01/2015 cnwma1 PAR #37438
			endif;										// TFS 58923
		endif;
		
		if cargoType &lt;&gt; null then	//NDL 07 Jan 2016
			//if _ediHeaderTI.cargoType = TI_CargoType_BreakBulk or cargoType.isUserDefinedAndHandledAs(ProductType_BreakBulk) or cargoType.isUserDefinedAndHandledAs(ProductType_PieceBreakBulk) then // 28/01/2015 cnwma1 PAR #37438
			if _ediDetailTI.cargoType = TI_CargoType_BreakBulk or cargoType.isUserDefinedAndHandledAs(ProductType_BreakBulk) or cargoType.isUserDefinedAndHandledAs(ProductType_PieceBreakBulk) then   // 28/01/2015 cnwma1 PAR #37438
				if cargoType.isSubCargoTypeRequired then
				
					//product	:= cargoType.allProducts[_ediHeaderTI.operatorCode, _ediHeaderTI.cargoSubType]; // 28/01/2015 cnwma1 PAR #37438
					product	:= cargoType.allProducts[_ediHeaderTI.operatorCode, _ediDetailTI.cargoSubType];
					if product = null then													//21/01/2015 cnwma1 PAR #37435 
						//product	:= cargoType.allProducts[null, _ediHeaderTI.cargoSubType];   //21/01/2015 cnwma1 PAR #37435  // 28/01/2015 cnwma1 PAR #37438
						product	:= cargoType.allProducts[null, _ediDetailTI.cargoSubType];   //21/01/2015 cnwma1 PAR #37435     // 28/01/2015 cnwma1 PAR #37438
					endif;
					
					if product = null then
						//app.raiseCMException2(Cargo_SubType_Not_Found_CType, _ediHeaderTI.cargoSubType, _ediHeaderTI.cargoTypeDescr, ETRow_CargoSubType, _ediHeaderTI);  // 28/01/2015 cnwma1 PAR #37438
						app.raiseCMException2(Cargo_SubType_Not_Found_CType, _ediDetailTI.cargoSubType, _ediDetailTI.cargoTypeDescr, ETRow_CargoSubType, _ediDetailTI);   // 28/01/2015 cnwma1 PAR #37438
						return null;
					elseif product.myOperator &lt;&gt; null and product.myOperator.code &lt;&gt; _ediHeaderTI.operatorCode then		//26 Mar	NDL	TFS 37539
						app.raiseCMException2(	Cargo_subtyp_not_valid_operat,
												_ediDetailTI.cargoSubType,
												_ediHeaderTI.operatorCode,
												ETRow_CargoSubType,
												_ediDetailTI);	
						return null;
					endif;
				endif;
			endif;
		endif;
		
		// TFS 58923 validate cargo group id if we have one
		if _ediDetailTI.cargoGroupId &lt;&gt; null then
			cargoGroup := terminal.getCargoGroupItem(_ediDetailTI.cargoGroupId);
			if cargoGroup = null or cargoGroup.id &lt;&gt; _ediDetailTI.cargoGroupId then
				//app.raiseCMException1(Cargo_group_not_found, _ediDetailTI.cargoGroupId, null, null);	// TFS 60115
				//return null;																			// TFS 60115
			endif;
		endif;
		// TFS 58923 end of this bit
		
		bestPick :=  _ediDetailTI.bestPick;
	endif;
	
	if _ediDetailTI.isoType &lt;&gt; null and root.allISOTypes[_ediDetailTI.isoType] = null then
		app.raiseCMException2(ERR_ISOTYPE_FIELD, _ediDetailTI.isoType, app.getString(ISO_Type), ETRow_IsoType, _ediDetailTI);
	endif;
	
	if _ediDetailTI.isoTypeGroup &lt;&gt; null and root.allISOTypeGroups[_ediDetailTI.isoTypeGroup] = null then
		app.raiseCMException2(ERR_ISOTYPE_FIELD, _ediDetailTI.isoTypeGroup, app.getString(ISO_Group), ETRow_IsoTypeGroup, _ediDetailTI);
	endif;
	
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;_ediDetailTI.availabilityGrades&amp;' '&amp;_ediHeaderTI.usesDefaultValues().String&amp;' '&amp;realBulkRelease.String;
	if _ediHeaderTI.usesDefaultValues() and realBulkRelease &lt;&gt; null then
	else
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;_ediDetailTI.availabilityGrades;
	create mtGradeArray transient;
	_ediDetailTI.getAllAvailabilityGrades(mtGradeArray);
	endif;
	create maskArray transient;
	
	if not _ediHeaderTI.releaseByType or (_ediHeaderTI.releaseByType and self.myCallOffEDIData &lt;&gt; null and _ediDetailTI.ids &lt;&gt; null) then		//19/6/24  navsaa30  64127
		// For the Ids (aka ID Masks) because these id masks are comma seperated the user must include
		// them in quotes of some kind so need to remove any left over single or double quotes here.
		maskString := _ediDetailTI.ids.trimBlanks();
		maskString := maskString.replaceString(SingleQuote, null);
		maskString := maskString.replaceString(DoubleQuote, null);
		
		maskString.convertToDelimitedArray(",", maskArray);
	endif;
	
	if _ediHeaderTI.releaseByType and self.myCallOffEDIData &lt;&gt; null then 		//19/6/24  navsaa30 #64127
		foreach mask in maskArray do
			ti := validateTI(mask,terminal,_ediHeaderTI,_ediDetailTI,_bulkRelease);
			if ti = null then
				return null;
			endif;
			self.validateProxyTI(ti,_ediHeaderTI,_ediDetailTI,_bulkRelease,_garbageColl,isInLoadState);
		endforeach;
	endif;
	operator := root.allOperators[_ediHeaderTI.operatorCode];
		
	if _ediDetailTI.billOfLading &lt;&gt; null then
		voyageCode := _ediHeaderTI.getVoyageCode();
		voyage := terminal.allVoyagesByCode.getAtKeyGeq(voyageCode, null);
		
		// If attempting to do a release by type and including a billOfLading then it must exist on this voyage.
		if voyage = null then
			app.raiseCMException2(Voyage_DoesNotExist_4_Terminal, _ediHeaderTI.getVoyageCode().trimBlanks(), terminal.code, ETRow_VoyageCode, _ediHeaderTI);
		else
			bol := voyage.doesBOLAlreadyExist(_ediDetailTI.billOfLading);
			
			if bol = null then
				app.raiseCMException2(BOL_not_found_voyage, _ediDetailTI.billOfLading, _ediHeaderTI.getVoyageCode(), ETRow_BillOfLading, _ediHeaderTI);
				return null;
			endif;
		endif;
	endif;
	
	//08 Jan 2015	NDl	Par 37288
	reservePackType := CM_ReserveDetail.PackType_Parent;
	if _ediDetailTI.isChild then
		reservePackType := CM_ReserveDetail.PackType_Child;
	endif;
	
	if _ediHeaderTI.releaseByType then
		if _ediHeaderTI.usesDefaultValues() and not isNew then	//15 Mar 2012 cnwrs1	Par29264
			isoType := _pxyReserve.CM_ReserveSelection.myISOType;
		else 
			isoType := root.allISOTypes[_ediDetailTI.isoType];
		endif;
		
		//08 Jan 2015	NDL	Par 37228
		reserveCargoType := root.getCargoTypeForID(_ediDetailTI.cargoType);
		if not isPackingRequest and reserveCargoType = null then
				reserveCargoType := cargoType;
		endif;
		if reserveCargoType &lt;&gt; null then
			reserveProduct	:= reserveCargoType.allProducts[_ediHeaderTI.operatorCode, _ediDetailTI.cargoSubType];
			if reserveProduct = null then														    //21/01/2015 cnwma1 PAR #37435 
				reserveProduct	:= reserveCargoType.allProducts[null, _ediDetailTI.cargoSubType];   // 21/10/2015 cnwma1 PAR #37435 
			endif;
		endif;
		
		// ### TFS 53953 27June2022 NAVPW1
		deliveryPartyCode 	:= _ediDetailTI.deliveryPartyCode;
		deliveryPartyName	:= _ediDetailTI.deliveryPartyName;
		
		if deliveryPartyCode &lt;&gt; null then
			deliveryParty := app.myRoot.allDeliveryParties[deliveryPartyCode];
		elseif deliveryPartyCode = null and deliveryPartyName &lt;&gt; null then
			deliveryParty := app.myRoot.allDeliveryParties.getDeliveryPartyByName(deliveryPartyName);
		endif;
		
		if deliveryParty &lt;&gt; null then
			deliveryAddress := deliveryParty.allAddresses[_ediDetailTI.deliveryAddressCode];
			if deliveryAddress = null then														// TFS 58923
				deliveryAddress := deliveryParty.allAddresses[_ediDetailTI.deliveryPartyCode];	// TFS 58923
			endif;																				// TFS 58923
		endif;
		// ### TFS 53953 27June2022 NAVPW1
		// TFS 58923 Create delivery party if not found, use address from call off message
		if deliveryParty = null and not _verifyOnly and _ediDetailTI.deliveryPartyCode &lt;&gt; null then
			create pxyDeliveryParty transient;
			create terminals transient;
			terminals.add(terminal);
			pxyDeliveryParty.setProxy(_ediDetailTI.deliveryPartyCode, _ediDetailTI.deliveryPartyName, false, terminals);
			create pxyDeliveryAddress transient;
			deliveryAddressCode := _ediDetailTI.deliveryAddressCode;
			if deliveryAddressCode = null then
				deliveryAddressCode := _ediDetailTI.deliveryPartyCode;
			endif;
			pxyDeliveryAddress.setProxy(deliveryAddressCode, _ediDetailTI.deliveryPartyName, _ediDetailTI.addressStreet1, _ediDetailTI.addressStreet1, null, _ediDetailTI.addressCounty, _ediDetailTI.addressPostCode, _ediDetailTI.addressCountryCode, _ediDetailTI.addressCity, null, null, true, false, null);
			pxyDeliveryParty.allAddresses.add(pxyDeliveryAddress);
			app.myTrxCA.trxCreateDeliveryParty(pxyDeliveryParty, deliveryParty, app.myPassport);
			if deliveryParty &lt;&gt; null then
				deliveryAddress := deliveryParty.allAddresses[deliveryAddressCode];
			endif;
		endif;
		// TFS 58923 end
		
		markSelection := _ediDetailTI.mark;	//29 Aug 2019	NDL	TFS 46118
		
		pxyReserve.CM_ReserveSelection.setProxy(	reservePackType,	//_packType 		: Integer;
													reserveCargoType,	//_cargoType 		: CM_CargoType;
													null,	//_bookRefItemObj	: CM_BookingRefItem;
													isoType,	//_isoType 		: CM_ISOType;
													root.allISOTypeGroups[_ediDetailTI.isoTypeGroup],	//_isoGroup		: CM_ISOTypeGroup;
													reserveProduct,	//_product 		: CM_Product;
													null,	//_productStr,
													_ediDetailTI.remarks,	//_remarks		: String;
													_ediDetailTI.quantity,	//_totalRequested : Integer;
													mtGradeArray,	//_allAvailGrades : IntegerArray;
													_ediDetailTI.clean,	//_clean,
													null,	//_doISOGroupCheck,
													_ediDetailTI.heavyDuty,	//_heavyRated 	: Boolean;
													maskArray,	//_maskIds 		: StringArray;
													_ediDetailTI.quantity,	//_maxToRelease : Integer;
													_ediDetailTI.colour,	//_color			: String;					04/11/2024  navcs2	MTN-33310
													_ediDetailTI.description,	//_descriptionSelection : String;
													0,	//_heightSelection : Decimal;
													0,	//_lengthSelection : Decimal;
													_ediDetailTI.markNumber,	//_markNumber : String;						04/11/2024  navcs2	MTN-33310
													_ediDetailTI.quantityPieces,	//_quantitySelection : Integer;			// 02/12/2024	navcs2		MTN-33047
													null,	//_remarksSelection : String;
													//_ediDetailTI.volume,	//_volumeSelection : Decimal;	//08 Jan 2015	NDL	Par 37228	// TFS 51386
													//_ediDetailTI.weight,	//_weightSelection : Decimal;	//08 Jan 2015	NDL	Par 37228	// TFS 51386
													0,	//_volumeSelection : Decimal;	//08 Jan 2015	NDL	Par 37228						// TFS 51386
													0,	//_weightSelection : Decimal;	//08 Jan 2015	NDL	Par 37228						// TFS 51386
													0,	//_widthSelection : Decimal;
													markSelection,	//_markSelection : String;
													0,	//_densitySelection : Integer;
													null,	//_typeSelection : String; 
													null,	//_allTermAreaDict : CM_TAByIdDict;
													bol,	//_myReceivalBOL	:CM_BOLIn;
													bestPick,	//_bestPick	:Boolean;
													_ediDetailTI.sequence,	//_sequence : String
													deliveryParty, 	//deliveryParty : CM_DeliveryParty						// ### TFS 53953 27June2022 NAVPW1
													deliveryAddress,	//deliveryAddress : CM_Address						// ### TFS 53953 27June2022 NAVPW1
													_ediDetailTI.deliveryInstructions,	//deliveryInstructions : String		// ### TFS 53953 27June2022 NAVPW1
													_ediDetailTI.deliveryFrom,	//deliveryFromDT : TimeStamp				// ### TFS 53953 27June2022 NAVPW1
													_ediDetailTI.deliveryTo,	//deliveryToDT : TimeStamp					// ### TFS 53953 27June2022 NAVPW1
													_ediDetailTI.defaultAnyAmount,	//defaultAnyAmount : Boolean			// ### TFS 53953 27June2022 NAVPW1
													_ediDetailTI.defaultAnyId,	//defaultAnyId : Boolean					// ### TFS 53953 27June2022 NAVPW1
													_ediDetailTI.cargoMatchClientReference,	//matchClientRef : String		// ### TFS 53953 27June2022 NAVPW1
													_ediDetailTI.cargoMatchIMDGCode,	//matchUNDGCode : String			// ### TFS 53953 27June2022 NAVPW1
													_ediDetailTI.cargoMatchOrderNumber,	//matchOrderNum : String			// ### TFS 53953 27June2022 NAVPW1
													_ediDetailTI.cargoMatchPurchaseOrder,	//matchPurchaseOrder : String	// ### TFS 53953 27June2022 NAVPW1
													_ediDetailTI.cargoMatchReceiveDate,	//matchReceivedDT : TimeStamp		// ### TFS 53953 27June2022 NAVPW1
													_ediDetailTI.cargoMatchReleaseDate,	//matchReleasedDT : TimeStamp		// ### TFS 53953 27June2022 NAVPW1
													_ediDetailTI.cargoMatchRemarks,	//matchRemarks : String					// ### TFS 53953 27June2022 NAVPW1
													_ediDetailTI.cargoMatchVessel,	//matchVesselCode : String				// ### TFS 53953 27June2022 NAVPW1
													_ediDetailTI.weightRequested,    //maxWeightRequested : Decimal			// ### TFS 53953 11July2022 NAVPW1
													_ediDetailTI.lineNumber,		// LineNumber : Int						//TFS 54067
													_ediDetailTI.customerReference,	// customerReference : String			//TFS 54067
													cargoGroup,	 					// cargoGroup : CM_CargoGroup			// TFS 58923
													_ediDetailTI.getByTypeByWeight(),
													_bulkRelease.context = RelReqContext_Calloff and terminal.getConfig(LocnByOldestTransArrival).Boolean, //19/02/2023	navkc1 CR 60078 Task 62450
													null,	//24/04/2025	navrv30	MTN 34319																// 6/12/2023	navcs2	ChangeRequest 57537
													null);
		// TFS 51386 setting weightRequested has been done in the release request form since 2019, but the same change didn't get made here
		if (reserveCargoType &lt;&gt; null and (reserveCargoType.isBulkByWeight or reserveCargoType.isBulkByVolume))
		or self.myCallOffEDIData &lt;&gt; null then									// TFS 60150
			if _ediDetailTI.weightRequested &lt;&gt; null then 						// TFS 60874
				pxyReserve.setWeightRequested(_ediDetailTI.weightRequested);	// TFS 60150
			else
				pxyReserve.setWeightRequested(_ediDetailTI.weight); 			// TFS 60874
			endif;
		endif;
		// TFS 51386 end
		
		// TFS 58923 Also create instructions if present
		if _ediDetailTI.instructionType &lt;&gt; null and not _verifyOnly then
			instructionType := terminal.allInstructionTypes[_ediDetailTI.instructionType];
			if instructionType &lt;&gt; null then
				create pxyInstructions transient;
				pxyInstructions.setProxy(_ediDetailTI.instructionInternal, _ediDetailTI.instructionExternal, instructionType, pxyReserve);
			endif;
		endif;
		// TFS 58923 end of this bit
	else
		// 36821 allow EDI 'Release Request' quantity, if set and also weight
		quantity := _ediDetailTI.quantity;
		if quantity = 0 then
			quantity := 1;			// default to 1
		endif;
		
		//Start 13.01.2025 navhl20 #33695
		deliveryPartyCode 	:= _ediDetailTI.deliveryPartyCode;
		deliveryPartyName	:= _ediDetailTI.deliveryPartyName;
		
		if deliveryPartyCode &lt;&gt; null then
			deliveryParty := app.myRoot.allDeliveryParties[deliveryPartyCode];
		elseif deliveryPartyCode = null and deliveryPartyName &lt;&gt; null then
			deliveryParty := app.myRoot.allDeliveryParties.getDeliveryPartyByName(deliveryPartyName);
		endif;
		
		if deliveryParty &lt;&gt; null then
			deliveryAddress := deliveryParty.allAddresses[_ediDetailTI.deliveryAddressCode];
			if deliveryAddress = null then
				deliveryAddress := deliveryParty.allAddresses[_ediDetailTI.deliveryPartyCode];
			endif;
		endif;
		
		if deliveryParty = null and not _verifyOnly and _ediDetailTI.deliveryPartyCode &lt;&gt; null then
			create pxyDeliveryParty transient;
			create terminals transient;
			terminals.add(terminal);
			pxyDeliveryParty.setProxy(_ediDetailTI.deliveryPartyCode, _ediDetailTI.deliveryPartyName, false, terminals);
			create pxyDeliveryAddress transient;
			deliveryAddressCode := _ediDetailTI.deliveryAddressCode;
			if deliveryAddressCode = null then
				deliveryAddressCode := _ediDetailTI.deliveryPartyCode;
			endif;
			pxyDeliveryAddress.setProxy(deliveryAddressCode, _ediDetailTI.deliveryPartyName, _ediDetailTI.addressStreet1, _ediDetailTI.addressStreet1, null, _ediDetailTI.addressCounty, _ediDetailTI.addressPostCode, _ediDetailTI.addressCountryCode, _ediDetailTI.addressCity, null, null, true, false, null);
			pxyDeliveryParty.allAddresses.add(pxyDeliveryAddress);
			app.myTrxCA.trxCreateDeliveryParty(pxyDeliveryParty, deliveryParty, app.myPassport);
			if deliveryParty &lt;&gt; null then
				deliveryAddress := deliveryParty.allAddresses[deliveryAddressCode];
			endif;
		endif;
		//End 13.01.2025 navhl20 #33695
		
		pxyReserve.CM_ReserveTI.setProxy(reservePackType,
												null,
												_ediHeaderTI.removeStops,
												_ediDetailTI.remarks,
												quantity,		// 36821
												quantity,		// 36821
												bol, 
												_ediDetailTI.weight,	// 36821
												_ediDetailTI.sequence,	// PAR #34058
												0,						// jlgka1 TFS 41708
												null,					// jlgka1 TFS 41708
												deliveryParty,deliveryAddress,_ediDetailTI.deliveryInstructions,_ediDetailTI.deliveryFrom,_ediDetailTI.deliveryTo		//10.02.2025 navhl20 #34036
												); 					
	endif;
	
	//15 Sep 2016	NDL	TFS 2646 / 2001
	if _ediDetailTI &lt;&gt; null and pxyReserve &lt;&gt; null then
		create stopsToApply transient;
		create allEDITiTaskRemarks transient;
		_ediDetailTI.getAllStopsToApply(stopsToApply);
		self.getAllEDITaskRemarks(_ediDetailTI, allEDITiTaskRemarks);	//06 Oct 2016	NDL	TFS 2001 / 2792
		if pxyReserve.myReserveDetailActions = null then
			create resDetActions transient;
			resDetActions.setMyReserveDetail( pxyReserve );
		endif;
		pxyReserve.myReserveDetailActions.setStopTablesToAdd( stopsToApply );
		pxyReserve.myReserveDetailActions.setTaskDescsToAddFromEDI( _ediDetailTI.cargoType, allEDITiTaskRemarks );	//06 Oct 2016	NDL	TFS 2001 / 2792
		
	endif;
	
	if isNew then
		pxyReserve.setMyHeader(_bulkRelease);
	endif;
	
	idx := 1;
	if not _ediHeaderTI.releaseByType or (_ediHeaderTI.releaseByType and self.myCallOffEDIData &lt;&gt; null) then		// 15.07.2024 navsaa30  #64127
		while true do
			if not _ediHeaderTI.releaseByType then
				id := _ediDetailTI.id;
			else
				if idx &lt;= maskArray.size then	// TFS 65400
					id := maskArray[idx];
				endif;
			endif;
			ti := terminal.lookupTrackedItem(id, _ediDetailTI.cargoType, TI_STATE_UNDEFINED, null, false);
			if ti &lt;&gt; null then
				if not pxyReserve.allTrackedItems.includes(ti) then
					pxyReserve.allTrackedItems.add(ti);
				endif;
			endif;
			idx := idx + 1;
			if idx &gt; maskArray.size or not _ediHeaderTI.releaseByType then
				break;
			endif;
		endwhile;
	endif;
	
	// packing request criteria
	if _ediHeaderTI.releaseByType then
		create allEDITiRequestCriterias transient;
		self.getAllEDIRequestCriteria(_ediDetailTI, allEDITiRequestCriterias);
		foreach obj in allEDITiRequestCriterias do
			releaseCriteria := pxyReserve.CM_ReserveSelection.myReleaseCriteria;
			if releaseCriteria = null then
				create releaseCriteria transient;
			endif;
			releaseCriteria.addPxyCriteriaFromEDI( pxyReserve.CM_ReserveSelection, obj.CM_EDIRequestCriteriaTI );
			if releaseCriteria.myReserveSelection = null then
				delete releaseCriteria;
			endif;
		endforeach;
	endif;
	
	return pxyReserve;
epilog
	delete mtGradeArray;
	delete maskArray;
	delete allEDITiRequestCriterias;
	delete stopsToApply;
	delete allEDITiTaskRemarks;
	delete terminals;				// TFS 58923
	delete pxyDeliveryParty;		// TFS 58923
end;</source>
        <access>protected</access>
        <Parameter name="_bulkRelease" type="CM_BulkRelease" usage="input"/>
        <Parameter name="_pxyReserve" type="CM_ReserveDetail"/>
        <Parameter name="_ediHeaderTI" type="CM_EDIRequestHeaderTI"/>
        <Parameter name="_ediDetailTI" type="CM_EDIRequestDetailTI"/>
        <Parameter name="_garbageColl" type="ObjectSet" usage="input"/>
        <Parameter name="_verifyOnly" type="Boolean"/>
        <ReturnType type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="findBulkReleaseToUpdate" id="4b778068-d9a9-4b6c-bf4e-8b53b8538494">
        <source>findBulkReleaseToUpdate(_ediTI : CM_EDIRequestHeaderTI; _cmifColl, _addColl, _updateColl, _deleteColl : ObjectSet input) : CM_BulkRelease protected;
//
//16 Dec 2015	cnwrs1	Par 37402 TFS 1192 MultiLine Release Request
// 22 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 29 Nov 2017	jlgrs1	TFS 5705A - SNO - EDIDataBooking Prenote release Req
// 08 Aug 2018	jlgmd1	TFS 39693 - JMT - Bulk Release deleting inconsistency between Bulk Release Form and EDI
//
vars
	realRelease	: CM_BulkRelease;
	proxy : CM_BulkRelease;
	cmif,
	cmifDelete : CMIF_EDIReleaseRequest;
	object : Object;
	releaseNumber : String;
	mode : String;
	releaseItem : CM_ReserveDetail;
	found : Boolean;
	ediTrackedItem : CM_EDITrackedItem;
	ediTIReqDetail : CM_EDIRequestDetailTI;
begin
	releaseNumber := _ediTI.releaseRequestNumber;
	mode := _ediTI.messageMode;

	
	// If this BR is going to be deleted, then don't bother doing anything.
	foreach object in _deleteColl do
		cmifDelete := object.CMIF_EDIReleaseRequest;
		
		if cmifDelete.myBulkRelease.code = releaseNumber then
			if cmifDelete.allReserveDetailDel.isEmpty then
				cmifDelete.allEDITIs.add(_ediTI);
				return null;
			endif;
		endif;
		
		cmifDelete := null;
	endforeach;

	// look for a CMIF for this release number - if we start to get big release files will need to revisit this
	foreach object in _cmifColl do
		if object.CMIF_EDIReleaseRequest.myBulkRelease &lt;&gt; null and
		   object.CMIF_EDIReleaseRequest.myBulkRelease.code = releaseNumber and
		   object.CMIF_EDIReleaseRequest.allReserveDetailDel.isEmpty then
			cmif := object.CMIF_EDIReleaseRequest;	
			
			if mode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_DELETE then
				proxy	:= object.CMIF_EDIReleaseRequest.myBulkRelease;
			endif;
			
			break;
		endif;
	endforeach;
	
	realRelease	:=	self.getMyTerminal().getBulkReleaseFromCode(releaseNumber);

	//dont create proxy for a delete
	if mode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_DELETE and (proxy = null or proxy.code &lt;&gt; _ediTI.releaseRequestNumber) then		
		if realRelease = null then
			create proxy transient;
		else
			beginLoad;
			proxy	:=	realRelease.pxyCreateUpdateProxy();
			endLoad;
		endif;
	endif;
		
	if cmif = null then
		create cmif transient;
		
		// set reference to real release for delete
		if mode = CM_EDITrackedItem.EDI_ACTION_DELETE then
			cmif.myBulkRelease	:= realRelease;
			foreach ediTrackedItem in self.allEDITrackedItems do
				if not ediTrackedItem.isKindOf(CM_EDIRequestDetailTI) then
					continue;
				endif;
				ediTIReqDetail := ediTrackedItem.CM_EDIRequestDetailTI;
				if ediTIReqDetail.releaseRequestNumber &lt;&gt; _ediTI.releaseRequestNumber then
					continue;
				endif;
				if self.isCoparnFile(_ediTI.myEDIData) and 
				   ediTIReqDetail.myParent &lt;&gt; _ediTI then
					continue;
				endif;
				if ediTIReqDetail.sequence &lt;&gt; null then
					found := false;
					if cmif.myBulkRelease &lt;&gt; null then
						foreach releaseItem in cmif.myBulkRelease.allReserveDetails do
							if releaseItem.sequence = ediTIReqDetail.sequence then
								cmif.allReserveDetailDel.add(releaseItem);
								found := true;
								break;
							endif;
						endforeach;
					endif;
					if not found then
						ediTrackedItem := _ediTI;
						app.myTrxUA.trxUpdateEDITIStatus(ediTrackedItem, CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING, app.myPassport);
						delete cmif;
						return null;
					endif;
				endif;
			endforeach;
		else
			cmif.myBulkRelease := proxy;
		endif;
		_cmifColl.add(cmif);
	endif;
	
	// we can have more then one EDI TI making up a single release
	cmif.allEDITIs.add(_ediTI);
	
	
	if mode = CM_EDITrackedItem.EDI_ACTION_ADD or mode = CM_EDITrackedItem.EDI_ACTION_UPDATE then
		if realRelease = null then
			_addColl.addNoDuplicates(cmif, false);
		else
			_updateColl.addNoDuplicates(cmif, false);
		endif;
		
	elseif mode = CM_EDITrackedItem.EDI_ACTION_DELETE then
		if realRelease &lt;&gt; null then
			// a bit of validation !!!
			realRelease.validateForDelete(app.myPassport);		// TFS 39693
			if not app.myPassport.hasErrors then				// TFS 39693
				_deleteColl.addNoDuplicates(cmif, false);
			endif;
		endif;
	else
		app.raiseCMException1(EDIModeIgnored, _ediTI.messageMode, ETRow_MessageMode, _ediTI);
	endif;
	
	return proxy;
epilog
	endLoad;
end;
</source>
        <access>protected</access>
        <Parameter name="_ediTI" type="CM_EDIRequestHeaderTI"/>
        <Parameter name="_cmifColl" type="ObjectSet" usage="input"/>
        <Parameter name="_addColl" type="ObjectSet" usage="input"/>
        <Parameter name="_updateColl" type="ObjectSet" usage="input"/>
        <Parameter name="_deleteColl" type="ObjectSet" usage="input"/>
        <ReturnType type="CM_BulkRelease"/>
    </JadeMethod>
    <JadeMethod name="findReleasedTrackedItem" id="589ebd89-d0f7-4902-9c8b-8545aaf762e9">
        <source>findReleasedTrackedItem(_ediHeaderTI : CM_EDIRequestHeaderTI; _ediDetailTI : CM_EDIRequestDetailTI; _release : CM_BulkRelease) : CM_TrackedItem protected;
/*
Date		Who		Reason
21 Feb 2013	cnwcs5	Initial Creation - CCMS PNL 2243 / par 31185 
28 Jan 2016   cnwma1  PAR #37438 [RELATED TO TFS1192] Error 70092 while loading EDI Release Request by Type
// 13 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
*/
vars
	ti	:CM_TrackedItem;
begin
	// par 31185 - maybe it has already been released
	if _release = null then
		return null;
	endif;
	
	foreach ti in _release.allTrackedItemsReleased do
		//if ti.id = _ediDetailTI.id and ti.cargoType = _ediHeaderTI.cargoType then // 28/01/2015 cnwma1 PAR #37438
		if ti.id = _ediDetailTI.id and ti.cargoType = _ediDetailTI.cargoType then  // 28/01/2015 cnwma1 PAR #37438
			return ti;
		endif;
	endforeach;
	
	return null;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ediHeaderTI" type="CM_EDIRequestHeaderTI"/>
        <Parameter name="_ediDetailTI" type="CM_EDIRequestDetailTI"/>
        <Parameter name="_release" type="CM_BulkRelease"/>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getAllEDIRequestCriteria" id="0eaedd56-9d88-4b77-927e-8c4a9ca63d41">
        <source>getAllEDIRequestCriteria(_ediRequestDetailTI : CM_EDIRequestDetailTI; _allEDITiRequestCriterias : ObjectSet io);
//
//16 Dec 2015	cnwrs1	Par 37402 TFS 1192 MultiLine Release Request
// 13 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
//
vars
	ediTi : CM_EDITrackedItem;
begin
	_allEDITiRequestCriterias.clear();
	foreach ediTi in self.allEDITrackedItems do
		if ediTi.isKindOf(CM_EDIRequestCriteriaTI) and
		   ediTi.CM_EDIRequestCriteriaTI.releaseRequestNumber = _ediRequestDetailTI.releaseRequestNumber and
		   ediTi.CM_EDIRequestCriteriaTI.requestDetailID = _ediRequestDetailTI.requestDetailID then
			_allEDITiRequestCriterias.add(ediTi);
		endif;
	endforeach;
end;
</source>
        <Parameter name="_ediRequestDetailTI" type="CM_EDIRequestDetailTI"/>
        <Parameter name="_allEDITiRequestCriterias" type="ObjectSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllEDIRequestDetails" id="4a06e336-643e-448b-9430-b96c2ac26d77">
        <source>getAllEDIRequestDetails(_ediRequestHeaderTI : CM_EDIRequestHeaderTI; _allEDITiRequestDetails : ObjectSet io);
//
//16 Dec 2015	cnwrs1	Par 37402 TFS 1192 MultiLine Release Request
// 26 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
//
vars
	ediTi : CM_EDITrackedItem;
begin
	_allEDITiRequestDetails.clear();
	foreach ediTi in self.allEDITrackedItems do
		if self.isCoparnFile(_ediRequestHeaderTI.myEDIData) then
			if ediTi.isKindOf(CM_EDIRequestDetailTI) and
			   ediTi.CM_EDIRequestDetailTI.releaseRequestNumber = _ediRequestHeaderTI.releaseRequestNumber and
			   ediTi.CM_EDIRequestDetailTI.myParent = _ediRequestHeaderTI then
				_allEDITiRequestDetails.add(ediTi);
			endif;
		else
			if ediTi.isKindOf(CM_EDIRequestDetailTI) and
			   ediTi.CM_EDIRequestDetailTI.releaseRequestNumber = _ediRequestHeaderTI.releaseRequestNumber then
				_allEDITiRequestDetails.add(ediTi);
			endif;
		endif;
	endforeach;
end;
</source>
        <Parameter name="_ediRequestHeaderTI" type="CM_EDIRequestHeaderTI"/>
        <Parameter name="_allEDITiRequestDetails" type="ObjectSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllEDITaskRemarks" id="05886b17-d6ba-4e21-8a2f-9fef8fec0028">
        <source>getAllEDITaskRemarks(_ediRequestDetailTI : CM_EDIRequestDetailTI; _allEDITiTaskRemarks : ObjectSet io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 October 2016	cnwndl1	Initial creation	TFS 2001 / 2792
// 13 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
*/
vars
	ediTi : CM_EDITrackedItem;
begin
	_allEDITiTaskRemarks.clear();
	foreach ediTi in self.allEDITrackedItems do
		if ediTi.isKindOf(CM_EDITaskRemarkRelBookTI) and
		   ediTi.CM_EDITaskRemarkRelBookTI.releaseRequestNumber = _ediRequestDetailTI.releaseRequestNumber and
		   ediTi.CM_EDITaskRemarkRelBookTI.requestDetailID = _ediRequestDetailTI.requestDetailID then
			_allEDITiTaskRemarks.add(ediTi);
		endif;
	endforeach;
end;
</source>
        <Parameter name="_ediRequestDetailTI" type="CM_EDIRequestDetailTI"/>
        <Parameter name="_allEDITiTaskRemarks" type="ObjectSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getStatFrEDITIsVerifyOrDBL" id="ebdfd355-6856-405b-bccb-9d22124c4744">
        <source>getStatFrEDITIsVerifyOrDBL(_validateOnly : Boolean) : Integer;
//
//getStatusFromEDITIsAfterVerifyOrDBLoad
// 19 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
//
vars
	ediTI : CM_EDITrackedItem;
	total : Integer;
	skipped : Integer; 
	dbLoaded : Integer;
	verified : Integer;
	warnings : Integer;
	errors : Integer; 
	todo : Integer;
//	verifyWarnings : Boolean; 
//	verifyErrors : Boolean;
	newStatus : Integer;
	oldStatus : Integer;
begin
	if not self.canGetStatusFromEDITrackedItem() then
		app.raiseUnexpectedProgramError (self.class.name, method.name, "Method called for invalid EDI data type");
		return null;
	endif;
	
	total := self.allEDITrackedItems.size;
	newStatus := CM_EDIFile.EDI_STATUS_UNPROCESSED;
	if total = 0 then
		return newStatus;
	endif;
	foreach ediTI in self.allEDITrackedItems discreteLock do
		if ediTI.isKindOf(CM_EDIRequestCriteriaTI) then
			total := total - 1;
			continue;
		endif;
		if ediTI.isKindOf(CM_EDIRequestDetailTI) then
			total := total - 1;
			continue;
		endif;
		if ediTI.isKindOf(CM_EDITaskRemarkRelBookTI) then	// 10 Oct 2016	NDL	TFS 2001 / 2792
			total := total - 1;
			continue;
		endif;
		oldStatus := ediTI.status;
		if oldStatus = CM_EDITrackedItem.EDI_STATUS_UNPROCESSED then
			todo := todo + 1;
		elseif oldStatus = CM_EDITrackedItem.EDI_STATUS_DBLOADED then
			dbLoaded := dbLoaded + 1;
		elseif oldStatus = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING then
			// we are ignoring this one
			total := total - 1;
		elseif oldStatus = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X then
			skipped := skipped + 1;
		elseif oldStatus = CM_EDITrackedItem.EDI_STATUS_VERIFIED then
			verified := verified + 1;
		elseif oldStatus = CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS then
			warnings := warnings + 1;
		elseif oldStatus = CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS or 
			oldStatus = CM_EDIFile.EDI_STATUS_DBLOADED_ERRORS then
			errors := errors + 1;				
		endif;
	endforeach;
	
	if todo = total then
		// nothing processed
		if todo &gt; 0 then
			newStatus := CM_EDIFile.EDI_STATUS_SKIP_PROCESSING;
		else
			// probably ignored everything
			if _validateOnly then
				newStatus := CM_EDIFile.EDI_STATUS_VERIFIED;
			else
				newStatus := CM_EDIFile.EDI_STATUS_DBLOADED;
			endif;
		endif;
	elseif dbLoaded = total then 
		// everything loaded
		if _validateOnly then
			newStatus := CM_EDIFile.EDI_STATUS_VERIFIED;
		else
			newStatus := CM_EDIFile.EDI_STATUS_DBLOADED;
		endif;
	elseif dbLoaded &gt; 0 then
		// file is partially loaded
		if skipped + dbLoaded = total then
			// all either loaded or skipped
			if _validateOnly then
				newStatus := CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X;
			else
				newStatus := CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL_X;
			endif;
		else
			// some skipped, some loaded, some yet to be loaded
			if _validateOnly then
				newStatus := CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS;
			else
				newStatus := CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL;
			endif;
		endif;
	else	
		// nothing loaded
		if skipped &gt; 0 then
			if skipped = total then
				// everything has been skipped
				newStatus := CM_EDIFile.EDI_STATUS_VERIFY_ERRORS_X;
			elseif skipped + verified = total then
				newStatus := CM_EDIFile.EDI_STATUS_VERIFIED;
			else
				newStatus := CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS;
			endif;
		else
			// still some stuff that has not loaded
			if errors &gt; 0 then
				newStatus := CM_EDIFile.EDI_STATUS_VERIFIED_ERRORS;
			elseif warnings &gt; 0 then
				newStatus := CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS;
			else
				newStatus := CM_EDIFile.EDI_STATUS_VERIFIED;
			endif;
		endif;
	endif;

	return newStatus;
epilog

end;</source>
        <Parameter name="_validateOnly" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getVoyageForRelease" id="9aa10833-6237-44f7-b8b8-d8c3e0e3f8a9">
        <source>getVoyageForRelease(_terminal : CM_Terminal; _ediTI : CM_EDIRequestHeaderTI; _realBulkRelease : CM_BulkRelease; _defaultVoyage : CM_Voyage; _voyage : CM_Voyage output; _voyageCode : String output) protected;
//
//11 Dec 2015	cnwrs1	Par 37402 TFS 1192 MultiLine Release Request
// 13 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 13 Dec 2017	jlgrs1	TFS 8281 - SNO - EDI New Coaprn Issues
//
vars
	ediReqHeaderTI : CM_EDIRequestHeaderTI;
	operator : CM_Operator;
//	voyage : CM_Voyage;
	voyageCode : String;
	newVoyageCode : String;
	foundMatch : Boolean;
begin
	//  re-worked this next voyage checking section so that if we are updating a release
	// and voyage in the file is not valid then if the release is already for the default voyage we just 
	// raise a warning about the invalid voyage
	// if there is no voyage in the file no errors/warnings will be raised because it is OK to have a release without a voyage

	voyageCode := _ediTI.getVoyageCode();

	operator := app.myRoot.allOperators[_ediTI.operatorCode];
	if _voyage = null and
	   operator &lt;&gt; null then
		newVoyageCode := operator.getXlationSystemCode_Voyage(voyageCode, _ediTI.vesselName, null, null, foundMatch);
		if newVoyageCode &lt;&gt; null and voyageCode &lt;&gt; newVoyageCode then
			ediReqHeaderTI := _ediTI;
			beginTransaction;
			ediReqHeaderTI.setVoyageCode(newVoyageCode);
			commitTransaction;
			voyageCode := newVoyageCode;
		endif;
	endif;
	if voyageCode &lt;&gt; null then
		_voyage	:= _terminal.allVoyagesByCode.getAtKeyGeq(voyageCode, null);
	endif;
	if _voyage &lt;&gt; null and 
	   _voyage.code &lt;&gt; voyageCode then
		// a different voyage was found
		_voyage := null;
	endif;
			
	if _voyage = null then
		// EDI File did not contain a valid voyage
		if _defaultVoyage &lt;&gt; null then
			// we have a default voyage we could use
			if _realBulkRelease = null or 
			   _realBulkRelease.myVoyage = _defaultVoyage then
				// we are adding a new release or updating a release that is already for the default voyage
				if voyageCode &lt;&gt; null then 
					// just give warning of invalid voyage in file as we will use the default voyage 
					app.raiseCMWarning1(ERR_INVALID_VOYAGE, voyageCode, ETRow_Voyage, _ediTI, null);	
				endif;
				// use default voyage instead of voyage from file
				_voyage := _defaultVoyage;														
				voyageCode	:= _voyage.code;	
			endif;
		endif;
	endif;

	if voyageCode &lt;&gt; null and 
	   _voyage = null then
		// the voyage from the file is invalid and we can't use the default voyage (if there is one)
		app.raiseCMException1(ERR_INVALID_VOYAGE, voyageCode, ETRow_Voyage, _ediTI);
	endif;
	_voyageCode := voyageCode;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_ediTI" type="CM_EDIRequestHeaderTI"/>
        <Parameter name="_realBulkRelease" type="CM_BulkRelease"/>
        <Parameter name="_defaultVoyage" type="CM_Voyage"/>
        <Parameter name="_voyage" type="CM_Voyage" usage="output"/>
        <Parameter name="_voyageCode" type="String" usage="output"/>
    </JadeMethod>
    <JadeMethod name="isCoparnFile" id="f7fa271a-ddc1-4649-8def-4848bc117d50">
        <source>isCoparnFile(_ediData : CM_EDIData) : Boolean;
//
//11 Dec 2015	cnwrs1	Par 37402 TFS 1192 MultiLine Release Request
//
// 13 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 07 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
vars
	file : CM_EDIFile;
	result : Boolean;
begin
	file := _ediData.myEDIFile;
	
// 07 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
	if file &lt;&gt; null and file.myEDIFileType &lt;&gt; null then
		result := file.myEDIFileType.type = EDIFileType_Coparn;
	endif;
	
	return result;
end;
</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isX12301File" id="b223b89b-9d66-413c-8621-be5a64118c1b">
        <source>isX12301File(_ediData : CM_EDIData) : Boolean;
//
// 18 Apr 2018	jlgrs1	TFS 8296 add release req and prenotes to X12 301
//
// 07 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
vars
	file : CM_EDIFile;
	result : Boolean;
begin
	file := _ediData.myEDIFile;
	
// 07 Sep 2018	jlgrs1	TFS 40627 STWR Make EDI MultiThreaded
	if file &lt;&gt; null and file.myEDIFileType &lt;&gt; null then
		result := file.myEDIFileType.type = EDIFileTypeX12_301_4010;
	endif;
	
	return result;
end;</source>
        <Parameter name="_ediData" type="CM_EDIData"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadDB_Adds" id="0c541295-2d79-4b39-8f92-faab9c0c07ff">
        <source>loadDB_Adds(_coll : ObjectSet; _verifyOnly : Boolean; _terminal : CM_Terminal; _isPartial : Boolean; _passport : CM_Passport input) protected;
//
//16 Dec 2015	cnwrs1	Par 37402 TFS 1192 MultiLine Release Request
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 20 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
//
vars
	realBulkRelease : CM_BulkRelease;
	object : Object;
	cmifEDIRelease : CMIF_EDIReleaseRequest;
	ediTI : CM_EDITrackedItem;
	partsDone : Integer; 
	partsInJob : Integer;
	progressStr	: String;
	progressTS : TimeStamp;
	errorSet : CM_ErrorSet;
	ediData : CM_EDIData;
begin
	create errorSet transient;
	
	ediData := self.allEDITrackedItems.first.myEDIData;
	
	partsInJob := _coll.size();
	partsDone := null;
	progressStr := app.getString(Creating_ReleaseRequests, partsInJob.display);
	progressTS := app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	ediData.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, _passport);
	
	foreach object in _coll do :outerLoop
		cmifEDIRelease := object.CMIF_EDIReleaseRequest;
		partsDone := partsDone + 1;
		ediData.updateProgress(progressTS, progressStr, partsInJob, partsDone, false, _passport);
		
		foreach ediTI in cmifEDIRelease.allEDITIs do
			if ediTI.status = CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS then 
				// we have a problem with these guys - will only happen if we allow partial loads
				continue outerLoop;
			endif;
		endforeach;
		
		app.myTrxCA.trxEDICreateBulkRelease(cmifEDIRelease, realBulkRelease, _verifyOnly, _passport);
		
		if _passport.hasErrors() then
			// we have to set status here if the trx failed
			if _verifyOnly then
				app.myTrxUA.trxUpdateEDITIStatusBulk(cmifEDIRelease.allEDITIs, CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS, _passport);
			else
				app.myTrxUA.trxUpdateEDITIStatusBulk(cmifEDIRelease.allEDITIs, CM_EDITrackedItem.EDI_STATUS_DBLOADED_ERRORS, _passport);
			endif;
			if not _isPartial then	
				// we got errors so stop here unless OK to do partial load
				_passport.moveErrorsToSet(errorSet); 
				return;
			endif;
		endif;
		
		_passport.moveErrorsToSet(errorSet); 
	endforeach;
	
	ediData.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, _passport);

	return;
epilog
	// make sure passport has  all errors so far
	_passport.addErrorsFromSet (errorSet);
	
	delete errorSet;
end;</source>
        <access>protected</access>
        <Parameter name="_coll" type="ObjectSet"/>
        <Parameter name="_verifyOnly" type="Boolean"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_isPartial" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="loadDB_Deletes" id="972c9a06-ac35-474d-8b4e-f193f6a11d84">
        <source>loadDB_Deletes(_coll : ObjectSet; _verifyOnly : Boolean; _terminal : CM_Terminal; _isPartial, _sendEmail : Boolean; _emailTo, _emailFrom : String; _passport : CM_Passport input) protected;
//
//16 Dec 2015	cnwrs1	Par 37402 TFS 1192 MultiLine Release Request
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 20 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
//
vars
	realBulkRelease	: CM_BulkRelease;
	reserveDetail : CM_ReserveDetail;
	isNotValid : Boolean;
	object : Object;
	obj : Object;
	cmifEDIRelease : CMIF_EDIReleaseRequest;
	ediTI : CM_EDITrackedItem;
	partsDone : Integer;
	partsInJob : Integer; 
	newStatus : Integer;
	progressStr : String;
	emailSubject : String;
	progressTS : TimeStamp;
	errorSet : CM_ErrorSet;
	sequence : String;
	ediData : CM_EDIData;
begin
	create errorSet transient;
	
	ediData := self.allEDITrackedItems.first.myEDIData;
	
	partsInJob := _coll.size;
	partsDone := null;
	progressStr := app.getString(Creating_ReleaseRequests, partsInJob.display);	
	progressTS := app.actualTimeServer;// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	ediData.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, _passport);
	
	on Exception do app.handleDeletedObject(exception, realBulkRelease, isNotValid);
	
	foreach object in _coll do :foreachLoop
		cmifEDIRelease := object.CMIF_EDIReleaseRequest;
		realBulkRelease := cmifEDIRelease.myBulkRelease;
//		reserveDetail := cmifEDIRelease.myReserveDetailDel;
		
		partsDone := partsDone + 1;
		ediData.updateProgress(progressTS, progressStr, partsInJob, partsDone, false, _passport);
		
		foreach ediTI in cmifEDIRelease.allEDITIs do
			if ediTI.status = CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS or
				ediTI.status = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING or
				ediTI.status = CM_EDITrackedItem.EDI_STATUS_SKIP_PROCESSING_X then
				// we have a problem with these guys - will only happen if we allow partial loads
				continue foreachLoop;
			endif;
		endforeach;
		foreach obj in cmifEDIRelease.allReserveDetailDel	do
			reserveDetail := obj.CM_ReserveDetail;
			_passport.setWarningsIgnored(true);
			sequence := reserveDetail.sequence;
			app.myTrxDA.trxEDIDeleteReserveDetail(reserveDetail, cmifEDIRelease, _verifyOnly, _passport);
			// if there were NO errors then status will have been updated in trxEDIDeleteBulkRelease
			if _passport.hasErrors() then
				if _verifyOnly then
					newStatus := CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS;
				else
					newStatus := CM_EDITrackedItem.EDI_STATUS_DBLOADED_ERRORS;
				endif;
//				app.myTrxUA.trxUpdateEDITIStatusBulk(cmifEDIRelease.allEDITIs, newStatus, _passport);
			else	
				if _verifyOnly then
					newStatus := CM_EDITrackedItem.EDI_STATUS_VERIFIED;
				else
					newStatus := CM_EDITrackedItem.EDI_STATUS_DBLOADED;
				endif;
			endif;
app.myTrxUA.trxUpdateEDITIStatusBulk(cmifEDIRelease.allEDITIs, newStatus, _passport);
			_passport.moveErrorsToSet(errorSet); 
			if newStatus = CM_EDITrackedItem.EDI_STATUS_DBLOADED_ERRORS and not _isPartial then
				// something went terribly wrong 
				break;
			endif;
			if newStatus = CM_EDITrackedItem.EDI_STATUS_DBLOADED and _sendEmail then
				emailSubject := "Reserve detail " &amp; realBulkRelease.code &amp; ' seq '&amp;sequence&amp; " has been deleted.";
				app.myTrxCA.trxCreateEmailSendRequest(app.getErrorString(BGP_Processing), _emailTo, _emailFrom, null, null, emailSubject, null,
															null, null, null, null, EmailSource_System,  null, _passport);
				app.setContinueCMExceptions(true);	// because last trx just reset it
			endif;

			_passport.setWarningsIgnored(false);
		endforeach;
		if reserveDetail = null and
		   realBulkRelease &lt;&gt; null then
		   
			_passport.setWarningsIgnored(true);
					
			app.myTrxDA.trxEDIDeleteBulkRelease(realBulkRelease, cmifEDIRelease, _verifyOnly, _passport);
			
			// if there were NO errors then status will have been updated in trxEDIDeleteBulkRelease
			if _passport.hasErrors() then
				if _verifyOnly then
					newStatus := CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS;
				else
					newStatus := CM_EDITrackedItem.EDI_STATUS_DBLOADED_ERRORS;
				endif;
//				app.myTrxUA.trxUpdateEDITIStatusBulk(cmifEDIRelease.allEDITIs, newStatus, _passport);
			else	
				if _verifyOnly then
					newStatus := CM_EDITrackedItem.EDI_STATUS_VERIFIED;
				else
					newStatus := CM_EDITrackedItem.EDI_STATUS_DBLOADED;
				endif;
			endif;
app.myTrxUA.trxUpdateEDITIStatusBulk(cmifEDIRelease.allEDITIs, newStatus, _passport);
			_passport.moveErrorsToSet(errorSet); 

			if newStatus = CM_EDITrackedItem.EDI_STATUS_DBLOADED_ERRORS and not _isPartial then	
				// something went terribly wrong 
				break;
			endif;
			
			if newStatus = CM_EDITrackedItem.EDI_STATUS_DBLOADED and _sendEmail then
				emailSubject := "Release Request " &amp; realBulkRelease.code &amp; " has been deleted.";

				app.myTrxCA.trxCreateEmailSendRequest(app.getErrorString(BGP_Processing), _emailTo, _emailFrom, null, null, emailSubject, null,
															null, null, null, null, EmailSource_System,  null, _passport);
				app.setContinueCMExceptions(true);	// par 29480 April 2012 because last trx just reset it
			endif;

			_passport.setWarningsIgnored(false);
		endif;
	endforeach;

	if realBulkRelease &lt;&gt; null then                              // 29/12/2015 cnwma1  PAR#37279
		if  realBulkRelease.allTrackedItemsReleased.isEmpty then 
			if realBulkRelease.allReserveDetails.isEmpty then
				_passport.setWarningsIgnored(true);
						
				app.myTrxDA.trxEDIDeleteBulkRelease(realBulkRelease, cmifEDIRelease, _verifyOnly, _passport);		
				// if there were NO errors then status will have been updated in trxEDIDeleteBulkRelease
				if _passport.hasErrors() then
					if _verifyOnly then
						newStatus := CM_EDITrackedItem.EDI_STATUS_VERIFIED_ERRORS;
					else
						newStatus := CM_EDITrackedItem.EDI_STATUS_DBLOADED_ERRORS;
					endif;
//					app.myTrxUA.trxUpdateEDITIStatusBulk(cmifEDIRelease.allEDITIs, newStatus, _passport);
				else	
					if _verifyOnly then
						newStatus := CM_EDITrackedItem.EDI_STATUS_VERIFIED;
					else
						newStatus := CM_EDITrackedItem.EDI_STATUS_DBLOADED;
					endif;
				endif;		
app.myTrxUA.trxUpdateEDITIStatusBulk(cmifEDIRelease.allEDITIs, newStatus, _passport);
				_passport.moveErrorsToSet(errorSet); 
				if newStatus = CM_EDITrackedItem.EDI_STATUS_DBLOADED_ERRORS and not _isPartial then	
					// something went terribly wrong 
				endif;
			endif;
		endif;
	endif;

	ediData.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, _passport);
epilog
	_passport.addErrorsFromSet(errorSet);
	
	delete errorSet;
end;</source>
        <access>protected</access>
        <Parameter name="_coll" type="ObjectSet"/>
        <Parameter name="_verifyOnly" type="Boolean"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_isPartial" type="Boolean"/>
        <Parameter name="_sendEmail" type="Boolean"/>
        <Parameter name="_emailTo" type="String"/>
        <Parameter name="_emailFrom" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
