    <JadeMethod name="cargoIF_GetStringForETRow" id="27f97fb5-4bbb-407b-9c3e-7280307a0b3a">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CargoField::getStringForETRow"/>
        </interfaceImplements>
        <source>cargoIF_GetStringForETRow(pAttrName : String):String;

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*
	Created on 17 January 2008
	
	by Debby Hutchison
	
	Purpose:
*/

vars
	tmpReal : Real;
	haz		: CM_Hazard;
	tmpStr  : String;
	hazDict : CM_HazardByCodeDict;
	brItem  : CM_BookingRefItem;
begin
	if not isTransient then
		brItem := self.allBookingRefItems.first;
		if brItem = null then
			return null;
		endif;
	endif;
	if pAttrName = ETRow_AvailabilityGradeCode then
		return null;
//	elseif pAttrName = ETRow_BolType then // adm 160310 Par 22937 remove bolType
//		return brItem.bolTypeDescr;
	elseif pAttrName = ETRow_CargoType then
	// AER Par16241 18/07/08 - this was an old version of displaying data , when "ETRow_BolType" was not existing
		//if bolType &lt;&gt; null then
	//		return brItem.bolTypeDescr;
	//	else
			return brItem.cargoTypeDescr;
	//	endif;
	elseif pAttrName = ETRow_CargoTypeDescr then
		return brItem.cargoTypeDescr;
	elseif pAttrName = ETRow_CarriageTempC then
		return brItem.getTempString(false);
	elseif pAttrName = ETRow_CarriageTempF then
		return brItem.getTempString(true);
	elseif pAttrName = ETRow_Commodity then
		return brItem.commodity;
	elseif pAttrName = ETRow_ConsigneeCode then
		return null;
	elseif pAttrName = ETRow_ConsignorCode then
		return null;
	elseif pAttrName = ETRow_FreightForwarderCode then
		return null;
	elseif pAttrName = ETRow_DestinationPort then
		return destinationPort;
	elseif pAttrName = ETRow_DischargePort then
		return dischargePort;
	elseif pAttrName = ETRow_MyTranshipToPort then
		if myTranshipToPort &lt;&gt; null then
			return myTranshipToPort.code;//cnwas3 ccms 1028
		else
			return null;
		endif;
	elseif pAttrName = ETRow_CoolingType then
		return null;
	elseif pAttrName = ETRow_OperatorCode then
		return operatorCode;
	elseif pAttrName = ETRow_VoltageType then
		return null;
	elseif pAttrName = ETRow_Humidity then
		if brItem.getHumidity &lt;&gt; NULL_HUMIDITY then
			return brItem.getHumidity.String;
		else
			return null;
		endif;
	elseif pAttrName = ETRow_IdTextBox then
		return null;
	elseif pAttrName = ETRow_Quantity then
//		if productQuantity = 0 then
		return getTotalQuantity.String;// dh 29/2/2008 ccms 1618
		//	return productQuantity.String;
	elseif pAttrName = ETRow_StatusString then
		return null;
	elseif pAttrName = ETRow_Ventilation then
		return brItem.getVentilationAsString();	// PAR 17601 July 2008
		/*
		if brItem.getVentilation &lt;&gt; NULL_VENTILATION then
	   		return brItem.getVentilation.String;
		else
			return null;
	   	endif;
		*/
	elseif pAttrName = ETRow_VoyageCode then
		if myVoyage &lt;&gt; null then
			return myVoyage.code;
		else
			return null;
		endif;
	elseif pAttrName = ETRow_WeightTotal then
//		return weight.String; // dh 29/2/2008 ccms 1618
		return getTotalWeight.asStringWeightJMT(); // cnwrd1 ccms JMT 1060 Imp Measurements
	elseif pAttrName = ETRow_MyHeight then
		return brItem.height.asStringMeasurementJMT(); // cnwrd1 ccms JMT 1060 Imp Measurements
	elseif pAttrName = ETRow_MyWeight then
		return brItem.weight.asStringWeightJMT(); // cnwrd1 ccms JMT 1060 Imp Measurements
	elseif pAttrName = ETRow_MyLength then
		return brItem.length.asStringMeasurementJMT(); // cnwrd1 ccms JMT 1060 Imp Measurements
	elseif pAttrName = ETRow_NumItems then
		return getTotalQuantity.String;
	elseif pAttrName = ETRow_MyQuantity then
		return brItem.productQuantity.String;
	elseif pAttrName = ETRow_MyDensity then
		return brItem.density.String;
	elseif pAttrName = ETRow_MyVolume then
		return brItem.volume.String;
	elseif pAttrName = ETRow_ShippingMarks then
		return brItem.shippingMarks;
//	elseif pAttrName = ETRow_MultiItem then	//05 Nov 2012	NDL	Par 29859
//		return isMultiItemBookingRef.getYesNo;
	elseif pAttrName = ETRow_IsStock or
		pAttrName = ETRow_IsStockBookingRef then
		return isStockBookingRef.getYesNo;
	elseif pAttrName = ETRow_CompanyCode then
		if myVoyage &lt;&gt; null then
			if myVoyage.myDischargeCompany &lt;&gt; null then
				return myVoyage.myDischargeCompany.code;
			endif;
		endif;
	elseif pAttrName = ETRow_AllTIHazards then
		create hazDict transient;
		self.getAllItemTIIHazards(hazDict);
		foreach haz in hazDict do
			if tmpStr &lt;&gt; null then
				tmpStr := tmpStr &amp; '; ';
			endif;
			tmpStr := tmpStr &amp; haz.getTableDisplay(false, true);
		endforeach;
		return tmpStr;
	elseif pAttrName = ETRow_IsControlledAtmosphere then	// CCMS 1654 - slw 11/09/2008
		return brItem.getIsControlledAtmosphere.getYesNo;
	elseif pAttrName = ETRow_Oxygen then					// CCMS 1654 - slw 11/09/2008
		brItem.getOxygen.asNullOxygen;
	elseif pAttrName = ETRow_CarbonDioxide then				// CCMS 1654 - slw 11/09/2008
		brItem.getCarbonDioxide.asNullCarbonDioxide;
	elseif pAttrName = ETRow_CurtainsIn then				// CCMS 1654 - slw 11/09/2008
		return brItem.getCurtainsIn.getYesNo;
	endif;
	
	return null;
epilog
	delete hazDict;
end;</source>
        <Parameter name="pAttrName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="cargoType" id="5ecc81ef-14bb-4764-973d-da1a0516cba5">
        <methodInvocation>mapping</methodInvocation>
        <source>cargoType(_set : Boolean; _value : Integer io) mapping;
// ---------------------------------------------------------------------------
// Created:     04 March 2010 by cnwcs5
// Purpose:     par 22762
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	type :CM_CargoType;
begin
	if not _set or
		self.isTransient or
		self.cargoType = _value then
		return;
	endif;
	
	type := app.myRoot.allCargoTypesById[_value];
	
	if type &lt;&gt; null then
		type.updateForNonInversedReference;
	endif;
epilog

end;</source>
        <Parameter name="_set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="cargoTypeDescr" id="bc7fb70a-863c-439d-a6db-b1e909451b19">
        <methodInvocation>mapping</methodInvocation>
        <source>cargoTypeDescr(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:     27 September 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpCargoType : CM_CargoType;

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	tmpCargoType := app.myRoot.allCargoTypesById[self.cargoType];
	if tmpCargoType &lt;&gt; null then
		_value := tmpCargoType.description;
	else
//		8/6/2006 Lorcan Cargo Type now can be null 
//		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid cargo type (' &amp; self.cargoType.String &amp; ') on ' &amp; self.String);
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="checkForHazardOnBookingRefItem" id="ee4d60fe-48a8-4dcb-b8c1-d789a9ba0923">
        <source>checkForHazardOnBookingRefItem(_tiHazard : CM_TIHazard; _bookingRefitem : CM_BookingRefItem output) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 September 2008	cnwer1	Initial creation

*/

vars
	iter : Iterator;
	bookingRefItem : CM_BookingRefItem;
begin
	
	iter:=self.allBookingRefItems.createIterator;
	while iter.next(bookingRefItem) do
		if bookingRefItem.allTIHazards[_tiHazard.code] &lt;&gt; null then
			_bookingRefitem:=bookingRefItem;
			return true;
		endif;
	endwhile;
	
	return false;
epilog
	delete iter;
end;</source>
        <Parameter name="_tiHazard" type="CM_TIHazard"/>
        <Parameter name="_bookingRefitem" type="CM_BookingRefItem" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkForPrenotedItem" id="d4bf2cb8-0cf2-4920-82ec-af465bfda2ed">
        <source>checkForPrenotedItem(_ti : CM_TrackedItem) : CM_BookingRefItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 July 2014	cnwmc5	Initial creation	PAR 34468

*/

vars
	brItem		: CM_BookingRefItem;
	
begin

	foreach brItem in self.allBookingRefItems do
		if brItem.containsPrenotedTI(_ti) then
			return brItem;
		endif;
	endforeach;
	
	return null;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="CM_BookingRefItem"/>
    </JadeMethod>
    <JadeMethod name="checkForTIsChangeVoyage" id="e684b63b-c37d-476b-bb54-0bfe8fda75c4">
        <updating/>
        <source>checkForTIsChangeVoyage() updating;
/*
Purpose:			if bookings are unique by number for my operator, check all onsite and prenoted
					cargo for my operator for matches on booking reference. 
					If we find any, change their voyage to match mine

Parameters:			None

Return Value:		None

Date		Who		Reason
27/12/2012	cnwdap1	Initial creation PAR #30882 CCMS PNL 2244
*/
vars
	opTerm 	: CM_OperatorTerminal;
	ti		: CM_TrackedItem;

begin
	if not self.myOperator.bookingsUniqueByNumber then
		return;
	endif;
	
	opTerm := self.myOperatorTerminal;
	
	if opTerm = null and self.myOperator &lt;&gt; null then
		opTerm := self.myOperator.getOperatorTerminal(self.myTerminal, false);
	endif;

	if opTerm = null then
		return;
	endif;
	
	// Notified cargo
	foreach ti in opTerm.allNotifiedTIsByCargoTypeId do
		if ti.bookingReference = self.bookingReference and ti.myVoyage &lt;&gt; self.myVoyage then
			ti.setMyVoyage(self.myVoyage, app.myPassport);
		endif;
	endforeach;
	
	// Onsite cargo
	foreach ti in opTerm.allOnsiteTIsByCargoTypeId do
		if ti.bookingReference = self.bookingReference and ti.myVoyage &lt;&gt; self.myVoyage then
			ti.setMyVoyage(self.myVoyage, app.myPassport);
		endif;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="checkIfUpdateMultiRelease" id="00a307ec-258e-4bf2-ae0f-9b1fed92e279">
        <source>checkIfUpdateMultiRelease(_cmifBookingRef :CMIF_BookingRef): Boolean;
// --------------------------------------------------------------------------------
// Created:		03 July 2008 by cnwaer1
//
// Purpose:		Check to see if the Release request exists in the db before creating a new one
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
//25/05/2016		cnwma1	PAR #37790 TFS#1880 MSL - EDI Bookings with Release Empties 
// --------------------------------------------------------------------------------
vars
	isFound 		: Boolean;
	terminalObj 	: CM_Terminal;
	bookingOpCode,
 	releaseOpCode	: String;
	iteratorObj		: Iterator;
	breleaseObj,
	rel				: CM_BulkRelease;
	dateTime		: TimeStamp;
	ediTrackedItem   : CM_EDITrackedItem; 		// 25/05/2016 cnwma1 PAR #37790 TFS #1880
	ediBookingRefTiSet : CM_EDIBookingRefTISet; // 25/05/2016 cnwma1 PAR #37790 TFS #1880
begin
	terminalObj	:=	app.myPassport.myTerminal;
	// Par 17378 02/07/08 -- Debby-Anca
	//Was creating a Bulk Release for every Booking Reference update!!
	if self.allReleaseRequests.size &gt; 0	then
		create  ediBookingRefTiSet transient;								// 25/05/2016 cnwma1 PAR #37790 TFS #1880
		if _cmifBookingRef.allEDIBookingRefTIs.size &gt; 0 then	// 25/05/2016 cnwma1 PAR #37790 TFS #1880
			_cmifBookingRef.allEDIBookingRefTIs.copy(ediBookingRefTiSet);	// 25/05/2016 cnwma1 PAR #37790 TFS #1880
		endif;
	
		foreach rel in self.allReleaseRequests do
			if self.myEDIBookingRefTI &lt;&gt; null and 
			   self.myEDIBookingRefTI.releaseRequestNumber = rel.code then
				return true;
            endif;
			
			if self.myEDIBookingRefTI = null then							// 25/05/2016 cnwma1 PAR #37790 TFS #1880
				foreach ediTrackedItem in ediBookingRefTiSet do
					if ediTrackedItem .isKindOf(CM_EDIBookingHeaderTI) then
						if ediTrackedItem.CM_EDIBookingHeaderTI.releaseRequestNumber =rel.code then
							return true;
						endif;
					endif;
				endforeach;
			endif;															// 25/05/2016 cnwma1 PAR #37790 TFS #1880
		endforeach;
		
		return false;
	endif;
	if (self.myEDIBookingRefTI &lt;&gt; null and 
	    self.myEDIBookingRefTI.releaseRequestNumber &lt;&gt; null) then
		isFound			:=	false;
		bookingOpCode	:=	self.operatorCode;
		// allBulkReleasesByCodeDate collection is keyed descending on date 
		dateTime := app.actualTimeServer().addYears(1000);	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
		iteratorObj		:=	terminalObj.allBulkReleasesByCodeDate.createIterator();
		terminalObj.allBulkReleasesByCodeDate.startKeyGeq(self.myEDIBookingRefTI.releaseRequestNumber, dateTime, iteratorObj);
		
		while iteratorObj.next(breleaseObj) do
			if breleaseObj.code &lt;&gt; self.myEDIBookingRefTI.releaseRequestNumber then
				break;
			endif;
			
			if breleaseObj.myOperator &lt;&gt; null then
				releaseOpCode	:=	breleaseObj.myOperator.code;
			else
				releaseOpCode	:=	null;
			endif;
			
			if releaseOpCode = bookingOpCode then
				isFound	:=	true;
				break;
			endif;
		endwhile;
		
		if not isFound then
			return true;
		endif;
	endif;
	return false;
epilog
	delete ediBookingRefTiSet;
	delete iteratorObj;
end;
</source>
        <Parameter name="_cmifBookingRef" type="CMIF_BookingRef"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cloneForRoll" id="af21e9a1-8ee0-49c9-9b12-a477d176f8f4">
        <source>cloneForRoll(_bookingRefStr :String; _voyage :CM_Voyage; _dischargePortCode :String; _transhipPort : CM_Port) :CM_BookingRef;

vars
	bookingRef		: CM_BookingRef;
	bookingItem,
	newBookingItem	: CM_BookingRefItem;
	releaseObj,
	newReleaseObj	: CM_BulkRelease;
begin
	//bookingRef	:= self.copySelf(false);
	bookingRef	:= self.copySelf(true); //creat pxy for create later for audit cnwrd1 12.2.09 par #17936
	//bookingRef.bookingReference := _bookingRefStr;
//	bookingRef.bookingReference := _bookingRefStr.trimBlanks;	//22 Oct 2013	NDL	Par 32553
	bookingRef.setBookingReference( _bookingRefStr.trimBlanks );	//06 Dec 2017	NDL	TFS 8013
	bookingRef.dischargePort	:= _dischargePortCode;
	//bookingRef.myTranshipToPort	:= _transhipPort;
	bookingRef.setTranshipToPort( _transhipPort, false );	//07 Sep 2012	NDL	Par 29684
	
	bookingRef.myVoyage		:= _voyage;	
	bookingRef.myProduct	:= self.myProduct;
//	bookingRef.setPxyHazards(self.allTIHazards);
	
	foreach releaseObj in self.allReleaseRequests do
		newReleaseObj	:=	releaseObj.cloneForRoll(bookingRef);
		newReleaseObj.setBookingRefStock(bookingRef);
	endforeach;
	
	
	foreach bookingItem in self.allBookingRefItems 
	where bookingItem.myReserveDetail = null do // bookingRefItems with Reserve Details are created with them
		newBookingItem	:=	bookingItem.cloneForRoll();
		newBookingItem.setMyBookingRef(bookingRef);
	endforeach;
	
	
	// set the references with inverses that will add to the appropriate collections
	bookingRef.myOperator	:= self.myOperator;
	bookingRef.myTerminal	:= self.myTerminal;
	bookingRef.myProduct	:= self.myProduct;
	bookingRef.myConsignor	:= self.myConsignor;
	bookingRef.myConsignee	:= self.myConsignee;
//	self.myEDIBookingRefTI	:= pProxyBookingRef.myEDIBookingRefTI;
//	self.rawEDIData			:= pProxyBookingRef.rawEDIData;
	
	return bookingRef;	
end;
	
	
	
	

</source>
        <Parameter name="_bookingRefStr" type="String"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_dischargePortCode" type="String"/>
        <Parameter name="_transhipPort" type="CM_Port"/>
        <ReturnType type="CM_BookingRef"/>
    </JadeMethod>
