    </PrimAttribute>
    <JadeMethod name="getEndTsLocalTZ" id="ae32c61a-b627-4d61-812b-ecde9b8a5be7">
        <source>getEndTsLocalTZ() : TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2016	cnwns1	Initial creation
// 07 June 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

begin
	return self.systemToLocalTime(self.endTs);
epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getStartTsLocalTZ" id="a696c2ad-3bfe-419a-912f-cc974b026a8b">
