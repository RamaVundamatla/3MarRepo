    <JadeMethod name="getTerminalAreasFromType" id="cc5557ee-fc5b-4a32-b49b-e75b1eab8a7b">
        <source>getTerminalAreasFromType(_taTypes : CM_TATypeByTypeDict; _taSet : CM_TerminalAreaSet input);

// cnwdvb1 25 June 2003 

vars

	iter	: Iterator;
	term	: CM_Terminal;
	ta		: CM_TerminalArea;
	taType	: CM_TerminalAreaType;

begin

	_taSet.clear();
	term := self.myTerminal;
	foreach taType in _taTypes do
		iter := taType.allTerminalAreasByTerminal.createIterator();
		ta := taType.allTerminalAreasByTerminal.getAtKeyGeq(term, null).CM_TerminalArea;
		//epr 28714 5/12/11
		if ta &lt;&gt; null then
			iter.startAtObject(ta);
		endif;
		while iter.next(ta) do
			if ta.myTerminal &lt;&gt; term then
				break;
			endif;
			_taSet.add(ta.CM_TerminalArea);
		endwhile;
		delete iter;
	endforeach;
		
epilog
	delete iter;
end;</source>
        <Parameter name="_taTypes" type="CM_TATypeByTypeDict"/>
        <Parameter name="_taSet" type="CM_TerminalAreaSet" usage="input"/>
    </JadeMethod>
