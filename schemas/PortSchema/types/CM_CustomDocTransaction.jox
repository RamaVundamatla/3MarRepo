    <JadeMethod name="setDetailsFromCusDoc" id="6f44f25b-7ce6-46fe-98d1-cf9c854dd0bb">
        <updating/>
        <source>setDetailsFromCusDoc(_custDoc : CM_CustomDocument) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/09/2023	navkc1	CR 59934 Task 59935: Jade - Cust Doc Cargo Transactions
17 November 2023 navrv30 #60979: Jade - Transaction and TI Cust Doc Get Methods
*/

vars
	customStatus    : Integer;
begin
	
	if _custDoc = null then
		return;
	endif;
	
	if _custDoc.myCustomsAgent &lt;&gt; null then
		self.custDocAgentCode := _custDoc.myCustomsAgent.code;
		self.custDocAgentName := _custDoc.myCustomsAgent.name;						//17 November 2023 navrv30 #60979
	endif;
	
	self.custDocCode := _custDoc.code;
	self.custDocCancelDT := _custDoc.cancelledTS;									//17 November 2023 navrv30 #60979
	self.custDocCreateDT := _custDoc.createdTS;
	self.custDocDateTime := _custDoc.dateTime;
	self.custDocDirection := _custDoc.direction.String;
	self.custDocExtRef := _custDoc.externalRef1;  
	
	if _custDoc.myHSCode &lt;&gt; null then
		self.custDocHSCode := _custDoc.myHSCode.id;
	endif;
	
	if _custDoc.myCustomLicense &lt;&gt; null then
		self.custDocLicenseCode := _custDoc.myCustomLicense.code;
		self.custDocLicenseDesc := _custDoc.myCustomLicense.description;
	endif;
	
	self.custDocModifyDT := _custDoc.lastModifiedTS;								//17 November 2023 navrv30 #60979
	self.custDocLineNumber := _custDoc.itemNumber;
	self.custDocSequence := _custDoc.sequence.String;
	self.custDocStatus := CM_CustomDocument@getStatusStrFromInt(_custDoc.status); //17 November 2023 navrv30 #60979
	
	if _custDoc.myCustomDocumentType &lt;&gt; null then
		self.custDocTypeCode := _custDoc.myCustomDocumentType.code &amp; " " &amp; CM_CustomDocumentType@getDirectStrFromInt(_custDoc.direction); // ### TFS CR 59942 TASK 59943 04SEP2023 NAVAB1
		self.custDocTypeDesc := _custDoc.myCustomDocumentType.description;           //17 November 2023 navrv30 #60979
	endif;
	
epilog

end;</source>
        <Parameter name="_custDoc" type="CM_CustomDocument"/>
    </JadeMethod>
</Class>
