    <JadeMethod name="initializeForActivity" id="83e4194d-47eb-43c1-b9d9-d22acf527f76">
        <updating/>
        <source>initializeForActivity(_any: Any; _ewsOpsView: CM_EWSActivityOpsview) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Jun 2022	navsp1	Initial creation TFS#53104

*/

vars
	measureType : CM_MeasurementType;
begin
	inheritMethod(_any, _ewsOpsView);
	self.tableName		:= self.Aux_measurement_unit;
	
	if _ewsOpsView.dataAction = BGP_OpsViewWSRequest.OPS_ACTION_DELETE then
		self.gkey		:= self.generateFullGKey(_any, "");
		return;
	endif;
	
	if _any.isKindOf(CM_MeasurementType) then
		measureType	:= _any.CM_MeasurementType;
		measureType.initializeForActivity(_ewsOpsView,self);
	endif;
epilog

end;</source>
        <Parameter name="_any" type="Any"/>
        <Parameter name="_ewsOpsView" type="CM_EWSActivityOpsview"/>
    </JadeMethod>
</Class>
