    <JadeWebServicesMethod name="getCargoTasks" id="bb3ad899-b8ea-423c-80dc-b896ffeee5d5">
        <source>getCargoTasks(cargoTasksRequest : WS_CargoTasksQueryRequest) : WS_CargoTasksResponse webService;

vars
	response		: WS_CargoTasksResponse;
	completedOK		: Boolean;
	terminal		: CM_Terminal;
	user			: CM_User;
	cargo 			: CM_TrackedItem;
	failedDAC 		: CM_DataAccessController;
	
	tasks : CM_ToDoTaskDescBySortKey;
	task : CM_ToDoTask;
	taskDesc : CM_ToDoTaskDesc;
	cargoTask : WS_CargoTask;
	lineStr : String;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	
	terminal := app.myPassport.myTerminal;
	user := app.myPassport.myUser;
	
	if cargoTasksRequest.cargoUid = "" then
		completedOK := true;
		return response;
	endif;
	//epr TFS 5535 4/8/17 
	cargo := app.myPassport.getObjectOfTypeFromOid(cargoTasksRequest.cargoUid,CM_TrackedItem).CM_TrackedItem;
	if cargo = null then
		completedOK := true;
		return response;
	endif;


	// Check security access to this message, if required
	app.checkCurrentUserHasAccess(PmAdmTodotableMaint);		// Replace with appropriate permission
	if app.myPassport.hasErrors then
		completedOK := true;
		return response;
	endif;
	
	// STUFF
	// Load the descriptions 
	if cargoTasksRequest.isSetOnly then
		foreach task in cargo.allToDoTasksToDo do
			create cargoTask transient;
			cargoTask.setProxyFromObject(task);
			cargoTask.isSet := true;
			
			response.allCargoTasks.add(cargoTask);
		endforeach;
	else
		tasks := terminal.myRoot.allToDoTaskDescsBySortOrder;
		
		foreach taskDesc in tasks do
			// Only those tasks for this kind of cargo
			if not taskDesc.isAvailableForCargoType( cargo.cargoType ) then
				continue;
			endif;
			
			//TFS 45392 - Return tasks that the user has permission to add/remove
			if not user.canAddRemoveTodoTask(terminal,taskDesc) then
				continue;
			endif;
						
			lineStr := "";
			if taskDesc.shortDescription = null then
				lineStr := taskDesc.description;
			else
				lineStr := taskDesc.shortDescription;
			endif;
			
			
			create cargoTask transient;
			//cargoTask.description := lineStr;
			// change made to reflect full string description rather than code, 9/3/17
			cargoTask.description := taskDesc.description;
			cargoTask.code := taskDesc.code;
			cargoTask.requiredExtraInfo := taskDesc.requiredExtraInfo;
			cargoTask.hasResources := taskDesc.allResourceTypes.isNotEmpty();
			
			// Put the date in for each completed task
			foreach task in cargo.allToDoTasksCompleted where task.toDoTaskDescDesc = taskDesc.description do
				cargoTask.completedDate := task.dtLastUpdate.asStringForWebInterface;
				//cargoTask.remarks := task.remarks; //jlier1 TFS 53661 15/7/22
			endforeach;
	
			// Mark set tasks
			foreach task in cargo.allToDoTasksToDo where task.toDoTaskDescDesc = taskDesc.description do
				cargoTask.isSet := true;
				cargoTask.remarks := task.remarks;
			endforeach;
	
			response.allCargoTasks.add(cargoTask);
		endforeach;
	endif;
		
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up any local transients
	// ...
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="cargoTasksRequest" type="WS_CargoTasksQueryRequest"/>
        <ReturnType type="WS_CargoTasksResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getCargoToSplitForBooking" id="6d7a16c9-96a0-4543-86c8-919c642a9db6">
        <source>getCargoToSplitForBooking(request : WS_CargoToSplitQueryRequest) : WS_TrackedItemQueryResponse webService;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 15/01/2020	jlgdap1		Initial creation TFS 47457 Web Portal Bookings
//
vars
	response : WS_TrackedItemQueryResponse;
	completedOK : Boolean;
	permissionsToCheck : IntegerArray;
	startFrom : Integer;
	matches	: Integer;
	maxResults : Integer;
	terminal : CM_Terminal;
	booking : CM_BookingRef;
	matchedTIs : CM_TISet;
	ti : CM_TrackedItem;
	wsTI : WS_TrackedItem;
	iter : Iterator;
	failedDAC : CM_DataAccessController;

begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);
	
	cnStartTransaction(method.qualifiedName[1:50]);

	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;

	// Initialise the passport for the new transaction
	// In particular this sets passport myUser and myTerminal
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// check security access
	create permissionsToCheck transient;
	permissionsToCheck.add(PmWebBookingMaint);
	permissionsToCheck.add(PmGteBookingRefMaint);
	app.myPassport.validateUserHasOnePermission(permissionsToCheck);
	if app.myPassport.hasErrors then
		completedOK:=true;
		return response;
	endif;
	
	matches := null;
	maxResults := request.maxReturnedItems;
	if maxResults = null then
		maxResults := 20;
	endif;
	startFrom := request.startFrom;
	
	terminal := app.myPassport.myTerminal;
	
	booking := app.myPassport.getObjectOfTypeFromOid(request.bookingOid, CM_BookingRef).CM_BookingRef;
	if booking = null then
		completedOK := true;
		return response;
	endif;
	
	create matchedTIs transient;
	iter := booking.allTIs.createIterator;
	while iter.next(ti) do
		app.sendHeartbeatIfRequired();
		
		// cargo has to be onsite or a prenote
		if not ti.isOnSite and not ti.isPreNote then
			continue;
		endif;
		if request.cargoID &lt;&gt; null then
			if not ti.id.pos(request.cargoID.toUpper, 1) = 1 then
				continue;
			endif;
		endif;
		if not ti.canUserAccessSelf(app.getMyUser, failedDAC, app.myPassport) then
			continue;
		endif;
		
		if not matchedTIs.includes(ti) then
			matches := matches + 1;
			if matches &lt; startFrom then
				continue;
			endif;
			
			if maxResults &gt; 0 and matches - startFrom = maxResults then
				app.writeLog("Return max results " &amp; matchedTIs.size.String, LogDEBUG);	//26 Nov 2019	NDL	TFS 47053
				completedOK := true;
				return response; //found enough items
			endif;
			
			create wsTI transient;
			wsTI.setProxyFromObject(ti);
			response.allTrackedItems.add(wsTI);
			
			matchedTIs.add(ti);
		endif;
	endwhile;
	
	completedOK := true;
	return response;
	
epilog
	delete iter; 
	delete matchedTIs;
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
end;</source>
        <Parameter name="request" type="WS_CargoToSplitQueryRequest"/>
        <ReturnType type="WS_TrackedItemQueryResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getCargoTypes" id="12b8fc33-8cfa-4bfc-b89a-a025bfcc811b">
        <usesRPC>default</usesRPC>
        <source>getCargoTypes() : WS_CargoTypesResponse webService;

/*

Purpose:			Get all the valid Cargo Types for the current user.

Parameters:			None

Return Value:		


Date		Who		Reason
15 Jul 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application
16 Sep 2008	cnwkao1	modified
16 Jul 2018 cnwma1	Bug 39681: Add Cargo Request includes all Cargo Types
07 may 2020	jlgdap1	TFS 49252 CPL Cargo Types not showing in System Admin
16 Sep 2022 navds21	Bug 54802: MTN - 1090 when reserve details with no subtype added
*/

vars
	response		: WS_CargoTypesResponse;
	completedOK		: Boolean;
	
	cargoBOLType	: CM_CargoBOLType;
	cargoTypeProxy	: WS_CargoType;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Populate response - ex CMUIAssistant::comboBoxCargoTypes
	foreach cargoBOLType in app.myPassport.myTerminal.allCargoBOLTypes do
		if (not CM_CargoType.hasInstance(cargoBOLType)) then //KO - this obviously filters out General Bill of Lading and Log Docket, and I think this is what we want as they are in a different hierarchy in the model
			continue;
		endif;
		
		//Start 16.09.2022 navds21 TFS 54802
		if cargoBOLType.isKindOf(CM_CargoType) and cargoBOLType.CM_CargoType.isSubCargoTypeRequired and cargoBOLType.CM_CargoType.allProducts.size = 0 then			
			continue;
		endif;
		//End 16.09.2022 navds21 TFS 54802
		
		if cargoBOLType.id &gt; TI_CargoBOLType_JMTMax and not app.myRoot.isClientCentrePort then		// TFS 49252
			continue;																				// TFS 49252
		endif;																						// TFS 49252
		
		//16.07.2018 cnwma1	TFS #39681
		if cargoBOLType.CM_CargoType.isNotAvailableForEntry then
			continue;
		endif;
		create cargoTypeProxy transient;
		cargoTypeProxy.setProxyFromObject(cargoBOLType.CM_CargoType);
		
		response.allCargoTypes.add(cargoTypeProxy);
		
	endforeach;
	
	// Got to here, everything is OK
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Get all the valid Cargo Types for the current user.</text>
        <wsdlName>getCargoTypes</wsdlName>
        <ReturnType type="WS_CargoTypesResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getCarriers" id="51f22286-6332-4e13-9f61-39049930419e">
        <usesRPC>default</usesRPC>
        <source>getCarriers() : WS_CarriersResponse webService;

/*

Purpose:			Get all the valid Carriers for the current user.

Parameters:			None

Return Value:		


Date		Who		Reason
15 Jul 2008	cnwkpd1	PAR #17554 - Development of new RIA Web Service application

*/

vars
	response		: WS_CarriersResponse;
	completedOK		: Boolean;
	
	carrier			: CM_Carrier;
	proxyCarrier	: WS_Carrier;
	failedDAC  		: CM_DataAccessController;
	passport		: CM_Passport;
	
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	passport := app.myPassport;
	
	// Populate response - cloned from CMUI_ComboCarrier
	foreach carrier in app.myRoot.allCarriers discreteLock do
		if carrier.isNotAvailableForEntry then
			continue;
		endif;
		
		if not carrier.canUserAccessSelf(null, failedDAC, passport) then
			continue;
		endif;
		
		create proxyCarrier transient;
		proxyCarrier.setProxyFromObject(carrier);
		response.allCarriers.add(proxyCarrier);
		
	endforeach;
	
	
	// Got to here, everything is OK
	completedOK := true;
	return response;
	

epilog
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	
end;</source>
        <text>Get all the valid Carriers for the current user.</text>
        <wsdlName>getCarriers</wsdlName>
        <ReturnType type="WS_CarriersResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getCashDebtors" id="087161d0-0d9a-48ca-95c6-90e8feeb8ce3">
        <source>getCashDebtors() : WS_DebtorsResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 March 2018	jlger1	Initial creation

*/

vars

	response		: WS_DebtorsResponse;
	completedOK		: Boolean;
	proxyDebtor		: WS_Debtor;
	debtor	: CM_Debtor;
	rootCompany	: CM_Bank;
	failedDAC  		: CM_DataAccessController;
begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passDelayType for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	// Populate the response
	rootCompany := app.myRoot.myRootCompany;
	foreach debtor in rootCompany.debtors do
		if not debtor.isCashOnlyDebtor(app.myPassport.myTerminal) then
			continue;
		endif;
		if not debtor.canUserAccessSelf(null,failedDAC,app.myPassport) then
			continue;
		endif;
		create proxyDebtor transient;
		proxyDebtor.setProxyFromObject(debtor);
		response.allDebtors.add(proxyDebtor);
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up transients
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;
	

end;</source>
        <ReturnType type="WS_DebtorsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getClearingAgents" id="6b60c58d-15e0-4ca5-aed6-00daa95d5022">
        <source>getClearingAgents()  : WS_ClearingAgentsResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 March 2018	jlger1	Initial creation

*/

vars

	response		: WS_ClearingAgentsResponse;
	completedOK		: Boolean;
	proxyClearingAgent	: WS_ClearingAgent;
	customsAgent		: CM_CustomsAgent;
	con					: CM_ConsigneeConsignor;
	terminal : CM_Terminal;
	cashDebtorType		: CM_DebtorType;
	failedDAC  			: CM_DataAccessController;
	isConsignor			: Boolean;
begin
// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passDelayType for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	
	// Create the response
	create response transient;
	
	terminal:=app.myPassport.myTerminal;
	if terminal = null then
		completedOK :=true;
		return response;
	endif;
	
	cashDebtorType := terminal.getConfig(CashDebtorType).CM_DebtorType;
	if cashDebtorType = null then
		cashDebtorType := app.myRoot.allDebtorTypes["SDT6"];	// default to customs agent
	endif;
	if cashDebtorType = null then
		completedOK :=true;
		return response;
	endif;
	
	if cashDebtorType.isCustomsAgent then
		foreach customsAgent in app.myRoot.allCustomsAgents do
			if (not customsAgent.canUserAccessSelf(null, failedDAC, app.myPassport) or customsAgent.isNotAvailableForEntry) then
				continue;
			endif;
			if customsAgent.myDebtor = null or not customsAgent.myDebtor.isCashOnlyDebtor( terminal ) then
				continue;
			endif;
			create proxyClearingAgent transient;
			proxyClearingAgent.setProxyFromObject(customsAgent);
			response.allClearingAgents.add(proxyClearingAgent);
		endforeach;
	else
		isConsignor := cashDebtorType.isConsignor;
	
		foreach con in app.myRoot.allConsigneeConsignors do
			if (not con.canUserAccessSelf(null, failedDAC,  app.myPassport)) then
				continue;
			endif;
			if con.isNotAvailableForEntry then
				continue;
			endif;
			if con.debtor = null or not con.debtor.isCashOnlyDebtor( terminal ) then
				continue;
			endif;
			if isConsignor then
				if not con.isConsignor then
					continue;
				endif;
			else
				if not con.isConsignee then
					continue;
				endif;
			endif;
			create proxyClearingAgent transient;
			proxyClearingAgent.setProxyFromObject(con);
			response.allClearingAgents.add(proxyClearingAgent);
		endforeach;
	endif;
	
	// Got to here, everything is ok
	completedOK := true;
	return response;
	

epilog
	// Tidy up transients
	
	if not completedOK then
		cnSetTransactionError(true);
		delete response;				// prevent transient leaks
	endif;
	
	// Copy any errors and warnings to the response before returning it
	if response &lt;&gt; null then
		response.setErrorsFromPassport();
	endif;
	cnEndTransaction;

end;</source>
        <ReturnType type="WS_ClearingAgentsResponse"/>
    </JadeWebServicesMethod>
    <JadeWebServicesMethod name="getColour" id="5343d06d-f9d2-4e01-8a90-a07a9d0599ae">
        <source>getColour() : WS_ColourResponse webService;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 August 2013	cnwmc5	Initial creation

*/


vars
	response 		: WS_ColourResponse;
	pxyColour		: WS_Colour;
	colour			: CM_VehicleColour;
	completedOK 	: Boolean;
	obj				: Object;
begin
	// Need to arm generic exception handlers locally to deal with all unexpected
	// application exceptions and lock exceptions, because the standard global exception handlers
	// are overridden to deal with XML parsing issues
	on Exception do self.handleJADEExceptions(exception);
	on LockException do self.handleLockExceptions(exception);

	cnStartTransaction(method.qualifiedName[1:50]);
	
	// Validate the current session
	if not self.validateCurrentSession(true) then
		return null;
	endif;
	
	// Initialise the passport for the new transaction
	self.initialisePassport();
	
	// Arm exception handler for CM Exceptions
