    <JadeMethod name="setComboValues" id="4686c525-cd5b-406f-b8eb-7210651f626b">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2014	cnwndl1	Initial creation

*/

vars

begin
	_combo.clear;
	_combo.addItem(app.getErrorString(Normal));
	_combo.addItem(app.getErrorString(Void));

	if CM_QIntegerLookupEqual.hasInstance(_queryOperator) then
		_combo.text := self.translateToDisplayValue(_queryOperator.CM_QIntegerLookupEqual.searchValue);
	elseif CM_QIntegerLookupNotEqual.hasInstance(_queryOperator) then
		_combo.text := self.translateToDisplayValue(_queryOperator.CM_QIntegerLookupNotEqual.searchValue);
	endif;

epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="26958678-d468-45a5-ade1-2357d24311da">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars
	intArray	: IntegerArray;
	idx,int	: Integer;
	cmString		: CM_String;
begin

	_tbl.purgeTableObjects();
	_tbl.clear;
	_tbl.rows := _tbl.fixedRows;
	
	create intArray transient;
	
	intArray.add(CM_InvoiceLine.STATUS_NORMAL);
	intArray.add(CM_InvoiceLine.STATUS_VOIDED);
	
	foreach int in intArray do
		create cmString transient;
		cmString.string := self.translateToDisplayValue( int );
		
		if _operator &lt;&gt; null then
			idx := _tbl.addItem(1.String &amp; Tab &amp; cmString.string);
		else
			idx := _tbl.addItem(0.String &amp; Tab &amp; cmString.string);	
		endif;
		_tbl.accessRow(idx).itemObject := cmString;
		_tbl.row := idx;
		_tbl.change(_tbl);	
	endforeach;

epilog
	delete intArray;
end;

</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="af22eb4f-decc-4a86-ba88-4e2060397e34">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars
	str		: String;
	numRows,
	idx		: Integer;
	ia		: IntegerArray;

begin

	create ia transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			str := _tbl.accessCell(idx, 2).text;
			ia.add(self.translateToSearchValue(str).Integer);
		endif;
	endforeach;
	
	_op.setSearchValue(ia);

epilog
	delete ia;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="fb4f0951-194b-4abf-b6aa-1a5ad14cbd8b">
        <source>translateStringToSearchValue(_value: Any; _criteriaLine: CM_SelectorCriteriaLine): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars
	intStatus	: Integer;
	
begin
	if _value.String.isInteger then
		return _value;
	endif;
	
	if _value.String = app.getErrorString(Normal) then
		intStatus := CM_InvoiceLine.STATUS_NORMAL;
	elseif _value.String = app.getErrorString(Void) then
		intStatus := CM_InvoiceLine.STATUS_VOIDED;
	endif;
	
	
	return intStatus;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="55d80c03-d25d-4d95-bb2d-2d2e51bcb219">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2014	cnwndl1	Initial creation

*/

vars

	int : Integer;

begin
	if _value.String.isInteger then
		int := _value.Integer;
		if int = CM_InvoiceLine.STATUS_NORMAL then
			return app.getErrorString(Normal);
		elseif int = CM_InvoiceLine.STATUS_VOIDED then
			return app.getErrorString(Void);
		endif;
	endif;
	
	return _value.String;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="85aa3cfa-580c-436f-9c86-76c2059840bd">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars
	
begin
	if _value.isKindOf(IntegerArray) then
		return _value;
	elseif _value.isKindOf(Integer) then	
		return _value.String;
	endif;
	
	return translateStringToSearchValue( _value.String, null).Integer;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
