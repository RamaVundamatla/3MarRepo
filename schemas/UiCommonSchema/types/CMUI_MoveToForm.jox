    <JadeMethod name="cmbTAType_lostFocus" id="a98bdc43-5bd4-4b6f-9c8c-6c1e28bfc79f">
        <controlMethod name="ComboBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbTAType_lostFocus(combobox: ComboBox input) updating;
//--------------------------------------------------
// Created:	25 August 2003 By: cnwgd1
//--------------------------------------------------
vars
	areaTypeCode : Integer;
	areaType : CM_TerminalAreaType;
begin
	self.tblMove.setValueByControlName(combobox.name, combobox.text);	
	if self.origValueStr &lt;&gt; combobox.text then
		areaTypeCode := TA_TYPE_NULL;
		if combobox.listObject &lt;&gt; null then		
			areaTypeCode := combobox.listObject.CM_TerminalAreaType.type; 
		endif;
		if combobox.text = app.getErrorString(ToVoyage) then //jlier1 TFS 53515 23/5/22 
			self.tblMove.showRowByName(ETRow_CurrentVoyages,false);
			self.tblMove.showRowByName(ETRow_LoadLocation,false);
			self.tblMove.hideRowByName(ETRow_TerminalArea,false);
			self.tblMove.hideRowByName(ETRow_YardLocation,false);
		else
			self.tblMove.hideRowByName(ETRow_CurrentVoyages,false);
			self.tblMove.hideRowByName(ETRow_LoadLocation,false);
			self.tblMove.showRowByName(ETRow_TerminalArea,false);
			self.tblMove.showRowByName(ETRow_YardLocation,false);
			cmbTermArea.gotFocus(self.cmbTermArea);	
			myAssistant.comboBoxTerminalArea(self.cmbTermArea,areaTypeCode,null);
			cmbTermArea.lostFocus(self.cmbTermArea);
		endif;
	endif;
	
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
