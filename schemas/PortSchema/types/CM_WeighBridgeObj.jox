    <JadeMethod name="pxyCreateUpdateProxy" id="891f4a1d-a915-4401-9dd9-fd1e1076a83f">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars
	proxy 		: CM_WeighBridgeObj;
	completedOK	: Boolean;
	
begin

	proxy := inheritMethod();
	
	proxy.myWeighBridgeType := self.myWeighBridgeType;
	proxy.myTerminal := self.myTerminal;
	
	proxy.myGateLane := self.myGateLane;		//TFS3153
	
	proxy.myWeightType := self.myWeightType;	//TFS3153
	
	completedOK := true;
	return proxy;
	
epilog
	if not completedOK then
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
