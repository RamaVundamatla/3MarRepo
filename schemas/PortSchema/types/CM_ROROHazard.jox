        <source>setForCreate(_pxyHaz: CM_Hazard; _locn: CM_ROROLocnDefn; _passport: CM_Passport) updating;
//----------------------------------------------------------------
//	Created:	01 April 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	inheritMethod(_pxyHaz, _locn, _passport);
