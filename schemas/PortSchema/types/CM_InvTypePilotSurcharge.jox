    <JadeMethod name="setForUpdate" id="755f03bf-16b0-46e7-a6ee-4643f9e73714">
        <updating/>
        <source>setForUpdate(_pxyPilotSurcharge : CM_InvTypePilotSurcharge) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 21/06/2018	jlgdap1		Initial creation TFS 38355 PEL1 Pilot Surcharges
//
vars

begin
	self.myPilotSurchargeInvLineTypeVNR := _pxyPilotSurcharge.myPilotSurchargeInvLineTypeVNR;
	self.myPilotSurchargeInvLineTypeRTS := _pxyPilotSurcharge.myPilotSurchargeInvLineTypeRTS;
	
