        <source>xPAR31367StatusBarStepB9() updating;

/*

Purpose:		Load the cargo to the voyage and check that status bar details are correct	

Date			Who		Reason
24/05/2013		cnwmh5	Initial creation

*/
vars

	locnDefnVoyage 						: CM_ROROLocnDefnVoyage;
	slotDefn 							: CM_ROROSlotDefn;
	locnGCDefnVoyage					: CM_ROROGCDefnVoyage;
	slotLC 								: CM_ROROSlotController;
	ti									: CM_TrackedItem;
	roroRequest							: CM_RORORequest;
	job									: CM_Job;
	
	tiArray								: CM_TIArray;
	
	locn								: String;

begin

	app.writeLog("STEP B9", LogINFO);
	app.writeLog("Load the cargo to the voyage.  Please wait...", LogINFO);
	
	// load containers
	self.locationArray.clear();
	self.locationArray.add("D4074");
	self.locationArray.add("D4076");
	self.locationArray.add("D4071");
	self.locationArray.add("D4083");
	self.locationArray.add("D4081");
	self.locationArray.add("D4086");
	self.locationArray.add("D4075");
	self.locationArray.add("D4077");
	self.locationArray.add("D4085");
	self.locationArray.add("D4087");

	self.roroLCs.clear();
	foreach locn in self.locationArray do
	
		locnDefnVoyage := self.myDeck.allROROLocnDefnByCode[locn].CM_ROROLocnDefnVoyage;
		self.assertNotEqual(locnDefnVoyage, null);
		
		foreach slotDefn in locnDefnVoyage.allROROSlotDefnByOrdinal discreteLock do
			slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
			if not slotLC.mySlotDefn.isAvailable then
				continue;
			endif;
			roroRequest := slotLC.myRORORequestLoad;
			if roroRequest &lt;&gt; null then
				ti := roroRequest.getTrackedItem();
				if ti &lt;&gt; null then
					app.writeLog('lc: ' &amp; slotLC.String &amp; Tab &amp; slotLC.ident, LogINFO);
					self.move(ti, slotLC);
					self.assertNoTrxErrorsOrWarnings();
				endif;
			endif;
		endforeach;
	
	endforeach;
	
	
	// load GC
	self.locationArray.clear();
	self.locationArray.add("D4002G");
	
	create tiArray transient;
	self.roroLCs.clear();
	foreach locn in self.locationArray do
	
		locnGCDefnVoyage := self.myDeck.allROROGCDefnByCode[locn].CM_ROROGCDefnVoyage;
		self.assertNotEqual(locnGCDefnVoyage, null);
		
		roroRequest := slotLC.myRORORequestLoad;
		if roroRequest &lt;&gt; null then
			locnGCDefnVoyage.myGCController.getTIs(tiArray, PLANNING_MODE, true);
			foreach ti in tiArray do
				app.writeLog('lc: ' &amp; locnGCDefnVoyage.myGCController.String &amp; Tab &amp; locnGCDefnVoyage.myGCController.ident, LogINFO);
				self.move(ti, locnGCDefnVoyage.myGCController);
				self.assertNoTrxErrorsOrWarnings();
			endforeach;
		endif;
	
	endforeach;
	
	/*
	return;
	// plan GC
