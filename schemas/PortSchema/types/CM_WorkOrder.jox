    <JadeMethod name="pinHasExpired" id="460cffd9-2474-4cf4-a880-d1e7a5e3d22b">
        <source>pinHasExpired():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 June 2018	jlgndl1	Initial creation	TFS 38795

*/

vars

begin

	if self.approvalExpiryTS &lt;&gt; null and self.approvalExpiryTS.isValid then
		//it is expired if the stored time stamp is earlier than the current time
		return ( self.approvalExpiryTS &lt; app.actualTimeAppServer );
	else
		// No date, not expired.
		return false;
	endif;
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
