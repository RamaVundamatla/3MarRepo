    <JadeMethod name="btnPopupEnq_click" id="0ffdd30e-b87f-460d-ac61-dcaef77c6dfc">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnPopupEnq_click(btn: Button input) updating;
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// ---------------------------------------------------------------------------
// 06/11/2012	cnwcs5	par 30475 - remove references to location restrictions, replace YRD_LocationMaintForm constants with YRDPadArea Constants
vars

	theTI 		: CM_TrackedItem;
	theLabour 	: CM_LabourRestriction;
	theSBS 		: CM_BlockStack;
	theObject 	: Object;
begin
	theObject := self.frmPopupInfo.userObject;
	
	if theObject = null then
		return;
	endif;
	
	if theObject.isKindOf(CM_TrackedItem) then
		theTI := theObject.CM_TrackedItem;
		
		self.myAssistant.showCargoEnquiryForm(theTI, self.myMasterMenuAction, true, false);	
		
	elseif theObject.isKindOf(CM_BlockStack) then
		theSBS := theObject.CM_BlockStack;
		
		self.myAssistant.showLocationEnquiryForm(theSBS, self.myMasterMenuAction, false, false);
		
	elseif theObject.isKindOf(CM_LabourRestriction) then
		theLabour := theObject.CM_LabourRestriction;

		self.myAssistant.showRestrictionsForm(theLabour.myTerminalArea,YRD_PadArea.AreaMode_Labour,theLabour,
														self.xmlFlipH,self.xmlFlipV, self.myMasterMenuAction);
	endif;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
