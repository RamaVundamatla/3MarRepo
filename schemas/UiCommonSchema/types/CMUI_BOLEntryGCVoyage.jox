//	self.cmbCargoType.text := '';
	self.cmbProduct.setObject(null);
	self.cmbHatch.text			:= '';
//	self.txtWeight.text			:= '';
	self.txtVolume.text			:= '';
	self.txtQuantity.text		:= '';
	self.txtRemarks.text			:= '';
//	self.txtMarks.text			:= '';
//	self.txtMarksNum.text		:= '';
	self.txtDescription.text	:= '';
	
	self.txtBOLNum.setFocus();
end;</source>
    </JadeMethod>
