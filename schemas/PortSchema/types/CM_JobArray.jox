<CollClass name="CM_JobArray" id="78174e7d-c90c-4f0b-a5d9-04061f801eb2">
    <memberType name="CM_Job"/>
    <superclass name="CM_ObjectArray"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="operatn"/>
    <JadeMethod name="getName" id="0afd1ce4-4c0c-4942-af16-447a449d1d94">
        <source>getName(): String;
// ---------------------------------------------------------------------------
// Created:		29 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aJob : CM_Job;
	tmpID, str : String;
begin

	foreach aJob in self do
		if aJob.isKindOf(CM_VoyageJob) then
			tmpID := aJob.CM_VoyageJob.jobNum;
		else
			tmpID := aJob.jobId;
		endif;
		if str = null then
			str := tmpID;
		else
			str := str &amp; ", " &amp; tmpID;
		endif;
		
	endforeach;
	return str;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTotalRequests" id="3f70e53d-cca3-4b4d-a433-c54f6ab54fcd">
        <source>getTotalRequests(_nonPlnOnly : Boolean) : Integer;
// ---------------------------------------------------------------------------
// Created:		30 August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aJ : CM_Job;
	idx : Integer;
		aReq : CM_Request;
begin
	foreach aJ in self do
		if _nonPlnOnly then // ##### NON PLANNED ONLY
			foreach aReq in aJ.allRequests discreteLock do : reqLoop
				if aReq.isKindOf(CM_SlotRequest) then
					if not aReq.hasTIsOfMode(PLANNING_MODE) then
						idx := idx + aReq.allWorkListEntries.size;
					endif;
				else
					idx := idx + aReq.allWorkListEntries.size;
				endif;
			endforeach;
		else
			idx := idx + aJ.allRequests.size;
		endif;
	endforeach;
	
	return idx;
end;</source>
        <Parameter name="_nonPlnOnly" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</CollClass>
