    <JadeMethod name="doGetVehicleDetails" id="7405d4bc-8b71-400f-934a-17a507420782">
        <updating/>
        <source>doGetVehicleDetails(_reg : String) protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	24 October 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	errorMsgs			: MobileHandHeldThin::DTO_HandHeldGateErrorDict;
	errorMsg			: MobileHandHeldThin::DTO_HandHeldGateError;
	numRecievals,
	numReleases			: Integer;
	inJob				: Boolean;
	gateLaneStr			: String;
	
begin
	self.lblJobInfo.caption := 'Waiting for vehicle ID match...';
	create errorMsgs transient;
	self.numButtons := 0;
	app.myHandHeldGateGuiAgent.doGetVehicleDetails(_reg, 
													numRecievals,
													numReleases,
													inJob,
													gateLaneStr,
													errorMsgs);

	//82145 = vehicle doesn't exist
	errorMsg := errorMsgs.last;
	if errorMsg &lt;&gt; null then
		self.lblJobInfo.caption := errorMsg.errorDescr;
	else
		self.lblJobInfo.caption := 'Truck is in gate lane ' &amp; gateLaneStr;
		
		if inJob then
			self.numButtons := numRecievals;
			if numRecievals = null then
				self.lblJobInfo.caption := self.lblJobInfo.caption &amp; CrLf &amp; 'No Containers on truck';
			else
				self.spawnInputForVehicle(self.numButtons);
			endif;
		else
			self.numButtons := numReleases;
			if numReleases = null then
				self.lblJobInfo.caption := self.lblJobInfo.caption &amp; CrLf &amp; 'No Containers on truck';
			else
				self.spawnInputForVehicle(self.numButtons);
			endif;
		endif;
	endif;
	
epilog
	delete errorMsgs;
end;


</source>
        <access>protected</access>
        <Parameter name="_reg" type="String"/>
    </JadeMethod>
