    <JadeMethod name="buildMovementsToValidateCol" id="1fe29f04-03dd-45d4-8586-59f74ac4e0c2">
        <source>buildMovementsToValidateCol();
//--------------------------------------------------
// Created:	02 May 2005 By: cnwgd1
//--------------------------------------------------
vars
	moveStart,
	moveEnd : TimeStamp;
begin
	self.allMovementsToValidate.clear();
	if self.myHarbour = null then
		return;
	endif;
	moveStart := self.portDate_From.cnEcAddDays(-self.myHarbour.shippingReportOffsetDays);
	moveEnd := self.portDate_To.cnEcAddDays(self.myHarbour.shippingReportOffsetDays);
	//self.myHarbour.buildMoveCollToValidate(self.allMovementsToValidate, moveStart, moveEnd);
	
	//epr par 14983 7/11/07 using new method that starts iterator at moveStart
	self.myHarbour.buildMoveCollForDateRange(self.allMovementsToValidate, moveStart, moveEnd);

end;</source>
    </JadeMethod>
    <JadeMethod name="doPrinting" id="7aa9be1f-0574-4a63-af35-350ef874d2e9">
        <updating/>
        <source>doPrinting(str:String;int:Integer io) updating;
constants
	Background : Integer = 15724527;
vars

begin
	// print the frame - advance page if frame wont fit
	if not app.printer.frameFits(fTableBody) then
		app.printer.newPage;
		app.printer.print(fBlank);
		app.printer.print(fTableHeader);
		//txtHeading.text := headText &amp; ' - continued';
		//app.printer.print(fHeading);
		int := 1;
	endif;
	// shade every alternate line
	//tableBody.accessMode := Table.AccessMode_Row;
	/*if int mod 2 = 0 then
		tableBody.fontBold	 := false;
	else
		tableBody.fontBold	 := true;
		tableBody
	endif;*/
	int := int + 1;


	// print the body of the table
	tableBody.accessMode := Table.AccessMode_Cell;
	tableBody.column := 1;
	tableBody.row 	 := 1;
	tableBody.text := str;
	app.printer.print(fTableBody);
end;</source>
        <Parameter name="str" type="String"/>
        <Parameter name="int" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getTidesForDay" id="bfddb1fa-9ee9-45d0-8b18-9e5a3a92d664">
        <updating/>
        <source>getTidesForDay(dateForTides:TimeStamp; tide1: String io; tide2: String io; tide3: String io; tide4: String io; draftChkPoint: HMS_CheckPoint io) updating;

vars
	highLow: 		Integer;
	timeOfTide:		TimeStamp;
	timeToTest:		TimeStamp;
	t1:				TimeStamp;
	t2:				TimeStamp;
	t3:				TimeStamp;
	t4:				TimeStamp;
	t1_HL_State:	Integer;
	t2_HL_State:	Integer;
	t3_HL_State:	Integer;
	t4_HL_State:	Integer;
	timeStep:		Time;
	lastTideAt:		TimeStamp;
	numTidesFound:	Integer;
	tideTolerance:	Time;
begin
	// This method returns 4 strings describing the tides on the given day 

	// Get tides
	timeToTest:=(dateForTides.date.String &amp; ", 00:00:00".String).TimeStamp;
	numTidesFound:=0;

	// Set tide tolerance to 1hr - ie if the next tide found is not at least 1hr different from the last 
	// tide found, then it is considered to be the same tide.
	tideTolerance:="01:00:00".Time;	

	// Set time test step to 3hrs
	timeStep:="03:00:00".Time;

	while timeToTest.date=dateForTides.date do
		app.myHMSRvTide.getNearestHighLowTide(draftChkPoint,timeToTest,timeOfTide,highLow);
		
 		if timeOfTide.date=dateForTides.date then
 			// Tide is on the correct day, check to see if tide has already been found  	
 			if numTidesFound=0 then
 				// This is the first tide of the day
 				t1:=timeOfTide;
 				t1_HL_State:=highLow;
 				numTidesFound:=1;
 				lastTideAt:=t1;
 			else
 				// Check that the new tide that has been found is not the same as the last tide found
 				if timeOfTide&gt;(lastTideAt+timeStep) or timeOfTide&lt;(lastTideAt-timeStep) then
 					// Tide is different
 					if numTidesFound=1 then
 						// The tide we have found is the 2nd tide of the day
 						t2:=timeOfTide;
 						t2_HL_State:=highLow;
 						lastTideAt:=t2;
 					elseif numTidesFound=2 then
 						// The tide we have found is the 3rd tide of the day
 						t3:=timeOfTide;
 						t3_HL_State:=highLow;
 						lastTideAt:=t3;
 					else
 						// The tide we have found is the 4th tide of the day
 						t4:=timeOfTide;
 						t4_HL_State:=highLow;
 						lastTideAt:=t4;
 					endif;
 					numTidesFound:=numTidesFound+1;
 				else
 					// Same tide
 				endif;
 			endif;
 		else
 			// Tide is on wrong day
 		endif;
 		timeToTest:=timeToTest+timeStep;
 	endwhile;

 	// Generate return strings
 	// 1st tide of the day
 	if t1_HL_State=TideHigh then
 		tide1:=t1.Time.userFormat($CM_HMS_Time24Hour) &amp; " H";
 	else		
    	tide1:=t1.Time.userFormat($CM_HMS_Time24Hour) &amp; " L";
    endif;

    // 2nd tide of the day
 	if t2_HL_State=TideHigh then
 		tide2:=t2.Time.userFormat($CM_HMS_Time24Hour) &amp; " H";
 	else		
    	tide2:=t2.Time.userFormat($CM_HMS_Time24Hour) &amp; " L";
    endif;

    // 3rd tide of the day
 	if t3_HL_State=TideHigh then
 		tide3:=t3.Time.userFormat($CM_HMS_Time24Hour) &amp; " H";
 	else		
    	tide3:=t3.Time.userFormat($CM_HMS_Time24Hour) &amp; " L";
    endif;

    // 4th tide of the day
    if numTidesFound=4 then
 		if t4_HL_State=TideHigh then
 			tide4:=t4.Time.userFormat($CM_HMS_Time24Hour) &amp; " H";
 		else		
  		  	tide4:=t4.Time.userFormat($CM_HMS_Time24Hour) &amp; " L";
  	  	endif;
  	else
  		// No fourth tide found
  		tide4:="";
  	endif;

end;</source>
        <Parameter name="dateForTides" type="TimeStamp"/>
        <Parameter name="tide1" type="String" usage="io"/>
        <Parameter name="tide2" type="String" usage="io"/>
        <Parameter name="tide3" type="String" usage="io"/>
        <Parameter name="tide4" type="String" usage="io"/>
        <Parameter name="draftChkPoint" type="HMS_CheckPoint" usage="io"/>
    </JadeMethod>
    <JadeMethod name="initialReportSetup" id="ac81f0cd-dcbd-4515-b281-794876d1d9fc">
        <updating/>
        <source>initialReportSetup() updating;

vars
	today : TimeStamp;
	usr  : String;
begin


	if app.getMyUser &lt;&gt; null then
		usr := app.getMyUser.userName;
	else
		usr := '** User Not Defined **';
	endif;		

	lblReportTitle.caption 	:= 'WORK ORDERS REPORT';
	lblRepDateTitle.caption:="Period " &amp; portDate_From.date.format("ddd dd MMM") &amp; " " &amp; portDate_From.Time.userFormat($CM_HMS_Time24Hour) &amp; " to " &amp; portDate_To.date.format("ddd dd MMM") &amp; " " &amp; portDate_To.Time.userFormat($CM_HMS_Time24Hour); 

	// Setup and load tide table
	setupTideTable;
	loadTideTable;

	txtFooterLeft.text 		:= "Printed: " &amp; today.date.format("ddd dd MMM") &amp; " " &amp; today.Time.userFormat($CM_HMS_Time24Hour);
	txtHeaderLeft.text 		:= 'Work Orders Report';
	txtHeaderRight.text 	:= 'Printed by: ' &amp; usr;
	app.printer.setHeader(fHeader);
	app.printer.setFooter(fFooter);

	tableHeader.accessMode  := Table.AccessMode_Row;
	tableHeader.rowHeight[1]:= 40;
	tableHeader.gridLines	:= false;
	tableBody.borderStyle 	:= Table.BorderStyle_None;
	tableBody.gridLines		:= true;
    tableBody.fontBold := true;
end;</source>
    </JadeMethod>
    <JadeMethod name="loadTideTable" id="432c220c-b06e-4027-a50b-319e076e722e">
        <updating/>
        <source>loadTideTable() updating, protected;

vars
	
	timeOfTide:		TimeStamp;
	highLow:		Integer;
	region: 		HMS_HarbourRegion;
	chkPoint:		HMS_CheckPoint;
	draftChkPoint:	HMS_CheckPoint;
	tide1:			String;
	tide2:			String;
	tide3:			String;
	tide4:			String;
	nextDay:		TimeStamp;


begin
	// This method loads the tides into the tidal table at the top of the report

	// --------------------------------------------------------------------------------
	// NOTE: uses the first harbour region with a draft checkpoint
	foreach region in self.myHarbour.allRegions do
		draftChkPoint:=region.myHeightCheckpoint;
		/*
		if region.hasCheckpointAssociated() then
			foreach chkPoint in region.allCheckpoints do
				if chkPoint.isKindOf(HMS_CheckPoint) then
					draftChkPoint:=chkPoint.HMS_CheckPoint;
				endif;
			endforeach;
		endif;
		*/
	endforeach;
	// Modified by Russell 05/05/99
	// --------------------------------------
	// Get tides for first day of report
	self.getTidesForDay(portDate_From,tide1,tide2,tide3,tide4,draftChkPoint);

	// Set name for first days tides eg "Mon"
	tableTides.row:=1;
	tableTides.column:=1;
	tableTides.text:=portDate_From.date.format("ddd");

	// Set tide values for first day
	tableTides.column:=2;
	tableTides.row:=1;
	tableTides.text:=tide1;
	tableTides.row:=2;
	tableTides.text:=tide2;
	tableTides.row:=3;
	tableTides.text:=tide3;
	tableTides.row:=4;
	tableTides.text:=tide4;

	// Get tides for next day of report
//	nextDay:=((((portDate_From.date).Date)+1).date.shortFormatJMT() &amp; ", " &amp; portDate_From.Time.String).TimeStamp;
	nextDay.setDate(portDate_From.date+1);
	nextDay.setTime(portDate_From.Time);
	
	getTidesForDay(nextDay,tide1,tide2,tide3,tide4,draftChkPoint);

	// Set name for first days tides eg "Tue"
	tableTides.row:=1;
	tableTides.column:=3;
	tableTides.text:=nextDay.date.format("ddd");

	// Set tide values for next day
	tableTides.column:=4;
	tableTides.row:=1;
	tableTides.text:=tide1;
	tableTides.row:=2;
	tableTides.text:=tide2;
	tableTides.row:=3;
	tableTides.text:=tide3;
	tableTides.row:=4;
	tableTides.text:=tide4;

	// Load user entries for Pilot, Tugmaster, Supervisior and Launchmaster
	tableTides.column:=6;
	tableTides.row:=1;
	tableTides.text:=textPilot;
	tableTides.row:=2;
	tableTides.text:=textTugmaster;
	tableTides.row:=3;
	tableTides.text:=textSupervisor;
	tableTides.row:=4;
	tableTides.text:=textLaunchmaster;
	// --------------------------------------
 	// --------------------------------------------------------------------------------


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="printWorkOrdersReport" id="f8a057c5-bf83-4d87-94eb-c274944d8948">
        <updating/>
        <source>printWorkOrdersReport() updating, protected;

// CCMS 1020 Remove unnessesary decimal points (i.e. if .00) with cnEcStripDecimalZeros
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks
20 jan 2014	cnwdap1	PAR #33337 CCMS PTR 2214 HMS Enhancements
17/06/2014	cnwdap1	PAR #34206 Remove beginLock / endLock stuff - nested locks that weren't being cleared 
					(because they hit a continue in the while loop) were leaving locks.
*/

vars
	iter: 			Iterator;
	voyageData: 	HMS_VoyageData;
	mov,movePrev: 	HMS_VoyageMovement;
	str,sDay,sVesselName,sMovePlanSide,sLineTime,sPilotLaunch,sTugTime,sTugs,sAgent: String;
	sLOA,sStemToBridge,sBow,sBridge,sStern,sFwd,sAft,sComments: String;
	int: 			Integer;
	date:		 	TimeStamp;
	tug:			HMS_Tug;
	offsetTime:		Time;
	orderTime:		Time;
	overlapsWharf,
	fromToLogical:	Boolean;
	foreClear,
	aftClear:		Decimal[12,2];
	extraInfo:		String;
    colWidth : Integer;
begin
	app.printer.print(fBlank);
	app.printer.print(fTableHeader);
	//txtHeading.text := headText;
	//app.printer.print(fHeading);	
	int := 1;


	iter := self.myHarbour.allVoyageMovements.createIterator;
	self.myHarbour.allVoyageMovements.startKeyGeq(portDate_From, iter);
	while iter.next(mov) do

		//beginLock;									// PAR #34206
		if mov.occursOnDTNEW &lt;= portDate_To then
			date:=mov.occursOnDTNEW;
			// Set movement day
			sDay:=date.date.format("ddd");

			// Set vessel name
			voyageData:=mov.myHMSVoyageData;
			sVesselName:=voyageData.myVoyage.vesselName;


			// -------------------------------------------------------------------------------------------
			// Set the details for arrival/shift/departure berth and ship orientation
			// Reset fromToLogical
			fromToLogical:=false;

			movePrev:=null;
			// ARRIVAL Movement
			if mov.moveType=HMSMovementTypeArrival then
				if mov.getMyBerth.noMarineServices=true then
					// Arrival to logical berth eg. 'Roadstead' or 'Non-booked'
					fromToLogical:=true;
					sMovePlanSide:="Arrv " &amp; mov.getMyBerth.code;
				else
					// Arrival to a physical berth
					sMovePlanSide:="In " &amp; mov.getMyBerth.code;
					// Add orientation
					if mov.sideTo = OrientPortSideTo then
						sMovePlanSide:=sMovePlanSide &amp; " P  ";
					else
						sMovePlanSide:=sMovePlanSide &amp; " S  ";
					endif;
				endif;
			// DEPARTURE Movement
			elseif mov.moveType=HMSMovementTypeDeparture then
				movePrev:= voyageData.allVoyageMovements.getAtKeyLss(date).HMS_VoyageMovement;			
				if movePrev &lt;&gt; null then
					if  movePrev.isLogicalBerth() then
						fromToLogical:=true;
						// Departure from a logical berth eg. 'Roadstead' or 'Non-booked'
						sMovePlanSide:="Dept " &amp; movePrev.getMyBerth.code;
					else
					 	// Departure from a physical berth
					 	sMovePlanSide:="Out " &amp; movePrev.getMyBerth.code;
						// Add orientation: AJA 29/3/00 For departures from physical berth, it should show the
						//current orientation of the ship on the berth (ie the side of the last movement)
						if movePrev.sideTo = OrientPortSideTo then
							sMovePlanSide:=sMovePlanSide &amp; " P  ";
						else
							sMovePlanSide:=sMovePlanSide &amp; " S  ";
						endif;
					endif;
				endif;
			// SHIFT Movement	
			else
				movePrev:= voyageData.allVoyageMovements.getAtKeyLss(date).HMS_VoyageMovement;			
				if movePrev &lt;&gt; null then
					if mov.getMyBerth.noMarineServices=true and movePrev.getMyBerth.noMarineServices=true then
						fromToLogical:=true;
						sMovePlanSide:="Shft " &amp; mov.getMyBerth.code;
					else
						if mov.getMyBerth.noMarineServices=true then 
							sMovePlanSide:="Out " &amp; movePrev.getMyBerth.code;
							extraInfo := "To " &amp; mov.getMyBerth.code &amp; ".";
						elseif movePrev.getMyBerth.noMarineServices=true then
							sMovePlanSide:="In " &amp; mov.getMyBerth.code;
							extraInfo := "From " &amp; movePrev.getMyBerth.code &amp; ".";
						else
							sMovePlanSide:="Shft " &amp; mov.getMyBerth.code;
							extraInfo := "From " &amp; movePrev.getMyBerth.code;
							if movePrev.sideTo = OrientPortSideTo then
								extraInfo:=extraInfo &amp; " P.  ";
							else
								extraInfo:=extraInfo &amp; " S.  ";
							endif;
						endif;  //AJA 7/8/00: This is my mod to the report for anchored vessels !!

						if (not mov.isLogicalBerth()) then
							// Add orientation
							if mov.sideTo = OrientPortSideTo then
								sMovePlanSide:=sMovePlanSide &amp; " P  ";
							else
								sMovePlanSide:=sMovePlanSide &amp; " S  ";
							endif;
						endif;	
					endif;
				endif;		//movePrev &lt;&gt; null	
			endif;	
			// -------------------------------------------------------------------------------------------


			// Set lines time 
 			if mov.relativeOrderTimeLines&lt;0 then
 				offsetTime.setTime(0,((mov.relativeOrderTimeLines)*-1),0,0);
 				orderTime:=(mov.occursOnDTNEW-offsetTime).Time;
 			else
 				offsetTime.setTime(0,(mov.relativeOrderTimeLines),0,0);
 				orderTime:=(mov.occursOnDTNEW+offsetTime).Time;
 			endif;
 			sLineTime:=orderTime.Time.userFormat($CM_HMS_Time24Hour);

 			// Set tugs time
 			if mov.relativeOrderTimeTugs&lt;0 then
 				offsetTime.setTime(0,((mov.relativeOrderTimeTugs)*-1),0,0);
 				orderTime:=(mov.occursOnDTNEW-offsetTime).Time;
 			else
 				offsetTime.setTime(0,(mov.relativeOrderTimeTugs),0,0);
 				orderTime:=(mov.occursOnDTNEW+offsetTime).Time;
 			endif;
 			if mov.locationTug=AlongSide then
 				sTugTime:="(A)  " &amp; orderTime.Time.userFormat($CM_HMS_Time24Hour);
 			else
 				sTugTime:="(O)  " &amp; orderTime.Time.userFormat($CM_HMS_Time24Hour);
 			endif;

 			// Set pilot launch time 
 			// Modified by Russell 07/04/99
 			// ---------------------------------------------------------------------------------------------
 			if mov.pilotExempt=false then
 				// Check to see whether vessel is moving between physical whaves - if so, launch not required
 				if mov.moveType=HMSMovementTypeShift then
 					if movePrev&lt;&gt;null then
 						if mov.isLogicalBerth()
 						or movePrev.isLogicalBerth() then
 							if mov.relativeOrderTimePlaunch&lt;0 then
 								offsetTime.setTime(0,((mov.relativeOrderTimePlaunch)*-1),0,0);
 								orderTime:=(mov.occursOnDTNEW-offsetTime).Time;
 							else
 								offsetTime.setTime(0,(mov.relativeOrderTimePlaunch),0,0);
 								orderTime:=(mov.occursOnDTNEW+offsetTime).Time;
 							endif;
 							if mov.locationPilotLaunch=AlongSide then
 								sPilotLaunch:="(A)  " &amp; orderTime.Time.userFormat($CM_HMS_Time24Hour);
 							else
 								sPilotLaunch:="(O)  " &amp; orderTime.Time.userFormat($CM_HMS_Time24Hour);
 							endif;
 						else
 							sPilotLaunch:=app.getErrorString(Dash);
 						endif;
 					else
 						sPilotLaunch:=app.getErrorString(Dash);
 					endif;
   				else
   					if mov.relativeOrderTimePlaunch&lt;0 then
 						offsetTime.setTime(0,((mov.relativeOrderTimePlaunch)*-1),0,0);
 						orderTime:=(mov.occursOnDTNEW-offsetTime).Time;
 					else
 						offsetTime.setTime(0,(mov.relativeOrderTimePlaunch),0,0);
 						orderTime:=(mov.occursOnDTNEW+offsetTime).Time;
 					endif;
 					if mov.locationPilotLaunch=AlongSide then
 						sPilotLaunch:="(A)  " &amp; orderTime.Time.userFormat($CM_HMS_Time24Hour);
 					else
 						sPilotLaunch:="(O)  " &amp; orderTime.Time.userFormat($CM_HMS_Time24Hour);
 					endif;
 				endif;
   			else
    			sPilotLaunch:=app.getErrorString(Dash);
   			endif;
   			// ---------------------------------------------------------------------------------------------

   			if fromToLogical=true then 
   				sLineTime:=app.getErrorString(Dash);	
   				sTugTime:=app.getErrorString(Dash);	
   				sPilotLaunch:=app.getErrorString(Dash);	
   				continue;
   			endif;

			// -------------------------------------------------------------------------------------------


            // Set tugs used
 			foreach tug in mov.allTugsUsed do
 				sTugs:=sTugs &amp; tug.description[1:3] &amp; ", ";
 			endforeach;
 			if mov.allTugsUsed.size&gt;0 then
 				// trim last comma
				sTugs:=sTugs.String[1:((sTugs.length)-2)];
			else
				// Tugs not required - set Tug Order Time to not required
				sTugTime:=app.getErrorString(Dash);

			endif;


			// Set agent for movement
			if mov.isAgentDefault=true then
				// Agent is default customer for this movement
				if mov.myShippingAgent &lt;&gt; null then
					sAgent := mov.myShippingAgent.description;
					if sAgent.length &gt; 4 then
						sAgent := sAgent[1:4];
					endif;
				else
					sAgent := app.getErrorString(Dash);
				endif;
			else
				// ShippingLine is default customer for this movement
				if mov.myShippingLine &lt;&gt; null then
					sAgent := mov.myShippingLine.description[1:3];
				else
					sAgent := app.getErrorString(Dash);
				endif;
			endif;
			//vesselData := voyageData.getMyHMSVesselData();
			sLOA := voyageData.dim_LengthOverall.rounded().asStringJMT;

			if mov.moveType=HMSMovementTypeDeparture and movePrev&lt;&gt;null then
				// Departure movement - use marks for 'departing from berth' 
				sBow	:= movePrev.bowMarkTo.rounded().asStringJMT;
				sStern	:= movePrev.sternMarkTo.rounded().asStringJMT;
				if movePrev.bowMarkTo&gt;movePrev.sternMarkTo then
					sBridge	:= (movePrev.bowMarkTo - voyageData.dist_BridgeToBow).rounded().asStringJMT;
				else	
					sBridge	:= (movePrev.bowMarkTo + voyageData.dist_BridgeToBow).rounded().asStringJMT;
				endif;

				// Get clearances at time of departure
				// Reset clearances 
				//mov.calcClearancesAtMoveTime(foreClear,aftClear);
				//added for par 15929
/*				if not mov.getMyBerth().isVisibleOnView then // dh 20/3/2008 par 15929 backed out
					foreClear := ClearanceNotApplicable;
					aftClear := ClearanceNotApplicable;
				else
*/					foreClear := null;
					aftClear := null;
//				endif;
				//add end
				
				overlapsWharf := false;
				//Par12764 Get the same clearances as movement that put this vessel here.
				mov.getForeAftClearances(self.allMovementsToValidate, foreClear, aftClear, overlapsWharf);				
				// par 16146 put this back
				//movePrev.getForeAftClearances(self.allMovementsToValidate, foreClear, aftClear, overlapsWharf);				
				
				if foreClear = ClearanceUnbounded then
					sFwd	:= app.getErrorString(Dash);
			//	elseif foreClear = ClearanceNotApplicable then//added for par 15929
			//		sFwd	:= app.getErrorString(NotApplicable); // dh 20/3/2008 par 15929 backed out
				else
		 		   	sFwd	:= foreClear.cnEcStripDecimalZeros().String;
		 	   	endif;	
				
	 			if aftClear = ClearanceUnbounded then
	 				sAft	:= app.getErrorString(Dash);
	 		//	elseif aftClear = ClearanceNotApplicable then//added for par 15929
			//		sAft	:= app.getErrorString(NotApplicable);// dh 20/3/2008 par 15929 backed out
				else
	 				sAft	:= aftClear.cnEcStripDecimalZeros().String;	
	 			endif;
				/*
				if movePrev.foreClearanceTo = ClearanceUnbounded then
					sFwd	:= app.getErrorString(TGAUnlimitedClearance);
				else	
		 		   	sFwd	:= movePrev.foreClearanceTo.String;
		 	   	endif;	
	 			if movePrev.aftClearanceTo = ClearanceUnbounded then
	 				sAft	:= app.getErrorString(TGAUnlimitedClearance);
	 			else
	 				sAft	:= movePrev.aftClearanceTo.String;	
	 			endif;
	 			*/
			else	
				// Arrival or Shift movement - use marks for 'arrv/shift to berth'
				sBow	:= mov.bowMarkTo.rounded().asStringJMT;
				sStern	:= mov.sternMarkTo.rounded().asStringJMT;
				if mov.bowMarkTo&gt;mov.sternMarkTo then
					sBridge	:= (mov.bowMarkTo - voyageData.dist_BridgeToBow).rounded().asStringJMT;
				else	
					sBridge	:= (mov.bowMarkTo + voyageData.dist_BridgeToBow).rounded().asStringJMT;
				endif;

				// Get clearances at time of departure
				// Reset clearances 
				//mov.calcClearancesAtMoveTime(foreClear,aftClear);
				foreClear := null;
				aftClear := null;
				overlapsWharf := false;
				mov.getForeAftClearances(self.allMovementsToValidate, foreClear, aftClear, overlapsWharf);								
				if foreClear = ClearanceUnbounded then
					sFwd	:= app.getErrorString(Dash);
				else	
		 		   	sFwd	:= foreClear.rounded().asStringJMT;
		 	   	endif;	
	 			if aftClear = ClearanceUnbounded then
	 				sAft	:= app.getErrorString(Dash);
	 			else
	 				sAft	:= aftClear.rounded().asStringJMT;	
	 			endif;
				/*

				if mov.foreClearanceTo = ClearanceUnbounded then
					sFwd	:= app.getErrorString(TGAUnlimitedClearance);
				else	
		 		   	sFwd	:= mov.foreClearanceTo.String;
		 	   	endif;	
	 			if mov.aftClearanceTo = ClearanceUnbounded then
	 				sAft	:= app.getErrorString(TGAUnlimitedClearance);
	 			else
	 				sAft	:= mov.aftClearanceTo.String;	
	 			endif;
	 			*/
    		endif;

			if voyageData.dist_BridgeToBow&lt;1 then
            	sStemToBridge:=app.getErrorString(Dash);
            	sBridge:=app.getErrorString(Dash);
			else
				sStemToBridge:=voyageData.dist_BridgeToBow.String;
			endif;



	 		if mov.moveType&lt;&gt;HMSMovementTypeDeparture and mov.isLogicalBerth() then
				// Arrival or shifting to a logical berth - marks are not applicable
				sBow:=app.getErrorString(Dash);
				sBridge:=app.getErrorString(Dash);
				sStemToBridge:=app.getErrorString(Dash);
				sStern:=app.getErrorString(Dash);
				sFwd:=app.getErrorString(Dash);
				sAft:=app.getErrorString(Dash);
			elseif mov.moveType=HMSMovementTypeDeparture and movePrev&lt;&gt;null then
				if movePrev.isLogicalBerth() then
					// Departing from a logical berth - marks are not applicable
					sBow:=app.getErrorString(Dash);
					sStemToBridge:=app.getErrorString(Dash);
					sBridge:=app.getErrorString(Dash);
					sStern:=app.getErrorString(Dash);
					sFwd:=app.getErrorString(Dash);
					sAft:=app.getErrorString(Dash);
				endif;
			endif;

			//sComments:= extraInfo &amp; " " &amp; voyageData.shortComment;				// PAR #33337
			sComments:= extraInfo &amp; " " &amp; voyageData.shortComment &amp; mov.remarks;	// PAR #33337

            tableBody.alignment := Table.Alignment_Left;

			// print the line
			str := sDay &amp; Tab &amp; sVesselName &amp; Tab &amp; sMovePlanSide &amp; Tab &amp; sLineTime;
			str := str &amp; Tab &amp; sPilotLaunch &amp; Tab &amp; sTugTime &amp; Tab &amp; sTugs &amp; Tab &amp; sAgent;
			str := str &amp; Tab &amp; sLOA &amp; Tab &amp; sStemToBridge &amp; Tab &amp; sBow &amp; Tab &amp; sBridge &amp; Tab &amp; sStern; 
			str := str &amp; Tab &amp; sFwd &amp; Tab &amp; sAft &amp; Tab &amp; "";
			doPrinting(str,int);

			/* AJA 21/11/00: Changes to the work orders report
			Comments are now printed on the formerly blank line below each entry in the report
			Comments are not bold and are right justified. Column 1 is 
			temporarily extended to cover the width of the report			
			*/

			tableBody.accessMode	:= Table.AccessMode_Column;
			tableBody.column := 01;
			colWidth := tableBody.columnWidth[01];
			tableBody.columnWidth[01] := tableBody.width.Integer;
            tableBody.fontBold :=  false;
            //tableBody.fontItalic := true;
            tableBody.alignment := Table.Alignment_Right;

		//	str:= sComments &amp; Tab &amp; "" &amp; Tab &amp; "" &amp; Tab &amp; "" &amp; Tab &amp; "" &amp; Tab &amp; "" &amp; Tab &amp; "" &amp; Tab &amp; "" &amp; Tab &amp; "" &amp; Tab;
		//	str:=str &amp; "" &amp; Tab &amp; "" &amp; Tab &amp; "" &amp; Tab &amp; "" &amp; Tab &amp; "" &amp; Tab &amp; "" &amp; Tab &amp; ""; 
			str:=sComments;
			doPrinting(str,int);

			tableBody.accessMode	:= Table.AccessMode_Column;
			tableBody.column := 01;
			tableBody.columnWidth[01] := colWidth;
			tableBody.fontBold := true;
			//tableBody.fontItalic := false;
			tableBody.alignment := Table.Alignment_Left;

			// reset variables
			str:=null;
			sDay:=null;
			sVesselName:=null;
			sMovePlanSide:=null;
			sLineTime:=null;
			sPilotLaunch:=null;
			sTugTime:=null;
			sTugs:=null;
			sAgent:=null;
			sLOA:=null;
			sBow:=null;
			sBridge:=null;
			sStern:=null;
			sFwd:=null;
			sAft:=null;
			extraInfo := null;

		else
			break;
		endif;
		//endLock;							// PAR #34206
	endwhile;

epilog
	//endLock;								// PAR #34206
	delete iter;			// PAR #26678
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="processReport" id="1943614e-0b4d-4781-9044-bd42d37754f0">
        <updating/>
        <source>processReport() updating;

vars
//	pxyJadeReport		: JadeReport;	// cnwvu1 commented - 5/12/2006 PAR13089
begin

	self.picTitleLogo.picture := app.getPicLogoPort();	
//	create pxyJadeReport transient;		// cnwvu1 commented - 5/12/2006 PAR13089
//	app.printer.printPreview := true;
//	app.printer.setReport(pxyJadeReport);	

 	// setup the report headings etc
	self.initialReportSetup();

	// print the initial report header and attributes strips
	app.printer.print(fTitleTop);
	app.printer.print(fTitleSep);

	// print the report
	if self.portDate_From &lt;&gt; null then
		self.setupWorkOrdersReport();
		self.headText := 'Work Orders for the period ' &amp; portDate_From.date.shortFormatJMT() &amp; ' - ' &amp; portDate_To.date.shortFormatJMT();
		self.buildMovementsToValidateCol();
		self.printWorkOrdersReport();
	endif;	
	fTitleSep.width := fTableHeader.width;
	app.printer.print(fTitleSep);

epilog
	app.printer.close();		
end;</source>
    </JadeMethod>
    <JadeMethod name="setReportTables" id="4feb1936-01a1-4dd0-a8fb-77c71e75cf8e">
        <updating/>
        <source>setReportTables(pTable:Table input;pColumnWidths:IntegerArray input;pColumnText:StringArray input)updating;

vars
	int : Integer;
	size: Integer;
begin
	size:= pColumnWidths.size;
	pTable.columns 		:= size;
	pTable.accessMode	:= Table.AccessMode_Column;
	pTable.width		:= 0;
	int := 1;
	while int &lt;= size do
		pTable.column := int;
		pTable.columnWidth[int] := pColumnWidths[int];
		pTable.text				:= pColumnText[int];
		pTable.width			:= pTable.width + pTable.columnWidth[int];
		int := int + 1;	
	endwhile;
	pTable.parent.width := pTable.width;
end;</source>
        <Parameter name="pTable" type="Table" usage="input"/>
        <Parameter name="pColumnWidths" type="IntegerArray" usage="input"/>
        <Parameter name="pColumnText" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupTideTable" id="e3cfbf32-dd76-4a6b-83cb-6e23311babf1">
        <updating/>
        <source>setupTideTable() updating;

vars
    i : Integer;
begin
	// This method setups up the tide table at the top of the report
	tableTides.columns:=6;

	// Set column widths
	tableTides.columnWidth[1]:=40;	
	tableTides.columnWidth[2]:=70;
	tableTides.columnWidth[3]:=40;
	tableTides.columnWidth[4]:=70;
	tableTides.columnWidth[5]:=120;
	tableTides.columnWidth[6]:=250;

	tableTides.column:=5;
	tableTides.row:=1;
	tableTides.text:="Pilot:";
	tableTides.row:=2;
	tableTides.text:="Tugmaster:";
	tableTides.row:=3;
	tableTides.text:="Supervisor:";
	tableTides.row:=4;
	tableTides.text:="Launchmaster:";

	// Make last two columns bold
	tableTides.accessMode:=tableTides.AccessMode_Column;
	foreach i in 1 to 6 do
    	tableTides.column := i;
    	tableTides.fontBold := true;
	endforeach;
	//tableTides.column:=5;
	//tableTides.fontBold:=true;
	//tableTides.column:=6;
	//tableTides.fontBold:=true;
	tableTides.accessMode:=tableTides.AccessMode_Cell;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupWorkOrdersReport" id="97ba36e9-d289-47cb-bb2c-3db6e015c032">
        <updating/>
        <source>setupWorkOrdersReport()updating;

/*

Date		Who		Reason
02/11/2007  EPR 	PAR 14985
27 Mar 2008	cnwkpd1	Changed setup of column headings to use CrLf instead of multi line string values

*/

vars
	columnWidths : IntegerArray;
	columnText	 : StringArray;
	int			 : Integer;
begin

	create columnWidths transient;
	create columnText	transient;

	columnWidths[01] := 35;
	columnWidths[02] := 160;
	columnWidths[03] := 70;
	columnWidths[04] := 60;
	columnWidths[05] := 75;
	columnWidths[06] := 75;
	columnWidths[07] := 70;
	columnWidths[08] := 65;
	columnWidths[09] := 50;
	columnWidths[10] := 45;
	columnWidths[11] := 52; //epr par 14985
	columnWidths[12] := 55;
	columnWidths[13] := 55;
	columnWidths[14] := 52;  //epr par 14985
	columnWidths[15] := 52;  //epr par 14985
	columnWidths[16] := 95;

	columnText[01]   := 'DAY';
	columnText[02]   := 'VESSEL';
	columnText[03]   := 'PLAN/' &amp; CrLf &amp; 'SIDE';
	columnText[04]   := 'LINES' &amp; CrLf &amp; 'TIME';
	columnText[05]   := "PILOT" &amp; CrLf &amp; "LAUNCH";
	columnText[06]   := 'TUG/S' &amp; CrLf &amp; 'TIME';
	columnText[07]   := 'TUGS';
	columnText[08]   := 'AGENT';
	columnText[09]   := 'LOA';
	columnText[10]   := 'S/B';
	columnText[11]   := 'BOW';
	columnText[12]   := 'BRIDGE';
	columnText[13]   := 'STERN';
	columnText[14]   := 'FWD';
	columnText[15]   := 'AFT';
	columnText[16]   := 'COMMENTS';

	// setup the header table
	setReportTables(tableHeader,columnWidths,columnText);

	// setup the body table
	columnText.clear;
	columnText[columnWidths.size] := null;
	setReportTables(tableBody,columnWidths,columnText);
	
epilog
	delete columnWidths;
	delete columnText;
end;</source>
    </JadeMethod>
</GUIClass>
