<GUIClass name="HMS_ScrollingWharfFrame" id="156bdc09-d327-4fea-b7c9-e718698b0125">
    <superclass name="CMUI_ScrollingFrame"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <ExplicitInverseRef name="myWharfDrawControl" id="b813fcdf-ced1-466e-a5e6-f9ba383a9f30">
        <kind>child</kind>
        <updateMode>automatic</updateMode>
        <embedded/>
        <type name="HMS_WharfDrawControl"/>
        <access>readonly</access>
        <Inverse name="HMS_WharfDrawControl::myScrollingFrame"/>
    </ExplicitInverseRef>
    <JadeMethod name="dragOver" id="f80e0fda-ec04-41b3-8ffc-7de133019526">
        <controlMethod name="CMUI_ScrollingFrame::dragOver"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>dragOver(frame: Frame input; win: Window input; x: Real; y: Real; state: Integer) updating, clientExecution;
//--------------------------------------------------
// Created:	20 August 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(frame, win, x, y, state);
	if self.myWharfDrawControl &lt;&gt; null then
		self.myWharfDrawControl.doDragOverEvent(frame, win, x, y);
	endif;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="mouseDown" id="1f0cda03-56b2-4824-8bb6-95f364046dce">
        <controlMethod name="Frame::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseDown(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
//--------------------------------------------------
// Created:	12 August 2004 By: cnwgd1
//--------------------------------------------------
vars
	xLeft 	: Real;
	yTop	: Real;
begin
	/* PAR 10455 - let myWharfDrawControl handle it 
	if button = 1 then
		return;
	endif;*/

	xLeft := x;
	yTop := y;

	frame.windowToScreen(xLeft, yTop);
	frame.form.screenToWindow(xLeft, yTop);

	if self.myWharfDrawControl &lt;&gt; null then
		self.myWharfDrawControl.mouseDown(self.myWharfDrawControl, button, shift, xLeft, yTop);		
	endif;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseMove" id="c5e83317-96c1-4665-aa32-a36659eb0cb3">
        <controlMethod name="Frame::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseMove(frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
//--------------------------------------------------
// Created:	20 August 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(frame, button, shift, x, y);
// I don't believe the following is required - rjs
//	if self.myWharfDrawControl &lt;&gt; null then
//		self.myWharfDrawControl.dragPictureMouseMoveEvent(frame, button, shift, x, y);
//	endif;
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
