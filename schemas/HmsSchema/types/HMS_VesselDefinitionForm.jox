    <JadeMethod name="createShipCode" id="96a3b612-29fa-4368-9951-f27b236af73d">
        <updating/>
        <source>createShipCode(shipName:String):String updating;

vars
	shipCode:				String;
	ship:					CM_Vessel;
	nextCode:				Integer;
	count:					Integer;
	msgBoxType:				Integer;
	errorMsg:				String;
	msgTitle:				String;
	tmpVessels:				CM_VesselByCodeDict;
begin

	tmpVessels := app.myRoot.allVessels;
	// Extract two letter code from shipName
	shipCode:=shipName.String.extractXXXCode;
	// Modified by Russell 24/03/99
	// -----------------------------------------
	shipCode:=shipCode.toUpper;
	// -----------------------------------------
    // get lowest available entry in dictionary entry for this two letter code
    count:=0;
    while count&lt;=999 do
    	ship:=(tmpVessels.getAtKey(shipCode &amp; count.String.padLeadingZeros(3))).CM_Vessel;
    	if ship&lt;&gt;null then
    		count:=count+1;
    	else
    		nextCode:=count;
    		count:=1100;
    	endif;
    endwhile;	

    if count&gt;=999 and count&lt;1100 then
    	// ERROR: All codes used for this two letter combination
		msgBoxType:=MsgBox_OK_Only+MsgBox_Stop_Icon;
		errorMsg:="All codes have been used for the 'ship' code class. Please use a different first letter for this ship.";
    	msgTitle:="ERROR: All codes used";
		if app.msgBox(errorMsg,msgTitle,msgBoxType)=MsgBox_Return_OK then
			// Set focus to field that is in error.
		tbxShipName.setFocus;
		endif;
    	shipCode:="";
    else
    	// Generate new customer code:
    	shipCode:=shipCode &amp; nextCode.String.padLeadingZeros(3);
    endif;

	return shipCode;
end;</source>
        <Parameter name="shipName" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayHMSMovementResources" id="3a61a360-2afd-4d35-b370-5dfaff7db561">
        <updating/>
        <source>displayHMSMovementResources()updating, protected;
//--------------------------------------------------
// Created:	08 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	idx : Integer;
	movementResource : HMS_ResourceTypeForMovement;
	tmpTable : CM_DataTable;
begin
	
	tmpTable := self.tblResources;
	
	if (not tmpTable.visible) then
		return;
	endif;
	
	tmpTable.rows := tmpTable.fixedRows;
		
	if self.myCurrentVesselDataHarbour = null then
		return;
	endif;

	foreach movementResource in self.myCurrentVesselDataHarbour.allMovementResourcesByMovement do	
		self.loadResourceTypeRow(movementResource);
	endforeach;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="displayVesselData" id="5f06c42e-373f-4923-9b66-1d592a6201a3">
        <updating/>
        <source>displayVesselData() updating, protected;

vars

begin

	self.clearForm();
	
	self.tbxNumHistVisits.text := 0.String;

	if self.myCurrentVessel &lt;&gt; null then
		// load form with existing ship details.
		self.tbxShipName.text := self.myCurrentVessel.name.trimBlanks;
		self.tbxShipCode.text := self.myCurrentVessel.code;
		self.tbxLLoydsNum.text := self.myCurrentVessel.lloydsNumber;
		self.setCaption(self.myCurrentVessel.name &amp; ' ' &amp; self.Caption);
		self.setNavigatorHeading(self.caption);
		if (not self.viewModeOnly) then
			self.btnDeleteTV.enabled := true;				
		endif;
		self.picShipBitmap.picture := self.myCurrentVessel.bitmap;		
	else
		self.setCaption(self.Caption);
		self.setNavigatorHeading(self.caption);
		self.btnDeleteTV.enabled := false;													
	endif; 
		
	if self.myCurrentVesselData &lt;&gt; null then
	
		self.txtGeneralRemark.text := self.myCurrentVesselData.remarksGeneral;
		self.txtPreviousNames.text := self.myCurrentVesselData.remarksPreviousNames;
		self.ckbxCoastalVessel.value := self.myCurrentVesselData.coastalServiceVessel;
		self.ckbxBowThrusters.value := self.myCurrentVesselData.hasBowThrust;
		self.ckbxSternThruster.value := self.myCurrentVesselData.hasSternThrust;
		self.ckbxHoldingTanks.value := self.myCurrentVesselData.hasHoldTanks;
		self.ckbxHasRamp.value := self.myCurrentVesselData.hasRamp;

		// Set Shipping Line if it is not blank
		if self.myCurrentVesselData.myDefaultShippingLine &lt;&gt; null then
			self.cmbShippingLine.setObject(self.myCurrentVesselData.myDefaultShippingLine);
			if self.cmbShippingLine.listIndex &gt; 0 then
				self.btnShipLine.enabled := true;
			endif;
		endif;

		// Set Country Flag if it is not blank
		if self.myCurrentVesselData.countryCode &lt;&gt; null then
			self.cbxCountryFlag.listIndex := self.cbxCountryFlag.findObject(self.myCurrentVesselData.getMyCountry);
		endif;

		// Set vessel type
		if self.myCurrentVesselData.myVesselType &lt;&gt; null then
			self.cbxShipType.listIndex := self.cbxShipType.findObject(self.myCurrentVesselData.myVesselType);
		endif;		

	endif;

	if self.myCurrentVesselDataHarbour &lt;&gt; null then
		self.ckbxPilotExempt.value := self.myCurrentVesselDataHarbour.isPilotExempt;
		self.ckbxExcludeReport.value := self.myCurrentVesselDataHarbour.excludeReport; 
		if self.myCurrentVesselData.hasFixedProp then
			self.optPropFixed.value := true;
		else
			self.optPropVariable.value := true;
		endif;

		// Set Agent if it is not blank
		if self.myCurrentVesselDataHarbour.myShippingAgent &lt;&gt; null then
			self.cmbShippingAgent.setObject(self.myCurrentVesselDataHarbour.myShippingAgent);
			if self.cmbShippingAgent.listIndex &gt; 0 then
				// Agent is found in list
				self.btnAgentContact.enabled := true;
			endif;
		endif;
		
		// Set Line company if it is not blank
		if self.myCurrentVesselDataHarbour.myLineCompany &lt;&gt; null then
			self.cbxLinesCompany.listIndex := self.cbxLinesCompany.findObject(self.myCurrentVesselDataHarbour.myLineCompany);
		endif;

		// Set tidal Class
		if self.myCurrentVesselDataHarbour.myTidalClassArrival &lt;&gt; null then
			self.cbxTidalClassArrv.listIndex := self.cbxTidalClassArrv.findObject(self.myCurrentVesselDataHarbour.myTidalClassArrival);
		endif;

		// Set tidal Class
		if self.myCurrentVesselDataHarbour.myTidalClassDeparture &lt;&gt; null then
			self.cbxTidalClassDept.listIndex := self.cbxTidalClassDept.findObject(self.myCurrentVesselDataHarbour.myTidalClassDeparture);
		endif;

		// Set vessel category
		if self.myCurrentVesselDataHarbour.myVesselCategoryIn &lt;&gt; null then
			self.cbxShipClass.listIndex := self.cbxShipClass.findObject(self.myCurrentVesselDataHarbour.myVesselCategoryIn);
		endif;							
		
		self.tbxEstTieUpTime.text := self.myCurrentVesselDataHarbour.estTieUpTime.String;
		self.tbxCrewLetGo.text := self.myCurrentVesselDataHarbour.numLCrewLetGo.String;
		self.tbxCrewTieUp.text := self.myCurrentVesselDataHarbour.numLCrewTieUp.String;
		self.tbxTugsArrive.text := self.myCurrentVesselDataHarbour.numTugsIn.String;
		self.tbxTugsDepart.text := self.myCurrentVesselDataHarbour.numTugsOut.String;
			
		if self.myCurrentVesselDataHarbour.berthPriority &lt;&gt; null then
			self.cbxBerthPriority.listIndex := self.myCurrentVesselDataHarbour.berthPriority;
			self.cbxBerthPriority.text := self.cbxBerthPriority.itemText[cbxBerthPriority.listIndex];
		endif;	
		self.txtPilotRemarks.text := self.myCurrentVesselDataHarbour.remarksPilotOnly;
		self.tbxNumHistVisits.text := self.myCurrentVesselDataHarbour.initialVoyageCount.String;
	endif;
	
	if self.txtPreviousNames.text = null then
		self.txtPreviousNames.text := self.tbxShipName.text;
	endif;
	// Load and set resource list as appropriate
	self.loadResourceList();
    // Load tables
	self.loadDimensionsTbl();
	self.loadKeyDistancesTbl();
	//self.loadBerthPrefTbl();
	self.loadBerthPrefRows();
	self.loadSummaryTbl();
	self.loadTidalClassTbl();	
	self.displayHMSMovementResources();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
