    <JadeMethod name="canPrintWOReportOnWeb" id="97ebd06d-5543-4ca0-b024-ba97d76fa4dd">
        <source>canPrintWOReportOnWeb(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
12 March 2019		jlgndl1	Initial creation
04 October 2019		jlgzm1	TFS 46736 Release extenstion WO should only print once
17 Dec 2019			NDL		TFS 48058 - remove ref to 'self.myReleaseWorkOrder.getMyParent.numPrints = 0;' just use 'return self.getMyParent.numPrints = 0;'

*/

vars

begin

	if self.getMyParent.allCashReceipts.isEmpty  // nothing paid
	or not self.getMyParent.allCashReceiptsAre( CM_CashReceipt.PAID ) // at least one not paid
//	or self.getMyParent.taskStatus &lt;&gt; WO_STATUS_APPROVED // wrong status	//Removed NDL 26 Mar 2019 TFS 43405
	then
		return false;
	else
		// TFS 46736 Start
		// should only be able to print once
//		if self.myReleaseWorkOrder &lt;&gt; null and self.myReleaseWorkOrder.getMyParent &lt;&gt; null then	
//			return self.myReleaseWorkOrder.getMyParent.numPrints = 0;
//		else
			return self.getMyParent.numPrints = 0;
//		endif;
		// TFS 46736 end
	endif;

	//return inheritMethod();

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doPaymentSuccessActions" id="771dbc25-1217-4378-be73-85aea1b590d9">
        <updating/>
        <source>doPaymentSuccessActions()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Mar 2019	jlgndl1	Initial creation	TFS 43405
19 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
08 Feb 2023 navma1  ChangeRequest 56457:[56458] EUP - Allowing different sets of cargo items per work order task [Refactor]
*/

vars

	relParent 	: CM_WorkOrder;
	ti 			: CM_TrackedItem;
	derivedDate : TimeStamp;

begin

	relParent   := self.myReleaseWorkOrder.getMyParent;
	derivedDate := self.getConfiguredApprovalExpiryTS(self.requiredByDT);	// TFS 43405 jlgdap1 24/04/2019

	if not derivedDate.isValid or self.requiredByDT &gt; derivedDate then
		relParent.setApprovalExpiry( self.requiredByDT );	
	else
		relParent.setApprovalExpiry( derivedDate );
	endif;
	
	foreach ti in self.myReleaseWorkOrder.allAvailableTIs do
		if not ti.isOnSite then
			continue;
		endif;
		self.getMyParent.addTrackedItem( ti ,self);						//08.02.2023 navma1 #56457 Task#56458
	endforeach;
	
	//self.addToDoTasksToCargo();										//13.03.2023 navma1 #56457:[56458]
	self.addCargoToDoTask();											//13.03.2023 navma1 #56457:[56458]
	self.getMyParent.setTaskStatus( WO_STATUS_COMPLETE );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAdvWOTransactionType" id="df69ab46-1f7d-4fc0-b546-792ae4c5c96b">
        <source>getAdvWOTransactionType(transType : Integer): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
17 October 2022		navcs2	ChangeRequest 56633:[56211] 54253.101 - Work order Transactions

*/

vars

begin
	if transType = TRANS_CREATED then
		return TRANS_TYPE_WO_TIRELEXT_CREATED;
	elseif transType = TRANS_UPDATED then
		return TRANS_TYPE_WO_TIRELEXT_UPDATED;
	else
		return TRANS_TYPE_WO_TIRELEXT_COMPLET;
	endif;
epilog

end;</source>
        <Parameter name="transType" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayString" id="694c22e6-6bfa-4d1b-a643-4a63fee8cba7">
        <source>getDisplayString(_useShortDesc: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Mar 2019	jlgndl1	Initial creation	TFS 43405
29 Sep 2021 navma1  ChangeRequest 51925: SAL - Web Portal Cargo Work Orders
06 Mar 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
*/

vars
	displayString : String;
	typeDesc	  : String;
	code		  : String;
begin
	
	typeDesc := self.getTypeDescription();												  //29.09.2021 navma1 #51925
	
	if _useShortDesc then
		displayString := typeDesc &amp;" Task #" &amp; self.getTaskSequenceNumber().String;				//06.03.2023 navma1 #56457:[56458]	
	else
		
		if self.getMyReleaseRequest &lt;&gt; null then
			code := self.getMyReleaseRequest.code;    									 //29.09.2021 navma1 #51925
		endif;
		
		displayString :=  self.getLongDescription(typeDesc,code);	 					//29.09.2021 navma1 #51925
		
	endif;
	
	return displayString;
epilog

end;</source>
        <Parameter name="_useShortDesc" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
