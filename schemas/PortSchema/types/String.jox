    <JadeMethod name="replaceCharsWithHTML" id="3d89589e-9289-49ca-a375-9773585a4fd7">
        <updating/>
        <source>replaceCharsWithHTML() : String updating;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 21 June 2006
//
//----------------------------------------------------------------------
constants
	HTML_COLON		= '%3A';
	HTML_COMMA 		= '%2C';
	HTML_EQUAL		= '%3D';
	HTML_SEMICOLON	= '%3B';
	HTML_SLASH 		= '%2F';
	HTML_SPACE		= '+';
	HTML_CrLf		= '%0D%0A';
	HTML_At = '%40';
vars
	str : String;
begin
//	str := self.cnEcEncodeWebData();
	str := self.cnEcDecodeWebData();
	str := str.cnEcFindReplace( '=', HTML_EQUAL, false);
	str := str.cnEcFindReplace('/', HTML_SLASH , false);
	str := str.cnEcFindReplace(',', HTML_COMMA , false);
	str := str.cnEcFindReplace( ';', HTML_SEMICOLON, false);
	str := str.cnEcFindReplace(' ', HTML_SPACE , false);
	str := str.cnEcFindReplace(':', HTML_COLON , false);
	str := str.cnEcFindReplace('@', HTML_At , false);
	str := str.cnEcFindReplace(CrLf, HTML_CrLf , false);
	
	return str;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="replaceHTMLChars" id="14deb9b0-bb89-4fd6-bc90-0f69e2fd0191">
        <updating/>
        <source>replaceHTMLChars() : String updating;
// -------------------------------------------
// Created 17 November 2004 by cnwdvb1
// -------------------------------------------
constants
	HTML_COLON		= '%3A';
	HTML_COMMA 		= '%2C';
	HTML_EQUAL		= '%3D';
	HTML_SEMICOLON	= '%3B';
	HTML_SLASH 		= '%2F';
	HTML_SPACE		= '+';
	HTML_CrLf		= '%0D%0A';
	HTML_At = '%40';
vars

	str	: String;

begin

	str := self.cnEcDecodeWebData();
	str := str.cnEcFindReplace(HTML_EQUAL, '=', false);
	str := str.cnEcFindReplace(HTML_SLASH, '/', false);
	str := str.cnEcFindReplace(HTML_COMMA, ',', false);
	str := str.cnEcFindReplace(HTML_SEMICOLON, ';', false);
	str := str.cnEcFindReplace(HTML_SPACE, ' ', false);
	str := str.cnEcFindReplace(HTML_COLON, ':', false);
	str := str.cnEcFindReplace(HTML_At, '@', false);
	str := str.cnEcFindReplace(HTML_CrLf, CrLf, false);
	
	return str;


end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="replaceString" id="e2e7aa06-ad74-4a83-962a-d0ff63990786">
        <source>replaceString(targetSubString: String; replacementString: String): String;

vars
	value:         String;
	i:             Integer;
	j:             Integer;
	targetLength:  Integer;
begin
	if targetSubString = null then
		return self;
	else
		targetLength := targetSubString.length;
	endif;

	i := 1;
	j := 1;
	while i &lt;= length do // AKB PAR 3869 was only &lt; now &lt;= Was not picking up single characters
		i := self.pos(targetSubString, i);
		if i = 0 then
			value := value &amp; self[j:end];
			break;
		else
			value := value &amp; self[j: i - j] &amp; replacementString;
			i := i + targetLength;
			j := i;
		endif;
	endwhile;

	return value;
end;</source>
        <Parameter name="targetSubString" type="String"/>
        <Parameter name="replacementString" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="replaceWord" id="62a8216e-6c13-45bd-a02e-e4dd6c9e9dc5">
        <source>replaceWord(_searchFor, _replaceWith : String): String;
// ---------------------------------------------------------------------------
// Created:     13 August 2004	cnwth2
//
// Purpose:     does a search and replace of a whole word only
//			 
// ----------   ----------  --------------------------------------------------
vars
	preString,
	postString,
	processedString		: String;
	foundStartPos,
	nextPos,
	replaceLength,
	searchLength,
	selfLength			: Integer;
begin

	if _searchFor = null or
	   _replaceWith = null then
		return self;
	endif;
	
	processedString := self;
	searchLength := _searchFor.length;
	
	nextPos := 1;
	selfLength := processedString.length;
	while foundStartPos &lt;= selfLength do
		foundStartPos := processedString.pos(_searchFor, nextPos);
		if foundStartPos &lt; 1 then
			break;
		endif;
	
		if (foundStartPos = 1) then
			if (searchLength = selfLength) then
				processedString := _replaceWith; //self is a single word
			elseif (not processedString[searchLength + 1].isAlpha) then //found at start of string and a word
				postString := processedString[searchLength + 1 : end]; 	
				processedString := _replaceWith &amp; postString;
			endif;
			
		elseif (not processedString[foundStartPos - 1].isAlpha) then
			preString := processedString[1 : foundStartPos - 1];
			
			if (foundStartPos + searchLength &gt;= selfLength) then
				processedString := preString &amp; _replaceWith;
				
			elseif (not processedString[foundStartPos + searchLength].isAlpha) then
				postString := processedString[(foundStartPos + searchLength) : end];
				processedString := preString &amp; _replaceWith &amp; postString;
			endif;
		endif;
		
		nextPos := foundStartPos + 1;
	endwhile;

	return processedString;
end;</source>
        <Parameter name="_searchFor" type="String"/>
        <Parameter name="_replaceWith" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="replace_regex" id="7ef01b3d-f7a7-4dda-8e1d-7df408521a4d">
