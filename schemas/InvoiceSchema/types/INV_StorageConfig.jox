    <JadeMethod name="initControls" id="3d033fda-adc0-4643-91e1-845fa06a64cc">
        <source>initControls() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2012	cnwer1	Initial creation SFW 1295
18 Sep 2019	jlgdi1	45972 Set the value of MT Storage checkboxes
23 Mar 2022 jlier1	 TFS 52292
*/

vars
	availYACriteria : CM_YACritetriaTypeByTypeDict;
	storageConfig : CM_StorageConfigType;
	selectedCargoTypes : CM_CargoTypesByIdDict;
begin
	self.myAssistant.comboBoxCalendar(self.myTerminal,self.cmbWorkingDays);
	self.myAssistant.comboBoxCalendar(self.myTerminal,self.cmbCompulsory);	//20 Sep 2017	NDL tfs 7032
	
	self.chkMTStorage.value := self.myTerminal.getConfig(MTsByDebtor).Boolean;
	self.chkMTStorageEX.value := self.myTerminal.getConfig(MTsByDebtorExport).Boolean;
	
	create availYACriteria transient;
	self.getAvailableYACriteria(availYACriteria);
 
	self.mulAttr.myAvailableListBox.sorted:=true;
	self.mulAttr.mySelectedListBox.sorted:=false;
	self.mulAttr.setupControl(app.getErrorString(Attributes), availYACriteria, INV_StorageConfig::getCriteriaTypeName.name);	

	self.mulAttr.setVisibleButtons(true,true,true);
	
	self.getAvailableStorageTriggers();
	self.mulTriggers.myAvailableListBox.sorted:=true;
	self.mulTriggers.mySelectedListBox.sorted:=false;
	self.mulTriggers.setupControl(app.getErrorString(Attributes), self.allAvailableStorageTriggers, INV_StorageConfig::getStorageTriggerDesc.name);	
	self.mulTriggers.mySelectedListBox.setEventMapping(ListBox::contextMenu.name,INV_StorageConfig::doContextMenuSelectedTriggers.name);
	self.mulTriggers.setVisibleButtons(true,true,false);
	
	self.populateDateCombos();
	self.mnuTriggersContext.visible:=false;
	
	storageConfig:=self.myTerminal.getConfig(StorageConfigType).CM_StorageConfigType;
	if storageConfig &lt;&gt; null and storageConfig.isSSLtype then
		self.shtCargoTypes.visible:=true;
		self.mulCargoTypes.myAvailableListBox.sorted:=true;
		self.mulCargoTypes.mySelectedListBox.sorted:=false;
		self.mulCargoTypes.setupControl(app.getErrorString(CargoType), app.myRoot.allCargoTypesById, INV_StorageConfig::getCargoTypeDescription.name);	
		
		create selectedCargoTypes transient;
		storageConfig.CM_StorageConfigTypeSSL.getAllExtraDayCargoTypeObjs(selectedCargoTypes);
		self.mulCargoTypes.setSelected(selectedCargoTypes);
		self.mulCargoTypes.setVisibleButtons(true,true,false);
	endif;
epilog
	delete availYACriteria;
	delete selectedCargoTypes;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadStorageConfig" id="28d15e6b-3976-441e-bd79-f7345d805bd7">
        <updating/>
        <source>loadStorageConfig()protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 September 2012	cnwer1	Initial creation SFW 1295
// 26/05/2023		navkc1	CR 58009 Task 58010: UI - Storage Config - Storage Configuration Receival
*/

vars
	foundTrigger : Integer;
	storageTrigger, pxyTrigger : CM_StorageTrigger;
	compulsoryCalendar : CM_Calendar;
begin
	
	self.myStorageConfig:= self.myTerminal.myStorageConfig;
	if self.myStorageConfig = null then
		return;
	endif;
	
	self.mulAttr.setSelected(self.myStorageConfig.allYACriteriaTypes);
	self.mulTriggers.setSelectedDisplayStringMatch(self.myStorageConfig.allStorageTriggers);
	
	foreach storageTrigger in self.myStorageConfig.allStorageTriggers do
		foundTrigger:=self.mulTriggers.mySelectedListBox.findStringExact(1,storageTrigger.getTriggerDescription());
		if foundTrigger &gt; 0 then
			pxyTrigger:=self.mulTriggers.mySelectedListBox.itemObject[foundTrigger].CM_StorageTrigger;
			if storageTrigger.resetFreeStorageDays and not pxyTrigger.resetFreeStorageDays then
				pxyTrigger.toggleResetFreeStorageDays;
			endif;
		endif;
	endforeach;
	// 30731 show the reset FSD option on selected triggers
	self.mulTriggers.mySelectedListBox.formDisplayEntryMethodName := INV_StorageConfig::getStorageTriggerSelectDesc.name;
	self.mulTriggers.mySelectedListBox.refreshSelf();
	
	if global.isValidObject(self.myStorageConfig.myWorkingDaysCalendar) then
		self.cmbWorkingDays.listObject:=self.myStorageConfig.myWorkingDaysCalendar;
	endif;
	
	//20 Sep 2017	NDL	TFS 7032
	compulsoryCalendar := self.myStorageConfig.getMyCompulsoryCalendar;
	if compulsoryCalendar &lt;&gt; null then
		self.cmbCompulsory.listIndex := self.cmbCompulsory.findObject(compulsoryCalendar);
	endif;
	
	self.setComboIndex(self.cmbReceivalDates, self.myStorageConfig.shipReceivalType);
	self.setComboIndex(self.cmbReleaseDates, self.myStorageConfig.shipReleaseType);
	// 26/05/2023	navkc1	CR 58009 Task 58010
	self.setComboIndex(self.cmbTruckReceival, self.myStorageConfig.roadReceivalType);
	self.setComboIndex(self.cmbWagonReceival, self.myStorageConfig.railReceivalType);
	self.setComboIndex(self.cmbChildReceival, self.myStorageConfig.unpackReceivalType);
	
	self.chkInc1stDay.value:=self.myStorageConfig.includeFirstDay;
	self.chkIncLastDay.value:=self.myStorageConfig.includeLastDay;
	self.txtCutoffTime.setTime(self.myStorageConfig.firstDayTimeCutoff);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="mnuResetStorageDays_click" id="8cd35d4b-7c99-42cc-bde1-b47b34e59a7f">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuResetStorageDays_click(menuItem: MenuItem input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 September 2012	cnwer1	Initial creation SFW 1295

*/

vars
	index	: Integer;
	storageTrigger : CM_StorageTrigger;
begin
	storageTrigger := self.mulTriggers.mySelectedListBox.listObject.CM_StorageTrigger;
	if storageTrigger = null then
		return;
	endif;
	
	storageTrigger.toggleResetFreeStorageDays();
	// 30731 update the list box text with the new reset FSD value
	index := self.mulTriggers.mySelectedListBox.listIndex;
	if index &gt; 0 then
		self.mulTriggers.mySelectedListBox.itemText[index] := self.getStorageTriggerSelectDesc(storageTrigger);
	endif;
epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
