    <JadeMethod name="auditIdDisplay" id="8264159e-0017-4da2-a470-2a81bd4d438e">
        <source>auditIdDisplay(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
16 October 2019	jlgndl1	Initial creation	TFS 47013

*/

vars

begin

	if self.auditId() &lt;&gt; null then
		return app.getErrorString(Rate) &amp; Space &amp; Hyphen &amp; Space &amp; app.getErrorString(VesselType) &amp; ": "&amp; self.auditId();
	else
		return app.getErrorString(Rate);
	endif;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getCode" id="1b67008e-bf20-4dc4-8d4c-5fdca8946da0">
        <source>getCode(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
// 07 Jun 2018  cnwma1		ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types

*/
vars

	invalidObject : Boolean;
	edition : Integer;

begin
	
	if self.myVesselType &lt;&gt; null then
		on Exception do app.handleDeletedObject( exception, self.myVesselType, invalidObject );	//16 Oct 2019	NDL	TFS 47013
		edition := self.myVesselType.edition;
		if invalidObject then
			return null;
		endif;
		return self.myVesselType.code;
	endif;
	
	return null;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
