    <JadeMethod name="reportRequestRun" id="dc79e694-c523-46f7-9728-c80db5b0d797">
        <source>reportRequestRun();
//
//25 May 2012	cnwrs1		Par 26914 - make cams restart after lock error
//
constants
	Terminal1 : String = 'UT';
vars
	terminal : CM_Terminal;
	bgpRequest : BGP_ReportRequest;
	reportTemplate : CM_ReportTemplate;
begin
	app.initialize;
	terminal := app.myRoot.allTerminals[Terminal1];
	if terminal = null then
		app.writeStatement('Can not find required terminal ' &amp; Terminal1);
		return;
	endif;
	app.myPassport.setMyTerminal(terminal);
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);
	app.changeLogLevel(LogDEBUG);
	create bgpRequest transient;
	reportTemplate := "7798.23862".asOid.CM_ReportTemplate;
	bgpRequest.setPropertyValue(BGP_ReportRequest::myTerminal.name, terminal);
	bgpRequest.setPropertyValue(BGP_ReportRequest::myUser.name, app.myPassport.myUser);
	bgpRequest.setPropertyValue(BGP_ReportRequest::myReportTemplate.name, reportTemplate);
	bgpRequest.setPropertyValue(BGP_ReportRequest::myReportDef.name, reportTemplate.myQryReport);
	bgpRequest.setPropertyValue(BGP_ReportRequest::myFilter.name, reportTemplate.myReportRequest.myFilter);
	bgpRequest.setPropertyValue(BGP_ReportRequest::outputDestination.name,0);

	bgpRequest.action();
epilog
	delete bgpRequest;
end;
</source>
    </JadeMethod>
