<CollClass name="IntegerArray">
    <JadeMethod name="cnEcDoSort" id="d6fff348-9179-446b-8f95-2c24def973f4">
        <lockReceiver/>
        <updating/>
        <source>cnEcDoSort(pSorterObj : CnEcSorter) lockReceiver, updating, protected;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		Refer to method implementation on the Array class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	integerValue	: Integer;
	sortKeyObj		: Object;

begin
	foreach integerValue in self do
		pSorterObj.addKey(integerValue);
	endforeach;
	
	self.purge();
	
	foreach sortKeyObj in pSorterObj.allKeys do
		self.add(sortKeyObj.CnEcSortKey.getKey().Integer);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pSorterObj" type="CnEcSorter"/>
    </JadeMethod>
</CollClass>
