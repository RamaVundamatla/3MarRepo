    <JadeMethod name="extractFieldsBody" id="9139142a-9c65-4ef3-a5c2-6ff3313b502c">
        <source>extractFieldsBody(_terminal: CM_Terminal; _outputFile: File; _counter: Integer io; _breakOut : Boolean output) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 May 2011	cnwkpd1	PAR #27436 - CCMS DCT 2073 - Product Transition Services

*/

vars
	iter	   : Iterator;
   	ti		   : CM_TrackedItem;
begin
	iter := _terminal.allOnsiteTIsByCargoTypeId.createIterator;
	while iter.next(ti) do
		// Skip over containers
		if ti.cargoType = TI_CargoType_Container then
			_terminal.allOnsiteTIsByCargoTypeId.startKeyGeq(TI_CargoType_Container + 1, null, iter);
			continue;
		endif;
		//write method.qualifiedName &amp; Tab &amp; ti.String;
		self.extractFieldsFromObject(ti, _outputFile, _counter, _breakOut);		
	endwhile;
	
epilog	
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_outputFile" type="File"/>
        <Parameter name="_counter" type="Integer" usage="io"/>
        <Parameter name="_breakOut" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getCollectionRefField" id="70495633-7e42-49cd-abfa-274b42a65a86">
        <source>getCollectionRefField(): CM_DataExtractFieldArray;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 May 2011	#cnwdz2	 

*/

vars
	refFields : CM_DataExtractFieldArray;
begin
	create refFields transient;
	refFields.add(self.allDataExtractFields[CM_TrackedItem::id.name]);
	refFields.add(self.allDataExtractFields["cargoType"]);
	return refFields;
epilog

end;</source>
        <ReturnType type="CM_DataExtractFieldArray"/>
    </JadeMethod>
