    <JadeMethod name="tblJobDetails_dblClick" id="c5df3427-ff76-4e13-ae21-afd25aab0dde">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblJobDetails_dblClick(table: CM_DataTable input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 02/02/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
// 18 Apr 2024	navnk30		Bug 63744: GPHA-Unable to sort the columns in Hold Planning and Hold Job operations screens.
//
vars

begin
	if table.row &gt; table.fixedRows then
		self.doMnuCargoEditEnquire(table.accessRow(table.row).itemObject.CM_WorkListEntry.myTrackedItem, false);
	elseif table.row = table.fixedRows then			//18.04.2024 navnk30 #63744
		table.resortTableByColumn(table.column);
	endif;
epilog

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblJobDetails_mouseDown" id="2ae8ca1d-96a7-4a11-8eb6-87c4e47d989a">
        <controlMethod name="CM_DataTable::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblJobDetails_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/01/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
// 18/07/2109	jlgzm1		TFS 42872 JMT - Direct Release Between HOLD Voyages and Rail
//
vars

begin
	if button = Window.MouseButton_Left then		// TFS 42872
		self.origXPos := x;							// TFS 42872
		self.origYPos := y;							// TFS 42872
	endif;
	self.tableRowChange(table.CM_DataTable, table.row);
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tblJobDetails_mouseMove" id="39cb5514-d6ca-45a5-99a6-cf7bbbc3b1ce">
        <controlMethod name="Table::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblJobDetails_mouseMove(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 July 2019		jlgzm1	Initial creation TFS 42872 Direct Release Hold Voyages

*/

vars
	tmpHeight : Real;	
begin
	if table.fixedRows &gt; 0 then
		tmpHeight := table.accessRow(table.fixedRows).height;
		if self.origYPos &lt;= tmpHeight then
			return;
		endif;
	endif;
	
	if table.row &gt; table.fixedRows then	
		self.tblWLEMouseMoveEvent(table, button, shift, x, y);
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tblWLEMouseMoveEvent" id="f83a743b-80f0-41fd-9862-f72bfa8baa52">
        <updating/>
        <source>tblWLEMouseMoveEvent(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*

Purpose:			Handles mouse move events on the given table

Parameters:			

Return Value:		

Date				Who		Reason
12 July 2019		jlgzm1	Initial creation TFS 42872 Direct Release Between HOLD Voyages and Rail - All Cargo Types

*/

vars
	theTI : CM_TrackedItem;
begin

	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	if self.myCurrentWLE = null and self.myCurrentTrackedItem = null then
		return;
	endif;
	
	// check drag/drop detected
	if button &lt;&gt; Window.MouseButton_Left or (not app.dragDetected(x, y, self.origXPos, self.origYPos)) then
	   return;
	endif;
	self.origXPos := 0;
	self.origYPos := 0;	
   	
   	if (not self.myCurrentWLE.isReceipt) then
   		return;
   	endif;
	
	// check there is a trackedItem to move
	if self.myCurrentWLE &lt;&gt; null then
		theTI := self.myCurrentWLE.myTrackedItem;
	endif;
	
	if theTI = null then
		theTI := self.myCurrentTrackedItem;
	endif;
	
	if theTI = null then
		return;
	endif;

	app.myDraggedTrackedItem := theTI;
	self.dragTrackedItem(theTI, self.myCurrentWLE, table);
	
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="toolbarShowCaptions" id="7428f2f4-09ef-403c-8de4-b86224e1895a">
        <updating/>
        <source>toolbarShowCaptions(_showCaptions: Boolean) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/02/2017	cnwdap1		Initial creation TFS 3220 LNX Voyage Operations Enhancements
//
vars
	currentHeight : Real;
	newHeight : Real;
	heightDiff : Real;
	
begin
	currentHeight := self.frmToolbar.height;
	inheritMethod(_showCaptions);
	newHeight := self.frmToolbar.height;
	heightDiff := newHeight - currentHeight;
	/* TFS 3549 done in doResize instead
	self.lblVoyage.top := self.lblVoyage.top + heightDiff;
	self.cmbVoyage.top := self.cmbVoyage.top + heightDiff;
	self.lblWorkPoint.top := self.lblWorkPoint.top + heightDiff;
	self.cmbWorkPoint.top := self.cmbWorkPoint.top + heightDiff;
	self.lblJobRemarks.top := self.lblJobRemarks.top + heightDiff;
	self.txtJobRemarks.top := self.txtJobRemarks.top + heightDiff;
	self.lblJobId.top := self.lblJobId.top + heightDiff;
	self.cmbJob.top := self.cmbJob.top + heightDiff;
	self.lblShiftRemarks.top := self.lblShiftRemarks.top + heightDiff;
	self.txtShiftRemarks.top := self.txtShiftRemarks.top + heightDiff;
	self.lblEffectiveDate.top := self.lblEffectiveDate.top + heightDiff;
	self.txtEffectiveDate.top := self.txtEffectiveDate.top + heightDiff;
	self.txtEffectiveTime.top := self.txtEffectiveTime.top + heightDiff;
	self.lblShiftStartDate.top := self.lblShiftStartDate.top + heightDiff;
	self.txtShiftStartDate.top := self.txtShiftStartDate.top + heightDiff;
	self.txtShiftStartTime.top := self.txtShiftStartTime.top + heightDiff;
	self.lblShiftEndDate.top := self.lblShiftEndDate.top + heightDiff;
	self.txtShiftEndDate.top := self.txtShiftEndDate.top + heightDiff;
	self.txtShiftEndTime.top := self.txtShiftEndTime.top + heightDiff;
	self.lblDischLoad.top := self.lblDischLoad.top + heightDiff;
	self.cmbDischLoad.top := self.cmbDischLoad.top + heightDiff;
	self.lblSubArea.top := self.lblSubArea.top + heightDiff;
	self.cmbSubArea.top := self.cmbSubArea.top + heightDiff;
	self.btnDischLoad.top := self.btnDischLoad.top + heightDiff;
	self.lblLoad.top := self.lblLoad.top + heightDiff;
	self.btnLoad.top := self.btnLoad.top + heightDiff;
	self.fldData.top := self.fldData.top + heightDiff;
	self.doResize();
	*/
epilog

end;</source>
        <Parameter name="_showCaptions" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="066559ee-eab6-4eb1-8661-d52cc5d8186c">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 26 February 2021 09:26:52.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0021759, locale);
	btnCheckList.translateBubbleHelp(Xlat_0021853, locale);
	btnCheckList.translateCaption(Xlat_0021854, locale);
	btnDischLoad.translateCaption(Xlat_0021760, locale);
	btnEventAlloc.translateBubbleHelp(Xlat_0021761, locale);
	btnEventAlloc.translateCaption(Xlat_0021762, locale);
	btnEventTrans.translateBubbleHelp(Xlat_0021926, locale);
	btnEventTrans.translateCaption(Xlat_0021927, locale);
	btnLoad.translateCaption(Xlat_0021763, locale);
	btnPrint.translateBubbleHelp(Xlat_0021764, locale);
