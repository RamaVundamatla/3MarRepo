    <JadeMethod name="translateForm" id="defd65f1-7016-4c55-b85a-5c94af6ac5ca">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 22 April 2021 10:02:10.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018902, locale);
	btnNoBook.translateCaption(Xlat_0018903, locale);
	btnUseBook.translateCaption(Xlat_0018904, locale);
	lblCarrier.translateCaption(Xlat_0018905, locale);
	lblDateTimeTo.translateCaption(Xlat_0019018, locale);
	lblDateTimefrom.translateCaption(Xlat_0019019, locale);
	lblDriver.translateCaption(Xlat_0018907, locale);
	lblVehicle.translateCaption(Xlat_0018910, locale);
	mnuColOrg.translateCaption(Xlat_0024159, locale);
	mnuContextOpts.translateCaption(Xlat_0024160, locale);
	mnuInpsectObj.translateCaption(Xlat_0024161, locale);
end;</source>
    </JadeMethod>
