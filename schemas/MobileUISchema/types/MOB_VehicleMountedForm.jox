    <JadeMethod name="btnTandem_click" id="83eab968-71e7-4202-86f7-c60a998c03a1">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnTandem_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 June 2010	cnwer1	Initial creation

*/

vars
	allSelectedRows : StringArray;
	selectedRow : Integer;
begin
	if not btn.value then
		if self.tblTasks.rows = 1 then
			self.tblTasks.tag:=null;
		else
			//make sure only one entry is selected
			allSelectedRows:=self.tblTasks.tag.getTokens();
			if allSelectedRows.size &gt; 1 then
				selectedRow:=allSelectedRows.first.Integer;
				allSelectedRows.remove(selectedRow.String);
				self.tblTasks.tag:=allSelectedRows.concatenate(Space);
				
				//epr par 35167 10/11/14
				if self.tblTasks.rows &gt;= selectedRow then
					self.tblTasks.row:=selectedRow;
					self.tblTasks.click(self.tblTasks);
				endif;
			endif;
		endif;
	endif;
	
	self.getSessionAgent.isTandem := btn.value;	// 29/05/2012 cnwar2 #28219
epilog
	delete allSelectedRows;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="btnTargetSearch_click" id="0d0e4326-de58-4be3-8fa6-638225c0ba3c">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnTargetSearch_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 June 2010	cnwer1	Initial creation

*/

vars
	lc : CM_LocationsController;
	ti : CM_TrackedItem;
	foundHeight : Integer;
	locString 	: String;
	sa, remStrings		: StringArray;
	allFoundTAs			: CM_TerminalAreaSet;
begin
	
	locString:=self.getSetdownLocID;
	// 34392 exit on null target string
	if locString = null then
		return;
	endif;

	app.myVMAgent.myTerminal.findLocationFromString(locString,true,lc,foundHeight);
	
	if lc = null then
		create sa transient;
		create remStrings transient;
		create allFoundTAs transient;
		locString.getTokensForDelimiter(Space,sa);
		app.myVMAgent.myTerminal.findTAFromString(sa,remStrings,true,allFoundTAs);
		if allFoundTAs.size &gt; 0 then
			lc :=allFoundTAs.first.allLocationsControllers.first;
		endif;
	endif;
	
	if not self.canLCGFXDisplay(lc) then
		return;
	endif;
	
	self.myDrawingController.gotoLocationByID(lc, ti, self.getConfiguredDefaultView(), not self.isZoomChanged);
epilog
	delete sa;
	delete remStrings;
	delete allFoundTAs;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
