    <JadeMethod name="fixCargoDischargePorts" id="52976335-c5b1-4ca8-902e-33ea0517fd86">
        <updating/>
        <source>fixCargoDischargePorts() updating;
/*
Purpose:			
Parameters:			
Return Value:		
Date		Who		Reason
08 March 2010	cnwas3	par 23043
24 march 2010	cnwas3	par 23402
*/

vars
	cargoPiece,
	pxyTI, 
	child 				: CM_TrackedItem;
	tmpDischargePort 	: CM_Port;
	tiUpdateCntrlr		: CMIF_TIUpdateController;//cnwas3	par 23402
begin
	
	tiUpdateCntrlr := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.myPassport.userCode,null);//cnwas3	par 23402
	foreach cargoPiece in self.allOnsiteTIsByIdCargoType do
		if cargoPiece.myTranshipToPort &lt;&gt; null then
			tmpDischargePort := self.getDischargePortForTranship(cargoPiece.myTranshipToPort);
			if tmpDischargePort &lt;&gt; null and tmpDischargePort.code &lt;&gt; cargoPiece.dischargePort then				
				pxyTI := cargoPiece.pxyCreateUpdateProxy();//cnwas3	par 23402
				/*if cargoPiece.isParent then // PAR 25082
					create children transient;
					pxyTI.getAllChildren(children);
				endif;*///cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
				
 				pxyTI.setDischargePort(tmpDischargePort.code);//cnwas3	par 23402
				cargoPiece.setForUpdate(pxyTI,tiUpdateCntrlr,null,true,app.myPassport);//cnwas3	par 23402
				
				// PAR 25082
				if cargoPiece.isParent then
					pxyTI.allChildren.purge();//cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
				endif;
				delete pxyTI;
			endif;			
		endif;	
	endforeach;
	
	foreach cargoPiece in self.allNotifiedTIsByIdCargoType do
		if cargoPiece.myTranshipToPort &lt;&gt; null then
			tmpDischargePort := self.getDischargePortForTranship(cargoPiece.myTranshipToPort);
			if tmpDischargePort &lt;&gt; null and tmpDischargePort.code &lt;&gt; cargoPiece.dischargePort then				
				pxyTI := cargoPiece.pxyCreateUpdateProxy();//cnwas3	par 23402
				/*if cargoPiece.isParent then // PAR 25082
					create children transient;
					pxyTI.getAllChildren(children);
				endif;*/

				pxyTI.setDischargePort(tmpDischargePort.code);//cnwas3	par 23402
				cargoPiece.setForUpdate(pxyTI,tiUpdateCntrlr,null,true,app.myPassport);//cnwas3	par 23402

				// PAR 25082
				if cargoPiece.isParent then
					pxyTI.allChildren.purge(); //cnwsh3 - PAR25103 - allChildren collection has been unprotected reversing the need for changes from PAR22954
				endif;
				delete pxyTI;

			endif;			
		endif;	
	endforeach;
	
epilog
	delete pxyTI;
	delete tiUpdateCntrlr;
end;</source>
    </JadeMethod>
    <JadeMethod name="fixupStockOnHand" id="e050fde5-7be7-4cec-a7b4-bf1f7232229c">
        <source>fixupStockOnHand(_passport : CM_Passport input; _comment : String; 
				 _parent : CM_SOHFixupHdr; _cmifMonitor : CMIF_Monitor input);
//--------------------------------------------------------------
//Created: 04 June 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	lc			: CM_LocationsController;
	saveMsg		: String;
begin

	if _cmifMonitor &lt;&gt; null then
		saveMsg := _cmifMonitor.message;
	endif;
	
	//fixup the locations first
	foreach lc in self.allVoyageLocations do
		app.writeLog('Fixup Stock on Hand :: Checking Location ' &amp; lc.getID, LogINFO);
		if _cmifMonitor &lt;&gt; null then
			_cmifMonitor.message := 'Location ' &amp; lc.getID;
		endif;
		lc.fixupStockOnHand(_passport, _comment, _parent, _cmifMonitor);
		if (not _passport.noErrors) then
			return;
		endif;
	endforeach;

	if _cmifMonitor &lt;&gt; null then
		_cmifMonitor.message := saveMsg;		
	endif;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_parent" type="CM_SOHFixupHdr"/>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="genVoyageStatistics" id="56363033-8736-492a-b6b6-07c77e791a05">
        <source>genVoyageStatistics(_passport : CM_Passport input);
//--------------------------------------------------
// Created:	29 November 2005 By: cnwgd1
//--------------------------------------------------
vars
	code,
	unitOfMeasure : String;
	group : Integer;
	value : Real;
	date,
	tmpDate : Date;
	tmpTI : CM_TrackedItem;
	tmpHMSData : HMS_VoyageData;
	tmpTerminal : CM_Terminal;
	tmpVoyageStat : CM_VoyageStatistic;
	tmpTrans : CM_TITransaction;
	tmpInvoice : CM_InvoiceLine;
	tmpMove : HMS_VoyageMovement;
	tmpResUsed : HMS_ResourceUsed;
	tmpHMSTrans : HMS_Transaction;
	tmpVeseslType : HMS_VesselType;	
begin
	
	tmpTerminal := self.myTerminal;
	if tmpTerminal = null then
		// huh.. unlikely. Belts and braces.
		return;
	endif;
	
	// set date to 1st of month arrived
	tmpDate := self.arrivedDT.date;
	if (not tmpDate.isValid()) then
		// assume it hasn't arrived
		return;
	endif;
	
	date.setDate(1, tmpDate.month, tmpDate.year);

	tmpHMSData := self.myHMSVoyageData;	

	// Vessel Call
	if tmpHMSData &lt;&gt; null then
		tmpVeseslType := tmpHMSData.myVesselType;
		
		if tmpVeseslType &lt;&gt; null then	
			if tmpVeseslType.description.cnContains('Cruise') 
			or tmpVeseslType.description.cnContains('Passenger') then	
				// passengers embarked/disembarked? no way of telling at the moment, TEMPORARY	
				group := VoyageStat_PassengerVesselCall;
			endif;
		endif;
	endif;
	
	if group &lt;&gt; VoyageStat_PassengerVesselCall then
		// cargo vessel call
		group := VoyageStat_CargoVesselCall;
	endif;			

	
	if tmpHMSData &lt;&gt; null
	and tmpHMSData.getMyBerth &lt;&gt; null 
	and tmpHMSData.getMyBerth.myWharf &lt;&gt; null then
		code := tmpHMSData.getMyBerth.myWharf.description;
	else
		code := tmpTerminal.code;
	endif;
	unitOfMeasure := BOL_UOM_UNITS;
	value := 1;
	tmpTerminal.updateVoyageStatistic(code, unitOfMeasure, group, date, value, _passport);	

	// Cargo exchanged
	foreach tmpTrans in self.allTITransactionsByDTType do

		tmpDate := tmpTrans.dateTime.date;
		if (not tmpDate.isValid) then
			tmpDate := self.arrivedDT.date;
		endif;						
		
		tmpTI := tmpTrans.myTrackedItem;
		if tmpTI = null then
			// Belts &amp; braces
			continue;
		endif;
				
		if tmpTrans.type = TRANS_TYPE_REL_SHIP then
			group := VoyageStat_CargoOffloaded;	
			code := tmpTI.cargoTypeDescr;							
		elseif tmpTrans.type = TRANS_TYPE_REC_SHIP then		
			group := VoyageStat_CargoLoaded;
			code := tmpTI.cargoTypeDescr;			
		else
			continue;
		endif;
		
		// set date to the 1st of the month when created
		date.setDate(1, tmpDate.month, tmpDate.year);			
	
		if CM_Car.hasInstance(tmpTI) then
		
			unitOfMeasure := BOL_UOM_UNITS;
			value := 1;
		
		elseif CM_Cargo.hasInstance(tmpTI) then
		
			unitOfMeasure := BOL_UOM_METRIC_TONS;
			value := tmpTI.totalWeight/1000;									
		else
			unitOfMeasure := BOL_UOM_UNITS;
			value := 1;
		endif;
		
		if value &gt; 0 then		
			tmpTerminal.updateVoyageStatistic(code, unitOfMeasure, group, date, value, _passport);
		endif;
		
		// Charges - Invouce line totals
//		tmpInvoice := tmpTrans.myInvoiceLine;
		if not tmpTrans.allInvoiceLines.isEmpty  then
			foreach tmpInvoice in tmpTrans.allInvoiceLines discreteLock do
				value := value + tmpInvoice.lineTotal;
			endforeach;
			group := VoyageStat_Charges;
			unitOfMeasure := BOL_UOM_CURRENCY;
			code := tmpTrans.class.name[4:end];
//			value := tmpInvoice.lineTotal;
			if value &gt; 0 then
				tmpTerminal.updateVoyageStatistic(code, unitOfMeasure, group, date, value, _passport);							
			endif;
		endif;						
	endforeach;

	// HMS Resource 
	if tmpHMSData &lt;&gt; null then
		foreach tmpMove in tmpHMSData.allVoyageMovements do	
			foreach tmpResUsed in tmpMove.allResourceUsed do

				if tmpResUsed.myResourceType = null then
					code := tmpResUsed.code;
				else
					code := tmpResUsed.myResourceType.code;				
				endif;
				
				if tmpResUsed.myVTMISTransaction &lt;&gt; null
				and not tmpResUsed.myVTMISTransaction.allInvoiceLines.isEmpty() then
					
					foreach tmpInvoice in tmpResUsed.myVTMISTransaction.allInvoiceLines discreteLock do
						value := value +  tmpInvoice.lineTotal;
					endforeach;
					// set date to the 1st of the month when created
					tmpDate := tmpResUsed.myVTMISTransaction.transactionDT.date;
					if (not tmpDate.isValid) then
						tmpDate := self.arrivedDT.date;
					endif;

					date.setDate(1, tmpDate.month, tmpDate.year);										
								
					group := VoyageStat_Charges;
					unitOfMeasure := BOL_UOM_CURRENCY;						
//					value := tmpResUsed.myVTMISTransaction.myInvoiceLine.lineTotal;	
					if value &gt; 0 then
						tmpTerminal.updateVoyageStatistic(code, unitOfMeasure, group, date, value, _passport);				
					endif;													
				else
					// set date to the 1st of the month when created
					tmpDate := tmpResUsed.fromDateTime.date;
					if (not tmpDate.isValid) then
						tmpDate := self.arrivedDT.date;
					endif;

					date.setDate(1, tmpDate.month, tmpDate.year);										
															
					group := VoyageStat_Resources;
					unitOfMeasure := BOL_UOM_UNITS;
					value := tmpResUsed.unitsUsed;
					if value &gt; 0 then
						tmpTerminal.updateVoyageStatistic(code, unitOfMeasure, group, date, value, _passport);				
					endif;													
				endif;

			endforeach;
		endforeach;
	endif;

	// Hmm.. on hold
	//group := VoyageStat_Passengers;
		
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="genVoyageStatisticsWithTotals" id="8afa832f-a8e8-418d-b129-2f2c436e09c2">
        <source>genVoyageStatisticsWithTotals(_passport : CM_Passport input);
//--------------------------------------------------
// Created:	29 November 2005 By: cnwgd1
//--------------------------------------------------
vars
	code,
	unitOfMeasure : String;
	group : Integer;
	totalUnits,	
	totalRes,	
	totalCharge,
	totalTons,	
	value : Real;
	resDate,
	invDate,
	date,
	tmpDate : Date;
	tmpTI : CM_TrackedItem;
	tmpHMSData : HMS_VoyageData;
	tmpTerminal : CM_Terminal;
	tmpVoyageStat : CM_VoyageStatistic;
	tmpTrans : CM_TITransaction;
	tmpInvoice : CM_InvoiceLine;
	tmpMove : HMS_VoyageMovement;
	tmpResUsed : HMS_ResourceUsed;
	tmpHMSTrans : HMS_Transaction;	
begin
	
	tmpTerminal := self.myTerminal;
	if tmpTerminal = null then
		// huh.. unlikely. Belts and braces.
		return;
	endif;
	
	// set date to 1st of month arrived
	tmpDate := self.arrivedDT.date;
	if (not tmpDate.isValid()) then
		// assume it hasn't arrived
		return;
	endif;
	
	date.setDate(1, tmpDate.month, tmpDate.year);

	tmpHMSData := self.myHMSVoyageData;			
	// Vessel Call
	if tmpHMSData &lt;&gt; null
	and tmpHMSData.myVesselType &lt;&gt; null	
	and tmpHMSData.myVesselType.description.cnContains('Passenger') then
		// passengers embarked/disembarked? no way of telling at the moment, TEMPORARY	
		group := VoyageStat_PassengerVesselCall;
	else
		// cargo vessel call
		group := VoyageStat_CargoVesselCall;
	endif;
	
	if tmpHMSData &lt;&gt; null
	and tmpHMSData.getMyBerth &lt;&gt; null 
	and tmpHMSData.getMyBerth.myWharf &lt;&gt; null then
		code := tmpHMSData.getMyBerth.myWharf.description;
	else
		code := tmpTerminal.code;
	endif;
	unitOfMeasure := BOL_UOM_UNITS;
	value := 1;
	tmpTerminal.updateVoyageStatistic(code, unitOfMeasure, group, date, value, _passport);	

	if group = VoyageStat_CargoVesselCall then
		group := VoyageStat_CargoVesCallTot;
		code := VoyageStat_CargoVesCallTot_Str;		
	else
		group := VoyageStat_PassVesselCallTot;
		code := VoyageStat_PassVesCallTot_Str;			
	endif;
	tmpTerminal.updateVoyageStatistic(code, unitOfMeasure, group, date, value, _passport);		

	// Total vessel calls
	group := VoyageStat_VesselCallTotal;
	code := VoyageStat_VesselCallTotal_Str;
	tmpTerminal.updateVoyageStatistic(code, unitOfMeasure, group, date, value, _passport);		
	
	// Cargo exchanged
	foreach tmpTrans in self.allTITransactionsByDTType do

		tmpDate := tmpTrans.dateTime.date;
		if (not tmpDate.isValid) then
			tmpDate := self.arrivedDT.date;
		endif;						
		
		tmpTI := tmpTrans.myTrackedItem;
		if tmpTI = null then
			// Belts &amp; braces
			continue;
		endif;
				
		if tmpTrans.type = TRANS_TYPE_REL_SHIP then
			group := VoyageStat_CargoOffloaded;	
			code := tmpTI.cargoTypeDescr;							
		elseif tmpTrans.type = TRANS_TYPE_REC_SHIP then		
			group := VoyageStat_CargoLoaded;
			code := tmpTI.cargoTypeDescr;			
		else
			continue;
		endif;
		
		if tmpDate.month &lt;&gt; date.month
		or tmpDate.year &lt;&gt; date.year then
			// Total cargo exchange
			if totalUnits &gt; 0 then
				// date is last TI transaction date
				group := VoyageStat_CargoUnits;
				code := VoyageStat_CargoUnits_Str;
				unitOfMeasure := BOL_UOM_UNITS;
				tmpTerminal.updateVoyageStatistic(code, unitOfMeasure, group, date, totalUnits, _passport);
			endif;
			totalUnits := null;			
		
			// Total cargo exchange
			if totalTons &gt; 0 then
				group := VoyageStat_CargoTons;
				code := VoyageStat_CargoTons_Str;
				unitOfMeasure := BOL_UOM_METRIC_TONS;
				tmpTerminal.updateVoyageStatistic(code, unitOfMeasure, group, date, totalTons, _passport);	
			endif;
			totalTons := null;
			
			if totalCharge &gt; 0 then
				group := VoyageStat_ChargesTotal;
				code := VoyageStat_ChargesTotal_Str;				
				unitOfMeasure := BOL_UOM_CURRENCY;
				tmpTerminal.updateVoyageStatistic(code, unitOfMeasure, group, date, totalCharge, _passport);							
			endif;	
			totalCharge := null;		
		
			// set date to the 1st of the month when created
			date.setDate(1, tmpDate.month, tmpDate.year);			
		endif;	
	
		if CM_Car.hasInstance(tmpTI) then
		
			unitOfMeasure := BOL_UOM_UNITS;
			value := 1;
			totalUnits := totalUnits+value;				
		
		elseif CM_Cargo.hasInstance(tmpTI) then
		
			unitOfMeasure := BOL_UOM_METRIC_TONS;
			value := tmpTI.totalWeight;									
			totalTons := totalTons+value;
		else
			unitOfMeasure := BOL_UOM_UNITS;
			value := 1;
			totalUnits := totalUnits+value;				
		endif;
		
		if value &gt; 0 then		
			tmpTerminal.updateVoyageStatistic(code, unitOfMeasure, group, date, value, _passport);
		endif;
		
		// Charges - Invouce line totals
//		tmpInvoice := tmpTrans.myInvoiceLine;
		if not tmpTrans.allInvoiceLines.isEmpty() then
			foreach tmpInvoice in tmpTrans.allInvoiceLines discreteLock do
				value := value + tmpInvoice.lineTotal;
			endforeach;
			group := VoyageStat_Charges;
			unitOfMeasure := BOL_UOM_CURRENCY;
			code := tmpTrans.class.name[4:end];
			//value := tmpInvoice.lineTotal;
			totalCharge := totalCharge+value;
			if value &gt; 0 then
				tmpTerminal.updateVoyageStatistic(code, unitOfMeasure, group, date, value, _passport);							
			endif;
		endif;						
	endforeach;

	// Total cargo exchange
	if totalUnits &gt; 0 then
		group := VoyageStat_CargoUnits;
		code := VoyageStat_CargoUnits_Str;
		unitOfMeasure := BOL_UOM_UNITS;
		tmpTerminal.updateVoyageStatistic(code, unitOfMeasure, group, date, totalUnits, _passport);
	endif;

	// Total cargo exchange
	if totalTons &gt; 0 then
		group := VoyageStat_CargoTons;
		code := VoyageStat_CargoTons_Str;
		unitOfMeasure := BOL_UOM_METRIC_TONS;
		tmpTerminal.updateVoyageStatistic(code, unitOfMeasure, group, date, totalTons, _passport);	
	endif;
	
	// Total charges
	if totalCharge &gt; 0 then
		group := VoyageStat_ChargesTotal;
		code := VoyageStat_ChargesTotal_Str;				
		unitOfMeasure := BOL_UOM_CURRENCY;
		tmpTerminal.updateVoyageStatistic(code, unitOfMeasure, group, date, totalCharge, _passport);
		totalCharge := null;							
	endif;	
			
	// HMS Resource 
	if tmpHMSData &lt;&gt; null then
		foreach tmpMove in tmpHMSData.allVoyageMovements do	
			foreach tmpResUsed in tmpMove.allResourceUsed do

				if tmpResUsed.myResourceType = null then
					code := tmpResUsed.code;
				else
					code := tmpResUsed.myResourceType.code;				
				endif;
				
				if tmpResUsed.myVTMISTransaction &lt;&gt; null
				and not tmpResUsed.myVTMISTransaction.allInvoiceLines.isEmpty() then
					foreach tmpInvoice in tmpResUsed.myVTMISTransaction.allInvoiceLines discreteLock do
						value := value + tmpInvoice.lineTotal;
					endforeach;
					// set date to the 1st of the month when created
					tmpDate := tmpResUsed.myVTMISTransaction.transactionDT.date;
					if (not tmpDate.isValid) then
						tmpDate := self.arrivedDT.date;
					endif;

					if tmpDate.month &lt;&gt; invDate.month
					or tmpDate.year &lt;&gt; invDate.year then
						if totalCharge &gt; 0 then
							group := VoyageStat_ChargesTotal;
							code := VoyageStat_ChargesTotal_Str;				
							unitOfMeasure := BOL_UOM_CURRENCY;
							tmpTerminal.updateVoyageStatistic(code, unitOfMeasure, group, invDate, totalCharge, _passport);							
						endif;	
						totalCharge := null;
						invDate.setDate(1, tmpDate.month, tmpDate.year);										
					endif;
								
					group := VoyageStat_Charges;
					unitOfMeasure := BOL_UOM_CURRENCY;						
//					value := tmpResUsed.myVTMISTransaction.myInvoiceLine.lineTotal;	
					totalCharge := totalCharge+value;
					if value &gt; 0 then
						tmpTerminal.updateVoyageStatistic(code, unitOfMeasure, group, invDate, value, _passport);				
					endif;													
				else
					// set date to the 1st of the month when created
					tmpDate := tmpResUsed.fromDateTime.date;
					if (not tmpDate.isValid) then
						tmpDate := self.arrivedDT.date;
					endif;

					if tmpDate.month &lt;&gt; resDate.month
					or tmpDate.year &lt;&gt; resDate.year then
						if totalRes &gt; 0 then
							group := VoyageStat_ResourcesTotal;
							code := VoyageStat_ResourcesTotal_Str;				
							unitOfMeasure := BOL_UOM_UNITS;
							tmpTerminal.updateVoyageStatistic(code, unitOfMeasure, group, resDate, totalRes, _passport);							
						endif;	
						totalRes := null;
						resDate.setDate(1, tmpDate.month, tmpDate.year);										
					endif;
														
					group := VoyageStat_Resources;
					unitOfMeasure := BOL_UOM_UNITS;
					value := tmpResUsed.unitsUsed;
					totalRes := totalRes+value;	
					if value &gt; 0 then
						tmpTerminal.updateVoyageStatistic(code, unitOfMeasure, group, resDate, value, _passport);				
					endif;													
				endif;

			endforeach;
		endforeach;
	endif;

	// set date to the 1st of the month when created
	invDate.setDate(1, tmpDate.month, tmpDate.year);			
	if totalCharge &gt; 0 then
		group := VoyageStat_ChargesTotal;
		code := VoyageStat_ChargesTotal_Str;				
		unitOfMeasure := BOL_UOM_CURRENCY;
		tmpTerminal.updateVoyageStatistic(code, unitOfMeasure, group, invDate, totalCharge, _passport);							
	endif;

	resDate.setDate(1, tmpDate.month, tmpDate.year);			
	if totalRes &gt; 0 then
		group := VoyageStat_ResourcesTotal;
		code := VoyageStat_ResourcesTotal_Str;				
		unitOfMeasure := BOL_UOM_UNITS;
		tmpTerminal.updateVoyageStatistic(code, unitOfMeasure, group, resDate, totalRes, _passport);							
	endif;					
				
	// Hmm.. on hold
	//group := VoyageStat_Passengers;
		
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllAllocatedRows" id="c784e45f-432e-44ad-8835-5f58a38df4e7">
        <source>getAllAllocatedRows(_locnSet : CM_LCSet input);
//--------------------------------------------------------------
//Created: 19 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	summary : CM_StockOrderSummary;
	allocation : CM_StockOrderAllocation;
begin
	if _locnSet = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null set passed to method. Contact Developer.');
		return;
	endif;
	
	foreach summary in self.allStockOrderSummaries do
		foreach allocation in summary.allStockAllocations do
			//epr par 11850 8/6/2006
			if allocation.myLocationsController &lt;&gt; null and allocation.myLocationsController.status = LC_Status_Archived then
				continue;
			endif;
		
			if (not _locnSet.includes(allocation.myLocationsController)) then
				_locnSet.add(allocation.myLocationsController);
			endif;
		endforeach;
	endforeach;
	
end;</source>
        <Parameter name="_locnSet" type="CM_LCSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllAllocatedSOHLocations" id="87a142b0-c4f7-4849-989c-8528c3df400f">
        <source>getAllAllocatedSOHLocations(_logLot : CM_LogLot; _operator : CM_Operator; _sohLocnSet : CM_SOHLocationSet input);
//--------------------------------------------------------------
//Created: 29 August 2002 By: cnwgd1
//--------------------------------------------------------------
// 08 Feb 2017	cnwrs1	Par 38593
vars
	sohLocn : CM_SOHLocation;
	lot : CM_LogLot;
	order : CM_LogStockOrderLine;
	summary : CM_StockOrderSummary;
	allocation : CM_StockOrderAllocation;
begin
	if _sohLocnSet = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null set passed to method. Contact Developer.');
		return;
	endif;
	
	if _logLot = null then
		foreach summary in self.allStockOrderSummaries do
			foreach allocation in summary.allStockAllocations do
				if allocation.mySOHLocation = null then
					continue;
				endif;
				if _operator &lt;&gt; null and allocation.mySOHLocation.myOperator &lt;&gt; _operator then
					continue;
				endif;
				if (not _sohLocnSet.includes(allocation.mySOHLocation)) then			
					_sohLocnSet.add(allocation.mySOHLocation);
				endif;
			endforeach;
		endforeach;
	else
		foreach order in _logLot.allLogStockOrderLines do
			foreach allocation in order.allStockAllocations do
				if _operator &lt;&gt; null and allocation.mySOHLocation.myOperator &lt;&gt; _operator then
					continue;
				endif;		
				if (not _sohLocnSet.includes(allocation.mySOHLocation)) then			
					_sohLocnSet.add(allocation.mySOHLocation);			
				endif;
			endforeach;		
		endforeach;
	endif;
	
end;</source>
        <Parameter name="_logLot" type="CM_LogLot"/>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_sohLocnSet" type="CM_SOHLocationSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllAvailableWorkPoints" id="d90ce009-d94b-4af9-a571-cf4df1b4e0c4">
        <source>getAllAvailableWorkPoints(_availableWorkPoints : ObjectArray input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	machine : CM_Machine;
	workPoint : CM_WorkPoint;
begin
	
	// if there are bays then they can use cranes
	if self.myCellularVoyageStructure &lt;&gt; null  then
		foreach machine in self.myTerminal.machines 
		where (machine.available and not machine.isNotAvailableForEntry) do		// 16/05/2012 cnwar2 #28342
			if machine.isKindOf(CM_Crane) then
				_availableWorkPoints.add(machine);	
			endif;		
		endforeach;
		
	endif;
	
	//if there is decks they can use work points
	if self.myROROStructure &lt;&gt; null 
	or self.myGeneralCargoVoyage &lt;&gt; null then // TFS 3646
		foreach workPoint in self.myTerminal.allWorkPointsByCode do
			_availableWorkPoints.add(workPoint);
		endforeach;
	endif;
	
epilog

end;</source>
        <Parameter name="_availableWorkPoints" type="ObjectArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllCargoByJobOrder" id="24a3d76e-b166-42b4-a826-77b221007b8c">
        <source>getAllCargoByJobOrder(_discharge : Boolean; _areaType : String; _areaCode : String; unactionedonly : Boolean; _isSOB : Boolean) : CM_TIArray;
/*
Purpose:			
Date		Who		Reason
14 August 2015	cnwab1	Initial creation
*/

vars
	jobsheet : CM_VoyageJobSheet;
	vjob : CM_VoyageJob;
	job : CM_Job;
	req : CM_Request;
	tmptis, tis : CM_TIArray;
	reqs : CM_SlotRequestArray;
	ti : CM_TrackedItem;
begin
	create reqs transient;
	
	if _areaType = "" or _areaCode = "" then
		return null;
	endif;
	
	create tis transient;
	create tmptis transient;

	foreach jobsheet in self.allJobSheetsInOrder discreteLock do
		foreach job in jobsheet.allJobsByOrder discreteLock do
			vjob := job.CM_VoyageJob;
			
			if vjob.isDischarge = _discharge then
				if _areaType = VesselArea_Bay then
					if vjob.bayId = _areaCode and vjob.myDeck = null then
						vjob.doSortReqsInToSeqOrder(reqs);
 
						foreach req in reqs discreteLock where not req.isComplete do
							req.getAllTrackedItems(tmptis);
							if unactionedonly then
								foreach ti in tmptis do
									if ti.getVoyageWLEUnactioned(not _discharge) &lt;&gt; null then
										if _discharge then // check it is not on ship
											if ti.myPrimaryActualLocation.isVoyageController() then
												if ti.isSOB = _isSOB then
													tis.addExclusive(ti);
												endif;
											endif;
										else
											tis.addExclusive(ti);
										endif;
									endif;
								endforeach;
							else
								tmptis.copy(tis);
							endif;
						endforeach;
						
						
					endif;
				elseif _areaType = VesselArea_Deck then
					if vjob.bayId = _areaCode and vjob.myDeck &lt;&gt; null then
						vjob.doSortReqsInToSeqOrder(reqs);

						foreach req in reqs discreteLock where not req.isComplete do
							req.getAllTrackedItems(tmptis);
							if unactionedonly then
								foreach ti in tmptis do
									if ti.getVoyageWLEUnactioned(not _discharge) &lt;&gt; null then
										if _discharge then // check it is not on ship
											if ti.myPrimaryActualLocation.isVoyageController() then
												if ti.isSOB = _isSOB then
													tis.addExclusive(ti);
												endif;
											endif;
										else
											tis.addExclusive(ti);
										endif;
									endif;
								endforeach;
							else
								tmptis.copy(tis);
							endif;
						endforeach;

						
					endif;
				endif;
			endif;
		endforeach;
	
	endforeach;
	
	
	return tis;
epilog
	delete reqs;
	delete tmptis;
end;</source>
        <Parameter name="_discharge" type="Boolean"/>
        <Parameter name="_areaType" type="String"/>
        <Parameter name="_areaCode" type="String"/>
        <Parameter name="unactionedonly" type="Boolean"/>
        <Parameter name="_isSOB" type="Boolean"/>
        <ReturnType type="CM_TIArray"/>
    </JadeMethod>
    <JadeMethod name="getAllCargoGroups" id="83bfae4e-2717-4d3c-ac11-1767b7313a62">
        <source>getAllCargoGroups(_cargoGroups : CM_TISet input) ;
/*
Purpose:			

Date		Who		Reason
30 June 2023	navab1	 CR 58857 TASK 58967 
*/

vars
	cargoGroupId, keys : String;
	cargoGroupIds, keyIds : StringArray;
	cargoGroup : CM_CargoGroup;
	term : CM_Terminal;
begin
	if _cargoGroups= null then
		return;
	endif;
	
	term := self.myTerminal;
	
	self.allOnshipTIsByCargoGroupId.getCargoGroups(_cargoGroups,term);
	self.allOffsiteTIsByCargoGroupId.getCargoGroups(_cargoGroups,term);
	self.allOnsiteTIsByCargoGroupId.getCargoGroups(_cargoGroups,term);
	self.allNotifiedTIsByCargoGroupId.getCargoGroups(_cargoGroups,term);
	
epilog
end;</source>
        <Parameter name="_cargoGroups" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllCraneDelays" id="ecc94e67-5eeb-4128-9bd9-784c78e9e19c">
        <source>getAllCraneDelays(_coll :Collection input);
/*
	Purpose:		Populate _coll with all crane delays for voyage.
					Up to calling method to decide type of coll
	Parameters:			
	Return Value:		

Date			Who		Reason
31 July 2008	concms1	Par 17592 - Initial creation
*/

vars
	kpi		:Object;
	delay	:CM_Delay;
	isBtree	:Boolean;
begin
	isBtree := _coll.isKindOf(Btree);

	foreach delay in self.allDelays do
		if not delay.myMachine.isKindOf (CM_Crane) then
			continue;
		endif;
		if isBtree then
			_coll.Btree.addNoDuplicates(delay, false);
		else
			_coll.add (delay);
		endif;
	endforeach;
epilog

end;</source>
        <Parameter name="_coll" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllCranes" id="3fcb4ddf-42e3-4eb6-b648-fde545d35dad">
        <updating/>
        <source>getAllCranes(_allCranes : CM_MachineSet input) updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theJS : CM_VoyageJobSheet;
	crane : CM_Crane;
begin
	_allCranes.clear;
	foreach theJS in self.allJobSheets do
		crane := theJS.getMyCrane;
		if crane &lt;&gt; null then	// RBarr 7/7/06 check the crane hasn't got lost (needs an inverse ref)
			_allCranes.add(crane);
		endif;
	endforeach;
end;</source>
        <Parameter name="_allCranes" type="CM_MachineSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllDischargedTIs" id="64b49206-de3e-4bae-b7d2-bd2a9cda3080">
        <source>getAllDischargedTIs(_dischargedTIs : CM_TISet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//26/01/2023	navkc1 CR 61998 Task 62000: UI - Voyage Enq Manifested Cargo Query

*/

vars
	ti				: CM_TrackedItem;
	tiTrans			: CM_TITransaction;
	recShipTrans	: CM_ReceiveShip;
	code			: String;
	
begin
	
	code := self.code;
	
	// Onsite TI
	foreach ti in self.allOnsiteTIsByCargoTypeId discreteLock do
		tiTrans := ti.getFirstTransOfType(TRANS_TYPE_REC_SHIP);
		if tiTrans = null then
			continue;
		endif;
		
		recShipTrans := tiTrans.CM_ReceiveShip;
		
		if recShipTrans.voyageCode &lt;&gt; code then
			continue;
		endif;
		
		_dischargedTIs.add(ti);
	endforeach;
	
	// Offsite TI
	foreach ti in self.allOffsiteTIsByCargoTypeId discreteLock do
		tiTrans := ti.getFirstTransOfType(TRANS_TYPE_REC_SHIP);
		
		if tiTrans = null then
			continue;
		endif;
		
		recShipTrans := tiTrans.CM_ReceiveShip;
		
		if recShipTrans.voyageCode &lt;&gt; code then
			continue;
		endif;
		
		_dischargedTIs.add(ti);
	endforeach;
	
epilog

end;</source>
        <Parameter name="_dischargedTIs" type="CM_TISet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllEDILoadLists" id="e22406fd-fb86-4268-b420-6cc6f4401994">
        <source>getAllEDILoadLists( _ediDatas : CM_EDIDataArray io );

/*
Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
16 April 2009		cnwrl1	PAR 19471 Initial creation - this is a copy of the method that used to be on CM_CellularVoyageStructure
14/07/2025			naviv1	35226	MTN - Usage of Iterator.getCurrentKeys  
*/
	
vars
	ediData		: CM_EDIData;
	ediConfig	: CM_EDIConfig;
	iter		: Iterator;
	keyType		: Integer;
	keyID		: Integer;
	
begin
	ediConfig := self.myTerminal.myEdiConfig;
	
	if ediConfig = null then
		app.raiseUnexpectedProgramError(class.name, method.name, app.getErrorString(ERR_NO_EDI_CONFIG));
		return;
	endif;
	
	iter := ediConfig.allEDIDatasByTypeNumber.createIterator();
	ediConfig.allEDIDatasByTypeNumber.startKeyGeq(EDIDataType_LoadList,0,iter);
	
	while iter.next(ediData) do
		iter.getCurrentKeys(keyType,keyID); //MTN-35226
		
		if keyType &lt;&gt; EDIDataType_LoadList then
			break;
		endif;
		if ediData.CM_EDIDataLoadList.voyageCode = self.code then
			_ediDatas.add(ediData);
		endif;
	endwhile;
	
epilog
	delete iter;
	
end;</source>
        <Parameter name="_ediDatas" type="CM_EDIDataArray" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getAllLcs" id="5197e0f3-0a4e-4dc9-abcd-8ecf357fd40a">
        <source>getAllLcs() : CM_LCSet;
/*
Purpose:			
Date		Who		Reason
16 September 2016	cnwab1	Initial creation
*/

vars
	lcs : CM_LCSet;
	lc : CM_LocationsController;
	bay : CM_BayVoyage;
	deck : CM_DeckVoyage;
begin
	create lcs transient;
	
	if self.myShipBlockStack &lt;&gt; null then
		lcs.add(self.myShipBlockStack);
	endif;
	if self.myCellularVoyageStructure &lt;&gt; null then
		foreach bay in self.myCellularVoyageStructure.allBayVoyagesById discreteLock do
			foreach lc in bay.allSlotControllersByOrdinal discreteLock do
				lcs.addNoDuplicates(lc,false);
			endforeach;
		endforeach;
	endif;

	if self.myROROStructure &lt;&gt; null then
		foreach deck in self.myROROStructure.allDecks discreteLock do
			foreach lc in deck.allROROControllers do
				lcs.addNoDuplicates(lc,false);
			endforeach;
		
		endforeach;
	endif;

	if self.myGeneralCargoVoyage &lt;&gt; null then
		foreach lc in self.myGeneralCargoVoyage.allLocationsByHatchPlace discreteLock do
			lcs.addNoDuplicates(lc,false);
		endforeach;
	endif;

	return lcs;
epilog

end;</source>
        <ReturnType type="CM_LCSet"/>
    </JadeMethod>
    <JadeMethod name="getAllOperatorCodes" id="451ebe53-819a-494f-9b13-8f96e0581e7b">
        <source>getAllOperatorCodes() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 October 2023		jlizm1	Initial creation TFS 60953 POB SQL Extraxt all voyage operators

*/

vars

	operator : CM_Operator;
	returnStr : String;

begin

	foreach	operator in self.allOperators do
 
 		if returnStr = "" then
			returnStr := operator.code;
		else
			returnStr := returnStr &amp; "," &amp; operator.code;
		endif;

	endforeach;
	
	return returnStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getAllResourcesUsed" id="334519dd-839c-47e9-ad13-e2d7d9ca0d57">
        <source>getAllResourcesUsed() : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26/02/2013	cnwdap1	Initial creation PAR #31213 CCMS PNL 2255 Additional SQL Fields
*/
vars
	voyageData	: HMS_VoyageData;
	movement	: HMS_VoyageMovement;
	resources	: String;

begin
	voyageData := self.myHMSVoyageData;
	if voyageData = null then
		return null;
	endif;
	
	foreach movement in voyageData.allVoyageMovements discreteLock do
		resources := resources &amp; movement.getResourceUsedString;
		if resources[resources.length:1] = '.' then
			resources := resources[1:resources.length-1] &amp; ',';
		endif;
	endforeach;
	
	if resources.length &gt; 3 then
		resources := resources[1:resources.length-1];
	endif;
	return resources.removeString(Cr);
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
