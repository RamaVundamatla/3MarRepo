    <JadeMethod name="daysAsTimeStampInterval" id="779347b0-e80c-41f3-a4c6-c2558bd32786">
        <source>daysAsTimeStampInterval():TimeStampInterval;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 June 2018	jlgndl1	Initial creation	TFS 39248

*/

vars

	partDay : Decimal[10,5];
	days : Integer;
	milliseconds : Integer;
	tsi : TimeStampInterval;
	
	oneWholeDay : Integer;

begin
	
	oneWholeDay := 3600 * 24 * 1000;  // in milliseconds
	
	days := self.Integer;
	partDay := self - days;
	milliseconds := ( partDay * oneWholeDay ).Integer;
	
	tsi.set( days, milliseconds );
	return tsi;

epilog

end;</source>
        <ReturnType type="TimeStampInterval"/>
    </JadeMethod>
