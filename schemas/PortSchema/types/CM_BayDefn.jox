    </JadeMethod>
    <JadeMethod name="updateOrdinalIdsNoDups" id="48959d57-914a-4805-8dc7-027bdd522245">
        <updating/>
        <source>updateOrdinalIdsNoDups(newBayOrdinal: Integer; id: String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 February 2013	cnwer1	Initial creation HAT 2189

*/

vars
	dupBay : CM_BayDefn;
	bayHoldIndex : Integer;
	id40 : String;
begin
	dupBay:= self.myVesselCellular.allBaysByOrdinal[newBayOrdinal];
	if dupBay &lt;&gt; null then
		dupBay.setOrdinalBay(dupBay.ordinalBay + CM_Bay.BayOrdinalOffset);
		dupBay.setId((dupBay.id.Integer + CM_Bay.BayOrdinalOffset).String);
		dupBay.setIdBay40((dupBay.idBay40.Integer + CM_Bay.BayOrdinalOffset).String);
	endif;	
	self.setOrdinalBay( newBayOrdinal);
	self.setId(id);
	bayHoldIndex:=self.myHold.allBays.indexOf(self) ;
	id40:=null;
	if	(self.myHold.allBays.size  = 2 and bayHoldIndex = 1 ) or
		(self.myHold.allBays.size  = 3 and (bayHoldIndex = 1 or bayHoldIndex = 2)) then			
		id40:= ( newBayOrdinal * 2).padLeadingWith("0",2);
	endif;
	self.setIdBay40(id40);	

epilog

end;</source>
        <Parameter name="newBayOrdinal" type="Integer"/>
        <Parameter name="id" type="String"/>
    </JadeMethod>
    <JadeMethod name="useCellTierNumbering" id="962fcd45-f7b0-44aa-98eb-f2256e1b3cbf">
