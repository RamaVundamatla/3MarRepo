    <JadeMethod name="doAlignLeft" id="4852c149-fcc9-47b2-9c93-ada5f2c74512">
        <source>doAlignLeft();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 August 2009	cnwer1	Initial creation

*/

vars
	currentFrame : CMUI_Frame;
	originFrame : CMUI_Frame;
	obj : Object;
	origin : Point;
	taViewPos : CM_TerminalAreaViewPosition;
begin
	
	if not self.allSelectedFrames.size &gt; 1 then
		//need more than one selected
		return;
	endif;
	
	currentFrame:=self.allSelectedFrames.last.CMUI_Frame;
	
	
	foreach obj in self.allSelectedFrames do
		if obj = currentFrame then
			break;
		endif;
		originFrame:=obj.CMUI_Frame;
		originFrame.left:=currentFrame.left;
		originFrame.mouseUp(originFrame,1,null,originFrame.left,originFrame.top);

	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doAlignTop" id="b0a1815c-5212-4ec6-aea8-59a551e7bb97">
        <source>doAlignTop();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 August 2009	cnwer1	Initial creation

*/

vars
	currentFrame : CMUI_Frame;
	originFrame : CMUI_Frame;
	obj : Object;
	origin : Point;
	taViewPos : CM_TerminalAreaViewPosition;
begin
	
	if not self.allSelectedFrames.size &gt; 1 then
		//need more than one selected
		return;
	endif;
	
	currentFrame:=self.allSelectedFrames.last.CMUI_Frame;
	
	
	foreach obj in self.allSelectedFrames do
		if obj = currentFrame then
			break;
		endif;
		originFrame:=obj.CMUI_Frame;
		originFrame.top:=currentFrame.top;
		originFrame.mouseUp(originFrame,1,null,originFrame.left,originFrame.top);

	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doAreaDelete" id="b229a87d-1ab0-44ec-9e02-6ab464e661b9">
        <updating/>
        <source>doAreaDelete() updating;

/*

Purpose:		Remove currently selected area from view

Parameters:			

Return Value:		


Date				Who		Reason
02 September 2008	consw1	Initial creation

*/

vars
	areaViewPosition 	: CM_TerminalAreaViewPosition;
	clonedFrame			: Frame;
	
begin
	clonedFrame := self.getCurrentAreaFrame();
	
	if clonedFrame = null then
		return;
	endif;

	areaViewPosition := clonedFrame.userObject.CM_TerminalAreaViewPosition;

	//  Reset area list item
	self.lstAreas.itemObject[self.lstAreas.listIndex] := areaViewPosition.myTerminalArea;
	
	//  Hide the frame - it will be deleted when the form is deleted/refreshed
	clonedFrame.visible := false;
	app.mousePointer := Window.MousePointer_Default;

	
	clonedFrame.userObject :=null; //epr TFS 2057 12/7/16
	//  Delete the proxy
	delete areaViewPosition;
	
	self.enableAreaButtons();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doAreaNew" id="ef27ba48-45ef-48f3-a9d4-a711c78249f3">
        <updating/>
        <source>doAreaNew() updating;

/*

Purpose:		Add new area to view

Parameters:			

Return Value:		


Date				Who		Reason
04 September 2008	consw1	Initial creation

*/

vars
	clonedFrame : Frame;
	obj : Object;

begin
	obj := lstAreas.listObject;
	
	if 	obj &lt;&gt; null and obj.isKindOf(CM_TerminalArea) and (self.isEditMode or self.isAddMode)  then
		self.lstAreas.itemObject[self.lstAreas.listIndex] := self.addArea(obj.CM_TerminalArea);
	endif;

	self.enableAreaButtons();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBaseFormCancel" id="b909a102-7c01-43d6-9a40-32f2cbf9f764">
        <updating/>
        <source>doBaseFormCancel() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
01 September 2008	consw1	Initial creation

*/

vars

begin
	inheritMethod();
	
	//  Reset edit mode
	self.setEditMode(false);

	//  Re-display areas
	self.populateForm();

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBaseFormSave" id="0ae09f59-ea38-45da-a5d8-8e9f5b432597">
        <updating/>
        <source>doBaseFormSave() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
01 September 2008	consw1	Initial creation

*/

vars
	areaView : CM_TerminalAreaView;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
begin

	//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		if self.isEditMode then
			app.myTrxUA.trxUpdateTerminalAreaView(self.myProxyAreaView, app.myPassport);
		elseif self.isAddMode then
			app.myTrxCA.trxCreateTerminalAreaView(self.myProxyAreaView,areaView, app.myPassport);	
			self.setMyAreaView(areaView);
		endif;
	
		if app.myPassport.trxCompletedOK then
			if self.isEditMode then
				self.setEditMode(false);
			elseif  self.isAddMode then
				self.setNewMode(false);
			endif;
			break;
		else
			theResult := app.showErrorWarningDialog(self.caption, app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return;
		
	endwhile;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doEditTAView" id="abe384f7-d9b8-4725-a9f6-51f1e5e59b5d">
        <updating/>
        <source>doEditTAView(_enable :Boolean) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 November 2010	cnwer1	Initial creation

*/

vars

begin
	self.btnSearch.enabled		:= not _enable;
	self.btnSaveBase.enabled 	:= _enable;
	self.btnCancelBase.enabled 	:= _enable;
	self.btnEdit.enabled 		:= not _enable;

	self.lstAreas.enabled		:= _enable;
	self.lstAreas.multiSelect:=ListBox.MultiSelect_Extended;
	self.populateForm();
	self.allSelectedFrames.clear;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
	self.btnEdit.enabled 		:= false;

	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
