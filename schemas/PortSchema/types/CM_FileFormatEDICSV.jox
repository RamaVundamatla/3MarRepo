    <JadeMethod name="addFileFieldNew" id="190e884d-cd75-4757-a54e-aef62f4fb837">
        <source>addFileFieldNew(_xmlElement: JadeXMLElement);
//----------------------------------------------------------------
//	Created:	16 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	fileField	: CM_EDIItemFieldCSV;
begin

	create fileField persistent;
	
	fileField.setFromXML(_xmlElement);
	fileField.setFileFormat(self);
	
end;</source>
        <Parameter name="_xmlElement" type="JadeXMLElement"/>
    </JadeMethod>
