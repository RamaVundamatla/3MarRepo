    <JadeMethod name="getAnswerFromMethod" id="93e05a01-2481-4a86-8ec8-d23cf417ff26">
        <source>getAnswerFromMethod(_theMethod : String;_theTI : CM_TrackedItem) : Boolean;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	tmpMethod	: Method;

begin
	if _theTI = null then
		return false;
	endif;
	
	// check to see if the method exists on the class
	// we are looking at.  Need to look up everytime as
	// we need to get the correct method for this sub-class,
	// and not one for another sub-class
	tmpMethod := _theTI.class.getMethodInHTree(_theMethod);
	if (tmpMethod = null) then
		return false;
	endif;
	

	if tmpMethod.isMappingMethod() then
		return _theTI.getPropertyValue(_theMethod).Boolean;
	endif;
	
	return _theTI.sendMsg(_theMethod).Boolean;

end;</source>
        <Parameter name="_theMethod" type="String"/>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAuditText" id="4f1ece0f-2110-402c-bc65-d7addcdd4d05">
        <source>getAuditText(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 January 2017	cnwma1	Initial creation

*/

vars
	txt,
	tmpStr	: String;
begin
	txt[10000] 	:= '*';
	txt 		:= null;
	txt 		:= inheritMethod();
	
	tmpStr := self.getTranMapBreadCrumb;
	txt := txt &amp; 'Item Path' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;
	if self.myDebtorNode &lt;&gt; null then
		tmpStr := self.myDebtorNode.name;
		txt := txt &amp; app.getErrorString(Debtor_GC) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.myDebtorType &lt;&gt; null then
		tmpStr := self.myDebtorType.description;
		txt := txt &amp; app.getErrorString(Debtor_type) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	if self.getMyTerminal &lt;&gt; null then
		tmpStr := self.getMyTerminal.name;
		txt := txt &amp; app.getErrorString(Terminal) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	tmpStr := null;
	if self.myServiceBroker.getBank &lt;&gt; null then
		tmpStr := self.myServiceBroker.getBank.mailingName;
		txt := txt &amp; app.getErrorString(CM_Business_Unit) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	
	return txt;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBank" id="d94fdea3-8900-4695-bb07-8675a526814f">
        <source>getBank() : CM_Bank;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
// 15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map
// ---------------------------------------------------------------------------

vars
	comMap : CM_CommodityMap;
begin
	if self.myServiceBroker.isKindOf(CM_TransServiceBroker) then
		comMap := self.myServiceBroker.CM_TransServiceBroker.commodityMap;
		return comMap.contentsMap.imexMap.myProductMap.myProductGroupMap.myCargoTypeMap.transactionMap.bank;
	elseif self.myServiceBroker.isKindOf(CM_ResourceServiceBroker) then
		return self.myServiceBroker.CM_ResourceServiceBroker.myTransMap.myBank;
	elseif self.myServiceBroker.isKindOf(CM_EventServiceBroker) then
		return self.myServiceBroker.CM_EventServiceBroker.myTranMap.myBank;
	elseif self.myServiceBroker.isKindOf(CM_WorkOrderServiceBroker) then // TFS 39236
		return self.myServiceBroker.CM_WorkOrderServiceBroker.myTransMap.myBank; // TFS 39236
	elseif self.myServiceBroker.isKindOf(CM_BOLServiceBroker) then // 04 Nov 2019	NDL	TFS 47100
		return self.myServiceBroker.CM_BOLServiceBroker.myTransMap.myBank; // 04 Nov 2019	NDL	TFS 47100
	elseif self.myServiceBroker.isKindOf(CM_MoveServiceBroker) then
		comMap := self.myServiceBroker.CM_MoveServiceBroker.commodityMap;
		return comMap.contentsMap.imexMap.myProductMap.myProductGroupMap.myCargoTypeMap.transactionMap.bank;
	elseif self.myServiceBroker.isToDoRsrcServiceBroker() then
		return self.myServiceBroker.getBank(); // 15/05/2023	navkc1	CR 57927 Task 54268
	else	
		return null;
	endif;
end;</source>
        <ReturnType type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="getDebtorDescription" id="094e7943-aa7b-4b0b-9e28-ddb0a6a618bc">
        <source>getDebtorDescription() : String;

vars
	desc	: String;
begin
	if self.myDebtorNode = null then
		desc := "(Default)";
	else
		desc := self.myDebtorNode.name;
	endif;
	return desc;

end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDebtorFromBOLTransaction" id="650e6c52-ea8f-4562-a077-c8411b18db5e">
        <source>getDebtorFromBOLTransaction(transaction: CM_BOLTransaction) : CM_Debtor;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods
*/
vars

	debtor:       CM_Debtor;
	lMessageText	: String;
	myDebtorTypeCode : String;
	debtorType :CM_DebtorType;
	canLogExtra	: Boolean;	//26.02.2025 navah1	#34141
	
begin
	canLogExtra	:= app.canLogExtraDetail();				//26.02.2025 navah1	#34141
	if self.myDebtorType &lt;&gt; null then
		myDebtorTypeCode := self.myDebtorType.code;
	
		if myDebtorTypeCode = CM_DebtorType.DT_BOL_OPERATOR then
			lMessageText := "Debtor for BOL Operator Charge";
			debtor := transaction.getDebtorFromOperator;
	
		elseif myDebtorTypeCode = CM_DebtorType.DT_BOL_ITEM_FIRST_CONSEE then
			lMessageText := "Debtor for BOL First Item Consignee Charge";
			debtor := transaction.getDebtorFromConsignee;
	
		elseif myDebtorTypeCode = CM_DebtorType.DT_BOL_ITEM_FIRST_CONSOR then
			lMessageText := "Debtor for BOL First Item Consignor Charge";
			debtor := transaction.getDebtorFromConsignor;
			
		elseif myDebtorTypeCode = CM_DebtorType.DT_BOL_VOY_OPERATOR then
			lMessageText := "Debtor for BOL Voyage Operator Charge";
			debtor := transaction.getDebtorFromShipOperator;
		
		endif;
	
	endif;
	
	if debtor &lt;&gt; null then
		if debtor.isSuspended then
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog(lMessageText &amp; " " &amp; debtor.name &amp; " not used, is suspended", LogINFO.String);  	// navlw1 #MTN-33107
			endif;
			debtor := null;
		else
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog(lMessageText &amp; " " &amp; debtor.name, LogINFO.String);  								// navlw1 #MTN-33107
			endif;
		endif;
	endif;
	
	if debtor = null then	
		debtor := app.myRoot.getDefaultDebtor( transaction.myTerminal );	
		if debtor &lt;&gt; null then
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog("Default debtor " &amp; debtor.name &amp; " used", LogINFO.String);  						// navlw1 #MTN-33107
			endif;
		endif;
	endif;

	return debtor;
end;</source>
        <Parameter name="transaction" type="CM_BOLTransaction"/>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDebtorFromTransaction" id="637c4755-1803-43d1-8be8-bb9fb878b787">
        <source>getDebtorFromTransaction(transaction: CM_TITransaction) : CM_Debtor;
/*

Purpose: 24051 copied and changed from CM_InvoiceLineDesc getDebtorFromTransaction 		

Parameters:			

Return Value:		

Date		Who		Reason
13/01/2017	cnwdap1	TFS 3042 SNO Empty Container Pool Management - new debtor type "Empty Pool Party"
05/06/2019	jlgdap1	TFS 44554 AAT Stevedore Data Access
04 Nov 2020 cnwma1 	ChangeRequest 50112: ASPA - GCI Stevedores
01.06.2022 	navak20 ChangeRequest 53195: EUP - GEN/REP/INB - Additional Cargo Field – Shipping Line - Portschema
18 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
25 Feb 2025	navah1	Story 34141: MTN - Performance Improvements - Review for invLog() Methods	
*/

vars
	debtor			 : CM_Debtor;
	chargeableBusinessUnit: CM_Bank;
	tmpCode,
	lMessageText	 : String;
	tmpConsigneeOr	 : CM_ConsigneeConsignor;
	tmpVoyage		 : CM_Voyage;
	tmpOperator		 : CM_Operator;
	tmpCA 		     : CM_CustomsAgent;
	tmpCarrier		 : CM_Carrier;
	myDebtorTypeCode : String;
	debtorType 		 : CM_DebtorType;
	tmpPoolParty     : CM_MTPoolingParty;		// TFS 3042
	opTerm 			 : CM_OperatorTerminal;		// TFS 3042
	tmpStevedore 	: CM_Stevedore;				// TFS 44554
	tmpShipLine		: CM_ShippingLine;			//TFS 53195
	canLogExtra		: Boolean;					//26.02.2025 navah1	#34141
begin
	canLogExtra	:= app.canLogExtraDetail();		//26.02.2025 navah1	#34141
	if self.myDebtorType &lt;&gt; null then
		myDebtorTypeCode := self.myDebtorType.code;
	
		if myDebtorTypeCode = CM_DebtorType.DT_CARGO_OPERATOR then
			lMessageText := "Debtor for Cargo Operator ";
			tmpCode := transaction.operatorCode;
			if tmpCode &lt;&gt; null then
				tmpOperator := app.myRoot.allOperators[tmpCode];
				if tmpOperator &lt;&gt; null then
					debtor := tmpOperator.debtor;
				endif;
			endif;
	
		elseif myDebtorTypeCode = CM_DebtorType.DT_CONSIGNEE then
			lMessageText := "Debtor for Consignee ";
			tmpCode := transaction.consignee;
			if tmpCode &lt;&gt; null then
				tmpConsigneeOr := app.myRoot.allConsigneeConsignors[tmpCode];
				if tmpConsigneeOr &lt;&gt; null then
					debtor := tmpConsigneeOr.debtor;
				endif;
			endif;
	
		elseif myDebtorTypeCode = CM_DebtorType.DT_CONSIGNOR then
			lMessageText := "Debtor for Consignor ";
			tmpCode := transaction.consignor;
			if tmpCode &lt;&gt; null then
				tmpConsigneeOr := app.myRoot.allConsigneeConsignors[tmpCode];
				if tmpConsigneeOr &lt;&gt; null then
					debtor := tmpConsigneeOr.debtor;
				endif;
			endif;
			
		elseif myDebtorTypeCode = CM_DebtorType.DT_SHIP_OPERATOR then
			lMessageText := "Debtor for Ship Operator ";
			tmpVoyage := transaction.getVoyage();
			if tmpVoyage &lt;&gt; null then
				tmpOperator := tmpVoyage.myOperator;
				if tmpOperator &lt;&gt; null then
					debtor := tmpOperator.debtor;
				endif;
			endif;
		elseif myDebtorTypeCode = CM_DebtorType.DT_BUSINESS_UNIT then
			lMessageText := "Debtor for Business Unit ";
			chargeableBusinessUnit := transaction.getChargeableBusinessUnit;
			if chargeableBusinessUnit &lt;&gt; null then
				debtor := chargeableBusinessUnit.businessUnitDebtor;
			endif;
	
		elseif myDebtorTypeCode = CM_DebtorType.DT_FREIGHT_FORWARDER then
			lMessageText := "Debtor for Freight Forwarder ";
			tmpCode := transaction.freightForwarderCode;
			
			if tmpCode &lt;&gt; null then
				tmpConsigneeOr := app.myRoot.allConsigneeConsignors[tmpCode];
				if tmpConsigneeOr &lt;&gt; null then
					debtor := tmpConsigneeOr.debtor;
				endif;
			endif;
		elseif myDebtorTypeCode = CM_DebtorType.DT_CUSTOMS_AGENT then
			lMessageText := "Debtor for Customs Agent ";
			tmpCode := transaction.customsAgentCode;
			if tmpCode &lt;&gt; null then
				tmpCA := app.myRoot.allCustomsAgents[tmpCode];
				if tmpCA &lt;&gt; null then
					debtor := tmpCA.myDebtor;
				endif;
			endif;
			// 24094 add carrier
		elseif myDebtorTypeCode = CM_DebtorType.DT_CARRIER then
			lMessageText := "Debtor for Carrier ";
			if transaction.myTrackedItem &lt;&gt; null then
				tmpCode := transaction.myTrackedItem.carrier;
				if tmpCode &lt;&gt; null then
					tmpCarrier := app.myRoot.allCarriers[tmpCode];
					if tmpCarrier &lt;&gt; null then
						debtor := tmpCarrier.myDebtor;
					endif;
				endif;
			endif;
			
		elseif myDebtorTypeCode = CM_DebtorType.DT_EMPTY_POOL_PARTY then						// TFS 3042
			lMessageText := "Debtor for Empty Pool Party";										// TFS 3042
			if transaction.myTrackedItem &lt;&gt; null then											// TFS 3042
				tmpCode := transaction.myTrackedItem.myPoolingPartyCode;						// TFS 3042
				if tmpCode &lt;&gt; null then															// TFS 3042
					tmpPoolParty := self.getMyTerminal.allMTPoolingParties[tmpCode];			// TFS 3042
					if tmpPoolParty &lt;&gt; null then												// TFS 3042
						foreach opTerm in tmpPoolParty.allOperatorTerminals do					// TFS 3042
							if opTerm.myOperator.debtor &lt;&gt; null then							// TFS 3042
								if not opTerm.myOperator.debtor.isRDT then						// TFS 3042
									debtor := opTerm.myOperator.debtor;							// TFS 3042
								endif;															// TFS 3042
							endif;																// TFS 3042
						endforeach;																// TFS 3042
					endif;																		// TFS 3042
				endif;																			// TFS 3042
			endif;																				// TFS 3042
		
		// TFS 44554 Stevedore Debtor Type
		elseif myDebtorTypeCode = CM_DebtorType.DT_STEVEDORE_VOYAGE then  //04.11.2020 cnwma1 TFS #50112
			lMessageText := "Debtor for Stevedore for Voyage ";           //04.11.2020 cnwma1 TFS #50112
			tmpCode := transaction.stevedoreCode;
			if tmpCode &lt;&gt; null then
				tmpStevedore := app.myRoot.allStevedores[tmpCode];
				if tmpStevedore &lt;&gt; null then
					debtor := tmpStevedore.myDebtor;
				endif;
			endif;
		// TFS 44554 end
		elseif myDebtorTypeCode = CM_DebtorType.DT_STEVEDORE_RECEIVE then  //04.11.2020 cnwma1 TFS #50112
			lMessageText := "Debtor for Stevedore for Receive ";           //04.11.2020 cnwma1 TFS #50112
			tmpCode := transaction.stevedoreCode;
			if tmpCode &lt;&gt; null then
				tmpStevedore := app.myRoot.allStevedores[tmpCode];
				if tmpStevedore &lt;&gt; null then
					debtor := tmpStevedore.myDebtor;
				endif;
			endif;
		elseif myDebtorTypeCode = CM_DebtorType.DT_STEVEDORE_RELEASE then  //04.11.2020 cnwma1 TFS #50112
			lMessageText := "Debtor for Stevedore for Release ";           //04.11.2020 cnwma1 TFS #50112
			tmpCode := transaction.stevedoreCode;
			if tmpCode &lt;&gt; null then
				tmpStevedore := app.myRoot.allStevedores[tmpCode];
				if tmpStevedore &lt;&gt; null then
					debtor := tmpStevedore.myDebtor;
				endif;
			endif;
		// 01.06.2022 navak20 TFS 53195 Start 
		elseif myDebtorTypeCode = CM_DebtorType.DT_SHIPPING_LINE   // May 13, 2022 navak20 TFS #53195
		or myDebtorTypeCode = CM_DebtorType.DT_SHIPPING_LINE_DESC then  // ### TFS BUG 56663 23FEB2023 NAVAB1
			lMessageText := "Debtor for Shipping Line ";          
			/* // ### TFS BUG 56663 23FEB2023 NAVAB1
			tmpCode := transaction.shippingLineCode;
			if tmpCode &lt;&gt; null then
				tmpShipLine := app.myRoot.allShippingLines[tmpCode];
				if tmpShipLine &lt;&gt; null then
					debtor := tmpShipLine.myDebtor;
				endif;
			endif;
			*/
			tmpShipLine := transaction.getShippingLineObject();
			if tmpShipLine &lt;&gt; null then
				debtor := tmpShipLine.myDebtor;
			endif;
			/*  // ### TFS BUG 56663 23FEB2023 NAVAB1
		elseif myDebtorTypeCode = CM_DebtorType.DT_SHIPPING_LINE_DESC then  // May 13, 2022 navak20 TFS #53195
			lMessageText := "Debtor for Shipping Line Description ";          
			tmpCode := transaction.shippingLineCode;
			if tmpCode &lt;&gt; null then
				tmpShipLine := app.myRoot.allShippingLines[tmpCode];
				if tmpShipLine &lt;&gt; null then
					debtor := tmpShipLine.myDebtor;
				endif;
			endif;
			*/
		//TFS 53195 End
		else
			debtorType := self.myDebtorType;
			
			//User defined debtor type
			lMessageText := "Debtor for" &amp; debtorType.description;
			debtor := transaction.allDebtorsByType[myDebtorTypeCode];
		endif;
	
	endif;
	
	if debtor &lt;&gt; null then
		if debtor.isSuspended then
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog(lMessageText &amp; " " &amp; debtor.name &amp; " not used, is suspended", LogINFO.String);  	// navlw1 #MTN-33107
			endif;
			debtor := null;
		else
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog(lMessageText &amp; " " &amp; debtor.name, LogINFO.String);  								// navlw1 #MTN-33107
			endif;
		endif;
	endif;
	
	if debtor = null then	
		debtor := app.myRoot.getDefaultDebtor( transaction.myTerminal );	//14 Sep 2012	NDL	Par 30375
		if debtor &lt;&gt; null then
			if canLogExtra then	//26.02.2025 navah1	#34141
				app.invLog("Default debtor " &amp; debtor.name &amp; " used", LogINFO.String);  						// navlw1 #MTN-33107
			endif;
		endif;
	endif;

	return debtor;
end;</source>
        <Parameter name="transaction" type="CM_TITransaction"/>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
    <JadeMethod name="getDebtorTypeFromILD" id="bcaa5a6f-5baa-4f58-be93-73487254b5f8">
        <source>getDebtorTypeFromILD() : CM_DebtorType;
// 24051 to add debtor type to existing debtor maps
vars
	ild : CM_InvoiceLineDesc;
	lclSBController : CMIF_ServiceBroker;
	qrm	: CM_QuantityRangeMap;
	mapping : CM_TranMapInvoiceLineMapping;
begin

	create lclSBController transient;

	self.getInvoiceLineDesc(lclSBController);
		
	foreach ild in lclSBController.allInvoiceLineTypes where ild.myDebtorType &lt;&gt; null do
		break;
	endforeach;
		
	if ild &lt;&gt; null and ild.myDebtorType &lt;&gt; null then
		return ild.myDebtorType;
	endif;
	
	if self.myChildQuantityMap &lt;&gt; null then
		foreach qrm in self.myChildQuantityMap.allQuantityRanges do
		
			foreach mapping in qrm.allTMInvoiceLineMappings do // TFS 40620
				ild := mapping.myTMInvoiceLineDesc; // TFS 40620
		
			// TFS 40620 foreach ild in qrm.allInvoiceLineMaps do
				if ild.myDebtorType &lt;&gt; null then
					return ild.myDebtorType;
				endif;
			endforeach;
		endforeach;
	endif;
	
	return null;
epilog
	delete lclSBController;
end;</source>
        <ReturnType type="CM_DebtorType"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="72fc2b65-6da7-4ea7-8682-e0ddc75f8db3">
