    <JadeMethod name="setProxyVoyageHoldJob" id="6eeeb285-0fa7-423f-95df-fac6badeb7d0">
        <updating/>
        <source>setProxyVoyageHoldJob(	_craneID,
						_jobNum,
						_remarks,	
						_systemRemarks : String;
						_isTwinLift	: Boolean;
						_jobType : Integer;
						_userJobType : CM_JobType;
						_estimatedTimeToCompleteMins : Integer;
						_actualStartTs,
						_actualEndTs : TimeStamp;
						_outOfSequenceLoading : Boolean;
						_shift : CM_Shift;
						_dlrDischargeJob : CM_VoyageHoldJob;					// TFS 3516
						_allocatedTIs : CM_TISet;
						_estimatedStartDT,
						_estimatedEndDT : TimeStamp) updating;
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 14/03/2017	cnwdap1		TFS 3516 LNX Hold Planning Quantity
// 24/07/2018	jlgam15		TFS 39837 Work Order Cargo Request additional fields
vars
	ti : CM_TrackedItem;

begin
	self.jobNum := _jobNum;
	self.id :=  _jobNum;
	self.remarks := _remarks.trimBlanks;
	self.systemRemarks := _systemRemarks.trimBlanks;
	self.craneId := _craneID;
	self.actualStartTs := _actualStartTs;
	self.actualEndTs := _actualEndTs;
	self.isTwinLift := _isTwinLift;
	self.jobType := _jobType;
	self.estimatedStartTS := _estimatedStartDT;
	self.estimatedEndTS := _estimatedEndDT;
	
	// TFS 3631 if self.jobType = JOB_TYPE_USER then
	// TFS 3631 	self.myUserJobType := _userJobType;
		self.estimatedTimeToCompleteMins := _estimatedTimeToCompleteMins;
	// TFS 3631 endif;
	self.allowOutOfOrderLoading := _outOfSequenceLoading;
	
	self.myShift := _shift;
	self.myDLRDischargeJob := _dlrDischargeJob;					// TFS 3516
	
	if _allocatedTIs&lt;&gt; null then
		if self.jobType = JOB_TYPE_DISCHARGE then
			self.allReceiveTrackedItems.clear;
			foreach ti in _allocatedTIs do
				self.allReceiveTrackedItems.add(ti);
			endforeach;
		elseif self.jobType = JOB_TYPE_LOAD then
			self.allReleaseTrackeditems.clear;
			foreach ti in _allocatedTIs do
				self.allReleaseTrackeditems.add(ti);
			endforeach;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_craneID" type="String"/>
        <Parameter name="_jobNum" type="String"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_systemRemarks" type="String"/>
        <Parameter name="_isTwinLift" type="Boolean"/>
        <Parameter name="_jobType" type="Integer"/>
        <Parameter name="_userJobType" type="CM_JobType"/>
        <Parameter name="_estimatedTimeToCompleteMins" type="Integer"/>
        <Parameter name="_actualStartTs" type="TimeStamp"/>
        <Parameter name="_actualEndTs" type="TimeStamp"/>
        <Parameter name="_outOfSequenceLoading" type="Boolean"/>
        <Parameter name="_shift" type="CM_Shift"/>
        <Parameter name="_dlrDischargeJob" type="CM_VoyageHoldJob"/>
        <Parameter name="_allocatedTIs" type="CM_TISet"/>
        <Parameter name="_estimatedStartDT" type="TimeStamp"/>
        <Parameter name="_estimatedEndDT" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setTITransitStatus" id="05b8763f-7bb3-4418-8ed6-7edb0c0ffd7c">
        <source>setTITransitStatus(_jobParams : CMIF_VoyageJobParams; _tis : CM_TISet; _passport : CM_Passport input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 21/02/2017	cnwdap1		Initial creation TFS 3489 LNX DLR/SOB
// 05/05/2022	jlizm1		TFS 53083 GPHA revceival/release of tranship cargo
//
vars
	ti : CM_TrackedItem;

begin
	foreach ti in _tis do
		if _jobParams.isDischarge and ti.isTranshipInterModal  and _jobParams.transitStatus = TI_TransitStatusNull then
			// tranship inter-modal cargo should retain its transit status
			continue;
		endif;
		ti.setTransitStatus(_jobParams.transitStatus, true, _passport);
	endforeach;
epilog

end;</source>
        <Parameter name="_jobParams" type="CMIF_VoyageJobParams"/>
        <Parameter name="_tis" type="CM_TISet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTransferType" id="c4858180-473c-43fe-8e0d-9d75b44c9c16">
        <updating/>
        <source>setTransferType(_tfrType: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 March 2018	jlgndl1	Initial creation	TFS 37444

*/

vars

begin

	self.transferType :=  _tfrType; // Defaults to ROR but allowed to be changed.

epilog

end;</source>
        <Parameter name="_tfrType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setWLEQuantities" id="c806e8ba-2d1d-4176-9ae6-529b50c32c73">
        <updating/>
        <source>setWLEQuantities(_wleArray : CM_WLEArray) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 01/03/2017	cnwdap1		Initial creation TFS 3516 LNX Hold Planning Quantity
//
vars
	wle, realWLE : CM_WorkListEntry;
	ti : CM_TrackedItem;
	coll : CM_TISet;

begin
	// go through the TIs on this job, and chck for a WLE that matches - then update the real WLE
	// on the TI with the quantity / weight from the array WLE
	if self.isDischarge then
		coll := self.allReceiveTrackedItems;
	else
		coll := self.allReleaseTrackeditems;
	endif;
	
	foreach ti in coll do
		foreach wle in _wleArray where wle.myTrackedItem = ti do
			foreach realWLE in ti.allWorklistEntries where realWLE.job = self do
				realWLE.setQuantity(wle.quantity);
				realWLE.setWeight(wle.weight);
				break;
			endforeach;
		endforeach;
	endforeach;
			
epilog

end;</source>
        <Parameter name="_wleArray" type="CM_WLEArray"/>
    </JadeMethod>
    <JadeMethod name="splitSelectedWLEs" id="d9d438f3-03c1-47ce-ac43-f6b8df3855e7">
        <updating/>
        <source>splitSelectedWLEs(_newJob			: CM_VoyageJob output; 
				  _selectedWLEs 	: CM_WLESet;
				  _newJobNum,
				  _newCrane 		: String;
				  _targetJob 		: CM_VoyageJob) updating;
/*
Purpose:			
Date				Who			Reason
MARCH 2017			CNWAB1		Initial creation
06/01/2020			jlgdap1		TFS 47144 JMT Refactor OOW Job Split Transfer
10/12/2021		    navma1		Bug 52539: SAL - Hold Planning Split Work - Delete Job
*/

vars
	wle 	  : CM_WorkListEntry;
	holdReq, 
	oldReq 	  : CM_HoldRequest;
	totQty 	  : Integer;
	totWeight : Real;
	jobParams : CMIF_VoyageJobParams;
	currReq   : CM_HoldRequest;				// TFS 47144
	trans     : CM_TITransaction;
begin
	
	if self.status = JOB_COMPLETE then
		app.setContinueCMExceptions(false);
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid status for split');
		return;
	endif;

	create jobParams transient;
	jobParams.myJobSheet := self.myVoyage.allJobSheets[_newCrane];
	
	if _targetJob &lt;&gt; null then
		_newJob := _targetJob;
	else
		// Only create the one new job 
		// for all selected WLEs to be attached to
		_newJob 			  := self.cloneSelf(false);
		_newJob.status 		  := JOB_UNACTIONED;
		_newJob.actualStartTs := self.actualStartTs;
		_newJob.actualEndTs   := self.actualEndTs;
		_newJob.myVoyage	  := self.myVoyage;
		_newJob.setJobNum(_newJobNum);
		_newJob.setCrane(jobParams,_newCrane);
		_newJob.setMyShift(self.myShift);
	endif;
	
	wle := _selectedWLEs.first;
	if wle &lt;&gt; null then
		oldReq := wle.myRequest.CM_HoldRequest;
		
		//_newJob.updateTICollections(wle.myTrackedItem,null); // TFS 3646				//10.12.21 navma1 #52539
		
		//10.12.21 navma1 #52539
		foreach wle in _selectedWLEs do
			_newJob.updateTICollections(wle.myTrackedItem,null);
			self.updateTICollectionsUnassign(wle.myTrackedItem);
		endforeach;

		foreach trans in self.CM_VoyageHoldJob.allShipReceivals do
			self.updateTICollections(trans.myTrackedItem,null);
		endforeach;
		
		foreach trans in self.CM_VoyageHoldJob.allShipReleases do
			self.updateTICollections(trans.myTrackedItem,null);
		endforeach;
		//10.12.21 navma1 #52539
	endif;
	
	create holdReq;
	holdReq.setJob(_newJob);
	
	if oldReq &lt;&gt; null and oldReq.myReserveDetail &lt;&gt; null then
		holdReq.setMyBulkReleaseReserveDetail(oldReq.myReserveDetail);
		holdReq.setMyOriginatingBulkRelease(oldReq.myReserveDetail.myReserveHeader);
	
	endif;

	if oldReq &lt;&gt; null then														// TFS 47144
		holdReq.setMoveType(oldReq.moveType);
	else																		// TFS 47144
		holdReq.setMoveType(self.allRequests.first.CM_HoldRequest.moveType);	// TFS 47144
	endif;																		// TFS 47144
	
	if _selectedWLEs.isEmpty then												// TFS 47144
		currReq := self.allRequests.first.CM_HoldRequest;						// TFS 47144
		foreach wle in currReq.allWorkListEntries do							// TFS 47144
			totQty 	  := totQty + wle.quantity;									// TFS 47144
			totWeight := totWeight + wle.weight;								// TFS 47144
			holdReq.addWLE(wle.CM_VoyageWLE,wle.myTrackedItem);					// TFS 47144
		endforeach;																// TFS 47144
	else																		// TFS 47144
		foreach wle in _selectedWLEs do
			totQty 	  := totQty + wle.quantity;
			totWeight := totWeight + wle.weight;
			
			holdReq.addWLE(wle.CM_VoyageWLE,wle.myTrackedItem);
		endforeach;
	endif;																		// TFS 47144

	holdReq.setForUpdateQuantity(totQty); 
	holdReq.setForUpdateWeight(totWeight); 

	_newJob.setRemarks(""); // TFS 3646

	self.rebuildStatus();


epilog
	delete jobParams;
end;</source>
        <Parameter name="_newJob" type="CM_VoyageJob" usage="output"/>
        <Parameter name="_selectedWLEs" type="CM_WLESet"/>
        <Parameter name="_newJobNum" type="String"/>
        <Parameter name="_newCrane" type="String"/>
        <Parameter name="_targetJob" type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="validateForVoyageRequests" id="ec4a5f07-af75-44c4-88f0-576b2b47ecd9">
        <source>validateForVoyageRequests(_jobParams: CMIF_VoyageJobParams input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 10/03/2017	cnwdap1		TFS 3516 LNX Hold Planning Quantity
//
vars
	shift : CM_Shift;
	isDLR, isNormal : Boolean;				// TFS 3516
	ti : CM_TrackedItem;					// TFS 3516
	wle : CM_WorkListEntry;					// TFS 3516

begin
	inheritMethod(_jobParams);
	
	// do we have a code?
	if self.id = null then
		app.raiseCMException(Input_required_field_jobID, null, null);
	endif;
	
	// do we have a shift?
	if self.myShift = null then
		app.raiseCMException1(NO_Shifts, self.id, null, null);
	endif;
	
	// does the shift have a kosher start and end time, and is the end time after the start time?
	shift := self.myShift;
	if not shift.startDateTime.isValid() then
		app.raiseCMException1(ERR_INVALID_TIMESTAMP, 'Start Date', null, null);
	endif;
	if not shift.endDateTime.isValid() then
		app.raiseCMException1(ERR_INVALID_TIMESTAMP, 'End', null, null);
	endif;
	if shift.endDateTime &lt; shift.startDateTime then
		app.raiseCMException1(ERR_SHIFT_WRONG_TIME, null, null, null);
	endif;
	
	// do we have a work point?
	if _jobParams.myWorkPoint = null then
		app.raiseCMException(Input_required_field_workPoint, null, null);
	endif;
	
	// do we have any cargo?
	if self.allReceiveTrackedItems.isEmpty and self.allReleaseTrackeditems.isEmpty then
		//app.raiseCMWarning(No_Cargo_Assigned_To_Job, null, null, null);
		app.raiseCMException(No_Cargo_Assigned_To_Job, null, null);	//28 Feb 2017	NDL	TFS 3562
	endif;

	// cannot mix DLR and normal loads in the same job								// TFS 3516
	foreach ti in self.allReleaseTrackeditems do									// TFS 3516
		if ti.isRehandle then														// TFS 3516
			isDLR := true;															// TFS 3516
		else																		// TFS 3516
			isNormal := true;														// TFS 3516
		endif;																		// TFS 3516
	endforeach;																		// TFS 3516
	if isDLR and isNormal then														// TFS 3516
		app.raiseCMException1(Cannot_Mix_DLR_And_Load, self.id, null, null);		// TFS 3516
	endif;																			// TFS 3516
	// DLR load jobs need a DLR discharge reference									// TFS 3516
	if not self.isDischarge and isDLR and self.myDLRDischargeJob = null then		// TFS 3516
		app.raiseCMException1(DLR_Load_Must_Have_Discharge, self.id, null, null);	// TFS 3516
	endif;																			// TFS 3516
epilog

end;</source>
        <Parameter name="_jobParams" type="CMIF_VoyageJobParams" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateRemoveTIsFromJob" id="9061dc05-9375-4ac9-9616-b70dbbc5e028">
        <source>validateRemoveTIsFromJob(_tisToRemove : CM_TISet) : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 23/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Ehancements
// 19/02/2022	navdap1		TFS 52801 SAL Direct Delivery - End of Shift Job Transfer
//
vars
	ti, splitTI : CM_TrackedItem;
	noError : Boolean;

begin
	noError := true;
	if self.status = JOB_COMPLETE then
		noError := false;
		app.raiseCMException1(ERR_JOB_COMPLETE, self.id, null, null);
	endif;
	
	if _tisToRemove.isEmpty then
		noError := false;
		app.raiseCMException(SELECT_ITEM_TO_REMOVE, null, null);
	endif;
	
	// if TI has already been moved, can't remove it from the job
	foreach ti in _tisToRemove discreteLock do
		if self.isDischarge and not ti.myPrimaryActualLocation.isVoyageController then
			noError := false;
			app.raiseCMException3(Cargo_item_cannot_removed, ti.id, self.id, app.getErrorString(Discharged), null, null);
		// TFS 52801 Might have a prenote, which has no location
		//elseif not self.isDischarge and ti.myPrimaryActualLocation.isVoyageController then																					// TFS 52801
		elseif not self.isDischarge and ti.myPrimaryActualLocation &lt;&gt; null and ti.myPrimaryActualLocation.isVoyageController then												// TFS 52801
			noError := false;
			app.raiseCMException3(Cargo_item_cannot_removed, ti.id, self.id, app.getErrorString(Loaded), null, null);
		endif;
		// have I been partially moved?
		if not ti.allSplitChildrenTis.isEmpty then
			foreach splitTI in ti.allSplitChildrenTis do
				// TFS 52801 Might have a prenote, which has no location
				//if ti.myPrimaryActualLocation.isVoyageController and not splitTI.myPrimaryActualLocation.isVoyageController then												// TFS 52801
				if ti.myPrimaryActualLocation &lt;&gt; null and ti.myPrimaryActualLocation.isVoyageController and not splitTI.myPrimaryActualLocation.isVoyageController then			// TFS 52801
					noError := false;
					app.raiseCMException3(Cargo_item_cannot_removed, ti.id, self.id, app.getErrorString(Partially) &amp; Space &amp; app.getErrorString(Discharged), null, null);
				//elseif not ti.myPrimaryActualLocation.isVoyageController and splitTI.myPrimaryActualLocation.isVoyageController then											// TFS 52801
				elseif ti.myPrimaryActualLocation &lt;&gt; null and not ti.myPrimaryActualLocation.isVoyageController and splitTI.myPrimaryActualLocation.isVoyageController then		// TFS 52801
					noError := false;
					app.raiseCMException3(Cargo_item_cannot_removed, ti.id, self.id, app.getErrorString(Partially) &amp; Space &amp; app.getErrorString(Loaded), null, null);
				endif;
			endforeach;
		endif;
	endforeach;
	
epilog
	return noError;
end;</source>
        <Parameter name="_tisToRemove" type="CM_TISet"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
