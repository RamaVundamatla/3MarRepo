    <JadeMethod name="mnuShippingReport_click" id="e7439ed5-3e7c-4323-a5d9-16881d280d82">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuShippingReport_click(menuItem: MenuItem input) updating;
//03 Oct 2017	cnwma1  TFS #7257 JMT - Refactoring - Commodity Planning
vars

begin

	if self.myHarbour = null then
		app.raiseCMException1(HMSNoHarbourForTerminal, self.myTerminal.name, null, null);
		return;
	endif;
	
	if (not self.checkSecurity(PmHMSReportInitiatorView, 'HMS Report Initiator')) then
		return;
	endif;
	
	self.myAssistant.showHMSReportInitForm(self.myTerminal, HMS_VesselStateReportInitiator.name, HMS_ReportInitiatorBase.HMS_ReportType_VoyageList,self.myDrawTimeLabel.fromTimePeriod,self.myDrawTimeLabel.toTimePeriod);

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
