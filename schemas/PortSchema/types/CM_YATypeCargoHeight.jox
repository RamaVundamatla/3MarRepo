    <JadeMethod name="getCriteriaValueForTi" id="a560d699-7b27-4a98-8ade-8addaee11dad">
        <source>getCriteriaValueForTi(_ti: CM_TrackedItem; _criteriaValue: Any output);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/11/2010	cnwdap1	Initial creation PAR #26184
*/
vars

begin
	if CM_Container.hasInstance(_ti) then
		_criteriaValue := _ti.CM_Container.overHeight.String;
	else
		_criteriaValue := _ti.height.String;
	endif;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaValue" type="Any" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getDataDisplay" id="f6ef9235-3103-4439-8e67-3d024619c788">
        <source>getDataDisplay(pDataObj: CM_YAData): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 July 2024	navrv30	Bug 64703: FR | 53383 - Release Request by Type - Cargo Group - Measurement Type

*/

vars
	measureType	: CM_MeasurementType;
	valueStr : String;
begin
	measureType := app.getDefaultMeasurementForType(Type_Height);
	valueStr := pDataObj.getDataValue().String;
	if measureType &lt;&gt; null and valueStr &lt;&gt; null then
			valueStr := app.convertMeasurementForDisplay(measureType.shortName, valueStr.Decimal);	
			return valueStr &amp; " " &amp; measureType.shortName;
	endif;
	return valueStr;
epilog

end;</source>
        <Parameter name="pDataObj" type="CM_YAData"/>
        <ReturnType type="String"/>
    </JadeMethod>
