    <JadeMethod name="populateSourceArea" id="1b978874-41c7-4ea9-8324-56d32dbac6b4">
        <updating/>
        <source>populateSourceArea( _lc : CM_LocationsController ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Apr 2018	jlgndl1	Initial creation	TFS 38083

*/

vars

	term : CM_Terminal;
	ta : CM_TerminalArea;
	firstTa : CM_TerminalArea;
	iter : Iterator;
	newIndex : Integer;
	index : Integer;
	lc : CM_LocationsController;

begin

	self.cmbSourceArea.clear();
	
	term := self.myMobileDataAgent.myTerminal; 
	firstTa := term.allTerminalAreasByTypeId.getAtKeyGeq( TA_TYPE_YARD_INTERCHANGE, null );
	
	if firstTa &lt;&gt; null then
		iter := term.allTerminalAreasByTypeId.createIterator;
		iter.startAtObject( firstTa );
		while iter.next( ta ) do
			if ta.type &lt;&gt; TA_TYPE_YARD_INTERCHANGE then
				break;
			endif;
			lc := null;
			if ta.isKindOf( CM_InterchangeArea ) then
				lc := ta.CM_InterchangeArea.getDefaultLane;   // 36089
			elseif ta.isKindOf( CM_BlockStack ) then
				lc := ta.CM_BlockStack.myLocationsController;
			endif;
			if lc = null then
				continue;
			endif;
			newIndex := self.cmbSourceArea.addItem( ta.id );
			self.cmbSourceArea.itemObject[newIndex] := lc;
		endwhile;
		
		if self.cmbSourceArea.listCount &lt; 1 then
			self.cmbSourceArea.addItemAt( 'No Child Source Areas', 1 );
		else
			self.cmbSourceArea.addItemAt( '&lt;Child Source Area&gt;', 1 );
			self.cmbSourceArea.listIndex := 1;
		endif;
		
		if self.applyTwelveStwRules then	
			self.autoSelectSourceArea();
		else
			if _lc &lt;&gt; null then
				index := self.cmbSourceArea.findObject(_lc);
				if index &gt; 0 then
					self.cmbSourceArea.listIndex := index;
				endif;
			endif;
		endif;
	endif;

epilog

	delete iter;

end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="selectParentItem" id="36befec5-f003-49ca-aeb0-b4b284ff2bc4">
        <updating/>
        <source>selectParentItem( manual : Boolean ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Apr 2018	jlgndl1	Initial creation	TFS 38083

*/

vars

	cargoId : String;
	term : CM_Terminal;
	firstTi : CM_TrackedItem;
	tiArray, plannedTiArray : CM_TIArray;
	iter : Iterator;
	ti : CM_TrackedItem;
	trackedItems : CM_TIArray;	
	revDict : CM_TIByIdCargoTypeDictRev;	
	cargoIdLength : Integer;	
	cargoIdReversed : String;
begin

	cargoId := txtParentId.text.trimBlanks.toUpper;
	if cargoId = lblParentId.caption.toUpper then
		cargoId := null;
	endif;

	self.setMyTrackedItem( null );
	
	term := self.myMobileDataAgent.myTerminal;
	create tiArray transient;
	
	if cargoId &lt;&gt; null then
	
		cargoIdLength := cargoId.length;	
		cargoIdReversed := cargoId.reverse;	
		
		firstTi := term.allOnsiteTIsByIdCargoType.getAtKeyGeq(cargoId,null);
		if firstTi &lt;&gt; null and firstTi.id[1:cargoIdLength] = cargoId then	
			iter := term.allOnsiteTIsByIdCargoType.createIterator;
			iter.startAtObject(firstTi);
			while iter.next( ti ) do
				if ti.id[1:cargoIdLength] &lt;&gt; cargoId then	
					break;
				endif;
				tiArray.addExclusive(ti);
			endwhile;
			delete iter;
		endif;
			
		if tiArray.isEmpty and not term.allOnsiteTIsByIdCargoType.isEmpty then
			create revDict transient;
			term.allOnsiteTIsByIdCargoType.copy( revDict );
			firstTi := revDict.getAtKeyGeq(cargoIdReversed,null);
			if firstTi &lt;&gt; null and firstTi.idReversed[1:cargoIdLength] = cargoIdReversed then
				iter := revDict.createIterator;
				iter.startAtObject(firstTi);
				while iter.next( ti ) do
					if ti.idReversed[1:cargoIdLength] &lt;&gt; cargoIdReversed then
						break;
					endif;
					tiArray.addExclusive(ti);
				endwhile;
				delete iter;
			endif;
			delete revDict;
		endif;
		
	endif;
		
	if not manual and tiArray.isEmpty then
		return;
		
	elseif tiArray.size = 1 then
		self.setMyTrackedItem( tiArray.first );	
		return;
		
	else
		// more than one found.
		app.myMobileCargoFindAgent.setID( cargoId );
		app.myMobileCargoFindAgent.setMyTrackedItemToProcess(null);
		app.myMobileCargoFindAgent.setSearchSite( TI_SITE_ONSITE );
		app.myMobileCargoFindAgent.setPreventSiteChange(true); 
		app.myMobileCargoFindAgent.setDoSearchImmediate( false );
		app.myMobileCargoFindAgent.setHidePackItems(true);
		app.myMobileCargoFindAgent.setHideOnTransportTIs(true);
		
		self.myMobileGenericAgent.setMyBulkRelease( self.myBulkRelease );
		self.myMobileGenericAgent.setMyYardLocation( self.cmbSourceArea.listObject.CM_LocationsController );
		
		self.myMobileGenericAgent.setMyNextTiToAction(null);

		self.gotoForm( MOB_HHCargoFind, false );
	endif;
	
epilog

	delete tiArray;
	delete plannedTiArray;
	delete iter;
	delete trackedItems;
	delete revDict;

end;</source>
        <Parameter name="manual" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setBtnsState" id="2179c580-4716-4a66-b166-64c7ff1da4c5">
        <source>setBtnsState();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Apr 2018	jlgndl1	Initial creation	TFS 38083

*/

vars

begin

	self.btnOne.enabled := ( self.myTruck &lt;&gt; null or self.myTrackedItem &lt;&gt; null or self.myTrailer &lt;&gt; null or self.myWagon &lt;&gt; null );

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setMyBulkRelease" id="8d28cb08-0be5-4576-9138-280fab6bff29">
        <updating/>
        <source>setMyBulkRelease( _bulkRelease : CM_BulkRelease; _reserveDetail :CM_ReserveDetail ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Apr 2018	jlgndl1	Initial creation	TFS 38083

*/

vars

	iter : Iterator;
	reserveDetail : CM_ReserveDetail;
	index : Integer;
	isPack : Boolean;
	roadJob : CM_Job;	
	jobReserveDetails : CM_ReserveDetailSet;	
	req : CM_Request;	
	vehicle : CM_Vehicle;	
	trailerLoc : CM_LocationsController;
	defColour : Integer;
	colour : Integer;

begin

	self.myBulkRelease := _bulkRelease;
	
	self.cmbRelItems.clear();
	self.cmbRelItems.enabled := false;
	defColour := cmbRelItems.backColor;
	
	if self.myBulkRelease = null then
		self.cmbRelItems.addItemAt( app.getErrorString(No_request_found), 1 );
		self.cmbRelItems.listIndex := 1;
		
		self.populateSourceArea( null );
		
	else
		if self.myTruck &lt;&gt; null then
			vehicle := self.myTruck;
		elseif self.myTrailer &lt;&gt; null then
			trailerLoc := self.myTrailer.myPrimaryActualLocation;
			if trailerLoc &lt;&gt; null and trailerLoc.isVehicle then
				vehicle := trailerLoc.CM_VehicleController.vehicle;
			endif;
		endif;
	
		if vehicle &lt;&gt; null then	
			if self.myBulkRelease.isPackingType then
				isPack := true;
			endif;
			create jobReserveDetails transient;
			roadJob := vehicle.allRoadJobs.first;
			if roadJob &lt;&gt; null then
				foreach req in roadJob.allRequests do
					if req.myReserveDetail &lt;&gt; null then
						jobReserveDetails.addNoDuplicates(req.myReserveDetail,false);	//19 Dec 2018	NDL	TFS 38083
					endif;
				endforeach;
				if not jobReserveDetails.isEmpty then
					iter := jobReserveDetails.createIterator;
				endif;
			endif;
		endif;

		if iter = null then
			if self.myBulkRelease.isPackingType then
				isPack := true;
				iter := self.myBulkRelease.allReservePackingChildren.createIterator;
			else
				iter := self.myBulkRelease.allReserveDetails.createIterator;
			endif;
		endif;
		
		if iter &lt;&gt; null then
			while iter.next( reserveDetail ) do	
				index := self.cmbRelItems.addItem( reserveDetail.getStwHHCmbDetails37200( defColour, colour ) );
				self.cmbRelItems.itemObject[index] := reserveDetail;
				self.cmbRelItems.itemBackColor[index] := colour;
			endwhile;
		endif;
	
		if self.cmbRelItems.listCount &gt; 1 then
			self.cmbRelItems.addItemAt( "&lt;" &amp; app.getErrorString(Please_select_release_item) &amp; "&gt;", 1 );
			self.cmbRelItems.listIndex := 1;
			self.cmbRelItems.enabled := true;
		elseif self.cmbRelItems.listCount = 1 then
			self.cmbRelItems.listIndex := 1;
		endif;
		
		if _reserveDetail &lt;&gt; null then
			index := self.cmbRelItems.findObject( _reserveDetail );
			if index &gt; 0 then
				self.cmbRelItems.listIndex := index;
			endif;
		endif;
	
	endif;
	
epilog

	delete jobReserveDetails;
	delete iter;

end;</source>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="setMyTrackedItem" id="36eb8717-ca90-4380-9799-e3db7e6bd995">
        <updating/>
        <source>setMyTrackedItem( _ti : CM_TrackedItem )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Apr 2018	jlgndl1	Initial creation	TFS 38083

*/

vars

	desc1 : String;
	desc2 : String;

begin

	if _ti = null then
		self.myTrackedItem := null;
		self.myTrailer := null;
		if self.cmbTrailer.listCount &gt; 0 then
			self.cmbTrailer.listIndex := 1;
		endif;
		if self.cmbParent.listCount &gt; 0 then
			self.cmbParent.listIndex := 1;
		endif;
	elseif _ti.isChassis then
		self.myTruck := null;
		if self.cmbParent.listCount &gt; 0 then
			self.cmbParent.listIndex := 1;
		endif;
		self.myTrailer := _ti;
	else
		self.myTrackedItem := _ti;
		self.myTrailer := null;
		if self.cmbTrailer.listCount &gt; 0 then
			self.cmbTrailer.listIndex := 1;
		endif;
	endif;
	
	if _ti = null then
		self.txtParentId.text := null;
		self.lblCargoType.caption := null;
		self.lblCargoDesc.caption := null;
	else
		self.txtParentId.text := _ti.id;
		_ti.getShortDescriptions( desc1, desc2 );
		self.lblCargoType.caption := desc1;
		self.lblCargoDesc.caption := desc2;
	endif;
	
	self.setBtnsState();

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setMyTruck" id="7dc858e4-dd6f-42eb-a0a5-aaf52c8a28ab">
        <updating/>
        <source>setMyTruck( _vehicle : CM_Vehicle ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Apr 2018	jlgndl1	Initial creation	TFS 38083

*/

vars

	vvr : CM_VehicleVisitRecord;
	trailer : CM_TILC;
	index : Integer;
	resDet : CM_ReserveDetail;
	
begin

	self.myTruck := _vehicle;
	
	if _vehicle &lt;&gt; null then
		vvr := _vehicle.getCurrentVisit;
		if vvr &lt;&gt; null then
			if vvr.myOutCMGTE_Chassis &lt;&gt; null then
				trailer := vvr.myOutCMGTE_Chassis.getTI.CM_TILC;
				if trailer &lt;&gt; null then
					index := self.cmbTrailer.findObject(trailer);
					if index &gt; 0 then
						self.cmbTrailer.listIndex := index;
						self.cmbTrailer_click(self.cmbTrailer);
					endif;
				endif;
			endif;
		endif;
	endif;
	
	if self.myBulkRelease &lt;&gt; null then
		//force rebuild of releserve selection combo based on selected truck.
		//setMyBulkRelease uses 'myTruck'
		if self.cmbRelItems.listIndex &gt; 0 then
			resDet := self.cmbRelItems.itemObject[ self.cmbRelItems.listIndex ].CM_ReserveDetail;
		endif;
		self.setMyBulkRelease(self.myBulkRelease,null);
		if resDet &lt;&gt; null then
			index := self.cmbRelItems.findObject( resDet );
			if index &gt; 0 then
				self.cmbRelItems.listIndex := index;
			else
				self.cmbRelItems.listIndex := 1;
			endif;
		endif;
	endif;
	
	self.setBtnsState();

epilog

end;</source>
        <Parameter name="_vehicle" type="CM_Vehicle"/>
    </JadeMethod>
    <JadeMethod name="setMyWagon" id="0c640650-5636-4522-a922-63e2ec7090db">
        <updating/>
        <source>setMyWagon(_wagon : CM_Wagon) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Apr 2018	jlgndl1	Initial creation	TFS 38083
*/

vars

begin

	self.myWagon := _wagon;
	
	self.setBtnsState();

epilog

end;</source>
        <Parameter name="_wagon" type="CM_Wagon"/>
    </JadeMethod>
    <JadeMethod name="setTruckOrTrailerComboFrom" id="662cc0b3-6005-423d-96fe-cb291cde1272">
        <updating/>
        <source>setTruckOrTrailerComboFrom( _lc :  CM_LocationsController ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Apr 2018	jlgndl1	Initial creation	TFS 38083

*/

vars

	index : Integer;
	trailer : CM_TILC;
	truck : CM_Vehicle;
	wagon : CM_Wagon;
	trailerLoc : CM_LocationsController;	

begin

	if _lc = null then
		return;
	endif;
	
	if _lc.isKindOf(CM_WagonController) then	
		wagon := _lc.CM_WagonController.myWagon;
		if wagon &lt;&gt; null then
			index := self.cmbWagon.findObject( wagon );
			if index &gt; 0 then
				self.cmbWagon.listIndex := index;
				self.setMyWagon(wagon);
				return;
			endif;
		endif;
		
	elseif _lc.isKindOf(CM_TILCController) then
		foreach index in 1 to self.cmbTrailer.listCount do
			trailer := self.cmbTrailer.itemObject[ index ].CM_TILC;
			if trailer = null then
				continue;
			endif;
			if trailer.allLCs.includes( _lc.CM_TILCController ) then
				self.cmbTrailer.listIndex := index;
				self.setMyTrackedItem(trailer);
				
				trailerLoc := self.myTrailer.myPrimaryActualLocation;
				if trailerLoc &lt;&gt; null and trailerLoc.isVehicle then
					truck := trailerLoc.CM_VehicleController.vehicle;
					if truck &lt;&gt; null then
						index := self.cmbTruck.findObject(truck);
						if index &gt; 0 then
							self.cmbTruck.listIndex := index;
							self.cmbTruck.click( self.cmbTruck );
						endif;
					endif;
				endif;
			
				return;
			endif;
		endforeach;
	
	else
		foreach index in 1 to self.cmbTruck.listCount do
			truck := self.cmbTruck.itemObject[ index ].CM_Vehicle;
			if truck = null then
				continue;
			endif;
			if truck.locationsController = _lc then
				self.cmbTruck.listIndex := index;
				self.setMyTruck(truck);
				return;
			endif;
		endforeach;
	
	endif;

epilog

end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="125e4683-5911-41d8-9798-50097d9f4f36">
        <updating/>
        <source>setupControls() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Apr 2018	jlgndl1	Initial creation	TFS 38083

*/

vars
	
	errMsg : String;
	index : Integer;

begin
	
	self.doResizeControls(true);
	
	//reset if returning from somewhere else...
	self.populateSourceArea( self.myMobileGenericAgent.myYardLocation );
	self.myMobileGenericAgent.setMyYardLocation( null );
	if self.myMobileGenericAgent.myBulkRelease &lt;&gt; null then
		self.setMyBulkRelease(self.myMobileGenericAgent.myBulkRelease, self.myMobileGenericAgent.myReserveSelection);
		self.myMobileGenericAgent.setMyBulkRelease( null );
		self.myMobileGenericAgent.setMyReserveDetail( null );
	endif;
	
	self.findRequest();
	
	if self.myMobileGenericAgent.myLocationsController &lt;&gt; null then
		self.setTruckOrTrailerComboFrom( self.myMobileGenericAgent.myLocationsController );
	endif;
	
	//returning from a search
	if app.myMobileCargoFindAgent.myTrackedItemToProcess &lt;&gt; null then
		self.setMyTrackedItem(	app.myMobileCargoFindAgent.myTrackedItemToProcess );
		app.myMobileCargoFindAgent.clearHistory(true);
	elseif self.myMobileGenericAgent.myPackTi &lt;&gt; null then	
		index := self.cmbParent.findObject( self.myMobileGenericAgent.myPackTi );
		if index &gt; 0 then
			self.cmbParent.listIndex := index;
			self.cmbParent.click(self.cmbParent);
		endif;
	endif;
	
	self.setBtnsState();
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForRailRelease" id="00b19536-e1ab-4788-9c7a-8620d0cb1230">
        <updating/>
        <source>setupForRailRelease()protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Apr 2018	jlgndl1	Initial creation	TFS 38083
*/

vars

	wagonArray : CM_WagonArray;
	wagon : CM_Wagon;
	newIndex : Integer;

begin

	if self.myBulkRelease = null or not self.myBulkRelease.isRailType then
		return;
	endif;
	
	self.cmbTruck.visible := false;
	self.cmbParent.visible := false;
	self.cmbTrailer.visible := false;
	self.btnPartCargoId.visible := false;
	self.txtParentId.visible := false;
	self.cmbWagon.visible := true;
	self.cmbWagon.enabled := true;
		
	create wagonArray transient;
	self.myBulkRelease.getAssociatedWagons(wagonArray, true );
			
	foreach wagon in wagonArray do
		newIndex := self.cmbWagon.addItem( wagon.id );
		self.cmbWagon.itemObject[newIndex] := wagon; 
	endforeach;
	
	if self.cmbWagon.listCount &lt; 1 then
		self.cmbWagon.addItem( app.getErrorString(Associated_wagons) );
		self.cmbWagon.enabled := false;
		self.cmbWagon.listIndex := 1;
	else
		self.cmbWagon.addItemAt( app.getErrorString(Select_Assoc_wagon),1 );
		self.cmbWagon.listIndex := 1;
	endif;
	
	self.requestedItemCount := self.myBulkRelease.allTrackedItemsAssigned.size;
	self.lblRequest.caption := self.myBulkRelease.code &amp; "    " &amp; app.releaseRequestTypeEnumToString( self.myBulkRelease.type ) &amp; " ["
	&amp; self.myBulkRelease.allReserveDetails.size.String &amp; " " &amp; app.getErrorString(INV_Items) &amp; "]";

	
	self.setMyTrackedItem( null );
	self.setMyTruck( null );
	
	self.autoSelectSourceArea();
	
	if self.cmbWagon.listCount = 2 then	
		self.cmbWagon.listIndex := 2;
		self.cmbWagon_click(self.cmbWagon);
	endif;
	
	self.doResizeControls(false);

epilog

	delete wagonArray;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="af8a0def-fcf5-48d4-8ed3-2f5a930ff9f6">
        <updating/>
        <source>setupForm() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Apr 2018	jlgndl1	Initial creation	TFS 38083
*/

vars

begin

	self.myHandHeldCheckerAgent := app.myHandHeldCheckerAgent;
	
	self.applyTwelveStwRules := self.myTerminal.getConfig(UseAltSelectRulesTL).Boolean;
	
	if app.myMobileCargoFindAgent = null then
		create app.myMobileCargoFindAgent transient;
	endif;
	
	inheritMethod();
	
	self.setupCmdButtons( 2, app.getErrorString(Next), app.getErrorString(Back), null, null, null );

	self.setupControls();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="translateForm" id="97d5a893-281d-4b3e-933f-e69571b3e12e">
        <updating/>
        <source>translateForm(locale : CM_Locale) updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 21 December 2018 12:21:45.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	
begin
	// Determine the locale for translations.
	inheritMethod(locale);
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023139, locale);
	lblPackLoadTarg.translateCaption(Xlat_0023140, locale);
	lblParentId.translateCaption(Xlat_0023141, locale);
	lblRequest.translateCaption(Xlat_0023142, locale);
	lblRequestId.translateCaption(Xlat_0023143, locale);
end;</source>
        <Parameter name="locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="txtParentId_gotFocus" id="d7d12e63-3e7d-4ba0-b777-5f263eb7b4ce">
        <controlMethod name="TextBox::gotFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtParentId_gotFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Apr 2018	jlgndl1	Initial creation	TFS 38083

*/

vars

begin

	if self.txtParentId.text = self.lblParentId.caption.toUpper then
		self.txtParentId.selStart := 0;
		self.txtParentId.selLength := self.lblParentId.caption.length;
	endif;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="txtParentId_lostFocus" id="821938c1-a849-490f-8d82-8f5f7e14fe1d">
        <controlMethod name="TextBox::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtParentId_lostFocus(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Apr 2018	jlgndl1	Initial creation	TFS 38083

*/

vars

begin

	app.convertScannedCargoId( self.myTerminal, textbox, false, null );	

	if self.txtParentId.text.trimBlanks = null then
		self.txtParentId.text := self.lblParentId.caption.toUpper;
	else
		if ( self.myTrackedItem &lt;&gt; null and self.myTrackedItem.id &lt;&gt; self.txtParentId.text )
		or ( self.myTrackedItem = null and self.txtParentId.text &lt;&gt; self.lblParentId.caption.toUpper )
		then
			self.selectParentItem( false );
		endif;
	endif;
	
	self.txtParentId.selStart := 0;
	self.txtParentId.selLength := 0;

epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
</GUIClass>
