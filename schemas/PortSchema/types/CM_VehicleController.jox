    <JadeMethod name="isSetNotToCreateRoadRelease" id="7f7915d9-3472-47b9-8603-8da422831b80">
        <source>isSetNotToCreateRoadRelease() : Boolean;
/*
Purpose:	Determines if selected option for 'Road Operation Delete Current Entry' is an option that 
			prevents creation of Road Release transaction when Road Receive Transaction is CANCELLED. The options are
			Option 2 = Road Receive Deleted, Road Release NOT Created, Road Receive Invoice Line Remains
			Option 3 = Road Receive Deleted, Road Release NOT Created, Road Receive Invoice Line Void
Parameters:			

Return Value:		

Date		Who		TFS		Reason
29 Oct 2019	jlgdi1	46578	Initial creation
*/

vars
	selectedOption : Integer;
	
begin
	selectedOption := self.getRoadOpsDelCurEntryOption();
	return (selectedOption = DEL_CUR_ENTRY_OPTION_3) or (selectedOption = DEL_CUR_ENTRY_OPTION_4);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
