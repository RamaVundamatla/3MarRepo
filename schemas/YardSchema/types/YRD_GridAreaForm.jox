    <JadeMethod name="doResize" id="916a3ec2-6825-4d82-b8d2-1b407bcdacda">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	toolbarTopOffset : Integer;
begin

	if self.frmToolbar.visible then
		toolbarTopOffset := (self.frmToolbar.top + self.frmToolbar.height).Integer;
	else
		toolbarTopOffset := self.frmToolbar.top.Integer;
	endif;

	inheritMethod();

	self.splMain.move(0, toolbarTopOffset, self.clientWidth, self.frmStatusLine.top - toolbarTopOffset);

	// ##### LOG AREAS
	if self.areaType = self.Area_Type_Log or
	   self.areaType = self.Area_Type_Shed then
		self.sptGridArea01.left := 0; 
		self.sptGridArea01.height := self.frmStatusLine.top - toolbarTopOffset;
		self.sptGridArea01.top := 0; 
		self.frmCargoPic.visible := false;

		self.sptGridArea01.left := 1;
		self.sptGridArea01.width := self.width - 10;
	// ##### STACK AREAS
	else
		self.frmCargoPic.visible := true;
	endif;	
	self.splMain.cnEcResizeContents();
	
	self.sdf01.repositionScrollBars();
	self.sdf02.repositionScrollBars();
	self.sdf03.repositionScrollBars();
	// #################################
	// GridArea INFORMATION
	self.setLastColumnMaxWidth(tblGridAreaInfo);

	self.sptBottom.cnEcResizeContents();

	if self.frmCargoPic.visible then
		self.picCargo.width := self.frmCargoPic.width;
		self.picCargo.top := 0;
		self.picCargo.left := 0;
		self.picCargo.height := self.frmCargoPic.height; 
	endif;
	
	if self.areaType = self.Area_Type_Log then
		// ##### LOG AREAS
		self.frmColLegendLogs.doResize();
	else
		// ##### STACK AREAS
		self.frmColLegendTIs.top := 0; 
		self.frmColLegendTIs.left := 0;
		self.frmColLegendTIs.height := self.sptGridArea01.height;
		self.frmColLegendTIs.doResize();
		self.frmModalDialog.centreWindow;
		self.frmModalDialog.height := 60;
		self.frmModalDialog.top := 100;
	endif;
	self.doResizeColumnWidths(self.tblGridAreaInfo, true);
end;</source>
    </JadeMethod>
    <JadeMethod name="doScrollToCorners" id="e620301b-5d21-4f1c-8004-080cb0488c5b">
        <source>doScrollToCorners(pCorner : Integer);
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/7/2006	RBarr		PAR 11526 Fixed vertical frame position. Had to refactor the code so I could understand what was going on
// ---------------------------------------------------------------------------

vars
	lHLabHeight, lVLabHeight,
	lFarRight, lFarBottom 		: Integer;
	lScrollBarV, lScrollBarH 	: Integer;
	theSDF 						: CMUI_ScrollableDrawingFrame;
	theGridFrame 				: CMUI_GridAreaFrame;
	theGridArea 				: CMUI_GridArea;
begin

	theSDF := self.myCurrentSDF;
	if theSDF = null then
		theSDF := self.sdf01;
	endif;
	
	if theSDF = null then
		return; // doesn't sound too healthy
	endif;
	
	// Get first (viewing top) or last (viewing bottom) grid area
	if pCorner = VIEW_LEFT_BOTTOM or pCorner = VIEW_RIGHT_BOTTOM then
		theGridArea := theSDF.allGridAreasByRowColumn.last;
	else
		theGridArea := theSDF.allGridAreasByRowColumn.first;
	endif;
	if theGridArea = null then
		return;
	endif;
	
	theGridFrame := theGridArea.myGridAreaFrame;


	// Allow for LABELS
	if theSDF.myHLabels.visible then
		lHLabHeight := theSDF.myHLabels.height.Integer;
	endif;

	if theSDF.myVLabels.visible then
		lVLabHeight := theSDF.myVLabels.width.Integer;
	endif;

	// Calculate VERTICAL values
	if pCorner = VIEW_LEFT_TOP or pCorner = VIEW_RIGHT_TOP then
		lScrollBarV := 1;
		lFarBottom 	:= lHLabHeight;
	else
		lScrollBarV := theGridFrame.height.Integer + theGridFrame.top.Integer;
		lFarBottom 	:= theSDF.height.Integer - lHLabHeight - lScrollBarV + 1;
	endif;

	// Calculate HORIZONTAL values
	if pCorner = VIEW_LEFT_TOP or pCorner = VIEW_LEFT_BOTTOM then
		lScrollBarH := 1;
		lFarRight 	:= lVLabHeight;
	else
		lScrollBarH := theGridFrame.width.Integer;
		lFarRight 	:= theSDF.width.Integer - lVLabHeight - lScrollBarH + 1;
	endif;

	// Set VERTICAL frame position and scroll bar extent
	theSDF.myDrawingFrame.top := lFarBottom;
	if theSDF.myVLabels &lt;&gt; null then
		theSDF.myVLabels.top := lFarBottom;
		theSDF.myHScroll.value := lScrollBarH;
	endif;

	// Set HORIZONTAL frame position and scroll bar extent
	theSDF.myDrawingFrame.left := lFarRight;
	if theSDF.myHLabels &lt;&gt; null then
		theSDF.myHLabels.left := lFarRight;
		theSDF.myVScroll.value := lScrollBarV;
	endif;

end;</source>
        <Parameter name="pCorner" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doSetCaption" id="21815615-dcc0-43ed-baa8-f64d2397b23d">
        <updating/>
        <source>doSetCaption(_theGridArea : CMUI_GridArea) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	flipString, accessString, naviString : String;
	theCaption : String;
	aTA : Object;
begin
	if _theGridArea &lt;&gt; null then
		if _theGridArea.flipHorizontal then
			flipString := " (Flipped Horizontal Only)";
			if _theGridArea.flipVertical then
				flipString := " (Flipped Horizontally &amp; Vertically)";
			else
				flipString := " (Flipped Horizontally Only)";
			endif;
		else
			if _theGridArea.flipVertical then
				flipString := " (Flipped Vertically Only)";
			else
				flipString := " (Normal View)";
			endif;
		endif;	
	endif;
		
	if self.areaType = Area_Type_Straddle then
//		if self.allTerminalAreas.size = 1 then
//			theCaption := "Stack Area - ";
//		else
//			theCaption := "Stack Areas - ";
//		endif;
		naviString := theCaption;
		theCaption := "**** OLD ****"; //null;
		
		foreach aTA in self.allTerminalAreas do
			if aTA.isKindOf(CM_ForkLiftStack) then
				accessString := null;
				if aTA.CM_ForkLiftStack.accessFront and aTA.CM_ForkLiftStack.accessBack then
					accessString := "Full Access";
				elseif aTA.CM_ForkLiftStack.accessFront and not aTA.CM_ForkLiftStack.accessBack then
					accessString := "Access Front Only";
				elseif not aTA.CM_ForkLiftStack.accessFront and aTA.CM_ForkLiftStack.accessBack then
					accessString := "Access Back Only";
				else
					accessString := "No Access Front Or Back";
				endif;
				theCaption := theCaption  &amp; aTA.CM_ForkLiftStack.id.trimBlanks &amp; " (" &amp; accessString &amp; "), ";
			else
				theCaption := theCaption  &amp; aTA.CM_GridArea.id.trimBlanks &amp; ", ";
			endif;
			naviString := naviString &amp; aTA.CM_GridArea.id.trimBlanks &amp; ", ";
		endforeach;
		if self.allTerminalAreas.size = 1 then
			theCaption := theCaption &amp; " Stack Area.";
		else
			theCaption := theCaption &amp; " Stack Areas.";
		endif;
//		theCaption := theCaption[1:theCaption.length - 2] &amp; flipString;
		theCaption := theCaption &amp; " " &amp; flipString;
		theCaption := theCaption &amp; " " &amp; self.myTerminal.code;
		naviString := naviString[1:naviString.length - 2];
	elseif self.areaType = Area_Type_Log then
		theCaption := "Log Areas ";
		naviString := theCaption;
	elseif self.areaType = Area_Type_Shed then
		theCaption := "Shed ";
		naviString := theCaption;
	endif;
	//self.caption := theCaption;
	self.setCaption ( theCaption ) ; // cnwrd1 par #17398 , 22.9.08
	// Update the navigator
	self.setNavigatorHeading(naviString); 

end;</source>
        <Parameter name="_theGridArea" type="CMUI_GridArea"/>
    </JadeMethod>
    <JadeMethod name="doSetMyType" id="ddef8b66-4576-4c0b-b342-e08395d9f4df">
        <updating/>
        <source>doSetMyType() updating;
// ---------------------------------------------------------------------------
// Created:		April  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.areaType := self.areaTypeString.Integer;
/*
	if self.areaType = null then
		if self.myMasterMenuAction.myParent &lt;&gt; null then
			if self.myMasterMenuAction.myParent.getHeading = "Yard Areas" then
				self.areaType := self.Area_Type_Straddle;
			elseif self.myMasterMenuAction.myParent.getHeading = "Log Areas" then
				self.areaType := self.Area_Type_Log;
			elseif self.myMasterMenuAction.myParent.getHeading = "Warehouse Areas" then
				self.areaType := self.Area_Type_Shed;
			elseif self.myMasterMenuAction.myParent.getHeading = "Voyage Areas" then
				self.areaType := self.Area_Type_Ship;
			else
				self.areaType := self.Area_Type_All;
			endif;
		else
			self.areaType := self.Area_Type_All;
		endif;
	endif;
*/	


end;</source>
    </JadeMethod>
    <JadeMethod name="doSwitchSplitterChild" id="354f7948-8adf-4141-9592-c6ef948220be">
        <source>doSwitchSplitterChild();
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if self.areaType = self.Area_Type_Log then
		self.frmCargoPic.visible := false;
		self.frmCargoPic.parent := self;
		self.frmColLegendLogs.visible := true;
		self.frmColLegendLogs.parent := self.sptBottom;
		self.sptBottom.setupChildControls;

	elseif self.areaType = self.Area_Type_Shed then
		self.frmCargoPic.visible := false;
		self.frmCargoPic.parent := self;
		self.frmColLegendLogs.visible := true;
		self.frmColLegendLogs.parent := self.sptBottom;
		self.sptBottom.setupChildControls;
	else

		self.frmCargoPic.visible := true;
		self.frmCargoPic.parent := self.sptBottom;
		self.frmColLegendLogs.visible := false;
		self.frmColLegendLogs.parent := self;
		self.sptBottom.setupChildControls;
	endif;			

end;</source>
    </JadeMethod>
    <JadeMethod name="doTableDblClick" id="86945045-f7a3-4b40-b34d-e2e2126e009f">
        <updating/>
        <source>doTableDblClick(table: Table input) updating;

// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	anObject : CM_Object;
	aForm 	: Form;
	menuAction 		: CMUI_MenuAction;
begin


	if table = null then
		return;
	endif;
	if table.row &lt;= table.fixedRows then
		return;
	endif;

	anObject := table.accessRow(table.row).itemObject.CM_Object ;
	if anObject &lt;&gt; null then
		if anObject.isKindOf(CM_Voyage) then
			self.showFormFromPermission(PmShipVoyageEnquiryView, true);
		else
			self.myAssistant.showTableMaintForm(anObject, self.myMasterMenuAction, false, false);
		endif;
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTurnOffContextMenus" id="1ce0e9cc-d536-41bf-983d-627dbe8e4111">
        <source>doTurnOffContextMenus();
// ---------------------------------------------------------------------------
// Created:		June 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();

	if self.areaType = self.Area_Type_Log then
		self.mnuGridHideLegend.visible := false;
		self.mnuGridHideToolbar.visible := false;
		self.mnuGridSelectAreas.visible := true;
		self.mnuGridHideMacro.visible := true;
		self.mnuGridSelectAreas.caption := "Select Log &amp;Areas...";
		self.mnuGridSelector.visible := false;
		self.mnuDevCreateQuickLogs.visible := app.isSpecial();
	else		
		self.mnuGridHideLegend.visible := true;
		self.mnuGridHideMacro.visible := true;
		self.mnuGridHideToolbar.visible := true;
		self.mnuGridSelectAreas.caption := "Select Terminal &amp;Areas...";
		self.mnuGridSelectAreas.visible := true;
		if self.myCurrentSDF &lt;&gt; null then
			self.mnuGridSelector.visible := not self.myCurrentSDF.allGridAreasByRowColumn.isEmpty;
			self.mnuGridSelectorClear.visible := not self.myCurrentSDF.allSelectorTIs.isEmpty;
		else
			self.mnuGridSelector.visible := false;
			self.mnuGridSelectorClear.visible := false;
		endif;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="dragOver" id="24f12853-e01b-470e-93b5-5a53993b53bd">
        <controlMethod name="Form::dragOver"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>dragOver(win: Window input; x: Real; y: Real; state: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	if app.myMoveController &lt;&gt; null then
		self.setFocus();
		self.zOrder(1);
		self.windowState := WindowState_Normal;
	endif;
	if self.myCurrentSDF &lt;&gt; null then
		self.frmGridAreaDragOver(null, self.myCurrentSDF, win, x, y, state);		
	endif;

end;</source>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="drawGridArea" id="2ba53bbc-1e7e-4310-8690-39f10705eafd">
        <updating/>
        <source>drawGridArea() updating;

vars
	cmuiGridArea : CMUI_GridArea;
	anObject : Object;
	aCMObject : CM_Object;
	rowFrame	: CMUI_GridAreaFrame;
	pointX, pointY, aColour : Integer;
	aLabel : String;
begin
	// clear these out cos we are only looking at one area at a time and they all have column =  and row = 1
	self.mousePointer := Window.MousePointer_HourGlass;


	if self.areaType = self.Area_Type_Log then
		self.sdf01.visible := true;
		self.setMyCurrentSDF(self.sdf01,true);
		self.sdf01.allGridAreasByColumnRow.clear;
		self.sdf01.allGridAreasByRowColumn.clear;
	
		cmuiGridArea := self.frmGridArea.myGridArea;
		delete cmuiGridArea;
		self.drawGridAreaLogs();

	elseif self.areaType = self.Area_Type_Shed then
		self.sdf01.visible := true;
		self.setMyCurrentSDF(self.sdf01,true);
		self.sdf01.allGridAreasByColumnRow.clear;
		self.sdf01.allGridAreasByRowColumn.clear;
	
		cmuiGridArea := self.frmGridArea.myGridArea;
		delete cmuiGridArea;
		self.drawGridAreaLogs();

	else
		if self.myCurrentTerminalArea = null then
			self.sdf01.visible := false;
			return;
		else
			self.sdf01.visible := true;
		endif;
	
		self.setMyCurrentSDF(self.sdf01,true);
		self.sdf01.allGridAreasByColumnRow.clear;
		self.sdf01.allGridAreasByRowColumn.clear;
	
		cmuiGridArea := self.frmGridArea.myGridArea;
		delete cmuiGridArea;
		self.drawGridAreaStacks(self.sdf01, self.myCurrentTerminalArea, 1);
	endif;

epilog
	self.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="drawGridAreaLogs" id="79ba648b-ce3d-44b7-9a2d-254718df1283">
        <updating/>
        <source>drawGridAreaLogs() updating;
// ---------------------------------------------------------------------------
// Created:     27 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
constants
	CaptionLen		: Integer = 255;	//Par 17466. 10 July 2008

vars
	cmuiGridArea 	: YRD_RowArea;
	anObject 		: Object;
	maxRowFrames, 
	pointX, 
	pointY, 
	aColour 		: Integer;
	rowFrame		: CMUI_GridAreaFrame;
	strTerminology	: String;
	captionStr		: String;
	id				: String;
	
begin

//	self.caption := "Log Areas";
	captionStr := "Log Areas";	//Par 17466. 10 July 2008

	self.frmGridArea.visible := false;
	self.myAssistant.allGridAreasByLabel.purge;
	
	foreach anObject in self.allTerminalAreas do
		//caption
		//self.caption := self.caption &amp; " " &amp; anObject.CM_RowArea.id;		//Par 17466. 10 July 2008
		if captionStr.length &lt; CaptionLen then
			id := anObject.CM_RowArea.id;
			if (captionStr &amp;" "&amp; id).length &lt;= CaptionLen then
				captionStr := captionStr &amp;" "&amp; id;
			else
				captionStr := captionStr &amp;" "&amp; id[ 1 : CaptionLen - captionStr.length -1 ];
			endif;
		endif;

		maxRowFrames := maxRowFrames + 1;
		rowFrame := self.frmGridArea.getControl(maxRowFrames).CMUI_GridAreaFrame;
		if rowFrame = null then
			rowFrame := self.frmGridArea.loadControl(maxRowFrames).CMUI_GridAreaFrame;
		endif;

		create cmuiGridArea  transient;
		cmuiGridArea.setForCreate(anObject.CM_RowArea, self.myAssistant, false, rowFrame);
		self.allGridAreas.add(cmuiGridArea);
		self.sdf01.addGridAreaAndFrame(cmuiGridArea, rowFrame);
	endforeach;

	//Par 17466. 10 July 2008
	/*
	if captionStr.length &lt; CaptionLen then
		self.caption := captionStr;
	else
		self.caption := captionStr[1 : CaptionLen - 3] &amp; "...";
	endif;
	*/
	
	// cnwrd1 par #17398 , 22.9.08
	self.setCaption( captionStr ) ;
	
	self.setNavigatorHeading(self.caption); 
	self.sdf01.doZoom(self.xmlZoomFactor); // this clears out the label for blockstack and re calcs them. it also draws the SDF

	self.doNotesForLegend(false);
	if not self.frmColLegendTIs.displayViewModeCodes(self.sdf01.viewMode, self.sdf01.myDrawingAttrController) then
		self.frmColLegendTIs.doChangeViewMode(self.sdf01.viewMode);
		
	endif;
	self.doNotesForLegend(true);

end;</source>
    </JadeMethod>
    <JadeMethod name="drawGridAreaStacks" id="d66fc1d1-7821-4d87-8f2f-b3866f4bc732">
        <updating/>
        <source>drawGridAreaStacks(_theSDF : CMUI_ScrollableDrawingFrame; _theTerminalArea : CM_TerminalArea;_index : Integer) updating;

vars
	cmuiGridArea : CMUI_GridArea;
	anObject : Object;
	aCMObject : CM_Object;
	gridFrame : CMUI_GridAreaFrame;
	maxRowFrames, pointX, pointY, aColour,aReturn : Integer;
	aLabel : String;
	theSDF : CMUI_ScrollableDrawingFrame; 
	theTerminalArea : CM_TerminalArea;
	theGridXMLCompressed : Binary;
	theGridXML, theXMLString, termID : String;
	st, et, idx,theX, fillerY		: Integer;
	fillerFrame : CMUI_Frame;
begin
	// clear these out cos we are only looking at one area at a time and they all have column =  and row = 1
	self.mousePointer := Window.MousePointer_HourGlass;

	theSDF := _theSDF;
	theTerminalArea := _theTerminalArea;
	theSDF.doNotableClear();

	if theTerminalArea = null then
		theSDF.visible := false;
		return;
	else
		theSDF.visible := true;
		theSDF.doNotableAdd(theTerminalArea);
	endif;

	//#############
	gridFrame := self.frmGridArea.getControl(_index).CMUI_GridAreaFrame;
	if gridFrame = null then
		gridFrame := self.frmGridArea.loadControl(_index).CMUI_GridAreaFrame;
	else
		if gridFrame.myGridArea &lt;&gt; null then
			gridFrame.myGridArea.myGridAreaFrame := null;
		endif;
	endif;

	theSDF.clearAll();
	create cmuiGridArea as YRD_GridArea transient;

	// ########################### using array
	self.getDataArray(theTerminalArea, cmuiGridArea.YRD_GridArea, theSDF.myDrawingAttrController);

	beginLoad;
	self.allGridAreas.add(cmuiGridArea);
	theSDF.addGridAreaAndFrame(cmuiGridArea, gridFrame);
	gridFrame.doAutoScrolling := true;
	cmuiGridArea.setFlips(self.xmlFlipH,self.xmlFlipV);
	if self.xmlFlipH then
		cmuiGridArea.doFlipH();
	endif;
	if self.xmlFlipV then
		cmuiGridArea.doFlipV();
	endif;
	
	
	self.setMyCurrentSDF(theSDF,true);
	theSDF.doZoom(self.xmlZoomFactor); // this clears out the label for blockstack and re calcs them. it also draws the SDF
	if (not self.frmColLegendTIs.displayViewModeCodes(theSDF.viewMode, theSDF.myDrawingAttrController)) then
		self.frmColLegendTIs.doChangeViewMode(theSDF.viewMode);
	endif;

	termID := theTerminalArea.id[1:4];
	fillerFrame := theSDF.myTopLeftFillerFrame;
	fillerFrame.clearGraphics();
	theX := (((fillerFrame.width ) / 2)).Integer;
	if termID.length = 1 then
		fillerFrame.drawFontSize := 12;
		fillerY := 6;
	elseif termID.length = 2 then
		fillerFrame.drawFontSize := 12;
		fillerY := 6;
	elseif termID.length = 3 then
		fillerFrame.drawFontSize := 10;
		fillerY := 8;
	else
		fillerFrame.drawFontSize := 8;
		fillerY := 10;
	endif;
	fillerFrame.drawTextAt(termID,theX,fillerY,Black);
epilog
	endLoad;
	self.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="_theSDF" type="CMUI_ScrollableDrawingFrame"/>
        <Parameter name="_theTerminalArea" type="CM_TerminalArea"/>
        <Parameter name="_index" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="exitForm" id="b148fa94-6f22-4a88-8b2d-dc41d28bff77">
        <source>exitForm();
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	self.doMnuLcnClickClearup();
end;</source>
    </JadeMethod>
    <JadeMethod name="frmGridAreaDragOver" id="613e0aba-adbe-475e-af5d-dba1977a0d17">
        <updating/>
        <source>frmGridAreaDragOver(_frmGridArea: CMUI_GridAreaFrame input; _sdf : CMUI_ScrollableDrawingFrame input; win: Window input; x: Real; y: Real; state: Integer) updating, protected;
//-----------------------------------------
// Created: 13 October 2003 By: cnwgd1
//-----------------------------------------
vars
	maskTI 	 : CM_TrackedItem;
	targetTA : CM_TerminalArea;
	gridArea : YRD_GridArea;
	sdf		 : CMUI_ScrollableDrawingFrame;
begin

	if _frmGridArea = null and _sdf = null then
		return;
	endif;
	
	if self.frmInfoDrag.visible then
		self.frmInfoDrag.move(x,y,self.frmInfoDrag.width,self.frmInfoDrag.height);
	endif;

	if app.myMoveController = null then
		return;
	endif;
	
	self.setFocus();
	self.zOrder(1);
	self.windowState := WindowState_Normal;
	
	if _frmGridArea &lt;&gt; null then
		sdf := _frmGridArea.parent.CMUI_DrawingFrame.mySDF;
	endif;
	if sdf = null then
		// draging over form, check if there was one passed in
		sdf := _sdf;
	endif;

	if self.myCurrentSDF &lt;&gt; sdf then
		self.setMyCurrentSDF(sdf,true);
		app.myMoveController.isAutoMasked := false;
	endif;
	if self.autoMask and (not app.myMoveController.isAutoMasked) then
		// auto masking on, colour up pad area for masked TI
		app.myMoveController.isAutoMasked := true;

		maskTI := app.myMoveController.myTrackedItem;
		if maskTI = null then
			return;
		endif;
		if sdf.allGridAreasByRowColumn.isEmpty then
			return;
		endif;
		gridArea := sdf.allGridAreasByRowColumn.first.YRD_GridArea;
		if gridArea = null then
			return;
		endif;
		targetTA := gridArea.myTerminalArea;
		if targetTA = null then
			return;
		endif;
		// no need to check TA as we only need to check if we are dragging
		// in same window (which is done above)
//		if targetTA &lt;&gt; app.myMoveController.myOriginatingLocation.myTerminalArea then
//process.profilerStart();
			self.doGridAreaDragOverAutoMask(sdf, maskTI, targetTA);
//process.profilerStop();
//process.profilerReport('d:/cnwdmast/automask.log');
//		endif;
	endif;	
end;</source>
        <access>protected</access>
        <Parameter name="_frmGridArea" type="CMUI_GridAreaFrame" usage="input"/>
        <Parameter name="_sdf" type="CMUI_ScrollableDrawingFrame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="frmGridArea_contextMenu" id="ec667d7c-41fb-4826-a45d-62fe8c8e6e80">
        <controlMethod name="Frame::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>frmGridArea_contextMenu(cntrl: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:     22 January 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
