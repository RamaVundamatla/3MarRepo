    <JadeMethod name="processYardJob" id="95f54814-435c-4c3e-8d46-d7efd24c19ae">
        <updating/>
        <source>processYardJob(_mode : Integer; _passport : CM_Passport input) updating, protected;
//--------------------------------------------------------------
//Created: 21 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	truck 		: CM_Vehicle;
	toLocn		: CM_LocationsController;
	roadJob	 	: CM_RoadJob;
	wle			: CM_WorkListEntry;
	toDoRequest	: CM_Request;
	cancelSave	: Boolean;
begin

	if self.allTrackedItems.isEmpty then
		// Nothing to move
		return;
	endif;
	
	//Set the master ti on the CM_YardWLE (and CM_ToDoWle if there is one)
	//Then update the toDoRequest to complete if there is one.
	foreach wle in self.myYardJob.workListEntries do
		if wle.myBOL.number = self.number then
			wle.setMyTrackedItem(self.allTrackedItems.first);
			if wle.myRequest.isKindOf(CM_ToDoRequest) then
				toDoRequest := wle.myRequest;
				app.myUtilityUA.utlUpdateToDoRequestStatus(toDoRequest, STATUS_COMPLETE, _passport);
			endif;
		endif;
	endforeach;
	
	if (not _passport.noErrors) then
		return;
	endif;	
	
	app.myUtilityUA.utlUpdateJobDoMove(self.myYardJob, _mode, app.myPassport);

end;</source>
        <access>protected</access>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="73a7b6da-b676-4498-bb59-a86cd5e12238">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------------------
//Created: 11 July 2002 By: cnwsb1
//--------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	pxyBOLOut	: CM_BOLOut;
	completedOK	: Boolean;
	
begin
	pxyBOLOut := inheritMethod();
	
	// Not maintained on the proxy:
	//   allBOLOutStockOrderTIs
	//   allStockOrderHeaders
	
	pxyBOLOut.myMasterTI		:= self.myMasterTI;
	pxyBOLOut.myReleaseTerminal	:= self.myReleaseTerminal;
	pxyBOLOut.myStevedore		:= self.myStevedore;
	pxyBOLOut.myVoyage			:= self.myVoyage;
	pxyBOLOut.myTerminalIfUnmatched	:= self.myTerminalIfUnmatched;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyBOLOut;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyBOLOut;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="removeTIs" id="dbe593cb-5e24-4a10-86ef-778c9bb95a7e">
        <updating/>
        <source>removeTIs(_passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 28 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	ti : CM_TrackedItem;
	tiSet : CM_TISet;
	firstTime : Boolean;
	moveController : CMIF_MoveController;
begin
	
	create tiSet transient;

	foreach ti in self.allTrackedItems do
		if ti.getPrimaryLocation(PLANNING_MODE) &lt;&gt; null then
			tiSet.add(ti);
		endif;
	endforeach;
	
	if tiSet.size &gt; 0 then
		create moveController transient;
		moveController.setMoveMode(PLANNING_MODE);
		moveController.isSystemMove := true;
		moveController.setJobForMove(self.myYardJob);			
		moveController.setMyToPrimaryLocation(null);
		firstTime := true;
		foreach ti in tiSet do
			if firstTime then
				moveController.setMyTrackedItem(ti);		
				firstTime := false;
				continue;
			endif;
			moveController.allOtherTrackedItems.add(ti);
		endforeach;
		app.myUtilityUA.utlUpdateMoveTrackedItem(moveController, _passport);
	endif;
	
epilog
	delete tiSet;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="resetTransitReferences" id="eff1b598-dd01-4641-85b5-b524b5c74a95">
        <updating/>
        <source>resetTransitReferences(_voyageController : CM_LogVoyageController) updating;

// cnwdvb1 14 October 2002 

vars

begin

	self.myVoyage 				:= _voyageController.myVoyage;
	self.myPlannedLocation		:= _voyageController;
	if self.myExtension &lt;&gt; null then
		self.myExtension.CM_BOLExtLogOut.resetTransitReferences(_voyageController);
	endif;

end;</source>
        <Parameter name="_voyageController" type="CM_LogVoyageController"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="b1812856-0355-493d-a976-d010ddc0cdd7">
        <updating/>
        <source>setForCreate(_pxyBOL : CM_BOLOut; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
// Created: 26 July 2002 By: cnwsb1
//--------------------------------------------------------------
vars
	logVoyCntrl : CM_LogVoyageController;
begin
	inheritMethod(_pxyBOL, _passport);
	self.myStockOrderHeader := _pxyBOL.myStockOrderHeader;
	app.myEventManager.createSingleObjInfoNoteEvt(self.myTerminal, Event_BOLOut_Create, self);
	
	if self.bolType = BOLType_Log then
		if self.transportMode = TI_TRANSMODE_ROAD then
			// On create we are always unmatched
			self.myTerminalIfUnmatched	:= self.myTerminal;	
			
		elseif _pxyBOL.myPlannedLocation.isTransient then
			create logVoyCntrl as _pxyBOL.myPlannedLocation.class persistent;
			logVoyCntrl.setForCreate(_pxyBOL.myPlannedLocation.CM_LogVoyageController);
			self.myPlannedLocation := logVoyCntrl;
		endif;
	endif;

end;</source>
        <Parameter name="_pxyBOL" type="CM_BOLOut"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="898f860d-d0b7-4742-b142-a4848cc42bd0">
        <updating/>
        <source>setForUpdate(_pxyBOL: CM_BOLOut; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
// Created: 29 July 2002 By: cnwsb1
//--------------------------------------------------------------
vars
	origStkOrd			: CM_StockOrderHeader;
begin
	inheritMethod(_pxyBOL, _passport);

	app.myEventManager.createSingleObjInfoNoteEvt(self.myTerminal, Event_BOLOut_Update, self);
	self.myTerminalIfUnmatched := _pxyBOL.myTerminalIfUnmatched;
	
			//might be changing or nulling the stock order reference
	origStkOrd := self.myStockOrderHeader;
	if origStkOrd &lt;&gt; null then 
		//doesn't matter if the original stockOrder is the same as the new one,
		//the contents of the docket may have changed and need re-matching anyway
		origStkOrd.doUnmatch(self, _passport);
	endif;
	
	self.myStockOrderHeader := _pxyBOL.myStockOrderHeader;
	
	if self.myStockOrderHeader &lt;&gt; null then
		self.myStockOrderHeader.doMatch(self, _passport);
	endif;	
end;</source>
        <Parameter name="_pxyBOL" type="CM_BOLOut"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_BOLOut" id="db518a4b-39da-44e0-bf04-da12181832a4">
        <updating/>
        <source>setFromCMIF_BOLOut(_cmifBOLOut : CMIF_BOLOut) updating;
// ---------------------------------------------------------------------------
// Created:     10 November 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 29 Nov 2013	cnwkpd1	   PAR #33107 - Docket number changes corrupting dictionary keys

vars

begin
	if _cmifBOLOut = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'CMIF_BOLOut object passed in is null');
		return;
	endif;
	
//	self.number := _cmifBOLOut.bolNumber;				// PAR #33107
	self.setNumber(_cmifBOLOut.bolNumber);
	
	self.myOperator := _cmifBOLOut.myOperator;
	if _cmifBOLOut.myConsignee &lt;&gt; null then
		self.consignee := _cmifBOLOut.myConsignee.code;
	else
		self.consignee := null;
	endif;
	
	if _cmifBOLOut.myConsignor &lt;&gt; null then
		self.consignor := _cmifBOLOut.myConsignor.code;
	else
		self.consignor := null;
	endif;
	
	self.notifyParty := _cmifBOLOut.notifyPartyCode;
	
	self.isCharged := not _cmifBOLOut.noCharge;

	self.referenceDate := _cmifBOLOut.referenceDate;
	app.myEventManager.createSingleObjInfoNoteEvt(self.myTerminal, Event_BOLOut_Update, self); // ### AKB2004NOV. Added to refresh LoadOut Updates
	
end;</source>
        <Parameter name="_cmifBOLOut" type="CMIF_BOLOut"/>
    </JadeMethod>
    <JadeMethod name="setFromProxy" id="babfb7da-c7c8-4618-8a4d-1c8f4cd54546">
        <updating/>
        <source>setFromProxy(_pxyBOL: CM_BOLOut; _passport : CM_Passport input) updating, protected;
//--------------------------------------------------------------
//Created: 28 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	inheritMethod(_pxyBOL, _passport);
	
	self.consignee			:= _pxyBOL.consignee;
	self.partialLoadout		:= _pxyBOL.partialLoadout;
	self.isAuditOut			:= _pxyBOL.isAuditOut;
	self.isTransfer			:= _pxyBOL.isTransfer;
	self.terminalCode		:= _pxyBOL.terminalCode;	
	
	// To avoid mapping method warning
	if self.myMasterTI &lt;&gt; _pxyBOL.myMasterTI then
		self.myMasterTI		:= _pxyBOL.myMasterTI;
	endif;
	
	self.myStevedore 		:= _pxyBOL.myStevedore;
	self.myVoyage 			:= _pxyBOL.myVoyage;
	self.myReleaseTerminal	:= _pxyBOL.myReleaseTerminal;
	
	self.myEDIDataBOLOutLog	:= _pxyBOL.myEDIDataBOLOutLog;

end;</source>
        <access>protected</access>
        <Parameter name="_pxyBOL" type="CM_BOLOut"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setPxyFromCMIF_BOL" id="858f2534-a4dc-4c37-b9a7-0b4fe26e9ff6">
        <updating/>
        <source>setPxyFromCMIF_BOL(_intFace : CMIF_BOLOut; _passport : CM_Passport input)updating;
//--------------------------------------------------------------
//Created: 13 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	ti	: CM_TrackedItem;

begin
	inheritMethod(_intFace, _passport);
	
	self.myStockOrderHeader := _intFace.myStockOrder;
	
	if _intFace.myConsignee &lt;&gt; null then
		self.consignee	:= _intFace.myConsignee.code;
	elseif _intFace.consigneeCode &lt;&gt; null then
		self.consignee	:= _intFace.consigneeCode;	
	endif;
	
	if _intFace.myConsignor &lt;&gt; null then
		self.consignor	:= _intFace.myConsignor.code;
	elseif _intFace.consignorCode &lt;&gt; null then
		self.consignor	:= _intFace.consigneeCode;	
	endif;

	self.notifyParty	:= _intFace.notifyPartyCode;	
	
	self.isAuditOut		:= _intFace.audit;
	self.isTransfer		:= _intFace.transfer;
	self.partialLoadout	:= _intFace.partialLoadout;
	self.terminalCode	:= _intFace.terminal;

	self.myMasterTI		:= _intFace.myMasterTI;
	self.myStevedore	:= _intFace.myStevedore;
	self.myVoyage		:= _intFace.myVoyage;
	
	self.myEDIDataBOLOutLog := _intFace.myEDIDataBOLOutLog;


end;</source>
        <Parameter name="_intFace" type="CMIF_BOLOut"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setReleaseBOLFromProxy" id="d9088e4a-f60b-42cd-9c86-ad7dbabd758c">
        <updating/>
        <source>setReleaseBOLFromProxy(_proxyBol : CM_BOLOut) updating;
//--------------------------------------------------------------
//Created: 13 June 2002 By: cnwgd1
//--------------------------------------------------------------
/*

Date		Who		Reason
29 Nov 2013	cnwkpd1	PAR #33107 - Docket number changes corrupting dictionary keys
	
*/

vars

begin
	self.bolType 		:= _proxyBol.bolType;
	self.dateTime 		:= app.serverTimestampAtTrxStart;
	self.referenceDate  := _proxyBol.referenceDate;
	self.myExtension 	:= _proxyBol.myExtension;
	self.myOperator 	:= _proxyBol.myOperator;
//	self.number 		:= _proxyBol.number;			// PAR #33107
	self.setNumber(_proxyBol.number);
	
	self.myStevedore	:= _proxyBol.myStevedore;

	self.myPlannedLocation := _proxyBol.myExtension.getPlannedLocation();

	self.myOperatorTerminal := _proxyBol.myOperator.getOperatorTerminal(self.myTerminal, (not self.isTransient));

end;</source>
        <Parameter name="_proxyBol" type="CM_BOLOut"/>
    </JadeMethod>
    <JadeMethod name="setTIsForCreate" id="1a551da8-6815-4899-9f2e-8c3f622fd7fa">
        <updating/>
        <source>setTIsForCreate(_tiDict: CM_TISet; _passport: CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     12 May 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	ti			: CM_TrackedItem;
	ts			: TimeStamp;
begin
	inheritMethod(_tiDict, _passport);
	ts := app.actualTimeServer();
	foreach ti in self.allTrackedItems do
		ti.setReleasedDT(ts);
	endforeach;
end;</source>
        <Parameter name="_tiDict" type="CM_TISet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="677e35e5-1aed-46c6-bedf-c7af8c7f1c70">
        <source>showThumbnailData(pHeadings: HugeStringArray input; pData: HugeStringArray input; _terminal : CM_Terminal);
//--------------------------------------------------------------
//Created: 25 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	ti					: CM_TrackedItem;
	supplierTerminology	: String;
	
begin
	pHeadings.clear();
	pData.clear();
	
	pHeadings.add('Docket Created Date');
	pData.add(self.dateTime.date.shortFormatJMT());
	
	if self.myExtension &lt;&gt; null then
		self.myExtension.showThumbnailData(pHeadings, pData, _terminal);
	endif;
	
	pHeadings.add('Cartage Contractor');
	pData.add(self.carrierDesc);
	pHeadings.add('Truck Number');
	pData.add(self.vehicle);
	pHeadings.add('Trailer Number(s)');
	pData.add(self.trailerNumber);
	pHeadings.add('Docket No.');
	pData.add(self.number);
	
	supplierTerminology	:=	app.getTerminologyAlternate(app.myRoot.allBOLTypes[BOLType_Log],
														self.myTerminal,
														CM_TerminologyOperator,
														CM_TermExpressionSingular,
														'Supplier');
	
	pHeadings.add(supplierTerminology);
	pData.add(self.getOperatorDescription());
	
	pHeadings.add('Item Count');
	pData.add(self.numItems.String);
	
	pHeadings.add('Number of Lifts');
	pData.add(self.numberOfLifts.String);
	pHeadings.add('Yard Location');
	pData.add(self.getLocationDescription());
	
	pHeadings.add('Customer');
	pData.add(self.consignee);
	
	if self.allTrackedItems &lt;&gt; null then
		foreach ti in self.allTrackedItems do
			pHeadings.add('TrackedItem Id');pData.add(ti.id);
		endforeach;
	endif;
end;</source>
        <Parameter name="pHeadings" type="HugeStringArray" usage="input"/>
        <Parameter name="pData" type="HugeStringArray" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="totalBOLWeight" id="cd4e6ec5-b948-43ee-bab5-f8d7a50f6557">
        <methodInvocation>mapping</methodInvocation>
        <source>totalBOLWeight(set: Boolean; _value: Decimal io) mapping;
// ---------------------------------------------------------------------------
// Created:     26 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	totalWeight,
	tiWeight,
	containerWeight		: Decimal[14,4];
	ti					: CM_TrackedItem;
	invalid : Boolean;
begin
	if set then
		app.raiseSetVirtualError(Class.name, method.name);
		return;
	endif;

	if WarehouseIntegrated and self.myMasterTI &lt;&gt; null then
		//containerWeight := self.myMasterTI.weight;					//-cnwml2 MSL CCMS 1017
		
		//13 Sep 2018	NDL	- DMAST cleanup
		on Exception do app.handleDeletedObject( exception, self.myMasterTI, invalid );
		
		containerWeight := self.myMasterTI.weightTare;					//+cnwml2 MSL CCMS 1017
	elseif self.myExtension &lt;&gt; null and self.myExtension.isKindOf(CM_BOLExtWarehouse) then
		containerWeight := self.myExtension.CM_BOLExtWarehouse.containerTareWeight;
	endif;
		
	foreach ti in self.allTrackedItems do
		//tiWeight := tiWeight + ti.weight;				//-cnwml2 MSL CCMS 1017
		tiWeight := tiWeight + ti.totalWeight;			//+cnwml2 MSL CCMS 1017
	endforeach;	 
	
	totalWeight := containerWeight + tiWeight;
	_value := totalWeight;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="totalTIVolume" id="f1195236-34d2-4a83-8abe-fb1bae668432">
        <methodInvocation>mapping</methodInvocation>
        <source>totalTIVolume(set: Boolean; _value: Decimal io) mapping;
// ---------------------------------------------------------------------------
// Created:     08 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ti				: CM_TrackedItem;
	totalVol	:Real;
begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		foreach ti in self.allTrackedItems do
			totalVol := totalVol + ti.getMyTotalVolume;
		endforeach;
		_value := totalVol;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="totalTIWeight" id="e793e9f9-2f95-4a1d-bad1-f19e81025445">
        <methodInvocation>mapping</methodInvocation>
        <source>totalTIWeight(set: Boolean; _value: Decimal io) mapping;
// ---------------------------------------------------------------------------
// Created:     08 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	ti				: 	CM_TrackedItem;
	totalWeight		:	Decimal[14,4];
begin
	if set then
		app.raiseSetVirtualError(Class.name, method.name);
	else
		foreach ti in self.allTrackedItems do
			//totalWeight := totalWeight + ti.weight;					//-cnwml2 MSL CCMS 1017
			totalWeight := totalWeight + ti.totalWeight;				//+cnwml2 MSL CCMS 1017
		endforeach;
		_value := totalWeight;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateFromCM_BOLOutHeader" id="fc23d47e-52d1-40ae-bdfc-64e07c65f27c">
        <updating/>
        <source>updateFromCM_BOLOutHeader(_bolOutHeader : CM_BOLOutHeader; _passport : CM_Passport input) :Boolean updating;
//--------------------------------------------------------------
//Created: 24 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	rtnValue 	: Boolean;
	terminal	: CM_Terminal;
begin
	if self.myExtension &lt;&gt; null then
		rtnValue := self.myExtension.updateFromCM_BOLOutHeader(_bolOutHeader, _passport);
	endif;
	
	if rtnValue then
		if self.myYardJob &lt;&gt; null then
			self.processYardJob(REAL_MODE, _passport);
		else
			//Move all TIs to self.myPlannedLocation
			self.doMoveToLocation(REAL_MODE, _passport);
		endif;
		rtnValue := _passport.noErrors();		
	endif;
	
	if rtnValue then
		terminal := _passport.myTerminal;
		self.myTerminalIfUnmatched := null;
		terminal.causeEvent(terminal.getTerminalEvent(BOLRecon_Matched_Event), false, self);
	endif;
	
epilog
	return _passport.noErrors;
end;</source>
        <Parameter name="_bolOutHeader" type="CM_BOLOutHeader"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="bdf4fdf2-9ebc-4234-a44c-7d4dea8f9e2f">
        <source>validateForDelete();
//--------------------------------------------------------------
//Created: 22 July 2002 By: cnwsb1
//--------------------------------------------------------------
vars

begin

	if self.bolType = BOLType_GeneralDocket or self.bolType = BOLType_GeneralBillOfLading then
		// We don't mind if a general bol out is deleted containing TIs.
	elseif self.myExtension &lt;&gt; null then
		self.myExtension.validateForDelete();
	else
		inheritMethod();
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="a8ba3764-111a-41fa-b622-87f151d1c4b3">
        <updating/>
        <source>validateForUpdate(pControl: CMIF_TIUpdateController input; _headerOnly: Boolean; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 11 July 2002 By: cnwsb1
//--------------------------------------------------------------
vars
	realBOLOut : CM_BOLOut;

begin
	inheritMethod(pControl, _headerOnly, _passport);
	/*cnwth2 - no problem with changing the docket number
	realBOLOut := self.pxyGetRealObject;
	
	if self.bolType &lt;&gt; BOLType_Log then
		if self.number &lt;&gt; realBOLOut.number then
			app.raiseCMException2(InvalidAttrForUpdate,
								  "Docket Number", realBOLOut.number &amp; " -&gt; " &amp; self.number,
								  ETRow_BolNumber, pControl.myUserObject);
		endif;
	endif;
	*/
end;</source>
        <Parameter name="pControl" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_headerOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="3a874269-3c80-4b4a-bb81-e21e62cf4096">
        <source>validateMe(pControl: CMIF_TIUpdateController input; _headerOnly: Boolean; _passport : CM_Passport input) protected;
// ---------------------------------------------------------------------------
// Created:     24 June 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	port			: CM_Port;
	tmpOperator	: CM_Operator;
	str				: String;
begin
	inheritMethod(pControl, _headerOnly, _passport);
	
	if self.dischargePort &lt;&gt; null then
		// If a port is given then it must be valid
		//port := app.myRoot.allPorts[self.dischargePort];
		port := app.myRoot.allPorts[self.dischargePort];
		if port = null then
			app.raiseCMException1(ERR_INVALID_DIS_PORT, self.dischargePort, 'dischargePort', null);
		else
			if self.myVoyage = null then
				// A voyage is required if a discharge port has been entered
			//	app.raiseCMException1(REQUIRED_FIELD, 'voyage', 'voyage', null);
				app.raiseCMException(Input_required_field_voyage, 'voyage', null);// cnwdb2	PAR 35364
			else
				self.myVoyage.validateDischargePort(port, null);
			endif;
		endif;
	endif;
	
	tmpOperator := self.myOperator;
	if tmpOperator &lt;&gt; null and
	   tmpOperator.requiresConsigneeConsignor and
	   self.myConsignee = null then
	//	app.raiseCMException1(REQUIRED_FIELD, "Consignee", null, null);
		app.raiseCMException(Input_required_field_consignee, null, null); // cnwdb2	PAR 35364

	endif;

	if self.bolType = BOLType_GeneralDocket then
		if not _headerOnly then
			if self.hasDamagedTIs then
				app.raiseCMWarning1(DamagedTIs, self.bolTypeDesc &amp; self.number, null, null, self);
			endif;
		endif;

		// General BOLs must have a master item (ie. the container)
		if false and self.myMasterTI = null and self.transportMode = TI_TRANSMODE_SHIP then
			app.raiseCMException1(BOLTypeGeneralMissingMasterTI, self.number, null, null);
		endif;
	elseif self.bolType = BOLType_GeneralBillOfLading then
		if not _headerOnly then
			if self.hasDamagedTIs then
				app.raiseCMWarning1(DamagedTIs, self.bolTypeDesc &amp; self.number, null, null, self);
			endif;
		endif;

		// General BOLs must have a master item (ie. the container)
		if false and self.myMasterTI = null and self.transportMode = TI_TRANSMODE_SHIP then
			app.raiseCMException1(BOLTypeGeneralMissingMasterTI, self.number, null, null);
		endif;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_headerOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateNumTIs" id="962ee717-f751-44ca-80b2-81aea1e06417">
        <source>validateNumTIs(_headerOnly: Boolean);
//-----------------------------------------
//Created: October 2002 By: cnwgd1
//-----------------------------------------
vars
	tmpNum : Integer;
begin
	inheritMethod(_headerOnly);
	
	if (_headerOnly) then
		return;
	endif;
	
	if self.transportMode = TI_TRANSMODE_ROAD and
		self.bolType = BOLType_Log then
		//Do nothing as quantity will be unknown until loaded/scaled
	else
		tmpNum := self.numTIs;	// as this is a virtual of self.allTrackedItems.size
		if self.numItems = 0 then
			if self.bolType = BOLType_GeneralDocket or self.bolType = BOLType_GeneralBillOfLading then
				//app.raiseCMException1(Full_Replacement_Message, 'You must enter at least one tracked item', null, self); //- cnwmd1, Par 20524
				app.raiseCMException(Must_enter_least_one_TI, null, self);//+ cnwmd1, Par 20524
			else
			//	app.raiseCMException1(REQUIRED_FIELD, 'Number of Items', ETRow_NumItems, self);
				app.raiseCMException(Input_required_field_numOfItem, ETRow_NumItems, self); // cnwdb2	PAR 35364

			endif;
		else
				// If numItems is set then check that numTIs agrees.
			if tmpNum &gt; 0 and 
				self.bolType &lt;&gt; BOLType_Log and
			   tmpNum &lt;&gt; self.numItems then
				app.raiseCMException3(BOLInvalidQuantity, tmpNum.String, self.number,
									  self.numItems.String, ETRow_NumItems, self);
			endif;
		endif;
	endif;
	
end;</source>
        <Parameter name="_headerOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateTransportMode" id="a3d5d2e5-b745-493b-8a67-0234beb18137">
        <source>validateTransportMode(pControl: CMIF_TIUpdateController) protected;
//--------------------------------------------------------------
//Created: 08 July 2002 By: cnwsb1
//--------------------------------------------------------------
vars
	transModeStr	: String;

begin
	inheritMethod(pControl);
	
	transModeStr := app.transModeToString(self.transportMode);
	
	// REQUIRED attributes for transport mode
	if self.transportMode = TI_TRANSMODE_ROAD then
	elseif self.transportMode = TI_TRANSMODE_RAIL then
	elseif self.transportMode = TI_TRANSMODE_SHIP then
		/* For Logs this is not required as may not be known
		   need to convert to a config flag if someone does require this.
		if self.dischargePort = null then
			app.raiseCMException2(RequiredAttrForTransportMode, "dischargePort",
					transModeStr, ETRow_DischargePort, pControl.myUserObject);
		endif;
		*/
		if self.myVoyage = null then
			app.raiseCMException2(RequiredAttrForTransportMode, "voyage",
					transModeStr, ETRow_Voyage, pControl.myUserObject);
		endif;
	endif;

	// INVALID attributes for transport mode
	if self.transportMode &lt;&gt; TI_TRANSMODE_ROAD then
	endif;
	if self.transportMode &lt;&gt; TI_TRANSMODE_RAIL then
	endif;
	if self.transportMode &lt;&gt; TI_TRANSMODE_SHIP then
		if self.dischargePort &lt;&gt; null then
			app.raiseCMException2(InvalidAttrForTransportMode, "dischargePort",
					transModeStr, ETRow_DischargePort, pControl.myUserObject);
		endif;
		if self.myStevedore &lt;&gt; null then
			app.raiseCMException2(InvalidAttrForTransportMode, "stevedore",
					transModeStr, ETRow_Stevedore, pControl.myUserObject);
		endif;
		if self.myVoyage &lt;&gt; null then
			app.raiseCMException2(InvalidAttrForTransportMode, "voyage",
					transModeStr, ETRow_Voyage, pControl.myUserObject);
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="pControl" type="CMIF_TIUpdateController"/>
    </JadeMethod>
</Class>
