<GUIClass name="OptionButton">
    <JadeMethod name="jssSet" id="b897f561-346f-412c-bd3d-1e7137653d66">
        <updating/>
        <source>jssSet(pValue:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		Updates the receiver's boolean flag with the specified value.
//
// Parameters:	pValue - The string value to set the text to.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.value &lt;&gt; pValue then
		self.value	:=	pValue;
	endif;
end;</source>
        <Parameter name="pValue" type="Boolean"/>
    </JadeMethod>
</GUIClass>
