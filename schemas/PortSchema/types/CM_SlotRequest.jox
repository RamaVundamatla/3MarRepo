    <JadeMethod name="getVoyage" id="35c08b3a-d08a-41cd-8c8b-72df33b80d9c">
        <source>getVoyage(): CM_Voyage;
/*
 ------------------------------------------------------------------------
Created:			09 October 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
	theVoyage : CM_Voyage;
begin
	if self.myJob &lt;&gt; null then
		theVoyage := self.myJob.CM_VoyageJob.myVoyage;
