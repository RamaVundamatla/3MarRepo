        <Parameter name="_payment2" type="Decimal"/>
        <Parameter name="_effectiveDate" type="Date"/>
        <Parameter name="_externalInvoiceNumber" type="String"/>
        <Parameter name="_externalReferenceNumber" type="String"/>
        <Parameter name="_totalCargoCharges" type="Decimal"/>
        <Parameter name="_cashAlreadyAllocated" type="Decimal"/>
        <Parameter name="_cashAllocationRequired" type="Decimal"/>
        <Parameter name="_cashPaymentRequired" type="Decimal"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_agent" type="CM_Object"/>
        <Parameter name="_wo" type="CM_WorkOrder"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
