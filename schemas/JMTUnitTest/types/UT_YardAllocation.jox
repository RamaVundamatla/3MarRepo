    <JadeMethod name="tDeleteYABlock" id="e1355f92-c166-48ee-9e32-3f572140d741">
        <source>tDeleteYABlock();
// cnwndl1
//17 July 2008	cnwdw1	
//
vars
	locations : CM_LCArray;
	ya, proxyYA: CM_YardAllocation;
	operatorSet: CM_ObjectSet;
	blocks: CM_YABlockArray;
	yaBlock: CM_YABlock;
	ta: CM_GridArea;
begin
	deleteTerminalArea("UTSTRD");
	ta:= addStraddleStack("UTSTRD", 2, 2, 1);
	assertNotNullMsg(ta, "straddleStack");

	self.deleteYA("UT");
	
	create locations transient;
	// Locations are added in reversed order
	locations.add(ta.allLocationsControllers.last.CM_YardController);
	locations.add(ta.allLocationsControllers.first.CM_YardController);
	create operatorSet transient;
	operatorSet.add(app.myRoot.allOperators["DOUG"]);
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, operatorSet, locations);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Create failed");
	locations.add(ta.allLocationsControllers.last.CM_YardController);

	create blocks transient;
	blocks.add(ya.allYABlocksIn.first);

	
	app.myTrxDA.trxDeleteYABlock( blocks,app.myPassport); 
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "YABlockOrder update failed");
	self.assertEqualMsg(ya.allYABlocksIn.size, 0, "YA blocks size incorrect");
	self.assertEqualMsg(ya.allYABlocksOut.size, 0, "YA blocks size incorrect");

epilog
	delete locations;
	delete operatorSet;
	delete blocks;
end;</source>
    </JadeMethod>
    <JadeMethod name="tDeleteYAGroup" id="107c9fa9-4c66-4e33-9d43-fa6a701c8b7b">
        <source>tDeleteYAGroup();
// cnwndl1
//27 January 2009	cnwdw1	
//
vars
	st: CM_StraddleStack;
	locations : CM_LCArray;
	pxyYA, ya: CM_YardAllocation;
	yaBlock, yaBlock1, yaBlock2, yaBlock3  : CM_YABlock;
	yaBlocksIn, yaBlocksOut: CM_YABlockArray;
	groupsIn, groupsOut: CM_YABlockGroupArray;
	pxyGroup, deletedGroup, group1, group2, group3: CM_YABlockGroup;
	criterias: CMIF_Array;
	yaBlockGroup, pxyYABlockGroup: CM_YABlockGroup;
begin
	self.deleteYA("UT");
	self.deleteTerminalArea("UTSTD");
	st := self.addStraddleStack("UTSTD", 6, 5, 3);

	create yaBlocksIn transient;
	create yaBlocksOut transient;
	
	yaBlock1 := st.allGridControllersByRowColumn[1, 1].yaBuildBlock(true, null);
	yaBlock1.allYardControllers.add(st.allGridControllersByRowColumn[1, 1]);
	yaBlock1.allYardControllers.add(st.allGridControllersByRowColumn[1, 2]);
	yaBlock1.setProxyDeckingOptions();
	
	yaBlock2 := st.allGridControllersByRowColumn[2, 1].yaBuildBlock(true, null);
	yaBlock2.allYardControllers.add(st.allGridControllersByRowColumn[2, 1]);
	yaBlock2.allYardControllers.add(st.allGridControllersByRowColumn[2, 2]);
	yaBlock2.setProxyDeckingOptions();

	// Create the Groups
	// Group 1 
	//	In
	//    UTSTD 01-01 01-02
	//    UTSTD 02-02 01-02
	//  Out 
	//    UTSTD 02-02 01-02
	//    UTSTD 01-01 01-02
	// Group 2 
	//  In
	//  Out
	create group1 transient;  
	yaBlocksIn.clear;
	yaBlocksIn.add(yaBlock1);
	yaBlocksIn.add(yaBlock2);
	yaBlocksOut.clear;
	yaBlocksOut.add(yaBlock2);
	yaBlocksOut.add(yaBlock1);
	group1.setProxy("Group 1", yaBlocksIn, yaBlocksOut);

	create group2 transient;  
	yaBlocksIn.clear;
	yaBlocksOut.clear;
	group2.setProxy("Group 2", yaBlocksIn, yaBlocksOut);

	create groupsIn transient;
	groupsIn.add(group1);
	groupsIn.add(group2);
	create groupsOut transient;
	groupsOut.add(group1);
	groupsOut.add(group2);
	
	ya := self.addYA1WithGroups("UT", YACriteriaType_Clean, CM_YADataBoolean.VALUE_TRUE, groupsIn, groupsOut, YAFillOption_InOrder, YAFillOption_InOrder);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Create failed");
	self.assertTrueMsg(ya.allYABlockGroupsIn.size = 2, "Groups not created");
	self.assertTrueMsg(ya.allCriteria.size  = 1, "Criteria not created");
	self.assertTrueMsg(ya.allYABlocksIn.first.myDeckingOptions &lt;&gt; null, "Decking options are null");
	
	pxyYA := app.createUpdateProxy(ya).CM_YardAllocation;
	pxyGroup := pxyYA.allYABlockGroupsIn[2];
	deletedGroup := pxyGroup.pxyGetRealObject();
	pxyYA.allYABlockGroupsIn.removeAt(2);
	pxyYA.allYABlockGroupsOut.removeAt(2);
	delete pxyGroup;
	
	create criterias transient;
	app.myTrxUA.trxUpdateYardAllocation(pxyYA, criterias, app.myPassport);
	delete criterias;
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(pxyYA.allYABlockGroupsIn.size, 1);
	self.assertEqual(pxyYA.allYABlockGroupsOut.size, 1);
	self.assertEqual(pxyYA.allYABlockGroupsIn.first.description, "Group 1");
	self.assertEqual(pxyYA.allYABlockGroupsOut.first.description, "Group 1");
	self.assertTrueMsg(ya.allCriteria.size  = 1, "Criteria not created");
	self.assertIsDeleted(deletedGroup);
	
	delete pxyYA;
	pxyYA := app.createUpdateProxy(ya).CM_YardAllocation;
	pxyGroup := pxyYA.allYABlockGroupsIn[1];
	deletedGroup := pxyGroup.pxyGetRealObject();
	pxyYA.allYABlockGroupsIn.removeAt(1);
	pxyYA.allYABlockGroupsOut.removeAt(1);
	delete pxyGroup;
	
	create criterias transient;
	app.myTrxUA.trxUpdateYardAllocation(pxyYA, criterias, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(pxyYA.allYABlockGroupsIn.size, 0);
	self.assertEqual(pxyYA.allYABlockGroupsOut.size, 0);
	self.assertTrueMsg(ya.allCriteria.size  = 1, "Criteria not created");
	self.assertIsDeleted(deletedGroup);
	
epilog
	delete yaBlocksIn;
	delete yaBlocksOut;
	delete groupsIn;
	delete groupsOut;
	delete criterias;
	delete pxyYA;
	delete yaBlock;
end;</source>
    </JadeMethod>
    <JadeMethod name="tGenericAllocationCheck" id="9075a245-a715-46db-8e58-94fe2b8ae19a">
        <source>tGenericAllocationCheck();

/*

Purpose:		

Date			Who		Reason
27/03/2015		cnwmh5	Initial creation

*/
constants

	BlockStack1Id			: String = "UTMHBX";
	BlockStack2Id			: String = "UTMHBY";
	YAExportId				: String = "UTMDHExport";
	YAStorageId				: String = "UTMDHStorage";
	YAImportId				: String = "UTMDHImport";
	YANOImexId				: String = "UTMDHNOImex";
	YATranshipId			: String = "UTMDHTranship";
	YAROBId					: String = "UTMDHROB";
	YAFlexWeight			: String = "UTMDHFlexW";
	YALength				: String = "UTMDHLength";
	YAWidth					: String = "UTMDHWidth";
	YAHeight				: String = "UTMDHHeight";
	YAFlexiWeight			: String = "UTMDHFlexi";
	TruckId					: String = "UTMHTRJ";
	TIId1					: String = "UTGALLC0001";
	TIId2					: String = "UTGALLC0002";
	TIId3					: String = "UTGALLC0003";
	TIId4					: String = "UTGALLC0004";
	TIId5					: String = "UTGALLC0005";
	VoyageId				: String = "UTMHGACVOY";
	VesselId				: String = "MESDIAM";
	CraneId					: String = "UTMV";
	CTAId					: String = "UTMVCTA";
	CTId1					: String = "UTMHREBAR01";
	CTId2					: String = "UTMHREBAR02";
	CTId3					: String = "UTMHREBAR03";
	CTId4					: String = "UTMHREBAR04";
	
vars

	bs1						: CM_BlockStack;
	bs2						: CM_BlockStack;
	ya						: CM_YardAllocation;
	vvr						: CM_VehicleVisitRecord;
	ti						: CM_TrackedItem;
	voyage					: CM_Voyage;
	crane					: CM_Machine;
	cta						: CM_CraneTransferArea;
	tmpLoadCC				: CMIF_LoadColorCode;
	voyageDischJob			: CM_VoyageJob;
	cargoType				: CM_CargoType;
	
	tas						: StringArray;
	locations 				: CM_LCArray;
	tiArray					: CM_TIArray;
	
	slotsFrom				: CM_SlotControllerArray;
	
begin

	self.deleteVehicle(TruckId);
	ti := self.getTrackedItem(TIId1);
	self.deleteTrackedItem(ti, false);
	ti := self.getTrackedItem(TIId2);
	self.deleteTrackedItem(ti, false);
	ti := self.getTrackedItem(TIId3);
	self.deleteTrackedItem(ti, false);
	ti := self.getTrackedItem(TIId4);
	self.deleteTrackedItem(ti, false);
	ti := self.getTrackedItem(TIId5);
	self.deleteTrackedItem(ti, false);
		
	self.deleteVoyage(VoyageId);
	voyage := self.addVoyageWithConRORO(VoyageId, VesselId, "UTOP", self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(),
		self.getProfileSetting(UT_Profile.P_TRADE).asString(), 0, true, false);
	self.assertNotNull(voyage);
	
	self.deleteMachine(CraneId);
	cta := self.addCraneTransferArea(CTAId);
	self.assertNotNull(cta);
	
	// 05/04/2016 cnmwh5 - Move here from after ti deletes to fix issue with slot discharge request error 4ing
	bs1 := self.addBlockStack(BlockStack1Id, 15, null);
	self.assertNotNull(bs1);
	
	bs2 := self.addBlockStack(BlockStack2Id, 15, null);
	self.assertNotNull(bs2);	
	
	create tiArray transient;
	
	create tas transient;
	tas.add(cta.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	crane := self.addCrane(CraneId, null, tas, null);
	self.assertNotNull(crane);
	
	cargoType := self.getCargoType("UTREBAR");
	self.assertNotNull(cargoType);	
	
	self.deleteAllCargo(CTId1, cargoType);
	self.deleteAllCargo(CTId2, cargoType);
	self.deleteAllCargo(CTId3, cargoType);
	self.deleteAllCargo(CTId4, cargoType);
	
	self.disableAllYA(true);
	
	create locations transient;
	
	// Export
	
	locations.clear();
	bs2.allLocationsControllers.copy(locations);
	ya := self.addYA(YALength, YACriteriaType_ImexStatus, "EXP", YACriteriaType_CargoType, "CONT", null, null, locations, null);
	self.assertNotNull(ya);
	self.opts.purge();
	self.xGACProcessCargo(bs2, TI_IMEX_STATUS_EXPORT, TIId1, TruckId, null);
	ti := self.getTrackedItem(TIId1);
	self.assertNotNull(ti);
	self.assertEqual(ti.myPrimaryActualLocation.ident, bs2.id);
	
	// Storage
	
	locations.clear();
	bs1.allLocationsControllers.copy(locations);
	ya := self.addYA(YALength, YACriteriaType_ImexStatus, "STO", YACriteriaType_CargoType, "CONT", null, null, locations, null);
	self.assertNotNull(ya);
	self.opts.purge();
	self.xGACProcessCargo(bs1, TI_IMEX_STATUS_STORAGE, TIId2, TruckId, null);
	ti := self.getTrackedItem(TIId2);
	self.assertNotNull(ti);
	self.assertEqual(ti.myPrimaryActualLocation.ident, bs1.id);
	
	// Import
	
	locations.clear();
	bs2.allLocationsControllers.copy(locations);
	ya := self.addYA(YALength, YACriteriaType_ImexStatus, "IMP", YACriteriaType_CargoType, "CONT", null, null, locations, null);
	self.assertNotNull(ya);
	self.xGACProcessCargo(bs2, TI_IMEX_STATUS_IMPORT, TIId3, TruckId, null);
	ti := self.getTrackedItem(TIId3);
	self.assertNotNull(ti);
	self.assertEqual(ti.myPrimaryActualLocation.ident, bs2.id);
	
	// NO IMEX
	
	locations.clear();
	bs1.allLocationsControllers.copy(locations);
	ya := self.addYA(YALength, YACriteriaType_ImexStatus, "NONE", YACriteriaType_CargoType, "CONT", null, null, locations, null);
	self.assertNotNull(ya);
	self.opts.purge();
	self.xGACProcessCargo(bs1, TI_IMEX_STATUS_NULL, TIId4, TruckId, null);
	ti := self.getTrackedItem(TIId4);
	self.assertNotNull(ti);
	self.assertEqual(ti.myPrimaryActualLocation.ident, bs1.id);
	
	// Tranship
	
	locations.clear();
	bs2.allLocationsControllers.copy(locations);
	ya := self.addYA(YALength, YACriteriaType_ImexStatus, "TSH", YACriteriaType_CargoType, "CONT", null, null, locations, null);
	self.assertNotNull(ya);
	self.opts.purge();
	self.xGACProcessCargo(bs2, TI_IMEX_STATUS_TRANSHIP, TIId5, TruckId, null);
	ti := self.getTrackedItem(TIId5);
	self.assertNotNull(ti);
	self.assertEqual(ti.myPrimaryActualLocation.ident, bs2.id);
	
	// Remain on Board
	
	locations.clear();
	bs1.allLocationsControllers.copy(locations);
	ya := self.addYA(YALength, YACriteriaType_ImexStatus, "ROB", YACriteriaType_CargoType, "CONT", null, null, locations, null);
	self.assertNotNull(ya);
	
	self.opts.purge();
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("ReturnTIs", true);
	self.addQuickCargo(voyage, null, 1, tiArray);
	
	ti := tiArray[1];
	self.assertNotNull(ti);
	
	// colour code the discharge slots
	create slotsFrom transient;
	self.getJobSlotControllers(VoyageId, "01", DeckUnderDeck, 1, 1, 1, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageDischJob := self.addVoyageJob(voyage, CraneId, slotsFrom, true);
	assertTrue(voyageDischJob &lt;&gt; null);
	
	// load to job ops
	self.loadAllJobsToOps(voyage, true);
	
	self.opts.purge();
	self.opts.addAssoc("IMEXStatus", TI_IMEX_STATUS_REMAINONBOARD);
	self.updateTI(ti);
	self.autoplanDischargeItems(voyage, bs1, crane.CM_Crane);
	self.assertEqualMsg(ti.myPrimaryPlannedLocation.getID(), bs1.getID(), ti.id &amp; " is either not planned or is planned to the wrong location.  " &amp;
		"Planned to " &amp; ti.myPrimaryPlannedLocation.getID() &amp; " rather than " &amp; bs1.getID());

	self.assertEqual(ti.myPrimaryPlannedLocation.ident, bs1.id);	
	
	// Import Length Criertia
	
	locations.clear();
	bs2.allLocationsControllers.copy(locations);
	ya := self.addYA(YALength, YACriteriaType_ImexStatus, "IMP", YACriteriaType_CargoType, cargoType, YACriteriaType_CargoLength, "33", locations, null);
	self.assertNotNull(ya);
	self.opts.purge();
	self.opts.addAssoc("CargoLength", 33.00.Real);
	self.xGACProcessCargo(bs2, TI_IMEX_STATUS_IMPORT, CTId1, TruckId, cargoType);
	ti := self.getTrackedItemByCargoType(CTId1, cargoType.id);
	self.assertEqual(ti.myPrimaryActualLocation.ident, bs2.id);
	
	// Import Width Criertia
	
	locations.clear();
	bs1.allLocationsControllers.copy(locations);
	ya := self.addYA(YAWidth, YACriteriaType_ImexStatus, "IMP", YACriteriaType_CargoType, cargoType, YACriteriaType_CargoWidth, "22", locations, null);
	self.assertNotNull(ya);
	self.opts.purge();
	self.opts.addAssoc("CargoWidth", 22.00.Real);
	self.xGACProcessCargo(bs1, TI_IMEX_STATUS_IMPORT, CTId2, TruckId, cargoType);
	ti := self.getTrackedItemByCargoType(CTId2, cargoType.id);
	self.assertNotNull(ti);
	self.assertEqual(ti.myPrimaryActualLocation.ident, bs1.id);
	
	// Import Height Criertia
	
	locations.clear();
	bs2.allLocationsControllers.copy(locations);
	ya := self.addYA(YAHeight, YACriteriaType_ImexStatus, "IMP", YACriteriaType_CargoType, cargoType, YACriteriaType_CargoHeight, "11", locations, null);
	self.assertNotNull(ya);
	self.opts.purge();
	self.opts.addAssoc("CargoHeight", 11.00.Real);
	self.xGACProcessCargo(bs2, TI_IMEX_STATUS_IMPORT, CTId3, TruckId, cargoType);
	ti := self.getTrackedItemByCargoType(CTId3, cargoType.id);
	self.assertNotNull(ti);
	self.assertEqual(ti.myPrimaryActualLocation.ident, bs2.id);
	
	// Import Weight Flexi Criertia
	
	locations.clear();
	bs1.allLocationsControllers.copy(locations);
	self.opts.purge();
	ya := self.addYA(YAFlexiWeight, YACriteriaType_ImexStatus, "IMP", YACriteriaType_CargoType, cargoType, YACriteriaType_TotalWeight, "2000", locations, null);
	self.assertNotNull(ya);
	self.xGACProcessCargo(bs2, TI_IMEX_STATUS_IMPORT, CTId4, TruckId, cargoType);
	ti := self.getTrackedItemByCargoType(CTId4, cargoType.id);
	self.assertNotNull(ti);
	self.assertEqual(ti.myPrimaryActualLocation.ident, bs1.id);
	
		
epilog
	
	delete locations;
	delete tas;
	delete slotsFrom;
	delete tiArray;
	
	self.disableAllYA(false);

end;</source>
    </JadeMethod>
    <JadeMethod name="tOpenCloseYABlock" id="4751a091-1014-4682-8b68-b1e7158dd5cc">
        <source>tOpenCloseYABlock();
// cnwndl1
//17 July 2008	cnwdw1	
//
vars
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	yaBlock, proxyYABlock: CM_YABlock;
	oldEdition: Integer;
	ta: CM_GridArea;
begin
	deleteTerminalArea("UTSTRD");
	ta:= addStraddleStack("UTSTRD", 2, 2, 1);
	assertNotNullMsg(ta, "straddleStack");

	self.deleteYA("UT");
	
	create locations transient;
	locations.add(ta.allLocationsControllers.first.CM_YardController);
	ya := self.addYA1("UT", YACriteriaType_Clean, CM_YADataBoolean.VALUE_TRUE, locations);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Create failed");
	self.assertTrueMsg(ya.allYABlocksIn.size = 1, "Locations not created");
	
	yaBlock := ya.allYABlocksIn.first;
	
	proxyYABlock := app.createUpdateProxy(yaBlock).CM_YABlock;
	proxyYABlock.closeBlock();
	app.myTrxUA.trxUpdateYABlock(proxyYABlock, yaBlock, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "YABlock update failed "&amp;app.myPassport.getAllErrorsWarningsAsString());
	self.assertFalseMsg(yaBlock.isOpen(), "Block did not get closed");
	delete proxyYABlock;
	
	proxyYABlock := app.createUpdateProxy(yaBlock).CM_YABlock;
	proxyYABlock.openBlock();
	app.myTrxUA.trxUpdateYABlock(proxyYABlock, yaBlock, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "YABlock update failed "&amp;app.myPassport.getAllErrorsWarningsAsString());
	self.assertTrueMsg(yaBlock.isOpen(), "Block did not get opened");
	
epilog
	delete locations;
	delete proxyYABlock;
end;</source>
    </JadeMethod>
    <JadeMethod name="tSetYABlockMinMaxHeight" id="fb7ac9e1-7aa7-4222-92ae-c371f3f034ad">
        <source>tSetYABlockMinMaxHeight();
// cnwndl1
//17 July 2008	cnwdw1	
//
vars
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	yaBlock, proxyYABlock: CM_YABlock;
	oldEdition: Integer;
	ta: CM_GridArea;
begin
	deleteTerminalArea("UTSTRD");
	ta:= addStraddleStack("UTSTRD", 2, 2, 2);
	assertNotNullMsg(ta, "straddleStack");

	self.deleteYA("UT");
	
	create locations transient;
	locations.add(ta.allLocationsControllers.first.CM_YardController);
	ya := self.addYA1("UT", YACriteriaType_Clean, CM_YADataBoolean.VALUE_TRUE, locations);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Create failed");
	self.assertTrueMsg(ya.allYABlocksIn.size = 1, "Locations not created");
	
	yaBlock := ya.allYABlocksIn.first;
	
	proxyYABlock := app.createUpdateProxy(yaBlock).CM_YABlock;
	proxyYABlock.setMinMaxHeight(1, 20);
	app.myTrxUA.trxUpdateYABlock(proxyYABlock, yaBlock, app.myPassport);
	self.assertFalseMsg(app.myPassport.trxCompletedOK, "YABlock update succeeded");
	delete proxyYABlock;
	
	proxyYABlock := app.createUpdateProxy(yaBlock).CM_YABlock;
	proxyYABlock.setMinMaxHeight(2, 1);
	app.myTrxUA.trxUpdateYABlock(proxyYABlock, yaBlock, app.myPassport);
	self.assertFalseMsg(app.myPassport.trxCompletedOK, "YABlock update succeeded");
	delete proxyYABlock;

	proxyYABlock := app.createUpdateProxy(yaBlock).CM_YABlock;
	proxyYABlock.setMinMaxHeight(2, 2);
	
	oldEdition := yaBlock.edition;
	app.myTrxUA.trxUpdateYABlock(proxyYABlock, yaBlock, app.myPassport);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "YABlock update failed "&amp;app.myPassport.getAllErrorsWarningsAsString());
	self.assertEqualMsg(yaBlock.getMinHeight, 2, "Min height incorrect");
	self.assertEqualMsg(yaBlock.getMaxHeight, 2, "Max height incorrect");
	self.assertTrueMsg(yaBlock.edition &lt;&gt; oldEdition, "Edition not updated");
	
epilog
	delete locations;
	delete proxyYABlock;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTestCargoTypeContenstYA" id="0db25f72-e60c-405e-858c-183e8ea25a48">
        <source>tTestCargoTypeContenstYA();
/*

Purpose:			This UT make sure that the new YA Criteria Type 'Cargo Type for Contents' is working correctly

Parameters:			

Return Value:		

Date		Who		Reason
08/10/2025	navkc1 JIRA 36145 AAT | RotaBox ISO Type and New Attributes - Unit Test

*/
constants
	UTISOTYPE = 'UR0T';
	UTCONT = 'CONT';
	UTCTYPECONTENTS = 'UR0TA';
	UTPRODCONTENTS = 'UR0TAS';
	UTCONTID = 'UTCROTA-1';
	UTTRUCKID = 'UTROTATRUCK';
	UTRELROTA = 'DELROTA';
	UTYA = 'UTYAROTA';
vars
	cTypeContents,
	cTypeContainer			: CM_CargoType;
	product					: CM_Product;
	iso						: CM_ISOType;
	term 					: CM_Terminal;
	root					: CM_Root;
	vvr						: CM_VehicleVisitRecord;
	tiCont					: CM_TrackedItem;
	operator				: CM_Operator;
	release					: CM_BulkRelease;
	pxyReleaseMatchCrit 	: CM_ReleaseByTypeCriteria;
	pxyCriteria 			: CM_YACriteria;
	locations 				: CM_LCArray;
	ya						: CM_YardAllocation;
begin
	term := self.getMyTerminal();
	root := app.getMyRoot();
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	// Get Cargo Type Container
		cTypeContainer := self.getCargoType(UTCONT);
		self.assertNotNullMsg(cTypeContainer, "Failed to get Cargo Type Container");
	
	// Get ISO Type
		iso := self.addISOType(UTISOTYPE, "UT ROTA ISO TYPE", cTypeContainer, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, false, true, 1000);
	
	// Get Cargo Type for Contents
		self.opts.purge();
		self.opts.addAssoc('TrackAs', ProductType_Bulk);
		cTypeContents := self.addCargoType(UTCTYPECONTENTS, true);
	
	// Get Product
		self.opts.purge();
		product := self.addProduct(UTPRODCONTENTS, null, cTypeContents);
	
	// Get TI Container
		// Delete existing one
		tiCont := self.getTrackedItem(UTCONTID);
		self.deleteTrackedItem(tiCont, true);
	
	// Gate in Container
		self.deleteVehicle(UTTRUCKID);
		self.opts.purge();
		self.opts.addAssoc('CargoTypeForContents',cTypeContents);
		self.opts.addAssoc('SubTypeForContents', product);
		self.opts.addAssoc('WeightCargo', 1000);
		vvr := self.gateInContainer(UTTRUCKID, UTCONTID, UTISOTYPE, operator.code, null, self.getProfileSetting(UT_Profile.P_DGATE).asString);
	
	// Do stuff
		self.workVehicle(vvr);
		self.roadExit(vvr);
		
	// Check - Make sure Cargo Type for Content and Prodcut is set correctly for Rota Container
		tiCont := self.getTrackedItem(UTCONTID);
		self.assertNotNullMsg(tiCont, 'Failed to get the Rota Container');
	
	// Add Yard Allocation
		create locations transient;
		locations.add(tiCont.myPrimaryActualLocation);
		
		ya := self.addYA(UTYA, YACriteriaType_CargoTypeCont, cTypeContents, null, null, null, null, locations, null);
		self.assertNotNullMsg(ya, "Failed to create Yard allocation");
		beginTransaction;
			ya.setPriorityValue(999999);
		commitTransaction;
	// Get Release request
		self.deleteReleaseRequest(UTRELROTA);
		
		create pxyCriteria transient;
		create pxyReleaseMatchCrit transient;
		pxyCriteria.setProxy(CM_YATypeCargoTypeForContents.firstInstance(), cTypeContents.abbreviation, 'Cargo Type');
		pxyReleaseMatchCrit.allCriteria.add(pxyCriteria);
		
		self.opts.purge;
		self.opts.addAssoc("ISOType", "UR0T");
		self.opts.addAssoc("Operator", operator);
		self.opts.addAssoc("FullRelease", true);
		self.opts.addAssoc(ETRow_SetCriteria, pxyReleaseMatchCrit);
		
		release := self.addReleaseByTypeRequest(UTRELROTA, BR_TYPE_ROAD, cTypeContainer.id, iso.code);
		self.assertNotNullMsg(release, "Failed to create release request");
		
		app.testAutoplanReseveDetails(term, release.allReserveDetails.first().CM_ReserveSelection);
		self.assertEqualMsg(app.myYAAgent.myCurrentAllocation, ya, "Failed to get the matching YA");
	
epilog
	self.deleteISOType(UTISOTYPE);
	self.deleteCargoType(UTCTYPECONTENTS);
	self.deleteTrackedItem(tiCont, true);
	self.deleteReleaseRequest(UTRELROTA);
	delete locations;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTestDwellDayRange" id="e92f1686-ebdc-4f6d-9e88-38f3a23b25bf">
        <source>tTestDwellDayRange();

/*

Purpose:		test the Dwell Day Range Yard Allocation Criteria

Date			Who		Reason
20/10/2015		cnwmh5	Initial creation

*/

vars

	ya						: CM_YardAllocation;
	bs1						: CM_BlockStack;
	bs2						: CM_BlockStack;
	cont1					: CM_Container;
	cont2					: CM_Container;
	
	lcArray					: CM_LCArray;
	tiArray					: CM_TIArray;
	
	receivedDT				: TimeStamp;
	
begin

	self.disableAllYA(true);

	self.deleteTerminalArea("UTMDBS1");
	bs1 := self.addBlockStack("UTMDBS1", 50, null);
	self.assertNotNull(bs1);
	
	self.deleteTerminalArea("UTMDBS2");
	bs2 := self.addBlockStack("UTMDBS2", 50, null);
	self.assertNotNull(bs2);
		
	create lcArray transient;
	bs2.allLocationsControllers.copy(lcArray);
	
	self.deleteYA("UTMDHDWELLDR");
	ya := self.addYA("UTMDHDWELLDR", YACriteriaType_DwellDays, "1 - 4", YACriteriaType_ISO, 2200, 
		YACriteriaType_Commodity, "MT", lcArray, null);
	self.assertNotNull(ya);
	
	cont1 := self.getTrackedItem("UTMHDDR0001").CM_Container;
	if cont1 &lt;&gt; null then
		self.deleteTrackedItem(cont1, false);
	endif;

	cont2 := self.getTrackedItem("UTMHDDR0002").CM_Container;
	if cont2 &lt;&gt; null then
		self.deleteTrackedItem(cont2, false);
	endif;

	// cont1 will plan
	cont1 := self.addContainerAtLocation("UTMHDDR0001", app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString()],
		"2200", "MT", TI_IMEX_STATUS_IMPORT, bs1.allLocationsControllers.first);
	self.assertNotNull(cont1);
	
	receivedDT := cont1.receivedDT.addDays(-1);
	beginTransaction;
	cont1.setReceivedDT(receivedDT);
	commitTransaction;
	
	create tiArray transient;
	tiArray.add(cont1);
	
	self.autoplanTIs(tiArray);
	self.assertNotEqual(cont1.myPrimaryPlannedLocation, null);
	
	// cont2 wont plan
	cont2 := self.addContainerAtLocation("UTMHDDR0002", app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString()],
		"2200", "MT", TI_IMEX_STATUS_IMPORT, bs1.allLocationsControllers.first);
	self.assertNotNull(cont2);
	
	// change the received date to be a couple of days ago so falls in the 0-4 band
	receivedDT := cont2.receivedDT.addDays(-7);
	beginTransaction;
	cont2.setReceivedDT(receivedDT);
	commitTransaction;
	
	tiArray.clear();
	tiArray.add(cont2);
	
	self.autoplanTIs(tiArray);
	self.assertEqual(cont2.myPrimaryPlannedLocation, null);
	
epilog

	self.disableAllYA(false);

	delete lcArray;
	delete tiArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdYALocations" id="2715abcc-edc1-4336-96bc-7d609e2c8d24">
        <source>tUpdYALocations();
// cnwndl1
//17 July 2008	cnwdw1	
// Add extra location block to existing YA that has one location block, 
vars
	locationBlock1 : CM_LCArray;
	locationBlock2 : CM_LCArray;
	ya: CM_YardAllocation;
	operatorSet: CM_ObjectSet;
	oldEdition: Integer;
	ta: CM_GridArea;
	blocks: ObjectArray;
begin
	deleteTerminalArea("UTSTRD");
	ta:= addStraddleStack("UTSTRD", 4, 4, 1);
	assertNotNullMsg(ta, "straddleStack");

	self.deleteYA("UT");
	
	create locationBlock1 transient;
	// First Block
	locationBlock1.add(ta.allGridControllersByRowColumn[1, 1]);
	locationBlock1.add(ta.allGridControllersByRowColumn[2, 2]);
	
	create operatorSet transient;
	operatorSet.add(app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString]);
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, operatorSet, locationBlock1);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Create failed");
	assertEqualMsg(ya.allYABlocksIn.size, 1, "YABlocks should be 1");
	
	create blocks transient;
	// Second Block
	create locationBlock2 transient;
	locationBlock2.add(ta.allGridControllersByRowColumn[3, 1]);
	locationBlock2.add(ta.allGridControllersByRowColumn[4, 2]);
	blocks.add(locationBlock1);
	blocks.add(locationBlock2);
	
	self.updateYABlocks(ya, blocks);
	self.assertEqualMsg(ya.allYABlockGroupsIn.first.allYABlocksIn.size, 2, "trxUpdateYardAllocation failed");

epilog
	delete blocks;
	delete locationBlock1;
	delete locationBlock2;
	delete operatorSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateYABlockOrderIn" id="9c04afdc-1005-4df6-bf8e-82be20fe9dae">
        <source>tUpdateYABlockOrderIn();
// cnwndl1
//17 July 2008	cnwdw1	
//
vars
	locations : CM_LCArray;
	ya, proxyYA: CM_YardAllocation;
	operatorSet: CM_ObjectSet;
	blockOrder: CM_YABlockArray;
	oldEdition: Integer;
	ta: CM_GridArea;
begin
	deleteTerminalArea("UTSTRD");
	ta:= addStraddleStack("UTSTRD", 4, 4, 1);
	assertNotNullMsg(ta, "straddleStack");

	self.deleteYA("UT");
	
	create locations transient;
	
	// First Block
	locations.add(ta.allGridControllersByRowColumn[1, 1]);
	locations.add(ta.allGridControllersByRowColumn[2, 2]);
	// Second Block
	locations.add(ta.allGridControllersByRowColumn[3, 1]);
	locations.add(ta.allGridControllersByRowColumn[4, 2]);
	
	create operatorSet transient;
	operatorSet.add(app.myRoot.allOperators[self.getProfileSetting(UT_Profile.P_OPERATOR).asString]);
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, operatorSet, locations);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Create failed");
	assertEqualMsg(ya.allYABlocksIn.size, 2, "YABlocks should be 2");
	
	create blockOrder transient;
	blockOrder.add(ya.allYABlocksIn[2]);
	blockOrder.add(ya.allYABlocksIn[1]);
	
	proxyYA := app.createUpdateProxy(ya).CM_YardAllocation;
	
	oldEdition := ya.edition;
	app.myTrxUA.trxUpdateYABlockOrder(proxyYA, blockOrder, null, true, false, app.myPassport);  // IN Order
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "YABlockOrder update failed");
	self.assertTrueMsg(ya.allYABlocksIn[1] = blockOrder[1], "YA block order incorrect");
	self.assertTrueMsg(ya.allYABlocksIn[2] = blockOrder[2], "YA block order incorrect");
	self.assertTrueMsg(ya.allYABlockGroupsIn.first.allYABlocksIn[1] = blockOrder[1], "YA Group block order incorrect");
	self.assertTrueMsg(ya.allYABlockGroupsIn.first.allYABlocksIn[2] = blockOrder[2], "YA Group block order incorrect");
	self.assertTrueMsg(ya.edition &lt;&gt; oldEdition, "Edition not updated");

	
epilog
	delete locations;
	delete operatorSet;
	delete blockOrder;
	delete proxyYA;
end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateYABlockOrderWithGroups" id="30a4093e-428b-4f7d-8a8e-a9f4e57f708a">
        <source>tUpdateYABlockOrderWithGroups();
// cnwndl1
//20 January 2009	cnwdw1	
//
vars
	st: CM_StraddleStack;
	locations : CM_LCArray;
	pxyYA, ya: CM_YardAllocation;
	yaBlock, yaBlock1, yaBlock2, yaBlock3  : CM_YABlock;
	yaBlocksIn, yaBlocksOut: CM_YABlockArray;
	group, groupsIn, groupsOut: CM_YABlockGroupArray;
	group1, group2: CM_YABlockGroup;
	updGroup1, updGroup2:CM_YABlockGroup;
	blockOrder: CM_YABlockArray;
	groupOrder: CM_YABlockGroupArray;
	criterias: CMIF_Array;
	oldEdition: Integer;
begin
	self.deleteYA("UT");
	self.deleteTerminalArea("UTSTD");
	st := self.addStraddleStack("UTSTD", 6, 5, 3);

	create yaBlocksIn transient;
	create yaBlocksOut transient;
	
	yaBlock1 := st.allGridControllersByRowColumn[1, 1].yaBuildBlock(true, null);
	yaBlock1.allYardControllers.add(st.allGridControllersByRowColumn[1, 1]);
	yaBlock1.allYardControllers.add(st.allGridControllersByRowColumn[1, 2]);
	yaBlock1.setProxyDeckingOptions();
	
	yaBlock2 := st.allGridControllersByRowColumn[2, 1].yaBuildBlock(true, null);
	yaBlock2.allYardControllers.add(st.allGridControllersByRowColumn[2, 1]);
	yaBlock2.allYardControllers.add(st.allGridControllersByRowColumn[2, 2]);
	yaBlock2.setProxyDeckingOptions();

	yaBlock3 := st.allGridControllersByRowColumn[3, 1].yaBuildBlock(true, null);
	yaBlock3.allYardControllers.add(st.allGridControllersByRowColumn[3, 1]);
	yaBlock3.allYardControllers.add(st.allGridControllersByRowColumn[3, 2]);
	yaBlock3.setProxyDeckingOptions();

	// Create the Groups
	// Group 1 
	//	In
	//    UTSTD 01-01 01-02
	//    UTSTD 02-02 01-02
	//  Out 
	//    UTSTD 02-02 01-02
	//    UTSTD 01-01 01-02
	// Group 2 
	//  In
	//    UTSTD 03-03 01-02
	//  Out
	//    UTSTD 03-03 01-02
	create group1 transient;  
	yaBlocksIn.clear;
	yaBlocksIn.add(yaBlock1);
	yaBlocksIn.add(yaBlock2);
	yaBlocksOut.clear;
	yaBlocksOut.add(yaBlock2);
	yaBlocksOut.add(yaBlock1);
	group1.setProxy("Group 1", yaBlocksIn, yaBlocksOut);

	create group2 transient;  
	yaBlocksIn.clear;
	yaBlocksIn.add(yaBlock3);
	yaBlocksOut.clear;
	yaBlocksOut.add(yaBlock3);
	group2.setProxy("Group 2", yaBlocksIn, yaBlocksOut);

	create groupsIn transient;
	groupsIn.add(group1);
	groupsIn.add(group2);
	create groupsOut transient;
	groupsOut.add(group2);
	groupsOut.add(group1);
	
	ya := self.addYA1WithGroups("UT", YACriteriaType_Clean, CM_YADataBoolean.VALUE_TRUE, groupsIn, groupsOut, YAFillOption_InOrder, YAFillOption_InOrder);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Create failed");
	self.assertTrueMsg(ya.allYABlockGroupsIn.size = 2, "Groups not created");
	self.assertTrueMsg(ya.allCriteria.size  = 1, "Criteria not created");
	self.assertTrueMsg(ya.allYABlocksIn.first.myDeckingOptions &lt;&gt; null, "Decking options are null");
	
	// Change the order in group 1 In
	// Group 1 
	//	In
	//    UTSTD 02-02 01-02
	//    UTSTD 01-01 01-02
	//  Out 
	//    UTSTD 02-02 01-02
	//    UTSTD 01-01 01-02
	// Group 2 
	//  In
	//    UTSTD 03-03 01-02
	//  Out
	//    UTSTD 03-03 01-02

	create blockOrder transient;
	blockOrder.add(ya.allYABlocksIn[2]);
	blockOrder.add(ya.allYABlocksIn[1]);
	blockOrder.add(ya.allYABlocksIn[3]);
	
	create updGroup1 transient;
	yaBlocksIn.clear;
	yaBlocksIn.add(ya.allYABlocksIn[2]);
	yaBlocksIn.add(ya.allYABlocksIn[1]);
	yaBlocksOut.clear;
	updGroup1.setProxy("Group 1", yaBlocksIn, yaBlocksOut);

	create updGroup2 transient;
	yaBlocksIn.clear;
	yaBlocksIn.add(ya.allYABlocksIn[3]);
	yaBlocksOut.clear;
	updGroup2.setProxy("Group 2", yaBlocksIn, yaBlocksOut);

	create groupOrder transient;
	groupOrder.add(updGroup2);
	groupOrder.add(updGroup1);
		
	pxyYA := app.createUpdateProxy(ya).CM_YardAllocation;
	oldEdition := ya.edition;
	app.myTrxUA.trxUpdateYABlockOrder(pxyYA, blockOrder, groupOrder, true, false, app.myPassport);  // IN Order
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "YABlockOrder update failed");
	self.assertTrueMsg(ya.allYABlocksIn[1] = blockOrder[1], "YA block order incorrect");
	self.assertTrueMsg(ya.allYABlocksIn[2] = blockOrder[2], "YA block order incorrect");
	self.assertTrueMsg(ya.allYABlocksIn[3] = blockOrder[3], "YA block order incorrect");
	self.assertTrueMsg(ya.allYABlockGroupsIn.first.allYABlocksIn[1] = blockOrder[3], "YA Group block order incorrect");
	self.assertTrueMsg(ya.allYABlockGroupsIn.last.allYABlocksIn[1] = blockOrder[1], "YA Group block order incorrect");
	self.assertTrueMsg(ya.allYABlockGroupsIn.last.allYABlocksIn[2] = blockOrder[2], "YA Group block order incorrect");
	self.assertTrueMsg(ya.edition &lt;&gt; oldEdition, "Edition not updated");
	
	delete pxyYA;
	// Move YABlock to new group
	// Group 1
	//	In
	//    UTSTD 03-03 01-02
	//    UTSTD 02-02 01-02
	//    UTSTD 01-01 01-02
	//  Out 
	//    UTSTD 03-03 01-02
	//    UTSTD 02-02 01-02
	//    UTSTD 01-01 01-02
	// Group 2 
	//  In
	//  Out
	blockOrder.clear();
	blockOrder.add(ya.allYABlocksIn[3]);
	blockOrder.add(ya.allYABlocksIn[2]);
	blockOrder.add(ya.allYABlocksIn[1]);
	
	yaBlocksIn.clear;
	yaBlocksIn.add(ya.allYABlocksIn[3]);
	yaBlocksIn.add(ya.allYABlocksIn[2]);
	yaBlocksIn.add(ya.allYABlocksIn[1]);
	yaBlocksOut.clear;
	yaBlocksOut.add(ya.allYABlocksIn[3]);
	yaBlocksOut.add(ya.allYABlocksIn[2]);
	yaBlocksOut.add(ya.allYABlocksIn[1]);
	updGroup1.setProxy("Group 1", yaBlocksIn, yaBlocksOut);

	yaBlocksIn.clear;
	yaBlocksOut.clear;
	updGroup2.setProxy("Group 2", yaBlocksIn, yaBlocksOut);

	groupOrder.clear();
	groupOrder.add(updGroup1);
	groupOrder.add(updGroup2);
		
	pxyYA := app.createUpdateProxy(ya).CM_YardAllocation;
	oldEdition := ya.edition;
	app.myTrxUA.trxUpdateYABlockOrder(pxyYA, blockOrder, groupOrder, true, true, app.myPassport);  // IN Order
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "YABlockOrder update failed");
	self.assertTrueMsg(ya.allYABlocksIn[1] = blockOrder[1], "YA block order incorrect");
	self.assertTrueMsg(ya.allYABlocksIn[2] = blockOrder[2], "YA block order incorrect");
	self.assertTrueMsg(ya.allYABlocksIn[3] = blockOrder[3], "YA block order incorrect");
	self.assertTrueMsg(ya.allYABlockGroupsIn.first.allYABlocksIn[1] = blockOrder[1], "YA Group block order incorrect");
	self.assertTrueMsg(ya.allYABlockGroupsIn.first.allYABlocksIn[2] = blockOrder[2], "YA Group block order incorrect");
	self.assertTrueMsg(ya.allYABlockGroupsIn.first.allYABlocksIn[3] = blockOrder[3], "YA Group block order incorrect");
	self.assertEqual(ya.allYABlockGroupsIn.last.allYABlocksIn.size, 0);
	self.assertEqual(ya.allYABlockGroupsIn.last.allYABlocksOut.size, 0);
	self.assertTrueMsg(ya.edition &lt;&gt; oldEdition, "Edition not updated");
	
epilog
	delete yaBlocksIn;
	delete yaBlocksOut;
	delete groupsIn;
	delete groupsOut;
	delete criterias;
	delete pxyYA;
	delete yaBlock;
	delete blockOrder;
	delete groupOrder;
	delete group;
	delete updGroup2;
	delete updGroup1;
end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateYAPriority" id="d4f19387-e80c-4963-955f-1b7401315286">
        <source>tUpdateYAPriority();
// cnwndl1
//17 July 2008	cnwdw1	
//
vars
	locations : CM_LCArray;
	ya: CM_YardAllocation;
	ta: CM_GridArea;
begin
	deleteTerminalArea("UTSTRD");
	ta:= addStraddleStack("UTSTRD", 2, 2, 1);
	assertNotNullMsg(ta, "straddleStack");

	self.deleteYA("UT");
	
	create locations transient;
	locations.add(ta.allLocationsControllers.first.CM_YardController);
	ya := self.addYA1("UT", YACriteriaType_Clean, CM_YADataBoolean.VALUE_TRUE, locations);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Create failed");
	self.assertTrueMsg(ya.allYABlocksIn.size = 1, "Locations not created");
	self.assertTrueMsg(ya.allCriteria.size  = 1, "Criteria not created");
	self.assertTrueMsg(ya.allYABlocksIn.first.myDeckingOptions &lt;&gt; null, "Decking options are null");
	
	updateYAPriority(ya, 99999);
	assertEqual(ya.priorityAdjustment, 99999);
epilog
	delete locations;
end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateYAWithGroups" id="185b7515-6828-46e6-902e-82018c662967">
        <source>tUpdateYAWithGroups();
// cnwndl1
//20 January 2009	cnwdw1	
//
vars
	st: CM_StraddleStack;
	locations : CM_LCArray;
	pxyYA, ya: CM_YardAllocation;
	yaBlock, yaBlock1, yaBlock2, yaBlock3  : CM_YABlock;
	yaBlocksIn, yaBlocksOut: CM_YABlockArray;
	groupsIn, groupsOut: CM_YABlockGroupArray;
	group1, group2: CM_YABlockGroup;
	criterias: CMIF_Array;
	yaBlockGroup, pxyYABlockGroup: CM_YABlockGroup;
begin
	self.deleteYA("UT");
	self.deleteTerminalArea("UTSTD");
	st := self.addStraddleStack("UTSTD", 6, 5, 3);

	create yaBlocksIn transient;
	create yaBlocksOut transient;
	
	yaBlock1 := st.allGridControllersByRowColumn[1, 1].yaBuildBlock(true, null);
	yaBlock1.allYardControllers.add(st.allGridControllersByRowColumn[1, 1]);
	yaBlock1.allYardControllers.add(st.allGridControllersByRowColumn[1, 2]);
	yaBlock1.setProxyDeckingOptions();
	
	yaBlock2 := st.allGridControllersByRowColumn[2, 1].yaBuildBlock(true, null);
	yaBlock2.allYardControllers.add(st.allGridControllersByRowColumn[2, 1]);
	yaBlock2.allYardControllers.add(st.allGridControllersByRowColumn[2, 2]);
	yaBlock2.setProxyDeckingOptions();

	yaBlock3 := st.allGridControllersByRowColumn[3, 1].yaBuildBlock(true, null);
	yaBlock3.allYardControllers.add(st.allGridControllersByRowColumn[3, 1]);
	yaBlock3.allYardControllers.add(st.allGridControllersByRowColumn[3, 2]);
	yaBlock3.setProxyDeckingOptions();

	// Create the Groups
	// Group 1 
	//	In
	//    UTSTD 01-01 01-02
	//    UTSTD 02-02 01-02
	//  Out 
	//    UTSTD 02-02 01-02
	//    UTSTD 01-01 01-02
	// Group 2 
	//  In
	//    UTSTD 03-03 01-02
	//  Out
	//    UTSTD 03-03 01-02
	create group1 transient;  
	yaBlocksIn.clear;
	yaBlocksIn.add(yaBlock1);
	yaBlocksIn.add(yaBlock2);
	yaBlocksOut.clear;
	yaBlocksOut.add(yaBlock2);
	yaBlocksOut.add(yaBlock1);
	group1.setProxy("Group 1", yaBlocksIn, yaBlocksOut);

	create group2 transient;  
	yaBlocksIn.clear;
	yaBlocksIn.add(yaBlock3);
	yaBlocksOut.clear;
	yaBlocksOut.add(yaBlock3);
	group2.setProxy("Group 2", yaBlocksIn, yaBlocksOut);

	create groupsIn transient;
	groupsIn.add(group1);
	groupsIn.add(group2);
	create groupsOut transient;
	groupsOut.add(group2);
	groupsOut.add(group1);
	
	ya := self.addYA1WithGroups("UT", YACriteriaType_Clean, CM_YADataBoolean.VALUE_TRUE, groupsIn, groupsOut, YAFillOption_InOrder, YAFillOption_InOrder);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Create failed");
	self.assertTrueMsg(ya.allYABlockGroupsIn.size = 2, "Groups not created");
	self.assertTrueMsg(ya.allCriteria.size  = 1, "Criteria not created");
	self.assertTrueMsg(ya.allYABlocksIn.first.myDeckingOptions &lt;&gt; null, "Decking options are null");
	
	pxyYA := app.createUpdateProxy(ya).CM_YardAllocation;
		// Create the Groups
	// Group 1 
	//	In
	//    UTSTD 01-01 01-02
	//  Out 
	//    UTSTD 01-01 01-02
	// Group 2 
	//  In
	//    UTSTD 03-03 01-02
	//  Out
	//    UTSTD 03-03 01-02

	yaBlock := pxyYA.allYABlockGroupsIn.first.allYABlocksIn.removeAt(2);
	pxyYA.allYABlocksIn.remove(yaBlock);
	yaBlock := pxyYA.allYABlockGroupsIn.first.allYABlocksOut.removeAt(1);
	pxyYA.allYABlocksOut.remove(yaBlock);
	
	create criterias transient;
	app.myTrxUA.trxUpdateYardAllocation(pxyYA, criterias, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(pxyYA.allYABlockGroupsIn.first.allYABlocksIn.size, 1);
	self.assertEqual(pxyYA.allYABlockGroupsIn.first.allYABlocksOut.size, 1);
	self.assertTrueMsg(ya.allCriteria.size  = 1, "Criteria not created");
	
	delete pxyYA;
	
	// Change the Group Name to group name already used
	yaBlockGroup := ya.allYABlockGroupsIn.first;
	pxyYA := app.createUpdateProxy(ya).CM_YardAllocation;
	pxyYABlockGroup := pxyYA.allYABlockGroupsIn.first;
	pxyYABlockGroup.setDescription("Group 2");
	self.expectTrxError(ERR_INVALID_YA_GROUP);
	app.myTrxUA.trxUpdateYABlockGroup(pxyYABlockGroup, yaBlockGroup, app.myPassport);
	assertNoTrxErrorsOrWarnings();
	
	delete pxyYA;
	// Change the Group Name
	yaBlockGroup := ya.allYABlockGroupsIn.first;
	pxyYA := app.createUpdateProxy(ya).CM_YardAllocation;
	pxyYABlockGroup := pxyYA.allYABlockGroupsIn.first;
	pxyYABlockGroup.setDescription("New Group");
	app.myTrxUA.trxUpdateYABlockGroup(pxyYABlockGroup, yaBlockGroup, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(yaBlockGroup.description, "New Group");
	self.assertEqual(yaBlockGroup.allYABlocksIn.size, 1);
	self.assertEqual(yaBlockGroup.allYABlocksOut.size, 1);
	
epilog
	delete yaBlocksIn;
	delete yaBlocksOut;
	delete groupsIn;
	delete groupsOut;
	delete criterias;
	delete pxyYA;
	delete yaBlock;
end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdateYAWithNewGroup" id="c7011c3c-e20b-45f3-a160-96b0baffec6f">
        <source>tUpdateYAWithNewGroup();
// cnwndl1
//27 January 2009	cnwdw1	
//
vars
	st: CM_StraddleStack;
	locations : CM_LCArray;
	pxyYA, ya: CM_YardAllocation;
	yaBlock, yaBlock1, yaBlock2, yaBlock3  : CM_YABlock;
	yaBlocksIn, yaBlocksOut: CM_YABlockArray;
	groupsIn, groupsOut: CM_YABlockGroupArray;
	group1, group2, group3: CM_YABlockGroup;
	criterias: CMIF_Array;
	yaBlockGroup, pxyYABlockGroup: CM_YABlockGroup;
begin
	self.deleteYA("UT");
	self.deleteTerminalArea("UTSTD");
	st := self.addStraddleStack("UTSTD", 6, 5, 3);

	create yaBlocksIn transient;
	create yaBlocksOut transient;
	
	yaBlock1 := st.allGridControllersByRowColumn[1, 1].yaBuildBlock(true, null);
	yaBlock1.allYardControllers.add(st.allGridControllersByRowColumn[1, 1]);
	yaBlock1.allYardControllers.add(st.allGridControllersByRowColumn[1, 2]);
	yaBlock1.setProxyDeckingOptions();
	
	yaBlock2 := st.allGridControllersByRowColumn[2, 1].yaBuildBlock(true, null);
	yaBlock2.allYardControllers.add(st.allGridControllersByRowColumn[2, 1]);
	yaBlock2.allYardControllers.add(st.allGridControllersByRowColumn[2, 2]);
	yaBlock2.setProxyDeckingOptions();

	yaBlock3 := st.allGridControllersByRowColumn[3, 1].yaBuildBlock(true, null);
	yaBlock3.allYardControllers.add(st.allGridControllersByRowColumn[3, 1]);
	yaBlock3.allYardControllers.add(st.allGridControllersByRowColumn[3, 2]);
	yaBlock3.setProxyDeckingOptions();

	// Create the Groups
	// Group 1 
	//	In
	//    UTSTD 01-01 01-02
	//    UTSTD 02-02 01-02
	//  Out 
	//    UTSTD 02-02 01-02
	//    UTSTD 01-01 01-02
	// Group 2 
	//  In
	//    UTSTD 03-03 01-02
	//  Out
	//    UTSTD 03-03 01-02
	create group1 transient;  
	yaBlocksIn.clear;
	yaBlocksIn.add(yaBlock1);
	yaBlocksIn.add(yaBlock2);
	yaBlocksOut.clear;
	yaBlocksOut.add(yaBlock2);
	yaBlocksOut.add(yaBlock1);
	group1.setProxy("Group 1", yaBlocksIn, yaBlocksOut);

	create group2 transient;  
	yaBlocksIn.clear;
	yaBlocksIn.add(yaBlock3);
	yaBlocksOut.clear;
	yaBlocksOut.add(yaBlock3);
	group2.setProxy("Group 2", yaBlocksIn, yaBlocksOut);

	create groupsIn transient;
	groupsIn.add(group1);
	groupsIn.add(group2);
	create groupsOut transient;
	groupsOut.add(group2);
	groupsOut.add(group1);
	
	ya := self.addYA1WithGroups("UT", YACriteriaType_Clean, CM_YADataBoolean.VALUE_TRUE, groupsIn, groupsOut, YAFillOption_InOrder, YAFillOption_InOrder);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Create failed");
	self.assertTrueMsg(ya.allYABlockGroupsIn.size = 2, "Groups not created");
	self.assertTrueMsg(ya.allCriteria.size  = 1, "Criteria not created");
	self.assertTrueMsg(ya.allYABlocksIn.first.myDeckingOptions &lt;&gt; null, "Decking options are null");
	
	pxyYA := app.createUpdateProxy(ya).CM_YardAllocation;
	// Add Group 3
	create group3 transient;  
	yaBlocksIn.clear;
	yaBlocksOut.clear;
	group3.setProxy("Group 3", yaBlocksIn, yaBlocksOut);
	
	pxyYA.allYABlockGroupsIn.add(group3);
	pxyYA.allYABlockGroupsOut.add(group3);
	
	create criterias transient;
	app.myTrxUA.trxUpdateYardAllocation(pxyYA, criterias, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(pxyYA.allYABlockGroupsIn.size, 3);
	self.assertEqual(pxyYA.allYABlockGroupsOut.size, 3);
	self.assertTrueMsg(ya.allCriteria.size  = 1, "Criteria not created");
	
epilog
	delete yaBlocksIn;
	delete yaBlocksOut;
	delete groupsIn;
	delete groupsOut;
	delete criterias;
	delete pxyYA;
	delete yaBlock;
end;</source>
    </JadeMethod>
    <JadeMethod name="tVGMYardAllocation" id="c2a367fd-2a2b-4f3e-8330-640026dedf63">
        <source>tVGMYardAllocation();
/*

Purpose:			TFS 1949

Date		Who		Reason
17/06/2016	cnwmk3	Initial creation
29/06/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
*/
constants
	ToDoTaskCode					= "VGMTODO";
	VoyCode							= "VGM_VOY";
	VesselCode						= "DIAM";
vars
	toDoTaskDesc                    : CM_ToDoTaskDesc;
	config							: CM_ToDoTaskDesc;
	locations, locations1			: CM_LCArray;
	ya								: CM_YardAllocation;
	ta, ta1							: CM_GridArea;
	vvr								: CM_VehicleVisitRecord;
	ti								: CM_TrackedItem;
	tiTapArray						: CM_TIArray;
	expectedLocArray				: CM_LCArray;
	voyage							: CM_Voyage;
	tiSet							: CM_TISet;
	controller						: CMIF_TIUpdateController;
	trxn							: CM_TITransaction;
begin
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[ToDoTaskCode];
	 if toDoTaskDesc &lt;&gt; null then
	    self.deleteToDoTaskDescription(toDoTaskDesc);
	 endif;
     
	 // create a ToDo task
	 toDoTaskDesc := self.createToDoTaskDesc(ToDoTaskCode);
	 self.assertNotNullMsg(toDoTaskDesc, "Add To Do Task failed");
	 
	 // Check that the new Terminal Config option "To Do Task To Remove When VGM Applied" on the VGM tab can be set and unset
	 self.setTerminalConfig("ToDoTaskRemoveVGM", toDoTaskDesc);
	 config := self.getTerminalConfig("ToDoTaskRemoveVGM").CM_ToDoTaskDesc;
	 self.assertEqual(config.code, toDoTaskDesc.code);
	 
	 // Check that "Is Weight Certified" is available as a Yard Allocation criteria with option Yes / No / N/A.
	 //Create a Yard Allocation for Export Containers with Is Weight Certified = No. 
	 self.disableAllYA(true);
	 self.deleteYA("UT_VGM1");
	
	deleteTerminalArea("VGMTA");
	ta:= addStraddleStack("VGMTA", 2, 2, 1);
	assertNotNullMsg(ta, "straddleStack not created");
	
	create locations transient;
	locations.add(ta.allLocationsControllers.first.CM_YardController);
	ya := self.addYA("UT_VGM1", YACriteriaType_ImexStatus, app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT], YACriteriaType_IsWeightCert, CM_YADataBoolean.VALUE_FALSE, null, null, locations, null);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Create failed");
	self.assertTrueMsg(ya.allYABlocksIn.size = 1, "Locations not created");
	self.assertTrueMsg(ya.allCriteria.size  = 2, "Criteria not created");
	
	// Create a Yard Allocation for Export Containers with Is Weight Certified = Yes.
	 self.deleteYA("UT_VGM2");
	
	deleteTerminalArea("VGMT1");
	ta1:= addStraddleStack("VGMT1", 2, 2, 1);
	assertNotNullMsg(ta1, "straddleStack not created");
	
	create locations1 transient;
	locations1.add(ta1.allLocationsControllers.first.CM_YardController);
	ya := self.addYA("UT_VGM2", YACriteriaType_ImexStatus, app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT], YACriteriaType_IsWeightCert, CM_YADataBoolean.VALUE_TRUE, null, null, locations1, null);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Create failed");
	self.assertTrueMsg(ya.allYABlocksIn.size = 1, "Locations not created");
	self.assertTrueMsg(ya.allCriteria.size  = 2, "Criteria not created");
	
	// Gate in a container without VGM details - it should autoplan to the Is Weight Certified = "no" yard allocation created above.
	self.deleteContainer("UTVGM00001");
	self.deleteVehicle("UT_VGM");
	self.deleteVoyage(VoyCode);
	voyage := self.addVoyageWithContainerStructur(VoyCode, VesselCode, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.opts.purge();
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_EXPORT);
	self.opts.addAssoc("Voyage", voyage.code);
	self.opts.addAssoc("DischargePort", app.myRoot.allPorts["NZAKL"].code);
	vvr := self.gateInContainer("UT_VGM", "UTVGM00001", "2200", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code, "APPL", 
		self.getProfileSetting(UT_Profile.P_SGATE).asString);
	 self.assertNotNull(vvr);
	 ti := self.getTrackedItem("UTVGM00001");
	
	assertEqual(vvr.myRoadJob.workListEntries.size, 1);
	assertEqual(vvr.myRoadJob.workListEntries.first.myTrackedItem, ti);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	self.assertNull(vvr.myRoadJob);
	self.assertEqual(vvr.status, CM_VehicleVisitRecord.Status_Complete);
	self.assertEqual(ti.locationId, "VGMTA 020002 1");
	
	
	// add ToDo task to cargo
	create tiSet transient;
	tiSet.add(ti);
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc[ToDoTaskCode];
	assertNotNull(toDoTaskDesc);
	self.addToDoTask(toDoTaskDesc, tiSet);
	self.assertEqual(ti.allToDoTasksToDo.size, 1);
	self.assertEqual(ti.allToDoTasksToDo.first.toDoTaskDesc, toDoTaskDesc);
	
	// update VGM details
	controller := app.createTIUpdateControl(TI_UPDMODE_NORMAL, app.getMyUserCode(), null);
	beginTransaction;
	ti.setIsWeightCertified(true, controller, app.myPassport);
	//ti.setWeightCertifiedName("TESTET1", controller, app.myPassport);				// TFS 4492
	//ti.setWeightCertifiedReference("TESTET1", controller, app.myPassport);		// TFS 4492
	ti.setMyVGMDetails(	"TESTET1", "TESTET1", null, null, null, null, null, 		// TFS 4492
						null, null, null, null, null, null, controller	);			// TFS 4492
	commitTransaction;
	
	// ToDo task should be removed after saving the VGM details
	ti := self.getTrackedItem("UTVGM00001");
	self.assertEqual(ti.allToDoTasksToDo.size, 0);
	
	// Gate in a container with VGM details - it should autoplan to the Is Weight Certified = "yes" yard allocation created above.
	self.deleteContainer("UTVGM00002");
	self.deleteVehicle("UT_VGM");
	
	self.opts.purge();
	self.opts.addAssoc("IMEX", TI_IMEX_STATUS_EXPORT);
	self.opts.addAssoc("Voyage", voyage.code);
	self.opts.addAssoc("DischargePort", app.myRoot.allPorts["NZAKL"].code);
	self.opts.addAssoc("IsWeightCertified", true);
	self.opts.addAssoc("WeightCertBy", "TESTER");
	self.opts.addAssoc("AuthorisedPerson", "TESTER");
	vvr := self.gateInContainer("UT_VGM", "UTVGM00002", "2200", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString).code, "APPL", 
		self.getProfileSetting(UT_Profile.P_SGATE).asString);
	 self.assertNotNull(vvr);
	 ti := self.getTrackedItem("UTVGM00002");
	
	assertEqual(vvr.myRoadJob.workListEntries.size, 1);
	assertEqual(vvr.myRoadJob.workListEntries.first.myTrackedItem, ti);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	self.assertNull(vvr.myRoadJob);
	self.assertEqual(vvr.status, CM_VehicleVisitRecord.Status_Complete);
	self.assertEqual(ti.locationId, "VGMT1 020002 1");
epilog
	self.disableAllYA(false);
	self.setTerminalConfig("ToDoTaskRemoveVGM", null);
	delete locations;
	delete locations1;
	delete tiSet;
	delete controller;
end;</source>
    </JadeMethod>
    <JadeMethod name="tVerifyDeliveryReq01" id="11b573a0-999b-4174-aab7-23d79807eabe">
        <source>tVerifyDeliveryReq01();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2022	navsks20 ChangeRequest 52721: PNL - Delivery Requests - Assign Cargo to Specified Release Request
*/

constants
	SubTerm			="UTSubTerm1";
	IsoType			= "2200";
vars
	 subTerminal  	: CM_SubTerminal;
	 terminalObj	: CM_Terminal;
	 t1,t2,t3,t4,t5 : CM_TrackedItem;
	 operator 		: CM_Operator;
	 releaseRequest : CM_BulkRelease;
	 blockStack			: CM_BlockStack;
	 gridArea			: CM_ForkLiftStack;
	 yardJob		: CM_YardInternalJob;
	 wle 			: CM_WorkListEntry;
	 location		: CM_LocationsController;
	 locations			: CM_LCArray;
	 ya					: CM_YardAllocation;
	sourceBays			: CM_GridObjectArray;
	deliveryRequest			: CM_YardDeliveryRequest;
	terminalAreas		: CM_TerminalAreaArray;
	tas					: StringArray;
	forkLift			: CM_Machine;
	queue				: CM_RadioTelemetryQueue;
	queueEntry			: CM_RTQueueEntry;
	reserveDetail : CM_ReserveDetail;
begin
	self.deleteContainer("TEST0000012");
	self.deleteContainer("TEST0000022");
	self.deleteContainer("TEST0000032");
	self.deleteContainer("TEST0000042");
	self.deleteContainer("TEST0000052");
	self.deleteReleaseRequest("UTRRRoad");
	self.deleteReleaseRequest("UTDRRoad");
	self.deleteSubTerminal(SubTerm);

	//Craete Block Stock
	gridArea := self.addForkLiftStack("GBS01", 4, 4, 2);
	self.assertNotNull(gridArea);
	
	blockStack := self.addBlockStack("BS01", 100, null);
	self.assertNotNull(blockStack);
	queue := self.addQueueToTA("GRIDQ", blockStack);
	
	//Create SubTerminal
	subTerminal := self.addSubTerminal(SubTerm,1);
	self.assertNotNull(subTerminal);
	
	//Setting Terminal config value
	beginTransaction;
	terminalObj := self.getTerminal();
	terminalObj.setConfig(DelReqAddToReleased,true);
	terminalObj.setConfig(DelReqAddToAssigned,true);
	terminalObj.setConfig(YardOpsDelReqTypes,DELIVERY_PACK_ROAD_STR);
	terminalObj.setConfig(DelReqChangeSubTerm,true);
	terminalObj.setConfig(DelReqAddToReleased,true);
	commitTransaction;
	
	//Checking Terminal Config
	self.assertEqual(terminalObj.getConfig(DelReqAddToReleased).Boolean,true);
	self.assertEqual(terminalObj.getConfig(DelReqAddToAssigned).Boolean,true);
	self.assertEqual(terminalObj.getConfig(YardOpsDelReqTypes).String,DELIVERY_PACK_ROAD_STR);
	self.assertEqual(terminalObj.getConfig(DelReqChangeSubTerm).Boolean,true);
	self.assertEqual(terminalObj.getConfig(DelReqAddToReleased).Boolean,true);
	
	create locations transient;
	locations.add(gridArea.allGridControllersByRowColumn[1, 1]);
	locations.add(gridArea.allGridControllersByRowColumn[1, 2]);
	
	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, locations);
	
	//Creating MT containers.
	operator := app.myRoot.allOperators["UTOP"];
	t1 :=self.addContainer("TEST0000012", operator,"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(t1, self.getGridLocation(gridArea, 1, 1));
	t2 :=self.addContainer("TEST0000022", operator,"2200", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(t2, self.getGridLocation(gridArea, 1, 2));
	//t3 :=self.addContainer("TEST0000032", operator,"2200", "MT", TI_IMEX_STATUS_STORAGE);
	//t4 :=self.addContainer("TEST0000042", operator,"2200", "MT", TI_IMEX_STATUS_STORAGE);
	//t5 :=self.addContainer("TEST0000052", operator,"2200", "MT", TI_IMEX_STATUS_STORAGE);
	
	//Create the Delivery Request
	self.opts.purge;
	self.opts.addAssoc("ISOGroup", "UT20");
	self.opts.addAssoc("CreateDeliveryRequest", true);
	self.opts.addAssoc("Number", 5);
	releaseRequest := self.addReleaseByTypeRequest("UTDRRoad", BR_TYPE_ROAD, TI_CargoType_Container,"2200");
	self.assertNotNull(releaseRequest);
	assertTrue(releaseRequest.requests.first.isKindOf(CM_DeliveryRequest));
	
	reserveDetail := releaseRequest.allReserveDetails.first;
	self.assertNotNull(reserveDetail);
	
	// Create Internal Move
	create sourceBays transient;
	create terminalAreas transient;
	terminalAreas.add(gridArea);
	self.opts.purge();
	self.opts.addAssoc("Release", releaseRequest);
	self.opts.addAssoc("ReserveDetail", reserveDetail);
	self.opts.addAssoc("SubTerminal", subTerminal);
	self.opts.addAssoc("IsAvail", true);
	deliveryRequest := self.moveDirector("UTJOB", 2, operator.code, "", terminalAreas, sourceBays, blockStack); 
	self.assertEqual(deliveryRequest.allWorkListEntries.first.allRTQueueEntries.first.allTasks.first.getSourceLocationId, "GBS01(0001)");
	
	// work the director task
	create tas transient;
	tas.add("GBS01");
	tas.add("BS01");
	
	self.addMachineRule (gridArea, blockStack, RTMoveMethod_24);
	forkLift := self.addForkLift("FL01", 85, tas, "GRIDQ");
	self.machineAssignToQueue(forkLift, queue);
	self.machineLogon(forkLift);

	queueEntry := deliveryRequest.allWorkListEntries.first.allRTQueueEntries[1];
		assertEqual(queueEntry.allTasks.size, 1);
	self.moveRTTask(queueEntry, queue);
	
	queueEntry := deliveryRequest.allWorkListEntries.first.allRTQueueEntries[2];
		assertEqual(queueEntry.allTasks.size, 1);
	self.moveRTTask(queueEntry, queue);
	
	queueEntry := deliveryRequest.allWorkListEntries.last.allRTQueueEntries[1];
		assertEqual(queueEntry.allTasks.size, 1);
	self.moveRTTask(queueEntry, queue);
	
	queueEntry := deliveryRequest.allWorkListEntries.last.allRTQueueEntries[2];
		assertEqual(queueEntry.allTasks.size, 1);
	self.moveRTTask(queueEntry, queue);
	
	self.machineAcceptSpecifiedTask(forkLift, queue.allEntries.first);		// director task completed
	assertEqual(queueEntry.allTasks.size, 1);
	self.machineDirector(forkLift, t1);
	self.assertEqual(forkLift.allCurrentWorkingQueueTasks.size, 1);
	self.machineSetdownTask(forkLift, forkLift.allCurrentWorkingQueueTasks.first , "BS01");
	
	self.machineAcceptSpecifiedTask(forkLift, queue.allEntries[2]);		// ti1 pickup/setdowneated
	self.machinePickup(forkLift);
	self.assertEqual(forkLift.allCurrentWorkingQueueTasks.size, 1);
	self.machineSetdownTask(forkLift, forkLift.allCurrentWorkingQueueTasks.first , "BS01");
	
	self.machineAcceptSpecifiedTask(forkLift, queue.allEntries[1]);		// director task completed
	self.machineDirector(forkLift, t2);
	self.assertEqual(forkLift.allCurrentWorkingQueueTasks.size, 1);
	self.machineSetdownTask(forkLift, forkLift.allCurrentWorkingQueueTasks.first, "BS01");
	
	self.machineAcceptSpecifiedTask(forkLift, queue.allEntries[2]);		// ti2 pickup/setdowneated
	self.machinePickup(forkLift);
	self.assertEqual(forkLift.allCurrentWorkingQueueTasks.size, 1);
	self.machineSetdownTask(forkLift, forkLift.allCurrentWorkingQueueTasks.first , "BS01");
	
	machineLogOff(forkLift);
	
	assertEqual(releaseRequest.allTrackedItemsReleased.size, 2);
epilog
	delete sourceBays;
	delete terminalAreas;
	delete locations;
	delete tas;
	self.disableAllYA(false);

end;</source>
    </JadeMethod>
    <JadeMethod name="tVerifyDeliveryReq02" id="5b6cb9f2-2941-4115-a54d-5796d6a212c3">
        <source>tVerifyDeliveryReq02();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 November 2022	navsks20 ChangeRequest 52721: PNL - Delivery Requests - Assign Cargo to Specified Release Request
*/

constants
	SubTerm1			="UTSubTerm1";
	SubTerm2			="UTSubTerm2";
	IsoType			= "2200";
	ContID1 = "DRUU2211151";
	ContID2 = "DRUU2211152";
	OpId = "UTDR";
vars
	subTermForDefault, subTermForUpdate  	: CM_SubTerminal;
	terminalObj	: CM_Terminal;
	t1,t2 : CM_TrackedItem;
	operator 		: CM_Operator;
	releaseRequest : CM_BulkRelease;
	sourceBS, targetBS			: CM_BlockStack;
	reserveDetail : CM_ReserveDetail;
	locations			: CM_LCArray;
	ya					: CM_YardAllocation;
	sourceBays			: CM_GridObjectArray;
	deliveryRequest			: CM_YardDeliveryRequest;
	terminalAreas		: CM_TerminalAreaArray;
	tas					: StringArray;
	forkLift			: CM_Machine;
	queue				: CM_RadioTelemetryQueue;
	queueEntry			: CM_RTQueueEntry;
	addToReleased, addToAssigned, changeSubTerm, isSubTermDefined, isSubTerminalsOn : Boolean;
	delReqTypes : String;
	defaultSubTerm : CM_SubTerminal;
begin
	//Setting Terminal config value
	addToReleased := self.setTerminalConfig(DelReqAddToReleased, true).Boolean;
	addToAssigned := self.setTerminalConfig(DelReqAddToAssigned, true).Boolean;
	delReqTypes := self.setTerminalConfig(YardOpsDelReqTypes, DELIVERY_PACK_ROAD_STR).String;
	changeSubTerm := self.setTerminalConfig(DelReqChangeSubTerm, true).Boolean;
	defaultSubTerm := self.getTerminal.getConfig(DelReqDefaultSubTerm).CM_SubTerminal;
	isSubTermDefined := self.setTerminalConfig(IsSubTerminalAreaDefined, true).Boolean;
	isSubTerminalsOn := self.setTerminalConfig(IsSubTerminalsOn, true).Boolean;
	
	//Checking Terminal Config
	terminalObj := self.getTerminal;
	self.assertEqual(terminalObj.getConfig(DelReqAddToReleased).Boolean,true);
	self.assertEqual(terminalObj.getConfig(DelReqAddToAssigned).Boolean,true);
	self.assertEqual(terminalObj.getConfig(YardOpsDelReqTypes).String,DELIVERY_PACK_ROAD_STR);
	self.assertEqual(terminalObj.getConfig(DelReqChangeSubTerm).Boolean,true);
	self.assertEqual(terminalObj.getConfig(IsSubTerminalAreaDefined).Boolean,true);
	self.assertEqual(terminalObj.getConfig(IsSubTerminalsOn).Boolean,true);
	
	self.deleteContainer(ContID1);
	self.deleteContainer(ContID2);
	self.deleteOperator(OpId);
	self.deleteReleaseRequest("UTDR01");
	self.deleteSubTerminal(SubTerm1);
	self.deleteSubTerminal(SubTerm2);

	//Create Block Stock
	sourceBS := self.addBlockStack("DR01", 100, null);
	self.assertNotNull(sourceBS);
	
	targetBS := self.addBlockStack("DR02", 100, null);
	self.assertNotNull(targetBS);
	
	queue := self.addQueueToTA("GRIDQ", targetBS);
	
	//Create SubTerminal
	subTermForDefault := self.addSubTerminal(SubTerm1,1);
	self.assertNotNull(subTermForDefault);
	subTermForUpdate := self.addSubTerminal(SubTerm2,1);
	self.assertNotNull(subTermForUpdate);
	// set subterminal terminal config
	self.setTerminalConfig(DelReqDefaultSubTerm, subTermForDefault);
	self.assertEqual(terminalObj.getConfig(DelReqDefaultSubTerm).CM_SubTerminal,subTermForDefault);
	
	create locations transient;
	locations.add(sourceBS.myLocationsController);

	operator := self.addOperatorSimple(OpId, "UT Delivery Request Op");
	self.assertNotNull(operator);
	
	self.deleteYA("DRYA");
	ya := self.addYA1("DRYA", YACriteriaType_OperatorItem, operator, locations);
	
	//Creating MT containers.
	t1 :=self.addContainer(ContID1, operator,"UT20", "MT", TI_IMEX_STATUS_STORAGE);
	self.assertTrueMsg(t1.mySubTerminal = null, "NEW Sub terminal has been set on " &amp; t1.id &amp; " This is wrong !!! " &amp; t1.mySubTerminal.String);
	
	self.move(t1, sourceBS.myLocationsController);
	t2 :=self.addContainer(ContID2, operator,"UT20", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(t2, sourceBS.myLocationsController);
	
	// Create the Release
	self.opts.purge;
	self.opts.addAssoc("ISOGroup", "UT20");
	self.opts.addAssoc("Number", 2);
	self.opts.addAssoc("Operator", operator);
	
	releaseRequest := self.addReleaseByTypeRequest("UTDR01", BR_TYPE_ROAD, TI_CargoType_Container,"UT20");
	self.assertNotNull(releaseRequest);
	
	reserveDetail := releaseRequest.allReserveDetails.first;
	self.assertNotNull(reserveDetail);
	
	// Create Internal Move
	create sourceBays transient;
	create terminalAreas transient;
	self.opts.purge();
	self.opts.addAssoc("Release", releaseRequest);
	self.opts.addAssoc("ReserveDetail", reserveDetail);
	
	self.opts.addAssoc("SubTerminal", subTermForUpdate);
	self.opts.addAssoc("IsAvail", true);
	deliveryRequest := self.moveDirector("UTJOB", 2, operator.code, "UT20", terminalAreas, sourceBays, targetBS); 
	self.assertEqual(deliveryRequest.allWorkListEntries.first.allRTQueueEntries.first.allTasks.first.getSourceLocationId, "DR01");
	self.assertTrueMsg(deliveryRequest.myUpdateSubTerminal = subTermForUpdate, "Sub terminal not set on yard delivery request");
	
	// work the director task
	create tas transient;
	tas.add("DR01");
	tas.add("DR02");
	
	self.addMachineRule (sourceBS, targetBS, RTMoveMethod_24);
	forkLift := self.addForkLift("FL01", 85, tas, "GRIDQ");
	self.machineAssignToQueue(forkLift, queue);
	self.machineLogon(forkLift);

	queueEntry := queue.allEntries.first;
	// ### ACCEPT FIRST DIRECTOR TASK
	self.machineAcceptSpecifiedTask(forkLift,queueEntry );
	assertEqual(queueEntry.allTasks.size, 1);
	
	// ### MOVE - PICKUP
	self.machineDirector(forkLift, t1);
	self.assertEqual(forkLift.allCurrentWorkingQueueTasks.size, 1);

	// ### CONFIGS ABOVE MEAN THE TI SHOULD NOW BE IN THE ASSIGNED COLLECTION ON THE RELEASE REQUEST
	self.assertTrueMsg(releaseRequest.allTrackedItemsAssigned.includes(t1),"After Pickup " &amp; t1.id &amp; " Should be assigned to release " &amp; releaseRequest.code);
	self.assertTrueMsg(releaseRequest.allTrackedItemsAssigned.size = 1,"After Pickup of " &amp; t1.id &amp; " Should be only 1 TI assigned to release " &amp; releaseRequest.code);
	
	// ### CONFIGS ABOVE MEAN THE TI SHOULD NOT HAVE THE SUB TERMINAL UPDATED UNTIL SETDOWN
	self.assertTrueMsg(t1.mySubTerminal = null, "Sub terminal has been set on " &amp; t1.id &amp; " This is wrong !!! " &amp; t1.mySubTerminal.String);

	// ### MOVE - SETDOWN
	self.machineSetdownTask(forkLift, forkLift.allCurrentWorkingQueueTasks.first , targetBS.id);
	// ### CONFIGS ABOVE MEAN THE TI SHOULD NOW BE IN THE RELEASED COLLECTION ON THE RELEASE REQUEST
	self.assertTrueMsg(releaseRequest.allTrackedItemsReleased.includes(t1),"After Setdown " &amp; t1.id &amp; " Should be released to release " &amp; releaseRequest.code);
	self.assertTrueMsg(releaseRequest.allTrackedItemsReleased.size = 1,"After Setdown of " &amp; t1.id &amp; " Should be only 1 TI released to release " &amp; releaseRequest.code);
	
	// ### CONFIGS ABOVE MEAN THE TI SHOULD NOT BE IN THE ASSIGNED COLLECTION ON THE RELEASE REQUEST
	self.assertTrueMsg(not releaseRequest.allTrackedItemsAssigned.includes(t1),"After Setdown " &amp; t1.id &amp; " Should not be assigned to release " &amp; releaseRequest.code);
	self.assertTrueMsg(releaseRequest.allTrackedItemsAssigned.size = 0,"After Setdown of " &amp; t1.id &amp; " Should be nothing assigned to release " &amp; releaseRequest.code);
	
	// ### CONFIGS ABOVE MEAN THE TI SHOULD HAVE THE SUB TERMINAL UPDATED
	self.assertTrueMsg(t1.mySubTerminal = subTermForUpdate, "Sub terminal not set correctly on " &amp; t1.id &amp; " !!!");
	
	
	queueEntry := queue.allEntries.first;
	// ### ACCEPT SECOND DIRECTOR TASK
	self.machineAcceptSpecifiedTask(forkLift,queueEntry );
	assertEqual(queueEntry.allTasks.size, 1);
	
	// ### MOVE - PICKUP
	self.machineDirector(forkLift, t2);
	self.assertEqual(forkLift.allCurrentWorkingQueueTasks.size, 1);
	
	// ### CONFIGS ABOVE MEAN THE TI SHOULD NOW BE IN THE ASSIGNED COLLECTION ON THE RELEASE REQUEST
	self.assertTrueMsg(releaseRequest.allTrackedItemsAssigned.includes(t2),"After Pickup " &amp; t2.id &amp; " Should be assigned to release " &amp; releaseRequest.code);
	self.assertTrueMsg(releaseRequest.allTrackedItemsAssigned.size = 1,"After Pickup of " &amp; t2.id &amp; " Should be only 1 TI assigned to release " &amp; releaseRequest.code);

	// ### MOVE - SETDOWN
	self.machineSetdownTask(forkLift, forkLift.allCurrentWorkingQueueTasks.first , targetBS.id);
	// ### CONFIGS ABOVE MEAN THE TI SHOULD NOW BE IN THE RELEASED COLLECTION ON THE RELEASE REQUEST
	self.assertTrueMsg(releaseRequest.allTrackedItemsReleased.includes(t2),"After Setdown " &amp; t2.id &amp; " Should be released to release " &amp; releaseRequest.code);
	self.assertTrueMsg(releaseRequest.allTrackedItemsReleased.size = 2,"After Setdown of " &amp; t2.id &amp; " Should be 2 TI released to release " &amp; releaseRequest.code);
	
	// ### CONFIGS ABOVE MEAN THE TI SHOULD NOT BE IN THE ASSIGNED COLLECTION ON THE RELEASE REQUEST
	self.assertTrueMsg(not releaseRequest.allTrackedItemsAssigned.includes(t2),"After Setdown " &amp; t2.id &amp; " Should not be assigned to release " &amp; releaseRequest.code);
	self.assertTrueMsg(releaseRequest.allTrackedItemsAssigned.size = 0,"After Setdown of " &amp; t1.id &amp; " Should be nothing assigned to release " &amp; releaseRequest.code);
	

	
	machineLogOff(forkLift);
epilog
	self.setTerminalConfig(DelReqAddToReleased, addToReleased);
	self.setTerminalConfig(DelReqAddToAssigned, addToAssigned);
	self.setTerminalConfig(YardOpsDelReqTypes, delReqTypes);
	self.setTerminalConfig(DelReqChangeSubTerm, changeSubTerm);
	self.setTerminalConfig(DelReqDefaultSubTerm, defaultSubTerm);
	self.setTerminalConfig(IsSubTerminalAreaDefined, isSubTermDefined);
	self.setTerminalConfig(IsSubTerminalsOn, isSubTerminalsOn);
	
	delete sourceBays;
	delete terminalAreas;
	delete locations;
	delete tas;
	self.disableAllYA(false);
end;</source>
    </JadeMethod>
    <JadeMethod name="tVerifyDeliveryReq03" id="ca1abd33-234e-4c6d-8614-8071c1dcd8d9">
        <source>tVerifyDeliveryReq03();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 November 2022	navhl20 ChangeRequest 52721: PNL - Delivery Requests - Assign Cargo to Specified Release Request
*/

constants
	SubTerm1			="UTSubTerm1";
	SubTerm2			="UTSubTerm2";
	IsoType			= "2200";
	ContID1 = "DRUU2211151";
	ContID2 = "DRUU2211152";
	OpId = "UTDR";
vars
	subTermForDefault, subTermForUpdate  	: CM_SubTerminal;
	terminalObj	: CM_Terminal;
	t1,t2 : CM_TrackedItem;
	operator 		: CM_Operator;
	releaseRequest : CM_BulkRelease;
	sourceBS, targetBS			: CM_BlockStack;
	reserveDetail : CM_ReserveDetail;
	locations			: CM_LCArray;
	ya					: CM_YardAllocation;
	sourceBays			: CM_GridObjectArray;
	deliveryRequest			: CM_YardDeliveryRequest;
	terminalAreas		: CM_TerminalAreaArray;
	tas					: StringArray;
	forkLift			: CM_Machine;
	queue				: CM_RadioTelemetryQueue;
	queueEntry			: CM_RTQueueEntry;
	tiSet : CM_TISet;
	toDoTaskDesc : CM_ToDoTaskDesc;
	addToReleased, addToAssigned, changeSubTerm, isSubTermDefined, isSubTerminalsOn : Boolean;
	delReqTypes : String;
	defaultSubTerm : CM_SubTerminal;
begin
	//Setting Terminal config value
	addToReleased := self.setTerminalConfig(DelReqAddToReleased, true).Boolean;
	addToAssigned := self.setTerminalConfig(DelReqAddToAssigned, true).Boolean;
	delReqTypes := self.setTerminalConfig(YardOpsDelReqTypes, DELIVERY_PACK_ROAD_STR).String;
	changeSubTerm := self.setTerminalConfig(DelReqChangeSubTerm, true).Boolean;
	defaultSubTerm := self.getTerminal.getConfig(DelReqDefaultSubTerm).CM_SubTerminal;
	isSubTermDefined := self.setTerminalConfig(IsSubTerminalAreaDefined, true).Boolean;
	isSubTerminalsOn := self.setTerminalConfig(IsSubTerminalsOn, true).Boolean;
	
	//Checking Terminal Config
	terminalObj := self.getTerminal;
	self.assertEqual(terminalObj.getConfig(DelReqAddToReleased).Boolean,true);
	self.assertEqual(terminalObj.getConfig(DelReqAddToAssigned).Boolean,true);
	self.assertEqual(terminalObj.getConfig(YardOpsDelReqTypes).String,DELIVERY_PACK_ROAD_STR);
	self.assertEqual(terminalObj.getConfig(DelReqChangeSubTerm).Boolean,true);
	self.assertEqual(terminalObj.getConfig(IsSubTerminalAreaDefined).Boolean,true);
	self.assertEqual(terminalObj.getConfig(IsSubTerminalsOn).Boolean,true);
	
	self.deleteContainer(ContID1);
	self.deleteContainer(ContID2);
	self.deleteOperator(OpId);
	self.deleteReleaseRequest("UTDR01");
	self.deleteSubTerminal(SubTerm1);
	self.deleteSubTerminal(SubTerm2);

	//Create Block Stock
	sourceBS := self.addBlockStack("DR01", 100, null);
	self.assertNotNull(sourceBS);
	
	targetBS := self.addBlockStack("DR02", 100, null);
	self.assertNotNull(targetBS);
	
	queue := self.addQueueToTA("GRIDQ", targetBS);
	
	//Create SubTerminal
	subTermForDefault := self.addSubTerminal(SubTerm1,1);
	self.assertNotNull(subTermForDefault);
	subTermForUpdate := self.addSubTerminal(SubTerm2,1);
	self.assertNotNull(subTermForUpdate);
	// set subterminal terminal config
	self.setTerminalConfig(DelReqDefaultSubTerm, subTermForDefault);
	self.assertEqual(terminalObj.getConfig(DelReqDefaultSubTerm).CM_SubTerminal,subTermForDefault);
	
	create locations transient;
	locations.add(sourceBS.myLocationsController);

	operator := self.addOperatorSimple(OpId, "UT Delivery Request Op");
	self.assertNotNull(operator);
	
	self.deleteYA("DRYA");
	ya := self.addYA1("DRYA", YACriteriaType_OperatorItem, operator, locations);
	
	//Creating MT containers.
	t1 :=self.addContainer(ContID1, operator,"UT20", "MT", TI_IMEX_STATUS_STORAGE);
	self.assertTrueMsg(t1.mySubTerminal = null, "NEW Sub terminal has been set on " &amp; t1.id &amp; " This is wrong !!! " &amp; t1.mySubTerminal.String);
	self.move(t1, sourceBS.myLocationsController);
	t2 :=self.addContainer(ContID2, operator,"UT20", "MT", TI_IMEX_STATUS_STORAGE);
	self.move(t2, sourceBS.myLocationsController);
	
	create tiSet transient;
	tiSet.add(t2);
	
	toDoTaskDesc := app.myRoot.allToDoTaskDescsByShortDesc["Dimension"];  
	self.addToDoTask(toDoTaskDesc, tiSet);
	assertEqual(t2.allToDoTasksToDo.size, 1);
	
	delete tiSet;
	
	// Create the Release
	self.opts.purge;
	self.opts.addAssoc("ISOGroup", "UT20");
	self.opts.addAssoc("Number", 2);
	self.opts.addAssoc("Operator", operator);
	releaseRequest := self.addReleaseByTypeRequest("UTDR01", BR_TYPE_ROAD, TI_CargoType_Container,"UT20");
	self.assertNotNull(releaseRequest);
	
	reserveDetail := releaseRequest.allReserveDetails.first;
	self.assertNotNull(reserveDetail);
	
	// Create Internal Move
	create sourceBays transient;
	create terminalAreas transient;
	self.opts.purge();
	self.opts.addAssoc("Release", releaseRequest);
	self.opts.addAssoc("ReserveDetail", reserveDetail);
	self.opts.addAssoc("SubTerminal", subTermForUpdate);
	self.opts.addAssoc("IsAvail", true);
	deliveryRequest := self.moveDirector("UTJOB", 2, operator.code, "UT20", terminalAreas, sourceBays, targetBS); 
	self.assertEqual(deliveryRequest.allWorkListEntries.first.allRTQueueEntries.first.allTasks.first.getSourceLocationId, "DR01");
	self.assertTrueMsg(deliveryRequest.myUpdateSubTerminal = subTermForUpdate, "Sub terminal not set on yard delivery request");
	
	// work the director task
	create tas transient;
	tas.add("DR01");
	tas.add("DR02");
	
	self.addMachineRule (sourceBS, targetBS, RTMoveMethod_24);
	forkLift := self.addForkLift("FL01", 85, tas, "GRIDQ");
	self.machineAssignToQueue(forkLift, queue);
	self.machineLogon(forkLift);

	queueEntry := queue.allEntries.first;
	// ### ACCEPT FIRST DIRECTOR TASK
	self.machineAcceptSpecifiedTask(forkLift,queueEntry );
	assertEqual(queueEntry.allTasks.size, 1);
	
	//Moving Ti without task
	// ### MOVE - PICKUP
	self.machineDirector(forkLift, t1);
	self.assertEqual(forkLift.allCurrentWorkingQueueTasks.size, 1);

	// ### CONFIGS ABOVE MEAN THE TI SHOULD NOW BE IN THE ASSIGNED COLLECTION ON THE RELEASE REQUEST
	self.assertTrueMsg(releaseRequest.allTrackedItemsAssigned.includes(t1),"After Pickup " &amp; t1.id &amp; " Should be assigned to release " &amp; releaseRequest.code);
	self.assertTrueMsg(releaseRequest.allTrackedItemsAssigned.size = 1,"After Pickup of " &amp; t1.id &amp; " Should be only 1 TI assigned to release " &amp; releaseRequest.code);
	
	// ### CONFIGS ABOVE MEAN THE TI SHOULD NOT HAVE THE SUB TERMINAL UPDATED UNTIL SETDOWN
	self.assertTrueMsg(t1.mySubTerminal = null, "Sub terminal has been set on " &amp; t1.id &amp; " This is wrong !!! " &amp; t1.mySubTerminal.String);

	// ### MOVE - SETDOWN
	self.machineSetdownTask(forkLift, forkLift.allCurrentWorkingQueueTasks.first , targetBS.id);
	// ### CONFIGS ABOVE MEAN THE TI SHOULD NOW BE IN THE RELEASED COLLECTION ON THE RELEASE REQUEST
	self.assertTrueMsg(releaseRequest.allTrackedItemsReleased.includes(t1),"After Setdown " &amp; t1.id &amp; " Should be released to release " &amp; releaseRequest.code);
	self.assertTrueMsg(releaseRequest.allTrackedItemsReleased.size = 1,"After Setdown of " &amp; t1.id &amp; " Should be only 1 TI released to release " &amp; releaseRequest.code);
	
	// ### CONFIGS ABOVE MEAN THE TI SHOULD NOT BE IN THE ASSIGNED COLLECTION ON THE RELEASE REQUEST
	self.assertTrueMsg(not releaseRequest.allTrackedItemsAssigned.includes(t1),"After Setdown " &amp; t1.id &amp; " Should not be assigned to release " &amp; releaseRequest.code);
	self.assertTrueMsg(releaseRequest.allTrackedItemsAssigned.size = 0,"After Setdown of " &amp; t1.id &amp; " Should be nothing assigned to release " &amp; releaseRequest.code);
	
	// ### CONFIGS ABOVE MEAN THE TI SHOULD HAVE THE SUB TERMINAL UPDATED
	self.assertTrueMsg(t1.mySubTerminal = subTermForUpdate, "Sub terminal not set correctly on " &amp; t1.id &amp; " !!!");
	
	
	queueEntry := queue.allEntries.first;
	// ### ACCEPT SECOND DIRECTOR TASK
	self.machineAcceptSpecifiedTask(forkLift,queueEntry );
	assertEqual(queueEntry.allTasks.size, 1);
	
	//Moving Ti with task
	// ### MOVE - PICKUP
	self.machineDirector(forkLift, t2);
	self.assertTrxErrorMsg(app.myPassport.allErrors.first.errorCode,"Container is not available for pickup");
	//self.assertEqual(forkLift.allCurrentWorkingQueueTasks.size, 1);
	machineLogOff(forkLift);
epilog
	self.setTerminalConfig(DelReqAddToReleased, addToReleased);
	self.setTerminalConfig(DelReqAddToAssigned, addToAssigned);
	self.setTerminalConfig(YardOpsDelReqTypes, delReqTypes);
	self.setTerminalConfig(DelReqChangeSubTerm, changeSubTerm);
	self.setTerminalConfig(DelReqDefaultSubTerm, defaultSubTerm);
	self.setTerminalConfig(IsSubTerminalAreaDefined, isSubTermDefined);
	self.setTerminalConfig(IsSubTerminalsOn, isSubTerminalsOn);
	
	delete sourceBays;
	delete terminalAreas;
	delete locations;
	delete tas;
	self.disableAllYA(false);
	delete tiSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="tVisitObjectsUntilTrue" id="27c0002a-5e5e-44c8-814b-7224a7ef7216">
        <source>tVisitObjectsUntilTrue();
// cnwndl1
//01 August 2008	cnwdw1	
// Test the visitObjecstUntilTrue method in CM_YADataObjects
vars
	dataObject: CM_YADataObjects;
	mtGrade1, mtGrade2: CM_MTGrade;
	ti: CM_Container;
	
	yaAuto: CMIF_YAAutoPlanNormal;
begin
	
	create dataObject transient;
	
	create mtGrade1 transient;
	mtGrade1.setProxy(1, "One",true, false, 0, null, null);
	dataObject.addAValue(mtGrade1);
	create mtGrade2 transient;
	mtGrade2.setProxy(2, "Two",true, false, 0, null, null);
	dataObject.addAValue(mtGrade2);
	
	create yaAuto transient;
	
	create ti transient;
	yaAuto.attachTI(ti);
	
	ti.setPropertyValue("availabilityGrade", 2);
	assertTrueMsg(yaAuto.isAvGrade_Match(dataObject), "Should return true");
	ti.setPropertyValue("availabilityGrade", 3);
	assertTrueMsg(not yaAuto.isAvGrade_Match(dataObject), "Should return false");
epilog
	delete mtGrade1;
	delete mtGrade2;
	delete yaAuto;
	delete ti;
	delete dataObject;
end;</source>
    </JadeMethod>
    <JadeMethod name="tYALocationDisplayString" id="cdc12dd0-86f6-4ac3-901c-3f04b5474793">
        <source>tYALocationDisplayString();
// cnwndl1
//10 September 2008	cnwdw1	
//
vars
	stradStack: CM_StraddleStack;
	locations: CM_LCArray;
	ya: CM_YardAllocation;
begin
	deleteTerminalArea("UTSTRD");
	stradStack := addStraddleStack("UTSTRD", 10, 5, 3);

	create locations transient;
	locations.add(stradStack.allGridControllersByName["020002"]);
	locations.add(stradStack.allGridControllersByName["040003"]);

	self.deleteYA("UT");
	ya := self.addYA1("UT", YACriteriaType_Clean, CM_YADataBoolean.VALUE_TRUE, locations);
	assertEqualMsg(ya.allYABlocksIn.size, 1, "allYABlocksIn wrong size");
	assertEqualMsg(ya.allYABlocksIn[1].getYAMLocationsString, "02-04 0002-0003", "incorrect locations string");

	
epilog
	delete locations;
end;</source>
