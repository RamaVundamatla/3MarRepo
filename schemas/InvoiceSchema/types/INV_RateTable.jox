    <JadeMethod name="doExtractCSVFile" id="d289017a-e3e5-420c-97ac-8e2dd7a0e50a">
        <source>doExtractCSVFile() : Boolean;
// July 2010 cnwjre1 par 25180 extract the selected debtors/services - code brought in-line from INV_RateTableCSVExtractForm
// 16/10/2012	cnwmh5	#30549 - Adjustment Of Base and Percentage Of Base to heading
// 07 May 2024	navnk30 Bug 64012: MTN - Rate Extract Column Name Change
// 10 Jan 2025  navrv30 JIRA 19179 and JIRA 33230 MTN - User can inadvertently fix debtor rates/expiry dates
//												  MTN - Export/Import of Rate table not as expected
vars
	obj : Object;
	dn : CM_DebtorNode;
	pd : CMS_Progress;
	fileName : String;
	file	: File;
	ls : Boolean;
	
begin
	
	fileName := app.getFilePath(null, '*.csv', fileName, false);
	
	if fileName = null then
		return false;
	else
		create file transient;
		file.fileName := fileName;
		file.mode := File.Mode_Output;
		
		if not file.tryOpen then
			app.msgBox(	"The extract file '" &amp; fileName &amp; "' is not available. Cannot open",
						"Extract Error",
						MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
				return false;
		endif;
	endif;
	
	on CM_ProgressException do haltProgress(exception, false, ls);

	create pd transient;
	pd.setBackground(self.backColor);
	pd.show();
	pd.progress.partsInJob	:=	self.getProgressCount();
	
	//10 Jan 2025 navrv30 JIRA 19179 and JIRA 33230
	file.writeLine('"Row Type","Debtor name","Debtor Code","Override flag","Service name","Effective Date","Effective time","Expiry Date","Expiry time","Rate Range Label","Cost per unit","GL code","Adjustment To Base","% of Base", "Updated/Derived Obj"'); //07.05.2024 navnk30 #64012
	
	foreach obj in self.allNonChildDebtors do
		dn := obj.CM_DebtorNode;
		self.doExtractForDebtor(dn, file, pd);
	endforeach;
	
	pd.progress.partsDone := pd.progress.partsInJob;
	pd.doWindowEvents(0);
	
	return true;
epilog
	delete pd;
	
	if file &lt;&gt; null then
		if file.isOpen() then
			file.close();
		endif;
		
		delete file;
	endif;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doExtractForDebtor" id="05e1a932-608a-4e4d-a7cd-da28900158eb">
        <source>doExtractForDebtor(_debtorNode : CM_DebtorNode input;
					_file : File input;
					_progress 	: CMS_Progress input);
// July 2010 cnwjre1 par 25180 extract the selected debtors/services - code brought in-line from INV_RateTableCSVExtractForm
vars
	obj		: Object;
	service : CM_Service;
	debtorNode : CM_DebtorNode;
	iter : Iterator;

begin

	// 25273 speed up extract by doing progress per debtor only, not debtor/service
	_progress.setAction(_debtorNode.name &amp; " - getting rates:");
	_progress.progress.partsDone := _progress.progress.partsDone  + 1;
	_progress.doWindowEvents(0);

	foreach obj in self.allSelectedServices do
		service := obj.CM_Service;
		self.doExtractForDebtorService(_debtorNode, service, _file, _progress);
	endforeach;
	
	// CCMS-1604 (Debtor groups) include children
	// 30204 but not from the root debtor to avoid double-extracting the children
	if _debtorNode.isRootDebtorGroup then
		return;
	endif;
	if (not _debtorNode.allChildDebtorNodes.isEmpty) then
		iter := _debtorNode.allChildDebtorNodes.createIterator;
		while iter.next(debtorNode) do	
			self.doExtractForDebtor(debtorNode, _file, _progress);
		endwhile;
	endif;
epilog
	delete iter;
end;</source>
        <Parameter name="_debtorNode" type="CM_DebtorNode" usage="input"/>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_progress" type="CMS_Progress" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doExtractForDebtorService" id="478bdba1-631a-4156-9b1b-9f00857d117d">
        <source>doExtractForDebtorService(	_debtorNode : CM_DebtorNode input;
							_service : CM_Service input;
							_file : File input;
							_progress 	: CMS_Progress input);
// July 2010 cnwjre1 par 25180 extract the selected debtors/services - code brought in-line from INV_RateTableCSVExtractForm
// 23582 add expiry date, ignore options
// 16/10/2012	cnwmh5	#30549 - Change costs per unit to pos 11 rather than 12	
// 10 Jan 2025  navrv30 JIRA 19179 and JIRA 33230 MTN - User can inadvertently fix debtor rates/expiry dates
//												  MTN - Export/Import of Rate table not as expected							
vars
	debtorCode			: String;
	debtorName			: String;
	derivedDebtorCode	: String;
	serviceName			: String;
	effectiveDate		: String;
	effectiveTime		: String;
	expiryDate			: String;
	expiryTime			: String;
	glCode				: String;
	rateEntry			: CM_RateEntry;
	ts					: TimeStamp;
	isOverRidingValue	: Boolean;
	extractLine			: CnStringArray;
	costPerUnitLabels	: StringArray;
	costPerUnitLabel	: String;
	i					: Integer;
	iter				: Iterator;
	debtorGroup			: String;
	objType 			: String;
	
	calculationType : CM_CalculationType;	//29 Jun 2018	NDL	TFS 39338
	calcType : Integer;	//29 Jun 2018	NDL	TFS 39338
	subTerm : CM_SubTerminal;	//29 Jun 2018	NDL	TFS 39338
	tidalClass : HMS_TidalClass;	//29 Jun 2018	NDL	TFS 39338
	
begin
	ts.setDate(self.effectiveDate);
	rateEntry	:=	_debtorNode.getServiceTimeRate(_service, ts);
		
	if rateEntry &lt;&gt; null then
	
		//29 Jun 2018	NDL	TFS 39338
		if _service &lt;&gt; null then
			calculationType := _service.myCalculationType;
			if calculationType&lt;&gt; null then
				calcType := calculationType.calculationType;
			endif;
		endif;
	
		if _debtorNode.isKindOf(CM_Debtor) then
			debtorCode			:=	_debtorNode.CM_Debtor.decfinName;
			derivedDebtorCode	:=	debtorCode;
			
			debtorGroup := 'D';
		else
			debtorGroup := 'G';
			
			if _debtorNode.myParentDebtorNode &lt;&gt; null then
				derivedDebtorCode	:=	_debtorNode.myParentDebtorNode.name;
			endif;
		endif;
		
		debtorName	:=	_debtorNode.name;
		
		isOverRidingValue	:=	rateEntry.rate.CM_DebtorRate.debtorNode = _debtorNode;
		serviceName			:=	_service.name.removeCrLfs();								// 17/10/2012 cnwmh5 #30549
		effectiveDate		:=	rateEntry.startTimestamp.date.String;
		effectiveTime		:=	rateEntry.startTimestamp.time.displayWithMilliSeconds__;  //10 Jan 2025 navrv30 JIRA 19179 and JIRA 33230
		expiryDate			:=	rateEntry.expiryTimestamp.date.String;
		expiryTime			:=	rateEntry.expiryTimestamp.time.displayWithMilliSeconds__; //10 Jan 2025 navrv30 JIRA 19179 and JIRA 33230
		
		if _service.genLCode &lt;&gt; null then
			glCode	:=	_service.genLCode.code.String;
		endif;

		create costPerUnitLabels transient;
		rateEntry.getCostPerUnitLabels(costPerUnitLabels);
		
		i		:=	1;
		iter	:=	costPerUnitLabels.createIterator();
		
		while iter.next(costPerUnitLabel) do	
			//epr par 11969 		
			create extractLine transient;
			extractLine[10]	:=	null;			
			extractLine[1]	:=	debtorGroup;	// debtorCode;		// change to be row type = D for Debtor, G for Group
			extractLine[2]	:=	debtorName;
			extractLine[3]	:=	derivedDebtorCode;
			extractLine[4]	:=	isOverRidingValue.getYesNo;
			extractLine[5]	:=	serviceName;
			extractLine[6]	:=	effectiveDate;
			extractLine[7]	:=	effectiveTime;
			extractLine[8]	:=	expiryDate;
			extractLine[9]	:=	expiryTime;
			
			if costPerUnitLabel = serviceName then
				extractLine[10]	:=	null;
			else
				extractLine[10]	:=	costPerUnitLabel;	// Non-null will indicate a multi-line rate.
			endif;
			
			if calcType = INV_CALC_TYPE_DAYSINCE_SUBTERM then	//29 Jun 2018	NDL	TFS 39338
				subTerm := self.myTerminal.allSubTerminals.getMatchingDesc( costPerUnitLabel );
				extractLine[11] :=	rateEntry.getCPUforObject( subTerm ).String;
				
			elseif calcType = INV_CALC_TYPE_TIDAL_CLASS then	//29 Jun 2018	NDL	TFS 39338
				tidalClass := app.myRoot.allTidalClasses.getMatchingDesc( costPerUnitLabel );
				extractLine[11] :=	rateEntry.getCPUforObject( tidalClass ).String;
				
			else
				if rateEntry.allCostPerUnits.size &lt; i then 
					extractLine[11]	:=	rateEntry.getRawCostPerUnit().String;                       //10 Jan 2025 navrv30 JIRA 19179 and JIRA 33230
				else
					extractLine[11]	:=	rateEntry.allCostPerUnits[i].String;						// 16/10/2012 cnwmh5 #30549
				endif;
			endif;
			
			extractLine[12]	:=	glCode;	
			//18 Sep 2012	NDL	Par 30375
			//extractLine[13]	:=	i.String;														// 16/10/2012 cnwmh5 #30549 removed as automatically generated on import
			extractLine[13]	:=	rateEntry.adjustmentToBase.Real.String;	
			extractLine[14]	:=	rateEntry.percentageOfBase.Real.String;	
			//10 Jan 2025 navrv30 JIRA 19179 and JIRA 33230
			if rateEntry.rate.CM_DebtorRate.debtorNode = _debtorNode then         
				objType	:=	'U';
			else 
				objType	:=	'D';
			endif;
			extractLine[15]	:= objType;
			
			_file.writeLine(extractLine.asCSV(true));	
			delete extractLine;
			i	:=	i + 1;
		endwhile;
		
		delete iter;			
	endif;
	
	// 25273 speed up extract by doing progress per debtor only, not debtor/service
epilog
	delete costPerUnitLabels;
	delete extractLine;
	delete iter;
end;</source>
        <Parameter name="_debtorNode" type="CM_DebtorNode" usage="input"/>
        <Parameter name="_service" type="CM_Service" usage="input"/>
        <Parameter name="_file" type="File" usage="input"/>
        <Parameter name="_progress" type="CMS_Progress" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doLoadCSVFile" id="9f9742af-4695-44d3-9324-95ee082dc1e3">
        <updating/>
        <source>doLoadCSVFile() updating, protected;
// --------------------------------------------------------------------------------
// Created:		11 December 2008 by cnwdad1
//
// Purpose:		Handles the loading of a CSV file.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
/* Changes

Date		Name	TFS#		Description
============================================================================
02/04/2024	jlika1	TFS 56073 56072 | MTN - Rate Table CSV Upload
============================================================================*/
vars
	fileObj			: File;
	fileName		: String;
	fileLine		: String;
	rowCount		: Integer;
	allRowFields	: HugeStringArray;
	allRowHeaders	: HugeStringArray;
	allFileRows		: ObjectArray;
	columnCount		: Integer;
	fieldCount		: Integer;
	pointer			: Integer;
	returnValue		: Integer;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	prof		    : JadeProfiler;
	startTM 		: Decimal[19,0];
begin
	app.myRoot.startJadeProfiler(prof,method.getNiceName() ,20,true,'MA',startTM);
	on FileException do self.xHandlerFile(exception);
	
	fileName	:=	self.cnEcBrowseForFile("CSV Files (*.csv)|*.csv");
	
	if fileName = null then
		return;
	endif;
	
	app.mousePointer	:= Busy;
	
	create fileObj transient;
	fileObj.fileName	:=	fileName;
	fileObj.close();
	fileObj.kind 		:= File.Kind_Unknown_Text; // 2/3/16  cnwns1 PAR 36286 unicode version
	fileObj.mode		:=	File.Mode_Input;
	fileObj.shareMode	:=	File.Share_Read;
	fileObj.endOfLine	:=	Lf;
	fileObj.open();
	
	create allFileRows transient;
	rowCount	:=	0;
	
	while not fileObj.endOfFile() do
		fileLine	:=	fileObj.readLine().trimBlanks();
		rowCount	:=	rowCount + 1;
		
		if rowCount = 1 then
			// Ignore the first line, this only contains headers
			// but from 23582 count the number of columns to see if this file was extracted before or after 23582 changes
			create allRowHeaders transient;
			fileLine.csvConvert(allRowHeaders, ",");
			columnCount := allRowHeaders.size;
			continue;
		elseif fileLine.isBlankRecordCSV() then
			// Also ignore blank lines.
			continue;
		endif;
		
		create allRowFields transient;
		fileLine.csvConvert(allRowFields, ",");		// cnwdad1 25/11/2009 - PAR #21720 Added delimiter parameter.
		allRowFields.add(rowCount.String);
		fieldCount	:=	allRowFields.size();
		
		// 23582 use the header column count + 1 (+ 1 for the added rowCount) instead of 11 below
		if fieldCount &lt; columnCount + 1 then
			// The last column can get lost.
			fieldCount	:=	columnCount + 1 - fieldCount;
			
			foreach pointer in 1 to fieldCount do
				allRowFields.add(null);
			endforeach;
		endif;
		
		allFileRows.add(allRowFields);
	endwhile;
	
	fileObj.close();
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateRateEntryCSV(self.myCurrentBank, allFileRows, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			break;
		else
			theResult := app.showErrorWarningDialog("Rate Entry", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
	
	app.msgBox(app.getErrorString(File_load_sucessful),app.getErrorString(Confirmation), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
	
epilog
	delete fileObj;
	delete allRowHeaders;
	
	if allFileRows &lt;&gt; null then
		allFileRows.purge();
		delete allFileRows;
	endif;
	app.mousePointer	:= Idle;
	app.myRoot.stopJadeProfiler(prof,startTM);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doMnuContextBuild" id="08390276-5489-4d77-bc10-b2263f544b6f">
        <source>doMnuContextBuild();
// ---------------------------------------------------------------------------
