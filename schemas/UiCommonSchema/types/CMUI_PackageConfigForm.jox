    <JadeMethod name="doDeleteHistory" id="95fd386a-4ac5-4609-9f7e-9c4b419536c0">
        <source>doDeleteHistory() protected;

// Created by cnwdvb1 on 30 June 2006

vars

	obj			: Object;
	result		: Integer;
	theResult : Integer;	//13 Jan 2020 NDL	TFS 46815
	
begin

	if self.tblHistory.allSelectedObjects.isEmpty() then
		app.msgBox(app.getErrorString(Please_Select_An_Item_Fiirst), self.caption, MsgBox_OK_Only+MsgBox_Stop_Icon);
		return;
	endif;
	
	result := app.msgBox('Do you wish to delete the selected history', self.caption,  MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
	if result &lt;&gt; MsgBox_Return_Yes then
		return;
	endif;

	app.mousePointer := Window.MousePointer_HourGlass;
	foreach obj in self.tblHistory.allSelectedObjects do
	
		//13 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxDA.trxDeleteCMObject(obj.CM_Object, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				break;
			else
				theResult := app.showErrorWarningDialog('Delete Package History', app.myPassport, ErrWarnMode_AddUpdate);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			return;
			
		endwhile;
		
	endforeach;
	
epilog
	app.mousePointer := Window.MousePointer_Default;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doFillExtractTypeCombo" id="37373968-a662-4a37-8bec-a2e1df25b88c">
        <source>doFillExtractTypeCombo(_cmb: ComboBox input) protected;
// ---------------------------------------------------------------------------
// Created:		24 June 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

	idx	: Integer;
begin
	_cmb.clear();
	
	idx := _cmb.addItem(CMUI_EDIDBExtract.EDIFILE_TYPE_ACTUAL_BAYPLAN);
	_cmb.itemData[idx] := ACTUAL_BAYPLANS;
	
	idx := _cmb.addItem(CMUI_EDIDBExtract.EDIFILE_TYPE_PROPOSED_BAYPLAN);
