    <JadeMethod name="getAllOverstows" id="e4bf23b1-7b65-4945-8c76-6507d81a9a0f">
        <updating/>
        <source>getAllOverstows() : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2018	jlger1	Initial creation tfs 37584

*/

vars
	sideOverstowNum : Integer;
begin
	self.getSideOverstow;
	sideOverstowNum:= self.allOverstowTIs.size;
	self.isSideOverstowed :=sideOverstowNum&gt; 0;
	self.getTopOverstow;
	if self.allOverstowTIs.size &gt; sideOverstowNum then
		self.isTopOverstowed:=true;
	endif;
	
	return self.allOverstowTIs.first &lt;&gt; null;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSideAccessRestrictingLCs" id="d8363226-0e17-4895-8be0-aebb75b0e45b">
        <source>getSideAccessRestrictingLCs(_allRestrictingLCs :  CM_LCSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 May 2018	jlger1	Initial creation tfs 37584

*/

vars
	backEndLocation,
	lc : CM_LocationsController;
	locations : CM_LCArray;
begin
	if 	self.accessDirection = CM_YABlock.SideAccess_NA then 
		return;
	endif;
	
	if self.myTI = null then
		if self.myCurrentLC &lt;&gt; null and self.myCurrentLC.isKindOf(CM_GridController) then
			self.myCurrentLC.CM_GridController.getSideAccessRestrictingLCs(self.accessDirection,_allRestrictingLCs);
		endif;
		return;
	endif;
	
	locations :=self.myTI.getLocationsArray(self.mode,0);
	if locations &lt;&gt; null then
		foreach lc in locations discreteLock do
			if not lc.isKindOf(CM_GridController) then
				continue;
			endif;
			lc.CM_GridController.getSideAccessRestrictingLCs(self.accessDirection,_allRestrictingLCs);
		endforeach;
	endif;
	
	backEndLocation :=self.myTI.getOSBackEndLocationForMode(self.mode);
	if backEndLocation &lt;&gt; null and backEndLocation.isKindOf(CM_GridController)  then
		backEndLocation.CM_GridController.getSideAccessRestrictingLCs(self.accessDirection,_allRestrictingLCs);
	endif;
epilog

end;</source>
        <Parameter name="_allRestrictingLCs" type="CM_LCSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSideOverstow" id="71193001-acec-4591-95d7-2d9eaea7871a">
        <updating/>
        <source>getSideOverstow()  updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2018	jlger1	Initial creation tfs 37584
 
*/

vars
	gridArea : CM_GridArea;
	bothDirections : Boolean;
	fromFront : CM_TIArray;
	yaBlock : CM_YABlock;
begin
	if self.myCurrentLC = null then
		self.accessDirection := CM_YABlock.SideAccess_NA;
		return;
	endif;
	
	if not self.isOverstowPossible then
		self.accessDirection := CM_YABlock.SideAccess_NA;
		return;
	endif;
	
	if not self.myCurrentLC.isKindOf(CM_GridController) then
		self.accessDirection := CM_YABlock.SideAccess_NA;
		return;
	endif;
	
	if not self.myCurrentLC.CM_GridController.myTerminalArea.CM_GridArea.useSideAccessRules then
		self.accessDirection := CM_YABlock.SideAccess_NA;
		return;
	endif;
	
	if self.accessDirection &lt;&gt; CM_YABlock.SideAccess_Back and 
		self.accessDirection &lt;&gt; CM_YABlock.SideAccess_Front then 
		//20 Mar 2012	NDL	Par 28122
		gridArea := self.myCurrentLC.CM_GridController.getMyGridArea;
		if gridArea.isForkliftStack then
			bothDirections := gridArea.CM_ForkLiftStack.accessBack and gridArea.CM_ForkLiftStack.accessFront;
		else
			bothDirections :=true;
		endif;
	
		if bothDirections then
			// Choose the side with the least number of boxes in the way.
			self.accessDirection:= CM_YABlock.SideAccess_Front;
			self.getSideOverstowForTI();
			if self.allOverstowTIs.isEmpty then
				return;
			else
				create fromFront transient;
				self.allOverstowTIs.copy(fromFront);
				
				self.accessDirection:= CM_YABlock.SideAccess_Back;
				self.getSideOverstowForTI();
				if self.allOverstowTIs.size &lt; fromFront.size then
					return;
				else
					 self.allOverstowTIs.clear;
					 fromFront.copy(self.allOverstowTIs);

					self.accessDirection := CM_YABlock.SideAccess_Front;
					return;
				endif;
			endif;
			
		else
		
			if gridArea.CM_ForkLiftStack.accessBack  then
				self.accessDirection:=CM_YABlock.SideAccess_Back;
			else				
				self.accessDirection:=CM_YABlock.SideAccess_Front;
			endif;
		endif;
		
	endif;
	
	self.getSideOverstowForTI();
	

epilog
	
	delete fromFront;
end;</source>
    </JadeMethod>
    <JadeMethod name="getSideOverstowForColumn" id="48634de2-ad99-4370-8ceb-0e0ba57228af">
        <updating/>
        <source>getSideOverstowForColumn(_gridLC : CM_GridController; _osBackend : Boolean) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2018	jlger1	Initial creation tfs 37584
17 Jun 2021	NDL TFS 51181 - If we are only checking the backend of the previous controller, like a 45 hanging over,
					it'll be ok if the grid controller has cargo in it as long as it doesn't start until the same distance in ( or more )

*/

vars
	gridArea : CM_GridArea;
	currentCol : Integer;
	currentGridCol	: CM_GridColumn;
	iter 		: Iterator;
	gridController : CM_GridController;
	canAccessFront,
	canAccessBack : Boolean;
	allTIsFront,
	allTIsBack	: CM_TIArray;
	rowsFromSelf : Integer;
	offSet : Integer;
	nextRowHeight : Integer;
begin

	if _gridLC = null then
		return;
	endif;
	
	gridArea := _gridLC.getMyGridArea;
	create allTIsFront transient;
	create allTIsBack transient;
		
	canAccessFront:=true;
	canAccessBack:=true;
	currentCol:=_gridLC.column;
	//17 Jun 2021	NDL	TFS 51181
	if _osBackend then
		offSet := _gridLC.offsetFlexi;
	endif;

	currentGridCol:=gridArea.allGridColumns[currentCol];
	iter:=currentGridCol.allControllersByRow.createIterator;
	currentGridCol.allControllersByRow.startKeyGeq(_gridLC.row,iter);
	if self.accessDirection = CM_YABlock.SideAccess_Front or 
		self.accessDirection = CM_YABlock.SideAccess_Both then
		rowsFromSelf:= 0;
		nextRowHeight:=_gridLC.allTrackedItems.size;
		//starts at the container we are moving
		while iter.next(gridController) do
			if gridController = _gridLC then
				continue;
			endif;
			rowsFromSelf:= rowsFromSelf + 1;
			if gridController.allTrackedItems.size  = 0 then
				continue;
			endif;
			//17 Jun 2021	NDL	TFS 51181
			if _osBackend and gridController.offsetFlexi &gt;= offSet then
				continue;
			endif;
			//jlier1 MTN-34637 22/5/25 - need to know the height of the next row
			self.getSideOverstowForLC(gridController,rowsFromSelf,nextRowHeight,allTIsFront);		
			nextRowHeight:=gridController.allTrackedItems.size;
		endwhile;
	endif;
	
	if self.accessDirection = CM_YABlock.SideAccess_Back or 
		self.accessDirection = CM_YABlock.SideAccess_Both then 
		rowsFromSelf:= 0;
		nextRowHeight:=_gridLC.allTrackedItems.size;
		while iter.back(gridController) do
			if gridController = _gridLC then
				continue;
			endif;
			rowsFromSelf:= rowsFromSelf + 1;
			
			if gridController.allTrackedItems.size  = 0 then
				continue;
			endif;
			//17 Jun 2021	NDL	TFS 51181
			if _osBackend and gridController.offsetFlexi &gt;= offSet then
				continue;
			endif;
			//jlier1 MTN-34637 22/5/25 - need to know the height of the next row
			self.getSideOverstowForLC(gridController,rowsFromSelf,nextRowHeight,allTIsBack);			
			nextRowHeight:=gridController.allTrackedItems.size;
		endwhile;
	endif;
	
	if 	self.accessDirection = CM_YABlock.SideAccess_Both then 	
		if allTIsFront.size &lt; allTIsBack.size then
			allTIsFront.copyNoDups(self.allOverstowTIs); //	PAR 34416
		else
			allTIsBack.copyNoDups(self.allOverstowTIs); //	PAR 34416
		endif;
	elseif self.accessDirection = CM_YABlock.SideAccess_Front then
		allTIsFront.copyNoDups(self.allOverstowTIs); //	PAR 34416
	else
		allTIsBack.copyNoDups(self.allOverstowTIs); //	PAR 34416
	endif;
	
epilog
	delete iter;
	delete allTIsFront;
	delete allTIsBack;

end;</source>
        <access>protected</access>
        <Parameter name="_gridLC" type="CM_GridController"/>
        <Parameter name="_osBackend" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getSideOverstowForLC" id="aea83344-fdf2-4b91-9a7d-0dcbeec154dd">
        <updating/>
        <source>getSideOverstowForLC(	_gridController : CM_GridController input;
						_rowsFromSelf : Integer;
						_nextRowHeight : Integer;
						_allOverstowTIs : CM_TIArray input ) protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2018	jlger1	Initial creation 37584
26 May 2025	jlier1  MTN-33471
*/

vars
	iter : Iterator;
	currentQueueIndex,
	cargoHeight : Integer;
	isQueuedOut,
	canAccessReach,
	canAccessHeighDiff: Boolean;
	ti : CM_TrackedItem;
	queue :	CM_RadioTelemetryQueue;
begin
	
	if self.myQueueEntry &lt;&gt; null then
		queue:=self.myQueueEntry.myQueue;
		currentQueueIndex:=queue.allEntries.indexOf(self.myQueueEntry);
	endif;
	
	iter:=_gridController.allTrackedItems.createIterator;
	cargoHeight :=0;
	canAccessHeighDiff:=false;
	canAccessReach:=false; //epr TFS 39001 1/6/18
	if  self.accessMaxLocationReach &gt; 0 and  self.accessMaxLocationReach &gt;= _rowsFromSelf then 
			canAccessReach:=true;
			canAccessHeighDiff:=true; // 
			//jlier1 JIRA#33471 18/12/24
		//	if  not (((_gridController.allTrackedItems.size - self.currentHeight) = 1 or ( self.currentHeight &gt;=  _gridController.allTrackedItems.size   ) ) and (self.accessMaxHeightDiff &gt;= (self.currentHeight - _gridController.allTrackedItems.size))) then
			if  not ((( self.currentHeight &gt;  _gridController.allTrackedItems.size   ) ) and (self.accessMaxHeightDiff &gt;= (self.currentHeight - _gridController.allTrackedItems.size))) then
				canAccessHeighDiff:=false;	
			endif;
		endif;
	
	while iter.next(ti) do
		
		cargoHeight :=cargoHeight +1;
		//jlier1 JIRA#33471 18/12/24
		if canAccessReach then
			if self.currentHeight = cargoHeight then
				//ok this stack - but if the next stack height is &gt; accessMaxOverstow there is a problem
				//jlier1 MTN-34637 22/5/25
				if _nextRowHeight &gt; self.currentHeight  then
					if self.accessMaxOverstowHeight = 0 or _nextRowHeight &gt; self.accessMaxOverstowHeight then
						canAccessReach:=false;
					endif;
				endif;
				if canAccessReach then
					continue;
				endif;
			endif;
		endif;
		
		if not canAccessHeighDiff and canAccessReach then
			if cargoHeight &lt;&gt; self.currentHeight then
			//if we are not actually reaching over i.e. rows ,= 1 then can access the height diff
				if _rowsFromSelf &lt;= 1 or (self.accessMaxHeightDiff &gt;= (self.currentHeight - cargoHeight)) then
					canAccessHeighDiff:=true;
				endif;
			endif;
		
		endif;
		
				
		if  canAccessHeighDiff then
			if self.accessMaxOverstowHeight &gt; 0 then
				if cargoHeight &lt;= self.currentHeight and					
					cargoHeight &lt;= self.accessMaxOverstowHeight then //epr TFS 38959 30/5/18 
					continue;
				endif;
			endif;					
		endif;	
		self.isOverstowed:=true;
		isQueuedOut:=false;
		if queue &lt;&gt; null then
			isQueuedOut:= ti.allQueuedFutureMoves.hasQueuedEntriesBeforeIndex(queue,currentQueueIndex);
		endif;
		if not 	isQueuedOut then
			if not _allOverstowTIs.includes(ti) then
				_allOverstowTIs.insert(1,ti);
				self.isOverstowedAtMoveTime:=true;
			endif;
		endif;
			
	endwhile;
epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_gridController" type="CM_GridController" usage="input"/>
        <Parameter name="_rowsFromSelf" type="Integer"/>
        <Parameter name="_nextRowHeight" type="Integer"/>
        <Parameter name="_allOverstowTIs" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getSideOverstowForTI" id="e033f424-e0cb-45f3-bd40-77360567e23a">
        <updating/>
        <source>getSideOverstowForTI() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2018	jlger1	Initial creation tfs 37584
22 Apr 2020 cnwma1  Bug 49078: MTN - UE Floods
*/

vars
	backEndLocation,
	lc 		  		: CM_LocationsController;
	locations 		: CM_LCArray;
	ed        		: Integer;
	invalid   		: Boolean;
begin
	on Exception do app.handleDeletedObject(exception, locations, invalid);
	
	self.allOverstowTIs.clear;
	if self.myTI = null then
		if self.myCurrentLC &lt;&gt; null and self.myCurrentLC.isKindOf(CM_GridController) then
			self.currentHeight:=self.myCurrentLC.allTrackedItems.size  + 1;
			self.getSideOverstowForColumn(myCurrentLC.CM_GridController, false);
		endif;		
		return;
	endif;
	
	locations := self.myTI.getLocationsArray(self.mode,0);
	
	if locations &lt;&gt; null then
		ed := locations.edition;
		if not invalid then
			foreach lc in locations discreteLock do
				if  lc.isKindOf(CM_GridController) then
					self.getSideOverstowForColumn(lc.CM_GridController, false);
				endif;
			endforeach;
		endif;
	endif;
	
	backEndLocation := self.myTI.getOSBackEndLocationForMode(self.mode);
	if backEndLocation &lt;&gt; null and  backEndLocation.isKindOf(CM_GridController) then
		self.getSideOverstowForColumn(backEndLocation.CM_GridController, true);
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getTopOverstow" id="4e44bf73-df58-4c2b-b861-dd1afc427d32">
        <updating/>
        <source>getTopOverstow() protected, updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2018	jlger1	Initial creation tfs 37584
30/05/2019 	JLGNS1	Bug 44890: SNO - Overstowed container
*/

vars
	tis :  CMIF_RTSortByPosDict;
	the40Info  : IntegerArray;
	currentQueueIndex : Integer;
	queue 	: CM_RadioTelemetryQueue;
	iter 	: Iterator;
	rtSort 	: CMIF_RTSort;
	theTI		: CM_TrackedItem;
	isQueuedOut : Boolean;
begin
	if self.myTI = null then
		return;
	endif;
	
	if not self.isOverstowPossible then
		return;
	endif;
	
	create tis transient;
	create the40Info transient;
	self.myTI.getOverstowedByTIs(self.mode,tis,the40Info,false);
	if tis.size &gt; 0 then
		self.isOverstowed:=true;
	endif;
	
	// Get the grid area
	// check if use side access
	// check which direction side access is from 
	// there 
	if self.myQueueEntry &lt;&gt; null then
		queue:=self.myQueueEntry.myQueue;
		currentQueueIndex:=queue.allEntries.indexOf(self.myQueueEntry);
	endif;
	
	iter:=tis.createIterator;
	while iter.next(rtSort) do
		//only what rt tasks coming from self tis REAL location
		theTI:=rtSort.myTi;
		if theTI = null then
			continue;
		endif;

		isQueuedOut:=false;
		if queue &lt;&gt; null and not self.skipQueuedFutureMoves then		// Bug 44890
			isQueuedOut:=theTI.allQueuedFutureMoves.hasQueuedEntriesBeforeIndex(queue,currentQueueIndex);
		endif;
		if not isQueuedOut then
			if not self.allOverstowTIs.includes(theTI) then
				self.allOverstowTIs.add(theTI);
				self.isOverstowedAtMoveTime:=true;
				
			endif;
		endif;
	endwhile;
	
epilog
	delete iter;
	delete tis;
	delete the40Info;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="isOverstowPossible" id="fa17086c-90ff-4be5-821d-bbecc279a8ad">
        <source>isOverstowPossible() : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 May 2018	jlger1	Initial creation tfs 37584

*/

vars

begin
	if self.myTI &lt;&gt; null and self.myTI.isChild then
		return false;
	endif;
	
	if self.myTI &lt;&gt; null and not self.myTI.isKindOf(CM_Container) then
		return false;
	endif;
	
	if self.myCurrentLC = null then
		return false;
	endif;
	
	//epr par 26947 14/2/2011
	if not self.myCurrentLC.isOverStowPossible then
		return false;
	endif;
	
	return true;
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setGridLocation" id="375d207a-d835-4e1a-b6ed-f3f6f73bd936">
