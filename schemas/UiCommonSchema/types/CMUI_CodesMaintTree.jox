    <JadeMethod name="doCancel" id="0fc47a28-b99e-4b05-b2d5-5c079ee9cae2">
        <updating/>
        <source>doCancel()updating;
//-----------------------------------------------------------------------
//
//  Created by: cnwsh3
//
//	Date: 23 September 2003
//
//-----------------------------------------------------------------------

begin
	app.mousePointer := Window.MousePointer_HourGlass;
	
	if self.tblInput1.hasChanged then
		self.confirmCancel(app.getErrorString(The_Current_Item));
	endif;

	self.zSetControlsForView();
	self.zClearProxyDetails();
	self.clearErrorWarnings();
	
	if self.mode = Mode_Update then
		if self.myCurrentObject &lt;&gt; null then
			self.zShowThumbnailData(self.myCurrentObject);
			
		else
			self.zClearThumbnailData();
		endif;

	elseif self.mode = Mode_Add then
		if self.myCurrentVMObject = null or not global.isValidObject(self.myCurrentVMObject) then
			return;
		endif;
		self.myCurrentVMObject.allVMObjectsRemove(self.allVMObjects);
		delete self.myCurrentVMObject;
		self.setMyCurrentVMObject( null); //epr par 16841 17/7/08
		self.showTree(self.currentGroupType, false);
		self.selectVMObject(self.allVMObjects.first.SOP_ViewModelObject, false);
	endif;
	self.selectVMObject(self.myCurrentVMObject, false);
	self.lstData.enabled := true;
	

epilog
	self.mode := Mode_View;
	app.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doDelete" id="9567b92e-3bda-4edf-89fb-6d2c27533ead">
        <updating/>
        <source>doDelete(): Boolean updating;
// -----------------------------------------------------------------------------
// Created:		13 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	result	: Boolean;
	view	: SOP_ViewModelObject;

begin

	view := self.myCurrentVMObject.myParent;
	self.myCurrentVMObject.doDelete();
	result := app.myPassport.noErrors();	
	if result then
		self.allVMObjects.remove(self.myCurrentVMObject);
		delete self.myCurrentVMObject;
	//	self.myCurrentVMObject := self.myLastVMObject;
		self.showTree(self.currentGroupType, false);
		self.selectVMObject(view, false);
		self.clearErrorWarnings();
	else
		app.showErrorWarningDialog('Codes Maint', app.myPassport, ErrWarnMode_Update);
		self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
	endif;
	// Returning false stop it from clearing.
	return result;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doListboxDblClick" id="544b5b0d-27a7-416b-a6d4-5cdf89cab414">
        <updating/>
        <source>doListboxDblClick(listbox : ListBox input) updating;
// ---------------------------------------------------------------------------
// Created:      28 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
vars
	numRows,
	idx,
	i,
	lvl		: Integer;
	vmObj : SOP_ViewModelObject;
	expanding : Boolean;

begin
	app.mousePointer := MousePointer_HourGlass;

	idx := listbox.listIndex;

	if idx &lt;&gt; -1 then
		expanding := not listbox.itemExpanded[idx];
	
		self.doPicClick(idx);

		if expanding then
			numRows := listbox.listCount;
			lvl := listbox.itemLevel[idx];
			foreach i in idx+1 to numRows do
				if listbox.itemLevel[i] = lvl then
					break;
				endif;
				
				vmObj := listbox.itemObject[i].SOP_ViewModelObject;
				vmObj.setExpanded(true);
				
				listbox.itemExpanded[i] := vmObj.expanded;
			endforeach;
		endif;
	endif;

epilog
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
    </JadeMethod>
