    <JadeMethod name="updateCargoTotalWeight" id="c9062832-1041-4aa4-b9a8-d61a1ae063a8">
        <source>updateCargoTotalWeight( _ti : CM_TrackedItem; _totalWeightKgs : Decimal; _certifiedBy, _authPerson : String; _wasAdjusted : Boolean );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11/03/2014	cnwndl1	Initial creation	Par 33268
29/06/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
*/

vars

	ti : CM_TrackedItem;
	result : Integer;
	load : Boolean;
	pxyTI : CM_TrackedItem;
	toDoId : Integer;
	toDo : CM_ToDoTask;
	ret : Integer;
	msg : String;
	controller : CMIF_TIUpdateController;					// TFS #2494
	vgmDetails : CM_VGMDetails;							// TFS 4492
	authSig, commsType, docDetails, ediTrans, email, 	// TFS 4492
	mail, phone, fax, telephone : String;				// TFS 4492
	docsIssued, determination : TimeStamp;				// TFS 4492

begin

	if _ti.isWeightCertified then
		msg := app.getErrorString(CARGO_ALREADY_CERFIFIED);
		result := app.msgBox(msg, app.getErrorString(DoYouWantToContinue), MsgBox_Yes_No);
		if result = MsgBox_Return_No then
			self.chkCertified.setFocus();
			return;
		endif;
	endif;

	if _ti.isTransient then
		ti := _ti;
		ti.setTotalWeightWithoutTrans( _totalWeightKgs );
		ti.setTotalWeight(_totalWeightKgs, null, app.myPassport);
		ti.setIsWeightCertified(self.chkCertified.value, null, app.myPassport);
		if self.chkCertified.value then														// TFS #2494
			//ti.setWeightCertifiedReference(_certifiedBy, controller, app.myPassport);		// TFS #2494	// TFS 4492
			//ti.setWeightCertifiedName(_authPerson, controller, app.myPassport);			// TFS #2494	// TFS 4492
			vgmDetails := ti.getMyVGMDetails();																// TFS 4492
			if vgmDetails &lt;&gt; null then																		// TFS 4492
				authSig := vgmDetails.vgmAuthSignature;														// TFS 4492
				commsType := vgmDetails.vgmCommsType;														// TFS 4492
				docDetails := vgmDetails.vgmDocumentDetails;												// TFS 4492
				ediTrans := vgmDetails.vgmEDITransmission;													// TFS 4492
				email := vgmDetails.vgmElectronicMail;														// TFS 4492
				mail := vgmDetails.vgmMail;																	// TFS 4492
				phone := vgmDetails.vgmPhone;																// TFS 4492
				fax := vgmDetails.vgmTelefax;																// TFS 4492
				telephone := vgmDetails.vgmTelephone;														// TFS 4492
				docsIssued := vgmDetails.vgmDocsIssuedDT;													// TFS 4492
				determination := vgmDetails.vgmDeterminationDT;												// TFS 4492
			endif;																							// TFS 4492
			ti.setMyVGMDetails(	_certifiedBy, _authPerson, 													// TFS 4492
								authSig, commsType, docDetails, ediTrans, email, mail, 						// TFS 4492
								phone, fax, telephone, docsIssued, determination, null	);					// TFS 4492
		endif;																				// TFS #2494
		
	else
	
		if _ti.hasToDoTasksWithTransClass(TRANS_TYPE_WEIGH, false) then
			foreach toDo in _ti.allToDoTasksToDo do
				if toDo.toDoTaskDescTransType = TRANS_TYPE_WEIGH then
					toDoId := toDo.toDoTaskDescCode;
					break;
				endif;
			endforeach;
		endif;
		
		app.cmsBeginLoad(load);
		pxyTI := _ti.pxyCreateUpdateProxy();
		app.cmsEndLoad(load);
		
		pxyTI.setTotalWeightAndCertified(_totalWeightKgs, pxyTI.weightCargo, pxyTI.weightTare, self.chkCertified.value, null, app.myPassport);
		if self.chkCertified.value then														// TFS #2494
			//pxyTI.setWeightCertifiedReference(_certifiedBy, controller, app.myPassport);	// TFS #2494	// TFS 4492
			//pxyTI.setWeightCertifiedName(_authPerson, controller, app.myPassport);		// TFS #2494	// TFS 4492
			vgmDetails := _ti.getMyVGMDetails();															// TFS 4492
			if vgmDetails &lt;&gt; null then																		// TFS 4492
				authSig := vgmDetails.vgmAuthSignature;														// TFS 4492
				commsType := vgmDetails.vgmCommsType;														// TFS 4492
				docDetails := vgmDetails.vgmDocumentDetails;												// TFS 4492
				ediTrans := vgmDetails.vgmEDITransmission;													// TFS 4492
				email := vgmDetails.vgmElectronicMail;														// TFS 4492
				mail := vgmDetails.vgmMail;																	// TFS 4492
				phone := vgmDetails.vgmPhone;																// TFS 4492
				fax := vgmDetails.vgmTelefax;																// TFS 4492
				telephone := vgmDetails.vgmTelephone;														// TFS 4492
				docsIssued := vgmDetails.vgmDocsIssuedDT;													// TFS 4492
				determination := vgmDetails.vgmDeterminationDT;												// TFS 4492
			endif;																							// TFS 4492
			pxyTI.setMyVGMDetails(	_certifiedBy, _authPerson, 												// TFS 4492
								authSig, commsType, docDetails, ediTrans, email, mail, 						// TFS 4492
								phone, fax, telephone, docsIssued, determination, null	);					// TFS 4492
		endif;																				// TFS #2494
	
		while true do
			app.myTrxUA.trxUpdateTIWeightToDo(pxyTI, toDoId, false, true, null, TI_UPDMODE_NORMAL, null, _wasAdjusted, app.myPassport);
		
			if app.myPassport.trxCompletedOK then
				self.clearErrorWarnings();
				ret := IDOK;
				self.btnUpdCargo.visible := false;
				break;
				
			else
				ret := app.showErrorWarningDialog(app.getErrorString(CM_Weight), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   ret = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				return;
			endif;
			
			break;
		
		endwhile;
		
	endif;
	
	self.updateGateScanRecord();	// ### TFS 54311 25Oct2022 NAVPW1
	
epilog

	app.cmsEndLoad(load);
	delete pxyTI;

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_totalWeightKgs" type="Decimal"/>
        <Parameter name="_certifiedBy" type="String"/>
        <Parameter name="_authPerson" type="String"/>
        <Parameter name="_wasAdjusted" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateChassisTareWeight" id="8d2d035a-8b11-4c2c-a43f-b8a060b461d1">
        <updating/>
        <source>updateChassisTareWeight( _chassis : CM_TILC; _newTareWeightKgs : Decimal ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

	pxyChassis : CM_TILC;
	load : Boolean;
	ret : Integer;

begin

	app.cmsBeginLoad( load );
	pxyChassis := _chassis.pxyCreateUpdateProxy().CM_TILC;
	app.cmsEndLoad( load );
	pxyChassis.setWeightTare( _newTareWeightKgs );
	
	while true do
		app.myTrxUA.trxUpdateTrackedItem( pxyChassis, null, TI_UPDMODE_NORMAL, null, app.myPassport );
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			ret := IDOK;
			self.btnUpdChassis.visible := false;
			break;
			
		else
			ret := app.showErrorWarningDialog(app.getErrorString(CM_Weight), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   ret = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		
		break;
	
	endwhile;


epilog

	app.cmsEndLoad( load );
	delete pxyChassis;

end;</source>
        <Parameter name="_chassis" type="CM_TILC"/>
        <Parameter name="_newTareWeightKgs" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="updateChassisTypeTareWeight" id="8f980295-cecb-45df-8359-3be059470428">
        <updating/>
        <source>updateChassisTypeTareWeight( _chassisType : CM_TILCType; _newTareWeightKgs : Decimal ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 March 2014	cnwndl1	Initial creation	Par 33268
10/03/2023	jlika1	Add width to Trailer Type
*/

vars

	pxyChassisType : CM_TILCType;
	load : Boolean;
	ret : Integer;

begin

	app.cmsBeginLoad( load );
	pxyChassisType := _chassisType.pxyCreateUpdateProxy().CM_TILCType;
	app.cmsEndLoad( load );
	
	pxyChassisType.setProxy(	_chassisType.code,	//_code : String;
								_chassisType.description,	//_description : String;
								_chassisType.myCargoType,	//_cargoType : CM_CargoType;
								_chassisType.length,	//_length : Decimal;
								_chassisType.numControllers,	//_numControllers : Integer;
								_chassisType.maxHeight,	//_maxHeight : Decimal; 
								_chassisType.maxWeight,	//_maxWeight : Decimal;
								_newTareWeightKgs,	//_tareWeight : Decimal;
								_chassisType.colour,	//_colour : Integer;
								_chassisType.isNotAvailableForEntry,	//_isNotAvailableForEntry :Boolean
								_chassisType.height,
								_chassisType.category,
								_chassisType.width,
								_chassisType.imageID,
								_chassisType.allowUpdateTotalWeight //15/10/2025	navkc1 JIRA 36057
								);
	
	while true do
		app.myTrxUA.trxUpdateTILCType( pxyChassisType, app.myPassport );
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			ret := IDOK;
			self.btnUpdChassis.visible := false;
			break;
			
		else
			ret := app.showErrorWarningDialog(app.getErrorString(CM_Weight), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   ret = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		
		break;
	
	endwhile;
	
epilog

	app.cmsEndLoad( load );
	delete pxyChassisType;

end;</source>
        <Parameter name="_chassisType" type="CM_TILCType"/>
        <Parameter name="_newTareWeightKgs" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="updateGateScanRecord" id="4998f971-bedf-4ede-bdcf-d128a84e00e7">
        <source>updateGateScanRecord() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 October 2022	navpw1	Initial creation TFS: 54311
22 Dec 2023	navbs1	Defect 61856:MTN - Receiving Full Prenote and using Scale to change weight causing a 1090

*/

vars
	pxyGateScanRecord : CM_GenericGateScanRecord;
	ret : Integer;
	
begin
	//if self.myAssistant.myCurrentGateScanRecord = null and self.myVehicleVisitRecord = null then			//22.12.2023 navbs1 #61856
	if self.myAssistant.myCurrentGateScanRecord = null then			//22.12.2023 navbs1 #61856
		return;
	endif;
	
	pxyGateScanRecord := app.createUpdateProxy(self.myAssistant.myCurrentGateScanRecord).CM_GenericGateScanRecord;
	if pxyGateScanRecord = null then
		return;
	endif;
	
	pxyGateScanRecord.setVehicleVisitRecord(self.myVehicleVisitRecord);
	
	while true do
		app.myTrxUA.trxUpdateGateScanRecord(pxyGateScanRecord, app.myPassport);
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			
			break;
			
		else
			ret := app.showErrorWarningDialog(app.getErrorString(CM_Weight), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   ret = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		
		break;
		
	endwhile;
	
epilog
    delete pxyGateScanRecord;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="updateGeneratorTotalWeight" id="2d7d9bdd-a5ac-47d5-aeaf-946b457a1d51">
        <updating/>
        <source>updateGeneratorTotalWeight( _generator : CM_TrackedItem; _newTotalWeightKgs : Decimal ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

	pxyGenerator : CM_TrackedItem;
	load : Boolean;
	ret : Integer;

begin

	app.cmsBeginLoad( load );
	pxyGenerator := _generator.pxyCreateUpdateProxy().CM_TrackedItem;
	app.cmsEndLoad( load );

	pxyGenerator.setTotalWeightAndCertified(_newTotalWeightKgs, pxyGenerator.weightCargo, pxyGenerator.weightTare, false, null, app.myPassport);
	
	while true do
		app.myTrxUA.trxUpdateTrackedItem( pxyGenerator, null, TI_UPDMODE_NORMAL, null, app.myPassport );
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			ret := IDOK;
			self.btnUpdGenny.visible := false;
			break;
			
		else
			ret := app.showErrorWarningDialog(app.getErrorString(CM_Weight), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   ret = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		
		break;
	
	endwhile;
	

epilog

	app.cmsEndLoad( load );
	delete pxyGenerator;

end;</source>
        <Parameter name="_generator" type="CM_TrackedItem"/>
        <Parameter name="_newTotalWeightKgs" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="updateGeneratorTypeDefWeight" id="de43f8ff-b6d7-4216-badc-80f5e31a7895">
        <updating/>
        <source>updateGeneratorTypeDefWeight( _generatorType : CM_GeneratorType; _newDefaultWeightKgs : Decimal ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

	pxyGenType : CM_GeneratorType;
	load : Boolean;
	ret : Integer;
	genType : String;

begin

	app.cmsBeginLoad( load );
	pxyGenType := _generatorType.pxyCreateUpdateProxy().CM_GeneratorType;
	app.cmsEndLoad( load );
	
	if _generatorType.isNoseMounted = true and _generatorType.isUnderSlung = false then
		genType := GeneratorType_NoseMounted;
	elseif _generatorType.isNoseMounted = false and _generatorType.isUnderSlung = true then
		genType := GeneratorType_UnderSlung;
	elseif  _generatorType.isNoseMounted = false and _generatorType.isUnderSlung = false then
		genType := GeneratorType_StandAlone;
	endif;
	
	pxyGenType.setProxy(	_generatorType.code,	//_code : String;
							_generatorType.description,	//_description : String;
							genType,	//_genType : String;
							_newDefaultWeightKgs	//_defaultWeight : Decimal
							);
	
	while true do
		app.myTrxUA.trxUpdateGeneratorType( pxyGenType, app.myPassport );
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			ret := IDOK;
			self.btnUpdGenny.visible := false;
			break;
			
		else
			ret := app.showErrorWarningDialog(app.getErrorString(CM_Weight), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   ret = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		
		break;
	
	endwhile;
	
epilog

	app.cmsEndLoad( load );
	delete pxyGenType;

end;</source>
        <Parameter name="_generatorType" type="CM_GeneratorType"/>
        <Parameter name="_newDefaultWeightKgs" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="updateISOTypeTareWeight" id="1de30b4f-83be-48de-a623-f9b407b8f4c6">
        <updating/>
        <source>updateISOTypeTareWeight( _isoType : CM_ISOType; _newTareWeightKgs : Decimal ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 March 2014	cnwndl1	Initial creation	Par 33268

*/

vars

	pxyISOType : CM_ISOType;
	load : Boolean;
	ret : Integer;

begin

	app.cmsBeginLoad( load );
	pxyISOType := _isoType.pxyCreateUpdateProxy().CM_ISOType;
	app.cmsEndLoad( load );
	
	pxyISOType.setProxy(	_isoType.code,	// id/code
							_isoType.description,	// desription
							_newTareWeightKgs.Integer,	// tare kilos
							_isoType.colour,	// colour
							_isoType.myCargoType,	// cargo type
							_isoType.myISOTypeGroup,	// iso type group
							_isoType.is20ftLong,	// 20ft
							_isoType.is30ftLong,	// 30ft
							_isoType.is40ftLong,	// 40ft
							_isoType.is45ftLong,	// 45ft
							_isoType.is53ftLong,	// 53ft
							_isoType.is4ft3High,	// 4ft 3'
							_isoType.is4ftHigh,	// 4ft
							_isoType.is8ft6High,	// 8ft 6'
							_isoType.is8ftHigh,	// 8ft
							_isoType.isHalfHeight,	// half height
							_isoType.is9ft6High,	// 9ft 6
							_isoType.isCrib,	// crib
							_isoType.isFantainer,	// fantail
							_isoType.isFlat,	// flat
							_isoType.isGeneral,	// general
							_isoType.isIntegral,	// integral		
							_isoType.isMachinery,	// machinery
							_isoType.isOpenTop,	// open top
							_isoType.isPorthole,	// port hole
							_isoType.isPowered,	// powered
							_isoType.isReefer,	// reefer
							_isoType.isTank,	// tank
							_isoType.isFrame,	//
							_isoType.isRotatable(), // Rotatable //02/10/2025	navkc1 JIRA 36151
							_isoType.isNotAvailableForEntry,	// not available for entry
							_isoType.isNotTwinLiftCapable,	// twin lift capable
							_isoType.maxTotalWeight,	// max total weight
							_isoType.maxTareWeight
							);
	
	while true do
		app.myTrxUA.trxUpdateISOType( pxyISOType, app.myPassport );
		
		if app.myPassport.trxCompletedOK then
			self.clearErrorWarnings();
			ret := IDOK;
			self.btnUpdGenny.visible := false;
			break;
			
		else
			ret := app.showErrorWarningDialog(app.getErrorString(CM_Weight), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   ret = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		
		break;
	
	endwhile;
	
epilog

	app.cmsEndLoad( load );
	delete pxyISOType;

end;</source>
        <Parameter name="_isoType" type="CM_ISOType"/>
        <Parameter name="_newTareWeightKgs" type="Decimal"/>
    </JadeMethod>
