    <JadeMethod name="updateQueueTable" id="da4d5537-a769-449a-9c8d-9c0de2d28a35">
        <updating/>
        <source>updateQueueTable() updating;

vars
    queueItem	: CnEcIspecToHost;

begin
	// Handle database enquiry exceptions
	on SystemException do readExceptionHandler(exception);
	on LockException   do readExceptionHandler(exception);

	/**************************************************************

	  Display the ISPEC and FIELD content details in the table

	**************************************************************/

	tableQueueItems.rows	:= myLincSystemDef.allIspecsToHost.size() + 1;
	tableQueueItems.row	:= 1;

	/****************
	  ROW 1 (Header)
	 ***************/
	tableQueueItems.rowHeight[1] := Tab_row_height_header;

	beginLoad;
		app.mousePointer := Window.MousePointer_HourGlass;

		foreach queueItem in myLincSystemDef.allIspecsToHost do
			tableQueueItems.row := tableQueueItems.row + 1;

			/***************
	 		 ROW n (Others)
	 		 **************/
			tableQueueItems.rowHeight[tableQueueItems.row] := Tab_row_height_other;

			/***********
			  COLUMN 1
			 ***********/
			tableQueueItems.column := 1;
			tableQueueItems.alignment := tableQueueItems.Alignment_Left;
			tableQueueItems.text := "  " &amp; queueItem.ispec;		// Left pad

			tableQueueItems.itemObject := queueItem;

			/***********
			  COLUMN 2
			 ***********/
			tableQueueItems.column := 2;

			if queueItem.timestamp = null then
				tableQueueItems.text := "Timestamp not yet added";
			else			
				tableQueueItems.alignment := tableQueueItems.Alignment_Left;
				tableQueueItems.text := queueItem.timestamp.String &amp; "      ";		// Right pad
            endif;

			tableQueueItems.itemObject := queueItem;

			/***********
			  COLUMN 3
			 ***********/

			tableQueueItems.column := 3;
			tableQueueItems.alignment := tableQueueItems.Alignment_Right;
			tableQueueItems.text := queueItem.statusString  ;		// Right pad

			tableQueueItems.itemObject := queueItem;

			/***********
			  COLUMN 4
			 ***********/							

			tableQueueItems.column := 4;
			tableQueueItems.alignment := tableQueueItems.Alignment_Center;
			if queueItem.priority = 0 then 
				tableQueueItems.text := "LOGON";
			else
				tableQueueItems.text := queueItem.priority.String;	// No padding
			endif;

			tableQueueItems.itemObject := queueItem;

			/***********
			  COLUMN 5
			 ***********/		

			tableQueueItems.column := 5;
			tableQueueItems.alignment := tableQueueItems.Alignment_Center;
			tableQueueItems.text := queueItem.timeoutValue.String;	// Right pad

			tableQueueItems.itemObject := queueItem;

		endforeach; // field

		app.mousePointer := Window.MousePointer_Default;

	endLoad;

//	tableFieldContents.resort();
end;</source>
    </JadeMethod>
