    <JadeMethod name="isValidForRT" id="a427ffbf-3cc9-406f-bc63-394056e94b37">
        <source>isValidForRT():Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars

	iter : Iterator;
	menuUserQuery : CM_MenuUserQuery;

begin

	iter := self.allSelectedQueries.createIterator();
	while iter.next( menuUserQuery ) do
		if not menuUserQuery.isValidForRT() then
			return false;
		endif;
	endwhile;

	return true;

epilog

	delete iter;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="c05a9845-effe-4cf3-9ae0-670c0f1cdd9b">
        <updating/>
        <source>setForCreate( _pxyQuerySet : CM_SelectorQueryAccess; _queryColl : CM_MenuUserQueryArray ) updating;
// ---------------------------------------------------------------------------
// Created:     14 April 2008		cnwvu1	
// ---------------------------------------------------------------------------

vars

begin

	self.description:= _pxyQuerySet.description;
	self.myRoot		:= app.myRoot;

	self.allSelectedQueries.clear();
	_queryColl.copy( self.allSelectedQueries );
		
end;
</source>
        <Parameter name="_pxyQuerySet" type="CM_SelectorQueryAccess"/>
        <Parameter name="_queryColl" type="CM_MenuUserQueryArray"/>
    </JadeMethod>
