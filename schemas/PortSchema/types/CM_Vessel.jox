    <JadeMethod name="pxyCreateUpdateProxy" id="f3eba7ce-ca0f-4333-a8fa-f7333b550b13">
        <source>pxyCreateUpdateProxy(): SelfType;
//--------------------------------------------------
// Created:	15 March 2004 By: cnwgd1
//--------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy
// 21 Mar 2013	PJS			PAR #31232 - Voyage Rationalisation
vars
	proxyObj		: SelfType;
	terminalDataObj	: CM_VesselTerminalData;
	proxyDataObj	: CM_VesselTerminalData;
	completedOK		: Boolean;
	
begin
	proxyObj	:=	inheritMethod();
	
	if self.myHMSVesselData &lt;&gt; null then
		proxyObj.myHMSVesselData	:=	self.myHMSVesselData.pxyCreateUpdateProxy();
	endif;

	if self.myGeneralCargoVesselStructure &lt;&gt; null then
		proxyObj.myGeneralCargoVesselStructure	:=	self.myGeneralCargoVesselStructure.pxyCreateUpdateProxy();
	endif;	


	if self.myROROVesselStructure &lt;&gt; null then
		proxyObj.myROROVesselStructure	:=	self.myROROVesselStructure.pxyCreateUpdateProxy();
	endif;	

	//31232 ... (how did it work before without this?)
	if self.myCellularVesselStructure &lt;&gt; null then
		proxyObj.myCellularVesselStructure	:=	self.myCellularVesselStructure.pxyCreateUpdateProxy();
	endif;	
		
	
	proxyObj.myOperator	:=	self.myOperator;
	
	foreach terminalDataObj in self.allTerminalDatas do
		proxyDataObj			:=	terminalDataObj.pxyCreateUpdateProxy();
		proxyDataObj.setVessel(proxyObj);
	endforeach;
	
	if self.myStructuralElements &lt;&gt; null then
		proxyObj.myStructuralElements := self.myStructuralElements.pxyCreateUpdateProxy();
	endif;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyObj;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyObj;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="85b20ea0-2321-41c9-8fd6-30703dc71bdc">
        <updating/>
        <source>setForCreate(_proxyVessel : CM_Vessel) updating;
//--------------------------------------------------------------
//Created: 10 July 2002 By: cnwgd1
//--------------------------------------------------------------
/*

Date		Who		Reason
17 May 2010	cnwkpd1	PAR #23525 - System performance enhancements

*/

vars
	agent			: CM_ObjectVolatilityConverter;
	
begin

	_proxyVessel.raiseExceptionIfNotTransient(method);

	self.setForUpdate(_proxyVessel, true);
	
	// PAR #23525 - If system is using stable objects, then need to change the volatility of
	// the newly created object's collections
	if app.myRoot.useStableObjects then
		create agent transient;
		agent.newVolatility := Volatility_Stable;
		agent.multipleTransactions := false;
		
		self.doObjectVolatilityConversion(agent, 1);
	endif;

	
epilog
	delete agent;
	
end;</source>
        <Parameter name="_proxyVessel" type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="0180c37d-2a0e-42fe-b207-03ac3939dc11">
        <updating/>
        <source>setForUpdate(_proxy :CM_Vessel; _includeStructure : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     16 January 2002 by cnwrs1
//
/* Changes

Date		Name	TFS#		Description
============================================================================
27/04/2009	cnwer1	CCMS 1058 	added default trade
23/03/2011	cnwer1	CCMS 1031 	added RORO vessel Structure
07/03/2013	cnwpjs1	PAR #31232 
					CCMS SFW 1274
15/04/2013	cnwcs5	CCMS POL 2097 
					/ par 31259
04/03/2019	jlgka1	37102		STWR CAMS STANDARD CODECO Add isBarge Flag.
============================================================================*/
vars
	realCellVessel			: CM_CellularVesselStructure;
	theCellVessel			: CM_CellularVesselStructure;
	realGCVessel			: CM_GeneralCargoVesselStructure;
	theGCVessel				: CM_GeneralCargoVesselStructure;
	realROROVessel			: CM_ROROVesselStructure;
	theROROVessel			: CM_ROROVesselStructure;
	hmsVesselData			: HMS_VesselData;
	realHMSVesselData		: HMS_VesselData;
	proxyTDataObj			: CM_VesselTerminalData;
	terminalDataObj			: CM_VesselTerminalData;
	pathDurationObj			: HMS_PSD_Vessel;
	proxyDurationObj		: HMS_PSD_Vessel;
	proxyUnavailObj			: CM_VesselUnavailability;
	unavailabilityObj		: CM_VesselUnavailability;
	pxyVesStructElement		: CM_VesselStructuralElements;
	realVesStructElement	: CM_VesselStructuralElements;
	theVoyageAllocConfig	: CM_VoyageAllocationConfig;
	realVoyageAllocConfig	: CM_VoyageAllocationConfig;//cnwas3 par 1035
	oldName					: String;	
begin
	oldName					:=	self.name;
	
	// par 31259 - make sure xlations updated with new code
	if self.code &lt;&gt; _proxy.code then
		self.updateXlations_Code (_proxy.code.String, self.code.String, self.allXlations);
	endif;

	self.code				:=	_proxy.code.trimBlanks();
	self.name				:=	_proxy.name.trimBlanks();
	self.bitmap				:=	_proxy.bitmap;
	self.callSign			:=	_proxy.callSign.trimBlanks();
	self.canCreateVoyages	:=	_proxy.canCreateVoyages;
	self.classLabel			:=	_proxy.classLabel;
	self.clonedFromVessel	:=	_proxy.clonedFromVessel;
	self.craneClearance		:=	_proxy.craneClearance;
	self.lloydsNumber		:=	_proxy.lloydsNumber;
	self.dailyCost			:=	_proxy.dailyCost;
	self.despatchRate		:=	_proxy.despatchRate;
	self.isDedicatedOrMulti	:=	_proxy.isDedicatedOrMulti;
	self.myOperator			:=	_proxy.myOperator;
	self.remarks			:=	_proxy.remarks;
	self.vesselType			:=	_proxy.vesselType;
	self.myDefaultTrade		:=  _proxy.myDefaultTrade;
	self.yearOfBuild		:=  _proxy.yearOfBuild; //cnwas3 ccms 1031
	self.airDraft			:=  _proxy.airDraft;
	self.loaWithRampsDown	:=  _proxy.loaWithRampsDown;
	self.maxVesselBeam		:=	_proxy.maxVesselBeam;
	self.draftBow			:=	_proxy.draftBow;
	self.draftStern         :=	_proxy.draftStern;
    self.draftMid			:=	_proxy.draftMid;
    self.buildingLine		:=	_proxy.buildingLine;
	self.isBarge			:=  _proxy.isBarge; // jlgka1 TFS 378102
	self.setMyRoot();

	if app.myPassport.hasErrors then
		return;
	endif;
	
	hmsVesselData	:=	_proxy.myHMSVesselData;
	
	if hmsVesselData &lt;&gt; null then
		if oldName &lt;&gt; null and oldName &lt;&gt; self.name then
			if hmsVesselData.remarksPreviousNames = null then
				hmsVesselData.setRemarksPreviousNames(oldName);
			else
				hmsVesselData.setRemarksPreviousNames(hmsVesselData.remarksPreviousNames &amp; '; ' &amp; oldName);
			endif;
		endif;
		
		realHMSVesselData	:=	hmsVesselData.pxyGetRealObject();
		
		if realHMSVesselData &lt;&gt; null then
			realHMSVesselData.setForUpdate(hmsVesselData, app.myPassport);
		elseif hmsVesselData.isTransient then
			create self.myHMSVesselData persistent;
			self.myHMSVesselData.setForCreate(hmsVesselData, app.myPassport);
		endif;
	endif;
	
	// General Cargo Structure
	theGCVessel	:=	_proxy.myGeneralCargoVesselStructure;
	
	if theGCVessel &lt;&gt; null then
		realGCVessel	:=	theGCVessel.pxyGetRealObject();
		
		if realGCVessel &lt;&gt; null then
			realGCVessel.setForUpdate(theGCVessel, app.myPassport);
		elseif theGCVessel.isTransient then
			create self.myGeneralCargoVesselStructure persistent;
			self.myGeneralCargoVesselStructure.setForCreate(theGCVessel, app.myPassport);
		endif;
	
	// 31232
	else
		if self.myGeneralCargoVesselStructure &lt;&gt; null then
			delete self.myGeneralCargoVesselStructure;
		endif;
		
	endif;
	// Cellular Structure
	theCellVessel	:=	_proxy.myCellularVesselStructure;
	if theCellVessel &lt;&gt; null then
		realCellVessel	:=	theCellVessel.pxyGetRealObject();
			
		if realCellVessel &lt;&gt; null then
			// CELLS NOT UPDATED FROM HERE. THEY HAVE THEIR OWN TRX FOR UPDATES
		elseif theCellVessel.isTransient then
			create self.myCellularVesselStructure persistent;
			self.myCellularVesselStructure.setForCreate(theCellVessel, app.myPassport);
			//self.myCellularVesselStructure.setForUpdateVessel(theCellVessel, app.myPassport); - cnwrd1 31874 done on structeleements now
		endif;
		
	// 31232
	else
		if self.myCellularVesselStructure &lt;&gt; null then
			delete self.myCellularVesselStructure;
		endif;	
		
	endif;
	
	
	//structural elements
	pxyVesStructElement	:=	_proxy.myStructuralElements;
	if pxyVesStructElement &lt;&gt; null then
		realVesStructElement	:=	pxyVesStructElement.pxyGetRealObject();
			
		if realVesStructElement &lt;&gt; null then
			// CELLS NOT UPDATED FROM HERE. THEY HAVE THEIR OWN TRX FOR UPDATES
		elseif pxyVesStructElement.isTransient then
			create self.myStructuralElements persistent;
			self.myStructuralElements.setForCreate(pxyVesStructElement, app.myPassport);
			self.myStructuralElements.setForUpdateVessel(pxyVesStructElement, app.myPassport);
		endif;
		
	// 31232
	else
		if self.myStructuralElements &lt;&gt; null then
			delete self.myStructuralElements;
		endif;	
		
	endif;
	
	
	// RORO Vessel Structure
	theROROVessel := _proxy.myROROVesselStructure;
	if theROROVessel &lt;&gt; null then
		realROROVessel := theROROVessel.pxyGetRealObject();
		if  realROROVessel = null then
			create self.myROROVesselStructure persistent;
			self.myROROVesselStructure.setForCreate(theROROVessel, app.myPassport);
		endif; 
		
		//  where is the update - not the same as cell and GC which handle the update here
	
	// 31232 .. is this where  the code really belongs?  What is the std approach to delete
	// references like this?  pass through a null on the proxy and manage that way??
	else
		if self.myROROVesselStructure &lt;&gt; null then
			delete self.myROROVesselStructure;
		endif;
				
	endif;
	
	// Voyage Allocation Attributes
	theVoyageAllocConfig := _proxy.myVoyageAllocationConfig;			//cnwas3 cms 1035
	if theVoyageAllocConfig &lt;&gt; null then
		realVoyageAllocConfig := theVoyageAllocConfig.pxyGetRealObject();
		if  realVoyageAllocConfig = null then
			create self.myVoyageAllocationConfig persistent;
			self.myVoyageAllocationConfig.setForUpdate(theVoyageAllocConfig);
		else
			self.myVoyageAllocationConfig.setForUpdate(theVoyageAllocConfig);
		endif; 
		if self.myVoyageAllocationConfig.allOpCriteria.isEmpty() then				// 17/10/2011 cnwmh5 #28309
			self.setVoyageAllocationConfig(null);
		endif;
	endif;
	
	// terminal specific data
	foreach proxyTDataObj in _proxy.allTerminalDatas do
		terminalDataObj	:=	self.allTerminalDatas[proxyTDataObj.myTerminal];
		
		if terminalDataObj = null then
			create terminalDataObj persistent;
			terminalDataObj.setForCreate(proxyTDataObj);
			terminalDataObj.setVessel(self);
		else
			terminalDataObj.setForUpdate(proxyTDataObj);
		endif;
	endforeach;
	
	foreach terminalDataObj in self.allTerminalDatas do
		if _proxy.allTerminalDatas[terminalDataObj.myTerminal] = null then
			terminalDataObj.setPropertyValue(CM_VesselTerminalData::isUseTerminalDefaults.name, true);
		endif;
	endforeach;
	
	// Vessel Segment Path travel durations.
	
	self.allPathSegmentDurations.purge();
	
	foreach proxyDurationObj in _proxy.allPathSegmentDurations do
		create pathDurationObj persistent;
		pathDurationObj.setForCreate(proxyDurationObj, null);
		pathDurationObj.setVessel(self);
	endforeach;
	
	// Vessel Unavailabilities.
	
	self.allUnavailabilities.purge();
	
	foreach proxyUnavailObj in _proxy.allUnavailabilities do
		create unavailabilityObj persistent;
		unavailabilityObj.setForCreate(proxyUnavailObj);
		unavailabilityObj.setVessel(self);
	endforeach;
end;</source>
        <Parameter name="_proxy" type="CM_Vessel"/>
        <Parameter name="_includeStructure" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setHMSVesselData" id="7fa2f6fd-e94f-4edd-b0c5-98f5bc895411">
