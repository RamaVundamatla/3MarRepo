	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;
	foreach ti in _tiSet do
		reserveLock(ti);//only I can upgrade to exclusive from this point on, but others can get share
	endforeach;
	
	app.myUtilityDA.utlDeleteStopTIMastsBulk(_tiSet, _stopTable, _passport);	
 
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
