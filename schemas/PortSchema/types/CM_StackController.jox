    <JadeMethod name="amIAvailable" id="d01f0939-6cb2-46cf-9f95-3dae5004a3b8">
        <source>amIAvailable() : Boolean;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if ( (self.usage &lt;&gt; NORMAL_USE) or (self.availability = PAD_UNAVAILABLE) or (self.availability = PAD_USER_UNAVAILABLE) ) then
		return false;
	endif;
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
