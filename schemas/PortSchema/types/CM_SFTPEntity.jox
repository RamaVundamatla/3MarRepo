    <JadeMethod name="setForUpdate" id="f7654b9e-95b3-40d9-a4db-b9420db3ddc7">
        <updating/>
        <source>setForUpdate(_ftpEntity: CM_SFTPEntity) updating;
//
// 17 Sep 2019	jlgrs1	TFS 46087 JMT implement SFTP.
//
vars

begin
	inheritMethod(_ftpEntity);
	self.privateKey := _ftpEntity.privateKey;
	self.publicKey := _ftpEntity.publicKey;
	self.passPhrase := _ftpEntity.passPhrase;
	self.port := _ftpEntity.port;
	self.timeOut := _ftpEntity.timeOut;
epilog

end;</source>
        <Parameter name="_ftpEntity" type="CM_SFTPEntity"/>
    </JadeMethod>
