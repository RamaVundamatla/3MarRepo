    <JadeMethod name="getDetailForDisplay" id="bc319239-6776-431f-ad18-64551fca09cc">
        <source>getDetailForDisplay(_array: HugeStringArray input): Boolean;
// -------------------------------------------
// Created 31 March 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	if not inheritMethod(_array) then
		return false;
	endif;
	
	self.addToArray(app.getErrorString(Operator), self.operatorCode, _array);
	self.addToArray(app.getErrorString(File_Version), self.fileVersion, _array);
	self.addToArray(app.getErrorString(File_Name), self.fileName, _array);
	self.addToArray(app.getErrorString(NumberOfItems) , self.numItems.String, _array);
	
	return true;


end;</source>
        <Parameter name="_array" type="HugeStringArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getTypeDescription" id="af04087d-cc6b-4b9e-a797-12ea6ad340d2">
