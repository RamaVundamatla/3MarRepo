    <JadeMethod name="getStrictOffsetForTI" id="86bb5bac-5c7b-4452-afcd-2c5c23c61395">
        <source>getStrictOffsetForTI(_ti : CM_TrackedItem) : Integer;
// ---------------------------------------------------------------------------
// Created:     16 March 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	offset : Integer;
begin
	if _ti.isAttributeTrue(TI_Attrib_IsFiftyThree) and self.is53ft then
		offset := self.offset53;
	elseif _ti.isAttributeTrue(TI_Attrib_IsFortyFive) and self.is45ft then
		offset := self.offset45;
	elseif _ti.isAttributeTrue(TI_Attrib_IsThirty) and self.is30ft then
		offset := self.offset30;
	else
		offset := self.offsetFlexi;
	endif;

	return offset;
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSwapStack" id="ed594dc5-795b-452e-9c69-314a9794ccdd">
        <source>getSwapStack()	 :		CM_SwapStack;
//Returns the the SwapStack associated with this area.
vars
begin
	if getParent.isKindOf(CM_TerminalArea) then
		if getParent.CM_TerminalArea.isKindOf(CM_SwapStack) then
			return getParent.CM_SwapStack;	//We are ALREADY a swapStack LC!!!
		endif;
		if getParent.CM_TerminalArea.swapStack = null then
			//--------------
			//Build the swapStack
			//--------------
			getParent.CM_TerminalArea.createSwapStack;
		endif;
		return getParent.CM_TerminalArea.swapStack;
	endif;
	return null;
end;</source>
        <ReturnType type="CM_SwapStack"/>
    </JadeMethod>
    <JadeMethod name="getSwapStackLC" id="ffe8c444-1569-43d5-8576-09b8af1d594e">
        <source>getSwapStackLC()	:	CM_LocationsController;
//Returns the lcid of the SwapStack associated with this area.
// Changed On	By			Reason
// ----------	--------	----------------------------------------------------------
// 01/09/2011	cnwdap1		PAR #28047 CCMS POL 2095 Prevent 1090 if my parent doesn't have a swap stack
//								(e.g. interchange areas)
vars
begin
	if getParent.isKindOf(CM_TerminalArea) then
		if getParent.CM_TerminalArea.isKindOf(CM_SwapStack) then
			return self;	//We are ALREADY a swapStack LC!!!
		endif;
		if getParent.CM_TerminalArea.swapStack = null then
			//--------------
			//Build the swapStack
			//--------------
			getParent.CM_TerminalArea.createSwapStack;
		endif;
		if getParent.CM_TerminalArea.swapStack &lt;&gt; null then						// PAR #28047
			return getParent.CM_TerminalArea.swapStack.myLocationsController;
		endif;																	// PAR #28047
	endif;
	return null;
end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
