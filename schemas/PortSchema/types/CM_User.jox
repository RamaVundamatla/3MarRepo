    <JadeMethod name="setProxy" id="74a320ac-0b2f-45c5-b9eb-eff6b8b29031">
        <updating/>
        <source>setProxy(pCode, pUserName : String; pStatus : Integer; pOrganisation : CM_Organisation; pRoot : CM_Root;
		 pPersistentPassword, pRadioTelemetryOnly, pIsNotAvailableForEntry, pAllowAutomaticDisability : Boolean; pLastLoginTS: TimeStamp; pDataAccessControllers : CM_DataAccessControllerSet;
		 _sysSecurityRole : CM_SecurityRoleSystem; _emailEntity : CM_EmailEntity;
		 _allEmailsICanSee : CM_EmailEntityByTypeNameDict;
		 _allSystemAlertTypes, _allEventTypes : Collection;
		 _locale : CM_Locale;
		 _userSingleSignOnOnly,
		 _userSingleSignOnAllowOverride : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     10 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/01/2001   cnwrs1      dont try and copy null collections
// 05/08/2021	navmd1		TFS 51226 Allow users with permission to force off old sessions
// ---------------------------------------------------------------------------
vars

	dac : CM_DataAccessController;

begin

	// This method should be used only to update transient
	self.raiseExceptionIfNotTransient(method);

	self.code 				:= pCode;
	self.myOrganisation 	:= pOrganisation;
	self.myRoot				:= pRoot;
	self.persistentPassword := pPersistentPassword;
	self.isNotAvailableForEntry := pIsNotAvailableForEntry;
	self.allowAutomaticDisability := pAllowAutomaticDisability; // cnwvu1	20/11/2006	ccms1051
	self.lastLoginTS 			:= pLastLoginTS; 			// cnwvu1	20/11/2006	ccms1051
	
	//self.radioTelemetryOnly := pRadioTelemetryOnly;	//GD removed dummy checkbox OCT01
	self.status 			:= pStatus;
	self.userName 			:= pUserName;
	self.myLocale           := _locale;

	self.mySystemSecurityRole := _sysSecurityRole;
	self.setUserSingleSignOnOnly(_userSingleSignOnOnly); //+ cnwmd1 Par 22287
	self.setUserSingleSignAllowOverride(_userSingleSignOnAllowOverride);	// TFS 51226
	
	//-------------------
	//Update the collections
	//-------------------
	self.allDataAccessControllers.clear;
	if pDataAccessControllers &lt;&gt; null then
		pDataAccessControllers.copy(self.allDataAccessControllers);
		dac := self.allDataAccessControllers[CM_Organisation.name];
		if dac &lt;&gt; null then
			if not dac.canAccess(self.myOrganisation) then
				app.raiseCMException2(Organ_data_acces_group_does_co, dac.name, self.myOrganisation.name, null, null);
			endif;
		endif;
	endif;
	self.myEmailEntity := _emailEntity;
	self.allEmailsICanSee.clear();
	_allEmailsICanSee.copy(self.allEmailsICanSee);
	if self.myEmailEntity &lt;&gt; null and (not self.allEmailsICanSee.includes(self.myEmailEntity)) then
		self.allEmailsICanSee.add(self.myEmailEntity);
	endif;
	
	self.allSystemAlertTypes.clear;
	if _allSystemAlertTypes &lt;&gt; null then
		_allSystemAlertTypes.copy(self.allSystemAlertTypes);
	endif;
	
	self.allEventTypes.clear;
	if _allEventTypes &lt;&gt; null then
		_allEventTypes.copy(self.allEventTypes);
	endif;
	
/*	
	self.allSecurityRoles.clear;
	if pSecurityRoles &lt;&gt; null then
		self.setSecurityRoles(pSecurityRoles);
		//pSecurityRoles.copy(self.allSecurityRoles);
	endif;
*/
end;</source>
        <Parameter name="pCode" type="String"/>
        <Parameter name="pUserName" type="String"/>
        <Parameter name="pStatus" type="Integer"/>
        <Parameter name="pOrganisation" type="CM_Organisation"/>
        <Parameter name="pRoot" type="CM_Root"/>
        <Parameter name="pPersistentPassword" type="Boolean"/>
        <Parameter name="pRadioTelemetryOnly" type="Boolean"/>
        <Parameter name="pIsNotAvailableForEntry" type="Boolean"/>
        <Parameter name="pAllowAutomaticDisability" type="Boolean"/>
        <Parameter name="pLastLoginTS" type="TimeStamp"/>
        <Parameter name="pDataAccessControllers" type="CM_DataAccessControllerSet"/>
        <Parameter name="_sysSecurityRole" type="CM_SecurityRoleSystem"/>
        <Parameter name="_emailEntity" type="CM_EmailEntity"/>
        <Parameter name="_allEmailsICanSee" type="CM_EmailEntityByTypeNameDict"/>
        <Parameter name="_allSystemAlertTypes" type="Collection"/>
        <Parameter name="_allEventTypes" type="Collection"/>
        <Parameter name="_locale" type="CM_Locale"/>
        <Parameter name="_userSingleSignOnOnly" type="Boolean"/>
        <Parameter name="_userSingleSignOnAllowOverride" type="Boolean"/>
    </JadeMethod>
