        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="7dee827f-d9da-4222-9af0-cdd68d9f277f">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
10 February 2010	cnwer1	Initial creation
20/04/2011			cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
							trying to create the proxy
02/09/2011			cnwdap1	PAR #25693 CCMS POL 2008 aded new attribute queuingRule
*/

vars
	pxyRTMoveMethod : CM_RTMoveMethodRule;
	completedOK		: Boolean;
begin
	pxyRTMoveMethod:= inheritMethod();

	pxyRTMoveMethod.myRTMoveMethod:=self.myRTMoveMethod;
	pxyRTMoveMethod.mySourceICArea:=self.mySourceICArea;
	pxyRTMoveMethod.myTargetICArea:=self.myTargetICArea;
	pxyRTMoveMethod.myRTQueueMultiRule:=self.myRTQueueMultiRule.pxyGetProxyObject;
	pxyRTMoveMethod.queuingRule:=self.queuingRule;		// PAR #25693
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyRTMoveMethod;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyRTMoveMethod;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="a9975c63-ea71-4986-931e-2ec36e0938d1">
        <updating/>
        <source>setForCreate(_proxy : CM_RTMoveMethodRule; _realRTQueueMultiRule : CM_RTQueueMultiRule ) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2010	cnwer1	Initial creation

*/

vars

begin
	self.myRTQueueMultiRule:=_realRTQueueMultiRule;
	self.setForUpdate(_proxy);

epilog

end;</source>
        <Parameter name="_proxy" type="CM_RTMoveMethodRule"/>
        <Parameter name="_realRTQueueMultiRule" type="CM_RTQueueMultiRule"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="330b9929-1813-4373-84d5-95fa778223a2">
        <updating/>
        <source>setForUpdate(_proxy : CM_RTMoveMethodRule) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2010	cnwer1	Initial creation
02 September 2011	cnwdap1	PAR #25693 CCMS POL 2008 added new queuingRule attribute, default to LegMoveQueuing if not supplied
*/

vars
	otherMoveMethodRule : CM_RTMoveMethodRule;
	sourceMachineType,
	targetMachineType : CM_MachineTypeGroup;
begin
	self.shortDescription:=_proxy.shortDescription;
	self.myRTMoveMethod:=_proxy.myRTMoveMethod;
	self.isDefault:=_proxy.isDefault;
	
	sourceMachineType:=app.myRoot.allMachineTypeGroups[MACHINETYPEGRP_SOURCEIC];
	if self.myRTMoveMethod.allMachineTypeGroups.indexOf(sourceMachineType) &gt; 0 then
		self.mySourceICArea:=_proxy.mySourceICArea;
	else
		self.mySourceICArea:=null;
	endif;
	
	targetMachineType:=app.myRoot.allMachineTypeGroups[MACHINETYPEGRP_TARGETIC];
	if self.myRTMoveMethod.allMachineTypeGroups.indexOf(targetMachineType) &gt; 0 then
		self.myTargetICArea:=_proxy.myTargetICArea;
	else
		self.myTargetICArea:=null;
	endif;
	
	
	if self.isDefault then
		foreach otherMoveMethodRule in self.myRTQueueMultiRule.allDefaultRTMoveMethodRules do
			if otherMoveMethodRule = self then
				continue;
			endif;
			otherMoveMethodRule.isDefault:=false;
		endforeach;
	endif;
	
	self.queuingRule := _proxy.queuingRule;		// PAR #25693
	if _proxy.queuingRule = null then			// PAR #25693
		self.queuingRule := LegMoveQueuing;		// PAR #25693
	endif;										// PAR #25693

epilog

end;</source>
        <Parameter name="_proxy" type="CM_RTMoveMethodRule"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="918e7980-6ed3-4cd2-a5b2-41f4c120b923">
        <updating/>
        <source>setProxy(_myRTQueueMultiRule : CM_RTQueueMultiRule;
			_myRTMoveMethod : CM_RTMoveMethod;
			_isDefault 		: Boolean;
			_shortDescription : String;
			_mySourceICArea : CM_InterchangeArea;
			_myTargetICArea : CM_InterchangeArea;
			_queuingRule : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 February 2010	cnwer1	Initial creation
02 September 2011	cnwdap1	PAR #@5693 CCMS POL 208 Added queuingRule attribute
*/

vars
	otherMoveMethodRule : CM_RTMoveMethodRule;
begin
	self.raiseExceptionIfNotTransient(method);
	self.myRTQueueMultiRule:=_myRTQueueMultiRule;
	self.myRTMoveMethod:=_myRTMoveMethod;
	self.isDefault:=_isDefault;
	if self.isDefault and   self.myRTQueueMultiRule&lt;&gt; null and self.myRTQueueMultiRule.isTransient then
		foreach otherMoveMethodRule in self.myRTQueueMultiRule.allDefaultRTMoveMethodRules do
			if otherMoveMethodRule = self then
				continue;
			endif;
			otherMoveMethodRule.isDefault:=false;
		endforeach;
	endif;
	
	self.shortDescription:=_shortDescription;
	self.mySourceICArea:=_mySourceICArea;
	self.myTargetICArea:=_myTargetICArea;
	
	// PAR #25693
	self.queuingRule := _queuingRule;
epilog	

end;</source>
        <Parameter name="_myRTQueueMultiRule" type="CM_RTQueueMultiRule"/>
        <Parameter name="_myRTMoveMethod" type="CM_RTMoveMethod"/>
        <Parameter name="_isDefault" type="Boolean"/>
        <Parameter name="_shortDescription" type="String"/>
        <Parameter name="_mySourceICArea" type="CM_InterchangeArea"/>
        <Parameter name="_myTargetICArea" type="CM_InterchangeArea"/>
        <Parameter name="_queuingRule" type="String"/>
    </JadeMethod>
    <JadeMethod name="setQueuingRule" id="7c0eb1c4-0867-47b0-b65d-a1a490430f76">
        <updating/>
        <source>setQueuingRule(_rule : String) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/09/2011	cnwdap1	Initial creation PAR #25693 CCMS POL 2008
*/
vars

begin
	self.queuingRule := _rule;
epilog

end;</source>
        <Parameter name="_rule" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateCreate" id="64f9c210-85ba-414f-b807-0ee8793ac4f1">
        <source>validateCreate(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	cnwer1	Initial creation

*/

vars
	sourceMachineType,
	targetMachineType : CM_MachineTypeGroup;
begin


	if self.myRTMoveMethod = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Machine Move Method', null, null);
		app.raiseCMException(Input_required_field_macMveMet, null, null); // cnwdb2	PAR 35364
		return;
	endif;

	if not self.myRTQueueMultiRule.isTATypeRule then
		sourceMachineType:=app.myRoot.allMachineTypeGroups[MACHINETYPEGRP_SOURCEIC];
		if self.myRTMoveMethod.allMachineTypeGroups.indexOf(sourceMachineType) &gt; 0 then
			if self.mySourceICArea = null then
			//	app.raiseCMException1(REQUIRED_FIELD, 'Source IC Area', null, null);
				app.raiseCMException(Input_required_field_sourceIC, null, null); // cnwdb2	PAR 35364
			endif;
		endif;
		
		targetMachineType:=app.myRoot.allMachineTypeGroups[MACHINETYPEGRP_TARGETIC];
		if self.myRTMoveMethod.allMachineTypeGroups.indexOf(targetMachineType) &gt; 0 then
			if self.myTargetICArea = null then
			//	app.raiseCMException1(REQUIRED_FIELD, 'Target IC Area', null, null);
				app.raiseCMException(Input_required_field_tarAraFld, null, null); // cnwdb2	PAR 35364
			endif;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateUpdate" id="b1a1ba22-fdb6-423f-9c60-008ccf3c2f7b">
        <source>validateUpdate(_passport: CM_Passport input);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 February 2010	cnwer1	Initial creation

*/

vars
	sourceMachineType,
	targetMachineType : CM_MachineTypeGroup;
begin
	if self.myRTMoveMethod = null then
		app.raiseCMException(Required_Machine_Move_Method, null, null);
		return;
	endif;

	if not self.myRTQueueMultiRule.isTATypeRule then
		sourceMachineType:=app.myRoot.allMachineTypeGroups[MACHINETYPEGRP_SOURCEIC];
		if self.myRTMoveMethod.allMachineTypeGroups.indexOf(sourceMachineType) &gt; 0 then
			if self.mySourceICArea = null then
				app.raiseCMException(Required_Source_IC, null, null);
			endif;
		endif;
		
		targetMachineType:=app.myRoot.allMachineTypeGroups[MACHINETYPEGRP_TARGETIC];
		if self.myRTMoveMethod.allMachineTypeGroups.indexOf(targetMachineType) &gt; 0 then
			if self.myTargetICArea = null then
				app.raiseCMException(Require_Target_IC, null, null);
			endif;
		endif;
	endif;

	if self.myRTQueueMultiRule.getDefaultRTMoveMethodRule = null then
		app.raiseCMException(Default_move_method_required ,null, null);
	endif;
	
	if self.myRTQueueMultiRule.allDefaultRTMoveMethodRules.size &gt; 1 then
		app.raiseCMException(More_Default_Move_Method,null, null);
	endif;

epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
