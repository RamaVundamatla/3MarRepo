    <JadeMethod name="xCreateDeckJobSheet" id="e0fd9717-6f45-429b-85da-cf615ab9f176">
        <source>xCreateDeckJobSheet(_vesselName, _voyageCode,_wpCode : String) : CM_VoyageDeckJobSheet;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 August 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars

	workPoints : ObjectArray;
	workPoint : CM_WorkPoint;
	voyage 		: CM_Voyage;
		vessel  : CM_Vessel;
operator : CM_Operator;
begin
	
	workPoint:=self.addWorkPoint(_wpCode, true);
	
	if workPoint = null then
		return null;
	endif;
	

	self.deleteVessel(_vesselName);
	operator := app.myRoot.allOperators["ANL"];
	vessel := self.addVesselLOLOholdsRORO(_vesselName,operator);
	
	if vessel = null then
		return null;
	endif;
	
	self.deleteVoyage(_voyageCode);
	voyage := self.addVoyageWithConRORO(_voyageCode, _vesselName, "ANL", "DOUG", null, 0, false, true);
	
	if voyage = null then
		return null;
	endif;
	
	create workPoints transient;
	workPoints.add(workPoint);
	
	app.myTrxUA.trxUpdateVoyageJobSheet(workPoints,voyage,CM_VoyageDeckJobSheet,app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings;
	
	return voyage.allJobSheets[workPoint.code].CM_VoyageDeckJobSheet;

epilog
	delete workPoints;
end;</source>
        <Parameter name="_vesselName" type="String"/>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_wpCode" type="String"/>
        <ReturnType type="CM_VoyageDeckJobSheet"/>
    </JadeMethod>
    <JadeMethod name="xSetupCargoForGCDC" id="314221b8-1b5a-439f-9a08-ae666ab22ce8">
        <source>xSetupCargoForGCDC(_voyage : CM_Voyage; _voyageDeck : CM_DeckVoyage; _slots : CM_LCArray io; _tis : CM_TIArray io);

/*

Purpose:		Setup the cargo for tCheckGetCargoDetailsCorrect	

Date			Who		Reason
06/09/2012 		cnwmh5	Initial creation

*/

constants
	
	CargoID						: String = "UTMDHYA0";

vars

	cargo						: CM_TrackedItem;
	port						: CM_Port;
	theSlot						: CM_LocationsController;
	locnDefnVoyage				: CM_ROROLocnDefnVoyage;
	bs							: CM_BlockStack;
	location					: CM_ROROLocnDefn;
	
	strs						: StringArray;
	
	idx							: Integer;
	portCode					: String;
	str							: String;
	
begin
	
	
	// initializations
	portCode := self.getTerminal().getConfig(PortDestCode).String;
	if portCode = null then
		portCode := "NZAKL";
	endif;
	port := app.myRoot.allPorts[portCode];
	self.assertNotNull(port);

	// setup ship cargo
	self.opts.purge;
	self.opts.addAssoc("CENum", "123");
	
	// set up the 20' slots we need to create
	create strs transient;
	strs.add("D40881");
	strs.add("D40831");
	strs.add("D40821");
	strs.add("D40871");
	strs.add("D40801");
	strs.add("D40851");
	strs.add("D40901");
	strs.add("D40902");
	strs.add("D40903");
	strs.add("D40904");
	strs.add("D40911");
	strs.add("D40951");
	strs.add("D40931");
	strs.add("D40932");
	strs.add("D40971");
	strs.add("D41081");
	strs.add("D41131");
	strs.add("D40981");
	strs.add("D41031");
	strs.add("D41161");
	strs.add("D41181");
	strs.add("D41191");
	strs.add("D41061");
	strs.add("D41011");

	idx := 1;
	
	foreach str in strs do
		location := _voyageDeck.allROROLocnDefnByCode[str];
		if location &lt;&gt; null then
			cargo := self.addContainerAtLocnDisch("UTMDHYA0" &amp; idx.padLeadingWith("0", 3), "U20G", "MT", TI_IMEX_STATUS_REMAINONBOARD, location.getLC(), port, _voyage);
			self.assertNotNull(cargo);
			self.deleteStops(cargo);
			idx := idx + 1;
		endif;
	endforeach;
	
	// set up the 40' slots we need to create
	strs.clear;
	strs.add("D40822");
	strs.add("D40823");
	strs.add("D40852");
	strs.add("D40841");
	strs.add("D40842");
	strs.add("D40843");
	strs.add("D40844");
	strs.add("D40991");
	strs.add("D41051");
	strs.add("D41062");
	strs.add("D41211");
	
	foreach str in strs do
		location := _voyageDeck.allROROLocnDefnByCode[str];
		if location &lt;&gt; null then
			cargo := self.addContainerAtLocnDisch("UTMDHYA0" &amp; idx.padLeadingWith("0", 3), "U40G", "MT", TI_IMEX_STATUS_REMAINONBOARD, location.getLC(), port, _voyage);
			self.assertNotNull(cargo);
			self.deleteStops(cargo);
			idx := idx + 1;
		endif;
	endforeach;
	
epilog

	delete strs;

end;</source>
