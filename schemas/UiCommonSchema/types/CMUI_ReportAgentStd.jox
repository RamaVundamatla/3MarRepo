    <JadeMethod name="doLoadScalers" id="e8498761-73e4-481d-b43b-58cea2e1e2b3">
        <source>doLoadScalers(_cmbScaler : CMUI_ComboBox input; _scalerCode : String) protected;
// ---------------------------------------------------------------------------
// Created:     05 January 2004	cnwth2
//
// Purpose:     Two combos here because both can be used in the same query
//			 
// ----------   ----------  --------------------------------------------------
vars
	userDict			: CM_UserByCodeDict;
begin
	if _cmbScaler = null then
		return;
	endif;
	
	userDict := app.myRoot.allUsers;
	
	_cmbScaler.listCollectionWithAny(userDict, ETRow_Code);
	
	if userDict[_scalerCode] &lt;&gt; null then
		_cmbScaler.text := _scalerCode;
	else
		_cmbScaler.text := Any_String;
	endif;
	
	self.setValueByName(ETRow_OrigScaler, _cmbScaler.text);

end;</source>
        <access>protected</access>
        <Parameter name="_cmbScaler" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_scalerCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadSealTypes" id="17293817-b4c8-41c6-ad44-2dd75cb16455">
        <source>doLoadSealTypes(_cmb : CMUI_ComboBox input; _sealType : String) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 September 2010	cnwndl1	Initial creation	Par 25608

*/

vars

	sealType : CM_SealType;
	index : Integer;
	
begin

	_cmb.clear();
	
	_cmb.addItem(Any_String);

	foreach sealType in app.myRoot.allSealTypes do
		index := _cmb.addItem(sealType.sealType);
		_cmb.itemObject[index] := sealType;
	endforeach;
	
	if _sealType = null then
		_cmb.listIndex := _cmb.findStringExact(1,Any_String);
	else
		_cmb.listIndex := _cmb.findStringExact(1,_sealType);
	endif;
	
	self.setValueByName(ETRow_SealType, _cmb.text);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_sealType" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadServiceGroup" id="eaf475e6-ae08-4fdd-8d3e-0215ae89182e">
        <source>doLoadServiceGroup( _cmbServiceGroup : CMUI_ComboBox input; _company : CM_Bank; _description : String ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 August 2010	cnwrd1	Initial creation
24 Sep 2024 navah1	Bug 23334: MTN - Service not defaulted on Invoice Rate Report  

*/

vars
	serviceGroup : CM_ServiceGroup;
	serviceNode:   CM_ServiceObject;
	theBank : CM_Bank;
	rootSG : CM_ServiceGroup;
begin

	_cmbServiceGroup.clear;

	if _company = null then 
		return;
	endif;
	
	theBank := _company;

	_cmbServiceGroup.addItem(Any_String);
	foreach serviceNode in theBank.serviceObjects 
		where serviceNode.isKindOf(CM_ServiceGroup) do
		
		rootSG := theBank.getRootServiceGroup();
		if serviceNode = rootSG then
		else
			_cmbServiceGroup.addItem(serviceNode.name);	
			_cmbServiceGroup.itemObject[_cmbServiceGroup.newIndex] := serviceNode;  //24.09.2024 navah1 #23334
		endif;
	endforeach;

	if _cmbServiceGroup.findString(1,_description) &lt;&gt; -1 then						//24.09.2024 navah1 #23334
		_cmbServiceGroup.text := _description; 	
	endif;
	
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_cmbServiceGroup" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_company" type="CM_Bank"/>
        <Parameter name="_description" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadServices" id="789b02d4-7f12-4c00-bb98-6eb1ff1ee8be">
        <source>doLoadServices(_cmbService : CMUI_ComboBox input; _bank : CM_Bank; _serviceGroup : CM_ServiceGroup; _description : String) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 August 2010	cnwrd1	Initial creation
03 Oct 2024 navah1	Bug 23334: MTN - Service not defaulted on Invoice Rate Report  

*/

vars
	serviceNode : CM_ServiceObject;
begin

	_cmbService.clear;
	
	if _bank = null and _serviceGroup = null then
		return;
	endif;
	
	_cmbService.addItem(Any_String);
		
	//if bank = null then load from selected service group
	if _serviceGroup &lt;&gt; null then
		
		foreach serviceNode in _serviceGroup.groupMembers do
			if serviceNode.isKindOf(CM_Service) then
				_cmbService.addItem(serviceNode.name);
				_cmbService.itemObject[_cmbService.newIndex] := serviceNode;	
			endif; 		
		endforeach;		
	
	//else load from bank
	elseif _bank &lt;&gt; null then
	
		foreach serviceNode in _bank.services do
			_cmbService.addItem(serviceNode.name);
			_cmbService.itemObject[_cmbService.newIndex] := serviceNode;	
		endforeach;
	endif;
	
	if _cmbService.findString(1,_description) &lt;&gt; -1 then	//24.09.2024 navah1 #23334
		_cmbService.text := _description;
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cmbService" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_serviceGroup" type="CM_ServiceGroup"/>
        <Parameter name="_description" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadShippingLines" id="4e53e104-70b9-4847-94aa-5dc8935e6723">
        <source>doLoadShippingLines(_combo :CMUI_ComboBox input; _shippingLine :String)protected;
// ---------------------------------------------------------------------------
// Created:     27 May 2009 by concms1
// Purpose:     Par 19768 - new shipping line parameter
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	terminal		: CM_Terminal;
	shippingLine, selected	: CM_ShippingLine;
	str				: String;
	index			: Integer;
	isDisplayByName : Boolean;
begin
	if _combo = null then
		return;
	endif;
	
	_combo.clear();
	_combo.addItem(Any_String);
	terminal := app.getMyTerminalDO_NOT_USE;	
	
	if terminal &lt;&gt; null then		
		isDisplayByName := terminal.getConfig(ComboByNameLine).Boolean;	
	endif;							
	
	foreach shippingLine in app.myRoot.allShippingLines do
		if isDisplayByName then
			index := _combo.addItemObject(shippingLine.description &amp; Tab &amp; shippingLine.code, shippingLine);
		else
			index := _combo.addItemObject(shippingLine.code &amp; Tab &amp; shippingLine.description, shippingLine);
			
		endif;
		
		if shippingLine.code = _shippingLine then
			selected := shippingLine;
		endif;
	endforeach;

	if selected &lt;&gt; null then
		_combo.listIndex := _combo.findObject(selected);
	else
		_combo.listIndex := 1;
	endif;

/*
	if _combo = null then
		return;
	endif;
	
	terminal := app.getMyTerminalDO_NOT_USE;	
	
	if terminal &lt;&gt; null then		
		_combo.isDisplayByName 	:= terminal.getConfig(ComboByNameLine).Boolean;	
	endif;							
	
	_combo.useDisplayCollection	:= true;	// so we can add an extra entry

	_combo.setTextForDisplayCollection (Any_String);
	
	if _shippingLine &lt;&gt; null then
		shippingLine := app.myRoot.allShippingLines[_shippingLine];
	else
		shippingLine := null;
	endif;
	
	if shippingLine &lt;&gt; null then
		_combo.listObject := shippingLine;
	else
		_combo.text := Any_String;
	endif;
	_combo.text := "";
	self.setValueByName(ETRow_ShippingLine, _combo.text);
	
	*/
end;</source>
        <access>protected</access>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_shippingLine" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadSourceLocation" id="f1ab821d-7023-4525-80d6-f20f078c297c">
        <source>doLoadSourceLocation(_op : CM_Operator; _srcLocationCode : String);
// ---------------------------------------------------------------------------
// Created:     18 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

	tmpCodeGroup 	: CM_CodesByCodeDict;
	code			: CM_Code;
	idx				: Integer;
	cmbSrc,
	cmbSubSrc,
	cmbSubSubSrc	: CMUI_ComboBox;
begin

	cmbSrc := self.myCmbSrcLocation;
	cmbSubSrc := self.myCmbSubSrc;
	cmbSubSubSrc := self.myCmbSubSubSrc;
	
	cmbSrc.clear();
	if _op &lt;&gt; null then
		tmpCodeGroup := _op.getAllSrcLocn;	
	endif;
	
	//load even if null so as to load an **Any** at the top
	cmbSrc.listCollectionWithAny(tmpCodeGroup, 'code');
	
	if tmpCodeGroup &lt;&gt; null and tmpCodeGroup[_srcLocationCode] &lt;&gt; null then
		cmbSrc.text := _srcLocationCode;
	else
		cmbSrc.text := Any_String;
	endif;
	
	cmbSubSrc.clear();
	cmbSubSubSrc.clear();
	
	cmbSubSrc.addItem(Any_String);
	cmbSubSubSrc.addItem(Any_String);
	
	self.setValueByName(ETRow_SrcLocation, cmbSrc.text);	
	self.setValueByName(ETRow_SrcSubLocation, Any_String);	
	self.setValueByName(ETRow_SrcSubSubLocation, Any_String);
	
	self.setValueByName(ETRow_Forest, cmbSrc.text);
	self.setValueByName(ETRow_Compartment, Any_String);
	self.setValueByName(ETRow_Stand, Any_String);
	

end;</source>
        <Parameter name="_op" type="CM_Operator"/>
        <Parameter name="_srcLocationCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadSourceSubLocation" id="4010115d-c125-425d-bdfd-55c13040d29e">
        <source>doLoadSourceSubLocation(_srcSubLocationCode : String);
// ---------------------------------------------------------------------------
// Created:     18 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	sourceLocation	: CM_SourceLocation;
	tmpCodeGroup 	: CM_CodesByCodeDict;
	code			: CM_Code;
	idx				: Integer;
	cmbSrc,
	cmbSubSrc,
	cmbSubSubSrc	: CMUI_ComboBox;

begin
	cmbSrc := self.myCmbSrcLocation;
	cmbSubSrc := self.myCmbSubSrc;
	cmbSubSubSrc := self.myCmbSubSubSrc;
	
	cmbSubSrc.clear();
	sourceLocation := cmbSrc.listObject.CM_SourceLocation;
	if sourceLocation &lt;&gt; null then
		tmpCodeGroup := sourceLocation.allSubLocations;
	endif;
	//load even if null so as to load an **Any** at the top
	cmbSubSrc.listCollectionWithAny(tmpCodeGroup, 'code');
	if tmpCodeGroup &lt;&gt; null and tmpCodeGroup[_srcSubLocationCode] &lt;&gt; null then
		cmbSubSrc.text := _srcSubLocationCode;
	else
		cmbSubSrc.text := Any_String;
	endif;
	
	cmbSubSubSrc.clear();	
	cmbSubSubSrc.addItem(Any_String);
	
	self.setValueByName(ETRow_SrcSubLocation, cmbSubSrc.text);	
	self.setValueByName(ETRow_SrcSubSubLocation, Any_String);	

end;</source>
        <Parameter name="_srcSubLocationCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadSourceSubSubLocation" id="cfc5c6f3-6fa2-4555-a007-6b237cac03f1">
        <source>doLoadSourceSubSubLocation(_srcSubSubLocation : String);
// ---------------------------------------------------------------------------
// Created:     18 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	sourceSubLocation	: CM_SourceSubLocation;
	tmpCodeGroup 		: CM_CodesByCodeDict;
	code				: CM_Code;
	idx					: Integer;
	cmbSrc,
	cmbSubSrc,
