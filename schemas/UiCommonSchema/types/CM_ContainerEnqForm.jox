    <JadeMethod name="updateHazardsFromDetailForm" id="73db0a1d-5d41-4a05-b9da-2bb24e9b942f">
        <updating/>
        <source>updateHazardsFromDetailForm(_hazDict : CM_HazardByCodeDict) : Boolean updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 15/11/2016	cnwdap1		Initial creation TFS 2842 STWR Hazardous Details Enhancements
// 29/05/2019	jlgdap1		TFS 43346 Correct hazard handling
//
vars
	obj : Object;
	str : String;
	tbl : CM_EntryTable;
	idx : Integer;
	entRowTrans : EntTableRowTransient;

begin
	
	// TFS 3249 handle bulk editing - myProxyObject already the hazards set from the maintenance form but the other selected item proxies
	//		need to be updated here
	if self.myProxyObject &lt;&gt; null and self.myProxyObject.isKindOf(CM_TrackedItem) then
		foreach obj in self.allProxyObjects where obj &lt;&gt; self.myProxyObject do
			obj.CM_TrackedItem.zSetPxyTIHazards(_hazDict);
		endforeach;
	endif;
	//epr TFS 47132 27/11/19 set straight from passed in coll the lstHaz on form not used
	foreach obj in _hazDict do
		if str &lt;&gt; null then
			str := str &amp; '; ';
		endif;
		
		str := str &amp; obj.CM_TIHazard.getTableDisplay(false, true);
	endforeach;
	
	tbl := self.getEditTableForSheet(self.fldEdit.topSheet.CMUI_Sheet);
	idx := tbl.getRowByName(ETRow_AllTIHazards);
	obj := tbl.accessRow(idx).itemObject;
	entRowTrans := obj.EntTableRowTransient;
	if entRowTrans.originalValue &lt;&gt; str then
		entRowTrans.hasChanged := true;
	endif;
	
	tbl.setValue(idx, str);
	tbl.doChangedComparison(idx);
	
	// TFS 43346 start
	if self.myProxyObject &lt;&gt; null and self.myProxyObject.isKindOf(CM_TrackedItem) then
		if self.myProxyObject.CM_TrackedItem.allChildren.isEmpty and self.myTerminal.getConfig(UseDetailedHazEntry).Boolean then
			idx := tbl.getRowByName(ETRow_AllTIHazardsNew);
			if idx &lt;&gt; null then
				tbl.setValue(idx, str);
				tbl.doChangedComparison(idx);
			endif;
		endif;
	endif;
	// TFS 44346 end
	
	return true;
epilog

end;</source>
        <Parameter name="_hazDict" type="CM_HazardByCodeDict"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateProgress" id="b1868971-229b-46a7-bd71-4be693962242">
        <updating/>
        <source>updateProgress(_cmifMonitor : CMIF_Monitor input) updating;
// ---------------------------------------------------------------------------
// Created:     08 April 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if (not self.frmModalDialog.visible) then
		return;
	endif;

	self.modalDialogShow(null, app.getErrorString(Cancel), null, null,
					_cmifMonitor.message,
					app.getErrorString(Searched)  &amp; ' ' &amp; _cmifMonitor.numSearched.String &amp; ' ' &amp; app.getErrorString(Found) &amp; ' ' &amp; _cmifMonitor.numFound.String);
	
	self.btnModalDefault.doWindowEvents(0);
	if self.modalDialogReturnValue = ModalDialogReturn_Null then
		// see if the user has pressed the Cancel button
		self.btnModalOpt1.doWindowEvents(0);
	endif;

	if self.modalDialogReturnValue &lt;&gt; ModalDialogReturn_Null then
		_cmifMonitor.monitorReturnValue := _cmifMonitor.MonitorReturnValue_Cancel;
	endif;

end;</source>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateProgressForBulkEdit" id="8b848fd2-e5fa-4b00-a399-911b4f2b963a">
        <source>updateProgressForBulkEdit(_cmifMonitor : CMIF_Monitor input);
// ---------------------------------------------------------------------------
// Created:     08 April 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 10/04/2024	navdap1		TFS 63307 EUP | Performance - Cargo Enquiry Bulk Updates
// ---------------------------------------------------------------------------
vars

begin
	self.pbProgressBar.partsInJob := _cmifMonitor.partsInJob;	
	self.pbProgressBar.partsDone := _cmifMonitor.partsDone;
	self.lblModalMessage.caption := _cmifMonitor.message;																		// TFS 63307
	if _cmifMonitor.message &lt;&gt; null and _cmifMonitor.message.pos('alid', 1) &lt;&gt; null then										// TFS 63307
		self.lblModalInfo.caption := 'Validated: ' &amp; _cmifMonitor.partsDone.String &amp; ' of ' &amp; _cmifMonitor.partsInJob.String;	// TFS 63307
	else																														// TFS 63307
		self.lblModalInfo.caption := 'Committed: ' &amp; _cmifMonitor.partsDone.String &amp; ' of ' &amp; _cmifMonitor.partsInJob.String;
	endif;																														// TFS 63307
	
	self.frmModalDialog.refreshNow();
	self.frmModalDialog.doWindowEvents(0);
	self.btnModalDefault.doWindowEvents(0);
	
	if self.modalDialogReturnValue &lt;&gt; ModalDialogReturn_Null then
		_cmifMonitor.monitorReturnValue := _cmifMonitor.MonitorReturnValue_Cancel;
	endif;

end;</source>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateTableColumnFilters" id="c2eecab9-b450-430e-bbac-4d722cd375d0">
