    <JadeMethod name="load" id="e1c9db04-16fe-4aad-9806-3c8e069a36ec">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

/*
Purpose:			

Return Value:		

Date		Who		Reason
18 Dec 2007	cnwkpd1	CCMS TWLENH 1018 - RF Gun Web Service
08 Nov 2017	jlgkpd1	Handle non JADE Web Services

*/

vars
	iPos1			: Integer;
	iPos2			: Integer;
	ws				: JadeWebServiceConsumer;
	url				: String;
	envStr			: String;
	tempStr			: String;
	
begin
	app.cnActivateKarmaControl(Cn_Fat_Client, null, null);
	
	create ws as app.getFirstConsumerClass transient;
	url := ws.getEndpointURL;
	
	iPos1 := url.pos("&amp;", 1);
	if iPos1 &gt; null then
		txtWebURL.text := url[1:iPos1 - 1];
	else
		txtWebURL.text := url;
	endif;
		
	// attempt to get the correct environment id.
	tempStr	:= app.dbPath();		// getJadeInstallDirAppServer();
	iPos1	:= tempStr.pos( 'mast', 1 );
	if iPos1 &gt; null then
		envStr	:= tempStr[ iPos1 - 1 : 1 ].toUpper;
		iPos2	:= url.pos( 'mast', 1 );
		if iPos2 &gt; null then
			txtWebURL.text	:= txtWebURL.text[ 1 : iPos2 - 2 ] &amp; envStr &amp; txtWebURL.text[ iPos2 : end ];
		endif;
	endif;
	
	self.loadServices();
	
	self.setDefaults();
	
epilog
	delete ws;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="loadOperations" id="92f1a6c6-80ff-4fac-9300-f77558330ca0">
        <source>loadOperations() protected;

/*

Purpose:			


Return Value:		


Date		Who		Reason
18 December 2007	cnwkpd1	CCMS TWLENH 1018 - RF Gun Web Service

*/

vars
	cls				: Class;
	methods			: MethodNDict;
	meth			: Method;
	
begin
	cmbOperation.clear;
	
	cls := cmbService.listObject.Class;
	if cls &lt;&gt; null then
		create methods transient;
		cls.getMethods(methods);
		foreach meth in methods where meth._rwGetNumberOfParameters = 1 and meth.isKindOf(JadeWebServicesMethod) do
			cmbOperation.itemObject[cmbOperation.addItem(meth.name)] := meth;
		endforeach;
	endif;
		
		
epilog
	delete methods;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadServices" id="3f44eee3-e4c0-4279-8ba2-3de4581ee0da">
        <source>loadServices() protected;

/*

Purpose:			


Return Value:		


Date		Who		Reason
18 December 2007	cnwkpd1	CCMS TWLENH 1018 - RF Gun Web Service

*/

vars
	cc				: ClassColl;
	cls				: Class;
	
begin
	create cc transient;
	currentSchema.getClass(JadeWebServiceConsumer.name).allLocalSubclasses(cc);
	
	cmbService.clear;
	foreach cls in cc do
		cmbService.itemObject[cmbService.addItem(cls.name)] := cls;
	endforeach;
	
	loadOperations;
	
	
epilog
	delete cc;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="logMessage" id="606876c8-cf73-4fa2-9be1-7b2a55ff7a4b">
