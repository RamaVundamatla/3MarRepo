    <JadeMethod name="doUpdateCrane" id="9c11f4f9-104a-4e11-a610-4b6812cc4ada">
        <updating/>
        <source>doUpdateCrane():Boolean updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2009	cnwndl1	Initial creation CCMS 1031 / Par 20474
20 February 2010	cnwas3 PAR 22429
08/04/2011	cnwmh5	PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
*/

vars

	ls : Boolean;
	controller : CMIF_OOWCraneUpdate;
	aTS : TimeStamp;
	aDate : Date;
	aTime : Time;
	theReturn : Integer;
	
begin

	
	app.mousePointer := Window.MousePointer_HourGlass;
	
	aDate := txtExchDate.getDate();
	aTime := txtExchTime.getTime();
	
	if aDate.isValid and self.myVoyage &lt;&gt; null and self.myVoyage.shipExchangeDate.isValid then
		aTS.setDate(aDate);
		aTS.setTime(aTime);
		if aTS &lt; self.myVoyage.shipExchangeDate then
			app.msgBox( app.getErrorString(Crane_start_date_prior_berth), app.getErrorString(Error), MsgBox_OK_Only + MsgBox_Stop_Icon);
			return false;
		endif;
	endif;
	
	create controller;
	controller.myWorkPoint := self.myWorkPoint;
	controller.myJobSheet := self.myVoyageJobSheet;
	controller.myVoyageStructure := self.myVoyage.myCellularVoyageStructure;
	controller.craneCPH := self.txtRatePH.text.Integer;
	controller.craneSeed := self.txtStartNum.text.Integer;
	controller.exchangeTS.setDate(aDate);
	controller.exchangeTS.setTime(aTime);
	
	if  self.myWorkPoint.isKindOf(CM_WorkPoint) then
		controller.craneRversed:=false;
		controller.targetRatePHLM:=self.txtRateLinear.text.Integer;
	else
		controller.craneRversed := cmbOrder.listData = 1;
	endif;
	while true do
		app.myTrxUA.trxUpdateVoyageOOWCrane(controller, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			theReturn := app.showErrorWarningDialog( app.getErrorString(OOW_Crane_update), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		break;
	endwhile;
	
	return true;
	
epilog
	delete controller;

	app.mousePointer := Window.MousePointer_Default;

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadData" id="bdbd4150-5f06-4b5b-bf4e-1479ae3dba8b">
        <source>loadData();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2009	cnwndl1	Initial creation CCMS 1031 / Par 20474

*/

vars

	aJS : CM_VoyageJobSheet;
	aTS : TimeStamp;
	crID : String;
	
begin

	if self.myWorkPoint &lt;&gt; null then
		aTS := self.myVoyageJobSheet.workStarted;
		if self.myWorkPoint.isKindOf(CM_WorkPoint) and self.myWorkPoint.CM_WorkPoint.hasDefinedCargoRates then	//08 Mar 2017	NDL	TFS 37437
			txtRatePH.text := self.myWorkPoint.CM_WorkPoint.getDefinedTargetRateWeight( self.myVoyageJobSheet ).asStringJMT;
		else
			txtRatePH.text:=self.myWorkPoint.IF_VoyageWorkPoint.getTargetRatePH.asStringJMT;
		endif;
		txtExchDate.setDate(aTS.Date);
		txtExchTime.setTime(aTS.Time);
		txtStartNum.text:=self.myWorkPoint.IF_VoyageWorkPoint.getJobSeed.asStringJMT;
		if self.myWorkPoint.isKindOf(CM_WorkPoint) then
			
			self.lblOrder.visible:=false;
			self.cmbOrder.visible:=false;
			self.lblRateLinear.visible:=true;
			self.txtRateLinear.visible:=true;
			if self.myWorkPoint.CM_WorkPoint.hasDefinedCargoRates then	//08 Mar 2017	NDL	TFS 37437
				self.txtRateLinear.text := self.myWorkPoint.CM_WorkPoint.getDefinedTargetRateStr( self.myVoyageJobSheet );
			else
				self.txtRateLinear.text:=self.myWorkPoint.CM_WorkPoint.targetRatePHLM.asStringJMT;
			endif;
		else
			cmbOrder.setIndexForItemData( self.myVoyageJobSheet.getCraneDir );
		endif;
	else
		txtRatePH.text:=null;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setBaseData" id="37b6e8f9-f3f6-4de8-b48b-364f1c2168c9">
        <updating/>
        <source>setBaseData( _workPoint : CM_Object; _voyage : CM_Voyage; _voyageJobSheet : CM_VoyageJobSheet )updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2009	cnwndl1	Initial creation CCMS 1031 / Par 20474

*/

vars

begin

	self.myWorkPoint := _workPoint;
	self.myVoyageJobSheet := _voyageJobSheet;
	self.myVoyage := _voyage;
	
epilog

end;</source>
        <Parameter name="_workPoint" type="CM_Object"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_voyageJobSheet" type="CM_VoyageJobSheet"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="cb0d0947-5688-4af5-a37c-591708882516">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2009	cnwndl1	Initial creation CCMS 1031 / Par 20474
6 April 2011	cnwrs2	remove Next button as never used.

*/

vars
	idx : Integer;
	ctrl : Control;
	
begin
	
	inheritMethod;

	self.cmbOrder.clear();
	self.cmbOrder.addItemWithData(CM_VoyageJobSheet.Crane_FwdAftString, CM_VoyageJobSheet.Crane_FwdAft);
	self.cmbOrder.addItemWithData(CM_VoyageJobSheet.Crane_AftFwdString, CM_VoyageJobSheet.Crane_AftFwd);
	self.setCaption( self.myWorkPoint.IF_VoyageWorkPoint.getTypeDescription&amp;  " " &amp; self.myWorkPoint.IF_VoyageWorkPoint.getID );
	
	self.loadData();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="45d06a38-b4be-4058-8bf9-d1c09764714a">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 August 2018 15:37:39.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022913, locale);
	btnDefault.translateBubbleHelp(Xlat_0016700, locale);
	btnDefault.translateCaption(Xlat_0016701, locale);
	lblExchange.translateCaption(Xlat_0016702, locale);
	lblJobNum.translateCaption(Xlat_0016703, locale);
	lblOrder.translateCaption(Xlat_0016704, locale);
	lblRateLinear.translateCaption(Xlat_0016705, locale);
	lblRatePH.translateCaption(Xlat_0016706, locale);
end;</source>
    </JadeMethod>
</GUIClass>
