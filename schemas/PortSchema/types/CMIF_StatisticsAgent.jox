/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 March 2009	cnwjk3	Initial creation

*/

vars

begin
	if not _lc.isStrictGrid() then
		return 0;
	elseif _lc.is20ft then
		return 0;
	elseif _lc.is30ft then
		return _lc.offset30;
	elseif _lc.is40ft then
		return _lc.offset40;
	elseif _lc.is45ft then
		return _lc.offset45;
	elseif _lc.is53ft then
		return _lc.offset53;
	else
		return -1;
	endif;
epilog

end;</source>
        <Parameter name="_lc" type="CM_GridController"/>
