<Class name="CM_StockMoveLocation" id="5d9ae252-718c-43d1-962e-861345fedd63">
    <superclass name="CM_StockMoveBucket"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="stkmove"/>
    <ExplicitInverseRef name="myLocationsController" id="89f0ee22-1689-44b2-b5b3-f5a637d57b0b">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_LocationsController"/>
        <access>readonly</access>
        <Inverse name="CM_LocationsController::allStockMovesByDateProduct"/>
        <Inverse name="CM_LocationsController::allStockMovesByProductDate"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="mySOHLocation" id="5e6611d3-d6ed-4a70-8e30-b6edfeca28e6">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_SOHLocation"/>
        <access>readonly</access>
        <Inverse name="CM_StockOnHand::allStockMovementsByDate"/>
    </ExplicitInverseRef>
    <JadeMethod name="getStockMovementClass" id="e869942b-f81a-4b2e-a94b-3f2353c590d7">
        <source>getStockMovementClass() : Class protected;
//--------------------------------------------------------------
//Created: 30 September 2002 By: cnwgd1
//--------------------------------------------------------------
begin

	return CM_StockMovementLocation;

end;</source>
        <access>protected</access>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="init" id="c7a1f826-9100-47df-ab43-fe15789f6016">
        <updating/>
        <source>init(_date: Date; _openingQuantity: Integer; _openingWeight: Decimal; _openingVolume: Real; _parent: CM_Object) updating;
// ---------------------------------------------------------------------------
// Created:     26 July 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_date, _openingQuantity, _openingWeight, _openingVolume, _parent);
	
	self.mySOHLocation	:= _parent.CM_SOHLocation;
	self.myLocationsController	:= self.mySOHLocation.myLocationsController;

end;</source>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_openingQuantity" type="Integer"/>
        <Parameter name="_openingWeight" type="Decimal"/>
        <Parameter name="_openingVolume" type="Real"/>
        <Parameter name="_parent" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="product" id="1acaefb3-11f8-44fa-aee0-2ca804eccc41">
        <methodInvocation>mapping</methodInvocation>
        <source>product(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:     02 August 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(Class.name, method.name);

	else
		if self.mySOHLocation &lt;&gt; null then
			if self.mySOHLocation.myProduct &lt;&gt; null then
				_value  := self.mySOHLocation.myProduct.code;
			endif;
		endif;
	endif;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="productType" id="f6ead54d-3f90-43ca-8bf2-8f39a6b44df2">
        <methodInvocation>mapping</methodInvocation>
        <source>productType(set: Boolean; _value: Integer io) mapping;
//--------------------------------------------------------------
//Created: 09 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(Class.name, method.name);

	else
		if self.mySOHLocation &lt;&gt; null then
			if self.mySOHLocation.myProduct &lt;&gt; null then
				_value  := self.mySOHLocation.myProduct.cargoType;
			endif;
		endif;
	endif;


end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
</Class>
