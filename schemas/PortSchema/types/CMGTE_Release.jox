    <JadeMethod name="setPXYFromBulkRelease" id="93ac4a1c-8e69-40c9-927a-b17667b3794c">
        <updating/>
        <source>setPXYFromBulkRelease(_bulkReleaseObj : CM_BulkRelease; _rd : CM_ReserveDetail) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 June 2009	cnwjk3	Initial creation
14/10/2010	cnwmh5	PAR 21854 - Check release object to see if release by id or type
					rather than form only, as if was release by id and changed on the 
					form to be change by type then caused 1086 error.
*/

vars

begin
	//14/01/2010 cnwmh5 #21854 - Start
	if _bulkReleaseObj.releaseByType then
		if self.isReleaseById then
			// need to delete something on pxy ???
			if self.myReserveDetail &lt;&gt; null then
				if self.myReserveDetail.isTransient then
					delete self.myReserveDetail;
				endif;
				self.myReserveDetail := null;
			endif;
		endif;
		self.setPXYFromBulkReleaseByType(_bulkReleaseObj, _rd.CM_ReserveSelection);	
	else
		// _bulkReleaseObj us a release by id
		if (not self.isReleaseById) then
			// need to delete something on pxy ???
			if self.myReserveDetail &lt;&gt; null then
				if self.myReserveDetail.isTransient then
					delete self.myReserveDetail;
				endif;
				self.myReserveDetail := null;
			endif;
		endif;
		self.setPXYFromBulkReleaseById(_bulkReleaseObj, _rd);
	endif;
	
	/*
	if self.isReleaseById then
		self.setPXYFromBulkReleaseById(_bulkReleaseObj, _rd);
	else
		self.setPXYFromBulkReleaseByType(_bulkReleaseObj, _rd.CM_ReserveSelection);	
	endif;
	*/
	//14/01/2010 cnwmh5 #21854 - End
	
epilog

end;</source>
        <Parameter name="_bulkReleaseObj" type="CM_BulkRelease"/>
        <Parameter name="_rd" type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="setPXYFromBulkReleaseById" id="6baf367c-e36f-4adc-a210-537b7fbc8d81">
        <updating/>
        <source>setPXYFromBulkReleaseById(_bulkRelease : CM_BulkRelease; _reserveDetail : CM_ReserveDetail) protected, updating;

/*

Purpose:			Set proxy values for Release by Id from Bulk Release.
					This method is based on CMIF_ReleaseById::setFromBulkRelease however it obtains
					the information from the Bulk Release / ReserveDetail rather than Yard Request.

Parameters:			

Return Value:		


Date		Who		Reason
16 Jun 2009	cnwjk3	Initial creation
17 Sep 2009	consw1	Revised to obtain info from Bulk Release/ReserveDetail.
17/12/2009	cnwmh5	PAR 21843 - Test that ISO Type not null - non container

*/

vars
	tmpISOType	: CM_ISOType;
begin
	if _bulkRelease = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_bulkRelease', null, null);
		return;
	elseif _reserveDetail = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_reserveDetail', null, null);
		return;
	endif;
	
	self.myTerminal				:= _bulkRelease.myTerminal;
	self.consigneeCode			:= _bulkRelease.consigneeCode;
	self.myBulkRelease			:= _bulkRelease;
	self.myReserveDetail		:= _reserveDetail;

	self.freightForwarderCode	:= null;
	if _bulkRelease.myFreightForwarder &lt;&gt; null then
		self.freightForwarderCode := _bulkRelease.myFreightForwarder.code;
	endif;
	self.freightPayerCode		:= _bulkRelease.freightPayerCode;
	self.removeStops			:= false;
	//self.ignoreWarnings			:=	true;

	self.consignorVoyageCode	:= _bulkRelease.consignorVoyageCode;
	self.deliveryReason			:= _bulkRelease.deliveryReasonDescr;  	// was CM_YardRequest::reasonCodeDescr
	self.doorsDirection			:= _bulkRelease.doorsDirection;
	self.eirNumber				:= null;								// looks like this was not set up in CM_YardRequest
	self.needCOU				:= false;								// looks like this was not set up in CM_YardRequest
	self.needGenerator			:= false;								// looks like this was not set up in CM_YardRequest
	self.remarks				:= _bulkRelease.cargoRemarks;			//cnwmc5 - 19 May 2014 - PAR 34173

	// 17/12/2009 cnwmh5 #21843 - Start
	///self.isoType := _reserveDetail.getISOType().code; //set this here , cnwrd1 par 20993 9/10/09
	tmpISOType := _reserveDetail.getISOType();
	if tmpISOType &lt;&gt; null then
		self.isoType := tmpISOType.code;
	endif;
	//17/12/2009 cnwmh5 #21843 - End
	
/* Commented out by consw1 1/9/2009
	if _reserveDetail.allTrackedItems.size &gt; 1 then
		app.msgBox("Unexpected Error Occurred","Unexpected Error Occurred",0);
	endif;	
	if _reserveDetail.allTrackedItems.size = 1 then
		self.id := _reserveDetail.allTrackedItems.first().id;
		self.cargoType := _reserveDetail.allTrackedItems.first().cargoType;
	endif;
*/
	self.setDeliveryReleaseNumber(_bulkRelease);						// 30/11/2010 cnwmh5 #26400
	/*
	self.deliveryReleaseNumber := _bulkRelease.deliveryReleaseNumber;
		
	//not sure if this is correct
	//cnwjo3
	self.deliveryReleaseNumber := _bulkRelease.code;
	*/
	
	if _reserveDetail &lt;&gt; null then
		self.myBookingRefItem := _reserveDetail.myBookingRefItem;//cnwas3 PAR 20941
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
    </JadeMethod>
    <JadeMethod name="setPXYFromBulkReleaseByType" id="9fffda80-140a-430a-b9e8-3fa4edbfbf48">
        <updating/>
        <source>setPXYFromBulkReleaseByType(_bulkRelease : CM_BulkRelease; _reserveDetail : CM_ReserveSelection) protected, updating;

/*

Purpose:			Set proxy values for Release by Type from Bulk Release.
					This method is based on CMIF_ReleaseByType::setFromBulkRelease however it obtains
					the information from the Bulk Release / ReserveDetail rather than Yard Request.
Parameters:			

Return Value:		


Date		Who		Reason
16 Jun 2009	cnwjk3	Initial creation
17 Sep 2009	consw1	Revised to obtain info from Bulk Release/ReserveDetail.

*/

vars
	allStringsObj	: HugeStringArray;
	
begin
	if _bulkRelease = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_bulkRelease', null, null);
		return;
	elseif _reserveDetail = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_reserveDetail', null, null);
		return;
	endif;
	
	_reserveDetail.allAvailabilityGrades.copy(self.allAvailabilityGrades);
	
	self.myTerminal				:= _bulkRelease.myTerminal;
	self.consigneeCode			:= _bulkRelease.consigneeCode;
	self.myBulkRelease			:= _bulkRelease;
	self.myReserveDetail		:= _reserveDetail;
	
	self.myCargoType 			:= _reserveDetail.getCargoType();
	
	self.freightForwarderCode	:= null;
	if _bulkRelease.myFreightForwarder &lt;&gt; null then
		self.freightForwarderCode := _bulkRelease.myFreightForwarder.code;
	endif;
	self.freightPayerCode		:= _bulkRelease.freightPayerCode;
	self.setDeliveryReleaseNumber(_bulkRelease);					// 30/11/2010 cnwmh5 #26400
	///self.deliveryReleaseNumber	:= _bulkRelease.code;
	self.removeStops			:= false;
	//self.ignoreWarnings			:= true;
	
	self.myOperatorGroup		:= _bulkRelease.myOperatorGroup;
	self.operatorGroupCode		:= null;
	if self.myOperatorGroup &lt;&gt; null then
		self.operatorGroupCode	:= self.myOperatorGroup.code;
	endif;
	self.operatorCode			:= null;
	if _bulkRelease.myOperator &lt;&gt; null then
		self.operatorCode		:= _bulkRelease.myOperator.code;
	endif;
	
	self.numItems				:= 1;
	
	self.consignorVoyageCode	:= _bulkRelease.consignorVoyageCode;
	self.deliveryReason			:= _bulkRelease.deliveryReasonDescr;  	// was CM_YardRequest::reasonCodeDescr
	self.doorsDirection			:= _bulkRelease.doorsDirection;
	self.eirNumber				:= null;								// looks like this was not set up in CM_YardRequest
	self.needCOU				:= false;								// looks like this was not set up in CM_YardRequest
	self.needGenerator			:= false;								// looks like this was not set up in CM_YardRequest
	self.remarks				:= _reserveDetail.remarks;				//cnwmc5 - 19 May 2014 - PAR 34173
	self.canBeHiLoCube			:= _bulkRelease.canBeHiLoCube;			// May 2011 cnwjre1 27097 POL CCMS 2043

	self.clean					:= _reserveDetail.clean;
	self.heavyRated				:= _reserveDetail.heavyRated;
	self.idMask					:= _reserveDetail.getIdsAsString();
	self.isoType 				:= _reserveDetail.getISOTypeCode();
	
	if _reserveDetail &lt;&gt; null then
		self.myBookingRefItem := _reserveDetail.myBookingRefItem;//cnwas3 PAR 20941
	endif;
	
	/*
	create allStringsObj transient;
	_reserveDetail.maskIds.getStrings(allStringsObj);
	allStringsObj.copy(self.ids);
	*/
	// cnwrd1 13.01.10 maskIds can be null.
	create allStringsObj transient;
	if _reserveDetail.maskIds &lt;&gt; null then
		_reserveDetail.maskIds.getStrings(allStringsObj);
		allStringsObj.copy(self.ids);
	endif;
		
epilog
	delete allStringsObj;
end;</source>
        <access>protected</access>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
        <Parameter name="_reserveDetail" type="CM_ReserveSelection"/>
    </JadeMethod>
    <JadeMethod name="setPXYFromController" id="82d4d58e-02cc-457f-842d-03c6a7ba0f91">
        <updating/>
        <source>setPXYFromController(_flexi : CMIF_FlexiGateController) updating;
// ---------------------------------------------------------------------------
// Created:     19 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 14/12/2016		cnwdap1			TFS 3039 SNO Empty Container Pool Management
// 14/11/2019		jlgsl4			TFS 47373 - PEN - Save-Next prevents use of Remarks Additional
// 02/10/2020	    cnwma1 			ChangeRequest 50112: ASPA - GCI Stevedores
// 22/04/2024		jlizm1			TFS 62856 Shipment Number field
// 19/07/2024		navpw1			TFS: 61525 (61527) - Added vbsti as it is populated from the flexi gate controller
// ---------------------------------------------------------------------------

vars
	subTerminal : CM_SubTerminal;
begin

	inheritMethod(_flexi);

	// This needs to be configurable
	
	self.myBulkRelease := _flexi.myBulkRelease;
	self.myReserveDetail := _flexi.myReserveDetail;
	
	// cnwjk3 not sure why we are setting this to null here.  Setting it to null attemps to re-apply the 
	// delivery release stop, which causes numerous problems.
	self.setDeliveryReleaseNumber(_flexi);									// 30/11/2010 cnwmh5 #26400

	if self.myReserveDetail &lt;&gt; null then
		self.myBookingRefItem := self.myReserveDetail.myBookingRefItem;//cnwas3 PAR 20941
	endif;

	self.importReleasePIN 		:= _flexi.importReleasePIN;
	self.bookingReference 		:= _flexi.bookingNumber;
	//self.updateRemarks 			:= _flexi.updateRemarks;		//cnwmc5 - 19 May 2014 - PAR 34173
	self.mtOnly 				:= _flexi.mtOnly;
	self.consignorVoyageCode 	:= _flexi.consignorVoyageCode;
	self.deliveryReason 		:= _flexi.deliveryReason;
	self.consigneeCode 			:= _flexi.consigneeCode;
	self.isoType 				:= _flexi.isoTypeCode;
	self.isoGroup 				:= _flexi.isoGroup;
	self.imexStatus 			:= _flexi.imexStatus;
	self.updateConsigneeCode 	:= _flexi.updateConsigneeCode;
	self.myTransferToTerminal 	:= _flexi.myTransferToTerminal;
	self.customEntryNumber 		:= _flexi.customEntryNumber;
	
	self.cargoType 			:= _flexi.cargoType;	
	self.myCargoType 		:= app.myRoot.allCargoTypesById[_flexi.cargoType];
	self.colour 			:= _flexi.colour;
	self.yardInstructions 	:= _flexi.yardInstructions;
	self.remarks 			:= _flexi.remarks;
	self.density 			:= _flexi.density;
	self.canBeHiLoCube 		:= _flexi.canBeHiLoCube;	// May 2011 cnwjre1 27097 POL CCMS 2043

	if self.subTerminalCode &lt;&gt; null then
		subTerminal := self.myTerminal.allSubTerminals[self.subTerminalCode];	
		
		if subTerminal &lt;&gt; null then
			self.mySubTerminalSource := subTerminal;
		else
			self.mySubTerminalSource := null;
		endif;
	endif;

	self.billOfLading		:= _flexi.billOfLading;
	self.myBOLDtl := _flexi.myBOLDtl;	//08 Oct 2020	NDL	TFS 49189
	self.subTerminalCode 	:= _flexi.subTerminalCode;
	self.operatorGroupCode 	:= _flexi.operatorGroupCode;
	self.numItems 			:= _flexi.numItems;
	self.totalQuantity 		:= _flexi.numItems; //cnwrd1 ccms 2274 do this for now 
	self.doISOGroupCheck 	:= _flexi.doISOGroupCheck;  //can be for best pick - cnwrd1 
	self.isFIFO 			:= _flexi.isFIFO;  //cnwrd1 par 24169 9.6.2010
	
	self.clean 		:= _flexi.clean;
	self.heavyRated := _flexi.heavyRated;
	self.idMask 	:= _flexi.idMask;
	self.clientRef 	:= _flexi.clientRef; //cnwrd1 par 23337 20.5.2010 

	self.ids.clear();
	
	_flexi.allAttachmentIDs.copy(self.ids);
	
	self.allAvailabilityGrades.clear();
	
	_flexi.allAvailabilityGrades.copy(self.allAvailabilityGrades);
	
	// added for release full by type
	self.commodity := _flexi.commodity;

	// Must be a chassis
	if _flexi.myChassisType &lt;&gt; null then
		self.myCargoType 	:= _flexi.myChassisType.myCargoType;
		self.cargoType		:=self.myCargoType.id; //epr PAR 21011 7/10/09 	
		self.myTILCType 		:= _flexi.myChassisType;
		self.bookingReference 	:= null;
		self.myBookingRefItem 	:= null;
	endif;
	
	// TFS 3039 If this is a release with a pool party, update operator and booking			// TFS 3039
	if self.myBulkRelease &lt;&gt; null and self.myBulkRelease.myPoolingParty &lt;&gt; null then		// TFS 3039
		self.operatorCode := self.myBulkRelease.getOperatorCode;							// TFS 3039
		if self.myBulkRelease.myBookingRefStock &lt;&gt; null then								// TFS 3039
			self.bookingReference := self.myBulkRelease.myBookingRefStock.bookingReference;	// TFS 3039
		endif;																				// TFS 3039
	endif;																					// TFS 3039
	
	self.myTrackedItem		:= _flexi.myTrackedItem;
	self.remarksAdditional1 := _flexi.remarksAdditional1; // TFS 47373
	self.remarksAdditional2 := _flexi.remarksAdditional2; // TFS 47373
	self.shipmentNumber		:= _flexi.shipmentNumber;	  // TFS 62856
	self.stevedoreCode      := _flexi.stevedoreCode;      //02.10.2020 cnwma1 TFS #50112
	
	self.releaseWeight		:= _flexi.releaseWeight;	//13.Dec.2023 navsp1 TFS 61547
	self.releaseQuantity	:= _flexi.releaseQuantity;  //13.Dec.2023 navsp1 TFS 61547
	self.myVbsti			:= _flexi.myVbtsi;			// ### TFS 61525 (61527) 18Jul2024 NAVPW1
	
epilog

end;</source>
        <Parameter name="_flexi" type="CMIF_FlexiGateController"/>
    </JadeMethod>
    <JadeMethod name="setPxyFromTI" id="0c7ceeb0-e8a5-4bb1-bfb8-3dc8864e1401">
        <updating/>
        <source>setPxyFromTI(_ti : CM_TrackedItem) updating;
/*

Date		Who		Reason
10 July 2014	cnwer1	Initial creation PAR

*/

vars

begin
	
	if _ti = null then
		return;
	endif;
	
	inheritMethod(_ti);
	self.setIsReleaseById(true);
	self.setMyTrackedItem(_ti);
	self.myCargoType:=_ti.myCargoType;
	self.cargoType:=self.myCargoType.id;
	self.imexStatus := _ti.getImExStatus;
	self.numItems:=1;
	if _ti.isKindOf(CM_TILC) then	
		self.myTILCType:=_ti.CM_TILC.myTILCType;
		self.jobType:=self.JobType_ChassisOut;
		self.isChassisOut:=true;
	endif;
	self.consigneeCode		 		:= _ti.consignee;
	self.commodity:=_ti.commodity;
	if _ti.isContainer then
		self.isoType 				:= _ti.CM_Container.isoType;
		self.isoGroup 				:= _ti.CM_Container.isoGroup;	
		if _ti.isEmpty then	
			self.jobType:=self.JobType_EmptyOUT;
			self.mtOnly 				:= true;
		else
			self.jobType:=self.JobType_FullOUT;
		endif;
	else	//16 Oct 2015	NDL	Par 37033
		self.jobType := self.JobType_GeneralOUT;
		self.totalQuantity := _ti.totalQuantity;
	endif;
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
