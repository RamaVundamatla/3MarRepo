    <JadeMethod name="setupThumbnailDetails" id="989f61ea-3e64-4d64-86f3-c779c70f4e27">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 October 2020	jlgndl1	Initial creation	TFS 49189

*/

vars

	theForm : SOP_TableMaintForm;
	
begin
	
	theForm := self.myForm;
  	theForm.tblData.userInputEnabled := false;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_CodeMaint);
	theForm.tblData.hideColumnByColName(ETRow_NotAvailableForEntry);
	
	theForm.shtTblInput1.caption := app.getErrorString(CM_Details);
	theForm.initTblInput(theForm.tblInput1, ETDef_CodeMaint);
	theForm.tblInput1.hideRowByName(ETRow_NotAvailableForEntry,false);
	theForm.shtTblInput1.visible := true;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="6ce582be-d014-48b3-a288-d124a5fd53c8">
        <updating/>
        <source>showThumbnail(pObj: CM_RoadProcess) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 October 2020	jlgndl1	Initial creation	TFS 49189

*/

vars

	theForm : SOP_TableMaintForm;

begin
  
    theForm := self.myForm;
	theForm.tblInput1.clearValues;
	theForm.tblInput1.setValueByName(ETRow_Code, pObj.code);
	theForm.tblInput1.setValueByName(ETRow_Description,	pObj.description);
	
end;</source>
        <Parameter name="pObj" type="CM_RoadProcess"/>
    </JadeMethod>
</Class>
