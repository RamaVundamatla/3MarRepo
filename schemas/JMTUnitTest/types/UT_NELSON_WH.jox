    <JadeMethod name="uFixupRServeSelections" id="d5715437-ea1b-41c8-83b4-50b3d608d827">
        <source>uFixupRServeSelections();
//17 February 2009	cnwdw1	
//
vars
	br: CM_BulkRelease;
	rs: CM_ReserveSelection;
begin

	br := self.getReleaseRequest("BR104");
	rs := br.allReserveDetails.first.CM_ReserveSelection;
	
	beginTransaction;
	rs.allTrackedItemsReleased.clear;
	commitTransaction;
	
	
end;</source>
    </JadeMethod>
