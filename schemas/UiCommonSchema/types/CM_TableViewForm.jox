end;</source>
        <Parameter name="_numItems" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="addToolbarControls" id="48b6ab13-3e1b-4732-bf33-586e41addb13">
        <source>addToolbarControls() protected;
// ---------------------------------------------------------------------------
// Created:     21 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 29 Aug 2014	NDL	Par 34737 - Remove conditional add of some buttons. 
vars
	toolbar			: CMUI_Toolbar;
	showCaptions	: Boolean;

begin

	toolbar := self.frmToolbar;
	
	// Hide print and export buttons for Yard Allocation Template Enquiry form and Overstow form
	if not self.isKindOf(CMUI_YATemplateEnqForm) and not self.isKindOf(CMUI_YAOverstowRules) then
		if self.allowPrint then
			toolbar.addButton(self.btnPrintTV, CMUI_Toolbar.Control_Alignment_Left);
		endif;
		
		if self.allowExportCSV then
			toolbar.addButton(self.btnExportCSVTV, CMUI_Toolbar.Control_Alignment_Left);
		endif;
	
		if self.allowPrint or self.allowExportCSV then
			toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
		endif;
	endif;
	
	if self.allowSearch then
		toolbar.addButton(self.btnShowSearchTV, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
//	if self.allowAdd then
		toolbar.addButton(self.btnNewTV, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnNewWc, CMUI_Toolbar.Control_Alignment_Left);	// 07 Aug 2009 NDL
//	endif;
	
//	if self.allowUpdate then
		toolbar.addButton(self.btnEditTV, CMUI_Toolbar.Control_Alignment_Left);
		toolbar.addButton(self.btnEditWc, CMUI_Toolbar.Control_Alignment_Left);	// 07 Aug 2009 NDL
//	endif;
	
//	if self.allowUpdate or self.allowAdd then
		toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
		if self.allowNext then
			toolbar.addButton(self.btnNextTV, CMUI_Toolbar.Control_Alignment_Left);
		endif;
		toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
//	endif;
	
	if self.allowDelete then
		toolbar.addButton(self.btnDeleteTV, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	if self.allowSelectAll then
		toolbar.addButton(self.btnSelectAllTV, CMUI_Toolbar.Control_Alignment_Left);
	endif;
	
	showCaptions := toolbar.showCaptions;
	
	//=======================================
	// now setup searchToolbar
	//=======================================
	toolbar := self.frmSearchToolbar;

	toolbar.showCaptions := showCaptions;

	toolbar.addButton(self.btnSearchTV, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnResetSearchTV, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCloseSearchTV, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="allowAdd" id="285b2716-5e09-4181-a84d-2ff043797174">
