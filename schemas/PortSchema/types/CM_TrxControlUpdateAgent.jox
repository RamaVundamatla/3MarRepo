    <JadeMethod name="trxUpdateDisconnect" id="28a7e401-91fa-4d0a-84a2-bd6860469aeb">
        <updating/>
        <source>trxUpdateDisconnect(params : CMIF_ConnectParams input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 18/09/2017	jlgmd1		TFS 6813 - QNS - Jade application slow
//
// ---------------------------------------------------------------------------

vars
	pxyTI : CM_TrackedItem;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	if params = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "Disconnection Parameters", null, null);
	endif;
	if params.allTrackedItems.size = 0 then
		app.raiseCMException2(MethodWithNullParam, method.name, "Disconnection Parameters: allTrackedItems", null, null);
	endif;	

	app.setContinueCMExceptions(false);
	
	_passport.useTITransactionDeferUpdate := true;		// TFS 6813
	_passport.useTIDictDeferUpdate := true;				// TFS 6813
		
	beginTransaction;
	
	foreach pxyTI in params.allTrackedItems do 
		app.myUtilityUA.utlUpdateDisconnect(params, pxyTI, _passport);
		if _passport.hasErrors() then
			return;
		endif;
	endforeach;
	
	if _passport.noErrors then				// TFS 6813
		_passport.doDeferredUpdates();		// TFS 6813
	endif;									// TFS 6813

epilog	
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="params" type="CMIF_ConnectParams" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateDisconnectReefers" id="73f82f57-bf5c-4953-bdde-1dd240b70b7f">
        <updating/>
        <source>trxUpdateDisconnectReefers(_paramSet : CMIF_TITxnControllerSet; _passport : CM_Passport input) updating;
//-----------------------------------------
//Created: April 2003 By: cnwgd1
//-----------------------------------------
vars
	param : CMIF_TITransactionController;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	if _paramSet = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "Disconnection Parameters", null, null);
	endif;

	app.setContinueCMExceptions(false);

	_passport.useTITransactionDeferUpdate := true;

	beginTransaction;
	
	foreach param in _paramSet do
		app.myUtilityUA.utlUpdateDisconnect(param.CMIF_ConnectParams, null, _passport);
	endforeach;

	if _passport.noErrors then
		_passport.doDeferredUpdates();	
	endif;

epilog	
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_paramSet" type="CMIF_TITxnControllerSet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateDoWORelExtForSap" id="58c6408b-9316-44c8-a070-20da352a2350">
        <updating/>
        <source>trxUpdateDoWORelExtForSap( _woExt : CM_WodReleaseExtension input; _passport : CM_Passport input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 March 2019	jlgndl1	Initial creation	TFS 43405

*/

vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);
		
	beginTransaction;

	if _woExt &lt;&gt; null then
		_woExt.doPaymentSuccessActions();
	endif;
	

epilog
	
	self.finaliseActivityWithPassport(_passport);
	
end;</source>
        <Parameter name="_woExt" type="CM_WodReleaseExtension" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxUpdateDocActionAssign" id="6d87d392-6cdb-4c96-930e-c032e90a9067">
        <updating/>
        <source>trxUpdateDocActionAssign(	_docAction : CM_DocumentActions input;	
							_tiArray : CM_TIArray input;
							_amountArray : RealArray input;
							_passport : CM_Passport input
							) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 September 2016	cnwndl1	Initial creation	TFS 2649 / 2001

*/

vars

begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	if _docAction = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "Document Action", null, null);
		return;
	endif;
	
	app.setContinueCMExceptions(false);
		
	beginTransaction;

	_docAction.assignTasksAndStops( _tiArray, _amountArray );	//05 Oct 2016	NDL	TFS 2001 / 2792

epilog	
	self.finaliseActivityWithPassport(_passport);
end;</source>
