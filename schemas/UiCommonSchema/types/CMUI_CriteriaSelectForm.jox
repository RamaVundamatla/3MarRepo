    <JadeMethod name="doFind" id="a1f04051-d9ad-4aa3-8fa5-960ba3b769d4">
        <source>doFind() protected;
/*
Date		Who		Reason
22/12/2012	cnwcs5	Initial creation - par 29158 EDI Booking Cutoff
*/
vars
	txt			: String;
	idx			: Integer;
	col, row, 
	fixedRows	: Integer;
	table		: Table;
begin
	txt 		:= self.txtFind.text.trimBlanks;
	table		:= self.tblAvailable;
	fixedRows	:= table.fixedRows;
	
	if txt = null then
		// No value entered
		if table.rows &gt; fixedRows then
			table.row 		:= fixedRows + 1;
			table.topRow 	:= fixedRows + 1;
		endif;
		return;
	endif;

	col := 2;
	
	if self.chkByDescription.visible and self.chkByDescription.value then
		col := 3;
	endif;
	
	row := fixedRows + 1;

	if table.row &gt; fixedRows and txt &gt;= table.accessCell( table.row, col ).text.toUpper() then
		row := table.row;
	endif;

	foreach idx	in row to table.rows do
		if txt &lt;= table.accessCell( idx, col ).text.toUpper() then
			table.row 		:= idx;
			table.topRow 	:= idx;
			break;
		endif;
	endforeach;
		
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
