    <DbClassMap file="query"/>
    <JadeMethod name="addObjectToTable" id="ea753cbb-bb30-4da9-9e32-794dfc7047e2">
        <source>addObjectToTable(_tbl : Table input; _voyage : CM_Voyage; _multiTerminal, _selected : Boolean; _passport : CM_Passport) protected;
// ---------------------------------------------------------------------------
// Created:     11 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	voyDescr		: String;
begin

	if _multiTerminal then
		voyDescr := _voyage.code &amp; '   ' &amp; _voyage.description &amp; ' - ' &amp; _voyage.myTerminal.code;
	else
		voyDescr := _voyage.code &amp; '   ' &amp; _voyage.description;
	endif;
			
	_tbl.accessRow(_tbl.addItem(_selected.cnEcGetTableCheckBoxValue &amp; Tab &amp; voyDescr)).itemObject := _voyage;
	


end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_multiTerminal" type="Boolean"/>
        <Parameter name="_selected" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="create" id="a239293d-4716-440d-b071-f9e8d7954ba1">
        <updating/>
        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     11 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	oper : CM_QueryOperator;
begin
	if self.isTransient then 
		return;
	endif;
	
	//create oper as CM_QReferenceIsOneOf persistent;
	create oper as CM_QStringIsOneOf persistent; //cnwsh3 - MES1019. To allow for reporting on cargo not prenoted Looks like this was
												 //never implemented in versions prior to 7.8.1.
	self.allAllowedOperators.add(oper);
	
end;</source>
    </JadeMethod>
    <JadeMethod name="getControlNameForOperator" id="e4422ef5-7ce1-4fdb-934d-e197dc16031e">
        <source>getControlNameForOperator(_operator: CM_QueryOperator): String;
// ---------------------------------------------------------------------------
// Created:     16 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	if CM_QReferenceLookup.hasInstance(_operator) then
		return 'cmbCellularVoyage';
	endif;


end;</source>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDependentProperties" id="6ba5e4bc-c54e-4c74-8c84-35b7af63b97f">
        <source>getDependentProperties(_dependentPropNames: StringArray input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25  Nov 2019 jlger1	Initial creation TFS 47132

*/

vars

begin
	if _dependentPropNames &lt;&gt; null then
		_dependentPropNames.add(CM_TrackedItem::bayId.name);
		_dependentPropNames.add(CM_TrackedItem::bayId40.name);
	endif;

epilog

end;</source>
