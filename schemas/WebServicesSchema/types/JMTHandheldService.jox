    <JadeMethod name="getTasks" id="ab12f1d5-3d72-417f-8f01-26dc8dace707">
        <updating/>
        <source>getTasks(optionalParam : ParamListType): WS_CargoTaskDescResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 Aug 2019	cnwma1	ChangeRequest 46185: PNL - Tasks, Grades and Marks via REST API

*/

vars
	response 	: WS_CargoTaskDescResponse;
	toDoTask	: CM_ToDoTaskDesc;
	toDo		: WS_CargoTaskDesc;
	cargoTypeId : Integer;
	cargoType   : CM_CargoType;
begin
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	// Get the parameters
	cargoTypeId := parseParameterList(optionalParam, 1, Integer).Integer;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
		
	if cargoTypeId &lt;&gt; null then
		cargoType := app.myRoot.allCargoTypesById[cargoTypeId.Integer];
		if cargoType = null then
			app.raiseCMException1(Cargo_Type_Invalid, cargoTypeId.String, null, null);
			return response;
		endif;
	endif;
	
	foreach toDoTask in app.myRoot.allToDoTaskDescriptions discreteLock
			where toDoTask.type = TODO_TYPE_GROUP_TI  do  // ### TFS  #56634[54259] 22NOV2022 NAVAB1 do	
		
		if cargoType &lt;&gt; null then
			if not toDoTask.isAvailableForCargoType(cargoTypeId) then
				continue;
			endif;
		endif;
		
		create toDo transient;
		toDo.setProxyFromObject(toDoTask);
		response.allTasks.add(toDo);	
	endforeach;
	
	return response;
epilog
	self.finaliseResponse(response);
end;</source>
        <Parameter name="optionalParam" type="ParamListType"/>
        <ReturnType type="WS_CargoTaskDescResponse"/>
    </JadeMethod>
    <JadeMethod name="getTasksOnCargo" id="e2c183a6-767c-441f-9ba3-dd0c58fd767f">
        <updating/>
        <source>getTasksOnCargo(cargoOid : String) : WS_CargoTaskDescResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 August 2019	jlgma1	Initial creation
9 Aug 2022 	navhl20 Bug 52943: MTN - Showing %1 in the JMTAppHandHeld Rest API Grade response code if the cargo item is not found in the system

*/

vars
	response 	: WS_CargoTaskDescResponse;
	cargo		: CM_TrackedItem;
	wsCargoTask : WS_CargoTaskDesc;
	task 		: CM_ToDoTask;
	failedDAC 	: CM_DataAccessController;
begin
	
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
			
	cargo := app.myPassport.getObjectOfTypeFromOid(cargoOid, CM_TrackedItem).CM_TrackedItem;
	
	if app.myPassport.hasErrors then
		return response;
	endif;

	if cargo = null then
		//app.raiseCMException(Cargo_item_not_found,null,null);		//9.8.2022 navhl20 TFS 52943
		app.raiseCMException1(Cargo_item_not_found,cargoOid,null,null);	//9.8.2022 navhl20 TFS 52943
		return response;
	endif;
			
	
	foreach task in cargo.allToDoTasksToDo discreteLock do
		
		create wsCargoTask transient;
		
		wsCargoTask.setProxyFromObject(task.getMyToDoTaskDesc);	
		wsCargoTask.remarks := task.remarks;
		
		response.allTasks.add(wsCargoTask);
	endforeach;
		
	return response;
epilog
	self.finaliseResponse(response);
end;</source>
        <Parameter name="cargoOid" type="String"/>
        <ReturnType type="WS_CargoTaskDescResponse"/>
    </JadeMethod>
    <JadeMethod name="getTrailersForRelease" id="4648fe75-701e-4b1c-9a1f-8a686a30f358">
        <updating/>
        <source>getTrailersForRelease(releaseOid  : String) : WS_TrailersResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2021	jlier1	Initial creation 51879

*/

vars
	response : WS_TrailersResponse;
	release 	: CM_BulkRelease;
	trailerArray : CM_TIArray ;
	ti : CM_TrackedItem;
	wsTrailer : WS_Trailer;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(self.httpStatusCode.String, LogDEBUG);	//25 Nov 2019	NDL	TFS 47053
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	
	
	release:=app.myPassport.getObjectOfTypeFromOid(releaseOid,CM_BulkRelease).CM_BulkRelease;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if release = null then
		app.raiseCMException(Input_required_field_delReleas,null,null);
		return response;
	endif;
	
	create trailerArray transient;
	release.getAssociatedTrailers(trailerArray);
	
	foreach ti in trailerArray discreteLock do 
	
		create wsTrailer transient;
		wsTrailer.setProxyFromObject(  ti.CM_TILC );
		response.allTrailers.add( wsTrailer );
	endforeach;
	
	return response;
epilog
	delete trailerArray;
	self.finaliseResponse(response);

end;</source>
        <Parameter name="releaseOid" type="String"/>
        <ReturnType type="WS_TrailersResponse"/>
    </JadeMethod>
    <JadeMethod name="getTrucksForRelease" id="c1c2e62c-ff01-4693-bfef-42ecce0dbb35">
        <updating/>
        <source>getTrucksForRelease(releaseOid : String) : WS_VehiclesResponse updating;
/*
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2021	jlier1	Initial creation 51879

*/

vars
response : WS_VehiclesResponse;
	terminal : CM_Terminal;
	release 	: CM_BulkRelease;
	vehicleArray : CM_VehicleArray ;
	vehicle : CM_Vehicle;
	wsVehicle		: WS_Vehicle;
	selectedStageArea : CM_LocationsController;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	// Set app.mypassport - user / terminal &amp; machine
	
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	terminal:=app.myPassport.myTerminal;
	
	release:=app.myPassport.getObjectOfTypeFromOid(releaseOid,CM_BulkRelease).CM_BulkRelease;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if release = null then
		app.raiseCMException(Input_required_field_delReleas,null,null);
		return response;
	endif;
	
	create vehicleArray transient;
	release.getAssociatedTrucks(vehicleArray);
	
	foreach vehicle in vehicleArray discreteLock do 
	
		create wsVehicle transient;
		wsVehicle.setProxyFromObject( vehicle );
		response.allVehicles.add( wsVehicle );
	endforeach;
	//have to check if need to pre select the vehicle
	if vehicleArray.size = 1 then
		selectedStageArea:=null;
		release.getAllPreStagedLocations(selectedStageArea);
		if selectedStageArea &lt;&gt; null then
			response.selectedVehicleOid:=vehicleArray.first.getOidAsString;
		endif;
	endif;
	
	
	return response;
epilog
	delete vehicleArray;
	self.finaliseResponse(response);

end;</source>
        <Parameter name="releaseOid" type="String"/>
        <ReturnType type="WS_VehiclesResponse"/>
    </JadeMethod>
    <JadeMethod name="getYardLocationById" id="0e243da0-c7e0-4530-a4a5-fa4ea8d52157">
        <updating/>
        <source>getYardLocationById(locationId : String) : WS_LocationResponse updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 August 2021	jlier1	Initial creation 51684

*/

vars
	terminal : CM_Terminal;
	response : WS_LocationResponse;
	foundLC : CM_LocationsController;
	foundHeight : Integer;
	wsLC : 	WS_LocationsController;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	//gets username password and validates the user then gets terminal and sets all that against the passport
	self.initialisePassport();
	
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		// this will return the rest faults
		return null;
	endif;	
	
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;	
	create response transient;

	if locationId = null then
		app.raiseCMException(Input_Required_For_Location,null,null);
		return response;
	endif;
	
	terminal := app.myPassport.myTerminal;
	
	terminal.findLocationFromString(locationId.asStringRESTFUL ,true,foundLC,foundHeight);
	
	if foundLC &lt;&gt; null and foundLC.isKindOf(CM_YardController) then
		create wsLC transient;
		wsLC.setProxyFromObject(foundLC);
		response.myLocation:=wsLC;
	
	else
		app.raiseCMException1(Location_NotFound,locationId.asStringRESTFUL.toUpper,null,null);	
	endif;
	return response;
epilog
	self.finaliseResponse(response);

end;</source>
        <Parameter name="locationId" type="String"/>
        <ReturnType type="WS_LocationResponse"/>
    </JadeMethod>
    <JadeMethod name="postLogoffMachineForPicking" id="ea6ffa09-7868-4059-bbe3-24a5b1b627f1">
        <updating/>
        <source>postLogoffMachineForPicking(machineOid : String): WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 July 2021	jlier1	Initial creation TFS 51626

*/

vars
	response : WS_Response;
	machine : CM_Machine;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	self.initialisePassport();
	
	app.writeLog(method.qualifiedName, LogTRACE);	//25 Nov 2019	NDL	TFS 47053
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
		
	app.checkCurrentUserHasAccess(PmHHOrderPicking);		
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;		
		
	machine:= app.myPassport.getObjectOfTypeFromOid(machineOid,CM_Machine).CM_Machine;
	if machine = null then
		app.raiseCMException2(ERR_MACH_NOTFOUND,machineOid,app.myPassport.myTerminal.code,null,null);
		return null;
	endif;
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	if machine.loggedOn and machine.user = app.myPassport.myUser then
		app.myTrxUA.trxUpdateLogoff( machine, app.myPassport );
	endif;
		
	return response;
epilog
	self.finaliseResponse(response);

end;</source>
        <Parameter name="machineOid" type="String"/>
        <ReturnType type="WS_Response"/>
    </JadeMethod>
    <JadeMethod name="postLogonMachineForPicking" id="2486d5bc-36e0-4afc-958a-5d1e9287a6fb">
        <updating/>
        <source>postLogonMachineForPicking(machineOid : String) : WS_Response updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 July 2021	jlier1	Initial creation TFS 51626

*/

vars
	response : WS_Response;
	machine : CM_Machine;
begin
	// Arm exception handler for CM Exceptions
	on CM_Exception do self.handleCMException(exception);
	on LockException do self.handleLockExceptions(exception);
	
	create response transient;
	
	self.initialisePassport();
	
	app.writeLog(method.qualifiedName, LogTRACE);	//25 Nov 2019	NDL	TFS 47053
	// Initialises user and checks request has valid headers deletes and recreates the passport
	if self.httpStatusCode &lt;&gt; HttpResponseOK then
		//user has not validated
		app.writeLog(method.qualifiedName &amp; Tab &amp; self.httpStatusCode.String, LogERROR);	//25 Nov 2019	NDL	TFS 47053	//navra1 - 24th Aug 2022 - TFS 50365
		return response;
	endif;	
	
	if app.myPassport.hasErrors then
		return response;
	endif;
	
	app.checkCurrentUserHasAccess(PmHHOrderPicking);		
	if app.myPassport.hasErrors then
		self.httpStatusCode := HttpResponseForbidden;
		return response;
	endif;		
		
	machine:= app.myPassport.getObjectOfTypeFromOid(machineOid,CM_Machine).CM_Machine;
	if machine = null then
		app.raiseCMException2(ERR_MACH_NOTFOUND,machineOid,app.myPassport.myTerminal.code,null,null);
		return null;
	endif;
	
	if app.myPassport.hasErrors then
		return response;
