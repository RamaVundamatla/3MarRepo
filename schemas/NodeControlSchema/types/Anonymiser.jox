<Class name="Anonymiser" id="215826ec-0d9c-452c-ad8f-beafb854e7f6">
    <superclass name="Misc"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="Lincrun"/>
    <PrimAttribute name="commitFrequency" id="651e3987-cfe1-47ac-b696-a53f3cb385ac">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="count" id="28c597d1-18a1-4d1c-9b03-3272f85e9365">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <ImplicitInverseRef name="meth" id="5d05bc3a-178c-4e81-abcc-eb3ba9c032f6">
        <embedded/>
        <type name="JadeMethod"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="myClass" id="494c2f71-cfbe-43af-a028-6797c1d6687d">
        <embedded/>
        <type name="Class"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="prop" id="ef916149-0dcd-4279-a7c7-59ca1d8802c3">
        <embedded/>
        <type name="Property"/>
    </ImplicitInverseRef>
    <PrimAttribute name="source" id="d3637d45-4972-4070-a25f-4c65df6ca497">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="totalClasses" id="11021e97-ad42-4f51-a93e-4c080a322b93">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="totalInstances" id="7a8cda49-b78a-44eb-8d88-161b9ca27672">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="totalProperties" id="a994fd25-733f-4753-ac3a-f7d372207f16">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="checkFor" id="c583db2a-6d1e-460f-a153-161e8ae405ec">
        <updating/>
        <source>checkFor(subString:String; propType:Type; len:Integer; encryptMethod:String) updating;

begin
	if prop.name.toLower.cnContains(subString) and prop.type = propType and prop.getLength-1 &gt;= len then
		totalProperties:=totalProperties+1;
//		if prop.access = #'0' then  // public - get/set prop not required for readonly properites, only to bypass readonly mapping methods
			source:=source&amp;prop.name&amp;"."&amp;encryptMethod&amp;";"&amp;CrLf;
		else
/*			source:=source&amp;'s:=getPropertyValue("'&amp;prop.name&amp;'").String;'&amp;CrLf;
//			source:=source&amp;'s.encryptName;'&amp;CrLf;
			source:=source&amp;'s.'&amp;encryptMethod&amp;";"&amp;CrLf;
			source:=source&amp;'setPropertyValue("'&amp;prop.name&amp;'",s);'&amp;CrLf;
		endif; */
	endif;
end;</source>
        <Parameter name="subString" type="String"/>
        <Parameter name="propType" type="Type"/>
        <Parameter name="len" type="Integer"/>
        <Parameter name="encryptMethod" type="String"/>
    </JadeMethod>
    <JadeMethod name="doAllClasses" id="662d7486-6b9c-45b9-b1b1-54aa73fc99f8">
        <updating/>
        <source>doAllClasses() updating;

// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support

vars
	cc:Class;
	i,j,k,l,errorCode,errorPosition,errorLength:Integer;
	s,t:String; skipping:Boolean;
	tStart,tEnd:TimeStamp;
begin
	commitFrequency:=global.bmkUsers;
	app.logMessage("");
	app.logMessage("starting "&amp;method.qualifiedName&amp;", commitFrequency="&amp;commitFrequency.integerFormat);
//	skipping:=true;
	tStart:=app.actualTimeServer;	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	foreach cc in Class.instances do
//	foreach cc in currentSchema.allClasses do  // SJetSchema only
//		if cc.name = "IVT95" then skipping:=false; continue; endif;
//		if skipping then continue; endif;
//		if cc &lt;&gt; CUS01 then continue; endif;
		if not cc.instancesExist or cc.isSubclassOf(Collection) then continue; endif;
		myClass:=cc;
		generateMethodSource(cc);
		if source &lt;&gt; null then
			source:="vars s:String; begin"&amp;CrLf&amp;source;
			app.logMessage(CrLf&amp;CrLf&amp;cc.schema.name&amp;"::"&amp;cc.name&amp;CrLf&amp;source);  //continue;
			totalClasses:=totalClasses+1;
			meth:=process.createTransientMethod("anon", cc, currentSchema, source, true, null, errorCode, errorPosition, errorLength);
			app.logMessage(meth.qualifiedName&amp;" compileResult="&amp;errorCode.String&amp;" "&amp;source);
			doClassWithMethod(cc, meth);
			searchClass(cc, meth);
			process.deleteTransientMethod(meth);
		endif;
	endforeach;

	tEnd:=app.actualTimeServer;			// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	app.logMessage("classes modified="&amp;totalClasses.integerFormat);
	app.logMessage("properties modified="&amp;totalProperties.integerFormat);
	app.logMessage("total instances="&amp;totalInstances.integerFormat);
	app.logMessage("overall time="&amp;((tEnd.time-tStart.time) div 1000).integerFormat&amp;" seconds ("&amp;app.displayInterval(tStart,tEnd)&amp;")");
	app.logMessage("finished "&amp;method.qualifiedName);
end;</source>
    </JadeMethod>
    <JadeMethod name="doClass" id="718a552e-a483-4c33-aea8-49c60d920407">
        <updating/>
        <source>doClass(clas:Class) updating;
//	this method requires an anonymise method on each class
vars
	o:Object;
	tStart,tEnd:Decimal[23];
begin
	myClass:=clas;
	count:=0;
	tStart:=app.relativeMachineTime;
	app.logMessage(myClass.name&amp;" updating started");

	beginTransaction;
	foreach o in myClass.instances do
//		o.LINCOBJECT.anonymise;
		count:=count+1;
		if count &gt;= 4000 then break; endif;
		if count mod 1000 = 0 or global.bmkUsers = 99 then
			doCommit;
		endif;
	endforeach;
	commitTransaction;
	
	tEnd:=app.relativeMachineTime;
	app.logMessage(myClass.name&amp;" updating finished - did "&amp;count.integerFormat&amp;" objects in "&amp;(tEnd-tStart).Time.String);
end;</source>
        <Parameter name="clas" type="Class"/>
    </JadeMethod>
    <JadeMethod name="doClassWithMethod" id="8d218785-dede-4afe-9a3f-1c0078005dd2">
        <updating/>
        <source>doClassWithMethod(clas:Class; meth:JadeMethod) updating;

// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support

vars
	o:Object; vc:VirtualColl;
	tStart,tEnd:TimeStamp;
begin
	myClass:=clas;
	count:=0;
	tStart:=app.actualTimeServer;  // include .instances and .size in time// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	vc:=myClass.instances;
	if vc.size = 0 then return; endif;
	totalInstances:=totalInstances+vc.size;
	app.logMessage(myClass.name&amp;" updating started, "&amp;vc.size.integerFormat&amp;" instances");

	beginTransaction;
	foreach o in vc do
		count:=count+1;
//		if clas &lt;&gt; CUS01 or count &gt; 739500 then  // restart point
			process.executeTransientMethod(meth, o);
//		endif;
		if count mod commitFrequency = 0 or global.bmkUsers = 99 then
			doCommit;
		endif;
	endforeach;
	commitTransaction;
	
	tEnd:=app.actualTimeServer;		// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	app.logMessage(myClass.name&amp;" updating finished - did "&amp;count.integerFormat
			&amp;" objects in "&amp;((tEnd.time-tStart.time) div 1000).integerFormat&amp;" seconds ("&amp;app.displayInterval(tStart,tEnd)&amp;")");
end;</source>
        <Parameter name="clas" type="Class"/>
        <Parameter name="meth" type="JadeMethod"/>
    </JadeMethod>
    <JadeMethod name="doCommit" id="d748c51c-f847-4af8-9467-3e5491750a17">
        <updating/>
        <source>doCommit() updating;

begin
	app.logMessage(count.integerFormat.rightAlign(12) &amp; " objects updated");
	commitTransaction;
	if global.bmkUsers = 99 then
		app.logMessage(myClass.name&amp;" updating paused - change global.bmkUsers to a value other than 99 to resume");
		while global.bmkUsers = 99 do
			app.doWindowEvents(1000);
		endwhile;
		commitFrequency:=global.bmkUsers;
		app.logMessage(myClass.name&amp;" updating resumed, commitFrequency="&amp;commitFrequency.integerFormat);
	endif;
	beginTransaction;
end;</source>
    </JadeMethod>
    <JadeMethod name="generateMethodSource" id="cf83c3e8-f7bb-4a6d-bcbc-10867eff90e5">
        <updating/>
        <source>generateMethodSource(clas:Class) updating;

vars
	cc:Class; ss:Schema;
begin
	cc:=clas;
	ss:=cc.schema;
	source:=null;
	while cc &lt;&gt; null and cc.schema = ss do
//		app.logMessage("looking in "&amp;cc.name);
		foreach prop in cc.getProperties do
			checkFor("surname",		String, 4, "encryptName");
			checkFor("postalnm",	String, 4, "encryptName");
			checkFor("clubname",	String, 4, "encryptName");
			checkFor("acctname",	String, 4, "encryptName");
			checkFor("acct_name",	String, 4, "encryptName");
			checkFor("bank_nm",		String, 4, "encryptName");
			checkFor("contact_",	String, 4, "encryptName");
			checkFor("lastName",	String, 4, "encryptName");
			checkFor("fullName",	String, 4, "encryptName");
			checkFor("sur_nam",		String, 4, "encryptName");
			checkFor("email",		String, 4, "encryptName");
			checkFor("e_mail",		String, 4, "encryptName");
			checkFor("postcode",	String, 2, "encryptPostcode");
			checkFor("pcode_",		String, 2, "encryptPostcode");
			checkFor("street",		String, 4, "encryptStreet");
			checkFor("address",		String, 4, "encryptStreet");
			checkFor("district",	String, 4, "encryptStreet");
			checkFor("addline",		String, 4, "encryptStreet");
			checkFor("tel_",		String, 4, "encryptNumber");
			checkFor("phone",		String, 4, "encryptNumber");
			checkFor("fax_nbr",		String, 4, "encryptNumber");
			checkFor("ninsnbr",		String, 4, "encryptNumber");
			checkFor("bkaccnum",	Integer,0, "encryptNumber");
			checkFor("bank_acno",	Integer,0, "encryptNumber");
/*			if cc = ADC91 or cc = CUS65 then
				checkFor("new_val",		String, 4, "fillWithRubbish");
				checkFor("pre_val",		String, 4, "fillWithRubbish");
			endif;
			if cc = ADC93 or cc = ADV99 then
				checkFor("text",		String, 4, "fillWithRubbish");
				checkFor("vendor",		String, 4, "fillWithRubbish");
			endif;
			if cc = APP80 then
				checkFor("act",			String, 4, "fillWithRubbish");
			endif;
			if cc = ARR98 then
				checkFor("notes",		String, 4, "fillWithRubbish");
			endif;
			if cc = ADC95 or cc = ADC92 or cc = ADV05 or cc = ADV17 then
				checkFor("text",		String, 4, "fillWithRubbish");
			endif; */
			if myClass.name = "LtWorkplace" or myClass.name = "SecUser" then  // myClass is original class name
				checkFor("desc",		String, 4, "fillWithRubbish");
			endif;
/*			if cc = CUS75 then
				checkFor("zadd",		String, 4, "encryptStreet");
				checkFor("dist_o",		String, 4, "encryptStreet");
			endif;
			if cc = CUS80 then
				checkFor("curreas",		String, 4, "fillWithRubbish");
			endif;
			if cc = LTT95 then
				checkFor("varalp_1",	String, 4, "fillWithRubbish");
			endif;
			if cc = PAR04 then
				checkFor("data",		String, 4, "fillWithRubbish");
			endif;
			if cc = SEC98 then
				checkFor("line",		String, 4, "fillWithRubbish");
			endif;
			if cc = TRI94 or cc = TRI96 then
				checkFor("contdets_",	String, 4, "fillWithRubbish");
			endif;
			if cc = VAT98 then
				checkFor("remitref",	String, 4, "fillWithRubbish");
			endif;
			if cc = WAR01 then
				checkFor("desclin",		String, 4, "fillWithRubbish");
			endif; */
		endforeach;
		cc:=cc.getSuperclass;
	endwhile;
end;</source>
        <Parameter name="clas" type="Class"/>
    </JadeMethod>
    <JadeMethod name="searchAllClasses" id="18751c30-a1b5-4280-8c2c-f7551d429132">
        <updating/>
        <source>searchAllClasses() updating;

// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support

vars
	cc:Class;
	i,j,k,l,errorCode,errorPosition,errorLength:Integer;
	s,t:String;
	tStart,tEnd:TimeStamp;
begin
	commitFrequency:=global.bmkUsers;
	app.logMessage("");
	app.logMessage("starting "&amp;method.qualifiedName);
	tStart:=app.actualTimeServer;		// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	foreach cc in Class.instances do
		if cc.isSubclassOf(Collection) or cc.isSubclassOf(Application) or cc.isSubclassOf(Control) then
			continue;
		endif; /* */
		if rootSchema.getClass(cc.name) &lt;&gt; null or rootSchema.getSchema("SJetSchema").getClass(cc.name) &lt;&gt; null then continue; endif;
		if not cc.instancesExist then continue; endif;
//		app.logMessage(cc.schema.name&amp;"::"&amp;cc.name); continue;
		generateMethodSource(cc);
		app.logMessage(cc.name&amp;CrLf&amp;source);
		searchClass(cc, meth);
	endforeach;
	tEnd:=app.actualTimeServer;		// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	app.logMessage("classes searched="&amp;totalClasses.integerFormat);
	app.logMessage("total instances="&amp;totalInstances.integerFormat);
	app.logMessage("overall time="&amp;((tEnd.time-tStart.time) div 1000).integerFormat&amp;" seconds ("&amp;app.displayInterval(tStart,tEnd)&amp;")");
	app.logMessage("finished "&amp;method.qualifiedName);
end;</source>
    </JadeMethod>
    <JadeMethod name="searchAllSJetSchemaClasses" id="212f9965-6b88-45db-b521-28b4c00dccab">
        <updating/>
        <source>searchAllSJetSchemaClasses() updating;

// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support

vars
	cc:Class;
	i,j,k,l,errorCode,errorPosition,errorLength:Integer;
	s,t:String;
	tStart,tEnd:TimeStamp;
begin
	commitFrequency:=global.bmkUsers;
	app.logMessage("");
	app.logMessage("starting "&amp;method.qualifiedName);
	tStart:=app.actualTimeServer;			// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	foreach cc in currentSchema.allClasses do
//		if cc &lt;&gt; ADC93 and cc &lt;&gt; ADV99 and cc &lt;&gt; APP80 and cc &lt;&gt; ARR98 then continue; endif;
//		if cc.name &lt; "ADV98" or cc.name &gt; "ZZZZZ" then continue; endif;
		if not cc.instancesExist then continue; endif;
/*		if cc.isSubclassOf(Collection)
		or cc = ADM08 or cc = ADV30 or cc = ADV81 or cc = ADV86 or cc = ADV87 
		or cc = ADV98 or cc = APP85 or cc = APP89 or cc = APP95 or cc = BAF01
		or cc = BNK15 then
			continue;
		endif; /* */
//		if cc = CUS01 then break; endif;
		generateMethodSource(cc);
		if true or source = null then
			app.logMessage(cc.name&amp;CrLf&amp;source);
			searchClass(cc, meth);
		else
			app.logMessage("skipping "&amp;cc.name&amp;CrLf&amp;source);
		endif;
	endforeach;
	tEnd:=app.actualTimeServer;			// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	app.logMessage("classes searched="&amp;totalClasses.integerFormat);
	app.logMessage("total instances="&amp;totalInstances.integerFormat);
	app.logMessage("overall time="&amp;((tEnd.time-tStart.time) div 1000).integerFormat&amp;" seconds ("&amp;app.displayInterval(tStart,tEnd)&amp;")");
	app.logMessage("finished "&amp;method.qualifiedName);
end;</source>
    </JadeMethod>
    <JadeMethod name="searchAllSchemas" id="c0c48bf6-8a3b-41b2-859d-5da951d45b5e">
        <updating/>
        <source>searchAllSchemas() updating;
//	not used - Class.instances is better
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	schema:Schema; allSchemas:SchemaColl; cc:Class;
	i,j,k,l,errorCode,errorPosition,errorLength:Integer;
	s,t:String;
	tStart,tEnd:TimeStamp;
begin
	create allSchemas transient;
	commitFrequency:=global.bmkUsers;
	app.logMessage("");
	app.logMessage("starting "&amp;method.qualifiedName);
	tStart:=app.actualTimeServer;		// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	rootSchema.allSubschemas(allSchemas);
	foreach schema in allSchemas where schema.name &lt;&gt; "SJetSchema" and schema.name[1:4] &lt;&gt; "Jade" do
		app.logMessage("doing "&amp;schema.name);
		foreach cc in schema.allClasses do
			if not cc.instancesExist then continue; endif;
			if cc.isSubclassOf(Collection) or cc.isSubclassOf(Application) or cc.isSubclassOf(Control) or cc.name[1:8] = "JadeSkin" then
				continue;
			endif; /* */
			generateMethodSource(cc);
			if true or source = null then
				app.logMessage(cc.name&amp;CrLf&amp;source);
				searchClass(cc, meth);
			else
				app.logMessage("skipping "&amp;cc.name&amp;CrLf&amp;source);
			endif;
		endforeach;
	endforeach;
	tEnd:=app.actualTimeServer;			// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	app.logMessage("classes searched="&amp;totalClasses.integerFormat);
	app.logMessage("total instances="&amp;totalInstances.integerFormat);
	app.logMessage("overall time="&amp;((tEnd.time-tStart.time) div 1000).integerFormat&amp;" seconds ("&amp;app.displayInterval(tStart,tEnd)&amp;")");
	app.logMessage("finished "&amp;method.qualifiedName);
epilog
	delete allSchemas;
end;</source>
    </JadeMethod>
    <JadeMethod name="searchClass" id="cdfc0992-b85a-4ef9-924c-1863f0806fb1">
        <updating/>
        <source>searchClass(clas:Class; meth:JadeMethod) updating;

// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support

vars
	o:Object; vc:VirtualColl;
	tStart,tEnd:TimeStamp;
	found:Integer;
	s:String;
begin
	myClass:=clas;
	count:=0;
	tStart:=app.actualTimeServer;  // include .instances and .size in time	// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	vc:=myClass.instances;
	if vc.size = 0 then return; endif;
	totalInstances:=totalInstances+vc.size;
	app.logMessage(myClass.name&amp;" search started, "&amp;vc.size.integerFormat&amp;" instances");

	beginTransaction;
	foreach o in vc do
//		app.logMessage(o.display);
		s:=o.display.toUpper;
		if s.cnContains("CAMPBELL") or s.cnContains("ROBERTS") or s.cnContains("HARRISON") or s.cnContains("SIMMONS")
		or s.cnContains("@") or s.cnContains(" AVENUE") or s.cnContains(" ROAD") or s.cnContains(" CRESCENT") then
			found:=found+1;
			if found &lt;= 5 then
				app.logMessage(o.display);
			endif;
		endif;
		count:=count+1;
		if count &gt;= 1000 then break; endif;
		if count mod commitFrequency = 0 or global.bmkUsers = 99 then
//			doCommit;  // for interim counts and interruption
		endif;
	endforeach;
	commitTransaction;
	
	tEnd:=app.actualTimeServer;		// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	app.logMessage(myClass.name&amp;" search finished - checked "&amp;count.integerFormat&amp;", found "&amp;found.integerFormat
			&amp;" hits in "&amp;((tEnd.time-tStart.time) div 1000).integerFormat&amp;" seconds ("&amp;app.displayInterval(tStart,tEnd)&amp;")");
end;</source>
        <Parameter name="clas" type="Class"/>
        <Parameter name="meth" type="JadeMethod"/>
    </JadeMethod>
</Class>
