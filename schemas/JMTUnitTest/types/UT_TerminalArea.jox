end;</source>
    </JadeMethod>
    <JadeMethod name="tFindRoRoLocation" id="e8de97e0-bdda-4554-9fe1-3189efbf7d59">
        <source>tFindRoRoLocation();
// cnwndl1
//22 Februarry 2010	cnwjk3	

vars
	roroArea: CM_RoRoLaneArea;
	lc		: CM_LocationsController;
	strs	: StringArray;
	height 	: Integer;
begin
	deleteTerminalArea("UTRORO");
	roroArea := addROROArea("UTRORO",  4, 100);
	assertTrueMsg(roroArea &lt;&gt; null, "Failed to add RORO Area");
	
	create strs transient;
	strs.add("03");
	roroArea.findLocation(strs, true, lc, height);
	assertTrueMsg(lc &lt;&gt; null, "Failed to locate location controller");
	assertTrueMsg(lc.CM_RoRoController.id = "03", "Failed to locate correct location controller");
	
epilog
	delete strs;
end;</source>
    </JadeMethod>
    <JadeMethod name="tGCCheckCapacityAndWeight" id="52aeff33-6a2a-43cb-82b4-b77bb278857d">
        <source>tGCCheckCapacityAndWeight();

/*

Purpose:		Chekc Capacity and weight messages for GC area

Date			Who		Reason
17/11/2015		cnwmh5	Initial creation

*/

vars

	gcArea					: CM_IrregularBlockArea;
	rack					: CM_IrregularBlockController;
	rack2					: CM_IrregularBlockController;
	rack3					: CM_IrregularBlockController;
	shelf 					: CM_RackShelfController;
	shelf2 					: CM_RackShelfController;
	shelf3 					: CM_RackShelfController;
	ground					: CM_IrregularBlockController;
	ground2					: CM_IrregularBlockController;
	ground3					: CM_IrregularBlockController;
	ti						: CM_TrackedItem;	
	bs						: CM_BlockStack;
	
	tiArray					: CM_TIArray;
	
	index					: Integer;
	
begin

	gcArea := self.addGeneralCargoArea("MDHGC1", "Michael's GC Area", 11, 10, 5, null, null);
	self.assertNotNull(gcArea);
		
	rack := self.addGCRackOrGround(gcArea, 8, 1, 10, 3, "R1S1CAP");
	self.assertNotNull(rack);
	
	shelf := self.addGCShelf(rack, 1, "01", 5, 0, null);
	self.assertNotNull(shelf);
	
	rack2 := self.addGCRackOrGround(gcArea, 8, 5, 10, 7, "R1S1WEI");
	self.assertNotNull(rack2);
	
	shelf2 := self.addGCShelf(rack2, 1, "01", 0, 15000, null);
	self.assertNotNull(shelf2);
	
	rack3 := self.addGCRackOrGround(gcArea, 8, 9, 10, 11, "R1S1CAPWEI");
	self.assertNotNull(rack3);
	
	shelf3 := self.addGCShelf(rack3, 1, "01", 5, 15000, null);
	self.assertNotNull(shelf3);
	
	self.opts.purge();
	self.opts.addAssoc("LocationType", GC_GroundLocation);
	self.opts.addAssoc("Capacity", 5);
	ground := self.addGCRackOrGround(gcArea, 1, 1, 3, 3, "G1S1CAP");
	self.assertNotNull(ground);
	
	self.opts.purge();
	self.opts.addAssoc("LocationType", GC_GroundLocation);
	self.opts.addAssoc("MaxWeight", 15000.Real);
	ground2 := self.addGCRackOrGround(gcArea, 1, 5, 3, 7, "G1S1WEI");
	self.assertNotNull(ground2);
	
	self.opts.purge();
	self.opts.addAssoc("LocationType", GC_GroundLocation);
	self.opts.addAssoc("Capacity", 5);
	self.opts.addAssoc("MaxWeight", 15000.Real);
	ground3 := self.addGCRackOrGround(gcArea, 1, 9, 3, 11, "G1S1CAPWEI");
	self.assertNotNull(ground3);

	bs := self.addBlockStack("UTMHBV", 500, null);
	self.assertNotNull(bs);
	
	create tiArray transient;
	
	self.opts.purge();
	self.opts.addAssoc("ReturnTIs", true);
	self.addQuickCargo(bs, null, 50, tiArray);
	self.assertEqual(tiArray.size, 50);
	
	// set up the base stuff in the areas
	foreach index in 1 to 40 step 1 do
		self.clearExpectedTrxErrors();
		self.opts.purge();
		if index &lt;= 5 then
			self.move(tiArray[index], ground);
		elseif index = 6 then
			// check capacity ground
			self.expectedTrxErrors.add(Move_WillBeOverCap);
			self.opts.addAssoc("DontIgnoreWarnings", true);
			self.opts.addAssoc("ExpectErrors", self.expectedTrxErrors.size &gt; 0);
			self.move(tiArray[index], ground);
			self.assertNoTrxErrorsOrWarnings();
		elseif index &lt;= 11 then
			self.move(tiArray[index], ground2);
		elseif index = 12 then
			// check weight ground
			self.expectedTrxErrors.add(Locat_maxim_weigh_curre_total_);
			self.opts.addAssoc("DontIgnoreWarnings", true);
			self.opts.addAssoc("ExpectErrors", self.expectedTrxErrors.size &gt; 0);
			self.move(tiArray[index], ground2);
			self.assertNoTrxErrorsOrWarnings();
		elseif index &lt;= 17 then
			self.move(tiArray[index], ground3);
		elseif index = 18 then
			// check capacity and weight ground
			self.expectedTrxErrors.add(Move_WillBeOverCap);
			self.expectedTrxErrors.add(Locat_maxim_weigh_curre_total_);
			self.opts.addAssoc("DontIgnoreWarnings", true);
			self.opts.addAssoc("ExpectErrors", self.expectedTrxErrors.size &gt; 0);
			self.move(tiArray[index], ground3);
			self.assertNoTrxErrorsOrWarnings();
		elseif index &lt;= 23 then
			self.move(tiArray[index], shelf);
		elseif index = 24 then
			// check capacity shelf
			self.expectedTrxErrors.add(Move_WillBeOverCap);
			self.opts.addAssoc("DontIgnoreWarnings", true);
			self.opts.addAssoc("ExpectErrors", self.expectedTrxErrors.size &gt; 0);
			self.move(tiArray[index], shelf);
			self.assertNoTrxErrorsOrWarnings();
		elseif index &lt;= 29 then
			self.move(tiArray[index], shelf2);
		elseif index = 30 then
			// check weight shelf
			self.expectedTrxErrors.add(Locat_maxim_weigh_curre_total_);
			self.opts.addAssoc("DontIgnoreWarnings", true);
			self.opts.addAssoc("ExpectErrors", self.expectedTrxErrors.size &gt; 0);
			self.move(tiArray[index], shelf2);
			self.assertNoTrxErrorsOrWarnings();
		elseif index &lt;= 35 then
			self.move(tiArray[index], shelf3);
		elseif index = 36 then
			// check capacity and weight ground
			self.expectedTrxErrors.add(Move_WillBeOverCap);
			self.expectedTrxErrors.add(Locat_maxim_weigh_curre_total_);
			self.opts.addAssoc("DontIgnoreWarnings", true);
			self.opts.addAssoc("ExpectErrors", self.expectedTrxErrors.size &gt; 0);
			self.move(tiArray[index], shelf3);
			self.assertNoTrxErrorsOrWarnings();
		else
			break;
		endif;
	endforeach;
	
epilog
	
	self.clearExpectedTrxErrors();
	
	delete tiArray;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tGriddedStackHeightChecks" id="885f9070-b96f-4a6b-aa01-e9fe94e1e219">
        <source>tGriddedStackHeightChecks();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2020	jlgndl1	Initial creation	TFS 49984 - Adds YA style criteria to allow control of max stack height in gridded areas.

*/

constants

	StraddleStack : String = "UTSS49984";
	BlockStack : String = "BS49984";
	HAZIdBase : String = "UTHZ49984";
	FlatBaseId : String = "UTFL49984";
	MT40BaseId : String = "UTMF49984";
	MT20BaseId : String = "UTMT49984";
	YA_Alloc : String = "TFS49984";
	ParentBaseId : String = "UTFP49984";
	ChildBaseId : String = "UTFc49984";
	
vars

	ss : CM_StraddleStack;
	names : StringArray;
	neverMixs : BooleanArray;
	heights : IntegerArray;
	objectArray : ObjectArray; // of CMIF_Array objects
	allTransientCriteriaObj	: CMIF_Array;
	obj : Object;
	bs : CM_BlockStack;
	index : Integer;
	tiId : String;
	ti : CM_TrackedItem;
	stackController : CM_StackController;
	foundLC : CM_LocationsController;
	dummyHeight : Integer;
	maxHeight : Integer;
	reason : String;
	ya : CM_YardAllocation;
	locations : CM_LCArray;
	packTIs: CM_TIArray;
	tiParent : CM_Container;
	tiChild : CM_TrackedItem;

begin

	self.disableAllYA(true);

	//clean-up
	foreach index in 1 to 10 do
		tiId := HAZIdBase &amp; index.padLeadingWith("0",2);
		self.deleteContainer( tiId );
	endforeach;
	foreach index in 1 to 10 do
		tiId := FlatBaseId &amp; index.padLeadingWith("0",2);
		self.deleteContainer( tiId );
	endforeach;
	foreach index in 1 to 10 do
		tiId := ChildBaseId &amp; index.padLeadingWith("0",2);
		self.deleteContainer( tiId );
	endforeach;	
	foreach index in 1 to 10 do
		tiId := ParentBaseId &amp; index.padLeadingWith("0",2);
		self.deleteContainer( tiId );
	endforeach;	
	foreach index in 1 to 10 do
		tiId := MT40BaseId &amp; index.padLeadingWith("0",2);
		self.deleteContainer( tiId );
	endforeach;
	foreach index in 1 to 10 do
		tiId := MT20BaseId &amp; index.padLeadingWith("0",2);
		self.deleteContainer( tiId );
	endforeach;
	self.deleteYA(YA_Alloc);
	self.deleteTerminalArea( StraddleStack );
	self.deleteTerminalArea( BlockStack );
	
	//set up
	ss := self.addStraddleStack( StraddleStack, 3, 2, 3 );
	self.assertTrueMsg( ss &lt;&gt; null, "Failed to create Straddle Stack in set up" );
	bs := self.addBlockStack( BlockStack, 50, null );
	self.assertTrueMsg( bs &lt;&gt; null, "Failed to create Block Stack in set up" );

	//create cargo in block stack
	self.opts.purge();
	self.opts.addAssoc("Hazard", "1.1");
	self.opts.addAssoc("HazardDescription", "Explosives");
	foreach index in 1 to 10 do
		tiId := HAZIdBase &amp; index.padLeadingWith("0",2);
		ti := self.addContainerAtLocation(tiId, null, "2200", "GENL", TI_IMEX_STATUS_STORAGE, bs);
		self.updateTI(ti);
	endforeach;	
	self.opts.purge();
	foreach index in 1 to 10 do
		tiId := FlatBaseId &amp; index.padLeadingWith("0",2);
		ti := self.addContainerAtLocation(tiId, null, "2061", "MT", TI_IMEX_STATUS_STORAGE, bs);
	endforeach;	
	create packTIs transient;
	foreach index in 1 to 10 do
		tiId := ParentBaseId &amp; index.padLeadingWith("0",2);
		tiParent := self.addContainerAtLocation(tiId, null, "2060", "MT", TI_IMEX_STATUS_STORAGE, bs);
		beginTransaction;
		tiParent.CM_Container.setDoorsDirn(TI_DOORSDIRN_ENDDOWN);
		commitTransaction;
		tiId := ChildBaseId &amp; index.padLeadingWith("0",2);
		tiChild := self.addContainerAtLocation(tiId, null, "2060", "MT", TI_IMEX_STATUS_STORAGE, bs);
		beginTransaction;
		tiChild.CM_Container.setDoorsDirn(TI_DOORSDIRN_ENDDOWN);
		commitTransaction;
		packTIs.clear();
		packTIs.add( tiChild );
		self.packContainer( tiParent, packTIs );
	endforeach;
	
	foreach index in 1 to 10 do
		tiId := MT40BaseId &amp; index.padLeadingWith("0",2);
		ti := self.addContainerAtLocation(tiId, null, "4200", "MT", TI_IMEX_STATUS_STORAGE, bs);
	endforeach;
	foreach index in 1 to 10 do
		tiId := MT20BaseId &amp; index.padLeadingWith("0",2);
		ti := self.addContainerAtLocation(tiId, null, "2200", "MT", TI_IMEX_STATUS_STORAGE, bs);
	endforeach;
	
	//Add Max Stack Height Criteria to the Starddle Stack.
	create names transient;
	create neverMixs transient;
	create heights transient;
	create objectArray transient;
	
	names.add("Hazardous");
	heights.add(1);
	neverMixs.add(true);
	create allTransientCriteriaObj transient;
	self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_IsHazardous], CM_YADataBoolean.VALUE_TRUE ); //Hazardous
	objectArray.add( allTransientCriteriaObj );
	
	names.add("Flat Racks with Child cargo");
	heights.add(2);
	neverMixs.add(true);
	create allTransientCriteriaObj transient;
	self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_ISO], "2061, 4261, 2060" ); //Flat racks
	self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_HasChildren],  CM_YADataBoolean.VALUE_TRUE ); //Has Children
	objectArray.add( allTransientCriteriaObj );
	
	names.add("Empty Forties");
	heights.add(3);
	neverMixs.add(false);
	create allTransientCriteriaObj transient;
	self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_IsForty], CM_YADataBoolean.VALUE_TRUE ); //Is 40
	self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_IsEmpty], CM_YADataBoolean.VALUE_TRUE ); //Is Empty
	objectArray.add( allTransientCriteriaObj );
	
	names.add("Empty Twenties");
	heights.add(4);
	neverMixs.add(false);
	create allTransientCriteriaObj transient;
	self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_IsTwenty], CM_YADataBoolean.VALUE_TRUE ); //Is 20
	self.getCriteriaSingleCMIF( allTransientCriteriaObj, app.myRoot.allYACriteriaTypes[YACriteriaType_IsEmpty], CM_YADataBoolean.VALUE_TRUE ); //Is Empty
	objectArray.add( allTransientCriteriaObj );
	
	self.addTermAreaMaxStackHeights( ss, names, neverMixs, heights, objectArray );
	
	//move one of each type to straddle stacks pad positions.
	
	//Hazardous - should not allow any stacking
	tiId := HAZIdBase &amp; "01";
	ti := self.getTerminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container );
	
	self.getTerminal.findLocationFromString(StraddleStack &amp; " 010001", true, foundLC, dummyHeight);	
	self.assertTrueMsg( foundLC &lt;&gt; null, "GC position '" &amp; StraddleStack &amp; " 010001' not found");
	stackController := foundLC.CM_StackController;
	
	//Check the mechanism first
	self.opts.purge();
	self.opts.addAssoc("IsForcedMove",false);
	maxHeight := stackController.getCurrentMaxHeightForPad(reason);
	self.assertTrueMsg( maxHeight = 3, "Test 1 " &amp; stackController.getFullId &amp; " getCurrentMaxHeightForPad not = 3 (was " &amp; maxHeight.String &amp; ") Pre Moves, reason = " &amp; reason );
	
	self.movePlanned( ti, stackController);
	maxHeight := stackController.getCurrentMaxHeightForPad(reason);
	self.assertTrueMsg( maxHeight = 1, "Test 2 " &amp; stackController.getFullId &amp; " getCurrentMaxHeightForPad not = 1 (was " &amp; maxHeight.String &amp; ") for Hazardous PLANNED, reason = " &amp; reason );
	
	self.moveQueued( ti, stackController);
	maxHeight := stackController.getCurrentMaxHeightForPad(reason);
	self.assertTrueMsg( maxHeight = 1, "Test 3 " &amp; stackController.getFullId &amp; " getCurrentMaxHeightForPad not = 1 (was " &amp; maxHeight.String &amp; ") for Hazardous QUEUED, reason = " &amp; reason );
	
	self.move( ti, stackController);
	self.assertTrueMsg( ti.myPrimaryActualLocation = stackController, "Failed to move first Hazardous" );
	maxHeight := stackController.getCurrentMaxHeightForPad(reason);
	self.assertTrueMsg( maxHeight = 1, "Test 4 " &amp; stackController.getFullId &amp; " getCurrentMaxHeightForPad not = 1 (was " &amp; maxHeight.String &amp; ") for Hazardous REAL, reason = " &amp; reason );
	
	//try to move a second one to the same pad position. plan, queue, real
	tiId := HAZIdBase &amp; "02";
	ti := self.getTerminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container );
	
	self.opts.purge();
	self.opts.addAssoc("ExpectErrors",true);
	self.opts.addAssoc("IsForcedMove",false);
	self.movePlanned( ti, stackController);
	self.assertTrueMsg( app.myPassport.allWarnings.includesErrorCode( Err_Cannot_Move ), "Test 5 " &amp; "Should have raised a warning trying to plan second Hazardous" );

	self.moveQueued( ti, stackController);
	self.assertTrueMsg( app.myPassport.allWarnings.includesErrorCode( Err_Cannot_Move ), "Test 6 " &amp; "Should have raised a warning trying to queue second Hazardous" );
	
	self.move( ti, stackController);
	self.assertTrueMsg( app.myPassport.allErrors.includesErrorCode( Err_Cannot_Move ), "Test 7 " &amp; "Should have raised an error trying to move second Hazardous" );

	
	//Flat racks with Children- should allow 2 high only
	tiId := ParentBaseId &amp; "01";
	ti := self.getTerminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container );
	self.getTerminal.findLocationFromString(StraddleStack &amp; " 010002", true, foundLC, dummyHeight);	
	self.assertTrueMsg( foundLC &lt;&gt; null, "Test 1 " &amp; "GC position '" &amp; StraddleStack &amp; " 010002' not found");
	stackController := foundLC.CM_StackController;
	
	self.opts.purge();
	self.opts.addAssoc("IsForcedMove",false);
	self.move( ti, stackController);
	self.assertTrueMsg( ti.myPrimaryActualLocation = stackController, "Test 8 " &amp; "Failed to move first Flat rack" );
	
	tiId := FlatBaseId &amp; "02";	// move a second flatrack but without children, should fail, because the stack rule for this cargo doesn't match the current Stack Rule and has to because of teh 'never Mix' value.
	ti := self.getTerminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container );
	self.opts.addAssoc("ExpectErrors",true);
	self.move( ti, stackController);
	self.assertTrueMsg( app.myPassport.allErrors.includesErrorCode( Restr_does_not_permi_mixin_car ), "Test 8A " &amp; "Should have raised a 'nver mix' error trying to move a non parent Flat rack" );
	
	tiId := ParentBaseId &amp; "02";	// move a second flatrack
	ti := self.getTerminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container );
	self.move( ti, stackController);
	self.assertTrueMsg( ti.myPrimaryActualLocation = stackController, "Test 9 " &amp; "Failed to move second Flat rack" );
	
	tiId := ParentBaseId &amp; "03";	// move a second flatrack
	ti := self.getTerminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container );
	self.opts.addAssoc("ExpectErrors",true);
	self.move( ti, stackController);
	self.assertTrueMsg( app.myPassport.allErrors.includesErrorCode( Err_Cannot_Move ), "Test 10 " &amp; "Should have raised an error trying to move the third Flat rack" );
		
	
	//Empty 40s - should not allow 3 high only
	tiId := MT40BaseId &amp; "01";
	ti := self.getTerminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container );
	self.getTerminal.findLocationFromString(StraddleStack &amp; " 020001", true, foundLC, dummyHeight);	
	self.assertTrueMsg( foundLC &lt;&gt; null, "GC position '" &amp; StraddleStack &amp; " 020001' not found");
	stackController := foundLC.CM_StackController;
	
	self.opts.purge();
	self.opts.addAssoc("IsForcedMove",false);
	self.move( ti, stackController);
	self.assertTrueMsg( ti.myPrimaryActualLocation = stackController, "Test 11 " &amp; "Failed to move first Empty Forty" );
	
	tiId := MT40BaseId &amp; "02";
	ti := self.getTerminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container );
	self.movePlanned( ti, stackController);
	self.assertTrueMsg( ti.myPrimaryPlannedLocation = stackController, "Test 12 " &amp; "Failed to plan second Empty Forty" );

	self.moveQueued( ti, stackController);
	self.assertTrueMsg( ti.myPrimaryQueuedLocation = stackController, "Test 13 " &amp; "Failed to queue second Empty Forty" );
	
	self.move( ti, stackController);
	self.assertTrueMsg( ti.myPrimaryActualLocation = stackController, "Test 14 " &amp; "Failed to move second Empty Forty" );
	
	tiId := MT40BaseId &amp; "03";
	ti := self.getTerminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container );
	self.move( ti, stackController);
	self.assertTrueMsg( ti.myPrimaryActualLocation = stackController, "Test 15 " &amp; "Failed to move third Empty Forty" );
	
	tiId := MT40BaseId &amp; "04";
	ti := self.getTerminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container );
	self.opts.addAssoc("ExpectErrors",true);
	self.move( ti, stackController);
	self.assertTrueMsg( app.myPassport.allErrors.includesErrorCode( Err_Cannot_Move ), "Test 16 " &amp; "Should have raised an error trying to move fourth Empty Forty" );
	
	
	//Empty 20s - should only allow 3 high even-though its declared as 4 on criteria, the existing code should stop it.
	tiId := MT20BaseId &amp; "01";
	ti := self.getTerminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container );
	self.getTerminal.findLocationFromString(StraddleStack &amp; " 030001", true, foundLC, dummyHeight);	
	self.assertTrueMsg( foundLC &lt;&gt; null, "GC position '" &amp; StraddleStack &amp; " 030001' not found");
	stackController := foundLC.CM_StackController;
	
	self.opts.purge();
	self.opts.addAssoc("IsForcedMove",false);
	self.move( ti, stackController);
	self.assertTrueMsg( ti.myPrimaryActualLocation = stackController, "Test 17 " &amp; "Failed to move first Empty Twenty" );
	
	tiId := MT20BaseId &amp; "02";
	ti := self.getTerminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container );
	self.move( ti, stackController);
	self.assertTrueMsg( ti.myPrimaryActualLocation = stackController, "Test 18 " &amp; "Failed to move second Empty Twenty" );
	
	tiId := MT20BaseId &amp; "03";
	ti := self.getTerminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container );
	self.move( ti, stackController);
	self.assertTrueMsg( ti.myPrimaryActualLocation = stackController, "Test 19 " &amp; "Failed to move third Empty Twenty" );
	
	tiId := MT20BaseId &amp; "04";
	ti := self.getTerminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container );
	self.opts.addAssoc("ExpectErrors",true);
	self.move( ti, stackController);
	self.assertTrueMsg( app.myPassport.allErrors.includesErrorCode( Err_Cannot_Move ), "Test 20 " &amp; "Should have raised an error trying to move fourth Empty Twenty" );
	
	//Now set up a yard allocation
	
	create locations transient; // This is actually a range represented by the first and last locations
	self.getTerminal.findLocationFromString(StraddleStack &amp; " 010001", true, foundLC, dummyHeight);	
	locations.add( foundLC );
	self.getTerminal.findLocationFromString(StraddleStack &amp; " 030002", true, foundLC, dummyHeight);	
	locations.add( foundLC );
	self.opts.addAssoc("SeparateRanges",true); 
	ya := self.addYA1(YA_Alloc, YACriteriaType_CargoType, app.myRoot.allCargoTypesById[TI_CargoType_Container].CM_CargoType, locations);
	
	//do an autoplan, (each of the twentys should find) should find the last position.
	
	self.getTerminal.findLocationFromString(StraddleStack &amp; " 030002", true, foundLC, dummyHeight);	
	self.assertTrueMsg( foundLC &lt;&gt; null, "GC position '" &amp; StraddleStack &amp; " 030002' not found");
	stackController := foundLC.CM_StackController;
	
	
	tiId := HAZIdBase &amp; "02";
	ti := self.getTerminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container );
	app.myPassport.clearErrorsWarnings();
	beginTransaction;
	ti.autoPlan(PLANNING_MODE, null, null, null, app.myPassport);
	commitTransaction;
	self.assertTrueMsg( ti.myPrimaryPlannedLocation = stackController, "Test 21 " &amp; "Failed to auto plan (PLANNING_MODE) Hazardous to the last stack controller. " &amp; app.myPassport.getAllErrorsWarningsAsString );	
	self.unplanTI( ti );
	
	beginTransaction;
	ti.autoPlan(QUEUE_MODE, null, null, null, app.myPassport);
	commitTransaction;
	self.assertTrueMsg( ti.myPrimaryQueuedLocation = stackController, "Test 22 " &amp; "Failed to auto plan (QUEUE_MODE) Hazardous to the last stack controller. " &amp; app.myPassport.getAllErrorsWarningsAsString );	
	
	//Try planning another HAz it should fail, because everything will be full.
	
	tiId := HAZIdBase &amp; "03";
	ti := self.getTerminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container );
	app.myPassport.clearErrorsWarnings();
	beginTransaction;
	ti.autoPlan(PLANNING_MODE, null, null, null, app.myPassport);
	commitTransaction;
	self.assertTrueMsg( ti.myPrimaryPlannedLocation = null, "Test 23 " &amp; "Should have failed to auto plan (PLANNING_MODE) second Hazardous to the last stack controller, its full. ");	
	
	//now try 20 foot MTs, should be able to do 3.
	//unplan the Haz from the last stack pad positiobn, so its completely empty again.
	tiId := HAZIdBase &amp; "02";
	ti := self.getTerminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container );
	self.unqueueTI( ti );
	
	tiId := MT20BaseId &amp; "04";
	ti := self.getTerminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container );
	app.myPassport.clearErrorsWarnings();
	beginTransaction;
	ti.autoPlan(PLANNING_MODE, null, null, null, app.myPassport);
	commitTransaction;
	self.assertTrueMsg( ti.myPrimaryPlannedLocation = stackController, "Test 24 " &amp; "Failed to auto plan (PLANNING_MODE) Empty Twenty to the last stack controller. " &amp; app.myPassport.getAllErrorsWarningsAsString );	
	
	tiId := MT20BaseId &amp; "05";
	ti := self.getTerminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container );
	app.myPassport.clearErrorsWarnings();
	beginTransaction;
	ti.autoPlan(PLANNING_MODE, null, null, null, app.myPassport);
	commitTransaction;
	self.assertTrueMsg( ti.myPrimaryPlannedLocation = stackController, "Test 25 " &amp; "Failed to auto plan (PLANNING_MODE) second Empty Twenty to the last stack controller. " &amp; app.myPassport.getAllErrorsWarningsAsString );	
	
	tiId := MT20BaseId &amp; "06";
	ti := self.getTerminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container );
	app.myPassport.clearErrorsWarnings();
	beginTransaction;
	ti.autoPlan(PLANNING_MODE, null, null, null, app.myPassport);
	commitTransaction;
	self.assertTrueMsg( ti.myPrimaryPlannedLocation = stackController, "Test 26 " &amp; "Failed to auto plan (PLANNING_MODE) third Empty Twenty to the last stack controller. " &amp; app.myPassport.getAllErrorsWarningsAsString );	
	
	//Should be fully planned now, so try one more and it should fail.
	tiId := MT20BaseId &amp; "07";
	ti := self.getTerminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container );
	app.myPassport.clearErrorsWarnings();
	beginTransaction;
	ti.autoPlan(PLANNING_MODE, null, null, null, app.myPassport);
	commitTransaction;
	self.assertTrueMsg( ti.myPrimaryPlannedLocation = null, "Test 27 " &amp; "Should have failed to auto plan (PLANNING_MODE) fourth Empty Twenty to the last stack controller, its already fully planned. ");
	
	//try a queue it should get the same result.
	app.myPassport.clearErrorsWarnings();
	beginTransaction;
	ti.autoPlan(QUEUE_MODE, null, null, null, app.myPassport);
	commitTransaction;
	self.assertTrueMsg( ti.myPrimaryQueuedLocation = null, "Test 28 " &amp; "Should have failed to auto plan (QUEUE_MODE) fourth Empty Twenty to the last stack controller, its already fully planned. ");
	
	//clear all the planned tis from the last position then re-plan, should only allow 2.
	tiId := MT20BaseId &amp; "04";
	ti := self.getTerminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container );
	self.unplanTI( ti );
	tiId := MT20BaseId &amp; "05";
	ti := self.getTerminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container );
	self.unplanTI( ti );
	tiId := MT20BaseId &amp; "06";
	ti := self.getTerminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container );
	self.unplanTI( ti );
	
	// make the last position unavailable above level 2
	beginTransaction;
	stackController.setPropertyValue( "availability", 5.Integer );
	commitTransaction;
	
	tiId := MT20BaseId &amp; "04";
	ti := self.getTerminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container );
	app.myPassport.clearErrorsWarnings();
	beginTransaction;
	ti.autoPlan(PLANNING_MODE, null, null, null, app.myPassport);
	commitTransaction;
	self.assertTrueMsg( ti.myPrimaryPlannedLocation = stackController, "Test 29 " &amp; "Failed to auto plan (PLANNING_MODE) Empty Twenty to the last stack controller with level 3 unavailable. " &amp; app.myPassport.getAllErrorsWarningsAsString );	
	
	tiId := MT20BaseId &amp; "05";
	ti := self.getTerminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container );
	app.myPassport.clearErrorsWarnings();
	beginTransaction;
	ti.autoPlan(PLANNING_MODE, null, null, null, app.myPassport);
	commitTransaction;
	self.assertTrueMsg( ti.myPrimaryPlannedLocation = stackController, "Test 30 " &amp; "Failed to auto plan (PLANNING_MODE) second Empty Twenty to the last stack controller with level 3 unavailable. " &amp; app.myPassport.getAllErrorsWarningsAsString );	
	
	tiId := MT20BaseId &amp; "06";
	ti := self.getTerminal.allOnsiteTIsByIdCargoType.getAtKey( tiId, TI_CargoType_Container );
	app.myPassport.clearErrorsWarnings();
	beginTransaction;
	ti.autoPlan(PLANNING_MODE, null, null, null, app.myPassport);
	commitTransaction;
	self.assertTrueMsg( ti.myPrimaryPlannedLocation = null, "Test 31 " &amp; "Should have failed to auto plan (PLANNING_MODE) third Empty Twenty to the last stack controller,  with level 3 unavailable. ");
	
	
	//All done, clean-up
	foreach index in 1 to 10 do
		tiId := HAZIdBase &amp; index.padLeadingWith("0",2);
		self.deleteContainer( tiId );
	endforeach;
	foreach index in 1 to 10 do
		tiId := FlatBaseId &amp; index.padLeadingWith("0",2);
		self.deleteContainer( tiId );
	endforeach;
	foreach index in 1 to 10 do
		tiId := ChildBaseId &amp; index.padLeadingWith("0",2);
		self.deleteContainer( tiId );
	endforeach;	
	foreach index in 1 to 10 do
		tiId := ParentBaseId &amp; index.padLeadingWith("0",2);
		self.deleteContainer( tiId );
	endforeach;	
	foreach index in 1 to 10 do
		tiId := MT40BaseId &amp; index.padLeadingWith("0",2);
		self.deleteContainer( tiId );
	endforeach;
	foreach index in 1 to 10 do
		tiId := MT20BaseId &amp; index.padLeadingWith("0",2);
		self.deleteContainer( tiId );
	endforeach;
	self.deleteYA(YA_Alloc);
	self.deleteTerminalArea( StraddleStack );
	self.deleteTerminalArea( BlockStack );
	
	
epilog

	abortTransaction;

	self.disableAllYA(false);

	delete names;
	delete neverMixs;
	delete heights;
	if objectArray &lt;&gt; null and not objectArray.isEmpty then
		foreach obj in objectArray do
			allTransientCriteriaObj := obj.CMIF_Array;
			if allTransientCriteriaObj &lt;&gt; null and not allTransientCriteriaObj.isEmpty then	
				allTransientCriteriaObj.purge();
			endif;
		endforeach;
		objectArray.purge();
	endif;
	delete objectArray;
	delete locations;
	delete packTIs;

end;</source>
    </JadeMethod>
    <JadeMethod name="tLabourRestrictionsPlnQueInstM" id="6836ecdf-35ca-4047-ad1c-edfae70cce51">
        <source>tLabourRestrictionsPlnQueInstM();

/*

Purpose:		Plan / Queue / Instance Move to / from Area with Labour Restrictions

Date			Who		Reason
19/02/2015		cnwmh5	Initial creation

*/

constants

	BlockStackRID				: String = "UTMHLBR";
	BlockStackNRID				: String = "UTMHLBNR";
	LabourRestrictionID			: String = "UTLBR1";

vars

	bsR							: CM_BlockStack;
	bsNR						: CM_BlockStack;
	labourRestriction			: CM_LabourRestriction;
	
	objSet						: ObjectSet;
	tiArray						: CM_TIArray;

begin

	create tiArray transient;

	// create the blockstacks and add cargo
	bsR := self.addBlockStack(BlockStackRID, 10, null);
	self.assertNotNull(bsR);
	self.addQuickCargo(bsR, null, 5, tiArray);
	
	bsNR := self.addBlockStack(BlockStackNRID, 10, null);
	self.assertNotNull(bsNR);
	tiArray.clear();
	self.opts.purge();
	self.opts.addAssoc("ReturnTIs", true);
	self.addQuickCargo(bsNR, null, 5, tiArray);
	
	// create labour restriction over UTMHLBR
	labourRestriction := self.addLabourRestriction(LabourRestrictionID, bsR, false);
	self.assertNotNull(labourRestriction);
	
	// plan an item to area with labour restriction - should plan without warning or error
	self.opts.purge();
	self.opts.addAssoc("MoveMode", PLANNING_MODE);
	self.move(tiArray[1].CM_TrackedItem, bsR);
		
	// queue an item to area with labour restriction - should return a warning, place on hold
	self.opts.purge();
	self.opts.addAssoc("MoveMode", QUEUE_MODE);
	self.move(tiArray[2].CM_TrackedItem, bsR);
	self.assertTrxWarning(WARN_RESTRICT_LABOUR);
	self.assertEqualMsg(tiArray[2].CM_TrackedItem.getQueueTask.status, TASK_SYS_HELD, tiArray[1].id &amp; ' task is NOT Held');
	
	// instant move an item to area with labour restriction - should return a warning
	self.opts.purge();
	self.opts.addAssoc("MoveMode", REAL_MODE);
	self.move(tiArray[3].CM_TrackedItem, bsR);
	self.assertTrxWarning(WARN_RESTRICT_LABOUR);
	
	create objSet transient;
	bsR.getAllLocationsTrackedItems(objSet);
	tiArray.clear();
	objSet.copy(tiArray);
	
	// plan an item from area with labour restriction - should plan without warning or error
	self.opts.purge();
	self.opts.addAssoc("MoveMode", PLANNING_MODE);
	self.move(tiArray[1].CM_TrackedItem, bsNR);
		
	// queue an item from area with labour restriction - should return a warning, place on hold
	self.opts.purge();
	self.opts.addAssoc("MoveMode", QUEUE_MODE);
	self.move(tiArray[2].CM_TrackedItem, bsNR);
	self.assertTrxWarning(WARN_RESTRICT_LABOUR);
	self.assertEqualMsg(tiArray[2].CM_TrackedItem.getQueueTask.status, TASK_SYS_HELD, tiArray[1].id &amp; ' task is NOT Held');
	
	// instant move an item from area with labour restriction - should return a warning
	self.opts.purge();
	self.opts.addAssoc("MoveMode", REAL_MODE);
	self.move(tiArray[3].CM_TrackedItem, bsNR);
	self.assertTrxWarning(WARN_RESTRICT_LABOUR);
	
epilog

	delete objSet;
	delete tiArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRMGArea" id="e68b6bcc-3495-4014-a73a-b7e1b392ca81">
        <source>tRMGArea();
/*

Purpose:			Testlink test 01-190

Date		Who		Reason
11 April 2016	cnwmk3	Initial creation

*/

vars
	rmg1, rmg2, rmg3			: CM_RTGArea;
	rtgArea1, rtgArea2			: CM_RTGArea;
	lane						: CM_RTGLane;
	q1, q2						: CM_SubQueue;
	taArray						: CM_TerminalAreaArray;
	realLane					: CM_TerminalAreaMaster;
	ta							: CM_TerminalArea;
begin
	// delete RTG lane
	lane := self.getTerminalArea("RTG01").CM_RTGArea.getRTGLane();
	if lane &lt;&gt; null then
		app.myTrxDA.trxDeleteRTGLane(lane, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
	// Add a terminal area of type Rail Mounted Gantry.
	rmg1 := self.addRMGArea("UT_RMG1", 5, 2, 2);
	self.assertNotNull(rmg1);
	
	//  Add a RMG area with the Side Interchange area above the first row.
	rmg2 := self.addRMGArea("UT_RMG2", 5, 2, 2);
	self.assertNotNull(rmg2);
	
	// Add a RMG area with the Side Interchange area below the last row.
	self.opts.purge();
	self.opts.addAssoc("ICArea", CM_RTGArea.ICPosition_AfterLastRow);
	rmg3 := self.addRMGArea("UT_RMG3", 5, 2, 2);
	self.assertNotNull(rmg3);
	
	// Add 2 RTG Areas in one Lane
	self.deleteTerminalArea("RTG01");
	rtgArea1 := self.addRTGArea("RTG01",2,2,2);
	self.assertNotNull(rtgArea1);
	self.deleteTerminalArea("RTG02");
	rtgArea2 := self.addRTGArea("RTG02",2,2,2);
	self.assertNotNull(rtgArea2);
	
	create taArray transient;
	taArray.add(rtgArea1);
	taArray.add(rtgArea2);
	
	create lane transient;
	lane.setProxy("UT_LANE", TA_TYPE_RTG_LANE, self.getTerminal, null, null, taArray);
	
	app.myTrxCA.trxCreateTerminalArea(lane, realLane, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// Add Queues for RTG and RMG
	q1 := self.addQueueToTA("UT_RMG_Q", rmg1);
	self.assertNotNull(q1);
	
	q2 := self.addQueueToTA("RTG01_Q", rtgArea1);
	self.assertNotNull(q2);
	
epilog
	delete lane;
	delete taArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="tReeferWalkPathUnavailable" id="c63377c0-52f8-4ca4-85db-5d55489bbe27">
        <source>tReeferWalkPathUnavailable();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
15 August 2023	navpw1	Initial creation TFS: 57947 (59757)

*/

constants
	Ref					: String = "UT" &amp; self.TFS57947;
	ForkLiftStackId		: String = Ref;
	BaseCargoId			: String = "C" &amp; Ref;
	ReeferBlockName		: String = Ref &amp; "ReeferWalk";
	ReeferBlockName2	: String = Ref &amp; "ReeferWalkChgd";
	StackHeight			: Integer = 2;
	
vars
	index, count, contId		: Integer;
	tiId						: String;
	operator					: CM_Operator;
	gridBS						: CM_ForkLiftStack;
	lcArray						: CM_LCArray;
	ti							: CM_TrackedItem;
	tiArray,
	checkTiArray				: CM_TIArray;
	pxyReeferBlock,
	reeferBlock					: CM_ReeferBlock;
	reeferWalkPositionArray 	: CM_ReeferBlockPositionArray;
	lc							: CM_LocationsController;
	proxyReeferBlockPos,
	reeferBlockPosition			: CM_ReeferBlockPosition;
	iter						: Iterator;
	gridController				: CM_GridController;
	
begin
	// clean up
	foreach index in 1 to 18 do
		tiId := BaseCargoId &amp; index.padLeadingWith('0',2);
		self.deleteTrackedItem( tiId, false );
	endforeach;
	self.deleteTerminalArea( ForkLiftStackId );
	
	// set up
	//Get Operator
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	
	//Add forklift stack
	self.opts.addAssoc("WithPower", true);
	gridBS := self.addForkLiftStack( ForkLiftStackId, 3, 3, 3 );
	self.assertTrueMsg( gridBS &lt;&gt; null, "Failed to set up Gridded Block Stack" );
	self.opts.purge;
	
	//Get all location contollers from gridded block stack
	create lcArray transient;
	gridBS.allLocationsControllers.copy( lcArray );
	
	//Check there are 9 of them
	self.assertTrueMsg( lcArray.size = 9, "Gridded Block Stack, incorrect number of LCs found during setup" );
	
	beginTransaction;
	foreach gridController in lcArray as CM_GridController do
		gridController.setAvailability(PAD_HEIGHT_3_UNAVAIL);
	endforeach;
	commitTransaction;
	
	//Create 27 cargo id's and add them to locations
	create tiArray transient;
	
	foreach lc in lcArray do
		foreach index in 1 to StackHeight do
			tiId := BaseCargoId &amp; contId.padLeadingWith('0',2);
			contId += 1;
			ti := self.addContainerAtLocation(tiId, operator, "22RT", "REEF", TI_IMEX_STATUS_EXPORT, lc );
			self.assertTrueMsg( ti &lt;&gt; null, tiId &amp; " container not created");
			tiArray.add( ti );
		endforeach;
		
	endforeach;
	
	// Test
	create reeferWalkPositionArray transient;
	
	count := 0;
	
	//Create Proxy Reefer Block
	create pxyReeferBlock transient;
	pxyReeferBlock.setProxy(ReeferBlockName, gridBS);
	//create the proxy walk poistions
	gridBS.getReeferWalkPositions(pxyReeferBlock);
	pxyReeferBlock.allReeferPositions.copy(reeferWalkPositionArray);
	
	//create a reefer walk path
	app.myPassport.setWarningsIgnored(false);
	app.myTrxCA.trxCreateReeferWalkPath( pxyReeferBlock, reeferWalkPositionArray, reeferBlock, app.myPassport );
	self.assertTrxWarningMsg(NReefer_Err_Name_To_Big, "Walk Patch name greater than 4 characters, expected warning to say as such");
	app.myPassport.warningsAcknowledged := true;
	self.assertNullMsg(reeferBlock, "Expected " &amp; ReeferBlockName &amp; " to not be created due to warnings not being acknowledged yet but was. reeferBlock");
	self.assertTrueMsg(gridBS.allReeferBlocks.size = 0, "Expected " &amp; ForkLiftStackId &amp; " to not have any Reefer Blocks, but found some");
	
	app.myTrxCA.trxCreateReeferWalkPath( pxyReeferBlock, reeferWalkPositionArray, reeferBlock, app.myPassport );
	self.assertTrueMsg( reeferBlock &lt;&gt; null, "Reefer Block not created - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	delete pxyReeferBlock;
	reeferWalkPositionArray.purge();
	
	//Check we have unavailable walk paths included
	self.checkUnavailableReeferWalkPath(reeferWalkPositionArray, PAD_HEIGHT_3_UNAVAIL);
	
	//check the output from the getCurrentTis to make sure everything is there in the order we set.
	create checkTiArray transient;
	reeferBlock.getCurrentTis( checkTiArray );	
	foreach index in 1 to 18 do
		self.assertTrueMsg( tiArray[index] = checkTiArray[index], "Index = " &amp; index.String &amp; " Actual TI failed to match expected TI - Test 1" );
	endforeach;
	
	//Create proxy and update the existing reefer walk path (use the last 10 positions in reverse of current order, and update the name)	
	iter := reeferBlock.allReeferPositions.createIterator;
	while iter.back( reeferBlockPosition ) do
		create proxyReeferBlockPos transient;	
		proxyReeferBlockPos.setDetails( reeferBlockPosition.myLocationController, null, reeferBlockPosition.position, reeferBlockPosition.tier );
		reeferWalkPositionArray.add( proxyReeferBlockPos );
		if reeferWalkPositionArray.size = 10 then
			break;
		endif;
	endwhile;
	pxyReeferBlock := app.createUpdateProxy( reeferBlock ).CM_ReeferBlock;
	pxyReeferBlock.setProxy( ReeferBlockName2, gridBS );
	app.myTrxUA.trxUpdateReeferWalkPath( pxyReeferBlock, reeferWalkPositionArray, app.myPassport );
	self.assertTrxWarningMsg(NReefer_Err_Name_To_Big, "Walk Patch name greater than 4 characters, expected warning to say as such");	// Warning should display the second time as the name has changed
	app.myPassport.warningsAcknowledged := true;
	app.myTrxUA.trxUpdateReeferWalkPath( pxyReeferBlock, reeferWalkPositionArray, app.myPassport );
	self.assertTrueMsg( reeferBlock.name = ReeferBlockName2, "Reefer Block not updated - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	//Check we have unavailable walk paths included
	self.checkUnavailableReeferWalkPath(reeferWalkPositionArray, PAD_HEIGHT_3_UNAVAIL);
	
	//check the output from the getCurrentTis to make sure we just have teh 10 and they are in the new order we set.
	checkTiArray.clear;
	reeferBlock.getCurrentTis( checkTiArray );
	self.assertTrueMsg( checkTiArray.size = 6, "Should be 6 Tis returned" );
	foreach index in 1 to checkTiArray.size do
		self.assertTrueMsg( tiArray[index + tiArray.size-checkTiArray.size] = checkTiArray[checkTiArray.size+1 - index], "Index = " &amp; index.String &amp; " Actual TI failed to match expected TI - Test 1" );
	endforeach;
	
	// clean up
	foreach index in 1 to 18 do
		tiId := BaseCargoId &amp; index.padLeadingWith('0',2);
		self.deleteTrackedItem( tiId, false );
	endforeach;
	self.deleteTerminalArea( ForkLiftStackId );

epilog
	delete pxyReeferBlock;
	if reeferWalkPositionArray &lt;&gt; null then
		reeferWalkPositionArray.purge();
	endif;
	delete reeferWalkPositionArray;
	delete lcArray;
	delete tiArray;
	delete checkTiArray;
	delete iter;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tReeferWalks" id="2af85ce3-5117-4b69-a8dd-d68f34a515d2">
        <source>tReeferWalks();
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
10 July 2020	jlgndl1	Initial creation	TFS 49579
15 April 2021	navmd1	TFS 51044 Restrict walk block names to alphanumeric (no spaces)

*/

constants

	ForkLiftStackId : String = "TFS49579";
	BaseCargoId : String = "CTFS49579";
	ReeferBlockName : String = "TFS49579ReeferWalk";
	ReeferBlockName2 : String = "TFS49579ReeferWalkChgd";

vars

	index : Integer;
	tiId : String;
	operator : CM_Operator;
	gridBS : CM_ForkLiftStack;
	lcArray : CM_LCArray;
	rem : Integer;
	lcIndex : Integer;
	ti : CM_TrackedItem;
	tiArray : CM_TIArray;
	pxyReeferBlock : CM_ReeferBlock;
	reeferWalkPositionArray : CM_ReeferBlockPositionArray;
	lc : CM_LocationsController;
	count : Integer;
	tier : Integer;
	maxHeight : Integer;
	proxyReeferBlockPos : CM_ReeferBlockPosition;
	reeferBlock : CM_ReeferBlock;
	reeferBlockPosition : CM_ReeferBlockPosition;
	checkTiArray : CM_TIArray;
	iter : Iterator;
	checkArrayIndex : Integer;
	
begin

	// clean up
	foreach index in 1 to 27 do
		tiId := BaseCargoId &amp; index.padLeadingWith('0',2);
		self.deleteTrackedItem( tiId, false );
	endforeach;
	self.deleteTerminalArea( ForkLiftStackId );
	
	
	// set up
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	gridBS := addForkLiftStack( ForkLiftStackId, 3, 3, 3 );
	self.assertTrueMsg( gridBS &lt;&gt; null, "Failed to set up Gridded Block Stack" );
	create lcArray transient;
	gridBS.allLocationsControllers.copy( lcArray );
	self.assertTrueMsg( lcArray.size = 9, "Gridded Block Stack, incorrect number of LCs found during setup" );
	create tiArray transient;
	
	foreach index in 1 to 27 do
		tiId := BaseCargoId &amp; index.padLeadingWith('0',2);
		rem := index mod 3;
		if rem = 0 then
			lcIndex := (index / 3 ).Integer;
		else
			lcIndex := (( index + ( 3 - rem ) ) / 3 ).Integer; 
		endif;
		ti := self.addContainerAtLocation(tiId, operator, "2200", "MT", TI_IMEX_STATUS_STORAGE, lcArray[lcIndex] );
		self.assertTrueMsg( ti &lt;&gt; null, tiId &amp; " container not created");
		tiArray.add( ti );
	endforeach;
	
	// Test
	
	
	create reeferWalkPositionArray transient;
	
	count := 0;
	//create the proxy walk poistions
	foreach lc in gridBS.allLocationsControllers do
		maxHeight := lc.getMaxStackingHeight;
		if maxHeight &lt; 1 then
			continue;
		endif;
		tier := 1;
		foreach tier in 1 to maxHeight do
			count := count + 1;
			create proxyReeferBlockPos transient;	
			proxyReeferBlockPos.setDetails( lc, null, count, tier );
			reeferWalkPositionArray.add( proxyReeferBlockPos );
		endforeach;	
	endforeach;

	create pxyReeferBlock transient;
	pxyReeferBlock.setProxy( ReeferBlockName, gridBS );
	pxyReeferBlock.allReeferPositions.copy( reeferWalkPositionArray );	
	
	//create a reefer walk path
	app.myPassport.setWarningsIgnored(false);
	app.myTrxCA.trxCreateReeferWalkPath( pxyReeferBlock, reeferWalkPositionArray, reeferBlock, app.myPassport );
	self.assertTrxWarningMsg(NReefer_Err_Name_To_Big, "Walk Patch name greater than 4 characters, expected warning to say as such");
	app.myPassport.warningsAcknowledged := true;
	self.assertNullMsg(reeferBlock, "Expected " &amp; ReeferBlockName &amp; " to not be created due to warnings not being acknowledged yet but was. reeferBlock");
	self.assertTrueMsg(gridBS.allReeferBlocks.size = 0, "Expected " &amp; ForkLiftStackId &amp; " to not have any Reefer Blocks, but found some");
	app.myTrxCA.trxCreateReeferWalkPath( pxyReeferBlock, reeferWalkPositionArray, reeferBlock, app.myPassport );
	self.assertTrueMsg( reeferBlock &lt;&gt; null, "Reefer Block not created - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	delete pxyReeferBlock;
	reeferWalkPositionArray.purge();
	
	
	//check the output from the getCurrentTis to make sure everything is there in the order we set.
	create checkTiArray transient;
	reeferBlock.getCurrentTis( checkTiArray );	
	foreach index in 1 to 27 do
		self.assertTrueMsg( tiArray[index] = checkTiArray[index], "Index = " &amp; index.String &amp; " Actual TI failed to match expected TI - Test 1" );
	endforeach;
	
	//Create proxy and update the existing reefer walk path (use the last 10 positions in reverse of current order, and update the name)	
	iter := reeferBlock.allReeferPositions.createIterator;
	while iter.back( reeferBlockPosition ) do
		create proxyReeferBlockPos transient;	
		proxyReeferBlockPos.setDetails( reeferBlockPosition.myLocationController, null, reeferBlockPosition.position, reeferBlockPosition.tier );
		reeferWalkPositionArray.add( proxyReeferBlockPos );
		if reeferWalkPositionArray.size = 10 then
			break;
		endif;
	endwhile;
	pxyReeferBlock := app.createUpdateProxy( reeferBlock ).CM_ReeferBlock;
	pxyReeferBlock.setProxy( ReeferBlockName2, gridBS );
	app.myTrxUA.trxUpdateReeferWalkPath( pxyReeferBlock, reeferWalkPositionArray, app.myPassport );
	self.assertTrxWarningMsg(NReefer_Err_Name_To_Big, "Walk Patch name greater than 4 characters, expected warning to say as such");	// Warning should display the second time as the name has changed
	app.myPassport.warningsAcknowledged := true;
	app.myTrxUA.trxUpdateReeferWalkPath( pxyReeferBlock, reeferWalkPositionArray, app.myPassport );
	self.assertTrueMsg( reeferBlock.name = ReeferBlockName2, "Reefer Block not updated - " &amp; app.myPassport.getErrorsAndWarningsAsString );
	
	//check the output from the getCurrentTis to make sure we just have teh 10 and they are in the new order we set.
	checkTiArray.clear;
	reeferBlock.getCurrentTis( checkTiArray );
	self.assertTrueMsg( checkTiArray.size = 10, "Should be 10 Tis returned" );
	foreach index in 1 to 10 do
		self.assertTrueMsg( tiArray[index + 17] = checkTiArray[11 - index], "Index = " &amp; index.String &amp; " Actual TI failed to match expected TI - Test 1" );
	endforeach;
	
	// clean up
	foreach index in 1 to 27 do
		tiId := BaseCargoId &amp; index.padLeadingWith('0',2);
		self.deleteTrackedItem( tiId, false );
	endforeach;
	self.deleteTerminalArea( ForkLiftStackId );

epilog

	delete pxyReeferBlock;
	if reeferWalkPositionArray &lt;&gt; null then
		reeferWalkPositionArray.purge();
	endif;
	delete reeferWalkPositionArray;
	delete lcArray;
	delete tiArray;
	delete checkTiArray;
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="tReleaseFromTransferArea" id="089823e9-1956-48dd-9b8c-f7f7aa1d99c1">
        <source>tReleaseFromTransferArea();

/*

Purpose:		trxReleaseFromTransArea

Date			Who		Reason
25/06/2015		cnwmh5	Initial creation

*/

vars

	releaseArea						: CM_BlockStack;
	consignee						: CM_ConsigneeConsignor;
	obj								: Object;
	
	objSet							: ObjectSet;
	tiArray							: CM_TIArray;
	tiSet							: CM_TISet;
	
	deliveryReason					: Integer;
	index							: Integer;

begin

	create tiArray transient;

	releaseArea := self.addReleaseTransArea("UTMHRELT1", 50, null);
	self.assertNotNull(releaseArea);
	self.opts.purge();
	self.opts.addAssoc("ReturnTIs", true);
	self.addQuickCargo(releaseArea, null, 10, tiArray);
	
	create tiSet transient;
	self.assertFalse(tiArray.isEmpty);
	
	foreach index in 1 to (tiArray.size / 2).Integer step 1 do
		tiSet.add(tiArray[index]);
	endforeach;
	
	consignee := self.addConsigneeConsignor("MDH2", "UT MDH Consignee", true, false, false);
	self.assertNotNull(consignee);
	
	deliveryReason := DEL_SNT;
	app.myTrxDA.trxReleaseFromTransArea(tiSet, 0, consignee.code, "Deliv101", deliveryReason, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	create objSet transient;
	releaseArea.getAllLocationsTrackedItems(objSet);
	self.assertEqual(objSet.size, 5);
	
epilog

	delete tiArray;
	delete objSet;
	delete tiSet;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="tResizeTIInRoRoArea" id="f2d4f3a9-799e-43e5-a762-d4fd2f91441c">
        <source>tResizeTIInRoRoArea();
// cnwndl1
//10 March 2010	cnwjk3	

vars
	ti 		: CM_TrackedItem;
	roroArea: CM_RoRoLaneArea;
	lc		: CM_LocationsController;
	tiLen	: Decimal[6,2];
begin
	
	deleteCargo("UCAN1000", "CANNON");
	deleteVehicle("UTTRUCK");
	deleteTerminalArea("UTRORO");
	
	roroArea := addROROArea("UTRORO",  4, 100);
	assertTrueMsg(roroArea &lt;&gt; null, "Failed to add RORO Area");

	gateInGC("UTTRUCK", "", "UTDRIVER", "UCAN1000", "CANNON", self.getProfileSetting(UT_Profile.P_OPERATOR).asString, "", self.getProfileSetting(UT_Profile.P_SGATE).asString,1);
	ti := self.getTrackedItem("UCAN1000");
	
	// Put some length on it
	self.opts.addAssoc("Length", "600");
	self.updateTrackedItem(ti);
			
	move(ti,  roroArea.allLanesByLaneNumber[1]);
	
	tiLen := ti.getLengthInMetres();
	self.assertEqual(roroArea.allLanesByLaneNumber[1].usedLengthActual, tiLen);

	// Resize the TI
	self.opts.purge();
	self.opts.addAssoc("Length", "700");
	self.updateTrackedItem(ti);
		
	tiLen := ti.getLengthInMetres();
	self.assertEqual(roroArea.allLanesByLaneNumber[1].usedLengthActual, tiLen);
	
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tRoadJobPhoto01" id="a6eb1e0e-6c55-43d1-99a5-0271638f1d95">
        <updating/>
        <source>tRoadJobPhoto01() updating;
/*
Purpose - 	the GETMAP for a job must find where the most cargo is and then use the MAP for that location.
				this test is a ROAD JOB that has a RELEASE BY TYPE RELEASE REQUEST. 
				It will use YAs to find where the matching cargo is. The cargo is in BLOCK STACKS, so the map image is on the block stack terminal area
Who - NAVAB1
Date - 28DEC2023
ADO -  CR 58499 TASK 61456
*/



constants
	VESSEL= "DSEQ100";
	VOYAGE= "DSEQ100";
	CARGOTYPEDESC = "UT_ABPULPD";
	TRUCKID = "CD230830";
	STOPID = 631223;
	STOPIDTL = 710227;
vars
	resourcesForm : PictureResourcesForm;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti : CM_TrackedItem;
	tis1, tis2 : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	term : CM_Terminal;
	vvr : CM_VehicleVisitRecord;
	ta1, ta2 : CM_TerminalArea;
	release : CM_BulkRelease;
	detail : CM_ReserveDetail;
	gteEntity : CMGTE_Release;
	wle : CM_WorkListEntry;
	photoDesc : String;
	pictureTA1, pictureTA2, pictureJob : Binary;
	photo : CM_Photo;
	ya : CM_YardAllocation;
	ta1lc, ta2lc : CM_LocationsController;
	cargoTypeSet : CM_CargoTypeSet;
	lcs : CM_LCArray;
begin
	term := self.getTerminal();
	
	// ### JIRA 23230 07OCT2024 NAVAB1
	self.setTerminalConfig(UseYardJobsCargoWO,true);
	
	self.deleteVehicle(TRUCKID);
	
	create tis1 transient;
	create tis2 transient;
	
	ta1 := self.addBlockStack("UTPHT1",9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	ta2 := self.addBlockStack("UTPHT2",9999999,null);
	self.assertNotNullMsg(ta2, "TA2 is null");

	photoDesc := "a photo descrption for TerminalArea";
	
	resourcesForm := PictureResourcesForm.createPrintForm();
	pictureTA1 := resourcesForm.picTA1.picture;
	photo := self.addTerminalAreaPhoto(ta1, photoDesc, pictureTA1);
	pictureTA2 := resourcesForm.picTA2.picture;
	photo := self.addTerminalAreaPhoto(ta2, photoDesc, pictureTA2);
	
	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	
	// ### On Site Import Cargo - "UT_ABPULP"
	
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis1);

	foreach idy in cgSuffix to cgSuffix + 10 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		tis1.add(ti);
	endforeach;
	
	totalQuantity := 200;
	totalWeight := 600;
	totalVolume := 6;
	
	foreach idy in cgSuffix + 20 to cgSuffix + 30 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		tis2.add(ti);
	endforeach;
		
	// ######### YARD ALLOC
	
	self.deleteYA("UTPHOT");
	create lcs transient;
	ta1lc := ta1.allLocationsControllers.first.CM_YardController;
	ta2lc := ta2.allLocationsControllers.first.CM_YardController;
	lcs.add(ta1lc);
	lcs.add(ta2lc);
	
	create cargoTypeSet transient;
	cargoTypeSet.add(cargoType);
	ya := self.addYA1("UTPHOT", YACriteriaType_CargoType, cargoTypeSet, lcs);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Create failed");
	self.assertTrueMsg(ya.allYABlocksIn.size = 2, "Locations not created");
	self.assertTrueMsg(ya.allCriteria.size  = 1, "Criteria not created");
	
	
	
	
	
	// ### MOVE TO YARD
	self.moveAllCargoOnVoyage2(voyage, ta1lc, false);
	
	// ### Create a road release request for the cargo group
	self.opts.purge();
	self.deleteReleaseRequest(cgId);
	
	self.opts.addAssoc("Context", RelReqContext_CargoGroupReview);
	self.opts.addAssoc("CargoGroup", cargoGroup1);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Number", cargoGroup1.totalQuantity);
	
	release := self.addReleaseByTypeRequestOpts(cgId,BR_TYPE_ROAD, cargoType.id);
	
	self.assertTrueMsg(release &lt;&gt; null, "BR is null!");
	
	detail := release.allReserveDetails.first;
	self.assertTrueMsg(detail &lt;&gt; null, "BR Detail is null!");
	self.assertTrueMsg(release.context = RelReqContext_CargoGroupReview, "BR Context should be " &amp; RelReqContext_CargoGroupReview);
	self.assertTrueMsg(detail.myCargoGroup = cargoGroup1, "BR Cargo Group is wrong should be " &amp; cargoGroup1.id);
	self.assertTrueMsg(detail.CM_ReserveSelection.totalRequested = cargoGroup1.totalQuantity, "BR totalRequested should be " &amp; cargoGroup1.totalQuantity.String);
	
	
	// ### Road Gate Release for whole of 1 TI
	self.opts.purge();
	self.opts.addAssoc("ReleaseRequest", release);
	self.opts.addAssoc("AnyId", true);
	self.opts.addAssoc("AnyAmt", true);
	vvr := self.gateOutGC(TRUCKID, "", "UTDRIVER", null,  self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString) , null);

	self.assertTrueMsg(vvr &lt;&gt; null, "VVR is NULL!");
	
	gteEntity := vvr.allGateEntities.first.CMGTE_Release;
	
	self.assertTrueMsg(vvr &lt;&gt; null, "VVR is NULL!");
	self.assertTrueMsg(gteEntity &lt;&gt; null, "gteEntity is NULL!");
	self.assertTrueMsg(gteEntity.getIsAnyAmount() = true, "Any Amount is FALSE");
	self.assertTrueMsg(gteEntity.getIsAnyId() = true, "Any Id is FALSE");
	
	
	pictureJob := vvr.getMap();
	self.assertTrueMsg(pictureJob &lt;&gt; null, "#1 pictureJob is NULL!");
	self.assertTrueMsg(pictureJob = pictureTA1, "pictureJob does not equal pictureTA1");

	
	
	// move LARGER cargo to different area. Shoudl use MAP for this area now
	self.moveCargo(tis2.first, tis2,ta2lc, app.myPassport);

	// ### JIRA 23230 07OCT2024 NAVAB1
	beginTransaction;
	vvr.myRoadJob.getFirstLocationId(true); 
	commitTransaction;
	
	pictureJob := vvr.getMap();
	self.assertTrueMsg(pictureJob &lt;&gt; null, "#2 pictureJob is NULL!");
	self.assertTrueMsg(pictureJob = pictureTA2, "pictureJob does not equal pictureTA2");
	
	// ### TIDY UP
//	return;
	
	self.deleteYA("UTPHOT");
	self.deleteReleaseRequest(cgId);
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
	self.deleteVehicle(TRUCKID);
	
epilog

	delete cargoTypeSet;
	delete resourcesForm;
	delete lcs;
	delete tis1;
	delete tis2;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRoadJobPhoto02" id="3de0b711-f2cb-46e4-b36a-3cbb8a4b5e25">
        <updating/>
        <source>tRoadJobPhoto02() updating;
/*
Purpose - 	the GETMAP for a job must find where the most cargo is and then use the MAP for that location.
				this test is a ROAD JOB that has a RELEASE BY TYPE RELEASE REQUEST. 
				It will use YAs to find where the matching cargo is. The cargo is in GENERAL CARGO AREAS, in this case the map on the TRANSFER AREA is used, not the general cargo area.
Who - NAVAB1
Date - 29DEC2023
ADO -  CR 58499 TASK 61456
*/



constants
	VESSEL= "DSEQ100";
	VOYAGE= "DSEQ100";
	CARGOTYPEDESC = "UT_ABPULPD";
	TRUCKID = "CD230830";
	STOPID = 631223;
	STOPIDTL = 710227;
vars
	resourcesForm : PictureResourcesForm;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti : CM_TrackedItem;
	tis1, tis2 : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	term : CM_Terminal;
	vvr : CM_VehicleVisitRecord;
	ta1 : CM_IrregularBlockArea;
	release : CM_BulkRelease;
	detail : CM_ReserveDetail;
	gteEntity : CMGTE_Release;
	wle : CM_WorkListEntry;
	photoDesc : String;
	pictureTA1, pictureTA2, pictureTA3, pictureJob : Binary;
	photo : CM_Photo;
	ya : CM_YardAllocation;
	cargoTypeSet : CM_CargoTypeSet;
	lcs : CM_LCArray;
	ica1, ica2 : CM_InterchangeArea;
	gc1, gc2 : CM_IrregularBlockController;
begin
	term := self.getTerminal();

	// ### JIRA 23230 07OCT2024 NAVAB1
	self.setTerminalConfig(UseYardJobsCargoWO,true);
	
	self.deleteVehicle(TRUCKID);
	
	create tis1 transient;
	create tis2 transient;
	
	// #### TERMINAL AREAS
	
	self.deleteTerminalArea("UTICA1");
	ica1 := self.addInterchangeArea("UTICA1",null);
	self.assertNotNullMsg(ica1, "UTICA1 is NULL");
	
	self.deleteTerminalArea("UTICA2");
	ica2 := self.addInterchangeArea("UTICA2",null);
	self.assertNotNullMsg(ica2, "UTICA2 is NULL");
	
	self.deleteTerminalArea("UTGC1");
	ta1 := self.addGeneralCargoArea("UTGC1",
									   "UT General Cargo Area",
									   10,
									   6,
									   100,
									   null,
									   null);
	self.assertNotNullMsg(ta1, "UTGC1 is NULL");
	
	self.opts.purge();
	self.opts.addAssoc( "LocationType",  GC_GroundLocation );
	self.opts.addAssoc( "ICArea",  ica1 );
	self.opts.addAssoc( "Capacity",  99999999 );
	self.opts.addAssoc( "MaxWeight",  99999999 );

	gc1 := self.addGCRackOrGround(ta1,1,1,1,1,"GR1");
	self.assertNotNullMsg(gc1, "GR1 is NULL");
	assertEqual(ta1.allLocationsControllers.first.status,0);
	
	self.opts.purge();
	self.opts.addAssoc( "LocationType",  GC_GroundLocation );
	self.opts.addAssoc( "ICArea",  ica2 );
	self.opts.addAssoc( "Capacity",  99999999 );
	self.opts.addAssoc( "MaxWeight",  99999999 );

	gc2 := self.addGCRackOrGround(ta1,3,3,3,3,"GR2");
	self.assertNotNullMsg(gc2, "GR2 is NULL");
	
	
	// # PHOTOS MAPS ON TAs
	
	photoDesc := "a photo descrption for TerminalArea";
	
	resourcesForm := PictureResourcesForm.createPrintForm();
	pictureTA1 := resourcesForm.picTA1.picture;
	photo := self.addTerminalAreaPhoto(ica1, photoDesc, pictureTA1);
	pictureTA2 := resourcesForm.picTA2.picture;
	photo := self.addTerminalAreaPhoto(ica2, photoDesc, pictureTA2);
	pictureTA3 := resourcesForm.picExamplePhoto.picture;
	photo := self.addTerminalAreaPhoto(ta1, photoDesc, pictureTA3);
	
	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	
	// ### On Site Import Cargo - "UT_ABPULP"
	
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis1);

	foreach idy in cgSuffix to cgSuffix + 10 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		tis1.add(ti);
	endforeach;
	
	totalQuantity := 200;
	totalWeight := 600;
	totalVolume := 6;
	
	foreach idy in cgSuffix + 20 to cgSuffix + 30 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		tis2.add(ti);
	endforeach;
		
	// ######### YARD ALLOC
	
	self.deleteYA("UTPHOT");
	create lcs transient;
	lcs.add(gc1);
	lcs.add(gc2);
	
	create cargoTypeSet transient;
	cargoTypeSet.add(cargoType);
	ya := self.addYA1("UTPHOT", YACriteriaType_CargoType, cargoTypeSet, lcs);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Create failed");
	self.assertTrueMsg(ya.allYABlocksIn.size = 2, "Locations not created");
	self.assertTrueMsg(ya.allCriteria.size  = 1, "Criteria not created");
	
	
	
	
	
	// ### MOVE TO YARD
	self.moveAllCargoOnVoyage2(voyage, gc1, false);
	
	// ### Create a road release request for the cargo group
	self.opts.purge();
	self.deleteReleaseRequest(cgId);
	
	self.opts.addAssoc("Context", RelReqContext_CargoGroupReview);
	self.opts.addAssoc("CargoGroup", cargoGroup1);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("Number", cargoGroup1.totalQuantity);
	
	release := self.addReleaseByTypeRequestOpts(cgId,BR_TYPE_ROAD, cargoType.id);
	
	self.assertTrueMsg(release &lt;&gt; null, "BR is null!");
	
	detail := release.allReserveDetails.first;
	self.assertTrueMsg(detail &lt;&gt; null, "BR Detail is null!");
	self.assertTrueMsg(release.context = RelReqContext_CargoGroupReview, "BR Context should be " &amp; RelReqContext_CargoGroupReview);
	self.assertTrueMsg(detail.myCargoGroup = cargoGroup1, "BR Cargo Group is wrong should be " &amp; cargoGroup1.id);
	self.assertTrueMsg(detail.CM_ReserveSelection.totalRequested = cargoGroup1.totalQuantity, "BR totalRequested should be " &amp; cargoGroup1.totalQuantity.String);
	
	
	// ### Road Gate Release for whole of 1 TI
	self.opts.purge();
	self.opts.addAssoc("ReleaseRequest", release);
	self.opts.addAssoc("AnyId", true);
	self.opts.addAssoc("AnyAmt", true);
	vvr := self.gateOutGC(TRUCKID, "", "UTDRIVER", null,  self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString) , null);

	self.assertTrueMsg(vvr &lt;&gt; null, "VVR is NULL!");
	
	gteEntity := vvr.allGateEntities.first.CMGTE_Release;
	
	self.assertTrueMsg(vvr &lt;&gt; null, "VVR is NULL!");
	self.assertTrueMsg(gteEntity &lt;&gt; null, "gteEntity is NULL!");
	self.assertTrueMsg(gteEntity.getIsAnyAmount() = true, "Any Amount is FALSE");
	self.assertTrueMsg(gteEntity.getIsAnyId() = true, "Any Id is FALSE");
	
	
	pictureJob := vvr.getMap();
	self.assertTrueMsg(pictureJob &lt;&gt; null, "#1 pictureJob is NULL!");
	self.assertTrueMsg(pictureJob = pictureTA1, "pictureJob does not equal pictureTA1");

	
	
	// move LARGER cargo to different area. Shoudl use MAP for this area now
	self.moveCargo(tis2.first, tis2,gc2, app.myPassport);

	// ### JIRA 23230 07OCT2024 NAVAB1
	beginTransaction;
	vvr.myRoadJob.getFirstLocationId(true); 
	commitTransaction;
	
	pictureJob := vvr.getMap();
	self.assertTrueMsg(pictureJob &lt;&gt; null, "#2 pictureJob is NULL!");
	self.assertTrueMsg(pictureJob = pictureTA2, "pictureJob does not equal pictureTA2");
	
	// ### TIDY UP
//	return;
	
	self.deleteYA("UTPHOT");
	
	self.deleteReleaseRequest(cgId);
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
	self.deleteVehicle(TRUCKID);
	
epilog
	delete cargoTypeSet;
	delete resourcesForm;
	delete lcs;
	delete tis1;
	delete tis2;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRoadJobPhoto03" id="14f1c553-ab9c-4a5e-8f4d-9d0311dfe645">
        <updating/>
        <source>tRoadJobPhoto03() updating;
/*
Purpose - 	the GETMAP for a job must find where the most cargo is and then use the MAP for that location.
				this test is a ROAD JOB that has a DELIVERY REQUEST no bulk release, reserve details . 
				It will use YAs to find where the matching cargo is. The cargo is in BLOCK STACKS, so the map image is on the block stack terminal area
Who - NAVAB1
Date - 28DEC2023
ADO -  CR 58499 TASK 61456
*/



constants
	VESSEL= "DSEQ100";
	VOYAGE= "DSEQ100";
	CARGOTYPEDESC = "UT_ABPULPD";
	TRUCKID = "CD230830";
	STOPID = 631223;
	STOPIDTL = 710227;
vars
	resourcesForm : PictureResourcesForm;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti : CM_TrackedItem;
	tis1, tis2 : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	term : CM_Terminal;
	vvr : CM_VehicleVisitRecord;
	ta1, ta2 : CM_TerminalArea;
	detail : CM_ReserveDetail;
	gteEntity : CMGTE_Release;
	wle : CM_WorkListEntry;
	photoDesc : String;
	pictureTA1, pictureTA2, pictureJob : Binary;
	photo : CM_Photo;
	ya : CM_YardAllocation;
	ta1lc, ta2lc : CM_LocationsController;
	cargoTypeSet : CM_CargoTypeSet;
	lcs : CM_LCArray;
begin
	term := self.getTerminal();

	// ### JIRA 23230 07OCT2024 NAVAB1
	self.setTerminalConfig(UseYardJobsCargoWO,true);
	
	self.deleteVehicle(TRUCKID);
	
	create tis1 transient;
	create tis2 transient;
	
	ta1 := self.addBlockStack("UTPHT1",9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	ta2 := self.addBlockStack("UTPHT2",9999999,null);
	self.assertNotNullMsg(ta2, "TA2 is null");

	photoDesc := "a photo descrption for TerminalArea";
	
	resourcesForm := PictureResourcesForm.createPrintForm();
	pictureTA1 := resourcesForm.picTA1.picture;
	photo := self.addTerminalAreaPhoto(ta1, photoDesc, pictureTA1);
	pictureTA2 := resourcesForm.picTA2.picture;
	photo := self.addTerminalAreaPhoto(ta2, photoDesc, pictureTA2);
	
	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	
	// ### On Site Import Cargo - "UT_ABPULP"
	
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis1);

	foreach idy in cgSuffix to cgSuffix + 10 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		tis1.add(ti);
	endforeach;
	
	totalQuantity := 200;
	totalWeight := 600;
	totalVolume := 6;
	
	foreach idy in cgSuffix + 20 to cgSuffix + 30 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		tis2.add(ti);
	endforeach;
		
	// ######### YARD ALLOC
	
	self.deleteYA("UTPHOT");
	create lcs transient;
	ta1lc := ta1.allLocationsControllers.first.CM_YardController;
	ta2lc := ta2.allLocationsControllers.first.CM_YardController;
	lcs.add(ta1lc);
	lcs.add(ta2lc);
	
	create cargoTypeSet transient;
	cargoTypeSet.add(cargoType);
	ya := self.addYA1("UTPHOT", YACriteriaType_CargoType, cargoTypeSet, lcs);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Create failed");
	self.assertTrueMsg(ya.allYABlocksIn.size = 2, "Locations not created");
	self.assertTrueMsg(ya.allCriteria.size  = 1, "Criteria not created");
	
	
	
	
	
	// ### MOVE TO YARD
	self.moveAllCargoOnVoyage2(voyage, ta1lc, false);
	
	// ### Road Gate Release 
	self.opts.purge();
	self.opts.addAssoc("AnyId", true);
//	self.opts.addAssoc("AnyAmt", true);
	self.opts.addAssoc("MakeByType", true);
	self.opts.addAssoc("TotalRequested", 1000);
	self.opts.addAssoc("consigneeCode", "UTDDC");
	
	vvr := self.gateOutGC(TRUCKID, "", "UTDRIVER", ti,  self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString) , null);

	self.assertTrueMsg(vvr &lt;&gt; null, "VVR is NULL!");
	
	gteEntity := vvr.allGateEntities.first.CMGTE_Release;
	
	self.assertTrueMsg(vvr &lt;&gt; null, "VVR is NULL!");
	self.assertTrueMsg(gteEntity &lt;&gt; null, "gteEntity is NULL!");
//	self.assertTrueMsg(gteEntity.getIsAnyAmount() = true, "Any Amount is FALSE");
	self.assertTrueMsg(gteEntity.getIsAnyId() = true, "Any Id is FALSE");
	
	
	pictureJob := vvr.getMap();
	self.assertTrueMsg(pictureJob &lt;&gt; null, "#1 pictureJob is NULL!");
	self.assertTrueMsg(pictureJob = pictureTA1, "pictureJob does not equal pictureTA1");

	
	
	// move LARGER cargo to different area. Shoudl use MAP for this area now
	self.moveCargo(tis2.first, tis2,ta2lc, app.myPassport);

	// ### JIRA 23230 07OCT2024 NAVAB1
	beginTransaction;
	vvr.myRoadJob.getFirstLocationId(true); 
	commitTransaction;
	
	pictureJob := vvr.getMap();
	self.assertTrueMsg(pictureJob &lt;&gt; null, "#2 pictureJob is NULL!");
	self.assertTrueMsg(pictureJob = pictureTA2, "pictureJob does not equal pictureTA2");
	
	// ### TIDY UP
//	return;
	
	self.deleteYA("UTPHOT");
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteCargoType(CARGOTYPEDESC);
	self.deleteReleaseRequest(cgId);
	
	self.deleteVehicle(TRUCKID);
	
epilog

	delete cargoTypeSet;
	delete resourcesForm;
	delete lcs;
	delete tis1;
	delete tis2;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRoadJobPhoto04" id="fa0bccc1-f2b6-4557-8b5d-5ec781e46667">
        <updating/>
        <source>tRoadJobPhoto04() updating;
/*
Purpose - 	the GETMAP for a job must find where the most cargo is and then use the MAP for that location.
				this test is a ROAD JOB that has a DELIVERY REQUEST no bulk release, reserve details . 
				It will use YAs to find where the matching cargo is. The cargo is in GENERAL CARGO AREAS, in this case the map on the TRANSFER AREA is used, not the general cargo area.
Who - NAVAB1
Date - 28DEC2023
ADO -  CR 58499 TASK 61456
*/



constants
	VESSEL= "DSEQ100";
	VOYAGE= "DSEQ100";
	CARGOTYPEDESC = "UT_ABPULPD";
	TRUCKID = "CD230830";
	STOPID = 631223;
	STOPIDTL = 710227;
vars
	resourcesForm : PictureResourcesForm;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti : CM_TrackedItem;
	tis1, tis2 : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	term : CM_Terminal;
	vvr : CM_VehicleVisitRecord;
	ta1 : CM_IrregularBlockArea;
	detail : CM_ReserveDetail;
	gteEntity : CMGTE_Release;
	wle : CM_WorkListEntry;
	photoDesc : String;
	pictureTA1, pictureTA2, pictureTA3, pictureJob : Binary;
	photo : CM_Photo;
	ya : CM_YardAllocation;
	ta1lc, ta2lc : CM_LocationsController;
	cargoTypeSet : CM_CargoTypeSet;
	lcs : CM_LCArray;
	ica1, ica2 : CM_InterchangeArea;
	gc1, gc2 : CM_IrregularBlockController;
begin
	term := self.getTerminal();

	// ### JIRA 23230 07OCT2024 NAVAB1
	self.setTerminalConfig(UseYardJobsCargoWO,true);
	
	self.deleteVehicle(TRUCKID);
	
	create tis1 transient;
	create tis2 transient;
	
	// #### TERMINAL AREAS
	
	self.deleteTerminalArea("UTICA1");
	ica1 := self.addInterchangeArea("UTICA1",null);
	self.assertNotNullMsg(ica1, "UTICA1 is NULL");
	
	self.deleteTerminalArea("UTICA2");
	ica2 := self.addInterchangeArea("UTICA2",null);
	self.assertNotNullMsg(ica2, "UTICA2 is NULL");
	
	self.deleteTerminalArea("UTGC1");
	ta1 := self.addGeneralCargoArea("UTGC1",
									   "UT General Cargo Area",
									   10,
									   6,
									   100,
									   null,
									   null);
	self.assertNotNullMsg(ta1, "UTGC1 is NULL");
	
	self.opts.purge();
	self.opts.addAssoc( "LocationType",  GC_GroundLocation );
	self.opts.addAssoc( "ICArea",  ica1 );
	self.opts.addAssoc( "Capacity",  99999999 );
	self.opts.addAssoc( "MaxWeight",  99999999 );

	gc1 := self.addGCRackOrGround(ta1,1,1,1,1,"GR1");
	self.assertNotNullMsg(gc1, "GR1 is NULL");
	assertEqual(ta1.allLocationsControllers.first.status,0);
	
	self.opts.purge();
	self.opts.addAssoc( "LocationType",  GC_GroundLocation );
	self.opts.addAssoc( "ICArea",  ica2 );
	self.opts.addAssoc( "Capacity",  99999999 );
	self.opts.addAssoc( "MaxWeight",  99999999 );

	gc2 := self.addGCRackOrGround(ta1,3,3,3,3,"GR2");
	self.assertNotNullMsg(gc2, "GR2 is NULL");

	// # PHOTOS MAPS ON TAs
	photoDesc := "a photo descrption for TerminalArea";
	
	resourcesForm := PictureResourcesForm.createPrintForm();
	pictureTA1 := resourcesForm.picTA1.picture;
	photo := self.addTerminalAreaPhoto(ica1, photoDesc, pictureTA1);
	pictureTA2 := resourcesForm.picTA2.picture;
	photo := self.addTerminalAreaPhoto(ica2, photoDesc, pictureTA2);
	pictureTA3 := resourcesForm.picExamplePhoto.picture;
	photo := self.addTerminalAreaPhoto(ta1, photoDesc, pictureTA3);
	
	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	
	// ### On Site Import Cargo - "UT_ABPULP"
	
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis1);

	foreach idy in cgSuffix to cgSuffix + 10 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		tis1.add(ti);
	endforeach;
	
	totalQuantity := 200;
	totalWeight := 600;
	totalVolume := 6;
	
	foreach idy in cgSuffix + 20 to cgSuffix + 30 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		tis2.add(ti);
	endforeach;
		
	// ######### YARD ALLOC
	
	self.deleteYA("UTPHOT");
	create lcs transient;
	lcs.add(gc1);
	lcs.add(gc2);
	
	create cargoTypeSet transient;
	cargoTypeSet.add(cargoType);
	ya := self.addYA1("UTPHOT", YACriteriaType_CargoType, cargoTypeSet, lcs);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Create failed");
	self.assertTrueMsg(ya.allYABlocksIn.size = 2, "Locations not created");
	self.assertTrueMsg(ya.allCriteria.size  = 1, "Criteria not created");
	
	
	
	
	
	// ### MOVE TO YARD
	self.moveAllCargoOnVoyage2(voyage, gc1, false);
	
	// ### Road Gate Release 
	self.opts.purge();
	self.opts.addAssoc("AnyId", true);
	self.opts.addAssoc("MakeByType", true);
	self.opts.addAssoc("TotalRequested", 1000);
	self.opts.addAssoc("consigneeCode", "UTDDC");
	
	vvr := self.gateOutGC(TRUCKID, "", "UTDRIVER", ti,  self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString) , null);

	self.assertTrueMsg(vvr &lt;&gt; null, "VVR is NULL!");
	
	gteEntity := vvr.allGateEntities.first.CMGTE_Release;
	
	self.assertTrueMsg(vvr &lt;&gt; null, "VVR is NULL!");
	self.assertTrueMsg(gteEntity &lt;&gt; null, "gteEntity is NULL!");
	self.assertTrueMsg(gteEntity.getIsAnyId() = true, "Any Id is FALSE");
	
	
	pictureJob := vvr.getMap();
	self.assertTrueMsg(pictureJob &lt;&gt; null, "#1 pictureJob is NULL!");
	self.assertTrueMsg(pictureJob = pictureTA1, "pictureJob does not equal pictureTA1");

	
	
	// move LARGER cargo to different area. Shoudl use MAP for this area now
	self.moveCargo(tis2.first, tis2,gc2, app.myPassport);

	// ### JIRA 23230 07OCT2024 NAVAB1
	beginTransaction;
	vvr.myRoadJob.getFirstLocationId(true); 
	commitTransaction;
	
	pictureJob := vvr.getMap();
	self.assertTrueMsg(pictureJob &lt;&gt; null, "#2 pictureJob is NULL!");
	self.assertTrueMsg(pictureJob = pictureTA2, "pictureJob does not equal pictureTA2");
	
	// ### TIDY UP
//	return;
	
	self.deleteYA("UTPHOT");
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteCargoType(CARGOTYPEDESC);
	self.deleteReleaseRequest(cgId);
	
	self.deleteVehicle(TRUCKID);
	
epilog

	delete cargoTypeSet;
	delete resourcesForm;
	delete lcs;
	delete tis1;
	delete tis2;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRoadJobPhoto05" id="9814f73c-8385-4146-b1d4-24a58f6cd574">
        <updating/>
        <source>tRoadJobPhoto05() updating;
/*
Purpose - 	the GETMAP for a job must find where the most cargo is and then use the MAP for that location.
				this test is a ROAD JOB that is BY ID, it has the TIs on the road job, no bulk release
				The cargo is in BLOCK STACKS, so the map image is on the block stack terminal area
Who - NAVAB1
Date - 28DEC2023
ADO -  CR 58499 TASK 61456
*/



constants
	VESSEL= "DSEQ100";
	VOYAGE= "DSEQ100";
	CARGOTYPEDESC = "UT_ABPULPD";
	TRUCKID = "CD230830";
	STOPID = 631223;
	STOPIDTL = 710227;
vars
	resourcesForm : PictureResourcesForm;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti : CM_TrackedItem;
	tis1, tis2 : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	term : CM_Terminal;
	vvr : CM_VehicleVisitRecord;
	ta1, ta2 : CM_TerminalArea;
	detail : CM_ReserveDetail;
	gteEntity : CMGTE_Release;
	wle : CM_WorkListEntry;
	photoDesc : String;
	pictureTA1, pictureTA2, pictureJob : Binary;
	photo : CM_Photo;
	ta1lc, ta2lc : CM_LocationsController;
	cargoTypeSet : CM_CargoTypeSet;
	lcs : CM_LCArray;
	job : CM_Job;
	truck : CM_Vehicle;
begin
	term := self.getTerminal();

	// ### JIRA 23230 07OCT2024 NAVAB1
	self.setTerminalConfig(UseYardJobsCargoWO,true);
	
	self.deleteVehicle(TRUCKID);
	
	create tis1 transient;
	create tis2 transient;
	
	ta1 := self.addBlockStack("UTPHT1",9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	ta2 := self.addBlockStack("UTPHT2",9999999,null);
	self.assertNotNullMsg(ta2, "TA2 is null");

	photoDesc := "a photo descrption for TerminalArea";
	
	resourcesForm := PictureResourcesForm.createPrintForm();
	pictureTA1 := resourcesForm.picTA1.picture;
	photo := self.addTerminalAreaPhoto(ta1, photoDesc, pictureTA1);
	pictureTA2 := resourcesForm.picTA2.picture;
	photo := self.addTerminalAreaPhoto(ta2, photoDesc, pictureTA2);
	
	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	
	// ### On Site Import Cargo - "UT_ABPULP"
	
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis1);

	foreach idy in cgSuffix to cgSuffix + 10 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		tis1.add(ti);
	endforeach;
	
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	
	foreach idy in cgSuffix + 20 to cgSuffix + 30 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		tis2.add(ti);
	endforeach;
		
	ta1lc := ta1.allLocationsControllers.first.CM_YardController;
	ta2lc := ta2.allLocationsControllers.first.CM_YardController;
	
	// ### MOVE TO YARD
	self.moveAllCargoOnVoyage2(voyage, ta1lc, false);
	
	// ### Road Gate Release 
	truck := self.addVehicle(TRUCKID, app.myRoot.allCarriers[ self.getProfileStr(UT_Profile.P_CARRIER)], term);
	job := self.createRoadJob(truck);
	self.assertNotNull(job);
	
	// create TI request for job 
	idy := 0;
	foreach ti in tis1 do
		idy += 1;
		app.myTrxCA.trxCreateTIRequestForJob(job, ti,false,ti.totalQuantity,ti.totalWeight, app.myPassport); 
		self.assertNoTrxErrorsOrWarnings();
		if idy &gt;= 2 then
			break;
		endif;
	endforeach;
	idy := 0;
	foreach ti in tis2 do
		idy += 1;
		app.myTrxCA.trxCreateTIRequestForJob(job, ti,false,ti.totalQuantity,ti.totalWeight, app.myPassport); 
		self.assertNoTrxErrorsOrWarnings();
		if idy &gt;= 6 then
			break;
		endif;
	endforeach;
	
	
	vvr := job.CM_RoadJob.myVehicleVisit;

	self.assertTrueMsg(vvr &lt;&gt; null, "VVR is NULL!");

	// ### JIRA 23230 07OCT2024 NAVAB1
	beginTransaction;
	vvr.myRoadJob.getFirstLocationId(true); 
	commitTransaction;
	
	pictureJob := vvr.getMap();
	self.assertTrueMsg(pictureJob &lt;&gt; null, "pictureJob 1 is NULL!");
	self.assertTrueMsg(pictureJob = pictureTA1, "pictureJob does not equal pictureTA1");

	
	
	// move LARGER cargo to different area. Shoudl use MAP for this area now
	self.moveCargo(tis2.first, tis2,ta2lc, app.myPassport);

	// ### JIRA 23230 07OCT2024 NAVAB1
	beginTransaction;
	vvr.myRoadJob.getFirstLocationId(true); 
	commitTransaction;
	
	pictureJob := vvr.getMap();
	self.assertTrueMsg(pictureJob &lt;&gt; null, "pictureJob 2 is NULL!");
	self.assertTrueMsg(pictureJob = pictureTA2, "pictureJob does not equal pictureTA2");
	
	// ### TIDY UP
//	return;
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteCargoType(CARGOTYPEDESC);
	self.deleteReleaseRequest(cgId);
	
	self.deleteVehicle(TRUCKID);
	
epilog

	delete cargoTypeSet;
	delete resourcesForm;
	delete lcs;
	delete tis1;
	delete tis2;

end;</source>
    </JadeMethod>
    <JadeMethod name="tRoadJobPhoto06" id="a62b371a-c397-42b5-865e-4a69a0df3678">
        <updating/>
        <source>tRoadJobPhoto06() updating;
/*
Purpose - 	the GETMAP for a job must find where the most cargo is and then use the MAP for that location.
				this test is a ROAD JOB that is BY ID, it has the TIs on the road job, no bulk release
				The cargo is in GENERAL CARGO AREAS, in this case the map on the TRANSFER AREA is used, not the general cargo area.
Who - NAVAB1
Date - 28DEC2023
ADO -  CR 58499 TASK 61456
*/



constants
	VESSEL= "DSEQ100";
	VOYAGE= "DSEQ100";
	CARGOTYPEDESC = "UT_ABPULPD";
	TRUCKID = "CD230830";
	STOPID = 631223;
	STOPIDTL = 710227;
vars
	resourcesForm : PictureResourcesForm;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti : CM_TrackedItem;
	tis1, tis2 : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	term : CM_Terminal;
	vvr : CM_VehicleVisitRecord;
	ta1 : CM_IrregularBlockArea;
	detail : CM_ReserveDetail;
	gteEntity : CMGTE_Release;
	wle : CM_WorkListEntry;
	photoDesc : String;
	pictureTA1, pictureTA2, pictureTA3, pictureJob : Binary;
	photo : CM_Photo;
	ya : CM_YardAllocation;
	cargoTypeSet : CM_CargoTypeSet;
	lcs : CM_LCArray;
	job : CM_Job;
	truck : CM_Vehicle;
	ica1, ica2 : CM_InterchangeArea;
	gc1, gc2 : CM_IrregularBlockController;
begin
	term := self.getTerminal();

	// ### JIRA 23230 07OCT2024 NAVAB1
	self.setTerminalConfig(UseYardJobsCargoWO,true);
	
	self.deleteVehicle(TRUCKID);
	
	create tis1 transient;
	create tis2 transient;
	
	// #### TERMINAL AREAS
	
	self.deleteTerminalArea("UTICA1");
	ica1 := self.addInterchangeArea("UTICA1",null);
	self.assertNotNullMsg(ica1, "UTICA1 is NULL");
	
	self.deleteTerminalArea("UTICA2");
	ica2 := self.addInterchangeArea("UTICA2",null);
	self.assertNotNullMsg(ica2, "UTICA2 is NULL");
	
	self.deleteTerminalArea("UTGC1");
	ta1 := self.addGeneralCargoArea("UTGC1",
									   "UT General Cargo Area",
									   10,
									   6,
									   100,
									   null,
									   null);
	self.assertNotNullMsg(ta1, "UTGC1 is NULL");
	
	self.opts.purge();
	self.opts.addAssoc( "LocationType",  GC_GroundLocation );
	self.opts.addAssoc( "ICArea",  ica1 );
	self.opts.addAssoc( "Capacity",  99999999 );
	self.opts.addAssoc( "MaxWeight",  99999999 );

	gc1 := self.addGCRackOrGround(ta1,1,1,1,1,"GR1");
	self.assertNotNullMsg(gc1, "GR1 is NULL");
	assertEqual(ta1.allLocationsControllers.first.status,0);
	
	self.opts.purge();
	self.opts.addAssoc( "LocationType",  GC_GroundLocation );
	self.opts.addAssoc( "ICArea",  ica2 );
	self.opts.addAssoc( "Capacity",  99999999 );
	self.opts.addAssoc( "MaxWeight",  99999999 );

	gc2 := self.addGCRackOrGround(ta1,3,3,3,3,"GR2");
	self.assertNotNullMsg(gc2, "GR2 is NULL");

	// # PHOTOS MAPS ON TAs
	photoDesc := "a photo descrption for TerminalArea";
	
	resourcesForm := PictureResourcesForm.createPrintForm();
	pictureTA1 := resourcesForm.picTA1.picture;
	photo := self.addTerminalAreaPhoto(ica1, photoDesc, pictureTA1);
	pictureTA2 := resourcesForm.picTA2.picture;
	photo := self.addTerminalAreaPhoto(ica2, photoDesc, pictureTA2);
	pictureTA3 := resourcesForm.picExamplePhoto.picture;
	photo := self.addTerminalAreaPhoto(ta1, photoDesc, pictureTA3);
	
	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	
	// ### On Site Import Cargo - "UT_ABPULP"
	
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis1);

	foreach idy in cgSuffix to cgSuffix + 10 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		tis1.add(ti);
	endforeach;
	
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	
	foreach idy in cgSuffix + 20 to cgSuffix + 30 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		tis2.add(ti);
	endforeach;
		
	// ### MOVE TO YARD
	self.moveAllCargoOnVoyage2(voyage, gc1, false);
	
	// ### Road Gate Release 
	truck := self.addVehicle(TRUCKID, app.myRoot.allCarriers[ self.getProfileStr(UT_Profile.P_CARRIER)], term);
	job := self.createRoadJob(truck);
	self.assertNotNull(job);
	
	// create TI request for job 
	idy := 0;
	foreach ti in tis1 do
		idy += 1;
		app.myTrxCA.trxCreateTIRequestForJob(job, ti,false,ti.totalQuantity,ti.totalWeight, app.myPassport); 
		self.assertNoTrxErrorsOrWarnings();
		if idy &gt;= 2 then
			break;
		endif;
	endforeach;
	idy := 0;
	foreach ti in tis2 do
		idy += 1;
		app.myTrxCA.trxCreateTIRequestForJob(job, ti,false,ti.totalQuantity,ti.totalWeight, app.myPassport); 
		self.assertNoTrxErrorsOrWarnings();
		if idy &gt;= 6 then
			break;
		endif;
	endforeach;
	
	
	vvr := job.CM_RoadJob.myVehicleVisit;

	self.assertTrueMsg(vvr &lt;&gt; null, "VVR is NULL!");

	// ### JIRA 23230 07OCT2024 NAVAB1
	beginTransaction;
	vvr.myRoadJob.getFirstLocationId(true); 
	commitTransaction;
	
	pictureJob := vvr.getMap();
	self.assertTrueMsg(pictureJob &lt;&gt; null, "pictureJob 1 is NULL!");
	self.assertTrueMsg(pictureJob = pictureTA1, "pictureJob does not equal pictureTA1");

	
	
	// move LARGER cargo to different area. Shoudl use MAP for this area now
	self.moveCargo(tis2.first, tis2,gc2, app.myPassport);

	// ### JIRA 23230 07OCT2024 NAVAB1
	beginTransaction;
	vvr.myRoadJob.getFirstLocationId(true); 
	commitTransaction;
	
	pictureJob := vvr.getMap();
	self.assertTrueMsg(pictureJob &lt;&gt; null, "pictureJob 2 is NULL!");
	self.assertTrueMsg(pictureJob = pictureTA2, "pictureJob does not equal pictureTA2");
	
	// ### TIDY UP
//	return;
	
	self.deleteVoyage(VOYAGE);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteCargoType(CARGOTYPEDESC);
	self.deleteReleaseRequest(cgId);
	
	self.deleteVehicle(TRUCKID);
	
epilog

	delete cargoTypeSet;
	delete resourcesForm;
	delete lcs;
	delete tis1;
	delete tis2;

end;</source>
    </JadeMethod>
    <JadeMethod name="tRoadJobPhotoByDate01" id="3a250821-b17b-4aee-b254-b344b778fe79">
        <source>tRoadJobPhotoByDate01();
/*
Purpose - 	the GETMAP for a job must find where the most cargo and cargo SHIP transport with oldest date is and then use the MAP for that location.
				this test is a ROAD JOB that has a RELEASE BY TYPE RELEASE REQUEST. 
				It will use YAs to find where the matching cargo is. The cargo is in BLOCK STACKS, so the map image is on the block stack terminal area

15/02/2023	navkc1 CR 60078 Task 62449: Jade - Unit Tests
*/



constants
	VESSEL= "DSEQ100";
	VOYAGE= "DSEQ100";
	VOYAGE2= "DSEQ101";
	VOYAGE3= "DSEQ102";
	CARGOTYPEDESC = "UT_ABPULPD";
	TRUCKID = "CD230830";
	STOPID = 631223;
	STOPIDTL = 710227;
vars
	resourcesForm : PictureResourcesForm;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti : CM_TrackedItem;
	tis1, tis2 : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage,
	voyage2,
	voyage3 : CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	term : CM_Terminal;
	vvr : CM_VehicleVisitRecord;
	ta1, ta2, ta3 : CM_TerminalArea;
	release : CM_BulkRelease;
	detail : CM_ReserveDetail;
	gteEntity : CMGTE_Release;
	photoDesc : String;
	pictureTA1, pictureTA2, pictureTA3, pictureJob : Binary;
	photo : CM_Photo;
	ya : CM_YardAllocation;
	ta1lc, ta2lc, ta3lc : CM_LocationsController;
	cargoTypeSet : CM_CargoTypeSet;
	lcs : CM_LCArray;
	twoDaysAgo : Date;
	twoDaysAgoTS : TimeStamp;
begin
	term := self.getTerminal();

	// ### JIRA 23230 07OCT2024 NAVAB1
	self.setTerminalConfig(UseYardJobsCargoWO,true);
	
	self.deleteVehicle(TRUCKID);
	
	create tis1 transient;
	create tis2 transient;
	
	ta1 := self.addBlockStack("UTPHT1",9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	ta2 := self.addBlockStack("UTPHT2",9999999,null);
	self.assertNotNullMsg(ta2, "TA2 is null");
	ta3 := self.addBlockStack("UTPHT3",9999999,null);
	self.assertNotNullMsg(ta3, "TA3 is null");

	photoDesc := "a photo descrption for TerminalArea";
	
	resourcesForm := PictureResourcesForm.createPrintForm();
	pictureTA1 := resourcesForm.picTA1.picture;
	photo := self.addTerminalAreaPhoto(ta1, photoDesc, pictureTA1);
	pictureTA2 := resourcesForm.picTA2.picture;
	photo := self.addTerminalAreaPhoto(ta2, photoDesc, pictureTA2);
	pictureTA3 := resourcesForm.picExamplePhoto.picture;
	photo := self.addTerminalAreaPhoto(ta3, photoDesc, pictureTA3);
	
	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	
	// ### On Site Import Cargo - "UT_ABPULP"
	
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	// Create first voyage
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
																				
	// Create second voyage - for different date
	voyage2 := self.addVoyageWithGeneralCargoStruc(VOYAGE2, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
																				
	// Create third voyage
	voyage3 := self.addVoyageWithGeneralCargoStruc(VOYAGE3, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
																				
	beginTransaction;
		twoDaysAgo := twoDaysAgo.addDays(-2);
		twoDaysAgoTS.setDate(twoDaysAgo);
		voyage2.setArrivalDT(twoDaysAgoTS);
	commitTransaction;
	
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis1);
	
	// Cargo for 1st voyage
	foreach idy in cgSuffix to cgSuffix + 10 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		tis1.add(ti);
	endforeach;
	
	totalQuantity := 100;
	totalWeight := 600;
	totalVolume := 6;
	
	foreach idy in cgSuffix + 20 to cgSuffix + 30 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		tis2.add(ti);
	endforeach;
	
	cgSuffix := 200;
	// Cargo for second voyage
	foreach idy in cgSuffix to cgSuffix + 10 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage2, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		tis1.add(ti);
	endforeach;
	
	totalQuantity := 100;
	totalWeight := 600;
	totalVolume := 6;
	
	foreach idy in cgSuffix + 20 to cgSuffix + 30 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage2, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		tis2.add(ti);
	endforeach;
	
	cgSuffix := 300;
	// Cargo for Third voyage
	foreach idy in cgSuffix to cgSuffix + 10 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage3, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
	endforeach;
	
	totalQuantity := 100;
	totalWeight := 600;
	totalVolume := 6;
	
	foreach idy in cgSuffix + 20 to cgSuffix + 31 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage3, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
	endforeach;
		
	// ######### YARD ALLOC
	
	self.deleteYA("UTPHOT");
	create lcs transient;
	ta1lc := ta1.allLocationsControllers.first.CM_YardController;
	ta2lc := ta2.allLocationsControllers.first.CM_YardController;
	ta3lc := ta3.allLocationsControllers.first.CM_YardController;
	lcs.add(ta1lc);
	lcs.add(ta2lc);
	lcs.add(ta3lc);
	
	create cargoTypeSet transient;
	cargoTypeSet.add(cargoType);
	ya := self.addYA1("UTPHOT", YACriteriaType_CargoType, cargoTypeSet, lcs);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Create failed");
	self.assertTrueMsg(ya.allYABlocksIn.size = 3, "Locations not created");
	self.assertTrueMsg(ya.allCriteria.size  = 1, "Criteria not created");
	
	
	// ### MOVE TO YARD - both YA has same amount, but YA 2 has older date
	// Voyage 1 to YA 1
	self.moveAllCargoOnVoyage2(voyage, ta1lc, false);
	// Voyage 2 to YA 2
	self.moveAllCargoOnVoyage2(voyage2, ta2lc, false);
	// Voyage 3 to YA 3
	self.moveAllCargoOnVoyage2(voyage3, ta3lc, false);
	
	// ### Create a road release request for the cargo group
	self.opts.purge();
	self.deleteReleaseRequest(cgId);
	
	self.opts.addAssoc("Context", RelReqContext_CargoGroupReview);
	self.opts.addAssoc("CargoGroup", cargoGroup1);
	self.opts.addAssoc("Number", cargoGroup1.totalQuantity);
	
	release := self.addReleaseByTypeRequestOpts(cgId,BR_TYPE_ROAD, cargoType.id);
	
	self.assertTrueMsg(release &lt;&gt; null, "BR is null!");
	
	detail := release.allReserveDetails.first;
	
	// We want to test the Oldest Date
	beginTransaction;
	detail.setPropertyValue("locnByOldestTransportArrival", true);
	commitTransaction;
	
	self.assertTrueMsg(detail &lt;&gt; null, "BR Detail is null!");
	self.assertTrueMsg(release.context = RelReqContext_CargoGroupReview, "BR Context should be " &amp; RelReqContext_CargoGroupReview);
	self.assertTrueMsg(detail.myCargoGroup = cargoGroup1, "BR Cargo Group is wrong should be " &amp; cargoGroup1.id);
	self.assertTrueMsg(detail.CM_ReserveSelection.totalRequested = cargoGroup1.totalQuantity, "BR totalRequested should be " &amp; cargoGroup1.totalQuantity.String);
	
	
	// ### Road Gate Release for whole of 1 TI
	self.opts.purge();
	self.opts.addAssoc("ReleaseRequest", release);
	self.opts.addAssoc("AnyId", true);
	self.opts.addAssoc("AnyAmt", true);
	vvr := self.gateOutGC(TRUCKID, "", "UTDRIVER", null,  self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString) , null);

	self.assertTrueMsg(vvr &lt;&gt; null, "VVR is NULL!");
	
	gteEntity := vvr.allGateEntities.first.CMGTE_Release;
	
	self.assertTrueMsg(vvr &lt;&gt; null, "VVR is NULL!");
	self.assertTrueMsg(gteEntity &lt;&gt; null, "gteEntity is NULL!");
	self.assertTrueMsg(gteEntity.getIsAnyAmount() = true, "Any Amount is FALSE");
	self.assertTrueMsg(gteEntity.getIsAnyId() = true, "Any Id is FALSE");
	
	//-----------
	// At this stage
	//	YA 1 - Number of cargo 22 - Date : today
	//  YA 2 - Number of cargo 22 - Date : 2 days ago  ********** MTN should take this
	//  YA 3 - Number of cargo 23 - Date : today
	//----------
	pictureJob := vvr.getMap();
	self.assertTrueMsg(pictureJob &lt;&gt; null, "#1 pictureJob is NULL!");
	//self.assertTrueMsg(pictureJob = pictureTA3, "pictureJob does not equal pictureTA2");
	self.assertTrueMsg(pictureJob = pictureTA2, "pictureJob does not equal pictureTA2"); //18/12/2024	navkc1 JIRA Bug MTN-33686 should be TA2 due to the oldest date option

	self.moveCargo(tis2.last, null,ta1lc, app.myPassport);

	// ### JIRA 23230 07OCT2024 NAVAB1
	beginTransaction;
	vvr.myRoadJob.getFirstLocationId(true); 
	commitTransaction;
	
	//-----------
	// At this stage
	//	YA 1 - Number of cargo 23 - Date : 2 days ago ********** MTN should take this
	//  YA 2 - Number of cargo 21 - Date : 2 days ago
	//  YA 3 - Number of cargo 23 - Date : today 
	//----------
	pictureJob := vvr.getMap();
	self.assertTrueMsg(pictureJob &lt;&gt; null, "#2 pictureJob is NULL!");
	self.assertTrueMsg(pictureJob = pictureTA1, "pictureJob does not equal pictureTA1");
	
	// ### TIDY UP
	
	self.deleteYA("UTPHOT");
	
	self.deleteReleaseRequest(cgId);
	self.deleteVoyage(VOYAGE);
	self.deleteVoyage(VOYAGE2);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
	self.deleteVehicle(TRUCKID);
	
epilog

	delete cargoTypeSet;
	delete resourcesForm;
	delete lcs;
	delete tis1;
	delete tis2;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRoadJobPhotoByDate02" id="d8aeb1f3-5c08-4797-8dd7-d7072a2798bc">
        <source>tRoadJobPhotoByDate02();
/*
Purpose - 	the GETMAP for a job must find where the most cargo and cargo SHIP transport with oldest date is and then use the MAP for that location.
				this test is a ROAD JOB that has a RELEASE BY TYPE RELEASE REQUEST. 
				It will use YAs to find where the matching cargo is. The cargo is in GENERAL CARGO AREAS, in this case the map on the TRANSFER AREA is used, not the general cargo area.
				
15/02/2023	navkc1 CR 60078 Task 62449: Jade - Unit Tests
*/



constants
	VESSEL= "DSEQ100";
	VOYAGE= "DSEQ100";
	VOYAGE2= "DSEQ101";
	VOYAGE3= "DSEQ102";
	CARGOTYPEDESC = "UT_ABPULPD";
	TRUCKID = "CD230830";
	STOPID = 631223;
	STOPIDTL = 710227;
vars
	resourcesForm : PictureResourcesForm;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti : CM_TrackedItem;
	tis1, tis2 : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	dateTime : TimeStamp;
	totalQuantity: Integer;
	totalWeight, totalVolume : Decimal [23,4];
	cargoOp : CM_Operator;
	vessel : CM_Vessel;
	voyage,
	voyage2,
	voyage3: CM_Voyage;
	aPort : CM_Port;
	cgSuffix : Integer;
	term : CM_Terminal;
	vvr : CM_VehicleVisitRecord;
	ta1, ta2, ta3 : CM_IrregularBlockArea;
	release : CM_BulkRelease;
	detail : CM_ReserveDetail;
	gteEntity : CMGTE_Release;
	photoDesc : String;
	pictureTA1, pictureTA2, pictureTA3, pictureJob : Binary;
	photo : CM_Photo;
	ya : CM_YardAllocation;
	cargoTypeSet : CM_CargoTypeSet;
	lcs : CM_LCArray;
	ica1, ica2, ica3 : CM_InterchangeArea;
	gc1, gc2, gc3 : CM_IrregularBlockController;
	twoDaysAgo : Date;
	twoDaysAgoTS : TimeStamp;
begin
	term := self.getTerminal();

	// ### JIRA 23230 07OCT2024 NAVAB1
	self.setTerminalConfig(UseYardJobsCargoWO,true);
	
	self.deleteVehicle(TRUCKID);
	
	create tis1 transient;
	create tis2 transient;
	
	// #### TERMINAL AREAS
	
	self.deleteTerminalArea("UTICA1");
	ica1 := self.addInterchangeArea("UTICA1",null);
	self.assertNotNullMsg(ica1, "UTICA1 is NULL");
	
	self.deleteTerminalArea("UTICA2");
	ica2 := self.addInterchangeArea("UTICA2",null);
	self.assertNotNullMsg(ica2, "UTICA2 is NULL");
	
	self.deleteTerminalArea("UTICA3");
	ica3 := self.addInterchangeArea("UTICA3",null);
	self.assertNotNullMsg(ica3, "UTICA3 is NULL");
	
	self.deleteTerminalArea("UTGC1");
	ta1 := self.addGeneralCargoArea("UTGC1",
									   "UT General Cargo Area",
									   10,
									   6,
									   100,
									   null,
									   null);
	self.assertNotNullMsg(ta1, "UTGC1 is NULL");
	
	self.opts.purge();
	self.opts.addAssoc( "LocationType",  GC_GroundLocation );
	self.opts.addAssoc( "ICArea",  ica1 );
	self.opts.addAssoc( "Capacity",  99999999 );
	self.opts.addAssoc( "MaxWeight",  99999999 );

	gc1 := self.addGCRackOrGround(ta1,1,1,1,1,"GR1");
	self.assertNotNullMsg(gc1, "GR1 is NULL");
	assertEqual(ta1.allLocationsControllers.first.status,0);
	
	self.opts.purge();
	self.opts.addAssoc( "LocationType",  GC_GroundLocation );
	self.opts.addAssoc( "ICArea",  ica2 );
	self.opts.addAssoc( "Capacity",  99999999 );
	self.opts.addAssoc( "MaxWeight",  99999999 );

	gc2 := self.addGCRackOrGround(ta1,3,3,3,3,"GR2");
	self.assertNotNullMsg(gc2, "GR2 is NULL");
	
	self.opts.purge();
	self.opts.addAssoc( "LocationType",  GC_GroundLocation );
	self.opts.addAssoc( "ICArea",  ica3 );
	self.opts.addAssoc( "Capacity",  99999999 );
	self.opts.addAssoc( "MaxWeight",  99999999 );

	gc3 := self.addGCRackOrGround(ta1,3,3,3,3,"GR3");
	self.assertNotNullMsg(gc3, "GR3 is NULL");
	
	
	// # PHOTOS MAPS ON TAs
	
	photoDesc := "a photo descrption for TerminalArea";
	
	resourcesForm := PictureResourcesForm.createPrintForm();
	pictureTA1 := resourcesForm.picTA1.picture;
	photo := self.addTerminalAreaPhoto(ica1, photoDesc, pictureTA1);
	pictureTA2 := resourcesForm.picTA2.picture;
	photo := self.addTerminalAreaPhoto(ica2, photoDesc, pictureTA2);
	pictureTA3 := resourcesForm.picExamplePhoto.picture;
	photo := self.addTerminalAreaPhoto(ica3, photoDesc, pictureTA3);
	
	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("isCargoGroupRequired", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	
	// ### On Site Import Cargo - "UT_ABPULP"
	
	totalQuantity := 100;
	totalWeight := 500;
	totalVolume := 4;
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	vessel := self.addVesselWithHolds(VESSEL, 2, 2);
	// Create first voyage
	voyage := self.addVoyageWithGeneralCargoStruc(VOYAGE, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	
	// Create second voyage
	voyage2 := self.addVoyageWithGeneralCargoStruc(VOYAGE2, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
																				
	// Create third voyage
	voyage3 := self.addVoyageWithGeneralCargoStruc(VOYAGE3, VESSEL,
																				opCode,	
																				self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 
																				0);
	beginTransaction;
		twoDaysAgo := twoDaysAgo.addDays(-2);
		twoDaysAgoTS.setDate(twoDaysAgo);
		voyage2.setArrivalDT(twoDaysAgoTS);
	commitTransaction;

	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
		
	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis1);
	
	// Cargo for 1st voyage
	foreach idy in cgSuffix to cgSuffix + 10 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		tis1.add(ti);
	endforeach;
	
	totalQuantity := 100;
	totalWeight := 600;
	totalVolume := 6;
	
	foreach idy in cgSuffix + 20 to cgSuffix + 30 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		tis2.add(ti);
	endforeach;
	
	// Cargo for second voyage
	cgSuffix := 200;
	foreach idy in cgSuffix to cgSuffix + 10 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage2, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		tis1.add(ti);
	endforeach;
	
	totalQuantity := 100;
	totalWeight := 600;
	totalVolume := 6;
	
	foreach idy in cgSuffix + 20 to cgSuffix + 30 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage2, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		tis2.add(ti);
	endforeach;
	
	
	// Cargo for thrid voyage
	cgSuffix := 300;
	foreach idy in cgSuffix to cgSuffix + 10 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage3, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
	endforeach;
	
	totalQuantity := 100;
	totalWeight := 600;
	totalVolume := 6;
	
	foreach idy in cgSuffix + 20 to cgSuffix + 31 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		ti := self.createGCOnVoyage(false, "", cargoId, cargoType, cargoOp, voyage3, aPort,totalWeight.Integer, totalVolume, totalQuantity, cargoGroup1);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
	endforeach;
	
	// ######### YARD ALLOC
	
	self.deleteYA("UTPHOT");
	create lcs transient;
	lcs.add(gc1);
	lcs.add(gc2);
	lcs.add(gc3);
	
	create cargoTypeSet transient;
	cargoTypeSet.add(cargoType);
	ya := self.addYA1("UTPHOT", YACriteriaType_CargoType, cargoTypeSet, lcs);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Create failed");
	self.assertTrueMsg(ya.allYABlocksIn.size = 3, "Locations not created");
	self.assertTrueMsg(ya.allCriteria.size  = 1, "Criteria not created");
	
	// ### MOVE TO YARD
	self.moveAllCargoOnVoyage2(voyage, gc1, false);
	self.moveAllCargoOnVoyage2(voyage2, gc2, false);
	self.moveAllCargoOnVoyage2(voyage3, gc3, false);
	
	// ### Create a road release request for the cargo group
	self.opts.purge();
	self.deleteReleaseRequest(cgId);
	
	self.opts.addAssoc("Context", RelReqContext_CargoGroupReview);
	self.opts.addAssoc("CargoGroup", cargoGroup1);
	self.opts.addAssoc("Number", cargoGroup1.totalQuantity);
	
	release := self.addReleaseByTypeRequestOpts(cgId,BR_TYPE_ROAD, cargoType.id);
	
	self.assertTrueMsg(release &lt;&gt; null, "BR is null!");
	
	detail := release.allReserveDetails.first;
	
	// We want to test the Oldest Date
	beginTransaction;
		detail.setPropertyValue("locnByOldestTransportArrival", true);
	commitTransaction;
	
	self.assertTrueMsg(detail &lt;&gt; null, "BR Detail is null!");
	self.assertTrueMsg(release.context = RelReqContext_CargoGroupReview, "BR Context should be " &amp; RelReqContext_CargoGroupReview);
	self.assertTrueMsg(detail.myCargoGroup = cargoGroup1, "BR Cargo Group is wrong should be " &amp; cargoGroup1.id);
	self.assertTrueMsg(detail.CM_ReserveSelection.totalRequested = cargoGroup1.totalQuantity, "BR totalRequested should be " &amp; cargoGroup1.totalQuantity.String);
	
	// ### Road Gate Release for whole of 1 TI
	self.opts.purge();
	self.opts.addAssoc("ReleaseRequest", release);
	self.opts.addAssoc("AnyId", true);
	self.opts.addAssoc("AnyAmt", true);
	vvr := self.gateOutGC(TRUCKID, "", "UTDRIVER", null,  self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString) , null);

	self.assertTrueMsg(vvr &lt;&gt; null, "VVR is NULL!");
	
	gteEntity := vvr.allGateEntities.first.CMGTE_Release;
	
	self.assertTrueMsg(vvr &lt;&gt; null, "VVR is NULL!");
	self.assertTrueMsg(gteEntity &lt;&gt; null, "gteEntity is NULL!");
	self.assertTrueMsg(gteEntity.getIsAnyAmount() = true, "Any Amount is FALSE");
	self.assertTrueMsg(gteEntity.getIsAnyId() = true, "Any Id is FALSE");
	
	//-----------
	// At this stage
	//	YA 1 - Number of cargo 22 - Date : today
	//  YA 2 - Number of cargo 22 - Date : 2 days ago  ********** MTN should take this
	//  YA 3 - Number of cargo 23 - Date : today
	//----------
	pictureJob := vvr.getMap();
	self.assertTrueMsg(pictureJob &lt;&gt; null, "#1 pictureJob is NULL!");
	//self.assertTrueMsg(pictureJob = pictureTA3, "pictureJob does not equal pictureTA3");
	self.assertTrueMsg(pictureJob = pictureTA2, "pictureJob does not equal pictureTA2"); //18/12/2024	navkc1 JIRA Bug MTN-33686, should be TA2 due to oldest date option

	self.moveCargo(tis2.last, null, gc1, app.myPassport);

	// ### JIRA 23230 07OCT2024 NAVAB1
	beginTransaction;
	vvr.myRoadJob.getFirstLocationId(true); 
	commitTransaction;
	
	//-----------
	// At this stage
	//	YA 1 - Number of cargo 23 - Date : 2 days ago  ********** MTN should take this
	//  YA 2 - Number of cargo 21 - Date : 2 days ago
	//  YA 3 - Number of cargo 23 - Date : today
	//----------
	pictureJob := vvr.getMap();
	self.assertTrueMsg(pictureJob &lt;&gt; null, "#2 pictureJob is NULL!");
	self.assertTrueMsg(pictureJob = pictureTA1, "pictureJob does not equal pictureTA1");
	
	// ### TIDY UP
	self.deleteYA("UTPHOT");
	
	self.deleteReleaseRequest(cgId);
	self.deleteVoyage(VOYAGE);
	self.deleteVoyage(VOYAGE2);
	self.deleteVoyage(VOYAGE3);
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteCargoType(CARGOTYPEDESC);
	
	self.deleteVehicle(TRUCKID);
	
epilog
	delete cargoTypeSet;
	delete resourcesForm;
	delete lcs;
	delete tis1;
	delete tis2;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRoadJobPhotoByDate03" id="92c1987b-0d00-4e2f-ae4a-264bea09c366">
        <source>tRoadJobPhotoByDate03();
/*
Purpose - 	the GETMAP for a job must find where the most cargo and cargo ROAD transport with oldest date is and then use the MAP for that location.
				this test is a ROAD JOB that has a RELEASE BY TYPE RELEASE REQUEST. 
				It will use YAs to find where the matching cargo is. The cargo is in BLOCK STACKS, so the map image is on the block stack terminal area

15/02/2023	navkc1 CR 60078 Task 62449: Jade - Unit Tests
*/



constants
	VESSEL= "DSEQ100";
	CARGOTYPEDESC = "UT_ABPULPD";
	TRUCKID = "CD230830";
	TRUCKID2 = "CD230831";
	TRUCKID3 = "CD230833";
	STOPID = 631223;
	STOPIDTL = 710227;
vars
	resourcesForm : PictureResourcesForm;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti : CM_TrackedItem;
	tis1, tis2, tis3 : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	dateTime : TimeStamp;
	cargoOp : CM_Operator;
	cgSuffix : Integer;
	term : CM_Terminal;
	vvr : CM_VehicleVisitRecord;
	ta1, ta2, ta3 : CM_TerminalArea;
	release : CM_BulkRelease;
	detail : CM_ReserveDetail;
	gteEntity : CMGTE_Release;
	photoDesc : String;
	pictureTA1, pictureTA2, pictureTA3, pictureJob : Binary;
	photo : CM_Photo;
	ya : CM_YardAllocation;
	locn, ta1lc, ta2lc, ta3lc : CM_LocationsController;
	cargoTypeSet : CM_CargoTypeSet;
	lcs : CM_LCArray;
	twoDaysAgo : Date;
	twoDaysAgoTime : Time;
	sGate : CM_Gate;
begin
	term := self.getTerminal();

	// ### JIRA 23230 07OCT2024 NAVAB1
	self.setTerminalConfig(UseYardJobsCargoWO,true);
	
	self.deleteVehicle(TRUCKID);
	self.deleteVehicle(TRUCKID2);
	self.deleteVehicle(TRUCKID3);
	
	create tis1 transient;
	create tis2 transient;
	create tis3 transient;
	
	ta1 := self.addBlockStack("UTPHT1",9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	ta2 := self.addBlockStack("UTPHT2",9999999,null);
	self.assertNotNullMsg(ta2, "TA2 is null");
	ta3 := self.addBlockStack("UTPHT3",9999999,null);
	self.assertNotNullMsg(ta3, "TA3 is null");

	photoDesc := "a photo descrption for TerminalArea";
	
	resourcesForm := PictureResourcesForm.createPrintForm();
	pictureTA1 := resourcesForm.picTA1.picture;
	photo := self.addTerminalAreaPhoto(ta1, photoDesc, pictureTA1);
	pictureTA2 := resourcesForm.picTA2.picture;
	photo := self.addTerminalAreaPhoto(ta2, photoDesc, pictureTA2);
	pictureTA3 := resourcesForm.picExamplePhoto.picture;
	photo := self.addTerminalAreaPhoto(ta3, photoDesc, pictureTA3);
	
	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);
	sGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);

	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis1);
	
	// CREATE FIRST BATCH CARGO AND MOVE TO TA1
	foreach idy in cgSuffix to cgSuffix + 10 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		vvr := self.gateInGC(TRUCKID, null, TRUCKID, cargoId, CARGOTYPEDESC, opCode, null, sGate, 100);
		ti := self.getTrackedItem(cargoId);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		tis1.add(ti);
		
		twoDaysAgoTime := twoDaysAgoTime.addSeconds(1);
		
		beginTransaction;
			ti.setCargoGroup(cargoGroup1, cargoGroup1.id, app.myPassport);
			vvr.setTimeIn(twoDaysAgo, twoDaysAgoTime);
		commitTransaction;
		
		self.deleteStops(ti);
		
		self.movePlanned(ti, ta1.getMyLocationsController());
		self.assertTrueMsg(ti.myPrimaryPlannedLocation &lt;&gt; null, ti.id &amp; " did not plan");
		
		self.moveVehicleToYard(vvr.vehicle);
		self.assertTrueMsg(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation,"VVR Primary Location ISSUE 1");
		
		self.workVehicle(vvr);
		locn := ti.getPrimaryLocation(REAL_MODE);
		
		self.assertNotNull(locn);
		self.assertTrueMsg(locn.isKindOf(CM_YardController),"TI primary location Issue");
		self.assertTrueMsg(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation,"VVR Primary Location ISSUE 2");
					
		self.roadExit(vvr);
	endforeach;
	self.moveCargo(ti, tis1, ta1.getMyLocationsController(), app.myPassport);
	
	
	// CREATE SECOND BATCH CARGO AND MOVE TO TA2
	// THESE ARRIVED 2 DAYS AGO
	cgSuffix := 200;
	twoDaysAgo := twoDaysAgo.addDays(-2);
	
	foreach idy in cgSuffix to cgSuffix + 10 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		vvr := self.gateInGC(TRUCKID2, null, TRUCKID2, cargoId, CARGOTYPEDESC, opCode, null, sGate, 100);
		ti := self.getTrackedItem(cargoId);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		tis2.add(ti);
		
		twoDaysAgoTime := twoDaysAgoTime.addSeconds(1);
		
		beginTransaction;
			ti.setCargoGroup(cargoGroup1, cargoGroup1.id, app.myPassport);
			vvr.setTimeIn(twoDaysAgo, twoDaysAgoTime);
		commitTransaction;
		
		
		self.deleteStops(ti);
		
		self.movePlanned(ti, ta2.getMyLocationsController());
		self.assertTrueMsg(ti.myPrimaryPlannedLocation &lt;&gt; null, ti.id &amp; " did not plan");
		
		self.moveVehicleToYard(vvr.vehicle);
		self.assertTrueMsg(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation,"VVR Primary Location ISSUE 1");
		
		self.workVehicle(vvr);
		locn := ti.getPrimaryLocation(REAL_MODE);
		
		self.assertNotNull(locn);
		self.assertTrueMsg(locn.isKindOf(CM_YardController),"TI primary location Issue");
		self.assertTrueMsg(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation,"VVR Primary Location ISSUE 2");
					
		self.roadExit(vvr);
	endforeach;
	self.moveCargo(ti, tis2, ta2.getMyLocationsController(), app.myPassport);
	
	// CREATE THIRD BATCH CARGO AND MOVE TO TA3
	// THESE TODAY
	cgSuffix := 300;
	
	foreach idy in cgSuffix to cgSuffix + 11 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		vvr := self.gateInGC(TRUCKID3, null, TRUCKID3, cargoId, CARGOTYPEDESC, opCode, null, sGate, 100);
		ti := self.getTrackedItem(cargoId);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		tis3.add(ti);
		
		beginTransaction;
			ti.setCargoGroup(cargoGroup1, cargoGroup1.id, app.myPassport);
		commitTransaction;
		
		
		self.deleteStops(ti);
		
		self.movePlanned(ti, ta3.getMyLocationsController());
		self.assertTrueMsg(ti.myPrimaryPlannedLocation &lt;&gt; null, ti.id &amp; " did not plan");
		
		self.moveVehicleToYard(vvr.vehicle);
		self.assertTrueMsg(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation,"VVR Primary Location ISSUE 1");
		
		self.workVehicle(vvr);
		locn := ti.getPrimaryLocation(REAL_MODE);
		
		self.assertNotNull(locn);
		self.assertTrueMsg(locn.isKindOf(CM_YardController),"TI primary location Issue");
		self.assertTrueMsg(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation,"VVR Primary Location ISSUE 2");
					
		self.roadExit(vvr);
	endforeach;
	self.moveCargo(ti, tis3, ta3.getMyLocationsController(), app.myPassport);
	
	// ######### YARD ALLOC
	self.deleteYA("UTPHOT");
	create lcs transient;
	ta1lc := ta1.allLocationsControllers.first.CM_YardController;
	ta2lc := ta2.allLocationsControllers.first.CM_YardController;
	ta3lc := ta3.allLocationsControllers.first.CM_YardController;
	lcs.add(ta1lc);
	lcs.add(ta2lc);
	lcs.add(ta3lc);
	
	create cargoTypeSet transient;
	cargoTypeSet.add(cargoType);
	ya := self.addYA1("UTPHOT", YACriteriaType_CargoType, cargoTypeSet, lcs);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Create failed");
	self.assertTrueMsg(ya.allYABlocksIn.size = 3, "Locations not created");
	self.assertTrueMsg(ya.allCriteria.size  = 1, "Criteria not created");
	
	// ### Create a road release request for the cargo group
	self.opts.purge();
	self.deleteReleaseRequest(cgId);
	
	self.opts.addAssoc("Context", RelReqContext_CargoGroupReview);
	self.opts.addAssoc("CargoGroup", cargoGroup1);
	self.opts.addAssoc("Number", cargoGroup1.totalQuantity);
	
	release := self.addReleaseByTypeRequestOpts(cgId,BR_TYPE_ROAD, cargoType.id);
	
	self.assertTrueMsg(release &lt;&gt; null, "BR is null!");
	
	detail := release.allReserveDetails.first;
	
	// We want to test the Oldest Date
	beginTransaction;
	detail.setPropertyValue("locnByOldestTransportArrival", true);
	commitTransaction;
	
	self.assertTrueMsg(detail &lt;&gt; null, "BR Detail is null!");
	self.assertTrueMsg(release.context = RelReqContext_CargoGroupReview, "BR Context should be " &amp; RelReqContext_CargoGroupReview);
	self.assertTrueMsg(detail.myCargoGroup = cargoGroup1, "BR Cargo Group is wrong should be " &amp; cargoGroup1.id);
	self.assertTrueMsg(detail.CM_ReserveSelection.totalRequested = cargoGroup1.totalQuantity, "BR totalRequested should be " &amp; cargoGroup1.totalQuantity.String);
	
	// ### Road Gate Release for whole of 1 TI
	self.opts.purge();
	self.opts.addAssoc("ReleaseRequest", release);
	self.opts.addAssoc("AnyId", true);
	self.opts.addAssoc("AnyAmt", true);
	vvr := self.gateOutGC(TRUCKID2, "", "UTDRIVER", null,  self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString) , null);

	self.assertTrueMsg(vvr &lt;&gt; null, "VVR is NULL!");
	
	gteEntity := vvr.allGateEntities.first.CMGTE_Release;
	
	self.assertTrueMsg(vvr &lt;&gt; null, "VVR is NULL!");
	self.assertTrueMsg(gteEntity &lt;&gt; null, "gteEntity is NULL!");
	self.assertTrueMsg(gteEntity.getIsAnyAmount() = true, "Any Amount is FALSE");
	self.assertTrueMsg(gteEntity.getIsAnyId() = true, "Any Id is FALSE");
	
	//-----------
	// At this stage
	//	YA 1 - Number of cargo 11 - Date : today
	//  YA 2 - Number of cargo 11 - Date : 2 days ago
	//  YA 3 - Number of cargo 12 - Date : today ********** MTN should take this
	//----------
	pictureJob := vvr.getMap();
	self.assertTrueMsg(pictureJob &lt;&gt; null, "#1 pictureJob is NULL!");
	//self.assertTrueMsg(pictureJob = pictureTA3, "pictureJob does not equal pictureTA2");
	self.assertTrueMsg(pictureJob = pictureTA2, "pictureJob does not equal pictureTA2"); //18/12/2024	navkc1 JIRA Bug MTN-33686, should be TA2 due to oldest date option

	self.moveCargo(tis2.first, tis2,ta1lc, app.myPassport);

	// ### JIRA 23230 07OCT2024 NAVAB1
	beginTransaction;
	vvr.myRoadJob.getFirstLocationId(true); 
	commitTransaction;
	
	//-----------
	// At this stage
	//	YA 1 - Number of cargo 12 - Date : 2days ago
	//  YA 2 - Number of cargo 10 - Date : 2 days ago
	//  YA 3 - Number of cargo 12 - Date : today ********** MTN should take this
	//----------
	pictureJob := vvr.getMap();
	self.assertTrueMsg(pictureJob &lt;&gt; null, "#2 pictureJob is NULL!");
	self.assertTrueMsg(pictureJob = pictureTA1, "pictureJob does not equal pictureTA1");
	
	// ### TIDY UP
	
	self.deleteYA("UTPHOT");
	
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteCargoType(CARGOTYPEDESC);
	self.deleteReleaseRequest(cgId);
	
	self.deleteVehicle(TRUCKID);
	self.deleteVehicle(TRUCKID2);
epilog

	delete cargoTypeSet;
	delete resourcesForm;
	delete lcs;
	delete tis1;
	delete tis2;
	delete tis3;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRoadJobPhotoByDate04" id="df0f1b5d-f607-4d0e-a3dd-afbcdc107129">
        <source>tRoadJobPhotoByDate04();
/*
Purpose - 	the GETMAP for a job must find where the most cargo and cargo ROAD transport with oldest date is and then use the MAP for that location.
				this test is a ROAD JOB that has a RELEASE BY TYPE RELEASE REQUEST. 
				It will use YAs to find where the matching cargo is. The cargo is in GENERAL CARGO AREAS, so the map image is on the block stack terminal area

15/02/2023	navkc1 CR 60078 Task 62449: Jade - Unit Tests
*/



constants
	VESSEL= "DSEQ100";
	CARGOTYPEDESC = "UT_ABPULPD";
	TRUCKID = "CD230830";
	TRUCKID2 = "CD230831";
	TRUCKID3 = "CD230832";
	STOPID = 631223;
	STOPIDTL = 710227;
vars
	resourcesForm : PictureResourcesForm;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	ti : CM_TrackedItem;
	tis1, tis2, tis3 : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	dateTime : TimeStamp;
	cargoOp : CM_Operator;
	cgSuffix : Integer;
	term : CM_Terminal;
	vvr : CM_VehicleVisitRecord;
	ta1, ta2, ta3 : CM_IrregularBlockArea;
	release : CM_BulkRelease;
	detail : CM_ReserveDetail;
	gteEntity : CMGTE_Release;
	photoDesc : String;
	pictureTA1, pictureTA2, pictureTA3, pictureJob : Binary;
	photo : CM_Photo;
	ya : CM_YardAllocation;
	locn, ta1lc, ta2lc, ta3lc : CM_LocationsController;
	cargoTypeSet : CM_CargoTypeSet;
	lcs : CM_LCArray;
	twoDaysAgo : Date;
	twoDaysAgoTime : Time;
	sGate : CM_Gate;
	ica1, ica2, ica3 : CM_InterchangeArea;
	gc1, gc2, gc3 : CM_IrregularBlockController;
begin
	term := self.getTerminal();

	// ### JIRA 23230 07OCT2024 NAVAB1
	self.setTerminalConfig(UseYardJobsCargoWO,true);
	
	self.deleteVehicle(TRUCKID);
	self.deleteVehicle(TRUCKID2);
	self.deleteVehicle(TRUCKID3);
	
	create tis1 transient;
	create tis2 transient;
	create tis3 transient;
	
	self.deleteTerminalArea("UTICA1");
	ica1 := self.addInterchangeArea("UTICA1",null);
	self.assertNotNullMsg(ica1, "UTICA1 is NULL");
	
	self.deleteTerminalArea("UTICA2");
	ica2 := self.addInterchangeArea("UTICA2",null);
	self.assertNotNullMsg(ica2, "UTICA2 is NULL");
	
	self.deleteTerminalArea("UTICA3");
	ica3 := self.addInterchangeArea("UTICA3",null);
	self.assertNotNullMsg(ica3, "UTICA3 is NULL");
	
	self.deleteTerminalArea("UTGC1");
	ta1 := self.addGeneralCargoArea("UTGC1",
									   "UT General Cargo Area",
									   10,
									   6,
									   100,
									   null,
									   null);
	self.assertNotNullMsg(ta1, "UTGC1 is NULL");
	
	self.opts.purge();
	self.opts.addAssoc( "LocationType",  GC_GroundLocation );
	self.opts.addAssoc( "ICArea",  ica1 );
	self.opts.addAssoc( "Capacity",  99999999 );
	self.opts.addAssoc( "MaxWeight",  99999999 );

	gc1 := self.addGCRackOrGround(ta1,1,1,1,1,"GR1");
	self.assertNotNullMsg(gc1, "GR1 is NULL");
	assertEqual(ta1.allLocationsControllers.first.status,0);
	
	self.opts.purge();
	self.opts.addAssoc( "LocationType",  GC_GroundLocation );
	self.opts.addAssoc( "ICArea",  ica2 );
	self.opts.addAssoc( "Capacity",  99999999 );
	self.opts.addAssoc( "MaxWeight",  99999999 );

	gc2 := self.addGCRackOrGround(ta1,3,3,3,3,"GR2");
	self.assertNotNullMsg(gc2, "GR2 is NULL");
	
	self.opts.purge();
	self.opts.addAssoc( "LocationType",  GC_GroundLocation );
	self.opts.addAssoc( "ICArea",  ica3 );
	self.opts.addAssoc( "Capacity",  99999999 );
	self.opts.addAssoc( "MaxWeight",  99999999 );

	gc3 := self.addGCRackOrGround(ta1,3,3,3,3,"GR3");
	self.assertNotNullMsg(gc3, "GR3 is NULL");

	photoDesc := "a photo descrption for TerminalArea";
	
	resourcesForm := PictureResourcesForm.createPrintForm();
	pictureTA1 := resourcesForm.picTA1.picture;
	photo := self.addTerminalAreaPhoto(ica1, photoDesc, pictureTA1);
	pictureTA2 := resourcesForm.picTA2.picture;
	photo := self.addTerminalAreaPhoto(ica2, photoDesc, pictureTA2);
	pictureTA3 := resourcesForm.picExamplePhoto.picture;
	photo := self.addTerminalAreaPhoto(ica3, photoDesc, pictureTA3);
	
	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);
	sGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);

	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis1);
	
	// CREATE FIRST BATCH CARGO AND MOVE TO TA1
	foreach idy in cgSuffix to cgSuffix + 10 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		vvr := self.gateInGC(TRUCKID, null, TRUCKID, cargoId, CARGOTYPEDESC, opCode, null, sGate, 100);
		ti := self.getTrackedItem(cargoId);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		tis1.add(ti);
		
		twoDaysAgoTime := twoDaysAgoTime.addSeconds(1);
		
		beginTransaction;
			ti.setCargoGroup(cargoGroup1, cargoGroup1.id, app.myPassport);
			vvr.setTimeIn(twoDaysAgo, twoDaysAgoTime);
		commitTransaction;
		
		self.deleteStops(ti);
		
		self.movePlanned(ti, gc1);
		self.assertTrueMsg(ti.myPrimaryPlannedLocation &lt;&gt; null, ti.id &amp; " did not plan");
		
		self.moveVehicleToYard(vvr.vehicle);
		self.assertTrueMsg(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation,"VVR Primary Location ISSUE 1");
		
		self.workVehicle(vvr);
		locn := ti.getPrimaryLocation(REAL_MODE);
		
		self.assertNotNull(locn);
		self.assertTrueMsg(locn.isKindOf(CM_YardController),"TI primary location Issue");
		self.assertTrueMsg(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation,"VVR Primary Location ISSUE 2");
					
		self.roadExit(vvr);
	endforeach;
	self.moveCargo(ti, tis1, gc1, app.myPassport);
	
	
	// CREATE SECOND BATCH CARGO AND MOVE TO TA2
	// THESE ARRIVED 2 DAYS AGO
	cgSuffix := 200;
	twoDaysAgo := twoDaysAgo.addDays(-2);
	
	foreach idy in cgSuffix to cgSuffix + 10 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		vvr := self.gateInGC(TRUCKID2, null, TRUCKID2, cargoId, CARGOTYPEDESC, opCode, null, sGate, 100);
		ti := self.getTrackedItem(cargoId);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		tis2.add(ti);
		
		twoDaysAgoTime := twoDaysAgoTime.addSeconds(1);
		
		beginTransaction;
			ti.setCargoGroup(cargoGroup1, cargoGroup1.id, app.myPassport);
			vvr.setTimeIn(twoDaysAgo, twoDaysAgoTime);
		commitTransaction;
		
		
		self.deleteStops(ti);
		
		self.movePlanned(ti, gc2);
		self.assertTrueMsg(ti.myPrimaryPlannedLocation &lt;&gt; null, ti.id &amp; " did not plan");
		
		self.moveVehicleToYard(vvr.vehicle);
		self.assertTrueMsg(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation,"VVR Primary Location ISSUE 1");
		
		self.workVehicle(vvr);
		locn := ti.getPrimaryLocation(REAL_MODE);
		
		self.assertNotNull(locn);
		self.assertTrueMsg(locn.isKindOf(CM_YardController),"TI primary location Issue");
		self.assertTrueMsg(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation,"VVR Primary Location ISSUE 2");
					
		self.roadExit(vvr);
	endforeach;
	self.moveCargo(ti, tis2, gc2, app.myPassport);
	
	
	// CREATE THIRD BATCH CARGO AND MOVE TO TA3
	// THESE ARRIVED TODAY
	cgSuffix := 300;
	
	foreach idy in cgSuffix to cgSuffix + 11 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		vvr := self.gateInGC(TRUCKID3, null, TRUCKID3, cargoId, CARGOTYPEDESC, opCode, null, sGate, 100);
		ti := self.getTrackedItem(cargoId);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		tis3.add(ti);
		
		beginTransaction;
			ti.setCargoGroup(cargoGroup1, cargoGroup1.id, app.myPassport);
		commitTransaction;
		
		
		self.deleteStops(ti);
		
		self.movePlanned(ti, gc3);
		self.assertTrueMsg(ti.myPrimaryPlannedLocation &lt;&gt; null, ti.id &amp; " did not plan");
		
		self.moveVehicleToYard(vvr.vehicle);
		self.assertTrueMsg(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation,"VVR Primary Location ISSUE 1");
		
		self.workVehicle(vvr);
		locn := ti.getPrimaryLocation(REAL_MODE);
		
		self.assertNotNull(locn);
		self.assertTrueMsg(locn.isKindOf(CM_YardController),"TI primary location Issue");
		self.assertTrueMsg(vvr.vehicle.myPrimaryActualLocation.isInterchangeAreaLocation,"VVR Primary Location ISSUE 2");
					
		self.roadExit(vvr);
	endforeach;
	self.moveCargo(ti, tis3, gc3, app.myPassport);
	
	
	// ######### YARD ALLOC
	self.deleteYA("UTPHOT");
	create lcs transient;
	lcs.add(gc1);
	lcs.add(gc2);
	lcs.add(gc3);
	
	create cargoTypeSet transient;
	cargoTypeSet.add(cargoType);
	ya := self.addYA1("UTPHOT", YACriteriaType_CargoType, cargoTypeSet, lcs);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Create failed");
	self.assertTrueMsg(ya.allYABlocksIn.size = 3, "Locations not created");
	self.assertTrueMsg(ya.allCriteria.size  = 1, "Criteria not created");
	
	// ### Create a road release request for the cargo group
	self.opts.purge();
	self.deleteReleaseRequest(cgId);
	
	self.opts.addAssoc("Context", RelReqContext_CargoGroupReview);
	self.opts.addAssoc("CargoGroup", cargoGroup1);
	self.opts.addAssoc("Number", cargoGroup1.totalQuantity);
	
	release := self.addReleaseByTypeRequestOpts(cgId,BR_TYPE_ROAD, cargoType.id);
	
	self.assertTrueMsg(release &lt;&gt; null, "BR is null!");
	
	detail := release.allReserveDetails.first;
	
	// We want to test the Oldest Date
	beginTransaction;
	detail.setPropertyValue("locnByOldestTransportArrival", true);
	commitTransaction;
	
	self.assertTrueMsg(detail &lt;&gt; null, "BR Detail is null!");
	self.assertTrueMsg(release.context = RelReqContext_CargoGroupReview, "BR Context should be " &amp; RelReqContext_CargoGroupReview);
	self.assertTrueMsg(detail.myCargoGroup = cargoGroup1, "BR Cargo Group is wrong should be " &amp; cargoGroup1.id);
	self.assertTrueMsg(detail.CM_ReserveSelection.totalRequested = cargoGroup1.totalQuantity, "BR totalRequested should be " &amp; cargoGroup1.totalQuantity.String);
	
	// ### Road Gate Release for whole of 1 TI
	self.opts.purge();
	self.opts.addAssoc("ReleaseRequest", release);
	self.opts.addAssoc("AnyId", true);
	self.opts.addAssoc("AnyAmt", true);
	vvr := self.gateOutGC(TRUCKID2, "", "UTDRIVER", null,  self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString) , null);

	self.assertTrueMsg(vvr &lt;&gt; null, "VVR is NULL!");
	
	gteEntity := vvr.allGateEntities.first.CMGTE_Release;
	
	self.assertTrueMsg(vvr &lt;&gt; null, "VVR is NULL!");
	self.assertTrueMsg(gteEntity &lt;&gt; null, "gteEntity is NULL!");
	self.assertTrueMsg(gteEntity.getIsAnyAmount() = true, "Any Amount is FALSE");
	self.assertTrueMsg(gteEntity.getIsAnyId() = true, "Any Id is FALSE");
	
	//-----------
	// At this stage
	//	YA 1 - Number of cargo 11 - Date : today
	//  YA 2 - Number of cargo 11 - Date : 2 days ago
	//  YA 3 - Number of cargo 12 - Date : today ********** MTN should take this
	//----------
	pictureJob := vvr.getMap();
	self.assertTrueMsg(pictureJob &lt;&gt; null, "#1 pictureJob is NULL!");
	//self.assertTrueMsg(pictureJob = pictureTA3, "pictureJob does not equal pictureTA3");
self.assertTrueMsg(pictureJob = pictureTA2, "pictureJob does not equal pictureTA3");  //18/12/2024	navkc1 JIRA Bug MTN-33686, should be TA2 due to oldest date option
	self.moveCargo(tis2.first, null, gc1, app.myPassport);

	// ### JIRA 23230 07OCT2024 NAVAB1
	beginTransaction;
	vvr.myRoadJob.getFirstLocationId(true); 
	commitTransaction;
	
	//-----------
	// At this stage
	//	YA 1 - Number of cargo 12 - Date : 2 days ago ********** MTN should take this
	//  YA 2 - Number of cargo 10 - Date : 2 days ago
	//  YA 3 - Number of cargo 12 - Date : today 
	//----------
	// MTN should return YA 1
	pictureJob := vvr.getMap();
	self.assertTrueMsg(pictureJob &lt;&gt; null, "#2 pictureJob is NULL!");
	self.assertTrueMsg(pictureJob = pictureTA1, "pictureJob does not equal pictureTA1");
	
	// ### TIDY UP
	
	self.deleteYA("UTPHOT");
	
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteCargoType(CARGOTYPEDESC);
	self.deleteReleaseRequest(cgId);
	
	self.deleteVehicle(TRUCKID);
	self.deleteVehicle(TRUCKID2);
epilog

	delete cargoTypeSet;
	delete resourcesForm;
	delete lcs;
	delete tis1;
	delete tis2;
	delete tis3;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRoadJobPhotoByDate05" id="d519817a-45f4-4af0-931b-5a9bae0b4d1d">
        <source>tRoadJobPhotoByDate05();/*
Purpose - 	the GETMAP for a job must find where the most cargo and cargo RAIL transport with oldest date is and then use the MAP for that location.
				this test is a ROAD JOB that has a RELEASE BY TYPE RELEASE REQUEST. 
				It will use YAs to find where the matching cargo is. The cargo is in GENERAL CARGO AREAS, so the map image is on the block stack terminal area

15/02/2023	navkc1 CR 60078 Task 62449: Jade - Unit Tests
*/



constants
	
	CARGOTYPEDESC = "UT_62449";
	TRUCKID2 = "CD230932";
	TRAINID = "TR62449";
	TRAINID2 = "TR62450";
	TRAINID3 = "TR62451";
	WAGONID = "W62449";
	WAGONID2 = "W62450";
	WAGONID3 = "W62451";
	WAGONCLASSCODE = "UT62449";
	RAILAREAID = "RA62119";
	STOPID = 631221;
	STOPIDTL = 710221;
vars
	resourcesForm : PictureResourcesForm;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	pxyTi,
	ti : CM_TrackedItem;
	tis1, tis2, tis3 : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	dateTime : TimeStamp;
	cargoOp : CM_Operator;
	cgSuffix : Integer;
	term : CM_Terminal;
	vvr : CM_VehicleVisitRecord;
	ta1, ta2, ta3 : CM_TerminalArea;
	release : CM_BulkRelease;
	detail : CM_ReserveDetail;
	gteEntity : CMGTE_Release;
	photoDesc : String;
	pictureTA1, pictureTA2, pictureTA3, pictureJob : Binary;
	photo : CM_Photo;
	ya : CM_YardAllocation;
	cargoTypeSet : CM_CargoTypeSet;
	lcs : CM_LCArray;
	twoDaysAgo : Date;
	twoDaysAgoTS, now : TimeStamp;
	ta1lc, ta2lc, ta3lc : CM_LocationsController;
	train, train2, train3 : CM_Train;
	railArea : CM_Rail;
	wagon, wagon2, wagon3 : CM_Wagon;
	wagonCont	: CM_WagonController;
	railLine : CM_RailLine;
	wagonClass : CM_WagonClass;
begin
	term := self.getTerminal();

	// ### JIRA 23230 07OCT2024 NAVAB1
	self.setTerminalConfig(UseYardJobsCargoWO,true);

	self.deleteVehicle(TRUCKID2);
	wagonClass := term.getWagonClass(null, WAGONCLASSCODE);
	self.deleteWagonClassAndWagons(wagonClass);
	self.deleteTrain(TRAINID, null);
	self.deleteTrain(TRAINID, null);
	self.deleteTrain(TRAINID3, null);
	self.deleteRailArea(RAILAREAID);
	
	create tis1 transient;
	create tis2 transient;
	create tis3 transient;
	
	ta1 := self.addBlockStack("UTPHT1",9999999,null);
	self.assertNotNullMsg(ta1, "TA1 is null");
	ta2 := self.addBlockStack("UTPHT2",9999999,null);
	self.assertNotNullMsg(ta2, "TA2 is null");
	ta3 := self.addBlockStack("UTPHT3",9999999,null);
	self.assertNotNullMsg(ta3, "TA3 is null");
	
	photoDesc := "a photo descrption for TerminalArea";
	
	resourcesForm := PictureResourcesForm.createPrintForm();
	pictureTA1 := resourcesForm.picTA1.picture;
	photo := self.addTerminalAreaPhoto(ta1, photoDesc, pictureTA1);
	pictureTA2 := resourcesForm.picTA2.picture;
	photo := self.addTerminalAreaPhoto(ta2, photoDesc, pictureTA2);
	pictureTA3 := resourcesForm.picExamplePhoto.picture;
	photo := self.addTerminalAreaPhoto(ta3, photoDesc, pictureTA3);
	
	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	
	
	railArea := self.addRailArea(RAILAREAID, 3, 5);
	train := self.addTrain(TRAINID, null);
	wagonClass := self.addWagonClass(WAGONCLASSCODE);
	wagon := self.addWagonInRailArea(WAGONID, WAGONCLASSCODE, railArea, train);
	
	train2 := self.addTrain(TRAINID2, null);
	wagon2 := self.addWagonInRailArea(WAGONID2, WAGONCLASSCODE, railArea, train2);
	
	train3 := self.addTrain(TRAINID3, null);
	wagon3 := self.addWagonInRailArea(WAGONID3, WAGONCLASSCODE, railArea, train3);
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KCKM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis1);
	
	
	// CREATE FIRST BATCH OF CARGO ON TRAIN1
	foreach idy in cgSuffix to cgSuffix + 5 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		pxyTi := term.createTI(cargoType, true);
		pxyTi.setPxyFromDefaultTI(term, cargoType.id, cargoId, null, cargoOp);
		pxyTi.zSetPxyImexStatus(TI_IMEX_STATUS_STORAGE);
		pxyTi.setReceiptTransportMode(TI_TRANSMODE_RAIL);
		pxyTi.setWagon(wagon.id, wagon, wagon.myWagonClass, false);
		pxyTi.setCargoGroup(cargoGroup1, cgId, app.myPassport);
		app.myTrxCA.trxCreateTrackedItem(pxyTi, ti, app.myPassport);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		tis1.add(ti);
		
		wagonCont := wagon.allLocationsControllersArray[1];
		self.moveTiToWagon(ti, wagonCont);
		railLine := railArea.allRailLinesByIndex[1];
		railLine.switchPositions(wagon, 01);
		
	endforeach;
	beginTransaction;
		train.setPropertyValue("arrivalDT", now);
	commitTransaction;
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train, true, app.myPassport);
	self.moveCargo(tis1.first(), tis1, ta1.allLocationsControllers.first(), app.myPassport);
	
	
	// CREATE SECOND BATCH CARGO ON TRAIN2
	// THESE ARRIVED 2 DAYS AGO
	cgSuffix := 200;
	twoDaysAgo := twoDaysAgo.addDays(-2);
	foreach idy in cgSuffix to cgSuffix + 5 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		pxyTi := term.createTI(cargoType, true);
		pxyTi.setPxyFromDefaultTI(term, cargoType.id, cargoId, null, cargoOp);
		pxyTi.zSetPxyImexStatus(TI_IMEX_STATUS_STORAGE);
		pxyTi.setReceiptTransportMode(TI_TRANSMODE_RAIL);
		pxyTi.setWagon(wagon2.id, wagon2, wagon2.myWagonClass, false);
		pxyTi.setCargoGroup(cargoGroup1, cgId, app.myPassport);
		app.myTrxCA.trxCreateTrackedItem(pxyTi, ti, app.myPassport);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		tis2.add(ti);
		
		wagonCont := wagon2.allLocationsControllersArray[1];
		self.moveTiToWagon(ti, wagonCont);
		railLine := railArea.allRailLinesByIndex[1];
		railLine.switchPositions(wagon2, 01);
	endforeach;
	twoDaysAgoTS.setDate(twoDaysAgo);
	beginTransaction;
		train2.setPropertyValue("arrivalDT", twoDaysAgoTS);
	commitTransaction;
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train2, true, app.myPassport);
	self.moveCargo(tis2.first(), tis2, ta2.allLocationsControllers.first(), app.myPassport);
	
	
	// CREATE THIRD BATCH CARGO AND MOVE TO TA3
	// THESE ARRIVED TODAY
	cgSuffix := 300;
	
	foreach idy in cgSuffix to cgSuffix + 6 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		pxyTi := term.createTI(cargoType, true);
		pxyTi.setPxyFromDefaultTI(term, cargoType.id, cargoId, null, cargoOp);
		pxyTi.zSetPxyImexStatus(TI_IMEX_STATUS_STORAGE);
		pxyTi.setReceiptTransportMode(TI_TRANSMODE_RAIL);
		pxyTi.setWagon(wagon3.id, wagon3, wagon3.myWagonClass, false);
		pxyTi.setCargoGroup(cargoGroup1, cgId, app.myPassport);
		app.myTrxCA.trxCreateTrackedItem(pxyTi, ti, app.myPassport);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		tis3.add(ti);
		
		wagonCont := wagon3.allLocationsControllersArray[1];
		self.moveTiToWagon(ti, wagonCont);
		railLine := railArea.allRailLinesByIndex[1];
		railLine.switchPositions(wagon3, 01);
	endforeach;
	beginTransaction;
		train3.setPropertyValue("arrivalDT", now);
	commitTransaction;
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train3, true, app.myPassport);
	self.moveCargo(tis3.first(), tis3, ta3.allLocationsControllers.first(), app.myPassport);
	
	
	// ######### YARD ALLOC
	self.deleteYA("UTPHOT");
	create lcs transient;
	ta1lc := ta1.allLocationsControllers.first.CM_YardController;
	ta2lc := ta2.allLocationsControllers.first.CM_YardController;
	ta3lc := ta3.allLocationsControllers.first.CM_YardController;
	lcs.add(ta1lc);
	lcs.add(ta2lc);
	lcs.add(ta3lc);
	
	create cargoTypeSet transient;
	cargoTypeSet.add(cargoType);
	ya := self.addYA1("UTPHOT", YACriteriaType_CargoType, cargoTypeSet, lcs);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Create failed");
	self.assertTrueMsg(ya.allYABlocksIn.size = 3, "Locations not created");
	self.assertTrueMsg(ya.allCriteria.size  = 1, "Criteria not created");
	
	// ### Create a road release request for the cargo group
	self.opts.purge();
	self.deleteReleaseRequest(cgId);
	
	self.opts.addAssoc("Context", RelReqContext_CargoGroupReview);
	self.opts.addAssoc("CargoGroup", cargoGroup1);
	self.opts.addAssoc("Number", cargoGroup1.totalQuantity);
	
	release := self.addReleaseByTypeRequestOpts(cgId,BR_TYPE_ROAD, cargoType.id);
	
	self.assertTrueMsg(release &lt;&gt; null, "BR is null!");
	
	detail := release.allReserveDetails.first;
	
	// We want to test the Oldest Date
	beginTransaction;
	detail.setPropertyValue("locnByOldestTransportArrival", true);
	commitTransaction;
	
	self.assertTrueMsg(detail &lt;&gt; null, "BR Detail is null!");
	self.assertTrueMsg(release.context = RelReqContext_CargoGroupReview, "BR Context should be " &amp; RelReqContext_CargoGroupReview);
	self.assertTrueMsg(detail.myCargoGroup = cargoGroup1, "BR Cargo Group is wrong should be " &amp; cargoGroup1.id);
	self.assertTrueMsg(detail.CM_ReserveSelection.totalRequested = cargoGroup1.totalQuantity, "BR totalRequested should be " &amp; cargoGroup1.totalQuantity.String);
	
	// ### Road Gate Release for whole of 1 TI
	self.opts.purge();
	self.opts.addAssoc("ReleaseRequest", release);
	self.opts.addAssoc("AnyId", true);
	self.opts.addAssoc("AnyAmt", true);
	vvr := self.gateOutGC(TRUCKID2, "", "UTDRIVER", null,  self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString) , null);

	self.assertTrueMsg(vvr &lt;&gt; null, "VVR is NULL!");
	
	gteEntity := vvr.allGateEntities.first.CMGTE_Release;
	
	self.assertTrueMsg(vvr &lt;&gt; null, "VVR is NULL!");
	self.assertTrueMsg(gteEntity &lt;&gt; null, "gteEntity is NULL!");
	self.assertTrueMsg(gteEntity.getIsAnyAmount() = true, "Any Amount is FALSE");
	self.assertTrueMsg(gteEntity.getIsAnyId() = true, "Any Id is FALSE");
	
	//-----------
	// At this stage
	//	YA 1 - Number of cargo 11 - Date : today
	//  YA 2 - Number of cargo 11 - Date : 2 days ago
	//  YA 3 - Number of cargo 12 - Date : today ********** MTN should take this
	//----------
	pictureJob := vvr.getMap();
	self.assertTrueMsg(pictureJob &lt;&gt; null, "#1 pictureJob is NULL!");
	//self.assertTrueMsg(pictureJob = pictureTA3, "pictureJob does not equal pictureTA3"); 
	self.assertTrueMsg(pictureJob = pictureTA2, "pictureJob does not equal pictureTA2");  //18/12/2024	navkc1 JIRA Bug MTN-33686, should be TA2 due to oldest date option
	
	self.moveCargo(tis2.first, null, ta1lc, app.myPassport);

	// ### JIRA 23230 07OCT2024 NAVAB1
	beginTransaction;
	vvr.myRoadJob.getFirstLocationId(true); 
	commitTransaction;
	
	//-----------
	// At this stage
	//	YA 1 - Number of cargo 12 - Date : 2 days ago ********** MTN should take this
	//  YA 2 - Number of cargo 10 - Date : 2 days ago
	//  YA 3 - Number of cargo 12 - Date : today 
	//----------
	// MTN should return YA 1
	pictureJob := vvr.getMap();
	self.assertTrueMsg(pictureJob &lt;&gt; null, "#2 pictureJob is NULL!");
	self.assertTrueMsg(pictureJob = pictureTA1, "pictureJob does not equal pictureTA1");
	
	// ### TIDY UP
	
	self.deleteYA("UTPHOT");
	
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteCargoType(CARGOTYPEDESC);
	self.deleteReleaseRequest(cgId);
	
	self.deleteVehicle(TRUCKID2);
	self.deleteWagonClassAndWagons(wagonClass);
	self.deleteTrain(TRAINID, train);
	self.deleteTrain(TRAINID3, train2);
	self.deleteTrain(TRAINID2, train3);
	self.deleteRailArea(RAILAREAID);
epilog

	delete cargoTypeSet;
	delete resourcesForm;
	delete lcs;
	delete tis1;
	delete tis2;
	delete tis3;
end;</source>
    </JadeMethod>
    <JadeMethod name="tRoadJobPhotoByDate06" id="96ef3d1e-4ee0-490c-9047-bb4d75a5deb7">
        <source>tRoadJobPhotoByDate06();
/*
Purpose - 	the GETMAP for a job must find where the most cargo and cargo RAIL transport with oldest date is and then use the MAP for that location.
				this test is a ROAD JOB that has a RELEASE BY TYPE RELEASE REQUEST. 
				It will use YAs to find where the matching cargo is. The cargo is in GENERAL CARGO AREAS, so the map image is on the block stack terminal area

15/02/2023	navkc1 CR 60078 Task 62449: Jade - Unit Tests
*/



constants
	
	CARGOTYPEDESC = "UT_62449";
	TRUCKID2 = "CD230932";
	TRAINID = "TR62449";
	TRAINID2 = "TR62450";
	TRAINID3 = "TR62451";
	WAGONID = "W62449";
	WAGONID2 = "W62450";
	WAGONID3 = "W62451";
	WAGONCLASSCODE = "UT62449";
	RAILAREAID = "RA62119";
	STOPID = 631221;
	STOPIDTL = 710221;
vars
	resourcesForm : PictureResourcesForm;
	cargoId, cgId, opCode : String;
	idy : Integer;
	cargoType : CM_CargoType;
	pxyTi,
	ti : CM_TrackedItem;
	tis1, tis2, tis3 : CM_TISet;
	cargoGroup1 : CM_CargoGroup;
	dateTime : TimeStamp;
	cargoOp : CM_Operator;
	cgSuffix : Integer;
	term : CM_Terminal;
	vvr : CM_VehicleVisitRecord;
	ta1 : CM_IrregularBlockArea;
	release : CM_BulkRelease;
	detail : CM_ReserveDetail;
	gteEntity : CMGTE_Release;
	photoDesc : String;
	pictureTA1, pictureTA2, pictureTA3, pictureJob : Binary;
	photo : CM_Photo;
	ya : CM_YardAllocation;
	cargoTypeSet : CM_CargoTypeSet;
	lcs : CM_LCArray;
	twoDaysAgo : Date;
	twoDaysAgoTS, now : TimeStamp;
	ica1, ica2, ica3 : CM_InterchangeArea;
	gc1, gc2, gc3 : CM_IrregularBlockController;
	train, train2, train3 : CM_Train;
	railArea : CM_Rail;
	wagon, wagon2, wagon3 : CM_Wagon;
	wagonCont	: CM_WagonController;
	railLine : CM_RailLine;
	wagonClass : CM_WagonClass;
begin
	term := self.getTerminal();

	// ### JIRA 23230 07OCT2024 NAVAB1
	self.setTerminalConfig(UseYardJobsCargoWO,true);

	self.deleteVehicle(TRUCKID2);
	wagonClass := term.getWagonClass(null, WAGONCLASSCODE);
	self.deleteWagonClassAndWagons(wagonClass);
	self.deleteTrain(TRAINID, null);
	self.deleteTrain(TRAINID, null);
	self.deleteTrain(TRAINID3, null);
	self.deleteRailArea(RAILAREAID);
	
	create tis1 transient;
	create tis2 transient;
	create tis3 transient;
	
	self.deleteTerminalArea("UTICA1");
	ica1 := self.addInterchangeArea("UTICA1",null);
	self.assertNotNullMsg(ica1, "UTICA1 is NULL");
	
	self.deleteTerminalArea("UTICA2");
	ica2 := self.addInterchangeArea("UTICA2",null);
	self.assertNotNullMsg(ica2, "UTICA2 is NULL");
	
	self.deleteTerminalArea("UTICA3");
	ica3 := self.addInterchangeArea("UTICA3",null);
	self.assertNotNullMsg(ica3, "UTICA3 is NULL");
	
	self.deleteTerminalArea("UTGC1");
	ta1 := self.addGeneralCargoArea("UTGC1",
									   "UT General Cargo Area",
									   10,
									   6,
									   100,
									   null,
									   null);
	self.assertNotNullMsg(ta1, "UTGC1 is NULL");
	
	self.opts.purge();
	self.opts.addAssoc( "LocationType",  GC_GroundLocation );
	self.opts.addAssoc( "ICArea",  ica1 );
	self.opts.addAssoc( "Capacity",  99999999 );
	self.opts.addAssoc( "MaxWeight",  99999999 );

	gc1 := self.addGCRackOrGround(ta1,1,1,1,1,"GR1");
	self.assertNotNullMsg(gc1, "GR1 is NULL");
	assertEqual(ta1.allLocationsControllers.first.status,0);
	
	self.opts.purge();
	self.opts.addAssoc( "LocationType",  GC_GroundLocation );
	self.opts.addAssoc( "ICArea",  ica2 );
	self.opts.addAssoc( "Capacity",  99999999 );
	self.opts.addAssoc( "MaxWeight",  99999999 );

	gc2 := self.addGCRackOrGround(ta1,3,3,3,3,"GR2");
	self.assertNotNullMsg(gc2, "GR2 is NULL");
	
	self.opts.purge();
	self.opts.addAssoc( "LocationType",  GC_GroundLocation );
	self.opts.addAssoc( "ICArea",  ica3 );
	self.opts.addAssoc( "Capacity",  99999999 );
	self.opts.addAssoc( "MaxWeight",  99999999 );

	gc3 := self.addGCRackOrGround(ta1,3,3,3,3,"GR3");
	self.assertNotNullMsg(gc3, "GR3 is NULL");

	photoDesc := "a photo descrption for TerminalArea";
	
	resourcesForm := PictureResourcesForm.createPrintForm();
	pictureTA1 := resourcesForm.picTA1.picture;
	photo := self.addTerminalAreaPhoto(ica1, photoDesc, pictureTA1);
	pictureTA2 := resourcesForm.picTA2.picture;
	photo := self.addTerminalAreaPhoto(ica2, photoDesc, pictureTA2);
	pictureTA3 := resourcesForm.picExamplePhoto.picture;
	photo := self.addTerminalAreaPhoto(ica3, photoDesc, pictureTA3);
	
	self.opts.purge();
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("Description", CARGOTYPEDESC  &amp; " Desc");

	cargoType := self.addCargoType(CARGOTYPEDESC, false);
	self.assertTrueMsg(cargoType &lt;&gt; null, CARGOTYPEDESC &amp; " not created during setup.");
	self.assertTrueMsg(cargoType.allTerminals.includes(term), CARGOTYPEDESC &amp; " does not include terminal " &amp; term.code);
	
	
	railArea := self.addRailArea(RAILAREAID, 3, 5);
	train := self.addTrain(TRAINID, null);
	wagonClass := self.addWagonClass(WAGONCLASSCODE);
	wagon := self.addWagonInRailArea(WAGONID, WAGONCLASSCODE, railArea, train);
	
	train2 := self.addTrain(TRAINID2, null);
	wagon2 := self.addWagonInRailArea(WAGONID2, WAGONCLASSCODE, railArea, train2);
	
	train3 := self.addTrain(TRAINID3, null);
	wagon3 := self.addWagonInRailArea(WAGONID3, WAGONCLASSCODE, railArea, train3);
	
	opCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString();
	
	cargoOp := self.getOperator(opCode);

	// ### ACTUAL CARGO CREATION For Cargo Group
	self.opts.addAssoc("CountryOrigin", app.myRoot.allCountries.last); 
	cgSuffix := 100;
	cgId := "KCKM" &amp; dateTime.date.year.String[3:2] &amp; dateTime.date.month.String &amp; dateTime.date.day.String &amp; "-" &amp; cgSuffix.String;
	self.deleteCargoGroup(cgId);
	cargoGroup1 := self.addCargoGroup(cgId,tis1);
	
	
	// CREATE FIRST BATCH OF CARGO ON TRAIN1
	foreach idy in cgSuffix to cgSuffix + 5 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		pxyTi := term.createTI(cargoType, true);
		pxyTi.setPxyFromDefaultTI(term, cargoType.id, cargoId, null, cargoOp);
		pxyTi.zSetPxyImexStatus(TI_IMEX_STATUS_STORAGE);
		pxyTi.setReceiptTransportMode(TI_TRANSMODE_RAIL);
		pxyTi.setWagon(wagon.id, wagon, wagon.myWagonClass, false);
		pxyTi.setCargoGroup(cargoGroup1, cgId, app.myPassport);
		app.myTrxCA.trxCreateTrackedItem(pxyTi, ti, app.myPassport);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		tis1.add(ti);
		
		wagonCont := wagon.allLocationsControllersArray[1];
		self.moveTiToWagon(ti, wagonCont);
		railLine := railArea.allRailLinesByIndex[1];
		railLine.switchPositions(wagon, 01);
		
	endforeach;
	beginTransaction;
		train.setPropertyValue("arrivalDT", now);
	commitTransaction;
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train, true, app.myPassport);
	self.moveCargo(tis1.first(), tis1, gc1, app.myPassport);
	
	
	// CREATE SECOND BATCH CARGO ON TRAIN2
	// THESE ARRIVED 2 DAYS AGO
	cgSuffix := 200;
	twoDaysAgo := twoDaysAgo.addDays(-2);
	foreach idy in cgSuffix to cgSuffix + 5 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		pxyTi := term.createTI(cargoType, true);
		pxyTi.setPxyFromDefaultTI(term, cargoType.id, cargoId, null, cargoOp);
		pxyTi.zSetPxyImexStatus(TI_IMEX_STATUS_STORAGE);
		pxyTi.setReceiptTransportMode(TI_TRANSMODE_RAIL);
		pxyTi.setWagon(wagon2.id, wagon2, wagon2.myWagonClass, false);
		pxyTi.setCargoGroup(cargoGroup1, cgId, app.myPassport);
		app.myTrxCA.trxCreateTrackedItem(pxyTi, ti, app.myPassport);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		tis2.add(ti);
		
		wagonCont := wagon2.allLocationsControllersArray[1];
		self.moveTiToWagon(ti, wagonCont);
		railLine := railArea.allRailLinesByIndex[1];
		railLine.switchPositions(wagon2, 01);
	endforeach;
	twoDaysAgoTS.setDate(twoDaysAgo);
	beginTransaction;
		train2.setPropertyValue("arrivalDT", twoDaysAgoTS);
	commitTransaction;
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train2, true, app.myPassport);
	self.moveCargo(tis2.first(), tis2, gc2, app.myPassport);
	
	
	// CREATE THIRD BATCH CARGO AND MOVE TO TA3
	// THESE ARRIVED TODAY
	cgSuffix := 300;
	
	foreach idy in cgSuffix to cgSuffix + 6 do
		cargoId := cargoType.abbreviation &amp; "-" &amp; idy.padLeadingWith("0",3);
		
		pxyTi := term.createTI(cargoType, true);
		pxyTi.setPxyFromDefaultTI(term, cargoType.id, cargoId, null, cargoOp);
		pxyTi.zSetPxyImexStatus(TI_IMEX_STATUS_STORAGE);
		pxyTi.setReceiptTransportMode(TI_TRANSMODE_RAIL);
		pxyTi.setWagon(wagon3.id, wagon3, wagon3.myWagonClass, false);
		pxyTi.setCargoGroup(cargoGroup1, cgId, app.myPassport);
		app.myTrxCA.trxCreateTrackedItem(pxyTi, ti, app.myPassport);
		
		assertTrueMsg(ti &lt;&gt; null, cargoId &amp; " is null, Cargo not created");
		tis3.add(ti);
		
		wagonCont := wagon3.allLocationsControllersArray[1];
		self.moveTiToWagon(ti, wagonCont);
		railLine := railArea.allRailLinesByIndex[1];
		railLine.switchPositions(wagon3, 01);
	endforeach;
	beginTransaction;
		train3.setPropertyValue("arrivalDT", now);
	commitTransaction;
	app.myTrxUA.trxUpdateWagonConfirmTrain(null, true, train3, true, app.myPassport);
	self.moveCargo(tis3.first(), tis3, gc3, app.myPassport);
	
	
	// ######### YARD ALLOC
	self.deleteYA("UTPHOT");
	create lcs transient;
	lcs.add(gc1);
	lcs.add(gc2);
	lcs.add(gc3);
	
	create cargoTypeSet transient;
	cargoTypeSet.add(cargoType);
	ya := self.addYA1("UTPHOT", YACriteriaType_CargoType, cargoTypeSet, lcs);
	self.assertTrueMsg(app.myPassport.trxCompletedOK, "Create failed");
	self.assertTrueMsg(ya.allYABlocksIn.size = 3, "Locations not created");
	self.assertTrueMsg(ya.allCriteria.size  = 1, "Criteria not created");
	
	// ### Create a road release request for the cargo group
	self.opts.purge();
	self.deleteReleaseRequest(cgId);
	
	self.opts.addAssoc("Context", RelReqContext_CargoGroupReview);
	self.opts.addAssoc("CargoGroup", cargoGroup1);
	self.opts.addAssoc("Number", cargoGroup1.totalQuantity);
	
	release := self.addReleaseByTypeRequestOpts(cgId,BR_TYPE_ROAD, cargoType.id);
	
	self.assertTrueMsg(release &lt;&gt; null, "BR is null!");
	
	detail := release.allReserveDetails.first;
	
	// We want to test the Oldest Date
	beginTransaction;
	detail.setPropertyValue("locnByOldestTransportArrival", true);
	commitTransaction;
	
	self.assertTrueMsg(detail &lt;&gt; null, "BR Detail is null!");
	self.assertTrueMsg(release.context = RelReqContext_CargoGroupReview, "BR Context should be " &amp; RelReqContext_CargoGroupReview);
	self.assertTrueMsg(detail.myCargoGroup = cargoGroup1, "BR Cargo Group is wrong should be " &amp; cargoGroup1.id);
	self.assertTrueMsg(detail.CM_ReserveSelection.totalRequested = cargoGroup1.totalQuantity, "BR totalRequested should be " &amp; cargoGroup1.totalQuantity.String);
	
	// ### Road Gate Release for whole of 1 TI
	self.opts.purge();
	self.opts.addAssoc("ReleaseRequest", release);
	self.opts.addAssoc("AnyId", true);
	self.opts.addAssoc("AnyAmt", true);
	vvr := self.gateOutGC(TRUCKID2, "", "UTDRIVER", null,  self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString) , null);

	self.assertTrueMsg(vvr &lt;&gt; null, "VVR is NULL!");
	
	gteEntity := vvr.allGateEntities.first.CMGTE_Release;
	
	self.assertTrueMsg(vvr &lt;&gt; null, "VVR is NULL!");
	self.assertTrueMsg(gteEntity &lt;&gt; null, "gteEntity is NULL!");
	self.assertTrueMsg(gteEntity.getIsAnyAmount() = true, "Any Amount is FALSE");
	self.assertTrueMsg(gteEntity.getIsAnyId() = true, "Any Id is FALSE");
	
	//-----------
	// At this stage
	//	YA 1 - Number of cargo 11 - Date : today
	//  YA 2 - Number of cargo 11 - Date : 2 days ago
	//  YA 3 - Number of cargo 12 - Date : today ********** MTN should take this
	//----------
	pictureJob := vvr.getMap();
	self.assertTrueMsg(pictureJob &lt;&gt; null, "#1 pictureJob is NULL!");
	//self.assertTrueMsg(pictureJob = pictureTA3, "pictureJob does not equal pictureTA3");
	self.assertTrueMsg(pictureJob = pictureTA2, "pictureJob does not equal pictureTA2");  //18/12/2024	navkc1 JIRA Bug MTN-33686, should be TA2 due to oldest date option
	
	self.moveCargo(tis2.first, null, gc1, app.myPassport);

	// ### JIRA 23230 07OCT2024 NAVAB1
	beginTransaction;
	vvr.myRoadJob.getFirstLocationId(true); 
	commitTransaction;
	
	//-----------
	// At this stage
	//	YA 1 - Number of cargo 12 - Date : 2 days ago ********** MTN should take this
	//  YA 2 - Number of cargo 10 - Date : 2 days ago
	//  YA 3 - Number of cargo 12 - Date : today 
	//----------
	// MTN should return YA 1
	pictureJob := vvr.getMap();
	self.assertTrueMsg(pictureJob &lt;&gt; null, "#2 pictureJob is NULL!");
	self.assertTrueMsg(pictureJob = pictureTA1, "pictureJob does not equal pictureTA1");
	
	// ### TIDY UP
	
	self.deleteYA("UTPHOT");
	
	self.deleteCargoGroup(cargoGroup1.id);
	
	self.deleteCargoType(CARGOTYPEDESC);
	self.deleteReleaseRequest(cgId);
	
	self.deleteVehicle(TRUCKID2);
	self.deleteWagonClassAndWagons(wagonClass);
	self.deleteTrain(TRAINID, train);
	self.deleteTrain(TRAINID3, train2);
	self.deleteTrain(TRAINID2, train3);
	self.deleteRailArea(RAILAREAID);
epilog

	delete cargoTypeSet;
	delete resourcesForm;
	delete lcs;
	delete tis1;
	delete tis2;
	delete tis3;
end;</source>
    </JadeMethod>
    <JadeMethod name="tSimpleGCAllocRow" id="68cb019c-bcad-4a04-aa9b-b53c85c8bd12">
        <source>tSimpleGCAllocRow();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 April 2021	navndl1	Initial creation	TFS 49912

*/

constants

	GCALLOC : String = "BUNKER";
	CoalCargoType : String = "CLINKER";
	YAId : String = "BUNKER_CLINKER";

vars

	gcAllocRowArea : CM_GeneralCargoAllocRowArea;
	pxyGcAllocRowArea : CM_GeneralCargoAllocRowArea;
	cargoType : CM_CargoType;
	pxyProdMinMax : CM_TerminalAreaProductMinMax;
	colArray : StringArray;
	divArray : StringArray;
	pxyColumnGroup : CM_GeneralCargoAllocGroup;
	gcColumnGroup : CM_GeneralCargoAllocGroup;
	ya : CM_YardAllocation;
	locations : CM_LCArray;
	rowController : CM_RowController;

begin

	cargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr( CoalCargoType );
	self.assertTrueMsg( cargoType &lt;&gt; null, CoalCargoType &amp; " cargo type not found in setup." );

	//cleanup
	
	self.deleteYA(YAId);
	self.deleteTerminalArea( GCALLOC );

	//setup
	
	gcAllocRowArea := self.addGCAllocRowArea( GCALLOC );
	
	self.assertTrueMsg( gcAllocRowArea &lt;&gt; null, GCALLOC &amp; " not created." );
	self.assertTrueMsg( gcAllocRowArea.allRowControllersById.size = 4, GCALLOC &amp; " should have four 'column group' objects." ); //A-B, C, D-E, F-H
	self.assertTrueMsg( gcAllocRowArea.allRows.size = 8, GCALLOC &amp; " should have eight 'column' objects." );
	
	create colArray transient;
	create divArray transient;
	
	//create a pxy and add capacity at column level - Mimicing using the Terminal Area definition form
	pxyGcAllocRowArea := createUpdateGcAllocAreaProxy( gcAllocRowArea, colArray, divArray );
	
	create pxyProdMinMax transient;
	pxyProdMinMax.setupProxy( null, cargoType, null, pxyGcAllocRowArea, 0, 0, 0, 2500, 0 );
	
	app.myTrxUA.trxUpdateTerminalAreaGCAlloc( pxyGcAllocRowArea, app.myPassport);
	
	delete pxyProdMinMax;
	delete pxyGcAllocRowArea;
	
	
	self.assertTrueMsg( gcAllocRowArea.allProductMinMax.size = 1, CoalCargoType &amp; " capacity per column not created." );
	self.assertTrueMsg( gcAllocRowArea.allProductMinMax.first.maxWeight = 2500, CoalCargoType &amp; " capacity per column should be 2500 kg." );
	
	//try an LC based capacity. - Mimicing using the Terminal Area definition form
	pxyGcAllocRowArea := createUpdateGcAllocAreaProxy( gcAllocRowArea, colArray, divArray );
	pxyColumnGroup := pxyGcAllocRowArea.allRowControllersById.first.CM_GeneralCargoAllocGroup;
	
	create pxyProdMinMax transient;
	pxyProdMinMax.setupProxy( pxyColumnGroup, cargoType, null, pxyGcAllocRowArea, 0, 0, 0, 3500, 0 );
	
	pxyGcAllocRowArea.createProxyLCsAndGroups( colArray, divArray );
	
	app.myTrxUA.trxUpdateTerminalAreaGCAlloc( pxyGcAllocRowArea, app.myPassport);
	
	delete pxyProdMinMax;
	delete pxyGcAllocRowArea;
	
	gcColumnGroup := gcAllocRowArea.allRowControllersById.first.CM_GeneralCargoAllocGroup;
	self.assertTrueMsg( gcColumnGroup.allProductMinMax.size = 1, CoalCargoType &amp; " capacity for column group '" &amp; gcColumnGroup.ident &amp; "' not created." );
	self.assertTrueMsg( gcAllocRowArea.allProductMinMax.size = 2, "Should be 2 capacity objects." );
	self.assertTrueMsg( gcColumnGroup.allProductMinMax.first.maxWeight = 3500, CoalCargoType &amp; " capacity for column group '" &amp; gcColumnGroup.ident &amp; "' should be 3500 kg." );
	
	
	//Try creating a cargo capacity from a yard allocation against a 'column Group', "D-E" using projected GC. Mimicing using the Yard Allocation form
	create locations transient;
	gcColumnGroup := gcAllocRowArea.allRowControllersById.getAtKey("D-E").CM_GeneralCargoAllocGroup;
	gcColumnGroup.allLocations.copy( locations );
	
	self.opts.purge();
	self.opts.addAssoc( "ProjectedGC", 4500.Real );
	ya := self.addYA(YAId, YACriteriaType_CargoType, cargoType, null, null, null, null, locations, null);
	
	self.assertTrueMsg(ya &lt;&gt; null, YAId &amp; " yard allocation not created during setup of YA Capacity test.");
	self.assertTrueMsg( ya.projectedGC = 4500, "Yard Allocation Projected GC should be 4500" );
	
	gcColumnGroup := gcAllocRowArea.allRowControllersById.getAtKey("D-E").CM_GeneralCargoAllocGroup;
	self.assertTrueMsg( gcColumnGroup &lt;&gt; null, "Column Group D-E not found after Yard Allocation creation" );
	self.assertTrueMsg( gcColumnGroup.allProductMinMax.size = 1, CoalCargoType &amp; " capacity for column group '" &amp; gcColumnGroup.ident &amp; "' not created as part of Yard Allocation." );
	self.assertTrueMsg( gcAllocRowArea.allProductMinMax.size = 3, "Should be 3 capacity objects." );
	
	//cleanup
	
	self.deleteYA(YAId);
	self.deleteTerminalArea( GCALLOC );
	
epilog

	delete colArray;
	delete divArray;
	delete locations;

end;</source>
    </JadeMethod>
    <JadeMethod name="tStraddleStackGapChecking" id="20e0c9a1-25cf-4ba6-9ae1-204daba45aca">
        <source>tStraddleStackGapChecking();

/*

Purpose:		Check that straddle stack gap checking

Date			Who		Reason
22/10/2015		cnwmh5	Initial creation

*/

vars

	straddle					: CM_StraddleStack;
	bs							: CM_BlockStack;
	ti							: CM_TrackedItem;
	lc							: CM_LocationsController;
	
	gapRowColumnArray			: StringArray;
	tiArray						: CM_TIArray;
	
	index						: Integer;

begin

	bs := self.addBlockStack("UTMHBSX", 999, null);
	self.assertNotNull(bs);
	
	create tiArray transient;
	self.opts.purge();
	self.opts.addAssoc("ISOType", "4200");
	self.opts.addAssoc("ReturnTIs", true);
	self.addQuickCargo(bs, null, 5, tiArray);

	// setup the straddle stack with gaps	
	create gapRowColumnArray transient;
	foreach index in 1 to 6 step 1 do
		gapRowColumnArray.add("0002," &amp; index.stringWithLeadingZeros(2));
		gapRowColumnArray.add("0005," &amp; index.stringWithLeadingZeros(2));
	endforeach;

	self.opts.purge();
	self.opts.addAssoc("GapRowColumn", gapRowColumnArray);
	straddle := self.addStraddleStack("UTMHSSH", 6, 6, 5);
	self.assertNotNull(straddle);

	// queue a container to slot next to a gap
	ti := tiArray.first;
	self.assertNotNull(ti);
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(Suitab_contai_longer_than_foot);
	lc := straddle.getLocationsControllerFromId("030004");
	self.assertNotNull(lc);
	self.move(ti, lc); 
	self.assertNoTrxErrorsOrWarnings();
	
	lc := straddle.getLocationsControllerFromId("030003");
	self.assertNotNull(lc);
	self.move(ti, lc); 
	self.assertNoTrxErrorsOrWarnings();

epilog
	
	delete tiArray;
	delete gapRowColumnArray;

end;</source>
    </JadeMethod>
    <JadeMethod name="tTerminalAreaDefinition" id="f0a79fb2-1f10-4cc5-975e-fef6862c8061">
        <source>tTerminalAreaDefinition();
/*

Purpose:			testlink test 01-188 Terminal Area Definition

Date		Who		Reason
07 February 2017	cnwmk3	Initial creation

*/
constants
	StraddleStack				= "SS188";
	GridAreaName				= "GRID188";
	BlockStack					= "BS188";
	LabourRestrictionID			= "LB188";
vars
	straddleStack				: CM_StraddleStack;
	gridArea					: CM_ForkLiftStack;
	bs							: CM_BlockStack;
	labourRestriction			: CM_LabourRestriction;
begin
	// Create a new 'Straddle Stack' Terminal Area
	self.deleteTerminalArea(StraddleStack);
	straddleStack := self.addStraddleStack(StraddleStack, 5, 5, 5);
	self.assertNotNull(straddleStack);
	
	//  check that 'Use Side Access Rules' is not ticked by default.
	self.assertFalse(straddleStack.useSideAccessRules);
	
	// Create a new 'Gridded Block Stack' Terminal Area
	self.deleteTerminalArea(GridAreaName);
	gridArea := self.addForkLiftStack(GridAreaName, 8, 8, 8);
	self.assertNotNull(gridArea);
	
	// check that 'Use Side Access Rules' is ticked by default.
	self.assertTrue(gridArea.useSideAccessRules);
	
	//  Set decking options for a block stack/yard interchange (expected result is that you will not be able to -&gt; decking options you will receive an error message).
	self.deleteTerminalArea(BlockStack);
	bs := self.addBlockStack(BlockStack, 4, null);
	self.assertNotNull(bs);
	
	self.assertEqual(bs.isDeckable, false);
	
	// create labour restriction over straddle stack
	labourRestriction := self.addLabourRestriction(LabourRestrictionID, straddleStack, false);
	self.assertNotNull(labourRestriction);
	
	// edit terminal area
	self.updateBlockStack(bs, 10);
	self.assertEqual(bs.maxCapacity, 10);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tUpdatePhoto" id="b9eea06b-214f-4b6b-93d3-f65758337b37">
