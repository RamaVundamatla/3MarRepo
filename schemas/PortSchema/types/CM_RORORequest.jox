    <JadeMethod name="setColourFromAllocation" id="5234fe4f-7e5d-4a34-81b3-9ed3260f1aa8">
        <updating/>
        <source>setColourFromAllocation(_allocation : CM_VoyageAllocation; _qty : Decimal) updating;
/*
Purpose:			
Date		Who		Reason
04 August 2011	cnwab1	Initial creation
*/

vars
	locnDefn : CM_DeckItem;
begin
	if _allocation = null then
		return;
	endif;
	
	self.quantity := _qty;
	
// 29373 NO this means that the background becomes solid colour when it should be WHITE			
	return;
	
	
	// update the request layout
	self.myLayout.setColourFromAllocation(_allocation);
	// update the location  layout
	locnDefn := self.myROROController.getDefn();
	
	if locnDefn &lt;&gt; null then
		locnDefn.myLayout.setColourFromAllocation(_allocation);
	endif;
epilog

end;</source>
        <Parameter name="_allocation" type="CM_VoyageAllocation"/>
        <Parameter name="_qty" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="39ae6fc3-f671-45b4-b564-d257d477f73b">
        <updating/>
        <source>setForCreate(_proxySlotRequest:CM_RORORequest) updating;
// ---------------------------------------------------------------------------
// Created:     02 June 2002 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	needToSetDoorDir	: Boolean;
	tmpSlot		: CM_VoyageROROController;
begin

	_proxySlotRequest.raiseExceptionIfNotTransient(method);
	
	if _proxySlotRequest.doorsDirection = TI_DOORSDIRN_NULL and
	   _proxySlotRequest.motorDirection = Motor_Null then
		// Assume that proxy has not been setup with defaults so set
		// a flag to set the defaults.  Need to do this once the
		// real is updated as the setDoorMotorDirDefault relies
		// on certain attributes being set.
		needToSetDoorDir := true;
	endif;

	self.myROROController := _proxySlotRequest.myROROController;

	self.setForUpdate(_proxySlotRequest);
	self.createWLEs();
	
	
	// PAR 29807 moved down    self.setForCreateLayout();
	self.myROROController.addSlotRequest(self.isLoad, self);

	self.setForCreateLayout(); // PAR 29807 
	
	// do this AFTER setting mySlotController as this relies
	// on the CM_SlotController.myDischargeRequest being set
	self.setForUpdateTI(NULL_MOVETYPE);
	
	app.writeVoyageLog(self, "Colour Code Create");  // PAR 31878 - logging
	

end;</source>
        <Parameter name="_proxySlotRequest" type="CM_RORORequest"/>
    </JadeMethod>
    <JadeMethod name="setForCreateLayout" id="abfc1510-3a45-4157-8510-0618edd2372b">
        <updating/>
        <source>setForCreateLayout() updating;
/*
Purpose:			
Date		Who		Reason
24 June 2011	cnwab1	Initial creation
*/

vars
	newLayout : CM_RORORequestLayout;
	theLayer : CM_DeckLayerLayout;
	deckItem : CM_DeckItem;
begin
	if self.myLayout &lt;&gt; null then
		return;
	endif;
	
	if self.myROROController = null then
		return;
	endif;
	
	if self.isDischarge then
		theLayer := self.myROROController.myDeck.myDeckLayout.getCCDischargeLayer();
	elseif self.isLoad then
		theLayer := self.myROROController.myDeck.myDeckLayout.getCCLoadLayer();
	else
		return;
	endif;

	deckItem := self.myROROController.getDefn();
	
	create self.myLayout;
	newLayout := self.myLayout;
	newLayout.setFromRequest(self);
	newLayout.setMyDeckLayer(theLayer);
	newLayout.setFromDefn(self.myROROController.getDefn());
	theLayer.addItemToBeginning(newLayout); // PAR 28990	
	
	if (not deckItem.isOOTL 
		or (deckItem.isOOTL and not deckItem.hasAlreadyCovered(true, DeckItemLayoutType_CCLoad))) then
	
			self.myROROController.myDeck.myDeckLayout.hideContainerPositionsUnderGC(self.myLayout); // PAR 28336
	
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="b981e723-f6b7-4081-ae80-261f4c68ead2">
        <updating/>
        <source>setForUpdate(_pxyRequest: CM_VoyageRequest) updating;
/*
Purpose:			
Date		Who		Reason
27 June 2011	cnwab1	Initial creation
*/

vars

begin
	inheritMethod(_pxyRequest);

	self.code := _pxyRequest.code;
	self.quantity := _pxyRequest.quantity;
	
	if self.myLayout &lt;&gt; null then
		self.myLayout.setFromRequest(self);
	endif;
epilog

end;</source>
