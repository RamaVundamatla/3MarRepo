    <JadeMethod name="hasRBTToAction" id="2316a6dd-4357-4d54-bed6-032dd46d3e9a">
        <source>hasRBTToAction(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 November 2009	cnwrd1	Initial creation

*/

vars

begin

	if not self.isFirstTask() then
		return false;
	endif;
	
	return self.myParent.hasRBTToAction();

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isOKToDelete" id="8653b375-6e55-4ae0-b673-c6088541aa05">
