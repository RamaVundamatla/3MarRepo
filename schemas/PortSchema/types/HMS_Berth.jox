    <JadeMethod name="validateForDelete" id="e89da923-3ca9-47c0-9f93-448fe064182a">
        <source>validateForDelete(_passport: CM_Passport input);
//--------------------------------------------------
// Created:	17 November 2004 By: cnwgd1
//--------------------------------------------------
vars

begin
	inheritMethod(_passport);
	
	if self.getAllVoyageMovements().size &gt; 0 then
		app.raiseCMException2(ObjectStillHasEntries, self.getDisplayString(), "Voyage Movement", null, null);	
		return;
	endif;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="7f33fdcb-5deb-4aee-9748-a8a36f842d52">
        <source>validateMe(_passport: CM_Passport input);
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
//--------------------------------------------------------------
vars
	tmpBerth : HMS_Berth;
begin
	inheritMethod(_passport);
	if self.code = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Code', ETRow_Code, null);
		app.raiseCMException(Input_required_field_code, ETRow_Code, null); // cnwdb2	PAR 35364
	endif;
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Description', ETRow_Description,  null);
		app.raiseCMException(Input_required_field_desc, ETRow_Description,  null); // cnwdb2	PAR 35364
	endif;

	if self.myHarbour = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Harbour', ETRow_MyHarbour,  null);
		app.raiseCMException(Input_required_field_harbour, ETRow_MyHarbour,  null); // cnwdb2	PAR 35364
	endif;

	if self.myWharf = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Wharf', ETRow_MyWharf,  null);
		app.raiseCMException(Input_required_field_wharf, ETRow_MyWharf,  null); // cnwdb2	PAR 35364
	endif;
	
	if self.isLogicalBerth() and self.defaultCargoOperation &lt;&gt; 0 then
		app.raiseCMException1(Logical_Berth_No_Cargo_Op, 'Wharf', ETRow_MyWharf,  null);
	endif;
	
	if _passport.hasErrors then
		return;
	endif;

	tmpBerth := self.myHarbour.allBerths.getAtKey(self.code);
	if tmpBerth &lt;&gt; null
	and tmpBerth &lt;&gt; self then
		if tmpBerth &lt;&gt; self.pxyGetRealObject() then
			//app.raiseCMException2(DuplicateItem, 'Berth', self.code, ETRow_Code, null); //14.06.2022 navds20 53760
			// Berth already exists for %1 : Berth_already_exists
			app.raiseCMException1(Berth_already_exists, self.code, ETRow_Code, null); //14.06.2022 navds20 53760
		endif;
	endif;

	if _passport.hasErrors then
		return;
	endif;

	if self.myWharf.isVisibleOnView then			
		if self.length = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Length', ETRow_Length,  null);
			app.raiseCMException(Input_required_field_length, ETRow_Length,  null); // cnwdb2	PAR 35364
		else
			self.validate_BerthOverlap(_passport);		
		endif;
		if self.minimumDepth = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Minimum Depth', ETRow_MinimumDepth,  null);
			app.raiseCMException(Input_required_field_minDepth, ETRow_MinimumDepth,  null); // cnwdb2	PAR 35364
		endif;
	elseif self.length &lt;&gt; null then
		self.validate_BerthOverlap(_passport);					
	endif;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateRangeForResource" id="326c402d-53b1-4939-96c4-bcc1757ed2aa">
        <source>validateRangeForResource(_startPosnAlongWharf, _endPosnAlongWharf : Integer; _resourceCode : String; _passport : CM_Passport input);
//--------------------------------------------------
//04 Oct 2022 navsj20	ChangeRequest 54739: EUP - PLAN - Berth planning by bollards
//--------------------------------------------------
vars
 	startPos,
 	endPos : Integer;
begin
  	// This method checks to see if the resource ranges entered are valid for the berth 
	startPos := self.startPosition;
	endPos := self.getBerthEndPosition;

	if _startPosnAlongWharf &lt; startPos or _startPosnAlongWharf &gt; endPos or _endPosnAlongWharf &lt; startPos or _endPosnAlongWharf &gt; endPos then
		app.raiseCMException3(ResourcePosInvalidForBerth,
							_resourceCode, myWharf.description,
							self.code, ETRow_StartPosnAlongWharf, null);
	endif;
end;</source>
        <Parameter name="_startPosnAlongWharf" type="Integer"/>
        <Parameter name="_endPosnAlongWharf" type="Integer"/>
        <Parameter name="_resourceCode" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validate_BerthOverlap" id="48f529a8-084c-4f54-b24e-4ac146a84d58">
        <source>validate_BerthOverlap(_passport: CM_Passport input);
//--------------------------------------------------------------
//Created: 10 July 2003 By: cnwgd1
//--------------------------------------------------------------
/*

Date		Who		Reason
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks
14/06/2022    navds20     TFS 53760 DuplicateItem not Translatable
*/
vars
	iter : Iterator;
	realBerth,
	tmpBerth : HMS_Berth;
	endPos,
	berthEndPos : Integer;
begin
	if app.isConverting then
		return;
	endif;
	iter := self.myWharf.allBerthsByStartPosnAndName.createIterator();
	self.myWharf.allBerthsByStartPosnAndName.startKeyLeq(self.startPosition, null, iter);
	endPos := self.getBerthEndPosition();
	
	if endPos &gt; self.myWharf.length then
		app.raiseCMException3(HMSBerthLength, self.code, endPos.String, self.myWharf.length.String, null, null);
	endif;
	
	if self.isTransient then
		realBerth := self.pxyGetRealObject();
	else
		realBerth := self;
	endif;
	// find berths spanning range
	while iter.next(tmpBerth) do
		if tmpBerth = realBerth then
			continue;
		endif;	
		if tmpBerth.code = self.code then
			continue;
		endif;
		berthEndPos := (tmpBerth.startPosition + tmpBerth.length).Integer;

		if (self.startPosition &gt;= tmpBerth.startPosition and self.startPosition &lt; berthEndPos)
		or (self.startPosition = tmpBerth.startPosition and endPos = berthEndPos)
		or (endPos &gt; tmpBerth.startPosition and endPos &lt; berthEndPos) then
			//will cause conflict in graphical view
			//app.raiseCMException2(DuplicateItem, 'BERTH POSITION OVERLAP: Berth ' &amp; tmpBerth.code, 'position ' &amp; tmpBerth.startPosition.String &amp; ' to ' &amp; berthEndPos.String, ETRow_Code, null); //14.06.2022 navds20 53760
			// BERTH POSITION OVERLAP: Berth %1 already exists for position %2 to %3 : Berth_posit_overl_berth_alrea_
			app.raiseCMException3(Berth_posit_overl_berth_alrea_, tmpBerth.code, tmpBerth.startPosition.String, berthEndPos.String, ETRow_Code, null); //14.06.2022 navds20 53760
		endif;
		
	endwhile;
	
epilog
	delete iter;		// PAR #26678
		
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
