    <JadeMethod name="createTALocationsAudits_Length" id="ce7626e7-3abc-496c-9966-6bd63bad1135">
        <source>createTALocationsAudits_Length(_proxy : SelfType; _ta :CM_TerminalArea) protected;
// ---------------------------------------------------------------------------
// Created:     03 March 2011 by cnwcs5 CCMS CPL 2027 / PAR 27126
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	adds, deletes 	:IntegerArray;
	int				:Integer;
begin
	create adds transient;
	create deletes transient;
	
	// first work out what is being changed
	if self.is20ft &lt;&gt; _proxy.is20ft then
		if _proxy.is20ft then
			adds.add (20);
		else
			deletes.add (20);
		endif;
	endif;
	if self.is30ft &lt;&gt; _proxy.is30ft then
		if _proxy.is30ft then
			adds.add (30);
		else
			deletes.add (30);
		endif;
	endif;
	if self.is40ft &lt;&gt; _proxy.is40ft then
		if _proxy.is40ft then
			adds.add (40);
		else
			deletes.add (40);
		endif;
	endif;
	if self.is45ft &lt;&gt; _proxy.is45ft then
		if _proxy.is45ft then
			adds.add (45);
		else
			deletes.add (45);
		endif;
	endif;
	if self.is53ft &lt;&gt; _proxy.is53ft then
		if _proxy.is53ft then
			adds.add (53);
		else
			deletes.add (53);
		endif;
	endif;
	// now create the audits
	foreach int in adds do 
		app.myUtilityCA.myCreateAuditAgent.audCreateTALocation (_ta, self, CM_AuditTALocations.LocnTypeUpdate_ContainerLength, AuditCreated, int.String);
	endforeach;
	
	foreach int in deletes do 
		app.myUtilityCA.myCreateAuditAgent.audCreateTALocation (_ta, self, CM_AuditTALocations.LocnTypeUpdate_ContainerLength, AuditDeleted, int.String);
	endforeach;

epilog
	delete adds;
	delete deletes;
end;</source>
        <access>protected</access>
        <Parameter name="_proxy" type="SelfType"/>
        <Parameter name="_ta" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="createYABlock" id="f475f510-e1ed-4751-944c-d8798a1d141b">
        <source>createYABlock(pIsTransient:Boolean):CM_YABlock protected;
