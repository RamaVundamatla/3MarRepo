    <JadeMethod name="addMyPersistentTI" id="2215f7ff-f281-4e31-af68-1a0f2cd5eeea">
        <updating/>
        <source>addMyPersistentTI(_value : CM_TrackedItem) updating;

begin
	_value.raiseExceptionIfTransient(method);

	if self.allPersistentTIs.includes(_value) then 
		return;
	endif;
	self.allPersistentTIs.add(_value);
end;</source>
        <Parameter name="_value" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="create" id="535a68ba-fc36-4c7a-b354-84752bfbb9b4">
        <updating/>
        <source>create() updating;
//--------------------------------------------------------------
//Created: 06 December 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	self.isAuditTextRequired := true;
	self.doValidateStops := true;
	self.validateDeliveryRelNo := true;
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="4e224702-5731-4ec0-8cd9-45e6cb092383">
        <source>delete();
/*
 ------------------------------------------------------------------------
Created:			01 August 2002 by cnwdwq1
Purpose:			Destructor called when object is deleted. Purges the transient TI's collection.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
begin
	self.allTransientTIs.purge;
end;</source>
    </JadeMethod>
    <JadeMethod name="isDocketCorrection" id="d7648c07-f9a3-4342-8338-a2a848b6ecd0">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>isDocketCorrection(set : Boolean; _value : Boolean io) mapping, updating;
// ---------------------------------------------------------------------------
// Created:     28 Feb 2008 by cnwvu1
// ---------------------------------------------------------------------------

vars

begin

	if set then
		self.isDocketCorrection := _value;
	else
		_value := self.isDocketCorrection;
	endif;

end;
</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="saveTIDataPriorUpdate" id="32266da7-b7db-4345-81ee-fa7bced2cf14">
        <updating/>
        <source>saveTIDataPriorUpdate(_trackedItem: CM_TrackedItem; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 27 September 2002 By: cnwgd1
//--------------------------------------------------------------
// 18 Mar 2010	cnwcs5	par 23159 - notifications affecting booking reconciliation
// 18 Mar 2010	cnwcs5  par 23239 - notifications affecting BOL reconciliation
vars
	tiAuditCntrl,
	subAuditCntrl	: CM_TIAuditController;

begin
	
	if _trackedItem = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null TI passed to method.');
		return;
	endif;
	
	self.myLocationFrom 		:= _trackedItem.getPrimaryLocation(REAL_MODE);
	self.myOperatorFrom 		:= _trackedItem.myOperator;
	self.myProductFrom			:= _trackedItem.myProduct;
	self.volume 				:= _trackedItem.getMyTotalVolume;
	//self.weight            		:= _trackedItem.weight;				//-cnwml2 MSL CCMS 1017
	self.weight            		:= _trackedItem.weight;				// cnwvu1 uncommented by #24378 16/06/2010. There was weight = 0 in stock movements
	//self.weight		:= _trackedItem.weightTare;							//+cnwml2 MSL CCMS 1017
	self.totalWeight			:= _trackedItem.totalWeight;
	self.quantity				:= _trackedItem.quantity;
	self.mySubTerminalFrom 		:= _trackedItem.mySubTerminal; 		//15/04/2009 cnwdz2ccms1735
	self.myBookingRefFrom		:= _trackedItem.myBookingRef;		// par 23159
	self.myBookingRefItemFrom	:= _trackedItem.myBookingRefItem;	// par 23259
	self.myReceivalBOLFrom		:= _trackedItem.myReceivalBOL;		// par 23239
	self.myBOLDtlFrom			:= _trackedItem.myBOLDtl;			// par 23239

	if self.isAuditTextRequired then
		tiAuditCntrl := _passport.getTIAuditController();
		
		// 18/05/2010 cnwar2 #18507
		if tiAuditCntrl.myTrackedItem &lt;&gt; null then	// nested update, store before values on sub controller
			if tiAuditCntrl.mySubAuditController &lt;&gt; null then
				delete tiAuditCntrl.mySubAuditController;
			endif;
			create subAuditCntrl transient;
			tiAuditCntrl.mySubAuditController := subAuditCntrl;
			
			tiAuditCntrl.mySubAuditController.setAuditAttributeValues(_trackedItem,true); //epr par 32291 8/1/14
			tiAuditCntrl.mySubAuditController.myTrackedItem := _trackedItem;
		else
			tiAuditCntrl.setAuditAttributeValues(_trackedItem,true); //epr par 32291 8/1/14
			tiAuditCntrl.myTrackedItem := _trackedItem;
		endif;
		//tiAuditCntrl.setBeforeValues(_trackedItem);
	endif;

end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setInterfaceAttributes" id="ae25e59e-9636-48db-8d4f-08dab28c0173">
        <updating/>
        <source>setInterfaceAttributes(_ifObj: CMIF_Receival) updating;
//----------------------------------------------------------------
//	Created:	10 August 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.isReceivalPrenote	:= _ifObj.isFromPrenote;
	self.isEDI				:= _ifObj.isEDI;
end;</source>
        <Parameter name="_ifObj" type="CMIF_Receival"/>
    </JadeMethod>
    <JadeMethod name="setIsValidated" id="965050ea-e80b-4a53-80f1-d8e91f6b3134">
        <updating/>
        <source>setIsValidated( newValidation : Boolean ) updating;
// ---------------------------------------------------------------------------
// Created:     07 Feb 2001 by cnwDWQ1
//
// Purpose: Controls the update mechanism, if this is not set, then add/updates will fail    
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
begin
	self.isValidated := newValidation;
end;</source>
        <Parameter name="newValidation" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setMode" id="6e99dca3-0ccc-4ddc-aab4-b6c603cc9eed">
        <updating/>
        <source>setMode(pMode : Integer) updating;
// ---------------------------------------------------------------------------
// Created:     31 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if pMode &gt; TI_UPDMODE_MAX then 
		app.raiseCMException1(TI_UPDCONTROL_PARAM_ERROR, 'mode', null, null);
		return;
	endif;
	
	self.mode := pMode;

end;</source>
        <Parameter name="pMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setMyTransientTIs" id="e5c968fe-90b2-4dde-aa78-014b41a929df">
        <updating/>
        <source>setMyTransientTIs(_values: CM_TISet) updating;

begin
	self.allTransientTIs.purge;
	
	_values.copy(self.allTransientTIs);
end;</source>
        <Parameter name="_values" type="CM_TISet"/>
    </JadeMethod>
    <JadeMethod name="setMyUserObject" id="426d6c8f-8a9e-48ba-a767-fcbdb3f24caa">
        <updating/>
        <source>setMyUserObject(pUserObject : Object) updating;
// ---------------------------------------------------------------------------
// Created:     31 January 2001 by cnwrs2
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.myUserObject := pUserObject;

end;</source>
        <Parameter name="pUserObject" type="Object"/>
    </JadeMethod>
</Class>
