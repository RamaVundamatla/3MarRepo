    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invoice"/>
    <PrimAttribute name="releasingCompanyCode" id="2346c677-3172-4657-ad86-0f6cfe1d7a83">
        <length>5</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="canUpdateTransaction" id="f98557a5-0b20-4018-85ff-44319a324a6c">
