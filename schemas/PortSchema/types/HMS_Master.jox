    <JadeMethod name="dateCertificateExpires" id="f2f7ef11-457a-4d92-979f-000a59c60e3e">
        <methodInvocation>mapping</methodInvocation>
        <source>dateCertificateExpires(set: Boolean; _value: Date io) mapping;
//-----------------------------------------------------------------------
//	Created:	01 August 2006 Lorcan Bolster  (cnwlb1/lorcan)
//-----------------------------------------------------------------------
vars
	tempDate 				: Date;
	lastQualifyingMovement	: HMS_VoyageMovement;
	realMaster : HMS_Master;
begin

	if set then
//		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	_value := null;
	
	if dateCertified &lt;&gt; null then
		tempDate := dateCertified.addMonths (self.myHarbour.exemptMasterExpiryPeriod);
		if tempDate &gt; _value then
			_value := tempDate;
		endif;
		
		if self.isTransient then	//12 Apr 2012	NDL	Par 27296
			realMaster := self.pxyGetRealObject().HMS_Master;
			if realMaster &lt;&gt; null then
				lastQualifyingMovement := realMaster.getLastQualifyingMovement();
			endif;
		else
			lastQualifyingMovement := self.getLastQualifyingMovement();
		endif;
		
		if lastQualifyingMovement  &lt;&gt; null then
			tempDate := lastQualifyingMovement.occursOnDTNEW.Date.addMonths (self.myHarbour.exemptMasterExpiryPeriod);
			if tempDate &gt; _value then
				_value := tempDate;
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Date" usage="io"/>
    </JadeMethod>
