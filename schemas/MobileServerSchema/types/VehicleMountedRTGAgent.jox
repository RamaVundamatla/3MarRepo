    <JadeMethod name="loadRTTaskTableEntry" id="89d9e5a5-2a2d-4501-a362-dce699bbcd65">
        <source>loadRTTaskTableEntry(_rtEntry: CM_RTQueueEntry input; _table: Table input;_order : Integer) protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
26 October 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	type : String;
	vehicleId : String;
	containerId : String;
	locationId : String;
	time  : String;
	ostow : String;
	hazard: String;
	ti : CM_TrackedItem;
	job : CM_Job;
	row : JadeTableRow;
	index : Integer;
	wle : CM_WorkListEntry;
	tableLine : String;
	vvr : CM_VehicleVisitRecord;
	rtTask,relatedTask : CM_RTQueueTask;
	lc,
	targetLocation : CM_LocationsController;
	imvTwinPosition : String;
	imvTwinFlag  : Integer;
begin
	
	job:=_rtEntry.myJob;
	wle:=_rtEntry.myWorkListEntry;
	rtTask:=_rtEntry.allTasks.first;
	if wle &lt;&gt; null then

		ti:=wle.myTrackedItem;
		if ti = null then
			return;
		endif;
		
		type:=job.getJobTypeForWLE(wle);
		if job.isKindOf(CM_RoadJob) then
			vvr:=job.CM_RoadJob.myVehicleVisit;
			vehicleId:=job.CM_RoadJob.myVehicle.regNumber;
			if vvr &lt;&gt; null then
				time := vvr.getElapsedTime().asStringJMT();		// PAR 16390
			endif;
		else
			
			relatedTask:=_rtEntry.getPreviousEntryFirstTask;
			if relatedTask = null then
				relatedTask:=_rtEntry.getNextEntryFirstTask;
			endif;
			if relatedTask &lt;&gt; null then
				// IMV Position epr par 20701 3/11/09
				if relatedTask.taskType = TASK_MOVE then
					imvTwinFlag:=relatedTask.myEntry.getTwinCarryFlag(); 
					if imvTwinFlag = CM_RTQueueEntry.TWIN_NEXT or 
						imvTwinFlag = CM_RTQueueEntry.TWIN_PREV then
						
						targetLocation:= wle.getTargetLocation();
						if targetLocation &lt;&gt; null and 
							targetLocation.isKindOf(CM_SlotController) then
							if targetLocation.CM_SlotController.myBayVoyage.isAftBay then
								imvTwinPosition:=app.getErrorString(CM_Aft);
							else
								imvTwinPosition:=app.getErrorString(CM_Fwd);
							endif;
						endif;
					endif;
				endif;
				if relatedTask.machine &lt;&gt; null then
					vehicleId:=relatedTask.machine.code;
				endif;
				
				// IMV Position epr par 20701 3/11/09
				if vehicleId &lt;&gt; null then
					vehicleId:=vehicleId;
					if imvTwinPosition &lt;&gt; null then
						vehicleId:=vehicleId	&amp; "-" &amp; imvTwinPosition;
					endif;
				else
					vehicleId:=imvTwinPosition;
				endif;
			endif;
			
			time := self.getElapsedTimeInMins(rtTask);
			
		endif;
		
		
		lc:= ti.getPrimaryLocation(REAL_MODE);
		
		if lc.isInRTGArea then
		//display where it is
			locationId:=ti.getPrimaryLocationId(REAL_MODE);
		else
		//display where it is going
			locationId:=ti.getPrimaryLocationId(QUEUE_MODE);
		endif;
		containerId:=null;
		
		ostow:=null;
		hazard:=null;
		if ti &lt;&gt; null then
			containerId:=ti.id;
			ostow:=ti.isOverStowed(REAL_MODE).getYesNo;
			hazard:=ti.isHazardous.getYesNo;
		endif;	
	endif;
	
	tableLine:=type &amp; Tab &amp; vehicleId &amp; Tab &amp; containerId &amp; Tab &amp; locationId &amp; Tab &amp;  time  &amp; Tab &amp;  ostow &amp; Tab &amp; hazard &amp; Tab &amp; _order.String;
	index:=_table.addItem(tableLine);
	row:=_table.accessRow(index);
	if row &lt;&gt; null then
		row.itemObject:=_rtEntry;
	endif;


epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rtEntry" type="CM_RTQueueEntry" usage="input"/>
        <Parameter name="_table" type="Table" usage="input"/>
        <Parameter name="_order" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="processTelegram" id="197e3ed0-d6a4-47b3-8e15-c03e35e6545b">
        <updating/>
        <source>processTelegram(_rtgTelegram : CM_RTGTelegram input) updating;
/*

Purpose:			


Return Value:		


Date		Who		Reason
28 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars
	info		: DTO_VehicleMountedInfo;
	theEvent	 : Integer;
	telegramLC, taskLC : CM_LocationsController;
	rtQueueTask, theRTQueueTask : CM_RTQueueTask;
	rtQueueEntry : CM_RTQueueEntry;
	allRTTasksInTelegramLoc : CM_RTQueueTaskArray;
	workingTI  : CM_TrackedItem;
begin
	self.initialiseForNewRequest(null);  //cnwjo3 par 24636
	
	if _rtgTelegram = null then
		return;
	endif;
	self.writeLog(method.name &amp; " " &amp; rtgState.String);	
	if self.myMachine &lt;&gt; _rtgTelegram.myMachine then
		self.writeLog(method.name &amp; " - rtgTelegram's machine is not for this device's machine");
		return;
	endif;

	if 	self.rtgState = IDLE then
		self.writeLog(method.name &amp; " - rtg is not working not expecting telegram to process");
		return;
	endif;
		
	//if we are picking up when we get twistlock info should be closed 
	if self.rtgState = PICKINGUP then
		// check that the rtgtelegram twistlock info is closed
		if not _rtgTelegram.isTwistLockClosed then
			self.writeLog(method.name &amp; " - rtg is picking up expecting twistlock info to be C however it is " &amp; _rtgTelegram.twistlock &amp; " State is " &amp; rtgState.String);
			return;
		endif;
		
		//if it was overstowed then the gui stuff will have been done and been acccepted need to now make sure start reading for the open
		self.setRTGState(SETTINGDOWN);
	
	
		theRTQueueTask:=self.getRTTaskFromTelegram(_rtgTelegram);
		
		if theRTQueueTask &lt;&gt; null then
			rtQueueEntry:=theRTQueueTask.myEntry;
			self.writeLog("event obj = " &amp; rtQueueEntry.id);
		else
			self.writeLog("event obj = null");
		endif;
		
			self.writeLog("sending note");
			//tell gui agent to do doAcceptTask 
			theEvent:=EVENT_TWISTLOCK_CLOSED;
			create info transient;
			info.event := theEvent;
			info.eventObject:=rtQueueEntry;
			self.causeEvent(self.Event_Server_Note, true, info);
	
		
		return;
	endif;
	
	//if we are setting down when we get twistlock info should be open 
	if self.rtgState = SETTINGDOWN then
		if _rtgTelegram.myMachine &lt;&gt; null then
			telegramLC:= _rtgTelegram.getLocationController(_rtgTelegram.myMachine);
			if telegramLC &lt;&gt; null then
				if telegramLC.isKindOf(CM_RTGLaneController) and self.myWorkedVehicleMachine = null then
					self.writeLog(method.name &amp; " setting down in rtg lane but worked machine is null");
					return;
				endif;
			else
				self.writeLog(method.name &amp; " telegrams location is null");
				return;
			endif;
		else
			self.writeLog(method.name &amp; " telegrams machine is null");
		endif;
	
	
		// check that the rtgtelegram twistlock info is open
		if not _rtgTelegram.isTwistLockOpen then
			self.writeLog(method.name &amp; " - rtg is setting down expecting twistlock info to be 0 however it is " &amp; _rtgTelegram.twistlock);
			//start reading again for O
			return;
		endif;
			
		if self.overstowTI &lt;&gt; null then
			workingTI:=self.overstowTI;
		else
			workingTI:=self.getCurrentTaskTI();
		endif;
		app.myTrxUA.trxUpdateMachineWeighContainer(self.myMachine,workingTI,_rtgTelegram.weight.Integer,false,app.myPassport);
		//have to figure out how to push out the Weight ERROR MESSAGES AT THIS STAGE
		app.myPassport.createAlertsFromErrors(EVENT_AT_RTGAlert,workingTI);
		app.myPassport.clearErrorsWarnings;	
		
		//tell gui agent that we have somewhere to put it
		create info transient;
		info.event := EVENT_TWISTLOCK_OPENED;
		info.eventMessage := _rtgTelegram.location;
		self.causeEvent(self.Event_Server_Note, true, info);
		
		return;
	endif;

epilog
	
end;</source>
        <Parameter name="_rtgTelegram" type="CM_RTGTelegram" usage="input"/>
    </JadeMethod>
    <JadeMethod name="resetNotes" id="f4a282a3-50f5-4564-be02-8cc4710b208e">
        <source>resetNotes() protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
27 November 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	inheritMethod();
	self.beginNotification(self.myMachine,self.myTerminal.getTerminalEvent(Event_RFIDTagRead),Response_Continuous,0);
	self.beginNotification(self.myRfidReaderConnection,Event_RFIDInfo,Response_Continuous,null);
	self.beginNotification(self.myMachine, EVENT_TWISTLOCK_RESPONSE  ,Response_Continuous , null);	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="resetNotesForQueue" id="55a33516-cdba-4a79-8ea0-8a94160bc7bd">
        <source>resetNotesForQueue(_rtQueue: CM_RadioTelemetryQueue input): Boolean protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
02 August 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	eventAdd :Integer;
begin

	if  not inheritMethod(_rtQueue) then
		return false;
	else
		eventAdd	:= self.myTerminal.getTerminalEvent(Event_New_Queue_Entry);
		self.beginNotification(_rtQueue, eventAdd, Response_Continuous, 0);
	endif;

	return true;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rtQueue" type="CM_RadioTelemetryQueue" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
