    </JadeMethod>
    <JadeMethod name="validateForDelete" id="e806b430-ccba-43ac-8ebf-38358a4e9814">
        <source>validateForDelete();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions

*/

vars

begin
	if self.allInstructionsIssued.isNotEmpty then
		app.raiseCMException1(Cannot_delete_instuct_type, self.code, null, null);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="6d41b950-5ceb-45a4-8d75-d02ff8a43fea">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
*/

vars
	realInstructionType,
	existingInstructionType			: CM_InstructionType;
begin
	if self.code = null then
		app.raiseCMException(Input_required_field_code, ETRow_Code, self);
	endif;
	
	if self.description = null then
		app.raiseCMException(Input_required_field_desc, ETRow_Description, self); 
	endif;
	
	existingInstructionType	:= self.myTerminal.allInstructionTypes[self.code];
	realInstructionType		:= self.pxyGetRealObject();
	
	if existingInstructionType &lt;&gt; null and
	   (realInstructionType = null or //in which case we are trying add a new one that is duplicate
	   realInstructionType &lt;&gt; existingInstructionType) //in which case we are trying update one to be same as another
	   then
		app.raiseCMException1(Instru_type_code_alread_exist, self.code.String, null, null); 
	endif;
epilog

end;</source>
    </JadeMethod>
</Class>
