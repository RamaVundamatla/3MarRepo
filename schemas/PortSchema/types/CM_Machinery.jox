vars

begin
	return 	app.myRoot.allISOTypes[self.isoType];

end;</source>
        <ReturnType type="CM_ISOType"/>
    </JadeMethod>
    <JadeMethod name="getMeasurementStringForAttrib" id="32812912-ce35-4bf9-8804-07cb62e4685b">
        <source>getMeasurementStringForAttrib(_attrName: String; _measureType: String; _short: Boolean): String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/04/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars

begin
	if _attrName = ETRow_OverHeight or
		_attrName = ETRow_OverLengthBack or
		_attrName = ETRow_OverLengthFront or
		_attrName = ETRow_OverWidthLeft or
		_attrName = ETRow_OverWidthRight then
		return null;
	endif;
	
	return inheritMethod(_attrName, _measureType, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_measureType" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isDifferentForBayPlanMerge" id="008c6f86-d181-4a50-ab30-7abaf349e907">
        <source>isDifferentForBayPlanMerge(_toTI : CM_Machinery): Boolean;
//----------------------------------------------------------------
//	Created:	14 February 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if self.isoType &lt;&gt; _toTI.isoType then
		return true;
	else
		return inheritMethod(_toTI);
	endif;
end;</source>
        <Parameter name="_toTI" type="CM_Machinery"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
