    <JadeMethod name="setInvoiceSplitDetailsFrom" id="47000301-2124-4b58-ad3c-dae5d56fa2af">
        <updating/>
        <source>setInvoiceSplitDetailsFrom( pSourceInvoice : CM_Invoice ) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 Decemeber 2012	cnwndl1	Initial creation	Par 30685

*/
vars

begin

	// basic clone of original data, but leave the new sequence number alone,
	// and leave any collections.
	
	self.bank					:= pSourceInvoice.bank;
	self.debtor					:= pSourceInvoice.debtor;
	self.debtorReference		:= pSourceInvoice.debtorReference;
	self.decfinBatchDate		:= pSourceInvoice.decfinBatchDate;
	self.decfinEntityCode		:= pSourceInvoice.decfinEntityCode;	
	self.decfinGLPeroid			:= pSourceInvoice.decfinGLPeroid;
	self.decfinGLYear			:= pSourceInvoice.decfinGLYear;
	self.decfinLedgerCode		:= pSourceInvoice.decfinLedgerCode;
	self.exportCurrencyCode		:= pSourceInvoice.exportCurrencyCode;
	self.exportCurrencyRate		:= pSourceInvoice.exportCurrencyRate;
	self.exportedCount			:= pSourceInvoice.exportedCount;
	self.fromDT					:= pSourceInvoice.fromDT;
	self.invoiceType			:= pSourceInvoice.invoiceType;
	self.isManual				:= pSourceInvoice.isManual;
	self.isZeroRatedTax			:= pSourceInvoice.isZeroRatedTax;
	self.myTrackedItem			:= pSourceInvoice.myTrackedItem;
	self.myVoyage				:= pSourceInvoice.myVoyage;
	self.narration				:= pSourceInvoice.narration;
	self.purchaseOrderNumber	:= pSourceInvoice.purchaseOrderNumber;
	//self.status					:= pSourceInvoice.status;
	self.setStatus( pSourceInvoice.status );	//13 Jun 2018	NDL	TFS 39197
	self.termsOfTrade			:= pSourceInvoice.termsOfTrade;
	self.termsOfTradeCode		:= pSourceInvoice.termsOfTradeCode;
	self.toDT					:= pSourceInvoice.toDT;
	self.vesselName				:= pSourceInvoice.vesselName;
	self.setMyInvoiceProcess( pSourceInvoice.getMyInvoiceProcess ); // TFS 39618


epilog

end;
</source>
        <Parameter name="pSourceInvoice" type="CM_Invoice"/>
    </JadeMethod>
