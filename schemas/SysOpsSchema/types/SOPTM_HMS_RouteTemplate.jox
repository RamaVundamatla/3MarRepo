    <JadeMethod name="initShtMultiSelect" id="31630b03-9855-4d2a-8adb-31b3413c598b">
        <source>initShtMultiSelect();
/*
----------   ----------  --------------------------------------------------
Created:	20 October 2006 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	theForm	: SOP_HMS_TableMaintForm;
begin
	theForm := self.myForm.SOP_HMS_TableMaintForm;
	inheritMethod();

	theForm.shtPathSegments.visible := true;
	theForm.shtPathSegments.caption := 'Waypoints';
	theForm.lblStartRoute.caption := 'Waypoints';
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="698ef376-98bf-4d90-85ae-717f42a09646">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:     30 October 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theForm		: SOP_HMS_TableMaintForm;
begin
	inheritMethod();
	
	theForm := self.myForm.SOP_HMS_TableMaintForm;

	theForm.tblRoute.userInputEnabled := true;

	if theForm.mode = theForm.Mode_Add then
		theForm.tblRoute.rows := theForm.tblRoute.fixedRows;
		
		// add 2 blank rows so the auto-insert works ok
		// need to do like this to ensure row object is set to null
		theForm.tblRoute.addItemObject(null, '');
		theForm.tblRoute.addItemObject(null, '');
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="56956891-df47-45e1-b131-5c64bcde5ac8">
