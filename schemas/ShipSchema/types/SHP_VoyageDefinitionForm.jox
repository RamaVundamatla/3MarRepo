    <JadeMethod name="doQueryUnload" id="56d2a01b-b234-4251-95e8-3758371707ef">
        <updating/>
        <source>doQueryUnload(cancel: Integer io; reason: Integer) updating, protected;
//--------------------------------------------------
// Created:	07 April 2005 By: cnwgd1
//--------------------------------------------------
constants
	CANCEL_UNLOAD	: Integer = 1;
	
vars
	userResponse	: Integer;
	
begin
	if (self.mode = self.Mode_Add or self.mode = self.Mode_Update)
	and self.isFormChanged
	then
		if reason = Form.QueryUnload_User 
		or reason = Form.QueryUnload_UnloadMethod
		or reason = Form.QueryUnload_MdiChild
		then
			userResponse	:=	app.msgBox(app.getErrorString(EditChangedAndClosing), self.caption &amp; " Window Closing !", MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
			
			if userResponse = MsgBox_Return_No then
				cancel := CANCEL_UNLOAD;	//Do not close form
			endif;			
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="cancel" type="Integer" usage="io"/>
        <Parameter name="reason" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doQueueOnsiteExpMAFIToVoyage" id="8b862c53-e8c6-422f-a288-bf7e951dea6c">
        <updating/>
        <source>doQueueOnsiteExpMAFIToVoyage() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 September 2022	jlizm1	Initial creation TFS 54702 CUX MAFI Auto Queueing

*/

vars
	realVoyage 	: CM_Voyage;
	result 		: Integer;
	
begin
	
	realVoyage := self.myCurrentVoyage;
	if realVoyage = null then
		return;
	endif;
	
	while true do
		app.myTrxUA.trxQueueOnsiteMAFIsToVoyage(realVoyage, app.myPassport);
		
		if app.myPassport.trxCompletedOK() then
			// Clear errors/warnings from form and err/warnings window.
			self.clearErrorWarnings();
			break;
		else
			result	:=	app.showErrorWarningDialog(app.getErrorString(Move), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			
			if app.myPassport.noErrors() and result = IDOK then
				// There must have just been warnings that the user has acknowledged so...
				app.myPassport.warningsAcknowledged	:=	true;
				continue;
			endif;
			
			self.setAllErrorWarnings(app.myPassport);	// Copies errors to this form and shows in err/warnings window.
		endif;
		
		break;
	endwhile;
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doQueueOnsiteGroundExpROROCont" id="a6c10447-dc8f-4dfb-9cb2-1afb58bdab53">
        <source>doQueueOnsiteGroundExpROROCont();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
29 September 2022	jlizm1	Initial creation TFS 54702 CUX MAFI Auto Queueing

*/

vars
	params : CMIF_AutoplanParams;
	tiset : CM_TISet;
	result : Integer;
	str	: String;
	
begin
		create params transient;
		create tiset transient;
		
		params.moveMode := QUEUE_MODE;
		params.showWarningWhenNoPlan := true;
		self.myCurrentVoyage.getGroundPlacedExpROROConts(tiset);
		tiset.copy(params.allTrackedItems);
		
		while true do
			str := app.myTrxUA.trxUpdateAutoplanTrackedItems(params, app.myPassport);
			if app.myPassport.trxCompletedOK then
				break;
			else
				result := app.showErrorWarningDialog(app.getErrorString(Move), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
					result = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			break;
		endwhile;	

epilog

	delete params;
	delete tiset;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doRampAdd" id="842c1ad8-0740-4ca4-b105-6837db7b75b8">
        <source>doRampAdd() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin

	if self.myCurrentVoyage = null then
		return;
	endif;
	
	if self.myCurrentVoyage.myStructuralElements = null then
		return;
	endif;
	
	self.myAssistant.SHP_Assistant.showVesselRampForm(self.myCurrentVoyage.myStructuralElements,null,SHP_ParentChildForm.Mode_New);
epilog


end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRampDelete" id="95906f8e-dcc7-4b29-adbf-5da25d9d439a">
        <source>doRampDelete() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	result : Integer;
	deckItem : CM_DeckItem;
begin

	if self.tblExtRamps.accessRow(self.tblExtRamps.row) = null then
		return;
	endif;
	deckItem:=self.tblExtRamps.accessRow(self.tblExtRamps.row).itemObject.CM_DeckItem;

	if deckItem = null then
		return;
	endif;
	if app.msgBox(app.getErrorString2(ConfirmDelete,app.getErrorString(Voyage_external_ramp),deckItem.code.String),app.getErrorString(Warning), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) &lt;&gt;  MsgBox_Return_Yes then
		return;
	endif;

	while true do
	
		app.myTrxDA.trxDeleteRORODeckItem(deckItem,app.myPassport);
	
		if app.myPassport.trxCompletedOK then		
			break;
		else
			result := app.showErrorWarningDialog(app.getErrorString(Voyage_external_ramp), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
	
		break;
	endwhile;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRampEdit" id="c25ecd38-8b46-4b2a-a3b5-d7e60cd56758">
        <source>doRampEdit() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	roroStructure  : CM_VoyageStructuralElements;
	ramp : CM_RORORampExternal;
begin
	if self.myCurrentVoyage = null then
		return;
	endif;
	
	roroStructure:= self.myCurrentVoyage.myStructuralElements;
	if roroStructure = null then
		return;
	endif;
	
	// PAR 27469
	if self.tblExtRamps.row &lt;= self.tblExtRamps.fixedRows then
		return;
	endif;
	
	if self.tblExtRamps.accessRow(self.tblExtRamps.row) = null then
		return;
	endif;
	ramp:=self.tblExtRamps.accessRow(self.tblExtRamps.row).itemObject.CM_RORORampExternal;

	
	self.myAssistant.SHP_Assistant.showVesselRampForm(roroStructure,ramp,SHP_ParentChildForm.Mode_Edit);


epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
