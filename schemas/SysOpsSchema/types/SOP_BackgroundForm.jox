    <JadeMethod name="doDumpStatsClick" id="c414ee8a-e0fc-4fc1-96b2-62b946ed802c">
        <updating/>
        <source>doDumpStatsClick(menuItem: MenuItem input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
17 September 2025		navmd1	Initial creation MTN-36066

*/

vars
	inputBox			: CMUI_InputBox;
	maxProcs			: Integer;
	start, idx			: Integer;
	menu, item			: MenuItem;
	includeCompleted	: Boolean;
begin
	create inputBox transient;
	inputBox.init("Max Processes", "Maximum Transactions per Process to dump stats for", "100", 4, TextBox.DataType_Numeric, TextBox.Case_None, false, false);
	inputBox.showModal();
	if inputBox.modalResult &lt;&gt; IDOK then
		return;
	endif;
	
	// The assumption here is that the dumpstats menu options are at the bottom of the list
	menu := self.mnuBackground;
	start := self.menuItemCount;
	foreach idx in start to 1 step -1 do
		item := menu.getMenuItem(idx);
		if item = null then
			// Reached the end of the dynamically generated menus, so bail
			break;
		endif;
		
		if item.caption = SOP_BackgroundForm.MenuCaption_IncludeTrx then
			includeCompleted := item.checked;
		endif;
	endforeach;
	
	maxProcs := inputBox.txtInput.text.Integer;
	system.causeEvent(LockKeeper_DumpStats_Event, true, maxProcs.String &amp; "^" &amp; includeCompleted.String);
	
	app.msgBox("Dump Status log being generated. Look for " &amp; CM_LockKeeperAgent.name &amp; "_DumpStats_&lt;date&gt;.log on the server", "Generating...", MsgBox_OK_Only);
	
epilog
	delete inputBox;
end;</source>
        <access>protected</access>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doEdit" id="870dc7f9-5c77-4a90-b00c-a60f41ff14e5">
        <updating/>
        <source>doEdit(_isEditView : Boolean) protected, updating;

// cnwdvb1 25 October 2002 

vars

begin

		
		
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;
		
	if global.isValidObject(self.myBGPObject) then
		if _isEditView then
			self.mode := Mode_EditView;
		else
			self.mode := Mode_Edit;
		endif;
		if self.myBGPObject.isManager() then
			if self.doLoadEditForm(true) then
				self.doDisplay();
			endif;
		else
			if not _isEditView and self.myBGPObject.isRunning then
				app.msgBox(app.getErrorString(Controller_Must_Not_Be_Running),app.getErrorString(Edit_Controller),MsgBox_OK_Only + MsgBox_Information_Icon);
				return;
			endif;
			
			if self.doLoadEditForm(false) then
				self.doDisplay();
			endif;
		endif;
		
		self.doStartStopButtons();
	endif;
epilog
	self.mode := Mode_View;
end;</source>
        <access>protected</access>
        <Parameter name="_isEditView" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLoadEditForm" id="e874da2a-999e-48f0-aa2e-08cca0d43295">
        <updating/>
        <source>doLoadEditForm(_isManager : Boolean) : Boolean protected, updating;
// -------------------------------------------
// Created 09 September 2003 by cnwdvb1
// -------------------------------------------
vars
	attachFrm2		: SOP_BackgroundEditForm2;
begin
	app.mousePointer	:=	self.MousePointer_Default;

	

	attachFrm2	:=	app.loadForm(SOP_BackgroundEditForm2, self.myAssistant.class, false, false, false, self.myTerminal, null).SOP_BackgroundEditForm2;
	
	if attachFrm2 = null then
		return false;
	endif;
	
	attachFrm2.initObjects(self.myBGPObject, self.mode, _isManager);
	
	if attachFrm2.showModal() = MsgBox_Return_OK then
		return true;
	endif;
	
	
	return false;
epilog
	delete attachFrm2;
	
	self.mode	:=	Mode_View;
end;</source>
        <access>protected</access>
        <Parameter name="_isManager" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLoadFutureActorsTable" id="0ac1b1a2-3753-4d49-9467-bd3ba7b30589">
        <updating/>
        <source>doLoadFutureActorsTable(_controller : BGP_Controller)  updating,protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29/11/2016	cnwma1	Initial creation
09/04/2018	jlgdap1	TFS 37858 PEL1 Invoice Status Advancement
11/09/2018	jlgdap1	TFS 40202 PEL1 Estimation SAP Integration
28 May 2024 navbs1 Defect 64264: EUP - BGP Future Storage with over 32000 rows
*/

vars
	iter		: Iterator;
	displayStr : String;
	objectArray : ObjectArray;
	obj 		: Object;
	offlineActor : CM_OfflineFutureActor;
	invalidActor : Boolean;
begin

	
	on Exception do _controller.xHandlerDisplay(exception);
	self.tblRequest.rows := 1;
	
	if  _controller.isKindOf(BGP_FutureTimerController) then

		create objectArray transient;
		CM_OfflineFutureActor.allInstances(objectArray,null,true);
		
		on Exception do app.handleDeletedObject(exception,offlineActor,invalidActor);
		//jlier1 22/5/23 refactored to removed repeated code
		iter := objectArray.createIterator;
		while iter.next(obj) do
			offlineActor:=obj.CM_OfflineFutureActor;
			//epr TFS 4474 1/6/17 
			displayStr:=offlineActor.getDisplay();
			if invalidActor then
				invalidActor:=false;
				continue;			
			endif;
			if displayStr = null then
				continue;
			endif;
			if self.tblRequest.rows &gt;= JadeTableRowLimit then						//28.05.2024 navbs1 #64264
				app.msgBox('Maximum number of entries in table exceeded. Only the first ' &amp; 
						JadeTableRowLimit.String &amp; ' will be shown', 'Error', MsgBox_OK_Only);
				break;
			endif;
			self.tblRequest.addItemObject(offlineActor,displayStr);
			
		endwhile;
		
		if self.selectedRequestRow &gt; 0 and self.selectedRequestRow &lt;= self.tblRequest.rows then
			self.selectRequest(self.selectedRequestRow, false);
		endif;
	endif;
	
	
	
	
epilog
	delete iter;
	delete objectArray;
end;</source>
        <access>protected</access>
        <Parameter name="_controller" type="BGP_Controller"/>
    </JadeMethod>
    <JadeMethod name="doLoadMessageForm" id="dc3fdaaf-1f96-4a83-8943-a88ae5360109">
        <updating/>
        <source>doLoadMessageForm() : Boolean protected, updating;
// -------------------------------------------
// Created 09 September 2003 by cnwdvb1
// -------------------------------------------
vars

	attachFrm 		: SOP_SendMsgForm;
	sender			: String;
	
begin

	app.mousePointer := MousePointer_Default;
				
	attachFrm := app.loadForm(SOP_SendMsgForm, self.myAssistant.class, false, false, false, self.myTerminal, null).SOP_SendMsgForm;

	if attachFrm = null then
		return false;
	endif;
	
	if attachFrm.showModal = MsgBox_Return_OK then
		return true;
	endif;
	
	return false;
epilog
	if attachFrm &lt;&gt; null then
		delete attachFrm;
	endif;
	self.mode := Mode_View;
	
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doLoadReqTableDeferred" id="d73cafcc-f2a6-4d81-a7a9-a10b72a4268c">
        <updating/>
        <source>doLoadReqTableDeferred( _controller : BGP_DeferredChargingController )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
08 July 2021	navndl1	Initial creation	TFS 51443
19 June 2024	navpw1	TFS: 64382 (64383) - Fixed 14051 Invalid Table Row Exception caused by exceeding the JadeTableRowLimit

*/

vars
	request	: BGP_Request;
	iter	: Iterator;
	row		: JadeTableRow;
	displayStr : String;
	invalid : Boolean;
	edition : Integer;
begin

	on Exception do _controller.xHandlerDisplay(exception);
	
	if _controller.myDeferredChargesRoot = null then
		return;
	endif;
	
	iter := _controller.myDeferredChargesRoot.allNewDeferredReqs.createIterator;
	while iter.next(request) do
		if not global.isValidObject(request) then
			continue;
		endif;
		
		if self.tblRequest.rows &gt;= JadeTableRowLimit then
			app.msgBox('Maximum number of entries in table exceeded. Only the first ' &amp; 
				JadeTableRowLimit.String &amp; ' will be shown', 'Error', MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		
		row := self.tblRequest.accessRow(self.tblRequest.addItem(request.getDisplay));
		//self.tblRequest.accessedRow.backColor := self.ColourYellowLight;		// TFS 51086 navmd1 15/09/2021 JADE2020 Skin Fixes
		if row &lt;&gt; null then
			row.itemObject := request;
		endif;
	endwhile;
	delete iter;
	
	iter := _controller.myDeferredChargesRoot.allRequestsToRetry.createIterator;
	while iter.next(request) do
		if not global.isValidObject(request) then
			continue;
		endif;
		
		if self.tblRequest.rows &gt;= JadeTableRowLimit then
			app.msgBox('Maximum number of entries in table exceeded. Only the first ' &amp; 
				JadeTableRowLimit.String &amp; ' will be shown', 'Error', MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		
		row := self.tblRequest.accessRow(self.tblRequest.addItem(request.getDisplay));
		//self.tblRequest.accessedRow.backColor := self.ColourYellowLight;		// TFS 51086 navmd1 15/09/2021 JADE2020 Skin Fixes
		if row &lt;&gt; null then
			row.itemObject := request;
		endif;
	endwhile;
	delete iter;

	
	on Exception do app.handleDeletedObject( exception, request, invalid ); // ### TFS BUG 64513 20AUG2024 NAVAB1
	
	iter := _controller.myDeferredChargesRoot.allRequestsBeingActioned.createIterator;
	while iter.next(request) do
		if not global.isValidObject(request) then
			continue;
		endif;
		
		if self.tblRequest.rows &gt;= JadeTableRowLimit then
			app.msgBox('Maximum number of entries in table exceeded. Only the first ' &amp; 
				JadeTableRowLimit.String &amp; ' will be shown', 'Error', MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
		endif;

		// ### TFS BUG 64513 20AUG2024 NAVAB1
		edition := request.edition;
		
		if invalid then
			continue;
		endif;
		
		displayStr := request.getDisplay();
		if invalid
		or displayStr = null
		or displayStr[1:23] = "Request will be deleted" then
			continue;
		endif;
		
		row := self.tblRequest.accessRow(self.tblRequest.addItem(displayStr));
		if row &lt;&gt; null then
			row.itemObject := request;
		endif;
	endwhile;
	delete iter;
	
epilog
	delete iter;
	
end;</source>
        <Parameter name="_controller" type="BGP_DeferredChargingController"/>
    </JadeMethod>
    <JadeMethod name="doLoadRequestTable" id="b24c709a-3902-48d6-bbf3-aa36b2bc612a">
        <updating/>
        <source>doLoadRequestTable(_controller : BGP_Controller) protected, updating;

// cnwdvb1 17 February 2003 
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 19/07/2023	navcs2		Bug 58916: MTN - External Web Service API Endpoint issues
//01 Apr 2024   navbs1      Bug 62880: EUP - Invalid Table row Error at Background Application Screen
vars

	class 		: Class;
	request		: BGP_Request;
	iter		: Iterator;
	row			: JadeTableRow;
	className	: String;
	rowName	: String;
begin

	on Exception do _controller.xHandlerDisplay(exception);
	self.tblRequest.rows := 1;

	if _controller.isKindOf( BGP_DeferredChargingController ) then
		self.doLoadReqTableDeferred( _controller.BGP_DeferredChargingController );
	else
		foreach className in _controller.allRequestClassesToProcess do
			class := _controller.getClass(className);
			if class = null then
				continue;
			endif;
			iter := class.instances.createIterator;
			while iter.next(request) do
				if not global.isValidObject(request) then
					continue;
				endif;
				//epr TFS 41229 29/10/18
				if _controller.getMyTerminal &lt;&gt; null and request.myTerminal &lt;&gt; null then
					if _controller.getMyTerminal &lt;&gt; request.myTerminal then
						continue;
					endif;
				endif;
				
				// 19/07/2023 navcs2 Bug 58916 Start
				if _controller.isKindOf( BGP_ExternalWSController) then
					if request.isKindOf(BGP_APIWSRequest) then
						rowName:=request.BGP_APIWSRequest.getEntRowForDataType();
						if _controller.BGP_ExternalWSController.myExternalWSDef.allEndpoints[rowName] = null then
							continue;
						endif;
					endif;
				endif;
				// 19/07/2023 navcs2 Bug 58916 End
				
				if self.tblRequest.rows &gt;= JadeTableRowLimit then						//01.04.2024 navbs1 #62880
					app.msgBox('Maximum number of entries in table exceeded. Only the first ' &amp; 
							JadeTableRowLimit.String &amp; ' will be shown', 'Error', MsgBox_OK_Only);
					break;
				endif;
				row := self.tblRequest.accessRow(self.tblRequest.addItem(request.getDisplay));
				//self.tblRequest.accessedRow.backColor := self.ColourYellowLight;		// TFS 51086 navmd1 15/09/2021 JADE2020 Skin Fixes
				if row &lt;&gt; null then
					row.itemObject := request;
				endif;

			endwhile;
			delete iter;
		endforeach;
	endif;
	if self.selectedRequestRow &gt; 0 and self.selectedRequestRow &lt;= self.tblRequest.rows then
		self.selectRequest(self.selectedRequestRow, false);
	endif;

epilog
	delete iter;
end;</source>
        <access>protected</access>
        <Parameter name="_controller" type="BGP_Controller"/>
    </JadeMethod>
    <JadeMethod name="doOpenAutoScheduler" id="5ed06cc9-e8e3-4916-b3bb-dd931c02504e">
        <source>doOpenAutoScheduler() protected;
// -------------------------------------------
// Created 02 February 2004 by cnwdvb1
