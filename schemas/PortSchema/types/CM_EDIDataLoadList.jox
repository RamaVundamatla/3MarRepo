    <JadeMethod name="processAttributeDependencies" id="f2bbde7d-d692-4cd4-903b-67e517050ddf">
        <updating/>
        <source>processAttributeDependencies(_ediUserDefinedAssist: CMIF_EDIUserDefinedAssist input; _strIdentifier: String; _reset: Boolean; _xlationOperator: CM_Operator) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
7  May 2025	navra1  //navra1 - MTN-34796 - 7th May 2025

*/

vars
	isAllLoadPortSame : Boolean;
	isAllDischPortSame : Boolean;
	ediTi : CM_EDITrackedItem;
	allEdiTis : CM_EDITIById;
	currentPortCode : String;
	commonLoadPort : String;
	commonDischargePort : String;
	first : Boolean;
	currPortCode : String;
	voyageCodeOnFile : String;								//navra1 - MTN-34854 - 13th May 2025
	terminal : CM_Terminal;									//navra1 - MTN-34854 - 13th May 2025
	voy : CM_Voyage;										//navra1 - MTN-34854 - 13th May 2025
	vessel : CM_Vessel;										//navra1 - MTN-34854 - 13th May 2025
	lloydsCode : String;									//navra1 - MTN-34854 - 13th May 2025
	tryVoy : CM_Voyage;										//navra1 - MTN-34854 - 13th May 2025
	voyageDetermined : CM_Voyage;							//navra1 - MTN-34854 - 13th May 2025	
	ediFile : CM_EDIFile;									//navra1 - MTN-34854 - 13th May 2025
	ediFileXlationOperator: CM_Operator;					//navra1 - MTN-34854 - 13th May 2025
	ediDataXlationOperator: CM_Operator;					//navra1 - MTN-34854 - 13th May 2025
	
begin
	inheritMethod(_ediUserDefinedAssist, _strIdentifier, _reset, _xlationOperator);
	
	//navra1 - MTN-34854 - 13th May 2025 - start
	voyageCodeOnFile := self.voyageCode;	
	terminal := app.myPassport.myTerminal;
	
	voy := terminal.allVoyagesByCode.getAtKeyGeq(voyageCodeOnFile, null);
	
	if voy = null or voy.code &lt;&gt; voyageCodeOnFile then
		if self.allEDITrackedItems &lt;&gt; null and self.allEDITrackedItems.size() &gt; 0 then
			allEdiTis := self.allEDITrackedItems;
			foreach ediTi in allEdiTis do
				if ediTi.isLoadListTI() then
					lloydsCode := ediTi.CM_EDILoadListTI.lloydsNumber;
					break;
				endif;
			endforeach;
			
			if lloydsCode &lt;&gt; null then
				vessel := app.myRoot.allVesselsByLloydsNumber[lloydsCode];
			endif;
			
			///
			if vessel &lt;&gt; null then
				// use the inwards code and external reference dictionaries to try to find a voyage with a matching vessel
				tryVoy := terminal.allVoyagesByInwardCodeAuto[voyageCodeOnFile, vessel.code];
				if tryVoy &lt;&gt; null then					
					voyageDetermined := tryVoy;
				else
					tryVoy := terminal.allVoyagesByInwardCode[voyageCodeOnFile];
					if tryVoy &lt;&gt; null then						
						voyageDetermined := tryVoy;
					endif;
				endif;
				// if we didn't find a match on inwards code, but the inwards code matches the voyage code,
				// this is a discharge (the inwards codes collections aren't populated if the inwards code matches the voyage code)
				if voy &lt;&gt; null and voy.inwardCodeAuto = voy.code and voyageDetermined = null then				
					voyageDetermined := voy;
				endif;
				
				// still not found? try external code
				if voyageDetermined = null then
					tryVoy := terminal.allVoyagesByExtCodeAuto[voyageCodeOnFile, vessel.code];
					if tryVoy &lt;&gt; null then						
						voyageDetermined := tryVoy;
					else
						tryVoy := terminal.allVoyagesByExternalCode[voyageCodeOnFile];
						if tryVoy &lt;&gt; null then							
							voyageDetermined := tryVoy;
						endif;
					endif;
				endif;
				// if we didn't find a match on external code, but the external code matches the voyage code,
				// this is a load (the external codes collections aren't populated if the external code matches the voyage code)
				if voy &lt;&gt; null and voy.voyageCodeExternalAuto = voy.code and voyageDetermined = null then					
					voyageDetermined := voy;
				endif;				
				
				// if we found a voyage, update the ediTI with the voyage code and the load list type
				if voyageDetermined &lt;&gt; null then //and voyageDetermined.isAutomaticProcess() then - should it only be for auto voyages? isnt this rule general?				
					
					ediDataXlationOperator := self.getXlationOperator();
					
					if self.myEDIFile &lt;&gt; null then				
						ediFile := self.myEDIFile;					
						ediFileXlationOperator := ediFile.myXlationOperator;
					endif;					
					
					foreach ediTi in allEdiTis do
						if ediTi.isLoadListTI() then							
							ediTi.setEDITIProperty(ETRow_VoyageCode, voyageDetermined.code, ediFile, null, ediFileXlationOperator, ediFileXlationOperator);
						endif;
					endforeach;
										
					self.setVoyageCode(voyageDetermined.code);					
					self.setVesselName(vessel.code);
					
				endif;
			else
				// didn't find a vessel? Oh well
			endif;	
			
		endif;
		
	endif;	
	
	//navra1 - MTN-34854 - 13th May 2025 - end	
	
	//navra1 - MTN-34796 - 7th May 2025 - start
	commonDischargePort := '-----';
	commonLoadPort := '-----';
	allEdiTis := self.allEDITrackedItems;
	
	//check load ports
	first := true;
	foreach ediTi in allEdiTis do		
		if ediTi.isLoadListTI() then		
			if first then
				first := false;
				isAllLoadPortSame := true;
				commonLoadPort := ediTi.CM_EDILoadListTI.loadPort;			//initialize commonLoadPort to the first one, not using commonLoadPort=null check to avoid the case where loadPort is empty on the first or more entries
				continue;
			endif;
			
			if commonLoadPort &lt;&gt; ediTi.CM_EDILoadListTI.loadPort then
				commonLoadPort := '-----';
				isAllLoadPortSame := false;
				break;
			endif;
		else
			commonLoadPort := '-----';
			isAllLoadPortSame := false;
			break;
		endif;
	endforeach;
	
	//check discharge ports
	first := true;
	foreach ediTi in allEdiTis do		
		if ediTi.isLoadListTI() then		
			if first then
				first := false;
				isAllDischPortSame := true;
				commonDischargePort := ediTi.CM_EDILoadListTI.dischargePort;			//initialize commonDischargePort to the first one, not using commonDischargePort=null check to avoid the case where dischargePort is empty on the first or more entries
				continue;
			endif;
			
			if commonDischargePort &lt;&gt; ediTi.CM_EDILoadListTI.dischargePort then
				commonDischargePort := '-----';
				isAllDischPortSame := false;
				break;
			endif;
		else
			commonDischargePort := '-----';
			isAllDischPortSame := false;
			break;
		endif;
	endforeach;
	
	currPortCode := app.myPassport.myTerminal.getConfig(PortDestCode).String.trimBlanks();
	if commonLoadPort &lt;&gt; commonDischargePort then
		if isAllLoadPortSame and commonLoadPort = currPortCode then					
			self.setListType('L');			
		elseif isAllDischPortSame and commonDischargePort = currPortCode then			
			self.setListType('D');			
		endif;
	endif;	
	//navra1 - MTN-34796 - 7th May 2025 - end
	
epilog	

end;</source>
        <Parameter name="_ediUserDefinedAssist" type="CMIF_EDIUserDefinedAssist" usage="input"/>
        <Parameter name="_strIdentifier" type="String"/>
        <Parameter name="_reset" type="Boolean"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="processTIs" id="6003c032-8466-490b-ac0e-3e86e9a06543">
        <updating/>
        <source>processTIs(_trackedItem: CM_TrackedItem; _type: Integer) updating;
//----------------------------------------------------------------
//	Created:	16 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 08 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	ediTI : CM_EDILoadListTI;
begin
	if _type = EDIFileType_CSVMSCLoad then
		create ediTI as CM_EDILoadListTIMSC;
	elseif _type = EDIFileType_CSVPONLoad then
		create ediTI as CM_EDILoadListTIPON;
	elseif _type = EDIFileType_CSVMSKLoad then
		create ediTI as CM_EDILoadListTIMSK;
	elseif _type = EDIFileType_LoadListTI then	//for development environment - creating Load List for LoadListComparison test
		create ediTI as CM_EDILoadListTI;
		//ediTI.setVoyageCode();
	elseif _type = EDIFileType_Coprar then //cnwrs1 Aug 2009 for development use creation of COPRAR from onsite data
		create ediTI as CM_EDILoadListTI;
	else
		return;
	endif;
	
	ediTI.setFromTI(_trackedItem);
	ediTI.setMyEDIData(self);
end;</source>
        <Parameter name="_trackedItem" type="CM_TrackedItem"/>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setControllerFromEDITIs" id="73a3cc85-18eb-4e9f-ac34-fef1870fc1c2">
        <source>setControllerFromEDITIs(_controller :CMIF_TranshipTIController input; _ediLoadListTI : CM_EDILoadListTI io; _realTI : CM_TrackedItem;
						updTranshipVoyageCode, updTranshipDischPort, updTranshipBookingRef, updTranshipBOLId, updTranshipPortsList : Boolean);
/*
	loading to the db from with bulk tis however the edi file may have different discharge ports per item (and i'm using the same controller that bulk updates
	the discharge port)	so when the discharge port changes submit previous group of tracked items then continue to the next until
	the discharge port changes again until we get to the end of file.
	Par 21809 - PHB - Export Voyage is now obtained from the individual TrackedItem lines, and so the same principle as above has been applied
*/

vars
	port : CM_Port;
	portCode : String;
begin
	_controller.clear();
	if _realTI &lt;&gt; null then //cnwrs1 22 mar 2010 par 23163
		if not _controller.allTrackedItems.includes(_realTI) then
			_controller.allTrackedItems.add(_realTI);
		endif;
	endif;
	if updTranshipDischPort then
		_controller.myExportDisPort := _ediLoadListTI.getTranshipDischargePort();
	endif;
	if updTranshipVoyageCode then
		_controller.myExportVoyage := self.getMyTerminal().lookupVoyage(_ediLoadListTI.getTranshipVoyageCode(), null, false);
	endif;
	if updTranshipPortsList then
		foreach portCode in _ediLoadListTI.transhipPortCodes do //cnwrs1 CCMS 1137 01 July 2010
			port := app.myRoot.allPorts[portCode];
			if port &lt;&gt; null then
				_controller.transhipToPorts.add(port); //cnwrs1 CCMS 1137 01 July 2010
			endif;
		endforeach;
	endif;
	if updTranshipBOLId then
		_controller.billOfLading := _ediLoadListTI.transhipBOLId; //cnwrs1 CCMS 1137 28 June 2010
	endif;
	if updTranshipBookingRef then
		_controller.bookingRef := _ediLoadListTI.transhipBookingRef; //cnwrs1 CCMS 1137 01 July 2010
	endif;
	// TFS 47222 jlgzm1 20/11/2019
	//_controller.removeStops := true; 		//+cnwml2 PAR21641
epilog
end;</source>
        <Parameter name="_controller" type="CMIF_TranshipTIController" usage="input"/>
        <Parameter name="_ediLoadListTI" type="CM_EDILoadListTI" usage="io"/>
        <Parameter name="_realTI" type="CM_TrackedItem"/>
        <Parameter name="updTranshipVoyageCode" type="Boolean"/>
        <Parameter name="updTranshipDischPort" type="Boolean"/>
        <Parameter name="updTranshipBookingRef" type="Boolean"/>
        <Parameter name="updTranshipBOLId" type="Boolean"/>
        <Parameter name="updTranshipPortsList" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setForCreateFromTIs" id="96ae84c2-9421-483e-90b8-1b16af7fa15c">
        <updating/>
        <source>setForCreateFromTIs(_tiDict: CM_TIByIdDict; _ediConfig: CM_EDIConfig input; _realEdiFile: CM_EDIFile input; _userCode: String) updating;
//----------------------------------------------------------------
//	Created:	16 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 07 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars
	ti		: CM_TrackedItem;
	type	: Integer;
begin
	
	self.setForCreateNoProxy(_ediConfig, null, null, _realEdiFile, _userCode); // cnwrs1 Par 24207 ccms 1117 11 May 2010
	
	type := _realEdiFile.myEDIFileType.type;
	
	foreach ti in _tiDict do
		self.processTIs(ti, type);
	endforeach;


end;</source>
        <Parameter name="_tiDict" type="CM_TIByIdDict"/>
        <Parameter name="_ediConfig" type="CM_EDIConfig" usage="input"/>
        <Parameter name="_realEdiFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_userCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="32a46764-f0ed-4fdb-a705-3cd209b08cd8">
        <updating/>
        <source>setForUpdate(_proxySelf: CM_EDIDataLoadList) updating;
//----------------------------------------------------------------
//	Created:	22 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
