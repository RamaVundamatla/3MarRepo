<Class name="CMQF_Invoice">
    <JadeMethod name="setFromAgent" id="2a439d59-bd64-4e20-87d1-686ab4aa9bb1">
        <updating/>
        <source>setFromAgent(_agent: CMUI_ReportAgent input) updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		22 April 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
// 17.02.2020    cnwma1     Bug 48590: ADP - Passing Invoice Status is not Working when passed by web services
//----------------------------------------------------------------------
vars
	company : CM_Bank;
	string : String;
begin
	inheritMethod(_agent);
	
	if _agent.isRowIncluded(ETRow_Company) then               //Must be moved first 
		company 			:= _agent.getSelectedCompany();
		if company &lt;&gt; null then
			self.allCompaniesByCode.add(company);
		endif;
	endif;
	
	if _agent.isRowIncluded(ETRow_InvoiceType) then
		self.setMyInvoiceType( _agent.getSelectedInvoiceType() );
	endif;
	
	if _agent.isRowIncluded(ETRow_InvoiceStatus) then
		self.invoiceStatus 	:= _agent.getSelectedInvoiceStatus(company);
	endif;
	
	if _agent.isRowIncluded(ETRow_Debtor) then
		self.setMyDebtor( _agent.getSelectedDebtor() );
	endif;
	
	
	
	if _agent.state = _agent.STATE_TEMPLATE_EDIT or
	   _agent.state = _agent.STATE_TEMPLATE_SAVE then
	   
	else
		self.startDate 	:= _agent.getValueByNameForDateIfVisible(ETRow_StartDate);
		self.endDate 	:= _agent.getValueByNameForDateIfVisible(ETRow_EndDate);
	endif;
	
	self.invoiceNumber := _agent.getValueByNameIfVisible(ETRow_InvoiceNumber).Integer;
	if _agent.isRowIncluded(ETRow_BillOfLading) then
		self.billOfLading := _agent.getValueByNameIfVisible(ETRow_BillOfLading).String;
	endif;
	if _agent.isRowIncluded(ETRow_CargoId) then
		self.cargoId := _agent.getValueByNameIfVisible(ETRow_CargoId).String;
	endif;
	if _agent.isRowIncluded(ETRow_Voyage) then
		self.setMyVoyage( _agent.getSelectedCellularVoyage() );
	endif;
	if _agent.isRowIncluded(ETRow_SiteState) then
		//_agent.getSelectedSites(self.allSites);
		self.allQrySites.clear;							//TFS 37093 jlgmd1 21/02/2018
		_agent.getSelectedSites(self.allQrySites);		//TFS 37093 jlgmd1 21/02/2018
		if not self.allQrySites.isEmpty then			//TFS 37093 jlgmd1 21/02/2018
			self.siteState := self.allQrySites[1];		//TFS 37093 jlgmd1 21/02/2018
		endif;											//TFS 37093 jlgmd1 21/02/2018
	endif;

	// ### TFS BUG 56660 23FEB2023 NAVAB1	
	if _agent.isRowIncluded(ETRow_ShippingLine) then
		if _agent.isKindOf(CMUI_ReportAgentStd) then
			self.setMyShippingLine( _agent.CMUI_ReportAgentStd.myCmbShippingLine.listObject.CM_ShippingLine );
		else
			string := _agent.getValueByName(ETRow_ShippingLine).String.trimBlanks;
			if string &lt;&gt; null then
				self.setMyShippingLine( string.asOid.CM_ShippingLine );
			endif;
		endif;
	endif;
epilog
end;</source>
        <Parameter name="_agent" type="CMUI_ReportAgent" usage="input"/>
    </JadeMethod>
</Class>
