    <JadeMethod name="cnwdad1_Test_Class_Count" id="75c65a68-eabb-4edf-bba3-342c5d1807e6">
        <source>cnwdad1_Test_Class_Count();
// --------------------------------------------------------------------------------
// Created:		20 December 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	sourceCode	: String;
	
begin
	sourceCode	:=	"self.name.length() &gt;= 3 and self.name[1:3] = 'sun'";
	
	write CnEcSpellWord.name &amp; " count: " &amp; CnEcSpellWord.cnEcCount(sourceCode, false).cnEcNumberFormat();
//	write CnEcSpellWord.name &amp; " count: " &amp; CnEcSpellWord.cnEcCount("booboo", false).cnEcNumberFormat();
end;</source>
    </JadeMethod>
    <JadeMethod name="cnwdad1_Test_Class_DocSelf" id="0b606e4c-e611-46c1-9770-79181c68f37a">
        <source>cnwdad1_Test_Class_DocSelf();
// --------------------------------------------------------------------------------
// Created:		16 July 2000 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
