    <JadeMethod name="doClickBtnEnable" id="8f70ff6e-571b-4985-b40c-d5d2f7dbbbc7">
        <updating/>
        <source>doClickBtnEnable()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2021	jlgndl1	Initial creation	TFS 50152

*/

vars

	newValue : Boolean;
	theResult : Integer;
	enabledColumn : Integer;

begin

	if self.mySelectedAuditConfig &lt;&gt; null then
	
		enabledColumn := self.tblAuditConfigs.getColumnByRowName(ETRow_IsEnabled);
		newValue := not self.mySelectedAuditConfig.isEnabled;
	
		while true do
		
			app.myTrxUA.trxAuditConfigSetIsEnable( newValue, self.mySelectedAuditConfig, app.myPassport );
			
			if app.myPassport.trxCompletedOK then
				self.tblAuditConfigs.accessRow( self.selectedRow ).selected := false;
				addOrUpdateRow( self.mySelectedAuditConfig, self.selectedRow, enabledColumn );
				break;
			else
				theResult := app.showErrorWarningDialog(app.getErrorString(Audit_configuration), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			break;
		
		endwhile;
		
	endif;

epilog

	self.doSelect();

end;</source>
    </JadeMethod>
    <JadeMethod name="doSelect" id="e6576281-df53-4498-ba96-1f0c3f518e1b">
        <updating/>
        <source>doSelect()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 January 2021	jlgndl1	Initial creation	TFS 20152

*/

vars

	rowIndex : Integer;
	rows : Integer;
	strEnabled : String;
	str : String;

begin

	self.selectedRow := 0;
	self.mySelectedAuditConfig := null;
	
	rows := self.tblAuditConfigs.rows;
	if rows &lt; 2 then
		return;
	endif;
	
	foreach rowIndex in 2 to rows do
		if self.tblAuditConfigs.accessRow( rowIndex ).selected then
			self.selectedRow := rowIndex;
			self.mySelectedAuditConfig := self.tblAuditConfigs.accessRow( rowIndex ).itemObject.CM_AuditConfig;
			break;
		endif;
	endforeach;
	
epilog

	if self.mySelectedAuditConfig = null or not self.mySelectedAuditConfig.canBeUserDisabled then
		self.grpSelected.visible := false; 
	else
		self.grpSelected.visible := true;
		if self.mySelectedAuditConfig.isEnabled then
			strEnabled :=  app.getErrorString(Enabled);
			self.btnEnable.caption := app.getErrorString(Disable);
		else
			strEnabled := app.getErrorString(Not_enabled);
			self.btnEnable.caption := app.getErrorString(Enable);
		endif;
		str := "'" &amp; self.mySelectedAuditConfig.getDescription &amp; "' is currently '" &amp; strEnabled &amp; "' for auditing";
		self.lblSelected.caption := str;
	endif;

end;</source>
    </JadeMethod>
