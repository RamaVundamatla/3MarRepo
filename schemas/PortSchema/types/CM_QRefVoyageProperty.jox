    <JadeMethod name="translateStringToSearchValue" id="42590308-0dc3-450b-87d7-69e688c78988">
        <source>translateStringToSearchValue(_value: Any; _criteriaLine: CM_SelectorCriteriaLine): Any;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
========================================================
08 February 2010		cnwcs5	CCMS 1925/PAR 22295 Release Summaries (Initial creation)
*/

vars
	
begin
	// for 7.7.3 this is only used for summaries so don't need this method.
	// we will get exception if it is called - but it won't be
	
	return inheritMethod(_value, _criteriaLine);

epilog
	
end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="49794410-ce09-4084-865b-43f0904b694a">
        <source>translateToDisplayValue(_value: Any): String;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
========================================================
08 February 2010		cnwcs5	CCMS 1925/PAR 22295 Release Summaries (Initial creation)
*/

vars

begin
	if _value &lt;&gt; null then
		return _value.CM_Voyage.code;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="17f95d75-6c71-4072-aaaf-513cc454af14">
        <source>translateToSearchValue(_value: Any): Any;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
========================================================
08/02/2010	cnwcs5	CCMS 1925/PAR 22295 Release Summaries (Initial creation)
*/
vars
	voyage	:CM_Voyage;
begin
	if _value &lt;&gt; null then
		if _value.isKindOf (Collection) then
			return _value;
		endif;
		
		if _value.isKindOf (CM_Voyage) then
			voyage := _value.CM_Voyage;
		endif;
	endif;
	
	return voyage;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
