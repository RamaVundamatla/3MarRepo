    <JadeMethod name="tblWorkEntryChange" id="4c1c36e2-2d39-46a6-8b17-af46ff98085e">
        <updating/>
        <source>tblWorkEntryChange(_tbl : CM_DataTable io) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2009	cnwml2	Initial creation

*/

vars

obj : CM_Object;
begin
		//self.myCurrentWLE := null;		

	obj := _tbl.accessRow(_tbl.row).itemObject.CM_Object;
	
	if self.myCurrentWLE = obj then
		return;
	endif;
	
	if not global.isValidObject(obj) then
		return;
	endif;
	
	if obj.isKindOf(CM_WorkListEntry) and self.myCurrentWLE &lt;&gt; obj then
		self.myCurrentWLE := obj.CM_WorkListEntry;
		self.doTblExtraInfo(obj);
	endif;
	
	self.setTblDataDetailCellText(_tbl);
end;
</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_DataTable" usage="io"/>
    </JadeMethod>
    <JadeMethod name="tblWorkEntryColor" id="cd532e96-7b8e-48e5-9ec4-2734ef084186">
        <updating/>
        <source>tblWorkEntryColor(_tbl : CM_DataTable io; _wle : CM_WorkListEntry; _row : Integer) updating, protected;
//----------------------------------------------------------------------
//
//  Created by cnwsh3
//
//	Date 26 June 2007
//
//----------------------------------------------------------------------
vars
	isSelected,
	isReceipt 	: Boolean;
	foreColour,
	backColour 	: Integer;	
	tbl 		: CM_DataTable;
begin
	tbl := _tbl;
	
	foreColour := Black;
	backColour := White;

	if _wle = null then
		return;
	endif;

	if _wle.job &lt;&gt; null and _wle.job.jobType = BOLType_Log then
		foreColour := Black;
		if _row mod 2 = 0 then
			backColour := self.colorRow1;
		else
			backColour := self.colorRow2;
		endif;
	else
		_wle.getRowColour(foreColour, backColour);	
	endif;	

	tbl.accessRow(_row).backColor := backColour;
	tbl.accessRow(_row).foreColor := foreColour;	
	
	if backColour = Red then
		tbl.accessRow(_row).fontBold := true;	
	else		
		tbl.accessRow(_row).fontBold := false;		
	endif;
	

end;</source>
        <access>protected</access>
        <Parameter name="_tbl" type="CM_DataTable" usage="io"/>
        <Parameter name="_wle" type="CM_WorkListEntry"/>
        <Parameter name="_row" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblWorkEntryDrop" id="4c0497e5-b785-4b07-8ea4-991ed36e9169">
        <updating/>
        <source>tblWorkEntryDrop(_table : Table; win : Window; x, y : Real)protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 November 2011	cnwndl1	Initial creation	Par 28366

*/

vars

begin
	if self.myCurrentWLE = null then
		app.msgBox(app.getErrorString(OPS_Select_Entry_For_Drop),'Make Selection', MsgBox_Information_Icon + MsgBox_OK_Only);
		return;
	endif;

	if (not global.isValidObject(self.myCurrentWLE)) then
		app.msgBox(app.getErrorString(OPS_Select_Entry_For_Drop),'Make Selection', MsgBox_Information_Icon + MsgBox_OK_Only);
		return;
	endif;	
	
	app.mousePointer := MousePointer_HourGlass;
	
	if self.myCurrentWLE.isReceipt then
		//selected wle is a receipt, they could be sending it back to the vehicle
		self.doMoveTrackedItem(self.myCurrentWLE.job.CM_RoadJob.myVehicle.locationsController, self.myCurrentWLE);
	else //selected wle is a release
		self.assignTIToReleaseRequest(app.myMoveController.myTrackedItem, self.myCurrentWLE);
	endif;
	
epilog
	app.mousePointer := MousePointer_Default;
end;
</source>
        <access>protected</access>
        <Parameter name="_table" type="Table"/>
        <Parameter name="win" type="Window"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="39a7b2e7-36ee-4e31-b0e1-e6ed9b824589">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 March 2019 19:45:34.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0023350, locale);
	btnAddRec.translateCaption(Xlat_0011344, locale);
	btnAddRel.translateCaption(Xlat_0011345, locale);
	btnCancel.translateCaption(Xlat_0011346, locale);
	btnNext.translateCaption(Xlat_0011347, locale);
	btnPrint.translateCaption(Xlat_0011348, locale);
	btnReturnRec.translateCaption(Xlat_0011349, locale);
	btnReturnRel.translateCaption(Xlat_0011350, locale);
	btnSave.translateCaption(Xlat_0011351, locale);
	btnTimeIn.translateCaption(Xlat_0011352, locale);
