    <JadeMethod name="initialise" id="86050373-3f62-4163-9ecb-40c5567a4aea">
        <updating/>
        <source>initialise(_qtyMap : CM_QuantityMap; _bank : CM_Bank; _default : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		02 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//09/02/2017 cnwma1  TFS #2901:ADP - Variable storage charges based on weight and time
// ---------------------------------------------------------------------------
vars
	key	: Integer;
	finObj : CM_FinancialObject;
	sb : CM_ServiceBroker;
	ild	: CM_InvoiceLineDesc;
	mapType	: CM_TranMapInvoiceLineGroupType;
	lineMapping		: CM_TranMapInvoiceLineMapping;
begin
	if _default then
		self.rangeStart := 0;
		self.rangeEnd := self.MAX_RANGE;
	endif;
	self.myQuantityMap := _qtyMap;
	finObj := self.myQuantityMap.myParentFinancialObject;
	if finObj.isKindOf(CM_DebtorMap) then
		sb := finObj.CM_DebtorMap.myServiceBroker;
	elseif  finObj.isKindOf(CM_QuantityRangeMap) then  //09/02/2017 cnwma1 TFS #2901 
		//cnwma1 Pending//
	else
		sb := finObj.CM_ServiceBroker;
	endif;
	

	if self.allRegisteredMethods = null then
		create self.allRegisteredMethods;
	endif;
	
	// CCMS QNS 2177 create default CM_TranMapInvoiceLineMapping(s)
	mapType := _bank.getInvLineGroupAll();
	ild := _bank.voidInvoiceLineDesc;
	
	create lineMapping persistent;
	if sb.isKindOf(CM_ResourceServiceBroker) then
		key := CM_ResourceServiceBroker.INVOICELINE_KEY_IN_CONTRACT;
		lineMapping.update(key, ild, self, mapType, null, null, null, null, null);
		create lineMapping persistent;
		key := CM_ResourceServiceBroker.INVOICELINE_KEY_OUT_CONTRACT;
	elseif sb.isKindOf(CM_EventServiceBroker) then
		key := CM_EventServiceBroker.DEFAULT_INVOICELINE_KEY;
	elseif sb.isKindOf(CM_WorkOrderServiceBroker) then // TFS 39236
		key := CM_WorkOrderServiceBroker.DEFAULT_INVOICELINE_KEY; // TFS 39236
	else
		key := DEFAULT_INVOICELINE_KEY;
	endif;
	lineMapping.update(key, ild, self, mapType, null, null, null, null, null);
	
end;</source>
        <Parameter name="_qtyMap" type="CM_QuantityMap"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_default" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isDefaultRange" id="32f37fe0-48a4-48aa-bd1d-74821ba0aa67">
        <source>isDefaultRange() : Boolean;
// ---------------------------------------------------------------------------
// Created:		04 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	return (self.rangeEnd &gt;= self.MAX_RANGE and self.rangeStart = 0);
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isSubRange" id="e4952a7a-a3fe-4aca-ac9c-18c0726397b1">
        <source>isSubRange() : Boolean;
/*
Purpose:			

Date		Who		Reason
31 May 2023	navab1	TFS CR 58022 TASK 58023
*/

vars
	qm			: CM_QuantityMap;
	parentFO	: CM_FinancialObject;
	
begin

	//09/01/2025	navkc1 JIRA Sub-task MTN-19517
	//return self.myQuantityMap.myParentFinancialObject &lt;&gt; null;
	
	qm := self.myQuantityMap;
	
	if qm &lt;&gt; null then
		parentFO := qm.myParentFinancialObject;
	endif;
	
	return parentFO &lt;&gt; null and parentFO.isKindOf(CM_QuantityRangeMap);
	
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="e19bf391-e6cc-438d-8db2-09a647f83e45">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		04 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle possible exceptions occurring when
//							trying to create the proxy

vars
	pxyMe : SelfType;
	lineMapping,
	pxyMapping		: CM_TranMapInvoiceLineMapping;
	completedOK		: Boolean;
begin
	pxyMe := inheritMethod();
	create pxyMe.allRegisteredMethods transient;
	
// TFS 40620	self.allInvoiceLineMaps.copy(pxyMe.allInvoiceLineMaps);
// TFS 40620	self.allInvoiceLinesUsed.copy(pxyMe.allInvoiceLinesUsed);
	self.allRegisteredMethods.copy(pxyMe.allRegisteredMethods);

	// 30955 copy line mapping as well - missed from initial implementation
	foreach lineMapping in self.allTMInvoiceLineMappings do
		create pxyMapping transient;
		pxyMapping.update(lineMapping.mapValue, lineMapping.myTMInvoiceLineDesc, pxyMe, lineMapping.myTMInvoiceLineGroupType, lineMapping.myTransferType, lineMapping.myVesselCategory,
										lineMapping.myCargoType, lineMapping.myCargoSubtype, lineMapping.myCommodity);
	endforeach;
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return pxyMe;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete pxyMe;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="replaceInvoiceLineTypes" id="131a3e09-1078-4b62-82b7-9036e6368476">
        <source>replaceInvoiceLineTypes(_oldILD : CM_InvoiceLineDesc; _newILD : CM_InvoiceLineDesc) : Integer;
// 32311
vars
	count			: Integer;
	lineDescription	: CM_InvoiceLineDesc;
	lineMapping		: CM_TranMapInvoiceLineMapping;
begin
	// new location of invoice line types
	foreach lineMapping in self.allTMInvoiceLineMappings do
	
		lineDescription := lineMapping.myTMInvoiceLineDesc;
		if lineDescription = _oldILD then
			lineMapping.update(lineMapping.mapValue, _newILD, lineMapping.myQuantityRangeMap, lineMapping.myTMInvoiceLineGroupType, lineMapping.myTransferType, lineMapping.myVesselCategory,
											lineMapping.myCargoType, lineMapping.myCargoSubtype, lineMapping.myCommodity);
			count := count + 1;
		endif;

	endforeach;

	return count;
end;
</source>
        <Parameter name="_oldILD" type="CM_InvoiceLineDesc"/>
        <Parameter name="_newILD" type="CM_InvoiceLineDesc"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="ffe00730-076e-488e-8f51-c15962240421">
        <updating/>
        <source>setForCreate(_pxyQRM : CM_QuantityRangeMap) updating;
// ---------------------------------------------------------------------------
// Created:		04 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.rangeStart := _pxyQRM.rangeStart;
	self.rangeEnd := _pxyQRM.rangeEnd;
	self.rangeType:=_pxyQRM.rangeType;
	self.initialise(_pxyQRM.myQuantityMap,_pxyQRM.myQuantityMap.getBank(), false);
end;</source>
        <Parameter name="_pxyQRM" type="CM_QuantityRangeMap"/>
    </JadeMethod>
    <JadeMethod name="setForCreateWholeStructure" id="e45832c1-95b0-4793-a053-7bacaf012be4">
        <updating/>
        <source>setForCreateWholeStructure(_pxyQRM : CM_QuantityRangeMap; _realQuantityMap : CM_QuantityMap) updating;
/*
Purpose:			
Date				Who			Reason
JULY 2017		CNWAB1		Initial creation
*/
vars
	realInvoiceLineDesc : CM_InvoiceLineDesc;
	proxyTranMapInvoiceLineMapping, realTranMapInvoiceLineMapping : CM_TranMapInvoiceLineMapping;
begin
	self.rangeStart := _pxyQRM.rangeStart;
	self.rangeEnd := _pxyQRM.rangeEnd;
	self.rangeType:=_pxyQRM.rangeType;
	self.myQuantityMap := _realQuantityMap;
// TFS 40620	self.allInvoiceLineMaps.clear();
	if self.allRegisteredMethods = null then // TFS 5627
		create self.allRegisteredMethods; // TFS 5627
	endif; // TFS 5627
	self.allRegisteredMethods.clear; // TFS 5627
	
	foreach proxyTranMapInvoiceLineMapping in _pxyQRM.allTMInvoiceLineMappings discreteLock do
		create realTranMapInvoiceLineMapping;
		realTranMapInvoiceLineMapping.update(proxyTranMapInvoiceLineMapping.mapValue, 
																proxyTranMapInvoiceLineMapping.myTMInvoiceLineDesc, // this is REAL
																self, // this is REAL
																proxyTranMapInvoiceLineMapping.myTMInvoiceLineGroupType, // this is REAL
																proxyTranMapInvoiceLineMapping.myTransferType,
																proxyTranMapInvoiceLineMapping.myVesselCategory,
																proxyTranMapInvoiceLineMapping.myCargoType, proxyTranMapInvoiceLineMapping.myCargoSubtype, proxyTranMapInvoiceLineMapping.myCommodity);
																
// TFS 40620		self.allInvoiceLineMaps.addNoDuplicates(proxyTranMapInvoiceLineMapping.myTMInvoiceLineDesc, false);
	endforeach;


	
	
	
end;</source>
        <Parameter name="_pxyQRM" type="CM_QuantityRangeMap"/>
        <Parameter name="_realQuantityMap" type="CM_QuantityMap"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="3366cc45-d92f-4829-ae2f-3d46cbf8f945">
        <updating/>
        <source>setForUpdate(_pxyQRM : CM_QuantityRangeMap) updating;
// ---------------------------------------------------------------------------
// Created:		04 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	pxyLineMapDict	: CM_TMInvLineMapByCargoAttrDict;
	pxyLineMapping,
	lineMapping		: CM_TranMapInvoiceLineMapping;
begin
	self.rangeStart := _pxyQRM.rangeStart;
	
	if self.MAX_RANGE.Integer = _pxyQRM.rangeEnd then
		self.rangeEnd :=self.MAX_RANGE;
	else
		self.rangeEnd := _pxyQRM.rangeEnd;
	endif;
	self.rangeType:=_pxyQRM.rangeType;
// TFS 40620	self.allInvoiceLineMaps.clear;
// TFS 40620	self.allInvoiceLinesUsed.clear;
	if self.allRegisteredMethods &lt;&gt; null then
		self.allRegisteredMethods.clear;
	endif;
	self.allTMInvoiceLineMappings.purge();

// TFS 40620	_pxyQRM.allInvoiceLineMaps.copy(self.allInvoiceLineMaps);
// TFS 40620	_pxyQRM.allInvoiceLinesUsed.copy(self.allInvoiceLinesUsed);
	if _pxyQRM.allRegisteredMethods &lt;&gt; null and self.allRegisteredMethods &lt;&gt; null then // PAR 35833
		_pxyQRM.allRegisteredMethods.copy(self.allRegisteredMethods);
	endif;
	
	// QNS 2177
	pxyLineMapDict := _pxyQRM.allTMInvoiceLineMappings;
	if pxyLineMapDict &lt;&gt; null then
		foreach pxyLineMapping in pxyLineMapDict do
			create lineMapping persistent;
			lineMapping.setFromProxy(pxyLineMapping, self);
		endforeach;
	endif;
end;</source>
        <Parameter name="_pxyQRM" type="CM_QuantityRangeMap"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="684ff889-f9bc-40ec-a2a2-59eb58f39e64">
        <updating/>
        <source>setProxy(	_qm : CM_QuantityMap;
			_start : Integer;
			_end : Integer;
			_rangeType : Integer) updating;
// ---------------------------------------------------------------------------
// Created:		04 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if _start &gt; _end then
		self.rangeStart := _end;
		self.rangeEnd := _start;
	else
		self.rangeStart := _start;
		self.rangeEnd := _end;
	endif;
	self.myQuantityMap := _qm;
	self.rangeType:=_rangeType;
	
end;</source>
        <Parameter name="_qm" type="CM_QuantityMap"/>
        <Parameter name="_start" type="Integer"/>
        <Parameter name="_end" type="Integer"/>
        <Parameter name="_rangeType" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setProxyInvoiceLineTypes" id="439404c2-dfcb-486e-b05e-e7fd37df3eda">
        <source>setProxyInvoiceLineTypes(_lines : Collection; _gt : CM_TranMapInvoiceLineGroupType);
/*
Purpose:			
Date		Who		Reason
19 March 2015	cnwab1	Initial creation
*/

vars
	ild : CM_InvoiceLineDesc;
	invLineMap, mapping : CM_TranMapInvoiceLineMapping;
	idx : Integer;
	ilds : CM_InvoiceLineDescSet;
begin
	self.clear();
	
	if _lines = null then
		return;
	endif;
	
// TFS 40620	_lines.copy(self.allInvoiceLineMaps);
	create ilds transient; // TFS 40620
	_lines.copy(ilds); // TFS 40620
// TFS 40620	foreach ild in self.allInvoiceLineMaps discreteLock do
	foreach ild in ilds discreteLock do
		idx := idx + 1;
		create invLineMap transient;
		invLineMap.update(idx,ild,self,_gt, null, null, null, null, null);
	
	endforeach;
	
epilog
	delete ilds;// TFS 40620
end;</source>
        <Parameter name="_lines" type="Collection"/>
        <Parameter name="_gt" type="CM_TranMapInvoiceLineGroupType"/>
    </JadeMethod>
    <JadeMethod name="setProxyInvoiceLineTypesFS" id="251f56dc-fd60-4033-9610-2b599e090063">
        <source>setProxyInvoiceLineTypesFS(_lines : Collection; _gt : CM_TranMapInvoiceLineGroupType);
/*
Purpose:			
Date		Who		Reason
28/01/2016	cnwjre1	copy of setProxyInvoiceLineTypes which keeps the CM_TranMapInvoiceLineMapping mapValue at 0 for future storage definitions
*/

vars
	ild : CM_InvoiceLineDesc;
	invLineMap : CM_TranMapInvoiceLineMapping;
	ilds : CM_InvoiceLineDescSet;

begin
	self.clear();
	
	
	if _lines = null then
		return;
	endif;
	
// TFS 40620	_lines.copy(self.allInvoiceLineMaps);
	create ilds transient; // TFS 40620
	_lines.copy(ilds); // TFS 40620
// TFS 40620	foreach ild in self.allInvoiceLineMaps discreteLock do
	foreach ild in ilds discreteLock do
		create invLineMap transient;
		invLineMap.update(0, ild, self, _gt, null, null, null, null, null);
	
	endforeach;
	
epilog
	delete ilds;// TFS 40620

end;</source>
        <Parameter name="_lines" type="Collection"/>
        <Parameter name="_gt" type="CM_TranMapInvoiceLineGroupType"/>
    </JadeMethod>
    <JadeMethod name="setQuantityMap" id="62afd4a8-70b7-40a6-bb32-ba7658905088">
        <updating/>
        <source>setQuantityMap(_value : CM_QuantityMap) updating;
// 37434 QM and QRM can be created together, need to be linked
vars

begin
	self.myQuantityMap :=  _value;
end;
</source>
        <Parameter name="_value" type="CM_QuantityMap"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="62085b6f-b542-49a3-bb30-9fe173b854b0">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 January 2017	cnwma1	Initial creation

*/

vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if	propName = CM_QuantityRangeMap::myChildQuantityMap.name or
		propName = CM_QuantityRangeMap::myQuantityMap.name or
		propName = CM_QuantityRangeMap::rangeType.name  
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateInvLineDescUsedTranMap" id="bdb7a581-2ae8-4961-b759-81309ca8e8b8">
        <source>validateInvLineDescUsedTranMap(_invLineDesc : CM_InvoiceLineDesc) : Boolean;
// ---------------------------------------------------------------------------
// Created:		12 October 2009 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	mapping : CM_TranMapInvoiceLineMapping;
	ild : CM_InvoiceLineDesc;
begin

	// TFS 40620 return self.allInvoiceLineMaps.includes(_invLineDesc);
	
	foreach mapping in self.allTMInvoiceLineMappings do // TFS 40620
		ild := mapping.myTMInvoiceLineDesc; // TFS 40620
		
		if ild = _invLineDesc then
			return true;
		endif;
	endforeach;
	
	return false;
end;</source>
        <Parameter name="_invLineDesc" type="CM_InvoiceLineDesc"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="3793ee4f-843d-4253-8ecf-4282d2b3a99c">
        <source>validateMe();
// ---------------------------------------------------------------------------
// Created:		04 October 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	mess : String;
begin

	if not self.doIConflictWithRanges(self.myQuantityMap, mess) then
		app.raiseCMException1(QuantityRangeConflict, mess, null, self);
	endif;
	
	//04 Feb 2019	NDL	TFS 43153
	if self.myQuantityMap &lt;&gt; null and self.myQuantityMap.mySnapShotQuantityType &lt;&gt; null then
		if allTMInvoiceLineMappings.isEmpty then
			app.raiseCMException(Input_required_field_invLneTyp, null, self);
		endif;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="validateRange" id="fb2080cc-be58-4c7e-b2b0-a5f8ba7d1fd4">
        <source>validateRange(_qm : CM_QuantityMap);
// CCMS 1043 Snapshot Summary Invoicing 	Oct 2010 	cnwjre1
vars
	mess : String;
begin

	if not self.doIConflictWithRanges(_qm, mess) then
		app.raiseCMException1(QuantityRangeConflict, mess, null, self);
	endif;
end;</source>
        <Parameter name="_qm" type="CM_QuantityMap"/>
    </JadeMethod>
</Class>
