    <JadeMethod name="doFormLoad" id="91b196fd-1a83-403f-987e-a91ec4991a6e">
        <updating/>
        <source>doFormLoad() updating, protected;

vars
	agentObj		: CnEcEmailAgent;
	emailRootObj	: CnEcEmailRoot;
	baseDataObj		: CnEcEmailBaseData;
	
begin
	self.allowClose	:=	false;
	self.centreWindow();
	
	create agentObj transient;
	self.aMyTA		:=	agentObj;
	emailRootObj	:=	CnEcEmailRoot.firstInstance();
	
	if aIsAdminMode then
		
		lblComputerName.caption := "System Default Values";
		baseDataObj	:=	emailRootObj.myDefaultBaseData;
		
		if baseDataObj &lt;&gt; null then 
			txtClient.text			:=	baseDataObj.emailClientName;
			txtServer.text			:=	baseDataObj.emailServerName;
			txtReturnAddress.text	:=	baseDataObj.emailReturnAddress;
			txtLdapBase.text		:=	baseDataObj.ldapBase;
			txtLdapHost.text		:=	baseDataObj.ldapHost;
			btnClose.enabled		:=	true;
		else
			txtClient.text			:=	"";
			txtServer.text			:=	"";
			txtReturnAddress.text	:=	"";
			txtLdapBase.text		:=	"";
			txtLdapHost.text		:=	"";
		endif;
	
	else
		lblComputerName.caption := "Computer name = " &amp; app.computerName();
		baseDataObj	:=	emailRootObj.getEmailBaseData(app.computerName());
		
		if baseDataObj = null then
			baseDataObj	:=	emailRootObj.myDefaultBaseData;
		endif;
		
		if baseDataObj &lt;&gt; null then 
			txtClient.text			:=	baseDataObj.emailClientName;
			txtServer.text			:=	baseDataObj.emailServerName;
			txtReturnAddress.text	:=	baseDataObj.emailReturnAddress;
			txtLdapBase.text		:=	baseDataObj.ldapBase;
			txtLdapHost.text		:=	baseDataObj.ldapHost;
			btnClose.enabled		:=	true;
		else
			txtClient.text			:= "";
			txtServer.text			:= "";
			txtReturnAddress.text	:=	"";
			txtLdapBase.text		:=	"";
			txtLdapHost.text		:=	"";
		endif;
	
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
