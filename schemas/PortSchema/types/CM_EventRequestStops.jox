    <JadeMethod name="setProxyWeightCertified" id="9465c23b-bdb6-4715-abaf-7f1805fbdcd8">
        <updating/>
        <source>setProxyWeightCertified(	_weight : Decimal;
							_isCertified : Boolean;
							_weightCertifiedName : String;						// TFS #1699
							_weightCertifiedReference : String	) updating;		// TFS #1699
/*

Date		Who		Reason
04/02/2016	cnwer1	Initial creation PAR 37551 TFS 1429
05/05/2016	cnwdap1	TFS #1699 Verified Gross Mass changes
*/
vars
	tmpTI : CM_TrackedItem;
	terminal : CM_Terminal;

begin
	self.totalWeight:=_weight;
	self.isWeightCertified:=_isCertified;
	self.weightCertifiedName := _weightCertifiedName;							// TFS #1699
	self.reference := _weightCertifiedReference;								// TFS #1699
epilog

end;</source>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_isCertified" type="Boolean"/>
        <Parameter name="_weightCertifiedName" type="String"/>
        <Parameter name="_weightCertifiedReference" type="String"/>
