    <JadeMethod name="hasSOBLoadJob" id="1adf2a30-6b10-4976-bd3c-099ea19c3a2e">
        <source>hasSOBLoadJob(_deck : CM_DeckVoyage ) : Boolean;
/*

Date		Who		Reason
30 August 2013	cnwer1	Initial creation PAR

*/

vars
iter : Iterator;
	request : CM_Request;
begin
	if not self.isSOB() then
		return false;
	endif;
	
	
	iter:=self.allRequests.createIterator;
	while iter.next(request) do
		if not request.CM_VoyageRequest.isSOBLoad then
				continue;
		endif;
		
		if request.CM_VoyageRequest.getDeck = _deck then
			return true;
		endif;
	endwhile;
	
	return false;
epilog
	delete iter;

end;</source>
        <Parameter name="_deck" type="CM_DeckVoyage"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
