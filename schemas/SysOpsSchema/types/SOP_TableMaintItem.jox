    <JadeMethod name="getConvertedDisplayValue" id="f63ae20c-6be2-4ded-9f17-b6015f2065f6">
        <source>getConvertedDisplayValue( _rowName : String; _measureType : CM_MeasurementType ):Decimal protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 March 2014	cnwndl1	Initial creation	Par 33268 - Returns the measurment data in the correct base units to be stored directly into the database

*/

vars

	measureTable : CMUI_MeasurementTable;
	prefix : String;

begin

	if _measureType = null then
		return 0;
	endif;

	prefix := app.getMeasurementPrefixFromType( _measureType.measurementType );

	measureTable := self.myForm.getMeasurementControl(prefix &amp; _rowName &amp; "_" &amp; _measureType.shortName);
	if measureTable &lt;&gt; null then
		return measureTable.getConvertedValue;
	endif;
	
	return 0;
	

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_measureType" type="CM_MeasurementType"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
