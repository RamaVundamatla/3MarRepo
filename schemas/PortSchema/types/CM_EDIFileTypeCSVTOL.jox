<Class name="CM_EDIFileTypeCSVTOL" id="e8ca506b-5029-4efe-b7fe-b0710484cc5d">
    <superclass name="CM_EDIFileTypeCSV"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
