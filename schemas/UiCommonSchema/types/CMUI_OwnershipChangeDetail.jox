    <JadeMethod name="setupForm" id="cbbe1c91-71d0-4b57-baf8-932b01296f36">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 July 2023 navtnr20	TFS CR 58230	Task 58231: UI - Change of Ownership Detail
09 August 2023 navmv20 CR 59391 Task 59417: COO Maint Include Changes
11 August 2023 navmv20 Bug 59697: EUP - Change of Ownership Cargo Review - Able to create COO for Offsite Cargo
30/11/2023		navkc1 ChangeRequest 58254 Task 61099: UI - Ownership Change Approved
//20.07.2024 navrv30 Bug 64858: MTN - Ownership Change Maint - Select All issues
*/

vars
	cargoType 		: CM_CargoType;
	ti 				: CM_TrackedItem;
	cooHeader		: CM_OwnershipChange;
begin
	inheritMethod();
	
	self.setTotalValues(); //11/08/2023 navmv20 Bug 59697
	self.doMeasurementVolume();
	self.doMeasurementWeight();
	
	//self.initTblData(ETDef_OwnershipChangeMaint); //09/08/2023 navmv20 CR 59391 Task 59417
	self.initTblData(ETDef_OwnershipChangeDetails); //09/08/2023 navmv20 CR 59391 Task 59417
	//25/06/2024	navkc1 CR 64823 Task 64824
	//self.btnClear.enabled	:= false;
	//self.txtFilterTblData.enabled	:= false;
	
	self.displayOwnershipDetail();

	ti := self.myOwnershipChangeDetail.myTrackedItem;
	if ti.isCargoGroupItem then
	
	else
		self.chkHide.value := true;
		self.chkHide.visible := false;
		self.showHideDetail();
	endif;
	self.chkIncludeDetail.value := self.myProxyDetail.included; //09/08/2023 navmv20 CR 59391 Task 59417
	
	//27/05/2024	navkc1 Bug 64182
	cooHeader := self.myOwnershipChange;
	
	//30/11/2023	navkc1 ChangeRequest 58254 Task 61099
	//if self.myOwnershipChange.dateTimeApproved.isValid() then
	if cooHeader &lt;&gt; null and cooHeader.isApproved() then //27/05/2024	navkc1 Bug 64182 // ### TFS CR 64164 TASK 64733 20JUNE024 NAVAB1
		self.cooHeaderIsApproved := true;
	endif;
	
	// ### TFS BUG 64115 13MAY2024 NAVAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) 
	or self.cooHeaderIsApproved  then // ### TFS CR 64164 TASK 64733 20JUNE024 NAVAB1
		self.tblData.userInputEnabled := false;
		self.tblData.readOnly := true;
		self.btnCargoUpdate.enabled := false;
		self.btnSave.enabled := false;
		self.chkIncludeDetail.enabled := false;
		self.txtTransferCargoQuantity.enabled := false;
		self.txtTransferCargoVolume.enabled := false;
		self.txtTransferCargoWeight.enabled := false;
		self.txtTransferQuantity.enabled := false;
		self.txtTransferVolume.enabled := false;
		self.txtTransferWeight.enabled := false;
		
		self.chkSelectAll.enabled := false; // ### TFS CR 64164 TASK 64733 20JUNE024 NAVAB1
		
	endif;
	
	self.frmTableFilter.setupControl(self.tblData, null); //05/06/2024	navkc1 CR 63736 Task 63770
	self.doSetSelectAll();		//20.07.2024 navrv30 Bug 64858
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showHideDetail" id="a6da80ef-dbdf-47ba-8711-53e52c464902">
        <updating/>
        <source>showHideDetail() updating;
/*
Purpose:			

Date		Who		Reason
24 July 2023	navab1	 CR 58230 TASK 58231
*/

vars

begin
	if self.chkHide.value then
		self.grpDetails.visible := false;
		self.minimumHeight := (self.grpDetails.top + 90).Integer;
		self.height := self.minimumHeight;
		
	else
		self.grpDetails.visible := true;
		self.minimumHeight := 585;
	endif;
epilog

end;</source>
