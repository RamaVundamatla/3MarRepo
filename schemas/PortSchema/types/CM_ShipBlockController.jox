    <JadeMethod name="myTerminal" id="8906afb0-7c33-4216-b980-bda8d991dfc8">
        <methodInvocation>mapping</methodInvocation>
        <source>myTerminal(_set: Boolean; _value: CM_Terminal io) mapping;
//--------------------------------------------------------------
//Created: 17 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if _set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	_value := null;
	
	if self.myTerminal = null and self.myVoyage &lt;&gt; null then
		_value := self.myVoyage.myTerminal;
	endif;


end;</source>
