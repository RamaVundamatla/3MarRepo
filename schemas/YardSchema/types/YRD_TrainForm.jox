    <JadeMethod name="selectWagonFromRange" id="65a92386-f3b5-423c-b2be-28dc27a15ee6">
        <source>selectWagonFromRange() : Boolean;
// ---------------------------------------------------------------------------
// Created:     07 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	integerArray : IntegerArray;
	wagonSet : CM_WagonSet;
	errString : String;
	wagon : CM_Wagon;
begin
	if txtWagonRange1.text.trimBlanks &lt;&gt; null then
		create integerArray transient;
		if not self.getPositionDataFromText( integerArray ) then
			return false;
		endif;
		
		// User has entered a range value, attempt to set up the selection from the range.
		if not self.tblWagons.allSelectedObjects.isEmpty() then
			// give a warning that the Wagon range will overwrite the table selection...
			if app.msgBox(app.getErrorString(YOU_HAVE_WAGONS_SELECTED),app.getErrorString(SHP_Do_You_Want_To_Continue),MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
				return false;
			endif;
		endif;
			
		// get the position values form the txtWagonRange.text
		// get a list of the wagons from the position data
		create wagonSet transient;
		self.getWagonsFromPositions( integerArray, wagonSet, errString );
		if errString &lt;&gt; null then
			app.msgBox(app.getErrorString(No_wagons_position) &amp; " " &amp; errString &amp; ".",app.getErrorString(Error),MsgBox_OK_Only);
			txtWagonRange1.setFocus();
			return false;
		endif;
		
		//clear then add the selected wagons to self.tblWagons.allSelectedObjects
		self.tblWagons.clearAllSelected();
		foreach wagon in wagonSet do
			self.tblWagons.selectObject(wagon,false);
		endforeach;
		
	endif;
	
	if self.cmbAreas.listIndex &lt; 1 then
		app.msgBox(app.getErrorString(Must_enter_rail_positio), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
		cmbAreas.setFocus();
		return false;
	endif;
	
	if self.cmbPosition.listIndex &lt; 1 then
		app.msgBox(app.getErrorString(Must_enter_rail_positio), app.getErrorString(Error), MsgBox_Exclamation_Mark_Icon);
		cmbPosition.setFocus();
		return false;
	endif;

	return true;
epilog
	delete integerArray;
	delete wagonSet;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setControlsForAddEdit" id="448596d8-9619-4be9-8aff-fdc539d8b1f3">
        <updating/>
        <source>setControlsForAddEdit() protected, updating;
/*
----------   ----------  --------------------------------------------------
Created:	07 November 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
02 Oct 2020 cnwma1 		 ChangeRequest 50112: ASPA - GCI Stevedores	
27 Apr 2022	navsrk20	 ChangeRequest 53142: EUP - INB - Cargo Forecast on Voyage &amp; Train - UI
18 Aug 2022 navhl20 	 ChangeRequest 54281: EUP - Wagon Track Planning
----------   ----------  --------------------------------------------------
*/
vars
	trackClear :CM_TrackClearance;
begin

	self.cmbTrain.enabled 			:= false;
	self.chkIncDeparted.enabled 	:= false;
	self.lblTrain.enabled 			:= false;
	self.btnMoveToRail.enabled		:= false;
	self.btnConfirmTrainI.enabled 		:= false;
	self.btnConfirmTrainO.enabled 		:= false;
	self.btnOutOrder.enabled := false;	//12 Aug 2009	NDL CCMS 1094
	self.btnEditTrain.enabled 		:= false;
	self.btnCopyTrain.enabled := false;	//28 Aug 2009	NDL CCMS 1094
	self.btnNewTrain.enabled 		:= false;
	self.btnDeleteTrain.enabled 	:= false;
	self.btnWagonDown.enabled 	:= false;
	self.btnCargoForecast.enabled := false; //27 Apr 2022 navsrk20 TFS 53142
	
	self.btnDeparture.enabled := false;
	self.btnEnquiryRec.enabled := false;
	self.btnEnquiryRel.enabled := false;
	self.btnSummariseAll.enabled := false;
	self.btnDeleteWagon.enabled := false;
	self.btnConfirmIn.enabled := false;
	self.btnConfirmOut.enabled := false;
	self.btnIntransit.enabled := false;
	self.btnIntransitNO.enabled := false;
	
	
	self.btnWagonUp.enabled 	:= false;
	self.btnRailPlan.enabled	:= false;
	self.btnRailOps.enabled	:= false;
	self.btnNewEvent.enabled := false;	// 29 Oct 2009	NDL	Par 21519
	self.btnLoadList.enabled	:= false;
	self.btnWarnings.enabled 	:= false;	//18 Feb 2010	RJS Par 21951
	
	self.btnSaveBase.enabled 		:= true;
	self.btnSaveNext.enabled		:= true; // 28 Aug 2009	NDL	CCMS 1094
	self.btnCancelBase.enabled 		:= true;
	
	self.btnNewWagon.enabled 		:= false;
	self.btnMoveWagon.enabled 		:= false;		//18.8.2022 navhl20 TFS 54281
	self.btnWagonUnplan.enabled		:= false;		//18.8.2022 navhl20 TFS 54281
	self.btnEditWagon.enabled 		:= false;
	self.btnCCWagon.enabled			:= false;
	self.btnRailAllocRem.enabled 	:= false;
	self.tblWagons.enabled 			:= false;
	//input controls
	self.txtCode.enabled 			:= true;
	self.txtDescription.enabled 	:= true;
	self.txtArrivalDate.enabled		:= true;
	self.txtArrivalTime.enabled		:= true;
	//departure set automatically when train cleared from the rake(s)
	self.txtDepartureDate.enabled 	:= true;
	self.txtDepartureTime.enabled 	:= true;
	self.cmbDestPort.enabled 		:= true;
	self.cmbOriginPort.enabled 		:= true;
	self.cmbStatus.enabled			:= true; //navsp1 17MAY2022 TFS#53619
	//cnwrd1 par 19710 20.5.09 -  ccms 1067
	self.clColour.enabled 			:= true;
	
	trackClear := cmbGaugeClear.listObject.CM_TrackClearance;	//09 Sep 2013	NDL	Par 32172
	self.tblHeight.enabled := ( trackClear = null );	//09 Sep 2013	NDL	Par 32172
	self.tblWidth.enabled :=  ( trackClear = null );	//09 Sep 2013	NDL	Par 32172
	self.tblWeight.enabled := ( trackClear = null );	//09 Sep 2013	NDL	Par 32172
	self.chkNoEmptyWagons.enabled       := true; 				// PAR 23176
	self.txtScheduleCode.enabled 	    := true;
	self.txtPortArrivalDt.enabled 		:= true;
	self.txtPortArrivalTm.enabled 		:= true;
	self.txtShunterInDt.enabled 		:= true;
	self.txtShunterInTm.enabled 		:= true;
	self.txtShunterOutDt.enabled 		:= true;
	self.txtShunterOutTm.enabled 		:= true;
	self.cmbCarrier.enabled				:= true;
	
	//26 Jun 2009 NDL CCMS 1067
	self.cmbGaugeClear.enabled			:= true;	 
	if cmbGaugeClear.listObject &lt;&gt; null then
		// not permitted to change these manually if set via a Gauge Clearance 
		self.tblHeight.enabled := false;	//09 Sep 2013	NDL	Par 32172
		self.tblWidth.enabled := false;		//09 Sep 2013	NDL	Par 32172
	endif;
	
	//+ 26/05/2009, cnwmd1, CCMS 1067, Par 19710
	self.txtSchArrivalDt.enabled 		:= true;
	self.txtSchArrivalTm.enabled 		:= true;
	self.txtSchDepartDt.enabled 		:= true;
	self.txtSchDepartTm.enabled 		:= true;
	self.txtCargoXStartDt.enabled 		:= true;
	self.txtCargoXStartTm.enabled 		:= true;
	self.txtCargoXEndDt.enabled 		:= true;
	self.txtCargoXEndTm.enabled 		:= true;
	self.txtRemaks.enabled 				:= true;
	self.cmbRecStevedore.enabled 		:= true;   //02.10.2020 cnwma1 TFS #50112
	self.cmbRelStevedore.enabled        := true;   //02.10.2020 cnwma1 TFS #50112
	self.txtCode.setFocus();
	
end;</source>
        <access>protected</access>
    </JadeMethod>
