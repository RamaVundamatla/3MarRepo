    <JadeMethod name="createFrameCaption" id="b24e22f0-5b62-4842-9893-69d26ac76f93">
        <updating/>
        <source>createFrameCaption() updating;
// ---------------------------------------------------------------------------
// Created:		March  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	gas : Frame;
begin

	create self.myFrameCaption transient;
	gas := self.myFrameCaption;
	
	//cnwmc5 - PAR 31051
	if not self.isInPainter then
		if not app.isUsingSkin then
			gas.bevelInner := Frame.Bevel_Inset;
			gas.bevelInnerWidth := 1;
			gas.bevelOuter := Frame.Bevel_None;
			gas.bevelOuterWidth := 0;
			gas.borderStyle := Table.BorderStyle_None;
			gas.boundaryWidth := 2;
			gas.backColor := gas.boundaryColor;
		else
			gas.skinCategoryName := "padded";
		endif;
	endif;
	
	gas.caption := "";
	gas.enabled := true;

	gas.parent := self;
	self.form.addControl(self.myFrameCaption);

end;</source>
    </JadeMethod>
    <JadeMethod name="createFrameDisplayMode" id="67efab50-3f00-448d-88b6-8e7b28700a1a">
