    <JadeMethod name="valWorkOrderPosition" id="4a509f08-cc7c-4d0f-b26e-01329051a313">
        <source>valWorkOrderPosition(_proxyWorkOrder : CM_WorkOrder);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 August 2009	cnwmd1	Initial creation

*/

vars
	realWorkOrder : CM_WorkOrder;
	task : CM_WorkOrderDtl;
	tasksToDelete : CM_WorkOrderDtlArray;
begin
	self.raiseExceptionIfNull(_proxyWorkOrder, 'Work Order');
	_proxyWorkOrder.raiseExceptionIfNotProxy(method);

	realWorkOrder := _proxyWorkOrder.pxyGetRealObject();
		
	if realWorkOrder = null then
		app.raiseUnexpectedProgramError(self.class.name, method.name, "Work Order does not exist");
	endif;
	
	create tasksToDelete transient;
	realWorkOrder.getTasksSelectedForDelete(_proxyWorkOrder, tasksToDelete);
	foreach task in tasksToDelete do
		task.validateForDelete();
	endforeach;
epilog
	delete tasksToDelete;
end;</source>
        <Parameter name="_proxyWorkOrder" type="CM_WorkOrder"/>
    </JadeMethod>
