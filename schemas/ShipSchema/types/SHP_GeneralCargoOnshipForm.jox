        <source>doResize() updating;
//7 July 2022 navukv20 ChangeRequest 53915: MTN - BOL Maintenance Toolbars
vars

begin

	self.splMain.top := self.frmToolbar.height + 2;
	self.splMain.height := self.height - self.splMain.top;
	
	/* temp table
	self.tblStowagePlan.width := self.frmStowage.clientWidth;
	self.tblStowagePlan.height := self.frmStowage.clientHeight;
	self.tblStowagePlan.columnWidth[1] := (self.tblStowagePlan.width * 0.25).Integer;
	self.tblStowagePlan.columnWidth[2] := (self.tblStowagePlan.width * 0.50).Integer;
	self.tblStowagePlan.columnWidth[3] := (self.tblStowagePlan.width * 0.15).Integer;
	self.tblStowagePlan.columnWidth[4] := (self.tblStowagePlan.width * 0.10).Integer;
	*/
	
	inheritMethod();
