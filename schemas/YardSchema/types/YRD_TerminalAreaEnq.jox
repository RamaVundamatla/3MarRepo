    <JadeMethod name="doCmbISOGroupClick" id="cedb1393-d993-4a8a-8815-340fa700d3f9">
        <source>doCmbISOGroupClick() protected;
// ---------------------------------------------------------------------------
// Created:     15 March 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	isoGroup		: CM_ISOTypeGroup;
begin
	isoGroup := self.cmbISOGroup.listObject.CM_ISOTypeGroup;
	//note here the last param - if the user has an isoType that is included in the new collection of isoTypes
	//(group if selected and root collection if no group) it will be re-selected
	self.myAssistant.comboBoxISOTypeByGroup(self.cmbISOType, isoGroup, self.cmbISOType.listObject.CM_ISOType);
	self.tblSearch.setValueByName(ETRow_FiltISOType, self.cmbISOType.text);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDelete" id="e8c54b94-5b0b-495d-ae7e-c269dcf42480">
        <updating/>
        <source>doDelete() : Boolean updating;
/*
----------   ----------  --------------------------------------------------
Created:	17 October 2006 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
1/11/2012	cnwcs5		par 30475 - tidy up translations
*/
vars
	rtnValue	: Boolean;
	table		: Table;
	obj			: Object;
	ta			: CM_TerminalArea;
	passport	: CM_Passport;
	theResult : Integer;	//15 Jan 2020 NDL	TFS 46815
	
begin
	table	:= self.tblData;
	obj 	:= table.accessRow(table.row).itemObject;
	
	if obj = null or (not obj.isKindOf(CM_TerminalArea)) then
		app.msgBox(app.getErrorString (Please_select_termin_area_dele),app.getErrorString (Terminal_area_selected), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return false;
	endif;

	ta := obj.CM_TerminalArea; 
	
	if app.msgBox(app.getErrorString1 (Lit_Confirm_Delete, ta.getID()) , app.getErrorString (Are_You_Sure), MsgBox_OK_Cancel) = MB_OK then
			
		passport := app.myPassport;
		
		//15 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
		while true do
		
			app.myTrxDA.trxDeleteTerminalArea(ta, passport);
		
			if app.myPassport.trxCompletedOK then
				return true;
			else
				theResult := app.showErrorWarningDialog(app.getErrorString (TerminalAreas), passport, ErrWarnMode_Update);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			
			return false;
			
		endwhile;

	else
		return false;
	endif;	
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doEdit" id="27302beb-8200-497b-9fa1-b6195c6d3a84">
