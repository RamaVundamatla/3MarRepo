    <JadeMethod name="getOverrideQueue" id="57491f01-b2dd-4b8c-bdb0-d2aa330eec13">
        <source>getOverrideQueue(): CM_SubQueue;

// Created by cnwdvb1 on 04 September 2006

vars
	truck	: CM_Vehicle;
	lc		: CM_YardController;
	ta		: CM_TerminalArea;
begin
	// par 24418 - I think this is how it should work ...
/*	if a vehicle is NOT inside the yard, i.e. because it is at the p-gate/a-gate then
	we want the job to go into a queue that is not being serviced.  We expect the vehicle
	to be located at a gate area (a-gate/p-gate) so look for a queue associated with that
	location.
*/
	truck := self.vehicle;
	
	if truck &lt;&gt; null then
		lc := truck.myPrimaryActualLocation;
	endif;
	
	if lc &lt;&gt; null then
		if lc.isInsideYard then 
			// don't look for an override queue - use yard queues (default)
			return null;
		endif;
		ta := lc.myTerminalArea;
		
		if ta &lt;&gt; null then
			app.writeLog("Vehicle is currently located at: " &amp; ta.id, 0);
			// get the first queue for this terminal area - 
			return ta.getOverrideQueue;
		endif;
	endif;
	// could get to here if vehicle:
	// - is at 'In terminal Unknown' location which has no terminal area (should not happen if setup is done correctly)
	// - has no primary actual location (should probably not be calling this method for vhicle not in terminal)
	return null;
end;</source>
        <ReturnType type="CM_SubQueue"/>
    </JadeMethod>
    <JadeMethod name="getParent" id="a72460e4-3df5-4900-89c8-e17f51072041">
        <source>getParent(): CM_TerminalArea;
// 01/09/2009	cnscw5	ccms1061 - changed return type 
vars
	ta : CM_TerminalAreaMaster;
begin
	// this will return the actual terminal area the vehicle is located in
	// if you need the location for RTG queuing then don't use this method - use one
	// that returns the gate area for the current job
	if self.vehicle &lt;&gt; null and self.vehicle.myPrimaryActualLocation &lt;&gt; null then
		// terminal area the vehicle is actually in
		return self.vehicle.myPrimaryActualLocation.myTerminalArea; 
	endif;
	// no location so return null
	return null;
	// Note the CM_VehicleController::myTerminalArea mapping method would have returned the myTerminalArea property from the 
	// LC as it relied on the same condition as the above code to go looking at the road job for the terminal area.
	// return self.myTerminalArea;
end;</source>
        <ReturnType type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="getParentForMachine" id="f45f7a45-df01-4049-b4c1-8eceb9a5d336">
        <source>getParentForMachine(_machine: CM_Machine): CM_Object;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 February 2010	cnwer1	Initial creation

*/

vars
	ya : CM_YardController;
begin
	//return null;
	//cnwrd1 5.3.2012 for Doha gate/queue setup -  now par 29235
	
	//epr TFS 3155 21/12/16
	if self.myTerminalArea = null and self.vehicle &lt;&gt; null then
		ya := self.vehicle.myPrimaryActualLocation;
		if ya &lt;&gt; null then
			if ya.isInsideYard then
				//if the truck is in the yard we don't really know where it is and returning this location which is the first location for a wle is 
				// a problem if the truck is picking up &gt; 1 container in different locations
				return null;
			endif;
		
			return ya.myTerminalArea;
		endif;
		
	endif;
	
	return self.myTerminalArea;

epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="getPickupTasks" id="090ef53d-1b02-49df-bd4e-4b6a02897fdb">
        <source>getPickupTasks(arbiter: CM_RTQueueArbiter input; isOverstowMove : Boolean);
/*
	method that returns the work required to pick up a TI.
*/
vars
	task	: CM_RTQueueTask;
begin
	create task;

	if arbiter.job.isKindOf(CM_YardInternalJob) then
		if arbiter.job.CM_YardInternalJob.isSwapJob then
			//SwapJob! Bad thing here!
			return;
		endif;
	endif;
	
	
	task.setDetails(	self,
						arbiter.ti.getPrimaryLocation(QUEUE_MODE),
						TASK_UNACTIONED,
						TASK_PICKUP,
						arbiter.ti);
	
	arbiter.entry.addTask(task);


end;</source>
        <Parameter name="arbiter" type="CM_RTQueueArbiter" usage="input"/>
        <Parameter name="isOverstowMove" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getQueueTasks" id="fab0a6c9-a09b-4866-a708-d0249dc1bfd3">
        <source>getQueueTasks(arbiter: CM_RTQueueArbiter input; _isSource : Boolean);
//Returns the tasks required to do a unit of work. (move a TI)
//Called from the RTQueueArbiter.
vars
	isSource : Boolean;
	height	: Integer;
	task	: CM_RTQueueTask;
begin
	//Determine if the ti in the arbiter transient is here.
	/*epr par 21716 24/11/09  determining if it is source based on if it is included in the allTrackedItems collection is incorrect if this is a multi machine move
		because it may not be on here yet. 
		In this case we would end up with 2 setdown tasks and no pickup task !!!!
		Changed to just use the parameter passed in
	
	*/
	if _isSource then
		//This lc is the source of all evil.
		//------------
		//Get the TI to provide its "pickup tasks"
		//------------
		self.getPickupTasks(arbiter, false);
	else
		//Target.
		//------------
		//Get the target to provide its "set-down tasks"
		//------------
		self.getSetdownTasks(arbiter, false);
	endif;

end;</source>
        <Parameter name="arbiter" type="CM_RTQueueArbiter" usage="input"/>
        <Parameter name="_isSource" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getQueues" id="ac4c76d7-6184-4ad2-b5b5-cfa3402645ac">
        <source>getQueues(queueSet : CM_RTQueueSet io);
// 14/10/2009	cnwcs5	par 21316/par 20797 - 
//
vars
	area	:CM_TerminalArea;
begin
	queueSet.clear;

	//---------------
	//Never any queues in this LC, go to the relevant TA
	//---------------
/*
	par 21316/ par 20797
	pre-7.7.3 there was a mapping method (CM_VehicleController::myTerminalArea) that always returned the 
	VTA for a vehicle that was in the terminal.  The mapping method has gone and this method does a similar thing 
*/	
	if self.vehicle &lt;&gt; null and self.vehicle.myPrimaryActualLocation &lt;&gt; null then
		area := self.vehicle.myPrimaryActualLocation.myTerminalArea; //self.myTerminalArea;
	endif;
	
	if area = null then
		// Something has gone terribly wrong... nothing we can do
		// job will be dumped in the master queue
		return;
	endif;
	
	area.getQueues (queueSet);
end;</source>
        <Parameter name="queueSet" type="CM_RTQueueSet" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getRoadOpsDelCurEntryOption" id="a448aa51-0aa1-496d-b57c-295d29f41dad">
        <source>getRoadOpsDelCurEntryOption() : Integer;
/*

Purpose: Determines if selected option for 'Road Operation Delete Current Entry' is an option that will
		 set the status of all invoice lines to VOID. Options that will void invoice line are :
		   Option 1 = Road Receive Deleted, Road Release NOT Created, Road Receive Invoice Line Remains
		   Option 3 = Road Receive Deleted, Road Release NOT Created, Road Receive Invoice Line Void

Parameters:			

Return Value:		

Date		Who		TFS		Reason
29 Oct 2019	jlgdi1	46578	Initial creation
*/

vars
	terminal : CM_Terminal;
	selectedOpt : Integer;
	
begin
	terminal := self.getMyTerminal;
	if terminal &lt;&gt; null then
		selectedOpt := terminal.getConfig(RoadOpsDelCurEntryOption).Integer;
	endif;
	
	return selectedOpt;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSetdownTasks" id="8501171d-8e94-4c9a-95e4-90e5c4fb73d2">
        <source>getSetdownTasks(arbiter: CM_RTQueueArbiter input; isOverstowMove: Boolean);

vars
	task	: CM_RTQueueTask;
begin
	create task;
	//parent will be set higher up.
	if arbiter.job.isKindOf(CM_YardInternalJob) then
		if arbiter.job.CM_YardInternalJob.isSwapJob then
			//SwapJob! PANIC!
			return;
		endif;
	endif;
	
	
	task.setDetails(	arbiter.ti.getPrimaryLocation(REAL_MODE),
						self,
						TASK_UNACTIONED,
						TASK_SETDOWN,
						arbiter.ti);
	
	arbiter.entry.addTask(task);
	//arbiter.addTask(task);
end;</source>
        <Parameter name="arbiter" type="CM_RTQueueArbiter" usage="input"/>
        <Parameter name="isOverstowMove" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getTAforRadioTelemetryQueue" id="df90257b-9dd5-4371-9cd4-f7372aefd9c3">
        <source>getTAforRadioTelemetryQueue() : CM_TerminalArea;
//
// Created: 17/5/2010, cnwjo3
//
// Purpose: This method returns the terminal area of a Vehicle for Radio Telemetry Queues
//			so the 'myTerminalArea' mapping method does not need to be reimplemented.  We don't
//			want 'myTerminalArea' reimplemented because that would create a link been this vehicle
//			controller and a VTA, which could mean that if the VehicleController is removed (truck
//			leaves site or general clean up of the system) general inverse rules might mean that
//			the VTA is also deleted.  No GOOD!  So this is the safe way
//			par 24180.
//
//
vars
	ta : CM_TerminalArea;
	yardController : CM_YardController;
begin
	if self.vehicle &lt;&gt; null then
		if self.vehicle.myPrimaryActualLocation &lt;&gt; null then
			yardController := self.vehicle.myPrimaryActualLocation;
			ta := yardController.myTerminalArea;
		endif;
	endif;

	return ta;
end;
</source>
        <ReturnType type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="getTiTxnTypesForMoveFromToNULL" id="9f7376b7-da48-4345-84d1-e218cdf2d371">
        <source>getTiTxnTypesForMoveFromToNULL(_moveController: CMIF_MoveController; _intArray: IntegerArray input);
/*
Created:     06 January 2004 by cnwrs2

Purpose:     

Changed On	By		TFS		Reason
----------	------	-----	--------------------------------------------
29 Oct 2019	jlgdi1	46578	Added condition check for 'Receive Road Cancelled' transaction and 
							Road Ops Delete Current Entry option not to create Road Release transaction.
							If both are true, do not add Road Release constant
							
20 Sep 2025	navcs2	MTN-35846	Dev - Returning of Lot Based Cargo | PortSchema Changes
*/
vars
	tmpTI	: CM_TrackedItem;
	
begin
	inheritMethod(_moveController, _intArray);
	// processing road exit
	
	tmpTI := _moveController.myTrackedItem;
	
	if _moveController.moveContext = CMIF_MoveController.CONTEXT_UPDATED_VEHICLEVISIT then		// 20 Sep 2025	navcs2	MTN-35846
		_intArray.add(TRANS_TYPE_CARGOADDEDTOVVR);												// 20 Sep 2025	navcs2	MTN-35846
	endif;																						// 20 Sep 2025	navcs2	MTN-35846

	app.addTiTxnSubTerminalRelease(tmpTI, TI_TRANSMODE_ROAD, _intArray);		// CCMS 1875.  	// PAR 20706 (swap order)
	
	if not (self.hasReceiveRoadCancelledTrans(tmpTI) and self.isSetNotToCreateRoadRelease()) then 
		if tmpTI.isAnInterTerminalRelease() then
			_intArray.add(TRANS_TYPE_REL_ROAD_INTER_TERM);
		else
			_intArray.add(TRANS_TYPE_REL_ROAD);
		endif;
	endif;
	
	// TFS 42277 ALL CM_Release transaction create a storage transaction, so this is not needed. 	_intArray.add(TRANS_TYPE_STORAGE);
end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController"/>
        <Parameter name="_intArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getTiTxnTypesForMoveToFromNULL" id="5d1fff67-ab46-41a2-8ced-160ad738621b">
        <source>getTiTxnTypesForMoveToFromNULL(_moveController: CMIF_MoveController; _intArray: IntegerArray input);
//--------------------------------------------------
// Created:	05 October 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpTI	: CM_TrackedItem;

begin
	inheritMethod(_moveController, _intArray);

	tmpTI := _moveController.myTrackedItem;
	
	//Cargo comming into yard from Road
	if tmpTI.isAnInterTerminalReceival() then
		_intArray.add(TRANS_TYPE_REC_ROAD_INTER_TERM);
	else
		_intArray.add(TRANS_TYPE_REC_ROAD);
	endif;
	
	app.addTiTxnSubTerminalReceive(tmpTI, TI_TRANSMODE_ROAD, _intArray);		// CCMS 1875.
end;</source>
        <Parameter name="_moveController" type="CMIF_MoveController"/>
        <Parameter name="_intArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
