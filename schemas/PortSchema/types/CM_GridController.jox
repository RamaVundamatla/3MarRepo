    <JadeMethod name="testAreYouNextToMe" id="d4aa313b-2d99-4a75-ad6a-225dd4cddf25">
        <source>testAreYouNextToMe(pController : CM_GridController) : Boolean;
// ---------------------------------------------------------------------------
// Created:		December 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	myGR, itsGR	: CM_GridRow;
	myGC, itsGC	: CM_GridColumn;
	myRow, myCol, itsRow, itsCol,rowSize, colSize : Integer;
	myGA : CM_GridArea;
begin
	myGA := self.myGridArea;

	myGR := self.myGridRow;
	myGC	:= self.myGridColumn;
	itsGR := pController.myGridRow;
	itsGC	:= pController.myGridColumn;
	
	myRow := myGA.allGridRows.indexOf(myGR);
	myCol := myGA.allGridColumns.indexOf(myGC);

	itsRow := myGA.allGridRows.indexOf(itsGR);
	itsCol := myGA.allGridColumns.indexOf(itsGC);
	
	if (itsRow = (myRow + 1)) or (itsRow = (myRow - 1))  then
		if itsCol = myCol then
			return true;
		else
			return false;
		endif;
	elseif itsRow = myRow then
		if (itsCol = (myCol + 1)) or (itsCol = (myCol - 1))  then
			return true;
		else
			return false;
		endif;
	endif;

	return false;

end;</source>
        <Parameter name="pController" type="CM_GridController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testAreYouNextToMeOLD" id="ed380cc4-e220-497f-a321-b6a381f8e721">
        <source>testAreYouNextToMeOLD(pController : CM_LocationsController) : Boolean;
// ---------------------------------------------------------------------------
// Created:		December  2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lGridRow	: CM_GridRow;
	lGridColumn	: CM_GridColumn;
	myRow, myCol, rowSize, colSize : Integer;
begin
	lGridRow := self.myGridRow;
	lGridColumn	:= self.myGridColumn;
	myCol := lGridColumn.column;
	myRow := lGridRow.row;
	colSize := lGridRow.allControllersByColumn.size;
	rowSize := lGridColumn.allControllersByRow.size;
	
	if myCol &gt; 1 then
		if lGridRow.allControllersByColumn[myCol - 1] = pController then
			return true;
		endif;
	endif;
	
	if myCol &lt; colSize then
		if lGridRow.allControllersByColumn[myCol + 1] = pController then
			return true;
		endif;
	endif;
	
	if myRow &gt; 1 then
		if lGridColumn.allControllersByRow[myRow - 1] = pController then
			return true;
		endif;
	endif;
	
	if myRow &lt; rowSize then
		if lGridColumn.allControllersByRow[myRow + 1] = pController then
			return true;
		endif;
	endif;

	return false;

end;</source>
        <Parameter name="pController" type="CM_LocationsController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testAutoPlanRequestYA" id="99fa431a-7842-45cd-b39d-212ca9c68d09">
        <source>testAutoPlanRequestYA(_yaAgent : CM_YAAutoplanAgent input) : Boolean;
//Request based testing only, looking for SOURCE of TI's
vars

	ti 			: CM_TrackedItem;
	tiId		: String;
	wle			: CM_WorkListEntry;
	fMove		: CM_FutureMove;
	testIds		: Boolean;
	cmifRequest	: CMIF_YARequest;
	bulkRelease	: CM_BulkRelease;
	assignedTIs : CM_TISet;
begin

	if self.allTrackedItems.isEmpty() then
		_yaAgent.addLogEntry(AP_Log_YA_Default,'Location has no tracked items', true);
		return false;
	endif;

	if not self.allQueuedFutureMoves.isEmpty() and
	// 23023 doesn't apply to release by type, for output
	   not _yaAgent.forOutput then
		// We have boxes queued here so they will probably
		// overstow the box we want.
		_yaAgent.addLogEntry(AP_Log_YA_Default,'Location (' &amp; self.getID() &amp; ') has items queued to it already. May cause overstow', true);
		return false;
	endif;
	
	cmifRequest := _yaAgent.myCurrentCMIFYAAutoPlan.CMIF_YARequest;	
	
	if cmifRequest.ids.isEmpty() then
	else
		_yaAgent.addLogEntry(AP_Log_YA_Default,"Identification masks to test on Request.", true);
		testIds := true;
	endif;
	
	if cmifRequest.isDeliveryRequest then
		bulkRelease := cmifRequest.myDeliveryRequest.myOriginatingBulkRelease;
	endif;
	
	if _yaAgent.forOutput and
	   _yaAgent.fillOptionOut = YAFillOption_BestPick then
	endif;
	
	
	//cnwrd1 par 31623 we may be working a release item that hasnt been manually assigned so we do not want to exclude non assigned ti's as we normally would 30.5.2013
	create assignedTIs transient;	
	if bulkRelease &lt;&gt; null and not bulkRelease.allTrackedItemsAssigned.isEmpty then
		bulkRelease.getAvailableAssignedTis( assignedTIs, cmifRequest.myDeliveryRequest );	//24 Apr 2020	NDL	TFS 49095 // ### TFS 52721 16NOV2022 NAVAB1
	/*	foreach ti in bulkRelease.allTrackedItemsAssigned do
			if ti.myPrimaryActualLocation.isVehicle 
			or ti.myPrimaryActualLocation.isMachineController
			or ti.myPrimaryActualLocation.isYardInterchangeAreaLocation then
				continue;
			endif;				
			assignedTIs.add(ti);			
		endforeach; */
	endif;
	
	foreach ti in self.allTrackedItems reversed do : outerLoop
		if _yaAgent.myCurrentCMIFYAAutoPlan.allKeepTrackedTis.includes(ti) then
			_yaAgent.addLogEntry(AP_Log_YA_Default,'Item ' &amp; ti.id &amp; ' has already been allocated.', true);
			continue;
		endif;
		
		if cmifRequest.myDeliveryRequest &lt;&gt; null // PAR 17260
		and cmifRequest.myDeliveryRequest.allTrackedItemsAllocated.includes(ti) then
			_yaAgent.addLogEntry(AP_Log_YA_Default,'Item (' &amp; ti.id &amp; ') is already part of current request', true);
			continue;
		endif;
		
		if testIds then
			tiId := ti.id.trimRight;
			if cmifRequest.ids.compareIds(tiId) then
				_yaAgent.addLogEntry(AP_Log_YA_Default,"Identification Masking, " &amp; tiId  &amp; " passed mask test, testing potentially good Item..", true);
			else
				continue;
			endif;
		endif;
		
		if bulkRelease &lt;&gt; null then
			if not assignedTIs.isEmpty then //cnwrd1 par 31623
				if (not assignedTIs.includes(ti)) then 
					_yaAgent.addLogEntry(AP_Log_YA_Default,'Item ' &amp; ti.id  &amp; ' is not allocated to bulk release', true);
					return false;
				endif;	
			endif;
			
			// Par 12270
			if (not ti.allBulkReleasesAssigned.isEmpty()) and (not ti.allBulkReleasesAssigned.includes(bulkRelease)) then
			//	if (not ti.allBulkReleasesAssigned.includes(bulkRelease)) then
				_yaAgent.addLogEntry(AP_Log_YA_Default,'Item ' &amp; ti.id  &amp; ' is assigned to another bulk release', true);
				return false;
			endif;
		endif;
					
		// Ok to queue under me if on the same job.
		if not ti.allQueuedFutureMoves.isEmpty() then
			foreach fMove in ti.allQueuedFutureMoves do
				wle := fMove.myWorkListEntry;
				if wle = null then
					_yaAgent.addLogEntry(AP_Log_YA_Default,'Could not determine wle from queued move skipping..', true);
					return false;
				elseif wle.job = _yaAgent.myCurrentJob then
					_yaAgent.addLogEntry(AP_Log_YA_Default,'Item (' &amp; ti.id &amp; ') is already queued to job, skipping ... ' &amp; wle.job.jobId, true);
					continue outerLoop;
				else
					_yaAgent.addLogEntry(AP_Log_YA_Default,'Item (' &amp; ti.id &amp; ') is queued to a different job stopping...', true);
					return false;
				endif;
			endforeach;
		else
			if ti.releaseRequest &lt;&gt; null then
			_yaAgent.addLogEntry(AP_Log_YA_Default,'Item (' &amp; ti.id &amp; ') is allocated to another request ', true);
			return false;
			endif;
		endif;
			

		// Back end of forty. Not queued so can't continue.
		if not ti.myPrimaryActualLocation = self then
			_yaAgent.addLogEntry(AP_Log_YA_Default,'Location (' &amp; self.getID() &amp; ') has back end of forty foot ' &amp; ti.id, true);
			return false;
		endif;
		
		// If we get here we must be the front end of a box that
		// hasn't been queued.
		if ti.testAutoPlanRequestYA(_yaAgent) then
		// 25/02/2010	cnwjre1
		// from CCMS 1101 best-pick allocation handling - if this TI is not over-stowed, use it and exit
		//	otherwise save the least-overstowed TI in the agent and carry on
			if _yaAgent.forOutput and
			   _yaAgent.fillOptionOut = YAFillOption_BestPick then
				/*
				allOverstowedTIs.clear;
				sideAccessDirection:=null;
				ti.getAllOverstowedTIs(allOverstowedTIs,true,sideAccessDirection,null);
				thisOverstow := allOverstowedTIs.size;*/
				// if zero, drop into the code below, otherwise store in the agent and continue
				//jlier1 MTN-35637 17/9/25
				if ti.numOverstows &gt; 0  then
					if  ti.numOverstows &lt; _yaAgent.lastOverstowLevel then
						_yaAgent.bestPickOverstowedTI := ti;
						_yaAgent.lastOverstowLevel :=  ti.numOverstows;
						_yaAgent.addLogEntry(AP_Log_YA_Default,'Least overstowed so far (' &amp; ti.id &amp; ') at ' &amp;  ti.numOverstows.String, true);
					endif;
					continue;
				endif;
			endif;
			_yaAgent.addLocationToAgent(self, CM_YAAutoplanAgent.Locations_Found);
			_yaAgent.myCurrentCMIFYAAutoPlan.allFoundTis.add(ti);
			_yaAgent.myCurrentCMIFYAAutoPlan.allKeepTrackedTis.add(ti);
			_yaAgent.addLogEntry(AP_Log_YA_Default,'Located item (' &amp; ti.id &amp; ')', false);	// 23676 for logging, was 'true'
			return true;
		else
			// best-pick and no match, continue
			if _yaAgent.forOutput and
			   _yaAgent.fillOptionOut = YAFillOption_BestPick then
			   continue;
			endif;
		endif;
		
		// Can't get here with out failing.
		return false;
	endforeach;
	
	return false;
epilog
	delete assignedTIs;
end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testForFreeSpaceYA" id="ac63386c-688b-437d-932f-a5d40da3c627">
        <source>testForFreeSpaceYA(_yaAgent : CM_YAAutoplanAgent input) : Integer;

// Created by cnwdvb1 on 08 May 2006
// 02/02/2011 cnwmh5 #26129 - Code has been moved up from CM_StackController::testForFreeSpaceYA
vars

	totalInThisStack,
	totalQueueInThisStack,
	totalPlanInThisStack,
	result,
	maxHeight				: Integer;
	
begin

	if not self.isSuitableForTIYA(_yaAgent) then
		return 0;
	endif;
	
	maxHeight := self.getMaxStackingHeight() * 2;
	
	totalInThisStack		:= self.getStackHeightOfTIs(REAL_MODE, null);
	totalQueueInThisStack	:= self.getStackHeightOfTIs(QUEUE_MODE, null);
	totalPlanInThisStack	:= self.getStackHeightOfTIs(PLANNING_MODE, null);
	
	result := (maxHeight - (totalInThisStack + totalQueueInThisStack + totalPlanInThisStack)).max(0); 
	
	if result = 0 then
		return 0;
	endif;
	
	return (result / 2).Integer;

end;
/*
vars

begin
	return 100;
end;
*/</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="testForOverstowYA" id="1384be16-bd51-4dab-9143-e72104512b11">
        <source>testForOverstowYA(_yaAgent : CM_YAAutoplanAgent input; _gridObject : CM_GridObject) : Boolean;
// -------------------------------------------
// Created 15 September 2005 by cnwdvb1
// -------------------------------------------
vars

	cell	: CM_YALocationCell;
		
begin

	_yaAgent.addLogEntry(AP_Log_YA_Default,'Testing location ' &amp; self.getID(), true);
	
	if not self.testLocationYA(_yaAgent, true) then
		return false;
	endif;

	foreach cell in self.allYAYardLocationCells discreteLock do
		if cell.testCellSuitabilityForTi(_yaAgent, null) then
		
			if cell.height = 1 then
				// Found a ground position.  We want to try and put o/stow box
				// in a ground position if possible.
				_yaAgent.addLocationToAgent(self, CM_YAAutoplanAgent.Locations_Found);
				return true;
			else
				// Non-grounded position.  Still ok to use as last resort
				_yaAgent.addLocationToAgent(self, YAOverlap_LastResort);
				return false;
			endif;

			/*
			RJS 13 Jan 2010.  Change from below to make easier to read
			if cell.height &lt;&gt; 1 then
				// Not a ground position.  We want to try and put o/stow box
				// in a ground position if possible.
				_yaAgent.addLocationToAgent(self, YAOverlap_LastResort);
				return false;
			else
				_yaAgent.addLocationToAgent(self, CM_YAAutoplanAgent.Locations_Found);
				return true;
			endif;
			*/
		endif;
	endforeach;
	
	return false;


end;</source>
        <Parameter name="_yaAgent" type="CM_YAAutoplanAgent" usage="input"/>
        <Parameter name="_gridObject" type="CM_GridObject"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="testHaveIGotA40" id="8e45863b-c9a0-481d-baeb-5df7f94351cf">
        <source>testHaveIGotA40(pSourceCol : Integer; p40InFront,p40SameOrdColAs20 : Boolean output );
// ---------------------------------------------------------------------------
// Created:		December  2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	myTI	: CM_TrackedItem;
	lMyRow, lMyCol : Integer;
begin
	p40InFront := false;
	p40SameOrdColAs20 := false;
	if self.numTIs &lt; 1 then 
		return;
	endif;

	self.getMyRowColOrdinal(lMyRow, lMyCol);
	// look at the TIs in front of me, are any 40s?
	foreach myTI in self.allTrackedItems do : thisLoop
		if myTI.getNumberOfControllers(REAL_MODE) &gt; 1 then // is a 40
			p40InFront := true;
			
			// if the source is a 20 and there is a 40 in the way, the 20 is either under the left or the right hand side of the 40
			if lMyCol = pSourceCol then
				p40SameOrdColAs20 := true;
			else
				p40SameOrdColAs20 := false;
			endif;
			break thisLoop;
		endif;
	endforeach;

end;</source>
        <Parameter name="pSourceCol" type="Integer"/>
        <Parameter name="p40InFront" type="Boolean" usage="output"/>
        <Parameter name="p40SameOrdColAs20" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="testHaveIGotA40FrontEnd" id="bacb8ec1-3435-4899-bed6-fb63ad132543">
        <source>testHaveIGotA40FrontEnd(_front : Boolean) : Boolean;
// ---------------------------------------------------------------------------
// Created:		August 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	myTI	: CM_TrackedItem;
	lMyRow, lMyCol : Integer;
begin
	foreach myTI in self.allTrackedItems do : thisLoop
		if _front and myTI.myPrimaryActualLocation = self  then
			if myTI.isAttributeTrue(TI_Attrib_IsForty) then
				return true;
			endif;
		endif;
		if not _front and myTI.myPrimaryActualLocation &lt;&gt; self  then
			if myTI.isAttributeTrue(TI_Attrib_IsForty) then
				return true;
			endif;
		endif;
	endforeach;

end;</source>
        <Parameter name="_front" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
