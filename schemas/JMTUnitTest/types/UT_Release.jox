		if index &lt; 5 then
			ti := self.addContainer( BaseTiId &amp; index.String, oper, "4230", "MT", TI_IMEX_STATUS_STORAGE );
		else
			ti := self.addContainer( BaseTiId &amp; index.String, oper, "2200", "MT", TI_IMEX_STATUS_STORAGE );
		endif;
		self.move(ti, bs);
	endforeach;
	
