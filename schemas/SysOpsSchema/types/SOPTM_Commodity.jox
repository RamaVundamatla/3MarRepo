    <JadeMethod name="setControlsForAddEdit" id="12dfaddf-2f80-47ba-8f44-544684171548">
        <updating/>
        <source>setControlsForAddEdit() updating;

vars
	theForm : SOP_TableMaintForm;

begin
  
  	theForm := self.myForm;
	
//	self.myAssistant.comboBoxCommodityGroup(cmbCommodityGrp, pCommodity.myCommodityGroup);

	if theForm.mode = theForm.Mode_Add then
		theForm.tblInput1.clearValues;
		theForm.cmbCommodityGrp.setObject(null);
		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.setValueByName(ETRow_Colour, White.String);
		theForm.tblInput1.setFocus;
		theForm.tblInput1.moveFirst();	
		theForm.tblInput1.gotFocus(theForm.tblInput1);	// sets case etc.
		theForm.mulSelect1.setSelected(null);		//PAR 19704. CCMS 1080 May 2009 cnwvu1
		
		theForm.cmbCommodityGrp.setObject(null);
	else
		// refresh the data from the newly created proxy
		self.showThumbnail(theForm.myProxyObject.CM_Commodity);
		// cannot update code

		theForm.tblInput1.enableRowByName(ETRow_Code);
		theForm.tblInput1.enableRowByName(ETRow_Description);
		theForm.tblInput1.enableRowByName(ETRow_MyCommodityGroup);
		
		theForm.mulSelect1.setSelected(theForm.myProxyObject.CM_Commodity.allCargoTypes);	//PAR 19704. CCMS 1080 May 2009 cnwvu1
		
	endif;

	theForm.tblInput1.userInputEnabled := true;
	
	self.enableMulSelect1Contents();	//PAR 19704. CCMS 1080 May 2009 cnwvu1
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="348b34b9-243a-494f-accd-8e2e2b2190d8">
        <updating/>
        <source>setCtrlsForView() updating;

vars
	theForm : SOP_TableMaintForm;

begin
	//cnwmc5 - 17 Oct 2013 - PAR 32622
