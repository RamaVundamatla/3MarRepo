    <JadeMethod name="tblFlashpoints_displayRow" id="871eb1f0-3a1f-46f3-8757-0e7d05300c53">
        <controlMethod name="Table::displayRow"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblFlashpoints_displayRow(table: Table input; theSheet: Integer; obj: Object; theRow: Integer; bcontinue: Boolean io):String updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/12/2016	cnwdap1		Initial creation TFS 2844 STWR Hazardous Details Enhancements
//
vars
	selected : Boolean;
	
begin
	selected := table.CMUI_ListTable.allSelectedObjects.includes(obj);
	if selected then 
		return TableCheckBox_Selected &amp; Tab &amp; obj.CM_HazTempRange.getDisplayDetails(false);
	else
		return TableCheckBox_NotSelected &amp; Tab &amp; obj.CM_HazTempRange.getDisplayDetails(false);
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="theSheet" type="Integer"/>
        <Parameter name="obj" type="Object"/>
        <Parameter name="theRow" type="Integer"/>
        <Parameter name="bcontinue" type="Boolean" usage="io"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="tblFlashpoints_lostFocus" id="99a73e9f-731d-4bed-bf92-299a41e0cf77">
        <controlMethod name="Table::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblFlashpoints_lostFocus(table: CMUI_ListTable input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/12/2016	cnwdap1		Initial creation TFS 2844 STWR Hazardous Details Enhancements
//
vars
	obj : Object;
	hazTemp : CM_HazTempRange;
	str : String;
	row : Integer;

begin
	foreach obj in table.allSelectedObjects do
		hazTemp := obj.CM_HazTempRange;
		if str = null then
			str := hazTemp.getDisplayDetails(false);
		else
			str := str &amp; Comma &amp; Space &amp; hazTemp.getDisplayDetails(false);
		endif;
	endforeach;
	self.tblOther.setValueByName(ETRow_Flashpoint, str);
	row := self.tblOther.getRowByControlName(self.tblFlashpoints.name);
	if row &gt; self.tblOther.fixedRows and row &lt;= self.tblOther.rows then
		self.tblOther.accessRow(row).height := self.tblOther.accessRow(1).height;
	endif;
epilog

end;</source>
        <Parameter name="table" type="CMUI_ListTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblOther_cellInputReady" id="e889a881-5639-4e6d-b5e3-ee5697bb625a">
        <controlMethod name="CM_EntryTable::cellInputReady"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblOther_cellInputReady(table: Table input; inputControl: Control input; cleft: Real io; ctop: Real io; cwidth: Real io; cheight: Real io) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19 December 2016	cnwdap1		Initial creation PAR #
//
vars
	saveHeight : Real;

begin
	if inputControl = self.tblFlashpoints then
		self.myAssistant.listTableCellInputReady(table.CM_BaseTable, cheight, saveHeight);
		table.accessRow(table.CM_EntryTable.getRowByControlName(self.tblFlashpoints.name)).height := 100;
	elseif inputControl = self.tblPackGroups then
		self.myAssistant.listTableCellInputReady(table.CM_BaseTable, cheight, saveHeight);
		table.accessRow(table.CM_EntryTable.getRowByControlName(self.tblPackGroups.name)).height := 80;
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="inputControl" type="Control" usage="input"/>
        <Parameter name="cleft" type="Real" usage="io"/>
        <Parameter name="ctop" type="Real" usage="io"/>
        <Parameter name="cwidth" type="Real" usage="io"/>
        <Parameter name="cheight" type="Real" usage="io"/>
    </JadeMethod>
