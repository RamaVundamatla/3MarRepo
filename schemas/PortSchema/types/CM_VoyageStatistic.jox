<Class name="CM_VoyageStatistic" id="0fb93905-4d4b-4425-a26a-0eaa6c6208d7">
    <superclass name="CM_Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="statistic"/>
    <PrimAttribute name="code" id="2bfb2217-7e8e-41aa-be2d-64b1d1cf6072">
        <length>51</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="group" id="5dcb6196-11ae-44aa-81c2-3f1460403f7f">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="groupDescription" id="dd5b4ee9-dd04-425e-a553-297e52981ed3">
        <length>51</length>
        <embedded/>
        <virtual/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="monthYear" id="dfff4c2b-b28d-48e8-a054-df18edfc5ca9">
        <embedded/>
        <type name="Date"/>
        <access>readonly</access>
    </PrimAttribute>
    <ExplicitInverseRef name="myTerminal" id="c58cf075-c7dc-426d-98d4-e50e50a01fc0">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_Terminal"/>
        <access>readonly</access>
        <Inverse name="CM_Terminal::allVoyageStatistics"/>
    </ExplicitInverseRef>
    <PrimAttribute name="unitsOfMeasure" id="8b837426-bf51-4a09-ba6a-db232b7a7751">
        <length>31</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="value" id="7474b6d8-97d7-4901-854d-378446c9101e">
        <embedded/>
        <type name="Real"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="getDisplayStringForAttribute" id="e0069f2f-e2ea-4248-bd01-823de6ab0b9f">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------
// Created:	30 November 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpMonth,
	tmpYear : String;
begin

	if _attrName = ETRow_MyTerminal then
		return self.myTerminal.name;
	elseif _attrName = ETRow_MonthYear then
		tmpMonth := self.monthYear.monthName;
		tmpYear := self.monthYear.year.String;
		return tmpMonth &amp; ' ' &amp; tmpYear;

	elseif _attrName = ETRow_Value then
		return self.value.numberFormat;			
				
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="groupDescription" id="7e6a8243-2a6c-4ce6-b254-ce5442e69486">
        <methodInvocation>mapping</methodInvocation>
        <source>groupDescription(set: Boolean; _value: String io) mapping;
//--------------------------------------------------
// Created:	30 November 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if set then
		// set code here
		return;
	else
		// get code here
		_value := app.voyageStatGroupENumToString(self.group);
	endif;


end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isGroupTotal" id="2cb93692-81a3-4526-b816-2b5e78571519">
        <source>isGroupTotal() : Boolean;
//--------------------------------------------------
// Created:	30 November 2005 By: cnwgd1
//--------------------------------------------------
vars
	tmpGroup : Integer;
begin
	
	tmpGroup := self.group;
	
	if tmpGroup = VoyageStat_CargoUnits
	or tmpGroup = VoyageStat_CargoTons
	or tmpGroup = VoyageStat_ChargesTotal		
	or tmpGroup = VoyageStat_ResourcesTotal	
	or tmpGroup = VoyageStat_PassengersTotal
	or tmpGroup = VoyageStat_PassVesselCallTot
	or tmpGroup = VoyageStat_CargoVesCallTot
	or tmpGroup = VoyageStat_VesselCallTotal then
		return true;
	endif;
	
	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="set" id="d3d4464c-3466-4e8d-9aff-737224fb02b8">
        <updating/>
        <source>set(_code, _unitsOfMeasure : String; _group : Integer; _monthYear : Date; _terminal : CM_Terminal; _passport : CM_Passport input) updating;
//--------------------------------------------------
// Created:	29 November 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.code := _code;
	self.group := _group;
	self.monthYear := _monthYear;
	self.myTerminal := _terminal;
	self.unitsOfMeasure := _unitsOfMeasure;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_unitsOfMeasure" type="String"/>
        <Parameter name="_group" type="Integer"/>
        <Parameter name="_monthYear" type="Date"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateAddValue" id="74abfe1e-ba41-4685-9c1c-0f72b94bc850">
        <updating/>
        <source>updateAddValue(_value : Real) updating;
//--------------------------------------------------
// Created:	29 November 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.value := self.value + _value;
end;</source>
        <Parameter name="_value" type="Real"/>
    </JadeMethod>
</Class>
