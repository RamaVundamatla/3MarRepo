        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getValueForObject" id="dd80930e-2e86-49ae-baf1-c16cba745be7">
        <source>getValueForObject(_obj: Object; _op: CM_QueryOperator input): Time;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2012	cnwndl1	Initial creation	Par 29532

*/

vars

	meth : Method;

begin

	meth := _obj.class.getMethodInHTree( self.propertyName );
	if meth = null then
		return null;
	endif;
	
	return _obj.sendMsg(self.propertyName).Time;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
        <ReturnType type="Time"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="9c6654b3-23e5-439a-840c-2f640bb799fc">
        <source>translateToDisplayValue(_value: Any): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2012	cnwndl1	Initial creation	Par 29532

*/

vars

begin

	return _value.asStringJMT;
	
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
