vars

begin
	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblBays_click" id="4c3cc752-c07f-4aa8-ac89-6ef8b06cec6c">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblBays_click(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		24 September 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if table.row &gt; table.fixedRows then
		self.mnuInspectObject.userObject := table.accessRow(table.row).itemObject;
	else
		self.mnuInspectObject.userObject := null;
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblBays_contextMenu" id="4349f55d-19f3-4105-8a53-258c9f027fb5">
        <controlMethod name="Table::contextMenu"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblBays_contextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:		24 September 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 02/08/2011		cnwcs5	Tidy up when removing old KPI classes
vars
	obj 	: Object;
begin
	self.doTurnOffContextMenus();
	
	self.mnuZoomSub.visible 		:= false;
	self.mnuGridAreaContext.visible := true;
	self.mnuGridAreaContext.enabled := true;
	self.mnuInspectObject.visible 	:= (self.mnuInspectObject.userObject &lt;&gt; null and app.isAllowedToInspect());
	self.mnuColumnOrgan.visible 	:= true;
	self.mnuColumnOrgan.userObject	:= table;
	
	obj 	:= table.accessRow(table.row).itemObject.Object;
	
	if obj &lt;&gt; null and obj.isKindOf( CM_KPIVoyageEntity ) then
		self.mnuKPIContainers.visible := true;
	else
		self.mnuKPIContainers.visible := false;
	endif;

	return self.showContextMenu(mnuGridAreaContext, table, conwin, mouse, x, y);
	

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblDelays_click" id="2108463c-dbff-489e-a0b8-8f714f6e4b2c">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblDelays_click(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:		25 September 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	if table.row &gt; table.fixedRows then
