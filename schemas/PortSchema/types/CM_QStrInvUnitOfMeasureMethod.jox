    <JadeMethod name="setComboValues" id="101bef53-72cc-4d36-ab1d-b03953ca3d42">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who			Reason
08/02/2023	navvt20 TFS 56132 Task 56137: Jade - Invoice Line Selector - UOM
*/

vars
	invUOM : CM_InvoiceUnitOfMeasure;
	dict : CM_InvoiceUnitOfMeasureByCode;

begin
	_combo.clear;
	dict := app.myRoot.allInvoiceUnitOfMeasure;
	
	foreach invUOM in dict discreteLock do
		_combo.itemObject[_combo.addItem(invUOM.code &amp; Tab &amp; invUOM.description)] := invUOM;
	endforeach;
	
	if CM_QStringLookup.hasInstance(_queryOperator) then
		_combo.listObject := dict[_queryOperator.CM_QStringLookup.selectionValue];
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		_combo.listObject := dict[_queryOperator.CM_QStringLookupNotEqual.selectionValue];
	endif;

epilog

end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="81ff1aec-d999-42bf-9069-1e335458f8a0">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/02/2023	navvt20 TFS 56132 Task 56137: Jade - Invoice Line Selector - UOM
17 Feb 2023	navmv20 TFS 55626 Task 55688: Jade - Selector Query Contracts
*/

vars
	invUOM : CM_InvoiceUnitOfMeasure;
	invDict : CM_InvoiceUnitOfMeasureByCode;
	selectionValue, idx : Integer;
	array : ObjectArray;

begin
	invDict := app.myRoot.allInvoiceUnitOfMeasure;
	
	_tbl.rows := _tbl.fixedRows;
	array := _tbl.getPropertyValue("allSelectedObjects").ObjectArray;
	array.clear;
	
	foreach invUOM in invDict discreteLock do
		selectionValue := 0;
		//if _operator &lt;&gt; null and _operator.CM_QStringIsOneOf.allSelectionValues.includes(invUOM.code) then //17/02/2023 navmv20 TFS 55626 TASK 55688
		if _operator &lt;&gt; null and _operator.CM_QStringLookupIsOneOf.allSelectionValues.includes(invUOM.code) then //17/02/2023 navmv20 TFS 55626 TASK 55688
			selectionValue := 1;
			array.add(invUOM);
		endif;
		idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; invUOM.code &amp; " (" &amp; invUOM.description &amp; ")");
		_tbl.accessRow(idx).itemObject := invUOM;
	endforeach;

epilog

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="71dcdc04-5fb9-4bf0-9752-22fb0f5b615b">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/02/2023	navvt20 TFS 56132 Task 56137: Jade - Invoice Line Selector - UOM

*/

vars
	invUOM : CM_InvoiceUnitOfMeasure;
	str : String;
	numRows, idx : Integer;
	sa : StringArray;

begin
	create sa transient;
	
	numRows := _tbl.rows;
	foreach idx in _tbl.fixedRows + 1 to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			invUOM := _tbl.accessRow(idx).itemObject.CM_InvoiceUnitOfMeasure;
			sa.add(invUOM.code);
		endif;
	endforeach;
	
	_op.setSearchValue(sa);

epilog

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="b3fe47e4-91d2-4ef5-9300-5ac147a08f33">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/02/2023	navvt20 TFS 56132 Task 56137: Jade - Invoice Line Selector - UOM
*/

vars

begin
	if _value.isKindOf(CM_InvoiceUnitOfMeasure) then
		if _value &lt;&gt; null then
			return _value.CM_InvoiceUnitOfMeasure.code;
		else
			return null;
		endif;
	else
		return _value.String;
	endif;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="0e5ceed9-8c1d-4412-a539-309863603126">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/02/2023	navvt20 TFS 56132 Task 56137: Jade - Invoice Line Selector - UOM
*/

vars
	invalidObj : Boolean;
	object : CM_InvoiceUnitOfMeasure;
	returnVal : String;
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then
			return _value;
		endif;
		
		if _value.isKindOf(CM_InvoiceUnitOfMeasure) then
			object := _value.CM_InvoiceUnitOfMeasure;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.code;
	endif;
	
	return returnVal;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
