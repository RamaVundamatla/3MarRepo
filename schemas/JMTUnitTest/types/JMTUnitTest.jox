    <JadeMethod name="handleFileTruncatedRec" id="f5d868f1-0f02-4afd-95f3-5900e1a5f533">
        <source>handleFileTruncatedRec(_exc : Exception) : Integer;

/*

Purpose:		Handle Record truncated to maxRecordSize characters error

Date			Who		Reason
17/03/2015		cnwmh5	Initial creation

*/

vars
	returnVal				: Integer;
begin

	returnVal := Ex_Pass_Back;

	if _exc.errorCode = 5011 then
		returnVal := Ex_Resume_Next;	
	endif;

	return returnVal;
	
epilog

end;</source>
        <Parameter name="_exc" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleSpecificException" id="31911588-5ca1-46a8-bf44-02202f355a21">
        <source>handleSpecificException( _exception : Exception; _exceptionInteger : Integer; _caughtIt : Boolean output ) : Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 March 2021	navndl1	Initial creation	TFS 50942

*/

vars
	returnVal : Integer;
begin

	returnVal := Ex_Pass_Back;

	if _exception.errorCode = _exceptionInteger then
		_caughtIt := true;
		returnVal := Ex_Resume_Next;	
	endif;

	return returnVal;
	
epilog

end;</source>
        <Parameter name="_exception" type="Exception"/>
        <Parameter name="_exceptionInteger" type="Integer"/>
        <Parameter name="_caughtIt" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="handleXMLExceptions" id="45fa1d92-d933-4000-84eb-fa2d99ab6fd5">
        <source>handleXMLExceptions(_exception : Exception) : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
23 September 2011	cnwmh5	Initial creation

*/

vars
	returnVal				: Integer;
begin

	returnVal := Ex_Pass_Back;

	if _exception.errorCode = 8901 then
		returnVal := Ex_Resume_Next;	
	endif;

	return returnVal;
	
epilog

end;</source>
        <Parameter name="_exception" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
