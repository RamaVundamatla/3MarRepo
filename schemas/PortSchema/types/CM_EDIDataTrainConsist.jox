vars
begin
	return EDIDataType_TrainConsist;
epilog
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getEDIDataTypeChildren" id="f82d5765-7c39-4bf1-9c12-a984431625fa">
        <source>getEDIDataTypeChildren(_ediDataType: Integer; _childrenDataTypes: IntegerArray input);
//
// 27 Aug 2014	cnwrs1	Par 34702 - Add support for JMT XML 
//
// 15 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
//18 Dec 2023	jlirs1	TFS 59171 User Defined Transport Manifest 
vars

begin
	if (_ediDataType = EDIDataType_TrainConsist and
	   self.myTransportManifest &lt;&gt; null) then
		_childrenDataTypes.add(EDIDataType_Wagon);
		_childrenDataTypes.add(EDIDataType_Prenote);
	endif;
	if _ediDataType = EDIDataType_JMTInternal then
		_childrenDataTypes.add(EDIDataType_Train);
	elseif _ediDataType = EDIDataType_Train then
		_childrenDataTypes.add(EDIDataType_Wagon);
		_childrenDataTypes.add(EDIDataType_Prenote);
	elseif _ediDataType = EDIDataType_Wagon then
		_childrenDataTypes.add(EDIDataType_Prenote);
	elseif _ediDataType = EDIDataType_Prenote then
		_childrenDataTypes.add(EDIDataType_TISeal);
	endif;
end;
</source>
        <Parameter name="_ediDataType" type="Integer"/>
        <Parameter name="_childrenDataTypes" type="IntegerArray" usage="input"/>
    </JadeMethod>
