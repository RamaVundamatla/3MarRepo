        <source>getExtraInfoForObj(_obj: CM_Object; _dataContainer: CM_DataContainer);

/*

Purpose:			Get data for Info Table

Parameters:			

Return Value:		


Date		Who		Reason
25 May 2009	consw1	PAR 19710 - SFW1067 Rail Simplifications

*/

vars

begin
	_obj.getExtraInfoRail(self.optDirInTB.value, _dataContainer);
	_obj.CM_Object.getExtraInfo(_dataContainer);

