    <JadeMethod name="getPicture" id="5392c7ba-d4fc-4803-8e1e-05027f376396">
        <source>getPicture(): Binary;
/*
Purpose:			
Date				Who			Reason
NOV 2016		CNWAB1		Initial creation
*/


vars

	thePicture : Binary;
	
begin

	if not self.getTerminal().getConfig(ShowCargoPicture).Boolean then // PAR 21182
		return null;
	endif;
	
	thePicture := app.myRoot.getConfig(PicWellcarJMT).Binary;
	if thePicture = null then
		thePicture := app.myRoot.getConfig(PicWagon).Binary;
	endif;

	return thePicture;

epilog

end;</source>
        <ReturnType type="Binary"/>
    </JadeMethod>
    <JadeMethod name="getWellAtPosition" id="24940195-52d6-4f1d-951f-588057e89d2d">
        <source>getWellAtPosition( _lcPos : Integer ):CM_WellcarWellVisit;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 December 2014	cnwndl1	Initial creation	Par 35346 / CCMS 1408

*/

vars

	wc : CM_WellcarWagonController;

begin

	if _lcPos &gt; self.allLocationsControllersArray.size then
		return null;
	endif;

	wc := self.allLocationsControllersArray[_lcPos].CM_WellcarWagonController;

	return wc.myWellcarWellVisit;
		
epilog

end;</source>
        <Parameter name="_lcPos" type="Integer"/>
        <ReturnType type="CM_WellcarWellVisit"/>
    </JadeMethod>
