vars

begin
	inheritMethod();
	
	self.myForm.SOP_HMS_TableMaintForm.tblRoute.userInputEnabled := false;

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="60b9dc6d-1e8d-4df0-bced-fc7752d1c7be">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*
----------   ----------  --------------------------------------------------
Created:	19 October 2006 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	multi1Obj		: CMUI_MultiSelectGroupBox;
	theForm			: SOP_HMS_TableMaintForm;
begin

	inheritMethod();
	theForm := self.myForm.SOP_HMS_TableMaintForm;
	
	theForm.cmbHarbourRegion.automaticCellControl := true;
	theForm.cmbHarbourRegion.listCollection(app.myRoot.allHMSHarbourRegions, true, 0);
	
	theForm.tblRoute.visible := true;
	theForm.tblRoute.accessColumn(1).cellControl := theForm.cmbHarbourRegion;
	theForm.tblRoute.tabKey := J_key_Tab;
	theForm.fieldRouteSeg.visible := false;
		
end;

</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="86192f27-075a-42aa-9655-f2e250b95f54">
        <updating/>
        <source>showThumbnail(pObj: HMS_RouteTemplate) updating;
/*
----------   ----------  --------------------------------------------------
Created:	19 October 2006 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	tableObj		: CM_BaseTable;
	theForm 		: SOP_HMS_TableMaintForm;
	tmpHarbourReg	: HMS_HarbourRegion;
	invalidObject : Boolean;
begin

	on Exception do app.handleDeletedObject(exception, tmpHarbourReg, invalidObject); // TFS 2101 during testing
	
	theForm := self.myForm.SOP_HMS_TableMaintForm;
	theForm.tblInput1.clearValues;
	theForm.tblInput1.setTableFromObject(pObj, null);
	
	
	tableObj		:=	theForm.tblRoute;
	tableObj.rows	:=	tableObj.fixedRows;
		
	foreach tmpHarbourReg in pObj.allHarbourRegions do
		if tmpHarbourReg.canWaitHere or (app.myRoot.getSeaHarbourRegion = tmpHarbourReg) then
			tableObj.addItemObject(tmpHarbourReg, theForm.myAssistant.displayEntryHMSHarbourRegion(tmpHarbourReg));
		endif;
	endforeach;
	
	//theForm.mulSelect1.isMultipleSelectAllowed := true;
	//theForm.mulSelect1.setSelected(pObj.allHarbourRegions);
end;</source>
        <Parameter name="pObj" type="HMS_RouteTemplate"/>
    </JadeMethod>
</Class>
