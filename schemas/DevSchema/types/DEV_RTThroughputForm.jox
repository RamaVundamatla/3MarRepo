    <JadeMethod name="populateToDoTable" id="ce58e93c-19df-4432-9b3f-ee063d1de60c">
        <updating/>
        <source>populateToDoTable()updating;
//--------------------------------------------------
// Created:	19 July 2005 By: cnwgd1
//--------------------------------------------------
vars
	numRows,
	row : Integer;
	tmpDone,
	tmpSel,
	tmpDesc,
	tmpDT : String;
	tmpTI : CM_TrackedItem;
	tmpComplete : Boolean;
	task : CM_ToDoTaskDesc;
	toDoTask : CM_ToDoTask;
	user : CM_User;
	passport : CM_Passport;	
	object : Object;
	failedDAC  :CM_DataAccessController;
begin
	
	tmpTI := self.myCurrentTrackedItem;
	if tmpTI = null then
		return;
	endif;
	
	self.populateToDoTableForInit();
	
	if CM_Container.hasInstance(tmpTI) then
		self.cmbAvGrade.setObject(self.myRoot.allAvailabilityGrades[tmpTI.CM_Container.availabilityGrade]);   		
	else
		self.cmbAvGrade.setObject(null);
	endif;

	passport := app.myPassport;
	user := passport.myUser;
	
   	foreach toDoTask in tmpTI.allToDoTasksToDo do
		row := 2;
		tmpDT := tmpTI.getLastToDoTaskDate(toDoTask.toDoTaskDescCode).shortCurrentLocaleFormat();   	
		tmpDesc := toDoTask.toDoTaskDescShort.trimRight;
		tmpSel := '1';
		tmpDone := '0';
		
		task := toDoTask.getMyToDoTaskDesc();

		if task = null then
			continue;
		endif;

		if (not task.canUserAccessSelf(user, failedDAC,  passport)) then
			continue;
		endif;		

		if self.tblDataToDo.findObjectInRow(task, row) then
			self.tblDataToDo.accessCell(row, 1).text := task.description &amp; Tab &amp; tmpSel &amp; Tab &amp; tmpDone &amp; Tab &amp; tmpDT;		
			self.tblDataToDo.accessRow(row).itemObject := toDoTask;
		endif;
		
	endforeach;
	
	numRows := self.tblDataToDo.rows;
	row := 0;
	tmpSel := '0';
	tmpDone := '0';	
	foreach row in 2 to numRows do

		object := self.tblDataToDo.accessRow(row).itemObject;

		task :=	null;

		if (not CM_ToDoTaskDesc.hasInstance(object)) then
			continue;
		endif;

		task :=	object.CM_ToDoTaskDesc;
		
		tmpDT := tmpTI.getLastToDoTaskDate(task.code).shortCurrentLocaleFormat();  
		if tmpDT &lt;&gt; null then
			self.tblDataToDo.accessCell(row, 1).text := task.description &amp; Tab &amp; tmpSel &amp; Tab &amp; tmpDone &amp; Tab &amp; tmpDT;				
		endif;		
	endforeach;
	
					
end;</source>
    </JadeMethod>
    <JadeMethod name="populateToDoTableForInit" id="0eed3215-26b1-48e6-ab4e-46ced966be06">
        <source>populateToDoTableForInit();
//--------------------------------------------------
// Created:	19 July 2005 By: cnwgd1
//--------------------------------------------------
vars	
	user : CM_User;
	passport : CM_Passport;
	task : CM_ToDoTaskDesc;
	failedDAC  :CM_DataAccessController;
begin

	self.tblDataToDo.rows := self.tblDataToDo.fixedRows;
	
	passport := app.myPassport;
	user := passport.myUser;
	
	foreach task in self.myRoot.allToDoTaskDescriptions do
		if (not task.canUserAccessSelf(user, failedDAC, passport)) then
			continue;
		endif;
		self.tblDataToDo.addItemObject(task, task.description &amp; Tab &amp; '0' &amp; Tab &amp; '0' &amp; Tab &amp; '');	
	endforeach;							

end;</source>
    </JadeMethod>
</GUIClass>
