        <updating/>
        <source>trxUpdateEDITIStatus(_ediTI: CM_EDITrackedItem input; _newStatus: Integer; _passport: CM_Passport input) updating;
//----------------------------------------------------------------
//	Created:	09 June 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 26 Jul 2013	cnwcs5	CCMS POL 2221 / par 32094 - change of parameters
//09 Mar 2015	cnwrs1	Par 35827 - for error 88612 set the status to skip processing
vars
	
begin
	//	do not initialize activity for this action
	app.setContinueCMExceptions(true);	//par 26223 17 Nov 2010
	if _ediTI.status = _newStatus then 
		return;
	endif;	
	beginTransaction;
	
	app.myUtilityUA.utlUpdateEDITIStatus(_ediTI, _newStatus, _passport);

	app.cmsCommitTransaction(null);
	
epilog
	//should have committed by now - must be a problem
	if process.isInTransactionState then
		app.cmsAbortTransaction;
	endif;
	
end;</source>
