    <JadeMethod name="addJobTotalsPerCargoType" id="5b778c57-6e67-4c85-b218-75028a029145">
        <source>addJobTotalsPerCargoType(_allCargoTypeTotals : CM_AssociationDict input) protected;
/*

Purpose:		PAR 31756	

Parameters:			

Return Value:		

Date		Who		Reason
21 May 2013	cnwer1	Initial creation CCMS DPH 2274

*/

vars
	wle : CM_WorkListEntry;
	cargoTypeTotal : CM_Association;
	totalKey 	: String;
	ct : CM_CargoType;
begin

	foreach wle in self.allWorkListEntries do
		if wle.myTrackedItem  = null then
			ct := wle.myRequest.getAttrCargoType();
		else
			ct := wle.myTrackedItem.myCargoType;
		endif;
		
		
		if ct = null then
			continue;
		endif;
		totalKey:=ct.abbreviation;
		
		
		
		cargoTypeTotal:= _allCargoTypeTotals[totalKey.toUpper];
		if cargoTypeTotal = null then
			_allCargoTypeTotals.addAssociation(totalKey,wle.quantity.max(1));
		else
			cargoTypeTotal.setValue((cargoTypeTotal.asInteger + wle.quantity.max(1)).Integer);
		endif;
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_allCargoTypeTotals" type="CM_AssociationDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addStringForRoadOpsDDKey" id="39cc640c-26fa-4082-b2b8-37232dd07404">
        <source>addStringForRoadOpsDDKey( type : Integer; _strArray : StringArray input );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 December 2016	cnwndl1	Initial creation	TFS 2995 / 2638

*/

vars

	str : String;

begin

	str := null;
	
	if type = YACriteriaType_AvGrade then
		//CM_Container::availabilityGrade Integer
		//_dynaDict.addExternalKey(String, 6, false, false);
		str := self.getAVGrade[1:6];
	elseif type = YACriteriaType_BOL then
		//CM_TrackedItem::billOfLading
		//_dynaDict.addExternalKey(String, 30, false, false);
		if self.getBOL &lt;&gt; null then
			str := self.getBOL.number;
		endif;
	elseif type = YACriteriaType_BookingRef then
		//CM_TrackedItem::bookingReference
		//_dynaDict.addExternalKey(String, 30, false, false);
		if self.getBooking &lt;&gt; null then
			str := self.getBooking.bookingReference;
		endif;
	elseif type = YACriteriaType_CargoGroup then
		//CM_TrackedItem::getMyCargoGroupId
		//_dynaDict.addExternalKey(String, 20, false, false);
		str := self.getCargoGroupId;
	elseif type = YACriteriaType_CargoType then
		//CM_TrackedItem::myCargoType.abbreviation
		//_dynaDict.addExternalKey(String, 10, false, false);
		if self.getAttrCargoType &lt;&gt; null then
			str := self.getAttrCargoType.abbreviation;
		endif;
	elseif type = YACriteriaType_Colour then
		//CM_TrackedItem::getColour
		//_dynaDict.addExternalKey(String, 60, false, false);
		str := self.getColour[1:60];
	elseif type = YACriteriaType_Commodity then
		//CM_TrackedItem::commodity String
		//_dynaDict.addExternalKey(String, 4, false, false);
		str := self.getCommodity;
	elseif type = YACriteriaType_Consignee then
		//CM_TrackedItem::consignee String
		//_dynaDict.addExternalKey(String, 5, false, false);
		if self.getConsignee &lt;&gt; null then
			str := self.getConsignee.code;
		endif;
	elseif type = YACriteriaType_Consignor then
		//CM_TrackedItem::consignor String
		//_dynaDict.addExternalKey(String, 5, false, false);
		str := self.getConsignorCode;
	elseif type = YACriteriaType_DestinationPort then
		//CM_TrackedItem::destinationPort String
		//_dynaDict.addExternalKey(String, 5, false, false);
		str := self.getDestinationPort;
	elseif type = YACriteriaType_DischargePort then
		//CM_TrackedItem::dischargePort String
		//_dynaDict.addExternalKey(String, 5, false, false);
		str := self.getDischargePort;
	elseif type = YACriteriaType_FreightForward then
		//CM_TrackedItem::freightForwarderCode String
		//_dynaDict.addExternalKey(String, 5, false, false);
		str := self.freightForwarderCode;
	elseif type = YACriteriaType_Hazardous then
		//CM_TrackedItem::getHazardsFirstAsString String
		//_dynaDict.addExternalKey(String, 30, false, false);
		str := self.getAttrHazardousList[1:30];
	elseif type = YACriteriaType_ImexStatus then
		//CM_TrackedItem::getImExStatusStringDesc(false) String
		//_dynaDict.addExternalKey(String, 4, false, false);
		str := self.getImExStatusAbbrev();
	elseif type = YACriteriaType_ISO then
		//CM_TrackedItem::getISOType String
		//_dynaDict.addExternalKey(String, 4, false, false);
		str := self.getISOType;
	elseif type = YACriteriaType_LoadPort then
		//CM_TrackedItem::loadPort String
		//_dynaDict.addExternalKey(String, 5, false, false);
		str := self.getLoadPort;
	elseif type = YACriteriaType_Mark then
		//CM_TrackedItem::mark String
		//_dynaDict.addExternalKey(String, 30, false, false);
		str := self.getMark[1:30];
	elseif type = YACriteriaType_OperatorItem then
		//CM_TrackedItem::operatorCode String
		//_dynaDict.addExternalKey(String, 4, false, false);
		str := self.getOperatorCode;
	elseif type = YACriteriaType_Product then
		//CM_TrackedItem::myProduct::code String
		//_dynaDict.addExternalKey(String, 30, false, false);
		if self.getCargoSubType &lt;&gt; null then
			str := self.getCargoSubType.code;
		endif;
	elseif type = YACriteriaType_SpecialLift then
		//CM_TrackedItem::getSpecialLiftsCodes String
		//_dynaDict.addExternalKey(String, 30, false, false);
		str := self.getSpecialLiftStr[1:30];
	elseif type = YACriteriaType_SpecialStow then
		//CM_TrackedItem::getSpecialStowString String
		//_dynaDict.addExternalKey(String, 30, false, false);
		str := self.getSpecialStowStr[1:30];
	elseif type = YACriteriaType_Voyage then
		//CM_TrackedItem::voyageCode String
		//_dynaDict.addExternalKey(String, 20, false, false);
		if self.getVoyage &lt;&gt; null then
			str := self.getVoyage.code;	
		endif;
	endif;
			
	_strArray.add(str);

epilog

end;</source>
        <Parameter name="type" type="Integer"/>
        <Parameter name="_strArray" type="StringArray" usage="input"/>
    </JadeMethod>
