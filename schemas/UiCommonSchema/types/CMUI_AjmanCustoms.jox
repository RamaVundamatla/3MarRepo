	self.allLabelsArray.add( self.lblO );	// Field 15
	self.allLabelsArray.add( self.lblP );	// Field 14
	self.allLabelsArray.add( self.lblQ );	// Field 20
	self.allLabelsArray.add( self.lblR );	// Field 21
	self.allLabelsArray.add( self.lblS );	// Field 31
	self.allLabelsArray.add( self.lblT );	// Field 30
	self.allLabelsArray.add( self.lblU );	// Field 29
	self.allLabelsArray.add( self.lblV );	// Field 28
	self.allLabelsArray.add( self.lblW );	// Field 27
	self.allLabelsArray.add( self.lblX );	// Field 26
	self.allLabelsArray.add( self.lblY );	// Field 25
	self.allLabelsArray.add( self.lblZ );	// Field 24
	self.allLabelsArray.add( self.lblAA );	// Field 23
	self.allLabelsArray.add( self.lblAB );	// Field 22
	self.allLabelsArray.add( self.lblAC );	// Field 44
	self.allLabelsArray.add( self.lblAD );	// Field 43
	self.allLabelsArray.add( self.lblAE );	// Field 42
	self.allLabelsArray.add( self.lblAF );	// Field 37
	self.allLabelsArray.add( self.lblAG );	// Field 36
	self.allLabelsArray.add( self.lblAH );	// Field 35
	self.allLabelsArray.add( self.lblAI );	// Field 34
	self.allLabelsArray.add( self.lblAJ );	// Field 33
	self.allLabelsArray.add( self.lblAK );	// Field 32
	self.allLabelsArray.add( self.lblAL );	// Field 41
	self.allLabelsArray.add( self.lblAM );	// Field 40
	self.allLabelsArray.add( self.lblAN );	// Field 56
	self.allLabelsArray.add( self.lblAO );	// Field 57
	self.allLabelsArray.add( self.lblAP );	// Field 58
	self.allLabelsArray.add( self.lblAQ );	// Field 59
	self.allLabelsArray.add( self.lblAR );	// Field 60
	self.allLabelsArray.add( self.lblAS );	// Field 61
	self.allLabelsArray.add( self.lblAT );	// Field 62
	self.allLabelsArray.add( self.lblAU );	// Field 63
	self.allLabelsArray.add( self.lblAV );	// Field 64
	self.allLabelsArray.add( self.lblAW );	// Field 65
	self.allLabelsArray.add( self.lblAX );	// Field 66
	self.allLabelsArray.add( self.lblAY );	// Field 67
	self.allLabelsArray.add( self.lblAZ );	// Field 68
	self.allLabelsArray.add( self.lblBA );	// Field 69
	self.allLabelsArray.add( self.lblBB );	// Field 70
	self.allLabelsArray.add( self.lblBC );	// Field 71
	self.allLabelsArray.add( self.lblBD );	// Field 72
	self.allLabelsArray.add( self.lblBE );	// Field 38
	self.allLabelsArray.add( self.lblBF );	// Field 39
	self.allLabelsArray.add( self.lblBG );	// Field 50
	self.allLabelsArray.add( self.lblBH );	// Field 51
	self.allLabelsArray.add( self.lblBI );	// Field 52
	self.allLabelsArray.add( self.lblBJ );	// Field 53
	self.allLabelsArray.add( self.lblBK );	// Field 54
	self.allLabelsArray.add( self.lblBL );	// Field 55
	self.allLabelsArray.add( self.lblBM );	// Field 45
	self.allLabelsArray.add( self.lblBN );	// Field 46
	self.allLabelsArray.add( self.lblBO );	// Field 47
	self.allLabelsArray.add( self.lblBP );	// Field 48
	self.allLabelsArray.add( self.lblBQ );	// Field 49
	self.allLabelsArray.add( self.lblBR );	// Field Page No
	self.allLabelsArray.add( self.lblBS );	// Field 19
	self.allLabelsArray.add( self.lblBT );	// Field 17
	self.allLabelsArray.add( self.lblBU );	// Field 18
	self.allLabelsArray.add( self.lblBV );	//ticket no
	
	self.itemLabelArray.add( self.lblAB );	// Field 22
	//self.itemLabelArray.add( self.lblAA );	// Field 23	//08 Aug 2013	NDL	Par 32305 - No longer a mutli line label
	self.itemLabelArray.add( self.lblZ );	// Field 24
	self.itemLabelArray.add( self.lblY );	// Field 25
	self.itemLabelArray.add( self.lblX );	// Field 26
	self.itemLabelArray.add( self.lblW );	// Field 27
	self.itemLabelArray.add( self.lblV );	// Field 28
	self.itemLabelArray.add( self.lblU );	// Field 29
	self.itemLabelArray.add( self.lblT );	// Field 30
	self.itemLabelArray.add( self.lblS );	// Field 31
	self.itemLabelArray.add( self.lblAK );	// Field 32
	self.itemLabelArray.add( self.lblAJ );	// Field 33
	self.itemLabelArray.add( self.lblAI );	// Field 34
	self.itemLabelArray.add( self.lblAH );	// Field 35
	self.itemLabelArray.add( self.lblAG );	// Field 36
	self.itemLabelArray.add( self.lblAF );	// Field 37	
	self.itemLabelArray.add( self.lblAM );	// Field 40
	self.itemLabelArray.add( self.lblAL );	// Field 41
	self.itemLabelArray.add( self.lblAE );	// Field 42
	self.itemLabelArray.add( self.lblAD );	// Field 43
	self.itemLabelArray.add( self.lblAC );	// Field 44
	
	foreach obj in self.allLabelsArray do
		label := obj.CMUI_Label;
		
		if label = self.lblD	// Field 4
		or label = self.lblS	// Field 31
		or label = self.lblU	// Field 29
		or label = self.lblV	// Field 28
		or label = self.lblW	// Field 27
		then
			label.alignment := Label.Alignment_Right_Top;
		elseif label = self.lblBR	// Page Number
		or label = self.lblBA	// Field 69	//19 dec 2013	NDL	Par 33229
		then
			label.alignment := Label.Alignment_Left_Top;
		else
			label.alignment := Label.Alignment_Center_Top;
		endif;
	endforeach;
	

epilog

end;</source>
