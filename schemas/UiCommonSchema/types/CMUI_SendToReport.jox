    <JadeMethod name="doShowTxtFilePath" id="3396d7f0-d0b0-4ac8-a837-8a034be2e902">
        <source>doShowTxtFilePath();
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		26 April 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
//----------------------------------------------------------------------
vars
	showMe : Boolean;
begin
	//Get the print output value from the combo box to determine whether we need a file path entry or a print preview checkbox.
	showMe := self.cmbOutputFormat.itemData[self.cmbOutputFormat.listIndex] &gt; 0;
	
	self.txtFilePath.visible 		:= showMe;
	self.lblFilePath.visible 		:= showMe;
	self.chkPrintPreview.visible 	:= not showMe;
	
epilog
end; </source>
    </JadeMethod>
    <JadeMethod name="getFilePath" id="8fdccc5e-7f60-4e67-b4e1-3c541ccfa4a0">
        <source>getFilePath();
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		23 April 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
//----------------------------------------------------------------------
vars
	file	: CMDFileSave;
	
begin
	create file;
	if file.open = 0 then
		self.txtFilePath.text := file.fileName;
	endif;
epilog
	delete file;
end;</source>
    </JadeMethod>
    <JadeMethod name="getResult" id="6f8e5471-dadd-44ab-b1cd-11926aaa5780">
        <updating/>
        <source>getResult(_jrwReportName: String output;  
		  _printPreview : Boolean output; 
		  _outputType 	: Integer output;
		  _filePath 	: String output;
		  _selectedOnly : Boolean output) updating;
// ---------------------------------------------------------------------------
// Created:     14 December 2007 by cnwaer1
//
// Feb 2012 from CCMS 1262 transaction enquiry add selectedOnly parameter to support selective reporting     
// ---------------------------------------------------------------------------
vars

begin
	_jrwReportName	:= self.cmbJRWReport.text;
	_printPreview	:= self.chkPrintPreview.value;
	_outputType  	:= self.cmbOutputFormat.itemData[self.cmbOutputFormat.listIndex];
	_filePath		:= self.txtFilePath.text;
	_selectedOnly 	:= self.optSelectedOnly.value;
end;</source>
        <Parameter name="_jrwReportName" type="String" usage="output"/>
        <Parameter name="_printPreview" type="Boolean" usage="output"/>
        <Parameter name="_outputType" type="Integer" usage="output"/>
        <Parameter name="_filePath" type="String" usage="output"/>
        <Parameter name="_selectedOnly" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="init" id="b0416385-08d0-40ba-af75-8e237994eeae">
        <updating/>
        <source>init(_showSelectedFrame : Boolean; _reportViewName : String; _reportPaths : StringArray) updating;
// ---------------------------------------------------------------------------
// Created:     13 December 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if self.myJRWRepresentationAgent = null then
		create self.myJRWRepresentationAgent transient;
	endif;
	
	self.chkPrintPreview.value := true;
	self.frmSelectedorAll.visible := _showSelectedFrame;
	if _showSelectedFrame then		// Feb 2012 cnwjre1 clean up the look when showing this option
		self.frmSelectedorAll.top := self.cmbOutputFormat.top + self.cmbOutputFormat.height + 10;
		self.frmSelectedorAll.left := self.lblFormatOption.left;
	endif;
	self.loadReports(_reportViewName, _reportPaths); // SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface.  Allow report views other than CM_TrackedItemView
	self.reportViewName := _reportViewName;
	self.loadCmbOutputFormat();
	self.doShowTxtFilePath();
	self.lblText.caption := app.getErrorString(PrintReportOptionsCaption) &amp; ":"; // SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
	self.cmbJRWReport.setFocus;
	
end;</source>
        <Parameter name="_showSelectedFrame" type="Boolean"/>
        <Parameter name="_reportViewName" type="String"/>
        <Parameter name="_reportPaths" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="loadCmbOutputFormat" id="96abfe47-dc16-4f4c-924e-b5c6e7f60022">
        <source>loadCmbOutputFormat();
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		23 April 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
//----------------------------------------------------------------------
vars
	cmb : CMUI_ComboBox;
begin
	//Set up the required output formats.
	cmb := self.cmbOutputFormat;
	
	cmb.clear();
	cmb.sorted := false;
	
	cmb.itemData[cmb.addItem(CMUI_ReportAgent.FORMAT_OPTION_STANDARD)] 	:= JadeReportWriterReport.PRINTER;
	cmb.itemData[cmb.addItem(CMUI_ReportAgent.FORMAT_OPTION_CSV)]		:= JadeReportWriterReport.CSV; 
	cmb.itemData[cmb.addItem(CMUI_ReportAgent.FORMAT_OPTION_HTML)]		:= JadeReportWriterReport.HTML;
	cmb.itemData[cmb.addItem(CMUI_ReportAgent.FORMAT_OPTION_RTF)]		:= JadeReportWriterReport.RTF;
	cmb.itemData[cmb.addItem(CMUI_ReportAgent.FORMAT_OPTION_XML)]		:= JadeReportWriterReport.XML;
	cmb.itemData[cmb.addItem(CMUI_ReportAgent.FORMAT_OPTION_TEXT)]		:= JadeReportWriterReport.TEXT;		// 28128
	
	cmb.listIndex := 1;
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="loadReports" id="ed9be682-ee53-4cd8-b7d8-a3902a584d09">
        <source>loadReports(_reportViewName : String; _reportPaths : StringArray) protected;
// ---------------------------------------------------------------------------
// Created:     14 December 2007 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
//  ----------  --------------------------------------------------
vars
	path		: String;
	cmb			: CMUI_ComboBox;
	jrwReport,
	jrwView		: CMUI_JRWEntityRepresentation;
begin
	cmb := self.cmbJRWReport;
	cmb.clear();
	if self.myJRWRepresentationAgent.allJRWViews.isEmpty then
		self.myJRWRepresentationAgent.loadJRWRepresentationObjects();
	endif;
	
	jrwView := self.myJRWRepresentationAgent.allJRWViews[_reportViewName]; // SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
	if jrwView = null then
		return;
	endif;

	foreach jrwReport in jrwView.allJRWRepresentationEntities do
		// Sept 2010 CCMS 1155 par 23583 Invoice rate reporting, modified 35069 to be an array of paths
		if _reportPaths = null or
		   _reportPaths.isEmpty() then
			cmb.itemObject[cmb.addItem(jrwReport.name)] := jrwReport;
		else
			foreach path in _reportPaths do
				if jrwReport.reportsOn(path) then
					cmb.itemObject[cmb.addItem(jrwReport.name)] := jrwReport;
					break;
				endif;
			endforeach;
		endif;
	endforeach;
	// show the first report, if any
	if self.cmbJRWReport.listCount &gt; 0 then
		self.cmbJRWReport.listIndex := 1;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_reportViewName" type="String"/>
        <Parameter name="_reportPaths" type="StringArray"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="d35def77-3f87-4fa0-be5f-750837d961dd">
        <updating/>
        <source>setupForm() updating;

vars

begin
	inheritMethod();
	self.cmbJRWReport.bubbleHelp := 'Send to a JRW report that uses the "' &amp; self.reportViewName &amp; '"';
	self.cmbOutputFormat.bubbleHelp := 'Send to a JRW report that uses the "' &amp; self.reportViewName &amp; '"';
end;
</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="f28494a9-2025-4df3-9876-0ea119757aa7">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008097, locale);
	chkPrintPreview.translateCaption(Xlat_0008098, locale);
	cmbJRWReport.translateBubbleHelp(Xlat_0018843, locale);
	cmbOutputFormat.translateBubbleHelp(Xlat_0018844, locale);
	lblFilePath.translateCaption(Xlat_0015079, locale);
	lblFormatOption.translateCaption(Xlat_0015080, locale);
	lblReport.translateCaption(Xlat_0008099, locale);
	optAllResults.translateCaption(Xlat_0008100, locale);
	optSelectedOnly.translateCaption(Xlat_0008101, locale);
end;</source>
    </JadeMethod>
