    <JadeMethod name="doApplyScreenColors" id="e152e6c9-9c9c-4a94-bb82-7b5d52142d44">
        <updating/>
        <source>doApplyScreenColors() updating, protected;

/*

Purpose:			Update the colors of the receiver controls as appropriate


Return Value:		None


Date		Who		Reason
11 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars
	backColorGen	: Integer;
	foreColorGen	: Integer;
	backColorTables	: Integer;
	foreColorTables	: Integer;
	numControls		: Integer;
	controlIndex	: Integer;
	controlObj		: Control;
	
begin
	inheritMethod();
	
	backColorGen	:=	app.colorBackGeneral;
	foreColorGen	:=	app.colorForeGeneral;
	backColorTables	:=	app.colorBackTables;
	foreColorTables	:=	app.colorForeTables;

	numControls		:=	self.controlCount();
	
	foreach controlIndex in 1 to numControls do
		controlObj	:=	self.controls(controlIndex);
		
		if controlObj.isKindOf(Label)
		or controlObj.isKindOf(GroupBox)
		or controlObj.isKindOf(Frame)
		or controlObj.isKindOf(Table)
		then
			controlObj.setBackForeColor(backColorGen, foreColorGen);
		endif;
	endforeach;
	
	self.tblQueues.mbSetFixedColors(backColorTables, foreColorTables);
	

epilog
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doLoadAvailableQueues" id="6d8ab29a-6db7-44b1-b9fb-42eaf7505dd5">
        <updating/>
        <source>doLoadAvailableQueues() updating, protected;

/*

Purpose:			


Return Value:		


Date		Who		Reason
11 March 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars
	errorStr		: String;
	state			: Integer;
	
begin
	if app.myRTGuiAgent.findAllAvailableQueues(self, errorStr, state) then
		// Do nothing, callback will load table
	
	else
		// If we had an error then unload after showing the error
		app.msgBox(errorStr, "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		self.unloadForm();
		
	endif;

	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSave" id="43fd2229-c6a3-4801-8aba-cc08721ef1d0">
        <updating/>
        <source>doSave() : Boolean updating, protected;

/*

Purpose:			


Return Value:		


Date		Who		Reason
12 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars
	errorString		: String;
	state			: Integer;
	queueTable		: Table;
	newQueueName	: String;
	
begin
	queueTable := self.tblQueues;
	if queueTable.row &gt; 1 then
		newQueueName := queueTable.getCellText(queueTable.row, 1).trimBlanks;
	endif;
	if newQueueName = null then
		return false;
	endif;
	
	if app.myRTGuiAgent.doChangeQueue(newQueueName, errorString, state) then
		self.modalResult := self.MB_MODAL_UPDATE;
		self.setPrimaryQueueName(newQueueName);
		return true;
	else
		app.msgBox(errorString, "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return false;
	endif;
	
	
epilog

end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadFormFromThinClientObj" id="30791c3b-8138-48ed-b6be-7b08970205a2">
        <updating/>
        <source>loadFormFromThinClientObj(_obj : MobileServerRTThin::DTO_EnquiryGradingTasks) updating;

/*

Purpose:			Load Queues table from the passed in object


Return Value:		None


Date		Who		Reason
11 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars
	dtoQueue		: DTO_RTQueue;
	canScroll		: Boolean;
	
begin
	foreach dtoQueue in _obj.allQueues do
		self.tblQueues.addItemWithColor(dtoQueue.queueId &amp; Tab &amp; 
										dtoQueue.numberOfEntries.String &amp; Tab &amp;
										dtoQueue.numberOfMachines.String);
	endforeach;

	canScroll := self.tblQueues.mbCanScroll;
	self.btnPageUp.visible := canScroll;
	self.btnPageDown.visible := canScroll;
	
	
epilog

end;</source>
        <Parameter name="_obj" type="MobileServerRTThin::DTO_EnquiryGradingTasks"/>
    </JadeMethod>
    <JadeMethod name="setOkButton" id="88960ff9-5609-4250-b098-0f70a6b1d3ba">
        <source>setOkButton() protected;

/*

Purpose:			


Return Value:		


Date		Who		Reason
12 Mar 2008	cnwkpd1	PAR #16010 - CCMS Otago 1502 - Thin Client RT Enhancements

*/

vars

begin
	self.btnOk.enabled := self.tblQueues.selectedCount &gt; 0;

	
epilog

