    <JadeMethod name="init" id="34915a60-e3c5-4c18-a6b9-e175097bf818">
        <updating/>
        <source>init(_voyage : CM_Voyage; _holds : CM_GeneralCCtrByHatchPlaceDict; _terminal : CM_Terminal) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 27/08/2015	cnwdap1		Initial creation PAR #36766 CCMS SFW 1334 Bulk Graphical Representation
//
vars
	hold : CM_GeneralCargoController;
	terminal : CM_Terminal;
	holdsByHatch : CM_ObjectArray;
	lastHatch : Integer;
	tmpArray : CM_ObjectArray;
	obj : Object;

begin
	terminal := _terminal;
	self.myTerminal := terminal;
	self.myVoyage := _voyage;
	
	self.allGCControllers.clear;
	self.allHoldsInDrawingOrder.clear;
	
	// add all the holds, split by hatch number, to the array of controllers to draw
	create tmpArray transient;
	_holds.copy(self.allGCControllers);
//	foreach hold in _holds do
	foreach hold in _holds reversed do	//27 May 2016	NDL	TFS 1922 - reverse the display of everything now....
		if hold.hatch &lt;&gt; lastHatch then
			if holdsByHatch &lt;&gt; null then
				tmpArray.add(holdsByHatch);
			endif;
			create holdsByHatch transient;
		endif;
		holdsByHatch.add(hold);
		lastHatch := hold.hatch;
	endforeach;
	if holdsByHatch &lt;&gt; null then
		tmpArray.add(holdsByHatch);
	endif;
	
	// now add the ship's block stack to the array of controllers to draw
	create holdsByHatch transient;
	if self.myVoyagePlanningForm.includeShipBlockStack then	// 20/7/16 cnwmp6 TFS 1601
		holdsByHatch.add(self.myVoyage.myShipBlockStack);
	endif;
	self.allHoldsInDrawingOrder.add(holdsByHatch);
	foreach obj in tmpArray do
		self.allHoldsInDrawingOrder.add(obj);
	endforeach;
	
	self.noteVoyageAreaUpdate	:= terminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA);
	self.noteVoyageAreaRefresh	:= terminal.getTerminalEvent(EVENT_REFRESH_VOYAGE_AREA);
	
epilog
	delete tmpArray;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_holds" type="CM_GeneralCCtrByHatchPlaceDict"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="notableObjectArmNotes" id="ea0a971a-87b3-4097-9b3e-865c76b7b16b">
        <source>notableObjectArmNotes(_obj: Object);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 31 August 2015	cnwdap1		Initial creation PAR #
//
vars

begin
	inheritMethod(_obj);
	
	if CM_Voyage.hasInstance(_obj) then
		self.beginNotification(_obj, self.noteVoyageAreaRefresh, Response_Continuous, null);
		self.beginNotification(_obj, self.noteVoyageAreaUpdate, Response_Continuous, null);
		self.beginNotification(_obj, self.myTerminal.getTerminalEvent(VoyageJob_Create_Event), Response_Continuous, null); // PAR 21817
	endif;
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="notableObjectEndNotes" id="37608d25-67db-4c02-93c8-d0e056a229a1">
        <source>notableObjectEndNotes(_obj: Object);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 31 August 2015	cnwdap1		Initial creation PAR #
//
vars

begin
	inheritMethod(_obj);
	
	if CM_Voyage.hasInstance(_obj) then
		self.endNotification(_obj, self.noteVoyageAreaRefresh);
		self.endNotification(_obj, self.noteVoyageAreaUpdate);
		self.endNotification(_obj, self.myTerminal.getTerminalEvent(VoyageJob_Create_Event));
	endif;
epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="redrawWeightsForHold" id="0eb71463-82e7-4209-876a-a182603db05a">
        <updating/>
        <source>redrawWeightsForHold(_lc : CM_LocationsController) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 31/08/2015	cnwdap1		Initial creation PAR #36766 Bulk Graphical Representation
// 10 Apr 2017	NDL			TFS 4058
//
vars
	hold : CM_GeneralCargoController;
//	shipStack : CM_ShipBlockController;
	frame : SHP_BulkDrawingFrame;
	theX, theY, weight : Integer;
	maxX, maxY : Real;
	mode : Integer;
	comment : String;
	isOverWeight : Boolean;
	maxWeight : Integer;
	volume : Decimal [16,4];
	maxVolume : Decimal [16,4];
	overVolume : Boolean;
	holdNum : Integer;
	isOnDeck : Boolean;
	iter : Iterator;
	lc : CM_LocationsController;

begin
	if _lc = null then
		return;
	endif;
	
	frame := self.getFrameForLocation(_lc);
	if frame = null then
		return;
	endif;

	self.setLabelFont(frame);
	
	theX := 38;
	if _lc.isKindOf(CM_GeneralCargoController) then
		maxWeight := _lc.CM_GeneralCargoController.maxWeight;
		maxVolume := _lc.CM_GeneralCargoController.maxVolume;
		holdNum := _lc.CM_GeneralCargoController.hatch;
		isOnDeck := _lc.CM_GeneralCargoController.isOnDeck;
		iter := _lc.CM_GeneralCargoController.myVoyage.allVoyageLocations.createIterator;
		while iter.next( lc ) do
			if not lc.isKindOf( CM_GeneralCargoController ) then
				continue;
			endif;
			if not lc.CM_GeneralCargoController.isOnDeck = isOnDeck then
				continue;
			endif;
			if not lc.CM_GeneralCargoController.hatch = holdNum then
				continue;
			endif;
			weight := weight + lc.CM_GeneralCargoController.totalWeightTonnes.Integer;
			volume := volume + lc.CM_GeneralCargoController.totalVolume;
		endwhile;
		delete iter;
		
	elseif _lc.isKindOf(CM_ShipBlockController) then
		weight := _lc.CM_ShipBlockController.totalWeightTonnes.Integer;
		volume := _lc.CM_ShipBlockController.totalVolume;
		
	endif;
	
	if _lc.isKindOf(CM_GeneralCargoController) and not _lc.CM_GeneralCargoController.isOnDeck then
		theY := self.yUnderDeckPos;
	elseif _lc.isKindOf(CM_ShipBlockController) then
		theY := 24;
	else
		theY := self.yOnDeckPos -15;
	endif;

	if self.workingMode = self.myVoyagePlanningForm.WorkMode_Volume then
		if volume &gt; maxVolume and maxVolume &lt;&gt; null then
			overVolume := true;
		endif;
		self.drawHoldVolume(frame, volume, maxVolume, overVolume, 38, theY);
	elseif self.hasWeights then
	
		if weight &gt; maxWeight and maxWeight &lt;&gt; null then
			isOverWeight := true;
		endif;
		self.drawHoldWeight(frame, weight, maxWeight, isOverWeight, theX, theY);
	endif;

epilog
	if frame &lt;&gt; null then
		self.setDefaultFont(frame);
	endif;
	delete iter;
end;</source>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="setActPlanQueMode" id="ddc58a80-5a1e-4335-a634-93fa792ab7b7">
        <updating/>
        <source>setActPlanQueMode(_mode : Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
