    </ImplicitInverseRef>
    <ImplicitInverseRef name="btnOk" id="b2f7583b-4d91-4e93-ade8-e772bc26a0ff">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="btnRemove" id="13d93b96-e98a-447b-b67d-16df6b85f169">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="fraLine" id="621b8e80-8ad6-4034-a008-82522b940a5c">
        <embedded/>
        <type name="CnEcLine3D"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lstPrinters" id="6ed7eeb3-9e64-490d-9b66-f2d8c47edeaf">
        <embedded/>
        <type name="ListBox"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lstSelected" id="ea2b8e75-fc63-4991-b100-20b918c9235b">
