    <JadeMethod name="doSave" id="084af1d4-9b42-48ac-bd68-d32eef4f7dfc">
        <updating/>
        <source>doSave() updating;
// ---------------------------------------------------------------------------
// Created:     18 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 19/10/2022		jlizm1			TFS 54118 Assigning Releases to Wagons
// ---------------------------------------------------------------------------

vars

	intFaceObj		: CMIF_Request;
	obj : Object;
	idx : Integer;
	qty : Integer;
	runningTotal : Integer;
	osValue : Integer;
	
	isByWeightOrVolume : Boolean;
	cargoType : CM_CargoType;
	density : Decimal [16,4];
	isAnyAmount : Boolean;	// TFS 54118
	tmpStr : String;		// TFS 54118
	
begin

	if self.trainMode and self.cmbTrain.listObject = null then
		app.msgBox(app.getErrorString(Please_select_train), app.getErrorString(Quantity_problem), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	// 30 Jul 2009	NDL - validation, moved from doApply when button removed
	foreach idx in 1 to self.tblData.rows do
		obj := self.tblData.accessRow(idx).itemObject;
		if obj = null then
			continue;
		endif;
		
		//13 Sep 2013	NDL	Par 32479
	//	osValue := obj.CMIF_Request.quantityTxt;
		osValue := self.tblData.accessCell(idx,self.OutstandingColumn).text.Integer;
		if obj.CMIF_Request.myTrackedItem &lt;&gt; null and obj.CMIF_Request.myTrackedItem.canMergeBreakBulk then	
			osValue := obj.CMIF_Request.myReserveDetail.totalRequested;
		endif;
		qty := self.tblData.accessCell(idx,self.QuantityColumn).text.Integer;
		isAnyAmount := self.tblData.accessCell(idx,self.AnyAmountColumn).text = "1";	// TFS 54118
		if qty &lt; 0 then
			app.msgBox(app.getErrorString1(Quantity_too_large,obj.CMIF_Request.quantityTxt.String),app.getErrorString(Quantity_problem),MsgBox_OK_Only);
			return;
		endif;
		if qty &gt; osValue then
			app.msgBox(app.getErrorString1(Quantity_too_large,osValue.String),app.getErrorString(Quantity_problem),MsgBox_OK_Only);
			return;
		endif;
		if qty = 0 and isAnyAmount then	// TFS 54118
			qty := 1;					// TFS 54118
		endif;
		
		runningTotal := runningTotal + qty;
	endforeach;
	
	if runningTotal &lt; 1 then
		if app.msgBox( app.getErrorString(No_Selection_No_Jobs),app.getErrorString(SHP_Do_You_Want_To_Continue),MsgBox_Yes_No) = MsgBox_Return_No then
			return;
		endif;
	endif;

	foreach idx in 1 to self.tblData.rows do
		obj := self.tblData.accessRow(idx).itemObject;
		intFaceObj := obj.CMIF_Request;
		
		//03 Feb 2016	NDL	Par 37492
		if intFaceObj = null then
			continue;
		endif;
		
		tmpStr := self.tblData.accessCell(idx,AssignColumn).text;	// TFS 54118
		if tmpStr &lt;&gt; "1" then				// TFS 54118
			intFaceObj.weight := 0;			// TFS 54118
			intFaceObj.quantityTxt := 0;	// TFS 54118
			continue;						// TFS 54118
		endif;
		
		//03 Feb 2016	NDL	Par 37492
		isByWeightOrVolume := false;
		isAnyAmount := self.tblData.accessCell(idx,AnyAmountColumn).text = "1";	// TFS 54118
		intFaceObj.isAnyAmount := isAnyAmount;									// TFS 54118
		
		cargoType := intFaceObj.myReserveDetail.getCargoType();
		if cargoType &lt;&gt; null then
			if cargoType.isBulkByVolume or cargoType.isBulkByWeight then
				isByWeightOrVolume := true;
				if cargoType.isBulkByVolume then
					density := intFaceObj.myReserveDetail.CM_ReserveSelection.getDensity();
				endif;
			endif;
		endif;
		if isByWeightOrVolume then
			if cargoType.isBulkByWeight then
				if cargoType.myWeightMeasurementType &lt;&gt; null then	//21 Dec 2020	NDL	TFS 50516  - Was only handling Kilos.
					intFaceObj.weight := cargoType.myWeightMeasurementType.conversionRate * self.tblData.accessCell(idx,QuantityColumn).text.asDecimalJMT;
				else
					intFaceObj.weight := self.tblData.accessCell(idx,QuantityColumn).text.asDecimalJMT;
				endif;
			elseif cargoType.isBulkByVolume then
				if cargoType.myWeightMeasurementType &lt;&gt; null then	//21 Dec 2020	NDL	TFS 50516
					intFaceObj.weight := cargoType.myWeightMeasurementType.conversionRate * ( self.tblData.accessCell(idx,QuantityColumn).text.asDecimalJMT * density );
				else
					intFaceObj.weight := ( self.tblData.accessCell(idx,QuantityColumn).text.asDecimalJMT * density ).Decimal;
				endif;
			endif;
		else
			intFaceObj.quantityTxt := self.tblData.accessCell(idx,QuantityColumn).text.Integer;
		endif;
		
	endforeach;
	modalResult := IDOK;
	
	self.myGateAssistant.myTrain := self.cmbTrain.listObject.CM_Train; // Pass back to a different assistant
	
	self.cmbTrain.listIndex := -1;
	self.unloadForm();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initialise" id="3819e694-94e8-4357-8c16-515f2459e57b">
        <updating/>
        <source>initialise(_cmifObjects : ObjectArray; _railIORake : CM_RailJSInOutRake; _trainMode, _wagonMode : Boolean; _term : CM_Terminal; _assist : GTE_Assistant) updating;
// ---------------------------------------------------------------------------
// Created:     18 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 19/10/2022		jlizm1			TFS 54118 Assigning Releases to Wagons
// 22/02/2023		jlizm1			TFS 56417 Error when too much cargo assigned
// ---------------------------------------------------------------------------

vars
	intFaceObj		: CMIF_Request;
	intFaceBP		: CMIF_BuildPriority;
	resDet : CM_ReserveDetail;
	obj : Object;
	idx : Integer;
	quantityCell : JadeTableCell;
	
	trainDict : CM_TrainByCodeDateDict;
	train : CM_Train;
	invalidTrain : Boolean;
	osValue : Integer;
	
	reserve : CM_ReserveDetail;
	totReq : Integer;
	totAct : Integer;
	totDel : Integer;
	
	releaseByType : Boolean;
	isByWeightOrVolume : Boolean;
	cargoType : CM_CargoType;
	density : Decimal [16,4];
	canBeAnyAmount : Boolean;
	multiWagons : Boolean;
	
	wtReq : Decimal [16,4];
	wtAct : Decimal [16,4];	
	wtDel : Decimal [16,4];
	osWeight : Decimal [16,4];
	wtReqStr : String;
	wtActStr : String;	
	wtDelStr : String;
	osWeightStr : String;
	cargoTypeStr : String;
	anyAmountStr : String;
	totalToProcess : String;
	
begin

	self.myTerminal := _term;
	self.myGateAssistant := _assist;
	self.lblWagons.visible := false;	// TFS 54118
	
	if _trainMode then
		
		//10 May 2010	NDL Par 24064
		on Exception do app.handleDeletedObject(exception, train, invalidTrain);
		self.cmbTrain.clear();
		trainDict := _term.allTrainsOnTerminal;// scheduled trains that have NOT departed yet.
		foreach train in trainDict do
			if train.isNullTrain() then
				continue;
			endif;
			if train.arrivalDT.isValid() then	// not allowed anything that has actually arrived - we are planning only.
				//16 Sep 2013	NDL
				//The real issue here is when the train comes into station all his jobs are assigned to the rake.
				// we don't want to confuse the issue by creating jobs against the train when he is in station
				// they must be created against the rake.
				continue;
			endif;
			invalidTrain := false;
			if not invalidTrain then
				self.cmbTrain.itemObject[self.cmbTrain.addItem(self.myAssistant.displayEntryTrain(train))] := train;
			endif;
		endforeach;
		
		self.cmbTrain.visible := true;
		self.trainMode := true;
	
	elseif _wagonMode then				// TFS 54118
		self.wagonMode := true;			// TFS 54118
		self.cmbTrain.visible := false;	// TFS 54118
		self.lblWagons.visible := true;	// TFS 54118
		multiWagons := self.allWagons.size &gt; 1;	// TFS 54118
		
	else
		self.cmbTrain.visible := false;
		if _railIORake &lt;&gt; null and _railIORake.myRail &lt;&gt; null then
			self.railId := _railIORake.myRail.id;
		endif;
	endif;
	
	self.tblData.rows := 0;
	self.tblData.columns := 8;

	self.tblData.addItem(
		app.getErrorString(Assign) &amp; Tab &amp;
		app.getErrorString(Release_number) &amp; Tab &amp; 
		app.getErrorString(TotReq) &amp; Tab &amp;
		app.getErrorString(TotActioned) &amp; Tab &amp;
		app.getErrorString(Delivered) &amp; Tab &amp;
		app.getErrorString(OutStanding_Short) &amp; Tab &amp;
		app.getErrorString(Total_to_process) &amp; Tab &amp;
		app.getErrorString(AnyAmount)
		);
	
	self.tblData.fixedRows := 1;
	self.tblData.fixedColumns := 0;
	self.tblData.selectMode := Table.SelectMode_CurrentRow;

	self.tblData.inputType := Table.InputType_None;
	self.tblData.accessColumn(self.QuantityColumn).inputType := Table.InputType_TextNumeric; //Table.InputType_None;
	self.tblData.accessColumn(self.QuantityColumn).alignment := Table.Alignment_Center_Middle;
	self.tblData.accessColumn(self.QuantityColumn).fontBold := true;
	self.tblData.accessColumn(self.AssignColumn).inputType := Table.InputType_CheckBox;	// TFS 54118
	if multiWagons then
		self.tblData.accessColumn(self.AnyAmountColumn).enabled := false;	// TFS 54118
	endif;
	
	foreach obj in _cmifObjects do
		intFaceBP := obj.CMIF_BuildPriority;
		releaseByType := false;						// TFS 54118
		if intFaceBP.myReserveHeader &lt;&gt; null then	// TFS 54118
			releaseByType := intFaceBP.myReserveHeader.releaseByType;	// TFS 54118
		endif;
		
		foreach intFaceObj in intFaceBP.allCMIFRequests do
		
			//03 Feb 2016	NDL	Par 37492
			isByWeightOrVolume := false;
			canBeAnyAmount := false;		// TFS 54118
			anyAmountStr := "";				// TFS 54118
			cargoTypeStr := null;
			cargoType := intFaceObj.myReserveDetail.getCargoType();
			if cargoType &lt;&gt; null then
				cargoTypeStr := cargoType.description;
				if cargoType.isBulkByVolume or cargoType.isBulkByWeight then
					isByWeightOrVolume := true;
					if cargoType.isBulkByVolume then
						density := intFaceObj.myReserveDetail.CM_ReserveSelection.getDensity();
					endif;
				endif;
				
				if releaseByType and cargoType.id &lt;&gt; TI_CargoType_Container then	// TFS 54118
					canBeAnyAmount := true;											// TFS 54118
				endif;
				
				if canBeAnyAmount then			// TFS 54118
					if intFaceObj.isAnyAmount or intFaceObj.myReserveDetail.defaultAnyAmount or multiWagons then
						anyAmountStr := "1";	// TFS 54118
					else
						anyAmountStr := "0";	// TFS 54118
					endif;
				endif;
			endif;
			
			if isByWeightOrVolume then	//03 Feb 2016	NDL	Par 37492
				wtReq := intFaceObj.myReserveDetail.weightRequested;
				wtReqStr := cargoType.getBulkTrackByDisplayForWeight( wtReq, density, true);
				intFaceObj.myReserveDetail.quantityOnSiteWithJobRail( wtAct );	
				wtActStr := cargoType.getBulkTrackByDisplayForWeight( wtAct, density, true);
				wtDel := intFaceObj.myReserveDetail.getWeightReleased();
				wtDelStr := cargoType.getBulkTrackByDisplayForWeight( wtDel, density, true);
				osWeight := wtReq - wtAct - wtDel;
				osWeightStr := cargoType.getBulkTrackByDisplayForWeight( osWeight, density, true);
				
				if osWeight &gt; 0 then
					totalToProcess := cargoType.getBulkTrackByDisplayForWeight( osWeight, density, false);
				else
					totalToProcess := "0";
				endif;
						
				idx := self.tblData.addItem(	'0' &amp; Tab &amp;
												intFaceObj.releaseNo &amp; " " &amp; cargoTypeStr &amp; Tab &amp;
												wtReqStr  &amp; Tab &amp; // ETRow_TotalRequested
												wtActStr  &amp; Tab &amp;	
												wtDelStr &amp; Tab &amp; // ETRow_DeliveredToDate
												osWeightStr // ETRow_QuantityRemaining
												);
				self.tblData.accessCell(idx,self.QuantityColumn).inputType := Table.InputType_TextBox;
				self.tblData.accessCell(idx,self.QuantityColumn).text := totalToProcess;
				self.tblData.accessRow(idx).itemObject := intFaceObj;
				
				self.tblData.accessCell(idx,self.AnyAmountColumn).text := anyAmountStr;	// TFS 54118
				if canBeAnyAmount then
					self.tblData.accessCell(idx, self.AnyAmountColumn).inputType := Table.InputType_CheckBox;	// TFS 54118
				else
					self.tblData.accessCell(idx, self.AnyAmountColumn).inputType := Table.InputType_None;		// TFS 54118
				endif;			
			
			else
				//07 Jan 2015	NDL	Par 35346
				totReq := intFaceObj.myReserveDetail.totalRequested;
				if intFaceBP.myReserveHeader.type = BR_TYPE_RAIL then
					totAct := intFaceObj.myReserveDetail.quantityOnSiteWithJobRail( wtAct );
				else
					totAct := intFaceObj.myReserveDetail.getDisplayStringForAttribute(ETRow_RequestsBeingActioned, false).Integer;
				endif;
				
				totDel:=intFaceObj.myReserveDetail.getTotalReleased; //jlier1 TFS 54150 26/7/22
				osValue := totReq - totAct - totDel;
				
				if intFaceObj.myTrackedItem &lt;&gt; null and intFaceObj.myTrackedItem.canMergeBreakBulk then	
					osValue := intFaceObj.myReserveDetail.totalRequested - intFaceObj.myReserveDetail.getNumItemsBeingActioned(null);
				endif;
				
				if osValue &gt; 0 then
					totalToProcess := osValue.String;
				else
					totalToProcess := "0";
				endif;
			
				idx := self.tblData.addItem(	'0' &amp; Tab &amp;
												intFaceObj.releaseNo  &amp; " " &amp; cargoTypeStr &amp; Tab &amp;
												totReq.String  &amp; Tab &amp; // ETRow_TotalRequested
												totAct.String  &amp; Tab &amp;	
												totDel.String &amp; Tab &amp; // ETRow_DeliveredToDate
												osValue.String  &amp; Tab &amp; // ETRow_QuantityRemaining
												totalToProcess &amp; Tab &amp;
												anyAmountStr);
				self.tblData.accessRow(idx).itemObject := intFaceObj;
				
				self.tblData.accessCell(idx,self.QuantityColumn).maxLength := 7;
				
				if canBeAnyAmount then	// TFS 54118
					self.tblData.accessCell(idx, self.AnyAmountColumn).inputType := Table.InputType_CheckBox;	// TFS 54118
				else
					self.tblData.accessCell(idx, self.AnyAmountColumn).inputType := Table.InputType_None;		// TFS 54118
				endif;
				
			endif;
			
			if anyAmountStr = "1" then		// TFS 54118
				// if AnyAmount then clear "Total to Process" and make cell readonly
				quantityCell := self.tblData.accessCell(idx, self.QuantityColumn).cloneSelf(true);	// TFS 54118
				quantityCell.inputType := Table.InputType_None;	// TFS 54118
				quantityCell.text := "";	// TFS 54118
				delete quantityCell;		// TFS 54118
			endif;
		endforeach;
		
	endforeach;
	
epilog
	delete quantityCell;
	
end;</source>
        <Parameter name="_cmifObjects" type="ObjectArray"/>
        <Parameter name="_railIORake" type="CM_RailJSInOutRake"/>
        <Parameter name="_trainMode" type="Boolean"/>
        <Parameter name="_wagonMode" type="Boolean"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_assist" type="GTE_Assistant"/>
    </JadeMethod>
    <JadeMethod name="keyDown" id="f8d02e48-d119-4df7-9217-383ab2ce278d">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 July 2009	cnwndl1	Initial creation

*/

vars
	cell : JadeTableCell;
	index : Integer;
begin

	if keyCode = 9 then	// Tab key
		if app.activeControl = cmbTrain then
			if tblData.rows &gt; tblData.fixedRows then
				tblData.row := tblData.fixedRows + 1;
				tblData.column := self.QuantityColumn;
				tblData.setFocus();
				tblData.click(tblData);
				keyCode := null;
				return;
			endif;
			
		elseif app.activeControl = tblData then
	
			tblData.selectMode := 8;	
			if tblData.row &lt; tblData.rows then
				tblData.row := tblData.row + 1;
				tblData.column := self.QuantityColumn;
				tblData.setFocus();
				tblData.click(tblData);
				tblData.setFocus();
				keyCode := null;
				return;	
				
			elseif tblData.row = tblData.rows then
				tblData.row := 1;
				
			endif;
			
		endif;
	endif;
	
	inheritMethod(keyCode, shift);
	
epilog

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setWagons" id="e3be5141-bbda-4890-b95b-86a00d872493">
        <source>setWagons(_wagons : CM_WagonArray);
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
19 October 2022		jlizm1	Initial creation Assigning Releases to Wagons

*/

vars
	wagon 		: CM_Wagon;
	wagonIds 	: String;
	first 		: Boolean;
	
begin
	
	if _wagons = null then
		return;
	endif;
	
	_wagons.copy(self.allWagons);
	
	first := true;
	
	foreach wagon in self.allWagons do
		if first then
			wagonIds := wagonIds &amp; " " &amp; wagon.id;
			first := false;
		else
			wagonIds := wagonIds &amp; ", " &amp; wagon.id;
		endif;
	endforeach;
	
	self.lblWagons.caption := app.getErrorString(Selected_wagons) &amp; ":" &amp; wagonIds; 
	self.lblWagons.visible := true;
	
epilog

end;</source>
        <Parameter name="_wagons" type="CM_WagonArray"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="2f369dbc-eba9-4710-8690-094678370520">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
19 October 2022		jlizm1	Initial creation TFS 54118 Assigning Releases to Wagons

*/

vars
	wagon 		: CM_Wagon;
	wagonIds 	: String;
	first 		: Boolean;
	
begin
	inheritMethod();
	
	if trainMode then
		self.caption := app.getErrorString(Outward_trains) &amp; " "  &amp; self.caption;
		
	elseif wagonMode then
		first := true;
	
		foreach wagon in self.allWagons do
			if first then
				wagonIds := wagonIds &amp; " " &amp; wagon.id;
				first := false;
			else
				wagonIds := wagonIds &amp; ", " &amp; wagon.id;
			endif;
		endforeach;
		
		self.lblWagons.caption := app.getErrorString(Selected_wagons) &amp; ":" &amp; wagonIds; 
		self.caption := app.getErrorString(Assign_release_detail_wagon);
		
	else	
		self.caption := self.railId &amp; " " &amp; self.caption;
		
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tblData_change" id="eb8ec4b1-414f-4bb3-85f9-78cface094ae">
        <controlMethod name="Table::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_change(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
19 October 2022		jlizm1	Initial creation TFS 54118 Assigning Releases to Wagons
22 February 2023	jlizm1	TFS 56417 Error when too much cargo assigned

*/

vars
	obj		 		: Object;
	hasChanged 		: Boolean;
	tmpCell			: JadeTableCell;
	quantityCell	: JadeTableCell;
	column 			: Integer;
	cargoType 		: CM_CargoType;
	isByWeightOrVolume : Boolean;
	density 		: Decimal [16,4];
	wtReq 			: Decimal [16,4];
	wtAct 			: Decimal [16,4];	
	wtDel 			: Decimal [16,4];
	osWeight 		: Decimal [16,4];
	intFaceObj 		: CMIF_Request;
	osWeightStrDef 	: String;
	osQty			: Integer;
	tmpStr			: String;
	
begin
	
	self.mousePointer := Window.MousePointer_HourGlass;
	if table.column &lt;&gt; AnyAmountColumn then
		return;
	endif;
	
	tmpCell := table.accessCell(table.row,table.column).cloneSelf(true);
	
	if tmpCell.inputType &lt;&gt; Table.InputType_CheckBox then
		return;
	endif;

	obj := self.tblData.accessRow(table.row).itemObject;
	
	if obj &lt;&gt; null and not obj.isKindOf(CMIF_Request) then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Invalid object behind cell');
		return;
	endif;
	
	intFaceObj := obj.CMIF_Request;
	cargoType := intFaceObj.myReserveDetail.getCargoType();
	
	if cargoType &lt;&gt; null then
		if cargoType.isBulkByVolume or cargoType.isBulkByWeight then
			isByWeightOrVolume := true;
			if cargoType.isBulkByVolume then
				density := intFaceObj.myReserveDetail.CM_ReserveSelection.getDensity();
			endif;
		endif;
	endif;
	
	if tmpCell.text = "1" then
		// if AnyAmount then clear "Total to Process" and make cell readonly
		quantityCell := table.accessCell(table.row, QuantityColumn).cloneSelf(true);
		quantityCell.inputType := Table.InputType_None;
		quantityCell.text := "";
	else
		// else default enable cell and set to outstanding amount
		if isByWeightOrVolume then
			wtReq := intFaceObj.myReserveDetail.weightRequested;
			intFaceObj.myReserveDetail.quantityOnSiteWithJobRail( wtAct );	
			wtDel := intFaceObj.myReserveDetail.getWeightReleased();
			osWeight := wtReq - wtAct - wtDel;
			osWeightStrDef := "0";
			if osWeight &gt; 0 then
				osWeightStrDef := cargoType.getBulkTrackByDisplayForWeight( osWeight, density, false);
			endif;
			
			quantityCell := table.accessCell(table.row, QuantityColumn).cloneSelf(true);
			quantityCell.inputType := Table.InputType_TextBox;
			quantityCell.text := osWeightStrDef;
		else
			tmpStr := self.tblData.accessCell(table.row, self.OutstandingColumn).text;
			osQty := tmpStr.Integer;
			if osQty &lt; 0 then
				tmpStr := "0";
			endif;
			quantityCell := table.accessCell(table.row, QuantityColumn).cloneSelf(true);
			quantityCell.inputType := Table.InputType_TextNumeric;
			quantityCell.text := tmpStr;
		endif;
	endif;
	
epilog
	delete tmpCell;
	delete quantityCell;
	self.mousePointer := Window.MousePointer_Default;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblData_click" id="65fda7a3-3b3b-4f67-b882-9fd2fd252192">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblData_click(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     19 May 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 19/10/2022		jlizm1			TFS 54118 Don't set focus to qty if trying to select a checkbox
// ---------------------------------------------------------------------------

vars

begin
	if table.row &lt;= table.fixedRows or table.row &gt; table.rows then
		return;
	endif;

//	if process.isNDL then
	//table.accessCell(table.row,self.QuantityColumn).inputType := Table.InputType_TextNumeric;
	if table.column &lt;&gt; AnyAmountColumn and table.column &lt;&gt; AssignColumn then	// TFS 54118
		table.column := self.QuantityColumn; 
		table.accessCell(table.row,self.QuantityColumn);
	endif;
	
		
//	else
//		self.txtQuantity.text := table.accessCell(table.row,self.QuantityColumn).text;
//		self.txtQuantity.setFocus();
//	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="0281869a-b550-402f-bf86-7bd7d429b642">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 November 2022 12:09:07.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0010647, locale);
	btnCancel.translateCaption(Xlat_0010649, locale);
	btnSave.translateCaption(Xlat_0010650, locale);
	lblWagons.translateCaption(Xlat_0025168, locale);
end;</source>
    </JadeMethod>
</GUIClass>
