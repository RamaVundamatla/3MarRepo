    <JadeMethod name="addToolbarControls" id="56f51bd8-6151-4cd8-a395-b0084f662612">
        <updating/>
        <source>addToolbarControls() updating, protected;
/*-------------------------------------------
// Created 12 September 2003 by cnwdvb1
// -------------------------------------------

// Changed On   Changed By  Reason
07/04/2011	Cnwer1	CCMS 1031 - added job priority and roro config
*/
vars
	toolbar	: CMUI_Toolbar;
	
begin
	inheritMethod();

	toolbar := self.frmToolbar;
	
	toolbar.addButton(self.btnEditNew, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSaveBase, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);
	toolbar.addButton(self.btnLicenseNew, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnOutputConfig, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnJobPriority, CMUI_Toolbar.Control_Alignment_Left); //epr CCMS 1031 roro stuff - also moved this to here
	toolbar.addButton(self.btnROROConfig, CMUI_Toolbar.Control_Alignment_Left); //epr CCMS 1031 roro stuff - also moved this to here
	//05 May 2011	NDL	Par 27438
// TFS 2101	if app.getMyUser.canDoSomewhere(PmAdmSysAdminSpec) then
		self.btnFixup.visible := true;
		self.btnFixup.enabled := true;
		toolbar.addButton(self.btnFixup, CMUI_Toolbar.Control_Alignment_Left);
//	endif;
	
	// ### JIRA 33710 20DEC2024 NAVAB1
	if app.myRoot.isClientJadeMaster
	or app.myRoot.isClientJMTTesting then
		toolbar.addButton(self.btnSetClient, CMUI_Toolbar.Control_Alignment_Left);	
	endif;
	toolbar := self.frmSearchMsgTB;
	toolbar.addButton(self.btnSearchMsg, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnResetSearchMs, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnHideSearchMsg, CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar.positionToolbarControls();
	toolbar.visible := true;

end;</source>
        <access>protected</access>
    </JadeMethod>
