    <JadeMethod name="trxCreateDamageInstance" id="4056e496-18fa-4537-9faf-fa814b11f54d">
        <updating/>
        <source>trxCreateDamageInstance(_pxyDamageInstance  : CM_DamageInstance input;
						_pxyRealTI 			: CM_TrackedItem input;
						_pxyRealTIMaster 	: CM_TIMaster input;
						_pxyNew 			: Boolean input; 
						_pxyRepaired 		: Boolean io;
						_newDamageInstance  : CM_DamageInstance output;
						_passport 			: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Jul 2022	navak20	53862: EUP - WMS - Damage Recording Extra Details
22 Oct 2024 navma1	MTN-33173 MTN - Error 1081 occurs when attempting to create or update cargo items. The system fails when trying to create associated damage instances
*/
vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	_passport.useTITransactionDeferUpdate	:= true;		//22.10.2024 navma1 #MTN-33173
	_passport.useTIDictDeferUpdate			:= true;		//22.10.2024 navma1 #MTN-33173
	
	// Start the transaction
	beginTransaction;

	app.myUtilityCA.utlCreateDamageInstance(_pxyDamageInstance, _pxyRealTI, _pxyRealTIMaster, _pxyNew, _pxyRepaired, _newDamageInstance, _passport);
	
	if _passport.noErrors then								//22.10.2024 navma1 #MTN-33173
		_passport.doDeferredUpdates();
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
