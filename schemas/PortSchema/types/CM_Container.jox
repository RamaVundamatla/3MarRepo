end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getO2FromLoadList" id="9788db96-2ad9-453d-b6dd-53babdc48b66">
        <source>getO2FromLoadList(): String;
//----------------------------------------------------------------
//	Created:	11 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//
//	Used in reports
//
vars
	lls	: CM_EDIDataArray;
begin
	if self.myVoyage &lt;&gt; null then
//		if self.myVoyage.myCellularVoyageStructure &lt;&gt; null then						cnwrl1 16/04/2009 PAR 19471
			create lls transient;
//			self.myVoyage.myCellularVoyageStructure.getAllEDILoadLists(lls);		cnwrl1 16/04/2009 PAR 19471
			self.myVoyage.getAllEDILoadLists(lls);
			if not lls.isEmpty then
				return lls.last.CM_EDIDataLoadList.getFieldValueForTI(ETRow_Oxygen, self);			
			endif;
//		endif;
	endif;
	return null;
epilog
	delete lls;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getODDescription" id="949a5490-98e5-4199-b134-d50a0ca47fa0">
        <source>getODDescription() : String;
// ---------------------------------------------------------------------------
// Created:     24 September 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpString : String;
begin
	if not self.isOverDimensions then
		return null;
	endif;
	
	if self.overHeight &gt; 0 then
		tmpString := tmpString &amp; " H: " &amp; self.overHeight.asStringMeasurementJMT();
	endif;
	
	if self.overLengthFront &gt; 0 then
		tmpString := tmpString &amp; " LF: " &amp; self.overLengthFront.asStringMeasurementJMT();
	endif;
	if self.overLengthRear &gt; 0 then
		tmpString := tmpString &amp; " LR: " &amp; self.overLengthRear.asStringMeasurementJMT();
	endif;

	if self.overWidthLeft &gt; 0 then
		tmpString := tmpString &amp; " WL: " &amp; self.overWidthLeft.asStringMeasurementJMT();
	endif;

	if self.overWidthRight &gt; 0 then
		tmpString := tmpString &amp; " WR: " &amp; self.overWidthRight.asStringMeasurementJMT();
	endif;
	
	tmpString := tmpString.trimBlanks();
	
	return tmpString;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOSTIsForDiffJobSheetAsWorkd" id="0caee1e4-7f6e-4da7-9a1d-6116d3a3ed25">
        <source>getOSTIsForDiffJobSheetAsWorkd(_tis : CM_TIArray input; _controller : CMIF_ShipOverstowController): Boolean;

vars
	lc : CM_LocationsController;
	ti : CM_TrackedItem;
	indexOfTI, indexOfME : Integer;
	orderOfTI, orderOfME : Integer;
	vWLEme, vWLEti : CM_VoyageWLE;
	jsOfTI, jsOfME : CM_JobSheet;
	mode : Integer;
begin
	lc := self.myPrimaryActualLocation;
	if lc = null then
		return false;
	endif;
	
	if not lc.isYardLocation then
		return false;
	endif;
	
	if not lc.isGridLocation then
		return false;
	endif;
	
	indexOfME := lc.allTrackedItems.indexOf(self);
	// TOP TI NO OverStows
	if indexOfME = lc.allTrackedItems.size then
		return false;
	endif;
	
	vWLEme := self.getVoyageWLEUnactioned(true);
	if vWLEme = null then
		return false;
	endif;
	mode := _controller.mode;
	
	orderOfME := _controller.getTIOrder(self, jsOfME);
	foreach ti in lc.allTrackedItems do
		indexOfTI := lc.allTrackedItems.indexOf(ti);
		if indexOfTI &lt;= indexOfME then
			continue;
		endif;

		orderOfTI := _controller.getTIOrder(ti, jsOfTI);
		// ### diff job sheet so add is as overstow for my crane
		if jsOfTI &lt;&gt; jsOfME then
			if mode = CMIF_ShipOverstowController.Mode_Absolute then
				if not _tis.includes(ti) then
					_tis.add(ti);
				endif;
			elseif mode = CMIF_ShipOverstowController.Mode_AsWorked 
			or mode = CMIF_ShipOverstowController.Mode_RealTimeActual
			or mode = CMIF_ShipOverstowController.Mode_RealTimeEstimated then
				// this TI is on a different JS, and if it is being worked after me then 
				// it will be still overstowing me when I come to be worked.
				// If this ti is to be worked before me then it should be gone by the time 
				// I get to be worked.
				if orderOfME &lt; orderOfTI then
				
					if not _tis.includes(ti) then
						_tis.add(ti);
					endif;
				endif;
			endif;
		else // Same JobSheet
			if mode = CMIF_ShipOverstowController.Mode_Absolute then
			
			elseif mode = CMIF_ShipOverstowController.Mode_AsWorked 
			or mode = CMIF_ShipOverstowController.Mode_RealTimeActual
			or mode = CMIF_ShipOverstowController.Mode_RealTimeEstimated then
				if orderOfME &lt; orderOfTI then
					if not _tis.includes(ti) then
						_tis.add(ti);
					endif;
				endif;
			endif;
		
		endif;
	endforeach;
end;
</source>
        <Parameter name="_tis" type="CM_TIArray" usage="input"/>
        <Parameter name="_controller" type="CMIF_ShipOverstowController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
