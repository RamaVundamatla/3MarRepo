<Class name="CM_FlatcarWagonController" id="351995fc-9167-401a-80ae-4b63f33b1997">
    <superclass name="CM_WagonController"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
