    <JadeMethod name="doSendChangePassword" id="f3d7dd38-3aff-4021-af47-7d91d47741bf">
        <updating/>
        <source>doSendChangePassword() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
19 December 2009	cnwkpd1	PAR #21593 - CCMS MES 1014 - ITS RDT Interface

*/

vars
	machineId		: String;
	message			: String;
	xml				: JadeXMLDocument;
	header,
	body			: JadeXMLElement;
	
begin
	if self.myMachine = null then
		self.registerMachine();
		if self.myMachine = null then
			return;
		endif;
	endif;

	xml := self.createXMLDocForNewMessage(Message_Type_ChangePassword);
	
	body := xml.rootElement.getElementByTagName(XML_Tag_Body);
	body.setElementValue(XML_Tag_UserName, self.txtUser.text.trimBlanks());
	body.setElementValue(XML_Tag_Password, self.txtPassword.text.trimBlanks());
	body.setElementValue(XML_Tag_NewPassword, self.txtNewPassword.text.trimBlanks());
	
	message := xml.writeToString();

	self.doSendMessage(message);

	
epilog
	delete xml;
	
end;
</source>
