	typeArray.add(YACriteriaType_Consignee);			strNameArray.add("YACriteriaType_Consignee");
	typeArray.add(YACriteriaType_Consignor);			strNameArray.add("YACriteriaType_Consignor");
	typeArray.add(YACriteriaType_ContentsStatus);		strNameArray.add("YACriteriaType_ContentsStatus");
	typeArray.add(YACriteriaType_DestinationPort);		strNameArray.add("YACriteriaType_DestinationPort");
	typeArray.add(YACriteriaType_DischargePort);		strNameArray.add("YACriteriaType_DischargePort");
	typeArray.add(YACriteriaType_TranshipToPort);		strNameArray.add("YACriteriaType_TranshipToPort");
	typeArray.add(YACriteriaType_FreightForward);		strNameArray.add("YACriteriaType_FreightForward");
	typeArray.add(YACriteriaType_Hazardous);			strNameArray.add("YACriteriaType_Hazardous");
	typeArray.add(YACriteriaType_HeavyDuty);			strNameArray.add("YACriteriaType_HeavyDuty");
	typeArray.add(YACriteriaType_ISO);					strNameArray.add("YACriteriaType_ISO");
	typeArray.add(YACriteriaType_ISOGroup);				strNameArray.add("YACriteriaType_ISOGroup");
	typeArray.add(YACriteriaType_ImexStatus);			strNameArray.add("YACriteriaType_ImexStatus");
	typeArray.add(YACriteriaType_IntendedRelMode);		strNameArray.add("YACriteriaType_IntendedRelMode");
	typeArray.add(YACriteriaType_IsCoastal);			strNameArray.add("YACriteriaType_IsCoastal");
	typeArray.add(YACriteriaType_IsForty);				strNameArray.add("YACriteriaType_IsForty");
	typeArray.add(YACriteriaType_IsFortyFive);			strNameArray.add("YACriteriaType_IsFortyFive");
	typeArray.add(YACriteriaType_IsThirty);				strNameArray.add("YACriteriaType_IsThirty");
	typeArray.add(YACriteriaType_IsFiftyThree);			strNameArray.add("YACriteriaType_IsFiftyThree");
	typeArray.add(YACriteriaType_IsHazardous);			strNameArray.add("YACriteriaType_IsHazardous");
	typeArray.add(YACriteriaType_IsHazNotLimited);		strNameArray.add("YACriteriaType_IsHazNotLimited");
	typeArray.add(YACriteriaType_LoadPort);				strNameArray.add("YACriteriaType_LoadPort");
	typeArray.add(YACriteriaType_IsOverDimension);		strNameArray.add("YACriteriaType_IsOverDimension");
	typeArray.add(YACriteriaType_OperatorItem);			strNameArray.add("YACriteriaType_OperatorItem");
	typeArray.add(YACriteriaType_Product);				strNameArray.add("YACriteriaType_Product");
	typeArray.add(YACriteriaType_RecTransMode);			strNameArray.add("YACriteriaType_RecTransMode");
	typeArray.add(YACriteriaType_Rehandles);			strNameArray.add("YACriteriaType_Rehandles");
	typeArray.add(YACriteriaType_RailReleaseReq);		strNameArray.add("YACriteriaType_RailReleaseReq");
	typeArray.add(YACriteriaType_RelTransMode);			strNameArray.add("YACriteriaType_RelTransMode");
	typeArray.add(YACriteriaType_RequiresPower);		strNameArray.add("YACriteriaType_RequiresPower");
	typeArray.add(YACriteriaType_SrcTermArea);			strNameArray.add("YACriteriaType_SrcTermArea");
	typeArray.add(YACriteriaType_SrcTermAreaType);		strNameArray.add("YACriteriaType_SrcTermAreaType");
	typeArray.add(YACriteriaType_Stops);				strNameArray.add("YACriteriaType_Stops");
	typeArray.add(YACriteriaType_SubTerminal);			strNameArray.add("YACriteriaType_SubTerminal");
	typeArray.add(YACriteriaType_ToDoTasks);			strNameArray.add("YACriteriaType_ToDoTasks");
	typeArray.add(YACriteriaType_TrailerType);			strNameArray.add("YACriteriaType_TrailerType");
	typeArray.add(YACriteriaType_Train);				strNameArray.add("YACriteriaType_Train");
	typeArray.add(YACriteriaType_TransactionType);		strNameArray.add("YACriteriaType_TransactionType"); 
	typeArray.add(YACriteriaType_Voyage);				strNameArray.add("YACriteriaType_Voyage");
	typeArray.add(YACriteriaType_VoyageBerth);			strNameArray.add("YACriteriaType_VoyageBerth");
	typeArray.add(YACriteriaType_OperatorVoyage);		strNameArray.add("YACriteriaType_OperatorVoyage");
	typeArray.add(YACriteriaType_VoyagePlanCode);		strNameArray.add("YACriteriaType_VoyagePlanCode");
	typeArray.add(YACriteriaType_VoyageTrade);			strNameArray.add("YACriteriaType_VoyageTrade");
	typeArray.add(YACriteriaType_WaterCooled);			strNameArray.add("YACriteriaType_WaterCooled");
	typeArray.add(YACriteriaType_Weight);				strNameArray.add("YACriteriaType_Weight");
	typeArray.add(YACriteriaType_IsTransShip);			strNameArray.add("YACriteriaType_IsTransShip");
	typeArray.add(YACriteriaType_IsCA);					strNameArray.add("YACriteriaType_IsCA");
	typeArray.add(YACriteriaType_IsTwenty);				strNameArray.add("YACriteriaType_IsTwenty");
	typeArray.add(YACriteriaType_ContainerLength);		strNameArray.add("YACriteriaType_ContainerLength");
	typeArray.add(YACriteriaType_IsHazAllLimited);		strNameArray.add("YACriteriaType_IsHazAllLimited");
	typeArray.add(YACriteriaType_IsHazOrLimited);		strNameArray.add("YACriteriaType_IsHazOrLimited");
	typeArray.add(YACriteriaType_CurtainsIn);			strNameArray.add("YACriteriaType_CurtainsIn");
	typeArray.add(YACriteriaType_IsAvailable);			strNameArray.add("YACriteriaType_IsAvailable");
	typeArray.add(YACriteriaType_ID);					strNameArray.add("YACriteriaType_ID");
	typeArray.add(YACriteriaType_BOL);					strNameArray.add("YACriteriaType_BOL");
	typeArray.add(YACriteriaType_SpecialStow);			strNameArray.add("YACriteriaType_SpecialStow");
	typeArray.add(YACriteriaType_TotalWeight);			strNameArray.add("YACriteriaType_TotalWeight");
	typeArray.add(YACriteriaType_CargoLength);			strNameArray.add("YACriteriaType_CargoLength");
	typeArray.add(YACriteriaType_CargoWidth);			strNameArray.add("YACriteriaType_CargoWidth");
	typeArray.add(YACriteriaType_CargoHeight);			strNameArray.add("YACriteriaType_CargoHeight");//
	typeArray.add(YACriteriaType_SpecialLift);			strNameArray.add("YACriteriaType_SpecialLift");
	typeArray.add(YACriteriaType_VoyageInbound);		strNameArray.add("YACriteriaType_VoyageInbound");
	typeArray.add(YACriteriaType_VoyageOutbound);		strNameArray.add("YACriteriaType_VoyageOutbound");
	typeArray.add(YACriteriaType_TranshipDischPt);		strNameArray.add("YACriteriaType_TranshipDischPt");
	typeArray.add(YACriteriaType_DestTerminal);			strNameArray.add("YACriteriaType_DestTerminal");
	typeArray.add(YACriteriaType_Damaged);				strNameArray.add("YACriteriaType_Damaged");
	typeArray.add(YACriteriaType_IsEmpty);				strNameArray.add("YACriteriaType_IsEmpty");
	typeArray.add(YACriteriaType_IsReefer);				strNameArray.add("YACriteriaType_IsReefer");
	typeArray.add(YACriteriaType_Colour);				strNameArray.add("YACriteriaType_Colour");
	typeArray.add(YACriteriaType_Mark);					strNameArray.add("YACriteriaType_Mark");
	typeArray.add(YACriteriaType_VehicleMake);			strNameArray.add("YACriteriaType_VehicleMake");			
	typeArray.add(YACriteriaType_VehicleModel);			strNameArray.add("YACriteriaType_VehicleModel");	
	typeArray.add(YACriteriaType_VehicleType);			strNameArray.add("YACriteriaType_VehicleType");			
	typeArray.add(YACriteriaType_VehicleYear);			strNameArray.add("YACriteriaType_VehicleYear");				
	typeArray.add(YACriteriaType_IsNewVehicle);			strNameArray.add("YACriteriaType_IsNewVehicle");	
	typeArray.add(YACriteriaType_VehicleNbrDoors);		strNameArray.add("YACriteriaType_VehicleNbrDoors");	
	typeArray.add(YACriteriaType_IsSelfPropelled);		strNameArray.add("YACriteriaType_IsSelfPropelled");	
	typeArray.add(YACriteriaType_Temperature);			strNameArray.add("YACriteriaType_Temperature");			
	typeArray.add(YACriteriaType_CargoGroup);			strNameArray.add("YACriteriaType_CargoGroup");
	typeArray.add(YACriteriaType_SortingMethod);		strNameArray.add("YACriteriaType_SortingMethod");	// ### TFS 58429 (58517) 20Jun2023 NAVPW1
	typeArray.add(YACriteriaType_SecondBarcodeId);		strNameArray.add("YACriteriaType_SecondBarcodeId");	// ### TFS 58429 (58517) 20Jun2023 NAVPW1
	typeArray.add(YACriteriaType_Itemized);				strNameArray.add("YACriteriaType_Itemized");		// ### TFS 58429 (58517) 20Jun2023 NAVPW1
	typeArray.add(YACriteriaType_InstructionType);		strNameArray.add("YACriteriaType_InstructionType");		//02.02.2023 navhl20 #61960
	
	foreach index in 1 to YA_CriteriaType_Max do
		if index = YA_CriteriaType_Max then
			continue;
		endif;
		if index = 37 then
			//was "YACriteriaType_IsWashed", whihc was not used
			continue;
		endif;
		if typeArray.includes(index) then
			continue;
		endif;
		typeArray.add(index);
		strNameArray.add("YACriteriaType_??????");
	endforeach;

	foreach index in 1 to typeArray.size do
	
		yaTypeKey := typeArray[index];
		if yaTypeKey = YACriteriaType_CommReefer then
			//should no longer be used, commented out in the load of the combos.
			//see UiCommonSchema::CMUI_YACriteriaCntl::loadCriteriaTypes
			continue;
		endif;
		strName := strNameArray[index];
		queryProp := null;
		queryProp := CM_QDefTrackedItem.firstInstance.getPropertyFromYAType( yaTypeKey );
		if queryProp = null then
			//try container
			 queryProp := CM_QDefContainer.firstInstance.getPropertyFromYAType( yaTypeKey );
		endif;
		if queryProp = null then
			//try car
			 queryProp := CM_QDefCar.firstInstance.getPropertyFromYAType( yaTypeKey );
		endif;
	
		self.assertTrueMsg( queryProp &lt;&gt; null, "*** " &amp; yaTypeKey.String &amp; " '" &amp; strName &amp; "' no equivalent query property found" );
		
		//write yaTypeKey.String &amp; " " &amp; queryProp.niceName &amp; ", '" &amp; strName &amp; "' equivalent query property found";
		
	endforeach;

	
epilog

	delete typeArray;
	delete strNameArray;
	
end;</source>
    </JadeMethod>
