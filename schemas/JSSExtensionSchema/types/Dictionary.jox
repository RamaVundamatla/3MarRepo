<CollClass name="Dictionary">
    <JadeMethod name="jssGetMemberClass" id="baa9c8a4-e41e-418e-b26b-e9a55f0e0114">
        <source>jssGetMemberClass():Class;
// --------------------------------------------------------------------------------
// Created:		15 March 2001 by cnwdad1
//
// Purpose:		Returns the Class of the receiver's membership.
//
// Parameters:	None
//
// Returns:		The Class of the receiver's membership.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return self.jssGetMemberType().Class;
end;</source>
        <ReturnType type="Class"/>
    </JadeMethod>
    <JadeMethod name="jssIsSameAs" id="50179278-ba24-4388-97a1-209d6af4d828">
        <source>jssIsSameAs(pDictionary:Dictionary): Boolean;
// --------------------------------------------------------------------------------
// Created:		08 November 2000 by cnwdad1
//
// Purpose:		Compares the specified dictionary to the receiver and returns TRUE
//				if they contain the same collections of objects.
//
// Parameters:	pDictionary (Dictionary) - The dictionary to compare the receiver to.
//
// Returns:		True if the collections are the same, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theObject	: Object;

begin
	// If size is different, then they can't be the same.
	
	if self.size() &lt;&gt; pDictionary.size() then
		return false;
	endif;

	// Compare the dictionaries.
	
	foreach theObject in self do
		if not pDictionary.includes(theObject) then
			return false;
		endif;
	endforeach;

	return true;
end;</source>
        <Parameter name="pDictionary" type="Dictionary"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssSort" id="fb9c91d6-b811-4878-94c9-ace5d1b12d06">
        <source>jssSort(pTheDynaDictionary:DynaDictionary io;
		pAllSortKeys:JSSSortKeyNameArray;
		pIsAllowDuplicates:Boolean):Boolean;
// --------------------------------------------------------------------------------
// Created:		13 March 2001 by cnwdad1
//
// Purpose:		This method will sort the receiver by the keys specified in the
//				pAllSortKeys array.
//
// Parameters:	pTheDynaDictionary - The dynamic dictionary to contain the sorted
//					collection members.
//				pAllSortKeys - An array of JSSSortKeyName objects identifying the
//					keys by which to sort the collection.
//				pIsAllowDuplicates - A flag to indicate whether duplicates are
//					allowed in the sort result.
//
// Returns:		True if the collection is successfully sorted, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theCollection	: Dictionary;
	theSortKey		: JSSSortKeyName;

begin
	// Set up the dyna-dictionary membership and keys.
	
	theCollection	:=	self;
	pTheDynaDictionary.setMembership(theCollection.jssGetMemberClass());

	foreach theSortKey in pAllSortKeys do
		pTheDynaDictionary.addMemberKey(theSortKey.keyName,
										theSortKey.isDescending,
										theSortKey.isCaseSensitive);
	endforeach;
	
	pTheDynaDictionary.endKeys(pIsAllowDuplicates);
	
	// Copy the members of the collection to the dyna-dictionary.
	
	theCollection.copy(pTheDynaDictionary);
	
	return true;
end;</source>
        <Parameter name="pTheDynaDictionary" type="DynaDictionary" usage="io"/>
        <Parameter name="pAllSortKeys" type="JSSSortKeyNameArray"/>
        <Parameter name="pIsAllowDuplicates" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</CollClass>
