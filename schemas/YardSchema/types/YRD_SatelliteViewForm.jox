    <JadeMethod name="doYAMTableSelection" id="069655b1-9d54-41e7-89fd-62c815f3339f">
        <updating/>
        <source>doYAMTableSelection() updating;
//04 November 2008	cnwdw1	
// Update the Satellite view with YA selected in YAM Table
// 01/12/2014 cnwma1 PAR#35333  1090 in YRD_SatelliteViewForm::selectYAForEdit
vars
	ydc : YRD_ContainerDrawingController;
	obj: Object;
	yaObj: Object;
	inEditMode : Boolean;
	ya: CM_YardAllocation;
	olf : YRD_ContainerOverDrawingFrame;
begin
	inEditMode := self.btnViewYardAllEd.value;
	if inEditMode then
		yaObj := self.tblYAM.getSelectedObject();
		if yaObj &lt;&gt; null then						// 04/12/2014 cnwma1 PAR #35333
			self.selectYAForEdit(yaObj);
		endif;
	else
		foreach obj in self.allDrawingControllers do
			ydc := obj.YRD_ContainerDrawingController;
			ydc.getOverlayViewFrame.setYardAllocations(self.tblYAM.allSelectedObjects);
			ydc.getOverlayViewFrame.setYABlocks(self.tblYAM.allSelectedObjects);
			ydc.getOverlayViewFrame.drawAllYAFrames();
			ydc.getOverlayViewFrame.visible := true;
			//24 Nov 2011	NDL	Par 28721 - flip flop transparency of overlay frame to deal to a jade bug....
			olf := null;
			olf := ydc.getOverlayFrame(false);
			if olf &lt;&gt; null then
				olf.transparent := not olf.transparent;
				olf.transparent := not olf.transparent;
			endif;
			////
		endforeach;
		self.btnViewYardAllEd.enabled := self.getSelectedYA() &lt;&gt; null;
	endif;
	
	


		// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnAddYA.enabled:= false;
		self.btnDeleteYA.enabled:= false;
		self.btnEditYA.enabled:= false;
		self.tblYAM.userInputEnabled := false;
		self.tblYAM.readOnly := true;
		self.btnViewYardAllEd.enabled := false;
	endif;

	
end;</source>
    </JadeMethod>
    <JadeMethod name="doYASelected" id="dfb7d9d6-915b-4cbe-91a2-207cebb81d43">
        <updating/>
        <source>doYASelected(_ya: CM_YardAllocation) updating;
//12 August 2008	cnwdw1	
// Ya has been selected in the floating ya dialog
vars
	obj : Object;
	ydc : YRD_ContainerDrawingController;
	olFrame : YRD_ContainerOverDrawingFrame;
	amEditing : Boolean;
begin
	foreach obj in self.allDrawingControllers do
		ydc := obj.YRD_ContainerDrawingController;
		olFrame := ydc.getOverlayFrame(true); // get editing frame
		amEditing := olFrame.visible;
		if amEditing then
			olFrame.setCurrentEditYardAllocation(_ya);
			self.doSelectYA(_ya);
		endif;
	endforeach; 
end;</source>
        <Parameter name="_ya" type="CM_YardAllocation"/>
    </JadeMethod>
