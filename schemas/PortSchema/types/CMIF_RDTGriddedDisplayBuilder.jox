    <JadeMethod name="getDefaultDisplayMode" id="5b21d5b6-e795-4e22-a583-61af4846e2bf">
        <source>getDefaultDisplayMode() : Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 May 2010	cnwjk3	Initial creation

*/

vars

	topDown : Boolean;
	faceView : Boolean;
	endView : Boolean;

begin

	//10 Feb 2012	NDL	Par 29108
	if self.myRTVehicleConfig &lt;&gt; null then
		faceView := self.myRTVehicleConfig.canDisplayFaceView;
		topDown := self.myRTVehicleConfig.canDisplayTopDownView;
		endView := self.myRTVehicleConfig.canDisplayEndView;
	endif;

	if topDown then
		return CMIF_RDTDrawElement.MODE_TOPDOWN;
	elseif faceView then
		return CMIF_RDTDrawElement.MODE_FACE;
	elseif endView then
		return CMIF_RDTDrawElement.MODE_END;
	else
		return CMIF_RDTDrawElement.MODE_TOPDOWN;
	endif;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMaxGridCol" id="6f920c36-9470-4d23-915a-86fa58d19207">
        <source>getMaxGridCol(): Integer;

/*

Purpose:			

Parameters:			

Return Value:		


