    <JadeMethod name="populateVoyagesCombo" id="a78d536a-1aea-4000-b5c1-2098f0b3b6e1">
        <source>populateVoyagesCombo() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 February 2016	cnwndl1	Initial creation	TFS	1593
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
*/

vars

	voyage : CM_Voyage;
	now : TimeStamp;

begin

	now := app.actualTimeServer();	// 16 Sept 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	self.cmbVoyage.clear();
	
	self.myMobileGenericAgent.setCurrentVoyages();
	
	self.cmbVoyage.addItem(self.lblVoyage.caption);
	now := app.actualTimeServer;		// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	foreach voyage in self.myMobileGenericAgent.allCurrentVoyages do
		if voyage.isNullVoyage then
			continue;
		endif;
		if voyage.status = Voyage_Status_Departed or voyage.status = Voyage_Status_Closed then
			continue;
		endif;
		if not voyage.arrivedDT.Date.isValid or voyage.arrivedDT &gt; now then
			// hasn't arrived yet
			continue;
		endif;
		if self.myMobileGenericAgent.myTerminal.getConfig(VesselNameOnVoyageCombo).Boolean then
			self.cmbVoyage.itemObject[self.cmbVoyage.addItem(voyage.code &amp; Tab &amp; voyage.vesselName )] := voyage;
		else
			self.cmbVoyage.itemObject[self.cmbVoyage.addItem(voyage.code)] := voyage;
		endif;
	endforeach;
	
	voyage := self.myMobileGenericAgent.myVoyage;
	
	if voyage &lt;&gt; null and cmbVoyage.findObject(voyage) &gt; 0 then
		cmbVoyage.listIndex := cmbVoyage.findObject(voyage);
	elseif cmbVoyage.listCount = 2 then
		cmbVoyage.listIndex := 2;
		voyage := cmbVoyage.itemObject[2].CM_Voyage;
	else
		cmbVoyage.listIndex := 1;
	endif;
	
	populateWorkPointsCombo( voyage );

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="populateWorkPointsCombo" id="2f36a7d3-aaaf-4849-939b-40d013a931b4">
        <source>populateWorkPointsCombo( voyage : CM_Voyage );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 February 2016	cnwndl1	Initial creation	TFS 1593

*/

vars

	objSet : CM_ObjectSetActual;
	obj : CM_Object;
	workPoint : CM_WorkPoint;
	index : Integer;
	msg : String;

begin

	self.cmbWorkPoint.clear();
	
	self.cmbWorkPoint.addItem(lblWorkPoint.caption);
	
	if voyage = null then
		self.cmbWorkPoint.enabled := false;
		self.cmbWorkPoint.listIndex := 1;
	
	else
		self.cmbWorkPoint.enabled := true;
	
		create objSet transient;
		voyage.findAllMyCranesAndWorkpoints( objSet );
		foreach obj in objSet where obj.isKindOf( CM_WorkPoint ) do
			workPoint := obj.CM_WorkPoint;
			index := self.cmbWorkPoint.addItem(workPoint.code);
			self.cmbWorkPoint.itemObject[index] := workPoint;
			self.cmbWorkPoint.itemEnabled[index] := not workPoint.isNotAvailableForEntry;
		endforeach;
		
		if self.cmbWorkPoint.listCount = 2 then
			self.cmbWorkPoint.listIndex := 2;	// only one real one to choose, select it.
		elseif self.cmbWorkPoint.listCount = 1 then	//12 Aug 2016	NDL	TFS 2527
			msg := app.getErrorString(Active_workpoi_found_voyage);
			app.msgBox(msg, app.getErrorString(Warning), MsgBox_OK_Only);
			self.cmbWorkPoint.listIndex := 1;
		endif;
		
	endif;
	
epilog

	delete objSet;

end;</source>
        <Parameter name="voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setupControls" id="b025068e-cbef-49c3-8617-76492208f27f">
