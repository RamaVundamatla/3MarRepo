<GUIClass name="CMS_UserMessageForm" id="4854094a-211d-495f-8d42-1211ea1047b6">
    <superclass name="Form"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="btnOk" id="b32a5217-82ad-4734-914a-ae6f416e498f">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblMessage" id="db38f45c-15e7-44b2-82cb-3bfd775e302c">
        <embedded/>
        <type name="Label"/>
    </ImplicitInverseRef>
    <JadeMethod name="btnOk_click" id="47d0ba1b-ef73-4dc6-908b-1e09895a41d5">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOk_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		29 September 2008 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.visible	:=	false;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="load" id="6e95ca89-30d1-4304-bf52-a8ddf3456fed">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// --------------------------------------------------------------------------------
// Created:		29 September 2008 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
epilog
	app.mousePointer	:=	Idle;
end;</source>
    </JadeMethod>
    <JadeMethod name="showMe" id="9391b3a6-8214-494e-b35e-505ec5a752fb">
        <updating/>
        <source>showMe() updating;
// --------------------------------------------------------------------------------
// Created:		29 September 2008 by cnwdad1
//
// Purpose:		Sets up the user message, and makes the receiver visible.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	gdi_warning		: String; //"Your computer has used up all available MS Windows GUI resorces.  You need to close some windows to free up resources before you can open any more applications or windows.";
begin
	//cnwjo3 par 20217, they can't press X.  Can only click OK
	self.controlBox := false;  
	
	//par 16649 AER 10/10/2008
	gdi_warning :=  app.getErrorString(NoMore_Restrictions);
	lblMessage.cnEcSet(gdi_warning);
	self.centreWindow();
	self.visible	:=	true;
	self.show();
end;</source>
    </JadeMethod>
</GUIClass>
