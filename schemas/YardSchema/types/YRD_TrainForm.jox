    <JadeMethod name="tblTrans_click" id="710bd105-be6a-4c5f-9bca-d5fd5f599bd6">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblTrans_click(table: Table input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 August 2009	cnwndl1	Initial creation

*/

vars

begin
	if table.row &gt; table.fixedRows then
		self.mnuInspectObject.userObject := table.accessRow(table.row).itemObject;
		self.mnuColumnOrganiser.userObject := table;
	else
		self.mnuInspectObject.userObject := null;
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
