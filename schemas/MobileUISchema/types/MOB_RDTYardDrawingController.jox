    <JadeMethod name="gotoLocationByString" id="f4c03ad1-7f68-4f69-832a-ad8e0d7382a8">
        <updating/>
        <source>gotoLocationByString(_location : String; _mode : Integer; _calcBestZoom : Boolean) : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 April 2010	cnwjk3	Initial creation

*/

vars
	location 	: String;
	height	 	: Integer;
	lc			: CM_LocationsController;
	glc			: CM_GridController;
begin	

	if _location = null then 
		return false;
	endif;
	location := _location.trimBlanks();
	
	self.myTerminal.findLocationFromString(location, true, lc, height);
	self.targetLocationHeight := height; // Used for side view
	return self.gotoLocationByID(lc, _mode, _calcBestZoom);
	
epilog

end;</source>
        <Parameter name="_location" type="String"/>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_calcBestZoom" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="gridPointsToLCPoints" id="7fbbc370-ac4d-4101-a415-671c9db315c8">
        <source>gridPointsToLCPoints(_x1, _y1, _x2, _y2 : Real io) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2010	cnwjk3	Initial creation

*/

vars
	tx, ty,
	lcXOffsetPixels,
	lcYOffsetPixels,
	lcWidthPixels,
	lcLengthPixels	: Real;
begin
	lcXOffsetPixels := self.getSizeInPixels(self.lcXGridOffsetFt);
	lcYOffsetPixels := self.getSizeInPixels(self.lcYGridOffsetFt);
	
	if self.isLandscape then
		lcWidthPixels := self.getSizeInPixels(self.lcHeightFt);
		lcLengthPixels := self.getSizeInPixels(self.lcWidthFt);	
		
		// New
		tx := lcXOffsetPixels;
		lcXOffsetPixels := lcYOffsetPixels;
		lcYOffsetPixels := tx;
		//

	else
		lcWidthPixels := self.getSizeInPixels(self.lcWidthFt);
		lcLengthPixels := self.getSizeInPixels(self.lcHeightFt);		
	endif;
	
	if self.flipH then 
		_x1 := _x2 - lcXOffsetPixels;
		_x2 := _x1 - lcWidthPixels;
	else
		_x1 := _x1 + lcXOffsetPixels;
		_x2 := _x1 + lcWidthPixels;		
	endif;
	
	if self.flipV then
		_y1 := _y2 - lcYOffsetPixels;
		_y2 := _y1 - lcLengthPixels;
	else
		_y1 := _y1 + lcYOffsetPixels;
		_y2 := _y1 + lcLengthPixels;
	endif;
	
	// This makes things easier later on...
	if _x1 &gt; _x2 then
		tx := _x1;
		_x1 := _x2;
		_x2 := tx;
	endif;
	if _y1 &gt; _y2 then
		ty := _y1;
		_y1 := _y2;
		_y2 := ty;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real" usage="io"/>
        <Parameter name="_y1" type="Real" usage="io"/>
        <Parameter name="_x2" type="Real" usage="io"/>
        <Parameter name="_y2" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="gridPointsToTIPoints" id="1900f365-67e9-4fb0-8410-dff09488396b">
        <source>gridPointsToTIPoints(_x1, _y1, _x2, _y2 : Real io; _ti : CM_TrackedItem) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 April 2010	cnwjk3	Initial creation

*/

vars
	tx, ty,
	tiXOffsetPixels,
	tiYOffsetPixels,
	tiWidthPixels,
	tiLengthPixels	: Real;
begin
	tiXOffsetPixels := self.getSizeInPixels(self.tiXGridOffsetFt);
	tiYOffsetPixels := self.getSizeInPixels(self.tiYGridOffsetFt);
	
	if self.isLandscape then
		tiWidthPixels := self.getLengthOfTIInPixels(_ti);
		tiLengthPixels := self.getWidthOfTIInPixels(_ti);
		
		// New
		tx := tiXOffsetPixels;
		tiXOffsetPixels := tiYOffsetPixels;
		tiYOffsetPixels := tx;
		//
	else
		tiWidthPixels := self.getWidthOfTIInPixels(_ti);
		tiLengthPixels := self.getLengthOfTIInPixels(_ti);	
	endif;

	if self.flipH then 
		_x1 := _x2 - tiXOffsetPixels;
		_x2 := _x1 - tiWidthPixels;
	else
		_x1 := _x1 + tiXOffsetPixels;
		_x2 := _x1 + tiWidthPixels;		
	endif;
	
	if self.flipV then
		_y1 := _y2 - tiYOffsetPixels;
		_y2 := _y1 - tiLengthPixels;
	else
		_y1 := _y1 + tiYOffsetPixels;
		_y2 := _y1 + tiLengthPixels;
	endif;
	
	// This makes things easier later on...
	if _x1 &gt; _x2 then
		tx := _x1;
		_x1 := _x2;
		_x2 := tx;
	endif;
	if _y1 &gt; _y2 then
		ty := _y1;
		_y1 := _y2;
		_y2 := ty;
	endif;
		
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real" usage="io"/>
        <Parameter name="_y1" type="Real" usage="io"/>
        <Parameter name="_x2" type="Real" usage="io"/>
        <Parameter name="_y2" type="Real" usage="io"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="gridRowToStackHeight" id="9c51e695-f663-42fb-99cd-641f90360992">
        <source>gridRowToStackHeight(_row : Integer; _gridArea : CM_GridArea) : Integer protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
04 June 2010	cnwjk3	Initial creation

*/

vars

begin
	return _gridArea.getHeightOfStack() - _row + 1;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_row" type="Integer"/>
        <Parameter name="_gridArea" type="CM_GridArea"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="hScrollAmount" id="99ea89fe-5d64-4715-a7ad-74daaaa574cc">
        <methodInvocation>mapping</methodInvocation>
        <source>hScrollAmount(set: Boolean; _value: Real io) protected, mapping;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2010	cnwjk3	Initial creation

*/

vars

begin
	if set then
		// set code here
	else
		// get code here
		_value := self.hScrollFactor * self.getGridWidth();
	endif;


epilog

end;</source>
        <access>protected</access>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="hideLocationHighlight" id="8cec209a-cc01-4c99-ab7d-1b9c4af2c48b">
        <source>hideLocationHighlight() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 April 2010	cnwjk3	Initial creation

*/

vars
	picture	: Picture;
begin
	// top
	picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicTopBar();
	picture.visible := false;

	// bottom
	picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicBottomBar();
	picture.visible := false;

	// left
	picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicLeftBar();
	picture.visible := false;
	
	// Right
	picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicRightBar();
	picture.visible := false;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="highlightLocation" id="c4cc5946-9093-48b1-89dd-1aa28eefc47d">
        <source>highlightLocation( _x1, _y1, _x2, _y2 : Real) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 April 2010	cnwjk3	Initial creation

*/

vars
	picture			: Picture;
	
begin

	picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicHBar();

	// top
	self.myTIFrame.drawPictureIn(picture.picture, _x1, _y1, _x2, _y1 + 4);
	
	// bottom
	self.myTIFrame.drawPictureIn(picture.picture, _x1, _y2-4, _x2, _y2);

	picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicVBar();

	// left
	self.myTIFrame.drawPictureIn(picture.picture, _x1, _y1, _x1+4, _y2);
	
	// right
	self.myTIFrame.drawPictureIn(picture.picture, _x2-4, _y1, _x2, _y2);
		
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
    </JadeMethod>
    <JadeMethod name="highlightSelectedLocation" id="22e642f1-1e06-4114-9882-5c8da28e4b92">
        <source>highlightSelectedLocation( _x1, _y1, _x2, _y2 : Real; _ti : CM_TrackedItem ) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
08 April 2010	cnwjk3	Initial creation

*/

vars
	lx1, lx2,
	ly1, ly2		: Real;
	operator 		: CM_Operator;
	tiColour,
	highlightColour,
	oldDrawStyle,
	oldDrawWidth    : Integer;
	picture			: Picture;
begin
	lx1 := _x1;
	lx2 := _x2;
	ly1 := _y1;
	ly2 := _y2;
	
	if _ti &lt;&gt; null then 
	
		operator := app.myRoot.allOperators[_ti.operatorCode];
		if operator &lt;&gt; null then
			tiColour := operator.colour;
			highlightColour := tiColour.getInverseColour();
		else
			highlightColour := Black;
		endif;
		
		// Adjust the selector size to matc the TI. Can only really do this
		// if this is the primary location
		if self.isLandscape then
			if self.flipH then
				lx1 := lx2 - self.getLengthOfTIInPixels(_ti);
			else
				lx2 := lx1 + self.getLengthOfTIInPixels(_ti);
			endif;
		else
			if self.flipV then
				ly1 := ly2 - self.getLengthOfTIInPixels(_ti);
			else
				ly2 := ly1 + self.getLengthOfTIInPixels(_ti);
			endif;
		endif;

	else
		highlightColour := Black;
	endif;

	oldDrawWidth := self.myTIFrame.drawWidth;
	oldDrawStyle := self.myTIFrame.drawStyle;
	
	self.myTIFrame.autoRedraw := true;
	self.myTIFrame.drawWidth := 4;
	
	// top
	picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicTopBar();
	picture.width := lx2 - lx1;
	picture.height := 4;
	picture.left := lx1;
	picture.top := ly1;

	// bottom
	picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicBottomBar();
	picture.width := lx2 - lx1;
	picture.height := 4;
	picture.left := lx1;
	picture.top := ly2 - picture.height;

	// left
	picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicLeftBar();
	picture.width := 4;
	picture.height := ly2 - ly1;
	picture.left := lx1;
	picture.top := ly1;
	
	
	// Right
	picture := self.myDrawingFrame.form.IF_RDTYardForm.getPicRightBar();
	picture.width := 4;
	picture.height := ly2 - ly1;
	picture.left := lx2 - picture.width;
	picture.top := ly1;
		
	self.showlocationHighlight();
	
	self.myTIFrame.drawWidth := oldDrawWidth;
	self.myTIFrame.drawStyle := oldDrawStyle;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="init" id="b92d9964-cf42-41b6-ae40-af5af5727fb7">
        <updating/>
        <source>init(_mode : Integer; _drawingFrame, _tiFrame, _viewportFrame : Frame ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 April 2010	cnwjk3	Initial creation

*/

vars

begin
	
	// The viewport frame will have a parent aspect of stretch both, so will always be the right size
	// The drawing and TI frames will be children of the viewport frame and will be larger to allow items
	// to be drawn outside of the viewport.  This helps with scrolling items into view, which span more than
	// one grid square.   The drawing and TI frames need to adjust in size when the zoom level changes. 
	
	self.myViewportFrame := _viewportFrame;
	
	self.myDrawingFrame := _drawingFrame;
	self.myTIFrame := _tiFrame;
	self.myDrawingFrame.autoRedraw := true;
	self.myTIFrame.autoRedraw := true;

	self.scaleFactor := 2;
	self.flipH := false;
	self.flipV := false;
	self.isLandscape := false;
	self.isInitialised := true;
	self.showGrid := false;
	self.showGuideLines := true;
	self.isFancyGFX := true;
	self.drawMode := _mode; // Default to top-down view
	
	self.resizeDrawingFrames();
	
epilog
	
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_drawingFrame" type="Frame"/>
        <Parameter name="_tiFrame" type="Frame"/>
        <Parameter name="_viewportFrame" type="Frame"/>
    </JadeMethod>
    <JadeMethod name="isLCBackendOf40" id="055bebc6-9260-44ce-a12a-4db4b1d7e64c">
        <source>isLCBackendOf40(_lc : CM_LocationsController; _ti : CM_TrackedItem) : Boolean protected;

/*

Purpose:			
 Indicate whether the location is holding the back-end of a 40 footer
Parameters:			

Return Value:		


Date		Who		Reason
03 May 2010	cnwjk3	Initial creation

*/

vars

begin
	if not _ti.isKindOf(CM_Container) then 
		return false;
	endif;
		
	if not _ti.CM_Container.is40 then
		return false;
	endif;
	
	return _ti.myPrimaryActualLocation &lt;&gt; null and _ti.myPrimaryActualLocation &lt;&gt; _lc;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isLCFrontendOf40" id="4f14ddc8-bcb6-43ef-86da-d8f321a3c2e5">
        <source>isLCFrontendOf40(_lc : CM_LocationsController; _ti : CM_TrackedItem) : Boolean protected;

/*

Purpose:			
 Indicate whether the location is holding the front-end of a 40 footer
Parameters:			

Return Value:		


Date		Who		Reason
03 May 2010	cnwjk3	Initial creation

*/

vars

begin
	if not _ti.isKindOf(CM_Container) then 
		return false;
	endif;
		
	if not _ti.CM_Container.is40 then
		return false;
	endif;
	
	return _ti.myPrimaryActualLocation &lt;&gt; null and _ti.myPrimaryActualLocation = _lc;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_LocationsController"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isLocationInGriddedArea" id="1fc08763-d50e-43e0-aafb-11fb62903b85">
        <source>isLocationInGriddedArea(_lc : CM_LocationsController) : Boolean  protected;

/*

Purpose:			

Parameters:			

