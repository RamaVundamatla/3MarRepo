    <JadeMethod name="checkForAutoVolumeCalc" id="3928505c-55cb-4b73-8939-c2b779c77683">
        <source>checkForAutoVolumeCalc(_objectArray: ObjectArray;_ti : CM_TrackedItem)  :Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Aug 2017	cnwma1	TFS #5695:STWO - Re-Calculate Volumes on Forms and EDI

*/

vars
	canAccess : Boolean;
	obj 	  : Object;
	ti,
	firstTi	  : CM_TrackedItem;
	checkedItems : CM_TIArray;
	
begin
	firstTi := _ti;
	//7/5/19 MAP TFS41707
	//This if only 1 cargoItem
	if not _ti.myCargoType.isBreakBulk and not _ti.isBulkCargo then
		return false;
	endif;
	
	if not _ti.myCargoType.allowAutoVolumeCalc then
		return false;
	endif;
	
	if _ti.myProduct &lt;&gt; null and _ti.myProduct.autoVolumeCalculate then
		return false;
	endif;

	
	if _objectArray.isEmpty and firstTi &lt;&gt; null then
		return true;
	endif;
	
	create checkedItems transient;
	foreach obj in _objectArray do
	
		if  obj.isKindOf(CM_BreakBulkGeneric) then
			ti := obj.CM_BreakBulkGeneric;
		else
			return false;
		endif;

		if not  (ti.myCargoType.isBreakBulk or _ti.myCargoType.isBulk ) then
			return false;
		endif;
	
		if not ti.myCargoType.allowAutoVolumeCalc then
			return false;
		endif;
		
		if ti.myProduct &lt;&gt; null and _ti.myProduct.autoVolumeCalculate then
			return false;
		endif;
	
		if firstTi.myCargoType 	 = ti.myCargoType 		and 
		   firstTi.myProduct  	 = ti.myProduct   		and
		   firstTi.totalQuantity = ti.totalQuantity     and 
		   firstTi.quantity      = ti.quantity			and
		   firstTi.width		 = ti.width				and
		   firstTi.length		 = ti.length			and
		   firstTi.height		 = ti.height			then
		   checkedItems.add(ti);
		   
		else
			return false;
		endif;

	
	endforeach;
	
	if not checkedItems.isEmpty then
		if checkedItems.size = _objectArray.size then
			return true;
		endif;
	else
		return false;
	endif;
epilog
	delete checkedItems;
end;</source>
        <Parameter name="_objectArray" type="ObjectArray"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkForDiffCargoTypes" id="87d3bb89-c634-4518-b69c-5d25da911a84">
        <source>checkForDiffCargoTypes(_objArray : ObjectArray) : Boolean;

/*

Purpose:		Check to see if we have multiple types of cargo types	

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2010	cnwmh5	Initial creation

*/

vars

	obj				: Object;
	cargoType		: CM_CargoType;
	
	diffCargoTypes	: Boolean;
	compareString	: String;
begin

	// read through array till find one different
	foreach obj in _objArray do
		
		// get the cargo type.  if null then get next one
		cargoType := obj.CM_TrackedItem.myCargoType;
		if cargoType = null then
			continue;
		endif;
		
		// add 1st one to compareString.  Check to see whether subsequent ones are same or different/
		// if different then leave
		if compareString &lt;&gt; null and not compareString.startsWith(cargoType.description) then
			diffCargoTypes := true;
			break;
		else
			compareString := cargoType.description;
		endif;
		
	endforeach;

	return diffCargoTypes;

epilog

end;</source>
        <Parameter name="_objArray" type="ObjectArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkProxyStopApplicable" id="d5ad9591-3ca7-475a-9a26-37b191350767">
        <source>checkProxyStopApplicable();
/*

Purpose:			This method go through all stops in the pxyTI
					Check whether the stop is still matching the stop criteria
					If it doesn't, cancel the stop

Parameters:			

Return Value:		

Date		Who		Reason
07/02/2023	navkc1 CR 61168 Task 62372: Jade - TI Update Stop Criteria Check
25/03/2024	navkc1 Defect 62985: EUP - COO - Approve - Remove of stops not working
*/

vars
	pxyTI		: CM_TrackedItem;
	pxyStop		: CM_Stops;
	stopTable	: CM_StopsTable;
	allPxyStops	: CM_StopsByIdDict;
begin
	
	// Loop all proxy TI
	foreach pxyTI in self.allProxyObjects as CM_TrackedItem do
		//25/03/2024	navkc1 Defect 62985
		pxyTI.checkProxyStopApplicable();
	endforeach;
	
epilog
	
end;</source>
    </JadeMethod>
