    <JadeMethod name="getLocationId" id="4f3cc78a-ed08-4db9-89ee-a629b2b1f253">
        <source>getLocationId(_mode : Integer; _ti : CM_TrackedItem) : String;
// ---------------------------------------------------------------------------
// Created:     
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	str : String;
	stowId : String;

begin

	sharedLock(self.myVoyage);

	str := self.myVoyage.code.trimBlanks;
	str := str &amp; " " &amp; self.getStowageId(_ti);
	str := str.toUpper;

	return str;
epilog
	unlock(self.myVoyage);
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
