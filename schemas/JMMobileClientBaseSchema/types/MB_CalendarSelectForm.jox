    <JadeMethod name="calCalendar_paint" id="ec7102bd-c36b-46ff-97a3-3a7f1d7e0db4">
        <controlMethod name="MB_Calendar::paint"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>calCalendar_paint(cntrl: MB_Calendar input) updating;
// --------------------------------------------------------------------------------
// Created:		01 February 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if calCalendar.getIsBuilt() then
		if txtDate.text.trimBlanks() &lt;&gt; null then
			self.setCalendarDate();
		else
			calCalendar.click(calCalendar);
		endif;
	endif;
end;</source>
        <Parameter name="cntrl" type="MB_Calendar" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUpdateDateTime" id="51b37233-73cc-42a4-bf3b-3f1b069901f8">
        <updating/>
        <source>doUpdateDateTime() updating, protected;
// --------------------------------------------------------------------------------
// Created:		01 February 2006 by cnwdad1
//
// Purpose:		Updates the date/time values, then closes the form with the modal
//				result set to "select".
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.aDate &lt;&gt; null then
		self.aDate	:=	txtDate.text.Date;
		self.aTimeStamp.setDate(self.aDate);
	endif;
	
	if self.aTime &lt;&gt; null then
		self.aTime	:=	txtTime.text.Time;
		self.aTimeStamp.setTime(self.aTime);
	endif;
	
	self.modalResult		:=	self.MB_MODAL_SELECT;
	self.aMyControl.text	:=	calCalendar.date.shortFormatJMT();
	self.unloadForm();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doValidate" id="bab043f3-3355-4a87-bbb9-845893baeb4f">
        <source>doValidate():Boolean protected;
// --------------------------------------------------------------------------------
// Created:		01 February 2006 by cnwdad1
//
// Purpose:		Validates the entered/selected date (and time if appropriate).
//
// Parameters:	None
//
// Returns:		True if the date/time are valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	currentDate		: Date;
	currentTime		: Time;
	errorMessage	: String;
	isDateValid		: Boolean;

begin
	isDateValid	:=	true;
	
	if txtDate.text.trimBlanks() &lt;&gt; null then
		currentDate	:=	txtDate.text.trimBlanks().Date;
		
		if not currentDate.isValid() then
			isDateValid			:=	false;
			errorMessage		:=	"The format of the date is incorrect. Please use 'dd/mm/ccyy' format";
			self.txtDate.text	:=	calCalendar.date.shortFormatJMT();
			txtDate.setFocus();
		endif;
	endif;
	
	if self.aIsTimeStamp then
		if txtTime.text &lt;&gt; null then
			currentTime	:=	txtTime.text.trimBlanks().Time;
		endif;
		
		if not currentTime.isValid() then
			if errorMessage = null then
				errorMessage	:=	"The format of the time is incorrect. Please use 'HH:mm' format";
			else
				errorMessage	:=	errorMessage &amp; CrLf &amp; "The format of the time is incorrect. Please use 'HH:mm' format";
			endif;
			
			self.txtTime.text	:=	app.actualTimeServer().time.currentLocaleFormatJMT();
			
			if isDateValid then
				txtTime.setFocus();
			endif;
		endif;
	endif;
	
	if errorMessage = null then
		return true;
	else
//		app.msgBox(errorMessage, "Error", MsgBox_Exclamation_Mark_Icon + MsgBox_OK_Only);
		return false;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCalendarDate" id="0883e702-3f82-40f0-aac4-c88baf8ae999">
        <source>setCalendarDate() protected;
// --------------------------------------------------------------------------------
// Created:		01 February 2006 by cnwdad1
//
// Purpose:		Sets the calendar date according to the current date in the date
//				textbox control.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	calCalendar.date	:=	txtDate.text.trimBlanks().Date;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setDateTime" id="2986aa11-7da5-477f-bb4f-2e157e97dda7">
        <updating/>
        <source>setDateTime(_date:Date; _time:Time; _isTimeStamp:Boolean) updating;
// --------------------------------------------------------------------------------
// Created:		01 February 2006 by cnwdad1
//
// Purpose:		Sets the receiver's date.
//
// Parameters:	_date - The default date for the receiver.
//				_time - The default time for the receiver.
//				_isTimeStamp - True if the form is to handle a timestamp, as opposed
//					to just handling a date only.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.aDate		:=	_date;
	
	if _isTimeStamp then
		self.aTime			:=	_time;
		self.aTimeStamp.setDate(_date);
		self.aTimeStamp.setTime(_time);
		self.aIsTimeStamp	:=	_isTimeStamp;
	endif;
end;</source>
        <Parameter name="_date" type="Date"/>
        <Parameter name="_time" type="Time"/>
        <Parameter name="_isTimeStamp" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTableTime" id="14064638-1009-4b43-808e-a2d3a8859346">
        <source>setTableTime() protected;
// --------------------------------------------------------------------------------
// Created:		02 February 2006 by cnwdad1
//
// Purpose:		Sets the minutes and hours tables according to the current time in
//				the time textbox control.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	currentTime		: Time;
	hoursTableObj	: Table;
	minutesTableObj	: Table;
	startRow		: Integer;
	endRow			: Integer;
	rowPointer		: Integer;
	hourValue		: Integer;
	minuteValue		: Integer;
	cellValue		: Integer;
	roundedMinutes	: Integer;
	
begin
	currentTime	:=	txtTime.text.Time;
	hourValue	:=	currentTime.hour;
	minuteValue	:=	currentTime.minute;
	
	if hourValue &lt; 12 then
		hoursTableObj	:=	tblHoursAM;
		tblHoursPM.clearAllSelected();
	else
		hourValue		:=	hourValue - 12;
		hoursTableObj	:=	tblHoursPM;
		tblHoursAM.clearAllSelected();
	endif;
	
	hoursTableObj.clearAllSelected();
	startRow	:=	hoursTableObj.fixedRows + 1;
	endRow		:=	hoursTableObj.rows;
	
	foreach rowPointer in startRow to endRow do
		cellValue	:=	hoursTableObj.getCellText(rowPointer, 1).Integer;
		
		if (hourValue = 0 and cellValue = 12)
		or cellValue = hourValue
		then
			hoursTableObj.setCellSelected(rowPointer, 1, true);
			break;
		endif;
	endforeach;
	
	if minuteValue &lt;&gt; 5 and minuteValue &lt; 10 then
		minutesTableObj	:=	tblMinutesOnes;
		tblMinutesFives.clearAllSelected();
		self.tableInitializeMinutesOnes(0);
	else
		if (minuteValue mod 5) = 0 then
			self.tableInitializeMinutesOnes(minuteValue);
			minutesTableObj	:=	tblMinutesFives;
		else
			roundedMinutes	:=	(minuteValue div 5) * 5;
			self.tableInitializeMinutesOnes(roundedMinutes);
			minutesTableObj	:=	tblMinutesOnes;
		endif;
		
		tblMinutesFives.clearAllSelected();
	endif;
	
	minutesTableObj.clearAllSelected();
	startRow	:=	minutesTableObj.fixedRows + 1;
	endRow		:=	minutesTableObj.rows;
	
	foreach rowPointer in startRow to endRow do
		cellValue	:=	minutesTableObj.getCellText(rowPointer, 1).Integer;
		
		if cellValue = minuteValue then
			minutesTableObj.setCellSelected(rowPointer, 1, true);
			break;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="8c1172de-4229-469f-8b58-c3d5fdeb68a0">
        <updating/>
        <source>setupForm() updating;
// --------------------------------------------------------------------------------
// Created:		01 February 2006 by cnwdad1
//
// Purpose:		Standard form setup method.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// --------------------------------------------------------------------------------
begin
	inheritMethod();
	calCalendar.dayNameLength	:=	2;
	
	self.aMyControl	:=	txtDate;
	
	if self.aMyControl.text.trimBlanks().Date.isValid() then
		//self.attr_Date	:=	aMyControl.AFDateTimeTextBox.text.trimBlanks.afAsDate.String;
		self.aDate	:=	self.aMyControl.text.trimBlanks().Date;
		self.aTimeStamp.setDate(self.aDate);
	endif;

	if self.aDate = null then
		self.aDate	:=	app.actualTimeServer.date();// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
		self.aTimeStamp.setDate(self.aDate);
	endif;
	
	self.setupLayout();
	
	calCalendar.fontBold	:=	true;
	calCalendar.fontSize	:=	18;
	txtDate.text	:=	self.aDate.shortFormatJMT();
	txtTime.text	:=	self.aTime.currentLocaleFormatJMT();
	txtDate.setFocus();
	self.setTableTime();
	btnOk.default	:=	true;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupLayout" id="bf6d88a2-c1ef-4c2f-b283-c5229b50211a">
        <updating/>
        <source>setupLayout() updating, protected;
// --------------------------------------------------------------------------------
// Created:		01 February 2006 by cnwdad1
//
// Purpose:		Sets up the receiver's layout, based upon whether we're dealing
//				just a TimeStamp, or just a Date.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	txtDate.mask	:=	"dd\/MM\/yyyy";
	
	if self.aIsTimeStamp then
		txtTime.mask	:=	"hh:mm";
		self.width		:=	(calCalendar.width * 2) + 6;
		self.tableInitializeHoursMinutes();
	else
		self.width		:=	calCalendar.width + 6;
		txtDate.mask	:=	"dd\/MM\/yyyy";
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tableInitializeHoursMinutes" id="e849e1fa-e1ff-476f-97e6-8240ba053112">
        <source>tableInitializeHoursMinutes() protected;
// --------------------------------------------------------------------------------
// Created:		01 February 2006 by cnwdad1
//
// Purpose:		Initializes the hours and minutes tables for the time setting.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj	: Table;
	
begin
	tableObj			:=	tblHoursAM;
	tableObj.clear();
	tableObj.rows		:=	1;
	tableObj.columns	:=	1;
	tableObj.fontBold	:=	true;
	tableObj.fontSize	:=	18;
	tableObj.accessColumn(1).alignment	:=	Table.Alignment_Center;
	tableObj.setCellText(1, 1, "AM");
	tableObj.addItem("12");
	tableObj.addItem("1");
	tableObj.addItem("2");
	tableObj.addItem("3");
	tableObj.addItem("4");
	tableObj.addItem("5");
	tableObj.addItem("6");
	tableObj.addItem("7");
	tableObj.addItem("8");
	tableObj.addItem("9");
	tableObj.addItem("10");
	tableObj.addItem("11");
	
	tableObj			:=	tblHoursPM;
	tableObj.clear();
	tableObj.rows		:=	1;
	tableObj.columns	:=	1;
	tableObj.fontBold	:=	true;
	tableObj.fontSize	:=	18;
	tableObj.accessColumn(1).alignment	:=	Table.Alignment_Center;
	tableObj.setCellText(1, 1, "PM");
	tableObj.addItem("12");
	tableObj.addItem("1");
	tableObj.addItem("2");
	tableObj.addItem("3");
	tableObj.addItem("4");
	tableObj.addItem("5");
	tableObj.addItem("6");
	tableObj.addItem("7");
	tableObj.addItem("8");
	tableObj.addItem("9");
	tableObj.addItem("10");
	tableObj.addItem("11");
	
	tableObj			:=	tblMinutesFives;
	tableObj.clear();
	tableObj.rows		:=	1;
	tableObj.columns	:=	1;
	tableObj.fontBold	:=	true;
	tableObj.fontSize	:=	18;
	tableObj.accessColumn(1).alignment	:=	Table.Alignment_Center;
	tableObj.setCellText(1, 1, "Mins");
	tableObj.addItem("0");
	tableObj.addItem("5");
	tableObj.addItem("10");
	tableObj.addItem("15");
	tableObj.addItem("20");
	tableObj.addItem("25");
	tableObj.addItem("30");
	tableObj.addItem("35");
	tableObj.addItem("40");
	tableObj.addItem("45");
	tableObj.addItem("50");
	tableObj.addItem("55");
	tableObj.addItem("60");
	
	self.tableInitializeMinutesOnes(0);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="tableInitializeMinutesOnes" id="d384fa68-b412-4dbe-9544-2a4f3726cdf3">
        <source>tableInitializeMinutesOnes(_fivesValue:Integer) protected;
// --------------------------------------------------------------------------------
// Created:		02 February 2006 by cnwdad1
//
// Purpose:		Initializes the single minutes table, using the parameter as a start
//				value.  If the start is zero, then single minutes will be populated
//				(e.g. 0, 1, 2, 3...), otherwise we'll start from five numbers back
//				from the start before loading the 10 numbers, this gives five numbers
//				either side of the start value for the user to choose from.
//
// Parameters:	_fivesValue - The start value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj	: Table;
	startMinute	: Integer;
	endMinute	: Integer;
	value		: Integer;
	
begin
	if _fivesValue = 0 then
		startMinute	:=	0;
		endMinute	:=	startMinute + 9;
	else
		startMinute	:=	_fivesValue - 4;
		endMinute	:=	startMinute + 8;
	endif;
	
	
	tableObj			:=	tblMinutesOnes;
	tableObj.clear();
	tableObj.rows		:=	1;
	tableObj.columns	:=	1;
	tableObj.fontBold	:=	true;
	tableObj.fontSize	:=	18;
	tableObj.accessColumn(1).alignment	:=	Table.Alignment_Center;
	tableObj.setCellText(1, 1, "Mins");
	
	foreach value in startMinute to endMinute do
		tableObj.addItem(value.String);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="_fivesValue" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblHoursAM_click" id="f0cac00b-bf40-433c-ba0e-a19beb7e10e4">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblHoursAM_click(table: Table input) updating;
// --------------------------------------------------------------------------------
// Created:		02 February 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj	: Table;
	value		: Integer;
	currentTime	: Time;
	setTime		: Time;
	
begin
	app.mousePointer	:=	Busy;
	tableObj			:=	table;
	value				:=	tableObj.getCellText(tableObj.row, tableObj.column).Integer;
	
	if value = 12 then
		value	:=	0;
	endif;
	
	setTime	:=	txtTime.text.trimBlanks().Time;
	
	if not setTime.isValid() then
		setTime	:=	currentTime;
	endif;
	
	setTime.setTime(value, setTime.minute, setTime.second, setTime.milliSecond);
	txtTime.text		:=	setTime.currentLocaleFormatJMT();
	tblHoursPM.clearAllSelected();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblHoursPM_click" id="3c67f17f-30a1-4095-a465-1dbfa1f53dd6">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblHoursPM_click(table: Table input) updating;
// --------------------------------------------------------------------------------
// Created:		02 February 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj	: Table;
	value		: Integer;
	currentTime	: Time;
	setTime		: Time;
	
begin
	app.mousePointer	:=	Busy;
	tableObj			:=	table;
	value				:=	tableObj.getCellText(tableObj.row, tableObj.column).Integer;
	
	if value &lt; 12 then
		value	:=	value + 12;
	endif;
	
	setTime	:=	txtTime.text.trimBlanks().Time;
	
	if not setTime.isValid() then
		setTime	:=	currentTime;
	endif;
	
	setTime.setTime(value, setTime.minute, setTime.second, setTime.milliSecond);
	txtTime.text		:=	setTime.currentLocaleFormatJMT();
	tblHoursAM.clearAllSelected();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblMinutesFives_click" id="66c82720-4d59-44a6-9eac-4615252312c4">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMinutesFives_click(table: Table input) updating;
// --------------------------------------------------------------------------------
// Created:		02 February 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	tableObj	: Table;
	value		: Integer;
	currentTime	: Time;
	setTime		: Time;
	
begin
	app.mousePointer	:=	Busy;
	tableObj			:=	table;
	value				:=	tableObj.getCellText(tableObj.row, tableObj.column).Integer;
	self.tableInitializeMinutesOnes(value);
	
	setTime	:=	txtTime.text.trimBlanks().Time;
	
	if not setTime.isValid() then
		setTime	:=	currentTime;
	endif;
	
	setTime.setTime(setTime.hour, value, setTime.second, setTime.milliSecond);
	txtTime.text		:=	setTime.currentLocaleFormatJMT();
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
