    <JadeMethod name="trxProcessEDITICargo" id="2c4d64af-42a2-4d0b-86a0-32f1605fcc7e">
        <updating/>
        <source>trxProcessEDITICargo(_ediTI : CM_EDICargoTI input; _updateController : CMIF_TIUpdateController input; _realTI : CM_TrackedItem output; _coll : CM_TIByCargoTypeIdDict; _validateOnly : Boolean; _passport : CM_Passport input) updating;
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 03 Jan 2018	jlgrs1	TFS 36430 Penn Ship Manifest too many locks
// 03 Jul 2018	jlgrs1	TFS 39298 (TFS 36430) Penn Ship Manifest too many locks
// 14 Jan 2019	jlgrs1	TFS 41659 42276 42276 STWR Make EDI MultiThreaded Stage 8
// 10 Jul 2020	jlgmd1	TFS 49690 STWR Remove the updront lock of the voyage so CargoOnSite and CargoFieldUpdate EDI messages play nice together
//
vars
	status : Integer;
	voyage : CM_Voyage;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if _validateOnly then
		app.setContinueCMExceptions(true);
	else
		app.setContinueCMExceptions(true);
	endif;
//	_passport.setWarningsIgnored(true);
	
	beginTransaction;
	
	_passport.useTITransactionDeferUpdate := true; //par14503 sh3 July 2007
	_passport.useTIDictDeferUpdate := true;
	
	app.myUtilityUA.utlProcessEDITICargo(_ediTI, _updateController, _realTI, _coll, _validateOnly, _passport);

	if _validateOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		return;
	else
		if _passport.noErrors() then
			// sucessful DB Load so update status in same transaction
			_passport.doDeferredUpdates();
		endif;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_ediTI" type="CM_EDICargoTI" usage="input"/>
        <Parameter name="_updateController" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_realTI" type="CM_TrackedItem" usage="output"/>
        <Parameter name="_coll" type="CM_TIByCargoTypeIdDict"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxProcessEDITIsCargo" id="5514d136-95a6-412e-8db7-ac105f15a479">
        <updating/>
        <source>trxProcessEDITIsCargo(_ediData : CM_EDIDataCargoBySite input; _validateOnly : Boolean; _passport : CM_Passport input) updating;
/*
----------   ----------  --------------------------------------------------
Created:	09 Feb 2010 cnwrs1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
20/06/2012	cnwcs5	par 29747 - refactor utl
26/06/2012	cnwcs5	par 29747:1 - fix problem with errors
26/06/2012	cnwcs5	par 29747:2 - make setting status simpler
14 Feb 2013	cnwrs1	Par 31143 EDI TRX not handling dbLoadErrors after no verify errors
04 Aug 2014	cnwrs1	Par 34668	EDI Status can be wrong if doDeferredUpdate fails
12 Nov 2018	jlgrs1	TFS 41659 STWR Make EDI MultiThreaded Stage 6
19 Nov 2025 navhl20 Bug MTN-36492: TPA - Overall System Slowness
*/
vars
	status			: Integer;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if _validateOnly then
		_passport.setPassportEdiMode(CM_Passport.EDI_MODE_VERIFY);		//19.11.2025 navhl20 #36492
		app.setContinueCMExceptions(true);
	else
		_passport.setPassportEdiMode(CM_Passport.EDI_MODE_DBLOAD);		//19.11.2025 navhl20 #36492
		app.setContinueCMExceptions(false);
	endif;

	beginTransaction;
	
	// This can't be set to true (apparently) because of it causing a problem for PNLs notification email sent to Carriers
	_passport.useTITransactionDeferUpdate := false; //par14503 sh3 July 2007
	_passport.useTIDictDeferUpdate := false;
	_passport.useOfflineFutureActorDeferUpd	:= true; // ### JIRA 33873 31JAN2025 NAVAB1
	
	app.myUtilityUA.utlProcessEDICargo(_ediData, _validateOnly, _passport);
	
	if _validateOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		return;
	else
		if _passport.noErrors() then
			// sucessful DB Load so update status in same transaction
			_passport.doDeferredUpdates();
			if _passport.noErrors() then
				// use passport to get new status for EDI Data
				status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
				app.myUtilityUA.utlSetEDIDataStatusAfterVerify(_ediData, status);
			endif;
		endif;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);
	if _validateOnly or _passport.hasErrors then
		// use passport to get new status for EDI Data
		status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(_ediData, status);	// par 27392 cnwrs1 14 Apr 2011
	endif;
end;</source>
        <Parameter name="_ediData" type="CM_EDIDataCargoBySite" usage="input"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxProcessEDIToDoTasks" id="16146a9d-a59a-4101-b7e6-7aca90c2c2ba">
        <updating/>
        <source>trxProcessEDIToDoTasks(_cmifList : DynaDictionary; _validateOnly : Boolean; _ediData : CM_EDIDataToDoTask input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:	22 February 2010 By Graeme Black cnwgb1 PAR 22022 MSl CCMS 1069
// Purpose:	Validate/Update a list of tracked items with ToDo task Changes
// ---------------------------------------------------------------------------
// 06/08/2012	cnwcs5	par 30136 - EDI BGP Split
//14 Feb 2013	cnwrs1	Par 31143 EDI TRX not handling dbLoadErrors after no verify errors
//04 Aug 2014	cnwrs1	Par 34668	EDI Status can be wrong if doDeferredUpdate fails
vars
	cmifObj 			: Object;
	cmif 				: CMIF_EDIToDoTask;
	updateController 	: CMIF_TIUpdateController;
	status 				: Integer;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	updateController := app.createTIUpdateControl(TI_UPDMODE_NORMAL, null, null);
	
	if _validateOnly then
		app.setContinueCMExceptions(true);
	else
		app.setContinueCMExceptions(false);
	endif;
	
	beginTransaction;
	_passport.useTIDictDeferUpdate := true;
	_passport.useTITransactionDeferUpdate := true;
	
	foreach cmifObj in _cmifList do
		cmif := cmifObj.CMIF_EDIToDoTask;
		if cmif = null then
			app.raiseCMException3(UNEXPECTED_PROGRAM_ERROR, self.class.name, method.name, 'cmifObj is not ToDo Task', null, null);
		endif;

		app.myUtilityUA.utlProcessEDIToDoTask( cmif, _validateOnly, _ediData, updateController, _passport); 
		
		if not _validateOnly and _passport.hasErrors() then //If in Update mode, we cam out on the first error cnwgb1 24/2/2010
			break;
		endif;
		
	endforeach;
	
	if _validateOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		return;
	else
		if _passport.noErrors() then
			// sucessful DB Load so update status in same transaction
			_passport.doDeferredUpdates();
			if _passport.noErrors() then
				// use passport to get new status for EDI Data
				status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
				app.myUtilityUA.utlSetEDIDataStatusAfterVerify(_ediData, status);
			endif;
		endif;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);

	if _validateOnly or _passport.hasErrors then
		// use passport to get new status for EDI Data
		status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(_ediData, status);	// par 27392 cnwrs1 14 Apr 2011
	endif;
	delete updateController;
end;</source>
        <Parameter name="_cmifList" type="DynaDictionary"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_ediData" type="CM_EDIDataToDoTask" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxProcessEDITrain" id="a89abbcd-4859-478a-a01e-1063636b3b46">
        <updating/>
        <source>trxProcessEDITrain(_ediData :CM_EDIDataTrain input; _validateOnly : Boolean; _passport : CM_Passport input) updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
14 Feb 2013	cnwrs1	Par 31143 	EDI TRX not handling dbLoadErrors after no verify errors take 4
04 Aug 2014	cnwrs1	Par 34668	EDI Status can be wrong if doDeferredUpdate fails
16 May 2016	cnwns1	TFS 488 	Multi Timezone Support
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
29 Oct 2019	cnwrs1	TFS 47281
20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
============================================================================*/
	
vars
	partsDone 		 : Integer;
	partsInJob 		 : Integer;
	progressStr 	 : String;
	progressTS 		 : TimeStamp;
	ediTI 			 : CM_EDITrackedItem;
	status 			 : Integer;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if _validateOnly then
		app.setContinueCMExceptions(true);
	else
		app.setContinueCMExceptions(false);
	endif;

	beginTransaction;
	
	_passport.useTITransactionDeferUpdate := false; 
	_passport.useTIDictDeferUpdate := false;
//utl
	
	partsInJob	:= _ediData.allEDITrackedItems.size();
	partsDone	:= null;

	progressStr	:= app.getString(Loading_EDI_Data_Total, partsInJob.display);
	progressTS	:= app.actualTimeServer;// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	_ediData.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, _passport);
	
	foreach ediTI in _ediData.allEDITrackedItems do : ediTI_loop
		partsDone := partsDone + 1;
		_ediData.updateProgress(progressTS, progressStr, partsInJob, partsDone, false, _passport);
		
		_ediData.zLoadDB(ediTI.CM_EDITrainTI, _ediData.getMyTerminal, _passport);
	endforeach ediTI_loop;
	
	_ediData.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, _passport);

	if _validateOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		return;
	else
		if _passport.noErrors() then
			// sucessful DB Load so update status in same transaction
			_passport.doDeferredUpdates();
			if _passport.noErrors() then
				// use passport to get new status for EDI Data
				status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
				app.myUtilityUA.utlSetEDIDataStatusAfterVerify(_ediData, status);
			endif;
		endif;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);

	if _validateOnly or _passport.hasErrors then
		// use passport to get new status for EDI Data
		status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(_ediData, status);	// par 27392 cnwrs1 14 Apr 2011
	endif;
end;</source>
        <Parameter name="_ediData" type="CM_EDIDataTrain" usage="input"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxProcessEDITrainConsist" id="a09f2e20-9ff4-4982-a53c-4529c2887d85">
        <updating/>
        <source>trxProcessEDITrainConsist(_ediData : CM_EDIDataTrainConsist input;
							_validateOnly : Boolean;
							_passport : CM_Passport input) updating;
// --------------------------------------------------------------------------------
// Created:		16 February 2010 by cnwdad1
//
// Purpose:		Transaction wrapper to add, delete or update a Train Consist, i.e.
//				Trains, Wagons and Prenotes.
//
// Parameters:	_cmifConsist - A reference to the CMIF object carrying the data to maintain.
//				_isValidate - Trus if objects are to be validated only.
//				_passport - A reference to the current User's Passport object.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//14 Feb 2013	cnwrs1	Par 31143 EDI TRX not handling dbLoadErrors after no verify errors take 3
// --------------------------------------------------------------------------------
//04 Aug 2014	cnwrs1	Par 34668	EDI Status can be wrong if doDeferredUpdate fails
//12 Sep 2023	jlirs1	TFS 60392 EUP | FR 53824 - Transport Manifest - Cargo Group Details
//04 May 2024	navdap1	TFS 64431 DB Loading status when loading the replace Rail manifest file
//24/07/2025	naviv1	MTN-34763 : MTN - Deferred Updates Required For Train Consist EDI
vars
	status : Integer;
	cmifConsist	: CMIF_TrainConsist;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	_passport.allCurrentCellularVoyages.clear;
	_passport.myTerminal.getAllCurrentCellularVoyagesNC(_passport.allCurrentCellularVoyages, false, false);

	if _validateOnly then
		app.setContinueCMExceptions(true);
		app.myPassport.setPassportEdiMode(CM_Passport.EDI_MODE_VERIFY);		//MTN-34763
	else
		app.setContinueCMExceptions(false);
	endif;
	
	// It is neccessary to do this here rather than in the UTL method,
	// because this validation sets up proxies on the CMIF_Prenotes.
	//app.myValCA.valPreNotes(_cmifConsist.allPrenotesToProcess, _passport);
	// Gather up the data to be maintained, onto the CMIF parameter object.
	create cmifConsist transient;
	cmifConsist.myTerminal	:=	_ediData.getMyTerminal();
	
	_ediData.setupCMIFAndValidate(_passport,
								Loading_EDI_Data_Total,
								cmifConsist);
	cmifConsist.fixPassportErrors(_passport); //cnwrd1 par 28809 19.3.2012
	if _passport.noErrors then
		beginTransaction;
		
		_passport.useTITransactionDeferUpdate := true; 	//MTN-34763
		_passport.useEventDeferUpdate := true;			//MTN-34763
		_passport.useTIDictDeferUpdate := true;			//MTN-34763
		
		_passport.setWarningsIgnored(true);		// TFS 64431 Ignore warnings otherwise we don't get a successful EDI DB Load
		app.myUtilityUA.utlProcessEDITrainConsist(cmifConsist, _validateOnly, _passport);
	endif;
	if _validateOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		return;
	else
		if _passport.noErrors() then
			// sucessful DB Load so update status in same transaction
			_passport.doDeferredUpdates();
			if _passport.noErrors() then
				// use passport to get new status for EDI Data
				status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
				app.myUtilityUA.utlSetEDIDataStatusAfterVerify(_ediData, status);
			endif;
		endif;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);

	if _validateOnly or _passport.hasErrors then
		// use passport to get new status for EDI Data
		status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(_ediData, status);	// par 27392 cnwrs1 14 Apr 2011
	endif;
	if app.myPassport.trxCompletedOK() then	//12 Sep 2023	jlirs1	TFS 60392 EUP | FR 53824 - Transport Manifest - Cargo Group Details
		app.myPassport.doTrxPostActions();		
	endif;
	delete cmifConsist;
end;</source>
        <Parameter name="_ediData" type="CM_EDIDataTrainConsist" usage="input"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxProcessEDITransactions" id="e0418882-4f3f-4ad4-8ad9-ad9850b8350c">
        <updating/>
        <source>trxProcessEDITransactions(_ediData : CM_EDIDataTransaction input; _validateOnly : Boolean; _passport : CM_Passport input) updating; 
//
//19 Sep 2012	cnwrs1		CCMS SFW 1290 Transaction file
//
//18 Oct 2012	cnwrs1		CCMS SFW 1290 Transaction file
//14 Feb 2013	cnwrs1	Par 31143 EDI TRX not handling dbLoadErrors after no verify errors
//04 Aug 2014	cnwrs1	Par 34668	EDI Status can be wrong if doDeferredUpdate fails
vars
	status : Integer;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if _validateOnly then
		app.setContinueCMExceptions(true);
	else
		app.setContinueCMExceptions(false);
	endif;

	beginTransaction;
	
	_passport.useTITransactionDeferUpdate := false; 
	_passport.useTIDictDeferUpdate := false;
	
	app.myUtilityUA.utlProcessEDITransactions(_ediData, _validateOnly, _passport);
	
	if _validateOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		return;
	else
		if _passport.noErrors() then
			// sucessful DB Load so update status in same transaction
			_passport.doDeferredUpdates();
			if _passport.noErrors() then
				// use passport to get new status for EDI Data
				status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
				app.myUtilityUA.utlSetEDIDataStatusAfterVerify(_ediData, status);
			endif;
		endif;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);

	if _validateOnly or _passport.hasErrors then
		// use passport to get new status for EDI Data
		status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(_ediData, status);	// par 27392 cnwrs1 14 Apr 2011
	endif;
end;</source>
        <Parameter name="_ediData" type="CM_EDIDataTransaction" usage="input"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxProcessEDIVBSSlots" id="4c9c790d-534e-4330-be5d-3a9c17a714b2">
        <updating/>
        <source>trxProcessEDIVBSSlots(_ediData : CM_EDIDataVBSSlot input; _validateOnly : Boolean; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
27 June 2023		jlizm1	Initial creation TFS 53901 EUP VBS EDI

*/

vars
	status			: Integer;
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if _validateOnly then
		app.setContinueCMExceptions(true);
	else
		app.setContinueCMExceptions(false);
	endif;

	beginTransaction;
	
	_passport.useTITransactionDeferUpdate := false;
	_passport.useTIDictDeferUpdate := false;
	
	app.myUtilityUA.utlProcessEDIVBSSlot(_ediData, _validateOnly, _passport);
	
	if _validateOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		return;
	else
		if _passport.noErrors() then
			// sucessful DB Load so update status in same transaction
			_passport.doDeferredUpdates();
			if _passport.noErrors() then
				// use passport to get new status for EDI Data
				status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
				app.myUtilityUA.utlSetEDIDataStatusAfterVerify(_ediData, status);
			endif;
		endif;
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);

	if _validateOnly or _passport.hasErrors then
		// use passport to get new status for EDI Data
		status := _ediData.getStatusAfterVerifyOrDBLoad(_validateOnly, _passport);
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(_ediData, status);
	endif;
end;</source>
        <Parameter name="_ediData" type="CM_EDIDataVBSSlot" usage="input"/>
