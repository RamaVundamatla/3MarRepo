    <JadeMethod name="registerNotifications" id="07d158ae-0030-40e5-abf0-0f6291273b85">
        <source>registerNotifications();
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 09 September 2019
TFS#		: 45332
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	if self.frmMode = self.Monitoring_Mode then
		self.beginClassNotification(CM_EDIFile, false, Object_Create_Event, Response_Continuous, 0);
		self.beginClassNotification(CM_EDIFile, false, Object_Update_Event, Response_Continuous, 0);		
	endif;
end;</source>
