    <JadeMethod name="setForUpdate" id="b64624fe-ce8a-42b6-a1a0-57555c951f17">
        <updating/>
        <source>setForUpdate(_pxyWWOJobGrouping : CM_WorkOrderJobGroupMethod)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 April 2023	navhl20	ChangeRequest 57712:[54552] EUP - Delivery Dispatch – Adding Work Point Types

*/

vars
	workPoint : CM_WorkPoint;
begin
	self.description 			:= _pxyWWOJobGrouping.description;
	self.code 					:= _pxyWWOJobGrouping.code;
	self.isNotAvailableForEntry := _pxyWWOJobGrouping.isNotAvailableForEntry;
	self.myTerminal				:= _pxyWWOJobGrouping.myTerminal;
	
	self.allGroupingCriteria.clear();
	_pxyWWOJobGrouping.allGroupingCriteria.copyNoDups(self.allGroupingCriteria);
	
	self.allVessels.clear();
	_pxyWWOJobGrouping.allVessels.copyNoDuplicates(self.allVessels,false);
	
	self.allWorkOrderDetailTypes.clear();
	_pxyWWOJobGrouping.allWorkOrderDetailTypes.copyNoDups(self.allWorkOrderDetailTypes);
epilog

end;</source>
        <Parameter name="_pxyWWOJobGrouping" type="CM_WorkOrderJobGroupMethod"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="438cd275-a6a5-4609-b34b-484613219103">
        <updating/>
        <source>setProxy(_code 					   : String;
		 _description			   : String;
		 _isNotAvailableForEntry   : Boolean;
		 _term					   : CM_Terminal;
		 _allGroupingCriteria      : IntegerArray;
		 _allVessels			   : CM_VesselSet;
		 _allWorkOrderDetailsTypes : CM_WorkOrderDetailTypeArray)updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Aug 2023	navma1	ChangeRequest 60063: EUP | Ship Operations in DD - Terminal Config for grouping attributes

*/

vars

begin
	self.code 		 			:= _code;
	self.description 			:= _description;
	self.isNotAvailableForEntry	:= _isNotAvailableForEntry;
	self.myTerminal				:= _term;
	
	self.allGroupingCriteria.clear();
	_allGroupingCriteria.copyNoDups(self.allGroupingCriteria);
	
	self.allVessels.clear();
	_allVessels.copyNoDuplicates(self.allVessels,false);
	
	self.allWorkOrderDetailTypes.clear();
	_allWorkOrderDetailsTypes.copyNoDups(self.allWorkOrderDetailTypes);
epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_isNotAvailableForEntry" type="Boolean"/>
        <Parameter name="_term" type="CM_Terminal"/>
        <Parameter name="_allGroupingCriteria" type="IntegerArray"/>
        <Parameter name="_allVessels" type="CM_VesselSet"/>
        <Parameter name="_allWorkOrderDetailsTypes" type="CM_WorkOrderDetailTypeArray"/>
    </JadeMethod>
