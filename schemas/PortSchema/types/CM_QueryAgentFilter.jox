    <JadeMethod name="qrySealCheckDiscrepancy" id="b015a6f4-67c1-4a85-b3de-1a2c02c8ad48">
        <updating/>
        <source>qrySealCheckDiscrepancy(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 September 2010	cnwndl1	Initial creation	Par 25608

*/

vars

	jrwTrans : CM_JRWSealCheckTransactions;
	trxFilter : CMQF_SealCheckTransactions;
	numSelected : Integer;
	trx : CM_TITransaction;
	iter : Iterator;
	ti : CM_TrackedItem;
	
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	trxFilter := _filter.CMQF_SealCheckTransactions;
	jrwTrans := self.createJRWTransient(CM_JRWSealCheckTransactions).CM_JRWSealCheckTransactions;

	jrwTrans.allTransactions.clear();
	jrwTrans.setAllTerminals(trxFilter.allTerminals);
	trxFilter.allQryImexStatus.copy( jrwTrans.imexStatuses );
	jrwTrans.myVoyage := trxFilter.getMyVoyage;
	jrwTrans.startDate := trxFilter.startDate;
	jrwTrans.endDate := trxFilter.endDate;
	jrwTrans.receiptTransportMode := trxFilter.receiptTransportMode;
	jrwTrans.sealType := trxFilter.sealType;
	jrwTrans.unMatchedOnly := trxFilter.unMatchedOnly;
	
	_filter.filterObjects(jrwTrans.allTransactions, _passport);

	foreach trx in jrwTrans.allTransactions do
		jrwTrans.addSealCheck( trxFilter, trx.CM_SealCheck );
	endforeach;
	
	if jrwTrans.myVoyage &lt;&gt; null and not jrwTrans.myVoyage.archived then
		// need to add dummy jrw seal check lines for all cargo on the voyage that was not checked.
		iter := jrwTrans.myVoyage.allOnshipTIsByCargoTypeId.createIterator;
		while iter.next( ti ) do
			jrwTrans.addNonSealCheck( ti );
		endwhile;
		delete iter;
		iter := jrwTrans.myVoyage.allOnsiteTIsByCargoTypeId.createIterator;
		while iter.next( ti ) do
			jrwTrans.addNonSealCheck( ti );
		endwhile;
		delete iter;
	endif;
	
	if jrwTrans.myVoyage = null then
		numSelected := jrwTrans.allTransactions.size;
	else
		numSelected := jrwTrans.allJRWSealCheckDetailLines.size;
	endif;
	
epilog

	return numSelected;
	delete iter;

end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qrySpecialVoySumm" id="c5b166c3-e7b3-49b7-9470-337b9e8077f7">
        <updating/>
        <source>qrySpecialVoySumm(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 August 2019	jlgndl1	Initial creation	TFS 46131
20 Aug 2019	jlgsl4	TFS 45615 - ASPA - Ship Load Summary
*/

vars

	numSelected 	: Integer;
	jrwTrans		: CM_JRWVoyages;
	filter			: CMQF_ASPAReports;
	loadSummaryDetails : CMIF_ASPAShipLoadSumDtlSByWP;
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	filter := _filter.CMQF_ASPAReports;
	jrwTrans := self.createJRWTransient(CM_JRWVoyages).CM_JRWVoyages;
	
	jrwTrans.setAllTerminals(filter.allTerminals);
	
	if filter.allNonBargeVessels.isNotEmpty() then  // TFS 45615 - code to populate _collection with
		filter.filterVoyageLoadObjects(jrwTrans.allCMIFLoadDetails, _passport); // load summary objects should be in here
		numSelected := jrwTrans.allCMIFLoadDetails.size;
		// TFS 45615 - code to populate _collection with unload summary objects should be under here
	elseif filter.allBargeVessels.isNotEmpty() then	//12 Nov 2019	NDL	TFS 47247
		// TFS 45678
		filter.filterForBargeUnloads(jrwTrans.allCMIFUnloadsDetails, _passport);
		numSelected := jrwTrans.allCMIFUnloadsDetails.size;
	endif;
	
	//need to reorg to add a collection onto 'CM_JRWVoyages' called 'allCMIFUnloadsDetails' of type 'CMIF_ASPABargeUnloadsDetailsByTypeWP

	/*
	filter.filterObjects(jrwTrans.allCMIFUnloadsDetails, _passport);
	
	numSelected := jrwTrans.allCMIFUnloadsDetails.size;
	*/
	
epilog

	return numSelected;

end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryStopsInspect" id="b3921e4b-c483-4af6-95c1-67e497553a2c">
        <updating/>
        <source>qryStopsInspect(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     19 December 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	numSelected 		: Integer;
	jrwTrans			: CM_JRWTrackedItems;
	tiFilter			: CMQF_StopsInspection;
begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	tiFilter := _filter.CMQF_StopsInspection;
	jrwTrans := self.createJRWTransient(CM_JRWTrackedItems).CM_JRWTrackedItems;
	jrwTrans.allTrackedItems.clear();
	_filter.filterObjects(jrwTrans.allTrackedItems, _passport);
//	tiFilter.allTerminals.copy(jrwTrans.allTerminals);
	jrwTrans.setAllTerminals(tiFilter.allTerminals);
	jrwTrans.myOperator := tiFilter.myOperator;
	jrwTrans.qryStartDate := tiFilter.startDate;
	jrwTrans.qryEndDate := tiFilter.endDate;
	jrwTrans.myTerminalArea := tiFilter.getMyTerminalArea;
	jrwTrans.myVoyage := tiFilter.getMyVoyage;
	numSelected := jrwTrans.allTrackedItems.size; 
	jrwTrans.myQryStopsTables := tiFilter.getQryStopsLabel;
	
epilog
	
	return numSelected;

end;</source>
