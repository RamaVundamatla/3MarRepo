<Class name="CM_MTGrade">
    <JadeMethod name="importPLXMLReference" id="2e413673-a568-4b06-96cc-090a199b263a">
        <source>importPLXMLReference(_name, _theCode, _referencesBlock: String): Object;

vars

begin
	if _name = CM_MTGrade::myRoot.name then
		return app.myRoot;
	else
		return null;
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_theCode" type="String"/>
