    <JadeMethod name="validateMe" id="8666c856-ee49-4436-a3bd-d175024c9f6d">
        <source>validateMe();
/*
Date		Who		Reason
18 Dec 2009	conkc1	Initial creation
27 Aug 2024 navhl20	Bug 65788: EUP | VAS - Job complete discrepancies between Todo mobile app and Thin client
*/

vars
	//cnwmc5 - 23 Sep 2015 - PAR 36920
	resourceVal		: CMIF_ResourceTypeValidation;
	error			: CM_Error;
	todoTaskDesc : CM_ToDoTaskDesc;
	type : CM_ResourceType;
	typestr : String;
	count,total : Integer;
begin
	
	//if self.quantity = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'ResourceTypeUsage quantity', null, null);
	//endif;
	
	if self.myResourceType = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'ResourceTypeUsage myResourceType', null, null);
		app.raiseCMException(Input_required_field_resTypUse, null, null); // cnwdb2	PAR 35364
	endif;
	
	if self.quantity = null and self.myResourceType &lt;&gt; null then								//27.08.2024 navhl20 #65788
		app.raiseCMException1(Input_required_field_Required, self.myResourceType.unitDescription, null, null);
	endif;
	
	//cnwmc5 - 21 Sep 2015 - PAR 36920
	if self.myResourceType &lt;&gt; null and self.myResourceType.isFromToDateTimeRequired then
		if self.fromDateTime = null then														//27.08.2024 navhl20 #65788
			app.raiseCMException(Input_requi_from_date_time_fie, null, null);
		endif;
		
		if self.toDateTime = null then															//27.08.2024 navhl20 #65788
			app.raiseCMException(Input_requir_date_time_field, null, null);
		endif;
		
		if self.fromDateTime &gt; self.toDateTime then
			app.raiseCMException(Date_from_before_to, null, null);
		endif;
	endif;
	
	create resourceVal transient;
	resourceVal.myResourceTypeUsage := self;
	if self.myResourceType &lt;&gt; null then
		app.myHookAgent.runHookLinkPublic(HookType_ToDoTaskResource, self.myResourceType, self.myResourceType, resourceVal);
	endif;
epilog
	delete resourceVal;
end;</source>
    </JadeMethod>
</Class>
