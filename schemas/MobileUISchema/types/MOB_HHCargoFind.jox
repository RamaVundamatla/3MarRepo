    <JadeMethod name="tblSearch_queryRowColChg" id="57f971f3-e515-43f1-bba5-004aa355de37">
        <controlMethod name="CM_MobEntryTable::queryRowColChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblSearch_queryRowColChg(table: Table input; newSheet: Integer; newRow: Integer; newCol: Integer):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 February 2010	cnwndl1	Initial creation	CCMS MES 1005

*/

vars

	entTableRow : EntTableRowTransient;
	rawData : String;
	convertedId : String;
	convertedAltId : String;
	rowIndex : Integer;
	nullArray : StringArray;
	
begin

	rowIndex := self.tblSearch.row;

	if self.tblSearch.column = 2 then
		if rowIndex &gt; 0 and rowIndex &lt;= self.tblSearch.rows then
			entTableRow := self.tblSearch.allEntRowTransients[self.tblSearch.row].EntTableRowTransient;
		endif;
		if entTableRow &lt;&gt; null and entTableRow.controlName = null then
			//07 Jul 2016	NDL	TFS 2275
			if entTableRow.name = ETRow_FilterId then
				rawData := self.tblSearch.accessCell(rowIndex,self.tblSearch.column).text;
				self.convertCargoIdForSearch( rawData, null, null, null, convertedId, convertedAltId );
				if rawData &lt;&gt; convertedId then
					self.tblSearch.accessCell(rowIndex,self.tblSearch.column).text := convertedId;
				endif;
			endif;
			self.setActionButton();
		endif;
	endif;
	
	return true;
	
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="newSheet" type="Integer"/>
        <Parameter name="newRow" type="Integer"/>
        <Parameter name="newCol" type="Integer"/>
