<Class name="CM_ClipOnUnit" id="38e4e166-9d31-4d31-b6c9-f91af69f6c12">
    <superclass name="CM_Machinery"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>This class is used for all trackedItem with a tiType of TI_COU</text>
    <DbClassMap file="trakitem"/>
    <PrimAttribute name="couType" id="c22df861-6a09-4f50-b9a3-98abd4cf2b92">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
        <text>This is the couType (ie land, marine etc) of the ti if it has 'tiType = TI_COU'.</text>
    </PrimAttribute>
    <ExplicitInverseRef name="myReefer" id="98373853-ffbd-43cf-9f32-8e86e9752b45">
