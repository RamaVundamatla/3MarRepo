    <JadeMethod name="tTemperatureConversion" id="0490081f-9ebf-4733-86c1-71a04b1e2742">
        <source>tTemperatureConversion();

/*

Purpose:		

Date			Who		Reason
30/06/2015		cnwmh5	Initial creation

*/

vars

	pxyTempConversion				: CM_TemperatureConversion;
	tempConversion					: CM_TemperatureConversion;
	file							: File;
	
	celsius							: Real;
	fahrenheit						: Real;
	
begin

	self.ignoreTrxWarnings(true);
	
	celsius := 86.1;
	fahrenheit := 186.0;
	

	tempConversion := app.myRoot.allTempsCelsius[celsius];
	if tempConversion &lt;&gt; null then
		app.myTrxDA.trxDeleteTemperatureConversion(tempConversion, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
	create pxyTempConversion transient;
	pxyTempConversion.setProxy(celsius, fahrenheit);
	
	app.myTrxCA.trxCreateTemperatureConversion(pxyTempConversion, tempConversion, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertNotNull(tempConversion);
	self.assertEqual(tempConversion.celsius,celsius);
	
	delete pxyTempConversion;
	
	beginLoad;
	pxyTempConversion := tempConversion.pxyCreateUpdateProxy();
	endLoad;
	
	self.clearExpectedTrxErrors();
	self.expectedTrxErrors.add(ERR_INVALID_VALUE);
	pxyTempConversion.setPropertyValue("fahrenheit", 187.0);
	app.myTrxUA.trxUpdateTemperatureConversion(pxyTempConversion, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(tempConversion.fahrenheit, 187.0);
	self.ignoreTrxWarnings(false);
	
	// import from file
	tempConversion := app.myRoot.allTempsCelsius[celsius];
	if tempConversion &lt;&gt; null then
		app.myTrxDA.trxDeleteTemperatureConversion(tempConversion, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;	
	
	file := self.xTempConvImportFile(celsius, fahrenheit);
	file.kind := File.Kind_Unknown_Text;
	file.mode := File.Mode_Input;	// 29/2/16 cnwmp6 PAR 36286 unicode version
	
	app.myTrxCA.trxImportTempConvsFromFile(file, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
		
	tempConversion := app.myRoot.allTempsCelsius[celsius];
	self.assertNotNull(tempConversion);
	
epilog

	self.ignoreTrxWarnings(false);
	self.clearExpectedTrxErrors();
	delete pxyTempConversion;
	delete file;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tTidalClass" id="12fa2be9-4cd6-4526-a794-43b397a8b230">
        <source>tTidalClass();

/*

Purpose:		

Date			Who		Reason
09/10/2015		cnwmh5	Initial creation

*/

vars

	tidalClass					: HMS_TidalClass;
	pxyTidalClass				: HMS_TidalClass;
	conflictManager	 			: CMIF_HMS_ConflictsManager;

	desc						: String;
	
begin
	
	tidalClass := self.addTidalClass("UTMDHTC1", "Michael's Tidal Class", 2.100.Decimal, 1.5000.Decimal, 1.5000.Decimal, 1.5000.Decimal);
	self.assertNotNull(tidalClass);
	
	beginLoad;
	pxyTidalClass := tidalClass.pxyCreateUpdateProxy();
	pxyTidalClass.allMaximumCurrents.clear();
	tidalClass.allMaximumCurrents.copy(pxyTidalClass.allMaximumCurrents);
	endLoad;
	
	desc := tidalClass.description &amp; " - Chg";
	pxyTidalClass.setPropertyValue("description", desc);
	app.myTrxUA.trxUpdateTidalClass(pxyTidalClass, conflictManager, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(tidalClass.description, desc);

epilog
	delete pxyTidalClass;
end;</source>
    </JadeMethod>
    <JadeMethod name="tTrade" id="51994439-56bb-4bb4-b9db-cdb50e8f5153">
        <source>tTrade();

/*

Purpose:		Create / Update / Delete Trade

Date			Who		Reason
21/02/2014		cnwmh5	Initial creation

*/

vars

	trade					: CM_Trade;
	
	shippingLines 			: CM_ShippingLineByCodeDict;
	operators				: ObjectArray;
	
begin

	create shippingLines transient;
	shippingLines.add(app.myRoot.allShippingLines[self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString]);
	
	create operators transient;
	operators.add(self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));

	trade := self.addTrade("UTMDHTRAD", "UT Michaels Trade", false, shippingLines, operators);
	self.assertNotNull(trade);

	operators.add(app.myRoot.allOperators["MSK"]);
	self.opts.purge();
	self.opts.addAssoc("Operators", operators);
	self.opts.addAssoc("Order", 1);
	self.updateTrade(trade);
	
epilog

	delete shippingLines;
	delete operators;

end;</source>
    </JadeMethod>
    <JadeMethod name="tUNDangerousGoods" id="4067a0ca-8e6a-4e79-be55-fe596148e806">
        <source>tUNDangerousGoods();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/04/2013	cnwer1	Initial creation CCMS DPH 2280
07/11/2016	cnwdap1	TFS 2841 STWR Hazardous Details Enhancements
*/

vars
	dg,
	pxyDG : CM_UNDangerousGoods;
	code : String;
	hazClass : CM_HazardClass;
	pGroups : StringArray;
begin
	
	code := "123456"; // in reality un dg codes are only 4 chars so assume this is a tester
	
	dg :=app.myRoot.allUNDangerousGoodsCodes[code];
	if dg &lt;&gt; null then
		beginTransaction;
		delete dg;
		commitTransaction;
	endif;
	
	hazClass:=app.myRoot.allHazardClasses.first;
	create pGroups transient;
	pGroups.add("I");
	pGroups.add("II");
	pGroups.add("III");
	create pxyDG transient;
	pxyDG.setForProxy(code,"Unit Test UN Danergous goods code",
						false,
						hazClass,
						pGroups,
						"a + b = c",
						"0800111999911",
						"Smelly Sludge",
						MarinePollutant_Yes,							// TFS 2841
						false,											// TFS 2841
						"More additional information",
						null,											// PAR #36421
						false);
						
		
	
	app.myTrxCA.trxCreateUNDGCode(pxyDG,dg,app.myPassport);
	
	self.assertNotNull(dg);
	if dg = null then
		return;
	endif;
	self.assertEqual(dg.code, code);
	self.assertEqual(dg.nameDesc, "Unit Test UN Danergous goods code");
	self.assertEqual(dg.myHazardClass, hazClass);
	self.assertTrue(dg.allPackingGroups.includes("I"));
	self.assertTrue(dg.allPackingGroups.includes("II"));
	self.assertTrue(dg.allPackingGroups.includes("III"));
	self.assertEqual(dg.symbols,"a + b = c");
	self.assertEqual(dg.emergencyNumber,"0800111999911");
	self.assertEqual(dg.marinePollutant,"Smelly Sludge");
	self.assertEqual(dg.additionalDesc,"More additional information");
	self.assertFalse(dg.noLongerUsed);
	
	// 18/06/2015 cnwmh5
	delete pxyDG;
	delete pGroups;
	code := "654123"; // in reality un dg codes are only 4 chars so assume this is a tester
	
	dg :=app.myRoot.allUNDangerousGoodsCodes[code];
	if dg &lt;&gt; null then
		beginTransaction;
		delete dg;
		commitTransaction;
	endif;
	
	hazClass:=app.myRoot.allHazardClasses.first;
	create pGroups transient;
	pGroups.add("i");
	pGroups.add("ii");
	pGroups.add("iii");
	create pxyDG transient;
	pxyDG.setForProxy("654321","Unit Test UN Danergous goods code UPDATE",
						false,
						hazClass,
						pGroups,
						"z + z = zz",
						"0800444444444",
						"Ugly Mud",
						MarinePollutant_Yes,							// TFS 2841
						false,											// TFS 2841
						"Should be additional information",
						null,											// PAR #36421
						false);
						
		
	
	app.myTrxCA.trxCreateUNDGCode(pxyDG,dg,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	self.assertNotNull(dg);
	if dg = null then
		return;
	endif;
	
	delete pxyDG;
	delete pGroups;
	beginLoad;
	pxyDG := dg.pxyCreateUpdateProxy();
	
	code := "654123";
	pxyDG.setCode(code);
	pxyDG.setNotAvailableForEntry(true);
	app.myTrxUA.trxUpdateUNDGCode(pxyDG, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(dg.code, code);
	self.assertEqual(dg.notAvailableForEntry, true);

epilog
	delete pxyDG;
	delete pGroups;
end;</source>
    </JadeMethod>
    <JadeMethod name="tVehicleMakeModelTypeColour" id="e2d45ac3-feaa-4238-b0e8-e398ebaa670e">
        <updating/>
        <source>tVehicleMakeModelTypeColour() updating;

/*

Purpose:		Call the trx's for Vechile Make, Model, Type and Colour for Add, Update, Delete and Import from File

				Trx's:
				trxCreateVehicleMake
				trxUpdateVehicleMake
				trxDeleteVehicleMake
				trxImportVehicleMakesFromFile
				trxCreateVehicleModel
				trxUpdateVehicleModel
				trxDeleteVehicleModel
				trxImportVehicleModelsFromFile
				trxCreateVehicleType
				trxUpdateVehicleType
				trxDeleteVehicleType
				trxImportVehicleTypesFromFile
				trxCreateVehicleColour
				trxUpdateVehicleColour
				trxDeleteVehicleColour
				trxImportVehicleColoursFromFil

Date			Who		Reason
14/05/2015		cnwmh5	Initial creation
02/07/2018		jlgmd1	TFS 39058 - Test maximum lengths (1035 string to long)

*/

vars

	make					: CM_VehicleMake;
	pxyMake					: CM_VehicleMake;
	model					: CM_VehicleModel;
	pxyModel				: CM_VehicleModel;
	type					: CM_VehicleType;
	pxyType					: CM_VehicleType;
	colour					: CM_VehicleColour;
	pxyColour				: CM_VehicleColour;
	file					: File;

begin

	// Vechile make
	make := app.myDutyDocRoot.allVehicleMakes["UT_FORD1"];
	if make &lt;&gt; null then
		app.myTrxDA.trxDeleteVehicleMake(make, app.myPassport);
		make := app.myDutyDocRoot.allVehicleMakes["UT_FORD1"];
		self.assertNull(make);
	endif;
	
	make := app.myDutyDocRoot.allVehicleMakes["UTFORD"];
	if make &lt;&gt; null then
		app.myTrxDA.trxDeleteVehicleMake(make, app.myPassport);
		make := app.myDutyDocRoot.allVehicleMakes["UTFORD"];
		self.assertNull(make);
	endif;
	
	make := app.myDutyDocRoot.allVehicleMakes["UT_MAKE8901234567890123456789012345678901234567890"];	// 50 characters
	if make &lt;&gt; null then
		app.myTrxDA.trxDeleteVehicleMake(make, app.myPassport);
		make := app.myDutyDocRoot.allVehicleMakes["UT_MAKE8901234567890123456789012345678901234567890"];
		self.assertNull(make);
	endif;
		
	create pxyMake transient;
	pxyMake.setProxy("UT_MAKE8901234567890123456789012345678901234567890");		// 50 characters
	app.myTrxCA.trxCreateVehicleMake(pxyMake, make, app.myPassport);
	self.assertNotNull(make);
	self.assertEqual(make.make, "UT_MAKE8901234567890123456789012345678901234567890");
	delete pxyMake;
	
	create pxyMake transient;
	on Exception do self.exHandlerAssertException(exception);
	pxyMake.setProxy("UT_MAKE89012345678901234567890123456789012345678901");	// 51 characters
	on Exception do null;
	self.assertExceptionRaised(1035, "Expected 1035 String to long exception");
	delete pxyMake;
	
	create pxyMake transient;
	pxyMake.setProxy("UTFORD");
	app.myTrxCA.trxCreateVehicleMake(pxyMake, make, app.myPassport);
	self.assertNotNull(make);
	self.assertEqual(make.make, "UTFORD");
	delete pxyMake;
	
	beginLoad;
	pxyMake := make.pxyCreateUpdateProxy();	
	endLoad;
	pxyMake.setPropertyValue("make", "UT_FORD1");
	app.myTrxUA.trxUpdateVehicleMake(pxyMake, app.myPassport);
	self.assertEqual(make.make, "UT_FORD1");
	
	delete file;
	create file transient;
	file.usePresentationFileSystem := true;
	file.fileName := "c:\temp\VehicleMake.txt";
	if file.isAvailable() then
		file.purge();
	endif;
	
	file.mode := File.Mode_Output;        // 4/3/16 cnwmp6 PAR 36286 unicode version
	file.writeLine("");
	file.writeLine("UTFORD1");
	file.writeLine("UTFORD2");
	file.writeLine("UT_MAKE8901234567890123456789012345678901234567891");	// 50 characters
	file.writeLine("UT_MAKE89012345678901234567890123456789012345678921");	// 51 characters
	file.close();
	file.kind := File.Kind_Unknown_Text;        // 4/3/16 cnwmp6 PAR 36286 unicode version
	file.mode := File.Mode_Input;        // 4/3/16 cnwmp6 PAR 36286 unicode version
	app.myTrxCA.trxImportVehicleMakesFromFile(file, app.myPassport);
	self.assertNoTrxErrors();
	self.assertNotNull(app.myDutyDocRoot.allVehicleMakes["UTFORD1"]);
	self.assertNotNull(app.myDutyDocRoot.allVehicleMakes["UTFORD2"]);
	self.assertNotNull(app.myDutyDocRoot.allVehicleMakes["UT_MAKE8901234567890123456789012345678901234567891"]);	// 50 characters
	self.assertNotNull(app.myDutyDocRoot.allVehicleMakes["UT_MAKE8901234567890123456789012345678901234567892"]); 	// truncated to 50 characters
	
	// Vechile MODEL
	model := app.myDutyDocRoot.allVehicleModels["UT_VAN1"];
	if model &lt;&gt; null then
		app.myTrxDA.trxDeleteVehicleModel(model, app.myPassport);
		model := app.myDutyDocRoot.allVehicleModels["UT_VAN1"];
		self.assertNull(model);
	endif;
	
	model := app.myDutyDocRoot.allVehicleModels["UTVAN"];
	if model &lt;&gt; null then
		app.myTrxDA.trxDeleteVehicleModel(model, app.myPassport);
		model := app.myDutyDocRoot.allVehicleModels["UTVAN"];
		self.assertNull(model);
	endif;
		
	model := app.myDutyDocRoot.allVehicleModels["UT_MODEL901234567890123456789012345678901234567890"];		// 50 characters
	if model &lt;&gt; null then
		app.myTrxDA.trxDeleteVehicleModel(model, app.myPassport);
		model := app.myDutyDocRoot.allVehicleModels["UT_MODEL901234567890123456789012345678901234567890"];
		self.assertNull(model);
	endif;
	
	create pxyModel transient;
	pxyModel.setProxy("UT_MODEL901234567890123456789012345678901234567890");		// 50 characters
	app.myTrxCA.trxCreateVehicleModel(pxyModel, model, app.myPassport);
	self.assertNotNull(model);
	self.assertEqual(model.model, "UT_MODEL901234567890123456789012345678901234567890");
	delete pxyModel;
	
	create pxyModel transient;
	on Exception do self.exHandlerAssertException(exception);
	pxyModel.setProxy("UT_MODEL9012345678901234567890123456789012345678901");	// 51 characters
	on Exception do null;
	self.assertExceptionRaised(1035, "Expected 1035 String to long exception");
	delete pxyModel;
	
	create pxyModel transient;
	pxyModel.setProxy("UTVAN");
	app.myTrxCA.trxCreateVehicleModel(pxyModel, model, app.myPassport);
	self.assertNotNull(model);
	self.assertEqual(model.model, "UTVAN");
	
	delete pxyModel;
	beginLoad;
	pxyModel := model.pxyCreateUpdateProxy();	
	endLoad;
	pxyModel.setPropertyValue("model", "UT_VAN1");
	app.myTrxUA.trxUpdateVehicleModel(pxyModel, app.myPassport);
	self.assertEqual(model.model, "UT_VAN1");
	
	delete file;
	create file transient;
	file.usePresentationFileSystem := true;
	file.fileName := "c:\temp\VehicleModel.txt";
	if file.isAvailable() then
		file.purge();
	endif;
	
	file.mode := File.Mode_Output;        // 4/3/16 cnwmp6 PAR 36286 unicode version
	file.writeLine("");
	file.writeLine("UTVAN1");
	file.writeLine("UTVAN2");
	file.writeLine("UT_MODEL901234567890123456789012345678901234567891");		// 50 characters
	file.writeLine("UT_MODEL9012345678901234567890123456789012345678921");		// 51 characters
	file.close();
	file.kind := File.Kind_Unknown_Text;        // 4/3/16 cnwmp6 PAR 36286 unicode version
	file.mode := File.Mode_Input;        // 4/3/16 cnwmp6 PAR 36286 unicode version
	app.myTrxCA.trxImportVehicleModelsFromFile(file, app.myPassport);
	self.assertNoTrxErrors();
	self.assertNotNull(app.myDutyDocRoot.allVehicleModels["UTVAN1"]);
	self.assertNotNull(app.myDutyDocRoot.allVehicleModels["UTVAN2"]);
	self.assertNotNull(app.myDutyDocRoot.allVehicleModels["UT_MODEL901234567890123456789012345678901234567891"]);	// 50 characters
	self.assertNotNull(app.myDutyDocRoot.allVehicleModels["UT_MODEL901234567890123456789012345678901234567892"]);	// truncated to 50 characters
	
	// Vechile TYPE
	type := app.myDutyDocRoot.allVehicleTypes["UT_SPORT1"];
	if type &lt;&gt; null then
		app.myTrxDA.trxDeleteVehicleType(type, app.myPassport);
		type := app.myDutyDocRoot.allVehicleTypes["UT_SPORT1"];
		self.assertNull(type);
	endif;
	
	type := app.myDutyDocRoot.allVehicleTypes["UTSPORT"];
	if type &lt;&gt; null then
		app.myTrxDA.trxDeleteVehicleType(type, app.myPassport);
		type := app.myDutyDocRoot.allVehicleTypes["UTSPORT"];
		self.assertNull(type);
	endif;
	
	type := app.myDutyDocRoot.allVehicleTypes["UT_TYPE8901234567890123456789012345678901234567890"];		// 50 characters
	if type &lt;&gt; null then
		app.myTrxDA.trxDeleteVehicleType(type, app.myPassport);
		type := app.myDutyDocRoot.allVehicleTypes["UT_TYPE8901234567890123456789012345678901234567890"];
		self.assertNull(type);
	endif;
	
	create pxyType transient;
	pxyType.setProxy("UT_TYPE8901234567890123456789012345678901234567890");		// 50 characters
	app.myTrxCA.trxCreateVehicleType(pxyType, type, app.myPassport);
	self.assertNotNull(type);
	self.assertEqual(type.type, "UT_TYPE8901234567890123456789012345678901234567890");
	delete pxyType;
	
	create pxyType transient;
	on Exception do self.exHandlerAssertException(exception);
	pxyType.setProxy("UT_TYPE89012345678901234567890123456789012345678901");	// 51 characters
	on Exception do null;
	self.assertExceptionRaised(1035, "Expected 1035 String to long exception");
	delete pxyType;
		
	create pxyType transient;
	pxyType.setProxy("UTSPORT");
	app.myTrxCA.trxCreateVehicleType(pxyType, type, app.myPassport);
	self.assertNotNull(type);
	self.assertEqual(type.type, "UTSPORT");
	
	delete pxyType;
	beginLoad;
	pxyType := type.pxyCreateUpdateProxy();	
	endLoad;
	pxyType.setPropertyValue("type", "UT_SPORT1");
	app.myTrxUA.trxUpdateVehicleType(pxyType, app.myPassport);
	self.assertEqual(type.type, "UT_SPORT1");
	
	delete file;
	create file transient;
	file.usePresentationFileSystem := true;
	file.fileName := "c:\temp\VehicleType.txt";
	if file.isAvailable() then
		file.purge();
	endif;
	
	file.mode := File.Mode_Output;        // 4/3/16 cnwmp6 PAR 36286 unicode version
	file.writeLine("");
	file.writeLine("UTSPORT1");
	file.writeLine("UTSPORT2");
	file.writeLine("UT_TYPE8901234567890123456789012345678901234567891");		// 50 characters
	file.writeLine("UT_TYPE89012345678901234567890123456789012345678921");		// 51 characters
	file.close();
	file.kind := File.Kind_Unknown_Text;        // 4/3/16 cnwmp6 PAR 36286 unicode version
	file.mode := File.Mode_Input;        // 4/3/16 cnwmp6 PAR 36286 unicode version
	app.myTrxCA.trxImportVehicleTypesFromFile(file, app.myPassport);
	self.assertNoTrxErrors();
	self.assertNotNull(app.myDutyDocRoot.allVehicleTypes["UTSPORT1"]);
	self.assertNotNull(app.myDutyDocRoot.allVehicleTypes["UTSPORT2"]);
	self.assertNotNull(app.myDutyDocRoot.allVehicleTypes["UT_TYPE8901234567890123456789012345678901234567891"]);	// 50 characters
	self.assertNotNull(app.myDutyDocRoot.allVehicleTypes["UT_TYPE8901234567890123456789012345678901234567892"]);	// truncated to 50 characters
	
	// Vechile COLOUR
	colour := app.myDutyDocRoot.allVehicleColours["UT_BLUE1"];
	if type &lt;&gt; null then
		app.myTrxDA.trxDeleteVehicleColour(colour, app.myPassport);
		colour := app.myDutyDocRoot.allVehicleColours["UT_BLUE1"];
		self.assertNull(colour);
	endif;
	
	colour := app.myDutyDocRoot.allVehicleColours["UTBLUE"];
	if type &lt;&gt; null then
		app.myTrxDA.trxDeleteVehicleColour(colour, app.myPassport);
		colour := app.myDutyDocRoot.allVehicleColours["UTBLUE"];
		self.assertNull(colour);
	endif;
	
	colour := app.myDutyDocRoot.allVehicleColours["UT_COLOUR01234567890"];	// 20 characters
	if type &lt;&gt; null then
		app.myTrxDA.trxDeleteVehicleColour(colour, app.myPassport);
		colour := app.myDutyDocRoot.allVehicleColours["UT_COLOUR01234567890"];
		self.assertNull(colour);
	endif;
	
	create pxyColour transient;
	pxyColour.setProxy("UT_COLOUR01234567890");		// 20 characters
	app.myTrxCA.trxCreateVehicleColour(pxyColour, colour, app.myPassport);
	self.assertNotNull(type);
	self.assertEqual(colour.colour, "UT_COLOUR01234567890");
	delete pxyColour;
	
	create pxyColour transient;
	on Exception do self.exHandlerAssertException(exception);
	pxyColour.setProxy("UT_COLOUR012345678901");	// 21 characters
	on Exception do null;
	self.assertExceptionRaised(1035, "Expected 1035 String to long exception");
	delete pxyColour;
	
	create pxyColour transient;
	pxyColour.setProxy("UTBLUE");
	app.myTrxCA.trxCreateVehicleColour(pxyColour, colour, app.myPassport);
	self.assertNotNull(colour);
	self.assertEqual(colour.colour, "UTBLUE");
	
	delete pxyColour;
	beginLoad;
	pxyColour := colour.pxyCreateUpdateProxy();	
	endLoad;
	pxyColour.setPropertyValue("colour", "UT_BLUE1");
	app.myTrxUA.trxUpdateVehicleColour(pxyColour, app.myPassport);
	self.assertEqual(colour.colour, "UT_BLUE1");
	
	delete file;
	create file transient;
	file.usePresentationFileSystem := true;
	file.fileName := "c:\temp\VehicleColour.txt";
	if file.isAvailable() then
		file.purge();
	endif;
	file.mode := File.Mode_Output;        // 4/3/16 cnwmp6 PAR 36286 unicode version
	file.writeLine("");
	file.writeLine("UTBLUE1");
	file.writeLine("UTBLUE2");
	file.writeLine("UT_COLOUR01234567891");		// 20 characters
	file.writeLine("UT_COLOUR012345678921");	// 21 characters
	file.close();
	file.kind := File.Kind_Unknown_Text;        // 4/3/16 cnwmp6 PAR 36286 unicode version
	file.mode := File.Mode_Input;        // 4/3/16 cnwmp6 PAR 36286 unicode version
	app.myTrxCA.trxImportVehicleColoursFromFil(file, app.myPassport);
	self.assertNoTrxErrors();
	self.assertNotNull(app.myDutyDocRoot.allVehicleColours["UTBLUE1"]);
	self.assertNotNull(app.myDutyDocRoot.allVehicleColours["UTBLUE2"]);
	self.assertNotNull(app.myDutyDocRoot.allVehicleColours["UT_COLOUR01234567891"]);	// 20 characters
	self.assertNotNull(app.myDutyDocRoot.allVehicleColours["UT_COLOUR01234567892"]);	// truncated to 20 characters

epilog

	delete pxyMake;
	delete pxyModel;
	delete pxyType;
	delete pxyColour;
	
	delete file;

end;</source>
