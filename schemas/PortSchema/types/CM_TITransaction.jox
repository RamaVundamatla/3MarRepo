    <JadeMethod name="getImExStatusAbbrev" id="ecfbc396-24ed-4af0-97a2-b04c4b51b2b5">
        <updating/>
        <source>getImExStatusAbbrev() : String updating;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		28 April 2011
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
// 28/04/2011	cnwsh3		PAR27423 - Add get abbreviation for reporting
//----------------------------------------------------------------------

vars
	imx : CM_IMEXStatus;
	
begin
	imx := app.myRoot.allImexStatuses[self.imExStatus];
	if imx &lt;&gt; null then
		return imx.abbreviation;
	else
		return app.getErrorString(Unknown);
	endif;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getImExStatusDescForMapping" id="3b91a255-86ca-4c4d-8cc1-a7232aab541a">
        <source>getImExStatusDescForMapping(_long : Boolean) : String;
/*
Purpose:	// TFS 37994 needs to show DLR and SOB as IMEX		
Date				Who			Reason
MARCH 2018		CNWAB1		Initial creation
*/

vars
	imx : CM_IMEXStatus;
	imex : Integer;
	transStatus			: CM_TransitStatus;
begin


	if self.myTrackedItem &lt;&gt; null then
		if self.myTrackedItem.isSOB then
			return self.myTrackedItem.getTransitStatusDescription();
		elseif self.myTrackedItem.isRehandle then
			return self.myTrackedItem.getTransitStatusDescription();
		endif;
	endif;

	imx := app.myRoot.allImexStatuses[self.imExStatus];
	if imx &lt;&gt; null then
		if _long then
			return imx.description;
		else
			return imx.abbreviation;
		endif;
	else
		return "Unknown";
	endif;
	
end;</source>
        <Parameter name="_long" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getImExStatusStringDesc" id="c8c125f9-e9af-47ea-aafa-f575c95eaff3">
