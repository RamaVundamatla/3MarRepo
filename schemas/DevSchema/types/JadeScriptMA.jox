    <JadeMethod name="qTSCashReceipts" id="b5ed776a-4aa7-46e9-b61c-5075e131ca47">
        <source>qTSCashReceipts();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 September 2022		navma1	Initial creation

*/

vars
	lFile   	: File;
	cashRec 	: CM_CashReceipt;
	debtorName	: String;
begin
	
	create lFile transient;
	lFile.fileName := "C:\TEMP\qnsData.csv";
    lFile.open;
	lFile.writeLine(
					"Terminal"       &amp; "," &amp;
					"Receipt Date"   &amp; "," &amp;
					"Receipt No"     &amp; "," &amp;
					"Debtor"		 &amp; "," &amp;
					"Payment Total"  &amp; "," &amp; 
					"cargo Total"    );
					
	foreach cashRec in CM_CashReceipt.instances discreteLock do
		
		if cashRec.getDebtor &lt;&gt; null then
			debtorName := cashRec.getDebtor.name;
		endif;
		lFile.writeLine(cashRec.myTerminal.code		 			&amp; "," &amp;
						cashRec.createdTime.String				&amp; "," &amp;
						cashRec.externalInvoiceNumber   		&amp; "," &amp;
						debtorName								&amp; "," &amp;
						cashRec.allCashPayments.size.String		&amp; "," &amp;
						cashRec.allTrackedItems.size.String		);
	endforeach;

	lFile.close;
epilog
	delete lFile;
end;
</source>
    </JadeMethod>
