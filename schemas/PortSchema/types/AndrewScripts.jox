	props := cls.getProperties();

	write "";
	write "";
	write Tab &amp; "self.tableName := _detail.tableName;";
	write "self.gkey := _detail.gkey;";

	foreach prop in props discreteLock do

		write Tab &amp; "self." &amp; prop.name &amp; " := _detail." &amp; prop.name &amp; ";";

	endforeach;
		
		

end;</source>
    </JadeMethod>
