    <JadeMethod name="doLoadDocketErrorTypes" id="dca62ca1-c0e6-4cc3-acb1-f480ebb8e4ca">
        <source>doLoadDocketErrorTypes(_cmb : CMUI_ComboBox input; _docketErrorCode : String) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Changed On  Changed	TFS		Reason
----------  -------	-----	--------------------------------------------------
15 February 2010	cnwas3	Initial creation
25 Sep 2019	jlgdi1	46717	Used the actual object to determine the listIndex of the combobox, 
							which also makes it independent from the sorting property of the control
-------------------------------------------------------------------------------
*/

vars
	docketErrorType			: CM_DocketErrorType;
	docketErrorTypeDict		: CM_DocketErrorTypeByCodeDict;
	idx : Integer;
	selDocketErrorType : CM_DocketErrorType;
	
begin
	if _cmb = null then
		return;
	endif;
	
	_cmb.clear();
	_cmb.addItem(Any_String);
	
	docketErrorTypeDict := app.myRoot.allDocketErrorTypes;
	
	foreach docketErrorType in docketErrorTypeDict do
		idx := _cmb.addItem(docketErrorType.code &amp; " " &amp; docketErrorType.description);	//#24306	27/05/2010
		_cmb.itemObject[idx] := docketErrorType;
		if docketErrorType.code = _docketErrorCode then
			selDocketErrorType := docketErrorType;
		endif;
	endforeach;
	
	if selDocketErrorType &lt;&gt; null then
		_cmb.listIndex := _cmb.findObject(selDocketErrorType);
	else
		_cmb.text := Any_String;
	endif;
	
	self.setValueByName(ETRow_DocketError, _cmb.text);
//	self.setValueByName(ETRow_DocketErrorDescription, _cmb.text);	//#24306	27/05/2010
end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_docketErrorCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadEventTypes" id="95464bc4-83cd-4a41-b1b1-5fa34bd2caaa">
        <source>doLoadEventTypes(_lstTable	: CMUI_ListTable input; _defaultTemplate : CMQF_FilterReports) protected;
//----------------------------------------------------------------
//	Created:	04 November 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// Changed On	By			Reason
// ----------	----------	--------------------------------------
// 06/12/2019	jlgdap1		TFS 47754 JMT Report Runner Event Types
vars
	
	eventType			: CM_EventType;
	idx					: Integer;
	defaultEventTypes	: IntegerArray;
	select				: Integer;
	dynaDict 			: DynaDictionary;			// TFS 47754
	obj 				: Object;					// TFS 47754
	
begin
//	if CMQF_Container.hasInstance(_defaultTemplate) then
	if CMQF_BookingRefDiscrepancy.hasInstance(_defaultTemplate) then
		defaultEventTypes := _defaultTemplate.CMQF_BookingRefDiscrepancy.allEventTypes;
	elseif CMQF_Events.hasInstance(_defaultTemplate) then	// NDL 04 Sep 2009
		defaultEventTypes := _defaultTemplate.CMQF_Events.allEventTypes;
	endif;
	
	if _lstTable = null then
		return;
	endif;
	
	_lstTable.rows := _lstTable.fixedRows;
	_lstTable.clearSelected();
	
	//TFS 47754 Sort event types by description
	create dynaDict transient;
	dynaDict.setMembership(CM_EventType);
	dynaDict.addMemberKey(CM_EventType::name.name, false, true);
	dynaDict.addMemberKey(CM_EventType::type.name, false, true);
	dynaDict.endKeys(true);
	app.myRoot.allEventTypesByType.copy(dynaDict);
	// TFS 47754 end

	//foreach eventType in app.myRoot.allEventTypesByType do		// TFS 47754
	foreach obj in dynaDict do										// TFS 47754
		eventType := obj.CM_EventType;								// TFS 47754
		select := 0;
		if defaultEventTypes &lt;&gt; null and defaultEventTypes.includes(eventType.type) then
			select := 1;
			_lstTable.allSelectedObjects.add(eventType);	
		endif;
		
		idx := _lstTable.addItem(select.String &amp; Tab &amp; eventType.name); 
		_lstTable.accessRow(idx).itemObject := eventType;
	endforeach;

epilog
	delete dynaDict;			// TFS 47754
end;</source>
        <access>protected</access>
        <Parameter name="_lstTable" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_defaultTemplate" type="CMQF_FilterReports"/>
    </JadeMethod>
    <JadeMethod name="doLoadGCIds" id="9e588646-f3e0-467b-8aa2-d32114ba4788">
        <source>doLoadGCIds(_cmb : CMUI_ComboBox input; _ta : CM_TerminalArea; _rowId : String);
//----------------------------------------------------------------------
//  Created by cnwsh3
//	Date 18 June 2008
//
// Implemented version: 7.6.2
// PAR17151 cnwsh3  Structural changes for warehousing and general cargo
// Now called by self.doLoadRowsOrArea so some of the code has been moved to this method.
// 
// Changed On   Changed	TFS		Reason
// ----------   -------	-----	--------------------------------------------------
// 25 Sep 2019	jlgdi1	46717	Used the actual object to determine the listIndex of the combobox, 
//								which also makes it independent from the sorting property of the control
// -------------------------------------------------------------------------------
vars
	area			: CM_LocationsController;
	tmpAreaDict		: CM_LCSet;
	passport		: CM_Passport;
	ta				: CM_TerminalArea;
	idx : Integer;
	failedDAC  		:CM_DataAccessController;
	selArea	: CM_LocationsController;
	
begin
	tmpAreaDict := _ta.allLocationsControllers;
	passport := app.myPassport;			
	foreach area in tmpAreaDict do
		if (not area.canUserAccessSelf(null, failedDAC, passport)) then
			continue;
		endif;
		idx := _cmb.addItem(area.ident);
		_cmb.itemObject[idx] := area;
		
		if area.ident = _rowId then
			selArea := area;
		endif;
	endforeach;
	
	if selArea &lt;&gt; null then 
		_cmb.listIndex := _cmb.findObject(selArea);
	else
		_cmb.text := Any_String; 
	endif;
	
	self.setValueByName(ETRow_RowId, _cmb.text);
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <Parameter name="_rowId" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadGatePasses" id="930b34b4-077a-43c0-9db7-cf934fa2c87f">
        <source>doLoadGatePasses(_cmb : CMUI_ComboBox input; _gatePass : String) protected;
// ---------------------------------------------------------------------------
// Created:     11 February 2003	cnwjo3
//
// Purpose:     Fill the Gate Pass combo with available Gate Passes
//	June 2012	29460 prevent 14025 max entries in the combo box
// ----------   ----------  --------------------------------------------------
constants
	MaxEntries = 31990;			// 32000 less Any_String and a safety limit
vars
	vr			: CM_VehicleVisitRecord;
	iter		: Iterator;
	dd			: DynaDictionary;
	
	size		: Integer;
	idx,
	keepIdx		: Integer;
	term		: CM_Terminal;
begin
	if _cmb = null then
		return;
	endif;
	
	_cmb.clear();
	_cmb.addItem(Any_String);

	create dd transient;
	dd.setMembership(CM_VehicleVisitRecord);
	//dd.addMemberKey("gatePass",false,false);
	dd.addMemberKey(CM_VehicleVisitRecord::visitNumber.name,false,false);	//PAR29460 - cnwsh3 18/04/2012
	dd.endKeys(true);
	
	if self.allTerminals.size &gt; 0 then
		foreach term in self.allTerminals do
			size := size + term.allVehicleVisits.size;
		endforeach;
	else
		foreach term in CM_Terminal.instances do
			size := size + term.allVehicleVisits.size;
		endforeach;
	endif;

	if size &lt; MaxEntries then
		if self.allTerminals.size &gt; 0 then
			foreach term in self.allTerminals do
				term.allVehicleVisits.copy(dd);
			endforeach;
		else
			foreach term in CM_Terminal.instances do
				term.allVehicleVisits.copy(dd);
			endforeach;
		endif;
	else
		// 29460 June 2012 combo limiting the display - take the most-recent first
		if self.allTerminals.size &gt; 0 then
			foreach term in self.allTerminals do
				foreach vr in term.allVehicleVisits reversed do
					if dd[vr.visitNumber] = null then
						idx := idx + 1;
						if idx &gt; MaxEntries then
							break;
						endif;
						dd.add(vr);
					endif;
				endforeach;
				if idx &gt; MaxEntries then
					break;
				endif;
			endforeach;
		else
			foreach term in CM_Terminal.instances do
				foreach vr in term.allVehicleVisits reversed do
					if dd[vr.visitNumber] = null then
						idx := idx + 1;
						if idx &gt; MaxEntries then
							break;
						endif;
						dd.add(vr);
					endif;
				endforeach;
				if idx &gt; MaxEntries then
					break;
				endif;
			endforeach;
		endif;
	endif;

	iter := dd.createIterator();
	keepIdx := -1;

	while iter.next(vr) do
			if _cmb.listCount &gt; 1 then
				if _cmb.itemText[_cmb.listCount] &lt;&gt; vr.visitNumber then
					idx := _cmb.addItem(vr.visitNumber);
				endif;
			else
				idx := _cmb.addItem(vr.visitNumber);
			endif;
			// 29460 June 2012 limit the combo entries - should have been handled by the code above, but just in case ...
			if idx &gt; MaxEntries then
				break;
			endif;
	endwhile;
	
	foreach idx in 1 to _cmb.listCount do
		if _cmb.itemText[idx] = _gatePass then
			keepIdx := idx;
			break;
		endif;
	endforeach;
	
	if keepIdx &gt; -1 then
		_cmb.listIndex := keepIdx;
	else
		_cmb.text := Any_String;
	endif;
	
	self.setValueByName(ETRow_GatePass, _cmb.text);
epilog
	delete iter;
	delete dd;
end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_gatePass" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadGlobalVoyActual" id="86bd777c-749b-466d-9f11-bfd9c6fa8b4b">
        <source>doLoadGlobalVoyActual(_cmbActualVoy : CMUI_ComboBox input; _voyageCode : String) protected;
// ---------------------------------------------------------------------------
// Created:     17 December 2003	cnwth2
//
// Purpose:     two combos passed in - one for actual - one for allocated (logs)
//			 
// Changed On   Changed	TFS		Reason
// ----------   -------	-----	--------------------------------------------------
// 25 Sep 2019	jlgdi1	46717	Used the actual object to determine the listIndex of the combobox, 
//								which also makes it independent from the sorting property of the control
// -------------------------------------------------------------------------------
vars
	voyGlobal	: CM_VoyageGlobal;
	voyDict		: CM_VoyageGlobalByCodeDict;
	str			: String;
	terminal	: CM_Terminal;
	passport	: CM_Passport;
	idx : Integer;
	failedDAC  :CM_DataAccessController;
	user		:CM_User;
	selVoyGlobal : CM_VoyageGlobal;
	
begin
	passport := app.myPassport;
	user := passport.myUser;
	if _cmbActualVoy = null then
		return;
	endif;

	_cmbActualVoy.clear();
	_cmbActualVoy.addItem(Any_String);
	
	voyDict := app.myRoot.allVoyagesGlobal;
	foreach voyGlobal in voyDict do
		if (not voyGlobal.canUserAccessSelf(null, failedDAC, passport)) then
			continue;
		endif;
		
		str := voyGlobal.code &amp; '  ' &amp; voyGlobal.vesselName; 
		idx := _cmbActualVoy.addItem(str);
		
		_cmbActualVoy.itemObject[idx] := voyGlobal;
		
		if (_voyageCode &lt;&gt; null) and (voyGlobal.code = _voyageCode) then
			selVoyGlobal := voyGlobal;
		endif;
	endforeach;
	
	if selVoyGlobal &lt;&gt; null then
		_cmbActualVoy.listIndex := _cmbActualVoy.findObject(selVoyGlobal);
	else
		_cmbActualVoy.listIndex := 1;
	endif;
	
	self.setValueByName(ETRow_VoyageActual, _cmbActualVoy.text);
end;</source>
        <access>protected</access>
        <Parameter name="_cmbActualVoy" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_voyageCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadGlobalVoyAllocated" id="d0029d0a-a082-4dc7-ae5f-bcc6f24fe28e">
        <source>doLoadGlobalVoyAllocated(_cmbAllocatedVoy : CMUI_ComboBox input; _voyageCode : String) protected;
// ---------------------------------------------------------------------------
// Created:     17 December 2003	cnwth2
//
// Purpose:     two combos passed in - one for actual - one for allocated (logs)
//	
// Changed On   Changed	TFS		Reason
// ----------   -------	-----	--------------------------------------------------
// 21/08/2008  PAR17722 - cnwsh3 - Changed to only include voyages that call at the selected terminals.
//								   We assume the user has already been checked for valid access to the terminal.
// 25 Sep 2019	jlgdi1	46717	Used the actual object to determine the listIndex of the combobox, 
//								which also makes it independent from the sorting property of the control
// -------------------------------------------------------------------------------
vars
	voyGlobal	: CM_VoyageGlobal;
	voyDict		: CM_VoyageGlobalByCodeDict;
	str			: String;
	terminal	: CM_Terminal;
	passport	: CM_Passport;
	idx : Integer;
	failedDAC  	: CM_DataAccessController;
	user		: CM_User;
	terminalSet : CM_TerminalSet;
	selVoyGlobal : CM_VoyageGlobal;
	
begin
	passport := app.myPassport;
	user := passport.myUser;
	if _cmbAllocatedVoy = null then
		return;
	endif;
	
	create terminalSet transient;
	self.allTerminals.copy(terminalSet);

	_cmbAllocatedVoy.clear();
	_cmbAllocatedVoy.addItem(Any_String);
	
	voyDict := app.myRoot.allVoyagesGlobal;
	
	foreach voyGlobal in voyDict where voyGlobal.hasStructureOfType(LogStructure) do
		if (not voyGlobal.canUserAccessSelf(user, failedDAC, passport)) then
			continue;
		endif;
		//PAR17722 - 21/8/2008- cnwsh3 - We only want to display voyages that call at the selected terminals.
		if voyGlobal.hasCurrentVoyageForTerminals(terminalSet) then

			idx := _cmbAllocatedVoy.addItem(voyGlobal.code &amp; '  ' &amp; voyGlobal.vesselName);
			_cmbAllocatedVoy.itemObject[idx] := voyGlobal;
			
			if _voyageCode &lt;&gt; null 
			and voyGlobal.code = _voyageCode then
				selVoyGlobal := voyGlobal;
			endif;
		endif;
	endforeach;
	
	if selVoyGlobal &lt;&gt; null then 
		_cmbAllocatedVoy.listIndex := _cmbAllocatedVoy.findObject(selVoyGlobal);
	else
		_cmbAllocatedVoy.listIndex := 1;
	endif;
	//18/05/2009 cnwdz2 par19257 changed ETRow_Voyage to ETRow_VoyageAllocated
	self.setValueByName(ETRow_VoyageAllocated, _cmbAllocatedVoy.text);
end;</source>
        <access>protected</access>
        <Parameter name="_cmbAllocatedVoy" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_voyageCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadIMEXStatus" id="cc2d216a-99bb-44eb-85eb-1a476d344fb2">
        <source>doLoadIMEXStatus(_table	: CMUI_ListTable input; _filterObject : CMQF_FilterReports) protected;
// ---------------------------------------------------------------------------
// Created:     17 December 2003	cnwth2
//
// Purpose:     
//21/06/2016   cnwma1 	    PAR #37960 TFS #2187 PEN - Report Maintenance Set and Save Default Value		 
// ----------   ----------  --------------------------------------------------
vars
	imexInteger : Integer;
	imexObj : Object;
begin
	_table.allSelectedObjects.clear();
	if _filterObject &lt;&gt; null and 
	   CMQF_TrackedItem.hasInstance(_filterObject) then
		_filterObject.CMQF_TrackedItem.allQryIMEXStatuses.copy(_table.allSelectedObjects);
	endif;
	

	if _filterObject &lt;&gt; null and 														//21/06/2016 cnwma1 PAR #37960 TFS #2187
		CMQF_Transactions.hasInstance(_filterObject) then
		foreach imexInteger in _filterObject.CMQF_Transactions.allQryImexStatus do
			foreach   imexObj in app.myRoot.allImexStatuses do
						if imexObj.CM_IMEXStatus.code = imexInteger then
							_table.allSelectedObjects.add(imexObj);
						endif;
			endforeach;
		endforeach;
	endif;
	self.myAssistant.listTableIMEX(_table);
	_table.lostFocus(_table);

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_filterObject" type="CMQF_FilterReports"/>
    </JadeMethod>
    <JadeMethod name="doLoadISOGroups" id="0ae8b0fe-e354-4b70-9a21-22c1f113cc6d">
        <source>doLoadISOGroups(_cmb : CMUI_ComboBox input; _entRowName, _isoGrpCode : String) protected;
//----------------------------------------------------------------
//	Created:	31 March 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
//
// Changed On   Changed	TFS		Reason
// ----------   -------	-----	--------------------------------------------------
// 25 Sep 2019	jlgdi1	46717	Used the actual object to determine the listIndex of the combobox, 
//								which also makes it independent from the sorting property of the control
// -------------------------------------------------------------------------------
vars
	isoGrpDict			: CM_ISOTypeGroupByCodeDict;
	isoGrp				: CM_ISOTypeGroup;
	idx					: Integer;
	passport			: CM_Passport;
	failedDAC  			:CM_DataAccessController;
	selIsoGrp : CM_ISOTypeGroup;
	
begin
	if _cmb = null then
		return;
	endif;
	
	_cmb.clear();
	_cmb.addItem(Any_String);
	
	isoGrpDict := app.myRoot.allISOTypeGroups;
	passport := app.myPassport;
	
	foreach isoGrp in isoGrpDict do
		if not isoGrp.canUserAccessSelf(null, failedDAC,passport) then
			continue;
		endif;
		
		idx := _cmb.addItem(isoGrp.code &amp; '  ' &amp; isoGrp.description);
		_cmb.itemObject[idx] := isoGrp;
		
		if isoGrp.code = _isoGrpCode then
			selIsoGrp := isoGrp;
		endif;
	endforeach;
	
	if selIsoGrp &lt;&gt; null then 
		_cmb.listIndex := _cmb.findObject(selIsoGrp);
	else
		_cmb.listIndex := 1;
	endif;
	
	self.setValueByName(_entRowName, _cmb.text);
end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_entRowName" type="String"/>
        <Parameter name="_isoGrpCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadInvoiceLineType" id="8ddf42cc-fea8-4bf7-afc7-7e82f853de51">
        <source>doLoadInvoiceLineType(_cmb : CMUI_ComboBox input; _typeString : String; _company : CM_Bank) protected;
//	CCMS 2348 invoice line types for invoice line reporting
//
// Changed On   Changed	TFS		Reason
// ----------   -------	-----	--------------------------------------------------
// 25 Sep 2019	jlgdi1	46717	Used the actual object to determine the listIndex of the combobox, 
//								which also makes it independent from the sorting property of the control
// -------------------------------------------------------------------------------
vars
	combo 			: CMUI_ComboBox;
	invLineType		: CM_InvoiceLineDesc;
	company			: CM_Bank;
	invDescription 	: String;
	idx				: Integer;
	dynaDict 		: DynaDictionary;
	obj				: Object;
	selInvLineType : CM_InvoiceLineDesc;
	
begin
	if _cmb = null then
		return;
	endif;
	
	combo := _cmb;
	combo.clear();
	combo.sorted := false;
	
	combo.addItem(app.getErrorString(AnyString));
		
	// Get the collection to search based on the company we've passed in otherwise it remains an any.
	create dynaDict transient;
	dynaDict.setMembership(CM_InvoiceLineDesc);
	dynaDict.addMemberKey(CM_InvoiceLineDesc::narration.name, false, false);
	dynaDict.endKeys(true);
	
	if _company &lt;&gt; null then
		company := _company;
		foreach invLineType in company.invoiceLineDescriptors where not invLineType.isNotAvailableForEntry do
			dynaDict.add(invLineType);
		endforeach;
		
		//Add all Invoice line types from the companies that are business units in the company.
		foreach obj in dynaDict do
			invLineType := obj.CM_InvoiceLineDesc;
			invDescription := null;
			invDescription := invLineType.getDescriptionWithTerminalStr();
			idx := combo.addItem(invDescription);
			combo.itemObject[idx] := invLineType;
			
			if (_typeString &lt;&gt; null) and (_typeString = invDescription) then
				selInvLineType := invLineType;
			endif;
		endforeach;
	endif;
	
	if selInvLineType &lt;&gt; null then
		combo.listIndex := combo.findObject(selInvLineType);
	else
		combo.listIndex := 1;
	endif;
	
	self.setValueByName(ETRow_InvLineType, combo.text);
	
epilog
	delete dynaDict;
end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_typeString" type="String"/>
        <Parameter name="_company" type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="doLoadInvoiceStatus" id="00fef0af-dcec-4c2b-b65b-d42f768aa5bc">
        <source>doLoadInvoiceStatus(_cmb : CMUI_ComboBox input; _status : String; _bank : CM_Bank) protected;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		20 April 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
// 04/04/2018 	   jlgdap1	 TFS 37560 PEL1 Prepend Invoice Status
// 31 Oct  2018    cnwma1	 ChangeRequest 41703: PEL1 - Sap Integration - Post Billing Cancelled Invoice
// 23 Jan 2019     cnwma1	 Bug 48352: ADP - FW: Get_invoice_date
//----------------------------------------------------------------------
vars
	combo 	   : CMUI_ComboBox;
	term 	   : CM_Terminal;
	bank 	   : CM_Bank;
	invProcess : CM_InvoiceProcess;
	invStatus  : CM_InvoiceStatus;
	
begin
	if _cmb = null then
		app.raiseUnexpectedProgramError(self.class.name, method.name, 'An Invoice combo box was expected but cannot be located.');
	endif;
	
	combo := _cmb;
	combo.clear();
	combo.sorted := false;
	
	combo.addItem(Any_String);
	combo.itemData[combo.newIndex] := CM_Invoice.INVOICE_ALL_STATUS;

	combo.listIndex := combo.newIndex;
	
	 // TFS 39618 PATCH 1  use soft statuses
	bank := _bank;
	if bank &lt;&gt; null then
		invProcess := bank.getMyInvoiceProcess;
		if invProcess &lt;&gt; null then
			foreach invStatus in invProcess.allStatuses	discreteLock do
				combo.addItem(invStatus.description);
				combo.itemData[combo.newIndex] := invStatus.id;
			endforeach;
		endif;
	endif;
	/*  // TFS 39618 PATCH 1 
	combo.addItem(app.getInvoiceStatusString(self.myParentForm.myTerminal.getDefaultCompanyBank().myInvoiceProcess, CM_Invoice.INVOICE_OPEN)); //getErrorString(Open_GC)); // TFS 39618
	combo.itemData[combo.newIndex] := CM_Invoice.INVOICE_OPEN;

	combo.addItem(app.getInvoiceStatusString(self.myParentForm.myTerminal.getDefaultCompanyBank().myInvoiceProcess, CM_Invoice.INVOICE_SUSPENSE)); //app.getErrorString(Suspense));
	combo.itemData[combo.newIndex] := CM_Invoice.INVOICE_SUSPENSE;
	
	combo.addItem(app.getInvoiceStatusString(self.myParentForm.myTerminal.getDefaultCompanyBank().myInvoiceProcess, CM_Invoice.INVOICE_PENDING)); //getErrorString(Pending)); // TFS 39618
	combo.itemData[combo.newIndex] := CM_Invoice.INVOICE_PENDING;

	combo.addItem(app.getInvoiceStatusString(self.myParentForm.myTerminal.getDefaultCompanyBank().myInvoiceProcess, CM_Invoice.INVOICE_POSTED)); //app.getErrorString(Posted)); // TFS 39618
	combo.itemData[combo.newIndex] := CM_Invoice.INVOICE_POSTED;
	
	combo.addItem(app.getInvoiceStatusString(self.myParentForm.myTerminal.getDefaultCompanyBank().myInvoiceProcess, CM_Invoice.INVOICE_VOID)); //app.getErrorString(Void)); // TFS 39618
	combo.itemData[combo.newIndex] := CM_Invoice.INVOICE_VOID;
	
	//04 Sep 2017	NDL	TFS 6759
	combo.addItem(app.getInvoiceStatusString(self.myParentForm.myTerminal.getDefaultCompanyBank().myInvoiceProcess, CM_Invoice.INVOICE_POSTED_REVERSE)); //app.getErrorString(Posted_returned)); // TFS 39618
	combo.itemData[combo.newIndex] := CM_Invoice.INVOICE_POSTED_REVERSE;
	
	//04 Sep 2017	NDL	TFS 6759
	combo.addItem(app.getInvoiceStatusString(self.myParentForm.myTerminal.getDefaultCompanyBank().myInvoiceProcess, CM_Invoice.INVOICE_POSTED_CREDIT)); //app.getErrorString(Posted_credit)); // TFS 39618
	combo.itemData[combo.newIndex] := CM_Invoice.INVOICE_POSTED_CREDIT;
	
	combo.addItem(app.getInvoiceStatusString(self.myParentForm.myTerminal.getDefaultCompanyBank().myInvoiceProcess, CM_Invoice.INVOICE_PREPEND)); //app.getErrorString(Prepend)); // TFS 37560 // TFS 39618
	combo.itemData[combo.newIndex] := CM_Invoice.INVOICE_PREPEND;		// TFS 37560
	combo.addItem(app.getInvoiceStatusString(self.myParentForm.myTerminal.getDefaultCompanyBank().myInvoiceProcess, CM_Invoice.INVOICE_DISPUTED)); //app.getErrorString(Disputed));	// TFS 37560 // TFS 39618
	combo.itemData[combo.newIndex] := CM_Invoice.INVOICE_DISPUTED;		// TFS 37560
	
	combo.addItem(app.getInvoiceStatusString(self.myParentForm.myTerminal.getDefaultCompanyBank().myInvoiceProcess, CM_Invoice.INVOICE_PENDING_REVERSE)); //app.getErrorString(Pending_returned)); //31.10.2018 cnwma1 TFS #41703 // TFS 39618
	combo.itemData[combo.newIndex] := CM_Invoice.INVOICE_PENDING_REVERSE; //31.10.2018 cnwma1 TFS #41703
	if _status &lt;&gt; null then
		combo.text := _status;
	else
		combo.listIndex := 1;
	endif;
	*/

	if _status &lt;&gt; null then      // 23.01.2020 cnwma1 48352
		combo.text := _status;
	else
		combo.listIndex := 1;
	endif;
	self.setValueByName(ETRow_InvoiceStatus, combo.text);
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_status" type="String"/>
        <Parameter name="_bank" type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="doLoadInvoiceType" id="232e8f8b-4b88-4fdc-9fab-c58f044e9852">
        <source>doLoadInvoiceType(_cmb : CMUI_ComboBox input; _typeString : String; _company : CM_Bank) protected;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		20 April 2010
//
// Implemented version: JMT 7.8.2
// Changed On   Changed	TFS		Reason
// ----------   -------	-----	--------------------------------------------------
// SFW CCMS 1115 PAR23680   cnwsh3 - Invoice JRW Interface
// 25 Sep 2019	jlgdi1	46717	Used the actual object to determine the listIndex of the combobox, 
//								which also makes it independent from the sorting property of the control
// -------------------------------------------------------------------------------
vars
	combo 			: CMUI_ComboBox;
	invType			: CM_InvoiceDesc;
	company			: CM_Bank;
	invDescription 	: String;
	idx				: Integer;
	dynaDict 		: DynaDictionary;
	obj				: Object;
	selInvType : CM_InvoiceDesc;
	
begin
	if _cmb = null then
		return;
	endif;
	
	combo := _cmb;
	combo.clear();
	combo.sorted := false;
	
	combo.addItem(app.getErrorString(AnyString));
		
	//Get the collection to search based on the company we've passed in otherwise it remains an any.
	create dynaDict transient;
	dynaDict.setMembership(CM_InvoiceDesc);
	dynaDict.addMemberKey(CM_InvoiceDesc::description.name, false, false);
	dynaDict.endKeys(true);
	
	if _company &lt;&gt; null then
		company := _company;
		foreach invType in company.invoiceTypes where not invType.isNotAvailableForEntry do
			dynaDict.add(invType);
		endforeach;
		
		//Add all Invoice types from the companies that are business units in the company.
		foreach obj in dynaDict do
			invType := obj.CM_InvoiceDesc;
			invDescription := null;
			invDescription := invType.getDescriptionWithTerminalStr();
			idx := combo.addItem(invDescription);
			combo.itemObject[idx] := invType;
			
			if (_typeString &lt;&gt; null) and (_typeString = invDescription) then
				selInvType := invType;
			endif;
		endforeach;
	endif;
	
	if selInvType &lt;&gt; null then
		combo.listIndex := combo.findObject(selInvType);		
	else
		combo.listIndex := 1;
	endif;
	
	self.setValueByName(ETRow_InvoiceType, combo.text);	
	
epilog
	delete dynaDict;
end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_typeString" type="String"/>
        <Parameter name="_company" type="CM_Bank"/>
    </JadeMethod>
    <JadeMethod name="doLoadListTableLogLot" id="c1605f02-2d72-487e-a409-580a0730e807">
        <source>doLoadListTableLogLot(_lstTblLogLot : CMUI_ListTable input; _voyageGlobal : CM_VoyageGlobal);
// ---------------------------------------------------------------------------
// Created:     06 January 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	logLot			: CM_LogLot;
	voyage			: CM_Voyage;
	logVoyageStruct		: CM_LogVoyageStructure;
	multiTerminal	: Boolean;
	str,
	terminalCode	: String;
begin
	if _voyageGlobal = null or _lstTblLogLot = null then
		return;
	endif;
	

	_lstTblLogLot.rows := 0;
	multiTerminal := (self.allTerminals.size &gt; 1);
	foreach voyage in _voyageGlobal.allVoyages discreteLock where self.allTerminals.includes(voyage.myTerminal) do
//		if (not CM_LogVoyage.hasInstance(voyage)) then
		if voyage.myLogVoyageStructure = null then
			continue;
		endif;
		terminalCode := voyage.myTerminal.code;
		logVoyageStruct := voyage.myLogVoyageStructure;	
		
		foreach logLot in logVoyageStruct.allLogLots discreteLock do
			str := _lstTblLogLot.allSelectedObjects.includes(logLot).Integer.String &amp; Tab &amp; logLot.lotNo;	
			if multiTerminal then
				str := str &amp; Tab &amp; ' -' &amp; terminalCode;	
			endif;
			
			_lstTblLogLot.accessRow(_lstTblLogLot.addItem(str)).itemObject := logLot;
		endforeach;		
	endforeach;
	
end;</source>
        <Parameter name="_lstTblLogLot" type="CMUI_ListTable" usage="input"/>
        <Parameter name="_voyageGlobal" type="CM_VoyageGlobal"/>
    </JadeMethod>
    <JadeMethod name="doLoadLogGrades" id="bb6e40ca-e962-41b8-8b38-fb982c556137">
        <source>doLoadLogGrades(_gradeCode : String);
// ---------------------------------------------------------------------------
// Created:     17 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tmpCodeGroup 	: CM_CodesByCodeDict;
	logGrade		: CM_Code;
	idx				: Integer;
	species			: CM_LogSpecies;
	gradeCmb		: CMUI_ComboBox;
begin
	gradeCmb := self.myCmbLogGrade;
	gradeCmb.clear();
	species := self.myCmbLogSpecies.listObject.CM_LogSpecies;
	
	if species &lt;&gt; null then
		tmpCodeGroup := species.allLogGrades;
	endif;
	//load even if null so as to load an **Any** at the top
	gradeCmb.listCollectionWithAny(tmpCodeGroup, 'code');
	
	if _gradeCode &lt;&gt; null and
	   tmpCodeGroup &lt;&gt; null and
	   tmpCodeGroup[_gradeCode] &lt;&gt; null then
		gradeCmb.text := _gradeCode;
	else
		gradeCmb.text := Any_String;
	endif;
	
	self.myCmbLogType.clear();
	self.myCmbLogTreatment.clear();
	self.myCmbLogLength.clear();
	
	self.myCmbLogType.addItem(Any_String);
	self.myCmbLogTreatment.addItem(Any_String);
	self.myCmbLogLength.addItem(Any_String);
	
	self.setValueByName(ETRow_LogGrade, gradeCmb.text);
	self.setValueByName(ETRow_LogType, Any_String);
	self.setValueByName(ETRow_LogTreatment, Any_String);
	self.setValueByName(ETRow_LogLength, Any_String);

end;</source>
        <Parameter name="_gradeCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadLogLengths" id="36eb3b22-68b6-406e-bd34-3190db55da3c">
        <source>doLoadLogLengths(_value : String);
// ---------------------------------------------------------------------------
// Created:     18 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tmpLogLengths	: CM_LogLengthsBySortOrder;
	logGrade		: CM_LogGrade;
	logLength		: CM_LogLength;
	idx				: Integer;
	gradeCmb,
	lengthCmb		: CMUI_ComboBox;	
	found : Boolean;
begin
	gradeCmb 		:= self.myCmbLogGrade;
	lengthCmb 		:= self.myCmbLogLength;
	
	lengthCmb.clear();
	logGrade := gradeCmb.listObject.CM_LogGrade;
	
	if logGrade &lt;&gt; null then
		tmpLogLengths := logGrade.allLogLengthsBySortOrder;	
	endif;
	
	lengthCmb.listCollectionWithAny(tmpLogLengths, 'code');

	if tmpLogLengths &lt;&gt; null then 
		foreach logLength in tmpLogLengths do 
			if _value = logLength.code then 
				found := true;
				break;
			endif;
		endforeach;
	endif;
	
	if found then 
		lengthCmb.text := _value;
	else
		lengthCmb.text := Any_String;
	endif;
		
//	if tmpLogLengths &lt;&gt; null and 
//	   tmpLogLengths[_value] &lt;&gt; null then
//		lengthCmb.text := _value;
//	else
//		lengthCmb.text := Any_String;
//	endif;
	
	self.setValueByName(ETRow_LogLength, lengthCmb.text);	

end;</source>
        <Parameter name="_value" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadLogRowFumigate" id="a822ee7f-6087-4a5a-961a-0df2f8ce1450">
        <source>doLoadLogRowFumigate(_cmb : CMUI_ComboBox input; _fumigate : String) protected;

/*
Date				Who		Reason
28 September 2009	cnwar2	CCMS1107/#20638

*/
vars

begin
	if _cmb = null then
		return;
	endif;
	
	_cmb.clear();
	
	_cmb.itemData[_cmb.addItem(Any_String)] := 0;
	_cmb.itemData[_cmb.addItem(app.getErrorString(Fumigated))]		:= LOG_ROW_FUMIGATED;
	_cmb.itemData[_cmb.addItem(app.getErrorString(NotFumigated))] 	:= LOG_ROW_NOTFUMIGATED;
	
	if _fumigate &lt;&gt; null then
		_cmb.text := _fumigate;
	else
		_cmb.listIndex := 1;
	endif;
	
	self.setValueByName(ETRow_IsLocationFumigated, _cmb.text);
end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_fumigate" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadLogRowInspect" id="94d16e8a-1251-465f-8baf-301f6a22734b">
        <source>doLoadLogRowInspect(_cmb : CMUI_ComboBox input; _inspect : String) protected;

/*
Date				Who		Reason
28 September 2009	cnwar2	CCMS1107/#20638

*/
vars

begin
	if _cmb = null then
		return;
	endif;
	
	_cmb.clear();
	
	_cmb.itemData[_cmb.addItem(Any_String)] := 0;
	_cmb.itemData[_cmb.addItem(app.getErrorString(Inspected))]		:= LOG_ROW_INSPECTED;
	_cmb.itemData[_cmb.addItem(app.getErrorString(NotInspected))] 	:= LOG_ROW_NOTINSPECTED;
	
	if _inspect &lt;&gt; null then
		_cmb.text := _inspect;
	else
		_cmb.listIndex := 1;
	endif;
	
	self.setValueByName(ETRow_IsLocationInspected, _cmb.text);
end;</source>
        <access>protected</access>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="input"/>
        <Parameter name="_inspect" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadLogSpecies" id="f2371aa9-8a96-4e95-944d-f3e26b752ad4">
        <source>doLoadLogSpecies(_speciesCode : String);
// ---------------------------------------------------------------------------
// Created:     18 December 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	tmpCodeGroup 	: CM_CodesByCodeDict;
	logSpecies		: CM_Code;
	idx				: Integer;
	op				: CM_Operator;
	opCmb,
	speciesCmb,
	gradeCmb,
	typeCmb,
	treatCmb,
	lengthCmb		: CMUI_ComboBox;
begin

	opCmb 			:= self.myCmbOperator;
	speciesCmb 		:= self.myCmbLogSpecies;
	gradeCmb 		:= self.myCmbLogGrade;
	typeCmb 		:= self.myCmbLogType;
	treatCmb 		:= self.myCmbLogTreatment;
	lengthCmb 		:= self.myCmbLogLength;
	
	speciesCmb.clear();
	op := opCmb.listObject.CM_Operator;
	
	if op &lt;&gt; null then
		tmpCodeGroup := op.getAllLogSpecies;
	endif;
	//load even if null so as to load an **Any** at the top
	speciesCmb.listCollectionWithAny(tmpCodeGroup, 'code');
	
	if _speciesCode &lt;&gt; null and
	   tmpCodeGroup &lt;&gt; null and
	   tmpCodeGroup[_speciesCode] &lt;&gt; null then
		speciesCmb.text := _speciesCode;
	else
		speciesCmb.text := Any_String;
	endif;
	
	gradeCmb.clear();
	typeCmb.clear();
	treatCmb.clear();
	lengthCmb.clear();
	
	gradeCmb.addItem(Any_String);
	typeCmb.addItem(Any_String);
	treatCmb.addItem(Any_String);
	lengthCmb.addItem(Any_String);
	
	self.setValueByName(ETRow_LogSpecies, speciesCmb.text);
	self.setValueByName(ETRow_LogGrade, Any_String);
	self.setValueByName(ETRow_LogType, Any_String);
	self.setValueByName(ETRow_LogTreatment, Any_String);
	self.setValueByName(ETRow_LogLength, Any_String);

end;</source>
        <Parameter name="_speciesCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="doLoadLogTreatments" id="494d882a-3a9d-4510-8d57-b9f76bf2f1d6">
