    <JadeMethod name="doBaseFormSave" id="85643112-74ed-4bcd-86f5-97ce3b63f94f">
        <updating/>
        <source>doBaseFormSave() updating, protected;
//----------------------------------------------------------------
//	Created:	20 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

	fileGet		 		: CMDFileSave;
	fileName			: String;
	file				: File;
begin
	create fileGet;
	
	fileGet.filter := '*.*';
	fileGet.fileName := "";
	fileGet.overwritePrompt := true;
	fileGet.initDir := "";
	if fileGet.open = 0 then	//user clicked OK
		fileName := fileGet.fileName;
	else
		return;
	endif;
	
	create file transient;
	file.openOutput(fileName);
	file.writeString(self.txtMessage.text);
	
epilog
	if file &lt;&gt; null then
		file.close;
		delete file;	
	endif;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="4fc98c58-7a32-4478-942f-cbd0bbf5dbe0">
        <updating/>
        <source>doResize() updating;
//----------------------------------------------------------------
//	Created:	20 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	self.frmToolbar.width := self.width;
	self.frmToolbar.positionToolbarControls;
	self.txtMessage.top := self.frmToolbar.height;
	self.txtMessage.width := self.width - 8;
	self.txtMessage.height := self.height - (27 + self.frmToolbar.height);
	

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="7cecce3f-039e-4b4d-84b8-c77394f09179">
        <updating/>
        <source>setupForm() updating;
//----------------------------------------------------------------
//	Created:	20 May 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin

	inheritMethod();
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;	
	self.showToolbar := true;
	
	self.width := 450;
	self.height := 450;

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="7a01e734-f6c1-4fcf-a178-f7f63630077b">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0013525, locale);
end;</source>
    </JadeMethod>
</GUIClass>
