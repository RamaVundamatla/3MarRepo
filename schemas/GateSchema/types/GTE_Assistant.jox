    <JadeMethod name="setTIHeading" id="b35662a3-9faa-46eb-92c3-480c8327abd4">
        <source>setTIHeading(pCargoTypeHeading : String; pMainTbl : CM_EntryTable io; _showMandatory :  Boolean);
// ---------------------------------------------------------------------------
// Created:     08 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 17/01/02		GD			Added heading for DocketType
// ---------------------------------------------------------------------------
vars
	tmpRow		: Integer;
	idHeading	: String;
	
begin

	if pCargoTypeHeading = null then
		idHeading := app.getErrorString(CargoId);
	else
		idHeading := pCargoTypeHeading;
	endif;
	
	tmpRow := pMainTbl.getRow(ETRow_Id);
	if tmpRow = 0 then
		tmpRow := pMainTbl.getRow(ETRow_IdCombo);
	endif;
	if tmpRow = 0 then
		tmpRow := pMainTbl.getRow(ETRow_IdTextBox);
	endif;
	if tmpRow = 0 then
		tmpRow := pMainTbl.getRow(ETRow_BolNumber);
	endif;
	
	if _showMandatory and app.showMandatoryFields() then
		idHeading := idHeading &amp; MandatoryFieldIndicator;
	endif;
	
	if tmpRow &gt; 0 then
		pMainTbl.setHeading(tmpRow, idHeading);
	endif;
	
end;</source>
        <Parameter name="pCargoTypeHeading" type="String"/>
        <Parameter name="pMainTbl" type="CM_EntryTable" usage="io"/>
        <Parameter name="_showMandatory" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showAttachments" id="25693479-c371-4343-b981-5ceb1814911b">
        <source>showAttachments(pAllAttachments : CMIF_InOutAttachmentArray; pTable : CM_EntryTable input; pAddAttachRow : Integer);
// ---------------------------------------------------------------------------
// Created:     15 February 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	idx,
	tmpRow			: Integer;
	intFaceAttach	: CMIF_InOutAttachment;
	
begin

	// clear any existing attachment(s)
	pTable.rows := pAddAttachRow;

	idx := 0;
	foreach intFaceAttach in pAllAttachments do
		idx := idx + 1;
		tmpRow := pTable.addAttribute(ATTACH_RowName &amp; idx.String, app.getErrorString(Attachment) &amp; ' (' &amp; idx.String &amp; ')', Table.InputType_None, 0, true);
		pTable.setValue(tmpRow, intFaceAttach.id);
	endforeach;

end;</source>
        <Parameter name="pAllAttachments" type="CMIF_InOutAttachmentArray"/>
        <Parameter name="pTable" type="CM_EntryTable" usage="input"/>
        <Parameter name="pAddAttachRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="showCargoReleaseFromFlexiGate" id="5383df3a-3b0e-4deb-8b93-6c2748739b64">
        <updating/>
        <source>showCargoReleaseFromFlexiGate(	_parentForm : CM_BaseForm; 
								_modal : Boolean; 
								_flexiCargoType, _columns, _controlWidth : Integer; 
								_tranNum : String; 
								_copy : Boolean; 
								_gteEntity : CMGTE_Entity; 
								_bulkRelease : CM_BulkRelease; 
								_reserve : CM_ReserveDetail; 
								_ti : CM_TrackedItem; 
								_brItem : CM_BookingRefItem;
								_bolDtl : CM_BOLDtl;	//06 Oct 2020	NDL	TFS 49189
								_vehicleVisit : CM_VehicleVisitRecord;
								_workOrder : CM_WorkOrder;
								_vbsti : CM_VehicleBookingTimeSlotItem	//31.8.2023 navhl20 #60183	
								) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/08/2009	cnwdap1	Initial creation
14/05/2018	jlgdap1	TFS 38501 PEL1 Work Order Chnages
31 Aug 2023 navhl20 Bug 60183: FR | 53429 - VBS changes - Quantity assigned in the VBS is not remembered during Road Gate announcement
15/07/2024	navpw1	TFS: 61525 (61527) - Added Vehicle booking timeslot item
20/02/2025	navcs2  MTN-34062 - EUP | Release by Weight - further issues
*/
vars
	form	: CMUI_ReleaseCargoForm;
	
begin
	form := app.loadForm(	CMUI_ReleaseCargoForm, 
							self.class, 
							false, false, false, 
							self.myTerminal, null).CMUI_ReleaseCargoForm;
														
	// If user fails security we don't want to show a null form.
	if form &lt;&gt; null then
		//form.setIsFull(_isFull);
		if _flexiCargoType = CMUI_FlexiCargoForm.FLEXI_CARGO_FULL then
			form.setIsFullContainer();
		elseif _flexiCargoType = CMUI_FlexiCargoForm.FLEXI_CARGO_EMPTY then
			form.setIsEmptyContainer();
		elseif _flexiCargoType = CMUI_FlexiCargoForm.FLEXI_CARGO_GENERAL then
			form.setIsGeneralCargo();  // Assume for now...	
		else
			app.raiseUnexpectedProgramError(class.name, method.name, "Undefined flexi cargo type");
		endif;		
		form.setColumnsAndControlWidth(_columns, _controlWidth);	// columns, default control width
		form.initFromFlexiGateForm(_parentForm, _tranNum, _copy, _gteEntity, _bulkRelease, _reserve, _ti, _brItem, _bolDtl, _vehicleVisit, null, _vbsti);		
		form.setMyWorkOrder(_workOrder);				// TFS 38501
		
		if _parentForm.isKindOf(GTE_FlexiGateForm) then
			form.setMyCarrier(_parentForm.GTE_FlexiGateForm.cmbCarrier.listObject.CM_Carrier); //21/03/2011 cnwdz2 27232			
		endif;
		
		if _modal then
			form.showModal();
		else
			form.show();
		endif;
		if _vbsti &lt;&gt; null and _vbsti.quantity &lt;&gt; null 							//31.8.2023 navhl20 #60183
			and (_gteEntity &lt;&gt; null 											// 19/02/2025 navcs2 MTN-34062
			and _gteEntity.isCMGTE_Release 										// 19/02/2025 navcs2 MTN-34062
			and _gteEntity.CMGTE_Release.releaseQuantity = 0) then				// 19/02/2025 navcs2 MTN-34062		
			form.txtNumItems.setValue(_vbsti.quantity);							// 19/02/2025 navcs2 MTN-34062
		endif;
		if _vbsti &lt;&gt; null and _vbsti.weight &lt;&gt; null then				//31.8.2023 navhl20 #60183
			form.tblWeight.setValue(_vbsti.weight);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_parentForm" type="CM_BaseForm"/>
        <Parameter name="_modal" type="Boolean"/>
        <Parameter name="_flexiCargoType" type="Integer"/>
        <Parameter name="_columns" type="Integer"/>
        <Parameter name="_controlWidth" type="Integer"/>
        <Parameter name="_tranNum" type="String"/>
        <Parameter name="_copy" type="Boolean"/>
        <Parameter name="_gteEntity" type="CMGTE_Entity"/>
        <Parameter name="_bulkRelease" type="CM_BulkRelease"/>
        <Parameter name="_reserve" type="CM_ReserveDetail"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_brItem" type="CM_BookingRefItem"/>
        <Parameter name="_bolDtl" type="CM_BOLDtl"/>
        <Parameter name="_vehicleVisit" type="CM_VehicleVisitRecord"/>
        <Parameter name="_workOrder" type="CM_WorkOrder"/>
        <Parameter name="_vbsti" type="CM_VehicleBookingTimeSlotItem"/>
    </JadeMethod>
