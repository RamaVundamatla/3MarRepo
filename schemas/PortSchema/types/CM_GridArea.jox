    <JadeMethod name="getNextAvailableLocation" id="785c849c-3d02-420d-8cc4-6f1ef4b9fed7">
        <source>getNextAvailableLocation(_startLC : CM_GridController) : CM_GridController;
// ---------------------------------------------------------------------------
// Created:     30 November 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	startRow, gridRow : CM_GridRow;
	freeGC : CM_GridController;
begin

	startRow := _startLC.myGridRow;
	
	foreach gridRow in self.allGridRows  discreteLock where gridRow.row &gt;= startRow.row do
		
		freeGC := gridRow.getNextAvailableLocation(REAL_MODE);
		if freeGC &lt;&gt; null then
			break;
		endif;
		
	endforeach;
	
	
	return freeGC;
epilog

end;</source>
        <Parameter name="_startLC" type="CM_GridController"/>
        <ReturnType type="CM_GridController"/>
    </JadeMethod>
