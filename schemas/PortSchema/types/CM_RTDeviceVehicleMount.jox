    <JadeMethod name="pxyCreateUpdateProxy" id="e24803ef-7c1d-41b2-99b2-6e18dfc2f03b">
        <source>pxyCreateUpdateProxy(): SelfType;

// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars

	device : CM_RTDeviceVehicleMount;
	completedOK		: Boolean;
	
begin

	device := inheritMethod();
	device.myMachine := self.myMachine;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return device;

epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete device;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="0b0af2e5-6252-4403-9a73-47d30988db54">
        <updating/>
        <source>setForCreate(_proxyRadioTelemetryDevice: CM_RTDeviceVehicleMount) updating;

vars
	rtVehicleConfig,pxyRTVehicleConfig : CM_RTVehicleConfig;
	terminal : CM_Terminal;
begin
	inheritMethod(_proxyRadioTelemetryDevice);
	self.myMachine := _proxyRadioTelemetryDevice.myMachine;
	
	//jlier1 TFS 54513 25/8/22
	terminal:=self.getMyTerminal;
	if terminal &lt;&gt; null then
		rtVehicleConfig := terminal.getRTVehicleConfigForObject(self);
		if rtVehicleConfig = null then
			create pxyRTVehicleConfig transient;
			app.myUtilityCA.utlCreateRTVehicleConfig(pxyRTVehicleConfig,rtVehicleConfig,null,terminal,null,null,app.myPassport);
		endif;
	endif;
	
epilog
	delete pxyRTVehicleConfig;
end;</source>
        <Parameter name="_proxyRadioTelemetryDevice" type="CM_RTDeviceVehicleMount"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="212da454-65d6-4e17-ba71-b74b12b194c1">
        <updating/>
        <source>setForUpdate(_proxyRTDevice: CM_RTDeviceVehicleMount) updating;
// ---------------------------------------------------------------------------
// Created:		26 March 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars
	rtVehicleConfig,pxyRTVehicleConfig : CM_RTVehicleConfig;
	terminal : CM_Terminal;
begin
	inheritMethod(_proxyRTDevice);
	self.myMachine := _proxyRTDevice.myMachine;
	
	//jlier1 TFS 54513 25/8/22
	terminal:=self.getMyTerminal;
	if terminal &lt;&gt; null then
		rtVehicleConfig := terminal.getRTVehicleConfigForObject(self);
		if rtVehicleConfig = null then
			create pxyRTVehicleConfig transient;
			app.myUtilityCA.utlCreateRTVehicleConfig(pxyRTVehicleConfig,rtVehicleConfig,null,terminal,null,null,app.myPassport);
		endif;
	endif;
	
epilog
	delete pxyRTVehicleConfig;
end;</source>
        <Parameter name="_proxyRTDevice" type="CM_RTDeviceVehicleMount"/>
    </JadeMethod>
    <JadeMethod name="setProxyForVehicleMount" id="9797decd-39d3-4d07-ae8b-3b13f52b13ab">
        <updating/>
        <source>setProxyForVehicleMount(_id 			: String; 
						_radioTelemetry : CM_RadioTelemetry; 
						_machine 		: CM_Machine; 
						_model,
						_computerName	: String; 
						_useSerialConnection : Boolean;
						_useLocalTCPConnection : Boolean ) updating;				// +17/08/2016 cnwrh7	TFS	2501
// ---------------------------------------------------------------------------
// Created:     18 September 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 17/08/2016 cnwrh7	TFS	2501
// ---------------------------------------------------------------------------
vars

begin

	self.setProxyRTDevice(_id, _radioTelemetry, _model, _computerName, _useSerialConnection, _useLocalTCPConnection,  0, null);	// +17/08/2016 cnwrh7	TFS	2501
	self.myMachine := _machine;

end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_radioTelemetry" type="CM_RadioTelemetry"/>
        <Parameter name="_machine" type="CM_Machine"/>
        <Parameter name="_model" type="String"/>
        <Parameter name="_computerName" type="String"/>
        <Parameter name="_useSerialConnection" type="Boolean"/>
        <Parameter name="_useLocalTCPConnection" type="Boolean"/>
    </JadeMethod>
