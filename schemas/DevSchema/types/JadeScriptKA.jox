    <JadeMethod name="runBGPTask" id="06e99a87-6893-4c9e-8bc8-c6bb1a2bcc21">
        <source>runBGPTask();
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 14 September 2023
TFS#		: 
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	
	task			: CM_AutoTask;
	tmpClass		: Class;
	request			: BGP_Request;
	term			: CM_Terminal;
	
begin

	app.initialize();


	task := "5645.44".asOid.CM_AutoTask;	

	write 'Processing task (' &amp; task.description &amp; ')';
	tmpClass := self.getClass(task.requestClassName);
	if tmpClass = null then
		// Class has not been correctly setup.
		write task.requestClassName &amp; ' Request class not found';
		return;
	endif;


	create request as tmpClass transient;
	request.initRequestFromTask(task);
	
	if process.isInTransactionState then
		commitTransaction;
	endif;

	request.action();

	self.unlock(task);
	write method.name&amp;" completed";	
	
epilog	
	write method.name&amp;" epilog";	
	if task &lt;&gt; null then
		self.unlock(task);
	endif;
	delete request;
end;</source>
    </JadeMethod>
    <JadeMethod name="yardCriteria" id="d2d6de40-3a00-4901-95e2-5f37b64d63dc">
        <source>yardCriteria();
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 10 January 2023
TFS#		: 55588
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

vars
	proxyObj		: CM_YACriteriaType;
	yardCriteriaObj	: CM_YATypeIsOnTrailer;
begin
	app.initialize();
	
	beginTransaction;
	if CM_YATypeIsOnTrailer.instances.isEmpty() then								
		create proxyObj as CM_YATypeIsOnTrailer transient;							
		proxyObj.setProxy(proxyObj.getTypeName, true, YACriteriaType_IsOnTrailer);
		create yardCriteriaObj;													
		yardCriteriaObj.setForCreate(proxyObj);									
		delete proxyObj;																
	endif;		
	commitTransaction;
end;</source>
    </JadeMethod>
</Class>
