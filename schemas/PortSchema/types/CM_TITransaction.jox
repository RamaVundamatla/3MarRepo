    </JadeMethod>
    <JadeMethod name="getXlatedCommodity" id="0e2f1148-3bcc-4378-8873-8b267645680d">
        <source>getXlatedCommodity( pXlateOperator : String	// this is the EDI translation operator code from Cam Protocol or wherever else 
						) : String;
/* 
---------------------------------------------------------------------------
 Created:     J Harliwich               

 Purpose:     MES1011  For use by JRW and Cams.
 			  Note, these methods will show as not being referenced, but they are selected on the CM_TransactionView for the JRW.


 Parameters:  EDI Translation Operator Code

 Returns:     the translation of the commodity code, or orignal if no translation

 Changed On   Changed By  Reason
 ----------   ----------  --------------------------------------------------
07 Mar 2013	cnwcs5	CCMS POL 2097 / par 31259 - include foundMatch in method signatures
 ---------------------------------------------------------------------------
*/

vars
	xlateOperator 	: CM_Operator;
	foreignCode 	: String;
	foundMatch		: Boolean;
begin
	
	if  pXlateOperator 				&lt;&gt; null 	and 
		commodity.trimBlanks 		&lt;&gt; "" 		then
		xlateOperator := app.myRoot.allOperators[pXlateOperator];
		if xlateOperator &lt;&gt; null then
			foreignCode := xlateOperator.getXlationForeignCode(commodity, XLATION_TYPE_COMMODITY_BYOP, foundMatch);
			if foreignCode &lt;&gt; null then
				return foreignCode;
			endif;
		endif;
	endif;
	
	return commodity.trimBlanks;	// default to same code if not translated

end;
</source>
        <Parameter name="pXlateOperator" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getXlatedConsignee" id="9ff6a1c0-af7a-47ba-93b2-924a8a928f43">
        <source>getXlatedConsignee( pXlateOperator : String	// this is the EDI translation operator code from Cam Protocol or wherever else 
						) : String;
/* 
---------------------------------------------------------------------------
 Created:     J Harliwich               

 Purpose:     MES1011  For use by JRW and Cams.
