    <JadeMethod name="doCompactTransientFile" id="17f9cc92-8d50-4609-94aa-04bda733487c">
        <source>doCompactTransientFile();
/*

Purpose:			Programmatically compact the transient database file belonging to the 
					receiver Process

Parameters:			None

Return Value:		None

Date		Who		Reason
12 Dec 2017	jlgkpd1	Initial creation - TFS 8294
11 Jul 2019 jlgmd1	TFS 43812 - Theres not much we can do to prevent a ping alert while the compaction is going on,
								But we can at least send a heartbeat before and after.
17 Feb 2021	NDL		TFS 50488	- Try to single thread transient compaction based on application
08 Jun 2021 navmd1	Par 68316 - Fix 3002 when calling compactTransientFile

*/

vars

	mutex : CM_Mutex;
	mutexLocked : Boolean;
	compactIndicator : Integer;

begin

	// app.compactTransientIntervalMins;
	// -1 = default, = do every time, existing behaviour
	// 0 = Off, = no compaction
	// + value = minimum delay in minutes between compactions.

	compactIndicator := app.compactTransientIntervalMins;
	
	if compactIndicator = 0 then
		//Ini file has transient compaction turned off.
		return;
	elseif compactIndicator &gt; 0 then
		//INI file says force a minimum time between transient compactions
		if app.actualTimeAppServer &lt; app.compactAfterTS then
			//Its too soon
			return;
		endif; 
	endif;
	
	mutexLocked := app.getAppnameMutexLock( Mutex_CompactTransients, mutex );
	if mutexLocked then

		app.writeLog(method.qualifiedName &amp; " starting compact of transient file", LogINFO);	//25 Nov 2019	NDL	TFS 47053
		self.cnStartTransaction(method.qualifiedName);
		app.sendHeartbeatIfRequired();
		
		if self.getTransientFileLength() &gt; 0 then
			self.compactTransientFile();
		endif;		
		
		app.sendHeartbeatIfRequired();
		app.writeLog(method.qualifiedName &amp; " compact of transient file complete", LogINFO);	//25 Nov 2019	NDL	TFS 47053
		
		if compactIndicator &gt; 0 then
			app.setNextCompactTime();
		endif;

	else
	
		app.writeLog(method.qualifiedName &amp; " failed to get mutex, compact skipped.", LogINFO);
	
	endif; 
	
epilog

	if mutexLocked then
		self.unlock( mutex );
		self.cnEndTransaction();
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="dumpStackMDH" id="7b32a1cd-7bd2-4e76-8fdd-2a2e208e1939">
        <source>dumpStackMDH();

/*

Purpose:			Called to dump the stack at the point we are at

Parameters:			

Return Value:		


Date		Who		Reason
11 January 2011	cnwmh5	Initial creation

*/

vars
	callStack		: ProcessStackArray;
	methCallDesc	: MethodCallDesc;
begin
	create callStack transient;
	process.currentStack(callStack);
	foreach methCallDesc in callStack do
		write methCallDesc.display;
		app.writeLog(methCallDesc.display, LogINFO);
	endforeach;
epilog
	callStack.purge;
	delete callStack;
end;</source>
    </JadeMethod>
    <JadeMethod name="dumpTranisentsMDH" id="664c77c8-4088-4016-9f48-91e31e167a7c">
        <source>dumpTranisentsMDH(_str : String);

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
21 February 2011	cnwmh5	Initial creation
24/04/2013			cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/

vars
	obj 			: Object;
	message 		: String;
	aLock			: Lock;
	objArray		: ObjectArray;
	
begin
	
	create objArray transient;
	
	process.allTransientInstances(objArray, 0);
	
	foreach obj in objArray do
		
		if not obj.isKindOf(CM_CashPayment) then
			continue;
		endif;
		
		write _str &amp; Tab &amp; obj.String;		
		
	endforeach;

epilog
	
	delete objArray;
	
end;</source>
        <Parameter name="_str" type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="9c307578-bb57-4bf1-bcff-4e0b3809c7c7">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
18 September 2023	navmd1	Initial creation TFS 60524

*/

vars
	str,
	str2	: String;
	user	: CM_User;
	iter	: Iterator;
	term	: CM_Terminal;
	mach	: CM_Machine;
	theNode	: Node;
	pos		: Integer;
	invalid : Boolean;
begin
	if _attrName = ETRow_ComputerName then
		theNode := self.node;
		on Exception do self.handleComputerNameFail(exception, invalid);
		str := theNode.getComputerName();
		on Exception do null;
		
		if invalid then
			return null;
		endif;
		
		if theNode.nodeType = Node.Type_DatabaseServer then								// 1
			return str &amp; Space &amp; app.getErrorString(Database_Server);
		elseif theNode.nodeType = Node.Type_ApplicationServer then						// 2
			str &amp;= Space &amp; app.getErrorString(Thin_Client);
			// Show the port number
			str2 := theNode.getCommandLine;
			pos := str2.pos("AppServerPort", 1);
			if pos &gt; 0 then
				pos += 14;
				str &amp;= " Port " &amp; str2.scanUntil(Space, pos);
			endif;
			return str;
		elseif theNode.nodeType = Node.Type_ApplicationServerAndDatabaseServer then		// 3
			return str &amp; Space &amp; app.getErrorString(Single_User_App_Server);
		elseif theNode.nodeType = Node.Type_StandardClient then							// 4
			return str &amp; Space &amp; app.getErrorString(FatClient);
		elseif theNode.nodeType = Node.Type_StandardClientAndDatabaseServer then		// 5
			return str &amp; Space &amp; app.getErrorString(Single_User_Fat_Client);
		else
			return str &amp; Space &amp; app.getErrorString(Unknown);
		endif;
		
	elseif _attrName = ETRow_UserCode then
		user := app.myRoot.allUsers[self.userCode];
		
		// Must be a machine code then, so grab the user from that
		if user = null then
			str := self.userCode;
			iter := app.myRoot.allTerminals.createIterator();
			while iter.next(term) do
				mach := term.machines[str];
				if mach &lt;&gt; null then
					if mach.loggedOn then
						user := mach.user;
						break;
					endif;
				endif;
			endwhile;
		endif;
		
		if user &lt;&gt; null then
			return self.userCode &amp; " - " &amp; user.userName;
		endif;
		
		return self.userCode;
	elseif _attrName = ETRow_Application then
		str := self.persistentApp.name;
		if self.userInfo &lt;&gt; null and self.userInfo &lt;&gt; str then
			return str &amp; " (" &amp; self.userInfo &amp; ")";
		else
			return str &amp; " (" &amp; self.cnGetInstanceId64(self).String &amp; ")";
		endif;
	elseif _attrName = ETRow_Workstation then
		return self.getComputerName();
	elseif _attrName = ETRow_SignedOn then
		return self.signOnTime.String;
	elseif _attrName = ETRow_LogLevel then
		return "-";		//This value will be replaced by notification once the base data is loaded.
	endif;

	return inheritMethod(_attrName, _short);

epilog
	delete iter;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLockDuration" id="0516d170-0b64-496c-8ce3-035b35261b55">
        <source>getLockDuration(obj : Object; lockedAt : TimeStamp io; lockDuration : String io);

vars
	l  : Lock;
	la : LockArray;
begin
	create la transient;
	self.node.system.getLocks(la, 10000);
	foreach l in la do
		if l.target &lt;&gt; obj then
			continue;
		endif;
		//Return the approprriate stuff.
		lockedAt := l.requestTime;
		lockDuration := l.elapsedTime.display;
		return;
	endforeach;
epilog
	la.purge;
	delete la;		
end;</source>
        <Parameter name="obj" type="Object"/>
        <Parameter name="lockedAt" type="TimeStamp" usage="io"/>
        <Parameter name="lockDuration" type="String" usage="io"/>
    </JadeMethod>
