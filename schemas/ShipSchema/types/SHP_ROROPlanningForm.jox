    <JadeMethod name="changeScale" id="7c87918a-8cf5-4ac6-8820-850601250646">
        <updating/>
        <source>changeScale(_increase : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     28 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 30 Jul 2012		cnwcs5			par 29124 - remarks
// ---------------------------------------------------------------------------
constants
	MaxZoom = 2;
	MinZoom = .5;
vars
	newScale, pc : Decimal[12,2];
begin

	newScale := self.scaleFactor;
	
	if _increase then
		newScale := newScale + .1;
		
		if newScale &gt; MaxZoom then
			newScale := MaxZoom;
		endif;
	else
		newScale := newScale - .1;
		
		if newScale &lt; MinZoom then
			newScale := MinZoom;
		endif;
	endif;
	

	self.setScale(newScale, self.frmDeck, self.myROROPlanDrawController.allBackFrames);
	self.doResize();

	if self.btnDrawRemarks.value then	// par 29124 July 2012
		// remarks will be added again if necessary
		self.doRepositionRemarks;
	endif;

epilog

end;</source>
        <Parameter name="_increase" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="changeViewMode" id="269c8dfe-d2cb-49eb-9ce4-5fac4d059855">
        <updating/>
        <source>changeViewMode(_newMode : Integer) updating;
/*
Purpose:			
Date			Who		Reason
10 June 2011	cnwab1	Initial creation
30 July 2012	cnwcs5	par 29124 - hide any load planning remarks
*/

vars
	formLoad	:CMUI_VoyageAllocsLoadListForm;
	formList	:CMUI_VoyageAllocationsListForm;
	voyage		:CM_Voyage;
begin
	if self.modeView = ShpDisplayMode_ColCodeLoad and	// par 29124 July 2012
		_newMode &lt;&gt; ShpDisplayMode_ColCodeLoad then
		self.doHideRemarks;
	endif;
	
	self.modeView 							:= _newMode;
	self.myROROPlanDrawController.modeView 	:= _newMode;

	self.doClearTopDrawingFrame(true);
	self.setCaptionForModesGetView(_newMode);
	
	self.btnWorkJob.value 		:= false;
	self.btnWorkPlan.value 		:= false;
	self.btnWorkSeq.value 		:= false;
	self.modeWork 				:= WorkMode_None;
	self.btnViewExport.visible := false; // PAR 31073
	self.btnAftFwdLinks.visible := false;
	
	if self.modeView = ShpDisplayMode_Defn then
		self.doNotesForLegendStartStop(VIEW_DISPORT);
		self.setModeViewDefn();
	endif;

	if self.modeView = ShpDisplayMode_Actual then
		self.doNotesForLegendStartStop(VIEW_DISPORT);
		self.setModeViewActual();
		self.btnAftFwdLinks.visible := app.isSpecial();

	endif;
	
	if self.modeView = ShpDisplayMode_Proposed then
		self.doNotesForLegendStartStop(VIEW_DISPORT);
		self.setModeViewProposed();
	endif;
	
	if self.modeView = ShpDisplayMode_ColCodeDisch then
		//24 Jan 2012	NDL	Par 28896
		formLoad := self.myCCPaletteLoad;
		
		if formLoad &lt;&gt; null then
			formLoad.unloadForm();
			self.myCCPaletteLoad := null;
		endif;
		
		self.doNotesForLegendStartStop(VIEW_YARD_ALLOC);
		
		if self.myCurrentVoyage &lt;&gt; null then 
			self.myCurrentVoyage.causeEvent(self.myTerminal.getTerminalEvent(ShowHide_VoyageAllocationsCC),true,true);
		endif;
		
		self.setModeViewCCDischarge();
		self.displayModeColour(false); //par  29098
	endif;
	
	if self.modeView = ShpDisplayMode_ColCodeLoad then
		//24 Jan 2012	NDL	Par 28896
		formList := self.myCCPalette;
		
		if formList &lt;&gt; null then
			formList.unloadForm();
			self.myCCPalette := null;
		endif;
		
		self.doNotesForLegendStartStop(VIEW_YARD_ALLOC);

		voyage := self.myCurrentVoyage;
		
		if voyage &lt;&gt; null then 
			voyage.causeEvent(self.myTerminal.getTerminalEvent(ShowHide_VoyageAllocationsCC),true,true);
		endif;
		
		self.setModeViewCCLoad();
		self.displayModeColour(true); 			// par  29098
		self.btnAftFwdLinks.visible := app.isSpecial();
	endif;
	
	self.frmDeck.myDrawingFrame.CMUI_PointDrawingFrame.setModeView(_newMode);
	self.doDrawLayers();
	
	self.setCaption(self.setCaptionForModesGetView(_newMode));
	
	self.frmDeck.repositionScrollBars();
epilog

end;</source>
        <Parameter name="_newMode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="changeVoyage" id="ad604aa9-d531-4a89-bc1b-ea9e2a338768">
        <updating/>
        <source>changeVoyage(_roro : CM_ROROVoyageStructure) updating;
/*
Purpose:			
Date		Who		Reason
23 September 2011	cnwab1	Initial creation
01 Aug 2012			cnwcs5	par 29124
27 dec 2012	cnwrs1	try and stop crashes if voyage deleted while window open
13 Mar 2020 cnwma1 Bug 48863: JMT - Voyage Archive, Non Worked Cargo Issue
*/

vars
	oldVoyage 		: CM_Voyage;
	tmpTermEvent 	: Integer;
	jobEvent		: Integer;
	str : String;
	isInvalid : Boolean;
begin
	on Exception do app.handleDeletedObject(exception, _roro, isInvalid);
	
	if _roro = null then  //13/03/2020 cnwma1 Bug #48863
		return;
	endif;
	str := _roro.typeString;
	if isInvalid then
		self.myCurrentRORO 		:= null;
		self.myCurrentVoyage 	:= null;
		return;
	endif;
	oldVoyage 				:= self.myCurrentVoyage;
	self.myCurrentRORO 		:= _roro;
	self.myCurrentVoyage 	:= _roro.myVoyage;
	self.setNavigatorHeading(self.myCurrentVoyage.code.trimBlanks &amp; " " &amp; self.myCurrentVoyage.vesselName); // NAVIGATOR 31110
	
	// PAR 28513
	if not  self.myCurrentVoyage.useVoyageAllocations then
		app.msgBox(app.getErrorString2(Voyag_does_not_voyag_alloc_ple, self.myCurrentVoyage.code, self.myCurrentVoyage.code),
							app.getErrorString(Voyage_issue), MsgBox_Exclamation_Mark_Icon);
							
		on Exception do app.handleDeletedObject(exception, oldVoyage, isInvalid);
		
		self.myCurrentVoyage := oldVoyage;
		// 28605 Nov 2011 cnwjre1 add null check to handle when called from setupForm
		if oldVoyage = null then
			self.myCurrentRORO := null;
		else
			self.myCurrentRORO := oldVoyage.myROROStructure;
			if isInvalid then
				self.myCurrentRORO 		:= null;
				self.myCurrentVoyage 	:= null;
				return;
			endif;
			// also restore combo voyage
			self.cmbVoyage.listIndex := self.cmbVoyage.findObject(self.myCurrentRORO);
		endif;

		return;
	endif;

	self.doNotesForLegendStartStop(VIEW_DISPORT);

	if oldVoyage = self.myCurrentVoyage then
		return;
	endif;
	
	tmpTermEvent 	:= self.myTerminal.getTerminalEvent(EVENT_UPDATE_VOYAGE_AREA);
	jobEvent 		:= self.myTerminal.getTerminalEvent(VoyageJob_Delete_Event);
	
	if oldVoyage &lt;&gt; null then
		self.endNotification(oldVoyage, tmpTermEvent);
		self.endNotification(oldVoyage, jobEvent);	// 28750 Jan 2012 job deletion
	endif;
	
	app.myCurrentVoyage := self.myCurrentVoyage;
	
	self.beginNotification(self.myCurrentVoyage, tmpTermEvent, Response_Continuous, null);
	self.beginNotification(self.myCurrentVoyage, jobEvent, Response_Continuous, null);	// 28750 Jan 2012 job deletion
	
	// 28977 Jan 2012 clear Deck Jobs tab
	self.tblJobsData.rows	:= self.tblJobsData.fixedRows;
	self.shtJobs.caption 	:= app.getErrorString(Deck) &amp; " " &amp; app.getErrorString(Jobs);
	// PAR 28629 
	self.hideCCP(true);
	self.hideLAC(true);
	
	self.doClearRemarks;	// par 29124 Aug 2012
	
	self.showDecks();
	
	self.setCaption( self.setCaptionForModesGetView(self.modeView)); //epr TFS 2362 4/8/16
	
	if self.mySideViewForm &lt;&gt; null then
		self.mySideViewForm.setNoteForVoyage(oldVoyage, self.myCurrentVoyage);
	endif;
	
	self.chkOutOfSequence.value := self.myCurrentVoyage.createOutOfSequenceLoadJobs(); //cnwrd1 par 30626 ccms 2209 23.10.12
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="_roro" type="CM_ROROVoyageStructure"/>
    </JadeMethod>
