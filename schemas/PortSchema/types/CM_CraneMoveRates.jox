Date		Who		Reason
01 February 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars

begin
	self.ratePerHourSLOD:=_rateSLOD;
	self.ratePerHourSLUD:=_rateSLUD;
	self.ratePerHourTLOD:=_rateTLOD;
	self.ratePerHourTLUD:=_rateTLUD;
	self.ratePerHourOD  :=_rateOD;

epilog

end;</source>
        <Parameter name="_rateSLOD" type="Integer"/>
        <Parameter name="_rateSLUD" type="Integer"/>
        <Parameter name="_rateTLOD" type="Integer"/>
        <Parameter name="_rateTLUD" type="Integer"/>
        <Parameter name="_rateOD" type="Integer"/>
    </JadeMethod>
