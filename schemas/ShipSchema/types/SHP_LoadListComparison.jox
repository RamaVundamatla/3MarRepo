    <JadeMethod name="getFilterDetailsForDisplay" id="38d2882c-2330-45f7-9687-1989ba18dbeb">
        <source>getFilterDetailsForDisplay():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 October 2025	navra1	Initial creation for //navra1 - MTN-36424 - 30th Oct 2025

*/

vars

	returnString : String;
	filter : CM_ColumnFilter;

begin

	returnString := null;

	foreach filter in self.allColumnFilters do
		returnString := returnString &amp; "    " &amp; filter.getFilterDetailsAsString() &amp; CrLf;
	endforeach;
	
	if returnString = null then
	else
		returnString := CrLf &amp; CrLf &amp; returnString;
	endif;
	
	returnString := JadeRegex@replaceFirst(returnString, "","^\s+|\s+$", true);	
	
	if returnString = null then
		returnString:= '-- No Filter Set --';
	endif;

	return returnString;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getIgnoreFields" id="53b08ec4-5ea4-4588-aa57-16c3cd7eeeff">
        <source>getIgnoreFields(_ignoreFields : StringArray input);
//----------------------------------------------------------------
//	Created:	10 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 26 Jun 2012	cnwrs1	Par 31625 DPH Load list changes
// 22 Jun 2-16	cnwdap1	TFS #2191 VGM Fields not being ignored
// 17 Aug 2017	cnwrs1	TFS 4462
// 30 Aug 2017	jlgrs1	TFS 6797 SNO SpecialStow
// 18 Jul 2019	jlgdap1	TFS 45640 SNO Cargo Comparison Discharge
vars
	objSet : ObjectSet;
	obj : Object;
	int : Integer;
begin
	create objSet transient;
	self.mulSelectIgnore.getSelected(objSet);
	foreach obj in objSet do
		int := obj.CM_Association.asInteger;
		if int = 33 then
			_ignoreFields.add(ETRow_Bol);
		elseif int = 3 then
			_ignoreFields.add(ETRow_BookingRef);
		elseif int = 18 then		// 10/02/2009 cnwar2 CCMS1797 (PAR18881)
			_ignoreFields.add(ETRow_CargoType);
		elseif int =  4 then
			_ignoreFields.add(ETRow_Commodity);
		elseif int = 7 then			//ccms 1915 - PAR 22271
			_ignoreFields.add(ETRow_Consignee);
		elseif int = 26 then			//ccms 1915 - PAR 22271
			_ignoreFields.add(ETRow_Consignor);
		elseif int = 17 then
			_ignoreFields.add(ETRow_Oxygen);
			_ignoreFields.add(ETRow_CarbonDioxide);
			_ignoreFields.add(ETRow_CurtainsIn);
		elseif int = 28 then
			_ignoreFields.add(ETRow_SealCustoms);
		elseif int = 5 then
			_ignoreFields.add(ETRow_DestinationPort);
		elseif int = 6 then
			_ignoreFields.add(ETRow_DischargePort);
		elseif int = 27 then	
			_ignoreFields.add(ETRow_FreightForwarder);
		elseif int = 8 then
			_ignoreFields.add(ETRow_Hazardous);
		elseif int = 9 then
			_ignoreFields.add(ETRow_Humidity);
		elseif int = 1 then
			_ignoreFields.add(ETRow_IsoGroup);
		elseif int = 2 then
			_ignoreFields.add(ETRow_IsoType);
		elseif int = 34 then										// TFS #2191
			_ignoreFields.add(ETRow_IsCertifiedWeight);				// TFS #2191
		elseif int = 11 then
			_ignoreFields.add(ETRow_OperatorCode);
		elseif int = 10 then
			_ignoreFields.add(ETRow_OutOfGauge);
		elseif int = 16 then
			_ignoreFields.add(ETRow_SealNum);
		elseif int = 29 then
			_ignoreFields.add(ETRow_SealShipper);
		elseif int = 30 then
			_ignoreFields.add(ETRow_SealNumberVent);		//+cnwml2 MSL CCMS 1017
		elseif int = 31 then
			_ignoreFields.add(ETRow_SealNumTerminalOperator);		//+cnwml2 MSL CCMS 1017
		elseif int = 32 then
			_ignoreFields.add(ETRow_SealNumUnknown);		//+cnwml2 MSL CCMS 1017
		elseif int = 12 then
			_ignoreFields.add(ETRow_Temperature);
		elseif int = 15 then
			_ignoreFields.add(ETRow_TotalWeight);		//+cnwml2 MSL CCMS 1017
		elseif int = 20 then	//cnwrs1 CCMS 1137 08 June 2010
			_ignoreFields.add(ETRow_TranshipVoyage);
		elseif int = 21 then	//cnwrs1 CCMS 1137 08 June 2010
			_ignoreFields.add(ETRow_TranshipDischargePort);
		elseif int = 22 then	//cnwrs1 CCMS 1137 08 June 2010
			_ignoreFields.add(ETRow_TranshipBookingRef);
		elseif int = 23 then	//cnwrs1 CCMS 1137 08 June 2010
			_ignoreFields.add(ETRow_TranshipDischargePort);
			_ignoreFields.add(ETRow_TranshipVoyageCode);
			_ignoreFields.add(ETRow_TranshipBookingRef);
			_ignoreFields.add(ETRow_TranshipBOLId);
			_ignoreFields.add(ETRow_TranshipToPort);
		elseif int = 24 then	//cnwrs1 CCMS 1137 08 June 2010
			_ignoreFields.add(ETRow_TranshipBOLId);
		elseif int = 25 then	//cnwrs1 CCMS 1137 08 June 2010
			_ignoreFields.add(ETRow_TranshipToPort);
		elseif int = 13 then
			_ignoreFields.add(ETRow_Vent);
		elseif int = 19 then	//cnwrs1 CCMS 1137 08 June 2010
			_ignoreFields.add(ETRow_VoyageCode);
		elseif int = 36 then										// TFS #2191
			_ignoreFields.add(ETRow_WeightCertifiedName);			// TFS #2191
		elseif int = 35 then										// TFS #2191
			_ignoreFields.add(ETRow_WeightCertifiedReference);		// TFS #2191
		elseif int = 14 then
			_ignoreFields.add(ETRow_IsWaterCooled);
		elseif int = 37 then		
			//_ignoreFields.add(ETRow_SpecialStow);				// TFS 45640
			_ignoreFields.add(ETRow_SpecialStowage);			// TFS 45640
		//navra1 - CR 64620/Task 64658 - 8th July 2024 - start
		elseif int = 38 then
			_ignoreFields.add(ETRow_ContainerLength);
		elseif int = 39 then
			_ignoreFields.add(ETRow_ContentsStatus);
		endif;
		//navra1 - CR 64620/Task 64658 - 8th July 2024 - end
	endforeach;
end;</source>
        <Parameter name="_ignoreFields" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getIngoreUpdateCodes" id="4105806f-43b0-4769-b1ae-0241d97f14df">
        <source>getIngoreUpdateCodes(_int : Integer; _ignore, _update, _tranship : Boolean) : String;
//
// 28 May 2012	cnwrs1	Par 31625 DPH Load list changes
// 03 May 2016	cnwdap1	TFS #1699 Verified Gross Mass changes
// 17 Aug 2017	cnwrs1	TFS 4462
// 30 Aug 2017	jlgrs1	TFS 6797 SNO SpecialStow
// 18 Jul 2019	jlgdap1	TFS 45640 SNO Cargo Comparison Discharge
//
vars
	str : String;
begin
	if _int = 1 then
		if _ignore then
			str := app.getString(ISO_Group);
		endif;
	elseif _int = 2 then
		if not _tranship then
			str := app.getString(ISO_Type);
		endif;
	elseif _int = 3 then
		if not _tranship then
			str := app.getString(BookingRef);
		endif;
	elseif _int = 4 then
		if not _tranship then
			str := app.getString(Commodity);
		endif;
	elseif _int = 5 then
		if not _tranship then
			str := app.getString(Destination);
		endif;
	elseif _int = 6 then
		if not _tranship then
			str := app.getString(DischargePort);
		endif;
	elseif _int = 7 then
		if not _tranship then
			str := app.getString(Consignee);
		endif;
	elseif _int = 8 then
		if _ignore then
			str := app.getString(Hazards);
		endif;
	elseif _int = 9 then
		if not _tranship then
			str := app.getString(HumidityStr);
		endif;
	elseif _int = 10 then
		if _ignore then
			str := app.getString(Overdimensional);
		endif;
	elseif _int = 11 then
		if not _tranship then
			str := app.getString(Operator);
		endif;
	elseif _int = 12 then
		if not _tranship then
			str := app.getString(Temperature);
		endif;
	elseif _int = 13 then
		if not _tranship then
			str := app.getString(CM_Ventilation);		
		endif;
	elseif _int = 14 then
		if not _tranship then
			str := app.getString(WaterCooled);
		endif;
	elseif _int = 15 then
		if not _tranship then
			str := app.getString(CM_Total_Weight);
		endif;
	elseif _int = 16 then
		if not _tranship then
			str := app.getString(Seal_number);
		endif;
	elseif _int = 17 then
		if not _tranship then
			str := app.getString(ControlledAtmosphere);
		endif;
	elseif _int = 18 then
		if not _tranship then
			str := app.getString(CargoType);
		endif;
	elseif _int = 19 then
		if _update then
			str := app.getString(Voyage);
		endif;
	elseif _int = 20 then
		if _tranship then
			str := app.getString(Outbound_voyage);
		endif;
	elseif _int = 21 then
		if _tranship then
			str := app.getString(Outbound_discharge_port);
		endif;
	elseif _int = 22 then
		if _tranship then
			str := app.getString(Outbound_bookingRef);
		endif;
	elseif _int = 23 then
		if _ignore then
			str := app.getString(Tranship);
		endif;
	elseif _int = 24 then
		if _tranship then
			str := app.getString(Outbound_BOLId);
		endif;
	elseif _int = 25 then
		if _tranship then
			str := app.getString(Outbound_ToPorts);
		endif;
	elseif _int = 26 then
		if not _tranship then
			str := app.getString(CM_Consignor);
		endif;
	elseif _int = 27 then
		if not _tranship then
			str := app.getString(FreightForwarder);
		endif;
	elseif _int = 28 then
		if not _tranship then
			str := app.getString(Custom_seal_number);
		endif;
	elseif _int = 29 then
		if not _tranship then
			str := app.getString(Shippers_seal_number);
		endif;
	elseif _int = 30 then
		if not _tranship then
			str := app.getString(Vent_seal_number);
		endif;
	elseif _int = 31 then
		if not _tranship then
			str := app.getString(Terminal_operator_seal);
		endif;
	elseif _int = 32 then
		if not _tranship then
			str := app.getString(Unknown_seal);
		endif;
	elseif _int = 33 then
		if not _tranship then
			str := app.getString(BillOfLading);
		endif;
	elseif _int = 34 then		
		if self.myTerminal.getConfig(AllowCargoComparisonVGM).Boolean then //tfs 2011
			// TFS #1699
			if not _tranship then										// TFS #1699
				str := app.getString(Is_Certified_Weight);				// TFS #1699
			endif;														// TFS #1699
		endif;
	elseif _int = 35 then											// TFS #1699
		if self.myTerminal.getConfig(AllowCargoComparisonVGM).Boolean then //epr tfs 2011
			if not _tranship then										// TFS #1699
				str := app.getString(Weight_certified_reference);		// TFS #1699
			endif;														// TFS #1699
		endif;
	elseif _int = 36 then		
		if self.myTerminal.getConfig(AllowCargoComparisonVGM).Boolean then //epr tfs 2011// TFS #1699
			if not _tranship then										// TFS #1699
				str := app.getString(Weight_certified_name);			// TFS #1699
			endif;														// TFS #1699
		endif;
	elseif _int = 37 then		
		if not _tranship then
			//str := app.getString(SpecialStow);			// TFS 45640
			str := app.getString(Special_stowage);			// TFS 45640
		endif;
	//navra1 - CR 64620/Task 64658 - 8th July 2024 - start
	elseif _int = 38 then		
		if _ignore then									//contents status can only be ignored, it cant be updated - according to NSW-BRD 63185
			str := app.getString(Container_length);
		endif;
	elseif _int = 39 then		
		if _ignore then									//contents status can only be ignored, it cant be updated - according to NSW-BRD 63185
			str := app.getString(Contents_statuses);
		endif;
	//navra1 - CR 64620/Task 64658 - 8th July 2024 - end
	endif;
	return str;
end;
</source>
        <Parameter name="_int" type="Integer"/>
        <Parameter name="_ignore" type="Boolean"/>
        <Parameter name="_update" type="Boolean"/>
        <Parameter name="_tranship" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getOperators" id="e7ee5307-3a5d-47a6-bb50-9cf06bc77e1e">
        <source>getOperators(_ops : CM_OperatorSet input);
//----------------------------------------------------------------
//	Created:	02 December 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	if self.lstTblOperator.allSelectedObjects.isEmpty then
		app.myRoot.allOperators.copy(_ops);	
	else
		self.lstTblOperator.allSelectedObjects.copy(_ops);	
	endif;
end;</source>
        <Parameter name="_ops" type="CM_OperatorSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getRefManifestReport" id="1404c0ee-c5ca-491a-8ac9-7a567c9f4df5">
        <source>getRefManifestReport(_rptName : String) : CM_QryReport protected;
//----------------------------------------------------------------
//	Created:	05 November 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------

vars
	menuItemDict				: CM_MenuItemByTypeMenuIdDict;
	menuItem					: CM_MenuItem;
	qryReport					: CM_QryReport;
begin
	menuItemDict := app.myRoot.myReportMenuRoot.allMenuItems;
	
	foreach menuItem in menuItemDict do
		if not menuItem.isKindOf(CM_QryReport) then
			continue;
		endif;
		
		if menuItem.CM_QryReport.reportName = _rptName then
			qryReport := menuItem.CM_QryReport;
			break;
		endif;
	endforeach;
	
	return qryReport;	
end;</source>
        <access>protected</access>
        <Parameter name="_rptName" type="String"/>
        <ReturnType type="CM_QryReport"/>
    </JadeMethod>
    <JadeMethod name="getTIDisplayString" id="6848fd87-b95b-43f3-9308-36b000e9bf15">
        <source>getTIDisplayString(_ti: CM_TrackedItem; _entTblRows: StringArray):String;
//----------------------------------------------------------------
//	Created:	23 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
// 30 Apr 2019	jlgrs1	TFS40086 JMT Not all EDI TrackedItem stringArray are exposed to the EDI JMT Internal
//
vars
	entRow		: String;
	strReturn	: String;
	text		: String;
begin
	
	strReturn := '';
	foreach entRow in _entTblRows do
	
		if strReturn &lt;&gt; '' then
			strReturn := strReturn &amp; Tab;
		endif;

		if entRow = ETRow_Id then
			strReturn := strReturn &amp; _ti.id;
		else
			if entRow = ETRow_YardLocation then
				strReturn := strReturn &amp; _ti.getDisplayStringForAttribute(ETRow_Location, false);
			elseif entRow = ETRow_Vent and
			   _ti.isKindOf(CM_Container) then
				strReturn := strReturn &amp; _ti.getDisplayStringForAttribute(ETRow_Ventilation, false);
			elseif entRow = ETRow_CurtainsIn and
				_ti.isKindOf(CM_Container) and _ti.CM_Container.getCurtainsIn then
			elseif entRow = ETRow_SpecialStowage then
				strReturn := strReturn &amp; _ti.getDisplayStringForAttribute(ETRow_SpecialStow, false);
			elseif entRow = ETRow_SealUnknown then
				strReturn := strReturn &amp; _ti.getDisplayStringForAttribute(ETRow_SealNumUnknown, false);
			elseif entRow = ETRow_SealTerminalOperator then
				strReturn := strReturn &amp; _ti.getDisplayStringForAttribute(ETRow_SealNumTerminalOperator, false);
			else
				strReturn := strReturn &amp; _ti.getDisplayStringForAttribute(entRow, false);
			endif;
		endif;

	endforeach;
	
epilog
	return strReturn;	
	
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_entTblRows" type="StringArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTableColumFilters" id="61764832-12c2-4bf3-9203-4620b0c1404e">
        <updating/>
        <source>getTableColumFilters(_table: Table; _allFilterColumns: CM_ColumnFilterDict io) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 September 2025	navra1	Initial creation for //navra1 - MTN-36126 - 24th Sep 2025

*/

vars

begin
	if self.allColumnFilters = null then
		create self.allColumnFilters transient;  // this is a non exclusive collection.
	endif;
	
	if self.allColumnFilters.isEmpty then
		return;
	endif;
	
	self.allColumnFilters.cloneFiltersForTable( _table, _allFilterColumns );

	//navra1 - MTN-36424 - 30th Oct 2025
	self.txtFilters.text := self.getFilterDetailsForDisplay();
	
epilog

end;</source>
        <Parameter name="_table" type="Table"/>
        <Parameter name="_allFilterColumns" type="CM_ColumnFilterDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getTranshipFields" id="97f59d82-a494-4ed4-8521-8fec27a669c1">
        <source>getTranshipFields(_transhipFields : StringArray input);
//----------------------------------------------------------------
//	Created:	//cnwrs1 CCMS 1137 15 June 2010
//----------------------------------------------------------------
vars
	objSet : ObjectSet;
	obj : Object;
	int : Integer;
begin
	create objSet transient;
	self.mulSelTranship.getSelected(objSet);
	foreach obj in objSet do
		int := obj.CM_Association.asInteger;
		if int =  4 then
			_transhipFields.add(ETRow_Commodity);
		elseif int = 1 then
			_transhipFields.add(ETRow_IsoGroup);
		elseif int = 2 then
			_transhipFields.add(ETRow_IsoType);
		elseif int = 14 then
			_transhipFields.add(ETRow_IsWaterCooled);
		elseif int = 15 then
			//_transhipFields.add(ETRow_Weight);			//-cnwml2 MSL CCMS 1017
			_transhipFields.add(ETRow_TotalWeight);		//+cnwml2 MSL CCMS 1017
		elseif int = 16 then
			_transhipFields.add(ETRow_SealNum);
		//th2 CCMS 1548 - adding all updatable as ignorable
		elseif int = 3 then
			_transhipFields.add(ETRow_BookingRef);
		elseif int = 12 then
			_transhipFields.add(ETRow_Temperature);
		elseif int = 6 then
			_transhipFields.add(ETRow_DischargePort);
		elseif int = 7 then			//ccms 1915 - PAR 22271
			_transhipFields.add(ETRow_Consignee);
		elseif int = 5 then
			_transhipFields.add(ETRow_DestinationPort);
		elseif int = 11 then
			_transhipFields.add(ETRow_OperatorCode);
		elseif int = 10 then
			_transhipFields.add(ETRow_OutOfGauge);
		elseif int = 8 then
			_transhipFields.add(ETRow_Hazardous);
		elseif int = 13 then
			_transhipFields.add(ETRow_Vent);
		elseif int = 9 then		//JMT1550 - adding Humidity
			_transhipFields.add(ETRow_Humidity);
		elseif int = 17 then
			_transhipFields.add(ETRow_ControlledAtmosphere);
		elseif int = 18 then		// 10/02/2009 cnwar2 CCMS1797 (PAR18881)
			_transhipFields.add(ETRow_CargoType);
		elseif int = 19 then	//cnwrs1 CCMS 1137 08 June 2010
			_transhipFields.add(ETRow_VoyageCode);
		elseif int = 20 then	//cnwrs1 CCMS 1137 08 June 2010
			_transhipFields.add(ETRow_TranshipVoyage);
		elseif int = 21 then	//cnwrs1 CCMS 1137 08 June 2010
			_transhipFields.add(ETRow_TranshipDischargePort);
		elseif int = 22 then	//cnwrs1 CCMS 1137 08 June 2010
			_transhipFields.add(ETRow_TranshipBookingRef);
		elseif int = 23 then	//cnwrs1 CCMS 1137 08 June 2010
			_transhipFields.add(ETRow_Tranship);
		elseif int = 24 then	//cnwrs1 CCMS 1137 08 June 2010
			_transhipFields.add(ETRow_TranshipBOLId);
		elseif int = 25 then	//cnwrs1 CCMS 1137 08 June 2010
			_transhipFields.add(ETRow_TranshipToPort);
		endif;
	endforeach;
end;</source>
        <Parameter name="_transhipFields" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getUpdateFields" id="e298e4f2-5d61-437b-9805-3f217c725d31">
        <source>getUpdateFields(_updateFields : StringArray input);
//----------------------------------------------------------------
//	Created:	//cnwrs1 CCMS 1137 15 June 2010
//----------------------------------------------------------------
// 20 Jun 2012	cnwrs1	Par 31625 DPH Load list changes
// 03 May 2016	cnwdap1	TFS #1699 Verified Gross Mass changes
// 17 Aug 2017	cnwrs1	TFS 4462
