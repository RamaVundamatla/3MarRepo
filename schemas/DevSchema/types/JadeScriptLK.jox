<Class name="JadeScriptLK" id="4fc66051-b8f3-42ab-951c-a2beb3580978">
    <superclass name="JadeScript"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
