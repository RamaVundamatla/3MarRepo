    <JadeMethod name="imexStatusString" id="f1aec5df-a53c-428f-9b22-c58d9e1fba72">
        <methodInvocation>mapping</methodInvocation>
        <source>imexStatusString(set: Boolean; _value: String io) mapping;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 19/05/2010	cnwdap1		CCMS SFW 1116 Tranship changes
vars

begin
	if set then
		return ;
	else
		if self.imexStatus = TI_IMEX_STATUS_IMPORT  then
			_value :=  "Import";
		elseif self.imexStatus = TI_IMEX_STATUS_EXPORT  then
			_value :=  "Export";
		elseif self.imexStatus = TI_IMEX_STATUS_STORAGE  then
			_value :=  "Storage";
		elseif self.imexStatus = TI_TransitStatusDLR  then
			_value :=  "Double Lift Restow";
		elseif self.imexStatus = TI_TransitStatusSOB  then
			//_value :=  "Shift on Board";
			_value :=  "Shift On Board";	//03 Oct 2017	NDL	TFS 7055
		elseif self.imexStatus = TI_IMEX_STATUS_REMAINONBOARD  then
			//_value :=  "Transit";									// PAR #23645 CCMS 1116
			_value :=  "Remain On Board";							// PAR #23645 CCMS 1116
		elseif self.imexStatus = TI_IMEX_STATUS_TRANSHIP  then		// PAR #23645 CCMS 1116
			_value :=  "Tranship";									// PAR #23645 CCMS 1116
		else
			_value :=  "(Default)";
		endif;
	
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="initialise" id="ab858d7d-01b8-41ba-b676-8966f2e17c39">
        <updating/>
        <source>initialise(_bank : CM_Bank) updating;

vars
	csn : CM_ContentsMap;

begin

	//initalise the serviceBroker Map
	csn := contentsMaps[TI_CONTENTS_STATUS_NULL];
	if csn = null then
		create csn;
		csn.contentsType := TI_CONTENTS_STATUS_NULL;
		csn.imexMap := self;
	endif;
	csn.initialise(_bank);

end;</source>
        <Parameter name="_bank" type="CM_Bank"/>
    </JadeMethod>
