    <JadeMethod name="addToPassport" id="7430dc7b-68c7-4652-b727-b576d7d37e1a">
        <updating/>
        <source>addToPassport(_passport : CM_Passport) updating;
// ---------------------------------------------------------------------------
// Created:     20 May 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if self.warningOnly then
		self.myWarningPassport := _passport;
	else
		self.myErrorPassport := _passport;
	endif;

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="create" id="e5bf58a5-bfb9-40aa-b996-37d7678993ae">
