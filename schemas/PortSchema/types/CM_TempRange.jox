    <JadeMethod name="cnEcGetDuplicate" id="6e69f284-55e5-4408-a3ed-730fae688d6c">
        <source>cnEcGetDuplicate(pFormat: CnEcXmlFormat; pInput: CnEcXmlStructureInstance): Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 September 2014	cnwndl1	Initial creation	Par 34893

*/

vars

	value : Real;
	temp : CM_TempRange;

begin

	value := self.cnEcXMLGetTheAttributeValue( pFormat, pInput, self.class.name, "value" ).Real; 
	
	temp := app.myRoot.allTempRanges.getAtKey( value );

epilog

	return temp;

end;</source>
        <Parameter name="pFormat" type="CnEcXmlFormat"/>
        <Parameter name="pInput" type="CnEcXmlStructureInstance"/>
        <ReturnType type="Object"/>
    </JadeMethod>
