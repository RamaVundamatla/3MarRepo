/*

Date		Who		Reason
22 Jan 2020	cnwkpd1	PAR #22185 - Fix up timestamp logging
					Method rewritten to use JADE method for performance and correctness
*/

vars
	
begin
	return self.padLeadingWith("0", digits);
	
end;</source>
        <Parameter name="digits" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="toGantryInterchangePosString" id="c4eae484-441d-4c87-b49b-38e52f1206b8">
        <source>toGantryInterchangePosString(): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 July 2009	cnwer1	Initial creation

*/

vars

begin
	if self =  CM_RTGArea.ICPosition_AfterLastBay then
		return app.getErrorString(After_Last_Bay);
	elseif self = CM_RTGArea.ICPosition_AfterLastRow then
		return app.getErrorString(After_Last_Row);
	elseif self = CM_RTGArea.ICPosition_BeforeBay1 then
		return app.getErrorString(Before_First_Bay);
	elseif self = CM_RTGArea.ICPosition_BeforeRow1 then
		return app.getErrorString(Before_First_Row);
	elseif self = CM_RTGArea.ICPosition_BothEnds or  self = CM_RTGArea.ICPosition_BothSides then
		return app.getErrorString(Both);
	elseif self = CM_RTGArea.ICPosition_NoEnds or self = CM_RTGArea.ICPosition_NoSides then
		return app.getErrorString(None);
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
