    <JadeMethod name="getFontSizeLabel" id="89c2abf3-6bae-479b-a3f0-d798c34f3d41">
        <source>getFontSizeLabel() :Integer;
//17 February 2009	cnwwc2	Initial creation

vars
	font: Integer;
	sf : Real;
begin
	font := 8;
	sf := self.scaleFactor * 2;	
	if sf = 0.75 then
		font := 6;
	elseif sf = 1 then
		font := 8;	
	elseif sf = 1.5 then
		font := 9;	
	elseif sf = 2 then
		font := 10;	
	elseif sf = 3 then
		font := 12;	
	elseif sf = 4 then
		font := 14;	
	endif;
	
	return font;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getFontSizeRowColHeading" id="0a408ac5-faef-4f43-a6cb-c661628dbbe0">
        <source>getFontSizeRowColHeading() :Integer;
//17 February 2009	cnwwc2	Initial creation

vars
	sf : Real;
	font: Integer;
begin
	font := 6;
	sf := self.scaleFactor * 2;
	if sf = 0.75 then
		font := 6;
	elseif sf = 1 then
		font := 6;	
	elseif sf = 1.5 then
		font := 7;	
	elseif sf = 2 then
		font := 8;	
	elseif sf = 3 then
		font := 8;	
	elseif sf = 4 then
		font := 10;	
	endif;
	
	return font;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
