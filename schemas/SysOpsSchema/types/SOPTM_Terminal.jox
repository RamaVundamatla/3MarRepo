    <JadeMethod name="doMnuContextAddClick" id="80434ac3-2008-45d0-861a-893acc0e8836">
        <updating/>
        <source>doMnuContextAddClick(theMenuItem: MenuItem) updating;
//26 August 2010	cnwml2
//+cnwml2 PAR23715 SFW CCMS1131

vars

	form : SOP_OperatorSealCheck;
	operator : CM_Operator;
	operation : String;
	receival : String;
	release : String;
begin
	form := app.loadForm(SOP_OperatorSealCheck, 
							CMUI_Assistant, 
							false, 
							false,
							false, 
							self.myForm.myTerminal,
							null).SOP_OperatorSealCheck;	


	form.showModal();
	
	if form.modalResult = ModalResultOK then
		//add item to the table
		operator := form.cmbOperator.listObject.CM_Operator;
		operation := form.cmbOperation.text;
		receival := form.cmbReceival.text;
		release := form.cmbRelease.text;
		
		self.myForm.tblFldSheet2.addItem(operator.code &amp; Tab &amp; operation &amp; Tab &amp; receival &amp; Tab &amp; release);
	endif;	
	
	
epilog

end;</source>
        <Parameter name="theMenuItem" type="MenuItem"/>
    </JadeMethod>
