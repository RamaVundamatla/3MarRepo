    <JadeMethod name="tblObjects_change" id="1e1f9b3e-6d1e-4cc3-ac2e-af3bf96e0f76">
        <controlMethod name="Table::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblObjects_change(table: Table input) updating;
// --------------------------------------------------------------------------------
// Created:		21 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if (not btnOk.enabled) then
		btnOk.enabled	:=	true;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblObjects_click" id="325965c4-4385-4c61-b9fc-a07204c18bd4">
        <controlMethod name="Table::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblObjects_click(table: Table input) updating;
// --------------------------------------------------------------------------------
// Created:		21 January 1999 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if (tblObjects.row &gt; 1) and (tblObjects.row &lt;= tblObjects.rows) then
		btnDelete.enabled	:=	true;
		btnInsert.enabled	:=	true;
	else
		btnDelete.enabled	:=	false;
		btnInsert.enabled	:=	false;
		tblObjects.clearAllSelected;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
</GUIClass>
