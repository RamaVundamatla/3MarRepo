        <source>create() updating;
// ---------------------------------------------------------------------------
// Created:     05 December 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin

	if (not self.isTransient) then
		self.createMenuRootForSysEntities();
		self.createMenuRootReportsCurrent();
		self.createMenuRootReportsSaved();
		self.createMenuRootReportsTemplate();
		self.createMenuRootToolbar();
		
		self.setAcknowledgeTodoStop(true);
		self.setPartialTextIndication(true);
		
		self.setUseAppSkins("JMTMetro2013");		//cnwmc5 - 24 Oct 2013 - PAR 32860
	endif;
	
end;</source>
