    <JadeMethod name="trxUpdateWagonDamageInstance" id="8c277889-2288-4313-8677-2eac2ee8ddd7">
        <updating/>
        <source>trxUpdateWagonDamageInstance(_wagon : CM_Wagon; _pxyDamageInstance : CM_DamageInstance; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2022	jlier1	Initial creation 53971

*/

vars
	newDamage : CM_DamageInstance;
begin
// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	_pxyDamageInstance.validateForUpdate();
	
	if app.myPassport.hasErrors then
		return;
	endif;
	// Start the transaction
	beginTransaction;

	// Perform the operation
	
	newDamage:=_pxyDamageInstance.pxyGetRealObject;
	
	newDamage.setForUpdateSubject(_pxyDamageInstance,_wagon);
	
	if app.myPassport.hasErrors then
		return;
	endif;
	_wagon.createTransaction(null,EVT_WagonDamaged, newDamage, null, null, _wagon.myTrainInwards &lt;&gt; null, null, null, null);
	
epilog
	self.finaliseActivityWithPassport(_passport);

end;</source>
