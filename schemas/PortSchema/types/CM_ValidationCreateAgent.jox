    <JadeMethod name="valAddFile" id="681ed82d-a899-457f-82be-ad4740217e39">
        <source>valAddFile(_masterObj : Object; _fileName : String; _file : File input);
// ---------------------------------------------------------------------------
// Created:     12 January 2007 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
vars
	invalid : Boolean;
begin

	on Exception do self.valAddFileHandleException(exception, invalid); // ### TFS DEFECT 56155 13JAN2023 NAVAB1
	
	if _masterObj = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_masterObj', null, null);
	endif;

	if _file = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_file', null, null);
	endif;

	if _fileName = null then
		app.raiseCMException(Please_enter_filename, null, null);
	endif;
	
	_file.fileName := _fileName;
	_file.createdTime:=app.actualTimeServer;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	if invalid then // ### TFS DEFECT 56155 13JAN2023 NAVAB1
		app.raiseCMException(Please_enter_filename, null, null); // ### TFS DEFECT 56155 13JAN2023 NAVAB1
	endif;
	
	_file.mode := File.Mode_Input;
	_file.kind	:= File.Kind_Binary;
	if (not _file.isAvailable) then
		app.raiseCMException1(File_available, _fileName,null, null); // ### TFS DEFECT 56155 13JAN2023 NAVAB1 added file name
	endif;

end;</source>
        <Parameter name="_masterObj" type="Object"/>
        <Parameter name="_fileName" type="String"/>
        <Parameter name="_file" type="File" usage="input"/>
    </JadeMethod>
    <JadeMethod name="valAddFileHandleException" id="a9b6f07e-4c8b-405a-92dd-e3c670c75e31">
        <source>valAddFileHandleException(_exObj : Exception; _wasFileRelated : Boolean output ) : Integer;
/*
Purpose:			

Date		Who		Reason
13 January 2023	navab1	TFS DEFECT 56155
*/

vars

	returnVal : Integer;

begin
	
	returnVal := Ex_Pass_Back;
	
	if _exObj.errorCode = 5003 
	or _exObj.errorCode = 5028 then
		_wasFileRelated := true;
		if _exObj.resumable then
			returnVal := Ex_Resume_Next;
		endif;
	endif;
	
	return returnVal;

epilog

end;</source>
        <Parameter name="_exObj" type="Exception"/>
        <Parameter name="_wasFileRelated" type="Boolean" usage="output"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="valAdhocCamsRequest" id="caeb6539-8ed6-4bde-8094-026d8adfdf56">
        <source>valAdhocCamsRequest(_camProtocol:  CM_CamProtocol; _startDate, _endDate:  TimeStamp);
// ---------------------------------------------------------------------------
// Created:		23 May 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------
// 13/02/2013	cnwcs5	CCMS SFW 1294 /par 30855 - check CAMS timstamp upgrade

vars
	earliestDate	: Date;
	agent			: CM_CamControllerAgent;
begin
	//other date/time validation done in interface e.g. start &lt; end etc.
	if not _startDate.isValid then
		app.raiseCMException1(ERR_INVALID_TIMESTAMP, null,  null, null);
	endif;
	
	if not _endDate.isValid then
		app.raiseCMException(ERR_INVALID_TIMESTAMP, null, null);
	endif;
	
	if _camProtocol = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Protocol was null for Cams Request.');
	endif;

	// par 30855 - check we have done the necessary CAMS timestamp upgrades for 8.2.1
	create agent transient;
	
	agent.setMyTerminal (_camProtocol.terminal);
	
	earliestDate	:= agent.getEarliestCAMSRunDate;		
	
	if _startDate.Date &lt; earliestDate or _endDate.Date &lt; earliestDate then
		app.raiseCMException2 (CAMS_Timestamp_Upgrade_Error, _camProtocol.code, earliestDate.asStringJMT, null, null);
	endif;
epilog
	delete agent;
end;</source>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_startDate" type="TimeStamp"/>
        <Parameter name="_endDate" type="TimeStamp"/>
    </JadeMethod>
