    <JadeMethod name="setMyCurrent" id="3b30519f-6d91-475d-9e88-1af37e7af286">
        <updating/>
        <source>setMyCurrent(form: INV_TransactionMap io) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(form);

	if self.myTranMapCargo &lt;&gt; null then // TRACKED ITEM
		
		form.myTMCTrans := self;
		form.myCurrentMapTM := self.myTranMapCargo;
	elseif self.myTranMapVTMIS &lt;&gt; null then // VOYAGE
		form.myTMCTrans := self;
		form.myCurrentMapTMVoyage := self.myTranMapVTMIS;
	elseif self.myTranMapEvent &lt;&gt; null then // EVENT
		form.myTMCTrans := self;
		form.myCurrentMapTMEvent := self.myTranMapEvent;
		
	//31 Oct 2019	NDL	TFS 47100
	elseif self.myTranMapBOL &lt;&gt; null then
		form.myTMCTrans := self;
		form.myCurrentMapTMBOL := self.myTranMapBOL;
		
	elseif self.myTranMapWO &lt;&gt; null then // WORK ORDER
		form.myTMCTrans := self; // TFS 39236
		form.myCurrentMapTMWorkOrder := self.myTranMapWO; // TFS 39236
	elseif self.myTranMapSSSummary &lt;&gt; null then
		form.myTMCTrans := self;
		form.myCurrentMapTMSS := self.myTranMapSSSummary;
	elseif self.myCurrentMapTMCargoAllocation &lt;&gt; null then // PAR 35833
		form.myTMCTrans := self;
		form.myCurrentMapTMCargoAllocation := self.myCurrentMapTMCargoAllocation;
	elseif self.myTranMapInventory &lt;&gt; null then  // ### TFS 51219 25MAY2021 NAVAB1
		form.myTMCTrans := self;
		form.myCurrentMapTMInventory := self.myTranMapInventory;
	
	endif;
end;</source>
        <Parameter name="form" type="INV_TransactionMap" usage="io"/>
    </JadeMethod>
</Class>
