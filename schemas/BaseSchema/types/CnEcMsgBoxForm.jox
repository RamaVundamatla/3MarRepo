    <Constant name="MSG_BOX_CLOSE" id="09091133-dfd9-4d9a-8e21-e41c700bd41c">
        <source>1</source>
        <type name="Integer"/>
    </Constant>
    <PrimAttribute name="aCloseSeconds" id="76061ef5-5d20-4c7b-a75d-48dfa725f206">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="aDialogMessage" id="16c2901d-2639-4383-bb90-c300cfef0405">
        <type name="String"/>
    </PrimAttribute>
    <ImplicitInverseRef name="btnOK" id="11022a29-34fd-44ae-89e1-560b4e0809eb">
        <embedded/>
        <type name="Button"/>
    </ImplicitInverseRef>
    <ImplicitInverseRef name="lblMsg" id="94f968c8-3feb-42d5-b63b-746130b074a2">
        <embedded/>
        <type name="Label"/>
    </ImplicitInverseRef>
    <JadeMethod name="btnOK_click" id="2619de29-f0a3-4834-8a33-d403246f33de">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnOK_click(btn: Button input) updating;
// --------------------------------------------------------------------------------
// Created:		25 January 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.doBtnOK();
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="cancelTimer" id="cea29605-25cb-4200-831f-3eef8f589b34">
        <source>cancelTimer();

vars
	timerOption		: Integer;
	timeRemaining	: Integer;

begin
	if getTimerStatus(self.MSG_BOX_CLOSE, timerOption, timeRemaining) then
		endTimer(self.MSG_BOX_CLOSE);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doAdjustLabelSize" id="fe8d0008-dcc4-4fba-a7ec-0cdfa2e89da6">
        <source>doAdjustLabelSize() protected;

vars
	characters : Integer;
begin
	characters := lblMsg.caption.length;
	 
	if characters &gt; 100 then 
		lblMsg.width := 500;
	elseif characters &gt; 60 then 
		lblMsg.width := 400;
	elseif  characters &gt; 30 then 
		lblMsg.width := 200;
	else
		lblMsg.width := 100;
	endif;			
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doBtnOK" id="2ca7e409-dc1b-454c-adf4-45985f76dc49">
        <updating/>
        <source>doBtnOK() updating, protected;

begin
	self.unloadForm();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="load" id="e097be18-40e5-4ff7-b17f-772a2cc39a56">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

begin
	inheritMethod();
	self.loadForm();
end;</source>
    </JadeMethod>
    <JadeMethod name="loadForm" id="19d33c3e-4df7-47bb-9d6f-a2871fcb9d79">
        <updating/>
        <source>loadForm() updating, protected;

begin
	if self.aDialogMessage[1:255].pos(" ", 1) = 0 then
		lblMsg.caption := self.aDialogMessage[1:255];
	else		
		lblMsg.caption := self.aDialogMessage[1:1024];
	endif;
	
	self.doAdjustLabelSize();

	self.height := lblMsg.top + lblMsg.height + 75;
	self.width	:= lblMsg.width + 15;

	if self.height &lt; 80 then
		self.height := 80;
	endif;

	btnOK.top	:= self.height - 60;
	btnOK.left 	:= (self.width / 2) - 50;

	self.centreWindow();

	beginTimer(self.aCloseSeconds * 1000, Timer_OneShot, self.MSG_BOX_CLOSE);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="43eecb64-ee03-4d0f-84f1-c928f6bf5cf0">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;

begin
	if eventTag = self.MSG_BOX_CLOSE then
		self.doBtnOK();
	endif;
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="unload" id="c5155e29-48b7-4d83-9ba5-d31e8c010414">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

begin
	self.cancelTimer();
end;</source>
    </JadeMethod>
</GUIClass>
