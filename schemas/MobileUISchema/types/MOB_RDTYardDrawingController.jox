    <JadeMethod name="convertStringForWidth" id="d5ed75ab-513f-4b8d-9ecb-9ce748e944e7">
        <source>convertStringForWidth(_width : Integer; _frame : Frame; _text : String) : String protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 April 2010	cnwjk3	Initial creation

 Add CRs to a string so that it will fit in the given width when drawn

*/

vars
	currentWidth	: Real;
	count 			: Integer;
	newText			: String;
begin
	foreach count in 1 to _text.length do
		newText := newText &amp; _text[count];
		currentWidth := currentWidth + _frame.drawTextWidth(_text[count]);
		
		if _text[count] = Cr then
			currentWidth := 0;
		endif;
			
		if currentWidth &gt;= _width then
			currentWidth := 0;
			newText := newText &amp; Cr;
		endif;
	endforeach;
	
	return newText;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_width" type="Integer"/>
        <Parameter name="_frame" type="Frame"/>
        <Parameter name="_text" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
