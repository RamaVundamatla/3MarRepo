    </JadeMethod>
    <JadeMethod name="doNotesCrane" id="b54b75fb-5698-4b94-983d-d7e080bc518f">
        <updating/>
        <source>doNotesCrane(_workPoint : CM_Object) updating;
// ---------------------------------------------------------------------------
// Created:		08 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	idx : Integer;
	aJS : CM_VoyageJobSheet;
	aTS : TimeStamp;
	str : String;
	workPointInterface : IF_VoyageWorkPoint;
begin
	
	if not _workPoint.respondsTo(IF_VoyageWorkPoint) then
		return;
	endif;
	workPointInterface:=_workPoint.IF_VoyageWorkPoint;
	//10 Aug 2009	NDL Rework for CCMS 1031 par 20474
	if self.tblCranes.findObjectInRow(_workPoint, idx) then
		aJS := self.myCurrentVoyage.allJobSheets[workPointInterface.getID];
		aTS := aJS.workStarted;
		if _workPoint.isKindOf(CM_WorkPoint) and _workPoint.CM_WorkPoint.hasDefinedCargoRates then	//08 Mar 2017	NDL	TFS 37437
			self.tblCranes.accessCell(idx,self.Column_Crane_CPH).text :=  _workPoint.CM_WorkPoint.getDefinedTargetRateWeight( aJS ).asStringJMT;
		else
			self.tblCranes.accessCell(idx,self.Column_Crane_CPH).text := workPointInterface.getTargetRatePH.asStringJMT;
		endif;
		self.tblCranes.accessCell(idx,self.Column_Crane_Date).text := aTS.date.shortFormatJMT();
		self.tblCranes.accessCell(idx,self.Column_Crane_Time).text := aTS.time.Time.shortFormatJMT();
		self.tblCranes.accessCell(idx,self.Column_Crane_Seed).text := workPointInterface.getJobSeed.asStringJMT; 
		self.tblCranes.accessCell(idx,self.Column_Crane_Rev).text := aJS.getCraneDirString(); 
	endif;
	
	if self.tblData.findObjectInRow(_workPoint, idx) then

		aJS := self.myCurrentVoyage.allJobSheets[workPointInterface.getID];
		if aJS &lt;&gt; null then
			str := aJS.getOOWInfoLine(0);
			self.tblData.accessCell(idx,1).text := str;
		endif;
	endif; 
end;</source>
        <Parameter name="_workPoint" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="doPrint" id="29663608-2e71-4a3b-b3e5-6f4cc3a3bc70">
        <updating/>
        <source>doPrint() updating;
// ---------------------------------------------------------------------------
// Created:		02 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aJS : CM_VoyageJobSheet;
	workPoint : CM_Object;
	aCrane : CM_Crane;
	idx : Integer;
	str : String;
	showLOLO : Boolean;
	showRORO : Boolean;
begin

	if not doCheckVoyage(false) then	// before searching there is null voyage	- cnwvu1
		return;
	endif;
	
	// ### Too much info on crane line, so just put ID, then put back after
	foreach aJS in self.myCurrentVoyage.allJobSheets do
		workPoint:= aJS.getMyWorkPointObject;
		idx := 0;
		if self.tblData.findObjectInRow(workPoint, idx) then
			str := workPoint.IF_VoyageWorkPoint.getTypeDescription &amp; " " &amp; workPoint.IF_VoyageWorkPoint.getID;
			self.tblData.accessCell(idx,1).text := str;
			showLOLO := true;	//05 Nov 2014	NDL	Par 35032
		elseif self.tblRORO.findObjectInRow(workPoint, idx) then	//05 Nov 2014	NDL	Par 35032
			str := workPoint.IF_VoyageWorkPoint.getTypeDescription &amp; " " &amp; workPoint.IF_VoyageWorkPoint.getID;
			self.tblRORO.accessCell(idx,1).text := str;
			showRORO := true;	//05 Nov 2014	NDL	Par 35032
		endif;
	endforeach;

	if showLOLO then	//05 Nov 2014	NDL	Par 35032
		self.doPrintOutTable(self.tblData,self.caption, true,false, true, false);
	endif;
	//05 Nov 2014	NDL	Par 35032
	if showRORO then
		self.doPrintOutTable(self.tblRORO,self.caption, true,false, true, false);
	endif;
	
	idx := 0;
	foreach aJS in self.myCurrentVoyage.allJobSheets do
		workPoint:= aJS.getMyWorkPointObject;
		if self.tblData.findObjectInRow(workPoint, idx) then
			str := aJS.getOOWInfoLine(0);
			self.tblData.accessCell(idx,1).text := str;
		elseif self.tblRORO.findObjectInRow(workPoint, idx) then	//05 Nov 2014	NDL	Par 35032
			str := aJS.getOOWInfoLine(0);
			self.tblRORO.accessCell(idx,1).text := str;
		endif;
	endforeach;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="425b554d-ee5e-40dc-af8c-c517e666ff6f">
        <updating/>
        <source>doQuery() updating;
// ---------------------------------------------------------------------------
// Created:		21 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	
	tmpStr                  : String;
	processStackArray       : ProcessStackArray;
	methodCallDesc          : MethodCallDesc;
begin
	if not self.doCheckVoyage(true) then
		return;
	endif;
	app.mousePointer := Window.MousePointer_HourGlass;
	// PAR 21787
	create processStackArray transient;
	process.currentStack(processStackArray);

	if processStackArray.size &gt; 2 then
		methodCallDesc := processStackArray[3];
		tmpStr := methodCallDesc.method.qualifiedName;
	else
		tmpStr := method.qualifiedName;
	endif;
	
	self.cnStartTransaction(tmpStr[1:50]);


	self.tblData.rows := self.tblData.fixedRows;
	self.tblRORO.rows:=self.tblRORO.fixedRows;

	// ### CRANES
	self.doQueryCranesDisplay();

	
	// ### BAYS
	if self.myCurrentVoyage.myCellularVoyageStructure.allOOWCreations.isEmpty then
		self.doQueryBaysCreate();
	endif;	
	self.doQueryBaysShow();

	
	if self.myCurrentVoyage.myROROStructure &lt;&gt; null then
	
		self.shtDeckJobs.visible:=true;
		if self.myCurrentVoyage.myROROStructure.allOOWCreations.isEmpty then
			self.doQueryDecksCreate();
		endif;
		self.doQueryDecksShow();
	else
		self.shtDeckJobs.visible:=false;
	endif;
	

	self.doQueryCranesPosition();

	self.doQueryBayTotals();

	self.doQueryDeckTotals();

epilog
	// PAR 21787
	if processStackArray &lt;&gt; null then
		processStackArray.purge;
		delete processStackArray;
	endif;
	if tmpStr &lt;&gt; null then
		self.cnEndTransaction();
	endif;
	app.mousePointer := Window.MousePointer_Default;

end;</source>
    </JadeMethod>
    <JadeMethod name="doQueryBayTotals" id="81267bc0-c3c0-416b-87c3-453e4fab22f0">
        <source>doQueryBayTotals() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	idx,st,en, tot, totcr, amt, totRow, totCol : Integer;
	totLifts : Real;
	theTable : CM_DataTable;
	totals : IntegerArray;
	tmpObj : Object;
	oowc : CM_OOWCreation;
	bayTotalCol,
	craneTotalCol,
	disch20Col,
	reef20Col,
	reef40Col,
	runTotalLifts,
	runTotFwdAft,
	runTotAftFwd: Integer;
	
begin
	theTable:=self.tblData;
	// ### RUNNING TOTALS
	st := theTable.fixedRows + 1;
	en := theTable.rows;
	totRow := theTable.addItem("Totals");
	theTable.accessRow(totRow).backColor := Black;
	theTable.accessRow(totRow).foreColor := White;
	theTable.getEntRowColumnByRowName(ETRow_DeckTotal, bayTotalCol);
	theTable.getEntRowColumnByRowName(ETRow_WorkPointTotal, craneTotalCol);
	theTable.getEntRowColumnByRowName(ETRow_Discharge20, disch20Col);
	theTable.getEntRowColumnByRowName(ETRow_Refeer20, reef20Col);
	theTable.getEntRowColumnByRowName(ETRow_Reefer40, reef40Col);
	theTable.getEntRowColumnByRowName(ETRow_Lifts, runTotalLifts);
	theTable.getEntRowColumnByRowName(ETRow_FwdAft, runTotFwdAft);
	theTable.getEntRowColumnByRowName(ETRow_AftFwd, runTotAftFwd);
	
	
	create totals transient;
	totals[theTable.columns] := 0;
	foreach idx in st to en do
		tmpObj := theTable.accessRow(idx).itemObject;
		if tmpObj.isKindOf(CM_OOWCreation) then
			oowc := tmpObj.CM_OOWCreation;
			amt := theTable.accessCell(idx,bayTotalCol).text.Integer;
			tot := tot + amt;
			totcr := totcr + amt;
			theTable.accessCell(idx,runTotFwdAft).text := tot.zeroNotAllowed();
			theTable.accessCell(idx,craneTotalCol).text := totcr.zeroNotAllowed();
			if oowc.myCraneJobSheet = null then
				totLifts := totcr;
			else
				totLifts := totLifts + oowc.getNumberOfLifts();
			
			endif;
			theTable.accessCell(idx,runTotalLifts).text := totLifts.String;
			
			foreach totCol in disch20Col to bayTotalCol do
				amt := theTable.accessCell(idx,totCol).text.Integer;
				totals[totCol] := totals[totCol] + amt;
			endforeach;
			foreach totCol in reef20Col to reef40Col do
				amt := theTable.accessCell(idx,totCol).text.Integer;
				totals[totCol] := totals[totCol] + amt;
			endforeach;
			
			
		else
			totcr := 0;	
			totLifts := 0;
		endif;
	endforeach;
	foreach totCol in disch20Col to reef40Col do
		amt := totals[totCol];
		theTable.accessCell(totRow,totCol).text := amt.zeroNotAllowed();
	endforeach;

	tot := 0;
	foreach idx in st to en reversed do
		if theTable.accessRow(idx).itemObject.isKindOf(CM_OOWCreation) then
			amt := theTable.accessCell(idx,bayTotalCol).text.Integer;
			tot := tot + amt;
			theTable.accessCell(idx,runTotAftFwd).text := tot.zeroNotAllowed();
		endif;
	endforeach;
epilog	
	delete totals;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doQueryBaysCreate" id="bed3f972-16ee-4972-8fac-a37dff24bb33">
        <updating/>
        <source>doQueryBaysCreate() updating, protected;
// ---------------------------------------------------------------------------
// Created:		01 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	
	theReturn : Integer;
	
begin
	
	while true do
		app.myTrxCA.trxCreateVoyageOOWCreation(self.myCurrentVoyage.myCellularVoyageStructure, app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("OOW Creation", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doQueryBaysShow" id="c4b77e31-dad5-4d1b-9ba6-3e288a4bfbab">
        <source>doQueryBaysShow() protected;
// ---------------------------------------------------------------------------
// Created:		01 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	
	theTable : CM_DataTable;
	theCol, idx, amt,
	jobCol,
	disch20Col,
	loadDLR40: Integer;
	str : String;
	oowc : CM_OOWCreation;
begin
	theTable := self.tblData;
	theTable.getEntRowColumnByRowName(ETRow_Job, jobCol);
	theTable.getEntRowColumnByRowName(ETRow_Discharge20, disch20Col);
	theTable.getEntRowColumnByRowName(ETRow_LoadDLR40, loadDLR40);
	
	foreach 	oowc in self.myCurrentVoyage.myCellularVoyageStructure.allOOWCreations where oowc.myCraneJobSheet &lt;&gt; null  do
		
		str:=oowc.getAttributeStringForDefArray(theTable.allTblDataEntRows);
		
		//str := oowc.getRowDetailString();
		idx := theTable.addItemObject(oowc,str);
		theTable.accessRow(idx).backColor := self.xmlColourRow;

		if not oowc.allJobs.isEmpty then
			theTable.accessCell(idx,jobCol).backColor := self.Colour_Pink;
		endif;

		self.doColourBayCell(theTable,oowc, idx, DeckOnDeck, oowc.myBay.isTwinLiftOD);
		self.doColourBayCell(theTable,oowc, idx, DeckUnderDeck, oowc.myBay.isTwinLiftUD);
		if oowc.orderType &gt;= 2 then
			foreach theCol in disch20Col to loadDLR40 do
				amt := theTable.accessCell(idx,theCol).text.Integer;
				if amt &lt;&gt; 0 then
					theTable.accessedCell.backColor := self.xmlColourCell;
					theTable.accessedCell.foreColor := self.xmlColourCell.getInverseColour();
				endif;
			endforeach;
		endif;
	endforeach;
	// UNALLOCATED
	foreach 	oowc in self.myCurrentVoyage.myCellularVoyageStructure.allOOWCreations where oowc.myCraneJobSheet = null do
		//str := oowc.getRowDetailString();
		str:=oowc.getAttributeStringForDefArray(theTable.allTblDataEntRows);
		idx := theTable.addItemObject(oowc,str);
		theTable.accessRow(idx).backColor := self.xmlColourRow;
		self.doColourBayCell(theTable,oowc, idx, DeckOnDeck, oowc.myBay.isTwinLiftOD);
		self.doColourBayCell(theTable,oowc, idx, DeckUnderDeck, oowc.myBay.isTwinLiftUD);
	endforeach;
	
	
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doQueryCranesDisplay" id="8a4cdba4-537e-42d4-b3b3-98d224d4ad78">
        <source>doQueryCranesDisplay() protected;
// ---------------------------------------------------------------------------
// Created:		21 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theDataTable : CM_DataTable;
	idx : Integer;
	str, crID : String;
	aJS : CM_VoyageJobSheet;
	aTs : TimeStamp;
	aCrane : CM_Crane;
	workPointObject : CM_Object;
	wpColour 	: Integer;
	targetRateStr : String;
begin
	

	 // ### CRANES add to main table
	foreach aJS in self.myCurrentVoyage.allJobSheetsInOrder 
		where aJS.isVoyageROROJobSheet() or aJS.isVoyageLOLOJobSheet	do // TFS 3631
		workPointObject:=aJS.getMyWorkPointObject;
		if workPointObject = null then
			continue;
		endif;
		wpColour:=workPointObject.IF_VoyageWorkPoint.getColour;

		str := aJS.getOOWInfoLine(0);

		if workPointObject.IF_VoyageWorkPoint.getCrane &lt;&gt; null then
			theDataTable:= self.tblData;
		else
			theDataTable:= self.tblRORO;
		endif;
		idx := theDataTable.addItem(str);
		theDataTable.accessRow(idx).itemObject := workPointObject;
		theDataTable.accessCell(idx,1).mergeCells := Table.MergeCells_Merge;
		theDataTable.accessRow(idx).backColor := wpColour; 
		theDataTable.accessRow(idx).foreColor := wpColour.getInverseColour(); 
	endforeach;

	self.tblCranes.rows := self.tblCranes.fixedRows;
	// ### CRANES add to update table
	foreach aJS in self.myCurrentVoyage.allJobSheetsInOrder	
			where aJS.isVoyageROROJobSheet() or aJS.isVoyageLOLOJobSheet	do // TFS 3631

		workPointObject:=aJS.getMyWorkPointObject;
		if workPointObject = null then
			continue;
		endif;
		aCrane := aJS.getMyCrane();
		
		//aTs := aJS.getWorkStarted();						//cnwmc5 - 16 Oct 2013 - PAR 32793
		aTs := aJS.workStarted;								//cnwmc5 - 16 Oct 2013 - PAR 32793
		if not aTs.isValid() then							//cnwmc5 - 16 Oct 2013 - PAR 32793
			aTs := self.myCurrentVoyage.shipExchangeDate;	//cnwmc5 - 16 Oct 2013 - PAR 32793
		endif;												//cnwmc5 - 16 Oct 2013 - PAR 32793

		crID := workPointObject.IF_VoyageWorkPoint.getID;
		if aCrane &lt;&gt; null and aCrane.machineLiftType = TWIN_LIFT then//ccms1595 27/11/07
			crID := crID &amp; " (T/L)";
		endif;
		
		//08 Mar 2018	NDL	TFS 37437
		targetRateStr := workPointObject.IF_VoyageWorkPoint.getTargetRatePH.String;
		
		//10 Aug 2009	NDL Rework for CCMS 1031 par 20474
		idx := self.tblCranes.addItem(	crID &amp; Tab &amp;
										aTs.date.shortFormatJMT() &amp; Tab &amp;  
										aTs.time.Time.shortFormatJMT() &amp; Tab &amp; 
										//workPointObject.IF_VoyageWorkPoint.getTargetRatePH.String &amp; Tab &amp;  
										targetRateStr &amp; Tab &amp;  
										aJS.getCraneDirString() &amp; Tab &amp;
										workPointObject.IF_VoyageWorkPoint.getJobSeed.String);
		self.tblCranes.accessRow(idx).itemObject := workPointObject;

	endforeach;
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doQueryCranesPosition" id="7e97c871-8ad0-4ce7-87eb-e8a006b0004b">
        <source>doQueryCranesPosition() protected;
// ---------------------------------------------------------------------------
// Created:		01 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	
	theTable : CM_DataTable;
	idx, cnt : Integer;
	aCrane : CM_Crane;
	workPointObject : CM_Object;
	aJS : CM_VoyageJobSheet;
	oowc : CM_OOWCreation;
begin
	theTable := self.tblData;

	
	foreach aJS in self.myCurrentVoyage.allJobSheetsInOrder
			where aJS.isVoyageROROJobSheet() or aJS.isVoyageLOLOJobSheet	do // TFS 3631

		workPointObject := aJS.getMyWorkPointObject();
		if workPointObject &lt;&gt; null then
			oowc := aJS.allOOWCreations.last;
			if oowc &lt;&gt; null then
				idx := 0;
				if workPointObject.IF_VoyageWorkPoint.getCrane &lt;&gt; null then
					theTable := self.tblData;
				else
				
					theTable := self.tblRORO;
				endif;
				if theTable.findObjectInRow(oowc,idx) then
					cnt := 0;
					if theTable.findObjectInRow(workPointObject,cnt) then
						if cnt &gt; 0 then
							theTable.moveRow(cnt,idx);
						endif;
					endif;
				endif;
			endif;
		endif;
	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doQueryDeckTotals" id="abe2d0dd-8e77-4a6c-afd6-048a062f66e3">
        <source>doQueryDeckTotals() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	oowc : CM_OOWCreation;
	theTable : CM_DataTable;
	tmpObj : Object;
	idx,st,en, tot, totcr, amt, totRow, totCol : Integer;
	deckTotalCol, 
	workPointTotalCol, 
	disch20Col,
	reef20Col,
	reef40Col: Integer;
	totals : IntegerArray;
begin
	theTable :=self.tblRORO;
	st := theTable.fixedRows + 1;
	en := theTable.rows;
	totRow := theTable.addItem("Totals");
	theTable.accessRow(totRow).backColor := Black;
	theTable.accessRow(totRow).foreColor := White;
	theTable.getEntRowColumnByRowName(ETRow_DeckTotal, deckTotalCol);
	theTable.getEntRowColumnByRowName(ETRow_WorkPointTotal, workPointTotalCol);
	theTable.getEntRowColumnByRowName(ETRow_Discharge20, disch20Col);
	theTable.getEntRowColumnByRowName(ETRow_Refeer20, reef20Col);
	theTable.getEntRowColumnByRowName(ETRow_Reefer40, reef40Col);
	
	create totals transient;
	totals[theTable.allTblDataEntRows.size] := 0;
	foreach idx in st to en do
		tmpObj := theTable.accessRow(idx).itemObject;
		if tmpObj.isKindOf(CM_OOWCreation) then
			oowc := tmpObj.CM_OOWCreation;
			amt := theTable.accessCell(idx,deckTotalCol).text.Integer;
			tot := tot + amt;
			totcr := totcr + amt;
			theTable.accessCell(idx,workPointTotalCol).text := totcr.zeroNotAllowed();
			
			foreach totCol in disch20Col to deckTotalCol do
				amt := theTable.accessCell(idx,totCol).text.Integer;
				totals[totCol] := totals[totCol] + amt;
			endforeach;
			foreach totCol in reef20Col to reef40Col do
				amt := theTable.accessCell(idx,totCol).text.Integer;
				totals[totCol] := totals[totCol] + amt;
			endforeach;
			
		else
			totcr := 0;	
		endif;
	endforeach;
	
	foreach totCol in disch20Col to reef40Col do
		amt := totals[totCol];
		theTable.accessCell(totRow,totCol).text := amt.zeroNotAllowed();
	endforeach;
	
epilog	
	delete totals;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doQueryDecksCreate" id="12fc51f3-045d-4c04-b57c-d74aec13efe8">
        <source>doQueryDecksCreate() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	theReturn : Integer;
begin
	
	while true do
		app.myTrxCA.trxCreateVoyageOOWCreationRORO(self.myCurrentVoyage.myROROStructure, app.myPassport);
		if app.myPassport.trxCompletedOK then
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog("OOW Creation", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doQueryDecksShow" id="224afb7b-ed77-4d81-bdff-cf57db170f82">
        <source>doQueryDecksShow() protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 September 2011	cnwer1	Initial creation CCMS MES 1033

*/

vars
	theTable : CM_DataTable;
	theCol, idx, amt : Integer;
	str : String;
	oowc : CM_OOWCreation;
begin
	if self.myCurrentVoyage.myROROStructure = null then
		return;
	endif;
	
	theTable:=self.tblRORO;
	
	foreach oowc in self.myCurrentVoyage.myROROStructure.allOOWCreations where oowc.myCraneJobSheet &lt;&gt; null   do
		
		str:=oowc.getAttributeStringForDefArray(theTable.allTblDataEntRows);
		idx := theTable.addItemObject(oowc,str);
		theTable.accessRow(idx).backColor := self.xmlColourRow;
		if not oowc.allJobs.isEmpty then
			theTable.accessCell(idx,2).backColor := self.Colour_Pink;
		endif;
	endforeach;
	
	
	foreach oowc in self.myCurrentVoyage.myROROStructure.allOOWCreations where oowc.myCraneJobSheet = null   do
		
		str:=oowc.getAttributeStringForDefArray(theTable.allTblDataEntRows);
		idx := theTable.addItemObject(oowc,str);
	
		// UNALLOCATED
		theTable.accessRow(idx).backColor := self.xmlColourRow;
			
	endforeach;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="0906cd8a-c780-4e47-944a-caa24201faac">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		21 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 25/09/2017	jlgdap1		TFS 7009 JMT Fix display when showing large toolbar captions
vars

begin


	self.frmHeading.left := 0;
	self.frmHeading.top := self.frmToolbar.clientHeight + 1;
	self.frmHeading.zOrder(1);//epr 29/8/11 for some reason status bar wasn't showing
	self.frmToolbar.repositionAfterResize();
	self.tblCranes.repositionAfterResize();
	
	self.doMoveControlsForLargeCaptions();						// TFS 7009
end;</source>
    </JadeMethod>
    <JadeMethod name="doTableReset" id="9121185c-3ef8-4b3c-befe-bb70f46958af">
        <source>doTableReset(_theTable : Table input; _theRow : Integer);
// ---------------------------------------------------------------------------
// Created:		02 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	
	_theTable.accessRow(_theRow).backColor := self.origColor;
	_theTable.accessRow(_theRow).foreColor := self.origColor.getInverseColour();
	_theTable.clearGraphics;

end;</source>
        <Parameter name="_theTable" type="Table" usage="input"/>
        <Parameter name="_theRow" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doTblCraneContextMenu" id="a7ca2321-5716-4f59-a642-267e2d0f0094">
        <updating/>
        <source>doTblCraneContextMenu(conwin: Window input; mouse: Boolean; x: Integer; y: Integer) : Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 August 2009	cnwndl1	Initial creation Rework for CCMS 1031 par 20474

*/

vars

	xLeft 	: Real;
	yTop	: Real;
	workPointObj : CM_Object;
	workPointID : String;
begin

	xLeft := x;
	yTop := y;
	
	conwin.windowToScreen(xLeft, yTop);
	self.screenToWindow(xLeft, yTop);
	
	self.mnuContextEditCrane.visible := true;
	self.mnuContextLoadOOW.visible := true;
	self.mnuCraneMaintenance.visible:=true;
	self.mnuWPOpHrs.visible := true;
	
	workPointObj := tblCranes.accessRow(tblCranes.row).itemObject.CM_Object;
	if workPointObj = null then
		return false;
	endif;
	workPointID:=workPointObj.IF_VoyageWorkPoint.getTypeDescription &amp; " " &amp; workPointObj.IF_VoyageWorkPoint.getID;
	self.mnuContextEditCrane.caption :=  workPointID &amp; " " &amp; app.getErrorString(Edit) &amp; "...";
	self.mnuContextEditCrane.userObject := workPointObj;
	self.mnuContextLoadOOW.caption := workPointID &amp; " " &amp; app.getErrorString(OOW_Load);
	self.mnuContextLoadOOW.userObject := workPointObj;
	self.mnuCraneMaintenance.caption:= workPointID &amp; " " &amp; app.getErrorString(Maintenance)&amp; "...";
	self.mnuCraneMaintenance.userObject := workPointObj;
	self.mnuWPOpHrs.userObject := workPointObj;
	
	self.popupMenu(mnuContextCrane, xLeft.Integer, yTop.Integer);
	
	return false;
	
epilog

end;</source>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblDataContextMenu" id="54d3a4d2-319d-43fe-934d-274cde39ef91">
        <updating/>
        <source>doTblDataContextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer): Boolean updating;
// ---------------------------------------------------------------------------
// Created:		04 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aBay : CM_Bay;
	aCrane : CM_Crane;
	anObj : Object;
	disMode : String;
	oow		: CM_OOWCreation;
begin
	anObj := table.accessRow(table.row).itemObject;
	if anObj.isKindOf(CM_OOWCreation) then
		oow:=anObj.CM_OOWCreation;
		self.mnuOOWShowBay.visible := true;
		aBay := oow.myBay;
		if aBay &lt;&gt; null then
			if oow.isDischarge() then
				disMode := app.getErrorString(SHP_Discharge_Colour_Coding);
			elseif oow.isLoad() then
				disMode := app.getErrorString(SHP_Load_Colour_Coding);
			else
				disMode := app.getErrorString(Actual);
			endif;

			self.mnuOOWShowBay.caption := "Show " &amp; self.myCurrentVoyage.code &amp; " Bay " &amp; aBay.id.String &amp; " (" &amp; disMode &amp; ") ...";
			self.mnuOOWShowBay.userObject := oow;
		endif;
	endif;
	
	return inheritMethod(table, conwin, mouse, x, y);

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblDataDragDrop" id="078985a1-b27a-4770-903d-3dfa801368ca">
        <updating/>
        <source>doTblDataDragDrop(table: Table input; win: Window input; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		27 April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theRow : Integer;
	aJS : CM_VoyageJobSheet;
	mess, attribute : String;
	oowc : CM_OOWCreation;
	targetObj : Object;
begin
	
	theRow := table.CM_DataTable.getRowFromY(y);
	targetObj := table.accessRow(theRow).itemObject;
	
	if theRow &gt; self.origRow then
		if theRow &lt; table.rows then
		theRow := theRow - 1;
		endif;
	endif;
	
	if theRow &gt; table.fixedRows then
		if self.origRow &gt; table.fixedRows 
		and theRow &lt;&gt; self.origRow then
			if self.origObject.respondsTo(IF_VoyageWorkPoint) then
				self.doDragDropCrane(table,theRow);
			elseif self.origObject.isKindOf(CM_OOWCreation) then
				self.doDragDropBay(table,targetObj, theRow);
			endif;
		else
			self.doTableReset(table,theRow);	
		endif;		
	else
		self.doTableReset(table,self.origRow);	
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doTblDataDragOver" id="8b1e9061-75bf-4a50-9ff2-8ccf7c0e3313">
        <updating/>
        <source>doTblDataDragOver(table: Table input; win: Window input; x: Real; y: Real; state: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		27 April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	str : String;
	aJS : CM_VoyageJobSheet;
	theRow, amt, tot, idx, st, en,bayTotalCol : Integer;
begin
	theRow := table.CM_DataTable.getRowFromY(y);
	
	table.clearGraphics();
	table.drawWidth := 2;

	if self.origObject.respondsTo(IF_VoyageWorkPoint) then  //isKindOf(CM_Crane) then
		table.drawFillColor := self.origColor;
		table.drawFilledRectangle(1,y,table.clientWidth,y + 16,Black);
		if self.origJS &lt;&gt; null then
			aJS := self.origJS;
		else
			aJS := self.myCurrentVoyage.allJobSheets[self.origObject.IF_VoyageWorkPoint.getID];
		endif;

		st := table.fixedRows + 1;
		en := theRow - 1;
		table.CM_DataTable.getEntRowColumnByRowName(ETRow_DeckTotal, bayTotalCol);
		foreach idx in st to en do
			if table.accessRow(idx).itemObject.isKindOf(CM_OOWCreation) then
				amt := table.accessCell(idx,bayTotalCol).text.Integer;
				tot := tot + amt;
			endif;
		endforeach;
		str := aJS.getOOWInfoLine(tot);
		table.drawTextAt(str,5,y,self.origColor.getInverseColour());
	elseif self.origObject.isKindOf(CM_OOWCreation) then
		if self.dragBay then
			table.drawFillColor := self.origColor;
			table.drawFilledRectangle(1,y,table.clientWidth,y + 16,Black);
			table.drawTextAt(self.origTextExtra &amp; " " &amp; self.origText,5,y,self.origColor.getInverseColour());
			
		else
			
			self.drawDraggedCell(x.Integer,y.Integer);
	
			table.drawTextAt(self.origText,x + 25,y+ 3,self.origColor.getInverseColour());
			table.drawTextAt(self.origTextExtra,x - 51,y - 16,White);
			table.drawTextAt(self.origTextExtra,x - 50,y - 15,Black);
		endif;		
	else
		str := self.origText;
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <Parameter name="state" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doTblDataMouseDown" id="6b8c567c-f9b0-44df-b7ad-b4142b32a242">
        <updating/>
        <source>doTblDataMouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		27 April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aJS : CM_VoyageJobSheet;
	bayIDColumn,
	bayDeckColumn : Integer;
begin
	inheritMethod(table, button, shift, x, y);
	
	self.origRow := table.CM_DataTable.getRowFromY(y);
	if self.origRow &lt; 1 then
		return;
	endif;
	self.dragBay := false;
	table.row := self.origRow;
	self.origObject := null;
	if self.origRow &gt; 0 and self.origRow &lt;= table.rows then
		self.origObject := table.accessRow(self.origRow).itemObject;
		if origObject = null then
			return;
		endif;
		
		if self.origObject.respondsTo(IF_VoyageWorkPoint) then
			aJS := self.myCurrentVoyage.allJobSheets[self.origObject.IF_VoyageWorkPoint.getID];
			self.origJS := aJS;
			self.origText := aJS.getOOWInfoLine(0);
			self.origColor:= self.origObject.IF_VoyageWorkPoint.getColour;
		elseif self.origObject.isKindOf(CM_OOWCreation) then
			self.origColumn := table.column;
			table.CM_DataTable.getEntRowColumnByRowName(ETRow_Deck, bayIDColumn);
			if self.origColumn = bayIDColumn then
				table.CM_DataTable.getEntRowColumnByRowName(ETRow_DeckOridinal, bayDeckColumn);
				self.origText := table.accessCell(table.row, bayIDColumn).text &amp; " " &amp;  table.accessCell(table.row, bayDeckColumn).text;
				self.origTextExtra := self.getCellDescription(table,bayIDColumn);
				self.origColor := table.accessedCell.backColor;
			
			else
				self.origText := table.accessCell(table.row, table.column).text;
				self.origTextExtra := self.getCellDescription(table,table.column);
				self.origColor := table.accessedCell.backColor;
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doTblDataMouseMove" id="95a00fb6-973d-456c-ab87-89c89f155727">
        <updating/>
        <source>doTblDataMouseMove(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		27 April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theObj : Object;
	aJS : CM_JobSheet;
	oowc : CM_OOWCreation;
	mess : String;
	disch20Col,
	disch40Col, bayIDCol : Integer; 
begin
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	mess := "Jobs have been created for this crane. Cannot move.";
	if button = Window.MouseButton_Left 
	and (app.isControlKeyDown()	and not app.isAltKeyDown()and not app.isShiftKeyDown())
	and app.dragDetected(x, y, self.origXPos, self.origYPos) 
	and y &gt; 15 then
	
		if self.origObject = null then
			return;
		endif;
		
		if self.origObject.respondsTo(IF_VoyageWorkPoint) then //isKindOf(CM_Crane) then
			aJS := self.myCurrentVoyage.allJobSheets[self.origObject.IF_VoyageWorkPoint.getID];
			if aJS &lt;&gt; null then
				oowc := aJS.CM_VoyageJobSheet.allOOWCreations.first;
				if oowc &lt;&gt; null 
				and not oowc.allJobs.isEmpty then
					app.msgBox(mess,app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
					return;
				endif;
			endif;
			self.dragMode := DragMode_Drag;
			self.dragCursor := self.picCtrlScroll.dragCursor;
			table.accessRow(self.origRow).backColor := White;
			table.accessRow(self.origRow).foreColor := Black;
		elseif self.origObject.isKindOf(CM_OOWCreation) then
			if self.origObject.CM_OOWCreation.allJobs.isEmpty then
				table.CM_DataTable.getEntRowColumnByRowName(ETRow_Discharge20, disch20Col);
				table.CM_DataTable.getEntRowColumnByRowName(ETRow_Deck,bayIDCol);
// PAR 28716				table.CM_DataTable.getEntRowColumnByRowName(ETRow_Discharge40, disch40Col);
				table.CM_DataTable.getEntRowColumnByRowName(ETRow_LoadDLR40, disch40Col);
				if self.origColumn &gt;= disch20Col 
				and self.origColumn &lt;= disch40Col 
				and self.origText &lt;&gt; null then
					self.dragMode := DragMode_Drag;
					self.dragCursor := self.picCtrlScroll.dragCursor;
				elseif self.origColumn = bayIDCol then
					self.dragMode := DragMode_Drag;
					self.dragCursor := self.picCtrlScroll.dragCursor;
					self.dragBay := true;
					table.accessRow(self.origRow).backColor := White;
					table.accessRow(self.origRow).foreColor := Grey;
				
				endif;
			else
				app.msgBox(mess,app.getErrorString(Error),MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
				return;
			endif;
		endif;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doUndoDrag" id="20cbda40-011a-436a-af31-7ffa346df660">
        <updating/>
        <source>doUndoDrag(_table : Table input) updating;
// ---------------------------------------------------------------------------
// Created:		09 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.dragMode := DragMode_None;
	_table.clearGraphics();
	_table.accessRow(self.origRow).backColor := self.origColor;
	_table.accessRow(self.origRow).foreColor := self.origColor.getInverseColour();

end;</source>
        <Parameter name="_table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUpdateBayJobSheet" id="dab80e62-2a17-49ed-95b7-6ea434ffa14d">
        <updating/>
        <source>doUpdateBayJobSheet(_theTable : Table input) updating;
// ---------------------------------------------------------------------------
// Created:		01 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theTable : CM_DataTable;
	bays : CM_OOWCreationByOrder;
	js : CM_VoyageJobSheet;

	idx, st, en, craneIDX : Integer;
	anObj : Object;
	workPointObject : CM_Object;
	aCrane : CM_Crane;
	theCranes, theCranesOrder : ObjectArray;
begin
	app.mousePointer := Window.MousePointer_HourGlass;
	theTable := _theTable.CM_DataTable;
	create bays transient;
	create theCranesOrder transient;
	create theCranes transient;
	
	// ## this is how the cranes are ordered now
	foreach js in self.myCurrentVoyage.allJobSheetsInOrder 
			where js.isVoyageROROJobSheet() or js.isVoyageLOLOJobSheet	do // TFS 3631

		workPointObject := js.getMyWorkPointObject;
		//aCrane := js.getMyCrane();
		theCranes.add(workPointObject);
	endforeach;
	
	
	st := theTable.fixedRows + 1;
	en := theTable.rows;
	foreach idx in st to en do
		anObj := theTable.accessRow(idx).itemObject;
		if anObj = null then
			continue;
		endif;
		if anObj.isKindOf(CM_OOWCreation) then
			bays.add(anObj.CM_OOWCreation);
		elseif anObj.respondsTo(IF_VoyageWorkPoint) then
			
		//	aCrane := anObj.CM_Crane;
			// ## this is how they are in the GUI
			theCranesOrder.add(anObj);
			js := self.myCurrentVoyage.allJobSheets[anObj.IF_VoyageWorkPoint.getID];

			/*if js = null then
				js := self.doUpdateCreateJS(aCrane);
			endif;*/

			self.doUpdateBayJobSheetTRX(bays,js,self.myCurrentVoyage.myCellularVoyageStructure);
			
			bays.clear;
			js := null;
		endif;
	endforeach;
	
	// ### unallocated bays
	self.doUpdateBayJobSheetTRX(bays,js,self.myCurrentVoyage.myCellularVoyageStructure);
	
	// ## if crane order is different re order the job sheets
	st := 1;
	en := self.myCurrentVoyage.allJobSheetsInOrder.size;
	foreach craneIDX in st to en do
		if theCranes[craneIDX] &lt;&gt; theCranesOrder[craneIDX] then
			self.doUpdateCraneOrder(theCranesOrder);
			break;
		endif;
	endforeach;
	
	global.beep;
	
epilog
	delete bays;
	delete theCranesOrder;
	delete theCranes;
	app.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_theTable" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doUpdateBayJobSheetTRX" id="e3f4cc7b-3596-49f7-8545-4160a3f378eb">
        <updating/>
        <source>doUpdateBayJobSheetTRX(_bays : CM_OOWCreationByOrder; _js : CM_VoyageJobSheet input; _cvs : CM_CellularVoyageStructure) updating;
// ---------------------------------------------------------------------------
// Created:		01 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theTable : CM_DataTable;
	
	theReturn : Integer;
	idx, st, en : Integer;
	anObj : Object;
	aCrane : CM_Crane;
begin
	while true do
		app.myTrxUA.trxUpdateVoyageOOWBays(_bays, _js, _cvs, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else
			theReturn := app.showErrorWarningDialog("OOW Creation", app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return;
		endif;
		break;
	endwhile;

end;</source>
        <Parameter name="_bays" type="CM_OOWCreationByOrder"/>
        <Parameter name="_js" type="CM_VoyageJobSheet" usage="input"/>
        <Parameter name="_cvs" type="CM_CellularVoyageStructure"/>
    </JadeMethod>
    <JadeMethod name="doUpdateCraneOrder" id="6e8abed9-372d-4e9d-b963-0ae73ac09af6">
        <updating/>
        <source>doUpdateCraneOrder(_theCRANES : ObjectArray) updating;
// ---------------------------------------------------------------------------
// Created:		31 May 2006 By Andrew Bishop cnwab1
