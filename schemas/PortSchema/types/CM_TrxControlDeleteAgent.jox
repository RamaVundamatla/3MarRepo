    <JadeMethod name="trxDeleteLocale" id="bae462de-4d16-46a4-9d6f-ed67613700f5">
        <updating/>
        <source>trxDeleteLocale(_locale : CM_Locale io; _passport : CM_Passport input) updating;

// cnwdvb1 15 January 2003 

vars

begin

		// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	app.setContinueCMExceptions(false);

	if (not _locale.validateForDelete()) then
		return;
	endif;
	
	beginTransaction;

	if not self.exclusiveLockObjectToDelete(_locale) then
	    // toDelete is null, invalid or has already been deleted
	    return;
	endif;

	if _passport.noErrors then
		delete _locale;
	endif;

epilog		
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_locale" type="CM_Locale" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
