    <JadeMethod name="setCurrencySymbolDecimalPlaces" id="5e25f0fe-4d3f-47d6-902c-f43aaface24c">
        <source>setCurrencySymbolDecimalPlaces();
// ---------------------------------------------------------------------------
// Created:		11 September 2007 By Andrew Bishop cnwab1
//
// Purpose:		These formats are exported when JMT does a realease. 
//					This means that the currency symbol and decimal places 
//					that have been set in these formats in DMAST go out to 
//					all customers, and overwrite the customers own settings.
//					So the first user to login after the upgrade will change the settings back.
//
// ---------------------------------------------------------------------------
vars
	currSymbol, dPlaces : Integer;
	aTerm : CM_Terminal;
begin
	if not app.myRoot.canDo(Mod_Invoicing) then
		return;
	endif;
	aTerm := CM_Terminal.firstInstance;
	if aTerm &lt;&gt; null then
		dPlaces := aTerm.getConfig(FinancialRateDPlaces).Integer;
	endif;

	currSymbol := app.myRoot.getInvoiceCurrencySymbol();		// PAR 17016
	//currSymbol := app.myRoot.getConfig(InvoiceCurrencySymbol).Integer;
	//if currSymbol = null then
	//	currSymbol := 36; // $
	//endif;
	
	// TFS 36954 MPD 20 Feb 2018
	//if $CM_RateMoney.decimalPlaces &lt;&gt; dPlaces or $CM_RateMoney.symbol &lt;&gt; currSymbol.Character then
	if $CM_InvoiceMoney.symbol &lt;&gt; currSymbol.Character then
		beginTransaction;
		// TFS 36954 MPD 20 Feb 2018
		// No longer used, now we just reference the terminal config directly
		/*$CM_RateMoney.defineCurrencyFormat(dPlaces,
						$CM_RateMoney.decimalSeparator,
						$CM_RateMoney.thousandSeparator,
						$CM_RateMoney.positiveFormat,
						$CM_RateMoney.negativeFormat,
						$CM_RateMoney.showLeadingZeros,
						currSymbol.Character);
		$CM_RateEntry.defineNumberFormat(dPlaces,
						$CM_RateEntry.decimalSeparator,
						$CM_RateEntry.thousandSeparator,
						$CM_RateEntry.negativeFormat,
						$CM_RateEntry.showLeadingZeros);*/
		
		$CM_InvoiceMoney.defineCurrencyFormat($CM_InvoiceMoney.decimalPlaces,
						$CM_InvoiceMoney.decimalSeparator,
						$CM_InvoiceMoney.thousandSeparator,
						$CM_InvoiceMoney.positiveFormat,
						$CM_InvoiceMoney.negativeFormat,
						$CM_InvoiceMoney.showLeadingZeros,
						currSymbol.Character);
		commitTransaction;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setCurrentLocale" id="b0e1b959-78ed-4da8-a147-c2c1882d1499">
        <updating/>
        <source>setCurrentLocale() updating;
// ---------------------------------------------------------------------------
// Created:     01 April 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	jadeLocaleId : Integer;
	jadeLocale	: Locale;
	jmtLocale	: CM_Locale;
	
	//11 Jan 2021	NDL	Unit Test tracking
	oldValue : String;
	newValue : String;
	changeString : String;
	
begin
	if myRoot = null then
		return;
	endif;
	
	// apply client locale
	jadeLocale := self.currentLocale;
	
	if jadeLocale &lt;&gt; null then
		jmtLocale := self.myRoot.allLocales[jadeLocale.name];
		if jmtLocale = null then
			app.writeLog('CM_Locale not found for ' &amp; jadeLocale.name &amp; ' (' &amp; jadeLocale.makeLocaleName &amp; ')', LogINFO);
		endif;
	endif;

	// not found? Fall back to the server (installation) locale
	if jmtLocale = null then
		jadeLocaleId := self.getServerLocale();
		if jadeLocaleId &lt;&gt; null then
			jmtLocale := self.myRoot.allLocales[jadeLocaleId.String];
			if jmtLocale = null then
				app.writeLog('CM_Locale not found for ' &amp; jadeLocaleId.String, LogINFO);
			endif;
		endif;
	endif;
	
	// Last resort - fall back to Manufacturing Plant local (NZ English)
	if jmtLocale = null then
		jmtLocale := self.myRoot.allLocales[StandardTextLocaleStr];
	endif;
	
	//11 Jan 2021	NDL	Unit Test tracking
	if self.myCurrentLocale = null then
		oldValue := "null";
	else
		oldValue := self.myCurrentLocale.localeDescription;
	endif;
	if jmtLocale = null then
		newValue := "null";
	else
		newValue := jmtLocale.localeDescription;
	endif;
	
	
	self.myCurrentLocale := jmtLocale;

	
	//11 Jan 2021	NDL	Unit Test tracking
	if app.myUtilityCA &lt;&gt; null and app.myTrxCA &lt;&gt; null then
		if oldValue &lt;&gt; newValue then
			changeString := "App.myCurrentLocale, was:'" &amp; oldValue &amp; "' now:'" &amp; newValue &amp; "' [" &amp; method.qualifiedName &amp; "]";
			app.createActivityHistory(	ActivityHistoryGeneralSys,	//_type : Integer;
										null,	//_terminal : CM_Terminal;
										null,	//_objectForExtraDetail : Object;
										changeString,	//_description : String;
										process.isInTransactionState,	//_insideTransaction : Boolean;
										false	//_temp: Boolean
										);
		endif; 
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="setDeferredChargesBgpRunning" id="dc97c0ad-cb54-4598-a55e-9efa2cc253ff">
        <updating/>
        <source>setDeferredChargesBgpRunning()updating;
/*

Purpose:			Called by the init and finalise of a BGP_DeferredChargingController
					value on app used by Transaction charging

Parameters:			

Return Value:		

Date		Who		Reason
07 July 2021	navndl1	Initial creation	TFS 51443

*/

vars

	bgpCont : BGP_DeferredChargingController;
	bgpIsRunning : Boolean;

begin

	foreach bgpCont in BGP_DeferredChargingController.instances do
		if bgpCont.isRunning and bgpCont.working then
			bgpIsRunning := true;
			break;
		endif;
	endforeach;
	
	self.deferredChargesBgpRunning := bgpIsRunning;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setErrorStore" id="744a6834-0ec7-4eca-87b8-d5a39c5f3cb5">
        <source>setErrorStore(_passport  : CM_Passport; _errText  : String;_errorStore: CM_ErrorSet input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 January 2023	navmv20	 TFS 55650 Task 55702: Jade - Contracts XML Load TRX

*/

vars
	err : CM_Error;
	
begin
	foreach err in _passport.allErrors do 
		err.setErrorText(_errText &amp; '  ' &amp; err.text, false);
		_errorStore.add(err);
	endforeach;
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_errText" type="String"/>
        <Parameter name="_errorStore" type="CM_ErrorSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setIsBackGroundApp" id="eb321bbf-df97-45d3-91a6-75e03fadb423">
        <updating/>
        <source>setIsBackGroundApp(_isBackGround : Boolean) updating;

vars

begin

	self.isBackGroundApp := _isBackGround;

end;</source>
