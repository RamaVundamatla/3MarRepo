        <source>edb_Remarks(set:Boolean; value:String io) mapping, updating, subschemaHidden;
begin
	if set then
		_setVirtualString( 'remarks',11, value );
	else
		value := _getVirtualString( 'remarks',11);
	endif;
end;</source>
