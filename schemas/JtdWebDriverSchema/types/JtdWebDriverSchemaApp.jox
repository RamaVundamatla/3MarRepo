    <JadeMethod name="jtdGetApplicationType" id="e0d61da8-2190-42bb-934d-d80c4d5f8b85">
        <source>jtdGetApplicationType() : String;

vars

begin
	if applicationType = "G" then
		return "GUI";
	elseif applicationType = "F" then
		return "GUI_No_Forms";
	elseif applicationType = "S" then
		return "Non_GUI";
	elseif applicationType = "W" then
		return "Web_Enabled";
	elseif applicationType = "N" then
		return "Non_GUI_Web";
	else
		return applicationType;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdGetClassAndOid" id="0103b3ef-a3e2-4f05-8470-fa74b52c8b44">
        <source>jtdGetClassAndOid(obj : Object) : String;

vars
 	classNo		: Integer;
	oidStr		: String;
	class		: Class;
	error		: Boolean;
	oid			: String;
begin
	if obj &lt;&gt; null then
		on Exception do jtdObjNotFoundExceptionHandler(exception, error);
		oidStr		:= obj.String;
		if not error then
			return oidStr;
		else
			class	:= getClassForObject(obj);			// refactored for 3.0 using 6.0.18 method
			oid		:= getOidStringForObject(obj);
			oidStr	:= class.name &amp; "/" &amp; oid;
			return oidStr;
		endif;
    	
	    if error then
	    	return "&lt;Unknown class, oid=" &amp; oid &amp; "&gt;";
	    endif;

	else
		return "&lt;null&gt;";
	endif;
end;</source>
        <Parameter name="obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jtdInit" id="67687885-a1dd-4c4c-b024-43ea9af693e3">
        <updating/>
        <source>jtdInit() updating, protected;

begin
	if self.jtdMyContext &lt;&gt; null and global.isValidObject(self.jtdMyContext) then
		delete self.jtdMyContext;
	endif;
	
	create self.jtdMyContext transient;
	
	self.jtdMyContext.jtdInitialize;
	
	self.jtdMyContext.jtdAppInit(null);
	
	self.jtdCommonUserInit;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="jtdInitClone" id="dc050e9e-9701-4ac6-965d-4f19e46ccc55">
        <updating/>
        <source>jtdInitClone(paramObj : Object) updating, protected;

begin
	if self.jtdMyContext &lt;&gt; null and global.isValidObject(self.jtdMyContext) then
		delete self.jtdMyContext;
	endif;
	
	create self.jtdMyContext transient;
	
	self.jtdMyContext.jtdInitialize;
	
	self.jtdMyContext.jtdAppInitClone(getOidStringForObject(paramObj));
	
	self.jtdCommonUserInit;
end;</source>
        <access>protected</access>
        <Parameter name="paramObj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="jtdInitExternalClone" id="78c000a3-8e73-4292-96c5-acca841ba5be">
