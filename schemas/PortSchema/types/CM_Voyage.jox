    <JadeMethod name="setStatusFromObject" id="5ed2797e-d2f8-426c-8a59-fd1ea4e0f93e">
        <updating/>
        <source>setStatusFromObject( _voyStatus : CM_VoyageStatus ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
06 Apr 2018		jlgndl1	Initial creation	TFS 37928
12 Apr 2023		navdap1	TFS 57362 CUX Changes to Outgoing Message Formats
*/

vars
	
begin
	if _voyStatus =  null or self.status = _voyStatus.id then
		return;
	endif;
	
	self.status := _voyStatus.id;
	
	//jlier1 TFS 51963 11/11/21
	if self.isTransient then
		return;
	endif;
	
	_voyStatus.processStatus(self.status, self);
	
	// ### TFS 55215 22Nov2022 NAVPW1
	if self.status = Voyage_Status_Arrived then
		CMIF_TrxActionTransport@createAction(self, null, null, CMIF_TrxActionTransport.ProcessVoyageArrival, app.myPassport);		// TFS 57362
	elseif self.status = Voyage_Status_Departed then
		CMIF_TrxActionTransport@createAction(self, null, null, CMIF_TrxActionTransport.ProcessVoyageDeparture, app.myPassport);		// TFS 57362
	endif;
	// ### TFS 55215 22Nov2022 NAVPW1
	
epilog

end;</source>
        <Parameter name="_voyStatus" type="CM_VoyageStatus"/>
    </JadeMethod>
