    <JadeMethod name="getLocationforVehicleMove" id="f0372d21-c85d-4329-aac9-b3c886e73fe3">
        <source>getLocationforVehicleMove():CM_YardController;
// ---------------------------------------------------------------------------
// Created:     27 May 2010 by cnwcs5
// Purpose:     Returns location for vehicle assuming this interchange area
//				has already been selected as the target IC area
// Parameters:  None
// Returns:     Nothing
// Note:		DO NOT USE THIS METHOD AS PART OF THE PROCESS RO SELECT A
//				CANDIDATE IC AREA
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	transit	:Boolean;
	lane	:CM_LaneController;
begin
	transit	:= self.myTerminal.getConfig (GateTransitIntoYard).Boolean;
	
	if transit = CM_YardInterchangeArea.Transit_Always then
		return self.myInTransitToLocation;
	endif;
	
	lane := self.getFirstAvailalableLane;
	
	if lane &lt;&gt; null then
		// there is room 
		return lane;
	endif;
	
	// there was no room so put them in transit
	return self.myInTransitToLocation;

epilog

end;</source>
        <ReturnType type="CM_YardController"/>
    </JadeMethod>
    <JadeMethod name="getLocationsController" id="6faca9ac-d9c8-42c7-b5f7-f6f203284c2a">
        <source>getLocationsController(): CM_LocationsController;
//08 November 2010	cnwml2
//+cnwml2 PAR23758 MSL CCMS 1111

vars

begin

	return self.getLocationforVehicleMove();

epilog

end;</source>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="getSatViewHeading" id="e8638457-c54b-400d-9f46-eca9e49280a3">
        <source>getSatViewHeading( taViewPos : CM_TerminalAreaViewPosition ):String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 September 2011	cnwndl1	Initial creation	Par 28076

*/

vars

	objectSet : ObjectSet;
	num : Integer;
	str : String;

begin
	
	create objectSet transient;
	self.getAllLocationsTrackedItems(objectSet);
	num := objectSet.size;
	
	if taViewPos &lt;&gt; null then	
		if taViewPos.displayItemCount then
			str := num.String;
		endif;

	else	
		str := num.String;
		
	endif;
	
	if str &lt;&gt; null then
		str := " ( " &amp; str &amp; " )";
	endif;
	
	str := self.id &amp; str;
	
	return str;
	
epilog

	delete objectSet;

end;</source>
        <Parameter name="taViewPos" type="CM_TerminalAreaViewPosition"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getVMAccessRulesDisplay" id="01ece678-97d8-42f6-8fd5-9448a0737bcf">
        <source>getVMAccessRulesDisplay():String;
// ---------------------------------------------------------------------------
// Created:     18 June 2010 by cnwcs5
// Purpose:     par 24418
// Parameters:  None
// Returns:     Translated text corresponding to value of vehicleMachineAccessRules property
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 
// ---------------------------------------------------------------------------
vars
	value	:Integer;
begin
	value := self.vehicleMachineAccessRules;
	
	if value = self.Access_VehicleMachines then
		return app.getErrorString (Vehicles_And_Machines);
	elseif value = self.Access_Vehicles then
		return app.getErrorString (Vehicles_Only);
	elseif value = self.Access_Machines then
		return app.getErrorString (Machines_only);
	endif;	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
