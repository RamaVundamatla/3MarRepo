    <JadeMethod name="loadDataForFirstTime" id="776f43d5-476d-4243-be19-16e168970277">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 August 2011	#cnwdz2	 

*/

vars
	rowColour	: Integer;
	row			: String;
	array		: HugeStringArray;
	rowIndex	: Integer;
begin
	create array transient;	
	if not self.getDetailForDisplay(array) then
		self.unloadForm();
		return;
	endif;

	foreach row in array do
		rowIndex := self.tblDetails.addItem(row);
		if rowIndex mod 2 = 0 then
			rowColour := self.lblEvenRowColour.backColor;
		else
			rowColour := self.lblOddRowColour.backColor;
		endif;
		self.tblDetails.accessRow(rowIndex).backColor := rowColour;
	endforeach;

epilog
	delete array;

end;</source>
        <access>protected</access>
    </JadeMethod>
