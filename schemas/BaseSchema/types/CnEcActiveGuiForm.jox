    <JadeMethod name="btnCInspect_click" id="07e1d206-e810-42e7-b71e-3c3b2e166b02">
        <controlMethod name="JadeMask::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCInspect_click(jadeMask: JadeMask input) updating;
// --------------------------------------------------------------------------------
// Created:		13 April 2006 by cnwdad1
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if chkCUseBase.value then
		self.aMyActiveControl.cnEcInspect();
	else
		self.aMyActiveControl.inspect();
	endif;
end;</source>
        <Parameter name="jadeMask" type="JadeMask" usage="input"/>
    </JadeMethod>
