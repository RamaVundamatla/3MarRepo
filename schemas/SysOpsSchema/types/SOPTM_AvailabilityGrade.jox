end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="a86546eb-b92d-4ab6-99b4-58a2e7933d62">
        <updating/>
        <source>setupThumbnailDetails() updating;

vars
	theForm : SOP_TableMaintForm;

begin
  
	theForm :=self.myForm;
  	
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_AvailGradeTbl);
	//12/01/2011 cnwdz2 25840
	//theForm.zClearSortColumns();
	//theForm.zAddSortColumn(ETRow_Code, false);

	theForm.shtTblInput1.caption := 'Details';
	theForm.initTblInput(theForm.tblInput1, ETDef_AvailGradeMaint);
	theForm.shtTblInput1.visible := true;
	
	
	//theForm.tblData.userInputEnabled := false;	// 27/04/2010 cnwar2 #23911 - moved to SOP_TableMaintForm :: initForm

	theForm.mulSelect1.formDisplayEntryMethodName := null;
	theForm.mulSelect2.formDisplayEntryMethodName := null;
	self.colourColumn := theForm.tblData.getColumnByRowName(ETRow_Colour);	//29 Jul 2011	NDl	Par 27890
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="51b94ce8-c2a8-4633-bff0-53f349111cdf">
        <updating/>
        <source>showThumbnail(pAvailabilityGrade : CM_MTGrade) updating;

vars

	theForm : SOP_TableMaintForm;
	codeStr : String;
	
begin
  
    theForm := self.myForm;
	theForm.tblInput1.clearValues;
	
	codeStr := pAvailabilityGrade.code.String;

	theForm.tblInput1.setValueByName(ETRow_Code, codeStr);
	theForm.tblInput1.setValueByName(ETRow_Description, pAvailabilityGrade.description);
	theForm.tblInput1.setValueByName(ETRow_IsSuitableForRelease, pAvailabilityGrade.isSuitableForRelease);
	theForm.tblInput1.setValueByName(ETRow_NotAvailableForEntry, pAvailabilityGrade.isNotAvailableForEntry);
	if pAvailabilityGrade.colour = 0 then
		theForm.tblInput1.setValueByName(ETRow_Colour, White);	//29 Jul 2011	NDL	Par 27890
	else
		theForm.tblInput1.setValueByName(ETRow_Colour, pAvailabilityGrade.colour);	//29 Jul 2011	NDL	Par 27890
	endif;
	
	//13 Oct 2010	NDL Par 23991
	theForm.mulSelect1.setSorted(true);
	theForm.mulSelect1.setSelected(pAvailabilityGrade.allAllowedReleaseTerms);
	self.disableMulSelect1Contents();
	
	theForm.mulSelect2.setSorted(true);
	theForm.mulSelect2.setSelected(pAvailabilityGrade.allAllowedEditSubTerms);
	self.disableMulSelect2Contents();
	
end;</source>
        <Parameter name="pAvailabilityGrade" type="CM_MTGrade"/>
    </JadeMethod>
    <JadeMethod name="tblDataShowDataSpecial" id="37126ad2-a3c8-4adb-a41a-662bbfb8bbf5">
        <source>tblDataShowDataSpecial(_idxRow: Integer; _obj: Object);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
29 July 2011	cnwndl1	Initial creation	Par 27890

*/

vars
	mtGrade : CM_MTGrade;
	cell : JadeTableCell;
	colour : Integer;
begin

	mtGrade := _obj.CM_MTGrade;
	if(_idxRow &lt;&gt; 1) then
		if colourColumn &gt; 0 then	
			cell := myForm.tblData.accessCell(_idxRow,colourColumn);
			cell.text := null;	
			colour := mtGrade.colour;
		//	if colour = 0 then
		//		colour := White;
		//	endif;
			cell.backColor := colour;
		endif;
	endif;

	epilog
	
end;</source>
        <Parameter name="_idxRow" type="Integer"/>
        <Parameter name="_obj" type="Object"/>
    </JadeMethod>
</Class>
