    <JadeMethod name="utlDeleteCargoForecast" id="aad80f3d-1f77-44fe-91f6-bb838a0ac02e">
        <source>utlDeleteCargoForecast(_realCargoForecast : CM_CargoForecast io; _passport : CM_Passport input);
/*

Purpose:			Utility to delete a Cargo Forecast from Real object passed in

Parameters:			_realCargoForecast	CM_CargoForecast	Real cargo forecast used to delete real object
					_passport			CM_Passport			Passport to use for our Trx that holds errors and other useful data

Return Value:		NONE

Date		Who		Reason
05 April 2022	navpw1	Initial creation TFS: 53132

*/

vars
	myParent : CM_Object;

begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	app.myValDA.valCargoForecast(_realCargoForecast);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	myParent := _realCargoForecast.myParent;

	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_realCargoForecast);
	endif;
	
	if _passport.noErrors then
		delete _realCargoForecast;
	endif;

	if _passport.noErrors and _passport.myTerminal &lt;&gt; null then
		if myParent &lt;&gt; null then
			self.updateObjectEdition(myParent);
			
		endif;
		
	endif;
	
end;</source>
        <Parameter name="_realCargoForecast" type="CM_CargoForecast" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlDeleteCargoPhoto" id="9d6fa15d-8444-454c-8f2e-5e35385d03a3">
        <source>utlDeleteCargoPhoto(_photo:CM_Photo io; _passport : CM_Passport input);
/*
----------   ----------  --------------------------------------------------
Created:	23 Nov 2009 By cnwdz2 par21808

Purpose:	CCMS1003: 

Changed On   Changed By  Reason
	
28/09/2010 cnwas3 par 25243
20 Feb 2024 navhl20 ChangeRequest 62525: EUP | Retrospective Operations - [54177.060] - Cargo &amp; Truck Checks
----------   ----------  --------------------------------------------------
*/
vars
	tiParent : CM_TrackedItem;
	taParent : CM_TerminalArea;
	beforeValue, afterValue, tmpStr : String;
begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);

	//app.myValDA.valSubTerminal(_proxySubTerminal);
	
	if (not self.checkValidationWithPassport(_passport)) then // Show any Errors and Warnings in a list
		return;
	endif;

	app.setContinueCMExceptions(false);

	if _photo.myParent &lt;&gt; null and _photo.myParent.isKindOf(CM_TrackedItem) then
		tiParent := _photo.myParent.CM_TrackedItem;
	elseif _photo.myParent &lt;&gt; null and _photo.myParent.isKindOf(CM_TerminalArea) then // ### TFS CR 58499 TASK 61455 28DEC2023 NAVAB1
		taParent := _photo.myParent.CM_TerminalArea;
	endif;
	
	//epr TFS 2227 3/8/16 
	if tiParent &lt;&gt; null then
		beforeValue := tiParent.getAttachmentsAuditText(true);	
	elseif taParent &lt;&gt; null then // ### TFS CR 58499 TASK 61455 28DEC2023 NAVAB1
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(taParent, true);
	endif;
	
	if _passport.noErrors then
		self.myDeleteAuditAgent.audDeleteGeneric(_photo);		
	endif;

	if _passport.noErrors then
		_photo.erase(NORMAL_ERASE);
	endif;
	
	if tiParent &lt;&gt; null then
		afterValue := tiParent.getAttachmentsAuditText(true);	
	
		if afterValue = null then
			tmpStr := app.getErrorString(Removed_photo) &amp; beforeValue;
		elseif beforeValue &lt;&gt; afterValue then
			tmpStr := app.formatForEditTransaction(app.getErrorString(Attached_photos_changed), beforeValue, afterValue);	
		endif;
		
		if _passport.noErrors and tmpStr &lt;&gt; null then													
			app.createEditTransaction(tiParent, tmpStr, null, _passport);			//20.02.2024 navhl20 #62525
		endif;
	elseif taParent &lt;&gt; null then // ### TFS CR 58499 TASK 61455 28DEC2023 NAVAB1
		app.myUtilityUA.myUpdateAuditAgent.audUpdateGeneric(taParent, false);
	endif;
epilog
	
end;</source>
        <Parameter name="_photo" type="CM_Photo" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
