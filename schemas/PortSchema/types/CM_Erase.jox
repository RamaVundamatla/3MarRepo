<Class name="CM_Erase" id="b427759d-4f5c-491d-843a-d558c7571f67">
    <superclass name="CM_TITransaction"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="transact"/>
    <ExplicitInverseRef name="myStockMovementOut" id="bd65e9cf-2fbe-4407-97e0-f8452dbbc01e">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_StockMovementLocation"/>
        <access>readonly</access>
        <Inverse name="CM_StockMovementLocation::allTITransactions"/>
    </ExplicitInverseRef>
    <JadeMethod name="addToStockMovement" id="ec60d93a-1431-4eab-b644-53c58e03977b">
        <updating/>
        <source>addToStockMovement(_stkMove: CM_StockMovementLocation) updating;
//-----------------------------------------
//Created: December 2002 By: cnwgd1
//-----------------------------------------
vars

begin
	if _stkMove = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unable to, null stockmove reference for ' &amp; self.String);
		return;
	endif;

	if _stkMove.isInwards then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unable to, no inwards stockMovement');	
	else
		self.myStockMovementOut := _stkMove;
	endif;

end;</source>
        <Parameter name="_stkMove" type="CM_StockMovementLocation"/>
    </JadeMethod>
    <JadeMethod name="getMyStockMovement" id="1d6c2b59-d29f-4d54-a29a-0646bf0499db">
        <source>getMyStockMovement(): CM_StockMovement;
//--------------------------------------------------------------
//Created: 10 December 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	
	return self.myStockMovementOut;		

end;</source>
        <ReturnType type="CM_StockMovement"/>
    </JadeMethod>
    <JadeMethod name="hasStockMovements" id="45bf4dd8-2b36-4ebd-be37-36c9c6ad5d5e">
        <source>hasStockMovements(): Boolean;
//-----------------------------------------
//Created: December 2002 By: cnwgd1
//-----------------------------------------
vars

begin
	if self.myStockMovementOut &lt;&gt; null then
	   	return true;
	endif;
	
	return inheritMethod();
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromCMIF_TIUpdateController" id="518118f6-f92b-48a5-8346-40c749b3547a">
        <updating/>
        <source>setFromCMIF_TIUpdateController(_tiUpdateCntrlr: CMIF_TIUpdateController; _passport : CM_Passport) updating;
//--------------------------------------------------------------
//Created: 04 October 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin 
	inheritMethod(_tiUpdateCntrlr, _passport);
	
	if (not self.deleted) then
		if self.myTerminal.getConfig (CamsCreateTrxAudit).Boolean then		// par 30855
			self.createCAMSAuditTransaction (AuditDeleted, self, app.myPassport);		// par 30855
		endif;																// par 30855		
	endif;
	
	self.deleted := true;
	self.deletedByUser := app.getMyUserCode();		// 16/10/18 MAP TFS41191
end;</source>
        <Parameter name="_tiUpdateCntrlr" type="CMIF_TIUpdateController"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
