    <JadeMethod name="cmbEntStevedore_displayEntry" id="f521211d-aa02-412c-b3a1-22f034047c86">
        <controlMethod name="CMUI_ComboBox::displayEntry"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>cmbEntStevedore_displayEntry(combobox: ComboBox input; obj: Any; lstIndex: Integer):String updating;
// ---------------------------------------------------------------------------
// Created:     30 August 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	stevedore : CM_Stevedore;
	failedDAC  :CM_DataAccessController;
begin
	stevedore := obj.CM_Stevedore;

	if stevedore = null then
		return null;
	endif;
	
	if (not stevedore.canUserAccessSelf(null, failedDAC, app.myPassport)) then
		return null;
	endif;
	
	return stevedore.code &amp; Tab &amp; stevedore.description;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
        <Parameter name="obj" type="Any"/>
        <Parameter name="lstIndex" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
