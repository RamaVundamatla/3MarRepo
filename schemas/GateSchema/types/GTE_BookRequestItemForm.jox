    <JadeMethod name="showHazardDetailsForm" id="bd8796bb-d675-4591-9420-9b78ca074cc8">
        <source>showHazardDetailsForm();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 15/11/2016	cnwdap1		Initial creation TFS 2842 STWR Hazardous Details Enhancements
//
vars
	hazards : ObjectArray;

begin
	create hazards transient;
	self.lstHazards.allSelectedObjects.copy(hazards);
	self.myAssistant.showHazardousDetailsForm(self.myTerminal, null, self.myProxyBookingRefItem, null, hazards, false, self, self.myMasterMenuAction);
epilog
	delete hazards;
end;</source>
    </JadeMethod>
