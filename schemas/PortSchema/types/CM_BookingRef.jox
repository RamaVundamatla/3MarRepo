    <JadeMethod name="getCommodityGroupStr" id="88f18879-d3e3-4243-9ef2-dae5aaef9c3e">
        <source>getCommodityGroupStr() : String;
// --------------------------------------------------------------------------------
// Created:		27 October 2009 by cnwjo3
//
// Purpose:		Return the commodity group for a booking reference.  For NFS 21418
//
// Returns:		String of Commodity Group
vars
	tmpCommodity	: CM_Commodity;
	tmpStr : String;
begin
	if self.commodity &lt;&gt; null then
		tmpCommodity := app.myRoot.allCommodities[self.commodity];
		if tmpCommodity &lt;&gt; null then
			if tmpCommodity.myCommodityGroup &lt;&gt; null then
				tmpStr := tmpCommodity.myCommodityGroup.code;
			endif;
		endif;
	endif;
	
	return tmpStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
