<Class name="JadeScript">
    <JadeMethod name="buildQueues" id="cd68cac1-e6b8-461e-a261-ed8b37f0a711">
        <source>buildQueues();

vars
	machine:Machine;
begin
	// One of the two options below should be run
	/*foreach machine in Machine.instances where machine.hostName &lt;&gt; "cnwchcs118" do
			machine.buildQueues;
	endforeach;/**/
	foreach machine in Machine.instances where machine.hostName = "cnwXchcs55" do
