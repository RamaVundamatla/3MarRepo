    <JadeMethod name="setAvailabilityGrade" id="48396960-dd19-40da-9881-4057a93d3c11">
        <updating/>
        <source>setAvailabilityGrade(_newGrade : Integer;
					_tiUpdateCntrl : CMIF_TIUpdateController input;
					_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		21 July 2003  by Jason Chapman  (cnwjc2)
// ---------------------------------------------------------------------------

vars

begin

	self.raiseExceptionIfTransient(method);
	
	exclusiveLock(self);

	if self.availabilityGrade = _newGrade then
		return;
	endif;
			
	if (not self.isTransient) then
		self.beginUpdate(_tiUpdateCntrl, _passport);
	endif;
	
	self.availabilityGrade := _newGrade;
	
	if (not self.isTransient) then
		self.endUpdate(_tiUpdateCntrl, _passport);
	endif;		

end;</source>
        <Parameter name="_newGrade" type="Integer"/>
        <Parameter name="_tiUpdateCntrl" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setAvailabilityGradeRT" id="ac7f47c3-2cab-44ad-b702-4431cdafdd59">
        <updating/>
        <source>setAvailabilityGradeRT(newGrade : Integer; _passport : CM_Passport input) updating;
/*
 ------------------------------------------------------------------------
Created:			26 July 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	txnParams : CMIF_TITransactionController;
	trans : CM_Edit;
	userStr : String;
begin

	exclusiveLock(self);

	if newGrade = self.availabilityGrade then
		return;
	endif;

/*	if app.myRoot.allAvailabilityGrades[newGrade] = null then
		app.raiseCMException2(ERR_KEY_NOT_FOUND, newGrade.String, "AvailabilityGrades", null, null);
		return;	
	endif;*/
	// CCMS 1235
	if app.myRoot.allAvailableAvailabilityGrades[newGrade] = null then
		app.raiseCMException2(ERR_KEY_NOT_FOUND, newGrade.String, "AvailabilityGrades", null, null);
		return;	
	endif;
	if _passport.userCode = null then
		userStr := app.getErrorString(UnknownUser);
	else
		userStr := _passport.userCode;
	endif;
	create txnParams transient;
	txnParams.userId := userStr;
	txnParams.dateTime := app.serverTimestampAtTrxStart;
	txnParams.noCharge := false;	//charge by default	
	txnParams.type := TRANS_TYPE_EDIT;
	//------------------
	//Create the edited transaction
	//------------------
	trans := self.createTransaction(txnParams, _passport).CM_Edit;
	trans.fieldsValues.add(CM_Container::availabilityGrade.name &amp; self.availabilityGrade.String &amp; " =&gt; " &amp; newGrade.String);
	self.availabilityGrade := newGrade;
epilog
	delete txnParams;
	unlock(self);
end;</source>
        <Parameter name="newGrade" type="Integer"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setCOUForUpdate" id="406abae1-3db4-421c-a6f5-13b91b305710">
        <updating/>
        <source>setCOUForUpdate(pProxyCOU : CM_ClipOnUnit; originalState : Integer; _tiUpdateCntrlr : CMIF_TIUpdateController input; _passport : CM_Passport input) updating, protected;
// ---------------------------------------------------------------------------
// Created:     15 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 16/09/2010	cnwdap1		PAR #25754 Update the edition on the tracked item, as this code
//							does not update any attribute on CM_TrackedItem (just CM_ReeferProperties)
//							so change tracker would not otherwise pick this up as a CM_TrackedItem update
// 29/08/2012	cnwcs5	par 30292 - use updateObjectEdition instead of updateEdition
// ---------------------------------------------------------------------------
vars
	prxyCOU,
	origCOU,
	realCOU			: CM_ClipOnUnit;
	expectedEdition	: Integer;
	aCOU: CM_ClipOnUnit;	

begin
	if self.getCou = null and pProxyCOU = null then
		// no work to do
		return;
	endif;

	if self.isTransient and
	   self.getCou = null and
	   pProxyCOU &lt;&gt; null then // AKB2002JAN added
		// i have not got a COU so attach this proxy one and get out, probably part of a container update
		prxyCOU := pProxyCOU;
		self.attachCOU(prxyCOU, _passport);
		return;
	endif;

	if self.getCou &lt;&gt; null then
		origCOU := self.getCou;
		if originalState = TI_STATE_NOTIFIED then
			//Prenoted Items: Just update the prenote COU with the proxy data
			realCOU := origCOU;
			expectedEdition := realCOU.edition;
		endif;
	endif;

	//We did have a COU attached and now we don't
	if pProxyCOU = null then
		// We must detach the original COU and erase it (if not onsite)
		if origCOU &lt;&gt; null then
			exclusiveLock(origCOU);
			self.detachCOU(_passport);		
			if originalState = TI_STATE_NOTIFIED then
				origCOU.erase(NORMAL_ERASE);
			else
				// RJS TODO - just move origCOU to default location
			endif;
		endif;
		return;
	endif;

	if pProxyCOU.cargoType &lt;&gt; TI_CargoType_COU then
		app.raiseCMException(VB_EDI_TI_NOT_COU,"", null);
		return;
	endif;

	if realCOU = null then
		if pProxyCOU.isTransient then
			//See if the COU is part of a proxy / persistent pair
			pProxyCOU.pxyGetRealObjectAndEdition(realCOU, expectedEdition);
			if realCOU = null then
				//Try a lookup
				realCOU := self.myTerminal.lookupTrackedItem(pProxyCOU.id, pProxyCOU.cargoType, originalState, null, false).CM_ClipOnUnit;
			endif;
		else
			app.raiseCMException1(NotAProxyObject,"COU " &amp; pProxyCOU.id,"", null);
		endif;
	endif;

	if realCOU = null then
		//Must create a new COU, based on the proxy
		if originalState = TI_STATE_NOTIFIED then
			aCOU := pProxyCOU;
			aCOU.setPropertyValue("isValid", true);
			realCOU := self.myTerminal.createTrackedItem(pProxyCOU, _passport).CM_ClipOnUnit;
			self.attachCOU(realCOU, _passport);
		else
			app.raiseCMException1(ProxyMgrCannotLocateReal, CM_TrackedItem.name, null, null);
			return;
		endif;

	else
		if realCOU &lt;&gt; null then // AKB2002JAN added
			exclusiveLock(realCOU);
			if realCOU = origCOU then
				//Check that it hasn't been updated meantime
				//if app.noErrors and realCOU.edition &lt;&gt; expectedEdition then
				//	app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Tracked Item COU', null, null);
				//	return;
				//endif;
			endif;
	
			if realCOU.myReefer &lt;&gt; null then // AKB2002JAN added
				if realCOU.myReefer &lt;&gt; self then
					// COU is already attached to another container
					app.raiseCMException2(ERR_DUPLICATE_CHILD, 'COU ' &amp; realCOU.id, 'Container ' &amp; realCOU.CM_ClipOnUnit.myReefer.id, null, null);
					return;
				endif;
			endif;

			if realCOU &lt;&gt; origCOU then
				// the original COU has been replaced with another COU
				//Detach the old COU and attach the new COU
				//OR there was no original COU to begin with
				if origCOU &lt;&gt; null then
					exclusiveLock(origCOU);
					self.detachCOU(_passport);		//Works even if origCOU is null			
				endif;
				// RJS TODO - need to move orig to default location
				self.attachCOU(realCOU, _passport);
			endif;
		endif;
		aCOU := pProxyCOU;
		aCOU.setPropertyValue("isValid", true);
		realCOU.setFromPxy(pProxyCOU, _tiUpdateCntrlr, _passport);
	endif;
	
	// PAR #25754 udpate edition so change tracker gets this change
	self.updateObjectEdition(self);		// par 30292

end;</source>
        <access>protected</access>
        <Parameter name="pProxyCOU" type="CM_ClipOnUnit"/>
        <Parameter name="originalState" type="Integer"/>
        <Parameter name="_tiUpdateCntrlr" type="CMIF_TIUpdateController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
