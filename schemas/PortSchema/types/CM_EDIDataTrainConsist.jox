    <JadeMethod name="setupCMIFAndValidate" id="5d67df49-b268-47df-a8ea-0969ba0dc9ba">
        <source>setupCMIFAndValidate(_passport : CM_Passport input;
						_progressStrInteger : Integer;
						_cmifConsist : CMIF_TrainConsist input);
// --------------------------------------------------------------------------------
// Created:		17 February 2010 by cnwdad1
//
// Purpose:		Populates the CMIF object with the Trains, Wagons and Prenotes.
//
// Parameters:	_passport - A reference to the current User's Passport object.
//				_progressStrInteger - ID of the Progress translation description.
//				_cmifConsist - The CMIF object containing the Trains, Wagons and
//					Prenotes to set up and validate.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 31/03/2010	cnwdad1		PAR #23489.
// 08/04/2011	cnwmh5		PAR #27347 - Add cmsEndLoad or endLoad to epilog so that if error occurs it will not leave it in beginLoad state
//14 Feb 2013	cnwrs1	Par 31143 EDI TRX not handling dbLoadErrors after no verify errors take 3
//28 Apr 2016   cnwma1      PAR #37237  TFS #1771 Attempted access via null object reference error appearing in Train Consist EDI loading
// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// 05 Jul 2017	jlgrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
// 20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
// 20 June 2023 navra1	TFS 57808 EUP - Manifest Processing - Train - Create
// 19 July 2023 navra1	TFS 57808 EUP - Manifest Processing - Train - Create - Changed Requirements
// 06/10/2023	navcs2		Bug 60776: EUP | FR 53824 - Transport Manifest - Duplicate Item IDs for different Cargo Group IDs
// 13 Nov 2023	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
// 15 Dec 2023	navsaa30 Bug 61219: EUP | FR - 53824 Transport Manifest - Verifying Train File Causes 1090 Error
// --------------------------------------------------------------------------------
vars
	partsDone			: Integer;
	partsInJob			: Integer;
	progressMsg			: String;
	progressTS			: TimeStamp;
	ediAction			: String;
	trainCode			: String;
	schedArrivalDT		: TimeStamp;
	wagonCode			: String;
	cargoWagon			: String;
	ediTI 				: CM_EDITrackedItem;
	trainTI				: CM_EDITrainTI;
	wagonTI				: CM_EDIWagonTI;
	prenoteTI			: CM_EDIPrenoteTI;
	realTrain			: CM_Train;
	pxyTrain			: CM_Train;
	realWagon			: CM_Wagon;
	pxyWagon			: CM_Wagon;
	cmifPrenoteObj		: CMIF_PreNote;
	realPrenote			: CM_TrackedItem;
	proxyPrenote		: CM_TrackedItem;
	realParentPrenote   : CM_TrackedItem;
	cmifParent			: CMIF_PreNote;
	sortedDict 			: DynaDictionary;
	iter				: Iterator;
	classOrder			: Integer;
	recordNumber		: Integer; //cnwgb1 9.2.2011 par 26930
	wagonClass			: CM_WagonClass;	//25 Aug 2015	NDL	Par 36644
	allEDISealDetails 	: DynaDictionary;
	sealIter 			: Iterator;
	sealObj 			: CM_EDITrackedItem;
	ediPrenote 			: CM_EDIPrenoteTI;
	prenoteTIs 			: CM_EDITIById;	
	allHazardDetails 	: DynaDictionary;					//navra1 - TFS 57808 - 20th June 2023
	hazDetIter 			: Iterator;							//navra1 - TFS 57808 - 20th June 2023
	hazDetObj 			: CM_EDITrackedItem;				//navra1 - TFS 57808 - 20th June 2023
	allHazardCodes 		: CM_HazardClassByCodeDict;			//navra1 - TFS 57808 - 20th June 2023
	tiHaz				: CM_TIHazard;						//navra1 - TFS 57808 - 20th June 2023	
	termDupsAllowed		: Boolean;
begin
	// Arm our base exception handlers
	on Exception do validationExceptionHandler(exception, _passport);
	
	app.setContinueCMExceptions(true);	// get as many error messages in 1 go as possible
	
	create prenoteTIs transient;
	
	partsInJob		:=	self.allEDITrackedItems.size();
	partsDone		:=	0;
		
	if _cmifConsist.myTerminal = null then
		// should never happen but just in case!
		app.raiseCMException1(Err_InvalidTerminal, null, null, null);
		return;
	endif;
	
	termDupsAllowed := _cmifConsist.myTerminal.getConfig(AllowDuplicatePreNotes).Boolean;
	
	if app.getMyUser() = null then
		// should never happen but just in case!
		app.raiseCMException(UnknownUser, null, null);
		return;
	endif;
	
	progressTS	:=	app.actualTimeServer();// 13 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	progressMsg	:=	app.getString(_progressStrInteger, partsInJob.display);
	
	self.updateProgress(progressTS, progressMsg, partsInJob, partsDone, true, _passport);
	
	create allEDISealDetails transient;
	allEDISealDetails.setMembership(CM_EDISealTI);
	allEDISealDetails.addMemberKey( CM_EDISealTI::id.name, false, true ); 
	allEDISealDetails.endKeys(true);
	
	//navra1 - TFS 57808 - 20th June 2023 - start
	create allHazardDetails transient;
	allHazardDetails.setMembership(CM_EDIHazDetailsTI);
	allHazardDetails.addMemberKey(CM_EDIHazDetailsTI::code.name, false, true); 
	allHazardDetails.endKeys(true);
	//navra1 - TFS 57808 - 20th June 2023 - end
	
	//cnwgb1 PAR 23419 15.4.2010
	create sortedDict transient;
	sortedDict.setMembership(CM_EDITrackedItem);
	sortedDict.addExternalKey(Integer,4,false,false); // Class Order Trains then Wagons then Prenotes
	sortedDict.addExternalKey(Integer,4,false,false); // Sort Order within class (makes sure child prenotes are after parents
	sortedDict.addExternalKey(Integer,4,false,false); // cnwgb1 PAR 26930 11.2.2011 Record order to keep the original file order of wagons (&amp; top-level prenotes).
	sortedDict.endKeys(true);
	recordNumber := 1; //cnwgb1 9.2.2011 par 26930
	foreach ediTI in self.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDISealTI) then
			classOrder := 3;
			allEDISealDetails.add(ediTI);
		elseif ediTI.isKindOf(CM_EDIHazDetailsTI) then	//navra1 - TFS 57808 - 20th June 2023
			classOrder := 3;							//navra1 - TFS 57808 - 20th June 2023
			allHazardDetails.add(ediTI);				//navra1 - TFS 57808 - 20th June 2023			
		elseif ediTI.isKindOf(CM_EDIPrenoteTI) then
			classOrder := 3;
			prenoteTIs.add(ediTI);
		elseif ediTI.isKindOf(CM_EDIWagonTI) then
			classOrder := 2;
		elseif ediTI.isKindOf(CM_EDITrainTI) then
			classOrder := 1;
		endif;
		sortedDict.putAtKey(classOrder, ediTI.getSortOrder(), recordNumber, ediTI); //cnwgb1 9.2.2011 par 26930 Add recordNumber key
		recordNumber := recordNumber+1; //cnwgb1 9.2.2011 par 26930
	endforeach;
	
	if not allEDISealDetails.isEmpty then
		sealIter := allEDISealDetails.createIterator;
		while sealIter.next(sealObj) do
			sealObj.CM_EDISealTI.sealEDITypeVerify;
			sealObj.CM_EDISealTI.sealEDINumVerify;
			if sealObj.myParent &lt;&gt; null then
				continue;
			endif;
			ediPrenote := prenoteTIs[sealObj.id].CM_EDIPrenoteTI;
			if ediPrenote = null then
				continue;
			endif;
			app.myTrxUA.trxUpdateEDITIParent(sealObj, ediPrenote, _passport);
		endwhile;
		delete sealIter;
	endif;
	
	//navra1 - TFS 57808 - 20th June 2023 - start
	if not allHazardDetails.isEmpty then
		hazDetIter := allHazardDetails.createIterator;
		allHazardCodes := app.myRoot.allHazardClasses;
		while hazDetIter.next(hazDetObj) do
			if hazDetObj.CM_EDIHazDetailsTI.code = null or allHazardCodes[hazDetObj.CM_EDIHazDetailsTI.code] = null then
				app.raiseCMWarning2(Hazard_code_not_found, hazDetObj.CM_EDIHazDetailsTI.code, 'Haz Code', null, self, self);				
			endif;			
			if hazDetObj.myParent &lt;&gt; null then
				continue;
			endif;
			//the id of the hazTI is the id of the prenoteTI, so use that to fetch the prenoteTI to make as parent
			ediPrenote := prenoteTIs[hazDetObj.id].CM_EDIPrenoteTI;
			if ediPrenote = null then
				continue;
			endif;
			app.myTrxUA.trxUpdateEDITIParent(hazDetObj, ediPrenote, _passport);
		endwhile;
		delete hazDetIter;
	endif;
	//navra1 - TFS 57808 - 20th June 2023 - end

	iter := sortedDict.createIterator();
	
	// Read all of the EDI trackeditems and create proxies of them.
	while iter.next(ediTI) do
//write class.name&amp;'::'&amp;method.name&amp;' '&amp;ediTI.String&amp;' '&amp;ediTI.id;
		ediAction			:=	ediTI.messageMode;
		partsDone			:=	partsDone + 1;
		self.updateProgress(progressTS, progressMsg, partsInJob, partsDone, false, _passport);
		
		if ediTI.isKindOf(CM_EDITrainTI) then
			trainTI	:=	ediTI.CM_EDITrainTI;
			
			if _cmifConsist.myProxyTrain &lt;&gt; null then
				app.raiseCMException(TrainConsist_MustHaveOneTrain, ETRow_Id, null);
			endif;
			
			realTrain	:=	_cmifConsist.getTrainFromTerminal(	trainTI.trainCode,
																trainTI.scheduledArrivalDT);
			
			if ediAction = CM_EDITrackedItem.EDI_ACTION_DELETE then
				if realTrain = null then
					// Train not found error.
					app.raiseCMException2(	Train_DoesNotExist_ForTerminal,
											trainTI.trainCode,
											self.getMyTerminal().name,
											ETRow_Id,
											null);
					return;
				endif;
			else
				if realTrain = null then
					ediAction	:=	CM_EDITrackedItem.EDI_ACTION_ADD;
				else
					ediAction	:=	CM_EDITrackedItem.EDI_ACTION_UPDATE;
				endif;				
			endif;		
			
			//navra1 - TFS 57808 - 19th July 2023 - start			
			//it cannot be an ADD if it was the null train that was being referred to, and return the null train if he couldnt find it			
			if trainTI.trainCode = NULL_TRAIN_CODE then
				ediAction	:=	CM_EDITrackedItem.EDI_ACTION_UPDATE;			
				
				if realTrain = null then
					if trainTI.getMyTerminal() &lt;&gt; null then
						realTrain := trainTI.getMyTerminal().getNullTrain();
					endif;
				endif;			
			endif;
			//navra1 - TFS 57808 - 19th July 2023 - end
			
			if realTrain = null then
				create pxyTrain transient;
			else
				beginLoad;
				pxyTrain	:=	realTrain.pxyCreateUpdateProxy();
				endLoad;
			endif;
			
			trainTI.setTrainProxy(pxyTrain);
			
			trainCode		:=	pxyTrain.code;
			schedArrivalDT	:=	pxyTrain.scheduledArrivalDT;
			
			_cmifConsist.trainCode			:=	trainCode;
			_cmifConsist.scheduledArrivalDT	:=	schedArrivalDT;
			_cmifConsist.myRealTrain		:=	realTrain;
			_cmifConsist.myProxyTrain		:=	pxyTrain;
			_cmifConsist.trainAction		:=	ediAction;
			
		elseif ediTI.isKindOf(CM_EDIWagonTI) then
			wagonTI		:=	ediTI.CM_EDIWagonTI;
			realWagon	:=	null;
			pxyWagon	:=	null;
			wagonClass	:= null;	//25 Aug 2015	NDL	Par 36644
			wagonCode	:=	wagonTI.wagonNumber;
			if wagonTI.wagonClass &lt;&gt; null then	//25 Aug 2015	NDL	Par 36644
				wagonClass := app.myRoot.allWagonClasses.getAtKey( wagonTI.wagonClass );
			endif;
			
			// Check that we haven't already come across this Wagon before creating a proxy.
			if _cmifConsist.isWagonAlreadyUsed(wagonTI.wagonNumber) then
				app.raiseCMException1(	Wagon_Only_Once_Per_Msg,
										wagonTI.wagonNumber,
										ETRow_Id,
										null);
				continue;
			endif;
			
			if realTrain &lt;&gt; null then
				realWagon	:=	realTrain.allWagonsByIdInward[wagonTI.wagonNumber];
			endif;
			
			if realWagon = null then
				//create pxyWagon transient;
				create pxyWagon as app.getWagonVisitClassToCreate( wagonClass, wagonTI.myEDIData.ediConfig.myTerminal, wagonTI.wagonNumber, null ) transient;	//15 Mar 2013	NDL	Par 31278
			else
				beginLoad;
				pxyWagon	:=	realWagon.pxyCreateUpdateProxy();
				endLoad;
			endif;
			
			if ediAction = CM_EDITrackedItem.EDI_ACTION_ADD then
				if realWagon &lt;&gt; null then
					ediAction	:=	CM_EDITrackedItem.EDI_ACTION_UPDATE;
				endif;

			elseif ediAction = CM_EDITrackedItem.EDI_ACTION_UPDATE then
				if realWagon = null then
					ediAction	:=	CM_EDITrackedItem.EDI_ACTION_ADD;
				endif;
				
			elseif ediAction = CM_EDITrackedItem.EDI_ACTION_DELETE then
				if realWagon = null then
					continue;
				endif;
			endif;
			
			if ediAction = CM_EDITrackedItem.EDI_ACTION_UPDATE then
				if _cmifConsist.allWagonsToDelete[wagonTI.wagonNumber, schedArrivalDT] &lt;&gt; null then
					app.raiseUnexpectedProgramError(class.name, method.name, "Wagon " &amp; wagonTI.wagonNumber &amp; " cannot be updated if it is already being deleted.");
				endif;
			
			elseif ediAction = CM_EDITrackedItem.EDI_ACTION_DELETE then
				if _cmifConsist.allWagonsToUpdate[wagonTI.wagonNumber, schedArrivalDT] &lt;&gt; null then
					app.raiseUnexpectedProgramError(class.name, method.name, "Wagon " &amp; wagonTI.wagonNumber &amp; " cannot be deleted if it is already being updated.");
				elseif _cmifConsist.allWagonsToDelete[wagonTI.wagonNumber, schedArrivalDT] &lt;&gt; null then
					// We're already deleting this one, so ignore this TI.
					continue;
				endif;
			endif;
			
			wagonTI.setWagonProxy(pxyWagon);
			pxyWagon.setMyTrain(true, _cmifConsist.myProxyTrain);
			pxyWagon.setMyTrain(false, _cmifConsist.myProxyTrain);	// cnwdad1 31/03/2010 - PAR #23489.			
			//pxyWagon.setDateTime(_cmifConsist.myProxyTrain.scheduledArrivalDT);		//28/04/2016 cnwma1 PAR #37237 TFS #1771
			if _cmifConsist.myProxyTrain &lt;&gt; null then									//28/04/2016 cnwma1 PAR #37237 TFS #1771
				pxyWagon.setDateTime(_cmifConsist.myProxyTrain.scheduledArrivalDT);
			endif;
			if _cmifConsist.allWagonsToAdd.getAtKey(pxyWagon.id, schedArrivalDT) &lt;&gt; null
			or _cmifConsist.allWagonsToDelete.getAtKey(pxyWagon.id, schedArrivalDT) &lt;&gt; null
			or _cmifConsist.allWagonsToUpdate.getAtKey(pxyWagon.id, schedArrivalDT) &lt;&gt; null
			then
				app.raiseCMException1(	Wagon_Only_Once_Per_Msg,
										pxyWagon.id,
										ETRow_Id,
										null);
			endif;
			
			if ediAction = CM_EDITrackedItem.EDI_ACTION_ADD then
				_cmifConsist.allWagonsToAdd.add(pxyWagon);
				_cmifConsist.allWagonsToAddUnsorted.add(pxyWagon); //cnwgb1 11.2.2011 Par 26930
			elseif ediAction = CM_EDITrackedItem.EDI_ACTION_DELETE then
				_cmifConsist.allWagonsToDelete.add(pxyWagon);
			elseif ediAction = CM_EDITrackedItem.EDI_ACTION_UPDATE then
				_cmifConsist.allWagonsToUpdate.add(pxyWagon);
			endif;
			
			if not self.validateWagonTI(_cmifConsist, wagonTI) then
				continue;
			endif;
			
		elseif ediTI.isKindOf(CM_EDIPrenoteTI) then
			prenoteTI	:=	ediTI.CM_EDIPrenoteTI;
			/* 
			06/10/2023	navcs2	Bug 60776 Start
			*/
			//if termDupsAllowed and ediTI.myCargoType.allowDuplicates then
			//	continue;
			//endif;
			if not self.validateIfPrenoteExists(_cmifConsist, prenoteTI) then
				continue;
			endif;
			/* 
			06/10/2023	navcs2	Bug 60776 End
			*/
			realPrenote	:=	_cmifConsist.getCargoFromTerminal(prenoteTI.cargoType, prenoteTI.id.toUpper());			 // 13 Nov 2023  jlirs1  TFS 60575 - Jade 2022 upgrade fixing unitTests 
			if realPrenote &lt;&gt; null and                                                                  			 //14/11/2023  navcs2  Bug 60776 End
			   realPrenote.getMyCargoGroupId() &lt;&gt; null and															// 29 Jan 2024	jlirs1	TFS 60575 - Jade 2022 upgrade fixing unitTests
			  (realPrenote.getMyCargoGroupId() &lt;&gt; ediTI.getCargoGroupId() or                            			 //15/12/2023 navsaa30 #61219
				realPrenote.receiptTransportMode &lt;&gt; TI_TRANSMODE_RAIL) then																	
					realPrenote := null;
			endif;
			
			if prenoteTI.myEDIData.isTransportManifestRelated() and prenoteTI.myEDIData.CM_EDIDataTrainConsist.myTransportManifest.statusString = CMIF_JsonHeaderEUP.Status_Cancel then
				ediAction := prenoteTI.messageMode;
			else
				ediAction := prenoteTI.normaliseAction(realPrenote);
			endif;			
			
			if not self.validatePrenoteTI(_cmifConsist, prenoteTI, ediAction) then
				continue;
			endif;

			//epr TFS 6980 26/9/17 removed unused products param
			cmifPrenoteObj := prenoteTI.createCMIF(_cmifConsist.allPrenotesToProcess, realPrenote );
		elseif ediTI.isKindOf(CM_EDISealTI) then
			if cmifPrenoteObj &lt;&gt; null then
				ediTI.CM_EDISealTI.setSealNumCMIFReceive(cmifPrenoteObj);
			endif;
		elseif ediTI.isKindOf(CM_EDIHazDetailsTI) then								//navra1 - TFS 57808 - 20th June 2023		
			if cmifPrenoteObj &lt;&gt; null then 											//navra1 - TFS 57808 - 20th June 2023		
				create tiHaz transient;												//navra1 - TFS 57808 - 20th June 2023		
				tiHaz.setPxyFromEDI(ediTI.CM_EDIHazDetailsTI);						//navra1 - TFS 57808 - 20th June 2023		
				cmifPrenoteObj.allTIHazards.addNoDuplicates(tiHaz, false);			//navra1 - TFS 57808 - 20th June 2023		
			endif;																	//navra1 - TFS 57808 - 20th June 2023		
		else
			// have some unknown data type - stop now - this should never happen.
			app.raiseUnexpectedProgramError(class.name, method.name, "Unknown EDI Class for Train Consist");
			return;					// no point continuing
		endif;
	endwhile;
	
	// Do specific EDI validation here, the actual Train Consist validation is done later.
	if _passport.noErrors() then
		self.validateTrainAndWagons(_cmifConsist);
	endif;
	
	_cmifConsist.myEDIDataTrainConsist := self;	//17 Mar 2015	NDL	Par 35828
	
	self.updateProgress(progressTS, progressMsg, partsInJob, partsDone, true, _passport);
epilog
	endLoad;				// 08/04/2011 cnwmh5 #27347
	delete sortedDict;
	delete iter;
	delete allEDISealDetails;
	delete sealIter;
	delete prenoteTIs;
	delete hazDetIter;					//navra1 - TFS 57808 - 20th June 2023
	delete allHazardDetails;			//navra1 - TFS 57808 - 20th June 2023
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_progressStrInteger" type="Integer"/>
        <Parameter name="_cmifConsist" type="CMIF_TrainConsist" usage="input"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="dd4dd266-42f6-4c2a-9354-3ad6b2107f0d">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
//
// 11 Aug 2016	cnwrs1	Par 38117 make deleted EDI for finable
//
vars
	propName : String;
begin
	if _property = null then
		return false;
	endif;
	propName := _property.name;
	if propName = CM_EDIDataTrainConsist::currentTrainCode.name or
	   propName = CM_EDIDataTrainConsist::currentWagonCode.name then
		return false;
	endif;
	return inheritMethod(_rootClass, _property);
end;
</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateIfPrenoteExists" id="b69e270b-58c4-479a-a716-11b82e117fe7">
        <source>validateIfPrenoteExists(_cmifConsist:CMIF_TrainConsist; _prenoteTI:CM_EDIPrenoteTI):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		26 March 2010 by cnwdad1
//
// Purpose:		Validates whether the specified EDI Prenote TI has already been processed.
//
// Parameters:	_cmifConsist - A reference to the current Train Consist object.
//				_prenoteTI - A reference to the EDI Prenote TI to validate.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//	05 Feb 2018	NDL			TFS 36949
// --------------------------------------------------------------------------------

vars

	cmifObject : CMIF_TIObject;
	termDupsAllowed : Boolean;
	userObj : Object;
	cargoType : Integer;
	wagonId : String;
	cargoTypeObj : CM_CargoType;
	cargoGroupId : String;
	
begin

	termDupsAllowed := self.getMyTerminal.getConfig(AllowDuplicatePreNotes).Boolean;

	foreach cmifObject in _cmifConsist.allPrenotesToProcess where cmifObject.isKindOf(CMIF_PreNote) do
		if cmifObject.getID() = _prenoteTI.id then
		
			if termDupsAllowed then
		
				wagonId := cmifObject.CMIF_PreNote.wagon;
			
				userObj := cmifObject.myUserObject;
				if userObj &lt;&gt; null and userObj.isKindOf( CM_EDIPrenoteTI) then
					cargoTypeObj := userObj.CM_EDIPrenoteTI.getCargoTypeObj;
					cargoGroupId := userObj.CM_EDIPrenoteTI.cargoGroupId;
				endif;
				
				if cargoTypeObj &lt;&gt; null then
					
					if cargoTypeObj.useCargoGroupForUniqueness then
						// cargo id can be the same as long as the cargo group is differnet
						if cargoGroupId &lt;&gt; _prenoteTI.cargoGroupId then
							// different cargo groups, all good
							return true;
						endif;
					endif;
						
					if ( _prenoteTI.getCargoTypeObj &lt;&gt; null and cargoTypeObj &lt;&gt; _prenoteTI.getCargoTypeObj ) then
						//different cargo types all good.
						return true;
						
					elseif cargoTypeObj.allowDuplicates then
						//same cargo type, which allows dups
						if ( wagonId &lt;&gt; null and _prenoteTI.wagonNumber &lt;&gt; null and wagonId &lt;&gt; _prenoteTI.wagonNumber ) then
							//different wagons all good.
							return true;
						endif;
						
					endif;
					
				endif;
			
			endif;
			
			app.raiseCMException1(	Cargo_Once_Per_Msg,
									_prenoteTI.id,
									ETRow_Id,
									null);
			return false;
		endif;
	endforeach;

	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_cmifConsist" type="CMIF_TrainConsist"/>
        <Parameter name="_prenoteTI" type="CM_EDIPrenoteTI"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validatePrenoteTI" id="5ad29f47-2727-4d3b-a973-16328a2fe018">
        <source>validatePrenoteTI(	_cmifConsist:CMIF_TrainConsist;
					_prenoteTI:CM_EDIPrenoteTI;
					_msgMode:String):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		17 February 2010 by cnwdad1
//
// Purpose:		Validates the specified EDI Prenote TI.
//
// Parameters:	_cmifConsist - A reference to the current Train Consist object.
//				_prenoteTI - A reference to the EDI Prenote TI to validate.
//				_msgMode - The action to be taken for this Prenote.
//
// Returns:		True if the Prenote TI is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//29/08/2018	JLGNS1	Bug 40008: PEN - Restrict Operator Issue - removed TFS2749
// --------------------------------------------------------------------------------
vars
	currentTrain	: CM_Train;
	trainCode		: String;
	scheduleDT		: String;
	carrier			: CM_Carrier;
	operator		: CM_Operator;
	dac				: CM_DataAccessController;
	operatorStr		: String;
begin
	currentTrain	:=	_cmifConsist.getCurrentTrain();
	
	if currentTrain = null then
		trainCode	:=	app.getString(Unknown);
		scheduleDT	:=	app.getString(Unknown);
	else
		trainCode	:=	currentTrain.code;
		scheduleDT	:=	currentTrain.scheduledArrivalDT.asStringJMT();
		carrier		:=	currentTrain.myCarrier;
		if carrier &lt;&gt; null then			// 18/9/17 MAP TFS2749
			operator := self.myOperator;
			if operator &lt;&gt; null then
				operatorStr := operator.description;
			endif;
			if not carrier.canCarrierAccessForOperator(operator, dac, true) then
				app.raiseCMException2(Carri_does_not_have_acces_oper, carrier.description, operatorStr, null, null);
				return false;
			endif;
		endif;
	endif;

	if _cmifConsist.trainAction = CM_EDITrackedItem.EDI_ACTION_DELETE
	and _msgMode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_DELETE
	then
		app.raiseCMException3(	Prenote_Cannot_Add_Or_Update,
								_prenoteTI.id,
								trainCode,
								scheduleDT,
								ETRow_Id,
								null);
	endif;
	
	if not _cmifConsist.isWagonOnTrain(_prenoteTI.wagonNumber) then
		app.raiseCMException4(	Prenote_Wagon_Not_On_Train,
								_prenoteTI.wagonNumber,
								_prenoteTI.id,
								trainCode,
								scheduleDT,
								ETRow_Id,
								null);
	endif;
	
	if _msgMode = null then
		app.raiseCMException1(	Prenote_Not_Exist_For_UpdDel,
								_prenoteTI.id,
								ETRow_Id,
								null);
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_cmifConsist" type="CMIF_TrainConsist"/>
        <Parameter name="_prenoteTI" type="CM_EDIPrenoteTI"/>
        <Parameter name="_msgMode" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateTrainAndWagons" id="b656eabe-4672-4d80-b8f9-fd7e79f9ec01">
        <source>validateTrainAndWagons(_cmifConsist : CMIF_TrainConsist) protected;
// --------------------------------------------------------------------------------
// Created:		17 February 2010 by cnwdad1
//
// Purpose:		Validates the trains and wagons being processed by this Train Consist.
//
// Note: We may be adding, updating or deleteing a Train and one or more Wagons.
//
// Parameters:	_cmifConsist - The CMIF object containing the Trains and Wagons to
//					validate.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	pxyTrain		: CM_Train;
	pxyWagon		: CM_Wagon;
	terminalObj		: CM_Terminal;
	allWagons		: CM_WagonByIdDict;
	
begin
	app.setContinueCMExceptions(true);	// Get as many error messages in 1 go as possible.
	
	terminalObj	:=	self.getMyTerminal();
	
	// Validate the train.
	
	pxyTrain	:=	_cmifConsist.myProxyTrain;
	
	if pxyTrain = null then
		if _cmifConsist.trainAction = CM_EDITrackedItem.EDI_ACTION_UPDATE
		or _cmifConsist.trainAction = CM_EDITrackedItem.EDI_ACTION_DELETE
		then
			app.raiseCMException2(	Train_DoesNotExist_ForTerminal,
									_cmifConsist.trainCode,
									terminalObj.code,
									ETRow_Id,
									null);
		endif;
	endif;
	
	// Validate the wagons to add.
	
	create allWagons transient;
	
	foreach pxyWagon in _cmifConsist.allWagonsToAdd do
		self.validateWagon(_cmifConsist, pxyWagon, pxyTrain, allWagons);
	endforeach;
	
	allWagons.clear();
	
	foreach pxyWagon in _cmifConsist.allWagonsToDelete do
		self.validateWagon(_cmifConsist, pxyWagon, pxyTrain, allWagons);
	endforeach;
	
	allWagons.clear();
	
	foreach pxyWagon in _cmifConsist.allWagonsToUpdate do
		self.validateWagon(_cmifConsist, pxyWagon, pxyTrain, allWagons);
	endforeach;
epilog
	delete allWagons;
end;</source>
        <access>protected</access>
        <Parameter name="_cmifConsist" type="CMIF_TrainConsist"/>
    </JadeMethod>
    <JadeMethod name="validateWagon" id="05d61126-9eed-46b0-b98a-623882192824">
        <source>validateWagon(	_cmifConsist:CMIF_TrainConsist;
				_pxyWagon:CM_Wagon;
				_pxyTrain:CM_Train;
				_allWagons:CM_WagonByIdDict input):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		17 February 2010 by cnwdad1
//
// Purpose:		Validates the specified Wagon.
//
// Parameters:	_cmifConsist - A reference to the current Train Consist CMIF.
//				_pxyWagon - A reference to the proxy Wagon to validate.
//				_pxyTrain - The proxy Train which the Wagon belongs to.
//				_allWagons - A collection of Wagons already validated.
//
// Returns:		True if the Wagon is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Check have not got a duplicate wagon id.
	
	if _allWagons.includesKey(_pxyWagon.id) then
		app.raiseCMException2(Wagon_with_alread_exists_train, _pxyWagon.id, _pxyTrain.code, ETRow_TrainCode, null);
		return false;
	endif;
	
	_allWagons.addNoDuplicates(_pxyWagon, true);
	
	if _pxyWagon.myTrainInwards = null then
		app.raiseCMException2(ERROR_NO_TRAIN, _pxyWagon.id, null, ETRow_TrainCode, null);
		return false;
	endif;
	
	if _pxyWagon.myTrainInwards.code &lt;&gt; _pxyWagon.myTrainInwards.code.toUpper() then
		app.raiseCMException2(WagonTrain_MustBeUpperCaseOnly, _pxyWagon.id, _pxyWagon.myTrainInwards.code, ETRow_TrainCode, null);
	endif;
	
	if _pxyWagon.myTrainInwards.code &lt;&gt; NULL_TRAIN_CODE
	and _pxyWagon.myTrainInwards.code &lt;&gt; _pxyTrain.code
	then
		app.raiseCMException2(WagonTrainCode_MustEqual_Train, _pxyWagon.id, _pxyTrain.code, ETRow_TrainCode, null);
		return false;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_cmifConsist" type="CMIF_TrainConsist"/>
        <Parameter name="_pxyWagon" type="CM_Wagon"/>
        <Parameter name="_pxyTrain" type="CM_Train"/>
        <Parameter name="_allWagons" type="CM_WagonByIdDict" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateWagonTI" id="cfab06f6-bfae-48a3-bc2e-afd345599e85">
        <source>validateWagonTI(_cmifConsist:CMIF_TrainConsist; _wagonTI:CM_EDIWagonTI):Boolean protected;
// --------------------------------------------------------------------------------
// Created:		17 February 2010 by cnwdad1
//
// Purpose:		Validates the specified EDI Wagon TI.
//
// Parameters:	_cmifConsist - A reference to the current Train Consist object.
//				_wagonTI - A reference to the EDI Wagon TI to validate.
//
// Returns:		True if the Wagon TI is valid, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// This Wagon's Train is the Train specified for the Train Consist message.
	
	if _cmifConsist.trainAction = CM_EDITrackedItem.EDI_ACTION_ADD then
//		if _wagonTI.messageMode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_ADD then
		if _cmifConsist.allWagonsToAdd[_wagonTI.wagonNumber, _cmifConsist.scheduledArrivalDT] = null then
			app.raiseCMException3(	Wagon_Cannot_Update_Or_Delete,
									_wagonTI.wagonNumber,
									_cmifConsist.trainCode,
									_cmifConsist.scheduledArrivalDT.asStringJMT(),
									ETRow_Id,
									null);
		endif;
	endif;
	
	if _cmifConsist.trainAction = CM_EDITrackedItem.EDI_ACTION_DELETE then
	//and _wagonTI.messageMode &lt;&gt; CM_EDITrackedItem.EDI_ACTION_DELETE
		if _cmifConsist.allWagonsToDelete[_wagonTI.wagonNumber, _cmifConsist.scheduledArrivalDT] = null then
			app.raiseCMException3(	Wagon_Cannot_Add_Or_Update,
									_cmifConsist.trainCode,
									_cmifConsist.scheduledArrivalDT.asStringJMT(),
									_wagonTI.wagonNumber,
									ETRow_Id,
									null);
		endif;
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <Parameter name="_cmifConsist" type="CMIF_TrainConsist"/>
        <Parameter name="_wagonTI" type="CM_EDIWagonTI"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
