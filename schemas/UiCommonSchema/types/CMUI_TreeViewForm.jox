    <JadeMethod name="timerEvent" id="492d81cf-ee6c-4fc3-8dab-71f19a21d8ec">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
/*
----------   ----------  --------------------------------------------------
Created:	24 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	menuEntity			: CM_MenuEntity;
	idx					: Integer;
begin
	if eventTag &lt;&gt; self.TIMER_OPENFOLDER then
		return;
	endif;
	
	idx := self.lstTree.listIndex;
	if idx &lt; 0 or idx &gt; self.lstTree.listCount then
		return;
	endif;
	
	if self.lstTree.itemHasSubItems(idx) and (self.lstTree.itemExpanded[idx] = false) then
		self.lstTree.itemExpanded[idx] := (true);
	endif;
end;


</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="90dacb76-9377-4176-9cbe-121e7c532d11">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 27 October 2016 09:01:26.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017518, locale);
	btnAddChild.translateCaption(Xlat_0005376, locale);
	btnAddParent.translateCaption(Xlat_0005377, locale);
	btnDelete.translateCaption(Xlat_0005378, locale);
	btnDockFrame.translateCaption(Xlat_0005379, locale);
	btnEdit.translateCaption(Xlat_0005380, locale);
	btnFloat.translateCaption(Xlat_0005381, locale);
	btnHideFrame.translateCaption(Xlat_0005382, locale);
	btnHideSearch.translateCaption(Xlat_0005383, locale);
	btnNew.translateCaption(Xlat_0005384, locale);
	btnNext.translateBubbleHelp(Xlat_0005385, locale);
	btnNext.translateCaption(Xlat_0005386, locale);
	btnSearch.translateCaption(Xlat_0005387, locale);
	btnSelectAll.translateBubbleHelp(Xlat_0005388, locale);
	btnSelectAll.translateCaption(Xlat_0005389, locale);
	btnShowSearch.translateCaption(Xlat_0005390, locale);
	lblItemInfo.translateCaption(Xlat_0005391, locale);
	mnuActsApplied.translateCaption(Xlat_0021375, locale);
	mnuAddChildItem.translateCaption(Xlat_0008218, locale);
	mnuAddChildItems.translateCaption(Xlat_0008219, locale);
	mnuAddPeerItem.translateCaption(Xlat_0008220, locale);
	mnuAddPeerItems.translateCaption(Xlat_0008221, locale);
	mnuCloseOnSave.translateCaption(Xlat_0008222, locale);
	mnuDockFrame.translateCaption(Xlat_0008223, locale);
	mnuDockFrameSub.translateCaption(Xlat_0008224, locale);
	mnuDockOptions.translateCaption(Xlat_0008225, locale);
	mnuEditItem.translateCaption(Xlat_0008226, locale);
	mnuEnquireCargo.translateCaption(Xlat_0020937, locale);
	mnuFloatFrame.translateCaption(Xlat_0008227, locale);
	mnuFloatFrameSub.translateCaption(Xlat_0008228, locale);
	mnuHideFrame.translateCaption(Xlat_0008229, locale);
	mnuHideFrameSub.translateCaption(Xlat_0008230, locale);
	mnuInspectObject.translateCaption(Xlat_0008231, locale);
	mnuLstTree.translateCaption(Xlat_0008232, locale);
	mnuRemoveItem.translateCaption(Xlat_0008233, locale);
	mnuShowFrame.translateCaption(Xlat_0008234, locale);
	mnuShowFrameSub.translateCaption(Xlat_0008235, locale);
	mnuStopsToApply.translateCaption(Xlat_0021329, locale);
	mnuTasksToApply.translateCaption(Xlat_0021330, locale);
end;</source>
