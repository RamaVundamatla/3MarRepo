    <JadeMethod name="setForCreate" id="04169ee9-dfe5-4978-b826-b1829acf567b">
        <updating/>
        <source>setForCreate(_pxyEventRequest : CM_EventRequest; _passport : CM_Passport input) updating;
//--------------------------------------------------
// Created:	19 April 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	self.statusDT := app.serverTimestampAtTrxStart;
	self.enteredDT := app.serverTimestampAtTrxStart;	
	self.setForUpdate(_pxyEventRequest, _passport);
	app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(self);
end;</source>
        <Parameter name="_pxyEventRequest" type="CM_EventRequest"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="1d2d313d-78a3-4b62-bd02-bc67a1177ce5">
        <updating/>
        <source>setForUpdate(_pxyEventRequest : CM_EventRequest; _passport : CM_Passport input) updating;
//--------------------------------------------------
// Created:	19 April 2005 By: cnwgd1
//--------------------------------------------------
vars
	beforeAuditText, 
	afterAuditText: String;
begin
	beforeAuditText:=self.getAuditText();
	
	self.allEmailAddresses.clear();
	_pxyEventRequest.allEmailAddresses.copy(self.allEmailAddresses);
	self.myOrganisation	:=	_pxyEventRequest.myOrganisation;
//	self.myRoot			:=	_pxyEventRequest.myRoot;		// PAR #19974.
	self.remarks		:=	_pxyEventRequest.remarks;
	self.myUser			:=	_pxyEventRequest.myUser;
	self.reference		:=	_pxyEventRequest.reference.removeCrLfs();
	self.autoCleanup	:=	_pxyEventRequest.autoCleanup;
	self.isEDI			:=	_pxyEventRequest.isEDI;			// // cnwrl1 21/09/2009 PAR 20320 - MES 1011 New Messina Messages
	self.myTerminal		:=	_pxyEventRequest.myTerminal;
	
	if _pxyEventRequest.pxyGetRealObject &lt;&gt; null then
		afterAuditText:=self.getAuditText();
		app.myAA.auditUpdateTrx(self, beforeAuditText, afterAuditText);
	
	endif;
end;</source>
        <Parameter name="_pxyEventRequest" type="CM_EventRequest"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
