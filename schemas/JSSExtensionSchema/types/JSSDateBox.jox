    <JadeMethod name="create" id="19186f4d-d530-43d2-b7a3-8890eee1f141">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.alignment		:=	TextBox.Alignment_Center;
	self.show3D			:=	Control.Show3D_Use3D;
	self.selectionStyle	:=	TextBox.SelectionStyle_SelectAll;
	self.backColor 		:= 	self.getSystemColor(Window.Color_Window);
	self.height			:=	20;
end;</source>
    </JadeMethod>
    <JadeMethod name="dblClick" id="59ed3835-6662-4b82-9cec-8738498ec77e">
        <updating/>
        <source>dblClick(textbox: TextBox input) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theCalendarForm	: JSSCalendarPopupForm;

begin
	app.mousePointer	:=	Busy;

	if self.readOnly then
		return;
	endif;

	create theCalendarForm;

	self.date.parseForCurrentLocale(self.text);
	self.isDateValid	:=	self.date.isValid();

	if self.isDateValid then
		theCalendarForm.setStartDate(self.date);
	endif;

	self.doPositionCalendar(theCalendarForm);

	theCalendarForm.showModal();

	if theCalendarForm.modalResult = Form.JSS_MODAL_SELECT then
		self.setDate(theCalendarForm.getDate());
	endif;

	inheritMethod(textbox);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doPositionCalendar" id="f9c89d76-d589-44e2-85b3-f81bda1afcc0">
        <updating/>
        <source>doPositionCalendar(pTheCalendarForm:JSSCalendarPopupForm io) updating, protected;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Positions the pop-up calendar form.
//
// Parameters:	pCalendarForm (CnEcCalendarSelectForm) - The pop-up calendar form.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 08/11/2000	cnwdad1		Changed to instantiate the new CnEcSelectCalendarForm.
// --------------------------------------------------------------------------------
vars
	theControl			: Control;
	theCalendarForm		: Form;
	sizeTop				: Real;				// Desktop value
	sizeLeft			: Real;				// Desktop value
	sizeHeight			: Real;				// Desktop value
	sizeWidth			: Real;				// Desktop value
	posCalendarLeft		: Real;				// Calendar control position values
	posCalendarTop		: Real;				// Calendar control position values
	
begin
	// Set the form variable.
	
	theControl	:=	self;
	
	// Starting with self, well work up the tree of the control's parents.
	
	while not theControl.parent.isKindOf(Form) do
		theControl	:=	theControl.parent.Control;
	endwhile;
	
	theCalendarForm	:=	theControl.parent.Form;			

	// Set the CnEcCalendar variables to the relative position of the Top
	// lefthand corner of the CnEcDateBox.
	
	self.windowToScreen(posCalendarLeft, posCalendarTop);

	// Add the width to make the relative position the top righthand corner.
	
	posCalendarLeft := posCalendarLeft + self.width;

	// Check that the postioning of the CalendarForm at the relative position
	// of the CnEcDateBox will leave the CalendarForm still within the bounds
	// of the parent Form, and adjust if necessary.
	
	if theCalendarForm.height &lt; (self.top + pTheCalendarForm.height) then
		// Will hang off bottom of form so re-position up from CnEcDateBox control.
		posCalendarTop	:=	posCalendarTop - pTheCalendarForm.height + self.height;
	endif;
	
	if theCalendarForm.width &lt; (self.left + self.width + pTheCalendarForm.width) then
		// will hang off right hand side of form so re-position left of CnEcDateBox control
		posCalendarLeft	:=	posCalendarLeft - pTheCalendarForm.width - self.width;
	endif;	
			
	if posCalendarLeft &lt; 0 or posCalendarTop &lt; 0 then
		// Will be too far left or too high, so just cause centreWindow by setting the values to '0'.
		posCalendarLeft	:=	0;
		posCalendarTop	:=	0;
	endif;

	// Populate the Form variables with the positioning of the form on the deskTop.
	
	theCalendarForm.getDeskTopWorkArea(sizeLeft, sizeTop, sizeWidth, sizeHeight);

	// If the current values for CnEcCalendarForm would overlap or be off the edge
	// of the desktop, force a centreWindow.
	
	if sizeLeft &gt; posCalendarLeft											// too far left
	or (sizeLeft + sizeWidth) &lt; (posCalendarLeft + pTheCalendarForm.width)	// too far right
	or sizeTop &gt; posCalendarTop												// too far up
	or (sizeTop + sizeHeight) &lt; (posCalendarTop + pTheCalendarForm.height)	// too far down
	then
		posCalendarLeft	:=	0;
		posCalendarTop	:=	0;
	endif;

	// Set the values on the CnEcCalendarForm.
	
	pTheCalendarForm.setPosition(posCalendarLeft.Integer, posCalendarTop.Integer);
end;</source>
        <access>protected</access>
        <Parameter name="pTheCalendarForm" type="JSSCalendarPopupForm" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getNumericDateFormat" id="3a0cad04-a11a-44f0-bea2-ccbbd6d47e7b">
        <source>getNumericDateFormat(pDate:Date):String protected;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		To format a system date format with all numeric values, eg.
//				'10/July/1962' will become '10/07/1962'.
//
// Parameters:	pDate (Date) - The date whose numeric format will be returned.
//
// Returns:		The formated date with (separated) numerics.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dateString	: String;
	dayNo		: String;
	monthNo		: String;
	yearNo		: String;
	separator	: String;

begin
	separator	:=	self.myDateFormat.separator;

	if pDate = null or (not pDate.isValid()) then
		dayNo	:=	'00';
		monthNo	:=	'00';
		yearNo	:=	'0000';
	else
		dayNo	:=	pDate.Date.day.String.padLeadingZeros(2);
		monthNo	:=	pDate.Date.month.String.padLeadingZeros(2);
		yearNo	:=	pDate.Date.year.String.padLeadingZeros(4);
	endif;

	if self.myDateFormat.shortFormatOrder = self.myDateFormat.MonthDayYear then
		dateString	:=	monthNo &amp; separator &amp; dayNo &amp; separator &amp; yearNo;

	elseif self.myDateFormat.shortFormatOrder = self.myDateFormat.DayMonthYear then
		dateString	:=	dayNo &amp; separator &amp; monthNo &amp; separator &amp; yearNo;

	elseif self.myDateFormat.shortFormatOrder = self.myDateFormat.YearMonthDay then
		dateString	:=	yearNo &amp; separator &amp; monthNo &amp; separator &amp; dayNo;
	endif;
epilog
	return dateString;
end;</source>
        <access>protected</access>
        <Parameter name="pDate" type="Date"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="gotFocus" id="2b4c7971-945c-4135-9c38-ee643138a6d4">
        <updating/>
        <source>gotFocus(textbox: TextBox input) updating;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	dateToday	: Date;

begin
	if (not self.isInPainter()) then
		if (not self.isDateValid) then
			if self.isDefaultToToday then
				self.text	:=	self.getNumericDateFormat(dateToday);
				self.date	:=	dateToday;
			else
				self.text	:=	self.getNumericDateFormat(null);
				self.date	:=	null;
			endif;
		endif;

		// If we click on the year for example then we want to edit the year, not the day.
		self.cursorPosition	:=	self.selStart + 1;
	endif;

	inheritMethod(textbox);
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="isDateBlank" id="513d330e-53d4-4bb0-b5ab-88e8780ae7cd">
        <source>isDateBlank():Boolean protected;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Indicates whether or not any part of the date has been entered.  If
//				nothing has been entered, a value of true will be returned.
//
// Parameters:	None
// Returns:		Boolean - True if no part of the date has been entered, else false.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	part1		: Integer;
	part2		: Integer;
	part3		: Integer;
	position1	: Integer;
	position2	: Integer;
	separator	: String;

begin
	part1		:=	0;
	part2		:=	0;
	part3		:=	0;
	separator	:=	self.myDateFormat.separator;
	position1	:=	self.text.pos(separator, 1);

	if position1 &gt; 1 then		// If the separator is the first character, then the date is rubbish anyway.
		part1	:=	self.text[1:(position1 - 1)].Integer;

		if position1 &lt; self.text.length() then	// If the separator is the last character, then the date is rubbish anyway.
			position2	:=	self.text.pos(separator, (position1 + 1));

			if position2 &gt; (position1 + 1) then	// If there's nothing between the two separators, then the date is rubbish.
				part2	:=	self.text[(position1 + 1):(position2 - 1)].Integer;

				if position2 &lt; self.text.length() then
					part3	:=	self.text[(position2 + 1):end].Integer;
				endif;
			endif;
		endif;
	endif;

	if part1 = 0 and part2 = 0 and part3 = 0 then
		return true;
	else
		return false;
	endif;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssDate" id="43aca5cf-7550-4b74-943a-62b6416da45a">
        <source>jssDate(): Date;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Returns the receiver's current date setting, provided that the
//				date is valid, otherwise a null value is returned.
//
// Parameters:	None
//
// Returns:		The current date setting.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	if self.date.isValid() then
		return self.date;
	else
		return null;
	endif;
end;</source>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="jssDecimal" id="6c736454-04d0-4a9f-936e-422515627548">
        <source>jssDecimal(): Decimal;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		Returns the receiver's current date setting as a Decimal Julian
//				day number.
//
// Parameters:	None
//
// Returns:		The Julian day number.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	if self.date.isValid() then
		return self.date.Decimal;
	else
		return 0;
	endif;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
