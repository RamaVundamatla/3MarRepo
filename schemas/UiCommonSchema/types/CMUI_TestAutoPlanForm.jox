    <JadeMethod name="initTables" id="6ec260f0-c3e6-4a3a-9c11-5310310a8b00">
        <updating/>
        <source>initTables() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 January 2012	cnwndl1	Initial creation	Par 29195

*/

vars

	ti : CM_TrackedItem;

begin

	while true do
		if self.allNotableTis.isEmpty then
			break;
		endif;
		ti := self.allNotableTis.first;
		self.removeNotableTi( ti );
	endwhile;

	// set up the Selected Cargo table.
	self.tblSelectedCargo.clear();
	self.tblSelectedCargo.fixedRows := 1;
	self.tblSelectedCargo.rows := self.tblSelectedCargo.fixedRows;
	self.tblSelectedCargo.selectionType := CM_BaseTable.SelectionType_Row;
	self.tblSelectedCargo.multiSelect := CM_BaseTable.MultiSelect_Simple;
	
	self.tblSelectedCargo.setTblDataEntRowsFromDef(app.myController.getEntTableDef(ETDef_CargoEnqDefaultData));
	self.tblSelectedCargo.setForm (self);
	self.shtSelected.caption := app.getErrorString(Selected_Cargo);
	
	// set up the results tables.
	self.clearWouldPlanAndFailed();
	
epilog
	
end;</source>
