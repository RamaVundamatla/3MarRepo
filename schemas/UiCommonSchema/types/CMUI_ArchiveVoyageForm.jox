    <JadeMethod name="getXMLSettingsForSave" id="4d24b79c-6c60-4b53-8ea6-2756c71a9f09">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
//--------------------------------------------------
// Created:	14 March 2006 By: cnwgd1
//--------------------------------------------------
vars
	str : String;
	
begin
	str	:=	inheritMethod();

	str	:=	str &amp; global.formatAsXML(RemoveEDI, self.cbxRemoveEDI.value.String) &amp;
			global.formatAsXML(RemovePrenote, self.cbxRemovePreNote.value.String) &amp;
			global.formatAsXML(RemoveTBA, self.cbxRemoveTBA.value.String) &amp;
			global.formatAsXML(RemoveNonWork, self.cbxRemoveNonWork.value.String)&amp;
			global.formatAsXML(RemoveBookRef, self.cbxRemoveBookRef.value.String) &amp;
			global.formatAsXML(ArchiveBookRef, self.cbxArchiveBookR.value.String) &amp;//10 Sep 2009	NDL	Par 20413
			global.formatAsXML(CompleteJobs, self.cbxCompleteJobs.value.String);	//jlier1 	28679 10/12/24
	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="initFromUserWindow" id="73284565-9e03-4698-b83a-72ba5f3d0706">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
//--------------------------------------------------
// Created:	14 March 2006 By: cnwgd1
//--------------------------------------------------
vars
	pos : Integer;
	xmlInfo : String;
	remove : Boolean;
begin

	if _userWindow = null then
		return;
	endif;
	inheritMethod(_userWindow);
	xmlInfo := _userWindow.xmlInfo;
	
	pos := 1;
	remove := xmlInfo.cnEcGetNextTagValueOfName(RemoveEDI, pos).Boolean;
	self.cbxRemoveEDI.value := remove;

	pos := 1;
	remove := xmlInfo.cnEcGetNextTagValueOfName(RemoveNonWork, pos).Boolean;
	self.cbxRemoveNonWork.value := remove;

	pos := 1;
	remove := xmlInfo.cnEcGetNextTagValueOfName(RemovePrenote, pos).Boolean;
	self.cbxRemovePreNote.value := remove;

	pos := 1;
	remove := xmlInfo.cnEcGetNextTagValueOfName(RemoveTBA, pos).Boolean;
	self.cbxRemoveTBA.value := remove;	
	
	pos := 1;
	remove := xmlInfo.cnEcGetNextTagValueOfName(RemoveBookRef, pos).Boolean;
	self.cbxRemoveBookRef.value := remove;	
	
	//10 Sep 2009	NDL	Par 20413
	pos := 1;
	remove := xmlInfo.cnEcGetNextTagValueOfName(ArchiveBookRef, pos).Boolean;
	self.cbxArchiveBookR.value := remove;	
	
	//jlier1 JIRA#28679 
	pos := 1;
	remove := xmlInfo.cnEcGetNextTagValueOfName(CompleteJobs, pos).Boolean;
	self.cbxCompleteJobs.value := remove;	
		
end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="a3d340c0-3bef-475e-b01e-0c36cde2578f">
