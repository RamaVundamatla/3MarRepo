	self.lblGlobalView.left := 4;
	self.lblGlobalView.top := 4;
	self.lblGlobalView.fontBold := true;
	self.optActualView.move(46, 28, 173, 17);
	self.optProposedView.move(46, 56, 173, 17);
	
	self.btnGlobViewOK.caption := "&amp;View";
	self.btnGlobViewOK.top := 113;
	self.btnGlobViewOK.left := 109;
	self.btnGlobViewQuit.caption := "&amp;Close";
	self.btnGlobViewQuit.top := 113; 
	self.btnGlobViewQuit.left := 186;
	self.btnGlobViewQuit.parentBottomOffset := self.btnGlobViewOK.parentBottomOffset;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupLinkContextMenus" id="02c26fd8-eb80-4dfb-bba0-f5683b8aef20">
        <source>setupLinkContextMenus();

/*

Purpose:		Setup the Link context menus	

Date			Who		Reason
11/07/2013		cnwmh5	Initial creation

*/

vars

	obj							: Object;
	slotRequest					: CM_SlotRequest;
	
	amLinked					: Boolean;
	notLinked					: Boolean;
	totalNoSlots				: Integer;
	noLinked					: Integer;
	noNotLinked					: Integer;
	
begin

	foreach obj in self.myCurrentDrawingController.allSelectedObjects do
		
		if not obj.isKindOf(CM_SlotController) then
			continue;
		endif;
		
		slotRequest := obj.CM_SlotController.getRequest(self.displayMode = ShpDisplayMode_ColCodeLoad).CM_SlotRequest;
		
		// don't care in not SOB
		if not slotRequest.isSOB() then
			continue;
		endif;
		
		totalNoSlots := totalNoSlots + 1;
		
		// update counters for linked and not linked
		if slotRequest.isLinked() then
			noLinked := noLinked + 1;
		else
			noNotLinked := noNotLinked + 1;
		endif;
	
	endforeach;
	
	amLinked := noLinked &gt; 0;
	notLinked := noNotLinked &gt; 0;
	
	// set the menu visibility
	self.mnuGridReLink.visible := amLinked;
	self.mnuGridDeLink.visible := amLinked;
	self.mnuGridLink.visible := notLinked;
	self.mnuGridLinkMain.visible := (self.mnuGridReLink.visible or self.mnuGridDeLink.visible or self.mnuGridLink.visible);
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupSelectVoyageFrame" id="fa46615d-217f-4487-82f2-44ef3d1ba747">
        <updating/>
        <source>setupSelectVoyageFrame() updating;
// ---------------------------------------------------------------------------
// Created:     08 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	self.frmSelectVoyage.height			:= 300;
	self.frmSelectVoyage.width			:= 400;
	
	self.msgHolds.caption 				:= null;
	self.msgHolds.multiSelect 			:= ListBox.MultiSelect_Extended;

	self.msgHolds.formDisplayEntryMethodName := "displayHolds";
	self.msgHolds.availableHeading := app.getErrorString(Available_holds);
	self.msgHolds.selectedHeading := app.getErrorString(Selected_holds);

	self.msgHolds.myBaseForm	:= self;
	self.msgHolds.mySelectedListBox.sorted := false;
	self.msgHolds.readOnly := false;
	self.msgHolds.left := 5;
	self.msgHolds.width := self.frmSelectVoyage.clientWidth - 10;
//	self.setupVoyageCombo();
	
end;</source>
    </JadeMethod>
    <JadeMethod name="setupVoyageCombo" id="7b689560-cf9d-4da9-903e-9ca02fd6bd4f">
        <updating/>
        <source>setupVoyageCombo(_theCombo : ComboBox input;_codeOnly : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     08 September 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	aVoyage,
	saveVoyage	: CM_Voyage;
	aBay 		: CM_Bay;
	idx 		: Integer;
	saveObjFound	: Boolean;
	passport 	: CM_Passport;
	failedDAC  :CM_DataAccessController;
	
begin
	_theCombo.clear;
	passport := app.myPassport;
	saveVoyage := _theCombo.listObject.CM_Voyage;
	if saveVoyage = null then
		saveVoyage := self.myCurrentVoyage;
	endif;
	
	foreach	aVoyage in self.myTerminal.allVoyagesByCode do
		if aVoyage.myCellularVoyageStructure &lt;&gt; null then
			if aVoyage.myCellularVoyageStructure.allBayVoyagesById.size = 0 then
				continue;
			endif;

			if aVoyage.isCancelled then  //jlier1 TFS51963 5/10/21
				continue;
			endif;
			
			if not aVoyage.canUserAccessSelf(null, failedDAC, passport) then
				continue;
			endif;
			if aVoyage = saveVoyage then
				saveObjFound := true;
			endif;
			
			if _codeOnly then
				idx := _theCombo.addItem(aVoyage.code.trimBlanks );
			else
				idx := _theCombo.addItem(aVoyage.code.trimBlanks &amp; " " &amp; aVoyage.vesselName.trimBlanks);
			endif;
			_theCombo.itemObject[idx] := aVoyage;
		endif;
	endforeach;
	
	if saveObjFound then
		_theCombo.listObject := saveVoyage;
	endif;

end;</source>
        <Parameter name="_theCombo" type="ComboBox" usage="input"/>
        <Parameter name="_codeOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="showCargoPicture" id="8b20046a-bd97-4728-bba6-481c14219abb">
