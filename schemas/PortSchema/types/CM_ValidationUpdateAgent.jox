    <JadeMethod name="valTransitTransfer" id="d5712488-1044-430e-bc73-8079b9d20d26">
        <updating/>
        <source>valTransitTransfer(_allCMIFBOLS : CMIF_Array; _voyageController : CM_LogVoyageController) updating;

// cnwdvb1 17 October 2002 

vars

	helper	: CMIF_DocketLocationHelper;
	iter	: Iterator;
begin

	self.raiseExceptionIfNull(_voyageController, 'Location');
	
	//for PAR 12749
	if _voyageController.getFullId.length &gt; 30 then
		app.raiseUnexpectedProgramError('CM_Log', method.name, 'Error');
	endif;
	
	iter := _allCMIFBOLS.createIterator;
	while iter.next(helper) do
		self.raiseExceptionIfNull(helper.myBOL, 'BOLOut');
	endwhile;
	
epilog
	delete iter;
end;</source>
        <Parameter name="_allCMIFBOLS" type="CMIF_Array"/>
        <Parameter name="_voyageController" type="CM_LogVoyageController"/>
    </JadeMethod>
