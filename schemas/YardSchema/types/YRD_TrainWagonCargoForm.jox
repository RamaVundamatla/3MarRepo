    <JadeMethod name="buildComboCargo" id="2ca95e58-3b5f-4ed1-a7c9-2416967b49ad">
        <updating/>
        <source>buildComboCargo(pType : Integer ; _combo : CMUI_ComboBox input) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 Jul 2009	cnwmd1	Initial creation
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	lTI	: CM_TrackedItem;
	lIter01	: Iterator;
	idStr	: String;
	lType	: Integer;
	idx	: Integer;
	transitAndPrenoteTIs : CM_TIByCargoTypeIdDict;
begin

	create transitAndPrenoteTIs transient;
	_combo.clear;

	// DVB 30/07/04 Pick up inter terminal transfers.
	self.myTerminal.allNotifiedTIsByCargoTypeId.copy(transitAndPrenoteTIs);
	self.myTerminal.allInTransitTIsToByFromTypeId.copy(transitAndPrenoteTIs);
	lIter01 := transitAndPrenoteTIs.createIterator();
	
	transitAndPrenoteTIs.startKeyGeq(pType, null, lIter01);
	
	while lIter01.next(lTI) do
		if lTI.isChild() then
			continue;
		endif;
		if lTI.cargoType &lt;&gt; pType then
			break;
		endif;
		if lTI.myPrimaryActualLocation &lt;&gt; null then	//23 Jul 09 NDL - Don't show those that are already assigned.
			continue;
		endif;

		if lTI.receiptTransportMode &lt;&gt; TI_TRANSMODE_RAIL then// 07 Oct 2009	NDL	Par 20839
			continue;
		endif;
		_combo.itemObject[_combo.addItem(lTI.id)] := lTI;
	endwhile;
	
epilog
	delete transitAndPrenoteTIs;
	delete lIter01;		// PAR #26678
end;</source>
        <access>protected</access>
        <Parameter name="pType" type="Integer"/>
        <Parameter name="_combo" type="CMUI_ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="buildComboCargoPosition" id="58923b56-97ac-4a9c-a144-d62dfe8d1e6d">
        <source>buildComboCargoPosition()protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 July 2009	cnwmd1	Initial creation

*/

vars
	//wagonClass : CM_WagonClass;
	i, idx : Integer;
	controller : CM_WagonController;
begin
	self.cmbCargoPosition.clear;
	if self.myCurrentWagon = null then
		return;
	endif;
	
	if self.myTerminal.getConfig( RailDefaultWCIdFormat ).Integer = Rail_UPSP_Int then	//Par 35346 / CCMS 1408
		self.cmbCargoPosition.enabled := false;
		idx := self.cmbCargoPosition.addItem("Automatically selected");
	else
		foreach controller in self.myCurrentWagon.allLocationsControllersArray do	//04 Dec 2014	NDL	Par 35345
			idx := self.cmbCargoPosition.addItem(controller.getLabel());
			self.cmbCargoPosition.itemObject[idx] := controller;
		endforeach;
	endif;
	
	setDefaultCargoPosition();
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="buildComboCargoType" id="a1e5707b-964f-48e9-8b29-a68bd4a9540c">
        <source>buildComboCargoType() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 July 2009	cnwmd1	Initial creation

*/

vars
	idx		: Integer;
	logType	: CM_CargoType;

begin
	self.myAssistant.comboBoxCargoBolType(self.cmbCargoType, app.myPassport.getDefaultCargoBOLTypeId(), true, false, true, true);
	// remove LOG from the combo - old gate will still be used for these
	logType := app.myRoot.allCargoTypesById[TI_CargoType_Log];
	idx := cmbCargoType.findObject(logType);
	if idx &gt; null then
		cmbCargoType.removeItem(idx);
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="buildComboTrain" id="fe07e9e5-f869-4d2e-817c-525d955a8de6">
        <updating/>
        <source>buildComboTrain()protected, updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 July 2009	cnwmd1	Initial creation

*/

vars

begin
	self.myAssistant.comboBoxTrain(self.cmbTrain, self.myCurrentTrain, false, false, false);
	self.cmbTrain_click(self.cmbTrain);
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="buildComboWagon" id="951d369c-9a46-41ec-aeb8-299a64353e0a">
        <source>buildComboWagon() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 July 2009	cnwmd1	Initial creation

*/

vars
	wagon : CM_Wagon;
begin
	self.cmbWagon.clear();
	
	if self.myCurrentTrain = null then
		return;
	endif;
	
	foreach wagon in self.myCurrentTrain.allWagonsByIdInward do
		self.cmbWagon.itemObject[self.cmbWagon.addItem(wagon.id)] := wagon;
	endforeach;
		
		/* copied from YRD_WagonForm.  If train is null then this code is called
		foreach wagon in self.myTerminal.allWagons do
			if wagon.confirmed then
				if self.myCurrentRailLine &lt;&gt; null and wagon.myRailLine &lt;&gt; null then
					if self.myCurrentRailLine &lt;&gt; wagon.myRailLine then
						continue;
					endif;
					if self.myPosition &lt;&gt; null then
						wagonIdx := self.myCurrentRailLine.allWagons.indexOf(wagon);
						if wagonIdx &lt;&gt; self.myPosition then
							continue;
						endif;
					endif;
				endif;
			endif;			
			idx := self.cmbWagon.addItem(wagon.id);
			self.cmbWagon.itemObject[idx] := wagon;
		endforeach;
	endif; */
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="buildWagonPositionForTI" id="e1384654-795d-4092-818d-7465dfbb91ba">
        <updating/>
        <source>buildWagonPositionForTI(_ti : CM_TrackedItem io; _position : Integer; _wagonPositions : CMIF_TIWagonPositionArray input) updating, protected;
//-----------------------------------------
//Created: February 2003 By: cnwgd1
//-----------------------------------------

//cnwmd1, CCMS 1067, Par 19913 Method copied from YRD_WagonForm and modified to suit
//Builds a new wagon position for the cargo item and adds to _wagonPositions
vars
	is40		: Boolean;
	idx, pos,
	unitsRequired : Integer;
	tiWagonPos	: CMIF_TIWagonPosition;		
	//tmpArray	: CMIF_TIWagonPositionArray;
	wagonClass : CM_WagonClass;
	totLenghtInUnits : Integer;
begin

	// create CMIF_TIWagonPositions, one for each wagon controller
	// this works out from the bottom row of container what controllers belong to what positions
	// it uses a Point which allows 2 integers to be grouped together in an array
	// the first number (x) is the starting position inthe controller array and the second number (y) is how many controllers, which is basically the length in units
	// use the position on the screen to pin point the controllers that this container is on
	// this allows us to use the position and height on the screen to stack the containers

	if _position = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Position', null, null);
		app.raiseCMException(Input_required_field_position, null, null); // cnwdb2	PAR 35364
		return;
	endif;

	if _ti = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Cargo Item', null, null);
		app.raiseCMException(Input_required_field_cargoItem, null, null); // cnwdb2	PAR 35364
		return;
	endif;	
	
	if myCurrentWagon.isFlatcar then	//25 Mar 2013	NDL	Par 31278
		unitsRequired := _ti.getLengthInUnitsForWagon().Integer; // PAR 18015
	elseif myCurrentWagon.isBoxcar then	//25 Mar 2013	NDL	Par 31278
		unitsRequired := 1;
	elseif myCurrentWagon.isWellcarVisit then	//10 Dec 2014	NDL	Par 31278
		unitsRequired := myCurrentWagon.CM_WellcarVisit.getLengthInUnitsForWagon( _ti ).Integer;
	endif;
	
	pos := _position;
	
	//th2 PAR 14253 - validate cargo does not run over the end of the wagon
	//and validate position is not already taken
	wagonClass := myCurrentWagon.myWagonClass;
//	if wagonClass &lt;&gt; null and wagonClass.isFlatcar then	//25 Mar 2013	NDL	Par 31278
	if wagonClass &lt;&gt; null and ( wagonClass.isFlatcar or wagonClass.isWellcar ) then
		//N.B. (pos + unitsRequired -1) because the first position itself is used
		totLenghtInUnits := wagonClass.getLenInUnits();	//10 Dec 2014	NDL	Par 35346
	//	if (pos + unitsRequired -1) &gt; wagonClass.lenInUnits then
		if (pos + unitsRequired -1) &gt; totLenghtInUnits then	//10 Dec 2014	NDL	Par 35346
			if _ti.isTransient then
				delete _ti;
			endif;
			app.raiseCMException(Wagon_Cargo_Overhang, null, null);
			return;
		endif;
	
		foreach tiWagonPos in _wagonPositions do
			if tiWagonPos.position = pos then
				if _ti.isTransient then
					delete _ti;
				endif;
				app.raiseCMException1(Wagon_invalid_cargo_position,pos.String, null, null);
				return;
			endif;
		endforeach;
	endif;
	
	// if its a forty footer then add to the bottom of stack	
	is40 := _ti.sizeAttributes.bitAnd(ISO_LEN_40) &gt; 0;
	
	foreach idx in 1 to unitsRequired  do
		create tiWagonPos transient;
		if is40 then
			_wagonPositions.insert(idx,tiWagonPos);		
		else
			_wagonPositions.add(tiWagonPos);
		endif;
		
		if pos = _position then
			// only set the ti on the first controller as the move code
			// finds the secondary location to move ti to
			// else we just set the twist locks for the secondary controllers
			//tiWagonPos.myTrackedItem := _ti;
			if _ti &lt;&gt; null then	//14 Oct 2014	NDL	Par 35040
				tiWagonPos.allTrackedItems.addExclusive(_ti);
			endif;
		endif;
		
		// set the id on all controllers
	//	tiWagonPos.trackedItemId := _ti.id;
		tiWagonPos.myRailLine := self.myCurrentWagon.myRailLine;

		// this relates to the order of the containers from left to right
		tiWagonPos.position := pos;
		// if there is a container then it must have twistlocks
		tiWagonPos.available := true;
		tiWagonPos.hasTwistLocks := true;
		// container locked
		tiWagonPos.twistLocksAreUp := false;
		pos := pos + 1; 
	endforeach;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem" usage="io"/>
        <Parameter name="_position" type="Integer"/>
        <Parameter name="_wagonPositions" type="CMIF_TIWagonPositionArray" usage="input"/>
    </JadeMethod>
