    <JadeMethod name="setupThumbnailDetails" id="da6d4bcc-172c-4e8f-b194-38193c366c26">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*
Purpose:			

Date		Who		Reason
04 August 2023	navab1	CR 56093 TASK 59625
*/

vars
	theForm	: SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_CustDocTypeList);
	
	theForm.shtTblInput1.caption := app.getErrorString(Details);
	theForm.initTblInput(theForm.tblInput1, ETDef_CustDocTypeMaint);
	theForm.shtTblInput1.visible := true;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="76adfcd4-f502-4509-a468-4f527d97fe74">
        <updating/>
        <source>showThumbnail(_custDocType: CM_CustomDocumentType) updating;
/*
Purpose:			

Date		Who		Reason
04 August 2023	navab1	CR 56093 TASK 59625
01/09/2023	navkc1	CR 59937 Task 59939: UI - Cust Doc Mandatory Fields
05/09/2023	navkc1	CR 60156  Task 60157: UI - Cust Doc Type Colour
*/

vars
	theForm : SOP_TableMaintForm;
	dirStr : String;
	etrow	: EntTableRow;
	entDef	: EntTableDef;
	mandatoryAttr	: ObjectArray;
	row		: Integer;
	
begin
	theForm := self.myForm;
	theForm.tblInput1.clearValues();
	theForm.loadCmbCustDocTypeDirection(_custDocType.direction);
	
	theForm.tblInput1.setValueByName(ETRow_Code, _custDocType.code);
	theForm.tblInput1.setValueByName(ETRow_Description, _custDocType.description);
	theForm.tblInput1.setValueByName(ETRow_Nafe, _custDocType.notAvailForEntry); 
	theForm.tblInput1.setValueByName(ETRow_HasAutoId, _custDocType.hasAutoId); 
	dirStr := CM_CustomDocumentType@getDirectStrFromInt(_custDocType.direction);
	
	theForm.tblInput1.setValueByName(ETRow_Direction,dirStr); 

	//05/09/2023	navkc1	CR 60156  Task 60157
	row := theForm.tblInput1.getRowByName(ETRow_Colour);
	
	if row &gt; 0 then
		theForm.tblInput1.accessCell(row, 2).text := null;
		theForm.tblInput1.accessCell(row, 2).backColor := _custDocType.colour;
		theForm.tblInput1.accessCell(row, 2).foreColor := _custDocType.colour.getInverseColour();
	endif;
	
	theForm.mulSelect2.setSelected(_custDocType.allStopsToApply);
	theForm.mulSelect1.setSelected(_custDocType.allStopsToClear);
	theForm.mulSelect3.setSelected(_custDocType.allNextDocumentTypes);
	theForm.mulSelect6.setSelected(_custDocType.allCustomLicenses);
	
	//01/09/2023	navkc1	CR 59937 Task 59939
	entDef := app.myController.getEntTableDef(ETDef_CustDocTypeMandAttr);
	if entDef &lt;&gt; null then
		create mandatoryAttr transient;
		foreach etrow in entDef.allEntTableRows do
			if _custDocType.allMandatoryFields.includes(etrow.name) then
				mandatoryAttr.add(etrow);
			endif;
		endforeach;
	endif;
	theForm.mulSelect7.setSelected(mandatoryAttr);
	
epilog
	delete mandatoryAttr;
end;</source>
        <Parameter name="_custDocType" type="CM_CustomDocumentType"/>
    </JadeMethod>
    <JadeMethod name="tblDataShowDataSpecial" id="91366e81-ee8a-4a41-8d28-cdd0145a13bd">
        <source>tblDataShowDataSpecial(_idxRow: Integer; _obj: CM_CustomDocumentType);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/09/2023	navkc1	CR 60156  Task 60157: UI - Cust Doc Type Colour

*/

vars
	cell		: JadeTableCell;
	column		: Integer;
	table		: CM_DataTable;
begin
	table := self.myForm.tblData;
	column := table.getColumnByRowName(ETRow_Colour);
	
	if (_idxRow &lt;&gt; 1) then
		if column &gt; 0 then
			cell := table.accessCell(_idxRow, column);
			cell.text := null;
			cell.backColor := _obj.colour;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_idxRow" type="Integer"/>
        <Parameter name="_obj" type="CM_CustomDocumentType"/>
    </JadeMethod>
</Class>
