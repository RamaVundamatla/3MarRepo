	write "Finished";
end;</source>
    </JadeMethod>
    <JadeMethod name="jhpRemoveDir" id="0632456d-5e1b-49dd-b37e-4e4550f3ad6a">
        <updating/>
        <source>jhpRemoveDir(dir:String; files,folders:Integer io) updating;

vars
	ff:FileFolder; fn:FileNode;
	i,j,k:Integer;
	ts:TimeStamp;
begin
	create ff transient;
	ff.usePresentationFileSystem:=false;
	ff.fileName:=dir;
	if not ff.isAvailable or ts.date - ff.lastModifiedTime.date &lt;= 14 then
		return;
	endif;
	ff.files;
	//write ff.lastModifiedTime.String &amp; Tab &amp; (ts.date - ff.lastModifiedTime.date).String &amp; Tab &amp; ff.fileName;
	foreach fn in ff.files do
		if fn.isKindOf(FileFolder) then
			jhpRemoveDir(fn.fileName, files, folders);  // recursion!!
		else
			//write app.actualTime.logFormat &amp; Tab &amp; "removing file " &amp; fn.fileName;
			files:=files + 1;
			fn.readOnly:=false;
			//fn.purge;
		endif;
	endforeach;
	//write app.actualTime.logFormat &amp; Tab &amp; "removing folder " &amp; ff.fileName;
	folders:=folders + 1;
	//ff.purge;
epilog
	delete ff;
end;
</source>
        <Parameter name="dir" type="String"/>
        <Parameter name="files" type="Integer" usage="io"/>
        <Parameter name="folders" type="Integer" usage="io"/>
    </JadeMethod>
