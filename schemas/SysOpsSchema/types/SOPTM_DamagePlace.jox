	theForm.tblInput2.userInputEnabled := false;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupThumbnailDetails" id="84e0ec5b-c368-4748-bd16-58d5256efcbe">
        <updating/>
        <source>setupThumbnailDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2022	navds20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars
	theForm	: SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.useProxyObject := true;
	theForm.setTblDataEntRows(ETDef_DamagePlace);
	
	theForm.shtTblInput1.caption := app.getErrorString(Details);
	theForm.initTblInput(theForm.tblInput1, ETDef_DamagePlace);
	theForm.shtTblInput1.visible := true;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnail" id="7b5d7fce-b8aa-4ca9-995b-925b4873182b">
        <updating/>
        <source>showThumbnail(_damagePlace : CM_DamagePlace) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 June 2022	navds20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars
	theForm : SOP_TableMaintForm;
begin
	theForm := self.myForm;
	theForm.tblInput1.clearValues();
	
	theForm.tblInput1.setValueByName(ETRow_Code, _damagePlace.code);
	theForm.tblInput1.setValueByName(ETRow_Description, _damagePlace.description);
	theForm.tblInput1.setValueByName(ETRow_IsNotAvailableForEntry, _damagePlace.isNotAvalableForEntry);
	

epilog

end;</source>
        <Parameter name="_damagePlace" type="CM_DamagePlace"/>
    </JadeMethod>
</Class>
