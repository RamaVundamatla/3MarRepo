    <JadeMethod name="doPrint" id="3ca700d5-c2b1-495d-8d7d-1a029a81ff5b">
        <updating/>
        <source>doPrint() updating ;
// ---------------------------------------------------------------------------
// Created:     04 February 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 08/12/2009	cnwdap1		CCMS MES 1007 Reefer properties moved from CM_Container to separate class
// 11/03/2010	cnwdap1		PAR #22938 Correct reefer checking
vars
	ourReport 	: CM_TITransEnquiryOutput;
	now			: TimeStamp;
	numTemps	: Integer;
	tmpReport 	: JadeReport;
begin
	if  self.mode = self.Mode_BOLItem_Enquiry then			//epr par 35427 29/1/15
		self.tblTrans.printTable(self.caption);
		return;	
	endif;
	
	// Jan 2012 CCMS 1262 Transaction Enquiry
	if self.mode &lt;&gt; self.Mode_CargoItem_Enquiry  then
		self.doPrintOutTable(self.tblTransactions, (self.caption &amp; " " &amp; self.lblSearchCrit.caption), true, false, true, true);		
		return;
	endif;
	
	app.mousePointer := MP_HOURGLASS;
	now := self.systemToLocalTime(app.actualTimeServer());	// 13/6/16 cnwmp6 TFS 488 - Multi timezone support
	create tmpReport transient;
	app.printer.close;
	app.printer.printPreview := false;
	app.printer.setMargins(Print_Portrait,5,5,10,10);
	app.printer.topOfPage := 1;
	app.printer.bottomOfPage := 1;
	app.printer.setReport(tmpReport);
	create ourReport;
	ourReport.initReport();
	// setup header information
	
		ourReport.lblCargoType.caption := self.myTrackedItem.isoTypeDesc.trimBlanks; //ti.isoTypeDesc;
		ourReport.lblTIID.caption := self.myTrackedItem.id;
	
	ourReport.lblPrintedBy.caption := app.getMyUserCode &amp; " - " &amp; now.date.String &amp; ", " &amp; now.time.format("H:mm").String;
	// set header
	app.printer.setHeader(ourReport.frHeader);
	app.printer.setFooter(null);
	
	
		// CCMS 107 other cargo can be reefer, temperature readings on new class accessed from CM_TrackedItem get method
		if CM_Container.hasInstance(self.myTrackedItem) or (self.myTrackedItem.isReefer) then	// PAR #22938
			if self.myTrackedItem.getAllTemperatureReadings() &lt;&gt; null then	// cnwdad1 26/02/2010 - May return null!
				numTemps := self.myTrackedItem.getAllTemperatureReadings().size;		// CCMS 1007
			endif;
		endif;
	
	
	ourReport.printReport(self, numTemps);
	app.printPreview(tmpReport, true);
epilog
	app.mousePointer := MP_DEFAULT;
	delete ourReport;
end;</source>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="a283bee2-12c2-4a33-a106-cc068081e8c0">
        <updating/>
        <source>doRefresh() updating, protected;
// ---------------------------------------------------------------------------
// Created:		19 December 2007 By Andrew Bishop cnwab1
//
// Purpose:		
/* Changes

Date		Name	TFS#	Description
============================================================================
08/07/2019	jlgka1	45518	STWO - After a refresh in Transaction enquiry 'rows found' 
							at the bottom of the screen is not updated.
11 Jul 2023 navhl20 Bug 59047: MTN - The Refresh button on the Transaction Enquiry is refreshing all the transactions.
============================================================================*/
begin
	inheritMethod();
	
	if self.myBOL &lt;&gt; null then	//28 Apr 2016	NDL	TFS 1903
		self.loadDataForBOL();
		self.showCharges;	//28 Nov 2019	NDL	TFS 47727
		
	// ### JIRA 33348 22NOV2024 NAVAB1
	elseif self.mode = self.Mode_ContractAccumulation then	
		self.loadDataForAccumulation();
	elseif self.mode = self.Mode_CargoItem_Enquiry then
		self.initTblTrans();
		self.showTransactions;
		self.showCharges;
		self.showDiscrepancies;
		self.showEventRequests();
	elseif	self.mode = self.Mode_WO_Transaction_Enquiry then			//11.7.2023 navhl20 #59047
		self.loadDataForWO();
	else
		// TFS 39236 self.populateTransactionTable();		
		self.doTransactionSearch(); 		// TFS 39236
	endif;
	
	//clear the column organiser filters.
	if self.allColumnFilters &lt;&gt; null and not self.allColumnFilters.isEmpty then
		if self.allColumnFilters.includesFiltersFor( self.tblTransactions ) then
			self.allColumnFilters.replaceAllFiltersForTable( self.tblTransactions, null );
			self.applyColumnFilter( self.tblTransactions );
		endif;
	endif;
	self.showNumRowsShown();			// jlgka1 TFS 45518
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRepositionTables" id="49d542b6-df01-45e8-8232-743bf536ba27">
        <source>doRepositionTables();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 September 2019	jlgns1	Initial creation
20/09/2019 	JLGNS1	Bug 46339 JMT - Event transaction does not resync
16 Aug 2023 navhl20 Bug 59665: EUP - Work Order - View Transactions - Not displaying anything 
*/

vars
	tableHeight : Real;
begin
	if app.myCurrentUserCan(self.myTerminal, PmTransEnquiryInvoiceDtls) then
		// show the charges table under the transaction table
		self.tblCharges.visible := true;
		self.tblCharges.parent := self;
		self.tblCharges.height := 60;
		self.tblCharges.left := 0;
		self.tblCharges.width := self.clientWidth -1;
		self.tblCharges.top := self.clientHeight - self.staLine.height - self.tblCharges.height;
		tableHeight := self.tblCharges.height + 4;
	else
		self.tblCharges.visible := false;
		tableHeight := 0;
	endif;
	
	if self.frmSearchCrit.visible then																			//16.8.2023 navhl20 #59665
		self.tblTransactions.top := self.frmSearchCrit.top + self.frmSearchCrit.height + 10;
	endif;
	self.tblTransactions.left := 0;
	self.tblTransactions.width := self.clientWidth -1;
	self.tblTransactions.height := self.clientHeight - self.tblTransactions.top - tableHeight - self.staLine.height;
		
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doResetSearch" id="d26c2962-7f00-4bde-8d2a-e2c8a1d36764">
        <updating/>
        <source>doResetSearch() updating, protected;
/*

Date		Who		Reason
06 Apr 2016	cnwkpd1	TFS 488 - Multi Timezone Support
	
*/

vars
	systemNow,
	localNow		: TimeStamp;
	tme : Time;
begin
	systemNow := app.actualTimeServer();
	localNow := self.systemToLocalTime(systemNow);
		
	 // ### TFS CR 54345 TASK 54267 01JUN2023 NAVAB1
	if process.isJLGAB1() then
		self.mskSearchDateFrm.setDate(localNow.date());
		self.mskSearchTimeFrm.setTime(null);
		self.mskSearchDateTo.setDate(localNow.date());
		tme.setTime(23,59,59,999);
		localNow.setTime(tme);
		self.mskSearchTimeTo.setTime(localNow.time());
	else
	// somewhat arbitrary choice of start date one week ago
		self.mskSearchDateFrm.setDate(localNow.date().cnEcAddDays(-7));
		self.mskSearchTimeFrm.setTime(null);
		self.mskSearchDateTo.setDate(localNow.date());
		self.mskSearchTimeTo.setTime(localNow.time());
	endif;
	self.cmbSearchTranTyp.listIndex := 1;
	self.cmbSearchVoyage.listIndex := 1;
	self.cmbSearchUser.listIndex := 1;
	self.cmbSearchBU.listIndex := 1;
	self.cmbSearchDebtor.listIndex := 1;
	self.cmbSearchCharged.listIndex := 1;
	self.txtSearchInvNo.text := "";
	
	self.setFilterDefaults();
	
	self.cmbSearchEnqType.setFocus();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="0fb92ce1-419a-4d4e-a632-0c60eb0fdbbb">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:     11 July 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
//20 Jan 2017	cnwrs1	TFS 3137 - resize the form when show captions is on
//20/09/2019 	JLGNS1	Bug 46339 JMT - Event transaction does not resync
//08/11/2019	jlgzm1	TFS 47428 Bottom of table hidden behind status line
//16 Aug 2023 	navhl20 Bug 59665: EUP - Work Order - View Transactions - Not displaying anything 
vars

begin
	inheritMethod;
	
	// Bottom of tables hare hidden behind status line when viewing a TI's transactions.
	// not a problem on when form opened 'normally' ie from the navigator, 
	if self.fldTrans.visible then
		//	//cnwmc5 - 11/01/2013 - PAR #30944
		self.tblTrans.height := self.tblTrans.height - self.staLine.height;
		//self.tblCharges.height := self.tblCharges.height - self.staLine.height; //jlgzm1 14/12/2018 tfs41956			//16.8.2023 navhl20 #59665
		self.tblDiscrepances.height := self.tblDiscrepances.height - self.staLine.height;
		self.tblEventNotify.height := self.tblEventNotify.height - self.staLine.height;
		self.tblTemperatures.height := self.tblTemperatures.height - self.staLine.height;
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doSearch" id="e14ecd7e-adb1-45a7-b13f-53b5338aeae9">
        <updating/>
        <source>doSearch() updating, protected;

vars
	
begin
	if self.mode = self.Mode_CargoItem_Enquiry then
		return;
	endif;

	self.setFilterValues();
	// must have at least a date or transaction/event type to be able to search
	if self.filterDateFrom = null and
	   self.filterDateTo = null and
	   self.filterEventType = null and
	   self.filterTransactionType = null then
		if self.mode = Mode_HMS_Transaction_Enquiry then
			app.msgBox(app.getErrorString(Please_enter_date), app.getErrorString(Search), 0);
		else
			app.msgBox(app.getErrorString(Please_enter_date_or_type), app.getErrorString(Search), 0);
		endif;
		return;
	endif;

	self.modalDialogReturnValue	:= ModalDialogReturn_Null;
	self.modalDialogShow(null, app.getErrorString(Cancel), null, null, app.getErrorString(SearchingForData), null);
	self.doTransactionSearch();
	
	self.showNumRowsShown();
	
	self.doShowSearcherClick();
	self.doEnableButtonsByMode();
epilog
	self.frmModalDialog.visible := false;
	app.mousePointer := MousePointer_Default;
	
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSelectAll" id="4652341b-e856-41ba-8aa3-71b0f3508747">
        <source>doSelectAll() protected;
//	Feb 2012 CCMS 1262
vars

begin
	if self.mode = self.Mode_CargoItem_Enquiry then
		return;
	endif;

	if self.btnSelectAllTV.caption = app.getErrorString(SelectAll) then
		self.tblTransactions.selectAll;
	else
		self.tblTransactions.clearAllSelected;
	endif;

	if self.btnSelectAllTV.caption = app.getErrorString(SelectAll) then
		self.btnSelectAllTV.bubbleHelp := app.getErrorString(Deselect_All);
		self.btnSelectAllTV.caption := app.getErrorString(Deselect_All);
	else
		self.btnSelectAllTV.bubbleHelp := app.getErrorString(SelectAll);
		self.btnSelectAllTV.caption := app.getErrorString(SelectAll);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSendToReport" id="bba19f4b-badf-4d96-aa17-b5ab51c1f852">
        <updating/>
        <source>doSendToReport() updating, protected;
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
vars
	jrwReportName	: String;
	selectedOnly,
	printPreview	: Boolean;
	objArray		: ObjectArray;
	pathList		: StringArray;
	obj				: Object;
	outputType		: Integer;
	filePath		: String;
begin
	if self.tblTransactions.allSelectedObjects.size &gt; 0 then
		selectedOnly := true;		// enable the option if there are items selected
	endif;
	create pathList transient;
	pathList.add("allTransactions.");
	pathList.add("allSnapShotReportings."); // TFS 40632
	// Get the report and print options
	if app.getReportToSendItems(CM_TransactionView, pathList, selectedOnly , jrwReportName, printPreview, outputType, filePath) then

		app.isReportWriter := true;

		create objArray transient;
		if selectedOnly then
			self.tblTransactions.allSelectedObjects.copy(objArray);
		else
			self.tblTransactions.getAllRowObjects(objArray);
		endif;

		app.sendItemsToReport(CM_JRWTransaction, objArray, jrwReportName, printPreview, outputType, filePath);
	endif;
epilog
	app.isReportWriter := false;
	delete objArray;
	delete pathList;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSetCharge" id="4ea9415b-44b2-46a6-bbd9-ec748f7e0dc5">
        <updating/>
        <source>doSetCharge(_set : Boolean) updating, protected;
// Feb 2012 CCMS 1262 transaction enquiry, set/reset the noCharge attribute of the selected transactions
//  (the only bulk-edit that makes sense in the general enquiry)
vars
	transactions	: CM_TransactionSet;
begin
	create transactions transient;
	self.tblTransactions.allSelectedObjects.copy(transactions);
	if transactions.size = 0 then
		return;
	endif;
	
	app.myTrxUA.trxUpdateTransactionCharge(transactions, _set, app.myPassport);

	if not app.myPassport.trxCompletedOK then
		app.showErrorsAsMsgBox(app.myPassport.allErrors, false);
		return;
	endif;
	
epilog
	delete transactions;
end;
</source>
        <access>protected</access>
        <Parameter name="_set" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doShowCargoEnquiry" id="2f31d4f0-bea6-437e-b0bb-0f4cf1bdbb56">
        <source>doShowCargoEnquiry() protected;

vars
	trans	: CM_TITransaction;
	tiArray : CM_TIArray;
	obj : Object;
begin
	create tiArray transient;
		
	if self.tblTransactions.allSelectedObjects.isEmpty then
		return;
	endif;
	
	foreach obj in self.tblTransactions.allSelectedObjects do
		if not obj.isKindOf(CM_TITransaction) then
			continue;
		endif;
		trans:=obj.CM_TITransaction;
		if trans.myTrackedItem &lt;&gt; null then
			tiArray.addExclusive(trans.myTrackedItem);
		endif;
	endforeach;
	
	
	if tiArray.isEmpty then
		return;
	endif;
	self.myAssistant.showCargoEnquiryForTIs(tiArray.first, tiArray,self.myMasterMenuAction, false);
	
epilog
	delete tiArray;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doShowInformation" id="6be1213d-a20e-4d1d-98e6-d5ef3297a75c">
        <source>doShowInformation() protected;
// -------------------------------------------
// Created 21 September 2005 by cnwdvb1
// -------------------------------------------
//23/05/2018 	Jlgns1	Bug 38662: STWO - Transaction resync for 2291 transactions gives error 14051

vars
	lDetails		: CMUI_SystemAlertsDetails;
	trans			: CM_TITransaction;
	dataContainer	: CM_DataContainer;
	tableAgent		: CMUI_TableAgent;

begin
	//trans := self.tblTrans.accessRow(self.tblTrans.row).itemObject.CM_TITransaction;
	// 14/02/2013 cnwar2 #31127
	// PAR 31709 We also show HMS Transactions
//	if self.mode &lt;&gt;  self.Mode_Cargo_Transaction_Enquiry then
//		return;
//	endif;
	
	
	if self.mode = self.Mode_CargoItem_Enquiry then
		trans := self.tblTrans.accessRow(self.tblTrans.row).itemObject.CM_TITransaction;
	elseif self.mode = self.Mode_Cargo_Transaction_Enquiry then	// 07 Oct 2013	NDL	Par 31709
		trans := self.tblTransactions.accessRow(self.tblTransactions.row).itemObject.CM_TITransaction;
	endif;
	
	if trans = null then
		return;
	endif;
	
	if not trans.isExtraDetailRequired(dataContainer) then
		return;
	endif;
	
	//02 Mar 2012	NDL	Par 29195
	if trans.isYAPlanInformation then
		self.myAssistant.showAutoPlanLog(null, null, null, trans.CM_Information);
		return;
		
	else
	
		// Update the navigator
		self.setNavigatorHeading("Information"); 
		create lDetails;
	
		lDetails.centreWindow();
		
		create tableAgent transient;
		dataContainer.headerColour	:=	self.colorHeadingColumn;
		dataContainer.valueColour	:=	self.colorValueColumn;
		dataContainer.displayMode	:=	2;
		lDetails.show();
		tableAgent.addDataToTable(	dataContainer,
									lDetails.tblAlerts,
									true,
									2,
									false,
									1,
									1,
									1,
									1,
									null,
									true);	
	
		lDetails.setMyTerminal(self.myTerminal);
	
	endif;
epilog
	delete tableAgent;
	delete dataContainer;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doShowInvoiceLogging" id="38828f3f-c977-4909-b4c3-d5e7127a8d19">
        <source>doShowInvoiceLogging(_logger : CMIF_Logger) protected;
// show the logged transaction map etc access
//23/05/2018 	Jlgns1	Bug 38662: STWO - Transaction resync for 2291 transactions gives error 14051

vars
	captionText		: String;
	transType		: String;
	dateTime		: TimeStamp;
	lDetails		: CMUI_SystemAlertsDetails;
	dataContainer	: CM_DataContainer;
	tableAgent		: CMUI_TableAgent;
	trans			: CM_Transaction;
begin
	
	if _logger = null then
		return;
	endif;
	
	// Update the navigator
	self.setNavigatorHeading("Charging"); 
	create lDetails;
	create dataContainer transient;
	
	_logger.getLogsAsBlocks(dataContainer);
	
	lDetails.centreWindow();
	
	create tableAgent transient;
	dataContainer.headerColour	:=	self.colorHeadingColumn;
	dataContainer.valueColour	:=	self.colorValueColumn;
	dataContainer.displayMode	:=	2;
	if self.mode = self.Mode_CargoItem_Enquiry then
		trans := self.tblTrans.accessRow(self.tblTrans.row).itemObject.CM_TITransaction;
	else
		trans := self.tblTransactions.accessRow(self.tblTransactions.row).itemObject.CM_Transaction;
	endif;
	captionText := "Charge logging ";
	if trans &lt;&gt; null then
		captionText := captionText &amp; "for ";
		if trans.isKindOf(CM_TITransaction) and
		   trans.CM_TITransaction.myTrackedItem &lt;&gt; null then
			captionText := captionText &amp; trans.CM_TITransaction.myTrackedItem.id &amp; " ";
		endif;
		if trans.isKindOf(CM_EventTransaction) then
			transType := trans.CM_EventTransaction.getName();
			dateTime := trans.CM_EventTransaction.dateTime;
		elseif trans.isKindOf(CM_TITransaction) then
			transType := trans.CM_TITransaction.typeString;
			dateTime := trans.CM_TITransaction.dateTime;
		elseif trans.isKindOf(HMS_VTMISTransaction) then
			transType := app.myRoot.allTransactionTypes[Trans_Type_ResourceCharged].description;
			dateTime := trans.HMS_VTMISTransaction.transactionDT;
		endif;
		captionText := captionText &amp; transType &amp; " " &amp; dateTime.asStringJMT;
	endif;
	lDetails.show();
	lDetails.displayMode := CMUI_SystemAlertsDetails.DisplayMode_TransactionLog;
	lDetails.setCaption(captionText);
	tableAgent.addDataToTable(	dataContainer,
								lDetails.tblAlerts,
								true,
								2,
								false,
								1,
								1,
								1,
								1, 
								CMUI_SystemAlertsDetails.DisplayMode_TransactionLog,
								true);	

	lDetails.setMyTerminal(self.myTerminal);
epilog
	delete tableAgent;
	delete dataContainer;
end;</source>
        <access>protected</access>
        <Parameter name="_logger" type="CMIF_Logger"/>
    </JadeMethod>
    <JadeMethod name="doShowSearcherClick" id="d61f440f-036e-40b3-8b53-80ada3212822">
        <updating/>
        <source>doShowSearcherClick() protected, updating;

vars

	defIndex : Integer;
	trn : CM_Transaction;
	mode : Integer;

begin
	if not self.frmQuery.visible then
		self.searcherShowHideControls(false);
		self.frmQuery.centreWindow();
	else
		self.searcherShowHideControls(true);
	endif;
	self.frmQuery.visible := (not self.frmQuery.visible);
	if self.frmQuery.visible then
		self.cmbSearchEnqType.setFocus();
		if self.allTransactions.isEmpty then
			if self.cmbSearchEnqType.listIndex = -1 then
				defIndex := self.cmbSearchEnqType.findStringExact( 1, app.getErrorString(Cargo_Transactions) );	//12 Nov 2019	TFS 47100
				if defIndex &gt; 1 then
					self.cmbSearchEnqType.listIndex := defIndex;
				endif;
			endif;
		else		//12 Nov 2019	TFS 47100
			trn := self.allTransactions.first.CM_Transaction;
			if trn.isBolTrx then
				mode := Mode_BOL_Transaction_Enquiry;
				defIndex := self.cmbSearchEnqType.findStringExact( 1, app.getErrorString(BOL_Transactions) );
			elseif trn.isEventTrx then
				mode := Mode_Event_Transaction_Enquiry;
				defIndex := self.cmbSearchEnqType.findStringExact( 1, app.getErrorString(Event_Transactions) );
			elseif trn.isCargoTrx then
				mode := Mode_Cargo_Transaction_Enquiry;
				defIndex := self.cmbSearchEnqType.findStringExact( 1, app.getErrorString(Cargo_Transactions) );
			elseif trn.isWoTrx then
				mode := Mode_WO_Transaction_Enquiry;
				defIndex := self.cmbSearchEnqType.findStringExact( 1, app.getErrorString(Work_order_transactio) );
			elseif trn.isHmsTrx then
				mode := Mode_HMS_Transaction_Enquiry;
				defIndex := self.cmbSearchEnqType.findStringExact( 1, app.getErrorString(HMS_Transactions) );
			endif;
			if defIndex &gt; 0 then
				self.cmbSearchEnqType.listIndex := defIndex;
				self.populateTransactionTypes(mode);
			endif;
		endif;
		self.frmQuery.zOrder(1);
	endif;
	// make the do query button default only when it is visible
	self.btnQuery.default := self.frmQuery.visible;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doShowSplitMergeCargo" id="cc2d6693-3dc4-41aa-8f9d-d5fd37f1458c">
        <source>doShowSplitMergeCargo(_txn : Object input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 May 2013	cnwer1	Initial creation CCMS DPH 2274

*/

vars
	ti : CM_TrackedItem;
begin
	if _txn.isKindOf(CM_Split) then
		ti:=_txn.CM_Split.getOtherTrackedItem();
	elseif _txn.isKindOf(CM_Merge) then
		ti:=_txn.CM_Merge.getOtherTrackedItem();
	endif;
	
	if ti = null then
		return;
	endif;
	
	self.myAssistant.showCargoEnquiry( ti );
	
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_txn" type="Object" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doSystemNotification" id="75b45540-3949-4aed-950f-66ffbea4c0fc">
        <updating/>
        <source>doSystemNotification(_eventType: Integer; _object:Object; _eventTag: Integer) protected, updating;
// Feb 2012 CCMS 1262 use system notifications to update table from delete, edit etc
vars
	row				:Integer;
	invalidObject	:Boolean;
begin
	on Exception do app.handleDeletedObject (exception, _object, invalidObject);
	
	if _eventType = Object_Update_Event and self.tblTransactions.findObjectInRow(_object, row) then
		self.updateItemInTable(_object.CM_Transaction, row);
	endif;
epilog
	endLoad;
end;</source>
        <access>protected</access>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doTblChargesContextMenu" id="a5c812cc-b02a-4dd3-8723-b6c5b15f31db">
        <updating/>
        <source>doTblChargesContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     May 2010 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	x1,
	y1			: Real;
	anObject	: Object;
	invoice		: CM_Invoice;

begin
	x1 := x;
	y1 := y;
	if (not mouse) then
	    x1 := 1;
	    y1 := 1;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);

	self.mnuInformation.visible := app.isSpecial();
	self.mnuTxnResync.visible := false;
	self.mnuTxnAdd.visible := false;
	self.mnuTxnEdit.visible := false;
	self.mnuTxnDelete.visible := false;
	self.mnuTxnUndelete.visible := false;
	self.mnuTxnResources.visible := false;
	self.mnuTxnViewAudits.visible := false;
	self.mnuPrint.visible := false;
	self.mnuSendToReport.visible := false;
	self.mnuCargoEnquiry.visible := false;
	self.mnuColumnOrganiser.visible := false;
	self.mnuColumnOrganiser.userObject := null;		//28 Apr 2016	NDL	TFS 1903
	self.mnuSetCharge.visible := false;
	self.mnuResetCharge.visible := false;

	// 33437 show invoice menu if there is an invoice to show
	if cntrl.row &gt; cntrl.fixedRows and
	   cntrl.row &lt;= cntrl.rows then
		anObject := cntrl.accessRow(cntrl.row).itemObject;
		if anObject.isKindOf(CM_InvoiceLine) then
			invoice := anObject.CM_InvoiceLine.invoice;
		elseif anObject.isKindOf(CM_CashPayment) then
			invoice := anObject.CM_CashPayment.myInvoice;
		endif;
	endif;
	self.mnuShowInvoice.visible := (invoice &lt;&gt; null);

	self.popupMenu(self.mnuContext, x1.Integer, y1.Integer);
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblTransCellInputReady" id="e7189725-064d-442b-8f0b-8b47aa33bd49">
        <updating/>
        <source>doTblTransCellInputReady(table: Table input; inputControl: Control input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 29 May 2013	cnwdap1		Initial creation CCMS 2274 Split/Merge Break Bulk Cargo
//
vars
	rows, row : Integer;
	visibleRows : Integer;

begin
	//return;
	if CMUI_ListBox.hasInstance(inputControl) and not inputControl = self.lstMergeSplit then
		if inputControl.CMUI_ListBox.listCount = 0 then
			inputControl.CMUI_ListBox.clear;
			self.doLoadMergeSplitTransaction(table.accessRow(table.row).itemObject.CM_TITransaction, inputControl.CMUI_ListBox);
		endif;
		rows := inputControl.CMUI_ListBox.listCount;
		foreach row in 1 to rows do
			if inputControl.CMUI_ListBox.itemVisible(row) then
				visibleRows := visibleRows + 1;
			endif;
		endforeach;
		table.accessRow(table.row).height := (inputControl.CMUI_ListBox.defaultLineHeight * visibleRows) + 5;
	endif;
epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="inputControl" type="Control" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTblTransContextMenu" id="453eeb94-6882-4ad6-a209-9cb8832f39fe">
        <updating/>
        <source>doTblTransContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;
// ---------------------------------------------------------------------------
// Created:     02 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
// 18 Apr 2016	NDL	TFS 1903
// 28 Nov 2018	cnwma1	ChangeRequest 42141: PEL1 - Allow changing transfer type for ISO Containers
//20/09/2019 	JLGNS1	Bug 46339 JMT - Event transaction does not resync
vars
	canEdit: Boolean;
	x1,
	y1			: Real;
//	txn			: CM_TITransaction;
	txn			: CM_Transaction;
begin
	x1 := x;
	y1 := y;
	if (not mouse) then
	    x1 := 1;
	    y1 := 1;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);

	//txn := self.tblTrans.accessRow(self.tblTrans.row).itemObject.CM_TITransaction;
	txn := self.tblTrans.accessRow(self.tblTrans.row).itemObject.CM_Transaction;

	self.mnuShowInvoice.visible := false;
//	self.mnuTxnResync.visible := self.myBOL = null and app.myCurrentUserCan(self.myTerminal, PmAdmResyncTrans);	//BUG 46339 
	self.mnuTxnResync.visible := ( txn &lt;&gt; null ) and app.myCurrentUserCan(self.myTerminal, PmAdmResyncTrans);	//28 Nov 2019	NDL	TFS 47727
	
	// Mar 2012 CCMS 1262 extend transaction edit permission test to item transaction enquiry
	//canEdit := app.myCurrentUserCan(self.myTerminal, PmAdmTransactioneditMaint);
	canEdit := app.myCurrentUserCan(self.myTerminal, PmAdmTransactioneditMaint) and self.myBOL = null;
	self.mnuTxnAdd.visible := canEdit;
	self.mnuTxnEdit.visible := canEdit;
	self.mnuTxnDelete.visible := canEdit;
	self.mnuTxnUndelete.visible := canEdit;
	
	//if txn &lt;&gt; null then
	if txn &lt;&gt; null and txn.isKindOf( CM_TITransaction ) then
		self.mnuTxnResources.visible := txn.CM_TITransaction.hasTaskThatAllowsResources() and txn.CM_TITransaction.hasTaskThatIsComplete();
		self.mnuTxnResources.userObject := txn;
		self.mnuTxnViewAudits.visible := txn.CM_TITransaction.hasTaskThatAllowsResources() and txn.CM_TITransaction.hasTaskThatIsComplete();
		self.mnuTxnViewAudits.userObject := txn;
		self.mnuEditTransferType.visible := canEdit and( txn.isKindOf(CM_ReceiveShip) or txn.isKindOf(CM_ReleaseShip));//22.11.2018 cnwma1 TFS #42141
	else
		self.mnuTxnResources.visible  := false;
		self.mnuTxnViewAudits.visible := false;
		self.mnuEditTransferType.visible := false; //22.11.2018 cnwma1 TFS #42141
	endif;
	self.mnuPrint.visible := true;
	self.mnuCargoEnquiry.visible := false;
	self.mnuInformation.visible := app.isSpecial();
	self.mnuEditBookingRefDiscr.visible := false;
	self.mnuEditDiscrepRemarks.visible := false;
	self.mnuSplitCargo.visible:= txn.isKindOf(CM_Split);
	self.mnuSplitCargo.userObject:=txn;
	self.mnuMergeCargo.visible:= txn.isKindOf(CM_Merge);
	self.mnuMergeCargo.userObject:=txn;
	
	self.mnuColumnOrganiser.visible := true;
	self.mnuColumnOrganiser.userObject := self.tblTrans;		//28 Apr 2016	NDL	TFS 1903
	
	self.popupMenu(self.mnuContext, x1.Integer, y1.Integer);
	return false;

end;</source>
        <access>protected</access>
        <Parameter name="cntrl" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblTransactionsContextMenu" id="dc0ca81e-22f9-438e-89ef-30d3946f4c6b">
        <updating/>
        <source>doTblTransactionsContextMenu(cntrl: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating, protected;
//  CCMS 1262 Jan 2012 transaction enquiry and selector queries
//  28 Nov 2018	cnwma1	ChangeRequest 42141: PEL1 - Allow changing transfer type for ISO Containers
//	20/09/2019 	JLGNS1	Bug 46339 JMT - Event transaction does not resync
//  24 May 2023  navmv20 CR 57925 Task 57921: UI - WO Enquiry To Do Tasks
//  11 Jul 2023  navhl20 Defect 59116: MTN - The Resync option is not working on the Work Order Transactions form
vars
	canEdit		: Boolean;
	x1,
	y1			: Real;
	txn : CM_Transaction; //24/05/2023  navmv20 CR 57925 Task 57921
begin
	x1 := x;
	y1 := y;
	if (not mouse) then
	    x1 := 1;
	    y1 := 1;
	endif;

	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);
	
	canEdit := app.myCurrentUserCan(self.myTerminal, PmAdmTransactioneditMaint);
	if self.mode = self.Mode_Cargo_Transaction_Enquiry then
		self.mnuSendToReport.visible := true;
		self.mnuTxnEdit.visible := canEdit;
		self.mnuTxnDelete.visible := canEdit;
		self.mnuTxnUndelete.visible := canEdit;
		self.mnuCargoEnquiry.visible := true; // PAR 31709
		self.mnuEditTransferType.visible := canEdit; //22.11.2018 cnwma1 TFS #42141
	// ### JIRA 33348 22NOV2024 NAVAB1
	elseif self.mode = self.Mode_ContractAccumulation then
		self.mnuSendToReport.visible := true;
		self.mnuTxnEdit.visible := false;
		self.mnuTxnDelete.visible := false;
		self.mnuTxnUndelete.visible := false;
		self.mnuCargoEnquiry.visible := true;
		self.mnuEditTransferType.visible := false;
		self.mnuTxnResync.visible := false;
		self.mnuResetCharge.visible := false;
		self.mnuSetCharge.visible := false;
	else
		self.mnuSendToReport.visible := false;
		self.mnuTxnEdit.visible := false;
		self.mnuTxnDelete.visible := false;
		self.mnuTxnUndelete.visible := false;
		self.mnuCargoEnquiry.visible := false; // PAR 31709
	endif;
	
	// ### JIRA 33348 22NOV2024 NAVAB1
	if self.mode &lt;&gt; self.Mode_ContractAccumulation then
		self.mnuTxnResync.visible := app.myCurrentUserCan(self.myTerminal, PmAdmResyncTrans);	//BUG 46339 
		
		self.mnuSetCharge.visible := canEdit;
		self.mnuResetCharge.visible := canEdit;
	endif;
	// for multiply-selected transactions, limit the options
//	if self.tblTransactions.allSelectedObjects.size &gt; 1 then
	if self.tblTransactions.allSelectedObjects.size &gt; 1 and not self.canMultiEdit() then	//21 Mar 2014	NDL	Par 27441
		self.mnuTxnEdit.visible			  := false;
		self.mnuEditTransferType.visible  := false; //22.11.2018 cnwma1 TFS #42141
	endif;
	//22.11.2018 cnwma1 TFS #42141
	if self.tblTransactions.allSelectedObjects.size &gt;= 1 and self.canMultiEdit then 
		if self.tblTransactions.allSelectedObjects.first.isKindOf(CM_ReleaseShip) or 
		   self.tblTransactions.allSelectedObjects.first.isKindOf(CM_ReceiveShip) then
		   self.mnuEditTransferType.visible			  := true;
		else
			self.mnuEditTransferType.visible  := false;
		endif;
	endif;
	
	self.mnuPrint.visible := true;
	// PAR 31709 self.mnuCargoEnquiry.visible := true;
	self.mnuColumnOrganiser.visible := true;
	self.mnuColumnOrganiser.userObject := null;		//28 Apr 2016	NDL	TFS 1903

	self.mnuShowInvoice.visible := false;
	self.mnuTxnAdd.visible := false;
	self.mnuTxnResources.visible  := false;
	self.mnuTxnViewAudits.visible := false;
	self.mnuEditBookingRefDiscr.visible := false;
	self.mnuEditDiscrepRemarks.visible := false;
	self.mnuInformation.visible := app.isSpecial;
	
	//24/05/2023  navmv20 CR 57925 Task 57921 - START		
	txn := self.tblTransactions.accessRow(self.tblTransactions.row).itemObject.CM_Transaction;
	if txn &lt;&gt; null and txn.isKindOf( CM_WOTransaction ) then
		self.mnuTxnResources.visible := txn.CM_WOTransaction.hasTaskThatAllowsResources() and txn.CM_WOTransaction.hasTaskThatIsComplete();
		self.mnuTxnResources.userObject := txn;
	elseif txn &lt;&gt; null and txn.isKindOf( CM_EventTransaction ) then
		self.mnuTxnResources.visible := txn.CM_EventTransaction.hasTaskThatAllowsResources() and txn.CM_EventTransaction.hasTaskThatIsComplete();
		self.mnuTxnResources.userObject := txn;
	endif;	
	//24/05/2023  navmv20 CR 57925 Task 57921 - END	
	
	self.popupMenu(self.mnuContext, x1.Integer, y1.Integer);
	
	// ### JIRA 33348 22NOV2024 NAVAB1
	if self.mode = self.Mode_ContractAccumulation then
		return false;
	endif;

	canEdit := app.myCurrentUserCan(self.myTerminal, PmAdmTransactioneditMaint) and self.myWorkOrder = null and self.myWorkOrderDtl = null;		//11.7.2023 navhl20 #59116
	self.mnuTxnAdd.visible := canEdit;
	self.mnuTxnEdit.visible := canEdit;
	self.mnuTxnDelete.visible := canEdit;
	self.mnuTxnUndelete.visible := canEdit;
	return false;

end;</source>
        <access>protected</access>
