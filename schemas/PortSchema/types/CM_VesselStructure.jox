	/*allChildElements 	: JadeXMLElementArray;
	childElement 		: JadeXMLElement;
	pxyTank  			: CM_VesselTankVessel;
	pxySection			: CM_VesselSectionVessel;*/
begin

	inheritMethod(_property, _xmlElement);	

	/*if _property = CM_VesselStructure::allTanks then
		create allChildElements transient;
		_xmlElement.getAllElementsByTagName(CM_VesselTankVessel.name,allChildElements);
		foreach childElement in allChildElements do
			create pxyTank transient;
			pxyTank.setMyVesselStructure(self);
			pxyTank.importFromXMLDoc(childElement);
		endforeach;
	elseif _property = CM_VesselStructure::allSections then
		create allChildElements transient;
		_xmlElement.getAllElementsByTagName(CM_VesselSectionVessel.name,allChildElements);
		foreach childElement in allChildElements do
			create pxySection transient;
			pxySection.setMyVesselStructure(self);
			pxySection.importFromXMLDoc(childElement);
		endforeach;
	else
		inheritMethod(_property, _xmlElement);
	endif;*/
	
epilog
	//delete allChildElements;
end;</source>
        <access>protected</access>
        <Parameter name="_property" type="Property"/>
