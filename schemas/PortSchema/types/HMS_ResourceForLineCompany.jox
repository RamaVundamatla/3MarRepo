<Class name="HMS_ResourceForLineCompany" id="60a2b09f-4305-4595-adb7-44913bd10fb3">
    <superclass name="HMS_ResourceForObject"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="harbour"/>
    <ExplicitInverseRef name="allLineCompanys" id="875b0503-d098-41ab-98c7-5a4847f05716">
        <updateMode>manual</updateMode>
        <type name="HMS_LineCompanyByCodeDict"/>
        <access>readonly</access>
        <Inverse name="HMS_LineCompany::allResourceForLineCompany"/>
    </ExplicitInverseRef>
    <ImplicitInverseRef name="myLineCompany" id="e25724bb-1990-4e30-ac39-ade20d97e02b">
        <embedded/>
        <type name="HMS_LineCompany"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="getObjectDescription" id="e4886b2f-5f5b-499a-bafa-189173b9ed98">
        <source>getObjectDescription(): String;
// ---------------------------------------------------------------------------
// Created:     22 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	return 	self.myLineCompany.getDisplayString;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setLineCompany" id="484fb6fd-a34b-4d75-8d69-27974a2bec4e">
        <updating/>
        <source>setLineCompany(_lineCompany	: HMS_LineCompany)updating;
// ---------------------------------------------------------------------------
// Created:     21 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars

begin
	self.myLineCompany := _lineCompany;
	self.myHMSObject := _lineCompany;
	
	if _lineCompany &lt;&gt; null and not self.allLineCompanys.includes(_lineCompany) then 
		self.allLineCompanys.add(_lineCompany);
	endif;
end;</source>
        <Parameter name="_lineCompany" type="HMS_LineCompany"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="035020bb-3b40-4315-b8c1-93431f0a1aa7">
        <updating/>
        <source>setProxy(_obj: HMS_Object; _harbour: HMS_Harbour; _arrivalResource: HMS_Resource; _departResource: HMS_Resource; _shiftResource: HMS_Resource) updating;
// ---------------------------------------------------------------------------
// Created:     21 February 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	lineCompany		: HMS_LineCompany;
begin
	inheritMethod(_obj, _harbour, _arrivalResource, _departResource, _shiftResource);
	lineCompany := _obj.HMS_LineCompany;
	
	self.myLineCompany := lineCompany;
	self.myHMSObject := lineCompany;
	
	if lineCompany &lt;&gt; null and not self.allLineCompanys.includes(lineCompany) then 
		self.allLineCompanys.add(lineCompany);
	endif;
end;</source>
        <Parameter name="_obj" type="HMS_Object"/>
        <Parameter name="_harbour" type="HMS_Harbour"/>
        <Parameter name="_arrivalResource" type="HMS_Resource"/>
        <Parameter name="_departResource" type="HMS_Resource"/>
        <Parameter name="_shiftResource" type="HMS_Resource"/>
    </JadeMethod>
</Class>
