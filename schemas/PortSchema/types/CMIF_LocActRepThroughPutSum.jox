    <JadeMethod name="getWeightAsST" id="8f162ae0-eb7d-42f6-b6cd-42725f8d3139">
        <source>getWeightAsST():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 June 2021	navndl1	Initial creation	TFS 51245

*/

vars

	measure : CM_MeasurementType;
	retVal : String;
	zero : Decimal[14,4];

begin

	measure := CM_Root.firstInstance.allMeasurementTypesByShortName["ST"];
	if measure &lt;&gt; null then
		if self.weight = 0 then
			retVal := zero.asStringJMTWithPrecision(measure.getDecimalPrecision, false);
		else
			retVal := measure.convertMeasurementForDisplay( self.weight );
		endif;
	endif;
	
	return retVal;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWeightYTDAsST" id="9ec342b4-7e36-4017-959e-f15df784fe2f">
        <source>getWeightYTDAsST():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 June 2021	navndl1	Initial creation	TFS 51245

*/

vars

	measure : CM_MeasurementType;
	retVal : String;


begin

	measure := CM_Root.firstInstance.allMeasurementTypesByShortName["ST"];
	if measure &lt;&gt; null then
		retVal := measure.convertMeasurementForDisplay( self.weightYTD );
	endif;
	
	return retVal;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="incrementCountWeight" id="60625305-377e-45cf-82ce-6d3a8ba7475c">
        <updating/>
        <source>incrementCountWeight( _locAct : CMEVT_LocationActivity; _count : Integer )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2021	navndl1	Initial creation	TFS 51245

*/

vars

begin

	self.count := self.count + _count;
	self.weight := self.weight + _locAct.weight;

epilog

end;</source>
        <Parameter name="_locAct" type="CMEVT_LocationActivity"/>
        <Parameter name="_count" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="incrementYTDCountWeight" id="969b623d-f4ef-4a3a-85df-f9881491c03a">
        <updating/>
        <source>incrementYTDCountWeight( _weight : Decimal; _count : Integer )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 June 2021	navndl1	Initial creation	TFS 51245

*/

vars

begin

	self.countYTD := self.countYTD + _count;
	self.weightYTD := self.weightYTD + _weight;

epilog

end;</source>
        <Parameter name="_weight" type="Decimal"/>
        <Parameter name="_count" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="isFromBarge" id="3ffea746-6295-404a-b997-16f44f2b6693">
        <source>isFromBarge(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2021	navndl1	Initial creation	TFS 51243

*/

vars

begin
	return self.modeInt.isOneOf( LocnActMoveDir_BargeToYard, LocnActMoveDir_BargeToVessel );

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
