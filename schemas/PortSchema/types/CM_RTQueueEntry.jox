    </JadeMethod>
    <JadeMethod name="isChildTiEntry" id="105bd15f-5da3-409e-96e2-449ccb75291b">
        <source>isChildTiEntry():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 July 2014	cnwndl1	Initial creation	Par 34665

*/

vars

	ti : CM_TrackedItem;
	invalid : Boolean;

begin

	if self.myWorkListEntry = null then
		return false;
	endif;
	
	on Exception do app.handleDeletedObject( exception, self.myWorkListEntry, invalid );
	ti := self.myWorkListEntry.getMyTrackedITem();
	
	if ti = null or invalid then
		return false;
	endif;
	
	return ti.isChild;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isFirstDirectorEntry" id="4ffe80d0-b6b8-4f2b-890b-91b350d34bd5">
        <source>isFirstDirectorEntry(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 November 2010	cnwrd1	Initial creation

*/

vars

begin
	//epr par 35702 CCMS 2457 17/2/15
	if self.isMultiMachineDirector() and self.getPreviousRelatedEntry() = null then
		return true;
	else
		return false;
	endif;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isHeldFromOverstowMove" id="fd288823-fb90-45e9-88b5-eaa74c97dde8">
        <source>isHeldFromOverstowMove() : Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 November 2011	cnwrd1	Initial creation

*/

vars
	aThing : CM_Object;
	anAlert : CM_SystemAlert;
	aTI : CM_TrackedItem;
begin

	if not self.hasHeldTasks then
		return false;
	endif;
	
	aTI := self.myWorkListEntry.myTrackedItem ;
	
	if aTI = null then
		return false;
	endif;
	
	foreach aThing in self.alerts do
		if aThing.isKindOf(CM_SystemAlert) then
			anAlert := aThing.CM_SystemAlert;			
			if anAlert.details = aTI.id.trimBlanks &amp; app.getErrorString(Queue_entry_held_preve_conflct) then
				return true;
			endif;		
		endif;		
	endforeach;

	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isLoadBargeMoveToInterchange" id="139700d2-358b-404c-b5bb-c20aef77d76a">
        <source>isLoadBargeMoveToInterchange():Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 June 2021	navndl1	Initial creation	TFS	TFS 51245

*/

vars

	lc	: CM_LocationsController;
	ti : CM_TrackedItem;
	voyage : CM_Voyage;
	
begin	
	
	if self.myWorkListEntry = null then
		return false;
	endif;
	
	ti := self.myWorkListEntry.myTrackedItem;
	if ti = null or not ti.isExport then
		return false;
	endif;
	
	voyage := ti.myVoyage;
	if voyage = null or not voyage.isBarge then
		return false;
	endif;
	
	lc := self.myWorkListEntry.getTargetLocation;
	if lc = null then
		return false;
	endif;
	
	if lc.isKindOf(CM_YardICAreaLaneController) then
		return true;
	elseif lc.isKindOf(CM_CraneLaneController) then
		return true;
	endif;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isMachineWorkingEntry" id="80effc6d-a15d-42e3-a585-19f65c97d49d">
        <source>isMachineWorkingEntry(_machine : CM_Machine) : Boolean;
/*

Date		Who		Reason
17 February 2015	cnwer1	Initial creation PAR 35702 CCMS 2457

*/

vars
	task : CM_RTQueueTask;
begin
	foreach task in self.allTasks discreteLock do
		if task.myMachine = _machine then
			return true;
		endif;
	endforeach;
	return false;
epilog

end;</source>
        <Parameter name="_machine" type="CM_Machine"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isMultiMachineDirector" id="82e37aac-fa48-48bf-af7f-9ce918cdb4e0">
        <source>isMultiMachineDirector(): Boolean;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 November 2010	cnwrd1	Initial creation
//cnwrd1 par 25681 18.11.2010 multi machine director moves
*/

vars
	result : Boolean;
begin
// currently just checking if we are a director task

	result := false; //yeah i kno...
	//epr par 35702 CCMS 2457 17/2/15
	if self.isMultiMachineMove then
		if  self.isOriginalDirector() then 
			result := true;
		endif;
	endif;

	return result;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isMultiMachineMove" id="95bae492-ef94-4017-af7e-c89ec86a76b7">
        <source>isMultiMachineMove() : Boolean;
/*

Date		Who		Reason
05 February 2015	cnwer1	Initial creation PAR 35702 CCMS 2457

*/

vars

begin
	return self.getPreviousRelatedEntry &lt;&gt; null or self.getNextRelatedEntry() &lt;&gt; null;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isMultiQueueEntry" id="a71dae0c-c3a2-49b3-be7c-72f41cc0e570">
        <source>isMultiQueueEntry() : Boolean;

// Created by cnwdvb1 on 17 September 2007

vars

begin

	if self.myWorkListEntry &lt;&gt; null then
