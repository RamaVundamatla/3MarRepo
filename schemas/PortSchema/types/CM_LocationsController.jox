    <JadeMethod name="getTiTxnTypesForMoveToFromLC" id="510265af-1569-4184-939f-09d78d114f2c">
        <source>getTiTxnTypesForMoveToFromLC(_fromController : CM_LocationsController; _intArray : IntegerArray input; _moveController : CMIF_MoveController);
// ---------------------------------------------------------------------------
// Created:     06 January 2004 by cnwrs2
//
// Purpose:     Setup the transactions to be added for a move to this location from
//				another LC.
// ---------------------------------------------------------------------------
vars
	voyageJob : CM_VoyageJob;
	shipReceive: CM_ReceiveShip;
	voyage : CM_Voyage;
begin
	if _fromController.isKindOf(CM_VoyageController) and not self.isKindOf(CM_VoyageController) then	
		voyage:=_fromController.CM_VoyageController.myVoyage;
		
		//if the to location is a trailer check it is not on a voyage - that would just be a on ship move don't need rec ship trxs
		//jlier1 TFS 65230 16/7/24
		if self.isKindOf(CM_TILCController) then
			if self.CM_TILCController.myTILC.myPrimaryActualLocation.isKindOf(CM_VoyageController) then
				return;
			endif;
		endif;
		
		
		if CM_VoyageJob.hasInstance(_moveController.jobForMove) then
			voyageJob := _moveController.jobForMove.CM_VoyageJob;
		elseif _moveController.myWorkListEntry &lt;&gt; null and CM_VoyageJob.hasInstance(_moveController.myWorkListEntry.job) then
			voyageJob := _moveController.myWorkListEntry.job.CM_VoyageJob;		
		endif;
	/* 06 Nov 2014	NDL	Par 35015
		if _moveController.myTrackedItem &lt;&gt; null and _moveController.myTrackedItem.canSplitTotalQuantity  and voyage&lt;&gt; null then
			//epr par 32776
			shipReceive:=voyage.getTITransactionForTIId(TRANS_TYPE_REC_SHIP,_moveController.myTrackedItem.id).CM_ReceiveShip;
			
			if shipReceive &lt;&gt; null then
				return;
			endif;			
		endif;
	*/
			
		_intArray.add(TRANS_TYPE_MOVE_CRANE); // ### TFS 51855 03FEB2022 NAVAB1
		_intArray.add(TRANS_TYPE_REC_SHIP);
		_intArray.add(TRANS_TYPE_WHARFAGE);
		app.addTiTxnSubTerminalReceive(_moveController.myTrackedItem, TI_TRANSMODE_SHIP, _intArray);			// PAR 20706 (swap order)
		
		
		if ( voyageJob &lt;&gt; null and voyageJob.isExportReturn ) or _moveController.isExportReturn then	//07 Sep 2012	NDL	Par 30319
			_intArray.add(TRANS_TYPE_EXPORT_RETURNED);			
		endif;
	
	endif;
end;</source>
        <Parameter name="_fromController" type="CM_LocationsController"/>
        <Parameter name="_intArray" type="IntegerArray" usage="input"/>
        <Parameter name="_moveController" type="CMIF_MoveController"/>
    </JadeMethod>
