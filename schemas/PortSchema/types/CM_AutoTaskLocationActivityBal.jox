    <JadeMethod name="setValueForRow" id="0b1b093b-1706-43a0-b15e-656c7446e894">
        <updating/>
        <source>setValueForRow(_rowName: String; _value: Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 May 2021	navndl1	Initial creation	TFS 50906

*/

vars

begin
	if _rowName = ETRow_RecalculateOnly then
		self.recalculateOnly := _value.Boolean;
	else
		inheritMethod(_rowName, _value);
	endif;

epilog

end;</source>
        <Parameter name="_rowName" type="String"/>
