    <JadeMethod name="getStringForRowDecTotal" id="06f4b51f-2b8e-418a-8f0f-49fa44d3f2ab">
        <source>getStringForRowDecTotal(_array : DecimalArray): String;
// ---------------------------------------------------------------------------
// Created:     01 December 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	str	: String;
	totDec,
	tmpDec	:  Decimal[12,1];
	array : DecimalArray;
	
begin
	array := _array;


	foreach tmpDec in array do
		totDec := totDec + tmpDec;
		if tmpDec = null then 
			str := str  &amp; Tab;
		else
			str := str &amp; tmpDec.String &amp; Tab;
		endif;
	endforeach;
	
	// add in total at right place
	str := str &amp; Tab &amp; Tab  &amp; totDec.String;
	
	return str; 

end;</source>
        <Parameter name="_array" type="DecimalArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStringForRowIntTotal" id="680ad81f-6483-4edb-8d47-e021148f5eb9">
        <source>getStringForRowIntTotal(_array : IntegerArray): String;
// ---------------------------------------------------------------------------
// Created:     01 December 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	str	: String;
	totInt,
	tmpInt	: Integer;
	array : IntegerArray;
	
begin
	array := _array;


	foreach tmpInt in array do
		totInt := totInt + tmpInt;
		if tmpInt = null then 
			str := str  &amp; Tab;
		else
			str := str &amp; tmpInt.String &amp; Tab;
		endif;
	endforeach;
	
	// add in total at right place
	str := str &amp; Tab &amp; Tab &amp; totInt.String;
	
	return str; 
end;</source>
        <Parameter name="_array" type="IntegerArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStringforRow" id="08c3506e-6ba5-46ff-a855-0a03b1d04875">
        <source>getStringforRow(_strArray : StringArray): String;
// ---------------------------------------------------------------------------
// Created:     17 November 2005	cnwhjg1
//
// Purpose:     Create a string from Array that will be able to be used to 
//				populate a row of a table. The String array passed in should be 
//				in order for the row from left to right and have nulls for the 
//				cells that are to be blank. 
// ----------   ----------  --------------------------------------------------
vars
	str,
	tmpString	: String;
	stringArray : StringArray;
begin
	stringArray := _strArray;


	foreach str in stringArray do
		
		if str = null then 
			tmpString := tmpString &amp; Tab;
		else
			tmpString := tmpString &amp; str &amp; Tab;
		endif;
	endforeach;
		
	return tmpString[1:tmpString.length-1]; // CUT OFF LAST TAB. 

end;</source>
        <Parameter name="_strArray" type="StringArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="populateTable" id="4ae26079-84bb-4de8-8889-804b575358a9">
        <source>populateTable() protected;
// ---------------------------------------------------------------------------
// Created:     07 November 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	voySummary										: CMIF_VoyageSummary;
	tbl												: Table;
	weightEmpty, weightRowEmpty,
	weightReefer, weightRowReefer, columnWeightTot,
	weightFull, weightRowFull,
	weightIsoGroupTotal, weightOperatorTotal		: Decimal[12,1];
	colWeightTotalsArray							: DecimalArray;
	colNumsTotalsArray								: IntegerArray;
	opRow, intFixedColumn, columnNumTot,
	numIsoGroupTotal, numOpTotal,
	numEmptyRowTotal,numFullRowTotal, numReeferRowTotal,
	numRows, row, arrayColumn,
	column, int										: Integer;
	iter											: Iterator;
	summaryDict										: CMIF_VoyageSumLoadByValueDict;
	strfull, strMT,	strReef,
	str, previousKey1, previousKey2					: String;
	strFullArrayNum, strMTArrayNum,
	strReefArrayNum, strFullArrayWeight,
	strMTArrayWeight,strReefArrayWeight,
	strArray										: StringArray;
	emptyRow, fullRow, reeferRow,
	newOp							: Boolean;

begin
	summaryDict := self.myJRWVoyageSummary.allVoyageLoadSumObjects;

	tbl := self.tblReport;
	//setup column and rows headings////////////////
	tbl.rows := 2;
	tbl.fixedRows := 2;
	tbl.columns := 3;
	tbl.accessRow(2).alignment := Table.Alignment_Center;
	tbl.accessedRow.fontSize := 9;
	tbl.accessedRow.fontBold := true;
//	tbl.accessColumn(1).backColor := Grey;
	tbl.fixedColumns := 3;
//	tbl.accessColumn(4).width := 1;
//	tbl.accessColumn(4).backColor := Black;
	intFixedColumn := tbl.fixedColumns;
//	intFixedColumn := 4;
	/////////////////////////////////////////////////
	
	iter := summaryDict.createIterator;
	create strArray transient;
	create strReefArrayNum transient;
	create strFullArrayNum transient;
	create strMTArrayNum transient;
	create strFullArrayWeight transient;
	create strMTArrayWeight transient;
	create strReefArrayWeight transient;
	create colNumsTotalsArray transient;
	create colWeightTotalsArray transient;

	self.sortDischargeHeadings(strArray);

	// setup totals array for columns so later can populate with totals 
	colNumsTotalsArray[strArray.size] := 0;  // assign 0 to end of array so all previous elements of array can now be accesed. 
	colWeightTotalsArray[strArray.size] := 0;

	foreach str in strArray do // for each discharge port add column and heading. 
		column := tbl.columns;
		tbl.columns := column + 1;
		column := column + 1;
		tbl.accessCell(2, column).text := str;
		if str = null then // null for discharge port so put something constructive in header instead
			tbl.accessCell(2, column).text := 'N/A';
		endif;
	endforeach;
	
	// Add Totals colum // one for row total, one for Iso Group total and one for Op total.
	column := tbl.columns;
	tbl.columns := column + 3;
	column := column + 2;
	tbl.accessCell(2, column).text := 'Totals';
	
	// now add the title for 'Ports of Discharge'
	int := (strArray.size()/2).Integer; // half number of new cols and bang in there (will be offset left by fixed columns)
	int := int + intFixedColumn;
	// tried to merge cells but didnt work. have to spread heading out. 
	tbl.accessCell(1, int).text := 'Port of';
	tbl.accessedCell.alignment := Table.Alignment_Right;
	tbl.accessedCell.fontBold := true;
	tbl.accessedCell.fontSize := 9;

	tbl.accessCell(1, int + 1).text := 'Disch.';
	tbl.accessedCell.alignment := Table.Alignment_Left;
	tbl.accessedCell.fontBold := true;
	tbl.accessedCell.fontSize := 9;

	while iter.next(voySummary) do
				///////////// ADD OPERATOR ROW \\\\\\\\\\\\\\\\\\
		if previousKey1 &lt;&gt; voySummary.keyValue1 then
			// new operator so add row and heading - will only go in here ONCE for each operator
			previousKey1 := voySummary.keyValue1;   			

			weightOperatorTotal := 0; // clear any previous totals
			numOpTotal			:= 0;

			// add thickline first
			row := tbl.rows;
			tbl.rows := row + 1;
			row := row + 1;
			tbl.accessRow(row).height := 3;
			tbl.accessRow(row).backColor := Black;

			// add row for header
			row := tbl.rows;
			tbl.rows := row + 1;
			row := row + 1;
			opRow := row; // remember for later when adding operator totals.
			
			tbl.accessCell(row, 1).text := voySummary.keyValue1;			 
			tbl.accessedCell.alignment := Table.Alignment_Center;
			tbl.accessedCell.fontSize := 14;
			tbl.accessedCell.fontBold := true;
			newOp := true;
			
			// reset all the values needed before adding new Op 
			
			// Set previous key to a string that will never be used as a discharge port.  CANNOT SET previousKey2 TO NULL.
			// null can be a valid key, so needs to be set to something that will never occur. 
			previousKey2 := 'Something That will never be used' ;  
						
			
			// loop through all with same operator to display each Iso Group for that operator in turn
			foreach voySummary in summaryDict where voySummary.keyValue1 = previousKey1 do	
				if voySummary.keyValue1 &lt;&gt; previousKey1 then  // double check that not getting other operators data
					continue;
				endif;

					///////////// ADD ISO GROUP ROW \\\\\\\\\\\\\\\\\\			
				if previousKey2 &lt;&gt; voySummary.keyValue2 then
					// new iso type so add heading - will only go in here ONCE for each iso group per operator				
					
					if newOp then // dont add row as one has been added for operator heading
					   newOp := false; //reset so that next time a new row is added if new iso group
					else
						row := tbl.rows;
						tbl.rows := row + 1;
						row := row + 1;
						tbl.accessRow(row).height := 1;
						tbl.accessRow(row).backColor := Grey;
						
						row := tbl.rows;
						tbl.rows := row + 1;
						row := row + 1;
					endif;

					tbl.accessCell(row, 2).text := voySummary.keyValue2;
					previousKey2 := voySummary.keyValue2;
					
					if previousKey2 = null then // has null for Iso Group so  put something constructive in header instead
						tbl.accessCell(row, 2).text := 'N/A';
					endif;
					
					tbl.accessedCell.fontBold := true;
					tbl.accessedCell.fontSize := 10;

					// reset all the values needed before adding a Iso Group Row
					emptyRow := false;
					fullRow := false;
					reeferRow := false;
					strReefArrayNum.purge();
					strFullArrayNum.purge();
					strMTArrayNum.purge();
					strFullArrayWeight.purge();
					strMTArrayWeight.purge();
					strReefArrayWeight.purge();
					numEmptyRowTotal		:= 0;
					weightRowEmpty			:= 0;
					numFullRowTotal			:= 0;
					weightRowFull			:= 0;
					numReeferRowTotal		:= 0;
					weightRowReefer			:= 0;
					weightIsoGroupTotal		:= 0;
					numIsoGroupTotal		:= 0;
						//////////////////////// BUILD UP ROW DATA FOR EACH ISO GROUP BY OPERATOR \\\\\\\\\\\\\\\\\\\\\\\\\
						// loop through all with same iso group to get row of data for table 
						foreach voySummary in summaryDict where voySummary.keyValue2 = previousKey2 do 
							if voySummary.keyValue1 &lt;&gt; previousKey1 then
								continue;  // only want Operator we are interested in
							endif;
		
							//find the column that the data corresponds to (what discharge port) so we can build an ordered string later
							arrayColumn := strArray.indexOf(voySummary.keyValue3);
							column := arrayColumn + intFixedColumn;		
							
							// column totals are kept in a array. get current total.
							columnNumTot := colNumsTotalsArray[arrayColumn];
							columnWeightTot := colWeightTotalsArray[arrayColumn];
							
							if not voySummary.numEmpty = 0 then 
								// put in number and weight in correct column order 
								strMTArrayNum[arrayColumn] := voySummary.numEmpty.String;
								weightEmpty := (voySummary.weightEmpty / 1000).roundedTo(1);
								strMTArrayWeight[arrayColumn] := weightEmpty.String;
								emptyRow := true;
								// keep a total for the row
								weightRowEmpty := weightRowEmpty + weightEmpty; 
								numEmptyRowTotal := numEmptyRowTotal + voySummary.numEmpty;
								// no keep track of column totals
								columnNumTot := columnNumTot + voySummary.numEmpty; 
								columnWeightTot := columnWeightTot + weightEmpty;	
							endif;
							
							if not voySummary.numGeneral = 0 then 
								// put in number and weight in correct column order 
								strFullArrayNum[arrayColumn] := voySummary.numGeneral.String;
								weightFull := (voySummary.weightFull/ 1000).roundedTo(1);
								strFullArrayWeight[arrayColumn] := weightFull.String;
								fullRow := true;
								weightRowFull := weightRowFull + weightFull; // keep a total for the row
								numFullRowTotal := numFullRowTotal + voySummary.numGeneral;
								// no keep track of column totals
								columnNumTot := columnNumTot + voySummary.numGeneral; 
								columnWeightTot := columnWeightTot + weightFull;
							endif;
							
							if not voySummary.numReefer = 0 then 
								// put in number and weight in correct column order 
								strReefArrayNum[arrayColumn] := voySummary.numReefer.String;
								weightReefer := (voySummary.reeferWeight/ 1000).roundedTo(1);
								strReefArrayWeight[arrayColumn] := weightReefer.String;						
								reeferRow := true;
								weightRowReefer := weightRowReefer + weightReefer; // keep a total for the row
								numReeferRowTotal := numReeferRowTotal + voySummary.numReefer;
								// no keep track of column totals
								columnNumTot := columnNumTot + voySummary.numReefer; 
								columnWeightTot := columnWeightTot + weightReefer;							
							endif;
							
							// store away column Total so can add to later when moving to next operator // stored by order of discharge port
							colNumsTotalsArray[arrayColumn] := columnNumTot;
							colWeightTotalsArray[arrayColumn] := columnWeightTot;

							
						endforeach;	
						
					arrayColumn := strArray.size(); // number of columns according to number of discharge ports
					column := arrayColumn + 1;		// only add one as it is going into an ordered array that will populate a string for the row. 
					// add totals to end of array
					strMTArrayWeight[column] := weightRowEmpty.String;
					strFullArrayWeight[column] := weightRowFull.String;
					strReefArrayWeight[column] := weightRowReefer.String;
					strMTArrayNum[column] := numEmptyRowTotal.String;
					strFullArrayNum[column] := numFullRowTotal.String;
					strReefArrayNum[column] := numReeferRowTotal.String;
					
					weightIsoGroupTotal := weightRowEmpty + weightRowFull + weightRowReefer;
					numIsoGroupTotal	:= numEmptyRowTotal + numFullRowTotal + numReeferRowTotal;
					weightOperatorTotal := weightOperatorTotal + weightIsoGroupTotal; //keep total for operator
					numOpTotal			:= numOpTotal + numIsoGroupTotal;
					
					// add row so can put in both totals for Iso Group. (at present only one row there for the Iso Group heading) 					
					row := tbl.rows;
					tbl.rows := row + 1;  
					row := row + 1;	

					column := arrayColumn + intFixedColumn + 2;	// equals number of columns for discharge ports + fixed cols + TWO col for row total. 

					tbl.accessCell(row -1,column).text := numIsoGroupTotal.String;
					tbl.accessCell(row, column).text := weightIsoGroupTotal.String; 
						
					//////////////  DISPLAY ROWS FOR A ISO GROUP \\\\\\\\\\\\\\\\\\\\\\\\\\\\\\\
					if emptyRow then 
						// dont need to add any rows as have been added for heading and totals for iso group 
//						row := tbl.rows;
//						tbl.rows := row + 1;  
//						row := row + 1;	
						tbl.accessCell(row - 1,3).text := 'E'; // Empty
						// populate rows with string built from array that has been ordered from dishcarge port headings
						tbl.accessCell(row - 1, intFixedColumn + 1).text := self.getStringforRow(strMTArrayNum);
						tbl.accessCell(row ,intFixedColumn + 1).text := self.getStringforRow(strMTArrayWeight);
					endif;					
					if fullRow then 
						if emptyRow then // this means the rows which was added for the ISO Group heading has already been populated so need to add two more
							row := tbl.rows;
							tbl.rows := row + 2;  
							row := row + 2;	
						endif;
						
						tbl.accessCell(row - 1,3).text := 'F'; // Full
						tbl.accessCell(row - 1,intFixedColumn + 1).text := self.getStringforRow(strFullArrayNum);
						tbl.accessCell(row ,intFixedColumn + 1).text := self.getStringforRow(strFullArrayWeight);								
					endif;
					if reeferRow then 
						if emptyRow or fullRow then // this means the row which was added for the ISO Group heading has already been populated so need to add two more
							row := tbl.rows;
							tbl.rows := row + 2;  
							row := row + 2;	
//						else // first row still not populated so only need to add one row
//							row := tbl.rows;
//							tbl.rows := row + 1;  
//							row := row + 1;	
						endif;
						
						tbl.accessCell(row - 1,3).text := 'R';  // Reefer
						tbl.accessCell(row - 1,intFixedColumn + 1).text := self.getStringforRow(strReefArrayNum);
						tbl.accessCell(row ,intFixedColumn + 1).text := self.getStringforRow(strReefArrayWeight);
					endif;
					
					
				endif;				
			endforeach;

		arrayColumn := strArray.size(); // number of columns according to number of discharge ports
		column := arrayColumn + intFixedColumn + 3;	
		// add operator total 
		tbl.accessCell(opRow,column).text := numOpTotal.String;
		tbl.accessCell(opRow + 1 ,column).text := weightOperatorTotal.String;			
		endif;
	endwhile;


	/////////////////		Totals at bottom of page 		\\\\\\\\\\\\\\\\\\\\\\\\\\\\
	
	// add thickline first
	row := tbl.rows;
	tbl.rows := row + 1;
	row := row + 1;
	tbl.accessRow(row).height := 2;
	tbl.accessRow(row).backColor := Black;	
	
	row := tbl.rows;
	tbl.rows := row + 1;
	row := row + 1;
	tbl.accessRow(row).height := 1;
//	tbl.accessRow(row).backColor := Black;	
	
	row := tbl.rows;
	tbl.rows := row + 1;
	row := row + 1;
	tbl.accessRow(row).height := 2;
	tbl.accessRow(row).backColor := Black;	
	
	// can now add totals\
	row := tbl.rows;
	tbl.rows := row + 2;  
	row := row + 2;	
	tbl.accessCell(row -1 ,1).text := 'Total';
	tbl.accessedCell.fontBold := true;
	tbl.accessCell(row - 1,intFixedColumn + 1).text := self.getStringForRowIntTotal(colNumsTotalsArray);
	tbl.accessCell(row ,intFixedColumn + 1).text := self.getStringForRowDecTotal(colWeightTotalsArray);

epilog
	delete iter;
	delete strArray;
	delete strReefArrayNum;
	delete strFullArrayNum;
	delete strMTArrayNum;
	delete strFullArrayWeight;
	delete strMTArrayWeight;
	delete strReefArrayWeight;
	delete colNumsTotalsArray;
	delete colWeightTotalsArray;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setNoDataDisplay" id="60935a4e-3fbc-41a0-92be-5d8b1b9f543d">
        <source>setNoDataDisplay();
// -------------------------------------------
// Created 23 September 2004 by cnwdvb1
// -------------------------------------------
vars

begin
	
	self.lblNoData.caption := 'No Data To Display For Voyage Load ISO Group Summary';



end;</source>
    </JadeMethod>
    <JadeMethod name="setupHeader" id="82e95f78-8852-45fd-8789-1de55a4939ea">
        <source>setupHeader() protected;
// ---------------------------------------------------------------------------
// Created:     07 November 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
constants
	Gap = 5;
vars

begin
	self.frmHeader.height := 145;
	self.lblPage.top := self.lblPrinted.top;
	self.lblHeading3_1.top := self.lblPrinted.top;
	self.lblHeading3_1.left := self.lblHeading3_1.left - Gap;
	
	self.lblTerminalName.visible := false;
	self.lblReportId.visible := false;
	self.lblPrinted.top := self.picPortLogo.top + self.picPortLogo.height + Gap;
	self.lblPrinted.left := self.lblPrinted.left - 10;
	self.lblPrintedDtl.top := self.lblPrinted.top;
	self.lblPrintedDtl.left := self.lblPrintedDtl.left - 10;
	self.lblPrintTime.top := self.lblPrinted.top;
	self.lblPrintTime.left := self.lblPrintTime.left - 15;
	
	self.picJadeLogo.picture := app.getPicLogoProduct;
	self.picPortLogo.picture := app.getPicLogoPort;
	self.picJadeLogo.visible := true;
	self.picPortLogo.visible := true;
	self.picJadeLogo.zOrder(1);
	self.picPortLogo.zOrder(1);
	
	self.lblHeading1.caption := 'Container Summary by ISO Groups';
							
	self.lblHeading1.alignment := self.lblHeading2.Alignment_Center_Middle;
	self.lblHeading1.top := 10;
	self.lblHeading1.height := 20;
	self.lblHeading1.fontSize := 12;
	self.lblHeading1.fontBold := true;
	
//	self.lblHeading2.caption := self.myJRWVoyageSummary.orderedByHeading1 &amp; 
//							' by ' &amp; self.myJRWVoyageSummary.orderedByHeading2 &amp; 
//							' - ' &amp; self.myJRWVoyageSummary.modeDescription;

	self.lblHeading2.caption := self.myJRWVoyageSummary.myVoyage.code &amp; ' - ' &amp; 
							self.myJRWVoyageSummary.myVoyage.vesselName.trimBlanks;
	self.lblHeading2.alignment := self.lblHeading2.Alignment_Center_Middle;
	self.lblHeading2.top := 40;
	self.lblHeading2.height := 20;
	self.lblHeading2.fontSize := 12;
	self.lblHeading2.fontBold := true;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTable" id="264e6685-b170-4eda-91d3-c297ee90f08a">
        <source>setupTable() protected;
// ---------------------------------------------------------------------------
// Created:     21 July 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	inheritMethod();
	self.tblReport.fontSize := 10;
	self.tblReport.gridLines := false;
	self.tblReport.alignment := self.tblReport.Alignment_Right_Middle;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="sortDischargeHeadings" id="e5262797-1aec-43ae-ad44-1d7cbf3d37cf">
        <source>sortDischargeHeadings(strArray	: StringArray io);
// ---------------------------------------------------------------------------
// Created:     09 December 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	summaryDict										: CMIF_VoyageSumLoadByValueDict;
	sorterObj										: CnEcSorter;	
	voySummary										: CMIF_VoyageSummary;	
	previousKey3									: String;
begin

	create sorterObj transient;
	
	summaryDict := self.myJRWVoyageSummary.allVoyageLoadSumObjects;
	sorterObj.setSortType(CnEcSorter.AS_STRING, false);
	
	// create strArray to hold headings for Discharge Ports
	foreach voySummary in summaryDict discreteLock do 
		// if key (discharge Port) not seen before then add to strArray (will be used to make up columns later on)
		if previousKey3 &lt;&gt; voySummary.keyValue3 then 
			previousKey3 := voySummary.keyValue3;
			if not strArray.includes(previousKey3) then 
				strArray.add(previousKey3);
			endif;
		endif;
	endforeach;

	strArray.doSort(sorterObj);
	
epilog
delete sorterObj;
end;</source>
        <Parameter name="strArray" type="StringArray" usage="io"/>
    </JadeMethod>
</GUIClass>
