    <JadeMethod name="btnUpdateFromDisk_click" id="c78df405-042f-4cf9-b892-6fbce592f29b">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnUpdateFromDisk_click(btn: Button input) updating;
/*
Purpose:			

Date		Who		Reason
14 October 2021	navab1	TFS 51853
*/

vars
	icon : CMUI_IconFile;
	row : Integer;
	newIcon : Binary;
	filename : String;
begin
	if self.tblData.row &lt;= self.tblData.fixedRows then
		return;
	endif;
	
	row := self.tblData.row;
	icon := self.tblData.accessRow(row).itemObject.CMUI_IconFile;
	
	if icon = null then
		global.beep;
		return;
	endif;

	newIcon := self.picLoadMethod(filename);

	
	if newIcon &lt;&gt; null then
		beginTransaction;
	
		icon.setForUpdate(newIcon);
	
		commitTransaction;
	endif;
	
	self.populateTable();
	
	self.tblData.topRow := row;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initialiseTable" id="5d38f86c-ef15-402c-99af-de06ee939c59">
        <source>initialiseTable();
 // ### TFS 50421 17SEP2021 NAVAB1
vars
	table : CM_DataTable;
begin
	table := self.tblData;
	
	table.selectionType	:= Table.SelectMode_CurrentRow;
	
	
	table.columns := 4;
	table.rows := 0;
	
	table.addItem("Year" &amp; Tab &amp; "Name" &amp; Tab &amp; "Unique" &amp; Tab &amp;  "Disk Icon");
	table.fixedRows := 1;

end;
</source>
    </JadeMethod>
    <JadeMethod name="load" id="e49d7d90-0b81-40b6-8e58-989cb2400738">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;

vars

begin

	app.initialize();

	self.initialiseTable();
	self.populateTable();
	
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="loadNewDiskIcons" id="8172244d-80e6-4cdb-9cb0-12f29eda1ae2">
        <updating/>
        <source>loadNewDiskIcons() updating;
/*
Purpose:			

Date		Who		Reason
27 September 2021	navab1	TFS 51853
*/

vars

	root : CMUI_Root;
	
begin
	
	if app.msgBox("This will PURGE all the new disk icons from this maintenance system and re generate them." &amp; CrLf &amp; CrLf &amp; "Are you sure you want to continue?", "Confirm", MsgBox_OK_Cancel) = MsgBox_Return_Cancel then
		return;
	endif;
	
	app.mousePointer := Form.MousePointer_HourGlass;
	
	self.tblData.rows := self.tblData.fixedRows;
	
	root := CMUI_Root.firstInstance;
	
	root.populateNewIconsFromDisk();
	
	
	self.populateTable();

epilog

end;</source>
    </JadeMethod>
