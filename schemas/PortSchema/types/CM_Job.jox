    <JadeMethod name="getShift" id="340063dc-56ad-4cbf-9347-f6fea0d72e5a">
        <source>getShift():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
07 June 2023		navhl20	ChangeRequest 58543: EUP - Delivery Dispatch – Allocation List - VAS
12 December 2024	navpw1	JIRA: MTN-33528 - Fixed 1090's

*/

vars
	jobSheet	: CM_WorkPointJobSheet;
	shift		: CM_Shift;
	
begin
	jobSheet := self.myJobSheetForWorkPoint;
	
	//if jobSheet &lt;&gt; null then
	//	return jobSheet.myShift.getShiftDay() &amp; Space &amp; jobSheet.myShift.code &amp; Space &amp; jobSheet.myShift.startDateTime.date.asStringJMT();
	//endif;
	
	if jobSheet = null then
		return null;
	endif;
	
	shift := jobSheet.myShift;
	
	if shift = null then
		return null;
	endif;
	
	return shift.getShiftDay() &amp; Space &amp; shift.code &amp; Space &amp; shift.startDateTime.date.asStringJMT();
	
end;</source>
