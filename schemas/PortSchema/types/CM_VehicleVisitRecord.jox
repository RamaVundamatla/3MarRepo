    <JadeMethod name="getSecurityGateInToOutTime" id="4270f7f8-f33a-46d8-8d71-b9d9a58aa8af">
        <source>getSecurityGateInToOutTime() : Integer;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 03/01/2014	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
//
vars
	securityIn,
	securityOut	: TimeStamp;

begin
	securityIn := self.getSecurityGateArrivalTS();
	securityOut := self.getSecurityGateDepartTS();
	
	if securityIn.isValid and securityOut.isValid then
		return securityIn.truncateToMinute.getDifferenceInMinutes(securityOut.truncateToMinute);
	endif;
	
	return 0;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getStatusForSecurityGateForm" id="53ed17df-0150-4069-aa72-6682eae7d048">
        <source>getStatusForSecurityGateForm() : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/12/2013	cnwdap1		Initial creation PAR #32849 CCMS PEN 2321 Security Gate
//
vars

begin
	if not self.allVehicleVisitRecordDetails.isEmpty then
		return self.allVehicleVisitRecordDetails.last.getRecordDetailDescription;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStatusString" id="d7230091-f55a-43ef-a355-1be904917fc1">
        <source>getStatusString() : String;
// ---------------------------------------------------------------------------
// Created:     26 August 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 18/12/2013		cnwdap1			PAR #32849 CCMS PEN 2321 Security Gate
// ---------------------------------------------------------------------------

vars

	
begin
	// Translate
	
	if self.status = CM_VehicleVisitRecord.Status_Trouble then
		return app.getErrorString(GateArea_Trouble);
	elseif self.status = CM_VehicleVisitRecord.Status_Unverified then
		if self.visitType = self.VisitType_SecurityGate then				// PAR #32849
			return app.getErrorString(Security_gate_entry);					// PAR #32849
		else																// PAR #32849
			return app.getErrorString(Pre_Check);
		endif;																// PAR #32849
	elseif self.status = CM_VehicleVisitRecord.Status_Unactioned then
		return app.getErrorString(PRE_GATE);
	elseif self.status = CM_VehicleVisitRecord.Status_Yard then
		return app.getErrorString(OnTerminal);
	elseif self.status = CM_VehicleVisitRecord.Status_Complete then
		return app.getErrorString(Completed);
	elseif self.status = CM_VehicleVisitRecord.Status_Cancelled then
		return app.getErrorString(Cancelled_At_Gate);
	else
		return app.getErrorString(Pre_Check);
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStevedore" id="4029177b-49a1-4776-92ab-326fa091fd40">
        <source>getStevedore():CM_Stevedore;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Nov 2020 cnwma1 ChangeRequest 50112: ASPA - GCI Stevedores

*/

vars
	gte 			: CMGTE_Entity;
	stevedoreCode   : String;
	stevedore       : CM_Stevedore;
begin
	
	if self.myStevedore &lt;&gt; null then
	
		return self.myStevedore;
	else
		foreach gte in self.allGateEntities discreteLock do
		
			if gte.isCMGTE_Receival then
				if gte.CMGTE_Receival.stevedoreCode &lt;&gt; null then
					stevedoreCode := gte.CMGTE_Receival.stevedoreCode;
					break;
				endif;
			elseif gte.isCMGTE_Release then
				if gte.CMGTE_Release.stevedoreCode &lt;&gt; null then
					stevedoreCode := gte.CMGTE_Release.stevedoreCode;
					break;
				endif;
			endif;
		endforeach;
	endif;

	
	if stevedoreCode &lt;&gt; null then
		stevedore := app.myRoot.allStevedores[stevedoreCode];
		
		return stevedore;
	endif;
	
epilog

end;</source>
        <ReturnType type="CM_Stevedore"/>
    </JadeMethod>
    <JadeMethod name="getStevedoreCode" id="30c8ecbb-3499-481a-8ff1-679660acc5e6">
