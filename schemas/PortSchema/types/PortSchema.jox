    <JadeMethod name="setLocale" id="dbf8991d-e7e9-4003-b9af-d0149370ad51">
        <updating/>
        <source>setLocale(_locale : CM_Locale) updating;
// ---------------------------------------------------------------------------
// Created:     01 April 2004 by cnwrs2
//
// Purpose:     Set current locale
//				Find a jmtLocale that matches the current windows locale
//				If no match is found, set to the jmt default
// ---------------------------------------------------------------------------
vars
	windowsLocale : Locale;
	jmtLocale : CM_Locale;
	
	//11 Jan 2021	NDL	Unit Test tracking
	oldValue : String;
	newValue : String;
	changeString : String;
begin

	//11 Jan 2021	NDL	Unit Test tracking
	if self.myCurrentLocale = null then
		oldValue := "null";
	else
		oldValue := self.myCurrentLocale.localeDescription;
	endif;
	if _locale = null then
		newValue := "null";
	else
		newValue := _locale.localeDescription;
	endif;
	

	if _locale &lt;&gt; null then
		self.myCurrentLocale := _locale;
		return;
	endif;
	
	// Need to determine the correct default locale to use

	jmtLocale := self.myCurrentLocale;
	
	// First get the windows locale and see if we have an equivalent JMT locale
	windowsLocale := app.currentLocale; 	//+ cnwmd1 Par 23856 - get windows locale - windows should always have a locale
	if windowsLocale &lt;&gt; null then
		jmtLocale := self.myRoot.allLocales[windowsLocale.name];//+ cnwmd1 Par 23856 - find a matching jmt locale
	endif;

	if jmtLocale = null then //Equivelent jmt locale cannot be found, set to system default locale
		jmtLocale := app.myRoot.myDefaultLocale;
	endif;
	
	if jmtLocale = null then // No jmt locale found so, set to JMT Plant default (i.e. 0000 locale)
		jmtLocale := self.myRoot.allLocales[StandardTextLocaleStr]; //- Par 23856
	endif;
	
	//11 Jan 2021	NDL	Unit Test tracking
	if jmtLocale = null then
		newValue := "null";
	else
		newValue := jmtLocale.localeDescription;
	endif;
	
	self.myCurrentLocale := jmtLocale;
	
epilog

	//11 Jan 2021	NDL	Unit Test tracking
	if oldValue &lt;&gt; newValue then
		changeString := app.name &amp; " app.myCurrentLocale, was:'" &amp; oldValue &amp; "' now:'" &amp; newValue &amp; "' [" &amp; method.qualifiedName &amp; "]";
		app.createActivityHistory(	ActivityHistoryGeneralSys,	//_type : Integer;
									null,	//_terminal : CM_Terminal;
									null,	//_objectForExtraDetail : Object;
									changeString,	//_description : String;
									process.isInTransactionState,	//_insideTransaction : Boolean;
									false	//_temp: Boolean
									);
	endif;
	
end;</source>
        <Parameter name="_locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="setLogFilename" id="237c6062-6050-4fb4-8934-012475f4b691">
        <source>setLogFilename() : String;

/*

Date		Who		Reason
14 Sep 2012	cnwkpd1	PAR #29274 - Replace Object::getInstanceIdForObjectXX with RootSchema methods
03 Jun 2025 navmd1	MTN-34699 Redirect imported package logs to somewhere a little more sensible
	
*/

vars
	appName	: String;
begin
	appName := app.name;
	
	// If we're initialising app from a package exported from PortSchema, then use the calling Schema Apps name instead
	if appContext.initialPackage &lt;&gt; null then
		appName := appContext.initialProcess.persistentApp.name;
	endif;

	if app.logFileNameSpecific &lt;&gt; null then
		return app.logFileNameSpecific;
	elseif process.isUsingThinClient then
		return appName &amp; "_" &amp; app.computerName &amp; "_ltl_" &amp; app.actualTimeServer.date.formatAsYYYYMMDD() &amp; self.getInstanceIdForObject64(process).String;
	else
		return appName &amp; "_ltl_" &amp; app.actualTimeServer.date.formatAsYYYYMMDD() &amp; self.getInstanceIdForObject64(process).String;
	endif;	

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
