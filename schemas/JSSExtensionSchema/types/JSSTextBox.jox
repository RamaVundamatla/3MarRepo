    <JadeMethod name="controlNamePrefix" id="b705d3d5-34e5-4cc1-9282-3e8046162b34">
        <source>controlNamePrefix(): String;
// --------------------------------------------------------------------------------
// Created:		04 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	return "txt";
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="create" id="01dc5032-b38e-402a-ace2-aa5faa19d1b6">
        <updating/>
        <source>create() updating;
// --------------------------------------------------------------------------------
// Created:		04 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	self.focusColor		:=	self.backColor;
	self.colorNoFocus	:=	self.backColor;
	self.show3D			:=	Control.Show3D_Use3D;
	self.selectionStyle	:=	TextBox.SelectionStyle_SelectAll;
	self.backColor 		:= 	self.getSystemColor(Window.Color_Window);
	self.height			:=	20;
end;</source>
    </JadeMethod>
    <JadeMethod name="gotFocus" id="ecc1fc25-86be-4e09-ae5d-04fa9afff2ba">
        <updating/>
        <source>gotFocus(textbox: TextBox input) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(textbox);
	
	if self.backColor &lt;&gt; self.focusColor then
		self.colorNoFocus	:=	self.backColor;
		self.backColor		:=	self.focusColor;
	endif;
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="lostFocus" id="3e33cb93-d25f-4871-bb53-2e761b833b3d">
        <updating/>
        <source>lostFocus(textbox: TextBox input) updating;
// --------------------------------------------------------------------------------
// Created:		05 February 2003 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(textbox);
	
	if self.backColor &lt;&gt; self.colorNoFocus then
		self.backColor		:=	self.colorNoFocus;
	endif;
end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="readOnly" id="bcadcff3-e11b-43b6-b2cf-1bf0671c2cd0">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>readOnly(set: Boolean; value: Boolean io) updating, mapping;
// --------------------------------------------------------------------------------
// Created:		04 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.isTransient() = true then
		if set then
			inheritMethod(set, value);
			
			if app.getName() = "Jade" then
				if value then
					if (not self.isReadOnlyDefaultColor) then
						backColor	:=	self.getSystemColor(Window.Color_3DFace);
						tabStop		:=	false;
					endif;
				endif;
			else
				if value then
					backColor	:=	Gray;
					tabStop		:=	false;
				else
					backColor	:=	White;
					tabStop		:=	true;
				endif;
			endif;

			// Make sure that a repaint is done.
			self.refresh();
		else
			inheritMethod(set, value);
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="a868e7c6-6467-47c1-847f-c21f90e845ee">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// --------------------------------------------------------------------------------
// Created:		04 September 2002 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	inheritMethod(cntrl, persistCntrl);
	
	if self.isRequired then
		self.autoRedraw	:=	true;
		self.drawSolidRectangle(self.clientWidth()-4, 0, self.clientWidth(), 4, Red);
	endif;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
