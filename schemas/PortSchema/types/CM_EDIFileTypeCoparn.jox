//MEA
	elseif _msgHelper.currentTag = "MEA" then
		// CCMS POL 2151 / par 29137 - there is nowhere on a release request to store ventuilation, 
		// o2, co2, humidity so if we find a message included these we will include them in the remarks
		_msgHelper.setNextField;
		
		if _msgHelper.currentGroup = 7 then
		
			if _msgHelper.currentField = 'AAE' then				 
				_msgHelper.setNextField;
				measurementType := _msgHelper.currentField; 								// jlggb1 TFS 6574 18.8.17
				_msgHelper.setNextField;													// jlggb1 TFS 6574 18.8.17
				_msgHelper.setNextSubItem;													// jlggb1 TFS 6574 18.8.17
				if measurementType = 'AAS' then			// ventilation						// jlggb1 TFS 6574 18.8.17
					remark	:= 'VENTILATION ' &amp;  _msgHelper.currentSubItem &amp; ' CBM/H';		// jlggb1 TFS 6574 18.8.17
				elseif measurementType = 'AAO' then		// humidity							// jlggb1 TFS 6574 18.8.17
					remark := 'HUMIDITY ' &amp;  _msgHelper.currentSubItem &amp; '%';				// jlggb1 TFS 6574 18.8.17
				elseif 	measurementType = 'ZO' then 	// oxygen							// jlggb1 TFS 6574 18.8.17
					remark := 'OXYGEN ' &amp;  _msgHelper.currentSubItem &amp; '%';					// jlggb1 TFS 6574 18.8.17
				elseif measurementType = 'CD' then		// carbon dioxide					// jlggb1 TFS 6574 18.8.17
					remark := 'CO2 ' &amp;  _msgHelper.currentSubItem &amp; '%';					// jlggb1 TFS 6574 18.8.17
				else
					remark := null;
				endif;
				
				//11 Jan 2018	NDL	TFS 36400
				if remark &lt;&gt; null and releaseItemTI &lt;&gt; null then
					reefTypeObj := app.myRoot.allISOTypes[releaseItemTI.isoType];
					if reefTypeObj = null or not reefTypeObj.isReefer then
						remark := null;
					endif;
				endif; 
				
				if remark &lt;&gt; null then
					if releaseHeaderTI.remarks = null then
						releaseHeaderTI.remarks := remark;
					else
						releaseHeaderTI.remarks := releaseHeaderTI.remarks &amp; CrLf &amp; remark;
					endif;	
				endif;
				// TFS#53294 NAVSP1 31MAR2022
				//releaseItemTI.remarks := releaseHeaderTI.remarks;																		//+TFS37308
				if remark &lt;&gt; null then
					if releaseItemTI.remarks = null then
						releaseItemTI.remarks := remark;
					else
						releaseItemTI.remarks := releaseItemTI.remarks &amp; CrLf &amp; remark;
					endif;
				endif;
				// TFS#53294 NAVSP1 31MAR2022 - END
			endif;
	
            // CCMS 2216 PAR 30902 cnwgb1 Heavy Rating
			if _ediPartyRules &lt;&gt; null then
				//meaString 		:= _msgHelper.currentMessage [5:16];// "MEA+|AAE+GW+KGM:|nnnnn"										//navra1 - TFS 55813 - 22nd Dec 2022
				pos := 5;                                                                                  								//navra1 - TFS 55813 - 22nd Dec 2022 - start after AAE+, ie. 5th position 
				meaString := _msgHelper.currentMessage.scanUntil("'", pos);																//navra1 - TFS 55813 - 22nd Dec 2022 - read until end of segment
				ruleFunction 	:= _ediPartyRules.getFunctionForItemValue(CM_EDIEDIFactRule.Item_MEA_3_2, meaString, segmentValue);
				
				if ruleFunction = CM_EDIEDIFactRule.Function_MEA_3_2_Heavy then // Heavy Rated Min Value
					if _msgHelper.currentGroup = 7 then
						releaseItemTI.heavyDuty := true;    // NOTE if there are multiple segments - any one of them can set 
					endif;                              // Heavy Duty to true - so we don't reset ever - cnwgb1
				endif;
			endif;
		endif;
//NAD
