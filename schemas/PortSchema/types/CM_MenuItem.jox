    <JadeMethod name="addToDeleteSet" id="e4ab9ed6-553d-4f77-9a8f-03a5209a0781">
        <source>addToDeleteSet(_deleteSet : CM_MenuEntitySet input);
// ---------------------------------------------------------------------------
// Created:     10 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	childEntity : CM_MenuEntity;
begin
	if _deleteSet = null then
		return;
	endif;
	
	if self.isKindOf(CM_MenuHdr) then
		_deleteSet.add(self);
	endif;
	
	foreach childEntity in self.allChildren do
		if childEntity.isKindOf(CM_MenuItem) then
			childEntity.CM_MenuItem.addToDeleteSet(_deleteSet);
		endif;
	endforeach;


end;</source>
        <Parameter name="_deleteSet" type="CM_MenuEntitySet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addToUserMenuFromMenu" id="7b4111fb-69c9-46d6-8c7e-e54564625a5a">
        <source>addToUserMenuFromMenu(_menuRoot: CM_MenuRoot input);
// ---------------------------------------------------------------------------
// Created:     03 December 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	child	: CM_MenuEntity;

begin

	foreach child in self.allChildren do
		child.addToUserMenuFromMenu(_menuRoot);
	endforeach;

end;</source>
        <Parameter name="_menuRoot" type="CM_MenuRoot" usage="input"/>
    </JadeMethod>
    <JadeMethod name="addToUserMenuRoot" id="30c580ab-f870-4ee4-9328-35d3056a94d3">
        <source>addToUserMenuRoot(_menuRoot : CM_MenuRoot input);
// ---------------------------------------------------------------------------
// Created:     26 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	parentArray	: CM_MenuEntityArray;
	menuEnt		: CM_MenuEntity;
	userItem	: CM_MenuUserItem;
	
begin

	if _menuRoot.allMenuUserItemsWithAMenuItem[self] &lt;&gt; null then
		// This item is already present so do not re-add
		return;
	endif;

	if self.myParent = null or self.myParent.isKindOf(CM_MenuRoot) then
		// I am a top level item so just add
		self.addAsUserItem(_menuRoot, _menuRoot);
		return;
	elseif self.myParent.isKindOf(CM_MenuItem) then
		// This should always be the case
		userItem := _menuRoot.allMenuUserItemsWithAMenuItem[self.myParent.CM_MenuItem];
		if userItem &lt;&gt; null then
			// parent exists so add with this as parent
			self.addAsUserItem(userItem, _menuRoot);
			return;
		endif;
	else
		app.raiseUnexpectedProgramError(class.name, method.name, 'Unknown type ' &amp; self.myParent.String);
		return;
	endif;

	// Need to search up tree and add all
	create parentArray transient;
	
	userItem := null;
	
	menuEnt := self.myParent;

	while (not menuEnt.isKindOf(CM_MenuRoot)) do
		if menuEnt.isKindOf(CM_MenuItem) then
			userItem := _menuRoot.allMenuUserItemsWithAMenuItem[menuEnt.CM_MenuItem];
			if userItem &lt;&gt; null then
				break;
			endif;
		endif;
		parentArray.add(menuEnt);
		menuEnt := menuEnt.myParent;
		
		if menuEnt = null then
			break;
		endif;
	endwhile;

	foreach menuEnt in parentArray reversed do
		if userItem = null then
			userItem := menuEnt.CM_MenuItem.addAsUserItem(_menuRoot, _menuRoot);
		else
			userItem := menuEnt.CM_MenuItem.addAsUserItem(userItem, _menuRoot);
		endif;
	endforeach;

	if userItem = null then
		self.addAsUserItem(_menuRoot, _menuRoot);
	else
		self.addAsUserItem(userItem, _menuRoot);
	endif;
	
epilog
	if parentArray &lt;&gt; null then
		delete parentArray;
	endif;	
	
end;</source>
        <Parameter name="_menuRoot" type="CM_MenuRoot" usage="input"/>
    </JadeMethod>
