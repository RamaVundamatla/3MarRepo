    <JadeMethod name="updateForLogoff" id="dbf7e2fc-2976-496a-ba71-fdd195423753">
        <updating/>
        <source>updateForLogoff(_history: CM_MachineLogOnOffHistory) updating, protected;
// ---------------------------------------------------------------------------
// Created:     15 November 2010 by cnwcs5 par 23714/ccms 1132
// Purpose:     Update KPI for logon
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin
	executeWhen JMTDevelopmentEnvironment;
	if self.date &lt;&gt; _history.dateTime.date then
		app.raiseUnexpectedProgramError (self.class.name, method.name, 'Wrong date for KPI');
	endif;
	endExecuteWhen;
	
	inheritMethod (_history);
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_history" type="CM_MachineLogOnOffHistory"/>
    </JadeMethod>
