    <JadeMethod name="createEmptyChild" id="9304e84a-b02d-4612-8484-178dbf6d6176">
        <updating/>
        <source>createEmptyChild(_parent: SOP_ViewModelObject) updating;
// -----------------------------------------------------------------------------
// Created:		13 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	create myObject as CM_LogSpecies transient;
	myObject.CM_LogSpecies.setProxy(null, null, false, _parent.myObject.CM_CodeGroup);
	myParent := _parent;
end;</source>
        <Parameter name="_parent" type="SOP_ViewModelObject"/>
    </JadeMethod>
    <JadeMethod name="createEmptyPeer" id="1687be2d-a147-496a-ae80-cfa2cb89e152">
        <updating/>
        <source>createEmptyPeer(_parent: SOP_ViewModelObject) updating;
// -----------------------------------------------------------------------------
// Created:		30 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	proxyLogSpecies : CM_LogSpecies;
begin
	create proxyLogSpecies transient;
	proxyLogSpecies.setProxy(null, null, false, _parent.myObject.CM_CodeGroupLogSpecs);
	self.myObject := proxyLogSpecies;	
	self.myParent := _parent;
end;</source>
        <Parameter name="_parent" type="SOP_ViewModelObject"/>
    </JadeMethod>
    <JadeMethod name="doDelete" id="977e2f3d-5392-46d4-86e5-e585d50ec369">
        <updating/>
        <source>doDelete(): Boolean updating;
// -----------------------------------------------------------------------------
// Created:		14 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	invalidObj : Boolean;
begin

 on Exception do app.handleDeletedObject(exception, self.myObject.CM_LogSpecies, invalidObj); // cnwrd1 3.11.08 par 18090
 
	app.myTrxDA.trxDeleteLogSpecies(self.myObject.CM_LogSpecies, app.myPassport);
	return app.myPassport.trxCompletedOK;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="74496e36-54bb-4c17-ac10-ea6164168154">
        <updating/>
        <source>doSave(): Boolean updating;
// -----------------------------------------------------------------------------
// Created:		13 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	proxySpecies, newSpecies : CM_LogSpecies;
begin
	if self.myForm.mode = self.myForm.Mode_Add then
		if self.myForm.myProxyObject &lt;&gt; null then
			self.myForm.myProxyObject.erase(NORMAL_ERASE);
		endif;
		
		create self.myForm.myProxyObject as CM_LogSpecies transient;
	endif;
	
	proxySpecies := self.myForm.myProxyObject.CM_LogSpecies;
	
	proxySpecies.setProxy(	self.myForm.tblInput1.getValueByName('code').String.removeTabCrLfs(),	// 18/04/2013 cnwar2 #27130
								self.myForm.tblInput1.getValueByName('description').String,
								self.myForm.tblInput1.getValueByName('notAvailableForEntry').Boolean,
								self.myObject.CM_LogSpecies.myCodeGroup);
								
	if self.myForm.mode = self.myForm.Mode_Add then
		app.myTrxCA.trxCreateLogSpecies(proxySpecies, newSpecies,app.myPassport);
		if app.myPassport.trxCompletedOK then
			delete self.myObject;  // delete the transient holder
			self.myObject := newSpecies;
		endif;
	elseif self.myForm.mode = self.myForm.Mode_Update then
		app.myTrxUA.trxUpdateLogSpecies(proxySpecies, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; self.myForm.mode.String &amp; ')');
	endif;
	
	self.myForm.myProxyObject := proxySpecies;
	return app.myPassport.trxCompletedOK;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSelected" id="d73a0990-5d77-421c-92ce-73d2e976e273">
