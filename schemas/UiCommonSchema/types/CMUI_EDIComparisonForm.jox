    <JadeMethod name="translateForm" id="f47965de-f35a-4340-b3d3-26fc80e835af">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 23 September 2016 13:34:09.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0019195, locale);
	btnEdit.translateBubbleHelp(Xlat_0021349, locale);
	btnEdit.translateCaption(Xlat_0021350, locale);
	btnExport.translateCaption(Xlat_0019196, locale);
	btnHideSearcher.translateBubbleHelp(Xlat_0019197, locale);
	btnHideSearcher.translateCaption(Xlat_0019198, locale);
	btnPrint.translateCaption(Xlat_0019199, locale);
	btnQuery.translateCaption(Xlat_0019200, locale);
	btnRefresh.translateBubbleHelp(Xlat_0019201, locale);
	btnRefresh.translateCaption(Xlat_0019202, locale);
	btnResetSearch.translateCaption(Xlat_0019203, locale);
	btnSaveVerify.translateBubbleHelp(Xlat_0021351, locale);
	btnSaveVerify.translateCaption(Xlat_0021352, locale);
	btnShowSearcher.translateCaption(Xlat_0019204, locale);
	grpSelect.translateCaption(Xlat_0019205, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="c3712934-7b91-4454-b740-f38e77045e87">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(_eventType: Integer; _object: Object; _eventTag: Integer; _userInfo: Any) updating;
/*
Date		Who		Reason
22 August 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
*/
vars
	eventType	:Integer;
begin
	eventType := self.myTerminal.getEventFromTerminalEvent(_eventType);
	
	if eventType = EVENT_EDI_EDITI_UPDATE then
		// update editi in table
		if _userInfo.isKindOf(CM_EDITrackedItem) then
			self.handleNotification (Object_Update_Event, _userInfo.CM_EDITrackedItem, _eventTag);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="_eventType" type="Integer"/>
        <Parameter name="_object" type="Object"/>
        <Parameter name="_eventTag" type="Integer"/>
        <Parameter name="_userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
