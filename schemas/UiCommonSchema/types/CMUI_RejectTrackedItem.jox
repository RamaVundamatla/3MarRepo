    <JadeMethod name="refreshTable" id="cf798abe-0de6-4221-b814-a3ce208e69ba">
        <source>refreshTable();
// ---------------------------------------------------------------------------
// Created:     19 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars

begin
	self.tblSelection.setValueByName(ETRow_Id, null);
	self.populateTIsByCargoType();
	self.tblSelectData.rows := self.tblSelection.fixedRows;
	self.txtDetails.text := null;

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="0aa702c0-82d2-47bf-ac47-0b30feff1f70">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008030, locale);
end;</source>
    </JadeMethod>
</GUIClass>
