    <JadeMethod name="setForUpdate" id="f4b5582d-226a-4187-80a8-f96b8a7ac1bc">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
// ---------------------------------------------------------------------------
// Created:     10 April 2008 by cnwaer1
//
// Purpose:     
// ---------------------------------------------------------------------------
/// 22 Feb 2016	cnwrs1	TFS 3401 fixup EDI Operations update of EDI TIs
//09 Apr 2024	jlirs1	TFS 63491 - TPT user defined EDI Cargo subtype is missing height

vars
//	tmpCargoType :CM_CargoType;
//	tmpOperator : CM_Operator;
//	cargoTypeStr : String;
begin
	/* cnwrl1 25/11/2009 PAR 21713 - start of what it was
	self.cargoTypeDescription := _proxyEDITI.cargoTypeDescription; 
	self.cargoTypeDescr := _proxyEDITI.cargoTypeDescription; 
	self.cargoType    := app.myRoot.getCargoTypeIDFromDescription(self.cargoTypeDescr);
	if self.cargoType = null then
		self.cargoType    := app.myRoot.getCargoTypeIDFromAbbrev(self.cargoTypeDescr);
	endif;
	cnwrl1 25/11/2009 PAR 21713 - end of what it was */
	inheritMethod(_proxyEDITI);
	self.code			:= _proxyEDITI.code;
	self.thickness		:= _proxyEDITI.thickness;
	self.width			:= _proxyEDITI.width;
	self.length			:= _proxyEDITI.length;
	self.height 		:= _proxyEDITI.height;			//09 Apr 2024	jlirs1	TFS 63491 - TPT user defined EDI Cargo subtype is missing height
	self.grade			:= _proxyEDITI.grade;
	self.sheets			:= _proxyEDITI.sheets;
	self.description	:= _proxyEDITI.description;
	self.operatorCode	:= _proxyEDITI.operatorCode;
	self.handlingType	:= _proxyEDITI.handlingType;
	self.productGroup	:= _proxyEDITI.productGroup;
	self.weight			:= _proxyEDITI.weight;
	self.volume			:= _proxyEDITI.volume;
	
	//29 Jan 2018	NDL	TFS 36697
	self.autoWeightCalculate := _proxyEDITI.autoWeightCalculate;
end;
</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setMeasurementTypeValue" id="4a863ebf-ecf3-4ba6-95d1-1c206154775f">
        <updating/>
        <source>setMeasurementTypeValue(_columnName: String; _value: String) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 September 2014	cnwmc5	Initial creation	PAR 34533

*/

vars
	rowName,
	measureType		: String;
	
begin

	if not inheritMethod(_columnName, _value) then
		return false;
	endif;
	
	_columnName.getRowNameMeasureType(rowName, measureType);
	
	if rowName = ETRow_TotalWeight then
		self.weight := app.convertMeasurementForStorage(measureType, _value.asDecimalJMT());
		return true;
	endif;
	
	if self.class.getPropertyInHTree(rowName) &lt;&gt; null then
		self.setPropertyValue(rowName, app.convertMeasurementForStorage(measureType, _value.asDecimalJMT()));
	endif;
	
	return true;
	
epilog

end;</source>
        <Parameter name="_columnName" type="String"/>
        <Parameter name="_value" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
