    <JadeMethod name="getBoxCarMaxVolume" id="f884acfe-59ab-4f20-971c-2d9771771ff0">
        <source>getBoxCarMaxVolume():Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 March 2013	cnwndl1	Initial creation	Par 31278

*/

vars

	maxVolume : Decimal [16,4];

begin

	//volume of boxcar in cubic metres.... 

	//stored dimensions are in cms...
	maxVolume := ( self.internalHeight / 100 ) * ( self.internalLength / 100 ) * ( self.internalWidth / 100 );
	return maxVolume;
	
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getBoxcarLengthAndDoorPosition" id="140c60ba-c16f-42e7-894b-96104f642c88">
        <source>getBoxcarLengthAndDoorPosition( _length : Integer output; _doorPosArray : IntegerArray input );
/*

Purpose:			

Parameters:			The length of the Boxcar in 10 foot units... for the drawing controller to use

Return Value:		

Date		Who		Reason
19 March 2013	cnwndl1	Initial creation	Par 31278

*/

vars

begin

	if not self.isBoxcar then
		return;
	endif;
	
	if self.internalLength &gt; 0 then
		_length := ( self.internalLength / 300 ).Integer; // approx 10 foot units
		if _length &lt; 3 then
			//too small to draw nicely - fudge it
			_length := 3;
		elseif _length &gt; 8 then	//07 June 2013	NDL	Par 31659
			// too big fudge it too.
			_length := 8;
		endif;
	endif;
	
	if _length = 3 then
		_doorPosArray.add(2);
	elseif _length = 4 then
		_doorPosArray.add(2);
		_doorPosArray.add(3);
	elseif _length &lt; 7 then
		_doorPosArray.add(3);
		_doorPosArray.add(4);
	else
		_doorPosArray.add(4);
		_doorPosArray.add(5);
	endif;

epilog

end;</source>
        <Parameter name="_length" type="Integer" usage="output"/>
        <Parameter name="_doorPosArray" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="07ae9286-c257-4f14-9822-d5794ff2731a">
        <source>getDisplayDetails(_short: Boolean): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
01 July 2009	cnwndl1	Initial creation

*/

vars

begin

	if _short then
		return self.code;
	else
		return "'" &amp; app.getErrorString(Wagon_class) &amp; "' " &amp; self.code;
	endif;

epilog

end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="547bff21-b011-453a-9010-f1adcc4c0f24">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Purpose:	location ids from array - MES 1010 interface loads		

Parameters:			

Return Value:		

Date		Who		Reason
27/08/2009	cnwjmn1	Initial creation
05/03/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars

	str, type	: String;							// PAR #31155
	value		: Decimal [22,10];					// PAR #31155
	well : CM_WagonWellDefinition;
	
begin
	if _attrName = ETRow_LocationIds then
		if self.isWellcar then	//Par 35346 / CCMS 1408
			foreach well in self.allWagonWellDefArray do
				if str = null then
					str := well.getDisplayStringForAttribute(ETRow_LocationIds,_short);
				else
					str := str &amp; "," &amp; well.getDisplayStringForAttribute(ETRow_LocationIds,_short);
				endif;
			endforeach;
			return str;
		else
			return self.locationIds.asCSV(false);
		endif;
		
	elseif _attrName = ETRow_WagonType then
		return self.getWagonTypeString();
		
	elseif _attrName = ETRow_SealTypes then	//10 Mar 2015	NDL	Par 35828
		return self.getWagonSealTypesString();
	elseif _attrName = ETRow_GraphicType then
		
		if self.isBoxcar() then
			if self.numOfTwenty = CM_BoxcarVisit.BoxcarGraphicBulk then
				return app.getErrorString(WagonGraphicBulk);
			elseif self.numOfTwenty = CM_BoxcarVisit.BoxcarGraphicTransporter then
				return app.getErrorString(WagonGraphicTransporter);
			elseif self.numOfTwenty = CM_BoxcarVisit.BoxcarGraphicBreakBulk then 
				return app.getErrorString(WagonGraphicBreakBulk);
			endif;
		elseif self.isSkeletonCar() then
			return app.getErrorString(WagonGraphicSkeleton);
		elseif self.isFlatcar() then
			return app.getErrorString(WagonGraphicFlat);
		elseif self.isWellcar() then
			return app.getErrorString(WagonGraphicWell);
		endif;
		return "";
	elseif _attrName.isMeasurementType then											// PAR #31155
		_attrName.getRowNameMeasureType(str, type);									// PAR #31155
		return self.getMeasurementStringForAttrib(str, type, _short);				// PAR #31155
	endif;

	return inheritMethod(_attrName, _short);
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLenInCMs" id="3af30595-1836-4cea-8b22-a168c4f8ebfe">
        <source>getLenInCMs() : Integer;
/*
Purpose:			

Date		Who		Reason
05 January 2022	navab1	TFS 51855
*/
constants
	CMSIN10FEET = 304.8;
vars
	
begin
	return (self.lenInUnits * CMSIN10FEET).Integer;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getLenInUnits" id="06fe7ea8-6671-4c2d-bac4-e60dfad47691">
        <source>getLenInUnits():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 December 2014	cnwndl1	Initial creation	Par 35346 / CCMS 1408

*/

vars
	well : CM_WagonWellDefinition;
	totLenInUnits : Integer;
begin

	if self.isWellcar then
		foreach well in self.allWagonWellDefArray do
			totLenInUnits := totLenInUnits + well.lenInUnits;
		endforeach;
		return totLenInUnits;
	else
		return self.lenInUnits;
	endif;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getMaxBoxcarInternalDimension" id="b4f61d23-e4b9-4287-9a38-6473ab313667">
        <source>getMaxBoxcarInternalDimension():Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 March 2013	cnwndl1	Initial creation	Par 31278

*/

vars

	maxDimension : Decimal [16,4];

begin

	maxDimension := self.internalLength;
	maxDimension := maxDimension.max(self.internalHeight);
	maxDimension := maxDimension.max(self.internalWidth);
	
	return maxDimension;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getMaxHeight" id="dc25a01b-57b6-4d9f-a1b8-f5ea8e1a7a19">
        <source>getMaxHeight() : Decimal;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 July 2009	cnwndl1	Initial creation

*/

vars
	decimal : Decimal [12,2];
begin

	if self.overallHeight &lt;&gt; 0 then
		decimal := self.overallHeight;
	elseif self.internalHeight &gt; self.maxCargoHeight then
		decimal := self.deckHeight + self.internalHeight;
	else
		decimal := self.deckHeight + self.maxCargoHeight;
	endif;
	return decimal;

epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
