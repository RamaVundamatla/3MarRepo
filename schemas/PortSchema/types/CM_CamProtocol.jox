    <JadeMethod name="segmentTerminator" id="202c4de1-b5f9-4297-ab96-5950a4cd3957">
        <methodInvocation>mapping</methodInvocation>
        <source>segmentTerminator(set : Boolean; _value : Character io) mapping;
/*
Purpose:		Use default value if property blank

Date		Who		Reason
09 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
20 Feb 2015 cnwma1  PAR #35322 CAM Protocol default separator characters are not correct for X12
*/
vars

begin
	if not set then
		if _value = null then
			if self.isX12 then
				_value := self.Default_SegmentTerminator_X12; //20/02/2015 cnwma1 PAR # 35322
			else
				_value := self.Default_SegmentTerminator;
			endif;
		endif;
	endif;
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Character" usage="io"/>
    </JadeMethod>
    <JadeMethod name="sendAction" id="64dd0c11-be4b-4dd1-b766-a1a50c037631">
        <updating/>
        <source>sendAction(_emailFolderName: String; _camHistory : CM_CamTaskHistory; _resendIndex : Integer): Integer updating;
/* 
---------------------------------------------------------------------------
 Created:     J Harliwich               

 Purpose:     The Cam Controller Agent used to call sendEmail. Notw we can do more than just emails, have created this
			  method sendAction that does emails and files. It then calls sendEmail

 Parameters:  None

 Returns:     Nothing

 Changed On		Changed By  Reason
 ----------		----------  --------------------------------------------------
 30/09/2015		cnwma1      PAR #36820 Query only  Interface Cams message to  Depot  Pro Gate In message
 17/09/2019		jlgrs1		TFS 46087 JMT implement SFTP.
 18/03/2023		navmd1		TFS 57092 Implement sending to JSON API Endpoint
 20/6/2023		jlier1 		TFS 58637 - resending only want to send a particular message from the cams history
 ---------------------------------------------------------------------------
*/

vars
	emailUniqueId : Integer;
begin
	// A cam protocol can be email enabled only, file transfer enabled only or both
	// File Transfer enabled was added for User Defined reports.
	
	if  self.isEmailEnabled then 
		emailUniqueId := self.sendEmail(_emailFolderName, _camHistory);
	endif;
	
	if not self.isUserDefinedReport and not  self.isUserDefinedEventReport then    // 29/09/2015 cnwma1 PAR #36820
		if self.isFileTransferEnabled  then
			//  Create a file in the File transfer directory nominated by the user.  
			self.sendFile(_emailFolderName, _camHistory);
		endif;
	endif;
	if self.myFTPEntity &lt;&gt; null  then	// CCMS 1143 cnwrs1 10 Aug 2010
	//	if self.myFTPEntity.isSFTP and
	//	   app.isSFTPEnabled then
		if self.myFTPEntity.isSFTP then   //27 Nov 2020	NDL	TFS 50191
			self.sendSFTP(_emailFolderName, _camHistory);
		else
			self.sendFTP(_emailFolderName, _camHistory);
		endif;
	endif;
	
	if self.myExternalWebServiceDef &lt;&gt; null then
		//jlier1 TFS 58637 20/6/23
		self.sendJSON(_camHistory,_resendIndex);
	endif;

	return emailUniqueId;

end;
</source>
        <Parameter name="_emailFolderName" type="String"/>
        <Parameter name="_camHistory" type="CM_CamTaskHistory"/>
        <Parameter name="_resendIndex" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="sendEmail" id="3f93c6f7-d800-4d4a-8644-8a206e16ec0a">
        <updating/>
        <source>sendEmail(_folderName: String; _camHistory : CM_CamTaskHistory): Integer updating, protected;
//----------------------------------------------------
//
//----------------------------------------------------
// 26 Jun 2013	cnwrs1	par 31047 Cam Exception Handling testing
//06 Jul 2016	cnwrs1	Par 38021 - Review Cam logging
vars
	eMailAddr		: CM_EmailEntity;	
	toAddress,
	fromAddress,
	ccAddresses,
	strAddress,
	sendSubject,
	sendMessage, 
	sendFilePath 	: String;	
	file			: File;
	attachedFiles	: HugeStringArray;
	emlEnt			: CM_EmailEntity;
	camsEmail		: String;
	emailUniqueId	: Integer;
begin
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Protocol.code='&amp;self.code&amp;' camTaskHistory='&amp;_camHistory.String, LogDEBUG);	
	create attachedFiles transient;
	toAddress := self.myEmailEntity.getEmailAddress();
	camsEmail := self.terminal.getConfig(CamsEmailAddress).String;
	emlEnt := app.myRoot.allEmailEntities[Email_Address,camsEmail];
	
	/* sender cannot be a group
	if emlEnt = null then
		emlEnt := app.myRoot.allEmailEntities.getAtKey(Email_Group,camsEmail);
	endif;
	*/
	if emlEnt = null then
		fromAddress := app.myRoot.getConfig(AutoSendersEmailAddress).String;
	else
		fromAddress := emlEnt.getEmailAddress();//self.terminal.getConfig(CamsEmailAddress).String;
	endif;
	
	sendSubject := self.emailSubject;

//	debug
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;"Email details: " &amp; fromAddress &amp; "(from) " &amp; toAddress &amp; "(to) " &amp; sendSubject &amp; "(subject)" , LogDEBUG);

	if self.emailFileImbedded then
		create file;
		file.mode := File.Mode_Input;
		file.kind := File.Kind_Unknown_Text;	// 25/2/16 cnwmp6 PAR 36286 unicode version
		file.fileName := _folderName &amp; _camHistory.fileName;
		if file.isAvailable then
			file.open;
			sendMessage := file.readString(file.fileLength);
			file.close;
			sendFilePath := null;
		else
			app.writeLog("File " &amp; file.fileName &amp; " not found." , LogINFO);
		endif;
	else
		sendMessage := self.emailMessage;
		sendFilePath := _folderName &amp; _camHistory.fileName;
		attachedFiles.add(sendFilePath);
	endif;
	
	foreach eMailAddr in self.allCopyEmailEntities do
		if global.isValidObject(eMailAddr) then
			if 	ccAddresses = "" then
				ccAddresses := eMailAddr.getEmailAddress();
			else
				ccAddresses := ccAddresses &amp; "; " &amp; eMailAddr.getEmailAddress();
			endif;
		endif;
	endforeach;

	if toAddress.trimBlanks = "" then
		app.writeLog(app.getErrorString1(ERR_Email_Blank, app.getErrorString(Recipients)), LogINFO);
		return 0;
	endif;
	
	if fromAddress.trimBlanks = ""  then
		app.writeLog(app.getErrorString1(ERR_Email_Blank, app.getErrorString(Senders)), LogINFO);
		return 0;
	endif;

	app.writeLog(app.getErrorString1(MSG_Email_CreatRequest, self.myEmailEntity.getEmailAddress), LogINFO);
	emailUniqueId := app.myTrxCA.trxCreateEmailSendRequest('Cams',
										  toAddress, 
										  fromAddress,
										  ccAddresses,
										  null,
										  sendSubject,
										  sendMessage,
										  attachedFiles,
										  null,
										  null,
										  null,
										  EmailSource_CAMS,
										  _camHistory,
										  app.myPassport);
	if not app.myPassport.trxCompletedOK then
		app.myPassport.getMyBGPAgent.writeCrashLogAlertAndEmail(app.myPassport);
		return 0;
	else
		app.writeLog(self.code &amp; " " &amp; _folderName &amp; _camHistory.fileName &amp; " " &amp; app.getErrorString1(Success, app.getErrorString(Email_Request)), LogINFO);
		if self.emailCopy then
		//copy to sender also
			app.myTrxCA.trxCreateEmailSendRequest('Cams', fromAddress, 
										  fromAddress,
										  null,
										  null,
										  "CAMS: " &amp; sendSubject &amp; " OK",
										  sendMessage,
										  attachedFiles,
										  null,
										  null,
										  null,
										  0,
										  null,
										  app.myPassport);
			if not app.myPassport.trxCompletedOK then
				app.myPassport.getMyBGPAgent.writeCrashLogAlertAndEmail(app.myPassport);
				return 0;
			endif;
		endif;
	endif;
	
	return emailUniqueId;
epilog

	delete attachedFiles;
	delete file;
end;</source>
        <access>protected</access>
        <Parameter name="_folderName" type="String"/>
        <Parameter name="_camHistory" type="CM_CamTaskHistory"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="sendFTP" id="e1b11cb4-264a-42e3-9cc9-7c758a7685f0">
        <source>sendFTP(_folderName: String; _camHistory : CM_CamTaskHistory) protected;
//
// CCMS 1143 cnwrs1 11 Aug 2010
//
//22 May 2013	cnwrs1	Par 31483 Ftp connect not always connecting
//11 Jun 2014	cnwrs1	Par 34062 add useProxy to FTP Get/Put
//06 Jul 2016	cnwrs1	Par 38021 - Review Cam logging
//05 Dec 2016	cnwrs1	TFS 3085 FTP not using current directory
//15 Nov 2017	jlgkpd1	TFS 7462 - Allow for optional port number to be specified in the server name
// 04 Nov 2024	jlier1  MTN-32974 - added more details to exceptions and alerts
vars
	fileName : String;
	file : File;
	ftp : CnFtp;
	result : String;
	resultInt : Integer;
	outFileName : String;
begin
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Protocol.code='&amp;self.code&amp;' camTaskHistory='&amp;_camHistory.String&amp;' folderName='&amp;_folderName, LogDEBUG);	
	fileName := _folderName &amp; _camHistory.fileName;
	app.writeLog("FTP " &amp; fileName &amp; " to " &amp; self.myFTPEntity.serverName, LogINFO);
	create file;
	file.kind := File.Kind_Unknown_Text; // 3/3/16  cnwns1 PAR 36286 unicode version	
	file.mode := File.Mode_Input;
	file.fileName := _folderName &amp; _camHistory.fileName;
	if file.isAvailable then
		create ftp transient;
		ftp.setServerName(self.myFTPEntity.getServerNameForConnect());			// TFS 7462
		ftp.portNumber := self.myFTPEntity.getPortNumberForConnect();			// TFS 7462		
		ftp.setServerType(self.myFTPEntity.serverType);
		ftp.setUseProxy(self.myFTPEntity.useProxy);
		ftp.setUserId(self.myFTPEntity.userId, self.myFTPEntity.getPwForUse(null));
		ftp.setServerGMTBias(self.myFTPEntity.serverGMTBias);
		ftp.passive := self.myFTPEntity.isPassive;
		ftp.setModeAscii(self.myFTPEntity.mode.Boolean);
		ftp.setMyNotifyObject(self);
		result := ftp.cnConnect();
		if result &lt;&gt; CN_OK then
			app.writeLog(app.getErrorString1(Error_Display, result), LogINFO);
			app.raiseCMException1(Error_Display, result, null, null); // cnwdb2	PAR 35364
		endif;
		if self.myFTPEntity.destinationDirectory &lt;&gt; null then
			result := ftp.createDirectory(self.myFTPEntity.destinationDirectory);
			if result &lt;&gt; CN_OK then
				app.writeLog(app.getErrorString1(Error_Display, result), LogINFO);
				app.raiseCMException1(Error_Display, result, null, null); // cnwdb2	PAR 35364
			endif;
			resultInt := ftp.emFtpSetCurrentDirectory(ftp.connectionHandle, self.myFTPEntity.destinationDirectory);
			if resultInt &lt;&gt; 0 then
				app.writeLog("Unable to set Current directory on FTP site "&amp;self.myFTPEntity.id&amp;' to '&amp;self.myFTPEntity.destinationDirectory&amp;' '&amp;ftp.cnGetInternetError(resultInt), LogINFO);
				app.raiseCMException1(Unable_current_dir_FTP,self.myFTPEntity.id &amp; " " &amp; self.myFTPEntity.destinationDirectory &amp;' '&amp;ftp.cnGetInternetError(resultInt),  null, null);
			endif;
//			outFileName := self.myFTPEntity.destinationDirectory&amp;'\'&amp;_camHistory.fileName;
		endif;
		outFileName := _camHistory.fileName;
		result := ftp.cnPutFile(fileName, outFileName, false, true);
		if result &lt;&gt; CN_OK then
			app.writeLog(app.getErrorString1(Error_Display, result), LogINFO);
			app.raiseCMException1(Error_Display, result, null, null);// cnwdb2	PAR 35364
		endif;
	else
		app.writeLog("FTP failed. File " &amp; file.fileName &amp; " not found.", LogINFO);
	endif;
epilog
	delete file;
	delete ftp;
end;
</source>
        <access>protected</access>
        <Parameter name="_folderName" type="String"/>
        <Parameter name="_camHistory" type="CM_CamTaskHistory"/>
    </JadeMethod>
    <JadeMethod name="sendFile" id="92953989-c061-4fb8-ade8-f5002426b15e">
        <source>sendFile(_folderName: String; _camHistory : CM_CamTaskHistory) protected;
/* 
---------------------------------------------------------------------------
 Created:     J Harliwich               

 Purpose:     

 Parameters:  None

 Returns:     Nothing

 Changed On   Changed By  Reason
 ----------   ----------  --------------------------------------------------
 //06 Jul 2016	cnwrs1	Par 38021 - Review Cam logging
 //30 Nov 2016	cnwrs1	Par 38468 setup destination folder correctly - debug messages
 //18 Jun 2021	NDL	TFS 50119 - add more detail to messages / alerts 
---------------------------------------------------------------------------
*/

vars
	folderObj		: FileFolder;
	fileObj : File;
	fileName : String;
	destFileName : String;
	errText : String;
	errorInfo : String;
	isFileError : Boolean;
begin
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Protocol.code='&amp;self.code&amp;' camTaskHistory='&amp;_camHistory.String&amp;' folderName='&amp;_folderName, LogDEBUG);	
	fileName := _folderName &amp; _camHistory.fileName;
//	app.writeLog("FTP " &amp; fileName &amp; " to " &amp; self.myFTPEntity.serverName, LogAlways);
	create fileObj;
	fileObj.kind := File.Kind_Unknown_Text; // 3/3/16  cnwns1 PAR 36286 unicode version
	fileObj.mode := File.Mode_Input;
	fileObj.fileName := _folderName &amp; _camHistory.fileName;
	if fileObj.isAvailable then
		create folderObj transient;
		folderObj.fileName := self.destinationFilePath;
		if not folderObj.isAvailable then
			on FileException do self.xHandlerFile(exception, isFileError, errorInfo);
			isFileError	:=	false;
			app.writeLog(class.name &amp; "::" &amp; method.name &amp; " make file Directory " &amp; folderObj.fileName, LogINFO);
			folderObj.make;
			if isFileError then
				app.writeLog(class.name &amp; "::" &amp; method.name &amp; " --- " &amp; errorInfo, LogINFO);
				app.writeLog( app.getErrorString2(ERR_CAMS_MAKEDIR, self.destinationFilePath, self.code &amp; " [" &amp; errorInfo &amp; "]"), LogINFO );
				app.raiseCMException2(ERR_CAMS_MAKEDIR, self.destinationFilePath, self.code &amp; " [" &amp; errorInfo &amp; "]", null, null);
				return;
			endif;
			on FileException do null;
		endif;
		if folderObj.isAvailable() then
			destFileName := self.destinationFilePath&amp;'/'&amp;_camHistory.fileName; 
			if not fileObj.cnCopyFile(destFileName,true, errText) then
				app.writeLog(errText, LogINFO);
				app.writeLog( app.getErrorString2(ERR_CAMS_MAKEDIR, destFileName, self.code &amp; " [" &amp; errText &amp; "]"), LogINFO );
				app.raiseCMException2( ERR_CAMS_MAKEDIR, destFileName, self.code &amp; " [" &amp; errText &amp; "]", null, null );
			endif;
		else
			
		endif;
	else
		
	endif;
	
			// ############### incomplete
		
			// we now need a copy of the file in the destination directory nominated on protocol, with a different name. 
			// or should we just create a copy using Cardschema method File.cnCopyFile?
			
			// we need to allocate another sequence to create a different name 
			// also need to code incomplete new method _camProtocl.constructTransferFilename
			
			// We need to store the dest filename on the Task history (havce added 'transferFileName'  otherwise we cannot match up?
			
			// Or maybe check with Richard, why do we want another name, could we just use the one already allocated? If so, the number needs to allow for bigger
			// ranges.
					
			// ############### incomplete

epilog
	delete fileObj;
	delete folderObj;
end;
</source>
        <access>protected</access>
        <Parameter name="_folderName" type="String"/>
        <Parameter name="_camHistory" type="CM_CamTaskHistory"/>
    </JadeMethod>
    <JadeMethod name="sendJSON" id="bc46542c-ac4b-4fea-9df6-d3a81697a8b7">
        <source>sendJSON(_camHistory : CM_CamTaskHistory;_resendIndex : Integer) protected;
/*

Purpose:			Sending CAMS messages to API Endpoints as JSON objects

Parameters:			

Return Value:		

Date			Who		Reason
18 Mar 2023		navmd1	Initial creation TFS 57092 Refactor / Move from CM_CamControllerAgent::createOutputJson
17 Apr 2023		navdap1	TFS 57207 EUP - Refactor Inspection App API Message
10 May 2023		navdap1	TFS 56801 EUP - EDI Message Type - Transport Status Message Processing
20 Jun 2023		jlier1 		TFS 58637 - resending only want to send a particular message from the cams history
03 Jul 2023		navcs2	Bug 58947: FR | 54536 - 1035 UHE logs Occurring processing Damage CAMs Message
26 April2024    navsp1  Bug 61182: EUP - Damage &amp; Repair message is not formatted correctly in Display when large
14 May 2024 	navsaa30 ChangeRequest 61187: EUP | Error Message column in CAMS history tab not shown as expected
14 Aug 2024		navmd1	TFS 61725 Return a known response when running a unit test
30 Aug 2024		navhn30	Bug 65667: MTN - Reverse Changes made for 61182 for handling large JSON messages
*/

vars
	serviceDef			: CM_APIEndpointServiceDef;
	verb				: String;
	agent				: CM_CamsConsumerAgent;
	msg					: String;
	response,
	camHistory			: String;
	responseCode		: Integer;
	pos					: Integer;
	msgCount			: Integer;
	endpoint			: String;
	proxyHist			: CM_CamTaskHistory;
	qualifiedEndpoint	: String;
	baseEndpointLocal	: String;
	endpointDesc		: String;
	//agentJson    		: CMIF_JsonHelper;	//TFS 61182
	//cntr 				: Integer;			//TFS 61182
	//formatJson,newMsg	: String;			//TFS 61182
	splitPos,crPos,
	//maxLength			: Integer;			//TFS 61182
	//hugeStrArr 		: HugeStringArray;	//TFS 61182
	error				: String;
begin
	
	proxyHist := app.createUpdateProxy(_camHistory).CM_CamTaskHistory;			// 14/5/24  navsaa30 #61187
	
	// TFS 56801 start
	endpointDesc := self.protocolDesc.getEndPointDescriptor();
	if endpointDesc = null then
		app.raiseUnexpectedProgramError(self.class.name, method.name, "No endpoint descriptor found for protocol description " &amp; self.protocolDesc.name);
		app.createAlert(self.class.name &amp; Tab &amp; method.name &amp; Tab &amp; "No endpoint descriptor found for protocol description " &amp; self.protocolDesc.name, true);
		return;
	endif;
	// TFS 56801 end
	serviceDef := self.myExternalWebServiceDef;
	serviceDef.getEndpointMethodAndValue(endpointDesc, verb, endpoint);		// TFS 56801
	
	//construct the qualified endpoint
	baseEndpointLocal := serviceDef.baseEndpoint;									// TFS 57207
	if not baseEndpointLocal.endsWith('/') then										// TFS 57207
		baseEndpointLocal := baseEndpointLocal &amp; '/';								// TFS 57207
	endif;																			// TFS 57207
	qualifiedEndpoint := baseEndpointLocal &amp; endpoint;								// TFS 57207
	
	// Default to 'POST' if no verb returned above	// TFS 57207
	if verb = null then
		verb := JadeHTTPConnection.Verb_POST;
	endif;
	
	// Create the ewb sevice agent, until TFS 57159, subsituting for EUP specifc agent where required
	create agent as self.protocolDesc.getMyWebServiceAgentClass();		// TFS 56801
	agent.setupFromWebServiceDefinition(serviceDef);
	agent.setExtraDetails(_camHistory);	
	
	camHistory := _camHistory.getRawDataString();
	/*create hugeStrArr transient;					//TFS 61182		//30.08.24	navhn30	TFS 65667
	create agentJson transient;						//TFS 61182		//30.08.24	navhn30	TFS 65667
	maxLength := hugeStrArr.getMaxLength();			//TFS 61182 */  //30.08.24	navhn30	TFS 65667
	while true do		
		pos += 1;
		 //jlier1 TFS 59815 15/8/23
		msg:=null;
		//jlier1 TFS 59815 29/8/23
		if pos &gt; camHistory.length then
			break;
		endif;
		if camHistory &lt;&gt; null then
		// //30.08.24	navhn30		TFS 65667	start
		/*	splitPos 	:= camHistory.pos(CM_CamProtocol.JSON_Split_Delimeter.String, pos);	//TFS 61182
			crPos 		:= camHistory.pos(Cr, pos);											//TFS 61182
			if splitPos &gt; 0 or (splitPos = 0 and crPos &gt; maxLength) then					//TFS 61182
				app.writeLog(method.qualifiedName &amp; "JSON split message", LogDEBUG);		//TFS 61182
				while true do																//TFS 61182
					newMsg := self.splitJsonMessage(camHistory, pos);						//TFS 61182
					formatJson := agentJson.formatJsonString(newMsg);						//TFS 61182
					if formatJson &lt;&gt; null then												//TFS 61182
						msg := formatJson;													//TFS 61182		
						break;																//TFS 61182
					else																	//TFS 61182
						msg := msg &amp; newMsg;												//TFS 61182
					endif;																	//TFS 61182
					if pos &gt;= camHistory.length then										//TFS 61182
						pos := 0;															//TFS 61182
						break;																//TFS 61182
					endif;																	//TFS 61182
					cntr += 1;																//TFS 61182
					if cntr &gt; 20 then														//TFS 61182
						pos := 0;															//TFS 61182
						app.writeLog( method.qualifiedName &amp; "Infinite loop", LogERROR);	//TFS 61182
						break;																//TFS 61182
					endif;																	//TFS 61182
				endwhile;																	//TFS 61182
			else*/																			//TFS 61182
				msg := camHistory.scanUntil(Cr, pos);
			//endif;		
			//30.08.24	navhn30		TFS 65667 end
		endif;
		app.writeLog(method.qualifiedName &amp; " CamHistory "  &amp; _camHistory.getOidAsString &amp; " position: " &amp; pos.String, LogTRACE);
		
		msgCount += 1;
		//jlier1 TFS 58637 20/6/23
		if _resendIndex &gt; 0 then
			//we are resending only send the message we are interested in - usually the one that failed
			if msgCount &lt;&gt; _resendIndex then
				app.writeLog(method.qualifiedName &amp; " Message " &amp; msgCount.String &amp; ": ignored. Only resending " &amp; _resendIndex.String , LogDEBUG);
				if pos = 0 then
					break;
				endif;
				continue;
			endif;
		endif;
		agent.setMsgIndex(msgCount);
		app.writeLog(method.qualifiedName &amp; " Message " &amp; msgCount.String &amp; ": " &amp; msg, LogDEBUG);
		
		// Make Unit Test life a bit easier - and if sending to localhost, then don't actually do it, just simulate it!
		if app.isJMTUnitTest and serviceDef.baseEndpoint = "http://localhost" then
			app.writeLog(method.qualifiedName &amp; " UNIT TEST: *Simulating* sending CAMS to : " &amp; serviceDef.name, LogINFO);
			response := "UNIT TEST RESPONSE OK";
			responseCode := HttpResponseOK;
		else
			// send this to the endpoint
			app.writeLog(method.qualifiedName &amp; " Sending CAMS to : " &amp; serviceDef.name, LogINFO);
			response := agent.doSendHTTPRequest(qualifiedEndpoint, verb, agent.getAdditionalHeadersForHTTP(), msg, responseCode);	// TFS 57207
		endif;

		if responseCode &lt;&gt; HttpResponseOK then		// 14/5/24  navsaa30 #61187
			proxyHist.setErrorMessage(response);
		endif;
		
		if responseCode = null or not responseCode.isOneOf(HttpResponseOK, HttpResponseCreated) then
			app.writeLog(method.qualifiedName &amp; " FAILED: Response from " &amp; serviceDef.name &amp; " was " &amp; responseCode.String &amp; ":" &amp; response, LogERROR);
		else
			app.writeLog(method.qualifiedName &amp; " Response from " &amp; serviceDef.name &amp; " was " &amp; responseCode.String &amp; ":" &amp; response, LogINFO);
		endif;
		
		if pos = 0 then
			break;
		endif;
		
	endwhile;
	
	// 14/5/24  navsaa30 #61187
	if responseCode &lt;&gt; null then
		error := responseCode.String;
	endif;
	if response &lt;&gt; null then
		if error &lt;&gt; null then
			error := error &amp; ": " &amp; response;
		else
			error := response;
		endif;
	endif;
	proxyHist.setErrorMessage(error);
	app.myTrxUA.trxUpdateCamTaskHistory(proxyHist, app.myPassport);
	
epilog
	delete agent;
	//delete agentJson;	//TFS 61182
	//delete hugeStrArr;	//TFS 61182
	delete proxyHist;	//TFS 61187
end;</source>
        <access>protected</access>
        <Parameter name="_camHistory" type="CM_CamTaskHistory"/>
        <Parameter name="_resendIndex" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="sendSFTP" id="6af2b85d-ec45-4cdd-bdf9-e653f9ca19ed">
        <source>sendSFTP(_folderName: String; _camHistory : CM_CamTaskHistory) protected;
//
// 17 Sep 2019	jlgrs1	TFS 46087 JMT implement SFTP.
// 05 Jun 2020	jlgmd1	TFS 49513 SNO cnwssh.dll is only on the server, and so we shouldn't be looking for the file to transfer on the thin client
// 11 Oct 2022  navds21 Bug 55119: MTN - Outbound SFTP adding multiple slashes to file paths
// 13 Mar 2023	navmd1	TFS 57047 Added some whitespace and fixed 1048 error caused by changes for 55119
//
vars
	sftpEntity : CM_SFTPEntity;
	fileName : String;
	file : File;
	sftp : CMIF_SFTPRequest;
	result : String;
	resultInt : Integer;
	outFileName : String;
	hadError : Boolean;
	msg : String;
	sftpEntDest : String;
begin
	sftpEntity := self.myFTPEntity.CM_SFTPEntity;
	app.writeLog(class.name&amp;'::'&amp;method.name&amp;' Protocol.code='&amp;self.code&amp;' camTaskHistory='&amp;_camHistory.String&amp;' folderName='&amp;_folderName, LogDEBUG);	
	
	fileName := _folderName &amp; _camHistory.fileName;
	app.writeLog("SFTP " &amp; fileName &amp; " to " &amp; sftpEntity.serverName, LogINFO);
	
	create file;
	file.kind := File.Kind_Unknown_Text; // 3/3/16  cnwns1 PAR 36286 unicode version	
	file.mode := File.Mode_Input;
	file.fileName := _folderName &amp; _camHistory.fileName;
	file.usePresentationFileSystem := false;
	
	if file.isAvailable then
		create sftp transient;
		sftpEntDest := sftpEntity.destinationDirectory;
		
		if sftpEntDest &lt;&gt; null then
			// Start 11.10.2022 navds21 TFS 55119
			//outFileName := '/'&amp;self.myFTPEntity.destinationDirectory&amp;'/'&amp;_camHistory.fileName;
			sftpEntDest.replaceChar('\', '/');
			
			if not sftpEntDest.startsWith("/") then
				outFileName := '/';
			endif;
			
			if sftpEntDest.endsWith('/') then
				outFileName &amp;= sftpEntDest &amp; _camHistory.fileName;
			else  
				outFileName &amp;= sftpEntDest &amp; '/' &amp; _camHistory.fileName;
			endif;
			// End 11.10.2022 navds21 TFS 55119
			
		else
			outFileName := '/' &amp; _camHistory.fileName;
		endif;
		
		app.writeLog("SFTP WriteFile " &amp; fileName &amp; " to " &amp; outFileName, LogINFO);
		msg := "emSFTP_WriteFileSync host="&amp;sftpEntity.getServerNameForConnect()&amp;' userId='&amp;sftpEntity.userId&amp;' password length='&amp;sftpEntity.getPwForUse(null).length.String&amp;' port='&amp;sftpEntity.port.String&amp;' sourceFile='&amp;fileName&amp;' destFile='&amp;outFileName&amp;' publicKey=null'&amp;' privateKey length='&amp;sftpEntity.privateKey.length.String&amp;' passPhrase length='&amp;sftpEntity.getPwForUse("passPhrase").length.String&amp;' subscriberOid='&amp;self.getInstanceIdForObjectXX(self).String&amp;' timeout='&amp;sftpEntity.timeOut.String;
		app.writeLog(class.name&amp;'::'&amp;method.name&amp;' '&amp;msg, LogDEBUG);
		
		hadError := sftp.emSFTP_WriteFileSync(self, sftpEntity.getServerNameForConnect(), sftpEntity.userId, sftpEntity.getPwForUse(null), sftpEntity.port, fileName, outFileName, sftpEntity.publicKey, sftpEntity.privateKey, sftpEntity.getPwForUse("passPhrase"), self.getInstanceIdForObjectXX(self), sftpEntity.timeOut, result);
		if hadError then
			app.writeLog(app.getErrorString1(Error_Display, result), LogINFO);
			app.raiseCMException1(Error_Display, result, null, null);
		endif;
	else
		app.writeLog("SFTP failed. File " &amp; file.fileName &amp; " not found.", LogINFO);
		if app.isJMTUnitTest then
			app.raiseCMException1(Error_Display, "SFTP failed. File " &amp; file.fileName &amp; " not found.", null, null);
		endif;
	endif;
epilog
	delete file;
	delete sftp;
end;
</source>
        <access>protected</access>
        <Parameter name="_folderName" type="String"/>
        <Parameter name="_camHistory" type="CM_CamTaskHistory"/>
    </JadeMethod>
    <JadeMethod name="setCoarri95BLocPDS" id="5ac61cd9-7a1b-4215-9fae-151dde24bbd6">
        <source>setCoarri95BLocPDS(_value : Boolean);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 Nov 2018	jlgsl4	TFS 39345 SNO - add LOC+7,LOC+PDS/LOC+11 to TDT+30
*/

vars

begin
	global.setExtraData(self.allExtraData, self, "changeCOARRI95BLocPDS", _value);
epilog

end;</source>
        <Parameter name="_value" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setCodecoVGMBGMMessageCode" id="d341c2a1-8d42-4fc8-bd88-dc427ee4e939">
        <source>setCodecoVGMBGMMessageCode(_value : String);
/*****************************************************
Author		: jlgka1 (Karen Alexander)
Date		: 25 June 2019
TFS#		: 44737
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/
begin
	global.setExtraData(self.allExtraData, self, "CodecoVGMBGMMsgCode", _value);
