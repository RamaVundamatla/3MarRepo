    </ExplicitInverseRef>
    <PrimAttribute name="windowHeight" id="17514e15-ff90-4337-88e0-8bad4db279ed">
        <embedded/>
        <type name="Real"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="windowLeft" id="c4517480-9a99-42dc-9d74-50b2dc10b0d2">
        <embedded/>
        <type name="Real"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="windowState" id="5b60e353-75d9-435f-a382-1e788d4f670c">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="windowTop" id="7cbbaaa3-e828-47c7-a1b8-364c1d85fcd0">
        <embedded/>
        <type name="Real"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="windowWidth" id="f9e1f7e1-8c01-403e-bf9a-0209186668ea">
        <embedded/>
        <type name="Real"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="updateMe" id="08622c01-27a3-4b8c-84b9-42db6077678b">
        <updating/>
        <source>updateMe(	pComputerName:String;
			pWindowState:Integer;
			pWindowLeft:Real;
			pWindowTop:Real;
			pWindowWidth:Real;
			pWindowHeight:Real;
			pTheRoot:JSSFMRoot) updating;
// --------------------------------------------------------------------------------
// Created:		13 July 2002 by cnwdad2
//
// Purpose:		Updates the User Profile with the window settings.
//
// Parameters:	pComputerName - The name of the workstation.
//				pWindowState - The current state of the window.
//				pWindowLeft - The coordinate of the window's left border.
//				pWindowTop - The coordinate of the window's top border.
//				pWindowWidth - The width of the window.
//				pWindowHeight - The height of the window.
//				pTheRoot - The owner of the receiver.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	// Set non-key properties.
	
	if self.windowState &lt;&gt; pWindowState then
		self.windowState	:=	pWindowState;
	endif;
	
	if self.windowLeft &lt;&gt; pWindowLeft then
		self.windowLeft		:=	pWindowLeft;
	endif;
	
	if self.windowTop &lt;&gt; pWindowTop then
		self.windowTop		:=	pWindowTop;
	endif;
	
	if self.windowWidth &lt;&gt; pWindowWidth then
		self.windowWidth	:=	pWindowWidth;
	endif;
	
	if self.windowHeight &lt;&gt; pWindowHeight then
		self.windowHeight	:=	pWindowHeight;
	endif;
	
	// Set key properties.
	
	if self.computerName &lt;&gt; pComputerName then
		self.computerName	:=	pComputerName;
	endif;
	
	// Set any inverse references.
	
	if self.myRoot &lt;&gt; pTheRoot then
		self.myRoot			:=	pTheRoot;
	endif;
end;</source>
        <Parameter name="pComputerName" type="String"/>
        <Parameter name="pWindowState" type="Integer"/>
        <Parameter name="pWindowLeft" type="Real"/>
        <Parameter name="pWindowTop" type="Real"/>
        <Parameter name="pWindowWidth" type="Real"/>
        <Parameter name="pWindowHeight" type="Real"/>
        <Parameter name="pTheRoot" type="JSSFMRoot"/>
    </JadeMethod>
</Class>
