    <JadeMethod name="setupForm" id="a3b59982-a9e5-45d7-8873-e8aa5782c189">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		November 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin
	create self.myQueryHdr transient;
	self.usesQueryFrame := true;
	self.useTableInfo := false;
	self.useTableSorting := true;
	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	
	inheritMethod();
	
	self.frmQuery.width := 330;
	self.frmQuery.height := 300;
	self.initTableData(null);
	self.initQueryStuff();
	
	self.txtDisplay.enabled := true;
	self.txtDisplay.visible := true;
	self.txtDisplay.width := self.tblData.width;
	self.txtDisplay.top := self.frmToolbar.height -1;
	self.txtDisplay.width := self.width-7;
	self.txtDisplay.height := 75;
	self.txtDisplay.left := 0;
	self.splMain.top := self.txtDisplay.top + self.txtDisplay.height;
	self.splMain.stretchHeight := true;
	self.setNavigatorHeading(self.caption);
	self.checkBox_Detail.caption := app.getErrorString(Contain_OtherCargoDtl);
	
	self.mnuColumnOrganiser.visible := false;
	self.mnuContextTIEnquire.visible := false;
	self.mnuSendToReport.visible := false;
	self.doResetSearch();
end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="974f9358-64a9-454d-b5ce-f999467dee00">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0007316, locale);
	btnExportCSV_CE.translateCaption(Xlat_0013419, locale);
	btnSendReport.translateCaption(Xlat_0007318, locale);
	btnSendScreen.translateCaption(Xlat_0007319, locale);
	checkBox_Detail.translateCaption(Xlat_0007320, locale);
	checkBox_Summary.translateCaption(Xlat_0007321, locale);
	lblDateFrom.translateCaption(Xlat_0007322, locale);
	lblDateTo.translateCaption(Xlat_0007323, locale);
	lblOR.translateCaption(Xlat_0007324, locale);
	lblVoyage.translateCaption(Xlat_0007325, locale);
end;</source>
    </JadeMethod>
</GUIClass>
