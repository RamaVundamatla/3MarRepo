    <JadeMethod name="setTable" id="f608ad45-b3f6-408d-8b61-7c006f6c324b">
        <updating/>
        <source>setTable( _table: Table; _column : Integer ) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 December 2011	cnwndl1	Initial creation

*/

vars

	 strArray : StringArray;
	 intArray : IntegerArray;

begin

	self.mySourceTable := _table;
	
	create strArray transient;
	create intArray transient;
	
	if self.mySourceTable = null then
		return;
	endif;
	
	self.column := _column;	
	if ( _column &gt; self.mySourceTable.columns or _column &lt; ( self.mySourceTable.fixedColumns + 1 )) then
		return;
	endif;
	
	self.startRow := self.mySourceTable.fixedRows + 1;
	self.endRow := self.mySourceTable.rows;
	
	if self.endRow &lt;= self.startRow then
		return;
	endif;
	
	self.getFilterValuesFromSource( strArray, intArray );
	
	if strArray.isEmpty then
		 return;
	endif;
	
	self.setTblFilterValues( strArray, intArray );

epilog

	if strArray.isEmpty then
		self.mySourceTable := null;
	endif;

	delete strArray;
	delete intArray;

end;</source>
        <Parameter name="_table" type="Table"/>
        <Parameter name="_column" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setTblFilterValues" id="1f63a7f1-887e-44df-9663-9dfe6de155ce">
        <updating/>
        <source>setTblFilterValues( _strArray : StringArray;  _intArray : IntegerArray ) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2011	cnwndl1	Initial creation

*/

vars

	index : Integer;
	str : String;
	str2 : String;
	pos : Integer;

begin

	// set up the name of the column we are playing with. (Allow for multi heading columns.)
	self.lblFilterColumn.caption := null;
	if self.mySourceTable.fixedRows &gt; 0 then
		foreach index in 1 to  self.mySourceTable.fixedRows do
			str2 := self.mySourceTable.getCellText( index, self.column ).trimBlanks;
			if str = null then
				str := str2;
			else
				if str2 &lt;&gt; null then
					str := str &amp; ", " &amp; str2;
				endif;
			endif;
		endforeach;
		self.lblFilterColumn.caption := str;
	endif;
	
	//set up the table for the filter values
	self.tblFilterValues.fixedRows := 1;
	self.tblFilterValues.rows := 1;
	self.tblFilterValues.fixedColumns := 0;
	self.tblFilterValues.columns := 3;
	self.tblFilterValues.accessColumn(1).inputType := Table.InputType_CheckBox;
	
	// set up the column headings for the table of filter values
	self.tblFilterValues.accessCell(1,1).inputType := Table.InputType_None;
	self.tblFilterValues.setCellText(1,1, "Include" &amp; Tab &amp; "Value" &amp; Tab &amp; "Items");
	
	// add in the filter value lines
	pos := 0;
	foreach str in _strArray do
		pos := pos + 1;
		index := self.tblFilterValues.addItem( "1" &amp; Tab &amp; str &amp; Tab &amp; _intArray[pos].String);
	endforeach;	
	
	self.tblFilterValues.sortAscending := true;
	self.tblFilterValues.resortTableByColumn(2);
	
epilog

	app.mousePointer	:=	Idle;

end;</source>
        <access>protected</access>
        <Parameter name="_strArray" type="StringArray"/>
        <Parameter name="_intArray" type="IntegerArray"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="d4c63ae8-1cd0-4010-8f0a-2d108a25d965">
        <updating/>
        <source>setupForm() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 December 2011	cnwndl1	Initial creation

*/

vars

begin

	inheritMethod();
	
	if self.mySourceTable = null then
		//nothing to do here... bye..
		self.doCancel();
		return;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="400a6580-ff64-4083-a449-b567bf8d045a">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018620, locale);
	btnClear.translateCaption(Xlat_0018621, locale);
	btnSelect.translateCaption(Xlat_0018622, locale);
	lblFilterColumn.translateCaption(Xlat_0018623, locale);
	optTableData.translateCaption(Xlat_0018624, locale);
	optUserData.translateCaption(Xlat_0018625, locale);
end;</source>
    </JadeMethod>
</GUIClass>
