    <JadeMethod name="updateLocation" id="17cc15a7-549e-48e7-b66a-eabcf6e67161">
        <updating/>
        <source>updateLocation(_lc : CM_LocationsController) updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 April 2010	cnwjk3	Initial creation

*/

vars
	gridLocation : CMIF_RDTGridLocation;
begin
	self.myTargetLocation := _lc;
	if self.isLocationInGriddedArea(_lc) then
		// The display builder will not have been executed yet, so we get the 
		// information we need from the gridded area itself.
		self.myGridArea :=  _lc.CM_GridController.getMyGridArea();
		if self.isLandscape then
			if self.drawMode = CMIF_RDTDrawElement.MODE_FACE then
				if self.targetLocationHeight &gt; 0 then
					if self.targetLocationHeight &gt; self.myGridArea.getHeightOfStack() then
						self.targetLocationHeight := 1;
					endif;
					self.rowLC := self.gridRowToStackHeight(self.targetLocationHeight, self.myGridArea);
					self.colLC := self.myTargetLocation.CM_GridController.column;
				else
					// No height was specified in the location string and we are looking at the side (or face) view
					// of a gridded row.  We need to work out the first height available in the stack so that we center 
					// on that.
					self.rowLC := self.myGridArea.getHeightOfStack - self.myTargetLocation.allTrackedItems.size();
					if self.rowLC &lt; 1 then
						self.rowLC := 1;
					endif;
					self.targetLocationHeight := self.gridRowToStackHeight(self.rowLC, self.myGridArea);

					//self.rowLC := self.myTargetLocation.CM_GridController.row;
					self.colLC := self.myTargetLocation.CM_GridController.column;
				endif;
			else
				self.rowLC := self.myTargetLocation.CM_GridController.row;
				self.colLC := self.myTargetLocation.CM_GridController.column;	
			endif;
		else
			self.rowLC := self.myTargetLocation.CM_GridController.column;
			self.colLC := self.myTargetLocation.CM_GridController.row;
		endif;
	else
		// The display builder will have been executed befor we get here.  This allows us
		// to ge the information we need from the display builder for non-gridded areas
		self.myGridArea :=  null;
		gridLocation := self.myDisplayBuilder.getGridLocation(_lc);
		if gridLocation &lt;&gt; null then
			self.rowLC := gridLocation.row;
			self.colLC := gridLocation.col;
		endif;
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_lc" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="vScrollAmount" id="2e09c176-9669-436b-b9b3-453f4977c3f0">
        <methodInvocation>mapping</methodInvocation>
        <source>vScrollAmount(set: Boolean; _value: Real io) protected, mapping;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2010	cnwjk3	Initial creation

*/

vars

begin
	if set then
		// set code here
	else
		// get code here
		_value := self.vScrollFactor * self.getGridHeight();
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="zoomIn" id="086ac733-bb3d-4e4d-9d5a-aedd809dc70c">
        <updating/>
        <source>zoomIn() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 April 2010	cnwjk3	Initial creation

*/

vars

begin
	if self.scaleFactor &gt;= MAX_SCALE then
		return;
	endif;

	self.debugCols( "-------- " &amp; method.name &amp; " Before Cols ------- " );
	self.debugRows( "-------- " &amp; method.name &amp; " Before Rows ------- " );	


	//self.scaleFactor := self.scaleFactor * 2;
	self.scaleFactor := self.scaleFactor + SCALE_INCREMENT;
	self.resetScrollOffsets();
	self.resizeDrawingFrames();
	
	// Zoom relative to the current top row and left column 
	self.rowLC := self.topGridRow;
	self.colLC := self.leftGridCol;
	
	self.calcViewSizes();
	self.reCalcRowsCols();
	//self.calcViewRowsColsFromLC();
	self.calcDrawRows();
	self.calcDrawCols();
	self.drawEverything();

	self.debugCols( "-------- " &amp; method.name &amp; " After Cols ------- " );
	self.debugRows( "-------- " &amp; method.name &amp; " After Rows ------- " );	


epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="zoomOut" id="48d0575b-6aaa-409f-8bf4-7b6b9b1ce289">
        <updating/>
        <source>zoomOut() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 April 2010	cnwjk3	Initial creation

*/

vars

begin
	
	if self.scaleFactor &lt;= MIN_SCALE then
		return;
	endif;

	
	//self.scaleFactor := self.scaleFactor / 2;
	self.scaleFactor := self.scaleFactor - SCALE_INCREMENT;

	self.resetScrollOffsets();
	self.resizeDrawingFrames();

	self.debugCols( "-------- " &amp; method.name &amp; " Before Cols ------- " );
	self.debugRows( "-------- " &amp; method.name &amp; " Before Rows ------- " );	
	
	// Zoom relative to the current top row and left column 
	self.rowLC := self.topGridRow;
	self.colLC := self.leftGridCol;

	self.calcViewSizes();
	self.reCalcRowsCols();

	//self.calcViewRowsColsFromLC();
	self.calcDrawRows();
	self.calcDrawCols();
	self.drawEverything();

	self.debugCols( "-------- " &amp; method.name &amp; " After Cols ------- " );
	self.debugRows( "-------- " &amp; method.name &amp; " After Rows ------- " );	
		
epilog

end;</source>
    </JadeMethod>
</Class>
