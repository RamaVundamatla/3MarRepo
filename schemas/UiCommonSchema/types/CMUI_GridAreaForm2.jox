    <JadeMethod name="dkcExtraInfo_queryDock" id="f84a0bfb-5d91-43f5-9bde-7f2066f6826c">
        <controlMethod name="JadeDockContainer::queryDock"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>dkcExtraInfo_queryDock(dockcont: JadeDockContainer input; dockWith: Window input; dockPosn: Integer):Boolean updating;
// ---------------------------------------------------------------------------
// Created:     05 August 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if dockWith = self.dkcSubMain and
	   dockPosn = JadeDockContainer.AlignContainer_AllHorizontal then
		// only allow to be docked horizontally in subMain
		return true;
	endif;
	
	return false;
end;</source>
