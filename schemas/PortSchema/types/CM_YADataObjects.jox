    <JadeMethod name="getYAIdentifier" id="a7371aaa-c915-45d1-a479-a1e32ff58b1e">
        <source>getYAIdentifier(): String;

/*

Purpose:		Returns the identifier for the criteria that is used for data entry.

Date			Who		Reason
27 August 2008	consw1	Initial creation
18 Sep 2009		cnwkpd1	PAR #20703 - Handle deleted objects by ignoring them in the display string
*/

vars
	dataObject: Object;
	displayString: String;
	invalid		: Boolean;

begin
	on Exception do app.handleDeletedObject(exception, dataObject, invalid);	//PAR #20703

	foreach dataObject in self.allObjects do
		displayString := displayString &amp; dataObject.getYAIdentifier() &amp; ", ";
	endforeach;
	
	if displayString &lt;&gt; null then
		displayString := displayString[1:displayString.length-2];
	endif;
	
	return displayString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
