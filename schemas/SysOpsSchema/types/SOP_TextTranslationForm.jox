    <JadeMethod name="txtSearch_change" id="f2a5d8b3-05d8-4eeb-b878-01431392069b">
        <controlMethod name="TextBox::change"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>txtSearch_change(textbox: TextBox input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 November 2018	jlgns1	Initial creation

*/

vars

begin
	
	chkInsensitive.value := true;
	if chkNumOnly.value &lt;&gt;	textbox.text.cnIsNumericAndNotNegative then
		chkNumOnly.value := not chkNumOnly.value;
		chkNumOnly_click(chkNumOnly);
	endif;
	
epilog

end;</source>
        <Parameter name="textbox" type="TextBox" usage="input"/>
    </JadeMethod>
