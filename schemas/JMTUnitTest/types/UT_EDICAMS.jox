    <JadeMethod name="zCodeco_STANDARD3" id="a76e4d83-fb5d-4497-9359-cc7ffddf09fd">
        <source>zCodeco_STANDARD3(_operator : String; _damSeverity : Integer) : String protected;
//
//22 August 2017	jlgrs1	TFS 6560 SNO Damaged/Repair
// 20 Sep 2017	jlgrs1	TFS 7033 Standard CODECO Corrections
// 08 Feb 2018	jlgsl4	TFS 36897 LOC+165 now required, UNT also changed as result; 160:20 -&gt; 139:6
// 07 Nov 2019	jlgdi1	46578 Cam process the transactions in transaction type and date/time ascending order,
//						and because the damaged transaction (TRANS_TYPE_DAMAGED = 1) has a value lower than 
//						the repair transaction (TRANS_TYPE_REPAIR = 10), damage transaction should come first in the message
// 26 Mar 2021  cnwma1  Bug 51009: GPHA - Inconsistencies in UNB segment between COARRI and CODECO
// 28OCT2022 - NAVAB1 - severity is now an object so calling method  created a severity, used it and then deletes it. 'DAMAGED TOP HAS BENT(8884)'
begin
return "UNA:+.? '
UNB+UNOA:2+UT_SENDER:ZZZ+UT_RECIPIENT:ZZZ+180208:1142+0'
UNH+1+CODECO:D:95B:UN:SMDG16'
BGM+DAM+1+9'
NAD+CA+" &amp; _operator &amp; ":160:20'
NAD+MS+NZCHC:160:87'
GID+1'
FTX+AAA+++Reefer Cargo'
TMP+2+0.0:CEL'
SGP+UTUT000005'
EQD+CN+UTUT000005+2232:102:5++2+5'
RFF+BM:20940709'
DTM+7:201708231132:203'
LOC+165+NZPOE:139:6+UT_FACILITY:TER:ZZZ'
MEA+AAE+G+KGM:2000'
FTX+DAR++0:ZZZ:184+DAMAGED TOP HAS BENT(" &amp; _damSeverity.String &amp; ")'
TDT+1'
NAD+CF+UTOP:172:20'
CNT+16:1'
UNT+18+1'
UNH+2+CODECO:D:95B:UN:SMDG16'
BGM+REP+2+9'
NAD+CA+" &amp; _operator &amp; ":160:20'
NAD+MS+NZCHC:160:87'
GID+1'
FTX+AAA+++Beer'
SGP+UTUT000006'
EQD+CN+UTUT000006+2200:102:5++3+5'
RFF+BM:20940710'
DTM+7:201708231132:203'
LOC+165+NZPOE:139:6+UT_FACILITY:TER:ZZZ'
MEA+AAE+G+KGM:4000'
MEA+AAE+T+KGM:4000'
FTX+DAR++0:ZZZ:184+NOT DAMAGED'
TDT+1'
NAD+CF+UTOP:172:20'
CNT+16:1'
UNT+18+2'
UNZ+2+0'";

/*
return
"UNA:+.? '
UNB+UNOA:2+UT_SENDER:ZZZ+UT_RECIPIENT+180208:1142+0'
UNH+1+CODECO:D:95B:UN:SMDG16'
BGM+REP+1+9'
