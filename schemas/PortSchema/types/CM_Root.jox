        <source>setupInvStatusEmailDefaults() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 16/01/2019	jlgsl4		TFS 39618
// 29/11/2023	navra1		TFS 54090 - EUP | EUP | Interface - MTN Invoicing Oracle &lt;&lt;54090&gt;&gt;(CR - 61386, Task - 61564)
