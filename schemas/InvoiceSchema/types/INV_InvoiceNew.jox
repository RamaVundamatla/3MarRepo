    <JadeMethod name="displayInvoice" id="f03d4df9-a57a-4bdd-8681-b10fcdc23a96">
        <source>displayInvoice() protected;
/*

Purpose:			Sets the form up to display an invoice

Parameters:			NONE

Return Value:		NONE

Date		Who		Reason
30 September 2022	navpw1	Initial creation TFS: 54565 (54384)
10/11/2023			navkc1 	Bug 61004: LNX - New Invoice Creation screen is multi tabbed
24/12/2024			navlw1 	JIRA-33637: MTN - JADE 1090 exception in Invoice Listing screen
*/

vars
	textHeight,
	narrHeight		: Integer;
	packageNames	: String;
	theTable 		: CM_EntryTable;
	theNarrRow 		: Integer;
	today			: Date;
	finIOClass 		: CM_ExtFinanceIO;
	isASPAInterface : Boolean;
	
begin
	finIOClass := self.myTerminal.getConfig(FinancialIOClass).CM_ExtFinanceIO;
	
	if finIOClass &lt;&gt; null and finIOClass.isKindOf( CM_ASPAInterface ) then
		isASPAInterface := true;
	endif;
	// 10/11/2023	navkc1 Bug 61004
	/*
	theTable := self.tblInvProperties;
	theTable.hideRowByName(ETRow_ArrivalTS,false);
	theTable.hideRowByName(ETRow_DepartureTS,false);
	theTable.hideRowByName(ETRow_VoyageDesc,false);
	theTable.hideRowByName(ETRow_Voyage,false);
	*/
	if theTable &lt;&gt; null then // navlw1 #JIRA:33637
		if isASPAInterface then
			theTable.hideRowByName(ETRow_IsZeroRated,false);
		endif;
	endif;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doAddToLinkTable" id="f6b4e999-c890-42d7-a504-10fa018b0416">
        <updating/>
        <source>doAddToLinkTable() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
//20/07/2023	navkc1	Bug 58995: EUP - Inv Maint Credit Notes

*/

vars
	allSelectedItems	: ObjectArray;
	resultTable, 
	linkTable			: CM_DataTable;
	invoice				: CM_Invoice;
	line				: String;
	row					: Integer;
begin
	resultTable := self.tblInvoiceResult;
	linkTable 	:= self.tblInvoiceLink;
	
	create allSelectedItems transient;
	
	resultTable.allSelectedObjects.copy(allSelectedItems);

	foreach invoice in allSelectedItems as CM_Invoice do
		// Add Invoice to the Link table
		line := invoice.getAttributeStringForDefArray(linkTable.allTblDataEntRows);
		linkTable.addItemObject(invoice, line);
		self.allInvoicesToLink.addNoDuplicates(invoice, false);
		// Remove Invoice from the Result table
		row := -1;
		resultTable.findObjectInRow(invoice, row);
		if row &gt; 0 then
			resultTable.removeItem(row);
		endif;
	endforeach;

epilog
	delete allSelectedItems;
end;</source>
    </JadeMethod>
