    <JadeMethod name="setNonce" id="403b2287-a821-4401-a783-314af8b962d2">
        <updating/>
        <source>setNonce(_guid : String; _expiry : TimeStamp; _utilised : Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 Aug 2022 navam1	ChangeRequest 53986: EUP - Azure Active Directory Single Sign On - Web
08 May 2025	navnk30	JIRA 34701: SSO Implementation for Vehicle App - Jade Portion

*/

vars

begin
	self.guid 	:= _guid;
	self.expiry	:= _expiry;
	//self.utilised := utilised;	//08.05.2025 navnk30 JIRA 34701
	self.utilised := _utilised;		//08.05.2025 navnk30 JIRA 34701
	
	self.myRoot := app.myRoot;

epilog

end;</source>
        <Parameter name="_guid" type="String"/>
        <Parameter name="_expiry" type="TimeStamp"/>
        <Parameter name="_utilised" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setUtilised" id="d92db870-3397-46fe-aa10-45a6ee8601da">
