<GUIClass name="GRP_Outline" id="b70efbec-9327-435f-9cdd-30aa388cda19">
    <superclass name="CnForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <ImplicitInverseRef name="frame1" id="a6b73cf9-22ba-4b89-9a84-6fa3ac1e3588">
        <embedded/>
        <type name="Frame"/>
    </ImplicitInverseRef>
    <JadeMethod name="drawOutline" id="ffc0b4fb-db36-4eaa-af42-7299991a2213">
        <source>drawOutline();
// ---------------------------------------------------------------------------
// Created:		25 July 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.frame1.autoRedraw := true;
	self.beginTimer(300, Timer_Continuous, 666);
end;</source>
    </JadeMethod>
    <JadeMethod name="load" id="ddbc00c9-3997-44ec-8b2b-80621586c3e1">
        <controlMethod name="Form::load"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>load() updating;
// ---------------------------------------------------------------------------
// Created:		25 July 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.drawOutline();
end;</source>
    </JadeMethod>
    <JadeMethod name="timerEvent" id="601352b9-ad6a-402b-b06e-9f9c5e246265">
        <updating/>
        <executionLocation>client</executionLocation>
        <source>timerEvent(eventTag: Integer) updating, clientExecution;
// ---------------------------------------------------------------------------
// Created:		25 July 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.frame1.drawStyle := Frame.DrawStyle_Dash;
	self.frame1.drawMode := Frame.DrawMode_Invert;
	self.frame1.drawRectangle(50,50,100,100,Red);
	
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
</GUIClass>
