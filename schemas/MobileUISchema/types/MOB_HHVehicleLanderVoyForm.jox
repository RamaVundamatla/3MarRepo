    <JadeMethod name="doResizeControls" id="8d5294b6-eafd-4b50-a4bf-024737c73f6e">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 February 2016	cnwndl1	Initial creation		TFS1593

*/

vars

	top : Real;
	width : Real;
	now : TimeStamp;
	stdHeight : Real;
	tabIndex : Integer;

begin

	self.setResizeableMarginAndFontSize();
	
	top := self.resizedMargin;
	width := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	tabIndex := 4000;
	
	if _initialSetup then
		self.cmbVoyage.setAndIncrementTabIndex( tabIndex );
		self.cmbVoyage.visible := true;
	endif;
	self.cmbVoyage.move(	self.resizedMargin,
							top,
							width,
							stdHeight
							);
	
	top := top + self.cmbVoyage.height + self.resizedMargin;
	if _initialSetup then
		self.cmbWorkPoint.setAndIncrementTabIndex( tabIndex );
		self.cmbWorkPoint.visible := true;
	endif;
	self.cmbWorkPoint.move(	self.resizedMargin,
							top,
							width,
							stdHeight
							);
	
	
	
	
	self.resizeCmdButtons();

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="handleBtnOne" id="f5640bd9-ab65-4f2c-96f6-3b01e538eb6d">
        <updating/>
        <source>handleBtnOne() updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
29 February 2016	cnwndl1	Initial creation	TFS 1593

*/

vars

	voyage : CM_Voyage;
	wp : CM_WorkPoint;
	msg : String;

begin

	self.myMobileGenericAgent.setMyVoyage(null);
	self.myMobileGenericAgent.setMyWorkPoint(null);

	voyage := self.cmbVoyage.listObject.CM_Voyage;
	if voyage = null then
		msg := app.getErrorString(Must_select_voyage);
		return;
	endif;
	
	wp := self.cmbWorkPoint.listObject.CM_WorkPoint;
	if wp = null then
		msg := app.getErrorString(Input_required_field_workPoint);
		return;
	endif;
	
	self.myMobileGenericAgent.setMyVoyage(voyage);
	self.myMobileGenericAgent.setMyWorkPoint(wp);
	
	self.gotoForm( MOB_HHVehicleLanderMove, false );

epilog

	if msg &lt;&gt; null then
		self.msgBox(msg , app.getErrorString(Error), MsgBox_OK_Only, true);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
