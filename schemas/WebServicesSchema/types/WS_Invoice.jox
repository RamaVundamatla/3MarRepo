<Class name="WS_Invoice" id="688b8501-a719-4511-94be-bb3ebb6bc02c">
    <superclass name="WS_ProxyObject"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <PrimAttribute name="canApprove" id="4999e01a-110e-4f45-9edf-ebf75b08f8fb">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="canRecheckFinance" id="2328d1bb-52ef-459b-8bf8-acb3538a0d90">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="canReject" id="5a2f04a8-7a13-491e-8db4-aa6a65d7abb8">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="externalInvoiceNumber" id="d41dfce4-0723-49bf-bad3-474822e6b37b">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="invoiceActionDT" id="18197ee3-e35f-4ad6-8317-fe908367f544">
        <length>31</length>
        <embedded/>
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="invoicePaymentStatus" id="12567bfd-fcde-445b-9da3-5d5476511b5f">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="invoiceStatus" id="982d0c4a-5112-44ba-94ba-20080f4f032f">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="invoiceType" id="6feddff3-3894-4e58-b008-b71cdc2b74cc">
        <type name="String"/>
    </PrimAttribute>
    <JadeMethod name="setFromCashReceipt" id="d64e8c33-d332-4ff2-a8c8-86f2008c7362">
        <updating/>
        <source>setFromCashReceipt(_cashrec : CM_CashReceipt) updating;

/*

Purpose:		TFS 41026	

Parameters:			

Return Value:		


Date		Who		Reason
21/09/2018	jlgab1	Initial creation TFS 
21/01/2019	jlgdap1	TFS 42925 Estimation Approval Countdown
23/01/2019	cnwma1	ChangeRequest 42943: PEL1 - Recheck Finance for WSDL 1.4 on Web Portal
09/08/2019	jlgdap1	TFS 45858 Pass back different invoice type if set on the cash receipt
*/

vars
	invtype  : CM_InvoiceDesc;
	wo 		 : CM_WorkOrder;
	apprDate : TimeStamp;				// TFS 42925
	now      : TimeStamp;
begin
	self.cmObjectEdition		:= _cashrec.edition();
	self.cmObjectId				:= _cashrec.getOidAsString();
	self.externalInvoiceNumber 	:= _cashrec.externalInvoiceNumber;
	self.canApprove				:= false;
	self.canReject 				:= false;
	self.canRecheckFinance      := false;  //23.01.2019 cnwma1 TFS #42943
	
	// ### ESTIMATE APPROVE AND REJECT IS ONLY FOR PREPAY NOT POST PAY AND AUTO PAY
	// ### IF THE ESTIMATE IS APPROVED AN INVOICE IS CREATED FROM THe CASH RECEIPT
	if _cashrec.myWorkOrder &lt;&gt; null  then
		wo := _cashrec.myWorkOrder;
		//if not wo.isVoyageWorkOrder and _cashrec.myDebtorTerminal.isPrePay then	// TFS 42925
		if not wo.isVoyageWorkOrder and _cashrec.isPrePay then						// TFS 42925
			apprDate			:= _cashrec.getActionDT();							// TFS 42925
			if apprDate.date.isValid then											// TFS 42925
				self.invoiceActionDT := apprDate.asStringForWebInterface;			// TFS 42925
			endif;																	// TFS 42925
			self.canApprove		:=_cashrec.myCashInvoice = null and (wo.taskStatus = WO_STATUS_USERENTRY or wo.taskStatus = WO_STATUS_PENDING );
			self.canReject 		:= _cashrec.myCashInvoice = null and (wo.taskStatus = WO_STATUS_USERENTRY or wo.taskStatus = WO_STATUS_PENDING ); //epr TFS 42924 22/1/18
			
			/*
			The Re-check Finance option on the Work Order screen for Cargo Work Orders must be displayed only if the below 2 conditions are met,
			23.01.2019 cnwma1 TFS #42943
			1. Finance check is rejected
			2. 24 hours have not passed since the Pre-invoice was created. 
			*/
			if _cashrec.myCashInvoice &lt;&gt; null then
				if _cashrec.myCashInvoice.prependDT.isValid then
					now := app.actualTimeServer; 
					if _cashrec.paymentStatus = CM_CashReceipt.CREDIT_CHECK_REJECTED then
						if _cashrec.myCashInvoice.prependDT.differenceInHoursReal(now) &lt;= 24 then
							self.canRecheckFinance      := true;
						endif;
					endif;
				endif;
			endif;
			
		endif;
	endif;
	
	invtype := _cashrec.getProformaInvoiceType();
	if invtype &lt;&gt; null then
		self.invoiceType 		:= invtype.description;
	endif;
	if _cashrec.cashId4 &lt;&gt; null then							// TFS 45853
		self.invoiceType		:= _cashrec.cashId4;			// TFS 45853
	endif;														// TFS 45853
	
	self.invoicePaymentStatus := _cashrec.getPaymentStatusStr(_cashrec.paymentStatus);
epilog

end;</source>
        <Parameter name="_cashrec" type="CM_CashReceipt"/>
    </JadeMethod>
    <JadeMethod name="setProxyFromObject" id="ab2f1520-72fc-4501-a3fe-d980d39d23f7">
        <updating/>
        <source>setProxyFromObject(_object: CM_Invoice) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17/09/2018	jlgndl1	Initial creation	TFS 40889
21/09/2018	jlgdap1	TFS 40030 Multiple Estimates and Invoices
14/03/2019	jlgdap1	TFS 43822 PEL1 Container Services - Approve/Reject options for PrePay Pre-Invoice
*/

vars
	debtorTerminal : CM_DebtorTerminal;				// TFS 40030
	preInvoiceDT : TimeStamp;	//29 Oct 2018	NDL	TFS 41309

begin

	inheritMethod(_object);
	
	//self.externalInvoiceNumber := _object.externalFinancialId;
	self.externalInvoiceNumber := _object.getExternalFinancialId(); //08/12/2025	navkc1 JIRA 36262
	self.invoiceType := _object.invoiceType.description;
	self.invoiceStatus := _object.getStatusDescriptionForSelf();
	self.invoicePaymentStatus := _object.getPaymentStatusStr();
	
	//29 Oct 2018	NDL	TFS 41309
	preInvoiceDT := _object.getPreInvoiceApprovalDT();
	if preInvoiceDT.date.isValid then
		self.invoiceActionDT := preInvoiceDT.asStringForWebInterface;
	endif;
	
	// TFS 40030 can only approve / reject for prepay debtors when invoice status is prepend
	if _object.status = _object.INVOICE_PREPEND then
		// TFS 43822 Approve and Reject should be based on the Payment Type of the Invoice,			// TFS 43822
		// not the debtor																			// TFS 43822
		//debtorTerminal := _object.debtor.allDebtorTerminals[_object.myTerminal];					// TFS 43822
		// ### INVOICE APPROVE AND REJECT IS ONLY FOR POST PAY AND AUTO PAY NOT PREPAY
		//if debtorTerminal &lt;&gt; null and not debtorTerminal.paymentType = PaymentType_PrePay then	// TFS 43822
		if _object.paymentType &lt;&gt; PaymentType_PrePay then											// TFS 43822 
			// TFS 39618 PATCH 1 self.canApprove := app.getMyUser.canDo( _object.myTerminal, PmAdmInvoiceStatusPost) ;
			// TFS 39618 PATCH 1 self.canReject := app.getMyUser.canDo( _object.myTerminal, PmAdmInvoiceStatusDisputed) ;

			self.canReject :=  _object.bank.userCanSet(CM_Invoice.INVOICE_DISPUTED);  // TFS 39618 PATCH 1 
			self.canApprove :=  _object.bank.userCanSet(CM_Invoice.INVOICE_POSTED);  // TFS 39618 PATCH 1 
			
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_object" type="CM_Invoice"/>
    </JadeMethod>
</Class>
