    <JadeMethod name="setForUpdateLocations" id="14a1a5ad-d84f-49b2-8cca-207ffc685b60">
        <source>setForUpdateLocations(blockAreaProxy: CM_IrregularBlockArea) protected;
// Update the location controllers from the proxy, the status of the proxy locations
// will be either New, Delete, Update if something has changed
vars
	locationProxy, location: CM_LocationsController;
	blockLocation: CM_IrregularBlockController;
begin
	// Find all the locations that have been deleted - ie there is no proxy for them
	foreach location in self.allLocationsControllers do
		if location.pxyGetProxyObject() = null then
			// PAR 32886 delete location;
			location.erase(NORMAL_ERASE);
		endif;
	endforeach;		

	// update locations in the proxy
	foreach locationProxy in blockAreaProxy.allLocationsControllers do
		location := locationProxy.pxyGetRealObject();
		if location &lt;&gt; null then
			// location changed
			location.CM_IrregularBlockController.setForUpdate(locationProxy.CM_IrregularBlockController, self);
		else	
			// location added
			create blockLocation;
			blockLocation.setForCreate(locationProxy.CM_IrregularBlockController, self);
		endif;
	endforeach;
		
end;
</source>
        <access>protected</access>
        <Parameter name="blockAreaProxy" type="CM_IrregularBlockArea"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="b8c28dd3-c912-49c4-a4ea-f4863b2e0e38">
        <updating/>
        <source>setProxy(_id, _comment 		: String;
		 _type				: Integer;
		 _rows				: Integer;
		 _columns			: Integer;
		 _unit				: Decimal;
		 _rowLabels			: StringArray;
		 _columnLabels		: StringArray;
		 _autoRestrictions,
		 _stockControlled   : Boolean;
		 _terminal			: CM_Terminal;
		 _allInterchangeAreas	:CM_InterchangeAreaArray;	// par 24292
					_defaultInterchangeArea: CM_InterchangeArea
		 ) updating;  
// 26/05/2010		cnwcs5	par 24292 - change _allInterchangeAreas parameter from set to array		 
begin
	self.raiseExceptionIfNotTransient(method);
	setProxyTerminalArea(_id, _comment, _type, false, _terminal, _autoRestrictions, _stockControlled, false, _allInterchangeAreas,_defaultInterchangeArea);
	self.columns := _columns;
	self.rows := _rows;
	self.unit := _unit;
	
	self.todo;	// Save labels
end;</source>
        <Parameter name="_id" type="String"/>
        <Parameter name="_comment" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_rows" type="Integer"/>
        <Parameter name="_columns" type="Integer"/>
