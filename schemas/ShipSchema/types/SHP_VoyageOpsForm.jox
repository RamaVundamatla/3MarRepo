    <JadeMethod name="doTaskStatus" id="3a4d0508-5d8e-4fb5-a5a5-b0a2798410bd">
        <updating/>
        <source>doTaskStatus(_newStatus : Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 18/12/2014	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394 Voyage Rationalisation
//
vars
	wle, taskWle	: CM_WorkListEntry;
	queueEntry		: CM_RTQueueEntry;
	task 			: CM_RTQueueTask;
	changeOK		: Boolean;
	confirm			: Integer;
	result			: Integer;
	objArray		: ObjectArray;
	invalidObj		: Boolean;
	obj				: Object;
	str				: String;

begin
	on Exception do app.handleDeletedObject(exception, task, invalidObj);
	foreach taskWle in self.myCurrentTrackedItem.allWorklistEntries discreteLock do
		if taskWle.isKindOf(CM_VoyageWLE) then
			wle := taskWle;
			break;
		endif;
	endforeach;
	if wle = null then 
		return;
	endif;
	
	changeOK := false;
	create objArray transient;
	foreach queueEntry in wle.allRTQueueEntries discreteLock do
		foreach task in queueEntry.allTasks discreteLock do
			if _newStatus &lt;&gt; task.status then
				changeOK := true;
				objArray.add(task);
			endif;
		endforeach;
	endforeach;
	if not changeOK then
		return;
	endif;
	
	confirm := app.msgBox(app.getErrorString3(ConfirmChange, "task status", task.statusString, task.getStatusStr(_newStatus)), app.getErrorString(Warning), MsgBox_Yes_No + MsgBox_Exclamation_Mark_Icon); 
	if confirm = MsgBox_Return_Yes then
	
		app.mousePointer := MousePointer_HourGlass;
		
		on Exception do app.handleDeletedObject(exception, task, invalidObj);
		
		create objArray transient;
		objArray.add(task);
		
		foreach obj in objArray do
			invalidObj := false;
			
			task := obj.CM_RTQueueTask;
			str := task.queueId;
			if invalidObj then
				continue;
			endif;
			
			//21 April 2015	NDL	Par 36014 - Don't dick with the ones that are system set to hold.
			if task.status = TASK_SYS_HELD then
				app.msgBox(app.getErrorString2(ERR_TASK_STATUS_CHANGE, task.statusString, task.getStatusStr(_newStatus)), app.getErrorString(Warning), MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
				continue;
			endif;
			
			// Task can be deleted during process.
			while true do
				app.myTrxUA.trxUpdateQueueTaskStatus(task, _newStatus, app.myPassport);
				if app.myPassport.trxCompletedOK then
					break;
				else
					result := app.showErrorWarningDialog('Change task status', app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
					if app.myPassport.noErrors and
						result = IDOK then
						// there must have just been warnings that the user has acknoledged so ..
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					else
						break;
					endif;
				endif;
			endwhile;
		endforeach;
	endif;	
	
epilog
	delete objArray;
	app.mousePointer := MousePointer_Default;
end;</source>
        <Parameter name="_newStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doTestAutoPlan" id="22766516-89ea-407a-9532-5d11288b0aa3">
        <source>doTestAutoPlan( _childrenOnly : Boolean );
