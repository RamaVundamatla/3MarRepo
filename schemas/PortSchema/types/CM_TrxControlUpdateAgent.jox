    <JadeMethod name="trxResetPasswordAndEmail" id="068605df-80e1-4143-8f8e-5ff3e3cb2a68">
        <updating/>
        <source>trxResetPasswordAndEmail(	_userId : String;
							_email : String;
							_passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 October 2017	jlger1	Initial creation tfs 7177
04 Feb 2025		navah1	Story 14660: MTN - New option to disable users from changing their own passwords
*/

vars
	user : CM_User;
	randomPassword : String;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	beginTransaction;
	
	user := app.myRoot.allUsers[_userId];
	if user = null then
		app.raiseCMException1(ERR_REST_INV_USER, _userId, null, null);

		return ;
	endif;
	
	if not user.canChangePassword() then  //04.02.2025 navah1 #14660
		app.raiseCMException1(PasswordChangeProhibited, user.code, null, null);
		return;
	endif;
	
	if _email = null then
		app.raiseCMException1(No_Email_address_supplied, _userId, null, null);
		return ;
	endif;
	
	if user.myEmailEntity = null or (user.myEmailEntity.getEmailAddress &lt;&gt; _email) then
		app.raiseCMException1(Users_does_not_have_email, _email, null, null);
		return;
	endif;
	
	randomPassword:= app.myRoot.generateRandomPassword;
	app.myUtilityUA.utlUpdatePassword(user, user.edition, randomPassword, _passport);
	
	if _passport.hasErrors then
		return;
	endif;
	app.myUtilityUA.utlUpdateUserStatus(user, user.edition, NewUser, _passport);
	if _passport.hasErrors then
		return;
	endif;
	app.myUtilityCA.utlCreateEmailSendRequest(true,
												app.getErrorString(Web) &amp; ' ' &amp; $User &amp; ' ' &amp; app.myPassport.getUserCode(),
												_email,
												app.myRoot.getConfig(AutoSendersEmailAddress).String,
												null,
												null,
												app.getErrorString(Password_reset),
												app.getErrorString1(Your_passwor_been_reset,randomPassword),
												null,
												null,
												null,
												null,
												EmailSource_System,
												null,
												_passport);
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_userId" type="String"/>
        <Parameter name="_email" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxResetRootSecurityRoles" id="46d1b46f-7a9a-4148-bcec-2ba4c73d1d62">
