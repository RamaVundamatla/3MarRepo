    <JadeMethod name="isMoving" id="4367b3ec-51ec-43ff-a686-b5cad481fcf6">
        <updating/>
        <source>isMoving() : Boolean updating;

vars

begin
	if self.movingUntil &lt;&gt; null and self.getCurrentTime() &gt; self.movingUntil then
		self.movingUntil := null;
		self.logMessage(LOG_FULL, "Machine " &amp; self.myMachine.id &amp; " is in position for task " &amp; self.getTaskDisplay());
	endif;
	
	return self.movingUntil &lt;&gt; null;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
