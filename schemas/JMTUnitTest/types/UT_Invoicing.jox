// cnwma1
// cnwjre1 test 1280
//	create an invoice line per range (full escalating) is percentage
// 14 Dec 2021	navdap1	Unit test fixups after DMAST -&gt; WMAST code overwrite
vars
	start,
	expiry : TimeStamp;
	cStatus : CM_ContentsStatus;
	cargoMap	: CM_TranMap;
	theService : CM_Service;
	calType1		: CM_CalculationType;
	invType			: CM_InvoiceDesc;
	invLineType1,
	invLineType2,
	invLineType3,
	invLineType4  	: CM_InvoiceLineDesc;
	services : CM_ServiceByNameDict;
	bs: CM_BlockStack;
	voy : CM_Voyage;
	cargo : CM_TrackedItem;
	aPort : CM_Port;
	tran : CM_TITransaction;
	tranTS : TimeStamp;
	tranDate, editDate, today : Date;
	vvr : CM_VehicleVisitRecord;
	singleGate : CM_Gate;
	operator	: CM_Operator;
	debtor		: CM_Debtor;
	pxyDebtorRate	: CM_DebtorRate;
 	rateEntry		: CM_RateEntry;
	storeTrans		: CM_TITransaction;
	invoiceLines	: ObjectArray;
	perDays, rangeStart, rangeEnd	: IntegerArray;
	costs : DecimalArray;
	isPrecentageRate,
	isAmount 			: Boolean;
	roundTotalOpt	: Integer;
begin

	isPrecentageRate := true;
	isAmount := true;

	cargoMap := self.myBank.myCurrentTranMapCargo['Default'];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");
	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

	roundTotalOpt := self.setTerminalConfig(InvoiceRoundLineTotal, CMIF_ConfigTerminal.InvLineRound_Value_NoRound).Integer;
	
	bs:= self.getTerminalArea("UTSTORE3").CM_BlockStack;
	if bs &lt;&gt; null then
		self.deleteInvoiceLines(bs.myLocationsController);
	endif;
	self.deleteTerminalArea("UTSTORE3");
	self.deleteInvoiceTransactionMap(1, 'UT_StorageEsc1');
	self.deleteInvoiceType("UT_InvTypeStore3");
	self.deleteInvoiceService("UT_ServiceStore13", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree1", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree2", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree3", FORCED_ERASE);
	self.deleteInvoiceLineType("UT_LineTypeStoreFree4", FORCED_ERASE);
	self.deleteInvoiceCalcType("UT_ESC");

	create services transient;

	////////////////////////////////////////////////////////////////////
	// Create Invoice Type, Services and Invoice Line Type
	////////////////////////////////////////////////////////////////////
	invType := self.createInvoiceType("UT_InvTypeStore3", InvoiceTypeStorage);
	self.assertNotNullMsg(invType, "Invoice type UT_InvTypeStore3 not created");

	// create an escalating charge cargo calculation type based on INV_CALC_TYPE_DAYS_SINCE_RECVL
	create perDays transient;
	create rangeStart transient;
	create rangeEnd transient;
	/* set up as in the functional spec - 1 to 5 days free
		6 - 10 days at $10 per day, 11 to 20 at $15 per day
		21 days plus at $20 per day, rate increasing by $8 every 10 days
	*/
	perDays.add(0); perDays.add(0); perDays.add(0); perDays.add(10);
	rangeStart.add(1); rangeStart.add(6); rangeStart.add(11); rangeStart.add(21);
	rangeEnd.add(5); rangeEnd.add(10); rangeEnd.add(20); rangeEnd.add(99999999);

	calType1 := self.createInvoiceCalcType(null, 6, "UT_ESC", "Escalating", 
										  0, 0, 0, 0, null, false,
										  null, null, 0, 0, 0,
										  null, null, null, null,
										  true, false, false,
										  perDays, rangeStart, rangeEnd, null);
	self.assertNotNullMsg(calType1, "Calculation type Escalating Storage not created");
	
	theService := self.createInvoiceService("UT_ServiceStore13","UT Store1", calType1, null);
	self.assertNotNullMsg(theService, "UT_ServiceStore13 not created");
 	services.add(theService);
	
	invLineType1 := self.createInvoiceLineType("UT_LineTypeStoreFree1", calType1, invType, services,"SDT1");
	invLineType2 := self.createInvoiceLineType("UT_LineTypeStoreFree2", calType1, invType, services,"SDT1");
	invLineType3 := self.createInvoiceLineType("UT_LineTypeStoreFree3", calType1, invType, services,"SDT1");
	invLineType4 := self.createInvoiceLineType("UT_LineTypeStoreFree4", calType1, invType, services,"SDT1");
	
	self.assertNotNullMsg(invLineType1, "UT_LineTypeStoreFree1 not created");
	self.assertNotNullMsg(invLineType2, "UT_LineTypeStoreFree2 not created");
	self.assertNotNullMsg(invLineType3, "UT_LineTypeStoreFree3 not created");
	self.assertNotNullMsg(invLineType4, "UT_LineTypeStoreFree4 not created");
	if invLineType1 &lt;&gt; null then
		self.assertNotNullMsg(invLineType1.invoiceType, "UT_LineTypeStoreFree1 has null INV TYPE");
	endif;
	if invLineType2 &lt;&gt; null then
		self.assertNotNullMsg(invLineType2.invoiceType, "UT_LineTypeStoreFree2 has null INV TYPE");
	endif;
	if invLineType3 &lt;&gt; null then
		self.assertNotNullMsg(invLineType3.invoiceType, "UT_LineTypeStoreFree3 has null INV TYPE");
	endif;
	if invLineType4 &lt;&gt; null then
		self.assertNotNullMsg(invLineType4.invoiceType, "UT_LineTypeStoreFree4 has null INV TYPE");
	endif;

	// the invoicing debtor is that of the operator
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	debtor := operator.debtor;

	// Need to map to above invoice line types, using quantity ranges
	self.tranMapLoadEscalatingChg3();
	
	// set up rates for this debtor and service used
	create costs transient;
	create pxyDebtorRate transient;
	pxyDebtorRate.setProxy(theService, debtor);
	// rates are: $0 for 1-5, $10 for 6-10, $15 for 11-20, $20 for 21-max with $8 increment every 10 days
	costs.add(0.00);
	costs.add(100.00);
	costs.add(150.00);
	costs.add(200.00);
	costs.add(8.00);
	start.setDate("01/01/2010".Date);
	start.setTime("00:00".Time);
	expiry := null;
	rateEntry := self.addInvoiceRateEntryPercentage(pxyDebtorRate, start, expiry, false, costs,isPrecentageRate, isAmount);

	// create a container with retrospective transactions (refer example on PAR 24160)
	voy:=self.createVesselVoyage3();
	aPort := app.myRoot.allPorts["NZAKL"];
	bs:= addBlockStack("UTSTORE3", 100, null);


	// Create Storage Transactions
	cargo := bs.myTerminal.allOnsiteTIsByCargoTypeId[TI_CargoType_Container,"STOR4300111"];
	if cargo &lt;&gt; null then
		self.deleteCargo(cargo.id, cargo.myCargoType.abbreviation.toUpper);
	endif;
	cargo := self.addContainerAtLocnDisch("STOR4300111", "2200", "MT", TI_IMEX_STATUS_STORAGE, bs.myLocationsController, aPort, voy);
	
	// set Trans to 65 days ago
	// ##################
	tranDate := tranDate - 65;
	tranTS.setDate(tranDate);
	foreach tran in cargo.allTransactions do
		tranTS.setDate(tranDate);
		tranTS.setTime(tran.dateTime.time);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	
	cStatus := app.myRoot.allContentsStatuses[TI_CONTENTS_STATUS_FCL];
	self.editIMEXStatus(cargo, TI_IMEX_STATUS_EXPORT,false);
	self.editCommodity(cargo, "GENL");
	
	// this creates the first storage transaction for 5 days
	editDate := tranDate + 5;
	// change the edit and storage tran to be 5 days later than receival
	foreach tran in cargo.allTransactions do
		if tran.dateTime.date &lt;&gt; today then
			continue;
		endif;
		tranTS.setDate(editDate);
		tranTS.setTime(tran.dateTime.time);
		
		beginTransaction;
		tran.setPropertyValue("dateTime", tranTS);
		commitTransaction;
	endforeach;
	self.reevalStorageTrans(cargo);

	singleGate := self.getGate(self.getProfileSetting(UT_Profile.P_SGATE).asString);
	
	self.deleteVehicle("UTMAT");
	vvr := self.gateOutContainer("UTMAT", "", "UTMATDRIVER", cargo.CM_Container, true, singleGate , null); 
	
	self.workVehicle(vvr);
	self.roadExit(vvr);		// creates the second storage transaction and invoice lines
	
	self.validateEscalatingCharges3c(cargo, 1);
	self.reevalStorageTrans(cargo);
	// the transaction re-evaluate should not have changed anything
	self.validateEscalatingCharges3c(cargo, 2);

	storeTrans := cargo.getLastTransOfType(TRANS_TYPE_STORAGE);
	create invoiceLines transient;
	storeTrans.allInvoiceLines.copy(invoiceLines);
	self.invoiceLineReevaluate(invoiceLines);
	// the  invoice line re-evaluate should not have changed anything
	self.validateEscalatingCharges3c(cargo, 3);
	
epilog
	self.resetDefaultTranMap();												// 17/04/2013 cnwmh5
	self.setTerminalConfig(InvoiceRoundLineTotal, roundTotalOpt);
	delete services;
	delete perDays;
	delete rangeStart;
	delete rangeEnd;
	delete costs;
	delete pxyDebtorRate;
	delete invoiceLines;
end;</source>
