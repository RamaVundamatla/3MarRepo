    <JadeMethod name="addNoDupsHaltExHandler" id="6b9757ea-f543-4e52-8f22-b388ae202548">
        <source>addNoDupsHaltExHandler(exObj : Exception) : Integer protected;
 // ### JIRA 36467 31OCT2025 NAVAB1 Written for STWR upgrade to 22.0.24 was taking 20-30 hours for PortSchema_22_0_24::populateCGOperators method.
constants
	ObjectAlreadyInCol = 1309;
	DuplicateKey = 1310;

vars
	errorCode : Integer;
		
begin
	errorCode := exObj.errorCode;
	
	// Is this one of the errors we want to handle...?	
	if errorCode = ObjectAlreadyInCol or errorCode = DuplicateKey then
		// ...Yes, so resume back to the method that armed us
		return Ex_Resume_Next;
	endif;

	// Otherwise an unexpected error, so pass back to the next handler
	return Ex_Pass_Back;
end;</source>
        <access>protected</access>
        <Parameter name="exObj" type="Exception"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addPrimaryTaskFieldDefaults" id="ac2dbda9-0de0-4c56-803c-1cd8342bbf03">
        <source>addPrimaryTaskFieldDefaults(_updController : CnEcReleaseController);

/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
11 October 2022	navcs2	Bug 54926: SNO - Vehicle RT Config apps in MTN version 20.0.21.08

*/


vars
	root 	 	: CM_Root;
	entTable 	: EntTableRowArray;
	entGroup	: EntTableGroup;
	entDef 		: EntTableDef;
	rtConfig	:  CM_RTVehicleConfig;
begin
	if self.hasScriptBeenRunAtAll(method.name, _updController) then
		return;
	endif;
	
	
	app.writeLog(method.qualifiedName &amp; " Adding default values to primary tasks", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Adding default values to primary tasks") ;	
	endif;
	
	
	// Get the right ent def
	root := app.getMyRoot();
	entDef :=  root.myEntTableDataRoot.allEntTableDefs[ETDef_MachineRTFields];
	entGroup := entDef.myEntTableGroup;
	
	beginTransaction;
	
	// Look through all instances of RTVehicleConfig and if it does not have them, add the correct fields to the top of the list
	// Added to the ent table rows array so that ID ends up at the top
	foreach rtConfig in CM_RTVehicleConfig.instances do
		if  rtConfig.myPrimaryTaskFields &lt;&gt; null then
			entTable := rtConfig.myPrimaryTaskFields.allEntTableRows;
			if not entTable.includes(entGroup.allEntTableRowsByName[ETRow_TargetLocation]) and 
			   not entTable.includes(entGroup.allEntTableRowsByName[ETRow_SourceLocation]) and 
			   not entTable.includes(entGroup.allEntTableRowsByName[ETRow_Info]) and 
			   not entTable.includes(entGroup.allEntTableRowsByName[ETRow_Id]) then
						
					entTable.insert(1,entGroup.allEntTableRowsByName[ETRow_TargetLocation]);
					entTable.insert(1,entGroup.allEntTableRowsByName[ETRow_SourceLocation]);
					entTable.insert(1,entGroup.allEntTableRowsByName[ETRow_Info]);
					entTable.insert(1, entGroup.allEntTableRowsByName[ETRow_Id]);
			endif;
		endif;
	endforeach;
	
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Adding default values to primary tasks", LogINFO);
	if _updController &lt;&gt; null then
		_updController.logEntry(" Adding default values to primary tasks") ;	
	endif;
	
	self.addScriptRun(method.name);
epilog

end;</source>
        <Parameter name="_updController" type="CnEcReleaseController"/>
    </JadeMethod>
    <JadeMethod name="addntlInventoryCalcTypes" id="2ebc63f4-5ae2-4a7b-b4fd-af0f0373a35c">
        <source>addntlInventoryCalcTypes(_controller : CnEcReleaseController);
/*****************************************************
Author		: jlika1 (Karen Alexander)
Date		: 27 October 2022
TFS#		: 54897
Function	:

*** Changes ***
Date			Name		TFS#		Description

****************************************************/

begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	app.writeLog(method.qualifiedName &amp; " Create new INVENTORY Calculation Types", LogINFO);

	beginTransaction;
	app.myRoot.createInvoiceCalcTypes();
	commitTransaction;
	
	app.writeLog(method.qualifiedName &amp; " Create new INVENTORY Calculation Types - Complete", LogINFO);
	self.addScriptRun(method.name);
end;</source>
