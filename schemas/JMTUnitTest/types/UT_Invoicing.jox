    <JadeMethod name="tranMapLoadFirstLast2" id="49d23d33-bc6f-4b12-8e6c-c5ce93e13163">
        <source>tranMapLoadFirstLast2();
// cnwjre1 load cargo transaction map with days since first discharge/last load calculation types, for a range of quantities, escalating
// the tran map has extra VOID entries to match the actual entries from the original customer setup
vars
	fileContent : String;
	fileName	: String;
	mapName		: String;
	bank		: CM_Bank;
	cargoMap	: CM_TranMap;
	
	calType 	: CM_CalculationType;
	invType : CM_InvoiceDesc;	
	invLineType : CM_InvoiceLineDesc;
	service	: CM_Service;
	services : CM_ServiceByNameDict;

begin
	// (re)create the invoice line types used here
	self.deleteInvoiceLineType("UTLineType20LL16ToMax", FORCED_ERASE);
	self.deleteInvoiceLineType("UTLineType40LL16ToMax", FORCED_ERASE);

	service := self.myBank.services["UT_ServiceFirstDischarge"];
	calType := app.myRoot.allCalculationTypesByCode["CCT108"];
	invType := self.getInvoiceType("UT_InvType");

	create services transient;
	services.add(service);
	invLineType := self.createInvoiceLineType("UTLineType20LL16ToMax", calType, invType, services, "SDT4");
	self.assertNotNullMsg(invLineType, "UTLineType20LL16ToMax not created");
	invLineType := self.createInvoiceLineType("UTLineType40LL16ToMax", calType, invType, services, "SDT4");
	self.assertNotNullMsg(invLineType, "UTLineType40LL16ToMax not created");

	fileName := "CargoStorage";
	mapName := "UT_Storage3";
	fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),VOID,' &amp; CrLf &amp; 
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Export,(Default),(Default),Storage,,(Default),CCT109 Days Since Last Load ›,(Default),UT_LineTypeLastLoad' &amp; CrLf &amp; 
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Import,(Default),(Default),Storage,,(Default),CCT108 Days Since First Discharge »,01 to 15,VOID' &amp; CrLf &amp; 
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Import,(Default),(Default),Storage,,(Default),CCT108 Days Since First Discharge »,01 to 15,VOID,,,X,,,,,,,' &amp; CrLf &amp; 
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Import,(Default),(Default),Storage,,(Default),CCT108 Days Since First Discharge »,16 to MAX,UTLineType20LL16ToMax' &amp; CrLf &amp; 
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Import,(Default),(Default),Storage,,(Default),CCT108 Days Since First Discharge »,16 to MAX,UTLineType40LL16ToMax,,,X,,,,,,,' &amp; CrLf;

	
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	//bank := app.myPassport.myTerminal.getConfig(DefCompany).CM_Bank;
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();	//17 Apr 2012	NDL	Par 29393
	cargoMap := bank.myCurrentTranMapCargo[mapName];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");

	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

epilog
	delete services;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tranMapLoadFirstLast3" id="0d086ee4-7cb7-40ad-b24f-76c89b33dc7e">
        <source>tranMapLoadFirstLast3();
// cnwjre1 load cargo transaction map with days since first discharge/last load calculation types, for a range of quantities, escalating
// the tran map has extra VOID entries to match the actual entries from the original customer setup
vars
	fileContent : String;
	fileName	: String;
	mapName		: String;
	bank		: CM_Bank;
	cargoMap	: CM_TranMap;
	
	calType 	: CM_CalculationType;
	invType : CM_InvoiceDesc;	
	invLineType : CM_InvoiceLineDesc;
	service	: CM_Service;
	services : CM_ServiceByNameDict;

begin
	// (re)create the invoice line types used here
	self.deleteInvoiceLineType("UTLineType20LL16ToMax", FORCED_ERASE);
	self.deleteInvoiceLineType("UTLineType40LL16ToMax", FORCED_ERASE);
	self.deleteInvoiceLineType("UTRecShip", FORCED_ERASE);
	self.deleteInvoiceType("UT_InvVoyType");

	service := self.myBank.services["UT_ServiceFirstDischarge"];
	calType := app.myRoot.allCalculationTypesByCode["CCT108"];
	invType := self.createInvoiceTypeFull(CM_InvoiceDesc.Accrue_Until_Manually_Closed,
											null,
											"UT_InvVoyType",
											CM_InvoiceDesc.Key_Voyage,
											InvoiceTypeGeneral,
											null,
											null,
											true,
											InvTypeTrigger_Release,
											null,
											null,
											0,
											"");

	create services transient;
	services.add(service);
	invLineType := self.createInvoiceLineType("UTLineType20LL16ToMax", calType, invType, services, "SDT4");
	self.assertNotNullMsg(invLineType, "UTLineType20LL16ToMax not created");
	invLineType := self.createInvoiceLineType("UTLineType40LL16ToMax", calType, invType, services, "SDT4");
	self.assertNotNullMsg(invLineType, "UTLineType40LL16ToMax not created");
	invLineType := self.createInvoiceLineType("UTRecShip", calType, invType, services, "SDT4");
	self.assertNotNullMsg(invLineType, "UTRecShip not created");

	fileName := "CargoStorage";
	mapName := "UT_Storage4";
	fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),(Default),(Default),(Default),(Default),,(Default),(Default) ›,(Default),VOID,' &amp; CrLf &amp; 
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Tranship,(Default),(Default),Received - Ship,,(Default),(Default) ›,(Default),UTRecShip' &amp; CrLf &amp;
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Export,(Default),(Default),Storage,,(Default),CCT109 Days Since Last Load ›,(Default),UT_LineTypeLastLoad' &amp; CrLf &amp; 
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Import,(Default),(Default),Storage,,(Default),CCT108 Days Since First Discharge »,01 to MAX,UTLineType20LL16ToMax' &amp; CrLf &amp; 
						'Cargo,'&amp;mapName&amp;',(Default),(Default),(Default),Import,(Default),(Default),Storage,,(Default),CCT108 Days Since First Discharge »,01 to MAX,UTLineType40LL16ToMax,,,X,,,,,,,' &amp; CrLf;

	
	self.transactionMapLoad(fileContent, fileName);
	self.assertNoTrxErrorsOrWarnings();
	
	bank := app.myPassport.myTerminal.getDefaultCompanyBank();
	cargoMap := bank.myCurrentTranMapCargo[mapName];
	self.assertNotNullMsg(cargoMap,"cargo map should not be null");

	app.myTrxUA.trxUpdateBankTMActive(cargoMap,app.myPassport);

epilog
	delete services;
end;
</source>
    </JadeMethod>
    <JadeMethod name="tranMapLoadFirstLastRange" id="01143fb9-dd99-4c65-888b-2f3ec460892d">
        <source>tranMapLoadFirstLastRange();
// cnwjre1 load cargo transaction map with days since first discharge/last load calculation types, for a range of quantities, escalating
vars
	fileContent : String;
	fileName	: String;
	mapName		: String;
	bank		: CM_Bank;
	cargoMap	: CM_TranMap;
	
	calType 	: CM_CalculationType;
	invType : CM_InvoiceDesc;	
	invLineType : CM_InvoiceLineDesc;
	service	: CM_Service;
	services : CM_ServiceByNameDict;

begin
	// (re)create the invoice line types used here
	self.deleteInvoiceLineType("UTLineTypeLL16To21", FORCED_ERASE);
	self.deleteInvoiceLineType("UTLineTypeLL22To28", FORCED_ERASE);
	self.deleteInvoiceLineType("UTLineTypeLL29To35", FORCED_ERASE);
	self.deleteInvoiceLineType("UTLineTypeLL36To42", FORCED_ERASE);
	self.deleteInvoiceLineType("UTLineTypeLL43To49", FORCED_ERASE);

	service := self.myBank.services["UT_ServiceFirstDischarge"];
	self.assertNotNullMsg(service, "Service UT_ServiceFirstDischarge not created");
	calType := app.myRoot.allCalculationTypesByCode["CCT108"];
	self.assertNotNullMsg(calType, "Calculation type CCT108 not created");
	invType := self.getInvoiceType("UT_InvType");
	self.assertNotNullMsg(invType, "Invoice Type UT_InvType not created");

	create services transient;
	services.add(service);
	invLineType := self.createInvoiceLineType("UTLineTypeLL16To21", calType, invType, services, "SDT4");
	self.assertNotNullMsg(invLineType, "UTLineTypeLL16To21 not created");
	invLineType := self.createInvoiceLineType("UTLineTypeLL22To28", calType, invType, services, "SDT4");
	self.assertNotNullMsg(invLineType, "UTLineTypeLL22To28 not created");
	invLineType := self.createInvoiceLineType("UTLineTypeLL29To35", calType, invType, services, "SDT4");
	self.assertNotNullMsg(invLineType, "UTLineTypeLL29To35 not created");
	invLineType := self.createInvoiceLineType("UTLineTypeLL36To42", calType, invType, services, "SDT4");
	self.assertNotNullMsg(invLineType, "UTLineTypeLL36To42 not created");
	invLineType := self.createInvoiceLineType("UTLineTypeLL43To49", calType, invType, services, "SDT4");
	self.assertNotNullMsg(invLineType, "UTLineTypeLL43To49 not created");

	fileName := "CargoStorage";
	mapName := "UT_Storage3";
	fileContent := 'TranMap Type,TranMap Name,CargoType,Cargo Subtype Group,Cargo Subtype,IMEX,Contents Status,Commodity,Transaction,MoveType,Debtor,Quantity Type,Quantity Range,Invoice Line,Over Dimsn?,Trans Ship?,Is 40?,Is Reefer?,Req Temp?,RORO?,Is 45?,Is 30?,Is 53?,Is Child?' &amp; CrLf &amp;
