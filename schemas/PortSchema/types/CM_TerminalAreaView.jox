    <JadeMethod name="copyTAView" id="c47b2fc0-0c76-4726-ba35-74763a553f82">
        <source>copyTAView(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 November 2010	cnwer1	Initial creation

*/

vars
	copyOfSelf : CM_TerminalAreaView;
	copyAreaViewPosition,areaViewPosition	: CM_TerminalAreaViewPosition;
begin
	//can not do a simple pxyCreateUpdateProxy because we do not want the tav copied from to be a proxy and in the proxy managers collection
	copyOfSelf:= self.copySelf(true);

	copyOfSelf.myTerminal	:=	self.myTerminal;

	//  Include proxies for position objects.
	
	foreach areaViewPosition in self.allTerminalAreaViewPositions do
		copyAreaViewPosition := areaViewPosition.copySelf(true);
		copyAreaViewPosition.setTerminalAreaView(copyOfSelf);
		copyAreaViewPosition.setTerminalArea(areaViewPosition.myTerminalArea);
	endforeach;

	
	return copyOfSelf;

epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
