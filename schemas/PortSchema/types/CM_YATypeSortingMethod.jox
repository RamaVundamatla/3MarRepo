    <JadeMethod name="getObjects" id="4b0462c0-c726-45bb-b939-1e022f06bb17">
        <source>getObjects(objects: ObjectLongNameDict input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 June 2023	navpw1	Initial creation TFS: 58429 (58517)

*/

vars
	sortingMethods	: CM_SortingMethodByCodeDict;
	sortingMethod	: CM_SortingMethod;
	iter			: Iterator;
	
begin
	sortingMethods := app.myRoot.allSortingMethods;
	
	if sortingMethods.size &gt; 15 then
		iter := sortingMethods.createIterator;
		while iter.next(sortingMethod) do
			objects[sortingMethod.getYAIdentifier] := sortingMethod;
		endwhile;
		
	else
		foreach sortingMethod in sortingMethods do
			objects[sortingMethod.getYAIdentifier] := sortingMethod;
		endforeach;
		
	endif;
	
epilog
	delete iter;
	
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
