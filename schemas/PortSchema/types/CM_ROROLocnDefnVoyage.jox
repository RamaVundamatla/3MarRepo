    <JadeMethod name="hasTIs" id="c1ceaa1a-fb47-411d-8f3a-8bdc9f674ff2">
        <source>hasTIs(_mode : Integer) : Boolean;
/*
Purpose:			
Date		Who		Reason
21 July 2011	cnwab1	Initial creation
*/

vars

	slotDefn : CM_ROROSlotDefn;
	slotLC : CM_ROROSlotController;
	obj : Object;
	has40s : Boolean;
	aTI : CM_TrackedItem;
begin
	
	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
		slotLC := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
		
		if slotLC &lt;&gt; null then
			if _mode = REAL_MODE then
				if not slotLC.allTrackedItems.isEmpty() then
					return true;
				endif;
			// PAR 28919
			elseif _mode = PLANNING_MODE then
				return slotLC.hasTIsOfMode(PLANNING_MODE);
			elseif _mode = QUEUE_MODE then
				return slotLC.hasTIsOfMode(QUEUE_MODE);
			endif;
		endif;
	endforeach;

	return false;
epilog

end;</source>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasTIs40" id="c3b866da-afa6-4454-bd06-43480e2757ea">
        <source>hasTIs40(_mode : Integer; _fwdSlot : Boolean) : Boolean;
/*
Purpose:			
Date				Who			Reason
JANUARY 2012		CNWAB1		Initial creation
*/

vars
	slotDefn 		: CM_ROROSlotDefn;
	slotController 	: CM_ROROSlotController;
	req				: CM_RORORequest;
	tmpTI			: CM_TrackedItem;
	array : CM_TIArray;
begin
	create array transient;

	foreach slotDefn in self.allROROSlotDefnByOrdinal do
		slotController := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
		if slotController &lt;&gt; null then
			slotController.getTIs(array, _mode, true);
			foreach tmpTI in array discreteLock do
// PAR 30152				if tmpTI.isForty() then
				if not tmpTI.isTwenty() then
					if _mode = REAL_MODE then
						if _fwdSlot  = (tmpTI.myPrimaryActualLocation = slotController) then
							return true;
						endif;
					elseif _mode = PLANNING_MODE then
						if _fwdSlot  = (tmpTI.myPrimaryPlannedLocation = slotController) then
							return true;
						endif;
					elseif _mode = QUEUE_MODE then
						if _fwdSlot  = (tmpTI.myPrimaryQueuedLocation = slotController) then
							return true;
						endif;
					endif;
				endif;
			endforeach;
		endif;
	endforeach;

	return false;
epilog
	delete array;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_fwdSlot" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasTIs40Loaded" id="aebd5746-cc43-4f08-abc4-7da9f3a9bd07">
        <source>hasTIs40Loaded(_mode : Integer; _fwdSlot : Boolean; _fortysOnly : Boolean) : Boolean;
/*
Purpose:			PAR 31118
Date				Who			Reason
FEBRUARY 2013		CNWAB1		Initial creation
*/

vars
	slotDefn 		: CM_ROROSlotDefn;
	slotController 	: CM_ROROSlotController;
	req				: CM_RORORequest;
	tmpTI			: CM_TrackedItem;
	array : CM_TIArray;
begin
	create array transient;

	foreach slotDefn in self.allROROSlotDefnByOrdinal do
		slotController := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
		if slotController &lt;&gt; null then
			slotController.getTIs(array, _mode, true);
			foreach tmpTI in array discreteLock do
				if (_fortysOnly and not tmpTI.isTwenty) or not _fortysOnly then
					
					if not tmpTI.hasBeenLoadedToShip() then
						continue;
					endif;
					
					
					if _mode = REAL_MODE then
						if _fwdSlot  = (tmpTI.myPrimaryActualLocation = slotController) then
							return true;
						endif;
					elseif _mode = PLANNING_MODE then
						if _fwdSlot  = (tmpTI.myPrimaryPlannedLocation = slotController) then
							return true;
						endif;
					elseif _mode = QUEUE_MODE then
						if _fwdSlot  = (tmpTI.myPrimaryQueuedLocation = slotController) then
							return true;
						endif;
					endif;
				endif;
			endforeach;
		endif;
	endforeach;

	return false;
epilog
	delete array;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_fwdSlot" type="Boolean"/>
        <Parameter name="_fortysOnly" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasTIsAllColourCoded" id="9dbffaee-6ab8-43f8-9b35-d26a15129af0">
        <source>hasTIsAllColourCoded(_mode : Integer; _fortysOnly : Boolean; _isLoad : Boolean) : Boolean;
/*
Purpose:			PAR 31347
Date				Who			Reason
MARCH 2013		CNWAB1		Initial creation
*/

vars
	slotDefn 		: CM_ROROSlotDefn;
	slotController 	: CM_ROROSlotController;
	req				: CM_RORORequest;
	tmpTI			: CM_TrackedItem;
	array : CM_TIArray;
begin
	create array transient;

	foreach slotDefn in self.allROROSlotDefnByOrdinal do
		slotController := slotDefn.CM_ROROSlotDefnVoyage.mySlotController;
		if slotController &lt;&gt; null then
			slotController.getTIs(array, _mode, true);
			if array.isEmpty() then
				continue;
			endif;
			if _isLoad then
				if slotController.myRORORequestLoad = null then
					return false;
				endif;
			else
				if slotController.myRORORequestDischarge = null then
					return false;
				endif;
			endif;
		endif;
	endforeach;

	return true;
epilog
	delete array;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_fortysOnly" type="Boolean"/>
        <Parameter name="_isLoad" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasUnactionedWLE" id="39bf6c43-2a79-4f70-b18a-5fb3fd117bb5">
        <source>hasUnactionedWLE(_isLoad : Boolean) : Boolean;
/*
Purpose:			
Date				Who			Reason
AUGUST 2012		CNWAB1		Initial creation
*/

vars
	slotDefn : CM_ROROSlotDefn;
	req : CM_RORORequest;
begin
	foreach slotDefn in self.allROROSlotDefnByOrdinal discreteLock do
		if _isLoad then
			req := slotDefn.CM_ROROSlotDefnVoyage.mySlotController.myRORORequestLoad;
		else
			req := slotDefn.CM_ROROSlotDefnVoyage.mySlotController.myRORORequestDischarge;
		endif;
		
		if req &lt;&gt; null then
			if req.getAttrIsBackend() then  // 40 back end
				req := req.getFwdSlotReq().CM_RORORequest;
			endif;
			
			if not req.isComplete then
				return true;
			endif;
		endif;
	endforeach;
	
	return false;
epilog

end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
