    <JadeMethod name="isDirectToVoyage" id="0b1881d8-0a5c-4ad7-9fb0-34880d7ec764">
        <source>isDirectToVoyage() : Boolean;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 03/10/2019	jlgdap1		Initial creation TFS 46870 JMT Cargo Request Direct Delivery Gate to Vessel
//
vars
	fm : CM_FutureMove;
	pfm : CM_FutureMovePlanned;

begin
	if self.myTrackedItem = null then
		return false;
	endif;
	if self.myTrackedItem.allPlannedFutureMoves.isEmpty then
		return false;
	endif;
	
	fm := self.myTrackedItem.allPlannedFutureMoves.first;
	if fm.isKindOf(CM_FutureMovePlanned) then
		pfm := fm.CM_FutureMovePlanned;
	else
		return false;
	endif;
	if pfm.myWorkListEntry = null then
		return false;
	endif;
	
	if self.isKindOf(CM_YardWLE) 
	and pfm.myWorkListEntry.isKindOf(CM_VoyageWLE)  
	and pfm.myWorkListEntry.job.isVoyageHoldJob
	and not self.myTrackedItem.allJobsShipRelease.isEmpty then
		return true;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
