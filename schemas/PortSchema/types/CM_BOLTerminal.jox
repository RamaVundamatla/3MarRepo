    <JadeMethod name="getAverageSED" id="2dc19e42-8973-46d1-a7d8-8878578772a2">
        <source>getAverageSED() : Real;
// -----------------------------------------------------------------------------
// Created:		14 May 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	tmpMean,
	sedTotal 	: Real;
	log 		: CM_Log;
	iter 		: Iterator;
	cnt			: Integer;
	
begin

	iter := self.allTrackedItems.createIterator();
	
	while iter.next(log) do
		tmpMean := log.sedMean;
		if tmpMean &lt;&gt; NULL_UNSCALED_LOG_SED then
			cnt := cnt + 1;
			sedTotal := sedTotal + tmpMean;
		endif;
	endwhile;
	if cnt &gt; 0 then
		return sedTotal / cnt;
	endif;
	
	return 0;
epilog
	delete iter;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getDataForDef" id="2871dfec-0072-44b7-acab-11886fa2e29f">
        <source>getDataForDef(_entTableDef: EntTableDef; _headings: StringArray input; _data: HugeStringArray input; _terminal : CM_Terminal);
//--------------------------------------------------------------
//Created: 04 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	entTableRow 	: EntTableRow;
	ti 				: CM_TrackedItem;
	bolType			: CM_BOLType;
	ctTerminal		: CM_TerminologyHdr;
begin

	if _entTableDef.name = ETDef_LogData then
		bolType := app.myRoot.allBOLTypes[self.myBOL.bolType];
		//ctTerminal := bolType.allTerminologyCTTerminalHdrs[_terminal];
		foreach entTableRow in _entTableDef.allEntTableRows do
			foreach ti in self.allTrackedItems do
				ti.getDataForAttribute(entTableRow.name, entTableRow.getHeading(bolType, null, app.myCurrentLocale), _headings, _data);
			endforeach;
		endforeach;
		
	else
		inheritMethod(_entTableDef, _headings, _data, _terminal);
	endif;

end;</source>
        <Parameter name="_entTableDef" type="EntTableDef"/>
        <Parameter name="_headings" type="StringArray" usage="input"/>
        <Parameter name="_data" type="HugeStringArray" usage="input"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="getTotalTIQty" id="ee94bb0c-007f-4666-8e85-7439a5870b30">
        <source>getTotalTIQty() : Integer;
//--------------------------------------------------
// Created:	24 March 2006 By: cnwgd1
//--------------------------------------------------
vars
	total : Integer;
	ti : CM_TrackedItem;
begin

	foreach ti in self.allTrackedItems do
		total := total + ti.quantity;
	endforeach;
	
	return total;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalTIVolume" id="62222ed1-2d52-47cb-a82f-d0bd499634ec">
        <source>getTotalTIVolume() :Real;
// ---------------------------------------------------------------------------
// Created:     14 Aug 2002 by cnwsb1
// ---------------------------------------------------------------------------
vars
	totalVolume	: Real;
	ti			: CM_TrackedItem;
	
begin
	foreach ti in self.allTrackedItems do

		totalVolume := totalVolume + ti.getMyTotalVolume;
	endforeach;
	
	return totalVolume;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getTotalTIWeight" id="592fc5bd-3dc9-4c63-b876-f6bd0204e9fe">
        <source>getTotalTIWeight() :Real;
// ---------------------------------------------------------------------------
// Created:     14 Aug 2002 by cnwsb1
// ---------------------------------------------------------------------------
vars
	totalWeight	: Real;
	ti			: CM_TrackedItem;
	
begin
	foreach ti in self.allTrackedItems do
		//totalWeight := totalWeight + ti.weight;				//-cnwml2 MSL CCMS 1017
		totalWeight := totalWeight + ti.totalWeight;			//+cnwml2 MSL CCMS 1017
	endforeach;
	
	return totalWeight;
end;</source>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getTrackedItemsNumbers" id="1f9b2f81-fb75-4d36-acd0-b57ad1a8a0ee">
        <source>getTrackedItemsNumbers(): String;
// -----------------------------------------------------------------------------
// Created:		02 July 2002 by cnwka1
//
// Purpose:		Used by the JRW to show the first and last Tracked item number on the docket.
//
// Parameters:	None
//
// Returns:		a string 
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	if self.allTrackedItems.size = 0 then
		return null;
	endif;
	return self.allTrackedItems.first.id &amp; ' - ' &amp; self.allTrackedItems.last.id;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="numTIs" id="d4a54d16-e2fc-4a4e-aeb5-9c1eb1ddc706">
        <methodInvocation>mapping</methodInvocation>
        <source>numTIs(set: Boolean; _value: Integer io) mapping;
// ---------------------------------------------------------------------------
// Created:     07 May 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	_value := self.allTrackedItems.size;

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
