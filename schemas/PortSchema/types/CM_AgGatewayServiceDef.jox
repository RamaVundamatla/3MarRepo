    <JadeMethod name="getOrderRespEndPointStr" id="3318afb3-4e41-4742-b769-e2e23c64c308">
        <source>getOrderRespEndPointStr() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Sep 2025 navnk30 JIRA 35707: 4 - YARA | Create a new web service definition to use to send out AG Gateway messages

*/

vars
	orderRespEndPoint	: CM_Endpoint;
begin
	orderRespEndPoint := self.allEndpoints[ETRow_OrderResponseEndpoint];
	if orderRespEndPoint = null then
		return self.baseEndpoint;
	else
		return self.baseEndpoint &amp; orderRespEndPoint.endpoint;
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
