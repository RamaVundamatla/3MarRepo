epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setFromLoadCC" id="e381d1f0-fd7f-4372-b1e5-7fff8cd9356b">
        <updating/>
        <source>setFromLoadCC( _theLoadCC : CMIF_LoadColorCode; _imexStatus : Integer; _moveType : Integer; _weightRange : CM_WeightRange) updating;
// ---------------------------------------------------------------------------
// Created:     08 January 2010 by cnwab1
//
// This is used to create DISCHARGE  allocation colour coding based on CM_SlotRequest::setFromTI
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 03/08/2010	cnwdad1		PAR #24045. Added Weight.
// ---------------------------------------------------------------------------
// 21 mar 2012	cnwrs1	Par 29308
//26 mar 2012	cnwrs1	Par 29266 - match cargo type when no isotype supplied
//05 Apr 2012	cnwrs1		Par 29391 - EDI RORO Stowage Advice hazard codes
//20 Jan 2015   cnwma1  Par 35379 EDI Movins - Empty, Commodity Code &amp; Weight   
vars
	criteria : CM_YACriteria;
	port : CM_Port;
	comm : CM_Commodity;
	commGrp : CM_CommodityGroup;
	aPortCode : String;
	isoSet : Boolean;
	usefulDesc : String;
	objSet : ObjectSet;
	imex : CM_IMEXStatus;
	isoType : CM_ISOType;
	weightRangeObj : CM_WeightRange;
	cargoType : CM_CargoType;
begin
	if _theLoadCC = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_theLoadCC', null, null);
		return;
	endif;
	
	create objSet transient;
	self.myTerminal := app.myPassport.myTerminal;
	// MANDATORY IMEX STATUS = IMPORT
	
	imex := app.myRoot.allImexStatuses[_imexStatus];
	objSet.clear;
	objSet.add(imex);
	criteria := self.createCriteria(objSet, YACriteriaType_ImexStatus);
	if criteria &lt;&gt; null then
		criteria.setYardAllocation(self);
	endif;
	
	// ### CARGOTYPE
	objSet.clear;
	cargoType := _theLoadCC.myCargoType;
	if cargoType = null then
		cargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	endif;
	objSet.add(cargoType);
	criteria := self.createCriteria(objSet, YACriteriaType_CargoType);
	if criteria &lt;&gt; null then
		criteria.setYardAllocation(self);
	endif;
	
	// ### DISCHARGE PORT
	if _imexStatus = TI_IMEX_STATUS_EXPORT or _moveType = DLR_MOVETYPE or _moveType = SOB_MOVETYPE then
		if _theLoadCC.myDischargePort &lt;&gt; null then // PAR 23426
			aPortCode := _theLoadCC.myDischargePort.code.trimBlanks;
		endif;
	else
		aPortCode := self.myTerminal.getConfig(PortDestCode).String.trimBlanks;
	endif;
	port := app.myRoot.allPorts[aPortCode];
	if port &lt;&gt; null then
		objSet.clear;
		objSet.add(port);
		criteria := self.createCriteria(objSet, YACriteriaType_DischargePort);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
	endif;
	
	// ### COMMODITY GROUP
	commGrp := _theLoadCC.myCommodityGroup;
	if commGrp &lt;&gt; null then
		objSet.clear;
		objSet.add(commGrp);
		criteria := self.createCriteria(objSet, YACriteriaType_CommodityGroup);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
	endif;
	if _theLoadCC.isEmpty then
		if commGrp &lt;&gt; null then
			comm := commGrp.getEmptyCommodity();
			if comm &lt;&gt; null and comm.isEmpty then
				objSet.clear;
				objSet.add(comm);
				criteria := self.createCriteria(objSet, YACriteriaType_Commodity);
				if criteria &lt;&gt; null then
					criteria.setYardAllocation(self);
				endif;
				criteria := self.createCriteria(true, YACriteriaType_IsEmpty); //20/1/2015 cnwma1 PAR #35379
				if criteria &lt;&gt; null then
					criteria.setYardAllocation(self);
				endif;
			endif;
		endif;
	endif;
	
	// PAR 28479
	if _theLoadCC.myISOType &lt;&gt; null then
		isoType := _theLoadCC.myISOType;
		isoSet := true;
	else
		foreach isoType in app.myRoot.allISOTypes discreteLock do
			if isoType.myCargoType = cargoType then		//26 mar 2012	cnwrs1	Par 29266 - match cargo type when no isotype supplied
				if isoType.is8ft6High() = _theLoadCC.highCube
				and isoType.isHalfHeight() = _theLoadCC.halfHeight
				and isoType.isPowered = _theLoadCC.requiresPower then
				
					if isoType.is53ftLong() = _theLoadCC.isFiftyThree then
						isoSet := true;
					elseif isoType.is40ftLong = _theLoadCC.isForty then
						isoSet := true;
					elseif isoType.is45ftLong = _theLoadCC.isFortyFive then
						isoSet := true;
					elseif isoType.is30ftLong = _theLoadCC.isThirty then
						isoSet := true;
					else // is20
						isoSet := true;
					endif;
				endif;
				if isoSet then
					break;
				endif;
			endif;
		endforeach;
	endif;
	
	
	if isoSet then
		objSet.clear;
		objSet.add(isoType);
		criteria := self.createCriteria(objSet, YACriteriaType_ISO);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
		
		if isoType &lt;&gt; null then
			if isoType.myISOTypeGroup &lt;&gt; null then
				objSet.clear;
				objSet.add(isoType.myISOTypeGroup);
				criteria := self.createCriteria(objSet, YACriteriaType_ISOGroup);
				if criteria &lt;&gt; null then
					criteria.setYardAllocation(self);
				endif;
			
			endif;
		endif;
	endif;
	
// cnwdad1 03/08/2010 - PAR #24045.
	if _theLoadCC.weight &gt; 0 then
		objSet.clear();
		weightRangeObj	:=	_weightRange; //_slotReq.getWeightRangeFromWeight(0);
		
		if weightRangeObj &lt;&gt; null then		// A weight range may not have been set up for this slot's weight.
			objSet.add(weightRangeObj);
			criteria := self.createCriteria(objSet, YACriteriaType_Weight);
			
			if criteria &lt;&gt; null then
				criteria.setYardAllocation(self);
			endif;
		endif;
	endif;
	
	if _theLoadCC.overDimension then
		criteria := self.createCriteria(true, YACriteriaType_IsOverDimension);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
	
	endif;
	if _theLoadCC.isHazardous then
		criteria := self.createCriteria(true, YACriteriaType_IsHazardous);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
		criteria := self.createCriteria(_theLoadCC.hazardCodes, YACriteriaType_Hazardous);	//05 Apr 2012	cnwrs1		Par 29391 - EDI RORO Stowage Advice hazard codes
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
	endif;
	
	if _theLoadCC.requiresPower then
		criteria := self.createCriteria(true, YACriteriaType_RequiresPower);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
	endif;

	if _theLoadCC.waterCooled then
		criteria := self.createCriteria(true, YACriteriaType_WaterCooled);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
	
	endif;
	
	if _theLoadCC.isForty then
		criteria := self.createCriteria(true, YACriteriaType_IsForty);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
	
	endif;
	
	if _theLoadCC.isThirty then
		criteria := self.createCriteria(true, YACriteriaType_IsThirty);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;

	endif;
	
	if _theLoadCC.isFortyFive then
		criteria := self.createCriteria(true, YACriteriaType_IsFortyFive);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;

	endif;
	
	if _theLoadCC.isFiftyThree then
		criteria := self.createCriteria(true, YACriteriaType_IsFiftyThree);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;

	endif;
epilog
	delete objSet;
end;</source>
        <Parameter name="_theLoadCC" type="CMIF_LoadColorCode"/>
        <Parameter name="_imexStatus" type="Integer"/>
        <Parameter name="_moveType" type="Integer"/>
        <Parameter name="_weightRange" type="CM_WeightRange"/>
    </JadeMethod>
    <JadeMethod name="setFromTI" id="294fdee3-b426-4de8-9b96-18207ca7a8a4">
        <updating/>
        <source>setFromTI(_theTI : CM_TrackedItem; _imexStatus : Integer; _isDLRSOB : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     08 January 2010 by cnwab1
//
// This is used to create DISCHARGE  allocation colour coding based on CM_SlotRequest::setFromTI
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 02/10/2017		jlgdap1			TFS 7212 SNO Correct Tranship Discharge Port colour coding
// ---------------------------------------------------------------------------

vars
	criteria : CM_YACriteria;
	port : CM_Port;
	comm : CM_Commodity;
	commGrp : CM_CommodityGroup;
	aPortCode : String;
	isoSet : Boolean;
	usefulDesc : String;
	objSet : ObjectSet;
	imex : CM_IMEXStatus;
	specialSt : CM_SpecialStow;
	weightRn : CM_WeightRange;
	isoGrp : CM_ISOTypeGroup;
	isoType : CM_ISOType;
begin
	if _theTI = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'theTI', null, null);
		return;
	endif;
	
	create objSet transient;
	self.myTerminal := _theTI.myTerminal;
	// MANDATORY IMEX STATUS = IMPORT
	
	imex := app.myRoot.allImexStatuses[_imexStatus];
	objSet.clear;
	objSet.add(imex);
	criteria := self.createCriteria(objSet, YACriteriaType_ImexStatus);
	if criteria &lt;&gt; null then
		criteria.setYardAllocation(self);
	endif;
	
	// ### CARGOTYPE
	objSet.clear;
	if _theTI.myCargoType = null then
		objSet.add(app.myRoot.allCargoTypesById[TI_CargoType_Container]);
	else
		objSet.add(_theTI.myCargoType);
	endif;
	criteria := self.createCriteria(objSet, YACriteriaType_CargoType);
	if criteria &lt;&gt; null then
		criteria.setYardAllocation(self);
	endif;
	
	// ### DISCHARGE PORT
// PAR 27749	if _imexStatus = TI_IMEX_STATUS_EXPORT or _slotReq.moveType = DLR_MOVETYPE or _slotReq.moveType = SOB_MOVETYPE then
	if _imexStatus = TI_IMEX_STATUS_EXPORT or _isDLRSOB then
		aPortCode := _theTI.dischargePort.trimBlanks;
	else
		aPortCode := self.myTerminal.getConfig(PortDestCode).String.trimBlanks;
	endif;
	port := app.myRoot.allPorts[aPortCode];
	if port &lt;&gt; null then
		objSet.clear;
		objSet.add(port);
		criteria := self.createCriteria(objSet, YACriteriaType_DischargePort);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
	endif;
	
	// PAR 23906
	// ### ISO GROUP
	isoGrp := _theTI.getISOTypeGroup();
	if isoGrp &lt;&gt; null then
		objSet.clear;
		objSet.add(isoGrp);
		criteria := self.createCriteria(objSet, YACriteriaType_ISOGroup);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
	
	endif;

	// PAR 32158
	// ### ISO TYPE
	isoType := _theTI.getISOTypeObject(); 
	if isoType &lt;&gt; null  and not isoSet then
		objSet.clear;
		objSet.add(isoType);
		criteria := self.createCriteria(objSet, YACriteriaType_ISO);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
			isoSet := true;
		endif;
	
	endif;
	
	// ### COMMODITY GROUP
	comm := app.myRoot.allCommodities[_theTI.commodity.trimBlanks];
	if comm &lt;&gt; null then
		commGrp := comm.myCommodityGroup;
	endif;
	if commGrp = null then
		commGrp := _theTI.myCommodityGroup;
	endif;
	if commGrp &lt;&gt; null then
		objSet.clear;
		objSet.add(commGrp);
		criteria := self.createCriteria(objSet, YACriteriaType_CommodityGroup);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
	endif;

	if _theTI.isAttributeTrue(TI_Attrib_IsEmpty) then
		if comm &lt;&gt; null then
			if comm.isEmpty then
				objSet.clear;
				objSet.add(comm);
				criteria := self.createCriteria(objSet, YACriteriaType_Commodity);
				if criteria &lt;&gt; null then
					criteria.setYardAllocation(self);
				endif;
			
			endif;
		endif;
	endif;
	
	if _theTI.isAttributeTrue(TI_Attrib_IsHiCubed) and not isoSet then
		objSet.clear;
		objSet.add(_theTI.getISOTypeObject());
		criteria := self.createCriteria(objSet, YACriteriaType_ISO);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
			isoSet := true;
		endif;
	
	endif;
	
	if _theTI.isOverDimensions then
		criteria := self.createCriteria(true, YACriteriaType_IsOverDimension);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
	
	endif;
	
	if _theTI.isHazardous then
		// PAR 27749. Noticed that we only use IsHazardous for auto discharge CC. Added this to use Hazardous if voyage is not using IsHazardous
		//if self.myVoyage.isUsingCriteriaType(YACriteriaType_IsHazardous) then
		if _theTI.myVoyage.isUsingCriteriaType(YACriteriaType_IsHazardous) then	//19 Jan 2012	NDL	Par 29014
			criteria := self.createCriteria(true, YACriteriaType_IsHazardous);
		else
			criteria := self.createCriteria(true, YACriteriaType_Hazardous);
		endif;
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
	
	endif;
	
	if _theTI.isAttributeTrue(TI_Attrib_IsHalfHeight) and not isoSet then
		objSet.clear;
		objSet.add(_theTI.getISOTypeObject());
		criteria := self.createCriteria(objSet, YACriteriaType_ISO);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
			isoSet := true;
		endif;
	endif;
	
	if _theTI.isAttributeTrue(TI_Attrib_RequiresPower) then
		criteria := self.createCriteria(true, YACriteriaType_RequiresPower);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
	
	endif;
	
	if _theTI.isAttributeTrue(TI_Attrib_IsWaterCooled) then
		criteria := self.createCriteria(true, YACriteriaType_WaterCooled);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
	
	endif;
	
	if _theTI.isAttributeTrue(TI_Attrib_IsForty) then
		criteria := self.createCriteria(true, YACriteriaType_IsForty);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
	
	endif;
	
	if _theTI.isAttributeTrue(TI_Attrib_IsThirty) then
		criteria := self.createCriteria(true, YACriteriaType_IsThirty);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;

	endif;
	
	if _theTI.isAttributeTrue(TI_Attrib_IsFortyFive) then
		criteria := self.createCriteria(true, YACriteriaType_IsFortyFive);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;

	endif;
	
	if _theTI.isAttributeTrue(TI_Attrib_IsFiftyThree) then
		criteria := self.createCriteria(true, YACriteriaType_IsFiftyThree);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;

	endif;
	// ### SPECIAL STOW
	if _theTI.specialStow &lt;&gt; null then
		specialSt := app.myRoot.allSpecialStows[_theTI.specialStow];
		if specialSt &lt;&gt; null then
			objSet.clear;
			objSet.add(specialSt);
			criteria := self.createCriteria(objSet, YACriteriaType_SpecialStow);
			if criteria &lt;&gt; null then
				criteria.setYardAllocation(self);
			endif;
		endif;
	endif;
	
	// ### WEIGHT
//		weightRn := app.myRoot.getColourFromWeightRange(_theTI.totalWeight);
	// ### BOOKING
	// ### DESTINATION PORT


	// ### CARGO SUBTYPE
	if _theTI.myProduct &lt;&gt; null then
		objSet.clear;
		objSet.add(_theTI.myProduct );
		criteria := self.createCriteria(objSet, YACriteriaType_Product);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
	endif;
	
	// ### TRANS SHIP TO PORT
	if _theTI.isTranshipItem then																// TFS 7212
		criteria := self.createCriteria(true, YACriteriaType_IsTransShip);						// TFS 7212
		if criteria &lt;&gt; null then																// TFS 7212
			criteria.setYardAllocation(self);													// TFS 7212
		endif;																					// TFS 7212
		
		if _theTI.myTranshipToPort &lt;&gt; null then
			objSet.clear;
			objSet.add(_theTI.myTranshipToPort);
			criteria := self.createCriteria(objSet, YACriteriaType_TranshipToPort);
			if criteria &lt;&gt; null then
				criteria.setYardAllocation(self);
			endif;
		endif;
		if _theTI.myTranshipDetail &lt;&gt; null then													// TFS 7212
			port := _theTI.myTranshipDetail.myDischargePort;									// TFS 7212
			if port &lt;&gt; null then																// TFS 7212
				objSet.clear;																	// TFS 7212
				objSet.add(port);																// TFS 7212
				criteria := self.createCriteria(objSet, YACriteriaType_TranshipDischPt);		// TFS 7212
				if criteria &lt;&gt; null then														// TFS 7212
					criteria.setYardAllocation(self);											// TFS 7212
				endif;																			// TFS 7212
			endif;																				// TFS 7212
		endif;																					// TFS 7212
	endif;
	
	
epilog
	delete objSet;
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_imexStatus" type="Integer"/>
        <Parameter name="_isDLRSOB" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setFromTIForRORO" id="1c858b68-a1e9-4a3a-85e3-9b55673abb42">
        <updating/>
        <source>setFromTIForRORO(_slotReq : CM_RORORequest; _theTI : CM_TrackedItem; _imexStatus : Integer) updating;
/*
Purpose:			
Date				Who			Reason
JUNE 2011		CNWAB1		Initial creation
*/

vars
	criteria : CM_YACriteria;
	port : CM_Port;
	comm : CM_Commodity;
	commGrp : CM_CommodityGroup;
	aPortCode : String;
	isoSet : Boolean;
	usefulDesc : String;
	objSet : ObjectSet;
	imex : CM_IMEXStatus;
	specialSt : CM_SpecialStow;
	weightRn : CM_WeightRange;
	isoGrp : CM_ISOTypeGroup;
	isoType : CM_ISOType;
begin
	if _theTI = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'theTI', null, null);
		return;
	endif;
	
	create objSet transient;
	self.myTerminal := _theTI.myTerminal;
	// MANDATORY IMEX STATUS = IMPORT
	
	imex := app.myRoot.allImexStatuses[_imexStatus];
	objSet.clear;
	objSet.add(imex);
	criteria := self.createCriteria(objSet, YACriteriaType_ImexStatus);
	if criteria &lt;&gt; null then
		criteria.setYardAllocation(self);
	endif;
	
	// ### CARGOTYPE
	objSet.clear;
	if _theTI.myCargoType = null then
		objSet.add(app.myRoot.allCargoTypesById[TI_CargoType_Container]);
	else
		objSet.add(_theTI.myCargoType);
	endif;
	criteria := self.createCriteria(objSet, YACriteriaType_CargoType);
	if criteria &lt;&gt; null then
		criteria.setYardAllocation(self);
	endif;
	
	// ### DISCHARGE PORT
	if _imexStatus = TI_IMEX_STATUS_EXPORT or _slotReq.moveType = DLR_MOVETYPE or _slotReq.moveType = SOB_MOVETYPE then
		aPortCode := _theTI.dischargePort.trimBlanks;
	else
		aPortCode := self.myTerminal.getConfig(PortDestCode).String.trimBlanks;
	endif;
	port := app.myRoot.allPorts[aPortCode];
	if port &lt;&gt; null then
		objSet.clear;
		objSet.add(port);
		criteria := self.createCriteria(objSet, YACriteriaType_DischargePort);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
	endif;
	
	// PAR 23906
	// ### ISO GROUP
	isoGrp := _theTI.getISOTypeGroup();
	if isoGrp &lt;&gt; null then
		objSet.clear;
		objSet.add(isoGrp);
		criteria := self.createCriteria(objSet, YACriteriaType_ISOGroup);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
	
	endif;
	
	// PAR 32158
	// ### ISO TYPE
	isoType := _theTI.getISOTypeObject(); 
	if isoType &lt;&gt; null  and not isoSet then
		objSet.clear;
		objSet.add(isoType);
		criteria := self.createCriteria(objSet, YACriteriaType_ISO);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
			isoSet := true;
		endif;
	
	endif;
	
	
	// ### COMMODITY GROUP
	comm := app.myRoot.allCommodities[_theTI.commodity.trimBlanks];
	if comm &lt;&gt; null then
		commGrp := comm.myCommodityGroup;
	endif;
	if commGrp = null then
		commGrp := _theTI.myCommodityGroup;
	endif;
	if commGrp &lt;&gt; null then
		objSet.clear;
		objSet.add(commGrp);
		criteria := self.createCriteria(objSet, YACriteriaType_CommodityGroup);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
	endif;

	if _theTI.isAttributeTrue(TI_Attrib_IsEmpty) then
		if comm &lt;&gt; null then
			if comm.isEmpty then
				objSet.clear;
				objSet.add(comm);
				criteria := self.createCriteria(objSet, YACriteriaType_Commodity);
				if criteria &lt;&gt; null then
					criteria.setYardAllocation(self);
				endif;
			
			endif;
		endif;
	endif;
	
	if _theTI.isAttributeTrue(TI_Attrib_IsHiCubed) and not isoSet then
		objSet.clear;
		objSet.add(_theTI.getISOTypeObject());
		criteria := self.createCriteria(objSet, YACriteriaType_ISO);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
			isoSet := true;
		endif;
	
	endif;
	
	if _theTI.isOverDimensions then
		criteria := self.createCriteria(true, YACriteriaType_IsOverDimension);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
	
	endif;
	
	if _theTI.isHazardous then
		// PAR 27749. Noticed that we only use IsHazardous for auto discharge CC. Added this to use Hazardous if voyage is not using IsHazardous
		if _theTI.myVoyage &lt;&gt; null then
			if _theTI.myVoyage.isUsingCriteriaType(YACriteriaType_IsHazardous) then
				criteria := self.createCriteria(true, YACriteriaType_IsHazardous);
			else
				criteria := self.createCriteria(true, YACriteriaType_Hazardous);
			endif;
		else
			criteria := self.createCriteria(true, YACriteriaType_IsHazardous);
		endif;
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
	
	endif;
	
	if _theTI.isAttributeTrue(TI_Attrib_IsHalfHeight) and not isoSet then
		objSet.clear;
		objSet.add(_theTI.getISOTypeObject());
		criteria := self.createCriteria(objSet, YACriteriaType_ISO);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
			isoSet := true;
		endif;
	endif;
	
	if _theTI.isAttributeTrue(TI_Attrib_RequiresPower) then
		criteria := self.createCriteria(true, YACriteriaType_RequiresPower);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
	
	endif;
	
	if _theTI.isAttributeTrue(TI_Attrib_IsWaterCooled) then
		criteria := self.createCriteria(true, YACriteriaType_WaterCooled);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
	
	endif;
	
	if _theTI.isAttributeTrue(TI_Attrib_IsForty) then
		criteria := self.createCriteria(true, YACriteriaType_IsForty);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
	
	endif;
	
	if _theTI.isAttributeTrue(TI_Attrib_IsThirty) then
		criteria := self.createCriteria(true, YACriteriaType_IsThirty);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;

	endif;
	
	if _theTI.isAttributeTrue(TI_Attrib_IsFortyFive) then
		criteria := self.createCriteria(true, YACriteriaType_IsFortyFive);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;

	endif;
	
	if _theTI.isAttributeTrue(TI_Attrib_IsFiftyThree) then
		criteria := self.createCriteria(true, YACriteriaType_IsFiftyThree);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;

	endif;
	// ### SPECIAL STOW
	if _theTI.specialStow &lt;&gt; null then
		specialSt := app.myRoot.allSpecialStows[_theTI.specialStow];
		if specialSt &lt;&gt; null then
			objSet.clear;
			objSet.add(specialSt);
			criteria := self.createCriteria(objSet, YACriteriaType_SpecialStow);
			if criteria &lt;&gt; null then
				criteria.setYardAllocation(self);
			endif;
		endif;
	endif;
	
	// ### WEIGHT
//		weightRn := app.myRoot.getColourFromWeightRange(_theTI.totalWeight);
	// ### BOOKING
	// ### DESTINATION PORT


	// ### CARGO SUBTYPE
	if _theTI.myProduct &lt;&gt; null then
		objSet.clear;
		objSet.add(_theTI.myProduct );
		criteria := self.createCriteria(objSet, YACriteriaType_Product);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
	endif;
	
	// ### TRANS SHIP TO PORT
	if _theTI.myTranshipToPort &lt;&gt; null then
		objSet.clear;
		objSet.add(_theTI.myTranshipToPort);
		criteria := self.createCriteria(objSet, YACriteriaType_TranshipToPort);
		if criteria &lt;&gt; null then
			criteria.setYardAllocation(self);
		endif;
	
	endif;
	
	
epilog
	delete objSet;
end;</source>
        <Parameter name="_slotReq" type="CM_RORORequest"/>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_imexStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="sortROROSlots" id="9d18fb4c-7e82-41e1-a6d3-84d1f4da6b8f">
        <source>sortROROSlots(_slots : CM_VoyageROROControllerArray) : CM_ROROSlotLCByOrd1AOrd2D;
/*
Purpose:	To sort the slots by the XY of teh location defn layout.
				The RORO 20 foot locations are not defined as 40 foot, as 40s can go anywhere, so there is no is back end for 40s.
				So this is sorting into 'rows' and 'columns' so we can 'link' them for the colour coding
Date		Who		Reason
02 August 2011	cnwab1	Initial creation
*/

vars
	sortDict : CM_ROROSlotLCByOrd1AOrd2D;
	locnDefn : CM_ROROLocnDefn;
	tmpSlot : CM_VoyageROROController;
	ord1, ord2 : Integer;
begin
	create sortDict transient;
	
	foreach tmpSlot in _slots  discreteLock do
		locnDefn := tmpSlot.CM_ROROSlotController.mySlotDefn.myROROLocnDen;
		
		locnDefn.myLayout.getOrdinalsForSorting(PSFA_Value, ord2, ord1);
//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1. ord1: ' &amp; ord1.String &amp; " ord2: " &amp; ord2.String);
		ord2 := ord2 + tmpSlot.CM_ROROSlotController.mySlotDefn.ordinal;

		sortDict.putAtKey(ord2, ord1, tmpSlot.CM_ROROSlotController);
	endforeach;
		
	return sortDict;
epilog

end;</source>
        <Parameter name="_slots" type="CM_VoyageROROControllerArray"/>
        <ReturnType type="CM_ROROSlotLCByOrd1AOrd2D"/>
    </JadeMethod>
    <JadeMethod name="testAgainstSlotRequest" id="b746ce99-ebed-44db-b27d-17be2bb62d43">
        <source>testAgainstSlotRequest(_theTI : CM_TrackedItem; _locId : String);
// ---------------------------------------------------------------------------
// Created:     10 March 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// CATCH ALL for any 'non old school' colour coding attribute checks
// ---------------------------------------------------------------------------

vars
	cmifAutoPlan : CMIF_YAAutoPlan;
	logStr, tmpStr : String;
begin
	create cmifAutoPlan as CMIF_YAAutoPlanNormal transient;
	cmifAutoPlan.attachTI(_theTI);

	if not self.doesTIMatchMe(cmifAutoPlan,false) then
		foreach logStr in cmifAutoPlan.allLogging  discreteLock do
			if tmpStr = null then
				tmpStr := logStr;
			else
				tmpStr := tmpStr &amp; ", " &amp; logStr;
			endif;
		endforeach;
		
		app.raiseCMWarning3(Cargo_item_does_not_match_colo, _theTI.id, _locId,tmpStr,null, null, self);
	endif;
epilog
	delete cmifAutoPlan;
end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_locId" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateForDelete" id="e8ede7dd-ff43-479f-a7d9-e6536996e975">
        <source>validateForDelete();

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
03 February 2010	cnwas3	Initial creation

*/

vars
	sr : CM_SlotRequest;
	voyRequest : CM_VoyageRequest;
	size : Integer;
begin
		
	foreach sr in self.allSlotRequests do
		
		if sr.myJob &lt;&gt; null then				
			// PAR 30165 - Messina discharge all their cargo 4 days before they load a MOVINS and work the exports.
			// 					The discharge work includes SoBs So this stops them from loading a MOVINS file
			if sr.isSOB() and sr.myJob.jobType = JOB_TYPE_SOB then
				continue;
			endif;
			// PAR 32732
			if sr.myJob.isJobComplete()
			or sr.myJob.status = JOB_PART_COMPLETE then
				continue;
			endif;
			app.raiseCMException2(Error_slot_reque_part_incom_ad, sr.mySlotController.getFullId(), sr.myJob.jobId, null, null);
			return;
		endif;
	endforeach;
	
	
	//epr par 29929 29/6/12
	foreach voyRequest in self.allRequests do
		if voyRequest.myJob &lt;&gt; null then
			// PAR 30165 - Messina discharge all their cargo 4 days before they load a MOVINS and work the exports.
			// 					The discharge work includes SoBs So this stops them from loading a MOVINS file
			if voyRequest.isSOB() and voyRequest.myJob.jobType = JOB_TYPE_SOB then
				continue;
			endif;
				// PAR 32732
			if voyRequest.myJob.isJobComplete()
			or voyRequest.myJob.status = JOB_PART_COMPLETE then
				continue;
			endif;
		
			app.raiseCMException2(Error_slot_reque_part_incom_ad, voyRequest.getVoyageController.getFullId(), voyRequest.myJob.jobId, null, null);
			return;
		endif;		
	endforeach;
	
	size := self.allSlotRequests.size + self.allRequests.size;
	
	if size &gt; 0 then
		app.raiseCMWarning1(Warni_voyag_alloc_about_delet,size.asStringJMT,null,null,self);
	endif;
	
epilog

end;</source>
    </JadeMethod>
</Class>
