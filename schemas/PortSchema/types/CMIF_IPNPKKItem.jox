    <JadeMethod name="getShippingLine" id="76a890a5-9b56-4bd1-a563-81a77a8ff17b">
        <source>getShippingLine() : CM_ShippingLine;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2018	jlger1	Initial creation

*/

vars
	shipLine,
	shippingLine : CM_ShippingLine;
	translatedCode : String;
	found : Boolean;

begin

	shippingLine := app.myRoot.allShippingLines[ self.perusahaanNama ];
		
	if shippingLine = null then
		translatedCode := app.myRoot.getXlationSystemCode(  self.perusahaanNama, XLATION_TYPE_SHIPPINGLINE, found );
		if found then
			shippingLine := app.myRoot.allShippingLines[ translatedCode ];
		endif;
	endif;
	
	if shippingLine = null then
		foreach shipLine in app.myRoot.allShippingLines do
			if shipLine.description = self.perusahaanNama then
				return shipLine;
			endif;
		endforeach;
	
	endif;
	
	return shippingLine;

epilog

end;</source>
        <ReturnType type="CM_ShippingLine"/>
    </JadeMethod>
    <JadeMethod name="getValidCurrentStatuses" id="10a9787d-4d5e-439a-a978-fe0ceb7991bb">
        <source>getValidCurrentStatuses(_validStatuses: IntegerArray input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
24 May 2018	jlgndl1	Initial creation	TFS 38135

*/

vars

begin

	_validStatuses.add( 0 );
	_validStatuses.add( Voyage_Status_IVoyCreated );
	_validStatuses.add( Voyage_Status_IVoyRequested );

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_validStatuses" type="IntegerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getVessel" id="2b1c6e85-70f1-49b4-aead-879a2889494a">
        <source>getVessel() : CM_Vessel;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 September 2018	jlger1	Initial creation

*/

vars

begin
	return app.myRoot.getVessel( self.kapalNama, self.imoNumber, self.callSign, self.getOperator );
epilog

end;</source>
        <ReturnType type="CM_Vessel"/>
    </JadeMethod>
    <JadeMethod name="getVesselType" id="54d2e149-a352-47cd-948e-efda166d04f1">
        <source>getVesselType() : HMS_VesselType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 August 2018	jlger1	Initial creation
11 Sep 2018	NDL		TFS 40778

*/

vars

	vesselType : HMS_VesselType;
	xlationValue : String;
	foundMatch : Boolean;

begin

//	return app.myRoot.allVesselTypes[self.jenisKapal];

	//11 Sep 2018	NDL		TFS 40778
	if self.jenisKapal &lt;&gt; null then
	
		vesselType := app.myRoot.allVesselTypes[self.jenisKapal];
	
		if vesselType = null then
			xlationValue := app.myRoot.getXlationSystemCode( self.jenisKapal, XLATION_TYPE_VESSEL_TYPE, foundMatch);
			
			if foundMatch then
				vesselType := app.myRoot.allVesselTypes[ xlationValue ];
			endif;
		
		endif;
	
	endif;
	
	return vesselType;
	
epilog

end;</source>
        <ReturnType type="HMS_VesselType"/>
    </JadeMethod>
    <JadeMethod name="getVoyage" id="bfe74468-6e0a-497d-b324-18e47cd6a67c">
        <source>getVoyage() : CM_Voyage;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 September 2018	jlger1	Initial creation

*/

vars
	voyage : CM_Voyage;
	term : CM_Terminal;
	vessel : CM_Vessel;
	eta : TimeStamp;
begin
	term := app.myPassport.myTerminal;
	
	//3. Number of PKK, Mandatory - self.nomorPKK  ( external voyage number)
	voyage := term.allVoyagesByExternalCode.getAtKey( self.nomorPKK );
	
	if voyage &lt;&gt; null then
		vessel := voyage.myVessel;
	else
		vessel := self.getVessel;
	endif;
/*	epr TFS 42662 20/12/18
	eta:=self.tanggalEta.asTimeStampFromInaportnet;
	if voyage = null and vessel &lt;&gt; null and eta.Date.isValid then
		voyage:=vessel.getLastVoyage(term);
		if voyage &lt;&gt; null then
			if voyage.departedDT &lt; eta then
				voyage:=null;
			endif;
		endif;
	endif;*/
	
	return voyage;
epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="hasCargo" id="49586be3-6f82-4802-860b-cd88e0876d21">
        <source>hasCargo() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 September 2018	jlger1	Initial creation

*/

vars

begin
	return self.statusBM.toUpper = "Y";

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="updateVesselOperator" id="41458950-1942-4b68-99d3-9bfdfd85761b">
        <source>updateVesselOperator( _vessel : CM_Vessel input; _operator : CM_Operator ) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 November 2018	jlgndl1	Initial creation	TFS 41829

*/

vars

	load : Boolean;
	vesselProxy : CM_Vessel;
	conflictManager : CMIF_HMS_ConflictsManager;

begin

	app.cmsBeginLoad( load );
	vesselProxy := _vessel.pxyCreateUpdateProxy();
	app.cmsEndLoad( load );
	
	vesselProxy.setProxyOperator( _operator );
	
	
	app.myTrxUA.trxUpdateVessel(vesselProxy, false, false, conflictManager, app.myPassport);

epilog

	delete vesselProxy;

	app.cmsEndLoad( load );

end;</source>
        <access>protected</access>
        <Parameter name="_vessel" type="CM_Vessel" usage="input"/>
        <Parameter name="_operator" type="CM_Operator"/>
    </JadeMethod>
    <JadeMethod name="validateDataFormats" id="e2ca3a43-d79e-4ef0-b1ac-d1feec1317cc">
        <source>validateDataFormats() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 September 2018	jlger1	Initial creation

*/

vars

		country : CM_Country;
	eta : TimeStamp;
	etd : TimeStamp;

begin

	

	//5. Taxpayer Registration Number of Shipping Company, Mandatory
//	if self.npwp &lt;&gt; null then
//	endif;
	
	//6. Vessel Registration Mark, Mandatory
//	if self.tandaPendaftaranKapal &lt;&gt; null then
//	endif;
	
	//8. Captain Of a Ship, Optional
//	if self.nahkoda &lt;&gt; null then
//	endif;
	
	//9. DeadWeight Tonnage of Vessel, Mandatory,  HMS_VoyageData::dim_DeadWeight
	if self.drt.trimBlanks &lt;&gt; null then
		if not self.drt.trimBlanks.isInteger then
			app.raiseCMException1(Value_field_must_integer, CMIF_IPNPKKItem::drt.name, null, null);
		endif;
	endif;
	
	//10. Gross Tonnage of Vessel, Mandatory, HMS_VoyageData::dim_GrossRegTonnes
	if self.grt.trimBlanks &lt;&gt; null then
		if not self.grt.trimBlanks.isInteger then
			app.raiseCMException1(Value_field_must_integer, CMIF_IPNPKKItem::grt.name, null, null);
		endif;
	endif;
	
	//11. Length Over All of Vessel, Mandatory, HMS_VoyageData::dim_LengthOverall
	if self.loa.trimBlanks &lt;&gt; null then
		if not self.loa.trimBlanks.isDecimal then
			app.raiseCMException1(Value_must_decimal, CMIF_IPNPKKItem::loa.name, null, null);
		endif;
	endif;
	
	if self.loa.trimBlanks.Integer  &gt; LOA_UpperLimit then
			app.raiseCMException3(VesselData_Dimension, CMIF_IPNPKKItem::loa.name, LOA_LowerLimit.String, LOA_UpperLimit.String, null, null); 	
	endif;
	
	//12. Vessel Type Code, Mandatory
//	if self.jenisKapal &lt;&gt; null then
//	endif;
	
	//13. Production Year, Mandatory,	CM_Voyage::yearOfBuild
	if self.tahunPembuatan.trimBlanks &lt;&gt; null then
		if not self.tahunPembuatan.trimBlanks.isInteger then
			app.raiseCMException1(Value_field_must_integer, CMIF_IPNPKKItem::tahunPembuatan.name, null, null);
		endif;
	endif;
	
	//14. Width of Vessel, Mandatory, HMS_VoyageData::dim_Beam
	if self.lebarKapal.trimBlanks &lt;&gt; null then
		if not self.lebarKapal.trimBlanks.isDecimal then
			app.raiseCMException1(Value_must_decimal, CMIF_IPNPKKItem::lebarKapal.name, null, null);
		endif;
	endif;
	
	//15. Maximum Draft, Mandatory
//	if self.drMax &lt;&gt; null then
//	endif;
	
	//16. Front Draft, Mandatory, HMS_VoyageData::dim_DraftFore
	if self.drDepan.trimBlanks &lt;&gt; null then
		if not self.drDepan.trimBlanks.isDecimal then
			app.raiseCMException1(Value_must_decimal, CMIF_IPNPKKItem::drDepan.name, null, null);
		endif;
	endif;
	
	//17. Back Draft, Mandatory, HMS_VoyageData::dim_DraftAft
	if self.drBelakang.trimBlanks &lt;&gt; null then
		if not self.drBelakang.trimBlanks.isDecimal then
			app.raiseCMException1(Value_must_decimal, CMIF_IPNPKKItem::drBelakang.name, null, null);
		endif;
	endif;

	//18. Middle Draft, Optional
//	if self.drTengah.trimBlanks &lt;&gt; null then
//	endif;
	
	//19. Type Of Route, Mandatory
//	if self.jenisTrayek &lt;&gt; null then
//	endif;
	
	//20. flag, Mandatory
	if self.bendera.trimBlanks &lt;&gt; null then
		country := app.myRoot.allCountries.getAtKey( self.bendera.trimBlanks );
		if country = null then
			app.raiseCMException3(Value_field_not_resolve, self.bendera, CMIF_IPNPKKItem::bendera.name, app.getErrorString(Country), null, null);
		endif;
	endif;
	
	//21. Vessel Call Sign, Optional, CM_Voyage::callSign  le 8
//	if self.callSign &lt;&gt; null then
//	endif;
	
	//22. IMO Number, Optional,	CM_Voyage::lloydsNumber  le 9
//	if self.imoNumber &lt;&gt; null then
//	endif;

	//23. Date of Estimated Arrival Time of Vessel, Mandatory - self.tanggalEta
	eta:=self.tanggalEta.asTimeStampFromInaportnet;	
	if not eta.Date.isValid
	or not eta.Time.isValid
	then
		app.raiseCMException2(ErrInvalidRptTemplateDateStr,"yyyy-mm-dd hh:mm:ss", CMIF_IPNPKKItem::tanggalEta.name, null, null); 
	endif;
	
	//24. Date of Estimated Departure Time of Vessel, Mandatory - self.tanggalEtd
	etd:=self.tanggalEtd.asTimeStampFromInaportnet;
	if not etd.Date.isValid
	or not etd.Time.isValid
	then
		app.raiseCMException2(ErrInvalidRptTemplateDateStr,"yyyy-mm-dd hh:mm:ss", CMIF_IPNPKKItem::tanggalEtd.name, null, null); 
	endif;
	
	
	//25. Port Origin Code, Mandatory
//	if self.kodeAsalPelabuhan &lt;&gt; null then
//	endif;

	//27. Port Departure Code, Mandatory
//	if self.kodeTujuanPelabuhan &lt;&gt; null then
//	endif;
	
	//28. Nama Pelabuhan Tujuan, Mandatory
//	if self.tujuanPelabuhan &lt;&gt; null then
//	endif;
	
	//29. Quay Name, Mandatory
//	if self.dermagaNama &lt;&gt; null then
//	endif;
	
	//61. Code of Loading Port, Mandatory
//	if self.kodeMuatPelabuhan &lt;&gt; null then
//	endif;
	
	//63. Last Port Destination Code, Mandatory
//	if self.kodeTujuanAkhirPelabuhan &lt;&gt; null then
//	endif;
	
	//65. Route Number, Mandatory
//	if self.nomorTrayek &lt;&gt; null then
//	endif;
	

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="validateDetails" id="665ca932-bb8c-472c-bc05-43e0efcc73b6">
        <source>validateDetails();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 September 2018	jlger1	Initial creation

*/

vars
	eta : TimeStamp ;
	etd  : TimeStamp ;
	country : CM_Country;
begin
	
	
	if self.getOperator = null then
		//The value '%1' in the field '%2' did not resolve to a '%3' in JMT.
		app.raiseCMException3(Value_field_not_resolve, self.perusahaanNama, CMIF_IPNPKKItem::perusahaanNama.name, app.getErrorString(Operator), null, null);
	endif;
	
	//23. Date of Estimated Arrival Time of Vessel, Mandatory - self.tanggalEta
	eta:=self.tanggalEta.asTimeStampFromInaportnet;
	
	//24. Date of Estimated Departure Time of Vessel, Mandatory - self.tanggalEtd
	etd:=self.tanggalEtd.asTimeStampFromInaportnet;
	
	if eta.Date.isValid and etd.Date.isValid then
		if eta &gt;= etd then
			app.raiseCMException2(ERR_DateRangeInvalid, CMIF_IPNPKKItem::tanggalEta.name, CMIF_IPNPKKItem::tanggalEtd.name, null, null);
		endif;
	endif;
	
	//30. Y = There is Loading Unloading ; N =  There is No Loading Unloading ; Mandatory
	if self.statusBM.toUpper = "Y" then

	elseif self.statusBM.toUpper = "N" then
	
	else
		app.raiseCMException3(Value_field_not_resolve, self.statusBM, CMIF_IPNPKKItem::statusBM.name, "'Y' or 'N'", null, null);
	endif;

	self.validateMandatoryFields;
	
	self.validateDataFormats;

	if self.getVesselType = null then
		app.raiseCMException3(Value_field_not_resolve, self.jenisKapal, CMIF_IPNPKKItem::jenisKapal.name, app.getErrorString(VesselType), null, null);

	endif;
	
	
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateMandatoryFields" id="f303c66f-2f2f-481f-8851-6896b3fd6fb3">
        <source>validateMandatoryFields() protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 September 2018	jlger1	Initial creation

*/

vars

begin
		//1. self.user - Checked in superClass ::validareCredentials
	
	//2. self.password - Checked in superClass ::validareCredentials
	
	//3. Number of PKK, Mandatory
	if self.nomorPKK = null then
		app.raiseCMException1(REQUIRED_FIELD, CMIF_IPNPKKItem::nomorPKK.name, null, null);
	endif;
	
	//4. Agent / Shipping Company Mandatory
	if self.perusahaanNama = null then
		app.raiseCMException1(REQUIRED_FIELD, CMIF_IPNPKKItem::perusahaanNama.name, null, null);
	endif;
	
	//5. Taxpayer Registration Number of Shipping Company, Mandatory
	if self.npwp = null then
		app.raiseCMException1(REQUIRED_FIELD,CMIF_IPNPKKItem::npwp.name, null, null);
	endif;
	
	//6. Vessel Registration Mark, Mandatory
	if self.tandaPendaftaranKapal = null then
		app.raiseCMException1(REQUIRED_FIELD, CMIF_IPNPKKItem::tandaPendaftaranKapal.name, null, null);
	endif;
	
	//7. Vessel Name, Mandatory
	if self.kapalNama = null then
		app.raiseCMException1(REQUIRED_FIELD, CMIF_IPNPKKItem::kapalNama.name, null, null);
	endif;
	
	//8. Captain Of a Ship, Optional
	//self.nahkoda
	
	//9. DeadWeight Tonnage of Vessel, Mandatory
	if self.drt = null then
		app.raiseCMException1(REQUIRED_FIELD, CMIF_IPNPKKItem::drt.name, null, null);
	endif;
	
	//10. Gross Tonnage of Vessel, Mandatory
	if self.grt = null then
		app.raiseCMException1(REQUIRED_FIELD, CMIF_IPNPKKItem::grt.name, null, null);
	endif;
	
	//11. Length Over All of Vessel, Mandatory
	if self.loa = null then
		app.raiseCMException1(REQUIRED_FIELD, CMIF_IPNPKKItem::loa.name, null, null);
	endif;
	
	//12. Vessel Type Code, Mandatory
	if self.jenisKapal = null then
		app.raiseCMException1(REQUIRED_FIELD, CMIF_IPNPKKItem::jenisKapal.name, null, null);
	endif;
	
	//13. Production Year, Mandatory
	if self.tahunPembuatan = null then
		app.raiseCMException1(REQUIRED_FIELD, CMIF_IPNPKKItem::tahunPembuatan.name, null, null);
	endif;
	
	//14. Width of Vessel, Mandatory
	if self.lebarKapal = null then
		app.raiseCMException1(REQUIRED_FIELD, CMIF_IPNPKKItem::lebarKapal.name, null, null);
	endif;
	
	//15. Maximum Draft, Mandatory
	if self.drMax = null then
		app.raiseCMException1(REQUIRED_FIELD, CMIF_IPNPKKItem::drMax.name, null, null);
	endif;
	
	//16. Front Draft, Mandatory
	if self.drDepan = null then
		app.raiseCMException1(REQUIRED_FIELD, CMIF_IPNPKKItem::drDepan.name, null, null);
	endif;
	
	//17. Back Draft, Mandatory
	if self.drBelakang = null then
		app.raiseCMException1(REQUIRED_FIELD, CMIF_IPNPKKItem::drBelakang.name, null, null);
	endif;

	//18. Middle Draft, Optional
	//self.drTengah
	
	//19. Type Of Route, Mandatory
	if self.jenisTrayek = null then
		app.raiseCMException1(REQUIRED_FIELD, CMIF_IPNPKKItem::jenisTrayek.name, null, null);
	endif;
	
	//20. flag, Mandatory
	if self.bendera = null then
		app.raiseCMException1(REQUIRED_FIELD, CMIF_IPNPKKItem::bendera.name, null, null);
	endif;
	
	//21. Vessel Call Sign, Optional
	//self.callSign
	
	//22. IMO Number, Optional
	//self.imoNumber
	
	//23. Date of Estimated Arrival Time of Vessel, Mandatory
	if self.tanggalEta = null then
		app.raiseCMException1(REQUIRED_FIELD, CMIF_IPNPKKItem::tanggalEta.name, null, null);
	endif;
	
	//24. Date of Estimated Departure Time of Vessel, Mandatory
	if self.tanggalEtd = null then
		app.raiseCMException1(REQUIRED_FIELD, CMIF_IPNPKKItem::tanggalEtd.name, null, null);
	endif;
	
	//25. Port Origin Code, Mandatory
	if self.kodeAsalPelabuhan = null then
		app.raiseCMException1(REQUIRED_FIELD, CMIF_IPNPKKItem::kodeAsalPelabuhan.name, null, null);
	endif;
	
	//26. Name of Port Origin, Mandatory
	if self.asalPelabuhan = null then
		app.raiseCMException1(REQUIRED_FIELD, CMIF_IPNPKKItem::asalPelabuhan.name, null, null);
	endif;

	//27. Port Departure Code, Mandatory
	if self.kodeTujuanPelabuhan = null then
		app.raiseCMException1(REQUIRED_FIELD, CMIF_IPNPKKItem::kodeTujuanPelabuhan.name, null, null);
	endif;
	
	//28. Nama Pelabuhan Tujuan, Mandatory
	if self.tujuanPelabuhan = null then
		app.raiseCMException1(REQUIRED_FIELD, CMIF_IPNPKKItem::tujuanPelabuhan.name, null, null);
	endif;
	
	//29. Quay Name, Mandatory
	if self.dermagaNama = null then
		app.raiseCMException1(REQUIRED_FIELD, CMIF_IPNPKKItem::dermagaNama.name, null, null);
	endif;

	//30. Y = There is Loading Unloading ; N =  There is No Loading Unloading ; Mandatory
	if self.statusBM = null then
		app.raiseCMException1(REQUIRED_FIELD, CMIF_IPNPKKItem::statusBM.name, null, null);
	endif;
	
	//31. Total Debarkation , optional
	//self.penumpangNaikTurunBongkar
	
	//32. Total Embarkation, optional
	//self.penumpangNaikTurunMuat
	
	//33. Goods Type, optional
	//self.jenisBarang
	
	//34. Quantity of Container Unloading 40 Full, Optional
	//self.containerBongkarIsi40
	
	//35. Quantity of Container Unloading 20 Full, Optional
	//self.containerBongkarIsi20

	//36. Quantity of Container Unloading 40 Empty, Optional
	//self.containerBongkarIsi40Empty
	
	//37. Quantity of Container Unloading 20 Empty, Optional
	//self.containerBongkarIsi20Empty
	
	//38. Quantity of Container Loading 40 Full, Optional
	//self.containerMuatIsi40
	
	//39. Quantity of Container Loading 20 Full, Optional
	//self.containerMuatIsi20
	
	//40. Quantity of Container Loading 40 Empty, Optional
	//self.containerMuatIsi40Empty
	
	//41. Quantity of Container Loading 20 Empty, Optional
	//self.containerMuatIsi20Empty
	
	//42. Quantity of Mix Cargo Unloading, Optional
	//self.cargoBarangCampurBongkar
	
	//43. Quantity of Mix Cargo Loading, Optional
	//self.cargoBarangCampurMuat
	
	//44.Quantity of Sack Cargo Unloading, Optional
	//self.cargoBarangKarungBongkar
	
	//45. Quantity of Sack Cargo Loading, Optional
	//self.cargoBarangKarungMuat

	//46. Quantity of Dry Cargo Unloading, Optional
	//self.cargoBarangCurahBongkar
	
	//47. Quantity of Dry Cargo Loading, Optional
	//self.cargoBarangCurahMuat

	//48. Quantity of Liquid Cargo Unloading, Optional
	//self.cargoBarangCairBongkar
	
	//49. Quantity of Liquid Cargo Loading Optional
	//self.cargoBarangCairMuat

	//50. Quantity of Dangerous Cargo Unloading, Optional
	//self.cargoBarangBerbahayaBongkar
	
	//51. Quantity of Dangerous Cargo Loading, Optional
	//self.cargoBarangBerbahayaMuat

	//52. Others Goods Type, Optional
	//self.jenisBarangLain
	
	//53. Others Goods Type Unloading Optional
	//self.jenisBarangLainBongkar
	
	//54. Others Goods Type Loading, Optional
	//self.jenisBarangLainMuat
	
	//55.Quantity of Goods Unloaded Optional
	//self.jumlahBongkar

	//56. Quantity of Goods Loaded Optional
	//self.jumlahMuat
	
	//57. Quantity of Unloading Animal Cargo, Optional
	//self.hewanNaikTurunBongkar
	
	//58. Quantity of Loading Animal Cargo, Optional
	//self.hewanNaikTurunMuat

	//59. Port Code, Mandatory	
	// - Checked in superClass ::validareCredentials
	
	//60. 2 = Approved, optional
	//self.sts
	
	//61. Code of Loading Port, Mandatory
	if self.kodeMuatPelabuhan = null then
		app.raiseCMException1(REQUIRED_FIELD, CMIF_IPNPKKItem::kodeMuatPelabuhan.name, null, null);
	endif;
	
	//62. Name of Loading Port, Mandatory
	if self.muatPelabuhan = null then
		app.raiseCMException1(REQUIRED_FIELD, CMIF_IPNPKKItem::muatPelabuhan.name, null, null);
	endif;
	
	//63. Last Port Destination Code, Mandatory
	if self.kodeTujuanAkhirPelabuhan = null then
		app.raiseCMException1(REQUIRED_FIELD, CMIF_IPNPKKItem::kodeTujuanAkhirPelabuhan.name, null, null);
	endif;
	
	//64. Name of Last Port Destination, Mandatory
	if self.tujuanAkhirPelabuhan = null then
		app.raiseCMException1(REQUIRED_FIELD, CMIF_IPNPKKItem::tujuanAkhirPelabuhan.name, null, null);
	endif;

	//65. Route Number, Mandatory
	if self.nomorTrayek = null then
		app.raiseCMException1(REQUIRED_FIELD, CMIF_IPNPKKItem::nomorTrayek.name, null, null);
	endif;
	
	//66. Inmarsat Number, Optional
	//self.noinmarsat
	
	//67. Mandatory
	/*if self.statusWindow = null then
		app.raiseCMException1(REQUIRED_FIELD, WS_EntryPKKRequest::statusWindow.name, null, null);
	endif;*/

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
