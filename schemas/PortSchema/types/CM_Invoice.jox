    <JadeMethod name="getSapTransactionDTLocalTZ" id="3455cf86-f88e-479a-accf-c8884aa9c33f">
        <source>getSapTransactionDTLocalTZ():TimeStamp;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 November 2018	jlgndl1	Initial creation	TFS 42116

*/

vars

	ts : TimeStamp;

begin

	ts := null;

	if self.paymentType = PaymentType_AutoCollection then
		if self.status = CM_Invoice.INVOICE_PENDING then
			ts := self.pendingDT;
		elseif self.status = CM_Invoice.INVOICE_POSTED then
			ts := self.postedDT;
		endif;
	elseif self.paymentType = PaymentType_PostPay then
		ts := self.pendingDT;
	elseif self.paymentType = PaymentType_PrePay then
		//epr TFS 44192 16/4/19 was just posted 
		if self.status = CM_Invoice.INVOICE_PENDING then
			ts := self.pendingDT;
		elseif self.status = CM_Invoice.INVOICE_POSTED then
			ts := self.postedDT;
		endif;
	endif;
	
	if ts = null then
		return null;
	endif;
	
	return self.systemToLocalTime( ts );

epilog

end;</source>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getSapVesselCargo" id="e939f345-175f-4c89-97ad-ce2bfc7beaa6">
        <source>getSapVesselCargo():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 November 2018	jlgndl1	Initial creation	TFS 42116

*/

vars

	invLine : CM_InvoiceLine;

begin

	foreach invLine in self.invoiceLines do
		if invLine.myTransactionVTMIS &lt;&gt; null then
			return "Vessel";
		endif;
		if invLine.myTransactionHMS &lt;&gt; null then
			return "Vessel";
		endif;
	endforeach;

	return "Cargo";

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSapWSDL112seqNum" id="e59f524b-6f1e-4aa1-af47-0049e830fc87">
        <source>getSapWSDL112seqNum():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 May 2019	jlgndl1	Initial creation	TFS 44807

*/

vars

	nextSeqNum : Integer;
	iter : Iterator;
	invLine : CM_InvoiceLine;

begin

	nextSeqNum := 1;
	
	iter := self.invoiceLines.createIterator;
	while iter.next( invLine ) do
		if invLine.externalTS05.date.isValid then
			nextSeqNum := nextSeqNum + 1;
		endif;
	endwhile;

	return nextSeqNum;

epilog

	delete iter;

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getSeqNumSignOffUserID" id="ea37be4d-5505-4b54-8d05-760cee93022a">
        <source>getSeqNumSignOffUserID():String;
/*

Purpose:			

Parameters:			Used in RWR

Return Value:		

Date		Who		Reason
15 May 2018	jlgndl1	Initial creation	TFS 38535

*/

vars

	signOffUser : CM_InvoiceSignoffUser;
	retString : String;

begin

	retString := self.sequenceNum.String &amp; " ";

	signOffUser := self.getSignOffUser();
	if signOffUser &lt;&gt; null then
	//	retString := retString &amp; signOffUser.userName.toUpper; 
		retString := retString &amp; signOffUser.userID.String; 
	endif;
	
	return retString;

epilog

end;</source>
