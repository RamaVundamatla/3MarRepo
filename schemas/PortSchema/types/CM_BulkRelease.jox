    <JadeMethod name="myConsignee" id="ac8a7ee2-196f-44bb-8b3b-1e6f61d86c65">
        <methodInvocation>mapping</methodInvocation>
        <source>myConsignee(set: Boolean; _value: CM_ConsigneeConsignor io) mapping;
/*
----------   ----------  --------------------------------------------------
Created:	02 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
22 Oct 2024  navma1 	 MTN-23340 MTN - Performance issues and locks when completing the Retrospective Pack jobs 
30 Oct 2024  navsck1	 MTN-33247 Web Portal - Release Request - Consignee Data Access Group not excluding Release Request
----------   ----------  --------------------------------------------------
*/
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		if self.consigneeCode &lt;&gt; null then									//22.10.2024 navma1 #MTN-23340
			_value := app.myRoot.allConsigneeConsignors[self.consigneeCode];//badly named for some reason
		else
			_value := null;													//30.10.2024 navsck1	#MTN=33247
		endif;		
	endif;
end;
</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_ConsigneeConsignor" usage="io"/>
    </JadeMethod>
    <JadeMethod name="myConsignor" id="30dff09f-2954-43c1-9122-81796e6f5924">
        <methodInvocation>mapping</methodInvocation>
        <source>myConsignor(set: Boolean; _value: CM_ConsigneeConsignor io) mapping;
/*
----------   ----------  --------------------------------------------------
Created:	02 May 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
22 Oct 2024  navma1 	 MTN-23340 MTN - Performance issues and locks when completing the Retrospective Pack jobs 
30 Oct 2024  navsck1	 MTN-33247 Web Portal - Release Request - Consignee Data Access Group not excluding Release Request
----------   ----------  --------------------------------------------------
*/
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		if self.consignorCode &lt;&gt; null then											//22.10.2024 navma1 #MTN-23340
			_value := app.myRoot.allConsigneeConsignors[self.consignorCode];
		else
			_value := null;															//30.10.2024 navsck1	#MTN=33247
		endif;
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_ConsigneeConsignor" usage="io"/>
    </JadeMethod>
    <JadeMethod name="myFreightForwarder" id="aafa9613-22ea-4278-aaee-04f76fad516e">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>myFreightForwarder(set: Boolean; _value: CM_ConsigneeConsignor io) updating, mapping;
/*
----------   ----------  --------------------------------------------------
Created:	08 November 2006 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
22 Oct 2024  navma1 	 MTN-23340 MTN - Performance issues and locks when completing the Retrospective Pack jobs 
----------   ----------  --------------------------------------------------
*/
vars
	
begin
	// PAR 20646 - change to lookup based on code
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		if self.freightForwarderCode &lt;&gt; null then										//22.10.2024 navma1 #MTN-23340
			_value := app.myRoot.allConsigneeConsignors[self.freightForwarderCode];
		else
			_value := null;
		endif;
	endif;
end;
</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="CM_ConsigneeConsignor" usage="io"/>
    </JadeMethod>
    <JadeMethod name="myPoolingParty" id="615f57e2-0b4f-4799-aafd-e9c16177504e">
        <source>myPoolingParty() : CM_MTPoolingParty;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 05/12/2016	cnwdap1		Initial creation TFS 3039 SNO Empty Container Pool Management
//
vars
	opTerm : CM_OperatorTerminal;

begin
	if self.myOperator &lt;&gt; null then
		opTerm := self.myOperator.getOperatorTerminal(self.myTerminal, false);
		if opTerm &lt;&gt; null then
			return opTerm.myPoolingParty;
		endif;
	endif;
	
	return null;
epilog

end;</source>
        <ReturnType type="CM_MTPoolingParty"/>
    </JadeMethod>
    <JadeMethod name="noPINforHazardousOD" id="9762d4ec-66ae-448b-b302-b58a789ae527">
        <source>noPINforHazardousOD( _tiSetNoPin : CM_TISet input ) : Boolean protected;
/* ---------------------------------------------------------------------------
Created:	03 February 2009	by cnwvu1

Purpose:	Gives true, when there is hazardous or over dimension ti 
			and No PIN Generation is setup in the Termional Config / Gate
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	ti	: CM_TrackedItem;
	
begin

	foreach ti in self.allTrackedItemsAssigned do
		if ti.noPINforHazardousOD(false) then	// there is cargo when PIN must not be generated.
			_tiSetNoPin.add(ti);
		endif;
	endforeach;

	if _tiSetNoPin.size &gt; 0 then
		return true;	// no PIN generation for hazard or over dimension cargo
	else
		return false;	// there is no hazardous or over dimension cargo or No PIN Generation not setup in Terminal Config. ccms 1676. Feb 2009
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_tiSetNoPin" type="CM_TISet" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="noPINforHazardousODProcess" id="d8838fbd-ecf3-4772-bed9-54acf2a7e8c1">
        <updating/>
        <source>noPINforHazardousODProcess(_pin : CM_PinNo input; _passport : CM_Passport input) : Boolean updating;
/* ---------------------------------------------------------------------------
Created:	02 February 2009	by cnwvu1

Purpose:	Gives true when no PIN should be generated for pre-notes or releases,
			when hazardous or over dimension.
			_pin	= null	- no PIN generation
					&lt;&gt; null	- deletes existing PIN for hazardous or over dimension cargo.
			
Change Date		Who		Reason
13/02/2012		cnwcs5	par 28756 - refactoring.  Moved validation code to CM_BulkRelease::validateForPIN
------------------------------------------------------------------------------*/
vars
	info			: String;
	tiSetNoPin		: CM_TISet;
	ti				: CM_TrackedItem;
	tiStr			: String;
begin

	create tiSetNoPin transient;
	
	if self.noPINforHazardousOD(tiSetNoPin) then	
		// for hazardous or over dimension cargo, we should not to create ( or should delete existing) PIN
		
		foreach ti in tiSetNoPin do
			tiStr := tiStr &amp; " " &amp; ti.id &amp; ", ";
		endforeach;
		
		tiStr := tiStr[1: tiStr.length()-2];	// removing the last commma
		
		// trx step - updating DB
		//create information Audit
		//creates info
		if _pin = null then
			info := app.getErrorString(Info_NoPINforReleaseHazardOD) &amp;' '&amp; tiStr;
		else
			_pin.erasePIN(null);
			info := app.getErrorString(Info_PINDeletedReleaseHazardOD) &amp;' '&amp; tiStr;
		endif;
		
		self.createAuditObjectInformation(info);
			
		return true; // return true - means no PIN generation.
		
	endif;
	
	return false; // generate PIN, when there is no setup in the Terminal Config / Gate sheet
	
epilog
	delete tiSetNoPin;
end;</source>
        <Parameter name="_pin" type="CM_PinNo" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="populatePxyFromBooking" id="f414cc29-52c4-4b07-9356-f2d4f33ea897">
        <updating/>
        <source>populatePxyFromBooking(_booking	: CM_BookingRef) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
04 October 2022	navgm20	ChangeRequest 54979: EUP - Cargo Work Orders Enhancements
02 February 2023 navdp20 ChangeRequest 56969:[56288] EUP - [Framework] Constructing methods to populate booking, bill of lading, and release request conversion
*/

vars
	ti				: CM_TrackedItem;
	reserveTi,
	newReserveTi	: CM_ReserveTI;
	tiSet 			: CM_TISet;
begin
	// ### WIll need to have moved the prenotes before this becasue the reserveTI add TI does not work with prenotes.

	self.code				:= _booking.bookingReference;         									//02.02.2023 navdp20 TFS #56969[56288]
	self.consigneeCode		:= _booking.consigneeCode;
	self.consignorCode		:= _booking.consignorCode;
	self.consigneeDesc		:= _booking.consigneeDesc;
	self.consignorDesc		:= _booking.consignorDesc;
	self.customsAgent		:= _booking.customsAgent;
	self.myCargoType		:= _booking.myCargoType;
	self.myOperator			:= _booking.myOperator;
	self.myOperatorTerminal	:= _booking.myOperatorTerminal;
	self.myTerminal			:= _booking.myTerminal;
	self.myVoyage			:= _booking.myVoyage;
	self.remarksAdditional1	:= _booking.remarks;
	self.remarksAdditional2	:= _booking.remarks;
	self.setSubTerminal(_booking.myTerminal.getConfig(MySubTerminalForOther).CM_SubTerminal); 		//02.02.2023 navdp20 TFS #56969[56288]
	
	if _booking.status = BOOKING_REF_ACTIVE  then
		self.status 		:= BR_ACTIVE;
	elseif	_booking.status = BOOKING_REF_PENDING  then
		self.status 		:= BR_PENDING;
	elseif _booking.status = BOOKING_REF_CLOSED then
		self.status			:= BR_COMPLETE;
	endif;
	self.type := BR_TYPE_SHIP;
	
	foreach	ti in _booking.allTIs do
		create reserveTi transient;
		reserveTi.populatePxyfromPrenote(ti);
		self.allReserveDetails.add(reserveTi);
		reserveTi.addTI(ti); 																		//02.02.2023 navdp20 TFS #56969[56288]
	endforeach;
epilog
	
end;</source>
        <Parameter name="_booking" type="CM_BookingRef"/>
    </JadeMethod>
    <JadeMethod name="populatePxyFromBookingPartial" id="da60cb42-c608-4b62-9a4a-c7dadd981ddc">
        <updating/>
        <source>populatePxyFromBookingPartial(_booking : CM_BookingRef; _allTis : CM_TISet; _transportMode : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 February 2024	navpw1	Initial creation TFS: 59411 (61864)

*/

vars
	ti			: CM_TrackedItem;
	reserveTi	: CM_ReserveTI;
	
begin
	// ### WIll need to have moved the prenotes before this becasue the reserveTI add TI does not work with prenotes.

	self.code				:= _booking.bookingReference;         									//02.02.2023 navdp20 TFS #56969[56288]
	self.consigneeCode		:= _booking.consigneeCode;
	self.consignorCode		:= _booking.consignorCode;
	self.consigneeDesc		:= _booking.consigneeDesc;
	self.consignorDesc		:= _booking.consignorDesc;
	self.customsAgent		:= _booking.customsAgent;
	self.myCargoType		:= _booking.myCargoType;
	self.myOperator			:= _booking.myOperator;
	self.myOperatorTerminal	:= _booking.myOperatorTerminal;
	self.myTerminal			:= _booking.myTerminal;
	self.myVoyage			:= _booking.myVoyage;
	self.remarksAdditional1	:= _booking.remarks;
	self.remarksAdditional2	:= _booking.remarks;
	self.setSubTerminal(_booking.myTerminal.getConfig(MySubTerminalForOther).CM_SubTerminal); 		//02.02.2023 navdp20 TFS #56969[56288]
	
	if _booking.status = BOOKING_REF_ACTIVE  then
		self.status 		:= BR_ACTIVE;
	elseif	_booking.status = BOOKING_REF_PENDING  then
		self.status 		:= BR_PENDING;
	elseif _booking.status = BOOKING_REF_CLOSED then
		self.status			:= BR_COMPLETE;
	endif;
	
	if _transportMode = TI_TRANSMODE_SHIP_STR then
		self.type			:= BR_TYPE_SHIP;
		
	elseif _transportMode = TI_TRANSMODE_RAIL_STR then
		self.type			:= BR_TYPE_RAIL;
		
	elseif _transportMode = TI_TRANSMODE_ROAD_STR then
		self.type			:= BR_TYPE_ROAD;
		
	endif;
	
	foreach	ti in _allTis do
		create reserveTi transient;
		reserveTi.populatePxyfromPrenote(ti);
		reserveTi.setTotalRequested(ti.totalQuantity);
		self.allReserveDetails.add(reserveTi);
		reserveTi.addTI(ti); 																		//02.02.2023 navdp20 TFS #56969[56288]
	endforeach;
	
end;</source>
        <Parameter name="_booking" type="CM_BookingRef"/>
        <Parameter name="_allTis" type="CM_TISet"/>
        <Parameter name="_transportMode" type="String"/>
    </JadeMethod>
    <JadeMethod name="populatePxyFromBulkRelease" id="f7b63f4b-bffd-4984-82d1-3f714dd69535">
        <updating/>
        <source>populatePxyFromBulkRelease(_releaseRequest : CM_BulkRelease; _wleArray : CM_WLEArray; _tiSet : CM_TISet; _quantity : Integer; _transportMode : String) updating;
/*

Purpose:			Used for creating a new release request by type from an existing release request by type.
					Handy when splitting a release by type into separate releases

Parameters:			_releaseRequest	CM_BulkRelease	The release request to base this one off of
					_wleArray		CM_WLEArray		Contains a wle that we will base the reserve selection off of
					_tiSet			CM_TISet		Contains tis that we will base the reserve tis off of
					_quantity		Integer			Contains the quantity that needs to go on the reserve selection
					_transportMode	String			Represents the transport mode we are creating the bulk release for

Return Value:		NONE

Date				Who		Reason
13 February 2024	navpw1	Initial creation TFS: 59411 (62272)
16 February 2024	navpw1	TFS: 59411 (61867) - Made changes to support release by id

*/

vars
	pxyReserveSelection : CM_ReserveSelection;
	pxyReserveTi		: CM_ReserveTI;
	ti					: CM_TrackedItem;
	
begin
	self.allowCargoOnMultipleReleases	:= _releaseRequest.allowCargoOnMultipleReleases;
	self.bookingConfirmation			:= _releaseRequest.bookingConfirmation;
	self.blockEDIUpdates				:= _releaseRequest.blockEDIUpdates;			// par 29481 May 2012
	self.carrierId						:= _releaseRequest.carrierId;
	self.cargoRemarks					:= _releaseRequest.cargoRemarks;
	self.canBeHiLoCube					:= _releaseRequest.canBeHiLoCube;			// May 2011 cnwjre1 27097 POL CCMS 2043
	self.code							:= _releaseRequest.code;
	self.consigneeCode					:= _releaseRequest.consigneeCode;
	self.consignorCode					:= _releaseRequest.consignorCode;
	self.consigneeDesc					:= _releaseRequest.consigneeDesc;
	self.consignorDesc					:= _releaseRequest.consignorDesc;
	self.consignorVoyageCode			:= _releaseRequest.consignorVoyageCode;
	//self.context						:= _releaseRequest.context;
	self.converted						:= true;									// PAR #27972
	self.customsAgent					:= _releaseRequest.customsAgent;
	self.customsAssistance				:= _releaseRequest.customsAssistance;
	self.dateEstimatedRequired			:= _releaseRequest.dateEstimatedRequired;
	self.dateRequested					:= _releaseRequest.dateRequested;
	self.deliveryReasonCode				:= _releaseRequest.deliveryReasonCode;
	self.deliveryReasonDescr			:= _releaseRequest.deliveryReasonDescr.trimBlanks;
	self.deliveryReleaseNumber			:= _releaseRequest.deliveryReleaseNumber.trimBlanks;
	self.dispatchLocation				:= _releaseRequest.dispatchLocation;
	self.doorsDirection					:= _releaseRequest.doorsDirection;
	self.expiryTimeStamp				:= _releaseRequest.expiryTimeStamp;
	self.freightForwarderCode			:= _releaseRequest.freightForwarderCode[1:5];
	self.freightPayerCode				:= _releaseRequest.freightPayerCode;
	self.fullRelease					:= _releaseRequest.fullRelease;
	self.myAssignedTrain				:= _releaseRequest.myAssignedTrain;
	self.myBOLIn						:= _releaseRequest.myBOLIn; 		// jlgka1 TFS 41708
	self.myBookingRefStock				:= _releaseRequest.myBookingRefStock;
	self.myBusinessUnit					:= _releaseRequest.myBusinessUnit;
	self.myCargoType					:= _releaseRequest.myCargoType;
	self.myDestinationPort				:= _releaseRequest.myDestinationPort; //03 Nov 2009	NDL	Par 21519
	self.myDischargePort				:= _releaseRequest.myDischargePort;
	self.myLoadPort						:= _releaseRequest.myLoadPort;
	self.myOperator						:= _releaseRequest.myOperator;
	self.myOperatorGroup				:= _releaseRequest.myOperatorGroup;
	self.myOperatorTerminal				:= _releaseRequest.myOperatorTerminal;
	self.myPoolPartner					:= _releaseRequest.myPoolPartner;
	self.myTerminal						:= _releaseRequest.myTerminal;
	self.myTransferToTerminal			:= _releaseRequest.myTransferToTerminal;
	self.myVoyage						:= _releaseRequest.myVoyage;
	self.needsReview					:= _releaseRequest.needsReview;	// par 28696
	self.remarksAdditional1				:= _releaseRequest.remarksAdditional1;
	self.remarksAdditional2				:= _releaseRequest.remarksAdditional2;
	self.releaseByType					:= _releaseRequest.releaseByType;
	self.setSubTerminal(_releaseRequest.myTerminal.getConfig(MySubTerminalForOther).CM_SubTerminal);
	self.status							:= _releaseRequest.status;
	self.type							:= _releaseRequest.type;
	
	// Update collections
	self.allPackLocations.clear();
	if self.type = BR_TYPE_PACKING and _releaseRequest.allPackLocations &lt;&gt; null then
		_releaseRequest.allPackLocations.copy(self.allPackLocations);
	endif;
	
	if _releaseRequest.allAvailabilityGrades &lt;&gt; null  and _releaseRequest.allAvailabilityGrades &lt;&gt; self.allAvailabilityGrades then //if it is the same primitive array then this will clear itself and update it with nothing
		self.allAvailabilityGrades.clear();
		_releaseRequest.allAvailabilityGrades.copy(self.allAvailabilityGrades);
	endif;
	
	if _transportMode = TI_TRANSMODE_SHIP_STR then
		self.type			:= BR_TYPE_SHIP;
		
	elseif _transportMode = TI_TRANSMODE_RAIL_STR then
		self.type			:= BR_TYPE_RAIL;
		
	elseif _transportMode = TI_TRANSMODE_ROAD_STR then
		self.type			:= BR_TYPE_ROAD;
		
	endif;
	
	if _wleArray &lt;&gt; null and _wleArray.isNotEmpty then
		create pxyReserveSelection transient;
		pxyReserveSelection.populatePxyFromWle(_wleArray.first, _quantity);
		self.allReserveDetails.add(pxyReserveSelection);
		
	elseif _tiSet &lt;&gt; null and _tiSet.isNotEmpty then
		foreach ti in _tiSet do
			create  pxyReserveTi transient;
			pxyReserveTi.populatePxyfromPrenote(ti);
			pxyReserveTi.setTotalRequested(ti.totalQuantity);
			self.allReserveDetails.add(pxyReserveTi);
			pxyReserveTi.addTI(ti);
			
		endforeach;
		
	endif;
	
end;</source>
        <Parameter name="_releaseRequest" type="CM_BulkRelease"/>
        <Parameter name="_wleArray" type="CM_WLEArray"/>
        <Parameter name="_tiSet" type="CM_TISet"/>
        <Parameter name="_quantity" type="Integer"/>
        <Parameter name="_transportMode" type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="72f5be2a-47c1-4394-b9f5-e5d681a05405">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:     20 February 2001 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

/* Changes

Date		Name	TFS#			Description
============================================================================
11/07/2008	cnwkpd1	PAR #17486  	Tidy up created proxies if there's an exception
21/04/2011	cnwmh5	PAR #27401 		Move the return to above the epilog
09/11/2011	cnwrs1	CCMS POL 2122 
					/ PAR 28696 - 	New property allEDIFiles
26/04/2012	cnwcs5	CCMS POL 2172 
					/ PAR 29480 - 	New property stopEDIUpdates
24/01/2019	jlgka1	41708			New property myBOLIn.					
14/05/2024	navnk30	ChangeRequest 63607: FR | 53127 - Additional Operational Instructions on the Order - Remedial
============================================================================*/

vars
	proxyBulkRelease		: CM_BulkRelease;
	persistentReq			: CM_Request;
	proxyReq				: CM_Request;
	pxyReserve,realReserve	: CM_ReserveDetail;
	pxyInstructions			: CM_InstructionsIssued;
	pxyEmailTemplate		: CM_EmailTemplate;
	completedOK				: Boolean;
	
begin
	proxyBulkRelease := inheritMethod();
	
	proxyBulkRelease.myBookingRefStock		:= self.myBookingRefStock;
	proxyBulkRelease.myCargoType			:= self.myCargoType;
	//proxyBulkRelease.myFreightForwarderTerminal	:=	self.myFreightForwarderTerminal;	// removed for PAR 20646
	proxyBulkRelease.myLoadPort				:= self.myLoadPort;
	proxyBulkRelease.myDestinationPort		:= self.myDestinationPort;	// 04 Nov 2009	NDL	Par 21519
	proxyBulkRelease.myAssignedTrain		:= self.myAssignedTrain;	// 04 Nov 2009	NDL	Par 21519
	proxyBulkRelease.myDischargePort		:= self.myDischargePort;
	proxyBulkRelease.myOperator				:= self.myOperator;
	proxyBulkRelease.myOperatorGroup		:= self.myOperatorGroup;
	proxyBulkRelease.myTerminal				:= self.myTerminal;
	proxyBulkRelease.myTransferToTerminal	:= self.myTransferToTerminal;
	proxyBulkRelease.myISOGroup				:= self.myISOGroup;
	proxyBulkRelease.myVoyage				:= self.myVoyage;
	proxyBulkRelease.myBusinessUnit			:= self.myBusinessUnit;
	proxyBulkRelease.myPoolPartner			:= self.myPoolPartner;
	proxyBulkRelease.mySubTerminal			:= self.mySubTerminal; 		//16/04/2009 cnwdz2 ccms1735
	proxyBulkRelease.mySubTerminalTarget	:= self.mySubTerminalTarget;// cnwrd1 par 23219 17.3.2010
	proxyBulkRelease.myBOLIn				:= self.myBOLIn; // jlgka1 TFS 41708
	
	if self.myInstructions &lt;&gt; null then					//14.05.2024 navnk30 #63607
		pxyInstructions	:= self.myInstructions.pxyCreateUpdateProxy();
		pxyInstructions.setProxy(pxyInstructions.internalInstructions, 
				pxyInstructions.externalInstruction,
				pxyInstructions.myInstructionType,
				proxyBulkRelease);
	endif;
	
	
	self.allTrackedItemsAssigned.copy(proxyBulkRelease.allTrackedItemsAssigned);
	self.allTrackedItemsReleased.copy(proxyBulkRelease.allTrackedItemsReleased);
	
	foreach persistentReq in self.requests do
		proxyReq := persistentReq.pxyCreateUpdateProxy();
		proxyReq.setBulkRelease(proxyBulkRelease);
	endforeach;

	foreach realReserve in self.allReserveDetails do
		pxyReserve := realReserve.pxyCreateUpdateProxy();
		pxyReserve.setMyHeader(proxyBulkRelease);
	endforeach;
	
	foreach realReserve in self.allReservePackingChildren do
		pxyReserve := realReserve.pxyCreateUpdateProxy();
		pxyReserve.setMyHeader(proxyBulkRelease);
	endforeach;

	if self.myEmailTemplate &lt;&gt; null then	//Par 19427. April 2009 cnwvu1
		pxyEmailTemplate := self.myEmailTemplate.pxyCreateUpdateProxy();
		pxyEmailTemplate.setMyParent(proxyBulkRelease);
	endif;
	
	self.allEDIFiles.copy(proxyBulkRelease.allEDIFiles);			// CCMS POL 2122 / cnwrs1
	
	proxyBulkRelease.blockEDIUpdates := self.blockEDIUpdates;	// CCMS POL 2172 / par 29480
	
	completedOK := true;			// PAR #17486
	return proxyBulkRelease;
	
epilog
	if not completedOK then			// PAR #17486
		delete proxyBulkRelease;
	endif;
	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="quantityOnSiteWithJobRail" id="1100a4e3-ee7e-43fb-984e-dc0c2688fc62">
        <source>quantityOnSiteWithJobRail():Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date				Who		Reason
31 July 2009		cnwndl1	Initial creation
14 November 2022	jlizm1	TFS 54118 Assigning Releases to Wagons
*/

vars
	count : Integer;
	req : CM_Request;
	tmpWeight : Decimal[14,4];
begin
	foreach req in self.allRequestsBeingActioned do
		if req.isKindOf(CM_DeliveryRequest) then
			if req.isAnyAmount then	// TFS 54118
				count := count + req.CM_DeliveryRequest.getTotalActionedForAnyAmount(tmpWeight); // TFS 54118
			else
				count := count + req.CM_DeliveryRequest.totalRequested;
			endif;
		endif;
	endforeach; 
epilog
	return count;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="quantityRemaining" id="08d01381-0249-433c-97aa-7d6a2abc8004">
        <methodInvocation>mapping</methodInvocation>
        <source>quantityRemaining(set: Boolean; _value: Integer io) mapping;
//Returns the number of items still to be released on this bulk release
//if you are considering changing this SEE "quantityRemainingRail" method as well....
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;

/*	//th2 30/05/2007 - in the event this is a split release, the releasedItemStrings is cleared
	//and the previously released TIs are preseved in the self.allTrackedItemsReleased collection
	_value := self.totalRequested - self.releasedItemStrings.size - self.getNumItemsBeingActioned;
*/
	if self.type = BR_TYPE_PACKING then		// 16/06/2008 cnwar2 #17104
		_value := self.getTotalRequested - self.getPackQuantity;
	else
		_value := self.getTotalRequested - self.releasedItemStrings.size - self.getNumItemsBeingActioned;
	endif;
	
	if _value &lt; 0 then
		_value :=  0;		//Sanity value
	endif;	
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="quantityRemainingRail" id="442577bf-2897-4995-ada5-b20fd0514d54">
        <source>quantityRemainingRail():Integer;

/*

Purpose:	
			if you are considering changing this SEE "quantityRemaining" method as well....
			
			
			We needs to return only the onsite NO JOB totals.

Parameters:			

Return Value:		


Date		Who		Reason
31 July 2009	cnwndl1	Initial creation

*/

vars

	remaining : Integer;
	beingActioned : Integer;
	req : CM_Request;

begin

	if self.type = BR_TYPE_PACKING then	
		remaining := self.getTotalRequested - self.getPackQuantity;
	else
		beingActioned := 0;
		foreach req in self.allRequestsBeingActioned do
			if req.isKindOf(CM_DeliveryRequest) then
				beingActioned := beingActioned + req.CM_DeliveryRequest.totalRequested;
			endif;
		endforeach; 
		remaining := self.getTotalRequested - self.releasedItemStrings.size - beingActioned;
	endif;
	
	if remaining &lt; 0 then
		remaining :=  0;
	endif;	

epilog
	
	return remaining;
	
end;</source>
        <ReturnType type="Integer"/>
