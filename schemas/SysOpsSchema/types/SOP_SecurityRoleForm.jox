    <JadeMethod name="isTopLevel" id="e16763ad-14e8-4cea-b74d-712b0a2efa31">
        <source>isTopLevel() : Boolean;
// ---------------------------------------------------------------------------
// Created:     21 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.myCurrentObject = null then
		return false;
	endif;

	return (self.allRootRoles.includes(self.myCurrentObject.CM_SecurityRole));

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadDataForFirstTime" id="d70e08b3-bd7f-4a35-b734-1b2b5374c2ee">
        <updating/>
        <source>loadDataForFirstTime() updating, protected;
//--------------------------------------------------
// Created:	21 August 2003 By: cnwgd1
//--------------------------------------------------
// Changed On	By			Reason
// ----------	--------	-------------------------------------------
// 21/03/2018	jlgdap1		TFS 37445 PEl1 Voyage Status Security
// 23/09/2022 	navds20 	ChangeRequest 54253: EUP - VAS Work Orders
vars

begin
	inheritMethod();

	create self.myPermissionAgent transient;
	self.myPermissionAgent.populatePermissionDict(true, true, 0);

	cmbMode.addItem(ViewSystem);
	cmbMode.addItem(ViewTerminal);
	
	cmbMode.text := ViewSystem;

	app.myRoot.getAllQryReports(self.allQryReports);	
		
	self.initTblInput();
	self.initTblPermissions();
	self.initMulToDoTasks();
	self.initMulStopsView();
	self.initMulStopsMaint();
	self.initMulStopsDelete();		// cnwdad1 03/06/2010 - CCMS 1129.
	self.initMulReports();
	self.initMulTransType();
	self.initMulStatusMaint();			// TFS 37445
	self.initMulInvoiceStatus(); // TFS 39618	
	self.initMulVolDescReasons();	// 30/4/19 MAP TFS41707
	self.initMulWorkOrderStatus(); // 23/09/2022 navds20 TFS 54253
	self.initMulEventTypes();	//09 Mar 2020	NDL	TFS 48784
	self.fillTableForUsers();
	
	beginClassNotification(CM_SecurityRole, false, Any_System_Event, Response_Continuous, 0);

	fldPermissions.topSheet := shtRoleDefn;

	self.doChangeMode(cmbMode.text);
	self.btnAllowAll.enabled := false;
	self.btnDisallowAll.enabled := false;
	
	self.doResize();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="loadDataTableForUsers" id="cc378d8c-13f1-4d66-89f8-140334af6556">
        <source>loadDataTableForUsers( _theTable: CM_DataTable input );
//-----------------------------------------------------
//	Created:	26 Jan 2006	by cnwvu1
//  28 September 2022	navmv20	Bug 54803: MTN - Superuser/Opsview/JMTSupport appearing on security roles form
//-----------------------------------------------------

vars
	user	: CM_User;	
	userSet	: CM_UserSet;
	str		: String;
	idx		: Integer;
begin

	create userSet transient;
	
	if (not self.mode=self.Mode_Add) then
		self.myCurrentObject.CM_SecurityRole.getAllUsers(userSet);
	endif;
	
	_theTable.rows := _theTable.fixedRows;
	foreach user in userSet discreteLock do
		if self.includeObject(user,app.myPassport) then //28/09/2022 navmv20 TFS 54803
			str := user.getAttributeStringForDefArray( _theTable.allTblDataEntRows );
			idx := _theTable.addItemObject( user, str );
		endif;		//28/09/2022 navmv20 TFS 54803
	endforeach;

epilog
	delete userSet;
	
end;
</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
