    <JadeMethod name="addISOGroup" id="5164613a-9cf5-4a72-b1ff-944e2d07fa92">
        <source>addISOGroup(_isoGroupId, _isoGroupDesc : String; _isoTypes : CM_ISOTypeByCodeDict ; _substituteISOGroups :  CM_ISOTypeGroupByCodeDict ) : CM_ISOTypeGroup;

/*

Purpose:		Add an ISO Type

Date			Who		Reason
29/11/2011		cnwmh5	Initial creation

*/

vars

	pxyISOGroup					: CM_ISOTypeGroup;
	isoGroup					: CM_ISOTypeGroup;
		
begin

	self.deleteISOGroup(_isoGroupId);

	create pxyISOGroup transient;
	
	pxyISOGroup.setProxy(_isoGroupId, 			// id/code
						 _isoGroupDesc, 		// desription
						 0,						// colour
						 0,						// Report group order
						 null,					// ext ref 1
						 null,					// ext ref 2
						 0, 					// max tare weight
						 0,						// max total weight
						_isoTypes,				// ISO Types
						_substituteISOGroups);		//substitute ISO groups
						  
	app.myTrxCA.trxCreateISOTypeGroup(pxyISOGroup, isoGroup, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return isoGroup;

epilog
	delete pxyISOGroup;
end;</source>
        <Parameter name="_isoGroupId" type="String"/>
        <Parameter name="_isoGroupDesc" type="String"/>
        <Parameter name="_isoTypes" type="CM_ISOTypeByCodeDict"/>
        <Parameter name="_substituteISOGroups" type="CM_ISOTypeGroupByCodeDict"/>
        <ReturnType type="CM_ISOTypeGroup"/>
    </JadeMethod>
    <JadeMethod name="addISOType" id="49c1cb54-bc61-4d53-abb2-0b14b05f8987">
        <source>addISOType(_isoTypeId, _isoTypeDesc : String; _cargoType : CM_CargoType; _general, _flat, _crib, _tank, _openTop, _reefer, _porthole, _integral, _fan, _powered, _frame, _20ft, _30ft, 
		_40ft, _45ft, _53ft, _8ft, _8ft6, _9ft6, _4ft, _4ft3, _canBeTwinLifted, _rotatable : Boolean; _tareWeight : Integer) : CM_ISOType;

/*

Purpose:		Add an ISO Type

Date			Who		Reason
29/11/2011		cnwmh5	Initial creation

*/

vars

	pxyISOType					: CM_ISOType;
	isoType						: CM_ISOType;
		
begin

	self.deleteISOType(_isoTypeId);

	create pxyISOType transient;
	
	pxyISOType.setProxy(_isoTypeId, 			// id/code
						_isoTypeDesc, 			// desription
						_tareWeight,			// tare kilos
						0,						// colour
						_cargoType,				// cargo type
						null,					// iso type group
						_20ft, 				// 20ft
						_30ft,	 			// 30ft
						_40ft,				// 40ft
						_45ft,				// 45ft
						_53ft,				// 53ft
						_4ft3, 					// 4ft 3'
						_4ft, 					// 4ft
						_8ft6,					// 8ft 6'
						_8ft, 					// 8ft
						false, 					// half height
						_9ft6,					// 9ft 6
						_crib, 					// crib
						_fan, 					// fantail
						_flat, 					// flat
						_general,					// general
						_integral, 					// integral		
						false, 					// machinery
						_openTop, 					// open top
						_porthole,					// port hole
						_powered, 					// powered
						_reefer,				// reefer
						_tank,					// tank
						_frame,	//Frame
						_rotatable, 			// Rotatable	//02/10/2025	navkc1 JIRA 36151
						false, 					// not available for entry
						_canBeTwinLifted,		// twin lift capable
						0, 						// max total weight
						0);						// max tare weight
						  
	app.myTrxCA.trxCreateISOType(pxyISOType, isoType, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	return isoType;

epilog
	delete pxyISOType;
end;</source>
