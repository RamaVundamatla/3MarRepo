    <JadeMethod name="isVoyageTrade_Match" id="d6776fb7-e766-4b52-b1ec-9e843a30307d">
        <source>isVoyageTrade_Match(_yaData: CM_YADataObjects) : Boolean;
// -------------------------------------------
// Created 27 May 2005 by cnwdvb1
// -------------------------------------------
vars

	yaData : CM_YAData;
	yaDataObjs : CM_YADataObjects;
	obj : Object;

begin

	//12 Aug 2016	NDL	TFS 2527
	yaData := self.getExtraCriteriaMatchData( YACriteriaType_VoyageTrade );

	if yaData &lt;&gt; null and yaData.isKindOf(CM_YADataObjects) then
		yaDataObjs := yaData.CM_YADataObjects;
		if not yaDataObjs.isEmpty then
			obj := yaDataObjs.getFirstObject;
		endif;
		if obj &lt;&gt; null then
			return _yaData.includes(obj);
		endif;
	endif;
		
	return false;

end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isVoyageVessel_Match" id="c5276a13-6132-4152-992b-3d3a0970c7c3">
        <source>isVoyageVessel_Match(_yaData: CM_YADataObjects): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 March 2023	navmv20 TFS 56216 Task 56217: Jade - New YA Criteria

*/
vars
	vesselType 		: HMS_VesselType;
	countryOfOrigin	: Object;
	str			    : String;

begin
	vesselType := self.myTrackedItem.getVoyageVessel();
	
	if vesselType &lt;&gt; null then
		str := vesselType.code.trimBlanks();
	endif;
	
	// Only priorities will be empty.
	if str &lt;&gt; null and _yaData.isEmpty() then
		return true;
	endif;
	
	return _yaData.visitObjectsUntilTrue(self, CMIF_YAAutoPlanNormal::isVoyageVessel_Compare, str);

end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
