    <JadeMethod name="setupForm" id="e4d0f422-6d0e-4d7a-8224-7407fb35d56c">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     07 August 2003 by cnwrs2
//
// Purpose:     
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/10/2008	consw1		SFW1030 - Remove unused auto plan flags
// 01/11/2012	cnwcs5		par 30475 - remove isUsingAllocations attribute
// ---------------------------------------------------------------------------
vars
	folder	:CMUI_Folder;
begin
	inheritMethod();

	self.initSearchFrame();	
	self.initDataTable();
	
	self.showToolbar 				:= true;
	self.frmToolbarSearch.visible 	:= true;
	self.toolbarStyle 				:= self.ToolbarStyle_ShowNoHide;
	self.txtSummary.backColor 		:= self.colorControlBack;
	
	self.setNavigatorHeading(app.getErrorString(Enquiry));
	
	self.beginClassNotification(CM_TerminalArea, false, self.myTerminal.getTerminalEvent(EVENT_REFRESH_GRID_AREA), Response_Continuous, 0);
	
	self.isSelectorCapable := true;
	
	folder 						:= self.fldDetails;	
	folder.useSheetBackColors 	:= true;
	
	folder.setDefaultSheetBackColors();
	folder.initSheetBackColors();
	
	folder 						:= self.fldSearch;
	folder.useSheetBackColors 	:= true;
	
	folder.setDefaultSheetBackColors();
	folder.initSheetBackColors();
	
	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnEdit.enabled:= false;
		self.btnNew.enabled:= false;
		self.btnDelete.enabled:= false;
		self.tblData.userInputEnabled := false;
		
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="showColourLegend" id="200f2984-a258-4990-8505-cff099dae34e">
        <source>showColourLegend();
//----------------------------------------------------------------
//	Created:	23 August 2007	by cnwvu1
//----------------------------------------------------------------
vars
	colLegend	: CMUI_ColourLegend;
begin

	create colLegend;
	self.setNavigatorHeading(colLegend.caption); 
	colLegend.centreWindow;
	
	colLegend.addLegendItem( app.getErrorString(LabourOnBlockRestriction), Blue, LightRed, null, false );
	colLegend.addLegendItem( app.getErrorString(OverlappingCargoPresent), Blue, Yellow, null, false );				//TFS#53231 NAVSP1 04APR2022
	colLegend.addLegendItem( app.getErrorString(LabourBlockRestr_OverlapCargo), Blue, LightSkyBlue, null, false );	//TFS#53231 NAVSP1 04APR2022
	colLegend.showModal;

epilog
	delete colLegend;

end;
</source>
    </JadeMethod>
