    <JadeMethod name="getAuditText" id="0d65849f-6b0d-4dc7-8004-dfdbea53218f">
        <source>getAuditText(): String;
// ---------------------------------------------------------------------------
// Created:     19 April 2007 by cnwaer1
// Purpose:     
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 22/08/2019	jlgdap1		TFS 45836 PEN Approved Carrier for ISO Type and Trailer Type
vars
	txt				: String;
	tmpStr,term		: String;
	codeGroup 		: CM_CodeGroup;
	opGroup 		: CM_OperatorGroup;
	opTerminal 		: CM_OperatorTerminal;
	opCrit 			: CM_OperatorCarrierCriteria;
begin
	txt[10000] := '*';
	txt := null;
	txt := inheritMethod();
	
//23 July 2019	NDL	TFS 45574 - remove
//	tmpStr := null;
//	tmpStr := self.getEmptyFreeStorageDays.String;
//	txt := txt &amp; ' Empty Free Storage Days' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
//	tmpStr := null;
//	tmpStr := self.getFullFreeStorageDays.String;
//	txt := txt &amp; ' Full Free Storage Days' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
//	tmpStr := null;
//	tmpStr := self.getFreeStorageDays.String;
//	txt := txt &amp; ' General Cargo Free Storage Days' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;
	tmpStr := self.getInwardsChargeRate.String;
	txt := txt &amp; ' Inwards Handling Charge' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;
	tmpStr := self.getPackingCharge20ft.String;
	txt := txt &amp; ' Container Packing Charge 20ft' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;
	tmpStr := self.getPackingCharge40ft.String;
	txt := txt &amp; ' Container Packing Charge 40ft' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;
	tmpStr := self.getConfig(PTIExpiryPeriodDays).String;
	txt := txt &amp; ' PTI Expiry Period Number of Days' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;
	tmpStr := self.getConfig(DefaultFreightPayerCode).String;
	txt := txt &amp; ' Default Freight Payer Code' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;
	tmpStr := self.getConfig(EDITempFormat).String;
	txt := txt &amp; ' EDI Temperature Format' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;

	tmpStr := null;
	tmpStr := self.getCargoReleaseImpFFUpdAllowed.String; // adm 220708 CCMS 1738
	txt := txt &amp; ' Cargo Release Imports Forwarders Update Allowed' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	

	//cnwrd1 4.11.08 CCMS JMT 1743/1764  start
	tmpStr := null;
	tmpStr := self.getRequiresExportOperatorNo().String; 
	txt := txt &amp; ' Requires Export Operator Number ' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;
	tmpStr := self.getRequiresImportFF().String; 
	txt := txt &amp; ' Requires Import Freight Forwarder ' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	tmpStr := null;
	tmpStr := self.getRequiresImpOperatorPIN().String;
	txt := txt &amp; ' Requires Import Operator PIN ' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	//cnwrd1 4.11.08 CCMS JMT 1743/1764  end
	
	// cnwcs5 14/03/2011 par 26909
	tmpStr := null;
	tmpStr := self.getShowOpExportReleaseWarning.String; 
	txt := txt &amp; ' Warn if Cargo Created with no Operator Export Release Number ' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;

//	tmpStr := null;
//	tmpStr := self..String;
//	txt := txt &amp; ' Default Freight Payer Code' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	tmpStr:=null;
	foreach codeGroup in self.allCodeGroups do
		if tmpStr = null then
			tmpStr := codeGroup.name;
		else
			tmpStr := tmpStr &amp; ', ' &amp; codeGroup.name;
		endif;
	endforeach;
	txt := txt &amp; 'Selected Code Groups ' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;	
	tmpStr:=null;
	
	foreach opGroup in self.allOperatorGroups do
		if tmpStr = null then
			tmpStr := opGroup.code;
		else
			tmpStr := tmpStr &amp; ', ' &amp; opGroup.code;
		endif;
	endforeach;
	txt := txt &amp; 'Operator Group selected' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	
	// TFS 45836 Adit changes to the Operator Carrier criteria
	tmpStr := null;
	foreach opCrit in self.allOperatorCarrierCriteria discreteLock do
		if tmpStr = null then
			tmpStr := opCrit.getAuditStringForOperator();
		else
			tmpStr := tmpStr &amp; ", " &amp; opCrit.getAuditStringForOperator();
		endif;
	endforeach;
	txt := txt &amp; 'Operator Carrier Criteria' &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp; tmpStr &amp; AuditStringSeparator;
	// TFS 45836 end
	// The Terminal Operators  changes are saved after the Operator transaction is completed.
	// This need to be done in the same transation with the Operator in order to be edited in the Audit Object.
	// For the moment the Terminal Configuration is not beeing audited.
	
	//tmpStr:=null;
	/*foreach opTerminal in self.allOperatorTerminals do
		term :=opTerminal.myTerminal.code.String ;
		txt := txt &amp; term &amp;' Auto - Weight Full Exports:'  &amp; AuditStringSeparator &amp; opTerminal.weighExports.String.length.String &amp; AuditStringSeparator &amp; opTerminal.weighExports.String &amp; AuditStringSeparator;
		txt := txt &amp; term &amp;' Auto - Weight Full Imports: ' &amp; AuditStringSeparator &amp; opTerminal.weighImports.String.length.String &amp; AuditStringSeparator &amp; opTerminal.weighImports.String &amp; AuditStringSeparator;
		txt := txt &amp; term &amp;' Auto - Weight MT Exports:'    &amp; AuditStringSeparator &amp; opTerminal.weighMTExports.String.length.String &amp; AuditStringSeparator &amp; opTerminal.weighMTExports.String &amp; AuditStringSeparator;
		txt := txt &amp; term &amp;' Auto - Weight MT Imports:'    &amp; AuditStringSeparator &amp; opTerminal.weighMTImports.String.length.String &amp; AuditStringSeparator &amp; opTerminal.weighMTImports.String &amp; AuditStringSeparator;
	endforeach;
	*/
	return txt;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getBOLIn" id="67a11243-4cf3-4359-9911-357f25a287d3">
        <updating/>
        <source>getBOLIn(_bolType: Integer; _number: String; _terminal : CM_Terminal) : CM_BOLIn updating;
//--------------------------------------------------------------
//Created: 18 July 2002 By: cnwsb1
// 
// Returns the most recent BOL In with the given number and type
//
//--------------------------------------------------------------
vars
	itr			: Iterator;
	bol			: CM_BOL;
	foundBOLOut	: CM_BOLIn;
	opTerm		: CM_OperatorTerminal;

begin

	opTerm := self.getOperatorTerminal(_terminal, false);
	if opTerm = null then
		return null;
	endif;

	itr := opTerm.allBOLByTypeNumber.createIterator;
	opTerm.allBOLByTypeNumber.startKeyGeq(_bolType, _number, null, itr);
	
	while itr.next(bol) do
		if bol.bolType &lt;&gt; _bolType or bol.number &lt;&gt; _number then
			break;
		endif;
		if CM_BOLIn.hasInstance(bol) then
			// Set, but keep looking in case there is a later match
			foundBOLOut := bol.CM_BOLIn;
		endif;
	endwhile;
	
	return foundBOLOut;

epilog
	delete itr;
end;</source>
        <Parameter name="_bolType" type="Integer"/>
        <Parameter name="_number" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_BOLIn"/>
    </JadeMethod>
    <JadeMethod name="getBOLOut" id="5f1419c3-efaa-4dde-9d7d-358e89c13f45">
        <updating/>
        <source>getBOLOut(_bolType: Integer; _number: String; _terminal : CM_Terminal) : CM_BOLOut updating;
//--------------------------------------------------------------
//Created: 18 July 2002 By: cnwsb1
// 
// Returns the most recent BOL Out with the given number and type
//
//--------------------------------------------------------------
vars
	itr			: Iterator;
	bol			: CM_BOL;
	foundBOLOut	: CM_BOLOut;
	opTerm		: CM_OperatorTerminal;

begin

	opTerm := self.getOperatorTerminal(_terminal, false);
	if opTerm = null then
		return null;
	endif;

	itr := opTerm.allBOLByTypeNumber.createIterator;
	opTerm.allBOLByTypeNumber.startKeyGeq(_bolType, _number, null, itr);
	
	while itr.next(bol) do
		if bol.bolType &lt;&gt; _bolType or bol.number &lt;&gt; _number then
			break;
		endif;
		if CM_BOLOut.hasInstance(bol) then
			// Set, but keep looking in case there is a later match
			foundBOLOut := bol.CM_BOLOut;
		endif;
	endwhile;
	
	return foundBOLOut;

epilog
	delete itr;
end;</source>
        <Parameter name="_bolType" type="Integer"/>
        <Parameter name="_number" type="String"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <ReturnType type="CM_BOLOut"/>
    </JadeMethod>
    <JadeMethod name="getCargoReleaseImpFFUpdAllowed" id="49325a44-2546-4746-a42f-e940d08bfccc">
        <source>getCargoReleaseImpFFUpdAllowed() : Boolean;
/* ---------------------------------------------------------------------------
Created:     16 July 2008 by cnwrs2

Purpose:     PAR 17562
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin

	// note that we use NOT here so that when release went out did not need
	// to run script to keep weorking as previously
	return (not self.getConfig(CargoReleaseImpFFUpdNotAllowed).Boolean);

epilog

