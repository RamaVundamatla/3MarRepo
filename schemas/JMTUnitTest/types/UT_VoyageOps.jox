    <JadeMethod name="planLoadItems" id="faa30508-034e-41b3-83e8-aa78e6c8f714">
        <updating/>
        <source>planLoadItems(_voyageCode : String; _crane : String) updating;
// cnwer1
/* 

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 December 2008	cnwer1	Initial creation
14 January 2015 added parameters  // PAR 35502
*/

vars
tmpOptionsUsed 	: IntegerArray;
 slots : CM_SlotControllerArray;
 allJobs 		: CM_JobArray;
	jobSheet		: CM_VoyageJobSheet;
	job				: CM_Job;
	allJobSet				: CM_VoyageJobSet;
	controller		: CMIF_ShipPlanningController;
	mode, idx 			: Integer;
	voyage 			: CM_Voyage;
	planIfStops,
	planFromRowEnds,
	useWeights,
	planAccrossTermArea,
	planAccrossTermAreaCol,
	ignoreWarnings,
	planTwinLift	: Boolean;
	
	height,
	numRowSep,
	weightAve,
	weightPC	: Integer;
	gridControler : CM_GridController;
	trackedItem 	: CM_TrackedItem;
	wle : CM_WorkListEntry;
	slot : CM_SlotController;
	theTIs: CM_TIArray;
	moveController : CMIF_MoveController;
	lcs : CM_LCArray;
	wles,wlesWithWarnings : CM_WLEArray;
begin
	
	//need to delete all containers and recreate
	
	self.removeAllStops(_voyageCode);
	self.removeAllRTS(_voyageCode);
	
	create tmpOptionsUsed transient;
	create allJobs transient;
	create controller transient;
	mode:=3; //this is job mode voyage is 1 crane is 2
	voyage := self.getVoyage(_voyageCode);
	jobSheet:=voyage.allJobSheets[_crane];
	
	/*
		//result of trying to rerun this test
		//really should create the voyage and jobs before hand
		won't work if that one job has been completed need to create the job and delete it everytime
		job was marked up as 20 tl for discharge port BNE
	
	*/
	//there's only one job
	foreach job in voyage.allVoyageJobs  discreteLock do
		if job.CM_VoyageJob.isDischarge then
			continue;
		endif;
		allJobs.add(job);
	endforeach;

	
	//not sure why this sets the config when the chk box changes value?
	app.myTrxUA.trxUpdateTerminalConfig(self.getTerminal, AutoLoadPlanAt3Height,false, app.myPassport );
	planAccrossTermArea:=true;
	ignoreWarnings := true;
	
	//self.setYardAreaFlipped();
	controller.init(self.getTerminal,
					mode, 
					allJobs, 
					jobSheet,
					voyage,
					planIfStops,
					tmpOptionsUsed, 
					height, 
					planFromRowEnds,
					numRowSep,
					null,
					useWeights,
					weightAve,
					weightPC,
					planAccrossTermArea,
					planAccrossTermAreaCol,
					ignoreWarnings,
					planTwinLift);
					
	controller.initQuery();
	controller.doQuery(null); // DO THE LOAD PLAN

	
epilog
	delete wles;
	delete wlesWithWarnings;
	delete lcs;
	delete theTIs;
	delete slots;
	delete allJobs;
	delete tmpOptionsUsed;
	delete controller;
	delete allJobSet;
	delete moveController;
end;</source>
        <Parameter name="_voyageCode" type="String"/>
        <Parameter name="_crane" type="String"/>
    </JadeMethod>
    <JadeMethod name="removeAllRTS" id="d5ae2150-5c58-47e8-a6cd-15ce9187d975">
        <updating/>
        <source>removeAllRTS(_voyCode : String) updating;
// ---------------------------------------------------------------------------
// Created:     January 2009 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//  // PAR 35502 added parameters
// ---------------------------------------------------------------------------

vars
	voy : CM_Voyage;
	theTIs: CM_TIArray;
begin
	create theTIs transient;
	
	voy := self.getVoyage(_voyCode);
	
	voy.allOnsiteTIsByCargoTypeId.copy(theTIs);
	app.myTrxUA.trxUpdateTIsReadyToShip(theTIs, true, app.myPassport);
	self.assertTrueMsg(app.myPassport.allErrorWarnings.isEmpty(), app.myPassport.getAllErrorsWarningsAsString());
epilog
	delete theTIs;
end;</source>
        <Parameter name="_voyCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="removeAllStops" id="3bed92ab-89c7-4091-ad94-cce5ad8a6239">
        <updating/>
        <source>removeAllStops(_voyCode : String) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 February 2009	cnwer1	Initial creation

*/

vars
	ti : CM_TrackedItem;
	voy : CM_Voyage;
begin
	voy := self.getVoyage(_voyCode);
	self.opts.purge;
	self.opts.addAssoc("CENum", "144");

	foreach ti in voy.allOnsiteTIsByCargoTypeId discreteLock do
			self.deleteStops(ti);
	endforeach;

	foreach ti in voy.allOnshipTIsByCargoTypeId discreteLock do
			self.deleteStops(ti);
	endforeach;
epilog

end;</source>
        <Parameter name="_voyCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="setCraneWeightDiff" id="d0ae348b-22fa-4970-900b-c40f756fc5d4">
        <updating/>
        <source>setCraneWeightDiff(_crane : CM_Crane input; _weight : Integer) updating;
/*
Purpose:			
Date		Who		Reason
22 August 2013	NAVAB1	Initial creation
*/

vars

begin
	if _crane = null then
		return;
	endif;
	
	beginTransaction;
		_crane.setPropertyValue("weightDifference", _weight);
	commitTransaction;
epilog

end;</source>
        <Parameter name="_crane" type="CM_Crane" usage="input"/>
        <Parameter name="_weight" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tAssignRotaRelToVoyage" id="791af5fe-1406-46a0-93aa-b82cdddc273a">
        <source>tAssignRotaRelToVoyage();
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
10 November 2025		jlizm1	Initial creation MTN 36328 Rotabox Assign Release To Vessel Unit Test

*/

constants
	VesselCode 		: String = 'SCONRO';
	Voyagecode 		: String = 'DRCONRO';
	BULKCargoType 	: String = "UTZBULK";
	ProductID		: String = "UTZBULKST";
	CommodityID	 	: String = "ZCOM";
	
	BSTACKID		: String = "BS54118";
	UTISOTYPE 		: String = "UZR2";
	
	DRWorkPoint 	: String = "DRWP";
	REL_ID			: String = "UTZR251104";
	ContId1			: String = "ZJMU2511041";
	ContId2			: String = "ZJMU2511042";

	IMV1 			: String = "UTIM";
	FLS				: String = "FLST";
	
vars
	operator 		: CM_Operator;
	voyage 			: CM_Voyage;
	shipLineStr 	: String;
	dischargePort	: CM_Port;
	
	cont1 			: CM_Container;
	cont2 			: CM_Container;
	ti 				: CM_TrackedItem;
	
	iso				: CM_ISOType;
	bulkCargoType 	: CM_CargoType;
	containerCType	: CM_CargoType;
	product			: CM_Product;
	allCommodities	: CM_CommodityByCodeDict;
	commodity		: CM_Commodity;
	allCargoTypes	: ObjectArray;
	
	allHolds		: CM_LCArray;
	hold1 			: CM_LocationsController;
	hold2 			: CM_LocationsController;
	
	releaseRequest	: CM_BulkRelease;
	resDet			: CM_ReserveDetail;
	reserveSelection : CM_ReserveSelection;
	workPoint 		: CM_WorkPoint;
	
	blockStack		: CM_BlockStack;
	
	job 			: CM_VoyageHoldJob;
	machine		 	: CM_Machine;
	imv				: CM_Machine;
	queue			: CM_VoyageQueue;
	wpQueue			: CM_RadioTelemetryQueue;
	tas				: StringArray;
	cargos 			: CM_CargoTypeSet;
	wle				: CM_WorkListEntry;
	wle2			: CM_WorkListEntry;
	queueEntry		: CM_RTQueueEntry;
	rtqTask			: CM_RTQueueTask;
	agent 			: CMIF_MobileGenericAgent;
	result			: Boolean;
	
begin
	//get base data
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	shipLineStr := self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString;
	dischargePort := app.myRoot.allPorts["NZAKL"];
	
	create allCommodities transient;
	commodity := self.addCommodity(CommodityID, "UT Z Commodity", allCargoTypes);
	allCommodities.add(commodity);
	
	self.opts.purge();
	self.opts.addAssoc("CreateClass", "CM_Bulk");
	self.opts.addAssoc("TrackAs", ProductType_Bulk);
	self.opts.addAssoc("AllowDuplicateId", true);
	self.opts.addAssoc("Comodities", allCommodities);
	bulkCargoType := addCargoType(BULKCargoType, false);
	self.opts.purge();
	
	// Get Product
	self.opts.purge();
	product := self.addProduct(ProductID, null, bulkCargoType);
	
	// Get Cargo Type Container
	containerCType := self.getCargoType("CONT");
	self.assertNotNullMsg(containerCType, "Failed to get Cargo Type Container");
	
	///************************
	//clean-up old data - if it exists
	//*************************
	self.deleteContainer(ContId1);
	self.deleteContainer(ContId2);
	self.deleteReleaseRequest(REL_ID);
	self.deleteTerminalArea(BSTACKID);
	self.deleteVoyage(Voyagecode);
	self.deleteMachine(IMV1);
	self.deleteMachine(FLS);
	
	//create new base data
	voyage := self.addVoyageWithConRORO(Voyagecode, VesselCode, operator.code, shipLineStr, null, 0, false, true);
	self.assertTrueMsg(voyage &lt;&gt; null, "'Voyage' not created during setup");
	
	hold1 := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace.first;
	hold2 := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace.last;
	self.assertNotNullMsg(hold1, "Voyage doesn't have any holds");
	self.assertNotEqualMsg(hold2, hold1, "Voyage doesn't have enough holds");
	
	blockStack := self.addBlockStack(BSTACKID, 32, null);
	
	// Get ISO Type
	iso := self.addISOType(UTISOTYPE, "UT ROTA ISO TYPE", containerCType, false, false, false, false, false, true, false, false, false, false, false, true, false, false, false, false, false, false, false, false, false, true, true, 1000);
	
	// create Release
	self.opts.purge;
	self.opts.addAssoc("ISOType", UTISOTYPE);
	self.opts.addAssoc("ContentsCargoType", bulkCargoType);
	self.opts.addAssoc("Product", product);
	self.opts.addAssoc("Voyage", voyage);
	self.opts.addAssoc("DischargePort", dischargePort);
	self.opts.addAssoc("TerminalArea", blockStack);
	self.opts.addAssoc("FullRelease", true);
	self.opts.addAssoc("Number", 2);
	releaseRequest := self.addReleaseByTypeRequestOpts(REL_ID, BR_TYPE_SHIP, TI_CargoType_Container);
	self.assertNotNullMsg(releaseRequest, "releaseRequest");
	self.assertEqualMsg(releaseRequest.allReserveDetails.size, 1, "Not correct number of release lines");
	resDet := releaseRequest.allReserveDetails.first;
	self.assertTrueMsg(resDet &lt;&gt; null, "No reserve detail attached to release request");
	self.assertTrueMsg(resDet.isKindOf(CM_ReserveSelection), "release is not by type");
	reserveSelection := resDet.CM_ReserveSelection;
	self.assertEqualMsg(reserveSelection.myContentsCargoType, bulkCargoType, "Release doesn't have the correct contents cargo type");
	self.assertEqualMsg(reserveSelection.myProduct, product, "Release doesn't have the correct contents cargo subtype");
	
	// create onsite rotatable containers
	self.opts.purge();
	self.opts.addAssoc("cargoTypeForContents", bulkCargoType);
	self.opts.addAssoc("cargoSubTypeForContents", product);
	cont1 :=  self.addContainerAtLocation(ContId1, operator, UTISOTYPE, CommodityID, TI_IMEX_STATUS_STORAGE, blockStack);
	self.assertTrueMsg(cont1 &lt;&gt; null, "'" &amp; ContId1 &amp; "' not created during setup");
	self.assertEqualMsg(cont1.getCargoTypeForContents, bulkCargoType, "cont 1 created with incorrect contents cargo type");
	self.assertEqualMsg(cont1.myProduct, product, "cont 1 created with incorrect contents cargo subtype");
	cont2 :=  self.addContainerAtLocation(ContId2, operator, UTISOTYPE, CommodityID, TI_IMEX_STATUS_STORAGE, blockStack);
	self.assertTrueMsg(cont2 &lt;&gt; null, "'" &amp; ContId2 &amp; "' not created during setup");
	self.assertEqualMsg(cont2.getCargoTypeForContents, bulkCargoType, "cont 2 created with incorrect contents cargo type");
	self.assertEqualMsg(cont2.myProduct, product, "cont 2 created with incorrect contents cargo subtype");
	
	self.opts.purge();
	self.opts.addAssoc("TotalWeight", 4500);
	self.opts.addAssoc("TareWeight", 2000);
	self.opts.addAssoc("CargoWeight", 2500);
	self.updateTI(cont1);
	self.updateTI(cont2);
	self.opts.purge();
	// ## CLEARUP ANY STOPS ADDED
	self.deleteStops(cont1);
	self.deleteStops(cont2);
	
	
	//**************
	//Setup Machines
	//**************
	workPoint := self.getWorkpoint(DRWorkPoint);
	self.assertNotNullMsg(workPoint, "workpoint");
	
	self.addMachineRule(blockStack, workPoint.myWorkPointInterchangeArea, RTMoveMethod_1);
	
	// ### ADD RTQUEUES
	queue := self.addVoyageQueue(voyage);
	beginTransaction;
	queue.createWorkPointQueue(workPoint, wpQueue);
	commitTransaction;
	self.assertNotNullMsg(wpQueue, "work point Queue");
	self.assertTrueMsg(wpQueue.isKindOf(CM_VoyageWorkPointQueue), "wpQueue not a WorkPointQueue");
	
	create allHolds transient;
	allHolds.add(voyage.myShipBlockStack);
	allHolds.add(hold1);
	allHolds.add(hold2);
	self.allocateHoldsToWPQueue(voyage, allHolds, workPoint);
	
	create tas transient;
	tas.add(BSTACKID); // source
	tas.add(workPoint.myWorkPointInterchangeArea.id);	// target
	machine := self.addMachine(MACHINETYPE_FORK_LIFT, FLS, 94, tas, wpQueue.id);
	
	create cargos transient;
	cargos.add(containerCType);
	cargos.add(bulkCargoType);
	beginTransaction;
	machine.setCargoTypes(cargos);
	commitTransaction;
	imv := self.addIMV(IMV1, 93, tas, wpQueue.id);
	self.machineAssignToQueue(imv, wpQueue);
	
	// create job
	app.myTrxCA.trxCreateHoldJobForRelReq(resDet, job, hold1, 2, 0);
	self.assertNoTrxErrors();
	self.assertTrueMsg(job &lt;&gt; null, "failed to create voyage job");
	self.assertEqualMsg(job.workListEntries.size, 2, "Unexpected number of wles");
	wle := job.workListEntries.first;
	wle2 := job.workListEntries.last;
	
	//**************
	// Perform the moves
	//**************
	
	// forklift - first part of move
	self.machineLogon(machine);
	queueEntry := wle.getFirstUncompleteRTEntry();
	self.assertNotNullMsg(queueEntry, "1st queueEntry");
	self.machineAssignToQueue(machine, queueEntry.myQueue);
	self.machineAcceptSpecifiedTask(machine, queueEntry);
	self.machineDirector(machine, cont1);
	self.machineSetdownTask(machine, queueEntry.allTasks.last , IMV1);
	
	self.assertEqualMsg(cont1.myPrimaryActualLocation, imv.getMyVehicleMachineController(), "cont not on imv");
	
	self.assertEqualMsg(hold1.allTrackedItems.size, 0, "voyage hold should be empty");
	// imv - second part of move
	create agent transient;
	agent.setMyTerminal(self.getTerminal());
	agent.setMyVoyage(voyage);
	agent.setDoNotShowMsgBox(true);
	result := agent.doLanderLoad(cont1, hold1, wle, 0, 0);
	
	self.checkTrxResult();
	self.assertTrueMsg(result, "failed to load to voyage");
	self.assertEqualMsg(hold1.allTrackedItems.size, 1, "incorrect cargo in voyage hold");
	ti := hold1.allTrackedItems.first;
	self.assertEqualMsg(ti.totalWeight.Integer, 2500, "incorrect cargo weight in voyage hold");
	self.assertEqualMsg(ti.myCargoType, bulkCargoType, "cargo type should be the same as the rota contents was");
	self.assertTrueMsg(cont1 &lt;&gt; null, "empty container1 should remain");
	self.assertNotEqualMsg(ti, cont1, "cargo should have seperated");

	// Second Move
	// forklift - first part of move
	queueEntry := wle2.getFirstUncompleteRTEntry();
	self.assertNotNullMsg(queueEntry, "2nd queueEntry");
	self.machineAssignToQueue(machine, queueEntry.myQueue);
	self.machineAcceptSpecifiedTask(machine, queueEntry);
	self.machineDirector(machine, cont2);
	self.machineSetdownTask(machine, queueEntry.allTasks.last , IMV1);
	self.assertEqualMsg(cont2.myPrimaryActualLocation, imv.getMyVehicleMachineController(), "cont not on imv");
	
	// imv - second part of move
	delete agent;
	create agent transient;
	agent.setMyTerminal(self.getTerminal());
	agent.setMyVoyage(voyage);
	agent.setDoNotShowMsgBox(true);
	result := agent.doLanderLoad(cont2, hold1, wle2, 0, 0);
	self.checkTrxResult();
	self.assertTrueMsg(result, "failed to load to voyage");
	self.assertEqualMsg(hold1.allTrackedItems.size, 1, "should shouldve merged with exsting cargo");
	ti := hold1.allTrackedItems.first;
	self.assertEqualMsg(ti.totalWeight.Integer, 5000, "incorrect cargo weight in voyage hold");
	self.assertEqualMsg(ti.myCargoType, bulkCargoType, "cargo loaded to voyage has incorrect cargo type");
	self.assertEqualMsg(ti.myProduct, product, "cargo loaded to voyage has incorrect cargo subtype");
	self.assertTrueMsg(cont2 &lt;&gt; null, "empty container1 should remain");
	self.assertNotEqualMsg(ti, cont2, "cargo should have seperated");

	//*************************
	// Cleanup after ourselves
	//*************************
	self.machineLogOff(machine);
	self.deleteReleaseRequest(REL_ID);
	self.deleteContainer(ContId1);
	self.deleteContainer(ContId2);
	self.deleteTerminalArea(BSTACKID);
	self.deleteCargoType(BULKCargoType);
	self.deleteISOType(UTISOTYPE);
	self.deleteVoyage(Voyagecode);
	self.deleteMachine(IMV1);
	self.deleteMachine(FLS);
	self.deleteCommodity(CommodityID);
	
epilog
	delete tas;
	delete cargos;
	delete allHolds;
	// delete allCommodities happens in addCargoType so doesn't need to happen here
	delete allCargoTypes;
	delete agent;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tBargeCreateCopyChg" id="7961ab0f-4e21-4080-89f5-72852385d0b3">
        <source>tBargeCreateCopyChg();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Jun 2020	jlgndl1	Initial creation	TFS 49417
21 May 2021	navdap1	TFS 50878 ASPA Bulk Barge Cargo Creation
*/

constants

	Vessel1 : String = "BARGE1";
	Vessel2 : String = "BARGE2";
	BargePrefix1 : String = "BARGVOYONE";
	BargePrefix2 : String = "BARGVOYTWO";

vars

	operator1 : CM_Operator;
	operator2 : CM_Operator;
	vessel1 : CM_Vessel;
	vessel2 : CM_Vessel;
	trade1 : CM_Trade;
	trade2 : CM_Trade;
	shipLine1 : CM_ShippingLine;
	shipLine2 : CM_ShippingLine;
	eventTypes : CM_EventTypeSet;
	eventType : CM_EventType;
	
	terminal : CM_Terminal;
	bank : CM_Bank;
	extReference : String;
	arrDateTime : TimeStamp;
	depDateTime : TimeStamp;
	dummyVoyage : CM_Voyage;
	pxyVoyage : CM_Voyage;
	realVoyage : CM_Voyage;
	now : TimeStamp;
	allPxyVoyages : CM_VoyageArray;
	voyageName : String;
	testNumber : String;
	realBaseVoyage : CM_Voyage;
	checkVessel : CM_Vessel;
	steveDict : CM_StevedoreByCodeDict;		//29 Jun 2020	NDL	TFS 49681
	vessels : CM_ObjectArray;			// TFS 50878
	evType : CM_EventType;
begin
	//cleanup
	self.deleteVoyage(BargePrefix1 &amp; '1');
	self.deleteVoyage(BargePrefix1 &amp; '2');
	self.deleteVoyage(BargePrefix2 &amp; '2');
	self.deleteVoyage(BargePrefix2 &amp; '3');
	
	self.deleteVessel(Vessel1);
	self.deleteVessel(Vessel2);
	
	//setup
	terminal := self.getTerminal;
	operator1 := app.myRoot.allOperators.getAtKey("DOUG");
	trade1 := app.myRoot.allTradesByDescription.getAtKey("Doug World");
	shipLine1 := app.myRoot.allShippingLines.getAtKey("DOUG");
	
	self.opts.purge();
	self.opts.addAssoc("isBarge",true);
	self.opts.addAssoc("VesselTrade",trade1);
	self.opts.addAssoc(ETRow_LloydsNumber,"491671");
	self.opts.addAssoc("ShippingLine",shipLine1);
	self.opts.addAssoc(ETRow_CallSign,"Duggy");
	self.opts.addAssoc("YearOfBuild",2019);
	vessel1 := addVesselCellular( Vessel1, operator1 );
	
	operator2 := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	trade2 := self.getTrade();
	shipLine2 := self.getShippingLineObj();
	
	self.opts.purge();
	self.opts.addAssoc("isBarge",true);
	self.opts.addAssoc("VesselTrade",trade2);
	self.opts.addAssoc(ETRow_LloydsNumber,"491672");
	self.opts.addAssoc("ShippingLine",shipLine2);
	self.opts.addAssoc(ETRow_CallSign,"Doofus");
	self.opts.addAssoc("YearOfBuild",2020);
	vessel2 := self.addVesselGeneralCargo( Vessel2, operator2, 1 );
	
	//Use the 'Multi Barge Create' to create two barge voyages from the 1st template barge vessel
	
	create eventTypes transient;
	//eventType := app.myRoot.allEventTypesByType.getAtKey(11453); //Barge Cleaning
	foreach evType in app.myRoot.allEventTypesByType discreteLock do
		if  evType.description = 'Barge Cleaning' then
			eventType := evType;
			break;
		endif;
	endforeach;
	self.assertTrueMsg( eventType &lt;&gt; null, "Event type not found during setup");
	eventTypes.add( eventType );
	
	bank := terminal.getDefaultCompanyBank();
	extReference := "ExternalRefOne";
	arrDateTime.setDate( now.date );
	arrDateTime.setTime( now.time.cnEcAddMinutes(-1) );
	depDateTime.setDate( now.date + 1 );
	depDateTime.setTime( now.time.cnEcAddMinutes(1) );
	
	create steveDict transient;		//29 Jun 2020	NDL	TFS 49681
	create dummyVoyage transient;
	dummyVoyage.setArrivalDepartureDT( arrDateTime, depDateTime, false);
	dummyVoyage.pxySetBaseBarge( operator1, shipLine1, bank, extReference, vessel1 );
	//29 Jun 2020	NDL	TFS 49681
	dummyVoyage.setRemarks( "Remarkable", false );
	steveDict.clear(); steveDict.add( CM_Stevedore.firstInstance );
	steveDict.copy( dummyVoyage.myHMSVoyageData.allStevedoresDischarge );
	steveDict.clear(); steveDict.add( CM_Stevedore.lastInstance );
	steveDict.copy( dummyVoyage.myHMSVoyageData.allStevedoresLoad );
	
	pxyVoyage := dummyVoyage.pxyFromBargeUsingVesselAndCode( vessel1, BargePrefix1 &amp; "1", terminal );
	delete dummyVoyage;
	
	create vessels transient;			// TFS 50878
	
	while true do
		// TFS 50878 add base vessel to array 2 times (creating 2 vyages, all with same vessel)
		vessels.clear;
		vessels.add(vessel1);
		vessels.add(vessel1);
		// TFS 50878 end
		
		//app.myTrxCA.trxCreateBarges( pxyVoyage, eventTypes, BargePrefix1, 2, 1, app.myPassport );					// TFS 50878
		app.myTrxCA.trxCreateBarges( pxyVoyage, eventTypes, BargePrefix1, 2, 1, null, vessels, app.myPassport );	// TFS 50878
		if app.myPassport.trxCompletedOK then
			break;	
		elseif not app.myPassport.hasErrors then
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
		break;
	endwhile;
	delete pxyVoyage;
	
	voyageName := BargePrefix1 &amp; "1";
	testNumber := " (Test 1)";
	checkVessel := vessel1;
	realVoyage := self.getVoyage( voyageName );
	self.assertTrueMsg( realVoyage &lt;&gt; null, voyageName  &amp; " Voyage not found" &amp; testNumber &amp; " : " &amp; app.myPassport.getErrorsAndWarningsAsString);
	self.assertTrueMsg( realVoyage.myTrade = trade1, voyageName  &amp; " Trade should be " &amp; trade1.description &amp; testNumber );
	self.assertTrueMsg( realVoyage.myShippingLine = shipLine1, voyageName  &amp; " Shippimg Line should be " &amp; shipLine1.description &amp; testNumber );
	self.assertTrueMsg( realVoyage.externalRef = extReference, voyageName  &amp; " External Ref should be " &amp; extReference &amp; testNumber );
	self.assertTrueMsg( realVoyage.myHMSVoyageData.dim_LengthOverall = checkVessel.myHMSVesselData.dim_LengthOverall, voyageName  &amp; " LOA should be " &amp;  checkVessel.myHMSVesselData.dim_LengthOverall.String &amp; testNumber );
	self.assertTrueMsg( realVoyage.callSign = checkVessel.callSign, voyageName  &amp; " Call sign should be " &amp;  checkVessel.callSign &amp; testNumber );
	self.assertTrueMsg( realVoyage.lloydsNumber = checkVessel.lloydsNumber, voyageName  &amp; " Lloyds Number should be " &amp;  checkVessel.lloydsNumber &amp; testNumber );
	self.assertTrueMsg( realVoyage.yearOfBuild = checkVessel.yearOfBuild, voyageName  &amp; " Year Of Build should be " &amp;  checkVessel.yearOfBuild.String &amp; testNumber );
	self.assertTrueMsg( realVoyage.allEventTransactionsByType.size = 1, voyageName  &amp; " should have an event"  &amp; testNumber );
	self.assertTrueMsg( realVoyage.allEventTransactionsByType.first.type = eventType.type, voyageName  &amp; " event type incorrect"  &amp; testNumber );
	self.assertTrueMsg( realVoyage.remarks = "Remarkable", voyageName  &amp; " remarks not set"  &amp; testNumber );	//29 Jun 2020	NDL	TFS 49681
	self.assertTrueMsg( realVoyage.myHMSVoyageData.allStevedoresDischarge.first = CM_Stevedore.firstInstance, voyageName  &amp; " Discharge Stevedore not set"  &amp; testNumber );	//29 Jun 2020	NDL	TFS 49681
	self.assertTrueMsg( realVoyage.myHMSVoyageData.allStevedoresLoad.first = CM_Stevedore.lastInstance, voyageName  &amp; " Load Stevedore not set"  &amp; testNumber );	//29 Jun 2020	NDL	TFS 49681
	self.assertTrueMsg( realVoyage.allPortRotations.size = trade1.allPortRotations.size, voyageName  &amp; " port rotations not set correctly"  &amp; testNumber ); //18 Jun 2021	NDL	TFS 51306
	
	voyageName := BargePrefix1 &amp; "2";
	testNumber := " (Test 2)";
	checkVessel := vessel1;
	realVoyage := self.getVoyage( voyageName );
	self.assertTrueMsg( realVoyage &lt;&gt; null, voyageName  &amp; " Voyage not found" &amp; testNumber &amp; " : " &amp; app.myPassport.getErrorsAndWarningsAsString);
	self.assertTrueMsg( realVoyage.myTrade = trade1, voyageName  &amp; " Trade should be " &amp; trade1.description &amp; testNumber );
	self.assertTrueMsg( realVoyage.myShippingLine = shipLine1, voyageName  &amp; " Shippimg Line should be " &amp; shipLine1.description &amp; testNumber );
	self.assertTrueMsg( realVoyage.externalRef = extReference, voyageName  &amp; " External Ref should be " &amp; extReference &amp; testNumber );
	self.assertTrueMsg( realVoyage.myHMSVoyageData.dim_LengthOverall = checkVessel.myHMSVesselData.dim_LengthOverall, voyageName  &amp; " LOA should be " &amp;  checkVessel.myHMSVesselData.dim_LengthOverall.String &amp; testNumber );
	self.assertTrueMsg( realVoyage.callSign = checkVessel.callSign, voyageName  &amp; " Call sign should be " &amp;  checkVessel.callSign &amp; testNumber );
	self.assertTrueMsg( realVoyage.lloydsNumber = checkVessel.lloydsNumber, voyageName  &amp; " Lloyds Number should be " &amp;  checkVessel.lloydsNumber &amp; testNumber );
	self.assertTrueMsg( realVoyage.yearOfBuild = checkVessel.yearOfBuild, voyageName  &amp; " Year Of Build should be " &amp;  checkVessel.yearOfBuild.String &amp; testNumber );
	self.assertTrueMsg( realVoyage.allEventTransactionsByType.size = 1, voyageName  &amp; " should have an event"  &amp; testNumber );
	self.assertTrueMsg( realVoyage.allEventTransactionsByType.first.type = eventType.type, voyageName  &amp; " event type incorrect"  &amp; testNumber );
	self.assertTrueMsg( realVoyage.allPortRotations.size = trade1.allPortRotations.size, voyageName  &amp; " port rotations not set correctly"  &amp; testNumber ); //18 Jun 2021	NDL	TFS 51306
	
	
	//Use the 'Barge Vessel Change' to update the vessel on the 2nd barge voyage
	voyageName := BargePrefix1 &amp; "2";
	testNumber := " (Test 3)";
	checkVessel := vessel2;
	realVoyage := self.getVoyage( voyageName );
	while true do
		app.myTrxCA.trxVoyageVesselChange( realVoyage, checkVessel, app.myPassport );
		if app.myPassport.trxCompletedOK then
			break;	
		elseif not app.myPassport.hasErrors then
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
		break;
	endwhile;
	
	self.assertTrueMsg( realVoyage.myVessel = checkVessel, voyageName  &amp; " Vessel should be " &amp; checkVessel.name &amp; testNumber &amp; " : " &amp; app.myPassport.getErrorsAndWarningsAsString);
	self.assertTrueMsg( realVoyage.myTrade = trade1, voyageName  &amp; " Trade should be " &amp; trade1.description &amp; testNumber );
	self.assertTrueMsg( realVoyage.myShippingLine = shipLine1, voyageName  &amp; " Shippimg Line should be " &amp; shipLine1.description &amp; testNumber );
	self.assertTrueMsg( realVoyage.externalRef = extReference, voyageName  &amp; " External Ref should be " &amp; extReference &amp; testNumber );
	self.assertTrueMsg( realVoyage.myHMSVoyageData.dim_LengthOverall = checkVessel.myHMSVesselData.dim_LengthOverall, voyageName  &amp; " LOA should be " &amp;  checkVessel.myHMSVesselData.dim_LengthOverall.String &amp; testNumber );
	self.assertTrueMsg( realVoyage.callSign = checkVessel.callSign, voyageName  &amp; " Call sign should be " &amp;  checkVessel.callSign &amp; testNumber );
	self.assertTrueMsg( realVoyage.lloydsNumber = checkVessel.lloydsNumber, voyageName  &amp; " Lloyds Number should be " &amp;  checkVessel.lloydsNumber &amp; testNumber );
	self.assertTrueMsg( realVoyage.yearOfBuild = checkVessel.yearOfBuild, voyageName  &amp; " Year Of Build should be " &amp;  checkVessel.yearOfBuild.String &amp; testNumber );
	self.assertTrueMsg( realVoyage.allEventTransactionsByType.size = 1, voyageName  &amp; " should have an event"  &amp; testNumber );
	self.assertTrueMsg( realVoyage.allEventTransactionsByType.first.type = eventType.type, voyageName  &amp; " event type incorrect"  &amp; testNumber );
	self.assertTrueMsg( realVoyage.allPortRotations.size = trade1.allPortRotations.size, voyageName  &amp; " port rotations not set correctly"  &amp; testNumber ); //18 Jun 2021	NDL	TFS 51306

	self.deleteVoyage( BargePrefix1 &amp; '2' );
	

	//Use the Multi Barge Copy to create 2 more barges
	voyageName := BargePrefix1 &amp; "1";
	
	realBaseVoyage := self.getVoyage( voyageName );
	
	create allPxyVoyages transient;	
	voyageName := BargePrefix2 &amp; '2';
	pxyVoyage := realBaseVoyage.pxyFromBargeUsingVesselAndCode( vessel1, voyageName, terminal );
	allPxyVoyages.add( pxyVoyage );
	voyageName := BargePrefix2 &amp; '3';
	pxyVoyage := realBaseVoyage.pxyFromBargeUsingVesselAndCode( vessel2, voyageName, terminal );
	allPxyVoyages.add( pxyVoyage );
	
	while true do
		//app.myTrxCA.trxCreateBargeCopies( allPxyVoyages, realBaseVoyage, app.myPassport );		// TFS 50878
		app.myTrxCA.trxCreateBargeCopies( allPxyVoyages, realBaseVoyage, null, app.myPassport );	// TFS 50878
		if app.myPassport.trxCompletedOK then
			break;	
		elseif not app.myPassport.hasErrors then
			app.myPassport.warningsAcknowledged	:= true;
			continue;
		endif;
		break;
	endwhile;
		
	//need to check attributes here
	voyageName := BargePrefix2 &amp; '2';
	realVoyage := self.getVoyage( voyageName );
	checkVessel := vessel1;
	testNumber := " (Test 4)";
	self.assertTrueMsg( realVoyage.myVessel = checkVessel, voyageName  &amp; " Vessel should be " &amp; checkVessel.name &amp; testNumber &amp; " : " &amp; app.myPassport.getErrorsAndWarningsAsString);
	self.assertTrueMsg( realVoyage.myTrade = realBaseVoyage.myTrade, voyageName  &amp; " Trade should be " &amp; realBaseVoyage.myTrade.description &amp; testNumber );
	self.assertTrueMsg( realVoyage.myShippingLine = realBaseVoyage.myShippingLine, voyageName  &amp; " Shippimg Line should be " &amp; realBaseVoyage.myShippingLine.description &amp; testNumber );
	self.assertTrueMsg( realVoyage.externalRef = extReference, voyageName  &amp; " External Ref should be " &amp; extReference &amp; testNumber );
	self.assertTrueMsg( realVoyage.myHMSVoyageData.dim_LengthOverall = checkVessel.myHMSVesselData.dim_LengthOverall, voyageName  &amp; " LOA should be " &amp;  checkVessel.myHMSVesselData.dim_LengthOverall.String &amp; testNumber );
	self.assertTrueMsg( realVoyage.callSign = checkVessel.callSign, voyageName  &amp; " Call sign should be " &amp;  checkVessel.callSign &amp; testNumber );
	self.assertTrueMsg( realVoyage.lloydsNumber = checkVessel.lloydsNumber, voyageName  &amp; " Lloyds Number should be " &amp;  checkVessel.lloydsNumber &amp; testNumber );
	self.assertTrueMsg( realVoyage.yearOfBuild = checkVessel.yearOfBuild, voyageName  &amp; " Year Of Build should be " &amp;  checkVessel.yearOfBuild.String &amp; testNumber );
	self.assertTrueMsg( realVoyage.allEventTransactionsByType.size = 1, voyageName  &amp; " should have an event"  &amp; testNumber );
	self.assertTrueMsg( realVoyage.allEventTransactionsByType.first.type = eventType.type, voyageName  &amp; " event type incorrect"  &amp; testNumber );
	self.assertTrueMsg( realVoyage.allPortRotations.size = trade1.allPortRotations.size, voyageName  &amp; " port rotations not set correctly"  &amp; testNumber ); //18 Jun 2021	NDL	TFS 51306
	
	
	//need to check attributes here
	voyageName := BargePrefix2 &amp; '3';
	realVoyage := self.getVoyage( voyageName );
	checkVessel := vessel2;
	testNumber := " (Test 5)";
	self.assertTrueMsg( realVoyage.myVessel = checkVessel, voyageName  &amp; " Vessel should be " &amp; checkVessel.name &amp; testNumber &amp; " : " &amp; app.myPassport.getErrorsAndWarningsAsString);
	self.assertTrueMsg( realVoyage.myTrade = realBaseVoyage.myTrade, voyageName  &amp; " Trade should be " &amp; realBaseVoyage.myTrade.description &amp; testNumber );
	self.assertTrueMsg( realVoyage.myShippingLine = realBaseVoyage.myShippingLine, voyageName  &amp; " Shippimg Line should be " &amp; realBaseVoyage.myShippingLine.description &amp; testNumber );
	self.assertTrueMsg( realVoyage.externalRef = extReference, voyageName  &amp; " External Ref should be " &amp; extReference &amp; testNumber );
	self.assertTrueMsg( realVoyage.myHMSVoyageData.dim_LengthOverall = checkVessel.myHMSVesselData.dim_LengthOverall, voyageName  &amp; " LOA should be " &amp;  checkVessel.myHMSVesselData.dim_LengthOverall.String &amp; testNumber );
	self.assertTrueMsg( realVoyage.callSign = checkVessel.callSign, voyageName  &amp; " Call sign should be " &amp;  checkVessel.callSign &amp; testNumber );
	self.assertTrueMsg( realVoyage.lloydsNumber = checkVessel.lloydsNumber, voyageName  &amp; " Lloyds Number should be " &amp;  checkVessel.lloydsNumber &amp; testNumber );
	self.assertTrueMsg( realVoyage.yearOfBuild = checkVessel.yearOfBuild, voyageName  &amp; " Year Of Build should be " &amp;  checkVessel.yearOfBuild.String &amp; testNumber );
	self.assertTrueMsg( realVoyage.allEventTransactionsByType.size = 1, voyageName  &amp; " should have an event"  &amp; testNumber );
	self.assertTrueMsg( realVoyage.allEventTransactionsByType.first.type = eventType.type, voyageName  &amp; " event type incorrect"  &amp; testNumber );
	self.assertTrueMsg( realVoyage.remarks = "Remarkable", voyageName  &amp; " remarks not set"  &amp; testNumber );	//29 Jun 2020	NDL	TFS 49681
	self.assertTrueMsg( realVoyage.myHMSVoyageData.allStevedoresDischarge.first = CM_Stevedore.firstInstance, voyageName  &amp; " Discharge Stevedore not set"  &amp; testNumber );	//29 Jun 2020	NDL	TFS 49681
	self.assertTrueMsg( realVoyage.myHMSVoyageData.allStevedoresLoad.first = CM_Stevedore.lastInstance, voyageName  &amp; " Load Stevedore not set"  &amp; testNumber );	//29 Jun 2020	NDL	TFS 49681
	self.assertTrueMsg( realVoyage.allPortRotations.size = trade1.allPortRotations.size, voyageName  &amp; " port rotations not set correctly"  &amp; testNumber ); //18 Jun 2021	NDL	TFS 51306
	
	//cleanup
	self.deleteVoyage(BargePrefix1 &amp; '1');
	self.deleteVoyage(BargePrefix1 &amp; '2');
	self.deleteVoyage(BargePrefix2 &amp; '2');
	self.deleteVoyage(BargePrefix2 &amp; '3');
	
	self.deleteVessel(Vessel1);
	self.deleteVessel(Vessel2);

epilog

	delete dummyVoyage;
	if allPxyVoyages &lt;&gt; null then
		allPxyVoyages.purge();
	else
		delete pxyVoyage;
	endif;
	delete allPxyVoyages;
	delete eventTypes;
	delete steveDict;
	delete vessels;			// TFS 50878

end;</source>
    </JadeMethod>
    <JadeMethod name="tBasicShipOps" id="d2dff105-85d0-4e00-8b49-7a84a0592ac8">
        <updating/>
        <source>tBasicShipOps() updating;
// cnwma1
//cnwrd1
/*

Purpose:	basic load and discharge of ship of 1 container each way		

Parameters:			

Return Value:		


Date		Who		Reason
09 August 2012	cnwrd1	Initial creation

*/


constants
	DischargeBox		= "UTDR0000002";
	LoadBox				= "UTDR0000003";
	BlockStack1			= "UT_RDBS1";
	YardIC				= "UT_RD_IC";
	Ship				= "UTRDSHIP";
	Voyage1				= "UTRDVOYAGE";
	CraneTransferAreaId	= "CTRD";
	CraneId				= "CRR1";

vars
	dischargeTi,
	loadTi,
	ti4				: CM_TrackedItem;
	bs				: CM_BlockStack;
	yardIC			: CM_InterchangeArea;
	wle				: CM_WorkListEntry;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	slots 			: CM_SlotControllerArray;
	voyageJob		: CM_VoyageJob;
	job				: CM_Job;
	request			: CM_Request;
	voyageQueue		: CM_VoyageQueue;
	craneQueue		: CM_VoyageCraneQueue;
	crane			: CM_Machine;
	operator		: CM_Operator;
	bayName			: String;
	loadPort,
	dischargePort	: CM_Port;
	jobs			: CM_JobArray;
	voyAlloc		: CM_VoyageAllocation;
	wles 			: CM_WLEArray;
	straddle		: CM_Machine;
	tas				: StringArray;
	cta				: CM_CraneTransferArea;
	stevedoreRec	: CM_Stevedore;
	stevedoreRel	: CM_Stevedore;
begin
	
	self.setTerminalConfig(AllowRTSwithoutVGM, true);					// 10/06/2016 cnwmh5
	
	create jobs transient;
	create wles transient;

	// delete everything first
	self.deleteContainer(DischargeBox);
	self.deleteContainer(LoadBox);
	self.deleteTerminalArea(BlockStack1);
	self.deleteTerminalArea(YardIC);
	self.deleteVoyage(Voyage1);
	self.deleteVessel(Ship);
	self.deleteMachine(CraneId);
	self.deleteTerminalArea(CraneTransferAreaId);
	
	
	// create the terminal areas - gridded block stack, block stack and interchange
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("HideOverview", true);
	yardIC := self.addInterchangeArea(YardIC, null);
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("StockControlled", true);
	self.opts.addAssoc("DefaultYIC", yardIC);
	bs := self.addBlockStack(BlockStack1, 20, null);		
	
	
	// create the crane transfer area
	cta := self.addCraneTransferArea(CraneTransferAreaId);
	self.assertNotNull(cta);
	
	//create vessel and voyage
	vessel := addVesselCellular(Ship, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	voyage := self.addVoyageWithContainerStructur(Voyage1, Ship, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNull(vessel);
	self.assertNotNull(voyage);
	
	//03 Mar 2021	NDL	TFS 50866
	stevedoreRec := app.myRoot.allStevedores.getAtKey('UTRECEIVE');
	stevedoreRel := app.myRoot.allStevedores.getAtKey('UTRELEASE');
	beginTransaction;
		voyage.myHMSVoyageData.allStevedoresDischarge.add( stevedoreRec );
		voyage.myHMSVoyageData.allStevedoresLoad.add( stevedoreRel );
	commitTransaction;
	
	// create the crane
	create tas transient;
	tas.add(cta.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	crane := self.addCrane(CraneId, null, tas, null);
	self.assertNotNull(crane);
	delete tas;

	
	loadPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;

	//create discharge job
	bayName := '01';
	create slots transient;
	self.getJobSlotControllers(Voyage1, bayName, DeckOnDeck, 1, 1, 1, slots);
	assertEqual(slots.size, 1);
	dischargeTi := self.addContainerAtLocnDisch(DischargeBox , "2200", "GENL", TI_IMEX_STATUS_IMPORT, slots[1], loadPort, voyage);
	// Color code and Create Discharge Jobs
	self.voyageDischargeColourCode(voyage);
	
	voyageJob := self.addVoyageJob(voyage, CraneId, slots, true);
	assertTrueMsg(voyageJob &lt;&gt; null, "Voyage job 1 not created");
	jobs.add(voyageJob);
	
	foreach wle in voyageJob.workListEntries do
		self.movePlannedWLE(wle.myTrackedItem, 	bs.myLocationsController, wle);
	endforeach;
	delete slots;
	
	self.opts.purge;																				// cnwmk3 6/01/2016
	voyAlloc := self.addVoyageAllocation(voyage, dischargePort.code,"GEN2",null,1,false,false);
	bayName :='01';
	self.logMessageNow("Create Load Jobs for bay " &amp; bayName);
	create slots transient;
	self.getJobSlotControllers(voyage.code, bayName, DeckOnDeck, 1, 2, 1, slots);
	assertEqual(slots.size, 1);

	self.addLCsToLOLOAllocation(true, voyAlloc, slots, null);
	
	voyageJob := self.addVoyageJob(voyage, CraneId, slots, false);
	assertTrueMsg(voyageJob &lt;&gt; null, "Voyage job not created");
	jobs.add(voyageJob);	
	loadTi := self.addContainerForExport(LoadBox, operator,
				"2200",	"GENL",	TI_IMEX_STATUS_EXPORT,	null, voyage.code, dischargePort.code, null).CM_Container;
	self.move(loadTi, bs.getLocationsController);
	self.setCargoReadyToShip(loadTi);
	self.deleteStops(loadTi);
	self.movePlannedRequestToJob(loadTi, slots[1], slots[1].getRequest(true));
	delete slots;

	// ok have my load and discharge jobs now
	
	//load to ops
	self.loadAllJobsToOps(voyage, true);				
	
	self.addMachineRule( bs, crane.CM_Crane.transferArea, RTMoveMethod_23); //simple single straddle moves
	self.addMachineRule( crane.CM_Crane.transferArea, bs, RTMoveMethod_23); 
		
	voyageQueue := self.addVoyageQueue(voyage);
	craneQueue := self.addVoyageCraneQueue(voyage, voyageQueue, crane);
	
	// Create Queues
	foreach job in jobs do
		foreach request in job.allRequests do
			foreach wle in request.allWorkListEntries do
				wles.add(wle);
				self.queueWLE(wle);
			endforeach;
		endforeach;
	endforeach;
	
	// workJob using straddle
	self.deleteMachine("UTS1");
	self.deleteRTDevice("91");
	create tas transient;
	tas.add(bs.id); 
	tas.add(yardIC.id); 
	tas.add(crane.CM_Crane.transferArea.id); 
	self.addStraddle("UTS1", 91, tas, null);
	straddle := self.getMachine("UTS1");
	assertNotNull(straddle);
	if craneQueue &lt;&gt; null then
		beginTransaction;
		straddle.addToQueue(craneQueue, true, 0); //add straddle to crane queue
		commitTransaction;
	endif;
	delete tas;
	
	app.isRTApp:=true;  
	self.machineLogon(straddle);

	foreach wle in wles do
		self.machineAcceptTask(straddle, wle.allRTQueueEntries.first.allTasks.first);
		
		if wle.isReceipt and wle.job.isVoyageJob then 
			//crane := wle.job.CM_VoyageJob.getJobCrane();
			self.machineCraneActionPickup(straddle, dischargeTi, ti4);
			self.machinePickup(straddle);			
			self.machineSetdownTask(straddle, wle.allRTQueueEntries.first.allTasks.last, bs.id);	
		else
			self.machinePickup(straddle);
			self.machineSetdownTask(straddle, wle.allRTQueueEntries.first.allTasks.last, wle.allRTQueueEntries.first.allTasks.last.targetLocationId);
		endif;
		
	endforeach;	
	
	self.assertTrue( dischargeTi.myPrimaryActualLocation.isYardLocation);
	self.assertTrue( loadTi.myPrimaryActualLocation.isVoyageController);
	
	// check txns created correctly for the following
	self.checkTIForTxnOfType(dischargeTi, TRANS_TYPE_REC_SHIP);			// 15/08/2012 cnwmh5
	self.checkTIForTxnOfType(dischargeTi, TRANS_TYPE_WHARFAGE);			// 15/08/2012 cnwmh5
	self.checkTIForTxnOfType(loadTi, TRANS_TYPE_REL_SHIP);				// 15/08/2012 cnwmh5
	self.checkTIForTxnOfType(loadTi, TRANS_TYPE_WHARFAGE);				// 15/08/2012 cnwmh5
	
	//10 Mar 2021	NDL	TFS 50866
	self.assertTrueMsg( dischargeTi.stevedoreCodeRecieve = 'UTRECEIVE', "Create of cargo on ship failed to set '.stevedoreCodeRecieve' value");
	self.assertTrueMsg( loadTi.stevedoreCodeRelease = 'UTRELEASE', "Load of cargo to ship failed to set '.stevedoreCodeRelease' value");
	
epilog
	app.isRTApp:=false;  
	delete jobs;
	delete slots;
	delete wles;
	delete tas;						// 13/09/2012 cnwmc5
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;Fails1006&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tChangeBargeVesselWithCargo" id="42602d1f-e2b4-4204-88b4-8ea76ca8b737">
        <source>tChangeBargeVesselWithCargo();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 Mar 2021 cnwma1  ChangeRequest 50852: ASPA - Change Vessel on Barge

*/

constants
	VesselCodeString1 = "50852UT_ZGC1";
	VesselCodeString2 = "50852UT_ZGC2";
vars

	vessel1,
	vessel2     : CM_Vessel;
	voyage		: CM_Voyage;
	bs1			: CM_BlockStack;
	cargoType 	: CM_CargoType;
	cargoOnship : CM_TrackedItem;
	lc			: CM_LocationsController;
	height          : Integer;

begin 
	
	//create 2 barges
	self.opts.addAssoc("isBarge",true);
	vessel1 := self.addVesselWithHolds(VesselCodeString1, 2, 2);
	vessel2 := self.addVesselWithHolds(VesselCodeString2, 2, 2);
	
	assertEqual(vessel1.isBarge, true);
	assertEqual(vessel2.isBarge, true);
	
	//Create Voyage
	voyage := self.addVoyageWithGeneralCargoStruc("UT_V50852GC1", vessel1.name, vessel1.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	bs1    := self.addBlockStack("UTBS50852", 9999, null);
	
	beginTransaction;
		voyage.setPropertyValue("isBarge",true);
	commitTransaction;
	
	// Create cargo
	cargoType := app.myRoot.getCargoTypeFromAbbrev("UTREBAR");
	self.getTerminal.findLocationFromString("UT_V50852GC1 0101", true, lc, height); 
	deleteCargo("UTASPA50852", cargoType);
	cargoOnship := self.addCargoBreakBulkAtLocation("UTASPA50852", cargoType, 50, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel1.myOperator);
	self.opts.addAssoc("TotalWeight", 50);
	self.updateTI(cargoOnship);
	assertEqual(cargoOnship.totalQuantity, 50);
	
	
	while true do
		app.myTrxCA.trxVoyageVesselChange( voyage, vessel2, app.myPassport );
		if app.myPassport.trxCompletedOK then
			break;
		else 
			if app.myPassport.noErrors then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
	assertEqual(cargoOnship.vesselCode, VesselCodeString2);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="tChangeFutureMoveQty" id="8f20b624-0214-4c49-bbfd-86ede1b83995">
        <source>tChangeFutureMoveQty();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 Mar 2021	jlgma1	ChangeRequest 50854: ASPA - Hold Planning Change Planned Amount

*/

constants
	VesselCodeString = "UT_ZGC1";
vars

	vessel		: CM_Vessel;
	voyage		: CM_Voyage;
	bs1			: CM_BlockStack;
	cargoType 	: CM_CargoType;
	cargoOnship : CM_TrackedItem;
	lc			: CM_LocationsController;
	moveController  : CMIF_MoveController;
	fm              : CM_FutureMove;
	wle             : CM_WorkListEntry;
	height          : Integer;
begin
	vessel := self.addVesselWithHolds("UT_ZVHOLDS", 2, 2);
	voyage := self.addVoyageWithGeneralCargoStruc("UT_ZVHOLDS", vessel.name, vessel.myOperator.code,	self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString(), 0);
	bs1    := self.addBlockStack("UTZBS1", 9999, null);
	
	cargoType := app.myRoot.getCargoTypeFromAbbrev("UTREBAR");
	self.getTerminal.findLocationFromString("UT_ZVHOLDS 0101", true, lc, height); 
	
	deleteCargo("UTASPA50854", cargoType);
	
	cargoOnship := self.addCargoBreakBulkAtLocation("UTASPA50854", cargoType, 50, lc, null, TI_IMEX_STATUS_IMPORT, voyage, vessel.myOperator);
	self.opts.addAssoc("TotalWeight", 50);
	self.updateTI(cargoOnship);
	assertEqual(cargoOnship.totalQuantity, 50);
	
	create moveController transient;
	
	moveController.setMyTrackedItem(cargoOnship);	
	moveController.setMoveMode(PLANNING_MODE);
	moveController.setQuantity(5);
	moveController.setMyOriginatingLocation(cargoOnship.myPrimaryActualLocation);
	moveController.setMyToPrimaryLocation(bs1.myLocationsController);
	while true do
		app.myTrxUA.trxMoveTrackedItem(moveController, app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else 
			if app.myPassport.noErrors then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	fm  := cargoOnship.allPlannedFutureMoves.first;
	wle := fm.myWorkListEntry;
	assertEqual(wle.quantity, 5);
	
	while true do
		app.myTrxUA.trxUpdateFutureMoveQty(fm,0,15,app.myPassport);
		if app.myPassport.trxCompletedOK then
			break;
		else 
			if app.myPassport.noErrors then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		break;
	endwhile;
	
	fm  := cargoOnship.allPlannedFutureMoves.first;
	assertEqual(fm.myWorkListEntry.quantity, 15);
	
epilog
	delete moveController;
end;</source>
    </JadeMethod>
    <JadeMethod name="tCheckROROGetsAllocFromVessel" id="430e76f5-d350-424c-aa39-00d3667d0299">
        <updating/>
        <source>tCheckROROGetsAllocFromVessel() updating;

/*

Purpose:		Check that when creating a voyage that it gets it allocations 
				from the vessel

Date			Who		Reason
24/07/2015		cnwmh5	Initial creation

*/

constants
	
	VoyageName 					: String = 'UTMDHVOYZ';
	VoyageName2					: String = "UTMDHVOYY";
	ShipName 					: String = 'UTMDHVES5';
	
vars
	cta							: CM_CraneTransferArea;
	bs							: CM_BlockStack;
	vessel 						: CM_Vessel;
	voyage 						: CM_Voyage;
	voyage2						: CM_Voyage;
	queue						: CM_VoyageQueue;
	rampQueue					: CM_VoyageCraneQueue;
	cargo1						: CM_TrackedItem;
	crane						: CM_Machine;
	imv							: CM_Machine;
	wle 						: CM_WorkListEntry;
	job 						: CM_VoyageJob;
	forkLift					: CM_Machine;
	task						: CM_RTQueueTask;
	slotsFrom					: CM_SlotControllerArray;
	tmpLoadCC					: CMIF_LoadColorCode;
	theSlot 					: CM_LocationsController;
	pxyTask						: CM_RTQueueTask;
	agent						: CM_MobileAgent;
	ct 							: CM_YACriteriaType;
	vaConfig					: CM_VoyageAllocationConfig;
	
	strs 						: StringArray;
	tas							: StringArray;
	opCriteriaColl 				: CM_YACriteriaTypeArray;
	
	idx							: Integer;
	success						: Boolean;
	result						: String;
	imvSetting					: Boolean;
		
begin
	
	self.deleteVoyage(VoyageName);
	self.deleteVoyage(VoyageName2);
	self.deleteVessel(ShipName);
	vessel := self.addVesselLOLOholdsRORO(ShipName, self.getOperator("MSK"));
	self.assertNotNull(vessel);						// 24/07/2015 cnwmh5
	
	create opCriteriaColl transient;
	ct := CM_YATypeISO.firstInstance;
	opCriteriaColl.add(ct);
	ct := CM_YATypeCargoType.firstInstance;
	opCriteriaColl.add(ct);
	ct := CM_YATypeCommodity.firstInstance;
	opCriteriaColl.add(ct);
	ct := CM_YATypeHazardous.firstInstance;
	opCriteriaColl.add(ct);
	
	self.opts.purge();
	self.opts.addAssociation("VoyageAllocationsCriteria", opCriteriaColl);
	self.updateVessel(vessel);
	
	self.opts.purge();
	self.opts.addAssoc("Vessel", vessel);
	self.opts.addAssoc("UseVesselAllocations", true);
	voyage	:= self.addVoyageWithConRORO(VoyageName,
													ShipName,
													"MSK", 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString,
													null, 10, false, true);
	self.assertNotNull(voyage);		
	vaConfig := voyage.allVoyageAllocationConfigs.first.CM_VoyageAllocationConfig;
	self.assertNotNull(vaConfig);
	
	// check that the vessels allocations are on the voyage
	opCriteriaColl.clear();
	foreach ct in vessel.myVoyageAllocationConfig.allOpCriteria do
		self.assertTrueMsg(vaConfig.allOpCriteria.includes(ct), 
			ct.String &amp; " is on vessel but isn't on the voyage");
		opCriteriaColl.add(ct);
	endforeach;
		
	// add extra allocation(s) to voyage	
	ct := CM_YATypeHeavyDuty.firstInstance;
	opCriteriaColl.add(ct);
	ct := CM_YATypeIsCoastal.firstInstance;
	opCriteriaColl.add(ct);
	
	beginTransaction;
	vaConfig.allOpCriteria.clear();
	opCriteriaColl.copy(vaConfig.allOpCriteria);
	commitTransaction;	
	
	// create second voyage and check vessels allocations are on the voyage
	self.opts.purge();
	self.opts.addAssoc("Vessel", vessel);
	self.opts.addAssoc("UseVesselAllocations", true);
	voyage	:= self.addVoyageWithConRORO(VoyageName2,
													ShipName,
													"MSK", 
													self.getProfileSetting( UT_Profile.P_SHIPPING_LINE ).asString,
													null, 10, false, true);
	self.assertNotNull(voyage);		
	vaConfig := voyage.allVoyageAllocationConfigs.first.CM_VoyageAllocationConfig;
	self.assertNotNull(vaConfig);
	
	// check that the vessels allocations are on the voyage
	foreach ct in vessel.myVoyageAllocationConfig.allOpCriteria do
		self.assertTrueMsg(vaConfig.allOpCriteria.includes(ct), 
			ct.String &amp; " is on vessel but isn't on the voyage");
	endforeach;

epilog

	delete opCriteriaColl;

end;</source>
    </JadeMethod>
    <JadeMethod name="tChkWLESeqNumWorkOrder1" id="10728c33-40d7-4f6a-90f7-23b46ea5b8a4">
        <updating/>
        <source>tChkWLESeqNumWorkOrder1() updating;

/*

Purpose:		Check to voayge's wle's to see that the work order number is correct using trxMoveTIsAUTOAssignToJob

Date			Who		Reason
31 October 2011	cnwmh5	Initial creation

*/
constants
	
	BlockStackId			: String = "UTMHBS1";
	YardAllocationId		: String = "UTMHBS1All";
	CraneTransferAreaId		: String = "UTC1TY";
	VesselId				: String = "UTMHHH2";
	VoyageId				: String = "UTMHHH2";
	CraneId					: String = "UTC2";
	QueueId					: String = "QUEID1";
	ForkliftId				: String = "UTF2";
	ContainerTLId			: String = "UTMHTL";
	ContainerNTLId			: String = "UTMHNTL";
	ContainerBBId			: String = "UTMHBB";
	CargoTypeId				: String = "Coal";
	CargoSubTypeId			: String = "LIGNITE";
	
vars
	
	blockStack				: CM_BlockStack;
	cta						: CM_CraneTransferArea;
	operator				: CM_Operator;
	dischargePort			: CM_Port;
	vessel					: CM_Vessel;
	voyage					: CM_Voyage;
	ti						: CM_TrackedItem;
	crane					: CM_Machine;
	tmpLoadCC				: CMIF_LoadColorCode;
	voyageLoadJobTL			: CM_VoyageJob;
	voyageLoadJobNTL		: CM_VoyageJob;
	voyageLoadJobBB			: CM_VoyageJob;
	cargo					: CM_Cargo;
	cargoType				: CM_CargoType;
	product					: CM_Product;
	slotLC					: CM_SlotController;
	moveController			: CMIF_MoveController;
	wle 					: CM_WorkListEntry;
	request					: CM_Request;
		
	locations				: CM_LCArray;
	slotsFrom				: CM_SlotControllerArray;
	slotsToTL				: CM_SlotControllerArray;
	slotsToNTL				: CM_SlotControllerArray;
	slotsToBB				: CM_SlotControllerArray;
	tiArray					: CM_TIArray;
	lcArray					: CM_LCArray;
	tiArray1				: CM_TIArray;
		
	strs 					: StringArray;
	cargoArray				: ObjectArray;
	tas						: StringArray;
	
	reqdNumberOfTis			: Integer;
	idx						: Integer;
	tiId					: String;
	seqNum					: Integer;
	otherCount,
	twinLift1Count, 
	twinLift2Count			: Integer;
	
begin

	self.setTerminalConfig(AllowRTSwithoutVGM, true);					// 10/06/2016 cnwmh5
	
	create tiArray1 transient;

	// get general values
	operator := app.myRoot.allOperators["UTOP"];
	dischargePort := app.myRoot.allPorts["NZPOE"];
	cargoType := self.getTerminal.getFirstNonSystemCargoType().CM_CargoType;
	product := cargoType.allProducts.first;
	
	// create the block stack
	self.deleteTerminalArea(BlockStackId);
	blockStack := addBlockStack(BlockStackId, 100, null);
	self.assertNotNull(blockStack);
	
	// create the crane transfer area
	self.deleteMachine(CraneId);
	self.opts.purge();
	self.opts.addAssoc("SetCraneLaneCages", true);
	self.deleteTerminalArea(CraneTransferAreaId);
	cta := self.addCraneTransferArea(CraneTransferAreaId);
	self.assertNotNull(cta);
	
	// create yard allocation;
	self.deleteYA(YardAllocationId);
	create locations transient;
	locations.add(blockStack.allLocationsControllers.first.CM_YardController);
	self.addYA1(YardAllocationId, YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, locations);
	
	// create Voyage
	deleteVoyage(VoyageId);
	deleteVessel(VesselId);
	vessel := addVesselCellular(VesselId, operator);
	voyage := addVoyageWithContainerStructur(VoyageId, VesselId, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	
	// create the crane
	create tas transient;
	tas.add(cta.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	
	crane := self.addCrane(CraneId, null, tas, null);
	self.assertNotNull(crane);
	
	create cargoArray transient;
	
	// create containers for twin lift loading
	self.opts.purge();
	self.opts.addAssoc("CENum", "12345");
	////self.opts.addAssoc("ReadyToShip", true);
	self.opts.addAssoc("TotalWeight", "2050");
	reqdNumberOfTis := 11;
	while reqdNumberOfTis &lt;&gt; 0 do
		tiId := ContainerTLId &amp; reqdNumberOfTis.String.padLeadingZeros(11 - ContainerTLId.length);
		self.deleteContainer(tiId);
		ti := self.addContainerAtLocation(tiId, operator, "2200", "GENL", TI_IMEX_STATUS_EXPORT, blockStack);
		self.updateTrackedItem(ti);
		self.deleteStops(ti);
		tiArray1.clear();
		tiArray1.add(ti);
		app.myTrxUA.trxUpdateTIsReadyToShip(tiArray1,true,app.myPassport);
		if ti &lt;&gt; null then
			cargoArray.add(ti);
		endif;
		reqdNumberOfTis := reqdNumberOfTis - 1;
	endwhile;
	
	// create containers for single lift loading
	self.opts.purge();
	self.opts.addAssoc("CENum", "12345");
	///self.opts.addAssoc("ReadyToShip", true);
	self.opts.addAssoc("TotalWeight", "2050");
	reqdNumberOfTis := 4;
	while reqdNumberOfTis &lt;&gt; 0 do
		tiId := ContainerNTLId &amp; reqdNumberOfTis.String.padLeadingZeros(11 - ContainerNTLId.length);
		self.deleteContainer(tiId);
		ti := self.addContainerAtLocation(tiId, operator, "2200", "GENL", TI_IMEX_STATUS_EXPORT, blockStack);
		self.updateTrackedItem(ti);
		self.deleteStops(ti);
		tiArray1.clear();
		tiArray1.add(ti);
		app.myTrxUA.trxUpdateTIsReadyToShip(tiArray1,true,app.myPassport);
		if ti &lt;&gt; null then
			cargoArray.add(ti);
		endif;
		reqdNumberOfTis := reqdNumberOfTis - 1;
	endwhile;
	
	// colour code the load slot for the twin lift
	create slotsToTL transient;
	self.getJobSlotControllers(VoyageId, "01", DeckOnDeck, 1, 1, 4, slotsToTL);
	self.getJobSlotControllers(VoyageId, "01", DeckOnDeck, 5, 3, 1, slotsToTL);
	self.getJobSlotControllers(VoyageId, "03", DeckOnDeck, 1, 1, 4, slotsToTL);
	self.getJobSlotControllers(VoyageId, "03", DeckOnDeck, 6, 4, 1, slotsToTL);
	self.getJobSlotControllers(VoyageId, "01", DeckUnderDeck, 1, 1, 1, slotsToTL);
	self.markSlotsAsLoadJob(slotsToTL, tmpLoadCC);
	self.markSlotsAsLoadCC(slotsToTL, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageLoadJobTL := self.addVoyageJob(voyage, crane.id, slotsToTL, false);
	assertTrue(voyageLoadJobTL &lt;&gt; null);
	
	// colour code the load slot for the single lift
	create slotsToNTL transient;
	self.getJobSlotControllers(VoyageId, "05", DeckOnDeck, 1, 1, 4, slotsToNTL);
	self.markSlotsAsLoadJob(slotsToNTL, tmpLoadCC);
	self.markSlotsAsLoadCC(slotsToNTL, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageLoadJobNTL := self.addVoyageJob(voyage, crane.id, slotsToNTL, false);
	assertTrue(voyageLoadJobNTL &lt;&gt; null);
	
	// load the containers to the ship
	idx := 1;
	while idx &lt;= cargoArray.size do
		ti := cargoArray[idx].CM_TrackedItem;
		beginTransaction;
		if idx &lt;= 11 then 
			slotLC := slotsToTL[idx];
			voyageLoadJobTL.updateReleaseTI(ti);
		else
			slotLC := slotsToNTL[idx-11];
			voyageLoadJobNTL.updateReleaseTI(ti);
		endif;
		commitTransaction;
		self.planItemBackToShip(ti, slotLC);	
		idx := idx + 1;
	endwhile;
	
	// create the bulk break cargo
	cargoArray.clear();
	reqdNumberOfTis := 12;
	self.opts.purge();
	self.opts.addAssoc( ETRow_CargoType, CargoTypeId );
	self.opts.addAssoc( ETRow_MyProduct, CargoSubTypeId );			
	self.opts.addAssoc( UTTI_IMEX, TI_IMEX_STATUS_EXPORT );
	///self.opts.addAssoc("ReadyToShip", true);
	self.opts.addAssoc("TotalWeight", "20");
	while reqdNumberOfTis &lt;&gt; 0 do
		tiId := ContainerBBId &amp; reqdNumberOfTis.String.padLeadingZeros(11 - ContainerBBId.length);
		self.deleteContainer(tiId);
		cargo := self.addCargoAtLocationDetailed(tiId, null,product, blockStack.myLocationsController, dischargePort.code, TI_IMEX_STATUS_EXPORT, voyage, operator);
		self.updateTrackedItem(cargo);
		if cargo &lt;&gt; null then
			cargoArray.add(cargo);
		endif;
		reqdNumberOfTis := reqdNumberOfTis - 1;
	endwhile;
	
	// colour code the load slot for the single lift
	create slotsToBB transient;
	self.getJobSlotControllers(VoyageId, "07", DeckOnDeck, 1, 1, 4, slotsToBB);
	self.markSlotsAsLoadJob(slotsToBB, tmpLoadCC);
	self.markSlotsAsLoadCC(slotsToBB, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageLoadJobBB := self.addVoyageJob(voyage, crane.id, slotsToBB, false);
	assertTrue(voyageLoadJobBB &lt;&gt; null);

	
	// load the break bulk to there slots
	create tiArray transient;
	tiArray.add(cargoArray[1].CM_TrackedItem);
	tiArray.add(cargoArray[2].CM_TrackedItem);
	tiArray.add(cargoArray[3].CM_TrackedItem);
	tiArray.add(cargoArray[4].CM_TrackedItem);
	create lcArray transient;
	lcArray.add(slotsToBB[1]);
	self.planGCTisLOLO(tiArray, lcArray);
	self.assertNoTrxErrorsOrWarnings();
	
	tiArray.clear();
	tiArray.add(cargoArray[5].CM_TrackedItem);
	tiArray.add(cargoArray[6].CM_TrackedItem);
	lcArray.clear();
	lcArray.add(slotsToBB[2]);
	self.planGCTisLOLO(tiArray, lcArray);
	self.assertNoTrxErrorsOrWarnings();
	
	tiArray.clear();
	tiArray.add(cargoArray[7].CM_TrackedItem);
	tiArray.add(cargoArray[8].CM_TrackedItem);
	lcArray.clear();
	lcArray.add(slotsToBB[3]);
	self.planGCTisLOLO(tiArray, lcArray);
	self.assertNoTrxErrorsOrWarnings();
	
	tiArray.clear();
	tiArray.add(cargoArray[9].CM_TrackedItem);
	tiArray.add(cargoArray[10].CM_TrackedItem);
	tiArray.add(cargoArray[11].CM_TrackedItem);
	tiArray.add(cargoArray[12].CM_TrackedItem);
	lcArray.clear();
	lcArray.add(slotsToBB[4]);
	self.planGCTisLOLO(tiArray, lcArray);
	self.assertNoTrxErrorsOrWarnings();
		
	// load to job ops
	self.loadAllJobsToOps(voyage, true);	
	
	// check seqNumWorkOrder for single lift
	foreach wle in voyageLoadJobNTL.workListEntries do
		self.assertEqualMsg(wle.CM_VoyageWLE.seqNumWorkOrder, 1, "WLE seqNumWorkOrder (" &amp; wle.CM_VoyageWLE.seqNumWorkOrder.String &amp; 
			") does not match 1");
	endforeach;
	
	// check seqNumWorkOrder for twin lift
	twinLift1Count := 0;
	twinLift2Count := 0;
	otherCount := 0;
	foreach wle in voyageLoadJobTL.workListEntries do
		if wle.CM_VoyageWLE.isTwinLift then
			if wle.CM_VoyageWLE.seqNumWorkOrder = 1 then
				twinLift1Count := twinLift1Count + 1;
			elseif wle.CM_VoyageWLE.seqNumWorkOrder = 2 then
				twinLift2Count := twinLift2Count + 1;
			endif;
		else
			otherCount := otherCount + 1;
		endif;
	endforeach;
	self.assertEqualMsg(twinLift1Count, twinLift2Count, "Twin Lift count do not match");
	self.assertEqual(voyageLoadJobTL.workListEntries.size, (otherCount + twinLift1Count + twinLift2Count));
	
	// check seqNumWorkOrder for GC multi loaded to slot
	foreach request in voyageLoadJobBB.allRequests do
		seqNum := 1;
		foreach wle in request.allWorkListEntries do
			self.assertEqualMsg(seqNum, wle.CM_VoyageWLE.seqNumWorkOrder, "WLE seqNumWorkOrder &lt;&gt; " &amp; seqNum.String);
			seqNum := seqNum + 1;
		endforeach;
		self.assertEqualMsg(request.allWorkListEntries.size, seqNum - 1, "Number of work list entries do not match");
	endforeach;
	
epilog
	
	delete strs;
	delete cargoArray;
	delete tas;
	delete slotsFrom;
	delete tmpLoadCC;
	delete locations;
	delete slotsToTL;
	delete slotsToNTL;
	delete slotsToBB;
	delete moveController;
	delete tiArray;
	delete lcArray;
	delete tiArray1;
	
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;MDHFAILSTEST&lt;/Category&gt;
    &lt;Category CanDelete="true"&gt;test1aasdfakhsdflkj&lt;/Category&gt;
    &lt;Category CanDelete="true"&gt;Fails1006&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tChkWLESeqNumWorkOrder2" id="2f07430d-889e-4036-a179-bb9b521cf169">
        <updating/>
        <source>tChkWLESeqNumWorkOrder2() updating;

/*

Purpose:		Check to voayge's wle's to see that the work order number is correct using trxMoveTrackedItemAssignToJob (Drag and Drop method)

Date			Who		Reason
31 October 2011	cnwmh5	Initial creation

*/
constants
	
	BlockStackId			: String = "UTMHBS1";
	YardAllocationId		: String = "UTMHBS1All";
	CraneTransferAreaId		: String = "UTC1TF";
	VesselId				: String = "UTMHHH2";
	VoyageId				: String = "UTMHHH2";
	CraneId					: String = "UTC2";
	QueueId					: String = "QUEID1";
	ForkliftId				: String = "UTF2";
	ContainerTLId			: String = "UTMHTL";
	ContainerNTLId			: String = "UTMHNTL";
	ContainerBBId			: String = "UTMHBB";
	CargoTypeId				: String = "Coal";
	CargoSubTypeId			: String = "LIGNITE";
	
vars
	
	blockStack				: CM_BlockStack;
	cta						: CM_CraneTransferArea;
	operator				: CM_Operator;
	dischargePort			: CM_Port;
	vessel					: CM_Vessel;
	voyage					: CM_Voyage;
	ti						: CM_TrackedItem;
	crane					: CM_Machine;
	tmpLoadCC				: CMIF_LoadColorCode;
	voyageLoadJobTL			: CM_VoyageJob;
	voyageLoadJobNTL		: CM_VoyageJob;
	voyageLoadJobBB			: CM_VoyageJob;
	cargo					: CM_Cargo;
	cargoType				: CM_CargoType;
	product					: CM_Product;
	slotLC					: CM_SlotController;
	moveController			: CMIF_MoveController;
	wle 					: CM_WorkListEntry;
	request					: CM_Request;
		
	locations				: CM_LCArray;
	slotsFrom				: CM_SlotControllerArray;
	slotsToTL				: CM_SlotControllerArray;
	slotsToNTL				: CM_SlotControllerArray;
	slotsToBB				: CM_SlotControllerArray;
	tiArray					: CM_TIArray;
	lcArray					: CM_LCArray;
	tiArray1				: CM_TIArray;
		
	strs 					: StringArray;
	cargoArray				: ObjectArray;
	tas						: StringArray;
	
	reqdNumberOfTis			: Integer;
	idx						: Integer;
	tiId					: String;
	seqNum					: Integer;
	otherCount,
	twinLift1Count, 
	twinLift2Count			: Integer;
	
begin

	self.setTerminalConfig(AllowRTSwithoutVGM, true);					// 10/06/2016 cnwmh5
	
	create tiArray1 transient;

	// get general values
	operator := app.myRoot.allOperators["UTOP"];
	dischargePort := app.myRoot.allPorts["NZPOE"];
	cargoType := self.getTerminal.getFirstNonSystemCargoType().CM_CargoType;
	product := cargoType.allProducts.first;
	
	// create the block stack
	self.deleteTerminalArea(BlockStackId);
	blockStack := addBlockStack(BlockStackId, 100, null);
	self.assertNotNull(blockStack);
	
	// create the crane transfer area
	self.deleteMachine(CraneId);
	self.opts.purge();
	self.opts.addAssoc("SetCraneLaneCages", true);
	self.deleteTerminalArea(CraneTransferAreaId);
	cta := self.addCraneTransferArea(CraneTransferAreaId);
	self.assertNotNull(cta);
	
	// create yard allocation;
	self.deleteYA(YardAllocationId);
	create locations transient;
	locations.add(blockStack.allLocationsControllers.first.CM_YardController);
	self.addYA1(YardAllocationId, YACriteriaType_OperatorItem, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, locations);
	
	// create Voyage
	deleteVoyage(VoyageId);
	deleteVessel(VesselId);
	vessel := addVesselCellular(VesselId, operator);
	voyage := addVoyageWithContainerStructur(VoyageId, VesselId, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	
	// create the crane
	create tas transient;
	tas.add(cta.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	crane := self.addCrane(CraneId, null, tas, null);
	self.assertNotNull(crane);
	
	create cargoArray transient;
	
	// create containers for twin lift loading
	self.opts.purge();
	self.opts.addAssoc("CENum", "12345");
	//self.opts.addAssoc("ReadyToShip", true);
	reqdNumberOfTis := 11;
	self.opts.addAssoc("TotalWeight", "2050");
	while reqdNumberOfTis &lt;&gt; 0 do
		tiId := ContainerTLId &amp; reqdNumberOfTis.String.padLeadingZeros(11 - ContainerTLId.length);
		self.deleteContainer(tiId);
		ti := self.addContainerAtLocation(tiId, operator, "2200", "GENL", TI_IMEX_STATUS_EXPORT, blockStack);
		self.updateTrackedItem(ti);
		self.deleteStops(ti);
		tiArray1.clear();
		tiArray1.add(ti);
		app.myTrxUA.trxUpdateTIsReadyToShip(tiArray1,true,app.myPassport);
		if ti &lt;&gt; null then
			cargoArray.add(ti);
		endif;
		reqdNumberOfTis := reqdNumberOfTis - 1;
	endwhile;
	
	// create containers for single lift loading
	self.opts.purge();
	self.opts.addAssoc("CENum", "12345");
	//self.opts.addAssoc("ReadyToShip", true);
	reqdNumberOfTis := 4;
	self.opts.addAssoc("TotalWeight", "2050");
	while reqdNumberOfTis &lt;&gt; 0 do
		tiId := ContainerNTLId &amp; reqdNumberOfTis.String.padLeadingZeros(11 - ContainerNTLId.length);
		self.deleteContainer(tiId);
		ti := self.addContainerAtLocation(tiId, operator, "2200", "GENL", TI_IMEX_STATUS_EXPORT, blockStack);
		self.updateTrackedItem(ti);
		self.deleteStops(ti);
		tiArray1.clear();
		tiArray1.add(ti);
		app.myTrxUA.trxUpdateTIsReadyToShip(tiArray1,true,app.myPassport);
		if ti &lt;&gt; null then
			cargoArray.add(ti);
		endif;
		reqdNumberOfTis := reqdNumberOfTis - 1;
	endwhile;
	
	// colour code the load slot for the twin lift
	create slotsToTL transient;
	self.getJobSlotControllers(VoyageId, "01", DeckOnDeck, 1, 1, 4, slotsToTL);
	self.getJobSlotControllers(VoyageId, "01", DeckOnDeck, 5, 3, 1, slotsToTL);
	self.getJobSlotControllers(VoyageId, "03", DeckOnDeck, 1, 1, 4, slotsToTL);
	self.getJobSlotControllers(VoyageId, "03", DeckOnDeck, 6, 4, 1, slotsToTL);
	self.getJobSlotControllers(VoyageId, "01", DeckUnderDeck, 1, 1, 1, slotsToTL);
	self.markSlotsAsLoadJob(slotsToTL, tmpLoadCC);
	self.markSlotsAsLoadCC(slotsToTL, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageLoadJobTL := self.addVoyageJob(voyage, crane.id, slotsToTL, false);
	assertTrue(voyageLoadJobTL &lt;&gt; null);
	
	// colour code the load slot for the single lift
	create slotsToNTL transient;
	self.getJobSlotControllers(VoyageId, "05", DeckOnDeck, 1, 1, 4, slotsToNTL);
	self.markSlotsAsLoadJob(slotsToNTL, tmpLoadCC);
	self.markSlotsAsLoadCC(slotsToNTL, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageLoadJobNTL := self.addVoyageJob(voyage, crane.id, slotsToNTL, false);
	assertTrue(voyageLoadJobNTL &lt;&gt; null);
	
	// load the containers to the ship
	idx := 1;
	while idx &lt;= cargoArray.size do
		ti := cargoArray[idx].CM_TrackedItem;
		beginTransaction;
		if idx &lt;= 11 then 
			slotLC := slotsToTL[idx];
			voyageLoadJobTL.updateReleaseTI(ti);
		else
			slotLC := slotsToNTL[idx-11];
			voyageLoadJobNTL.updateReleaseTI(ti);
		endif;
		commitTransaction;
		self.planItemBackToShip(ti, slotLC);	
		idx := idx + 1;
	endwhile;
	
	// create the bulk break cargo
	cargoArray.clear();
	reqdNumberOfTis := 12;
	self.opts.purge();
	self.opts.addAssoc( ETRow_CargoType, CargoTypeId );
	self.opts.addAssoc( ETRow_MyProduct, CargoSubTypeId );			
	self.opts.addAssoc( UTTI_IMEX, TI_IMEX_STATUS_EXPORT );
	//self.opts.addAssoc("ReadyToShip", true);
	self.opts.addAssoc("TotalWeight", "20");
	while reqdNumberOfTis &lt;&gt; 0 do
		tiId := ContainerBBId &amp; reqdNumberOfTis.String.padLeadingZeros(11 - ContainerBBId.length);
		self.deleteContainer(tiId);
		cargo := self.addCargoAtLocationDetailed(tiId,null, product, blockStack.myLocationsController, dischargePort.code, TI_IMEX_STATUS_EXPORT, voyage, operator);
		self.updateTrackedItem(cargo);
		tiArray1.clear();
		tiArray1.add(cargo);
		app.myTrxUA.trxUpdateTIsReadyToShip(tiArray1,true,app.myPassport);
		if cargo &lt;&gt; null then
			cargoArray.add(cargo);
		endif;
		reqdNumberOfTis := reqdNumberOfTis - 1;
	endwhile;
	
	// colour code the load slot for the single lift
	create slotsToBB transient;
	self.getJobSlotControllers(VoyageId, "07", DeckOnDeck, 1, 1, 4, slotsToBB);
	self.markSlotsAsLoadJob(slotsToBB, tmpLoadCC);
	self.markSlotsAsLoadCC(slotsToBB, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	voyageLoadJobBB := self.addVoyageJob(voyage, crane.id, slotsToBB, false);
	assertTrue(voyageLoadJobBB &lt;&gt; null);

	
	// load the break bulk to there slots
	self.opts.purge();
	self.opts.addAssoc("LikeDragAndDrop", true);
	create tiArray transient;
	tiArray.add(cargoArray[1].CM_TrackedItem);
	tiArray.add(cargoArray[2].CM_TrackedItem);
	tiArray.add(cargoArray[3].CM_TrackedItem);
	tiArray.add(cargoArray[4].CM_TrackedItem);
	create lcArray transient;
	lcArray.add(slotsToBB[1]);
	self.planGCTisLOLO(tiArray, lcArray);
	self.assertNoTrxErrorsOrWarnings();
	
	tiArray.clear();
	tiArray.add(cargoArray[5].CM_TrackedItem);
	tiArray.add(cargoArray[6].CM_TrackedItem);
	lcArray.clear();
	lcArray.add(slotsToBB[2]);
	self.planGCTisLOLO(tiArray, lcArray);
	self.assertNoTrxErrorsOrWarnings();
	
	tiArray.clear();
	tiArray.add(cargoArray[7].CM_TrackedItem);
	tiArray.add(cargoArray[8].CM_TrackedItem);
	lcArray.clear();
	lcArray.add(slotsToBB[3]);
	self.planGCTisLOLO(tiArray, lcArray);
	self.assertNoTrxErrorsOrWarnings();
	
	
	tiArray.clear();
	tiArray.add(cargoArray[9].CM_TrackedItem);
	tiArray.add(cargoArray[10].CM_TrackedItem);
	tiArray.add(cargoArray[11].CM_TrackedItem);
	tiArray.add(cargoArray[12].CM_TrackedItem);
	lcArray.clear();
	lcArray.add(slotsToBB[4]);
	self.planGCTisLOLO(tiArray, lcArray);
	self.assertNoTrxErrorsOrWarnings();
		
	// load to job ops
	self.loadAllJobsToOps(voyage, true);	
	
	// check seqNumWorkOrder for single lift
	foreach wle in voyageLoadJobNTL.workListEntries do
		self.assertEqualMsg(wle.CM_VoyageWLE.seqNumWorkOrder, 1, "WLE seqNumWorkOrder (" &amp; wle.CM_VoyageWLE.seqNumWorkOrder.String &amp; 
			") does not match 1");
	endforeach;
	
	// check seqNumWorkOrder for twin lift
	twinLift1Count := 0;
	twinLift2Count := 0;
	otherCount := 0;
	foreach wle in voyageLoadJobTL.workListEntries do
		if wle.CM_VoyageWLE.isTwinLift then
			if wle.CM_VoyageWLE.seqNumWorkOrder = 1 then
				twinLift1Count := twinLift1Count + 1;
			elseif wle.CM_VoyageWLE.seqNumWorkOrder = 2 then
				twinLift2Count := twinLift2Count + 1;
			endif;
		else
			otherCount := otherCount + 1;
		endif;
	endforeach;
	self.assertEqualMsg(twinLift1Count, twinLift2Count, "Twin Lift count do not match");
	self.assertEqual(voyageLoadJobTL.workListEntries.size, (otherCount + twinLift1Count + twinLift2Count));
	
	// check seqNumWorkOrder for GC multi loaded to slot
	foreach request in voyageLoadJobBB.allRequests do
		seqNum := 1;
		foreach wle in request.allWorkListEntries do
			self.assertEqualMsg(seqNum, wle.CM_VoyageWLE.seqNumWorkOrder, "WLE seqNumWorkOrder &lt;&gt; " &amp; seqNum.String);
			seqNum := seqNum + 1;
		endforeach;
		self.assertEqualMsg(request.allWorkListEntries.size, seqNum - 1, "Number of work list entries do not match");
	endforeach;
	
epilog
	
	delete strs;
	delete cargoArray;
	delete tas;
	delete slotsFrom;
	delete tmpLoadCC;
	delete locations;
	delete slotsToTL;
	delete slotsToNTL;
	delete slotsToBB;
	delete moveController;
	delete tiArray;
	delete lcArray;
	delete tiArray1;
	
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;MDHFAILSTEST&lt;/Category&gt;
    &lt;Category CanDelete="true"&gt;test1aasdfakhsdflkj&lt;/Category&gt;
    &lt;Category CanDelete="true"&gt;Fails1006&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tDeleteTBA" id="183a3c02-ba5b-46a8-b946-c4e32386c605">
        <updating/>
        <source>tDeleteTBA()updating;
/*

Purpose:			Delete TBA

Date		Who		Reason
01/05/2014	cnwma1	Initial creation

*/

vars
	voyageJob : CM_VoyageJob;
	realAlloc : CM_VoyageAllocation;
	slots : CM_SlotControllerArray;
	ss: CM_StraddleStack;
	tbaController : CMIF_TBAContainer;
	cargo, tbaCont : CM_TrackedItem;
	strs : StringArray;
	idx : Integer;	
	aPort : CM_Port;
	voy : CM_Voyage;
	op : CM_Operator;
	ct : CM_CargoType;
	product: CM_Product;
	startLC : CM_GridController;
	slotLC : CM_SlotController;
    ti	   : CM_TrackedItem;
	
begin
	
	// ### CREATE TERMINAL AREA AND VOYAGE
	voy := self.createVesselVoyage("CAI2020", "CAI", null);
	deleteTerminalArea("CAI2020");
	ss := self.addStraddleStack("CAI2020", 5,5,3);
	startLC := ss.allGridControllersByRowColumn.first();
	
	op := voy.myOperator;
	
	// #### CREATE LOAD COLOUR CODING
	create slots transient;
	self.getJobSlotControllers("CAI2020","01",DeckOnDeck,2,1,1,slots);
	realAlloc := self.addVoyageAllocation(voy, "NZAKL", "GEN2", null, TI_CargoType_Container, false, false);
	self.addLCsToLOLOAllocation(true, realAlloc, slots, null);
	voyageJob:=self.addVoyageJob(voy,"CRN2",slots, false);
	assertTrue(voyageJob &lt;&gt; null);
	slotLC := slots[1];
	slots.clear;

	// #### CREATE TBA
	create tbaController transient;
	
	tbaController.id				:=	"TBA";
	tbaController.myCommodity		:=	self.getCommodity("GENL");
	tbaController.myDischargePort	:=	self.getPort("NZAKL");
	tbaController.myISOType		:=	self.getISOType("2200");
	tbaController.myLocationSource	:=	startLC;
	tbaController.myLocationTarget	:=	slotLC; // where to plan the TBA
	tbaController.myOperator		:=	op; //self.getOperator("MSC");
	tbaController.myTerminal		:=	self.getTerminal;
	tbaController.bookingReference := "BOOKINGREF";
	tbaController.myVoyage			:=	voy;
	tbaController.state			:=	TI_STATE_TBA;
	tbaController.weight			:=	13750;
	tbaController.planContainer	:=	true;
	
	app.myPassport.setWarningsIgnored(true);
	app.myTrxCA.trxCreateTBAContainer(tbaController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	
	tbaCont := tbaController.myTrackedItem;
	assertTrueMsg(tbaCont.state = TI_STATE_TBA, "TBA should have a state of TBA!");
	assertTrueMsg(tbaCont.site = TI_SITE_TBA, "TBA should have a site of TBA!");
	
	ti := self.getTrackedItem(tbaController.myTrackedItem.id);
	self.assertNotNull(ti);
	self.unqueueTI(ti);
	self.unplanTI(ti);
	app.myTrxDA.trxDeleteTITba(ti,app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqual(voy.allExportTIs.size,0);
epilog

	delete tbaController;
	delete slots;
end;</source>
    </JadeMethod>
    <JadeMethod name="tDischHoldJobBrkBlkNonSplit" id="832b52fe-a17e-4109-b35f-2626dc1fc9b8">
        <source>tDischHoldJobBrkBlkNonSplit();
/*
Purpose: TFS 51988  Break Bulk Splittable have never before been able to be moved to an IMV by  part of what is on the voyage.
					Test that non splittable break bulk can be still moved to an IMV and Fork Lift to Yard with a HOLD job

Date		Who		Reason
07OCT2021	NAVAB1	TFS 51988
*/


constants
	
	VesselCode 		: String = 'SCONRO';
	Voyagecode 		: String = 'ABSPLIT';
	
	BBULKCargoType 	: String = "UT_WIDGET";  // Pre existing Break Bulk cargo type NO duplicates
	
	BBIdHR 			: String = "BBLK20006001";
	
	DRWorkPoint 	: String = "DRWP";
	
	// Machines
	IMV1 	= "IMVS";
	FLS	= "FLST";
	
	YANAME = "SPLITYA";
	
vars
	agent : CMIF_MobileGenericAgent;
	result: Boolean;

	operator 		: CM_Operator;
	shipLineStr 	: String;
	voyage 			: CM_Voyage;
	
	bbHR 			: CM_BreakBulkGeneric;
	newBBTI : CM_TrackedItem;
	
	
	bbCargoType 	: CM_CargoType;

	importHold 		: CM_LocationsController;
	exportHold 		: CM_LocationsController;
	bsLC			: CM_LocationsController;
	bs : CM_BlockStack;
	
	
	
	dischJob1		: CM_VoyageHoldJob;
	allocatedWLEs 	: CM_WLEArray;
	tmpVWle			: CM_VoyageWLE;
	workPoint 		: CM_WorkPoint;
	
	machine, imv 	: CM_Machine;
	queue			: CM_VoyageQueue;
	wpQueue			: CM_RadioTelemetryQueue;
	tas				: StringArray;
	
	loadWleSet		: CM_WLESet;
	cargos : CM_CargoTypeSet;
	wpaType, bsaType : CM_TerminalAreaType;
	locations : CM_LCArray;
	ya : CM_YardAllocation;
	rtq : CM_RadioTelemetryQueue;
	rtqtask : CM_RTQueueTask;
	bsID : String;
begin
	// ## BASE DATA SETUP
	bsID := self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	shipLineStr := self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString;
	bs:= self.addBlockStack(bsID, 99999, null);
	bsLC := bs.allLocationsControllers.first;
	workPoint := self.getWorkpoint(DRWorkPoint);
	
	self.opts.purge();
	
	bbCargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(BBULKCargoType);
	self.assertTrueMsg(bbCargoType &lt;&gt; null, "Cargo Type '" &amp; BBULKCargoType &amp; "' not found during setup.");
	self.assertTrueMsg(not bbCargoType.allowDuplicates, "Cargo Type '" &amp; BBULKCargoType &amp; "' is splittable.");  // ### TFS 51988 07OCT2021 NAVAB1
	
	
	// ### CLEANUP OLD DATA
	if workPoint.myWorkPointInterchangeArea &lt;&gt; null then
		wpaType := workPoint.myWorkPointInterchangeArea.myType;
	endif;
	if bs &lt;&gt; null then
		bsaType := bs.myType;
	endif;

	self.deleteMachineRule(wpaType, bsaType);
	self.deleteVoyage(Voyagecode);
	self.deleteCargo( BBIdHR, bbCargoType );
	self.deleteYA(YANAME);
		
	// ### MORE DATA SETUP

	// ### Add Machine Rule WPTA to BS = IMV&gt;&gt;FL
	self.addMachineRuleType(wpaType, bsaType, RTMoveMethod_7, FullMoveQueuing);

	// ### ADD VOYAGE AND HOLDS
	voyage := self.addVoyageWithConRORO(Voyagecode, VesselCode, operator.code, shipLineStr, null, 0, false, true);
	self.assertTrueMsg(voyage &lt;&gt; null, "'Voyage' not created during setup");
	
	importHold := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace.first;
	exportHold := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace.last;
	assertNotNullMsg(importHold, "Voyage doesn't have any holds");
	assertNotEqualMsg(exportHold, importHold, "Voyage doesn't have enough holds");
	
	
	// ### CREATE CARGO ON SHIP
	bbHR := self.addCargoBreakBulkAtLocation(BBIdHR, bbCargoType, 1000, importHold, null, TI_IMEX_STATUS_IMPORT, voyage, operator).CM_BreakBulkGeneric;
	self.assertTrueMsg(bbHR &lt;&gt; null, "'" &amp; BBIdHR &amp; "' on ship cargo not created during setup");
	self.opts.addAssoc("TotalWeight", 80);
	self.updateTI( bbHR );
	
	// ## CLEARUP ANY STOPS ADDED
	self.deleteStops( bbHR );
	
	// ## HOLD DISCHARGE JOB - 200 of 1000 for Break-bulk
	create allocatedWLEs transient;
	create tmpVWle transient;
	allocatedWLEs.add(tmpVWle);
	tmpVWle.setMyTrackedItem(bbHR);
	tmpVWle.setQuantity(1000);
	dischJob1 := self.addVoyageHoldJob(JOB_TYPE_DISCHARGE, voyage, allocatedWLEs, bsLC, workPoint);
	self.assertNotNullMsg(dischJob1, "Discharge job 1 not created");
	self.assertEqualMsg(dischJob1.workListEntries.size, 1, "Disc Job 1 wrong number of WLEs");
	
	
	// ### CREATE YA FOR DISCHARGE CARGO
	create tas transient;
	tas.add(workPoint.myWorkPointInterchangeArea.id);	// SOURCE
	tas.add(bsID); // TARGET
	
	create locations transient;
	locations.add(bsLC);
	ya := self.addYA(YANAME,YACriteriaType_ImexStatus,app.myRoot.allImexStatuses[TI_IMEX_STATUS_IMPORT], YACriteriaType_Voyage, voyage, 0, 0, locations, null);
	beginTransaction;
	ya.setPriorityValue(999999);
	commitTransaction;
	
	// ### ADD RTQUEUES
	queue := self.addVoyageQueue(voyage);
	beginTransaction;
	queue.createWorkPointQueue(workPoint, wpQueue);
	commitTransaction;
	
	// ### CREATE AND CONFIGURE IMV
	machine := self.addMachine(MACHINETYPE_FORK_LIFT, FLS, 94, tas, wpQueue.id);
	
	create cargos transient;
	cargos.add(bbCargoType);
	beginTransaction;
	machine.setCargoTypes(cargos);
	commitTransaction;
	imv := self.addIMV(IMV1, 93, tas, wpQueue.id);
	self.machineAssignToQueue(imv,wpQueue);


	// ### LOAD JOB TO OPS
	self.loadAllJobsToOps(voyage, true);
	
	
	
	// ### PERFORM DISCHARGE TO MACHINE
	create agent transient;
	agent.setMyTerminal(self.getTerminal());
	agent.setMyVoyage(voyage);
	agent.setDoNotShowMsgBox(true);
	
	on CM_Exception do app.validationExHandler(exception,app.myPassport);
	
	result :=agent.doLanderDischarge(bbHR, imv.getMyVehicleMachineController,200,null);
	self.checkTrxResult();
	self.assertTrue(result );
	
	// ### IS IT IN AN RTQUEUE?
	rtq := bbHR.allQueues.first;
	self.assertNotNull(rtq);
	
	// #### LOGON TO THE FORK LIFT, ASSIGN TO YARD QUEUE
	self.machineLogon(machine);
	self.machineAssignToQueue(machine,rtq);
	rtqtask := bbHR.queueTask.myEntry.myNextRelatedEntry.allTasks.first;
	
	
	// ### ACCEPT THE Q ENTRY
	self.machineAcceptSpecifiedTask(machine,rtqtask.myEntry);

	// ### PICKUP
	self.opts.addAssoc("QUANTITY", 200);
	self.machinePickup(machine);
	assertEqual(bbHR.myPrimaryActualLocation, machine.myMachineController);

	// ### SETDOWN
	self.machineSetdown(machine,bbHR, bs.id);
	assertEqual(bbHR.myPrimaryActualLocation,bsLC);
	
	// ### LOGOFF
	self.machineLogOff(machine);
	
	self.assertEqualMsg(bbHR.totalQuantity,1000,"In Yard Cargo Should Have Quantity 1000");
	
	// ### TIDYUP
	self.deleteVoyage(Voyagecode);
	self.deleteCargo( BBIdHR, bbCargoType );
	self.deleteYA(YANAME);
	self.deleteMachineRule(wpaType, bsaType);
	
epilog
	
	delete locations;
	if process.isInTransactionState then
		abortTransaction;
	endif;
	if allocatedWLEs &lt;&gt; null then
		beginTransaction;
		allocatedWLEs.purge();
		commitTransaction;
	endif;
	delete loadWleSet;
	delete allocatedWLEs;
	delete tas;
	
	delete agent;
	delete cargos;
end;</source>
    </JadeMethod>
    <JadeMethod name="tDischHoldJobBrkBlkSplit" id="d46d2e5b-225d-4a14-b92b-fa275c719774">
        <source>tDischHoldJobBrkBlkSplit();
/*
Purpose: TFS 51988  Break Bulk Splittable have never before been able to be moved to an IMV by  part of what is on the voyage.
					Test that splittable break bulk can be moved to an IMV and Fork Lift to Yard with a HOLD job


Date		Who		Reason
07OCT2021	NAVAB1	TFS 51988
*/


constants
	
	VesselCode 		: String = 'SCONRO';
	Voyagecode 		: String = 'ABSPLIT';
	
	BBULKCargoType 	: String = "UTREBAR";  // Pre existing Break Bulk cargo type allows duplicates
	
	ContIdHR 		: String = "CONT0007001";
	ContIdHR2 		: String = "CONT0007002";
	BBIdHR 			: String = "BBLK20006001";
	
	
	DRWorkPoint 	: String = "DRWP";
	
	// Machines
	IMV1 	= "IMVS";
	FLS	= "FLST";
	
	YANAME = "SPLITYA";
	
vars
	agent : CMIF_MobileGenericAgent;
	result: Boolean;

	operator 		: CM_Operator;
	shipLineStr 	: String;
	voyage 			: CM_Voyage;
	
	bbHR 			: CM_BreakBulkGeneric;
	newBBTI : CM_TrackedItem;
	
	
	bbCargoType 	: CM_CargoType;

	importHold 		: CM_LocationsController;
	exportHold 		: CM_LocationsController;
	bsLC			: CM_LocationsController;
	bs : CM_BlockStack;
	
	
	
	dischJob1		: CM_VoyageHoldJob;
	allocatedWLEs 	: CM_WLEArray;
	tmpVWle			: CM_VoyageWLE;
	workPoint 		: CM_WorkPoint;
	
	machine, imv 	: CM_Machine;
	queue			: CM_VoyageQueue;
	wpQueue			: CM_RadioTelemetryQueue;
	tas				: StringArray;
	
	loadWleSet		: CM_WLESet;
	cargos : CM_CargoTypeSet;
	wpaType, bsaType : CM_TerminalAreaType;
	locations : CM_LCArray;
	ya : CM_YardAllocation;
	rtq : CM_RadioTelemetryQueue;
	rtqtask : CM_RTQueueTask;
	bsID : String;
begin
	
	// ### CLEANUP OLD DATA
	workPoint := self.getWorkpoint(DRWorkPoint);
	if workPoint.myWorkPointInterchangeArea &lt;&gt; null then
		wpaType := workPoint.myWorkPointInterchangeArea.myType;
	endif;

	self.deleteMachineRule(wpaType, bsaType);
	self.deleteVoyage(Voyagecode);
	self.deleteCargo( BBIdHR, bbCargoType );
	self.deleteYA(YANAME);
		
	// ## BASE DATA SETUP
	bsID := self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	shipLineStr := self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString;
	bs:= self.addBlockStack(bsID, 99999, null);
	bsLC := bs.allLocationsControllers.first;
	if bs &lt;&gt; null then
		bsaType := bs.myType;
	endif;
	
	self.opts.purge();
	
	bbCargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(BBULKCargoType);
	self.assertTrueMsg(bbCargoType &lt;&gt; null, "Cargo Type '" &amp; BBULKCargoType &amp; "' not found during setup.");
	self.assertTrueMsg(bbCargoType.allowDuplicates, "Cargo Type '" &amp; BBULKCargoType &amp; "' is not splittable.");  // ### TFS 51988 07OCT2021 NAVAB1

	// ### Add Machine Rule WPTA to BS = IMV&gt;&gt;FL
	self.addMachineRuleType(wpaType, bsaType, RTMoveMethod_7, FullMoveQueuing);

	// ### ADD VOYAGE AND HOLDS
	voyage := self.addVoyageWithConRORO(Voyagecode, VesselCode, operator.code, shipLineStr, null, 0, false, true);
	self.assertTrueMsg(voyage &lt;&gt; null, "'Voyage' not created during setup");
	
	importHold := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace.first;
	exportHold := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace.last;
	assertNotNullMsg(importHold, "Voyage doesn't have any holds");
	assertNotEqualMsg(exportHold, importHold, "Voyage doesn't have enough holds");
	
	
	// ### CREATE CARGO ON SHIP
	bbHR := self.addCargoBreakBulkAtLocation(BBIdHR, bbCargoType, 1000, importHold, null, TI_IMEX_STATUS_IMPORT, voyage, operator).CM_BreakBulkGeneric;
	self.assertTrueMsg(bbHR &lt;&gt; null, "'" &amp; BBIdHR &amp; "' on ship cargo not created during setup");
	self.opts.addAssoc("TotalWeight", 80);
	self.updateTI( bbHR );
	
	
	// ## CLEARUP ANY STOPS ADDED
	self.deleteStops( bbHR );
	
	// ## HOLD DISCHARGE JOB - 200 of 1000 for Break-bulk
	create allocatedWLEs transient;
	create tmpVWle transient;
	allocatedWLEs.add(tmpVWle);
	tmpVWle.setMyTrackedItem(bbHR);
	tmpVWle.setQuantity(1000);
	dischJob1 := self.addVoyageHoldJob(JOB_TYPE_DISCHARGE, voyage, allocatedWLEs, bsLC, workPoint);
	self.assertNotNullMsg(dischJob1, "Discharge job 1 not creted");
	self.assertEqualMsg(dischJob1.workListEntries.size, 1, "Disc Job 1 wrong number of WLEs");
	
	
	// ### CREATE YA FOR DISCHARGE CARGO
	create tas transient;
	tas.add(workPoint.myWorkPointInterchangeArea.id);	// SOURCE
	tas.add(bsID); // TARGET
	
	create locations transient;
	locations.add(bsLC);
	ya := self.addYA(YANAME,YACriteriaType_ImexStatus,app.myRoot.allImexStatuses[TI_IMEX_STATUS_IMPORT], YACriteriaType_Voyage, voyage, 0, 0, locations, null);
	beginTransaction;
	ya.setPriorityValue(999999);
	commitTransaction;
	
	// ### ADD RTQUEUES
	queue := self.addVoyageQueue(voyage);
	beginTransaction;
	queue.createWorkPointQueue(workPoint, wpQueue);
	commitTransaction;
	
	// ### CREATE AND CONFIGURE IMV
	machine := self.addMachine(MACHINETYPE_FORK_LIFT, FLS, 94, tas, wpQueue.id);
	
	create cargos transient;
	cargos.add(bbCargoType);
	beginTransaction;
	machine.setCargoTypes(cargos);
	commitTransaction;
	imv := self.addIMV(IMV1, 93, tas, wpQueue.id);
	self.machineAssignToQueue(imv,wpQueue);


	// ### LOAD JOB TO OPS
	self.loadAllJobsToOps(voyage, true);
	
	
	
	// ### PERFORM DISCHARGE TO MACHINE
	create agent transient;
	agent.setMyTerminal(self.getTerminal());
	agent.setMyVoyage(voyage);
	agent.setDoNotShowMsgBox(true);
	
	on CM_Exception do app.validationExHandler(exception,app.myPassport);
	
	result :=agent.doLanderDischarge(bbHR, imv.getMyVehicleMachineController,200,null);
	self.checkTrxResult();
	self.assertTrue(result );
	
	// ### IS THERE A NEW TI (SPLIT 200 from 1000)
	newBBTI := bbHR.allSplitChildrenTis.first;
	self.assertNotNull(newBBTI);
	assertEqual(newBBTI.myPrimaryActualLocation, imv.myMachineController);
	assertEqual(newBBTI.myPrimaryQueuedLocation, bsLC);
	
	// ### IS IT IN AN RTQUEUE?
	rtq := newBBTI.allQueues.first;
	self.assertNotNull(rtq);
	
	// #### LOGON TO THE FORK LIFT, ASSIGN TO YARD QUEUE
	self.machineLogon(machine);
	self.machineAssignToQueue(machine,rtq);
	rtqtask := newBBTI.queueTask.myEntry.myNextRelatedEntry.allTasks.first;
	
	
	// ### ACCEPT THE Q ENTRY
	self.machineAcceptSpecifiedTask(machine,rtqtask.myEntry);

	// ### PICKUP
	self.opts.addAssoc("QUANTITY", 200);
	self.machinePickup(machine);
	assertEqual(newBBTI.myPrimaryActualLocation, machine.myMachineController);

	// ### SETDOWN
	self.machineSetdown(machine,newBBTI, bs.id);
	assertEqual(newBBTI.myPrimaryActualLocation,bsLC);
	
	// ### LOGOFF
	self.machineLogOff(machine);
	
	self.assertEqualMsg(bbHR.totalQuantity,800,"Onship Cargo Should Have Quantity 800");
	self.assertEqualMsg(newBBTI.totalQuantity,200,"In Yard Cargo Should Have Quantity 200");
	
	// ### TIDYUP
	self.deleteVoyage(Voyagecode);
	self.deleteCargo( BBIdHR, bbCargoType );
	self.deleteYA(YANAME);
	self.deleteMachineRule(wpaType, bsaType);
	
epilog
	
	delete locations;
	if process.isInTransactionState then
		abortTransaction;
	endif;
	if allocatedWLEs &lt;&gt; null then
		beginTransaction;
		allocatedWLEs.purge();
		commitTransaction;
	endif;
	delete loadWleSet;
	delete allocatedWLEs;
	delete tas;
	
	delete agent;
	delete cargos;
end;</source>
    </JadeMethod>
    <JadeMethod name="tDischHoldJobContainer" id="5a025fe1-0fff-493c-8e1e-109df3d7a53f">
        <source>tDischHoldJobContainer();
/*
Purpose: TFS 51988  Break Bulk Splittable have never before been able to be moved to an IMV by  part of what is on the voyage.
					Test that container can still be moved to an IMV and Fork Lift to Yard with a HOLD job

Date		Who		Reason
07OCT2021	NAVAB1	TFS 51988
*/


constants
	
	VesselCode 		: String = 'SCONRO';
	Voyagecode 		: String = 'ABSPLIT';
	
	ContIdHR 		: String = "CONT0007001";
	
	DRWorkPoint 	: String = "DRWP";
	
	// Machines
	IMV1 	= "IMVS";
	FLS	= "FLST";
	
	YANAME = "SPLITYA";
	
vars
	agent : CMIF_MobileGenericAgent;
	result: Boolean;

	operator 		: CM_Operator;
	shipLineStr 	: String;
	voyage 			: CM_Voyage;
	
	contHR 			: CM_Container;
	newBBTI : CM_TrackedItem;
	
	contCargoType 	: CM_CargoType;

	importHold 		: CM_LocationsController;
	exportHold 		: CM_LocationsController;
	bsLC			: CM_LocationsController;
	bs : CM_BlockStack;	
	
	dischJob1		: CM_VoyageHoldJob;
	allocatedWLEs 	: CM_WLEArray;
	tmpVWle			: CM_VoyageWLE;
	workPoint 		: CM_WorkPoint;
	
	machine, imv 	: CM_Machine;
	queue			: CM_VoyageQueue;
	wpQueue			: CM_RadioTelemetryQueue;
	tas				: StringArray;
	
	loadWleSet		: CM_WLESet;
	cargos : CM_CargoTypeSet;
	wpaType, bsaType : CM_TerminalAreaType;
	locations : CM_LCArray;
	ya : CM_YardAllocation;
	rtq : CM_RadioTelemetryQueue;
	rtqtask : CM_RTQueueTask;
	bsID : String;
begin
	// ## BASE DATA SETUP
	bsID := self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	shipLineStr := self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString;
	bs:= self.addBlockStack(bsID, 99999, null);
	bsLC := bs.allLocationsControllers.first;
	workPoint := self.getWorkpoint(DRWorkPoint);
	
	self.opts.purge();
	
	contCargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	self.assertTrueMsg(contCargoType &lt;&gt; null, "Container Cargo Type not found during setup.");
	
	// ### CLEANUP OLD DATA
	if workPoint.myWorkPointInterchangeArea &lt;&gt; null then
		wpaType := workPoint.myWorkPointInterchangeArea.myType;
	endif;
	if bs &lt;&gt; null then
		bsaType := bs.myType;
	endif;

	self.deleteMachineRule(wpaType, bsaType);
	self.deleteVoyage(Voyagecode);
	self.deleteContainer( ContIdHR );
	self.deleteYA(YANAME);
		
	// ### MORE DATA SETUP

	// ### Add Machine Rule WPTA to BS = IMV&gt;&gt;FL
	self.addMachineRuleType(wpaType, bsaType, RTMoveMethod_7, FullMoveQueuing);

	// ### ADD VOYAGE AND HOLDS
	voyage := self.addVoyageWithConRORO(Voyagecode, VesselCode, operator.code, shipLineStr, null, 0, false, true);
	self.assertTrueMsg(voyage &lt;&gt; null, "'Voyage' not created during setup");
	
	importHold := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace.first;
	exportHold := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace.last;
	assertNotNullMsg(importHold, "Voyage doesn't have any holds");
	assertNotEqualMsg(exportHold, importHold, "Voyage doesn't have enough holds");
	
	
	// ### CREATE CARGO ON SHIP

	contHR := self.addContainerAtLocation(ContIdHR, operator, "2200", "MT", TI_IMEX_STATUS_IMPORT, importHold);
	self.assertTrueMsg(contHR &lt;&gt; null, "'" &amp; ContIdHR &amp; "' on ship cargo not created during setup");
	
	// ## CLEARUP ANY STOPS ADDED
	self.deleteStops( contHR );
	
	// ## HOLD DISCHARGE JOB - 1 CONTAINER
	create allocatedWLEs transient;
	create tmpVWle transient;
	allocatedWLEs.add(tmpVWle);
	tmpVWle.setMyTrackedItem(contHR);
	dischJob1 := self.addVoyageHoldJob(JOB_TYPE_DISCHARGE, voyage, allocatedWLEs, bsLC, workPoint);
	self.assertNotNullMsg(dischJob1, "Discharge job 1 not created");
	self.assertEqualMsg(dischJob1.workListEntries.size, 1, "Disc Job 1 wrong number of WLEs");
	
	
	// ### CREATE YA FOR DISCHARGE CARGO
	create tas transient;
	tas.add(workPoint.myWorkPointInterchangeArea.id);	// SOURCE
	tas.add(bsID); // TARGET
	
	create locations transient;
	locations.add(bsLC);
	ya := self.addYA(YANAME,YACriteriaType_ImexStatus,app.myRoot.allImexStatuses[TI_IMEX_STATUS_IMPORT], YACriteriaType_Voyage, voyage, 0, 0, locations, null);
	beginTransaction;
	ya.setPriorityValue(999999);
	commitTransaction;
	
	// ### ADD RTQUEUES
	queue := self.addVoyageQueue(voyage);
	beginTransaction;
	queue.createWorkPointQueue(workPoint, wpQueue);
	commitTransaction;
	
	// ### CREATE AND CONFIGURE IMV
	machine := self.addMachine(MACHINETYPE_FORK_LIFT, FLS, 94, tas, wpQueue.id);
	
	create cargos transient;
	cargos.add(contCargoType);
	beginTransaction;
	machine.setCargoTypes(cargos);
	commitTransaction;
	imv := self.addIMV(IMV1, 93, tas, wpQueue.id);
	self.machineAssignToQueue(imv,wpQueue);


	// ### LOAD JOB TO OPS
	self.loadAllJobsToOps(voyage, true);
	
	
	
	// ### PERFORM DISCHARGE TO MACHINE
	create agent transient;
	agent.setMyTerminal(self.getTerminal());
	agent.setMyVoyage(voyage);
	agent.setDoNotShowMsgBox(true);
	
	on CM_Exception do app.validationExHandler(exception,app.myPassport);
	
	result :=agent.doLanderDischarge(contHR, imv.getMyVehicleMachineController,200,null);
	self.checkTrxResult();
	self.assertTrue(result );
	
	// ### IS IT IN AN RTQUEUE?
	rtq := contHR.allQueues.first;
	self.assertNotNull(rtq);
	
	// #### LOGON TO THE FORK LIFT, ASSIGN TO YARD QUEUE
	self.machineLogon(machine);
	self.machineAssignToQueue(machine,rtq);
	rtqtask := contHR.queueTask.myEntry.myNextRelatedEntry.allTasks.first;
	
	
	// ### ACCEPT THE Q ENTRY
	self.machineAcceptSpecifiedTask(machine,rtqtask.myEntry);

	// ### PICKUP
	self.opts.addAssoc("QUANTITY", 200);
	self.machinePickup(machine);
	assertEqual(contHR.myPrimaryActualLocation, machine.myMachineController);

	// ### SETDOWN
	self.machineSetdown(machine,contHR, bs.id);
	assertEqual(contHR.myPrimaryActualLocation,bsLC);
	
	// ### LOGOFF
	self.machineLogOff(machine);
	
	// ### TIDYUP
	self.deleteVoyage(Voyagecode);
	self.deleteContainer( ContIdHR );
	self.deleteYA(YANAME);
	self.deleteMachineRule(wpaType, bsaType);
	
epilog
	
	delete locations;
	if process.isInTransactionState then
		abortTransaction;
	endif;
	if allocatedWLEs &lt;&gt; null then
		beginTransaction;
		allocatedWLEs.purge();
		commitTransaction;
	endif;
	delete loadWleSet;
	delete allocatedWLEs;
	delete tas;
	
	delete agent;
	delete cargos;
end;</source>
    </JadeMethod>
    <JadeMethod name="tDischNoJobBrkBlkSplit" id="7888fade-fecc-46f0-9d2a-bdaf5331d0b9">
        <source>tDischNoJobBrkBlkSplit();
/*
Purpose: TFS 51988  Break Bulk Splittable have never before been able to be moved to an IMV by  part of what is on the voyage.
					Test that splittable break bulk can be moved to an IMV and Fork Lift to Yard with out a job


Date		Who		Reason
07OCT2021	NAVAB1	TFS 51988
*/


constants
	
	VesselCode 		: String = 'SCONRO';
	Voyagecode 		: String = 'ABSPLIT';
	
	BBULKCargoType 	: String = "UTREBAR";  // Pre existing Break Bulk cargo type allows duplicates
	
	ContIdHR 		: String = "CONT0007001";
	ContIdHR2 		: String = "CONT0007002";
	BBIdHR 			: String = "BBLK20006001";
	
	
	DRWorkPoint 	: String = "DRWP";
	
	// Machines
	IMV1 	= "IMVS";
	FLS	= "FLST";
	
	YANAME = "SPLITYA";
	
vars
	agent : CMIF_MobileGenericAgent;
	result: Boolean;

	operator 		: CM_Operator;
	shipLineStr 	: String;
	voyage 			: CM_Voyage;
	
	bbHR 			: CM_BreakBulkGeneric;
	newBBTI : CM_TrackedItem;
	
	
	bbCargoType 	: CM_CargoType;
	contCargoType 	: CM_CargoType;

	importHold 		: CM_LocationsController;
	exportHold 		: CM_LocationsController;
	bsLC			: CM_LocationsController;
	bs : CM_BlockStack;
	
	workPoint 		: CM_WorkPoint;
	
	machine, imv 	: CM_Machine;
	queue			: CM_VoyageQueue;
	wpQueue			: CM_RadioTelemetryQueue;
	tas				: StringArray;
	cargos : CM_CargoTypeSet;
	wpaType, bsaType : CM_TerminalAreaType;
	locations : CM_LCArray;
	ya : CM_YardAllocation;
	rtq : CM_RadioTelemetryQueue;
	rtqtask : CM_RTQueueTask;
	bsID : String;
begin
	// ## BASE DATA SETUP
	bsID := self.getProfileSetting(UT_Profile.P_BLOCKSTACK).asString;
	operator := self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString);
	shipLineStr := self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString;
	bs:= self.addBlockStack(bsID, 99999, null);
	bsLC := bs.allLocationsControllers.first;
	workPoint := self.getWorkpoint(DRWorkPoint);
	
	self.opts.purge();
	
	bbCargoType := app.myRoot.getCargoTypeFromAbbrevOrDescr(BBULKCargoType);
	self.assertTrueMsg(bbCargoType &lt;&gt; null, "Cargo Type '" &amp; BBULKCargoType &amp; "' not found during setup.");
	self.assertTrueMsg(bbCargoType.allowDuplicates, "Cargo Type '" &amp; BBULKCargoType &amp; "' is not splittable.");  // ### TFS 51988 07OCT2021 NAVAB1
	
	contCargoType := app.myRoot.allCargoTypesById[TI_CargoType_Container];
	self.assertTrueMsg(contCargoType &lt;&gt; null, "Container Cargo Type not found during setup.");
	
	// ### CLEANUP OLD DATA
	if workPoint.myWorkPointInterchangeArea &lt;&gt; null then
		wpaType := workPoint.myWorkPointInterchangeArea.myType;
	endif;
	if bs &lt;&gt; null then
		bsaType := bs.myType;
	endif;

	self.deleteMachineRule(wpaType, bsaType);
	self.deleteVoyage(Voyagecode);
	self.deleteContainer( ContIdHR );
	self.deleteContainer( ContIdHR2 );
	self.deleteCargo( BBIdHR, bbCargoType );
	self.deleteYA(YANAME);
		
	// ### MORE DATA SETUP

	// ### Add Machine Rule WPTA to BS = IMV&gt;&gt;FL
	self.addMachineRuleType(wpaType, bsaType, RTMoveMethod_7, FullMoveQueuing);

	// ### ADD VOYAGE AND HOLDS
	voyage := self.addVoyageWithConRORO(Voyagecode, VesselCode, operator.code, shipLineStr, null, 0, false, true);
	self.assertTrueMsg(voyage &lt;&gt; null, "'Voyage' not created during setup");
	
	importHold := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace.first;
	exportHold := voyage.myGeneralCargoVoyage.allLocationsByHatchPlace.last;
	assertNotNullMsg(importHold, "Voyage doesn't have any holds");
	assertNotEqualMsg(exportHold, importHold, "Voyage doesn't have enough holds");
	
	
	// ### CREATE CARGO ON SHIP
	bbHR := self.addCargoBreakBulkAtLocation(BBIdHR, bbCargoType, 1000, importHold, null, TI_IMEX_STATUS_IMPORT, voyage, operator).CM_BreakBulkGeneric;
	self.assertTrueMsg(bbHR &lt;&gt; null, "'" &amp; BBIdHR &amp; "' on ship cargo not created during setup");
	self.opts.addAssoc("TotalWeight", 80);
	self.updateTI( bbHR );
	
	
	
	// ## CLEARUP ANY STOPS ADDED
	self.deleteStops( bbHR );
	
	// ### CREATE YA FOR DISCHARGE CARGO
	create tas transient;
	tas.add(workPoint.myWorkPointInterchangeArea.id);	// SOURCE
	tas.add(bsID); // TARGET
	
	create locations transient;
	locations.add(bsLC);
	ya := self.addYA(YANAME,YACriteriaType_ImexStatus,app.myRoot.allImexStatuses[TI_IMEX_STATUS_IMPORT], YACriteriaType_Voyage, voyage, 0, 0, locations, null);
	beginTransaction;
	ya.setPriorityValue(999999);
	commitTransaction;
	
	// ### ADD RTQUEUES
	queue := self.addVoyageQueue(voyage);
	beginTransaction;
	queue.createWorkPointQueue(workPoint, wpQueue);
	commitTransaction;
	
	// ### CREATE AND CONFIGURE IMV
	machine := self.addMachine(MACHINETYPE_FORK_LIFT, FLS, 94, tas, wpQueue.id);
	
	create cargos transient;
	cargos.add(bbCargoType);
	cargos.add(contCargoType);
	beginTransaction;
	machine.setCargoTypes(cargos);
	commitTransaction;
	imv := self.addIMV(IMV1, 93, tas, wpQueue.id);
	self.machineAssignToQueue(imv,wpQueue);


	// ### LOAD JOB TO OPS
	self.loadAllJobsToOps(voyage, true);
	
	
	
	// ### PERFORM DISCHARGE TO MACHINE
	create agent transient;
	agent.setMyTerminal(self.getTerminal());
	agent.setMyVoyage(voyage);
	agent.setDoNotShowMsgBox(true);
	
	on CM_Exception do app.validationExHandler(exception,app.myPassport);
	
	result :=agent.doLanderDischarge(bbHR, imv.getMyVehicleMachineController,200,null);
	self.checkTrxResult();
	self.assertTrue(result );
	
	// ### IS THERE A NEW TI (SPLIT 200 from 1000)
	newBBTI := bbHR.allSplitChildrenTis.first;
	self.assertNotNull(newBBTI);
	assertEqual(newBBTI.myPrimaryActualLocation, imv.myMachineController);
	assertEqual(newBBTI.myPrimaryQueuedLocation, bsLC);
	
	// ### IS IT IN AN RTQUEUE?
	rtq := newBBTI.allQueues.first;
	self.assertNotNull(rtq);
	
	// #### LOGON TO THE FORK LIFT, ASSIGN TO YARD QUEUE
	self.machineLogon(machine);
	self.machineAssignToQueue(machine,rtq);
	rtqtask := newBBTI.queueTask.myEntry.myNextRelatedEntry.allTasks.first;
	
	
	// ### ACCEPT THE Q ENTRY
	self.machineAcceptSpecifiedTask(machine,rtqtask.myEntry);

	// ### PICKUP
	self.opts.addAssoc("QUANTITY", 200);
	self.machinePickup(machine);
	assertEqual(newBBTI.myPrimaryActualLocation, machine.myMachineController);

	// ### SETDOWN
	self.machineSetdown(machine,newBBTI, bs.id);
	assertEqual(newBBTI.myPrimaryActualLocation,bsLC);
	
	// ### LOGOFF
	self.machineLogOff(machine);
	
	self.assertEqualMsg(bbHR.totalQuantity,800,"Onship Cargo Should Have Quantity 800");
	self.assertEqualMsg(newBBTI.totalQuantity,200,"In Yard Cargo Should Have Quantity 200");
	
	// ### TIDYUP
	self.deleteVoyage(Voyagecode);
	self.deleteCargo( BBIdHR, bbCargoType );
	self.deleteYA(YANAME);
	self.deleteMachineRule(wpaType, bsaType);
	
epilog
	
	delete locations;
	if process.isInTransactionState then
		abortTransaction;
	endif;
	delete tas;
	
	delete agent;
	delete cargos;
end;</source>
    </JadeMethod>
    <JadeMethod name="tDischargeModeAccept" id="f14f3fda-578b-499f-b630-653b1968bece">
        <updating/>
        <source>tDischargeModeAccept() updating;
// cnwer1
//cnwdw1
/*
Purpose:	Check that accepting a discharge task, does not move it to the cta.		
*/

constants
	DischargeBox		= "UTDR0000002";
	BlockStack1			= "UT_RDBS1";
	YardIC				= "UT_RD_IC";
	Ship				= "UTRDSHIP";
	Voyage1				= "UTRDVOYAGE";
	CraneTransferAreaId	= "CTRD";
	CraneId				= "CRR1";

vars
	dischargeTi,
	ti4				: CM_TrackedItem;
	bs				: CM_BlockStack;
	yardIC			: CM_InterchangeArea;
	wle				: CM_WorkListEntry;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	slots 			: CM_SlotControllerArray;
	voyageJob		: CM_VoyageJob;
	job				: CM_Job;
	request			: CM_Request;
	voyageQueue		: CM_VoyageQueue;
	craneQueue		: CM_VoyageCraneQueue;
	crane			: CM_Machine;
	operator		: CM_Operator;
	bayName			: String;
	loadPort,
	dischargePort	: CM_Port;
	jobs			: CM_JobArray;
	voyAlloc		: CM_VoyageAllocation;
	wles 			: CM_WLEArray;
	straddle		: CM_Machine;
	tas				: StringArray;
	cta				: CM_CraneTransferArea;
begin
	
	create jobs transient;
	create wles transient;

	// delete everything first
	self.deleteContainer(DischargeBox);
	self.deleteTerminalArea(BlockStack1);
	self.deleteTerminalArea(YardIC);
	self.deleteVoyage(Voyage1);
	self.deleteVessel(Ship);
	self.deleteMachine(CraneId);
	self.deleteTerminalArea(CraneTransferAreaId);
	
	
	// create the terminal areas - gridded block stack, block stack and interchange
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("HideOverview", true);
	yardIC := self.addInterchangeArea(YardIC, null);
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("StockControlled", true);
	self.opts.addAssoc("DefaultYIC", yardIC);
	bs := self.addBlockStack(BlockStack1, 20, null);		
	
	
	// create the crane transfer area
	cta := self.addCraneTransferArea(CraneTransferAreaId);
	self.assertNotNull(cta);
	
	//create vessel and voyage
	vessel := addVesselCellular(Ship, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	voyage := self.addVoyageWithContainerStructur(Voyage1, Ship, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNull(vessel);
	self.assertNotNull(voyage);
	
	// create the crane
	create tas transient;
	tas.add(cta.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	crane := self.addCrane(CraneId, null, tas, null);
	self.assertNotNull(crane);
	delete tas;

	
	loadPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;

	//create discharge job
	bayName := '01';
	create slots transient;
	self.getJobSlotControllers(Voyage1, bayName, DeckOnDeck, 1, 1, 1, slots);
	assertEqual(slots.size, 1);
	dischargeTi := self.addContainerAtLocnDisch(DischargeBox , "2200", "GENL", TI_IMEX_STATUS_IMPORT, slots[1], loadPort, voyage);
	// Color code and Create Discharge Jobs
	self.voyageDischargeColourCode(voyage);
	
	voyageJob := self.addVoyageJob(voyage, CraneId, slots, true);
	assertTrueMsg(voyageJob &lt;&gt; null, "Voyage job 1 not created");
	jobs.add(voyageJob);
	
	foreach wle in voyageJob.workListEntries do
		self.movePlannedWLE(wle.myTrackedItem, 	bs.myLocationsController, wle);
	endforeach;
	delete slots;

	//load to ops
	self.loadAllJobsToOps(voyage, true);				
	
	self.addMachineRule( bs, crane.CM_Crane.transferArea, RTMoveMethod_23); //simple single straddle moves
	self.addMachineRule( crane.CM_Crane.transferArea, bs, RTMoveMethod_23); 
		
	voyageQueue := self.addVoyageQueue(voyage);
	craneQueue := self.addVoyageCraneQueue(voyage, voyageQueue, crane);
	
	// Create Queues
	foreach job in jobs do
		foreach request in job.allRequests do
			foreach wle in request.allWorkListEntries do
				wles.add(wle);
//				self.queueWLE(wle);
			endforeach;
		endforeach;
	endforeach;
	// workJob using straddle
	self.deleteMachine("UTS1");
	self.deleteRTDevice("91");
	create tas transient;
	tas.add(bs.id); 
	tas.add(yardIC.id); 
	tas.add(crane.CM_Crane.transferArea.id); 
	self.addStraddle("UTS1", 91, tas, null);
	straddle := self.getMachine("UTS1");
	assertNotNull(straddle);
	if craneQueue &lt;&gt; null then
		beginTransaction;
		straddle.addToQueue(craneQueue, true, 0); //add straddle to crane queue
		commitTransaction;
	endif;
	delete tas;
	
	app.isRTApp:=true;  
	self.machineLogon(straddle);

	foreach wle in wles do
		self.machineCraneActionPickup(straddle, dischargeTi, ti4);
			self.assertTrue( dischargeTi.myPrimaryActualLocation.isKindOf(CM_SlotController));
			self.assertTrue(wle.allRTQueueEntries.first.allTasks.first.status = TASK_ACCEPTED);
		self.machineRejectTask(straddle, wle.allRTQueueEntries.first.allTasks.first);
			self.assertTrue(wle.allRTQueueEntries.first.allTasks.first.status = TASK_UNACTIONED);
		self.machineAcceptTask(straddle, wle.allRTQueueEntries.first.allTasks.first);
			self.assertTrue( dischargeTi.myPrimaryActualLocation.isKindOf(CM_SlotController));
			self.assertTrue(wle.allRTQueueEntries.first.allTasks.first.status = TASK_ACCEPTED);
		self.machinePickup(straddle);
			self.assertTrue( dischargeTi.myPrimaryActualLocation.isKindOf(CM_MachineController));
			self.assertTrue(wle.allRTQueueEntries.first.allTasks.last.status = TASK_WORKING);
		self.machineSetdownTask(straddle, wle.allRTQueueEntries.first.allTasks.last, wle.allRTQueueEntries.first.allTasks.last.targetLocationId);
			self.assertTrue( dischargeTi.myPrimaryActualLocation.isKindOf(CM_YardController));
	endforeach;	
	
epilog
	app.isRTApp:=false;  
	delete jobs;
	delete slots;
	delete wles;
	delete tas;						// 13/09/2012 cnwmc5
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;Fails1006&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tExportConsignmentofRebar" id="7def26bd-0a69-4ec2-a68a-10336e1358c2">
        <updating/>
        <source>tExportConsignmentofRebar() updating;
/*

Purpose:			Testlink test 01-1050

Date		Who		Reason
10 June 2016	cnwmk3	Initial creation

*/

constants
	Cargo_Type				: String = "REBAR";
	Truck1					: String = "REBARTRK";
	Truck2					: String = "REBARTRK2";
	CraneId					: String = "CRN4";
	CraneTransferAreaId		: String = "CTA4";
vars
	cargoTypeObj 			: CM_CargoType;
	preCargo , onsiteCargo	: CM_TrackedItem;
	ifArray					: CMIF_TIObjectArray;
	ifPreNote				: CMIF_PreNote;
	truck, truck2 			: CM_Vehicle;
	bs1 					: CM_BlockStack;
	booking					: CM_BookingRef;
	voyage					: CM_Voyage;
	allSlots				: CM_SlotControllerArray;
	colourCode				: CMIF_LoadColorCode;
	voyageJob				: CM_VoyageJob;
	wle						: CM_WorkListEntry;
	job						: CM_Job;
	tiArray					: CM_TIArray;
	taArray					: StringArray;
	crane					: CM_Machine;
	cta						: CM_CraneTransferArea;
	vvr						: CM_VehicleVisitRecord;
begin
	// bbk cargo type with allow duplicates
	
	cargoTypeObj	:=	app.myRoot.getCargoTypeFromAbbrev(Cargo_Type);
	
	// book 500*REBAR on v1
	voyage := self.createVesselVoyage("UT_VOY1050", "UT_VESSEL1050", null);
	booking := self.addBookingForGeneralCargo("REBAR_BOOK01", self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString), voyage, "NZAKL", cargoTypeObj.id, 500);

	bs1 := self.addBlockStack("BSREBAR",999,null);
	
	// prenote 500*REBAR1050
	create ifArray transient;
	create ifPreNote transient;	
	create tiArray transient;

	self.deleteAllCargo("REBAR1050",cargoTypeObj);
	ifPreNote.id := "REBAR1050";
	ifPreNote.myTerminal := self.getTerminal;
	ifPreNote.cargoType := cargoTypeObj.id;
	ifPreNote.voyageCode := voyage.code;
	ifPreNote.dischargePort := "NZAKL";
	ifPreNote.imExStatus := getRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT];
	ifPreNote.operatorCode := self.getProfileSetting(UT_Profile.P_OPERATOR).asString;
	ifPreNote.transportMode := TI_TRANSMODE_ROAD_STR;
	ifPreNote.numberOfItems := 500;
	ifArray.add(ifPreNote);
	self.ignoreTrxWarnings(true);
	
	app.myTrxCA.trxCreatePreNotes(ifArray, false, app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	
	preCargo := self.getTerminal.lookupTrackedItem(ifPreNote.id, cargoTypeObj.id, TI_STATE_NOTIFIED, null, false);

	self.assertNotNull(preCargo);
	self.assertEqual(preCargo.totalQuantity,500);
	self.assertEqual(preCargo.state,TI_STATE_NOTIFIED);
	self.assertNotNull(preCargo.myPinNo);
	
	// Gate in 250*REBAR1050 on TruckA
	truck := self.getVehicle(Truck1);
	if truck &lt;&gt; null then
		self.deleteVehicle(Truck1);
	endif;
	vvr := self.gateInGC(Truck1,null,Truck1,preCargo.id,cargoTypeObj.description,self.getProfileSetting(UT_Profile.P_OPERATOR).asString,null,self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString),250);
	self.assertNotNull(vvr);
	self.workVehicle(vvr);
	self.roadExit(vvr);

	truck := self.getVehicle(Truck1);
	self.assertNotNull(truck);
	//pre note cargo should still be prenoted total quanity should = 250
	self.assertEqual(preCargo.state,TI_STATE_NOTIFIED);
	self.assertEqual(preCargo.totalQuantity,250);
	
	onsiteCargo:= self.getTerminal.lookupTrackedItem(ifPreNote.id, cargoTypeObj.id, TI_STATE_NORMAL, null, false);
	self.assertNotNull(onsiteCargo);
	self.assertEqual(onsiteCargo.totalQuantity,250);
	self.unqueueTI(onsiteCargo);
	self.move(onsiteCargo,bs1.myLocationsController);
	self.assertEqual(onsiteCargo.myPrimaryActualLocation,bs1.myLocationsController);
	
	//gate in last 250 should just move prenote cargo onsite
	truck2 := self.getVehicle(Truck2);
	if truck2 &lt;&gt; null then
		self.deleteVehicle(Truck2);
	endif;
	vvr := self.gateInGC(Truck2,null,Truck2,preCargo.id,cargoTypeObj.description,self.getProfileSetting(UT_Profile.P_OPERATOR).asString,null,self.getGate(self.getProfileSetting(UT_Profile.P_DGATE).asString),250);
	self.assertNotNull(vvr);
	self.workVehicle(vvr);
	self.roadExit(vvr);
	
	truck2 := self.getVehicle(Truck2);
	self.assertNotNull(truck2);
	self.assertEqual(preCargo.state,TI_STATE_NORMAL);
	self.assertEqual(preCargo.totalQuantity,250);
	self.unqueueTI(preCargo);
	self.move(preCargo,bs1.myLocationsController);
	self.assertEqual(onsiteCargo.totalQuantity,500);
	
	// Plan 250*REBAR to v1 Hold1 - Job1
	
	// Set up colour coding for Load.
	
	create allSlots transient;
	create colourCode transient;
	colourCode.overrideMoveType	:=	true;
	colourCode.myDischargePort	:=	app.myRoot.allPorts["NZAKL"];
	
	// Set up Jobs and Slots for Voyage.
	
	self.getJobSlotControllers(voyage.code, "01", DeckOnDeck, 1, 1, 1, allSlots);
	self.markSlotsAsLoadJob(allSlots, colourCode);
	self.markSlotsAsLoadCC(allSlots, colourCode, CM_SlotRequest.Attribute_Empty);
	
	// create the crane transfer area
	self.deleteMachine(CraneId);
	cta := self.addCraneTransferArea(CraneTransferAreaId);
	self.assertNotNull(cta);
	
	create taArray transient;
	taArray.add(bs1.id);
	taArray.add(cta.id);
	self.addVoyageQueue(voyage);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	
	crane := self.addCrane(CraneId, null, taArray, null);
	self.assertNotNull(crane);
	
	voyageJob	:=	self.addVoyageJob(voyage, CraneId, allSlots, false);
	self.assertTrue(voyageJob &lt;&gt; null);
	
	tiArray.add(onsiteCargo);
	self.planTIsLOLO(tiArray, allSlots, voyage, false);
	self.assertEqual(onsiteCargo.plannedLocnId, "010682");

	self.loadVoyJobToOps(voyageJob,true,true);
	self.assertTrue(voyageJob.workListEntries.size = 1);
	
	wle:=voyageJob.workListEntries.first;
	self.assertNotNull(wle);
	
		
	// Queue the voyage jobs
	self.queueWLE(wle);
	
	// move 50*REBAR to ship should be OK
	app.isRTApp:=true;  
	self.machineLogon(crane);
	self.machineAcceptSpecifiedTask(crane, wle.allRTQueueEntries.first);
	
	self.opts.purge();
	self.opts.addAssoc("QUANTITY", 50);
	self.machinePickup(crane);			
	self.machineSetdownTask(crane, crane.allCurrentWorkingQueueTasks.last, onsiteCargo.queuedLocnId);	
	
	// move 50*REBAR to ship should be OK
	self.machineAcceptSpecifiedTask(crane, wle.allRTQueueEntries.first);
	
	self.opts.purge();
	self.opts.addAssoc("QUANTITY", 50);
	self.machinePickup(crane);			
	self.machineSetdownTask(crane, crane.allCurrentWorkingQueueTasks.last, onsiteCargo.queuedLocnId);
	
	// move 400*REBAR to ship should be OK
	self.machineAcceptSpecifiedTask(crane, wle.allRTQueueEntries.first);
	
	self.opts.purge();
	self.opts.addAssoc("QUANTITY", 400);
	self.machinePickup(crane);			
	self.machineSetdownTask(crane, crane.allCurrentWorkingQueueTasks.last, onsiteCargo.queuedLocnId);
	
	self.machineLogOff(crane);
	onsiteCargo := self.getTrackedItem("REBAR1050");
	self.assertNotNull(onsiteCargo);
	self.assertEqual(onsiteCargo.locationId, "010682");
epilog
	self.ignoreTrxWarnings(false);
	app.isRTApp:=false;
	delete ifArray;
	delete ifPreNote;
//	self.deleteAllCargo("REBAR1050",cargoTypeObj);
	delete allSlots;
	delete colourCode;
	delete tiArray;
	delete taArray;
end;</source>
    </JadeMethod>
    <JadeMethod name="tExportTBAs" id="6dbbada8-e452-4ddf-ae5e-ae965047fd66">
        <updating/>
        <source>tExportTBAs() updating;
// CNWMA1
/*
Purpose:			
Date		Who		Reason
25 March 2014	NAVAB1	Initial creation
*/

vars
	voyageJob : CM_VoyageJob;
	realAlloc : CM_VoyageAllocation;
	slots : CM_SlotControllerArray;
	ss: CM_StraddleStack;
	tbaController : CMIF_TBAContainer;
	cargo, tbaCont : CM_TrackedItem;
	strs : StringArray;
	idx : Integer;	
	aPort : CM_Port;
	voy : CM_Voyage;
	op : CM_Operator;
	ct : CM_CargoType;
	product: CM_Product;
	startLC : CM_GridController;
	slotLC : CM_SlotController;
	roadWLE,proxyWLE : CM_WorkListEntry;
begin

	// ### CREATE TERMINAL AREA AND VOYAGE
	voy := self.createVesselVoyage("UTBISHTBA", "UTBISHTBA", null);
	deleteTerminalArea("UTBISHTBA");
	ss := self.addStraddleStack("UTBISHTBA", 5,5,3);
	startLC := ss.allGridControllersByRowColumn.first();

	
	op := voy.myOperator;
	
	// #### CREATE LOAD COLOUR CODING
	create slots transient;
	self.getJobSlotControllers("UTBISHTBA","01",DeckOnDeck,2,1,1,slots);
	realAlloc := self.addVoyageAllocation(voy, "NZAKL", "GEN2", null, TI_CargoType_Container, false, false);
	self.addLCsToLOLOAllocation(true, realAlloc, slots, null);
	voyageJob:=self.addVoyageJob(voy,"CRN2",slots, false);
	assertTrue(voyageJob &lt;&gt; null);
	slotLC := slots[1];
	slots.clear;

	// #### CREATE TBA
	create tbaController transient;
	
	tbaController.id				:=	"TBA";
	tbaController.myCommodity		:=	self.getCommodity("GENL");
	tbaController.myDischargePort	:=	self.getPort("NZAKL");
	tbaController.myISOType		:=	self.getISOType("2200");
	tbaController.myLocationSource	:=	startLC;
	tbaController.myLocationTarget	:=	slotLC; // where to plan the TBA
	tbaController.myOperator		:=	op; //self.getOperator("MSC");
	tbaController.myTerminal		:=	self.getTerminal;
	tbaController.bookingReference := "BOOKINGREF";
	tbaController.myVoyage			:=	voy;
	tbaController.state			:=	TI_STATE_TBA;
	tbaController.weight			:=	13750;
	tbaController.planContainer	:=	true;
	
	app.myPassport.setWarningsIgnored(true);
	app.myTrxCA.trxCreateTBAContainer(tbaController, app.myPassport);
	self.assertNoTrxErrorsOrWarnings;
	
	tbaCont := tbaController.myTrackedItem;
	assertTrueMsg(tbaCont.state = TI_STATE_TBA, "TBA should have a state of TBA!");
	assertTrueMsg(tbaCont.site = TI_SITE_TBA, "TBA should have a site of TBA!");
	
	// ### The TBA is in the yard and is planned to the slot on the ship
	opts.addAssociation("Voyage", voy.code);
	opts.addAssociation("DischargePort", "NZAKL");
	opts.addAssociation("IMEX", "Export");
	
	
	// #### GATE IN the real container, it should match to the TBA
	self.deleteVehicle("TRKTBA");
	gateInContainer("TRKTBA", "REAL8899771", "2200", op.code, "GENL", self.getGate("Single Gate"));
	cargo := self.getTrackedItem("REAL8899771");
// PAR 35574	self.assertTrueMsg((cargo.tbaMatch &lt;&gt; null), "REAL8899771 did not match to TBA in Gate In");
	self.assertTrueMsg((cargo.myMatchedTBA &lt;&gt; null), "REAL8899771 did not match to TBA in Gate In");
	self.unqueueTI(cargo);
	self.setCargoReadyToShip(cargo);
	
	// #### NOW MAKE THE REAL TI TAKE OVER THE TBA
	roadWLE := cargo.getIncompleteRoadReceiveWle();
	proxyWLE := app.createUpdateProxy(roadWLE).CM_WorkListEntry;
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateTIMatchAndQueueToTBA(proxyWLE, app.myPassport);	
	self.assertNoTrxErrorsOrWarnings;
// PAR 35574		self.assertTrueMsg((cargo.tbaMatch = null), "REAL8899771 is still a TBA MATCH!");
	self.assertTrueMsg((cargo.myMatchedTBA = null), "REAL8899771 is still a TBA MATCH!");
	
	// #### MOVE THE REAL TI TO THE YARD
	self.moveIT(cargo,QUEUE_MODE);
	// #### MOVE THE REAL TI TO THE SHIP
	self.moveIT(cargo,PLANNING_MODE);

epilog
	delete tbaController;
	delete slots;
	delete proxyWLE;
end;</source>
    </JadeMethod>
    <JadeMethod name="tFullLegVoyageQueueing" id="22b1c09b-6ec4-4af9-85be-34d5ff1a3a98">
        <updating/>
        <source>tFullLegVoyageQueueing()updating;
// cnwma1
//cnwrd1
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 August 2012	cnwrd1	Initial creation

*/

constants
	Container2			= "UTDR0000002";
	Container3			= "UTDR0000003";
	GriddedBlockStack1	= "UT_RDGBS1";
	BlockStack1			= "UT_RDBS1";
	YardIC				= "UT_RD_IC";
	Truck1				= "UTRDTRUCK";
	Ship				= "UTRDSHIP";
	Voyage1				= "UTRDVOYAGE";
	TestOperator		= "MSK";
	FirstQueue			= "UT_RDQ1";
	SecondQueue			= "UT_RDQ2";

vars
	craneName: String;	
	ti2,
	ti3: CM_Container;
	bs				: CM_BlockStack;
	yardIC			: CM_InterchangeArea;
	machineRule		: CM_RTQueueMultiRule;
	wle				: CM_WorkListEntry;
	taType1,
	taType2			: CM_TerminalAreaType;
	vessel			: CM_Vessel;
	voyage			: CM_Voyage;
	slots 			: CM_SlotControllerArray;
	voyageJob		: CM_VoyageJob;
	job				: CM_Job;
	request			: CM_Request;
	voyageQueue		: CM_VoyageQueue;
	craneQueue		: CM_VoyageCraneQueue;
	crane			: CM_Crane;
	firstQueue		: CM_SubQueue;
	secondQueue		: CM_SubQueue;
	operator		: CM_Operator;
	bayName			: String;
	slot 			: CM_SlotController;
	loadPort,
	dischargePort	: CM_Port;
	jobs			: CM_JobArray;
	voyAlloc		: CM_VoyageAllocation;
	wles 			: CM_WLEArray;
	rtEntry			: CM_RTQueueEntry;
	rtTask			: CM_RTQueueTask;
begin
	
	self.setTerminalConfig(AllowRTSwithoutVGM, true);					// 10/06/2016 cnwmh5
	
	create jobs transient;
	create wles transient;

	// delete everything first
	self.deleteContainer(Container2);
	self.deleteContainer(Container3);
	self.deleteTerminalArea(GriddedBlockStack1);
	self.deleteTerminalArea(BlockStack1);
	self.deleteTerminalArea(YardIC);
	self.deleteVehicle(Truck1);
	self.deleteQueue(FirstQueue);
	self.deleteQueue(SecondQueue);
	
	
	// create the terminal areas - gridded block stack, block stack and interchange
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("HideOverview", true);
	yardIC := self.addInterchangeArea(YardIC, null);
	self.opts.purge;
	self.opts.addAssoc("ActAsReleasePoint", 1);
	self.opts.addAssoc("StockControlled", true);
	self.opts.addAssoc("DefaultYIC", yardIC);
	bs := self.addBlockStack(BlockStack1, 20, null);		
	
	// the machine move rules created here will be created with Full Move Queuing
	// create a machine move rule for cta to null
	taType1 := self.getRoot.allTerminalAreaTypes[TA_TYPE_CRANE_TRANS];
	taType2 := self.getRoot.allTerminalAreaTypes[TA_TYPE_BLOCK_STACK];
	// delete old rule first
	machineRule := self.getTerminal.allRTQueueMultiRuleTATypes[taType1, taType2];
	if machineRule &lt;&gt; null then
		beginTransaction;
		delete machineRule;
		commitTransaction;
	endif;
	self.addMachineRuleType(taType1, taType2, RTMoveMethod_16, FullMoveQueuing);
	// and vice versa (null to CTA
	// delete old first
	machineRule := self.getTerminal.allRTQueueMultiRuleTATypes[taType2, taType1];
	if machineRule &lt;&gt; null then
		beginTransaction;
		delete machineRule;
		commitTransaction;
	endif;
	self.addMachineRuleType(taType2, taType1, RTMoveMethod_26, FullMoveQueuing);

	//ti1 now in gbs onsite.
	
	deleteVoyage(Voyage1);
	deleteVessel(Ship);
	vessel := addVesselCellular(Ship, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	voyage := self.addVoyageWithContainerStructur(Voyage1, Ship, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	
	
	//create discharge job
	
	loadPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];
	dischargePort := voyage.myTrade.allPortRotations.first.myPort;

	bayName := '01';
	//self.logMessageNow("Create Discharge Jobs for bay " &amp; bayName);
	create slots transient;
	self.getJobSlotControllers(Voyage1, bayName, DeckOnDeck, 1, 1, 1, slots);
	assertEqual(slots.size, 1);
	ti2 := self.addContainerAtLocnDisch(Container2 , "2200", "GENL", TI_IMEX_STATUS_IMPORT, slots[1], loadPort, voyage);

	
	// Color code and Create Discharge Jobs
	self.voyageDischargeColourCode(voyage);
	
	craneName := self.getProfileSetting(UT_Profile.P_CRANE).asString;
	
	voyageJob := self.addVoyageJob(voyage, craneName, slots, true);
	assertTrueMsg(voyageJob &lt;&gt; null, "Voyage job 1 not created");
	jobs.add(voyageJob);
	
	foreach wle in voyageJob.workListEntries do
		self.movePlannedWLE(wle.myTrackedItem, 	bs.myLocationsController, wle);
	endforeach;
	delete slots;
	
	self.logMessageNow("Create Load Jobs");
	self.opts.purge;																				// cnwmk3 6/01/2016
	voyAlloc := self.addVoyageAllocation(voyage, dischargePort.code,"GEN2",null,1,false,false);
	bayName :='01';
	self.logMessageNow("Create Load Jobs for bay " &amp; bayName);
	create slots transient;
	self.getJobSlotControllers(voyage.code, bayName, DeckOnDeck, 1, 2, 1, slots);
	assertEqual(slots.size, 1);

	self.addLCsToLOLOAllocation(true, voyAlloc, slots, null);
	
	voyageJob := self.addVoyageJob(voyage, craneName, slots, false);
	assertTrueMsg(voyageJob &lt;&gt; null, "Voyage job not created");
	jobs.add(voyageJob);	
	ti3 := self.addContainerForExport(Container3, operator,
				"2200",	"GENL",	TI_IMEX_STATUS_EXPORT,	null, voyage.code, dischargePort.code, null).CM_Container;
	self.move(ti3, bs.getLocationsController);
	self.setCargoReadyToShip(ti3);
	self.deleteStops(ti3);
	self.movePlannedRequestToJob(ti3, slots[1], slots[1].getRequest(true));

	delete slots;

	// ok have my load and discharge jobs now
	
	//load to ops
	self.logMessageNow("Load to Ops");
	self.loadAllJobsToOps(voyage, true);

	self.logMessageNow("Queue the jobs");
	// Create Queues
	crane := self.getCrane(craneName);
	voyageQueue := self.addVoyageQueue(voyage);
	craneQueue := self.addVoyageCraneQueue(voyage, voyageQueue, crane);
	
	foreach job in jobs do
		foreach request in job.allRequests do
			foreach wle in request.allWorkListEntries do
				wles.add(wle);
				self.queueWLE(wle);
			endforeach;
		endforeach;
	endforeach;
	
	
	// ok now we should have queued WLE's we can check their queues.
	//should all be in the crane queues
	
	foreach wle in wles do
		 foreach rtEntry in wle.allRTQueueEntries do		 
			self.assertEqual(rtEntry.myQueue, craneQueue);
		 endforeach;
	endforeach;
	
	
	//tidty up machien rules.
	machineRule := self.getTerminal.allRTQueueMultiRuleTATypes[taType1, taType2];
	if machineRule &lt;&gt; null then
		beginTransaction;
		delete machineRule;
		commitTransaction;
	endif;
	machineRule := self.getTerminal.allRTQueueMultiRuleTATypes[taType2, taType1];
	if machineRule &lt;&gt; null then
		beginTransaction;
		delete machineRule;
		commitTransaction;
	endif;
	
epilog
	delete jobs;
	delete slots;
	delete wles;
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;Fails1006&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tHHDLRGroundToShip" id="0d838fca-336a-4d41-a13b-fecb73547376">
        <source>tHHDLRGroundToShip();

/*

Purpose:		Use the Hand Held to discharge to ground DLR's

Date		Who		Reason
17 May 2011	cnwmh5	Initial creation
26/06/2012	cnwmh5	Rules on landing have changed.  Now completed when hits the ground.
*/
constants
	CONTAINER1ID		: String = "MDHA9999994";
	CONTAINER2ID		: String = "MDHA9999995";
	CONTAINER3ID		: String = "MDHA9999996";
	BLOCKSTACK			: String = "UTMBS1";
	YARDALLOCATION 	 	: String = "UTMBS1";
	//CRANENAME			: String = "CRN1";   //"UTC1";
	CRANENAME			: String = "UTMV";
	RTDEVICE			: Integer = 11;
	VOYAGENAME			: String = "UTMHHH2";
	VESSELNAME			: String = "UTMHHH2";
vars

	vessel				: CM_Vessel;
	voyage				: CM_Voyage;
	tmpLoadCC			: CMIF_LoadColorCode;
	slotsTo				: CM_SlotControllerArray;
	slotsFrom			: CM_SlotControllerArray;
	operator			: CM_Operator;
	//crane				: CM_Crane;
	crane				: CM_Machine;
	voyageDischJob		: CM_VoyageJob;
	voyageLoadJob		: CM_VoyageJob;
	blockStack			: CM_BlockStack;
	locations			: CM_LCArray;
	dischargePort		: CM_Port;
	theSlot 			: CM_LocationsController;
	cargo1,
	cargo2, 
	cargo3 				: CM_TrackedItem;
	cta					: CM_CraneTransferArea;
	slot				: CM_SlotController;
	wle					: CM_WorkListEntry;
	trackedItem			: CM_TrackedItem;
	pxyMovement			: HMS_VoyageMovement;
	voyageMovement		: HMS_VoyageMovement;
	
	strs 				: StringArray;
	tas					: StringArray;
		
	allObjectEditions	: CM_ObjectByOidEditionDict;	
	
	idx 				: Integer;
	tmpTS				: TimeStamp;
	loadState			: Boolean;
	warningsIgnored		: Boolean;
	remarks				: String;
	
begin

	operator := app.myRoot.allOperators["UTOP"];
	dischargePort := app.myRoot.allPorts["NZPOE"];
	
	// create the block stack
	self.deleteTerminalArea(BLOCKSTACK);
	blockStack := addBlockStack(BLOCKSTACK, 100, null);
	
	// create the crane transfer area
	self.deleteMachine(CRANENAME);
	self.deleteTerminalArea("UTC1TQ");
	cta := self.addCraneTransferArea("UTC1TQ");
	self.assertNotNull(cta);
	
	// create crane CRMH
	create tas transient;
	tas.add(cta.id);
	self.opts.purge();
	self.opts.addAssoc("CraneTransferArea", cta);
	self.opts.addAssoc("MachineLiftType", TWIN_LIFT);
	self.opts.addAssoc("BaseJobNumber", 459);
	crane := self.addCrane(CRANENAME, null, tas, null);
	self.assertNotNull(crane);
	
	// create yard allocation;
	self.deleteYA(YARDALLOCATION);
	create locations transient;
	locations.add(blockStack.allLocationsControllers.first.CM_YardController);
	self.addYA1(YARDALLOCATION, YACriteriaType_Clean, CM_YADataBoolean.VALUE_TRUE, locations);
	
	// create Voyage
	self.opts.purge();
	self.opts.addAssoc("useHMSData", true);
	deleteVoyage(VOYAGENAME);
	deleteVessel(VESSELNAME);
	vessel := addVesselCellular(VESSELNAME, operator);
	voyage := addVoyageWithContainerStructur(VOYAGENAME, VESSELNAME, operator.code, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	
	// update the HMS Departure Movement
	voyageMovement := voyage.myHMSVoyageData.allVoyageMovements.last;
	tmpTS := voyageMovement.occursOnDTNEW.addMinutes(10);
	app.cmsBeginLoad(loadState);
	pxyMovement := voyageMovement.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);
	pxyMovement.setProxyForMoveConfirmation(tmpTS, MovementStatus_Actual, 
		voyageMovement.draftAft, voyageMovement.draftFwd);
	
	warningsIgnored := app.myPassport.warningsIgnored;
	app.myPassport.setWarningsIgnored(true);
	app.myTrxUA.trxUpdateHMSMovement(pxyMovement, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	app.myPassport.setWarningsIgnored(warningsIgnored);
	delete pxyMovement;
	
	app.cmsBeginLoad(loadState);
	pxyMovement := voyageMovement.pxyCreateUpdateProxy();
	app.cmsEndLoad(loadState);
	remarks := "Updated from " &amp; class.name &amp; '::' &amp; method.name;
	app.myTrxUA.trxUpdateHMSMovementRemarks(pxyMovement, remarks, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	voyageMovement := voyage.myHMSVoyageData.allVoyageMovements.last;
	self.assertEqual(voyageMovement.occursOnDTNEW, tmpTS);
	self.assertEqual(voyageMovement.remarks, remarks);
			
	// add the container(s)
	create strs transient;
	deleteContainer(CONTAINER1ID);
	strs.clear;
	strs.add("010682");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo1 := self.addContainerAtLocnDisch(CONTAINER1ID, "2200", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, dischargePort, voyage);
	deleteContainer(CONTAINER2ID);	
	strs.clear;
	strs.add("010684");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo2 := self.addContainerAtLocnDisch(CONTAINER2ID, "2200", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, dischargePort, voyage);
	deleteContainer(CONTAINER3ID);
	strs.clear;
	strs.add("010686");
	voyage.findLocation(strs, false, theSlot, idx);
	cargo3 := self.addContainerAtLocnDisch(CONTAINER3ID, "2200", "GENL", TI_IMEX_STATUS_IMPORT, theSlot, dischargePort, voyage);
	strs.clear;
	
	app.myTrxUA.trxSetDfltDischargeColourCode(voyage.myCellularVoyageStructure, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();																		// 04/07/2013 cnwmh5
	
	// get the crane
	crane := self.getCrane(CRANENAME);
	self.assertNotNull(crane);
		
	// colour code the discharge slots
	create slotsFrom transient;
	self.getJobSlotControllers(VOYAGENAME, "01", DeckOnDeck, 1, 1, 3, slotsFrom);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	self.markSlotsAsDischargeCC(slotsFrom, tmpLoadCC, CM_SlotRequest.Attribute_DLR);
	voyageDischJob := self.addVoyageJob(voyage, crane.id, slotsFrom, true);
	assertTrue(voyageDischJob &lt;&gt; null);
	
	// colour code the load slots
	create slotsTo transient;
	self.getJobSlotControllers(VOYAGENAME, "03", DeckOnDeck, 1, 1, 3, slotsTo);
	self.markSlotsAsLoadJob(slotsTo, tmpLoadCC);
	self.markSlotsAsLoadCC(slotsTo, tmpLoadCC, CM_SlotRequest.Attribute_D20);
	self.markSlotsAsLoadCC(slotsTo, tmpLoadCC, CM_SlotRequest.Attribute_DLR);
	voyageLoadJob := self.addVoyageJob(voyage, crane.id, slotsTo, false);
	assertTrue(voyageLoadJob &lt;&gt; null);
	
	// link the slots
	create allObjectEditions transient;
	foreach slot in slotsFrom do
		allObjectEditions.add(slot);
	endforeach;
	foreach slot in slotsTo do
		allObjectEditions.add(slot);
	endforeach;
	app.myTrxUA.trxUpdateSlotReqLinkSOBDLR2(slotsFrom, slotsTo, allObjectEditions, true, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	// use the hand held to move item(s) to the ground
	self.opts.purge();
	self.moveToGroundUsingHH(cargo1, voyageDischJob, crane.CM_Crane);
	self.moveToGroundUsingHH(cargo2, voyageDischJob, crane.CM_Crane);
	self.moveToGroundUsingHH(cargo3, voyageDischJob, crane.CM_Crane);
	
	// check to see discharge status is completed
	foreach wle in voyageDischJob.workListEntries do
		self.assertEqual(WLE_COMPLETED, wle.status);
	endforeach;
		
	// update the load jobs release ti's
	beginTransaction;
	voyageLoadJob.updateReleaseTI(cargo1);
	voyageLoadJob.updateReleaseTI(cargo2);
	voyageLoadJob.updateReleaseTI(cargo3);
	commitTransaction;
	
	// load to job ops
	self.loadAllJobsToOps(voyage, true);	
	
	// plan the items back to the ship
	self.planItemBackToShip(cargo1, slotsTo[3]);
	self.planItemBackToShip(cargo2, slotsTo[2]);
	self.planItemBackToShip(cargo3, slotsTo[1]);
	
	self.assertTrueMsg(cargo1.myPrimaryActualLocation.isKindOf(CM_CraneLaneController) and 
		cargo1.myPrimaryPlannedLocation.isKindOf(CM_SlotController), cargo1.id &amp; " current location isn't a Crane Area (" &amp; 
		cargo1.myPrimaryActualLocation.String &amp; ") and it isn't planned back to a slot (" &amp; cargo1.myPrimaryPlannedLocation.String &amp; ")");
	self.assertTrueMsg(cargo2.myPrimaryActualLocation.isKindOf(CM_CraneLaneController) and 
		cargo2.myPrimaryPlannedLocation.isKindOf(CM_SlotController), cargo2.id &amp; " current location isn't a Crane Area (" &amp; 
		cargo2.myPrimaryActualLocation.String &amp; ") and it isn't planned back to a slot (" &amp; cargo2.myPrimaryPlannedLocation.String &amp; ")");
	self.assertTrueMsg(cargo3.myPrimaryActualLocation.isKindOf(CM_CraneLaneController) and 
		cargo3.myPrimaryPlannedLocation.isKindOf(CM_SlotController), cargo3.id &amp; " current location isn't a Crane Area (" &amp; 
		cargo3.myPrimaryActualLocation.String &amp; ") and it isn't planned back to a slot (" &amp; cargo3.myPrimaryPlannedLocation.String &amp; ")");
	
epilog

	delete tmpLoadCC;
	delete slotsTo;
	delete slotsFrom;
	delete locations;
	delete strs;
	delete tas;
	delete allObjectEditions;
	delete pxyMovement;
	
end;</source>
        <text>Unit Test class for Voyage Commodity Planning tests.

Application level setting "Voyage Commodity Planning" is set at the start of this class, and 
reset at the end.




&lt;?xml version="1.0"?&gt;
&lt;UT_Additional&gt;
  &lt;Categories&gt;
    &lt;Category CanDelete="true"&gt;MDHFAILSTEST&lt;/Category&gt;
  &lt;/Categories&gt;
&lt;/UT_Additional&gt;</text>
    </JadeMethod>
    <JadeMethod name="tInwardExtCodeAutoChecks" id="d39b6157-bcd2-48f2-b84d-c7e9cc2e290c">
        <updating/>
        <source>tInwardExtCodeAutoChecks() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			who		Reason
18 July 2024	navlw1	ChangeRequest 63839: NSW | OnePort - Uniqueness of Inward and External Code		
26 Nov 2024		navdap1	MTN-33516 NSW | OnePort - Voyage Already Exists With External Code Error
*/

constants
VOYAGE1="UTVOY638391";
VOYAGE2="UTVOY638392";
VESSEL1="UTVES638391";
VESSEL2="UTVES638392";
INWARDCODEAUTO="UT638391";
EXTERNALCODEAUTO="UTEXT638391";
vars
	voyage1,
	voyage2				: CM_Voyage;
	vessel1, 
	vessel2 		 	: CM_Vessel;
	defVoyageProcess	: String;
	allowDupCodes		: Boolean;		// MTN-33516
begin
	// need to turn on auto processing for voyages
	defVoyageProcess := self.getTerminalConfig(DefaultVoyageProcess).String;
	self.setTerminalConfig(DefaultVoyageProcess, "AUTO");
	allowDupCodes := self.getTerminalConfig(AllowDupVoyageInOutCodes).Boolean;	// MTN-33516
	
	self.deleteVoyage(VOYAGE1);
	self.deleteVoyage(VOYAGE2);
	self.deleteVessel(VESSEL1);
	self.deleteVessel(VESSEL2);
	self.opts.purge();
	
	self.opts.addAssoc("AutoVoyageProcess", true);
	self.opts.addAssoc("IgnorePassportErrors", true);
	self.setTerminalConfig(AllowDupVoyageInOutCodes, true);						// MTN-33516
	
	/*******************TEST One - Check that two voyages for the same vessel can't be created with the same Inwards Code*********************************************/
	// create the vessel
	vessel1 := addVesselCellular(VESSEL1, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertNotNullMsg(vessel1,"Vessel1 has not been created for " &amp; VESSEL1);
	
	// create two voyages
	voyage1 := self.addVoyageWithInwardCode(VOYAGE1, INWARDCODEAUTO, VESSEL1, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage1.myVoyageProcess,"VoyageProcess is null");
	self.assertNotNullMsg(voyage1,"Voyage has not been created for code " &amp; VOYAGE1);
	self.assertEqualMsg(voyage1.inwardCodeAuto.toUpper,INWARDCODEAUTO,"Inward code auto should match with the voyage inwardCodeAuto");
	
	self.expectedTrxErrors.add(Already_exist_inward_voyage);
	voyage2 := self.addVoyageWithInwardCode(VOYAGE2, INWARDCODEAUTO, VESSEL1, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertIncludesExceptions();
	
	/******************TEST Two - Check that two voyages for the same vessel can't be created with the same External Code***********************************************/
	self.deleteVoyage(VOYAGE1);
	self.expectedTrxErrors.clear();
	
	self.opts.addAssoc("AutoVoyageProcess", true);
	self.opts.addAssoc("IgnorePassportErrors", true);
	self.opts.addAssoc(UT_OPTS_ExternalCode, EXTERNALCODEAUTO);
	
	// voyage 1
	voyage1 := self.addVoyageWithInwardCode(VOYAGE1, null, VESSEL1, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage1.myVoyageProcess,"VoyageProcess is null");
	self.assertNotNullMsg(voyage1,"Voyage has not been created for code " &amp; VOYAGE1);
	self.assertEqualMsg(voyage1.voyageCodeExternalAuto.toUpper,EXTERNALCODEAUTO,"External code auto should match with the voyage voyageExternalCodeAuto");
	
	// voyage 2
	self.expectedTrxErrors.add(Voyage_Duplicate_External);
	voyage2 := self.addVoyageWithInwardCode(VOYAGE2, null, VESSEL1, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertIncludesExceptions();
	
	/*****************TEST Three - Scenario one - Check that two voyages with different vessels cannot be created with the same Inward Code when voyageProcess is set to MTN Default***********************************/
	self.deleteVoyage(VOYAGE1);
	self.opts.purge();
	self.expectedTrxErrors.clear();
	self.setTerminalConfig(DefaultVoyageProcess, "MTN");
			
	self.opts.addAssoc("AutoVoyageProcess", false);
	self.opts.addAssoc("IgnorePassportErrors", true);
	self.setTerminalConfig(AllowDupVoyageInOutCodes, false);					// MTN-33516
	
	// expected error we should get on the passport allErrors
	self.expectedTrxErrors.add(Already_exist_inward_voyage);
		
	// vessel 2
	vessel2 := addVesselCellular(VESSEL2, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertNotNullMsg(vessel2,"Vessel1 has not been created for " &amp; VESSEL2);
	
	// voyage 1
	voyage1 := self.addVoyageWithInwardCode(VOYAGE1, INWARDCODEAUTO, VESSEL1, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage1.myVoyageProcess,"VoyageProcess is null");
	self.assertNotNullMsg(voyage1,"Voyage has not been created for code " &amp; VOYAGE1);
	self.assertEqualMsg(voyage1.inwardCode.toUpper,INWARDCODEAUTO,"Inward code auto should match with the voyage inwardCodeAuto");
	
	// voyage 2
	voyage2 := self.addVoyageWithInwardCode(VOYAGE2, INWARDCODEAUTO, VESSEL2, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertIncludesExceptions();
	
	/*****************TEST Three - Scenario Two - Check that two voyages with different vessels cannot be created with the same External Code when voyageProcess is set to MTN Default*******************************/
	self.deleteVoyage(VOYAGE1);
	self.opts.purge();
	self.expectedTrxErrors.clear();
	self.setTerminalConfig(DefaultVoyageProcess, "MTN");
	self.opts.addAssoc(UT_OPTS_ExternalCode, EXTERNALCODEAUTO);
	
	voyage1 := self.addVoyageWithInwardCode(VOYAGE1, null, VESSEL1, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage1.myVoyageProcess,"VoyageProcess is null");
	self.assertNotNullMsg(voyage1,"Voyage has not been created for code " &amp; VOYAGE1);
	self.assertEqualMsg(voyage1.voyageCodeExternal.toUpper,EXTERNALCODEAUTO,"External code should match with the voyage voyageExternalCode");
	
	// expected error we should get on the passport allErrors
	self.expectedTrxErrors.add(Voyage_Duplicate_External);
	// voyage 2
	voyage2 := self.addVoyageWithInwardCode(VOYAGE2, null, VESSEL2, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertIncludesExceptions();
	
	/*****************TEST Three - Scenario Three - Check that two voyages with different vessels can be created with the same Inward Code when voyageProcess is set to AUTO****************************/
	self.deleteVoyage(VOYAGE1);
	self.opts.purge();
	self.expectedTrxErrors.clear();
	self.setTerminalConfig(DefaultVoyageProcess, "AUTO");
	
	self.opts.addAssoc("AutoVoyageProcess", true);
	self.opts.addAssoc("IgnorePassportErrors", false);
	self.setTerminalConfig(AllowDupVoyageInOutCodes, true);						// MTN-33516
	
	voyage1 := self.addVoyageWithInwardCode(VOYAGE1, INWARDCODEAUTO, VESSEL1, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage1.myVoyageProcess,"VoyageProcess is null");
	self.assertNotNullMsg(voyage1,"Voyage has not been created for code " &amp; VOYAGE1);
	self.assertEqualMsg(voyage1.inwardCodeAuto.toUpper,INWARDCODEAUTO,"Inward code auto should match with the voyage inwardCodeAuto");
	
	voyage2 := self.addVoyageWithInwardCode(VOYAGE2, INWARDCODEAUTO, VESSEL2, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage2.myVoyageProcess,"VoyageProcess is null");
	self.assertNotNullMsg(voyage2,"Voyage has not been created for code " &amp; VOYAGE2);
	self.assertEqualMsg(voyage2.inwardCodeAuto.toUpper,INWARDCODEAUTO,"Inward code auto should match with the voyage inwardCodeAuto");
	
	/*****************TEST Four - Check that two voyages for the different vessels can be created with the same External Code*****************************************/
	self.deleteVoyage(VOYAGE1);
	self.deleteVoyage(VOYAGE2);
	self.opts.purge();
	self.setTerminalConfig(DefaultVoyageProcess, "AUTO");
	self.opts.addAssoc("AutoVoyageProcess", true);
	self.opts.addAssoc("IgnorePassportErrors", false);
	self.opts.addAssoc(UT_OPTS_ExternalCode, EXTERNALCODEAUTO);
	self.setTerminalConfig(AllowDupVoyageInOutCodes, true);						// MTN-33516
	
	// voyage 1
	voyage1 := self.addVoyageWithInwardCode(VOYAGE1, null, VESSEL1, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage1.myVoyageProcess,"VoyageProcess is null");
	self.assertNotNullMsg(voyage1,"Voyage has not been created for code " &amp; VOYAGE1);
	self.assertEqualMsg(voyage1.voyageCodeExternalAuto.toUpper,EXTERNALCODEAUTO,"External code auto should match with the voyage voyageExternalCodeAuto");
	
	// voyage 2
	voyage2 := self.addVoyageWithInwardCode(VOYAGE2, null, VESSEL2, self.getProfileSetting(UT_Profile.P_OPERATOR).asString, self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg(voyage2.myVoyageProcess,"VoyageProcess is null");
	self.assertNotNullMsg(voyage2,"Voyage has not been created for code " &amp; VOYAGE1);
	self.assertEqualMsg(voyage2.voyageCodeExternalAuto.toUpper,EXTERNALCODEAUTO,"External code auto should match with the voyage voyageExternalCodeAuto");
	
	// Tidy up the data :)
	self.deleteVoyage(VOYAGE1);
	self.deleteVoyage(VOYAGE2);
	self.deleteVessel(VESSEL1);
	self.deleteVessel(VESSEL2);
epilog
	
end;</source>
    </JadeMethod>
    <JadeMethod name="tLOLOGroupSLinTLJob" id="0777aae3-d8f3-4f99-9ece-3b35494ec80e">
        <updating/>
        <source>tLOLOGroupSLinTLJob() updating;
// CNWMA1
/*
Purpose:	PAR 30303	- Creates load colour coding for mixes of 40, 20TL and 20SL in 1 job. Then checks sequence numbers

								This test uses ISO Groups in the load colour coding. The ISO Groups are then used to know whether the colour coding is 20, 40, hiCubed, Reefer etc.
								It does this by getting the first ISO Type in the group and looks at its attributes.
								If this test fails check that the ISO groups and their ISO Type are correct.
								
Date				Who			Reason
SEPTEMBER 2012		NAVAB1		Initial creation
02/10/2025	navkc1 JIRA 36151 AAT | RotaBox ISO Type and New Attributes - JADE
*/

vars
	isoTypeGroup 		: CM_ISOTypeGroup;
	isoTypeGroupDesc	: String;
	isoType				: CM_ISOType;
	isotypecoll			: CM_ISOTypeByCodeDict;
	isoTypeGroupSub		: CM_ISOTypeGroupByCodeDict;

	slots, jobSlots : CM_SlotControllerArray;
	aSlot : CM_SlotController;
	voyageJob : CM_VoyageJob;
	ct : CM_CargoType;
	product: CM_Product;
	voyage : CM_Voyage;
	realAlloc : CM_VoyageAllocation;
	seqGroupSingleLifts, shipSLiftIfDiffHeights : Boolean;
	container : CM_Container;
		aPort : CM_Port;
	locations20 : StringArray; 
	locations40 : StringArray; 
	locnSeq : StringArray; 
	sequence : StringArray; 
	startId : Integer;
begin

	create locations20 transient;
	create locations40 transient;
	create locnSeq transient;
	create sequence transient;


	ct	:= self.getTerminal.getFirstNonSystemCargoType().CM_CargoType;
	product := ct.allProducts.first;
		
	self.setTerminalConfig(SeqGroupSingleLifts, true);
	self.setTerminalConfig(ShipSLiftIfDiffHeights, true);
	self.setTerminalConfig(UseReadyToShip, false);
	self.setTerminalConfig(ShipSLiftIfTLWELoadPlan, true);
	self.setTerminalConfig(SequenceUnderDeckSeaToWharf, false);
	self.setTerminalConfig(SeperateLengthSequencing, false);
	self.setTerminalConfig(SameSeqNumberTwinLift, true);
	
	// CHECK that the ISO GROUPS are corrects
	isoTypeGroup := app.myRoot.allISOTypeGroups["20OT"];
	self.assertTrueMsg(isoTypeGroup &lt;&gt; null,"20OT ISO Group is NULL");
	isoType := isoTypeGroup.allISOTypes.first;
	self.assertTrueMsg(isoType &lt;&gt; null,"20OT ISO Group has no ISO Types!");
	self.assertTrueMsg(isoType.isOpenTop,"20OT Should be OPENTOP");
	
	isoTypeGroup := app.myRoot.allISOTypeGroups["40BX"];
	self.assertTrueMsg(isoTypeGroup &lt;&gt; null,"40BX ISO Group is NULL");
	isoType := isoTypeGroup.allISOTypes.first;
	self.assertTrueMsg(isoType &lt;&gt; null,"40BX ISO Group has no ISO Types!");
	self.assertTrueMsg(isoType.is40ftLong,"40BX Should be 40 FOOT");
	
	isoTypeGroup := app.myRoot.allISOTypeGroups["20BX"];
	self.assertTrueMsg(isoTypeGroup &lt;&gt; null,"20BX ISO Group is NULL");
	isoType := isoTypeGroup.allISOTypes.first;
	self.assertTrueMsg(isoType &lt;&gt; null,"20BX ISO Group has no ISO Types!");
	self.assertTrueMsg(isoType.is20ftLong,"20BX Should be 20 FOOT");
	
	isoTypeGroup := app.myRoot.allISOTypeGroups["UTH4"];
	self.assertTrueMsg(isoTypeGroup &lt;&gt; null,"UTH4 ISO Group is NULL");
	isoType := isoTypeGroup.allISOTypes.first;
	self.assertTrueMsg(isoType &lt;&gt; null,"UTH4 ISO Group has no ISO Types!");
	self.assertTrueMsg(isoType.is40ftLong,"UTH4 Should be 40 FOOT");
	self.assertTrueMsg(isoType.isHiCube,"UTH4 Should be HICUBE");
		
	isoTypeGroup := app.myRoot.allISOTypeGroups["U20R"];
	self.assertTrueMsg(isoTypeGroup &lt;&gt; null,"U20R ISO Group is NULL");
	isoType := isoTypeGroup.allISOTypes.first;
	self.assertTrueMsg(isoType &lt;&gt; null,"U20R ISO Group has no ISO Types!");
	self.assertTrueMsg(isoType.is20ftLong,"U20R Should be 20 FOOT");
	self.assertTrueMsg(isoType.isReefer,"U20R Should be REEFER");
		
	isoTypeGroup := app.myRoot.allISOTypeGroups["U20G"];
	self.assertTrueMsg(isoTypeGroup &lt;&gt; null,"U20G ISO Group is NULL");
	isoType := isoTypeGroup.allISOTypes.first;
	self.assertTrueMsg(isoType &lt;&gt; null,"U20G ISO Group has no ISO Types!");
	self.assertTrueMsg(isoType.is20ftLong,"U20G Should be 20 FOOT");
		
	isoTypeGroup := app.myRoot.allISOTypeGroups["U40G"];
	self.assertTrueMsg(isoTypeGroup &lt;&gt; null,"U40G ISO Group is NULL");
	isoType := isoTypeGroup.allISOTypes.first;
	self.assertTrueMsg(isoType &lt;&gt; null,"U40G ISO Group has no ISO Types!");
	self.assertTrueMsg(isoType.is40ftLong,"U40G Should be 40 FOOT");
		
	

	self.opts.purge();
	self.opts.addAssoc("Bays", 5);
	self.opts.addAssoc("Big", true);

	voyage := self.createVesselVoyage("UTBISH_SL1", "UTBISH_SL", null);
	aPort := app.myRoot.allPorts[voyage.myTerminal.getConfig(PortDestCode).String];

	
	create slots transient;
	create jobSlots transient;
	// ### JOB 1 LOAD
	jobSlots.clear();
	slots.clear;
	aSlot := self.getJobLOLOControllerByID("UTBISH_SL1", "01", "010388"); slots.add(aSlot);
	aSlot := self.getJobLOLOControllerByID("UTBISH_SL1", "01", "010386"); slots.add(aSlot);
	aSlot := self.getJobLOLOControllerByID("UTBISH_SL1", "01", "010384"); slots.add(aSlot);
	aSlot := self.getJobLOLOControllerByID("UTBISH_SL1", "01", "010382"); slots.add(aSlot);
	
	realAlloc := self.addVoyageAllocation(voyage, "AUSYD", "40BX", null, TI_CargoType_Container, false, false);
	self.addLCsToLOLOAllocation(true, realAlloc, slots, null);
	
	slots.copy(jobSlots);
	
	slots.clear;
	aSlot := self.getJobLOLOControllerByID("UTBISH_SL1", "01", "010484"); slots.add(aSlot);
	aSlot := self.getJobLOLOControllerByID("UTBISH_SL1", "01", "010288"); slots.add(aSlot);
	aSlot := self.getJobLOLOControllerByID("UTBISH_SL1", "01", "010286"); slots.add(aSlot);
	aSlot := self.getJobLOLOControllerByID("UTBISH_SL1", "01", "010284"); slots.add(aSlot);
	aSlot := self.getJobLOLOControllerByID("UTBISH_SL1", "01", "010184"); slots.add(aSlot);
	aSlot := self.getJobLOLOControllerByID("UTBISH_SL1", "01", "010182"); slots.add(aSlot);

	aSlot := self.getJobLOLOControllerByID("UTBISH_SL1", "03", "030484"); slots.add(aSlot);
	aSlot := self.getJobLOLOControllerByID("UTBISH_SL1", "03", "030286"); slots.add(aSlot);
	aSlot := self.getJobLOLOControllerByID("UTBISH_SL1", "03", "030284"); slots.add(aSlot);
	aSlot := self.getJobLOLOControllerByID("UTBISH_SL1", "03", "030184"); slots.add(aSlot);
	aSlot := self.getJobLOLOControllerByID("UTBISH_SL1", "03", "030182"); slots.add(aSlot);
	
	realAlloc := self.addVoyageAllocation(voyage, "DEBRV", "20BX", null, TI_CargoType_Container, false, false);
	self.addLCsToLOLOAllocation(true, realAlloc, slots, null);

	slots.copy(jobSlots);
	voyageJob:=self.addVoyageJob(voyage,"CRN2",jobSlots, false);
	assertTrue(voyageJob &lt;&gt; null);
	assertTrueMsg(voyageJob.isTwinLift, "Job " &amp; voyageJob.jobNum &amp; " Should be TWINLIFT");
	aSlot := self.getJobLOLOControllerByID("UTBISH_SL1", "01", "010288"); 
	self.assertTrueMsg(aSlot.mySlotRequestLoad.numSeqPortTwin = 10,"Job " &amp; voyageJob.jobNum &amp; "(L) - " &amp; aSlot.getFullId &amp; " should be seq num 10, is " &amp; aSlot.mySlotRequestLoad.numSeqPortTwin.String);
	
	
	// ### JOB 2 LOAD
	jobSlots.clear();
	slots.clear;
	aSlot := self.getJobLOLOControllerByID("UTBISH_SL1", "03", "030104"); slots.add(aSlot);
