    <JadeMethod name="zCashReceiptCleanup" id="666ee818-4932-421d-b562-6354c9dcc69b">
        <source>zCashReceiptCleanup() protected;
// delete cash receipt instances with invalid invoice line or tracked item references (because no inversed collections back to do it automatically)
//   and cash payments also
vars
	invInvalid,
	tiInvalid	: Boolean;
	ed			: Integer;
	receipt		: CM_CashReceipt;
	invLine		: CM_InvoiceLine;
	ti			: CM_TrackedItem;
	toDelete	: ObjectArray;
begin
	on Exception do app.handleDeletedObject(exception, invLine, invInvalid);
	on Exception do app.handleDeletedObject(exception, ti, tiInvalid);
	
	create toDelete transient;
	foreach receipt in CM_CashReceipt.instances do
		invInvalid := false;
		foreach invLine in receipt.allInvoiceLines do
			invInvalid := false;
			ed := invLine.edition;
			if invInvalid then
				toDelete.add(receipt);
				break;
			endif;
		endforeach;
		if invInvalid then
			continue;
		endif;
		tiInvalid := false;
		foreach ti in receipt.allTrackedItems do
			tiInvalid := false;
			ed := ti.edition;
			if tiInvalid then
				toDelete.add(receipt);
				break;
			endif;
		endforeach;
	endforeach;
	beginTransaction;
	toDelete.purge;
	commitTransaction;
	
epilog
	delete toDelete;
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="zOracleFinExportCreateDebtors" id="39547866-d7bd-4d33-ad66-b4551a0f9fb8">
        <source>zOracleFinExportCreateDebtors(_debtors : CM_DebtorSet input) protected;
// cnwjre1 Doha invoice export test
//  (re)create customers based on the sample data provided by Doha.
// 33862 add 4th debtor to test rounding (Gl codes etc not so important)
vars
	debtorName	: String;
	debtorNode	: CM_DebtorNode;
	proxyDebtor	: CM_Debtor;
	debtorNodeController	: CMIF_DebtorNode;
begin

	// delete debtors first
	debtorName := "UT_DebtorX1";
	debtorNode := app.myRoot.myRootCompany.debtors[debtorName];
	if debtorNode &lt;&gt; null then
		self.deleteDebtor(debtorNode);
	endif;
	debtorName := "UT_DebtorX2";
	debtorNode := app.myRoot.myRootCompany.debtors[debtorName];
	if debtorNode &lt;&gt; null then
		self.deleteDebtor(debtorNode);
	endif;
	debtorName := "UT_DebtorX3";
	debtorNode := app.myRoot.myRootCompany.debtors[debtorName];
	if debtorNode &lt;&gt; null then
		self.deleteDebtor(debtorNode);
	endif;
	debtorName := "UT_DebtorX4";
	debtorNode := app.myRoot.myRootCompany.debtors[debtorName];
	if debtorNode &lt;&gt; null then
		self.deleteDebtor(debtorNode);
	endif;
	
	// new debtors
	debtorName := "UT_DebtorX1";
	create debtorNodeController transient;
	create proxyDebtor transient;
	self.setDebtorNodeController(debtorName, "600555", "", "1.45.N10.1161001", debtorNodeController, proxyDebtor);
	
	app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqualMsg(debtorNode.CM_Debtor.decfinName, "600555", "Debtor1 decfinName");
	_debtors.add(debtorNode.CM_Debtor);
	
	debtorName := "UT_DebtorX2";
	delete proxyDebtor;
	delete debtorNodeController;
	create debtorNodeController transient;
	create proxyDebtor transient;
	self.setDebtorNodeController(debtorName, "612098", "", "1.45.N10.1161001", debtorNodeController, proxyDebtor);
	
	app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqualMsg(debtorNode.CM_Debtor.decfinName, "612098", "Debtor2 decfinName");	
	_debtors.add(debtorNode.CM_Debtor);
	
	debtorName := "UT_DebtorX3";
	delete proxyDebtor;
	delete debtorNodeController;
	create debtorNodeController transient;
	create proxyDebtor transient;
	self.setDebtorNodeController(debtorName, "123456", "", "1.45.N10.1161001", debtorNodeController, proxyDebtor);
	
	app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqualMsg(debtorNode.CM_Debtor.decfinName, "123456", "Debtor3 decfinName");	
	_debtors.add(debtorNode.CM_Debtor);

	debtorName := "UT_DebtorX4";
	delete proxyDebtor;
	delete debtorNodeController;
	create debtorNodeController transient;
	create proxyDebtor transient;
	self.setDebtorNodeController(debtorName, "654321", "", "1.45.N10.1161001", debtorNodeController, proxyDebtor);
	
	app.myTrxCA.trxCreateDebtorNode(debtorNodeController, debtorNode, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	self.assertEqualMsg(debtorNode.CM_Debtor.decfinName, "654321", "Debtor4 decfinName");	
	_debtors.add(debtorNode.CM_Debtor);
epilog

	delete proxyDebtor;
	delete debtorNodeController;
end;</source>
        <access>protected</access>
        <Parameter name="_debtors" type="CM_DebtorSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="zOracleFinExportCreateILTs" id="8d4c551b-2ce4-49f6-94d9-2e40003d86ec">
        <source>zOracleFinExportCreateILTs(_invType : CM_InvoiceDesc; _services : CM_ServiceByNameDict) protected;
// cnwjre1 Doha invoice export test
//  (re)create invoice line types
// 		based on the sample data provided by Doha.
vars
	count		: Integer;
	code		: String;
	calType1 	: CM_CalculationType;
	service		: CM_Service;
	serviceList 	: CM_ServiceByNameDict;
	invLineType  	: CM_InvoiceLineDesc;

begin
	calType1 := app.myRoot.allCalculationTypesByCode["CCT01"];	// units
	create serviceList transient;

	foreach service in _services do
		count := count + 1;
		code := "UT_ILT" &amp; count.String;
		self.deleteInvoiceLineType(code, FORCED_ERASE);
		serviceList.clear();
		serviceList.add(service);
		invLineType := self.createInvoiceLineType(code, calType1, _invType, serviceList, "SDT1");
	endforeach;

epilog
	delete serviceList;
end;
</source>
        <access>protected</access>
        <Parameter name="_invType" type="CM_InvoiceDesc"/>
        <Parameter name="_services" type="CM_ServiceByNameDict"/>
    </JadeMethod>
    <JadeMethod name="zOracleFinExportCreateInvoices" id="86578dc8-6832-4461-8fd1-356efe927e46">
        <source>zOracleFinExportCreateInvoices(_debtors : CM_DebtorSet; _invType : CM_InvoiceDesc) : CM_InvoiceSet protected;
// cnwjre1 Doha invoice export test
//  (re)create invoices (debit and credit values) for internal and external customers
// 		based on the sample data provided by Doha.
vars
	date		: Date;
	count		: Integer;
	bank		: CM_Bank;
	debtor		: CM_Debtor;
	invLineType	: CM_InvoiceLineDesc;
	invoice		: CM_Invoice;
	invoiceLine	: CM_InvoiceLine;
	invoices	: CM_InvoiceSet;
begin

	bank := self.myBank;
	create invoices transient;
	
	// create invoices
	foreach debtor in _debtors do
		invoice := self.createManualInvoice(bank, debtor, null, _invType, null);
		count := count + 1;
		if count = 1 then		// first external customer invoice, credit -1450
			invLineType := self.getInvoiceLineType("UT_ILT2");		// -1750 in 2 lines
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, -1000, "Line 1", date);
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, -750, "Line 2", date);
			invLineType := self.getInvoiceLineType("UT_ILT3");		// +350 in 3 lines
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 100, "Line 3", date);
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 100, "Line 4", date);
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 150, "Line 5", date);
		elseif count = 2 then		// second external customer invoice, debit 4237
			invLineType := self.getInvoiceLineType("UT_ILT4");		// 3840 in 3 lines
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 1000, "Line 1", date);
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 1000, "Line 2", date);
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 1840, "Line 3", date);
			invLineType := self.getInvoiceLineType("UT_ILT2");		// 1145 in 3 lines
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 1000, "Line 4", date);
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 100, "Line 5", date);
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 45, "Line 6", date);
			invLineType := self.getInvoiceLineType("UT_ILT3");		// -748 in 2 lines
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, -700, "Line 7", date);
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, -48, "Line 8", date);
		elseif count = 3 then		// first internal customer invoice, four different G/L codes
			invLineType := self.getInvoiceLineType("UT_ILT5");		// -75 in 2 lines
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, -50, "Line 1", date);
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, -25, "Line 2", date);
			invLineType := self.getInvoiceLineType("UT_ILT6");		// +1170 in 2 lines
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 1000, "Line 3", date);
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 170, "Line 4", date);
			invLineType := self.getInvoiceLineType("UT_ILT5");		// -351 in 3 lines (same GL code as 1st 2 lines)
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, -101, "Line 5", date);
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, -150, "Line 6", date);
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, -100, "Line 7", date);
			invLineType := self.getInvoiceLineType("UT_ILT7");		// -744 in 1 line
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, -744, "Line 8", date);
		elseif count = 4 then		// test rounding, don't care about the GL codes
			invLineType := self.getInvoiceLineType("UT_ILT2");		// decimal quantities
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 10, "Line 1", date);
			invLineType := self.getInvoiceLineType("UT_ILT3");
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 10.333, "Line 2", date);
			invLineType := self.getInvoiceLineType("UT_ILT4");
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 10.333, "Line 3", date);
			invLineType := self.getInvoiceLineType("UT_ILT5");
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 10.333, "Line 4", date);
			invLineType := self.getInvoiceLineType("UT_ILT6");
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 10.3348, "Line 5", date);
			invLineType := self.getInvoiceLineType("UT_ILT7");
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 11, "Line 6", date);
			invoices.add(invoice);
			// more invoices to test rounding, par 34104
			invoice := self.createManualInvoice(bank, debtor, null, _invType, null);
			invLineType := self.getInvoiceLineType("UT_ILT2");
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 10, "Line 1", date);
			invLineType := self.getInvoiceLineType("UT_ILT8");
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 1777.988, "Line 2", date);
			invoices.add(invoice);
			// and another one
			invoice := self.createManualInvoice(bank, debtor, null, _invType, null);
			invLineType := self.getInvoiceLineType("UT_ILT8");
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 1538.72, "Line 1", date);
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 194.692, "Line 2", date);
			invLineType := self.getInvoiceLineType("UT_ILT2");
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 10, "Line 3", date);
			invoices.add(invoice);
			// even more
			invoice := self.createManualInvoice(bank, debtor, null, _invType, null);
			invLineType := self.getInvoiceLineType("UT_ILT8");
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 557.91, "Line 1", date);
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 6340.43, "Line 2", date);
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 167.712, "Line 3", date);
			invLineType := self.getInvoiceLineType("UT_ILT2");
			invoiceLine := self.createManualInvoiceLine(invLineType, invoice, 10, "Line 4", date);
			
		else
			break;		// only know about 4 debtors so far
		endif;
		invoices.add(invoice);
	
	endforeach;
	
	return invoices;
	
epilog
end;</source>
        <access>protected</access>
        <Parameter name="_debtors" type="CM_DebtorSet"/>
        <Parameter name="_invType" type="CM_InvoiceDesc"/>
        <ReturnType type="CM_InvoiceSet"/>
    </JadeMethod>
    <JadeMethod name="zOracleFinExportCreateRates" id="d4f67514-5810-4694-ad34-409bd472914f">
        <source>zOracleFinExportCreateRates(_debtors : CM_DebtorSet; _services : CM_ServiceByNameDict) protected;
// cnwjre1 Doha invoice export test
//  (re)create rates for debtors and services - all rates are 1 and the quantity is used to set the required total value
// 		based on the sample data provided by Doha.
vars
	start,
	expiry : TimeStamp;
	costs : DecimalArray;
	service	: CM_Service;
	debtorRate  : CM_DebtorRate;
	rateEntry 	: CM_RateEntry;
	debtor		: CM_Debtor;
begin
	
	// set up rates for these debtors and services
	create costs transient;
	create debtorRate transient;
	foreach debtor in _debtors do
		foreach service in _services do
			debtorRate.setProxy(service, debtor);
			costs.clear();
			if service.name = "UT_ServiceX8" then		// rate for rounding test to match the actual Milaha case
				costs.add(18.00);
			else
				costs.add(1.00);
			endif;
			start.setDate("01/01/2010".Date);
			start.setTime("00:00".Time);
			expiry := null;
			rateEntry := self.addInvoiceRateEntry(debtorRate, start, expiry, false, costs, 0, 0, null, null);
		endforeach;
	endforeach;
	
epilog
	delete costs;
	delete debtorRate;
end;</source>
        <access>protected</access>
        <Parameter name="_debtors" type="CM_DebtorSet"/>
        <Parameter name="_services" type="CM_ServiceByNameDict"/>
    </JadeMethod>
    <JadeMethod name="zOracleFinExportCreateServices" id="bd53e317-fa08-40f8-97ab-47b0d6cec2cb">
        <source>zOracleFinExportCreateServices(_services : CM_ServiceByNameDict input) protected;
// cnwjre1 Doha invoice export test
//  (re)create GL codes and services
// 		based on the sample data provided by Doha.
vars
	code,
	servCode		: String;
	calType1 	: CM_CalculationType;
	glCode		: CM_GLCode;
	service		: CM_Service;
begin

	// recreate the GL codes and services
	calType1 := app.myRoot.allCalculationTypesByCode["CCT01"];	// units

	// create GL codes and associated services - delete service first then GL code and create in reverse order
	servCode := "UT_ServiceX1";
	self.deleteInvoiceService(servCode, FORCED_ERASE);
	code := "1.45.N10.1161001";
	self.deleteInvoiceGLCode(code);
	glCode := self.createInvoiceGLCode(code, "");
	service := self.createInvoiceService(servCode, "", calType1, glCode);
	_services.add(service);
	
	servCode := "UT_ServiceX2";
	self.deleteInvoiceService(servCode, FORCED_ERASE);
	code := "1.45.N15.3035012";
	self.deleteInvoiceGLCode(code);
	glCode := self.createInvoiceGLCode(code, "");
	service := self.createInvoiceService(servCode, "", calType1, glCode);
	_services.add(service);
	
	servCode := "UT_ServiceX3";
	self.deleteInvoiceService(servCode, FORCED_ERASE);
	code := "1.45.N15.3091004";
	self.deleteInvoiceGLCode(code);
	glCode := self.createInvoiceGLCode(code, "");
	service := self.createInvoiceService(servCode, "", calType1, glCode);
	_services.add(service);
	
	servCode := "UT_ServiceX4";
	self.deleteInvoiceService(servCode, FORCED_ERASE);
	code := "1.45.N10.3035025";
	self.deleteInvoiceGLCode(code);
	glCode := self.createInvoiceGLCode(code, "");
	service := self.createInvoiceService(servCode, "", calType1, glCode);
	_services.add(service);
	
	servCode := "UT_ServiceX5";
	self.deleteInvoiceService(servCode, FORCED_ERASE);
	code := "1.64.R10.3022005";
	self.deleteInvoiceGLCode(code);
	glCode := self.createInvoiceGLCode(code, "");
	service := self.createInvoiceService(servCode, "", calType1, glCode);
	_services.add(service);
	
	servCode := "UT_ServiceX6";
	self.deleteInvoiceService(servCode, FORCED_ERASE);
	code := "1.41.H19.4612001";
	self.deleteInvoiceGLCode(code);
	glCode := self.createInvoiceGLCode(code, "");
	service := self.createInvoiceService(servCode, "", calType1, glCode);
	_services.add(service);
	
	servCode := "UT_ServiceX7";
	self.deleteInvoiceService(servCode, FORCED_ERASE);
	code := "1.64.R10.1135038";
	self.deleteInvoiceGLCode(code);
	glCode := self.createInvoiceGLCode(code, "");
	service := self.createInvoiceService(servCode, "", calType1, glCode);
	_services.add(service);

	// extra service for rounding tests
	servCode := "UT_ServiceX8";
	self.deleteInvoiceService(servCode, FORCED_ERASE);
	code := "1.64.R10.9999999";
	self.deleteInvoiceGLCode(code);
	glCode := self.createInvoiceGLCode(code, "");
	service := self.createInvoiceService(servCode, "", calType1, glCode);
	_services.add(service);
end;</source>
        <access>protected</access>
        <Parameter name="_services" type="CM_ServiceByNameDict" usage="input"/>
    </JadeMethod>
    <JadeMethod name="zOracleFinExportPostInvoices" id="88e3db00-48d8-43e2-8d1f-a07e37325eeb">
        <source>zOracleFinExportPostInvoices(_invoices : CM_InvoiceSet) protected;
// cnwjre1	post and export each Doha invoice
vars
	count	: Integer;
	status	: Integer;
	isZeroRated : Boolean;
	termsOfTrade : CM_InvoiceTermsOfTrade;
	purchaseOrderNumber : String;
	narration : String;
	endDate : Date;
	doExport : Boolean;
	
	invoice		: CM_Invoice;
begin

	foreach invoice in _invoices do
		count := count + 1;
		status := CM_Invoice.INVOICE_PENDING;
		self.updateInvoiceStatus(invoice, status, isZeroRated, termsOfTrade, purchaseOrderNumber, narration, endDate, doExport);
		self.assertEqualMsg(invoice.status, CM_Invoice.INVOICE_PENDING, "Invoice " &amp; count.String &amp; " Pending");

		status := CM_Invoice.INVOICE_POSTED;
		isZeroRated := true;
		purchaseOrderNumber := "ABC123";
		narration := "Unit test";
		doExport := true;
		self.updateInvoiceStatus(invoice, status, isZeroRated, termsOfTrade, purchaseOrderNumber, narration, endDate, doExport);
		self.assertEqualMsg(invoice.status, CM_Invoice.INVOICE_POSTED, "Invoice " &amp; count.String &amp; " POSTED");
		self.assertEqualMsg(invoice.exportedCount, 1, "Invoice " &amp; count.String &amp; " exported");
	endforeach;
	self.assertEqualMsg(count, 7, "Posted invoices");
end;
</source>
        <access>protected</access>
        <Parameter name="_invoices" type="CM_InvoiceSet"/>
    </JadeMethod>
    <JadeMethod name="zOracleFinExportTest" id="f2b2a232-3bb6-43c4-a741-6fd7952adf68">
        <source>zOracleFinExportTest(_file : File; _invoiceNumber : Integer) protected;
// each debtor invoice
vars
	fileLine	: String;
	count		: Integer;
	allFields	: HugeStringArray;
	errMsg		: String;
	
	operating_unit_name	: String;
	org_id			: String;
	header_id		: String;
	batch_source	: String;
	batch_source_id	: String;
	transaction_number 	: String;
	header_or_line	: String;
	invoice_number	: String;
	transaction_type	: String;
	transaction_type_id	: String;
	transaction_class	: String;
	legal_entity_name	: String;
	legal_entity_id	: String;
	bill_to_customer_name	: String;
	bill_to_customer_id		: String;
	bill_to_customer_number	: String;
	bill_to_customer_account	: String;
	bill_to_site	: String;
	bill_to_site_id	: String;
	ship_to_customer_name	: String;
	ship_to_customer_id	: String;
	ship_to_customer_number	: String;
	ship_to_customer_account	: String;
	ship_to_site	: String;
	ship_to_site_id	: String;
	invoice_date		: String;
	invoice_amount	: Real;
	description		: String;
	gl_date			: String;
	currency_code	: String;
	currency_conversion_type	: String;
	currency_conversion_date	: String;
	currency_conversion_rate	: String;
	terms_name		: String;
	terms_id		: String;
	line_id			: String;
	line_number		: String;
	link_to_line_number	: String;
	line_type		: String;
	line_type_code	: String;
	quantity_invoiced	: Real;
	quantity_ordered	: String;
	unit_selling_price	: Real;
	line_amount		: Real;
	account_class	: String;
	segment1		: String;
	segment2		: String;
	segment3		: String;
	segment4		: String;
	segment5		: String;
	segment6		: String;
	segment7		: String;
	segment8		: String;
	code_combination_id	: String;
	created_by		: String;
	creation_date	: String;
	attribute_category	: String;
	attribute1		: String;
	attribute2		: String;
	attribute3		: String;
	attribute4		: String;
	attribute5		: String;
	attribute6		: String;
	attribute7		: String;
	attribute8		: String;
	attribute9		: String;
	attribute10		: String;
	attribute11		: String;
	attribute12		: String;
	attribute13		: String;
	attribute14		: String;
	attribute15		: String;
	attribute16		: String;
	attribute17		: String;
	attribute18		: String;
	attribute19		: String;
	attribute20		: String;
	invoice_id		: String;
	process_flag	: String;
	message			: String;
	
begin
	create allFields transient;
	while not _file.endOfFile() do
		count := count + 1;
		errMsg := "File " &amp; _file.fileName &amp; " invoice " &amp; _invoiceNumber.String &amp; " row " &amp; count.String;
		fileLine := _file.readLine().trimBlanks();
		allFields.clear;
		fileLine.csvConvert(allFields, ',');
		self.assertTrueMsg(allFields.size &gt;= 79, errMsg &amp; " insufficient fields, " &amp; allFields.size.String);

		operating_unit_name := allFields[1];
		org_id := allFields[2];
		header_id := allFields[3];
		batch_source := allFields[4];
		batch_source_id := allFields[5];
		transaction_number := allFields[6];
		header_or_line := allFields[7];
		invoice_number := allFields[8];
		transaction_type := allFields[9];
		transaction_type_id := allFields[10];
		transaction_class := allFields[11];
		legal_entity_name := allFields[12];
		legal_entity_id := allFields[13];
		bill_to_customer_name := allFields[14];
		bill_to_customer_id := allFields[15];
		bill_to_customer_number := allFields[16];
		bill_to_customer_account := allFields[17];
		bill_to_site := allFields[18];
		bill_to_site_id := allFields[19];
		ship_to_customer_name := allFields[20];
		ship_to_customer_id := allFields[21];
		ship_to_customer_number := allFields[22];
		ship_to_customer_account := allFields[23];
		ship_to_site := allFields[24];
		ship_to_site_id := allFields[25];
		invoice_date := allFields[26];
		invoice_amount := allFields[27].Real;
		description := allFields[28];
		gl_date := allFields[29];
		currency_code := allFields[30];
		currency_conversion_type := allFields[31];
		currency_conversion_date := allFields[32];
		currency_conversion_rate := allFields[33];
		terms_name := allFields[34];
		terms_id := allFields[35];
		line_id := allFields[36];
		line_number := allFields[37];
		link_to_line_number := allFields[38];
		line_type := allFields[39];
		line_type_code := allFields[40];
		quantity_invoiced := allFields[41].Real;
		quantity_ordered := allFields[42];
		unit_selling_price := allFields[43].Real;
		line_amount := allFields[44].Real;
		account_class := allFields[45];
		segment1 := allFields[46];
		segment2 := allFields[47];
		segment3 := allFields[48];
		segment4 := allFields[49];
		segment5 := allFields[50];
		segment6 := allFields[51];
		segment7 := allFields[52];
		segment8 := allFields[53];
		code_combination_id := allFields[54];
		created_by := allFields[55];
		creation_date := allFields[56];
		attribute_category := allFields[57];
		attribute1 := allFields[58];
		attribute2 := allFields[59];
		attribute3 := allFields[60];
		attribute4 := allFields[61];
		attribute5 := allFields[62];
		attribute6 := allFields[63];
		attribute7 := allFields[64];
		attribute8 := allFields[65];
		attribute9 := allFields[66];
		attribute10 := allFields[67];
		attribute11 := allFields[68];
		attribute12 := allFields[69];
		attribute13 := allFields[70];
		attribute14 := allFields[71];
		attribute15 := allFields[72];
		attribute16 := allFields[73];
		attribute17 := allFields[74];
		attribute18 := allFields[75];
		attribute19 := allFields[76];
		attribute20 := allFields[77];
		invoice_id := allFields[78];
		process_flag := allFields[79];
		message := allFields[80];
		
		// validate the key fields
		// header/line
		if count = 1 then
			self.assertEqualMsg(header_or_line, "H".String, errMsg &amp; " header_or_line");
		else
			self.assertEqualMsg(header_or_line, "L".String, errMsg &amp; " header_or_line");
		endif;
		if _invoiceNumber = 1 then
			// debtor
			self.assertEqualMsg(bill_to_customer_account, "600555", errMsg &amp; " customer number");
			// total
			if count = 1 then
				self.assertEqualMsg(invoice_amount, -1400.Real, errMsg &amp; " invoice_amount");
			elseif count = 2 then
				self.assertEqualMsg(line_amount, -1750.Real, errMsg &amp; " line_amount");
			else
				self.assertEqualMsg(line_amount, 350.Real, errMsg &amp; " line_amount");
			endif;

			// GL codes
			if count = 2 then
				self.assertEqualMsg(segment3, "N15", errMsg &amp; " segment3");
				self.assertEqualMsg(segment4, "3035012", errMsg &amp; " segment4");
			elseif count = 3 then
				self.assertEqualMsg(segment3, "N15", errMsg &amp; " segment3");
				self.assertEqualMsg(segment4, "3091004", errMsg &amp; " segment4");
			endif;
		
		elseif _invoiceNumber = 2 then
			// debtor
			self.assertEqualMsg(bill_to_customer_account, "612098", errMsg &amp; " customer_number");
			// total
			if count = 1 then
				self.assertEqualMsg(invoice_amount, 4237.Real, errMsg &amp; " invoice_amount");
			elseif count = 2 then
				self.assertEqualMsg(line_amount, 3840.Real, errMsg &amp; " line_amount");
			elseif count = 3 then
				self.assertEqualMsg(line_amount, 1145.Real, errMsg &amp; " line_amount");
			else
				self.assertEqualMsg(line_amount, -748.Real, errMsg &amp; " line_amount");
			endif;
			// GL codes
			if count = 2 then
				self.assertEqualMsg(segment3, "N10", errMsg &amp; " segment3");
				self.assertEqualMsg(segment4, "3035025", errMsg &amp; " segment4");
			elseif count = 3 then
				self.assertEqualMsg(segment3, "N15", errMsg &amp; " segment3");
				self.assertEqualMsg(segment4, "3035012", errMsg &amp; " segment4");
			elseif count = 4 then
				self.assertEqualMsg(segment3, "N15", errMsg &amp; " segment3");
				self.assertEqualMsg(segment4, "3091004", errMsg &amp; " segment4");
			endif;
			
		elseif _invoiceNumber = 3 then
			if count = 1 then
				self.assertEqualMsg(line_amount, 0.Real, errMsg &amp; " line_amount");
			elseif count = 2 then
				self.assertEqualMsg(line_amount, 1170.Real, errMsg &amp; " line_amount");
			elseif count = 3 then
				self.assertEqualMsg(line_amount, -744.Real, errMsg &amp; " line_amount");
			else
				self.assertEqualMsg(line_amount, -426.Real, errMsg &amp; " line_amount");
			endif;
			// GL codes
			if count = 2 then
				self.assertEqualMsg(segment3, "H19", errMsg &amp; " segment3");
				self.assertEqualMsg(segment4, "4612001", errMsg &amp; " segment4");
			elseif count = 3 then
				self.assertEqualMsg(segment3, "R10", errMsg &amp; " segment3");
				self.assertEqualMsg(segment4, "1135038", errMsg &amp; " segment4");
			elseif count = 4 then
				self.assertEqualMsg(segment3, "R10", errMsg &amp; " segment3");
				self.assertEqualMsg(segment4, "3022005", errMsg &amp; " segment4");
			endif;
		
		elseif _invoiceNumber = 4 then		// rounding test
		// cnwjre1 16/1/2015 this used to run with inv line types having all the same remarks so all got consolidated into one
		//   but a unit test change to create these (ILDs) without remarks means that the details consolidation is now different and so is the invoice total
		//   different by 0.01.  Since the new way actually matches the Milaha invoice line types (these have no remarks) the test
		//	 has been changed to reflect these new values, rather than cretaing the ILDS as before.
			if count = 1 then		// header, total amount
				self.assertEqualMsg(line_amount, 62.33.Real, errMsg &amp; " line_amount");		// was 62.33
			elseif count = 2 then
				self.assertEqualMsg(line_amount, 10.33.Real, errMsg &amp; " line_amount");
			elseif count = 3 then
				self.assertEqualMsg(line_amount, 10.34.Real, errMsg &amp; " line_amount");
			elseif count = 4 then
				self.assertEqualMsg(line_amount, 10.Real, errMsg &amp; " line_amount");
			elseif count = 5 then
				self.assertEqualMsg(line_amount, 10.33.Real, errMsg &amp; " line_amount");
			elseif count = 6 then
				self.assertEqualMsg(line_amount, 11.Real, errMsg &amp; " line_amount");
			elseif count = 7 then
				self.assertEqualMsg(line_amount, 10.33.Real, errMsg &amp; " line_amount");		// was 10.33
			endif;
		elseif _invoiceNumber = 5 then		// more rounding tests
			if count = 1 then		// header, total amount
				self.assertEqualMsg(line_amount, 32013.78.Real, errMsg &amp; " line_amount");
			elseif count = 2 then
				self.assertEqualMsg(line_amount, 10.Real, errMsg &amp; " line_amount");
			elseif count = 3 then
				self.assertEqualMsg(line_amount, 32003.78.Real, errMsg &amp; " line_amount");		// was 32003.79 in error
			endif;
		elseif _invoiceNumber = 6 then		// even more rounding tests
			if count = 1 then		// header, total amount
				self.assertEqualMsg(line_amount, 31211.42.Real, errMsg &amp; " line_amount");
			elseif count = 2 then
				self.assertEqualMsg(line_amount, 10.Real, errMsg &amp; " line_amount");
			elseif count = 3 then
				self.assertEqualMsg(line_amount, 31201.42.Real, errMsg &amp; " line_amount");		// was 31201.41 in error
			endif;
		elseif _invoiceNumber = 7 then		// even more rounding tests
			if count = 1 then		// header, total amount
				self.assertEqualMsg(line_amount, 127198.94.Real, errMsg &amp; " line_amount");
			elseif count = 2 then
				self.assertEqualMsg(line_amount, 10.Real, errMsg &amp; " line_amount");
			elseif count = 3 then
				self.assertEqualMsg(line_amount, 127188.94.Real, errMsg &amp; " line_amount");		// was 127188.93 in error
			endif;
		endif;
	endwhile;
	
	if _invoiceNumber = 1 then
		self.assertEqualMsg(count, 3, errMsg &amp; " Invoice " &amp; _invoiceNumber.String &amp; " number of records");
	elseif _invoiceNumber = 2 then
		self.assertEqualMsg(count, 4, errMsg &amp; " Invoice " &amp; _invoiceNumber.String &amp; " number of records");
	elseif _invoiceNumber = 3 then
		self.assertEqualMsg(count, 4, errMsg &amp; " Invoice " &amp; _invoiceNumber.String &amp; " number of records");
	elseif _invoiceNumber = 4 then
		self.assertEqualMsg(count, 7, errMsg &amp; " Invoice " &amp; _invoiceNumber.String &amp; " number of records");
	endif;
	
epilog
	delete allFields;
end;
</source>
        <access>protected</access>
        <Parameter name="_file" type="File"/>
        <Parameter name="_invoiceNumber" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="zOracleFinExportTestInvoices" id="6af6fb21-12c2-4b22-9487-1eedb28a406f">
        <source>zOracleFinExportTestInvoices(_invoices : CM_InvoiceSet) protected;
// cnwjre1	test each exported Doha invoice - the file name includes the invoice number so need the actual
//	invoice details to find them
vars
	tempDir		: String;
	path		: String;
	fileName	: String;
	count		: Integer;
	file		: File;
	invoice		: CM_Invoice;
begin

	tempDir := self.getTempDirectory();
	if tempDir[tempDir.length:1] = '\' then
		path := tempDir;
	else
		path := tempDir &amp; '\';
	endif;
	create file;
	file.kind := File.Kind_Unknown_Text; // 29/2/16  cnwns1 PAR 36286 unicode version	
	foreach invoice in _invoices do
		count := count + 1;
		fileName := path &amp; "ar_invoice_";

		fileName := fileName &amp; invoice.sequenceNum.padLeadingWith('0', 6) &amp; ".csv";
		file.openInput(fileName);
		self.zOracleFinExportTest(file, count);
		
		file.close();
	endforeach;
	self.assertEqualMsg(count, 7, "Number of files");
	
epilog
	if file &lt;&gt; null then
		if file.isOpen() then
			file.close();
		endif;
		delete file;
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="_invoices" type="CM_InvoiceSet"/>
    </JadeMethod>
</Class>
