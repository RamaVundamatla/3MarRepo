    <JadeMethod name="loadMeasurementTypes" id="4c8f15f8-70da-45a1-b756-551db4153337">
        <updating/>
        <source>loadMeasurementTypes(	_tbl : CM_EntryTable io; 
						_entDefName : String; 
						_allEntTableRows : ObjectArray; 
						_isForEdit : Boolean	) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/03/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
19/06/2013	cnwdap1	PAR #31754 Correct handling of product attribute measurement types
29 Aug 2013	NDL	Par 32055 - set up heading etc based off product when no currentObject available
*/
vars
	obj					: Object;
	row					: EntTableRow;
	measure				: CM_MeasurementType;
	defaultMeasure		: CM_MeasurementType;
	insertAfterRow 		: Integer;
	controlId			: Integer;
	currentObject		: CM_Object;
	product				: CM_Product;
	attr				: CM_ProductAttr;
	seperateMeasureLines : Boolean;
begin
	controlId := 13000;
	self.allMeasurementControls.purge;
	self.allMeasurementControls.clear;
	
	currentObject:=_tbl.userObject.CM_Object;
	if currentObject = null then
		currentObject := self.getMyCurrentObject;
	endif;
	//29 Aug 2013	NDL	Par 32055
	product := self.getProductForMeasurementTypes();
	//jlier1 MTN-34671 23/4/25 - just call getconfig once
	seperateMeasureLines:=app.myRoot.getConfig(MeasuresSeparateLines).Boolean ;
	
	
	foreach obj in _allEntTableRows do
		row := obj.EntTableRow;
		if row.measurementType = null then
			continue;
		endif;
		insertAfterRow := _tbl.getRowByName(row.name);
		
		if insertAfterRow &gt; 0 then
			// load the default measurement first, then any others
			defaultMeasure := app.getDefaultMeasurementForType(row.measurementType);
			// do we have a tracked item that has a product attribute with a measurement type that overrides this default?
		
		/*	code moved to 'getProductForMeasurementTypes' method
			if CM_TrackedItem.hasInstance(currentObject) then 
				if currentObject.CM_TrackedItem.myProduct &lt;&gt; null then
					product := currentObject.CM_TrackedItem.myProduct;
				elseif currentObject.CM_TrackedItem.myCargoType.mySystemProductType &lt;&gt; null then
					product := currentObject.CM_TrackedItem.myCargoType.mySystemProductType;
				endif;
			endif; */
			
			if product &lt;&gt; null then
				attr := product.getProdAttrFromName(row.name);
				if attr &lt;&gt; null and attr.myMeasurementType &lt;&gt; null and attr.myMeasurementType &lt;&gt; defaultMeasure then
					defaultMeasure := attr.myMeasurementType;
				endif;
			endif; 

			//self.insertMeasurementType(_tbl, row, defaultMeasure, insertAfterRow, controlId, _isForEdit, currentObject);							// PAR #31754
			self.insertMeasurementType(_tbl, row, defaultMeasure, insertAfterRow, controlId, _isForEdit, currentObject, null, product);		//29 Aug 2013	NDL	Par 32055					// PAR #31754
			
			if seperateMeasureLines then
				insertAfterRow := insertAfterRow + 1;
				if not _isForEdit then
					foreach measure in app.myRoot.allMeasurementTypesByShortName do
						if measure.isDefault or measure = defaultMeasure or not measure.isDisplay or measure.measurementType &lt;&gt; row.measurementType then
							continue;
						endif;
						if measure.isAvailableForEntry then
							//self.insertMeasurementType(_tbl, row, measure, insertAfterRow, controlId, _isForEdit, currentObject);					// PAR #31754
							self.insertMeasurementType(_tbl, row, measure, insertAfterRow, controlId, _isForEdit, currentObject, defaultMeasure, product);	// PAR #31754
						endif;
					endforeach;
				endif;
			endif;
			// hide the original measurement row
			insertAfterRow := _tbl.getRowByName(row.name);
			_tbl.hideRow(insertAfterRow);
		endif;
	endforeach;
	
epilog

end;</source>
        <Parameter name="_tbl" type="CM_EntryTable" usage="io"/>
        <Parameter name="_entDefName" type="String"/>
        <Parameter name="_allEntTableRows" type="ObjectArray"/>
        <Parameter name="_isForEdit" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadMenuItem" id="4485fb28-838f-4a62-ac17-192c51361061">
        <source>loadMenuItem(_menuUserItem : CM_MenuEntity; _idx : Integer io; _menuItem : MenuItem input) protected;
// ---------------------------------------------------------------------------
// Created:     28 January 2003		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	childEntity		: CM_MenuEntity;
	newMenu			: MenuItem;
begin
	
	_idx 				:= _idx + 1;
	_menuItem.caption 	:= _menuUserItem.getHeading();
	_menuItem.visible 	:= true;
	_menuItem.userObject:= _menuUserItem;
	_menuItem.picture 	:= _menuUserItem.pictureButton;

/*	if _menuUserItem.isKindOf(CM_MenuUserHdr) then
		_
	endif;
		if _menuUserItem.isKindOf(CM_MenuRootUserTerminal) then
		_menuItem.picture 	:= _menuUserItem.pictureButton;
	endif;*/
	if _menuUserItem.isKindOf(CM_MenuUserDtl) then
		_menuItem.picture 	:= _menuUserItem.pictureIcon; //_menuUserItem.getPictureIcon();
	else	
		_menuItem.picture 	:= _menuUserItem.pictureButton;
	endif;
	
	foreach childEntity in _menuUserItem.allChildren do
		delete _menuItem.getMenuItem(_idx);
		newMenu := _menuItem.loadSubMenu(_idx);
		self.loadMenuItem(childEntity, _idx, newMenu);
	endforeach;
	
end;</source>
        <access>protected</access>
        <Parameter name="_menuUserItem" type="CM_MenuEntity"/>
        <Parameter name="_idx" type="Integer" usage="io"/>
        <Parameter name="_menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="messageSelect" id="bc80b983-5e8d-487a-998a-3ab8be5de316">
        <source>messageSelect();
// ---------------------------------------------------------------------------
// Created:		January  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
