    <JadeMethod name="getDirsOfHotFixes" id="2b6acf44-76bb-4123-a277-6cf11f377fe1">
        <source>getDirsOfHotFixes( _dir: String; _dirHtFxSuper: FileFolder input; _dirsHtFx: FileNodeArray io) : Boolean;
// Vytenis	11/2006
vars
	rt				: RootHotFixes;
	dirHtFxSum		: FileFolder;
	fileN			: FileNode;
	theFirstTime	: Boolean;	// used for check dirs lenght
	len				: Integer;	// used for check dirs lenght
	firstAttention	: Boolean;
	listAll			: FileFolder;
	
begin

	create listAll transient;
	rt := app.myRootHotFix;
	
	app.writeLogMessage('');
	app.writeLogMessage(' List of all Hotfixes:');
	
	rt.getListOfActualFiles( _dir, RootHotFixes.MASK_DIR_HOTFIXES, _dirHtFxSuper, _dirsHtFx, true );
	
	if not ( _dirsHtFx.size &gt; 0 ) then
		app.writeLogMessage(' There are no Hotfixes in directory - ' &amp; _dir);
		return false;
	endif;
	
		// check length - all dirs has to have standard shape and equal length
	theFirstTime := true;
	firstAttention := false;
	len := 0;
	foreach fileN in _dirsHtFx do
		if theFirstTime then
			theFirstTime:= false;
			len			:= fileN.fileName.length;
		else
			if len &lt;&gt; fileN.fileName.length and not firstAttention then
				firstAttention := true;
				app.writeLogMessage('! Attention - there are directories with different length.');
			endif;
		endif;
	endforeach;

	// check all files in directory without mask
	if not firstAttention then
		listAll.fileName := _dir;
		foreach fileN in listAll.files do
			if len &lt;&gt; fileN.fileName.length and not firstAttention then
			app.writeLogMessage('');
			app.writeLogMessage('! Attention - there are extra not Hotfix directories.');
			endif;
		endforeach;
	endif;

	return true;

epilog
	delete listAll;

	
end;
</source>
        <Parameter name="_dir" type="String"/>
        <Parameter name="_dirHtFxSuper" type="FileFolder" usage="input"/>
        <Parameter name="_dirsHtFx" type="FileNodeArray" usage="io"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getNameDirHotFixSuper" id="f507f3bf-e2df-4985-92b5-be0660b5a50e">
        <source>getNameDirHotFixSuper( _dirsHotFix : FileNodeArray ) : String;
// analise all hotFixes and create name for a new hotFixSuper
// Vytenis 11/2006
vars
	rt	: RootHotFixes;
	rtS : RootHotFixSuper;
	sBeg,sEnd : String;
	sB3, sE3  : String;

begin

	rt := app.myRootHotFix;
	rtS:= rt.myRootHotFixSuper;
	
	sBeg := _dirsHotFix[1].fileName;
	
	if (rtS.hotfixFrom = 1) and (rtS.hotfixTo= MAX_HOTFIX_NO) then
		// all hotfixes included
		sEnd := _dirsHotFix[ _dirsHotFix.size ].fileName;
		sB3  := sBeg[ sBeg.length - 2 : 3];
		sE3  := sEnd[ sEnd.length - 2 : 3];
		
	else	// there is some range of hotfixes included in a superHotfix
	
		sB3 := rtS.hotfixFrom.String;
		sB3 := sB3.padLeadingZeros(3);
		sE3 := rtS.hotfixTo.String;
		sE3 := sE3.padLeadingZeros(3);
		
	endif;
	
	return sBeg[ sBeg.length-12 : 3] &amp; rt.DIR_PART_HOTFIX &amp; sB3 &amp; '_to_' &amp; sE3;

end;
</source>
        <Parameter name="_dirsHotFix" type="FileNodeArray"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNameHotFix" id="60b26a22-e814-414f-bb70-406f1fc7fce5">
        <source>getNameHotFix( _dir : String ) : String;
// Vytenis	11/2006
vars
	dirReversed : String;
	pos			: Integer;
	s			: String;
	
begin

	//return _dir[ _dir.length-12 : 13 ];
	
	dirReversed := _dir.reverse();
	pos := 1;
	s := dirReversed.scanUntil("\/", pos);
	
	return s.reverse();
	
end;
</source>
        <Parameter name="_dir" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isHotfixInRangeOfSuperHotfix" id="d545b4f5-eec9-4925-86b5-447fffdb930d">
        <source>isHotfixInRangeOfSuperHotfix( _hotFix : String; _from, _to : Integer ) : Boolean;
// created: 31 Dec 2007 by cnwvu1
vars
	currentNo : Integer;
begin

	// check whether the _hotFix is in the superHotfix's range
	currentNo := _hotFix[_hotFix.length-2 : 3].Integer;
	
	if (currentNo &gt;= _from) and (currentNo &lt;= _to) then
		return true;
	else
		return false;
	endif;

end;
</source>
        <Parameter name="_hotFix" type="String"/>
        <Parameter name="_from" type="Integer"/>
        <Parameter name="_to" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="prepareRangeForSuperHotfix" id="81655cbb-c7c2-4018-aa26-f8eba9fbb40f">
        <source>prepareRangeForSuperHotfix( _from, _to : Integer; _fromInteger, _toInteger : Integer output ) : Boolean;
// created: 31 Dec 2007 by cnwvu1
vars

begin

	_fromInteger:= 0;
	_toInteger	:= 0;

	if _from = null and _to = null then
		_fromInteger:= 1;
		_toInteger	:= MAX_HOTFIX_NO;
		return true;
	endif;
	
	// when _from &gt; 0
	if _from &lt;&gt; null then

		if _to = null then
			app.msgBox( "Please input value for To.", class.name &amp;"."&amp; method.name, null );
			app.writeLogMessage(class.name &amp; '&gt;&gt;' &amp; method.name &amp;" - Please input value for To.");
			return false;
		else
			if _from &lt;= _to then
				_fromInteger:= _from;
				_toInteger	:= _to;
				return true;
			else
				app.msgBox( "Please check values From and To.", null, null );
				app.writeLogMessage(class.name &amp; '&gt;&gt;' &amp; method.name &amp;" - Error: please check values From And To.");
				return false;
			endif;
		endif;
		
	endif;

	//when _from = null and _to &lt;&gt; null
	if _to &lt;&gt; null then
		app.msgBox( "Please input value for From.", class.name &amp;"."&amp; method.name, null );
		app.writeLogMessage(class.name &amp; '&gt;&gt;' &amp; method.name &amp;" - Please input value for From.");
		return false;
	endif;
	
	app.msgBox( "Unexpexted program error.", class.name &amp;"."&amp; method.name, null );
	app.writeLogMessage(class.name &amp; '&gt;&gt;' &amp; method.name &amp;" - Unexpected program error.");
	return false;
	
end;</source>
        <Parameter name="_from" type="Integer"/>
        <Parameter name="_to" type="Integer"/>
        <Parameter name="_fromInteger" type="Integer" usage="output"/>
        <Parameter name="_toInteger" type="Integer" usage="output"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="removeBinWebNotUsed" id="7a7e9f54-ba85-47bc-992a-aa80d9e74386">
        <source>removeBinWebNotUsed( _dirsHotFix: FileNodeArray );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 April 2014	cnwmc5	Initial creation

*/

vars

	fJdB 	: FileFolder;
	fClB	: FileFolder;
	web		: FileFolder;
	
begin

	create fJdB transient;
	create fClB transient;
	create web transient;
	
	fJdB.fileName := self.getDirHotFixSuperJadeMasterBin(_dirsHotFix);
	fClB.fileName := self.getDirHotFixSuperClientBin(_dirsHotFix);
	web.fileName := self.getDirHotFixSuper(_dirsHotFix) &amp; RootHotFixes.DIR_WEB_NAME;
	
	if fJdB.files.size = 0 then
		app.writeLogMessage(' removing ' &amp; fJdB.fileName &amp; ' because not used.');
		fJdB.cnEcRemove();
	endif;
	if fClB.files.size = 0 then
		app.writeLogMessage(' removing ' &amp; fClB.fileName &amp; ' because not used.');
		fClB.cnEcRemove();
	endif;
	if web.files.size = 0 then
		app.writeLogMessage(' removing ' &amp; web.fileName &amp; ' because not used.');
		web.cnEcRemove();
	endif;
	
epilog

	delete fJdB;
	delete fClB;
	delete web;
	
end;</source>
        <Parameter name="_dirsHotFix" type="FileNodeArray"/>
    </JadeMethod>
    <JadeMethod name="setSingleUser" id="13ba4003-3b08-466e-a364-0e32739a2108">
        <source>setSingleUser( _allDirs: FileNodeArray );
/* ---------------------------------------------------------------------------
Created:	19 December 2008	by cnwvu1

Purpose:	Have to set SINGLEUSER for all hotfixes in a superhotfix.
				when there is SINGLEUSER in a hotfix. Par18697. Dec 2008
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	fInstall	: File;
	strArray	: StringArray;
	str			: String;
	i			: Integer;
	rtH			: RootHotFixes;
	
begin
	
	create fInstall transient;
	create strArray transient;
	
	rtH := app.myRootHotFix;
	fInstall.fileName := self.getDirHotFixSuperClient(_allDirs) &amp; rtH.FILE_JMT_INSTALL_NAME;
	fInstall.kind := File.Kind_Unknown_Text; // 2/3/16  cnwns1 PAR 36286 unicode version
	fInstall.mode := File.Mode_Input;

	//	reading file into strArray
	while not fInstall.endOfFile do
		str := fInstall.readLine();
		strArray.add(str);
	endwhile;
	fInstall.close;
	
	// searching for singleuser
	if not rtH.myRootHotFixSuper.singleUserFound(strArray) then
		return;	//singleuser not found, don't need to put singleuser in JMTInstal.txt
	endif;
	// changing multiUser to singleUser for each hotfix in a super hotfix
	foreach i in 1 to strArray.size do
		strArray[i] := strArray[i].replace(rtH.TXT_MULTIUSER, rtH.TXT_SINGLEUSER);
	endforeach;
	
	
	//	writing file into strArray
	fInstall.mode := File.Mode_Output;
	fInstall.open;
	
	// reading file into strArray
	foreach i in 1 to strArray.size do
		fInstall.writeLine(strArray[i]);
	endforeach;
	
	fInstall.close;
	
	
epilog
	delete fInstall;
	delete strArray;
	
end;</source>
        <Parameter name="_allDirs" type="FileNodeArray"/>
    </JadeMethod>
