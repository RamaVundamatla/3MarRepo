        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setCombo" id="6408f2f6-888c-4f84-96df-c254ebf04311">
        <source>setCombo( _comboValues : ObjectArray; _selected : EntTableRow);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 September 2008	cnwrd1	Initial creation

*/

vars
	tmpEnt 	: Object;
	entRow 	: EntTableRow;
	indx 	: Integer;
begin
	self.cmbField.sorted := true;
	
	
	foreach tmpEnt in _comboValues do
		entRow := tmpEnt.EntTableRow;
		self.cmbField.addItemObject( entRow.getHeading(null, self.myTerminal, app.myCurrentLocale ) , entRow );
	endforeach;
	
	if _selected &lt;&gt; null then
		indx:=self.cmbField.findObject(	_selected );
		if indx &gt; 0 then
			self.cmbField.listIndex:=indx;
		endif;
	else
		self.cmbField.listIndex:=1;
	endif;
	

epilog

end;</source>
        <Parameter name="_comboValues" type="ObjectArray"/>
        <Parameter name="_selected" type="EntTableRow"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="99a9fb91-fa64-4ee9-b803-aeec14984283">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0017372, locale);
	lCombotext.translateCaption(Xlat_0009875, locale);
end;</source>
    </JadeMethod>
</GUIClass>
