<Class name="JadeScript">
    <JadeMethod name="analyze" id="c16f5b98-ed2f-40c9-8e0e-85f139386961">
        <source>analyze();

/*
Create a file that can be loaded into Excel. List the classes currently initialized and being tracked. Can also
list the first and last object id - useful when testing the IgnoreDeletes option.
*/

constants

	GetOids: Boolean = false; // CHANGE THIS TO FALSE IF ONLY INTERESTED IN CLASSES AND NUMBER OF INSTANCES - FALSE RUNS A LOT QUICKER
vars
	root: JSSCTChangeTrackingRoot;
	file: File;
	cto , firstObj, lastObj :JSSCTChangeTrackingObject;
	ctd: JSSCTChangeTrackingClass;
	classNo: String;
	iter, iter2: Iterator;
	startPos, oidI, firstOid, lastOid: Integer;

begin
	root := JSSCTChangeTrackingRoot.firstInstance;
	if root = null then
		write "No root found";
		return;
	endif;
	create file;
	file.fileName := "c:\temp\ChangeTrackingAnalyze.txt";
	file.mode := File.Mode_Output;
	file.open;

	file.writeLine ("# of updates " &amp;Tab &amp;  root.allUpdatesByTransactionIdDict.size.String);
	file.writeLine ("# of classes with changed " &amp;Tab &amp; root.allDeleteClasses.size.String);
	file.writeLine ("# of classes with deletes " &amp;Tab &amp; root.allChangeClasses.size.String);

	file.writeLine(" ");
	file.writeLine ("CHANGES");
	file.writeLine ("Class" &amp; Tab  &amp; "Instances" &amp; Tab &amp; "Class No" &amp; Tab &amp; "First" &amp; Tab &amp; "Last" &amp; Tab &amp; "First Date" &amp; Tab &amp; "Last Date");

	iter := root.allChangeClasses.createIterator;
	while iter.next (ctd) do

		if not ctd.allChangesByOid.isEmpty  and GetOids then

			cto := ctd.allChangesByOid.first;
			startPos := 1;
			cto.changeObjectID.scanUntil (".", startPos);
			classNo := cto.changeObjectID [1: startPos];
			startPos := startPos + 1;
			firstOid := null; lastOid := null;

			iter2 := ctd.allChangesByOid.createIterator;
			while iter2.next (cto) do
				oidI := cto.changeObjectID [startPos:end].Integer;
				if oidI &lt; firstOid  or firstOid = null then
					firstOid := oidI;
					firstObj := cto;
				elseif oidI &gt;  lastOid  or lastOid = null then
					lastOid := oidI;
					lastObj := cto;
				endif;
			endwhile;
			delete iter2;

			file.writeLine (ctd.className &amp; Tab &amp; ctd.allChangesByOid.size.String &amp; Tab &amp; classNo &amp; Tab &amp;
					  firstOid.String &amp; Tab &amp; lastOid.String &amp; Tab &amp;
					  firstObj.creationTime.Date.format("dd/MM/yy") &amp; Tab &amp; lastObj.creationTime.Date.format("dd/MM/yy"));
		else
			file.writeLine (ctd.className &amp; Tab &amp; ctd.allChangesByOid.size.String);
		endif;
	endwhile;
	delete iter;


	file.writeLine(" ");
	file.writeLine ("DELETES");
	file.writeLine ("Class" &amp; Tab  &amp; "Instances" &amp; Tab &amp; "Class No" &amp; Tab &amp; "First" &amp; Tab &amp; "Last" &amp; Tab &amp; "First Date" &amp; Tab &amp; "Last Date");

	iter :=  root.allDeleteClasses.createIterator;
	while iter.next (ctd) do
		if not ctd.allChangesByOid.isEmpty  and GetOids then

			cto := ctd.allChangesByOid.first;
			startPos := 1;
			cto.changeObjectID.scanUntil (".", startPos);
			classNo := cto.changeObjectID [1: startPos];
			startPos := startPos + 1;
			firstOid := null; lastOid := null;

			iter2 := ctd.allChangesByOid.createIterator;
			while iter2.next (cto) do
				oidI := cto.changeObjectID [startPos:end].Integer;
				if oidI &lt; firstOid  or firstOid = null then
					firstOid := oidI;
					firstObj := cto;
				elseif oidI &gt;  lastOid  or lastOid = null then
					lastOid := oidI;
					lastObj := cto;
				endif;
			endwhile;
			delete iter2;

			file.writeLine (ctd.className &amp; Tab &amp; ctd.allChangesByOid.size.String &amp; Tab &amp; classNo &amp; Tab &amp;
						  firstOid.String &amp; Tab &amp; lastOid.String &amp; Tab &amp;
						  firstObj.creationTime.Date.format("dd/MM/yy") &amp; Tab &amp; lastObj.creationTime.Date.format("dd/MM/yy"));

		else
			file.writeLine (ctd.className &amp; Tab &amp; ctd.allChangesByOid.size.String);
		endif;
	endwhile;

	file.close;
epilog
	delete file;
	delete iter;
	delete iter2;
end;</source>
    </JadeMethod>
    <JadeMethod name="clearTranIdDict" id="837df80e-b80d-477e-88eb-70301df58f9e">
        <updating/>
        <source>clearTranIdDict() updating;
/*
*/
vars
	changeTrackingRoot: JSSCTChangeTrackingRoot;
	changeObject: JSSCTChangeTrackingObject;
	myChangeObjectTA: JSSChangeTrackingObjectTA;
begin
	changeTrackingRoot := JSSCTChangeTrackingRoot.firstInstance;
	create myChangeObjectTA transient;  // added kgd 04/12/2003
	myChangeObjectTA.myChangeTrackingRoot:= changeTrackingRoot; // added kgd 04/12/2003

	beginTransaction;
	foreach changeObject in changeTrackingRoot.allUpdatesByTransactionIdDict do
		//	apply the commited change
		myChangeObjectTA.myChangeObject := changeObject;
		myChangeObjectTA.changeAction := changeObject.changeAction;
		myChangeObjectTA.changeObject := changeObject.changeObject;
		myChangeObjectTA.changeSequence := changeObject.changeSequence;
		myChangeObjectTA.changeTimestamp := changeObject.changeTimestamp;
		myChangeObjectTA.changeTransactionID := null;
		myChangeObjectTA.previouslyTracked := false;

		myChangeObjectTA.myChangeClass := null;
		myChangeObjectTA.myDeleteClass := null;

		myChangeObjectTA.updateEntityInTransState();

	endforeach;
	commitTransaction;

	delete myChangeObjectTA;   // added kgd 04/12/2003
end;</source>
    </JadeMethod>
    <JadeMethod name="closeCurrentAuditFile" id="00b71a2b-41a6-4564-91de-7f909a249e8a">
        <source>closeCurrentAuditFile();

vars
	dba: JadeDatabaseAdmin;
begin


	create  dba transient;
	dba.closeCurrentJournal;

epilog
	if dba &lt;&gt; null then
		delete dba;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="countInstances" id="994210c2-7780-4c11-95dc-d5225cd64e56">
        <source>countInstances();
// ---------------------------------------------------------------------------
// Created:     12 August 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	root: JSSCTChangeTrackingRoot;
	class : JSSCTChangeTrackingClass;
	num: Integer;
begin
	root := JSSCTChangeTrackingRoot.firstInstance;
	foreach class in root.allChangeClasses do
		num := class.allChangesByTime.size;
		if num &gt; 0 then
			write "Change "&amp;class.className &amp; Tab &amp; num.String;
		endif;
	endforeach;
	foreach class in root.allDeleteClasses do
		num := class.allChangesByTime.size;
		if num &gt; 0 then
			write "Delete "&amp;class.className &amp; Tab &amp; num.String;
		endif;
	endforeach;
epilog
end;</source>
    </JadeMethod>
    <JadeMethod name="getChangeInstance" id="1ec80970-d91e-4338-bf3d-9426fffe5d70">
