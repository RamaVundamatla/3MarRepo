    <JadeMethod name="sdlFillSecyRoleInvStatuses" id="e98687d4-0bfe-46f5-aebc-bed56d684f0d">
        <updating/>
        <source>sdlFillSecyRoleInvStatuses() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 January 2019	jlgsl4	Initial creation

*/

vars
	invoiceStatus : CM_InvoiceStatus;
	role : CM_SecurityRoleTerminal;
	rootRole : CM_SecurityRoleTerminalRoot;
begin
	app.initialize;
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);
	beginTransaction;
	foreach invoiceStatus in app.myRoot.allInvoiceStatuses do
		foreach role in CM_SecurityRoleTerminal.instances do
			role.allInvoiceStatusesMaint.addNoDuplicates(invoiceStatus, false);
		endforeach;
		foreach rootRole in CM_SecurityRoleTerminalRoot.instances do // terminal root statuses used when populating
			rootRole.allInvoiceStatusesMaint.addNoDuplicates(invoiceStatus, false); // 'Available' on security roles form
		endforeach;
	endforeach;
	commitTransaction;
epilog

end;</source>
