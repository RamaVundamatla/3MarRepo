<Class name="CM_QRefTrailerTypeMethod" id="26c95fcb-d200-4aad-82e3-a07474f1b01b">
    <superclass name="CM_QReferenceMethod"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <JadeMethod name="create" id="d1e669ea-a0ee-41b6-b4ce-4855b92d623d">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 October 2019	jlger1	Initial creation TFS 47132

*/

vars

	queryOperator	: CM_QueryOperator;
begin

	if self.isTransient then	
		return;
	endif;

	create queryOperator as CM_QReferenceIsOneOf persistent;
	self.allAllowedOperators.add(queryOperator);	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setComboValues" id="2c85a5e5-f283-4c89-bf79-fa928ff26b04">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 October 2019	jlger1	Initial creation TFS 47132

*/

vars

	trailerType		: CM_TILCType;
	dict 		: CM_CargoTypesByIdDict;
	os				: ObjectSet;
	crit		: CM_SelectorCriteriaLine;
begin
	_combo.clear();

	
	create os transient;	
	_params.getCargoTypes(os);		
		
	
	foreach trailerType in app.myRoot.allTILCTypes do
		if os.size &gt; 0 and not os.includes(trailerType.myCargoType) then
			continue;
		endif;
		_combo.itemObject[_combo.addItem(trailerType.description)] := trailerType;
	endforeach;

	
	
	
	if CM_QIntegerLookupEqual.hasInstance(_queryOperator) then
		_combo.listObject := app.myRoot.allTILCTypes[null,_queryOperator.CM_QIntegerLookupEqual.searchValue.asStringJMT];
	elseif CM_QIntegerLookupNotEqual.hasInstance(_queryOperator) then
	//	_combo.listObject := cargoTypeDict[_queryOperator.CM_QIntegerLookupNotEqual.searchValue];
	endif;
epilog
	delete os;


end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="16584459-8b63-4977-9611-2cf01e9dbfa2">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QReferenceIsOneOf; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 October 2019	jlger1	Initial creation TFS 47132

*/

vars
	selectionValue		: Integer;
	idx					: Integer;
	trailerType		: CM_TILCType;
	os				: ObjectSet;
begin
	_tbl.clear;
	_tbl.rows := 0;
	_tbl.sortColumn[1] := 2; // TFS 7821

	
	create os transient;	
	_params.getCargoTypes(os);		
		
	
	foreach trailerType in app.myRoot.allTILCTypes do
		if os.size &gt; 0 and not os.includes(trailerType.myCargoType) then
			continue;
		endif;
		selectionValue := 0;
		if _operator &lt;&gt; null and _operator.allSelectionValues.includes(trailerType) then
			selectionValue := 1;
		endif;
		idx := _tbl.addItem(selectionValue.String &amp; Tab &amp; trailerType.description);
		_tbl.accessRow(idx).itemObject := trailerType;
		_tbl.row := idx;
		_tbl.change(_tbl);
	endforeach;
	

epilog
	delete os;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QReferenceIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="showCriteria" id="acdc577a-eb10-4710-aa9e-6db82d436ad6">
        <source>showCriteria(lineHolder: CM_QueryCriteriaLineHolder input): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Nov 2019	jlger1	Initial creation  47132

*/

vars
	os : ObjectSet;
	obj : Object;
begin
	
	create os transient;
	lineHolder.getCargoTypes(os);
	
	foreach obj in os discreteLock do
		if obj.CM_CargoType.allTILCTypes.first &lt;&gt; null then
			return true;
		endif;
	endforeach;
	
	return false;

epilog
	delete os;

end;</source>
        <Parameter name="lineHolder" type="CM_QueryCriteriaLineHolder" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="799e3ca3-3b7c-4f66-b4e4-4256a4e01f83">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 October 2019	jlger1	Initial creation TFS 47132

*/

vars

begin
	if _value &lt;&gt; null and _value.isKindOf(CM_TILCType) then
		return _value.CM_TILCType.description;
	endif;
	
	return null;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="bd5b3c47-4eac-489f-bd5e-4533450c0c06">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 October 2019	jlger1	Initial creation TFS 47132

*/

vars
	returnVal		: CM_TILCType;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then			// PAR #18348
			return _value;
		endif;

		if _value.isKindOf(CM_TILCType) then
			returnVal := _value.CM_TILCType;
		endif;
	endif;
	
	return returnVal;
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
