	//gotoForm(MOB_HandHeldSelectVoyageForm,true);
	gotoForm(MOB_HandHeldSelectVoyageForm,false);	//24 Nov 2010	NDL Par 1972
end;
</source>
    </JadeMethod>
    <JadeMethod name="doInspect" id="6f0eda39-531e-483e-9c84-a78949f00aa3">
        <source>doInspect();
begin
	self.getSessionAgent.myJob.inspect;
	self.tblBay.accessCell(tblBay.row, tblBay.column).itemObject.inspect;
	if tblCraneXferArea.rows &gt; 0 then
		self.tblCraneXferArea.accessCell(tblCraneXferArea.row, tblCraneXferArea.column).itemObject.inspect;
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doOK" id="2c91cb2b-391c-4998-995b-fbb98f67d9e2">
        <updating/>
        <source>doOK() updating;
// Move the tracked item selected from the crane transfer area onto the ship at the selected slot
vars
	trackedItems : CM_TIArray;
	slotControllers : CM_LCArray;
begin
	if self.validateForm() then
		if self.isTwinLift then
			self.gotoForm(MOB_HandHeldTwinLift,false);
		else
			create trackedItems transient;
			trackedItems.add(tblCraneXferArea.accessCell(tblCraneXferArea.row, tblCraneXferArea.column).itemObject.CM_TrackedItem);
			create slotControllers transient;
			slotControllers.add(tblBay.accessCell(tblBay.row, tblBay.column).itemObject.CM_SlotController);
			while true do
				self.getDataAgent().moveToShip(trackedItems, self.getSessionAgent.myJob, slotControllers);
				if self.completedOK() then
					if self.isJobComplete() then
						self.doBack();
					else
						self.refreshForm();
					endif;
					break;
				endif;
			endwhile;
		endif;
	endif;
epilog
	delete trackedItems;
	delete slotControllers;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="b59dd873-7655-4461-bee0-e1bbafc6a2ba">
        <updating/>
        <source>doResize() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 November 2010	cnwndl1	Initial creation

*/

vars

begin

	inheritMethod();
	
	//to maximise the available space for displaying the 'cells' i.e. tblBay.

	// adjust widths and left position.

	self.tblBay.width := self.frmMain.width - 14;
	self.tblCraneXferArea.width := self.frmMain.width - 14;
	self.lblSlotDetail.width := self.frmMain.width - 78;
	self.lblLiftType.left :=  self.lblSlotDetail.width + 14;
	
	//adjust heights and top

	self.tblBay.height := frmMain.height - 155;
	self.lblSlotDetail.top := self.frmMain.height - 125;
	self.lblLiftType.top := self.frmMain.height - 125;
	self.tblCraneXferArea.top := self.frmMain.height - 102;
	self.btnOK.top := self.frmMain.height - 38;
	self.btnBack.top := self.frmMain.height - 38;

epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doSlotSelected" id="40187324-e0d8-4803-a79c-90bd19ea0cd1">
        <updating/>
        <source>doSlotSelected() updating;
// A slot has been selected in the bay table
vars
	trackedItem : CM_TrackedItem;
	cell : JadeTableCell;
	slotController : CM_SlotController;
begin
	cell := tblBay.accessCell(tblBay.row, tblBay.column);
	lblLiftType.caption := "";
	slotController := cell.itemObject.CM_SlotController;
	if slotController &lt;&gt; null then
		lblSlotDetail.caption := "";
		if slotController.isBulkRelease() then
			lblSlotDetail.caption := slotController.mySlotRequestLoad.getBulkRelease().code;
		endif;
		
		trackedItem := slotController.allTrackedItems.first;
		if trackedItem &lt;&gt; null then
			lblSlotDetail.caption := lblSlotDetail.caption &amp; " " &amp; trackedItem.id;
		endif;
		
		self.isTwinLift := self.canTwinLift(slotController);
	endif;
	self.showTwinLift();
end;
</source>
    </JadeMethod>
    <JadeMethod name="doTrackedItemSelected" id="3c142b24-b749-44de-ad9f-c688d5a97e1c">
        <source>doTrackedItemSelected();
// A tracked item has been selected from the crane transfer area, so enabled the OK button
begin
	self.btnOK.enabled := false;
	if tblCraneXferArea.rows &gt; 0 then
		if self.isTwinLift then
			self.btnOK.enabled := self.tblBay.selected and self.tblCraneXferArea.selectedCount = 4;
		else
			self.btnOK.enabled := self.tblBay.selected and self.tblCraneXferArea.selectedCount = 2;
		endif;
		
	endif;
end;
</source>
    </JadeMethod>
    <JadeMethod name="doUndo" id="4c5c17a6-2994-4bfe-bd6e-fe48e98216e9">
        <updating/>
        <source>doUndo() protected, updating;
//06 June 2008	cnwdw1	
// Undo the assignment

/*

Date		Who		Reason
16 Dec 2008	cnwkpd1	PAR #18664 - Clean up leaked transients

*/

vars
	slotController : CM_SlotController;
	trackedItems : CM_TIArray;
	slotControllers : CM_LCArray;
begin
	slotController := tblBay.accessCell(tblBay.row, tblBay.column).itemObject.CM_SlotController;
	if self.isCompletedSlot(slotController) then
		//self.msgBox("Under construction", "Undo a Release", MsgBox_Exclamation_Mark_Icon);

		create trackedItems transient;
		trackedItems.add(slotController.allTrackedItems.first);
		create slotControllers transient;
		slotControllers.add(slotController);
		while true do
			self.getDataAgent().moveToPreviousLocation(trackedItems, self.getSessionAgent.myJob, slotControllers);
			if self.completedOK() then
				self.refreshForm();
				break;
			endif;
		endwhile;
	endif;
	
	
epilog
	delete slotControllers;		// PAR #18664
	delete trackedItems;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doUserNotify" id="1658564f-2770-4ba4-b845-c21cc499955a">
        <updating/>
        <source>doUserNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating, protected;
// adm 270509 Par 19483 myTerminal
vars
	event : Integer;
begin
	event := self.myTerminal().getEventFromTerminalEvent(eventType);
	if event = EVENT_TI_MOVE_TO_LOCATION or 
			event = EVENT_TI_MOVE_FROM_LOCATION then
		self.refreshForm();
	endif;
end;
</source>
        <access>protected</access>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
    <JadeMethod name="getHelpDescr" id="5854c79d-bd27-46fb-9022-95ec760aa6ee">
        <source>getHelpDescr(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 November 2010	cnwndl1	Initial creation	Par 25074

*/

constants
	Bullet = 149;
vars
	
begin

	return	Bullet.Character &amp; " " &amp; app.getErrorString(Switch_between_day_night) &amp; CrLf; 

			
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTwinSlotController" id="cd378fae-ceb7-49f5-b068-4fab0dff3653">
        <source>getTwinSlotController(slotController : CM_SlotController) : CM_SlotController protected;
//03 June 2008	cnwdw1	
// Find the twin slot controller
begin
	return slotController.mySlotRequestLoad.getTwinController();
end;</source>
        <access>protected</access>
        <Parameter name="slotController" type="CM_SlotController"/>
        <ReturnType type="CM_SlotController"/>
    </JadeMethod>
    <JadeMethod name="handleF2Key" id="5301c27e-4e1e-47c9-95a3-9b386d7e1ccc">
        <updating/>
        <source>handleF2Key() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 November 2010	cnwndl1	Initial creation	Par 25074

*/

vars

	vehicleConfig : CM_RTVehicleConfig;
	form : MOB_HandHeldForm;

begin

	vehicleConfig := self.myMobileGenericAgent.myTerminal.getRTVehicleConfigForObject(null);

	if self.myMobileGenericAgent.myScreenConfig = vehicleConfig.myDayScreenConfig then
		//changing from day to night
		self.myMobileGenericAgent.setMyScreenConfig( vehicleConfig.myNightScreenConfig );
		
	else
		//changing from night to day or setting up from null
		self.myMobileGenericAgent.setMyScreenConfig( vehicleConfig.myDayScreenConfig );
		
	endif;
	
	form := self;
	self.myHandHeldCheckerAgent.doApplyConfigColours( form );
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="handleF3Key" id="ecbde957-163d-4f49-accc-3942418efa2b">
        <updating/>
        <source>handleF3Key() updating;
// Undo a completed slot in the current job. Returns the tracked item back to the crane queue so it can then
// be assigned to another slot. This is done when a tracked item is incorrectly assigned to the wrong slot
begin
	self.doUndo();
end;
</source>
    </JadeMethod>
    <JadeMethod name="handleF4Key" id="344c7af4-514d-41ec-8c9d-58c346a0875f">
        <updating/>
        <source>handleF4Key() updating;
// Toggle the TWIN lift indicator
vars
	cell : JadeTableCell;
	slotController : CM_SlotController;
	
begin
	cell := tblBay.accessCell(tblBay.row, tblBay.column);
	slotController := cell.itemObject.CM_SlotController;
	
	if slotController &lt;&gt; null then
		if self.canTwinLift(slotController) then
			self.isTwinLift := not self.isTwinLift;
			self.showTwinLift();
		endif;
	endif;
	
	self.doTrackedItemSelected();
end;</source>
    </JadeMethod>
    <JadeMethod name="isAvailableSlot" id="ddc58d99-98e4-4a11-99b0-cc7d0bd107f8">
        <source>isAvailableSlot(slotController : CM_SlotController) : Boolean;
// Is this bay slot controller available for a bulk release load?
vars

begin
	return (not self.isCompletedSlot(slotController)) and 
			self.isCurrentJobSlot(slotController) and
			slotController.isBulkRelease();
end;
</source>
        <Parameter name="slotController" type="CM_SlotController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCompletedSlot" id="8fdc2c46-498e-403f-a5df-d5e4733aa8f7">
        <source>isCompletedSlot(slotController : CM_SlotController) : Boolean;
// Is this slot load Completed?
begin
	return slotController.mySlotRequestLoad &lt;&gt; null and 
		   slotController.mySlotRequestLoad.isComplete;
end;
</source>
        <Parameter name="slotController" type="CM_SlotController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isCurrentJobSlot" id="eb0ffb2a-c92c-440b-97c4-3cf707a47b02">
        <source>isCurrentJobSlot(slotController : CM_SlotController) : Boolean;
// Is the bay slot for the current job?
begin
	return slotController.mySlotRequestLoad &lt;&gt; null and self.getSessionAgent().myJob &lt;&gt; null and
		   slotController.mySlotRequestLoad.myJob = self.getSessionAgent().myJob;
end;
</source>
        <Parameter name="slotController" type="CM_SlotController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="loadBayLayout" id="08458180-c261-4ff0-9dcb-57393094cb6b">
        <source>loadBayLayout();
/*

Purpose:			Load up the bay table with each cell linked to the slot controller

Parameters:			None

Return Value:		None


Date		Who		Reason
???			???		Initial creation
11 Jan 2011	cnwkpd1	PAR #26678 - Tidy up transient leaks

*/

vars
	headings : String;
	bay : CM_BayVoyage;
	bayTier : CM_TierDefn;
	bayTierCount : Integer;
	bayCell : CM_CellDefn;
	bayCellCount : Integer;
	index : Integer;
	iter : Iterator;
	bayCellID, bayTierID : String;
	bayCellIndex, bayTierIndex : Integer;
	cell : JadeTableCell;
	slot : CM_SlotDefn;
begin
	tblBay.clear;
	
	bay := self.getSessionAgent().myBay;
	if self.getSessionAgent().deck = DeckOnDeck then
		bayTierCount := bay.allTiersOnDeck.size;
		bayCellCount := bay.allCellsOnDeck.size;
	else
		bayTierCount := bay.allTiersUnderDeck.size;
		bayCellCount := bay.allCellsUnderDeck.size;
	endif;
	tblBay.rows := bayTierCount + 1; 
	tblBay.columns := bayCellCount + 1;
	

	// Do Row Headings
	if self.getSessionAgent().deck = DeckOnDeck then
		iter := bay.allTiersOnDeck.createIterator;
	else
		iter := bay.allTiersUnderDeck.createIterator;
	endif;
	index := tblBay.rows;
	while iter.next(bayTier) do
		cell := tblBay.accessCell(index, 1);
		cell.text := bayTier.id;
		cell.itemObject := bayTier;
		cell.enabled := false;
		cell.alignment := Table.Alignment_Center_Middle;
		tblBay.rowHeight[index] := 22; 	
		index := index - 1;
	endwhile;
	delete iter;
	
	// Do Column Headings
	if self.getSessionAgent().deck = DeckOnDeck then
		iter := bay.allCellsOnDeckByOrdinal.createIterator;
	else
		iter := bay.allCellsUnderDeckByOrdinal.createIterator;
	endif;
	index := 2;
	while iter.next(bayCell) do
		cell := tblBay.accessCell(1, index);
		cell.text := bayCell.id;
		cell.itemObject := bayCell;
		cell.enabled:= false;
		cell.alignment := Table.Alignment_Center_Middle;
		tblBay.columnWidth[index] := 32; 	
		index := index + 1;
	endwhile;
	delete iter;
	
	// link all the cells to the slot controller
	foreach bayTierIndex in 1 to bayTierCount do
		foreach bayCellIndex in 1 to bayCellCount do
			bayCell := tblBay.accessCell(1, bayCellIndex + 1).itemObject.CM_CellDefn;
			bayTier := tblBay.accessCell(bayTierIndex + 1, 1).itemObject.CM_TierDefn;
			cell := tblBay.accessCell(bayTierIndex + 1, bayCellIndex + 1);
			cell.itemObject := bay.getSlotController(self.getSessionAgent().deck, bayCell.ordinal, bayTier.ordinal);
			cell.alignment := Table.Alignment_Center_Middle;
			self.displaySlot(cell);
		endforeach;
	endforeach;

epilog
	delete iter;		// PAR #26678
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="loadCraneTransferAreaTable" id="90cf6376-f48c-48c3-80ed-77bdbe0b1762">
        <source>loadCraneTransferAreaTable();

vars
	trackedItems : CM_TIArray;
	trackedItem : CM_TrackedItem;
	job : CM_VoyageJob;
	index : Integer;
	cell : JadeTableCell;
begin
	tblCraneXferArea.clear();
	job := self.getSessionAgent().myJob;
	if job = null then
		return;
	endif;

	create trackedItems transient;
	getDataAgent().getTrackedItemsInCTAForJob(job, trackedItems);
	tblCraneXferArea.columns := 2;
	tblCraneXferArea.rows := trackedItems.size;
	index := 1;
	foreach trackedItem in trackedItems discreteLock do
		cell := tblCraneXferArea.accessCell(index, 1);
		cell.text := trackedItem.id;
		cell.itemObject := trackedItem;
		cell := tblCraneXferArea.accessCell(index, 2);
		cell.text := trackedItem.isoTypeDesc;
		cell.itemObject := trackedItem;
		index := index + 1;
	endforeach;

epilog	
	delete trackedItems;
end;</source>
    </JadeMethod>
    <JadeMethod name="refreshForm" id="e6f5c1fa-7a56-4785-8fff-0d23dce96c52">
        <updating/>
        <source>refreshForm() updating;
vars
	job : CM_VoyageJob;
begin
	job := self.getSessionAgent().myJob;
	self.txtJob.caption := "";
	if job &lt;&gt; null then
		self.txtJob.caption := "Job " &amp; job.id;
	endif;
	
	// Set the bay id and deck
	self.txtBay.caption := "Bay " &amp; self.getSessionAgent().myBay.id;
	if self.getSessionAgent.deck = DeckOnDeck then
		self.txtBay.caption := self.txtBay.caption &amp; " OD";
	else
		self.txtBay.caption := self.txtBay.caption &amp; " UD";
	endif;	

	self.btnOK.enabled := false;
	self.lblSlotDetail.caption := "";
	self.lblLiftType.caption := "";
	
	self.doResize();

	self.loadBayLayout();
	self.loadCraneTransferAreaTable();
	self.selectBayCell();
	self.selectCraneXferAreaTrackedItem();
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="resize" id="a478d224-2924-4e82-bfaa-7b04fe667c4e">
