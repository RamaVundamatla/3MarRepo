	foreach yardAlloc in terminal.allYardAllocatonsByCode discreteLock do
		create wsAlloc transient;
		wsAlloc.setProxyFromObject(yardAlloc);
		response.allYardAllocations.add(wsAlloc);
	endforeach;
	
	// Got to here, everything is ok
	completedOK := true;
