    <JadeMethod name="getAvailableEventResources" id="853e37e6-d644-4768-b122-b90bdfdbb5c6">
        <source>getAvailableEventResources(_resources : CM_ResourceTypeDict io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map

*/

vars
	toDoTask		: CM_ToDoTaskDesc;
	resourceObj		: CM_Object;
	resource		: CM_ResourceType;
	root			: CM_Root;
	
begin

	if _resources = null or self.myEventType = null then
		return;
	endif;
	
	_resources.clear();
	
	foreach toDoTask in self.myEventType.allToDoTaskDesc discreteLock do
		foreach resourceObj in toDoTask.allResourceTypes discreteLock do
			if not resourceObj.isKindOf(CM_ResourceType) then
				continue;
			endif;
			resource := resourceObj.CM_ResourceType;
			_resources.addNoDuplicates(resource, false);
		endforeach;
	endforeach;
	
	/* // ### TFS BUG 60696 27SEP2023 NAVAB1
	root := app.myRoot;
	
	if root = null then
		return;
	endif;
	
	foreach resource in root.allTaskResourceTypes discreteLock do
		if not resource.type = TODO_TYPE_GROUP_ALL then
			continue;
		endif;
		
		_resources.addNoDuplicates(resource, false);
		
	endforeach;
	*/
epilog

end;</source>
        <Parameter name="_resources" type="CM_ResourceTypeDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getEventResourceInUseFor" id="901eee27-7525-4302-9391-06d7c75e5296">
        <source>getEventResourceInUseFor(_transEventBroker : CM_EventServiceBroker; _resources : CM_ResourceTypeDict io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15/05/2023	navkc1	CR 57927 Task 54268 - Transaction Map

*/

vars

begin
	if _resources = null then
		return;
	endif;
	
	_resources.clear();
	
	_transEventBroker.getEventResourceInUse(_resources);
	
epilog

end;</source>
        <Parameter name="_transEventBroker" type="CM_EventServiceBroker"/>
        <Parameter name="_resources" type="CM_ResourceTypeDict" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getPicture" id="61432af6-37fa-4d57-991c-df4e561e1408">
        <source>getPicture(form: INV_TransactionMap): Picture;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
