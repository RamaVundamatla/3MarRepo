	if pvDet = null then
		return;
	endif;
	diff := (self.statsServerExecutions - pvDet.statsServerExecutions).abs;
	value := diff div sampTime;
	if value &gt; Max_Integer then
		_value := Max_Integer;
	else
		_value := value.Integer;
	endif;

epilog
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="avgUnlockObjectsMin" id="839db477-f85d-48a6-971c-bd8519988721">
        <methodInvocation>mapping</methodInvocation>
        <source>avgUnlockObjectsMin(set: Boolean; _value: Integer io) mapping;
/*
------------------------------------------------------------------------
Created:			16 October 2003 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
	pvDet : CM_GlobalProcessDetail;
		value,
	diff : Integer64;
	sampTime : Real;
begin
	if set then
		return;
	endif;
	_value := 0;
	sampTime := self.sampleTimeDifference;
	if sampTime = 0 then
		return;
	endif;
	if sampTime &lt; 1 then
		sampTime := 1;
	endif;
	pvDet := self.myPreviousDetail;
	if pvDet = null then
		return;
	endif;
	diff := (self.statsUnlockObjects - pvDet.statsUnlockObjects).abs;
	value := diff div sampTime;
	if value &gt; Max_Integer then
		_value := Max_Integer;
	else
		_value := value.Integer;
	endif;
epilog
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="avgUpdateObjectsMin" id="bb944a4d-ab81-4f62-b59d-669a9dcc1b66">
        <methodInvocation>mapping</methodInvocation>
        <source>avgUpdateObjectsMin(set: Boolean; _value: Integer io) mapping;
/*
------------------------------------------------------------------------
Created:			16 October 2003 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/

vars
	pvDet : CM_GlobalProcessDetail;
	value,
	diff : Integer64;
	sampTime : Real;
begin
	if set then
		return;
	endif;
	_value := 0;
	sampTime := self.sampleTimeDifference;
	if sampTime = 0 then
		return;
	endif;
	if sampTime &lt; 1 then
		sampTime := 1;
	endif;
	pvDet := self.myPreviousDetail;
	if pvDet = null then
		return;
	endif;
	diff := (self.statsUpdateObjects - pvDet.statsUpdateObjects).abs;
	value := diff div sampTime;
	if value &gt; Max_Integer then
		_value := Max_Integer;
	else
		_value := value.Integer;
	endif;
epilog
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="create" id="3cfc9d36-6a56-4f73-874c-7404d1a8fbc9">
        <updating/>
        <source>create() updating;
/*
------------------------------------------------------------------------
Created:			27 March 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		
Returns:			
