    <JadeMethod name="setupForm" id="f5f7c158-adcc-4dcb-bb8f-c64a9dedd355">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	navForm : CMUI_Navigator;
	idxOldForm : Integer;
	theForm : CM_TableViewForm;
begin
	inheritMethod();
	theForm := self.myAssistant.showTableMaintForm(self.myTerminal, self.myMasterMenuAction, true, false);

	if theForm = null then // AKB2007JULY - DCT EXCEPTION
		return;// AKB2007JULY - DCT EXCEPTION
	endif;
	
	// below code added so this new form will show up under Terminal Config and NOT Sys ops. (as this SOPS_TerminalConfig is unloaded) 
	// forms are added to nave by notes, so need to make special exception here.  
	
	// get navigator so can find where to add
	navForm := app.getForm(CMUI_Navigator.name).CMUI_Navigator;
	if navForm = null then 
		return;
	endif;
	
	// get where the old form would go (the one about to be unloaded.)
	idxOldForm := navForm.lstTest.findObject(self.myMasterMenuAction.myParent);
	
	// Chuck this newly created form in the place where it is expected to be.
	if idxOldForm &gt; 0 then
		idxOldForm := idxOldForm + 1;
		navForm.lstTest.addItemObjectAt(theForm.myMasterMenuAction, idxOldForm);
	else
		//can't find what I'm supposed to go under, so have to bail out
		return;
	endif;

	// select the newly added item
	if navForm.lstTest.listIndex &gt; 0 then
		navForm.lstTest.itemSelected[navForm.lstTest.listIndex] := false;
	endif;
		
	navForm.lstTest.itemSelected[idxOldForm] := true;
	navForm.lstTest.listIndex := idxOldForm;

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="548cb8e7-1aa8-4ab0-9fcd-c3953d4effcb">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	return;//
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
//	self.translateCaption(Xlat_0017705, locale);
end;</source>
    </JadeMethod>
</GUIClass>
