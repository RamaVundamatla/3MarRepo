	self.getSelectedForTable(allVoyageJobs, self.myCurrentTable, false);
	
	if allVoyageJobs.size &gt; 1 then
		//can only bulk move jobs that are unactioned
		foreach job in allVoyageJobs do
			if job.status &lt;&gt; JOB_UNACTIONED then
				app.msgBox(app.getErrorString1(Bulk_transfer_not_unactioned,job.id), app.getErrorString(Error),MsgBox_OK_Only);
				return;
			endif;
