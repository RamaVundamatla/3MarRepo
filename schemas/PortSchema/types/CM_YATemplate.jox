    <JadeMethod name="validate" id="f8f34b37-5c34-4919-92e3-71aa341a45f5">
        <source>validate();
//17 July 2008	cnwdw1	
//
vars

begin
	if  self.status &lt;&gt; YATemplateStatus_Active
	and self.status &lt;&gt; YATemplateStatus_Disabled then
		app.raiseCMException2(ERR_INVALID_VALUE,"Status"," ",null,null);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="7ca499e5-147a-4dc5-b543-c54754fea637">
        <source>validateForCreate();
//17 July 2008	cnwdw1	
//
begin
	if self.myTerminal.allYATemplates[self.code] &lt;&gt; null then
		app.raiseCMException1(Err_YATmpl_AlreadyExists, self.code, null, null);
	endif;
end;</source>
    </JadeMethod>
