    <JadeMethod name="getWLEForExportReplan" id="7cdfbe4d-f61d-463f-9345-1f92fa74dfba">
        <source>getWLEForExportReplan(): CM_WorkListEntry;
/*

Purpose:			Gets the WorkListEntry to be used for an export replan

Parameters:			

Return Value:		

Date			Who		Reason
30 July 2019	jlgzm1	Initial creation TFS 42863 Direct Delivery Between RORO Voyages and Rail - Break Bulk

*/

vars
	tmpWLE,
	theWLE,
	newWLE : CM_WorkListEntry;
	iter : Iterator;
begin
	iter := self.allWorkListEntries.createIterator;
	iter.back(tmpWLE);
	// if there isn't an unassigned wle then create a new one
	if tmpWLE.myTrackedItem &lt;&gt; null then
		create newWLE as CM_VoyageWLE;
		newWLE.updateRequest(self);
		newWLE.setJob(self.myJob);
		return newWLE;
	else
		theWLE := tmpWLE;
	endif;
	
	// usually we will want the last wle, but if the wle has been split then
	// it will be the 2nd to last one we want
	if iter.back(tmpWLE) then
		if tmpWLE.myTrackedItem = null then
			theWLE := tmpWLE;
		endif;
	endif;
	
	return theWLE;
epilog
	delete iter;
end;</source>
        <ReturnType type="CM_WorkListEntry"/>
    </JadeMethod>
    <JadeMethod name="getWeightRangeFromWeight" id="42508b3c-2a69-4b2b-bf59-a73f8e6b0e16">
        <source>getWeightRangeFromWeight(_weight: Integer): CM_WeightRange;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23/08/2011	cnwer1	Initial creation CCMS MES 1033
30/04/2013	cnwdap1	PAR #31155 CCMS SFW 1321 Imperial Measurements
*/

vars
	roundedWeight	: Integer;
	measure			: CM_MeasurementType;									// PAR #31155
	
begin
	measure := app.getDefaultMeasurementForType(Type_Weight);				// PAR #31155
	if _weight = 0 then
		roundedWeight	:=	self.weight.rounded();
		
		//return app.myRoot.allWeightRanges.getAtKeyGeq(roundedWeight);		// PAR #31155
		return measure.allWeightRanges.getAtKeyGeq(measure, roundedWeight);	// PAR #31155
	else
		//return app.myRoot.allWeightRanges.getAtKeyGeq(_weight);				// PAR #31155
		return measure.allWeightRanges.getAtKeyGeq(measure, _weight);			// PAR #31155
	endif;

epilog

end;</source>
        <Parameter name="_weight" type="Integer"/>
        <ReturnType type="CM_WeightRange"/>
    </JadeMethod>
