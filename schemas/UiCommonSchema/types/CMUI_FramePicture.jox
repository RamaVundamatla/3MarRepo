<GUIClass name="CMUI_FramePicture" id="bb9c02a0-a46b-4953-acee-a6996c4304d7">
    <superclass name="Picture"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="_usergui"/>
    <JadeMethod name="mouseDown" id="a103dbaa-7bce-454e-811c-77204e664b85">
        <controlMethod name="Picture::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseDown(pict: Picture input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
//----------------------------------------------------------------
//	Created:	06 April 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod(pict, button, shift, x, y);

	pict.left := pict.left + 1;
	pict.top := pict.top + 1;

end;</source>
        <Parameter name="pict" type="Picture" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="mouseUp" id="24f1e380-e668-45bd-b6a6-5204be16b9ab">
        <controlMethod name="Picture::mouseUp"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <executionLocation>client</executionLocation>
        <source>mouseUp(pict: Picture input; button: Integer; shift: Integer; x: Real; y: Real) updating, clientExecution;
//----------------------------------------------------------------
//	Created:	06 April 2006	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

begin
	inheritMethod(pict, button, shift, x, y);

	pict.left := pict.left - 1;
	pict.top := pict.top - 1;

end;</source>
        <Parameter name="pict" type="Picture" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
