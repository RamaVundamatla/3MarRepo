/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 December 2010	cnwrd1	Initial creation

*/

vars

begin
	// make list box bigger, and place it over the textbox
	self.lstMTGrade.move(self.txtMTGrades.getFormLeft, self.txtMTGrades.getFormTop, self.txtMTGrades.width, 125);
	self.lstMTGrade.visible := true;
