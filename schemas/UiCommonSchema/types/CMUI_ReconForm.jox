/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 August 2009	cnwml2	Initial creation

*/

vars

begin
	self.frmComplete.visible := true;
	//self.doClearComplete();
	self.frmComplete.zOrder(1);
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnSaveComplete.enabled:= false;
		self.btnSaveClose.enabled:= false;
	endif;

	self.frmMain.enabled := false;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
