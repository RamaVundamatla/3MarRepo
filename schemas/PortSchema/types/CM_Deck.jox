    <JadeMethod name="getDisplayStringForAttribute" id="7bec94f4-7050-42b4-90c3-a91406696db2">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 March 2011	cnwer1	Initial creation

*/

vars
	
begin

	if _attrName = ETRow_Code or _attrName = ETRow_DeckCode then
		return self.code.asStringJMT;
	elseif _attrName = ETRow_Description then
		return self.description.asStringJMT;
	elseif _attrName = ETRow_Remarks then
		return self.remarks.asStringJMT;
	elseif _attrName = ETRow_DeckFloorArea then
		return self.totalArea.asStringJMT;
	elseif _attrName = ETRow_DeckVolume then
		return self.totalVolume.asStringJMT;
	elseif _attrName = ETRow_FortyMaxLoad then
		return self.maxLoadStack40.asStringJMT;
	elseif _attrName = ETRow_TwentyMaxLoad then
		return self.maxLoadStack20.asStringJMT;
	elseif _attrName = ETRow_HeightFromBL then
		return self.heightFromBL.asStringJMT;
	elseif _attrName = ETRow_MaxClearance then
		return self.maxClearHeight.asStringJMT;
	elseif _attrName = ETRow_MaxLoadAxel then
		return self.maxLoadAxel.asStringJMT;
	elseif _attrName = ETRow_MaxLoadPerM then
		return self.maxLoadM2.asStringJMT;
	elseif _attrName = ETRow_MaxTier then
		return self.numTier.asStringJMT;
	elseif _attrName = ETRow_TotalContainers then
		return self.totalTEU.asStringJMT;
	elseif _attrName = ETRow_DeckItemCode then
		return null;
	elseif _attrName = ETRow_DeckItemType then
		return self.typeName();
	elseif _attrName = ETRow_TotalLinearMetres then
		return self.totalLM.asStringJMT;
	else
		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
