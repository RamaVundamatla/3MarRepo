    <JadeMethod name="clearThumbnailData" id="9d712cb7-7657-4f03-b652-e4c4af6af2df">
        <updating/>
        <source>clearThumbnailData() updating;
// ---------------------------------------------------------------------------
// Created:     25 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if self.useTxtThumb then
		self.txtThumbnail.text := null;
		self.txtHeader.text := null;		
		return;
	endif;

	tblInputTop.clearValues();
	tblAlpha.clearValues();
	tblEdit1.clearValues();
	tblEdit2.clearValues();
	tblEdit3.clearValues();
	tblEdit4.clearValues();
	tblEdit5.clearValues();
	tblEdit6.clearValues();
	tblEdit7.clearValues();
	tblEdit8.clearValues();
	tblEdit9.clearValues();
	tblEdit10.clearValues();
	self.allInitializedSheets.clear();
	self.allEntryTableDefs.clear();
end;</source>
