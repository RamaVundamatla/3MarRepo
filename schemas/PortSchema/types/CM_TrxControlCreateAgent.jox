												  null);

	if _passport.hasErrors then
		return;
	endif;

	pProxyInterTerminalConfig.setRelease(newInterTermBulkRelease);
	// Perform the operation
	app.myUtilityCA.utlCreateInterTerminalConfig(pProxyInterTerminalConfig, pNewInterTerminalConfig, _passport);
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
