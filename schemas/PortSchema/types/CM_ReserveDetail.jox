    <JadeMethod name="getTiForRailAssignIfOnlyOne" id="384691cd-6319-4fb5-9388-49205ca8d6ef">
        <source>getTiForRailAssignIfOnlyOne():CM_TrackedItem;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28 February 2017	cnwndl1	Initial creation TFS 3514
23/06/2023	navkc1	CR 58406 Task 58408: Jade - Release Request All Tracked Items
*/

vars

	prospects : CM_TIArray;
	ti : CM_TrackedItem;
	allTis	: CM_TISet;
begin

	create prospects transient;
	create allTis transient; //23/06/2023	navkc1	CR 58406 Task 58408
	
	self.getAllTrackedItems(allTis, false); //23/06/2023	navkc1	CR 58406 Task 58408
	
	//foreach ti in self.allTrackedItems do
	foreach ti in allTis do //23/06/2023	navkc1	CR 58406 Task 58408
		if not ti.isOnSite then
			continue;
		endif;
		if ti.isRRP then	//31 Mar 2020	NDL	TFS 47004
			continue;
		endif;
		if ti.hasBeenMerged then
			continue;
		endif;
		if ti.myPrimaryActualLocation = null or ti.myPrimaryActualLocation.isWagon then
			continue;
		endif;
		prospects.add(ti);
	endforeach;
	
	if prospects.size = 1 then
		return prospects.first;
	endif;
	
	return null;

epilog

	delete prospects;
	delete allTis; //23/06/2023	navkc1	CR 58406 Task 58408
end;</source>
        <ReturnType type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="getTotalActionedDisplay" id="c930f5e4-6ab1-4868-886a-e88fdb95bb8f">
        <source>getTotalActionedDisplay( _excludingJob : CM_Job ) : String;
/*

Date		Who		Reason
25 June 2014	cnwer1	Initial creation PAR 34406

*/

vars
	req	: CM_Request;
	num : Decimal[14,4];
	ct : CM_CargoType;
	isForWeight : Boolean;
begin
	if self.myReserveHeader = null then
		return null;
	endif;
	num:=0;
	
	ct := self.getCargoType;
	isForWeight:= ct &lt;&gt; null and  ct.isBulkMulti;
	
	foreach req in self.allRequests do
		if _excludingJob &lt;&gt; null and
		   req.myJob = _excludingJob then
			continue;
		endif;
		if self.myReserveHeader.allRequestsBeingActioned.includes(req) then
			if  isForWeight then
				num:=num +req.weightRequested;
			else
				num:=num + req.getQuantityOnRequest().Integer;
			endif;
			
		endif;
	endforeach;

	if  isForWeight then
		return ct.getBulkTrackByDisplayForWeight(num,self.getDensity,true);
	else
		return num.Integer.asStringJMT;
	endif;

epilog

end;</source>
        <Parameter name="_excludingJob" type="CM_Job"/>
        <ReturnType type="String"/>
    </JadeMethod>
