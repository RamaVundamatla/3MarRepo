    <JadeMethod name="trxCreateBolInCustoms" id="8b718e11-85e6-4285-b287-48616c3256a7">
        <updating/>
        <source>trxCreateBolInCustoms(_intBOLIn:CMIF_BOLIn input; _ediBOL : CM_EDIDataBillOfLading; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: cnwrs1 sept 2009
//--------------------------------------------------------------
vars
	realBOL		: CM_BOLIn;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);
	
	if _ediBOL = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_ediBOL', null, null);
		return;
	endif;
	
	// Start the transaction
	beginTransaction;

	// Perform the operation
	app.myUtilityCA.utlCreateBOLInFromCMIF(_intBOLIn, realBOL, _passport);
	
	if _passport.hasErrors then
		return;
	endif;
	
	if realBOL = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'realBOL is null after call to utlCreateBOLIn');
		return;
	endif;
	
	
	
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_intBOLIn" type="CMIF_BOLIn" usage="input"/>
        <Parameter name="_ediBOL" type="CM_EDIDataBillOfLading"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateBookingBulkRel" id="b5477f09-0f5e-40b1-b654-707555e11caa">
        <updating/>
        <source>trxCreateBookingBulkRel(_pxyBooking 	: CM_BookingRef input; 
						_newBookingRef 	: CM_BookingRef output;
						_newBulkRelease : CM_BulkRelease output;
						_passport 		: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 Nov 2008	cnwer1	Initial creation
20 Jul 2023	navdap1	TFS 58923 EUP CallOff EDI Data Type / Data Load
28 May 2024	navdap1	TFS 64315 CUX - System Lock when creating bookings and prenotes via Booking and Cargo APIs
*/

vars
	pxyBulkRelease 	: CM_BulkRelease;
	proxyColl 		: CM_ObjectArrayActual;
	proxy			: CM_Object;
begin
// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	create proxyColl transient;
	
	beginTransaction;
	
	// TFS 64315 lock everything up front
	if app.myPassport.myTerminal &lt;&gt; null then
		self.exclusiveLock(app.myPassport.myTerminal.allBookingRefsByOperatorRef);
		self.exclusiveLock(app.myPassport.myTerminal.allBookingRefsByRef);
	endif;
	if _pxyBooking.myVoyage &lt;&gt; null then
		self.exclusiveLock(_pxyBooking.myVoyage.allBookingRefs);
	endif;
	// TFS 64315 end
	
	app.myUtilityCA.utlCreateBookingRef(_pxyBooking, _passport, null, _newBookingRef,proxyColl);

	pxyBulkRelease :=_pxyBooking.allReleaseRequests.first.CM_BulkRelease;

	if _passport.noErrors() and pxyBulkRelease &lt;&gt; null  then
		app.myUtilityCA.utlCreateBulkRelease(pxyBulkRelease, _newBulkRelease,  _newBookingRef, null, null, null, _passport);	// TFS 58923
	endif;
	
	//+cnwml2 PAR21072
	if _passport.noErrors and _newBookingRef &lt;&gt; null then	// par 22762 - could be null if there were warnings
		app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(_newBookingRef);
	endif;
epilog

	self.finaliseActivityWithPassport(_passport);

	if proxyColl &lt;&gt; null then
		//these proxies have not been committed yet so if there was an exception then need to remove proxy link
		foreach proxy in proxyColl do
			app.myProxyManager.deleteProxyLink(proxy);
		endforeach;
		
		delete proxyColl;
	endif;

end;</source>
        <Parameter name="_pxyBooking" type="CM_BookingRef" usage="input"/>
        <Parameter name="_newBookingRef" type="CM_BookingRef" usage="output"/>
        <Parameter name="_newBulkRelease" type="CM_BulkRelease" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxCreateBookingBulkRel_CMIF" id="7d75eb67-c2a1-42d8-8096-1bdd5d62c239">
        <updating/>
        <source>trxCreateBookingBulkRel_CMIF(	_cmifBooking 	: CMIF_BookingRef input; 
								_allTIPins 		: CM_StringDict;  //cnwrd1 par 25594 10.12.2010
								_passport 		: CM_Passport input;
								_guiObject 		: Object; 
								_newBooking 	: CM_BookingRef output;
								_pxyRelease 	: CM_BulkRelease io;
								_newRelease 	: CM_BulkRelease output;
								_extraInfo 		: String) updating;
// --------------------------------------------------------------------------------
// Created:		14 May 2008 by cnwdad1
//
// Purpose:		Creates a Booking Reference (and its Booking Reference Items), and
//				a new Bulk Release (and its Reserve Details).  The Bulk Release and
//				its Reserve Details are a mirror of the Booking Reference.
//
// Parameters:	_cmifBooking 	- A reference to the CMIF Booking Reference object.
//				_passport 		- A reference to the User Passport object.
//				_guiObject 		- A reference to an EDI Booking Reference TI object.
//				_newBooking 	- A reference to the new Booking Reference object.
//				_pxyRelease 	- A reference to a proxy Bulk Release object.
//				_newRelease 	- A reference to the new Bulk Release object.
//
// Returns:		Output parameter references to the new Booking Reference and the new
//				Bulk Release objects.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 20/02/2012	cnwcs5		par 28756 - change to use utlCreateBulkRelease instead of utlCreateBulkRelease_CMIF
// 20/07/2023	navdap1		TFS 58923 EUP CallOff EDI Data Type / Data Load
// 28/05/2024	navdap1		TFS 64315 CUX - System Lock when creating bookings and prenotes via Booking and Cargo APIs
// --------------------------------------------------------------------------------
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	beginTransaction;

	// TFS 64315 lock everything up front
	if app.myPassport.myTerminal &lt;&gt; null then
		self.exclusiveLock(app.myPassport.myTerminal.allBookingRefsByOperatorRef);
		self.exclusiveLock(app.myPassport.myTerminal.allBookingRefsByRef);
	endif;
	if _cmifBooking.myProxyBookingRef.myVoyage &lt;&gt; null then
		self.exclusiveLock(_cmifBooking.myProxyBookingRef.myVoyage.allBookingRefs);
	endif;
	// TFS 64315 end
	
	app.myUtilityCA.utlCreateBookingRefMulti(_cmifBooking, _passport, _guiObject, _newBooking, _extraInfo);
	
	if _passport.noErrors() and _pxyRelease &lt;&gt; null then
		app.myUtilityCA.utlCreateBulkRelease(_pxyRelease, _newRelease, _newBooking, _cmifBooking, _allTIPins, null, _passport);		// TFS 58923
	endif;

epilog
	if not _passport.isOkToCommit(false) and _cmifBooking &lt;&gt; null then	
		_cmifBooking.setMyRealBookingRef(null);
		_cmifBooking.clearInvalidBRefItems();
	endif;
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_cmifBooking" type="CMIF_BookingRef" usage="input"/>
        <Parameter name="_allTIPins" type="CM_StringDict"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_guiObject" type="Object"/>
        <Parameter name="_newBooking" type="CM_BookingRef" usage="output"/>
        <Parameter name="_pxyRelease" type="CM_BulkRelease" usage="io"/>
        <Parameter name="_newRelease" type="CM_BulkRelease" usage="output"/>
        <Parameter name="_extraInfo" type="String"/>
    </JadeMethod>
    <JadeMethod name="trxCreateBookingRef" id="a9864e1f-1299-410a-9d5a-6e50a874f7d4">
        <updating/>
        <source>trxCreateBookingRef(pProxyBookingRef : CM_BookingRef input; 
					_passport : CM_Passport input; pGuiObject : Object; 
					pNewBookingRef : CM_BookingRef output) updating;
// ---------------------------------------------------------------------------
// Created:     12 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 28/05/2024	navdap1		TFS 64315 CUX - System Lock when creating bookings and prenotes via Booking and Cargo APIs
// ---------------------------------------------------------------------------
vars
	
begin

	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	beginTransaction;

	// TFS 64315 lock everything up front
	if app.myPassport.myTerminal &lt;&gt; null then
		self.exclusiveLock(app.myPassport.myTerminal.allBookingRefsByOperatorRef);
		self.exclusiveLock(app.myPassport.myTerminal.allBookingRefsByRef);
	endif;
	if pProxyBookingRef.myVoyage &lt;&gt; null then
		self.exclusiveLock(pProxyBookingRef.myVoyage.allBookingRefs);
	endif;
	// TFS 64315 end
	
	app.myUtilityCA.utlCreateBookingRef(pProxyBookingRef, _passport, pGuiObject, pNewBookingRef,null);
	
	//+cnwml2 PAR21072
	if _passport.noErrors then
		app.myUtilityCA.myCreateAuditAgent.audCreateGeneric(pNewBookingRef);
	endif;

epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="pProxyBookingRef" type="CM_BookingRef" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="pGuiObject" type="Object"/>
        <Parameter name="pNewBookingRef" type="CM_BookingRef" usage="output"/>
    </JadeMethod>
    <JadeMethod name="trxCreateBookingRefMulti" id="faf988d7-a135-44ed-a6f0-c8cc2ec5017b">
        <updating/>
        <source>trxCreateBookingRefMulti(pCMIF : CMIF_BookingRef input; 
					_passport : CM_Passport input; pGuiObject : Object; 
					pNewBookingRef : CM_BookingRef output) updating;
/*
	Created on 13 February 2008
	
	by Debby Hutchison
	
	Purpose:
	
Changed On	By			Reason
----------	--------	----------------------------------------------------------
28/05/2024	navdap1		TFS 64315 CUX - System Lock when creating bookings and prenotes via Booking and Cargo APIs
*/
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	beginTransaction;

	// TFS 64315 lock everything up front
	if app.myPassport.myTerminal &lt;&gt; null then
		self.exclusiveLock(app.myPassport.myTerminal.allBookingRefsByOperatorRef);
		self.exclusiveLock(app.myPassport.myTerminal.allBookingRefsByRef);
	endif;
	if pCMIF.myProxyBookingRef.myVoyage &lt;&gt; null then
		self.exclusiveLock(pCMIF.myProxyBookingRef.myVoyage.allBookingRefs);
	endif;
	// TFS 64315 end
	
	app.myUtilityCA.utlCreateBookingRefMulti(pCMIF, _passport, pGuiObject, pNewBookingRef, null);
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="pCMIF" type="CMIF_BookingRef" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="pGuiObject" type="Object"/>
        <Parameter name="pNewBookingRef" type="CM_BookingRef" usage="output"/>
    </JadeMethod>
    <JadeMethod name="trxCreateBoom" id="3b051966-a211-48cb-b2c8-d22fb0d8f301">
        <updating/>
        <source>trxCreateBoom(	_pxyBoom	: CM_Boom input;
				_newBoom	: CM_Boom output;
				_passport	: CM_Passport input) updating;

/*
Date			Who		Reason
06 July 2009	cnwar2	Initial creation

*/
vars

begin
	self.initialiseActivityWithPassport(_passport, method);

	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	beginTransaction;

	app.myUtilityCA.utlCreateBoom(_pxyBoom, _newBoom, _passport);
epilog
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_pxyBoom" type="CM_Boom" usage="input"/>
        <Parameter name="_newBoom" type="CM_Boom" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
