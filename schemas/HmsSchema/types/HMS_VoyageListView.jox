    <JadeMethod name="translateForm" id="dc3f5c80-4bd6-4c7e-a6a8-b705ed804dc0">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0005974, locale);
	btnDelete.translateCaption(Xlat_0001724, locale);
	btnEdit.translateBubbleHelp(Xlat_0001722, locale);
	btnEdit.translateCaption(Xlat_0001725, locale);
	btnNew.translateBubbleHelp(Xlat_0001723, locale);
	btnNew.translateCaption(Xlat_0001726, locale);
	lblViewOrder.translateCaption(Xlat_0001727, locale);
	optByArrival.translateCaption(Xlat_0001728, locale);
	optByDeparture.translateCaption(Xlat_0001721, locale);
	optByVoyageCode.translateCaption(Xlat_0001720, locale);
end;</source>
    </JadeMethod>
</GUIClass>
