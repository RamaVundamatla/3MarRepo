    <JadeMethod name="saveTrackedItems" id="0c03c11f-f505-4bbe-9dc6-4317a2f81ad0">
        <updating/>
        <source>saveTrackedItems(): Boolean updating, protected;

// 10/12/2014  cnwdb2	PAR 35364

vars
	moveController	: CMIF_MoveController;
	rtnValue		: Boolean;
	cancelSave		: Boolean;
	location		: CM_LocationsController;
	cmif			: CMIF_Remote;
	manager			: CM_RemoteDataManagerInternal;
	errSet			: CM_TISet;
	result			: Integer;

begin
	
	create errSet transient;
	if self.cmbTOLocation.listObject = null then

		app.addWarningFullPassport(Input_required_field_toLocn, app.getErrorString(Input_required_field_toLocn), null, null, app.myPassport); // cnwdb2	PAR 35364
  
		app.showErrorWarningDialog(app.getErrorString(Log_Transfer), app.myPassport, ErrWarnMode_Update);		//#25491 17/02/2011 - showing error for a user0
		
		return false;
	endif;
	location := self.cmbTOLocation.listObject.CM_LocationsController;

	if self.btnBackground.value then
		create manager transient;
		create cmif transient;
		cmif.transactionType	:= manager.TRANSFERRQ;
		cmif.terminalAreaTo 	:= location.myTerminalArea.id;
		cmif.transferTo			:= location.getID();
		cmif.terminal			:= self.myTerminal.code;
		self.getTrackedItems(cmif.allTis);
	else
		// doing in foreground
		self.myCMIFMonitor.partsInJob := self.allTrackedItems.size;
		self.myCMIFMonitor.partsDone := 0;
		self.pbProgressBar.visible := true;   	
		self.updateProgress(self.myCMIFMonitor);	
		
		create moveController transient;
		moveController.setMoveMode(REAL_MODE);
		moveController.isSystemMove := true;
		moveController.setMyToPrimaryLocation(location);
	endif;
	
	// ccms 1107 / PAR20627 - neeed to organize warnings to a user
	while true do
	
		if self.btnBackground.value then
			rtnValue := manager.processInternal(cmif, app.myPassport);
		else
			// doing in foreground
			app.myTrxUA.trxMoveTrackedItemsWithSplit(self.allTrackedItems, errSet, moveController, app.myPassport);
			rtnValue := app.myPassport.trxCompletedOK;	// 06/10/2009 cnwar2 #20961 - uncommented
		endif;
	
		if app.myPassport.trxCompletedOK and errSet.size = 0 then
			break;
		else
			if errSet.size &gt; 0 then
				app.addWarningFullPassport(Err_TiMoveFailure, app.getErrorString2(Err_TiMoveFailure, errSet.size.String, self.allTrackedItems.size.String), null, null, app.myPassport);
			endif;
			//epr par 36720 31/8/15 some tis have been moved reset allTrackedItems to those which errored and didn't move
			self.allTrackedItems.clear;
			errSet.copy(self.allTrackedItems);
			result := app.showErrorWarningDialog(app.getErrorString(Log_Transfer), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			return false;
		endif;
		break;
		
	endwhile;


epilog
	delete moveController;
	delete manager;
	delete cmif;
	delete errSet;
	return rtnValue;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
