    <JadeMethod name="doExportShip" id="b195b1b9-3f92-476c-a461-dd1d1eb16768">
        <source>doExportShip();
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theXML, theXMLTagValue : String;
	fileXML : CMDFileOpen;
	theXMLFile : File;
	pos,pos2 : Integer;
	theID,thePoints,thePoint : String;
	theTerminal : CM_Terminal;
	layoutGraphic : CMIF_LayoutGraphics;
	theTerminalArea : CM_TerminalArea;
	thePointsArray : PointArray;
	theXYStrings : StringArray;
	theX, theY, idx : Integer;
	anError : CM_Error;
	aPoint:Point;
	nullVoy : CM_Voyage;
	fileName : String;
begin

	theTerminal := self.myTerminal;
	nullVoy := theTerminal.getNullVoyage();	
	
	if nullVoy = null then
		app.msgBox("No Null Voyage"	,"Error",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	
	endif;
	create fileXML;
	fileXML.filter := "JMT Ship Graphic (*.xml)|*.xml";
	fileXML.fileName := "NullVoyageGraphic.xml";
	if fileXML.open = 0 then
		create theXMLFile;
		theXMLFile.mode := File.Mode_Output;	// 1/3/16 cnwmp6 PAR 36286 unicode version
		theXMLFile.fileName := fileXML.fileName;
		fileName := fileXML.fileName;
		// use these if not compressed		
		theXMLFile.maxRecordSize := 40000;
		theXMLFile.writeString(nullVoy.myLayoutGraphic.getXMLData());
	
		app.msgBox("Export finished to file" &amp; Cr &amp; "'" &amp;  fileName &amp; "'","Export",MsgBox_OK_Only + MsgBox_Information_Icon);
	endif;
epilog
	if theXMLFile &lt;&gt; null then	// it can be null after pressing Cancel - cnwvu1
		theXMLFile.close;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doExportTIBehaviour" id="2cc8fd4e-be5d-4a8b-982f-32eb10b336ee">
        <source>doExportTIBehaviour();
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theXML, theXMLTagValue : String;
	fileXML : CMDFileSave;
	theXMLFile : File;
	pos,pos2 : Integer;
	theID,thePoints,thePoint : String;
	theTerminal : CM_Terminal;
	layoutGraphic : CMIF_LayoutGraphics;
	theTerminalArea : CM_TerminalArea;
	thePointsArray : PointArray;
	theXYStrings : StringArray;
	theX, theY, idx : Integer;
	anError : CM_Error;
	aPoint:Point;
	fileName : String;
	tiBType : CM_TIBehaviourType;
	result : Integer;
begin

	theTerminal := self.myTerminal;
	tiBType := self.cmbGraphics.listObject.CM_TIBehaviourType;
	
	if tiBType = null then
		app.msgBox("No TI Behaviour"	,"Error",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	write tiBType.myGraphic.getXMLData();
	
	create fileXML;
	fileXML.filter := "JMT TI Behaviour Graphic (*.xml)|*.xml";
	fileXML.fileName := tiBType.description.removeString(" ") &amp; "Graphic.xml";
	
	if fileXML.open() = 0 then
	
		create theXMLFile;
		theXMLFile.mode := File.Mode_Output;	// 1/3/16 cnwmp6 PAR 36286 unicode version
		theXMLFile.fileName := fileXML.fileName;
		fileName := fileXML.fileName;
		// use these if not compressed		
		theXMLFile.maxRecordSize := 40000;
		theXMLFile.writeString(tiBType.myGraphic.getXMLData());
		theXMLFile.close;
		
		app.msgBox("Export finished to file" &amp; Cr &amp; "'" &amp;  fileName &amp; "'","Export",MsgBox_OK_Only + MsgBox_Information_Icon);
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doImportShip" id="159da885-1f49-43f3-ada9-692914e95bdf">
        <source>doImportShip();
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theXML, theXMLTagValue : String;
	theXMLFile : File;
	fileXML : CMDFileOpen;
	pos,pos2 : Integer;
	theID,thePoints,thePoint : String;
	theTerminal : CM_Terminal;
	layoutGraphic : CMIF_LayoutGraphics;
	theTerminalArea : CM_TerminalArea;
	thePointsArray : PointArray;
	theXYStrings : StringArray;
	theX, theY, idx : Integer;
	anError : CM_Error;
	aPoint:Point;
	nullVoy : CM_Voyage;
	fileName : String;
	theReturn : Integer;
begin
	if app.msgBox("Are you sure that you want to import new side profile layout for terminal " &amp; self.myTerminal.name &amp; "?","Confirm",MsgBox_Yes_No) = MsgBox_Return_No then
		return;
	endif;
	theTerminal := self.myTerminal;
	nullVoy := theTerminal.getNullVoyage();	
	
	if nullVoy = null then
		app.msgBox("No Null Voyage"	,"Error",MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
		return;
	
	endif;
	create fileXML;
	fileXML.fileName := "NullVoyageGraphic.xml";
	fileXML.filter := "JMT Ship Graphic (*.xml)|*.xml";
	if fileXML.open = 0 then
		app.mousePointer := Window.MousePointer_HourGlass;
		create theXMLFile;
		theXMLFile.kind := File.Kind_Unknown_Text;	// 1/3/16 cnwmp6 PAR 36286 unicode version
		theXMLFile.fileName := fileXML.fileName;
		fileName := fileXML.fileName;
		theXMLFile.maxRecordSize := 40000;
		theXML := theXMLFile.readLine();
	
		if nullVoy.myLayoutGraphic	= null then
			nullVoy.createGraphicForNullVoyage();
		endif;
		nullVoy.myLayoutGraphic.setXMLData(theXML);
	
		app.msgBox("Import finished from file" &amp; Cr &amp; "'" &amp;  fileName &amp; "'","Import",MsgBox_OK_Only + MsgBox_Information_Icon);
	endif;
epilog
	if theXMLFile &lt;&gt; null then
		theXMLFile.close;
	endif;


end;</source>
    </JadeMethod>
    <JadeMethod name="doImportTIBehaviour" id="10ec1491-e185-4009-9842-50407ae90157">
        <source>doImportTIBehaviour();
// ---------------------------------------------------------------------------
// Created:		February 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theXML, theXMLTagValue : String;
	theXMLFile : File;
	fileXML : CMDFileOpen;
//	pos,pos2 : Integer;
//	theID,thePoints,thePoint : String;
//	theTerminal : CM_Terminal;
//	layoutGraphic : CMIF_LayoutGraphics;
//	theTerminalArea : CM_TerminalArea;
//	thePointsArray : PointArray;
//	theXYStrings : StringArray;
//	theX, theY, idx : Integer;
//	anError : CM_Error;
//	aPoint:Point;
	fileName : String;
	theReturn, tiBTypeType : Integer;
	tiBType : CM_TIBehaviourType;
begin
	if app.msgBox("Are you sure that you want to import a TI Behaviour?","Confirm",MsgBox_Yes_No) = MsgBox_Return_No then
		return;
	endif;
	create fileXML;
	fileXML.filter := "JMT TI Behaviour Graphic (*.xml)|*.xml";
	if fileXML.open = 0 then
		app.mousePointer := Window.MousePointer_HourGlass;
		create theXMLFile;
		theXMLFile.kind := File.Kind_Unknown_Text;	// 1/3/16 cnwmp6 PAR 36286 unicode version
		theXMLFile.fileName := fileXML.fileName;
		fileName := fileXML.fileName;
		theXMLFile.maxRecordSize := 40000;
		theXML := theXMLFile.readLine();
	
		theXMLTagValue := theXML.cnEcGetTagValueOfName("TIBTYPE"); 
		tiBTypeType := theXMLTagValue.Integer;
		tiBType := app.myRoot.allTIBehaviourTypes[tiBTypeType];
		// oh dear
		if tiBType = null then
			app.msgBox("No TI Behaviour Type Exists!!! Type '" &amp; tiBType.String &amp; "'","Error",MsgBox_Exclamation_Mark_Icon);
			return;
		endif;
		
		// this needs to be trx'd if this form is ever implemented correctly
		beginTransaction;
		
		if tiBType.myGraphic	= null then
			tiBType.createGraphic();
		endif;
		tiBType.myGraphic.setXMLData(theXML);
		
		commitTransaction;
	
		app.msgBox("Import finished from file" &amp; Cr &amp; "'" &amp;  fileName &amp; "'","Import",MsgBox_OK_Only + MsgBox_Information_Icon);
	endif;
epilog
	if theXMLFile &lt;&gt; null then
		theXMLFile.close;
	endif;


end;</source>
    </JadeMethod>
    <JadeMethod name="doRenumberTable" id="c38dd3d0-ec96-41c6-b460-b3b4329cb7a3">
        <source>doRenumberTable();
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	idx : Integer;
begin
	foreach idx in 2 to self.tblDim.rows do
		self.tblDim.accessCell(idx,1).text := (idx - 1).String;
	endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="doResize" id="4b14458c-a2b8-4dc8-b7e6-7d1d306d1d2a">
        <updating/>
        <source>doResize() updating;
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	tbHeight : Integer;
begin
	inheritMethod();
	
	tbHeight := self.frmToolbar.clientHeight;
	
	self.splMain.move(0,tbHeight,self.clientWidth,self.clientHeight - tbHeight);
	self.splMain.cnEcResizeContents();
	self.splMain.repositionAfterResize();

	if self.tblDim.columns = self.COLUMN_LABEL then
	self.doResizeTable();
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="doResizeTable" id="4eec38a0-3e47-42de-adce-6bce8d82bb00">
        <source>doResizeTable();
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theTable : Table;
begin
	theTable := self.tblDim;
	theTable.accessColumn(COLUMN_NUM).width := 50;
	theTable.accessColumn(COLUMN_TYPE).width := 70;
	theTable.accessColumn(COLUMN_COLOUR).width := 50;
	theTable.accessColumn(COLUMN_FILL).width := 50;
	theTable.accessColumn(COLUMN_X1).width := 50;
	theTable.accessColumn(COLUMN_X2).width := 50;
	theTable.accessColumn(COLUMN_Y1).width := 50;
	theTable.accessColumn(COLUMN_Y2).width := 50;
	//epr 8/8/08 ccms 1045
	theTable.accessColumn(COLUMN_STARTX).width := 30;
	theTable.accessColumn(COLUMN_ENDX).width := 30;
	theTable.accessColumn(COLUMN_STARTY).width := 30;
	theTable.accessColumn(COLUMN_ENDY).width := 30;
	self.setLastColumnMaxWidth(theTable);

end;</source>
    </JadeMethod>
