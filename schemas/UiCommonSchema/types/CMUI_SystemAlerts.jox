        <updating/>
        <source>lstAlertTypes_displayRow(_table: CMUI_ListTable input; _sheet: Integer; _obj: CM_SystemAlertType; _row: Integer; _continue: Boolean io):String updating;
// ---------------------------------------------------------------------------
// Created:     08 December 2010 by cnwcs5 ccms MES 1112/par 24464
// Purpose:     
// Parameters:  None
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str : String;
begin
	str := _obj.name;
	
	if _table.allSelectedObjects.includes (_obj) then
		return TableCheckBox_Selected &amp; Tab &amp; str;
	else
		return TableCheckBox_NotSelected &amp; Tab &amp; str;
	endif;
	
	return null;
epilog

end;</source>
