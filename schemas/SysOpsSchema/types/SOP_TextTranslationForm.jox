end;</source>
    </JadeMethod>
    <JadeMethod name="updateProgress" id="da2d39d7-3e0c-4026-ac5d-f145e4b374b2">
        <updating/>
        <source>updateProgress(_cmifMonitor : CMIF_Monitor input) updating;
//--------------------------------------------------------------
//Created: 21 Aug 2006 By: RBarr 
// Reimplemented so refresh happens properly
//--------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	-------------------------------------------------------
// 31/03/2016	cnwdap1		PAR #35843 Make monitor time-based rather than object-count based
// this is the callback method from CMIF_Monitor

vars
	lastUpdate : Decimal [20];												// PAR #35843

begin
	if (not frmModalDialog.visible) then
		return;
	endif;

	_cmifMonitor.monitorReturnValue := modalDialogReturnValue;	

	// only update display periodically
	if self.userScript &lt;&gt; null and self.userScript.isDecimal then								// PAR #35843
		lastUpdate := self.userScript.Decimal;													// PAR #35843
	endif;																						// PAR #35843
	//if _cmifMonitor.partsDone mod 50 &lt;&gt; 0 and 												// PAR #35843
	if app.relativeMachineTime - lastUpdate &lt; CMIF_Monitor.Monitor_TimeBetweenUpdates and 		// PAR #35843
	   _cmifMonitor.partsDone &lt;&gt; _cmifMonitor.partsInJob // we want to see the 100% value
	then
		return;
	endif;
	self.userScript := app.relativeMachineTime.String;											// PAR #35843

//	modalDialogUpdateInfo(_cmifMonitor.message);
//	lblModalInfo.caption 		:= _cmifMonitor.message;
	lblModalInfo.caption 		:= _cmifMonitor.partsDone.String &amp; ' of ' &amp; _cmifMonitor.partsInJob.String &amp; ', found ' &amp; self.myAgent.progressCount.String;
	pbProgressBar.partsInJob	:= _cmifMonitor.partsInJob;	
	pbProgressBar.partsDone		:= _cmifMonitor.partsDone;

	lblModalInfo.refreshNow();
	pbProgressBar.refreshNow();
	btnModalDefault.refreshNow();
	self.doWindowEvents( null );	// cnwrl1 03/11/2009 PAR 21295	// make sure cancel press gets processed.
	
end;</source>
        <Parameter name="_cmifMonitor" type="CMIF_Monitor" usage="input"/>
    </JadeMethod>
    <JadeMethod name="updateTranslation" id="090a1c3d-daba-4283-ab16-db3a9efce2c9">
        <source>updateTranslation(localeName : String; constantCategoryName : String; number : String; property : String; value : String) protected;

vars
	category : XLAT_Category;
	translatableText : XLAT_TranslatableText;
	locale : CM_Locale;
	translation : XLAT_Translation;
	isShortText : Boolean;

begin
	locale := self.myRoot.getLocale(localeName, false);
	category := self.myRoot.allXLAT_Categories[constantCategoryName];
	translatableText := category.allTranslatableText[number.Integer];
	translation := translatableText.getTranslation(locale);

	// The updateLocaleTranslation expects to set both the 'text' and 'shortText' properties.
	// However when doImport calls this method, only one property is being set.
	// Consequently care must be taken not to overwrite an existing value for the other property.
	isShortText := (property = XLAT_Translation::shortText.name);
	
	if translation = null then
		if isShortText then
			translatableText.updateLocaleTranslation(self.myRoot, locale, null, value, null, false);
		else
			translatableText.updateLocaleTranslation(self.myRoot, locale, value, null, null, false);
		endif;
	else
		if isShortText then
			translatableText.updateLocaleTranslation(self.myRoot, locale, translation.text, value, null, false);
		else
			translatableText.updateLocaleTranslation(self.myRoot, locale, value, translation.shortText, null, false);
		endif;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="localeName" type="String"/>
        <Parameter name="constantCategoryName" type="String"/>
        <Parameter name="number" type="String"/>
        <Parameter name="property" type="String"/>
        <Parameter name="value" type="String"/>
    </JadeMethod>
