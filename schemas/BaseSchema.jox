    <DateFormat name="CNEC_ANSI_DATE_FORMAT" id="e6f99bfc-0c76-421f-889e-856b6c3fcb07">
        <dayHasLeadingZeros/>
        <monthHasLeadingZeros/>
        <separator>-</separator>
        <shortFormatOrder>2</shortFormatOrder>
        <showFullCentury/>
    </DateFormat>
    <TimeFormat name="CNEC_ANSI_TIME_FORMAT" id="a43daf6b-3a5e-43cf-a060-89535ab72c7f">
        <ampmIsSuffix/>
        <pmText>PM</pmText>
        <separator>:</separator>
        <showLeadingZeros/>
        <showSeconds/>
    </TimeFormat>
    <DateFormat name="CNEC_DATE_LONG_FULL" id="0f071aa3-613b-48bd-8462-60f71cc22fb1">
        <dayHasLeadingZeros/>
        <firstDayOfWeek>1</firstDayOfWeek>
        <firstWeekOfYear>1</firstWeekOfYear>
        <longFormatOrder>1</longFormatOrder>
        <shortDayNames>
            <value>, </value>
            <value> </value>
            <value> </value>
        </shortDayNames>
        <showFullCentury/>
    </DateFormat>
