    <JadeMethod name="createSystemAlert" id="65182933-684e-4e84-8777-4d40106464b5">
        <source>createSystemAlert(_oldStatus : Integer);
//--------------------------------------------------------------
//Created: 27 May 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	alert : CM_SystemAlert;
begin
	
	if _oldStatus = self.status then
		return;
	endif;
	
	create alert transient;
	alert.details := app.getErrorString3(StatusConverted, self.jobId, app.jobStatusEnumToString(_oldStatus), self.statusString);
	alert.setSeverity(SEVERE_INFO);
	alert.add();
	
end;</source>
        <Parameter name="_oldStatus" type="Integer"/>
