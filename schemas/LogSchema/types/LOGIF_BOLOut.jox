<Class name="LOGIF_BOLOut" id="af06073b-bbee-4733-b3fd-e1761a3dbe60">
    <superclass name="CMIF_BOLOut"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="bol"/>
    <JadeMethod name="setDataFromTable" id="d55e05be-13af-44f9-b03c-fb754a2dcee4">
        <updating/>
        <source>setDataFromTable(pTblMain: CM_EntryTable input; pTblExtra: CM_EntryTable input; pIntFaceCommon: CMIF_InOutCommon; pAssistant: LOG_Assistant) updating;
//--------------------------------------------------------------
//Created: 14 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	placeStr	: String;
	imexStatus	: Integer;
	commodity	: String;
	
begin
	self.myTerminal	:=	pAssistant.myTerminal;

	self.setUserDetails(app.getMyUser());
	pTblMain.setObjectFromTable(self, null, false);
	self.bolType		:=	BOLType_Log;
	self.operatorCode	:=	self.supplier;
	self.bolNumber		:=	pTblMain.getValueByName(ETRow_DocketNumber).String;
	placeStr			:=	pTblMain.getValueByName(ETRow_Place).String;
	self.place			:=	app.vesselPlaceStrToEnum(placeStr);
	
// cnwdad1 09/10/2009 - PAR #21118.
	if app.isSubTerminalsOn(self.myTerminal) then
		if self.myIMEXStatus = null then
			imexStatus	:=	TI_IMEX_STATUS_NULL;
		else
			imexStatus	:=	self.myIMEXStatus.code;
		endif;
		
		if self.myCommodity &lt;&gt; null then
			commodity	:=	self.myCommodity.code;
		endif;
		
		self.mySubTerminal	:=	self.myTerminal.getDefaultSubTerminal(	CM_SubTerminal.Type_BOL,
																		0,	// cnwdad1 27/01/2010 - PAR #22205.
																		imexStatus,
																		commodity,
																		false);
	endif;
end;</source>
        <Parameter name="pTblMain" type="CM_EntryTable" usage="input"/>
        <Parameter name="pTblExtra" type="CM_EntryTable" usage="input"/>
        <Parameter name="pIntFaceCommon" type="CMIF_InOutCommon"/>
        <Parameter name="pAssistant" type="LOG_Assistant"/>
    </JadeMethod>
</Class>
