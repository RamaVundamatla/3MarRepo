    <JadeMethod name="btnCancelR_click" id="86de504a-fbb7-4ea4-a2d9-70691fc5d72b">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnCancelR_click(btn: Button input) updating;

begin
	app.mousePointer	:=	Busy;
	self.doCancelReportQueueEntry(tblQueueR);
	self.doCheckErrorStatus(btnStatusR, tblQueueR);
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
