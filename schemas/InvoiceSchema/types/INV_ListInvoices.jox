Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	voyage	: CM_Voyage;
begin
	voyage := self.cmbCargoVoyage_.listObject.CM_Voyage;
	self.doCmbBOLBuild(voyage);
end;</source>
