    <JadeMethod name="add" id="3f87183f-e58d-473b-9a6d-6f80897fdb51">
        <updating/>
        <source>add(lStr : String) updating;
// ---------------------------------------------------------------------------
// Created:		February  2002 By Andrew Bishop cnwab1
//
// Purpose:		Adds a new string to the array
//
// Parameters:	String to be added
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 22 Aug 03	DWQ			Altered to add the null to the string, speeds up add.
// 03 Jul 2015	cnwkpd1		PAR #36286 - Changes for Unicode JADE
// ---------------------------------------------------------------------------
vars
	tStr : String;

begin
	tStr := lStr &amp; 0.Character;			// Add null terminator;

	self.bstrings[self.bstrings.length + 1 : tStr.lengthInBytes()] := tStr.Binary;

	self.numStrings := self.numStrings + 1;	
	
end;</source>
        <Parameter name="lStr" type="String"/>
    </JadeMethod>
    <JadeMethod name="addStrings" id="ddd0f885-ec04-4090-a6b3-32070b00da67">
        <updating/>
        <source>addStrings(_array : HugeStringArray) updating;
// ---------------------------------------------------------------------------
// Created:     18 November 2003 by cnwrs2
//
// Purpose:     Add all the strings in the incoming array to the array in the receiver
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
03 Jul 2015	cnwkpd1	PAR #36286 - Changes for Unicode JADE
	
*/

vars
	tmpStr,
	outStr	: String;
	tmpNum	: Integer;
	
begin
	if _array = null then
		return;
	endif;

	foreach tmpStr in _array do
		outStr := outStr &amp; tmpStr &amp; 0.Character;	// add null terminator
		tmpNum := tmpNum + 1;
	endforeach;

	self.bstrings[self.bstrings.length + 1 : outStr.lengthInBytes] := outStr.Binary;

	self.numStrings := self.numStrings + tmpNum;	

end;</source>
        <Parameter name="_array" type="HugeStringArray"/>
    </JadeMethod>
    <JadeMethod name="at" id="d65dbd6d-2bc5-4123-a3d3-7f66fffce795">
        <source>at(pos : Integer) : String;
/*
THIS IS VERY SLOW WHEN GETTING A LOT OF STRINGS, use getStrings() if you want them all in one hit.
 ------------------------------------------------------------------------
Created:			28 February 2002 by cnwdwq1
Purpose:			Returns the string at index pos in this null terminated binary (variable length strings)
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	pointer, counter : Integer;
	tStr : String;
	lenStr : Integer;
	lStrs : Binary;
begin
	
	if pos = 0 or pos &gt; self.numStrings then
		app.raiseCMException(ERR_INVALID_INDEX, null, null);
		return null;
	endif;
	lStrs := self.bstrings;
	lenStr := lStrs.length;
	pointer := 1;
	counter := 1;
	while pointer &lt;= lenStr do
		tStr := lStrs.unpackCStringJMT(pointer);
		if counter = pos then
			return tStr;
		endif;
		counter := counter + 1;
	endwhile;
	return null;
end;</source>
        <Parameter name="pos" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="clear" id="f0c686de-d9da-4188-9d7e-9a66141fea12">
        <updating/>
        <source>clear() updating;
// ---------------------------------------------------------------------------
// Created:			16 May 2001 by cnwdwq1
// Purpose:			!     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------			----------			--------------------------------------------------
//
// ---------------------------------------------------------------------------

begin
	self.bstrings := null;
	self.numStrings := 0;
end;</source>
    </JadeMethod>
    <JadeMethod name="clone" id="d7af45ef-4c65-4a2a-a6b3-3ea714597d5e">
        <source>clone(newObjToCloneTo	:	CM_Strings input);

begin
	newObjToCloneTo.bstrings := self.bstrings;
	newObjToCloneTo.numStrings := self.numStrings;
end;</source>
        <Parameter name="newObjToCloneTo" type="CM_Strings" usage="input"/>
    </JadeMethod>
    <JadeMethod name="compareIDStrings" id="9bcb6c51-97d7-4b66-a7bb-07b93cbacae2">
        <source>compareIDStrings(tiKey : String) : Boolean;
/*
 ------------------------------------------------------------------------
Created:			30 August 2002 by cnwdwq1
Purpose:			VERY specific method for comparing container ids (or parts thereof)
					stored in one of these objects with an id passed in.
					Pass an ID in, this method checks the "ids" against the key.
					These ids represent special instructions, ie, ! (not) OCLU24, !OCLU25, OCLU26
					must NOT be oclu24 &amp; 25, but must BE oclu26.
Parameters:			Key to match against
Returns:			True if there's a match
Changed On			Changed By		Reason
--------------		--------------	-----------------------------------------
08 Jul 2015			cnwkpd1			Performance changes
---------------------------------------------------------------------------
*/
vars
	numStrs	:	Integer;
	searchKey : String;
	isNottedKey	:	Boolean;
	keyLen	:	Integer;
	requiredNotFound : Boolean;
	strings : HugeStringArray;
begin
	if tiKey = null then
		return false;
	endif;
	numStrs := self.numStrings;
	if numStrs = 0 then
		//No strings to test, quit...
		return true;
	endif;

	create strings transient;
	self.getStrings(strings);
	foreach searchKey in strings do
		isNottedKey := false;
		if searchKey.trimRight &lt;&gt; null and searchKey.length &gt;= 2 then
			if searchKey[1 : 1] = "!" then
				//--------------
				//NOT key Chop off the "!" ("not" symbol)
				//--------------
				searchKey := searchKey[2 : end];
				isNottedKey := true;
			endif;
			keyLen := searchKey.length;
			if isNottedKey then
				//This is a MUST NOT = key, return straight away!
				if tiKey[1 : keyLen] = searchKey then
					return false;
				endif;
			else
				//This is a MUST = key
				if tiKey[1 : keyLen] = searchKey then
					return true;
				endif;
				//Set a flag to say we didnt find a required key!
				requiredNotFound := true;
				//just continue if its != the key...
			endif;
		endif;
	endforeach;
	if requiredNotFound then 
		return false;
	endif;
	return true;

epilog
	delete strings;
end;</source>
        <Parameter name="tiKey" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="fieldCorrection" id="7b659a0e-b1f2-438a-80d1-8cc0083035fe">
        <updating/>
        <source>fieldCorrection( _fieldName, _valueFrom, _valueTo : String ) : Boolean updating;
// --------------------------------------------------------------------------------------------------------
// Created:     13 Feb 2008 by cnwvu1
//
// Purpose:     Finds the string with the field and changes values.
// 				If _valueFrom &lt;&gt; null then changes old value in the string
// 				If _valueTo &lt;&gt; null then changes new value in the string
// --------------------------------------------------------------------------------------------------------

vars
	array		: HugeStringArray;
	str,
	s			: String;
	i			: Integer;
	posDelimiter: Integer;
begin

	if _fieldName = null then
		app.raiseUnexpectedProgramError( class.name, method.name, 'The field is null' );
		return false;
	endif;
	
	if _valueFrom = null and _valueTo = null then
		app.raiseUnexpectedProgramError( class.name, method.name, 'The values for the field are null' );
		return false;
	endif;

	create array transient;
	
	self.getStrings( array );
	
	i := 0;
	foreach str in array do
	
		i := i + 1;
		
		if str[ 1 : _fieldName.length ] = _fieldName then
			
			s := str;
			posDelimiter := s.pos( "=&gt;", _fieldName.length+1 );
			if _valueFrom &lt;&gt; null then
				s			:= str[ 1 : _fieldName.length+1 ] &amp; _valueFrom &amp; str[ posDelimiter-1 : str.length() - posDelimiter+2 ];
				array[i]	:= s;
			endif;
			if _valueTo &lt;&gt; null then
				posDelimiter	:= s.pos( "=&gt;", _fieldName.length+1 );
				array[i]		:= s[ 1 : posDelimiter+2 ] &amp; _valueTo;
			endif;
			
			self.clear;
			self.addStrings( array );
			
			return true;
			
		endif;
	
	endforeach;
	
	return false;
	
epilog
	delete array;

end;
</source>
        <Parameter name="_fieldName" type="String"/>
        <Parameter name="_valueFrom" type="String"/>
        <Parameter name="_valueTo" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getAsEditPair" id="ec650cb2-0a8e-4f99-a995-af0ec8dfc423">
        <source>getAsEditPair() : String;
/*
	Returns the strings formatted as a Key : Value combo with CRLF's between them
*/
vars
	array : HugeStringArray;
	i : Integer;
	str : String;
	num : Integer;
begin
	create array transient;
	self.getStrings(array);
	num := array.size;
	i := 1;
	//while i &lt; num do		JC 9/9/2003	was returning nothing if array size was 1
	while i &lt; num+1 do
		str := str &amp; array[i] ;//&amp; ": ";  //-cnwas3 par 25243
		if i +1 &lt;= array.size then
			str := str &amp; ": " &amp; array[i + 1] &amp; CrLf; //+cnwas3 par 25243
		endif;
		i := i + 2;
	endwhile;
	return str;
epilog
	delete array;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getString01" id="ffbee6ae-6daf-46d6-a0d4-5f8a7fe0b5f7">
        <source>getString01() : String;
/*
Purpose - 	
Who - NAVAB1
Date - 08MAY2024
ADO -  CR 64033 TASK 64035
*/


vars
	pointer : Integer;
	tStr : String;
	lenStr : Integer;
	lStrs : Binary;
	strs : HugeStringArray;
begin
	create strs transient;
	if self.numStrings = 0 then
		return "";
	endif;
	lStrs := self.bstrings;
	lenStr := lStrs.length;

	pointer := 1;
	while pointer &lt;= lenStr do
		tStr := lStrs.unpackCStringJMT(pointer);
		strs.add(tStr[1:2047].trimBlanks);		//protect against String Too Long 
	endwhile;
	
	if strs.size &gt; 0 then
	return strs[1];
	endif;
	
	return "";
epilog
	delete strs;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStrings" id="ab78759b-d2d2-4d6c-9506-1ddb78da63e2">
        <source>getStrings(_strs : HugeStringArray input);
/*
 ------------------------------------------------------------------------
Created:			28 August 2003 by cnwdwq1
Purpose:			Returns ALL strings in one hit
Parameters:			Array to be populated with all the strings
Returns:			Nothing

Date		Who		Reason
03 Jul 2015	cnwkpd1	PAR #36286 - Changes for Unicode JADE
	
*/

vars
	pointer : Integer;
	tStr : String;
	lenStr : Integer;
	lStrs : Binary;

begin
	if _strs = null then
		app.raiseCMException2(MethodWithNullParam, method.name, "No array Reference", null, null);
		return;		
	endif;
	_strs.clear;
	if self.numStrings = 0 then
		return;
	endif;
	lStrs := self.bstrings;
	lenStr := lStrs.length;

	pointer := 1;
	while pointer &lt;= lenStr do
		tStr := lStrs.unpackCStringJMT(pointer);
		_strs.add(tStr[1:2047].trimBlanks);		//protect against String Too Long 
	endwhile;
	
end;</source>
        <Parameter name="_strs" type="HugeStringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="includes" id="d11c1f8a-ce72-481b-930a-165a4d6006e2">
        <source>includes(str : String) : Integer;
/*
 ------------------------------------------------------------------------
Created:			28 February 2002 by cnwdwq1
Purpose:			Given a string, returns the index (at) position if in binary, else returns null
Parameters:			None
Returns:			Nothing
Changed On			Changed By			Reason
--------------		--------------		-----------------------------------------
29/04/2013			cnwcs5				par 30652 - remove resynch/resynchObject method calls
03 Jul 2015			cnwkpd1				PAR #36286 - Changes for Unicode JADE
---------------------------------------------------------------------------
*/
vars
	pointer, counter, sizeStr : Integer;
	tStr : String;
	tStr2 : String;
begin
	sizeStr := bstrings.length;
	if sizeStr = 0 then
		return null;
	endif;

	tStr2 := str.trimBlanks;
	if tStr2 = null then
		return null;
	endif;
	tStr2 := tStr2.toLower;
		
	pointer := 1;
	counter := 1;
	
	while pointer &lt;= sizeStr do
		tStr := self.bstrings.unpackCStringJMT(pointer);
		if (tStr.toLower = tStr2) then
			return counter;
		endif;	
		counter := counter + 1;
	endwhile;

	return null;
end;</source>
        <Parameter name="str" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="last" id="b8788d37-c204-480f-8e47-315cf916a923">
        <source>last() : String;
/*
 ------------------------------------------------------------------------
Created:			16 October 2001 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
---------------------------------------------------------------------------
*/
vars

begin
	if self.numStrings = 0 then
		return null;
	endif;
	
	return self.at(self.numStrings);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="size" id="e97d859d-ffe5-4dce-b7b1-887a3add7118">
        <source>size() : Integer;
// ---------------------------------------------------------------------------
// Created:			16 May 2001 by cnwdwq1
// Purpose:			!     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------			----------			--------------------------------------------------
// 29/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------
begin
	return self.numStrings;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
