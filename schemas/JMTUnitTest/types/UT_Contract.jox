    <JadeMethod name="createContractDetail1000d" id="2c7ea7cc-22ec-47d2-a09f-956337c85728">
        <updating/>
        <source>createContractDetail1000d(realCon : CM_InvoiceContract; operator : CM_Operator; cargoType : CM_CargoType; _fromTS1, _toTS1, _fromTS2, _toTS2, _fromTS3, _toTS3 : String) updating;
/*
Purpose:			

Date		Who		Reason
30 December 2022	navab1	TFS CR 55645 TASK 55662
*/

vars
	fromTS, toTS : TimeStamp;
	realConDtl : CM_InvoiceContractDetails;
	realRate : CM_InvoiceContractRate;
	realRateEntry01 : CM_InvoiceContractRateEntry;
	invLineType100 : CM_InvoiceLineDesc;
	service100, service200 : CM_Service;

begin
		
		// ### FIRST DETAIL
		fromTS.setFromYYYYMMDDHHmm(_fromTS1);
		toTS.setFromYYYYMMDDHHmm(_toTS1);
		realConDtl := self.createContractDetail1000(realCon, operator,cargoType, fromTS,toTS);
		
		beginTransaction;
		realConDtl.setPropertyValue("myShippingTerm",realCon.myBusinessUnit.allShippingTermsByCode.first);
		realConDtl.setPropertyValue("myUnitOfMeasure",app.myRoot.allInvoiceUnitOfMeasure.first);
		commitTransaction;
		
		invLineType100 := realConDtl.myInvoiceLineType;
		service100 := invLineType100.services.first;
		service200 := invLineType100.services.last;
		
		realRate := self.createContractRate(realConDtl,service100);
		
		// ### FIRST RATE ENTRY
		fromTS.setFromYYYYMMDDHHmm(_fromTS2);
		toTS.setFromYYYYMMDDHHmm(_toTS2);
		realRateEntry01 := self.createContractRateEntry1000(realRate,1000,0,100,fromTS,toTS);
		
		// ### SECOND RATE ENTRY
		fromTS.setFromYYYYMMDDHHmm(_fromTS3);
		toTS.setFromYYYYMMDDHHmm(_toTS3);
		realRateEntry01 := self.createContractRateEntry1000(realRate,1000,101,9999,fromTS,toTS);

epilog

end;</source>
