    <JadeMethod name="validateForUpdate" id="43e507e2-10ec-4102-8f8c-d0b5de58cd96">
        <source>validateForUpdate();
/*
Purpose:			

Date		Who		Reason
07 December 2022	navab1	TFS CR 55623 TASK 55673
15 April 2023  navmv20 TFS 55304 Task 55545: UI - Invoice Line List Changes
*/

vars

begin
	//inheritMethod(); //02/05/2023 navmv20 Bug 57068
	
	//02/05/2023 navmv20 Bug 57068- START
	if self.allCriteria.isEmpty then
		app.raiseCMWarning(Crite_been_enter_contr_detai_t, null, null, null);
	endif;
	//02/05/2023 navmv20 Bug 57068- END
	
	//if self.name = null then //02/05/2023 navmv20 Bug 57068
	if not self.allCriteria.isEmpty and self.name = null then //02/05/2023 navmv20 Bug 57068
		app.raiseCMException(Contra_criter_must_have_name, null, null);
	endif;

	//if self.description = null then //02/05/2023 navmv20 Bug 57068
	if not self.allCriteria.isEmpty and self.description = null then //02/05/2023 navmv20 Bug 57068
		app.raiseCMException(Contra_criter_must_have_descri, null, null);
	endif;

	if self.myInvoiceContractDetail = null then
		app.raiseCMException(Contract_criteria_orphan, null, null);
	endif;

epilog

end;</source>
    </JadeMethod>
