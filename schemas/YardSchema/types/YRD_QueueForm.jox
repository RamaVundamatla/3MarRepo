    <JadeMethod name="tblQEntriesDeselectRow" id="5e3d3997-4294-43d1-86e1-f67ff3706fdd">
        <interfaceImplements>
            <JadeInterfaceMethod name="IF_CM_DataTable::deselectRow"/>
        </interfaceImplements>
        <source>tblQEntriesDeselectRow(_tbl : CM_DataTable; _idx : Integer);

	/*
		this method stub has been automatically generated by Jade to satisfy interface implementation requirements
	*/
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 March 2010	cnwer1	Initial creation

*/

vars
	colPosQueueID :Integer;
	colPosContainer,
	tblBackColour,
	tblForeColour : Integer;
begin

	if _tbl  &lt;&gt; self.tblQEntries then
		return;
	endif;

	colPosQueueID:=self.tblQEntries.getColumnByRowName(ETRow_QueueId);
	colPosContainer:=self.tblQEntries.getColumnByRowName(ETRow_ItemId);
	
	tblBackColour := self.tblQEntries.accessCell(_idx,4).backColor;
	tblForeColour := tblBackColour.getInverseColour;
	if colPosQueueID &gt; 0 then
		self.tblQEntries.accessCell(_idx,colPosQueueID).backColor := tblBackColour;
		self.tblQEntries.accessedCell.foreColor := tblForeColour;
	endif;
	if colPosContainer &gt; 0 then
		self.tblQEntries.accessCell(_idx,colPosContainer).backColor := tblBackColour;
		self.tblQEntries.accessedCell.foreColor := tblForeColour;
	endif;


epilog

end;</source>
