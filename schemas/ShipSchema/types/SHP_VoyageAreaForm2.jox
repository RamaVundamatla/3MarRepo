        <source>confirmPrinting(_booleanArray : BooleanArray input) protected;
// ---------------------------------------------------------------------------
// Created:     12 May 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars
	msg			: String;
	frm			: SHP_PrintConfirm;
begin
	if _booleanArray = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null boolean array passed in');
		return;
	endif;

	if self.allSelectedHolds.size &gt;= self.myCurrentVoyage.myCellularVoyageStructure.allHolds.size then
		msg :=  "All Holds";
	else
		msg :=  self.allSelectedHolds.getDescription(true);
	endif;
	msg := "Are you sure that you want to print " &amp; msg &amp; "?" &amp; Cr &amp; "At Scale Factor " &amp; self.myCurrentDrawingController.scaleFactor.String &amp; " That Is An Estimated " 
			&amp; self.doEstimatePages.String &amp; " Pages." ;
	
	create frm transient;
	frm.lblMessage.caption := msg;
	frm.chkOption.caption := 'Print profile summary';
	// cnwsb1 14 May 2003 - CM_BaseForm::showModal() now sets isModal:
	// frm.isModal := true;
	frm.width := 300;
	frm.lblMessage.width := frm.width;
	frm.height := 180;
	frm.showModal;

	if frm.modalResult &lt;&gt; IDOK then
		_booleanArray[1] := false;
		return;
	else
		_booleanArray[1] := true;
		_booleanArray[2] := frm.chkOption.value;
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_booleanArray" type="BooleanArray" usage="input"/>
    </JadeMethod>
