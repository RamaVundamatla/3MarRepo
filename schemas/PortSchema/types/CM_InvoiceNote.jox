    <JadeMethod name="setProxyForCreate" id="2f8a28f0-2e41-4847-a6c0-5af407764925">
        <updating/>
        <source>setProxyForCreate(_note : String; _internalOnly : Boolean; _theInvoice : CM_Invoice) updating;
/*

Purpose:			Sets up Proxy instance so real object can be created from it

Parameters:			_note			String		The note for the invoice note
					_internalOnly	Boolean		Whether the Note is for terminal/internal use only (Stops it appearing on some reports etc)
					_theInvoice		CM_Invoice	The invoice this invoice note belongs to

Return Value:		NONE

Date		Who		Reason
03 February 2022	navpw1	Initial creation TFS: 52752

*/

begin
	self.raiseExceptionIfNotTransient(method);
	
	self.note 			:= _note;
	self.internalOnly 	:= _internalOnly;
	self.myInvoice 		:= _theInvoice;

end;</source>
        <Parameter name="_note" type="String"/>
        <Parameter name="_internalOnly" type="Boolean"/>
        <Parameter name="_theInvoice" type="CM_Invoice"/>
    </JadeMethod>
    <JadeMethod name="setProxyForUpdate" id="6defac53-ce3e-440c-a197-03bc1f429612">
        <updating/>
        <source>setProxyForUpdate(_note : String; _internalOnly : Boolean) updating;
/*

Purpose:			Sets up Proxy instance so real object can be updated from it

Parameters:			_note			String		The note for the invoice note
					_internalOnly	Boolean		Whether the Note is for terminal/internal use only (Stops it appearing on some reports etc)
					_theInvoice		CM_Invoice	The invoice this invoice note belongs to

Return Value:		NONE

Date		Who		Reason
03 February 2022	navpw1	Initial creation TFS: 52752

*/

begin
	self.raiseExceptionIfNotTransient(method);
	
	self.note 			:= _note;
	self.internalOnly	:= _internalOnly;

end;</source>
        <Parameter name="_note" type="String"/>
        <Parameter name="_internalOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="shouldAuditProperty" id="3206d5f2-ac38-4c18-a9ab-be73a0ff93a3">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			Whether or not we should audit a particular property

Parameters:			_rootClass	Class		Class the proeprty belongs to
					_property	Property	Property we are trying to audit

Return Value:		Boolean	Returns whether or not we should audit the property

Date		Who		Reason
03 February 2022	navpw1	Initial creation TFS: 52752

*/

vars
	propName	: String;
	
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	//CM_InvoiceNote::callingFormContext.name //Property does not exist on class but comes up in audit changes??
	if propName  = "callingFormContext" or
		propName = "myChildQuantityMap" then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;
	
end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
