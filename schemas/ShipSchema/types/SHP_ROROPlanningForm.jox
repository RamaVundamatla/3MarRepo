    <JadeMethod name="doBtnAutoDischCCClick" id="236a8c62-f3d5-4b34-aad3-81d787bb2e27">
        <updating/>
        <source>doBtnAutoDischCCClick() updating;
/*
Purpose:			
Date				Who			Reason
JULY 2011		CNWAB1		Initial creation
*/

vars
	theReturn : Integer;
begin
	app.mousePointer := Window.MousePointer_HourGlass;

	while true do
		app.myTrxUA.trxSetDfltDischargeColourCode(self.myCurrentVoyage.myCellularVoyageStructure, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Auto) &amp; " " &amp; app.getErrorString(SHP_Discharge_Colour_Coding), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;


						
epilog
	app.mousePointer := Window.MousePointer_Default;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnCCModeDischClick" id="912a388f-083a-48ef-96c9-e8ffcdd63220">
        <updating/>
        <source>doBtnCCModeDischClick() updating;
/*
Purpose:			
Date		Who		Reason
24 June 2011	cnwab1	Initial creation
*/

vars
	realROROController : CM_VoyageROROController;
	itemLayout : CM_DeckItemLayout;
	theReturn : Integer;
	tmpLCs, theLCs : CM_LCSet;
	anLC : CM_LocationsController;
	obj : Object;
begin
	create theLCs transient;
	create tmpLCs transient;



	foreach obj in self.myROROPlanDrawController.allSelectedObjects  discreteLock do
		if not obj.isKindOf(CM_DeckItem) then
			continue; // already colour coded
		endif;
		itemLayout := obj.CM_DeckItem.myLayout;
		itemLayout.getLCs(tmpLCs, true);
		
		foreach anLC in tmpLCs discreteLock do
			realROROController := anLC.CM_VoyageROROController;
			if not realROROController.allTrackedItems.isEmpty() 
			and realROROController.myRORORequestDischarge = null then
				theLCs.add(anLC);
			endif;
		endforeach;
	endforeach;





	while true do
		app.myTrxCA.trxCreateRORODischargeCCs(theLCs, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Roro) &amp; " " &amp; app.getErrorString(Colour_coding), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;



epilog
	delete theLCs;
	delete tmpLCs;


end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnCCModeErase" id="a9b66453-fbed-48fb-a31a-b51516f0bec2">
        <updating/>
        <source>doBtnCCModeErase() updating;
/*
Purpose:			
Date		Who		Reason
28 June 2011	cnwab1	Initial creation
*/

vars
	theLCs : CM_LCSet;
	itemLayout : CM_DeckItemLayout;
	obj : Object;
	isLoad : Boolean;
	theReturn : Integer;
	deckItem : CM_DeckItem;
	locnDefn : CM_ROROLocnDefn;
	locnDefns : CM_ROROLocnDefnByCodeDict;
begin
	create theLCs transient;
	create locnDefns transient;
	
	isLoad := (self.modeView=ShpDisplayMode_ColCodeLoad);
	
	
	// PAR 29051 - performance. changed this because  a 6 high stack of colour coding will get the same LocnDefn 6 times and ask for all the same LCs each time
	foreach obj in self.myROROPlanDrawController.allSelectedObjects discreteLock do
		deckItem := null;
		
		if obj.isKindOf(CM_RORORequest) then
			theLCs.addNoDuplicates(obj.CM_RORORequest.myROROController, false); // Add the LC direct from the Request. PAR 31937 changed to addNoDuplicates
		elseif obj.isKindOf(CM_ROROLocnDefnVoyage) then // Container LOCN if mixed with Requests this will be the backend of the 40 request.
			locnDefn := obj.CM_ROROLocnDefnVoyage;
			locnDefn.getLCs(theLCs, false);
		endif;
	endforeach;
	
	// PAR 29050
	if theLCs.isEmpty() then
		if self.mySideViewForm &lt;&gt; null and self.mySideViewForm.myROROLocnDrawingController &lt;&gt; null then
			foreach obj in self.mySideViewForm.myROROLocnDrawingController.allSelectedObjects discreteLock do
				deckItem := null;
				
				if obj.isKindOf(CM_ROROSlotController) then
					theLCs.addNoDuplicates(obj.CM_ROROSlotController, false); // Add the LC direct from the Request. PAR 31937 changed to addNoDuplicates
				endif;
			endforeach;
		endif;
	endif;
	
/*	PAR 29051
	foreach obj in self.myROROPlanDrawController.allSelectedObjects discreteLock do
		if not  obj.isKindOf(CM_RORORequest) then
			continue;
		endif;
			
		deckItem := obj.CM_RORORequest.myROROController.getDefn();
		
		if  obj.CM_RORORequest.myROROController.isROROVoyageLanePos() then
			theLCs.add(obj.CM_RORORequest.myROROController);
		elseif deckItem &lt;&gt; null  then
			deckItem.getLCs(theLCs, false);
		else
			theLCs.add(obj.CM_RORORequest.myROROController);
		endif;
	endforeach;
	*/
	
	if app.myMoveController &lt;&gt; null then
		app.myMoveController.myVoyageRequest := null;
	endif;
	while true do
		app.myTrxDA.trxDeleteRORORequests(theLCs, isLoad, app.myPassport);
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			global.beep;
			break;
		else
			theReturn := app.showErrorWarningDialog(app.getErrorString(Erase_requests), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and
			   theReturn = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return;
		endif;
		break;
	endwhile;

epilog
	delete theLCs;
	delete locnDefns;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnCargoEnquiryAll" id="70bc71a1-e1e9-4578-b6bd-be43c2824d54">
        <source>doBtnCargoEnquiryAll();
/*
Date		    Who			Reason
12 August 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars
	coll				: ObjectSet;
	cm_TrackedItem		: CM_TrackedItem;
	iter1				: Iterator;
	isVoyCC : Boolean;
begin
	app.mousePointer	:= Busy;
	create coll transient;
	
	// Get a collection of ALL the objects (containers) to pass to the Summary Definition form.
	if self.myCurrentVoyage &lt;&gt; null then
		if self.modeView = ShpDisplayMode_ColCodeLoad then
			// For the current voyage get the ONSITE tracked items.
			iter1	:= self.myCurrentVoyage.allNotifiedTIsByIdCargoType.createIterator;
			while iter1.next( cm_TrackedItem ) do 
				//if cm_TrackedItem.isExport then										// PAR #25021
				if cm_TrackedItem.isExport or cm_TrackedItem.isTranshipOutbound then	// PAR #25021
					coll.addNoDuplicates( cm_TrackedItem, false );
				endif;
			endwhile;
			
			delete iter1;
			iter1	:= self.myCurrentVoyage.allOnsiteTIsByIdCargoType.createIterator;
			while iter1.next( cm_TrackedItem ) do 
				//if cm_TrackedItem.isExport then										//PAR #25021
				if cm_TrackedItem.isExport or cm_TrackedItem.isTranshipOutbound then	//PAR #25021
					coll.addNoDuplicates( cm_TrackedItem, false );
				endif;
			endwhile; 
			isVoyCC := true;
		else
			// For the current voyage get the  ONSHIP tracked items.
			iter1	:= self.myCurrentVoyage.allOnshipTIsByIdCargoType.createIterator;
			while iter1.next( cm_TrackedItem ) do : cm_TrackedItem_loop
				coll.addNoDuplicates( cm_TrackedItem, false );
			endwhile cm_TrackedItem_loop;
			isVoyCC := false;
		endif;
	endif;
	
	
	self.myAssistant.showXTABSummaryDefinitionForm( coll, false, false, isVoyCC, true );
	
epilog
	delete coll;
	delete iter1;
	app.mousePointer	:= Idle;	
end;
</source>
    </JadeMethod>
    <JadeMethod name="doBtnCargoUnplanCLick" id="71e7b81e-848b-4597-ab6b-e93da2d175d9">
        <updating/>
        <source>doBtnCargoUnplanCLick() updating;
/*
Purpose:			
Date				Who			Reason
OCTOBER 2011		CNWAB1		Initial creation
*/

vars
	anObj : Object;
	tmpWLE : CM_WorkListEntry;
	aTI : CM_TrackedItem;
	str : String;
	idx : Integer;
	ls : Boolean;
	wles : CM_WLEArray;
	aReq : CM_RORORequest;
	tmpWles : CM_WLEArray;
	tmpSlots : CM_LCArray;
begin


	if self.myROROPlanDrawController.allSelectedObjects.isEmpty then
		return;
	endif;
	
	
	//16 Apr 2012	NDL	Par 29405
	create tmpWles transient;
	self.getWlesForSelectedArea( tmpWles );	
	
	create tmpSlots transient;
	self.getRequestsForSelectedAreaBR(tmpSlots);
	
	create wles transient;
	foreach tmpWLE in tmpWles do
		if tmpWLE.myFutureMove = null then
			continue;
		endif;
		aTI := tmpWLE.myTrackedItem;
		if aTI &lt;&gt; null then
			idx := idx + 1;
			if str = null then
				str := aTI.id;
			else
				if idx mod 3 = 0 then
					str := str &amp; ", " &amp; Cr &amp; aTI.id;
				else
					str := str &amp; ", " &amp; aTI.id;
				endif;
			endif;
			wles.add(tmpWLE);
		endif;
	endforeach;
			
	// PAR 18695
	if wles.isEmpty() and tmpSlots.isEmpty() then
		app.msgBox("Please select some cargo to unplan.","Problem",MsgBox_OK_Only);
		return;
	else
		if app.msgBox(app.getErrorString(Unplan_GC) &amp; str &amp; "?", app.getErrorString(SHP_Confirm_Unplan_Cargo),MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
			global.beep;
			return;
		endif;
	endif;
	
	app.cmsBeginLoad(ls);

	if not wles.isEmpty then
		self.doUnplanTIs(wles, PLANNING_MODE);	// Dec 2011 cnwjre1 28636 RORO unplanning of queued load moves
	endif;
	
	if not tmpSlots.isEmpty() then
		self.doUnplanBulkReleases(tmpSlots);
	endif;
	
epilog
	app.cmsEndLoad(ls);
	delete wles;
	delete tmpWles;
	delete tmpSlots;
end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnSummariseAll" id="1ee09a2b-efe2-458d-8f62-8509c0046a5a">
        <source>doBtnSummariseAll();

/*

Purpose:		
Parameters:		
Return Value:	

Date				Who		Reason
13 February 2009	cnwrl1	Initial creation (CCMS SFW 1047 - Totals Only Lists)
15 July 2010		cnwdap1	PAR #25021 review use of isImport/isExport for tranships
*/
	
vars
	coll				: ObjectSet;
	cm_TrackedItem		: CM_TrackedItem;
	iter1				: Iterator;
	isVoyCC : Boolean;
begin
	app.mousePointer	:= Busy;
	create coll transient;
	
	// Get a collection of ALL the objects (containers) to pass to the Summary Definition form.
	if self.myCurrentVoyage &lt;&gt; null then
		if self.modeView = ShpDisplayMode_ColCodeLoad then
			// For the current voyage get the ONSITE tracked items.
			iter1	:= self.myCurrentVoyage.allNotifiedTIsByIdCargoType.createIterator;
			while iter1.next( cm_TrackedItem ) do 
				//if cm_TrackedItem.isExport then										// PAR #25021
				if cm_TrackedItem.isExport or cm_TrackedItem.isTranshipOutbound then	// PAR #25021
					coll.addNoDuplicates( cm_TrackedItem, false );
				endif;
			endwhile;
			
			delete iter1;
			iter1	:= self.myCurrentVoyage.allOnsiteTIsByIdCargoType.createIterator;
			while iter1.next( cm_TrackedItem ) do 
				//if cm_TrackedItem.isExport then										//PAR #25021
				if cm_TrackedItem.isExport or cm_TrackedItem.isTranshipOutbound then	//PAR #25021
					coll.addNoDuplicates( cm_TrackedItem, false );
				endif;
			endwhile; 
			isVoyCC := true;
		else
			// For the current voyage get the  ONSHIP tracked items.
			iter1	:= self.myCurrentVoyage.allOnshipTIsByIdCargoType.createIterator;
			while iter1.next( cm_TrackedItem ) do : cm_TrackedItem_loop
				coll.addNoDuplicates( cm_TrackedItem, false );
			endwhile cm_TrackedItem_loop;
			isVoyCC := false;
		endif;
	endif;
	
	
	self.myAssistant.showXTABSummaryDefinitionForm( coll, false, false, isVoyCC, true );
	
epilog
	delete coll;
	delete iter1;
	app.mousePointer	:= Idle;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="doClearAllSelectedObjects" id="6a8b9777-70e5-49f0-8778-ee2bc02dc2f9">
        <source>doClearAllSelectedObjects();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 June 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	obj : Object;
	allSelectedObjects : ObjectSet;
	theFrame : CMUI_PointDrawingFrame;
	selectedIndex : Integer;
	invalidObj : Boolean;
begin
	create allSelectedObjects transient;
	self.myROROPlanDrawController.allSelectedObjects.copy(allSelectedObjects);
	self.myROROPlanDrawController.allSelectedAltObjects.copy(allSelectedObjects);
	self.myROROPlanDrawController.allSelectedObjects.clear;
	self.myROROPlanDrawController.allSelectedAltObjects.clear;
	
	foreach obj in allSelectedObjects where obj.isKindOf(CM_DeckItemLayout) do
		theFrame:=self.myROROPlanDrawController.getFrameForLayer(obj.CM_DeckItemLayout.myDeckLayer);// myROROPlanDrawController.getBackFrameOfType(ROROLayerType_CCLoad).CMUI_PointDrawingFrame;
		selectedIndex := theFrame.allPointGraphics.indexOf(obj.CM_DeckItemLayout);
		if selectedIndex &lt; 1 then
			continue;
		endif;
		if self.modeView = ShpDisplayMode_ColCodeLoad or self.modeView =ShpDisplayMode_ColCodeDisch then
			self.myROROPlanDrawController.drawLayoutItemColourCoding(theFrame,selectedIndex,self.modeView = ShpDisplayMode_ColCodeLoad );
		elseif self.modeView = ShpDisplayMode_Actual or self.modeView =  ShpDisplayMode_Defn then
			self.myROROPlanDrawController.drawLayoutItemActual(theFrame,selectedIndex );
		elseif  self.modeView = ShpDisplayMode_Proposed then
			self.myROROPlanDrawController.drawLayoutItemProposed(theFrame,selectedIndex);
		endif;
		
	endforeach;
	
	if  self.frmDeck.myDrawingFrame &lt;&gt; null then
		self.frmDeck.myDrawingFrame.CMUI_PointDrawingFrame.allPointGraphics.clear;
		self.frmDeck.myDrawingFrame.clearGraphics;
	endif;
	
	if self.modeWork = self.WorkMode_Job then
		if self.mySideViewForm &lt;&gt; null then
			self.mySideViewForm.doDeselectAll();
		endif;
	endif;
	
	// PAR 28336
	if self.modeWork = self.WorkMode_Plan then
		on Exception do app.handleDeletedObject(exception, app.myMoveController, invalidObj);
		if app.myMoveController &lt;&gt; null then
			app.myMoveController.myVoyageRequest := null;
		endif;
	endif;
	
epilog
	delete allSelectedObjects;
end;</source>
    </JadeMethod>
    <JadeMethod name="doClearRemarks" id="45a7e2ce-60ff-48d0-926c-03a70ffda555">
        <updating/>
        <source>doClearRemarks()updating, protected;
/*
Date		Who		Reason
25 July 2012	cnwcs5	Initial creation - par 29124
*/
vars

begin 
	self.allRemarksControls.purge;
	
	self.lastIndexForRemarks	:= 0;
	self.haveCreatedRemarks		:= false;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doClearSelectedObject" id="fa79e539-5f56-44a4-90fb-2e6e2c7ceab3">
        <updating/>
        <source>doClearSelectedObject(_deckItemLayout : CM_DeckItemLayout) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:	returns true if it cleared a selected object	


Date		Who		Reason
25 June 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	theFrame : CMUI_PointDrawingFrame;
	allSelectedObjects : ObjectSet;
	selectedIndex : Integer;
	obj : Object;
	altKey : Boolean;
	objectIRepresent : Object;
begin
	create allSelectedObjects transient;
	theFrame:=self.myROROPlanDrawController.getFrameForLayer(_deckItemLayout.myDeckLayer);// myROROPlanDrawController.getBackFrameOfType(ROROLayerType_CCLoad).CMUI_PointDrawingFrame;
	objectIRepresent := _deckItemLayout.getObjectIRepresent();	
	
	if  self.myROROPlanDrawController.allSelectedObjects.includes(_deckItemLayout) or
		self.myROROPlanDrawController.allSelectedAltObjects.includes(_deckItemLayout) then
	
		if self.modeWork = self.WorkMode_Job and objectIRepresent.isKindOf(CM_RORORequest) then
			if objectIRepresent.CM_RORORequest.myJob &lt;&gt; null then
				//should just update caption
				return true;
			endif;
		endif;
		self.myROROPlanDrawController.getSelectObjectsForMode(_deckItemLayout,allSelectedObjects);
		altKey:=self.myROROPlanDrawController.allSelectedAltObjects.includes(_deckItemLayout);
		foreach obj in allSelectedObjects do
			self.myROROPlanDrawController.deselectObject(obj,false,altKey);
		endforeach;
		
		if _deckItemLayout.isMoveable() then
			self.frmDeck.myDrawingFrame.CMUI_PointDrawingFrame.doRemoveGraphic(_deckItemLayout);
			self.frmDeck.myDrawingFrame.clearGraphics;		
		endif;
		if theFrame &lt;&gt; null then
			selectedIndex := theFrame.allPointGraphics.indexOf(_deckItemLayout);
			if selectedIndex &lt; 1 then
				return true;
			endif;
			if self.modeView = ShpDisplayMode_ColCodeLoad or self.modeView =ShpDisplayMode_ColCodeDisch then
				self.myROROPlanDrawController.drawLayoutItemColourCoding(theFrame,selectedIndex,self.modeView = ShpDisplayMode_ColCodeLoad );
			elseif self.modeView = ShpDisplayMode_Actual or self.modeView =  ShpDisplayMode_Defn then
				self.myROROPlanDrawController.drawLayoutItemActual(theFrame,selectedIndex );
			elseif  self.modeView = ShpDisplayMode_Proposed then
				self.myROROPlanDrawController.drawLayoutItemProposed(theFrame,selectedIndex);
			endif;
		endif;

		self.frmStatus.myFrameCaption.caption:=null;
		return true;
	else
		if self.modeWork = self.WorkMode_Job then
			if self.myCurrentJob &lt;&gt; null then
				self.myROROPlanDrawController.clearSelectedJob();
				self.setCurrentJob(null);
			else
				if objectIRepresent.isKindOf(CM_RORORequest) and objectIRepresent.CM_RORORequest.myJob &lt;&gt; null then
					self.doClearAllSelectedObjects();
				endif;
			endif;
		endif;
	endif;
		
	return false;
epilog
	delete allSelectedObjects;
end;</source>
        <Parameter name="_deckItemLayout" type="CM_DeckItemLayout"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doClearTopDrawingFrame" id="92729aae-069e-438f-b286-aa686f713b28">
        <updating/>
        <source>doClearTopDrawingFrame(_redrawLayers : Boolean) updating;
/*
Purpose:			
Date		Who		Reason
22 July 2011	cnwab1	Initial creation
*/

vars
	layers : CM_DeckLayerLayoutArray;
	layer : CM_DeckLayerLayout;
	obj : Object;
	invalidObj : Boolean;
begin	

	on Exception do app.handleDeletedObject(exception, obj, invalidObj);

	if _redrawLayers then
		create layers transient;
		foreach obj in self.myROROPlanDrawController.allSelectedObjects discreteLock do // PAR 28920 where obj.isKindOf(CM_DeckItem) do
			if obj.isKindOf(CM_DeckItem) then // PAR 28920
				layer := obj.CM_DeckItem.myLayout.myDeckLayer;
			elseif obj.isKindOf(CM_RORORequest) then // PAR 28920
				layer := obj.CM_RORORequest.myLayout.myDeckLayer; // PAR 28920
			endif;
			if invalidObj then
				invalidObj:=false;
				continue;
			endif;
			if layer &lt;&gt; null and layer.isPlanningRedrawable() and not layers.includes(layer) then
				layers.add(layer);
			endif;
		endforeach;
	endif;
	
	app.isDragging := false;
	self.origMouseX := 0;
	self.origXPos := 0;
	self.origMouseY := 0;
	self.origYPos := 0;
	self.frmDeck.myDrawingFrame.CMUI_PointDrawingFrame.doBtnClearClick(true);
	self.frmDeck.myDrawingFrame.CMUI_PointDrawingFrame.setPropertyValue("dragging",false);
	self.frmDeck.myDrawingFrame.dragMode := Frame.DragMode_None;
	
	self.backFrameIndex := 0;
	self.myROROPlanDrawController.clearAllSelectedObjects();
	self.myROROPlanDrawController.clearAllSelectedObjectsAlt();
	self.frmStatus.myFrameCaption.caption := null;
	
	if _redrawLayers then
		foreach layer in layers  discreteLock do
			self.doDrawLayerForLayer(layer);
		endforeach;
	endif;
epilog
	delete layers;
end;</source>
        <Parameter name="_redrawLayers" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCloneBackFrame" id="6e65682a-c441-476b-a5ff-f792313fe9f1">
        <updating/>
        <source>doCloneBackFrame(_layer : CM_DeckLayerLayout; _parent : Control; _scale : Decimal; _frames : ObjectArray input; _top : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     07 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
// 08 Oct 2015      cnwma1 			PAR #36557 1090 in ShipSchema::SHP_ROROPlanningForm::doCloneBackFrame
// ---------------------------------------------------------------------------

vars
	aLayer : CM_DeckLayerLayout;
	obj : Object;
	backFrame : CMUI_PointDrawingFrame;
	tmpRoot : CM_Root;
begin

		if _layer = null then    //08/10/2015 cnwma1 PAR #36557
			return;
		endif;
		
		aLayer := _layer;
		
		backFrame := self.frmBackground.cloneSelf(true);
		self.addControl(backFrame);		

		backFrame.bevelInnerWidth := 0;
		backFrame.bevelOuterWidth := 0;
		backFrame.boundaryWidth := 0;
		
		backFrame.name := "BACK" &amp; aLayer.code; // DO NOT TRANSLATE
		backFrame.caption := null;
		
		backFrame.parent := _parent; //self.shtDeck;
		backFrame.backColor := Red;
		backFrame.transparent := true;
		backFrame.visible := false;
		backFrame.autoRedraw := true;
		backFrame.parentAspect := self.frmDeck.parentAspect;
		backFrame.scaleFactor := _scale; //self.scaleFactor;
		// FOR POSITION SEE REPOSITION METHOD ON THIS FORM repositionAllBackFrames
		backFrame.CMUI_PointDrawingFrame.mode := CMUI_PointDrawingFrame.Mode_Work; //Mode_Work;
		backFrame.userObject := aLayer;
		backFrame.zOrder(0);
		
		// PAR 28481
		// PAR 29079 epr 24/2/11 messina had a case where the load CC layer was after the container layer
		// could not reproduce this in jmt added code below to make sure the load CC or discharge CC will 
		// be one of the first layers
		if _top or _layer.type = ROROLayerType_CCLoad or _layer.type = ROROLayerType_CCDischarge  then
			_frames.insert(1,backFrame);
		else
			_frames.add(backFrame); 
		endif;
//	backFrame.setUpIcons();

/* REMOVED. allDrawingAttributes was an un used StringArray
	tmpRoot := app.myRoot;
	if tmpRoot &lt;&gt; null then
		tmpRoot.allDrawingAttributes.copy(backFrame.allDrawingAttributes);
	endif;
*/

	
epilog

end;</source>
        <Parameter name="_layer" type="CM_DeckLayerLayout"/>
        <Parameter name="_parent" type="Control"/>
        <Parameter name="_scale" type="Decimal"/>
        <Parameter name="_frames" type="ObjectArray" usage="input"/>
        <Parameter name="_top" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCloneBackFrames" id="c09274c7-f1be-4804-b05c-97320a389cf5">
        <updating/>
        <source>doCloneBackFrames() updating;
// ---------------------------------------------------------------------------
// Created:     07 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aLayer : CM_DeckLayerLayout;
	obj : Object;
	backFrame : CMUI_PointDrawingFrame;
begin
	self.myROROPlanDrawController.allBackFrames.purge();

	self.frmDeck.myDrawingFrame.height := self.frmDeck.myDrawingFrame.height + (self.deckY1Offset * self.scaleFactor);
	
	if self.myCurrentDeck &lt;&gt; null then
		foreach aLayer in self.myCurrentDeck.myDeckLayout.allDeckLayerLayouts discreteLock do
			self.doCloneBackFrame(aLayer, self.shtDeck, self.scaleFactor, self.myROROPlanDrawController.allBackFrames, false);
		endforeach;
	endif;
	self.frmBackground.visible := false;
	self.repositionAllBackFrames();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doCmbJobBuild" id="18034d36-04f0-404c-871e-3f74f05d9e87">
        <updating/>
        <source>doCmbJobBuild(_clearJob : Boolean) updating;
/*
Purpose:			
Date				Who			Reason
AUGUST 2011		CNWAB1		Initial creation
25/08/2016		cnwma1		 2557:SPT - Missing Planned Location on Sequence Sheets- Issue not fixed from previous TFS
*/

vars
	idx			: Integer;
	aVoyage		: CM_Voyage;
	theVoyageJS	: CM_VoyageJobSheet;
	aCrane		: CM_Machine;
	aWP : CM_WorkPoint;
	theJob		: CM_Job;
	aVoyageJob	: CM_VoyageJob;
	jobNumber	: Integer;
	maxJobNumber: Integer;
	theObject : Object;
begin

	self.cmbWPJob.clear;
	self.cmbWPJob.sorted := true;
	if _clearJob then
		self.myCurrentJob := null;
		self.chkOutOfSequence.value := self.myCurrentVoyage.createOutOfSequenceLoadJobs(); //cnwrd1 par 30626 ccms 2209 23.10.12
	endif;
	self.cmbWPJob.style := ComboBox.Style_DropDown;

	self.cmbWPJob.maxLength := 30; // max job number length
	
	aVoyage := self.myCurrentVoyage;
	if aVoyage = null then
		return;
	endif;
	theObject := self.cmbWorkPoint.listObject;
	if theObject.isKindOf(CM_WorkPoint) then
		aWP:= theObject.CM_WorkPoint;
		if aWP &lt;&gt; null then
			theVoyageJS :=  aVoyage.allJobSheets[aWP.code.trimBlanks];
		endif;

		// TFS 3631
		if theVoyageJS &lt;&gt; null and theVoyageJS.isVoyageHoldJobSheet() then
			app.msgBox(app.getErrorString1(Alloc_hold_sheet_this_voyag_ca,aWP.code),app.getErrorString(Job_Sheet),MsgBox_OK_Only);
			self.cmbWorkPoint.listIndex := -1;
			return;
		endif;

		maxJobNumber := aVoyage.getNextJobNumber(theVoyageJS, aWP.CM_WorkPoint.IF_VoyageWorkPoint).Integer;
	elseif theObject.isKindOf(CM_Machine) then
		aCrane:= theObject.CM_Machine;
		if aCrane &lt;&gt; null then
			theVoyageJS :=  aVoyage.allJobSheets[aCrane.id.trimBlanks];
		endif;
		maxJobNumber := aVoyage.getNextJobNumber(theVoyageJS, aCrane.CM_Crane.IF_VoyageWorkPoint).Integer;
	endif;
	
	
	if theVoyageJS = null then
		//foreach theJob in aVoyage.allVoyageJobs do    25/08/2016 cnwma1 TFS#2557
		foreach theJob in aVoyage.allVoyageJobs where not theJob.isKindOf(CM_VoyageROROJob) do //25/08/2016 cnwma1 TFS#2557
			aVoyageJob := theJob.CM_VoyageJob;
			
			// PAR 28941
			if aVoyageJob.myDeck &lt;&gt; self.myCurrentDeck then
				continue;
			endif;
			
			if aVoyageJob.myJobSheet = null then
				jobNumber := aVoyageJob.jobNum.extractNumber.Integer;
				if jobNumber &gt; maxJobNumber then
					maxJobNumber := jobNumber;
				endif;
				
				if self.modeView = ShpDisplayMode_ColCodeDisch then 
					if aVoyageJob.isDischarge  
					  or aVoyageJob.jobType = JOB_TYPE_USER
					  or aVoyageJob.jobType = JOB_TYPE_SOB then
						idx := self.cmbWPJob.addItem(aVoyageJob.jobNum);
						self.cmbWPJob.itemObject[idx] := theJob;
					endif;
				endif;
				if self.modeView = ShpDisplayMode_ColCodeLoad then
					if not aVoyageJob.isDischarge 
					or aVoyageJob.jobType = JOB_TYPE_USER
					or aVoyageJob.jobType = JOB_TYPE_SOB then
						idx := self.cmbWPJob.addItem(aVoyageJob.jobNum);
						self.cmbWPJob.itemObject[idx] := theJob;
					endif;
				endif;
			endif;		
		endforeach;
	else
	
		foreach theJob in theVoyageJS.allJobsByOrder do
			aVoyageJob := theJob.CM_VoyageJob;
			
			// PAR 28941
			if aVoyageJob.myDeck &lt;&gt; self.myCurrentDeck then
				continue;
			endif;

			jobNumber := aVoyageJob.jobNum.extractNumber.Integer;
			if jobNumber &gt; maxJobNumber then
				maxJobNumber := jobNumber;
			endif;
			if self.modeView = ShpDisplayMode_ColCodeDisch then 
				if aVoyageJob.isDischarge  
				or aVoyageJob.jobType = JOB_TYPE_USER
				or aVoyageJob.jobType = JOB_TYPE_SOB then
					idx := self.cmbWPJob.addItem(aVoyageJob.jobNum);
					self.cmbWPJob.itemObject[idx] := theJob;
				endif;
			endif;
			if self.modeView = ShpDisplayMode_ColCodeLoad then
				if not aVoyageJob.isDischarge 
				or aVoyageJob.jobType = JOB_TYPE_USER
				or aVoyageJob.jobType = JOB_TYPE_SOB then
					idx := self.cmbWPJob.addItem(aVoyageJob.jobNum);
					self.cmbWPJob.itemObject[idx] := theJob;
				endif;
			endif;
		
		endforeach;
	endif;
	
	


	self.cmbWPJob.listIndex := -1;	

	//auto job number generation CCMS 1369

	if maxJobNumber &lt; 10 and app.myRoot.client = Client_CentrePort then
		self.cmbWPJob.text := maxJobNumber.String.padLeadingZeros(2);
	else
		self.cmbWPJob.text := maxJobNumber.asStringJMT;
	endif;
	

end;</source>
        <Parameter name="_clearJob" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doCmbJobClick" id="124e3c33-f8c6-4ba3-ba03-26a464f00c39">
        <updating/>
        <source>doCmbJobClick(combobox: ComboBox input) updating;
// ---------------------------------------------------------------------------
// Created:		September 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	tmpJob 			: CM_VoyageJob;
	tmpDrawController	: SHP_BayDrawingController;
	tmpHatchLidJob	: CM_VoyageHatchLidJob;
	tmpHatchLid		: CM_HatchLid;
	tmpRequest		: CM_SlotRequest;
	tmpSlot			: CM_SlotController;
	inLoadMode		: Boolean;
	
begin
	if combobox.listObject = null then
		return;
	endif;
	tmpJob := combobox.listObject.CM_VoyageJob;
	
	// PAR 28941
	if tmpJob.myDeck &lt;&gt; self.myCurrentDeck then
		return;
	endif;

	self.setCurrentJob(tmpJob);

	if tmpJob = null then
		return;
	endif;

	inLoadMode := (self.modeView = ShpDisplayMode_ColCodeLoad);

	self.myROROPlanDrawController.selectObjectsForJob(tmpJob, inLoadMode, true);
	if self.mySideViewForm &lt;&gt; null then
		self.mySideViewForm.myROROLocnDrawingController.selectObjectsForJob(tmpJob, inLoadMode, true);
	endif;
end;</source>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doContextMenuAssignRelease" id="94709b7f-b960-41aa-96f7-c26ab05e9e0f">
        <updating/>
        <source>doContextMenuAssignRelease( _roroRequest : CM_RORORequest input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 December 2012	cnwrd1	Initial creation

*/

vars
	contextReq : CM_RORORequest;
	assignReleaseMenu : MenuItem; 
	mnuChild : MenuItem;
	bulkReleases : CM_BulkReleaseByTypeStCodeDict;
	bulkRelease	: CM_BulkRelease;
	reserveDetail : CM_ReserveDetail;
	iter : Iterator;
	typeKey,
	statusKey			: Integer;
	codeKey				: String;
	dtKey				: TimeStamp;
	location: CM_LocationsController;
	isoCode: String;
	idx			: Integer;
begin

	idx := 2;
	contextReq := findContextSlot(_roroRequest);
	if contextReq &lt;&gt; null then
		assignReleaseMenu := self.mnuAssignRelease; 
		assignReleaseMenu.visible := true;
		assignReleaseMenu.enabled := true;
		assignReleaseMenu.caption := "Assign Release";
		assignReleaseMenu.userObject := contextReq;
		self.mnuAssignReleaseStub.visible := true;
		self.mnuAssignReleaseStub.caption := "No Releases";		
		
		// Find all relevent BulkReleases
		bulkReleases := self.myTerminal.allBulkReleaseByTypeByStByCd;
		iter := bulkReleases.createIterator();
		bulkReleases.startKeyGeq(BR_TYPE_SHIP, BR_ACTIVE, null, null, iter);
		while iter.next(bulkRelease) do 
			bulkReleases.getIteratorKeys(typeKey, statusKey, codeKey, dtKey, iter);
			if typeKey &lt;&gt; BR_TYPE_SHIP or statusKey &lt;&gt; BR_ACTIVE then
				break;
			endif;
			// Only want bulk release for current voyage
			if bulkRelease.myVoyage = self.myCurrentVoyage and
					bulkRelease.myDischargePort &lt;&gt; null and
					//bulkRelease.myOperator &lt;&gt; null then
					( bulkRelease.myOperator &lt;&gt; null or bulkRelease.myOperatorGroup &lt;&gt; null )
					then
				foreach reserveDetail in bulkRelease.allReserveDetails do
					if reserveDetail.isKindOf(CM_ReserveSelection) then
						//assignReleaseSubMenu := assignReleaseMenu.loadSubMenu(self.allMenuItems.size+1);	
						self.mnuAssignReleaseStub.visible := false;
						mnuChild := assignReleaseMenu.getMenuItem(idx); // Clone menu
						if mnuChild = null then
							mnuChild := assignReleaseMenu.loadSubMenu(idx); // Clone menu						
						endif;
						idx := idx +1;
						mnuChild.visible := true;
						mnuChild.enabled := true;
						mnuChild.setEventMapping(MenuItem::click.name,SHP_ROROPlanningForm::doAssignRelease.name);
						
						isoCode := reserveDetail.getISOTypeCode();     // PAR 25283
						if isoCode = "" then
							isoCode := reserveDetail.getISOGroupCode();
						endif;
						if  bulkRelease.myOperator &lt;&gt; null then
							mnuChild.caption := 
								bulkRelease.getOperatorCode() &amp; " " &amp; 
								isoCode &amp; " " &amp;
								bulkRelease.myDischargePort.code &amp; " " &amp; 
								"(" &amp; bulkRelease.code &amp; ")";
						else	//12 Mar 2012	NDL	Par 29248
							mnuChild.caption := 
								bulkRelease.myOperatorGroup.code &amp; " " &amp; 
								isoCode &amp; " " &amp;
								bulkRelease.myDischargePort.code &amp; " " &amp; 
								"(" &amp; bulkRelease.code &amp; ")";
						endif;
						location := reserveDetail.getLocationLC();		// PAR 18617
						if location &lt;&gt; null then
							mnuChild.caption := mnuChild.caption &amp; " " &amp; location.getID();
						endif;
						mnuChild.visible := true;
						mnuChild.userObject := reserveDetail;
					endif;
				endforeach;
			endif;
		endwhile;

	endif;	
epilog
	delete iter; //epr par 18417 3/11/08
end;
</source>
        <Parameter name="_roroRequest" type="CM_RORORequest" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doDisplayJobAllocCargoForm" id="56c23b74-aaa3-4584-af2a-8e756b8d9b2c">
        <source>doDisplayJobAllocCargoForm( _job : CM_VoyageJob );

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 November 2012	cnwrd1	Initial creation

*/

vars

	form	: SHP_VoyAllocJobCargoMaintForm;
	anAlloc 	: CM_YardAllocation;
	aRequest : CM_Request;
begin

	if _job = null then
		return;
	endif;
	
	form := app.loadForm(	SHP_VoyAllocJobCargoMaintForm, 
							self.myAssistant.class, 
							false, false, false, 
							self.myTerminal, null).SHP_VoyAllocJobCargoMaintForm;
														
	// If user fails security we don't want to show a null form.
	if form &lt;&gt; null then
		aRequest := _job.allRequests.first;
		if aRequest &lt;&gt; null then
			anAlloc := aRequest.getFirstAllocation();
		else
			return;
		endif;
	
		form.initForJob( _job.allAssignedCargoForAlloc, anAlloc, _job);
		form.show();

	endif;

epilog

end;</source>
        <Parameter name="_job" type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="doDisplayLoadCCList" id="ee542742-b9db-4ffb-8636-80ddae4849c9">
        <updating/>
        <source>doDisplayLoadCCList() updating;
/*
Purpose:			
Date		Who		Reason
04 Aug 2011	cnwab1	Initial creation
09 Feb 2012	cnwkpd1	PAR #28731 - fix transient leaks

*/

vars
	req, otherReq : Object;
	iter : Iterator;
	deckOrd,portIndex, x1,y1,z1 : Integer;
	odeckOrd,oportIndex, ox1,oy1,oz1 : Integer;
	theTable : Table;
	ccPort : CM_Port;
	portName : String;
	newRow, theReturn : Integer;
begin
	theTable := self.tblLoadCC;
	theTable.rows := theTable.fixedRows;
	if app.msgBox(app.getErrorString1(Regenerate_sorting,app.getErrorString(SHP_Load_Colour_Coding)), app.getErrorString(Port_rotation), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_Yes then
		while true do
			app.myTrxUA.trxUpdateROROLoadCCSort(self.myCurrentDeck, app.myPassport);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				self.clearErrorWarnings();
				global.beep;
				break;
			else
				theReturn := app.showErrorWarningDialog(app.getErrorString(Deck_sort_load), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				return;
			endif;
			break;
		endwhile;
	endif;
	
//	self.myCurrentDeck.sortLoadCCByPortRotation();
//	otherReq := col.getAtKeyLss(8,0,0,0,0);
//	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' REQ: ' &amp; req.String &amp; " otherReq: " &amp; otherReq.String);

		
	iter := self.myCurrentDeck.allLoadCCByPortRotationXYZ.createIterator();
	
	while iter.next(req) do
		self.myCurrentDeck.allLoadCCByPortRotationXYZ.getIteratorKeys(portIndex, x1,y1,z1,deckOrd, iter);
		
		otherReq := self.myCurrentDeck.allLoadCCByPortRotationXYZ.getAtKeyLss(portIndex,0,0,0,0);
	//	app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' REQ: ' &amp; req.String &amp; " otherReq: " &amp; otherReq.String);

		ccPort := req.CM_RORORequest.getAttrDischargePort();
		portName := null;
		if ccPort &lt;&gt; null then
			portName := ccPort.code;
		endif;
	//	theTable.addItemAt("Allocation" &amp; Tab &amp; "Deck" &amp; Tab &amp; "Port" &amp; Tab &amp; "Port Rotation" &amp; Tab &amp; "X Pos" &amp; Tab &amp; "Y Pos" &amp; Tab &amp; "Z Pos" ,1);
		newRow := theTable.addItem(req.String &amp; Tab &amp; req.CM_RORORequest.getAllocationName() &amp; Tab &amp; req.CM_RORORequest.myROROController.myDeck.code &amp; Tab &amp; portName &amp; Tab &amp; portIndex.String &amp; Tab &amp; x1.String &amp; Tab &amp; y1.String &amp; Tab &amp; z1.String);

		if otherReq &lt;&gt; null and otherReq.CM_RORORequest.getX1ForPortRotationSort() &lt; x1 then
			theTable.accessCell(newRow, 6).backColor := Red;
		endif;
	endwhile;
	

epilog
	delete iter;

end;</source>
    </JadeMethod>
    <JadeMethod name="doDrawCurrentLayer" id="a4db4062-5f1f-4551-a7ff-64bc51e28306">
        <updating/>
        <source>doDrawCurrentLayer() updating;
/*
Purpose:			
Date		Who		Reason
18 April 2011	cnwab1	Initial creation
*/

vars
//	layerFrame : CMUI_PointDrawingFrame;
begin
	self.doDrawLayerForLayer(self.myCurrentLayer);
//		layerFrame := self.getFrameForLayer(self.myCurrentLayer,self.myROROPlanDrawController.allBackFrames);
	
	//	self.doDrawLayer(layerFrame, self.frmDeck.myDrawingFrame.CMUI_PointDrawingFrame);

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDrawCurrentPoly4CurrentLayer" id="687a484b-212a-4cb0-bb25-4f1fe0ac670e">
        <updating/>
        <source>doDrawCurrentPoly4CurrentLayer() updating; 
/*
Purpose:	This draws the SELECTION		
Date				Who			Reason
APRIL 2011		CNWAB1		Initial creation
*/





// NOT USED see doDrawSelectObject






















vars
	theFrame, layerFrame : CMUI_PointDrawingFrame;
	deckItemLayout, pxyLayout : CM_DeckItemLayout;
	deckLayer : CM_DeckLayerLayout;
	theSDF : CMUI_ScrollableDrawingFrame;
	allTIs : ObjectArray;
	numTier : Integer;
	tmpPoints : PointArray;
	aTI : CM_TrackedItem;
	aftLocn : CM_ROROLocnDefn;
	area : Decimal[12,4];
	lcs: CM_LCSet;
	aReq : CM_RORORequest;
	tmpObj, objectIRepresent : Object;
	slotDefn : CM_ROROSlotDefn;
	theJob : CM_VoyageJob;
	theJobLC : CM_VoyageROROController;
	altKey : Boolean;
	selectedColour : Integer;
begin


	self.backFrameIndex := 0;
	theSDF := self.frmDeck;
	theFrame := theSDF.myDrawingFrame.CMUI_PointDrawingFrame;
	deckItemLayout := self.myCurrentItemLayout;
	selectedColour := Gray;
	if  self.modeView = ShpDisplayMode_ColCodeDisch 
	or self.modeView = ShpDisplayMode_ColCodeLoad then
		altKey := app.isAltKeyDown();
		if altKey then
			selectedColour := DarkGray;
		endif;
	endif;
	
	if deckItemLayout = null then
		self.doClearTopDrawingFrame(true);

		return;
	endif;

	
//	if self.myROROPlanDrawController.allSelectedObjects.includes(deckItemLayout.getObjectIRepresent()) then
//		self.myROROPlanDrawController.deselectObject(deckItemLayout.getObjectIRepresent(), true);
//	else
		// JOB MODE, select all the slots for the same job
		objectIRepresent := deckItemLayout.getObjectIRepresent();
		self.myROROPlanDrawController.selectObject(objectIRepresent, false, altKey);
		if self.modeView = ShpDisplayMode_Actual then
			if objectIRepresent.isKindOf(CM_ROROLocnDefnVoyage) then
				tmpObj := objectIRepresent.CM_ROROLocnDefnVoyage.getAftLCFor40(REAL_MODE);
				if tmpObj &lt;&gt; null then
					self.myROROPlanDrawController.selectObject(tmpObj, false, altKey);
				endif;
				self.frmStatus.myFrameCaption.caption := objectIRepresent.CM_ROROLocnDefnVoyage.code;
			endif;
		elseif self.modeView = ShpDisplayMode_ColCodeDisch 
		or self.modeView = ShpDisplayMode_ColCodeLoad then
			if objectIRepresent.isKindOf(CM_RORORequest) then

				aReq := objectIRepresent.CM_RORORequest;
				tmpObj := aReq.getAftLocnDefn();
				
				if tmpObj &lt;&gt; null then
					self.myROROPlanDrawController.selectObject(tmpObj, false, altKey);
				endif;
				// get the request's locn, then get all the requests for this locn
				 tmpObj := aReq.myROROController.getDefn();
				 if tmpObj &lt;&gt; null and tmpObj.CM_DeckItem.isLocnContainer() then
						self.frmStatus.myFrameCaption.caption := tmpObj.CM_ROROLocnDefnVoyage.code;
					if self.modeView = ShpDisplayMode_ColCodeLoad then
						foreach slotDefn in tmpObj.CM_ROROLocnDefnVoyage.allROROSlotDefnByOrdinal  discreteLock do
							aReq := slotDefn.CM_ROROSlotDefnVoyage.mySlotController.myRORORequestDischarge ;
							if aReq &lt;&gt; null then
								if aReq &lt;&gt; objectIRepresent then
									self.myROROPlanDrawController.selectObject(aReq, false, altKey);
								endif;
								if theJob = null and aReq.myJob &lt;&gt; null then
									theJob := aReq.myJob.CM_VoyageJob;
									theJobLC := aReq.myROROController;
								endif;
							endif;
						endforeach;
					elseif self.modeView = ShpDisplayMode_ColCodeDisch then
						foreach slotDefn in tmpObj.CM_ROROLocnDefnVoyage.allROROSlotDefnByOrdinal  reversed, discreteLock do
							aReq := slotDefn.CM_ROROSlotDefnVoyage.mySlotController.myRORORequestDischarge ;
							if aReq &lt;&gt; null then
								if aReq &lt;&gt; objectIRepresent then
									self.myROROPlanDrawController.selectObject(aReq, false, altKey);
								endif;
								if theJob = null and aReq.myJob &lt;&gt; null then
									theJob := aReq.myJob.CM_VoyageJob;
									theJobLC := aReq.myROROController;
								endif;
							endif;
						endforeach;
					endif;
				elseif  tmpObj &lt;&gt; null and  tmpObj.CM_DeckItem.isLocnGC() then
					if aReq &lt;&gt; null then
						if theJob = null and aReq.myJob &lt;&gt; null then
							theJob := aReq.myJob.CM_VoyageJob;
							theJobLC := aReq.myROROController;
						endif;
					endif;
				endif;
			elseif objectIRepresent.isKindOf(CM_ROROLocnDefnVoyage) then
				aReq := objectIRepresent.CM_ROROLocnDefnVoyage.getFirst40Request(self.modeView = ShpDisplayMode_ColCodeLoad);
						self.frmStatus.myFrameCaption.caption := objectIRepresent.CM_ROROLocnDefnVoyage.code;
 				
				if aReq &lt;&gt; null then
					if aReq.isBackEndRequest() then
						return;
					endif;
					tmpObj := objectIRepresent.CM_ROROLocnDefnVoyage.getAftLCFor40(REAL_MODE);
					if tmpObj &lt;&gt; null then
						self.myROROPlanDrawController.selectObject(tmpObj, false, altKey);
					endif;
				endif;

			endif;
		endif;
		if self.modeWork = WorkMode_Plan then
			if aReq &lt;&gt; null then
				self.setUpPlannedToLCs(aReq);

			endif;
		elseif self.modeWork = self.WorkMode_Job then
			if deckItemLayout.isKindOf(CM_RORORequestLayout) then
//				aReq := deckItemLayout.CM_RORORequestLayout.myRequest;
				if theJob &lt;&gt; null then //aReq.myJob &lt;&gt; null then
					self.doClearTopDrawingFrame(true);
					if theJob &lt;&gt; null then 
						self.frmStatus.myFrameCaption.caption := "Job: " &amp; theJob.jobNum;
					endif;
					self.myROROPlanDrawController.selectSlotsForJob(theJobLC); //aReq.myROROController);
					if self.mySideViewForm &lt;&gt; null then
						self.mySideViewForm.myROROLocnDrawingController.selectObjectsForJob(theJob, (self.modeView = ShpDisplayMode_ColCodeLoad), true);
					endif;
	
					self.cmbWorkPoint.setIndexFromObject(theJob.getWorkPointObject());
					self.doCmbJobBuild(true);
					self.cmbWPJob.setIndexFromObject(theJob);
					return;
				
					
				endif;
			endif;
		else
			if theJob &lt;&gt; null then 
				self.frmStatus.myFrameCaption.caption := "Job: " &amp; theJob.jobNum;
			endif;

		endif;
//	endif;
	
	
	deckLayer := deckItemLayout.myDeckLayer;
	// ### REGISTER FOR NOTES
	self.beginNotification(deckItemLayout, EVENT_RORO_ITEM_SELECT, Response_Continuous, null);

	self.lblArea.caption:=deckItemLayout.getAreaInSquareMetresDisplay;
	
	// we make these transparent so that the other polygons for this terminal can be seen underneath
	if theFrame.mode &lt;&gt; theFrame.Mode_MultiSelect then
		theFrame.mode := CMUI_PointDrawingFrame.Mode_LineAlter; 
	endif;
	theFrame.transparent := true;
	
	
	if theFrame.mode &lt;&gt; theFrame.Mode_MultiSelect 
	and ((self.myCurrentLayer &lt;&gt; null and self.myCurrentLayer.type &lt;&gt; ROROLayerType_GC) or self.myCurrentLayer = null) then

		self.doClearTopDrawingFrame(true);
	endif;
	theFrame.enabled := true;
	theSDF.transparent := true;
 	
	
	if self.modeView = ShpDisplayMode_Actual 
	or self.modeView = ShpDisplayMode_Defn then
		theFrame.showText := (self.modeView = ShpDisplayMode_Defn and  self.optText.value);
		theFrame.doPointArrayAdd(Black,true, Frame.DrawFillStyle_Solid, 1, selectedColour, deckItemLayout);
		self.addPillarsToTopFrame();	
		self.myROROPlanDrawController.getAllPolygonsActual(theFrame,deckLayer, White);
	elseif  self.modeView = ShpDisplayMode_ColCodeDisch 
	or self.modeView = ShpDisplayMode_ColCodeLoad then
		theFrame.doPointArrayAdd(Black,true, Frame.DrawFillStyle_Solid, 1, selectedColour, deckItemLayout);
		self.myROROPlanDrawController.getAllPolygonsColourCoding(theFrame,null,(self.modeView = ShpDisplayMode_ColCodeLoad), White);

	else
		theFrame.drawAllPolygons(White);
	endif;
	theFrame.showText := false;

	// this draws all the polygons on the background frame, makes it easier to line up what you are drawing
	
	 // PAR 27749. do not do this for container layers as the drawing of selecting takes the container graphic off the container layer and redraws the whole layer each time.
	 //					container positions cannot be moved so do not need to remove from container layer.
	 //					However GC and OOTL can be moved
//	if self.myCurrentLayer &lt;&gt; null and (self.myCurrentLayer.type = ROROLayerType_GC or self.myCurrentLayer.type = ROROLayerType_OOTL or self.myCurrentLayer.type = ROROLayerType_CCLoad) then
	if deckLayer &lt;&gt; null and deckLayer.isPlanningRedrawable() then
		if self.myCurrentLayer = null then
			self.myCurrentLayer := deckLayer;
		endif;
		self.doDrawCurrentLayer();
	endif;
	

epilog
	delete allTIs;
	delete tmpPoints;
	delete lcs;
end;</source>
    </JadeMethod>
    <JadeMethod name="doDrawDeckItemLayout" id="bc65e8ed-d729-48ab-9e55-8f88d13d18fd">
        <updating/>
        <source>doDrawDeckItemLayout(_deckItemLayout : CM_DeckItemLayout) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 June 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	theFrame : CMUI_PointDrawingFrame;
	deckItemLayout : CM_DeckItemLayout;
	locnDefn : CM_ROROLocnDefnVoyage;
	deckItem : CM_DeckItem;
	deckLayer : CM_DeckLayerLayout;
	theSDF : CMUI_ScrollableDrawingFrame;
	aReq,
	nonPlannedReq: CM_RORORequest;
	objectIRepresent : Object;
	theJob : CM_VoyageJob;
	altKey, isLoad, ccMode  : Boolean;
	selectedColour : Integer;
	statusCaption : String;
	selectedIndex : Integer;
	allSelectedObjects : ObjectSet;
	obj : Object;
begin
	ccMode:=self.modeView = ShpDisplayMode_ColCodeLoad or self.modeView = ShpDisplayMode_ColCodeDisch;
	isLoad:= self.modeView = ShpDisplayMode_ColCodeLoad;
	theSDF := self.frmDeck;
	deckItemLayout := _deckItemLayout;
	self.frmDeck.myDrawingFrame.CMUI_PointDrawingFrame.setCurrentPoint(null);// PAR 28920
	
	selectedColour := Gray;
	altKey := app.isAltKeyDown();
	if altKey then
		selectedColour := DarkGray;
	endif;
	
	if deckItemLayout = null then
		return;
	endif;
	deckLayer := deckItemLayout.myDeckLayer;
	objectIRepresent := deckItemLayout.getObjectIRepresent();

	theFrame:=self.myROROPlanDrawController.getFrameForLayer(deckItemLayout.myDeckLayer);
	//already selected clear and return
	if self.doClearSelectedObject(deckItemLayout) then	
		self.redrawSelectLayer(deckItemLayout);
		return;
	endif;

	create allSelectedObjects transient;
	self.myROROPlanDrawController.getSelectObjectsForMode(deckItemLayout,allSelectedObjects);
	if allSelectedObjects.size = 0 then
		return;
	endif;
	
	foreach obj in allSelectedObjects do
		self.myROROPlanDrawController.selectObject(obj,false,altKey);
	endforeach;

	// JOB MODE, select all the slots for the same job
	
	if objectIRepresent.isKindOf(CM_RORORequest) then
		
		aReq := objectIRepresent.CM_RORORequest;
		if theJob = null and aReq.myJob &lt;&gt; null then
			theJob := aReq.myJob.CM_VoyageJob;
		endif;
		// get the request's locn, then get all the requests for this locn
		 deckItem := aReq.myROROController.getDefn();
		 if deckItem &lt;&gt; null then	
			if deckItem.isLocnContainer() then
				locnDefn := deckItem.CM_ROROLocnDefnVoyage;		
				//epr par 29406 help with the load plan on yard forms select req that has not been planned yet
				nonPlannedReq:=deckItem.getFirstUnplannedRequest(isLoad);
				if nonPlannedReq &lt;&gt;  null then
					aReq:= nonPlannedReq;
				endif;
			endif;
		endif;
	elseif objectIRepresent.isKindOf(CM_DeckItem) then
		 deckItem :=objectIRepresent.CM_DeckItem;
	endif;
	
	if deckItem &lt;&gt; null then
		statusCaption := statusCaption &amp; deckItem.code &amp; " ";
		if isLoad then
			statusCaption := statusCaption &amp; deckItem.getCargoDetails(ShpDisplayMode_Proposed, self.modeView, self.myROROPlanDrawController.modeViewSubSub) &amp; " ";		 // PAR 29298  // 30332	// #31367
		else
			statusCaption := statusCaption &amp; deckItem.getCargoDetails(ShpDisplayMode_Actual, self.modeView, self.myROROPlanDrawController.modeViewSubSub) &amp; " ";		 // PAR 29298   // 30332	// #31367
		endif;
	endif;
	
	if  ccMode then
		if self.modeWork = WorkMode_Plan then
			if aReq &lt;&gt; null then
				self.setUpPlannedToLCs(aReq);
			endif;
		elseif self.modeWork = self.WorkMode_Job then
			if deckItemLayout.isKindOf(CM_RORORequestLayout) then
				if theJob &lt;&gt; null then 
					self.doDrawSelectObjectsForJob(theJob);
					return;
				else
					//epr par 29098
					self.cmbWorkPoint.listIndex := -1;
					self.cmbWPJob.listIndex := -1;
				endif;
			endif;	
		endif;
	endif;
	if theJob &lt;&gt; null then 
		statusCaption := statusCaption &amp;  app.getErrorString(Job) &amp; ": " &amp; theJob.jobNum &amp; " ";
	endif;
	
	// ### REGISTER FOR NOTES
	self.beginNotification(deckItemLayout, EVENT_RORO_ITEM_SELECT, Response_Continuous, null);
	self.lblArea.caption:=deckItemLayout.getAreaInSquareMetresDisplay;
	
	
	theSDF.transparent := true;
 	

	if deckItemLayout.CM_DeckItemLayout.isMoveable() then
		//theFrame := theSDF.myDrawingFrame.CMUI_PointDrawingFrame;
		theSDF.myDrawingFrame.CMUI_PointDrawingFrame.doPointArrayAdd(Black,true, Frame.DrawFillStyle_Solid, 1, selectedColour, deckItemLayout);
		if ccMode then
			self.myROROPlanDrawController.drawLayoutItemColourCoding(theSDF.myDrawingFrame.CMUI_PointDrawingFrame,theSDF.myDrawingFrame.CMUI_PointDrawingFrame.allPointGraphics.size,isLoad);	
		elseif self.modeView = ShpDisplayMode_Actual or self.modeView =  ShpDisplayMode_Defn then
			//self.myROROPlanDrawController.getAllPolygonsActual(theSDF.myDrawingFrame.CMUI_PointDrawingFrame,null,null);
			self.myROROPlanDrawController.drawLayoutItemActual(theSDF.myDrawingFrame.CMUI_PointDrawingFrame,theSDF.myDrawingFrame.CMUI_PointDrawingFrame.allPointGraphics.size);
		elseif self.modeView = ShpDisplayMode_Proposed then
			//self.myROROPlanDrawController.getAllPolygonsProposed(theSDF.myDrawingFrame.CMUI_PointDrawingFrame,null,null);
			self.myROROPlanDrawController.drawLayoutItemProposed(theSDF.myDrawingFrame.CMUI_PointDrawingFrame,theSDF.myDrawingFrame.CMUI_PointDrawingFrame.allPointGraphics.size);
		endif;
	endif;
	
	if theFrame &lt;&gt; null then
		theFrame.enabled := true;
		
		selectedIndex := theFrame.allPointGraphics.indexOf(deckItemLayout);
		if selectedIndex &gt; 0  then
		else
			theFrame.doAddToArraysForProxy( deckItemLayout);
			selectedIndex:=theFrame.allPointGraphics.size;
		endif;
		if ccMode then
			self.myROROPlanDrawController.drawLayoutItemColourCoding(theFrame,selectedIndex,isLoad);
		elseif self.modeView = ShpDisplayMode_Actual or self.modeView =  ShpDisplayMode_Defn then
			self.myROROPlanDrawController.drawLayoutItemActual(theFrame,selectedIndex);
		elseif self.modeView = ShpDisplayMode_Proposed then
			self.myROROPlanDrawController.drawLayoutItemProposed(theFrame,selectedIndex);
		endif;
	
		theFrame.showText := (self.modeView = ShpDisplayMode_Defn and  self.optText.value);
	endif;
	
	self.frmStatus.myFrameCaption.caption := statusCaption;
	
epilog
	delete allSelectedObjects;
end;</source>
        <access>protected</access>
        <Parameter name="_deckItemLayout" type="CM_DeckItemLayout"/>
    </JadeMethod>
    <JadeMethod name="doDrawLabelH" id="ca95b7ef-0096-4b3f-9ebb-25687e0e3f26">
        <source>doDrawLabelH();
// ---------------------------------------------------------------------------
// Created:     10 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
/*

RULER

SCALE
####

1 foot = 3 pixels
8 feet = 24 pixels
20 feet = 60 pixels
40 feet = 120 pixels

1 metre = 10 pixels
6 metre = 60 pixels (20 feet)
2.4 metre = 24 pixels (8 feet)

*/
vars
	frame : Frame;
	m, idx : Integer;
	length : Integer;
	scale : Decimal[12,4];
	x1,y1,x2,y2 : Real;

begin
	scale := self.scaleFactor;
	
	frame := self.frmDeck.myHLabels;
	frame.clearGraphics();
	length := self.rulerHPixels;
	
	frame.backColor := White;
	frame.drawLine(0,3,length,3, Black);
	frame.drawLine(0,30,length,30, Black);
	frame.height := 50;
	frame.width := length;
	frame.drawFontSize := 8;
	
//	self.frmDeckBottom.myDrawingFrame.top := 70;
//	self.frmDeckBottom.myVLabels.top := 70;
	frame.drawLine(0,3,0,20 ,Black); // ZERO METRES
	frame.drawLine(0,30,0,40 ,Black); // ZERO SECTION
	
	//m := -15;
	m := ((ROROStructureRearLine/10) * -1).Integer; // -15
	
	
	foreach idx in 1 to length do
		frame.drawTextAlign := Frame.DrawTextAlign_Center;
		// 1 METRE MARK
		if idx mod 10 = 0 then
			m := m + 1;
			frame.drawWidth := 1;
			
			x1 := (idx * scale);
			y1 := 3; 
			x2 := (idx * scale);
			y2 := 8;

			frame.drawLine(x1,y1,x2,y2 ,Black);
		endif;
		// 5 METRE MARK
		if idx mod 50 = 0 then
			frame.drawWidth := 2;
			
			x1 := (idx * scale);
			y1 := 3; 
			x2 := (idx * scale);
			y2 := 12;

			frame.drawLine(x1,y1,x2,y2, Black);
			
			x1 := (idx * scale);
			y1 := 14; 
			frame.drawTextAt(m.String,x1,y1,Black);
		endif;
		// 10 METRE MARK
		if idx mod 100 = 0 then
			frame.drawWidth := 2;
			
			x1 := (idx * scale);
			y1 := 3; 
			x2 := (idx * scale);
			y2 := 12;
			frame.drawLine(x1,y1,x2,y2, Black);
		endif;
	
	endforeach;

	self.doDrawSections(self.frmDeck.myHLabels, self.scaleFactor);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDrawLabelV" id="976a579b-5153-4e19-bfad-49e837ec3029">
        <source>doDrawLabelV();
// ---------------------------------------------------------------------------
// Created:     10 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------
/*

RULER

SCALE
####

1 foot = 3 pixels
8 feet = 24 pixels
20 feet = 60 pixels
40 feet = 120 pixels

1 metre = 10 pixels
6 metre = 60 pixels (20 feet)
2.4 metre = 24 pixels (8 feet)

*/

vars
	frame : Frame;
	m, idx : Integer;
	scale : Decimal[12,4];
	x1,y1,x2,y2 : Real;
begin
	scale := self.scaleFactor;
	
	frame := self.frmDeck.myVLabels;
	frame.clearGraphics();
	
	frame.backColor := White;
	frame.drawLine(10,0,10,2200, Black);
	frame.width := 50;
	frame.drawFontSize := 8;
	
	self.frmDeck.myDrawingFrame.left := 50;
	self.frmDeck.myHLabels.left := 50;
	frame.drawLine(10,0,20,0 ,Black);
	
	m := ((ROROStructureCentreLine/10) * -1).Integer; // -30
	
	foreach idx in 1 to self.rulerVPixels do
		if idx mod 10 = 0 then
			m := m + 1;
			frame.drawWidth := 1;
			
			x1 := 10;
			y1 := (idx * scale);
			x2 := 20;
			y2 := (idx * scale);
			
			frame.drawLine(x1,y1,x2,y2, Black);
		endif;
		if idx mod 50 = 0 then
			frame.drawWidth := 2;

			x1 := 10;
			y1 := (idx * scale);
			x2 := 25;
			y2 := (idx * scale);
			
			frame.drawLine(x1,y1,x2,y2, Black);

			x1 := 27;
			y1 := ((idx-6) * scale);
			frame.drawTextAt(m.String,x1,y1,Black);
		endif;
		if idx mod 100 = 0 then
			frame.drawWidth := 2;

			x1 := 10;
			y1 := (idx * scale);
			x2 := 25;
			y2 := (idx * scale);
			frame.drawLine(x1,y1,x2,y2, Black);
		endif;
	endforeach;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDrawLayer" id="d87be7fa-37ec-45c4-8b27-9fb9a7ea48ed">
        <updating/>
        <source>doDrawLayer(_frame : CMUI_PointDrawingFrame input; _sdfDrawingFrame : CMUI_PointDrawingFrame) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		This draws all the polygons fro this terminal on a background frame, that the user cannot alter
// ---------------------------------------------------------------------------
// 
vars
	deckItemLayout 	: CM_DeckItemLayout;
	theLayer 		: CM_DeckLayerLayout;
begin

	if _frame = null then
		return;
	endif;

	_frame.doBtnClearClick(true);
	
	theLayer := _frame.userObject.CM_DeckLayerLayout;

	if theLayer = null then
		app.msgBox(app.getErrorString(Choose_layer),app.getErrorString(Layer_problem), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	// ### REGISTER FOR NOTES
	self.beginNotification(theLayer, EVENT_RORO_LAYER_SELECT, Response_Continuous, null);
	self.beginNotification(theLayer, EVENT_RORO_LAYER_VISIBLE, Response_Continuous, null);
	self.beginNotification(theLayer, EVENT_RORO_LAYER_UPDATE, Response_Continuous, null);
	
	foreach deckItemLayout in theLayer.allDeckItemLayouts do
		// ### REGISTER FOR NOTES
		self.beginNotification(deckItemLayout, EVENT_RORO_ITEM_SELECT, Response_Continuous, null);
		self.beginNotification(deckItemLayout, EVENT_RORO_ITEM_VISIBLE, Response_Continuous, null);
		self.beginNotification(deckItemLayout, EVENT_RORO_ITEM_UPDATE, Response_Continuous, null);
		self.beginNotification(deckItemLayout, EVENT_RORO_ITEM_DELETE, Response_Continuous, null);
		
	endforeach;
	
	self.myROROPlanDrawController.doDrawLayer(_frame, theLayer,_sdfDrawingFrame);
end;</source>
        <Parameter name="_frame" type="CMUI_PointDrawingFrame" usage="input"/>
        <Parameter name="_sdfDrawingFrame" type="CMUI_PointDrawingFrame"/>
    </JadeMethod>
    <JadeMethod name="doDrawLayerForLayer" id="c37c195a-501d-4c04-a173-d938dff76805">
        <updating/>
        <source>doDrawLayerForLayer(_layer : CM_DeckLayerLayout) updating;
/*
Purpose:			
Date		Who		Reason
18 April 2011	cnwab1	Initial creation
*/

vars
	layerFrame : CMUI_PointDrawingFrame;
begin
		layerFrame := self.getFrameForLayer(_layer,self.myROROPlanDrawController.allBackFrames);
	
		self.doDrawLayer(layerFrame, self.frmDeck.myDrawingFrame.CMUI_PointDrawingFrame);

epilog

end;</source>
        <Parameter name="_layer" type="CM_DeckLayerLayout"/>
    </JadeMethod>
    <JadeMethod name="doDrawLayers" id="3b18b47f-d96c-44c9-8a05-165b3f0d2d5b">
        <updating/>
        <source>doDrawLayers() updating;
// ---------------------------------------------------------------------------
// Created:     07 January 2011 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	obj : Object;
	layerFrame : CMUI_PointDrawingFrame;
	first : Boolean;
	theTable : Table;
	layer : CM_DeckLayerLayout;
	idx : Integer;
begin
	first := true;
	theTable := self.tblLayers;
	theTable.rows := 0;
	theTable.columns := 1;
	theTable.selectMode := Table.SelectMode_Multiple; // PAR 29897
	idx := theTable.addItem(app.getErrorString(All_layers));


	self.doClearTopDrawingFrame(false); // PAR 30924


	foreach obj in self.myROROPlanDrawController.allBackFrames reversed, discreteLock do
		layerFrame := obj.CMUI_PointDrawingFrame;
		layer := layerFrame.userObject.CM_DeckLayerLayout;
		if self.modeView = ShpDisplayMode_Defn then
			if layer.type = ROROLayerType_CCDischarge 
			or layer.type = ROROLayerType_CCLoad
			or layer.type = ROROLayerType_GC then
				layerFrame.visible := false;
				layerFrame.zOrder(0);
				continue;
			endif;
		endif;
		if self.modeView = ShpDisplayMode_Actual then
			if layer.type = ROROLayerType_CCDischarge 
			or layer.type = ROROLayerType_CCLoad then
				layerFrame.visible := false;
				layerFrame.zOrder(0);
				continue;
			endif;
		endif;
		if self.modeView = ShpDisplayMode_Proposed then
			if layer.type = ROROLayerType_CCDischarge then
				layerFrame.visible := false;
				layerFrame.zOrder(0);
				continue;
			endif;
		endif;
		layerFrame.visible := true;

		self.doDrawLayer(layerFrame, self.frmDeck.myDrawingFrame.CMUI_PointDrawingFrame);
		layerFrame.zOrder(1);
		
		
		// ### ADD LAYER TO LAYER LIST
		if layer.isVisible and layer.type &lt;&gt; ROROLayerType_Structure then
			idx := theTable.addItem(app.getROROLayerTypeString(layer.type));
			theTable.accessRow(idx).itemObject := layer;
		endif;


	endforeach;
	
	self.doDrawLabelH();
	self.doDrawLabelV();
	
	if theTable.row &gt;= 1 then

		theTable.accessRow(1).selected := true;
		self.doTblLayerClick();
	endif;
	
	self.repositionAllBackFrames();
	if self.addPillarsToTopFrame() then
		self.frmDeck.myDrawingFrame.CMUI_PointDrawingFrame.drawAllPolygons(White);
	endif;
	

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doDrawRemarks" id="ce05720b-1c5a-47d1-8b41-fb2000adcbf8">
        <updating/>
        <source>doDrawRemarks(_graphic : CM_DeckItemLayout) updating, protected;
/*
Date		Who		Reason
25 Jul 2012	cnwcs5	Initial creation - par 29124
20 Aug 2012	cnwcs5	par 29124:2 - fix up layout remarks
*/
vars
	pic 		: Picture;
	text, str	: String;
	deckItem	: CM_DeckItem;
	index		: Integer;
	left, top	: Real;
begin 
	text := _graphic.getROROLayoutRemarks;
	
	if text = null then 
		return;
	endif;
	
	if not self.getPositionForRemarks (_graphic, left, top) then
		return;
	endif;
	
	// each icon will have a unique index - we will use the same index for the remarks moveable frame as well
	index	:= self.lastIndexForRemarks + 1;
	pic 	:= self.picRemarks.loadControl (index).Picture;
	// save off last index used
	self.lastIndexForRemarks	:= index;
	
	self.allRemarksControls.add(pic);
	
	pic.parent 		:= self.frmDeck.myDrawingFrame;	
	pic.bubbleHelp 	:= _graphic.code &amp; CrLf &amp; text;		// par 29124:2 Aug 2012
	pic.userObject 	:= _graphic;
	
	pic.left 		:= left;
	pic.top 		:= top;
	pic.visible 	:= true;
	
	pic.zOrder(1);
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_graphic" type="CM_DeckItemLayout"/>
    </JadeMethod>
    <JadeMethod name="doDrawSections" id="d4dd7937-568d-4f38-affe-30f67cdef6e4">
        <source>doDrawSections(_hFrame : Frame; _scale : Decimal);
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	section : CM_VesselSection;
	frame : Frame;
	xSect, scale : Decimal[12,4];
	x1,y1,x2,y2 : Real;
begin
	if self.myCurrentRORO = null then
		return;
	endif;

	frame := _hFrame;
	scale := _scale;
//	frame.clearGraphics();
	foreach section in self.myCurrentRORO.myVoyage.myStructuralElements.allSectionsByPosition discreteLock do
		frame.drawTextAlign := Frame.DrawTextAlign_Left;
		frame.drawWidth := 2;
		xSect := (section.position * ROROStructurePixelsPerMetre) + ROROStructureRearLine;
		

		x1 := (xSect * scale);
		y1 := 30; 
		x2 := (xSect * scale);
		y2 := 40; 
		frame.drawLine(x1,y1,x2,y2 ,Black);
		
		x1 := ((xSect * scale) + 5);
		y1 := 32; 
		frame.drawTextAt(section.code,x1,y1,Black);
	
	endforeach;
	
epilog

end;</source>
        <Parameter name="_hFrame" type="Frame"/>
        <Parameter name="_scale" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="doDrawSelectObject" id="cc714580-2e8f-4b64-8cf6-e2fab9a5e113">
        <updating/>
        <source>doDrawSelectObject(_isMultiSelect : Boolean) updating; 
/*
Purpose:	This draws the SELECTION		
Date				Who			Reason
APRIL 2011		CNWAB1		Initial creation
*/

vars
begin
	self.backFrameIndex := 0;

	self.frmDeck.myDrawingFrame.CMUI_PointDrawingFrame.setCurrentPoint(null);// PAR 28920
	
	if  self.modeView = ShpDisplayMode_ColCodeDisch then
		self.doDrawSelectObjectCCDischarge(_isMultiSelect);		//cnwmc5 - 26 Nov 2013 - PAR 32697
	elseif self.modeView = ShpDisplayMode_ColCodeLoad then
		self.doDrawSelectObjectCCLoad(_isMultiSelect);			//cnwmc5 - 26 Nov 2013 - PAR 32697
	elseif self.modeView = ShpDisplayMode_Actual then
		self.doDrawSelectObjectActual(_isMultiSelect);			//cnwmc5 - 26 Nov 2013 - PAR 32697
	elseif self.modeView = ShpDisplayMode_Proposed then // PAR 28990	//cnwmc5 - 26 Nov 2013 - PAR 32697
		self.doDrawSelectObjectProposed(_isMultiSelect);		//cnwmc5 - 26 Nov 2013 - PAR 32697
	elseif self.modeView = ShpDisplayMode_Defn then
		self.doDrawSelectObjectDefn(_isMultiSelect);			//cnwmc5 - 26 Nov 2013 - PAR 32697

	endif;

epilog
end;</source>
        <Parameter name="_isMultiSelect" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDrawSelectObjectActual" id="01948f0e-89de-4f8a-bd70-232fea6be1a5">
        <updating/>
        <source>doDrawSelectObjectActual(_isMultiSelect : Boolean) updating; 
/*
Purpose:	This draws the SELECTION		
Date				Who			Reason
APRIL 2011		CNWAB1		Initial creation
*/

vars
	theFrame, layerFrame : CMUI_PointDrawingFrame;
	deckItemLayout, pxyLayout : CM_DeckItemLayout;
	deckLayer : CM_DeckLayerLayout;
	theSDF : CMUI_ScrollableDrawingFrame;
	allTIs : ObjectArray;
	numTier : Integer;
	tmpPoints : PointArray;
	aTI : CM_TrackedItem;
	aftLocn : CM_ROROLocnDefn;
	area : Decimal[12,4];
	lcs: CM_LCSet;
	aReq : CM_RORORequest;
	tmpObj, objectIRepresent : Object;
	slotDefn : CM_ROROSlotDefn;
	theJob : CM_VoyageJob;
	theJobLC : CM_VoyageROROController;
	altKey : Boolean;
	selectedColour : Integer;
	tmpCaption : String;
	invalidObject : Boolean;
	edition : Integer;
begin
	if  self.modeView &lt;&gt; ShpDisplayMode_Actual then
		return;
	endif;

	theSDF := self.frmDeck;
	theFrame := theSDF.myDrawingFrame.CMUI_PointDrawingFrame;
	deckItemLayout := self.myCurrentItemLayout;
	selectedColour := Gray;
	//cnwmc5 - par 29952 - changed the font of a selected object.
	theFrame.drawFontName := Font_MicrosoftSansSerif;
	
	if deckItemLayout = null then
		self.doClearTopDrawingFrame(true);

		return;
	endif;
	
	//11 Sep 2014	NDL	Par 34827
	on Exception do app.handleDeletedObject( exception, deckItemLayout, invalidObject );
	edition := deckItemLayout.edition;
	if invalidObject then
		self.doClearTopDrawingFrame(true);
		return;
	endif;
	
//	if self.myROROPlanDrawController.allSelectedObjects.includes(deckItemLayout.getObjectIRepresent()) then
//		self.myROROPlanDrawController.deselectObject(deckItemLayout.getObjectIRepresent(), true);
//	else
		// JOB MODE, select all the slots for the same job
		objectIRepresent := deckItemLayout.getObjectIRepresent();
		self.myROROPlanDrawController.selectObject(objectIRepresent, false, altKey);
		if objectIRepresent.isKindOf(CM_ROROLocnDefnVoyage) then
			tmpObj := objectIRepresent.CM_ROROLocnDefnVoyage.getAftLCFor40(REAL_MODE);
			if tmpObj &lt;&gt; null then
				self.myROROPlanDrawController.selectObject(tmpObj, false, altKey);
			endif;
		endif;
	if objectIRepresent.isKindOf(CM_DeckItem) then
		tmpCaption := objectIRepresent.CM_DeckItem.getCargoDetails(ShpDisplayMode_Actual, self.modeView, self.myROROPlanDrawController.modeViewSubSub);     // 05/09/2012 cnwmh5 30332	// #31367
		self.frmStatus.myFrameCaption.caption := tmpCaption;
	endif;

	
//	process.debugAKB();




	
	deckLayer := deckItemLayout.myDeckLayer;
	// ### REGISTER FOR NOTES
	self.beginNotification(deckItemLayout, EVENT_RORO_ITEM_SELECT, Response_Continuous, null);

	self.lblArea.caption:=deckItemLayout.getAreaInSquareMetresDisplay;
	
	// we make these transparent so that the other polygons for this terminal can be seen underneath
	if theFrame.mode &lt;&gt; theFrame.Mode_MultiSelect then
		theFrame.mode := CMUI_PointDrawingFrame.Mode_LineAlter; 
	endif;
	theFrame.transparent := true;
	
	
	if theFrame.mode &lt;&gt; theFrame.Mode_MultiSelect 
	and ((self.myCurrentLayer &lt;&gt; null and self.myCurrentLayer.type &lt;&gt; ROROLayerType_GC) or self.myCurrentLayer = null) then

		self.doClearTopDrawingFrame(true);
	endif;
	theFrame.enabled := true;
	theSDF.transparent := true;
 	

	
	theFrame.showText := (self.modeView = ShpDisplayMode_Defn and  self.optText.value);
	theFrame.doPointArrayAdd(Black,true, Frame.DrawFillStyle_Solid, 1, selectedColour, deckItemLayout);
	self.addPillarsToTopFrame();
	
	//cnwmc5 - 26 Nov 2013 - PAR 32697
	if not _isMultiSelect then
		self.myROROPlanDrawController.getAllPolygonsActual(theFrame,deckLayer, Black); // PAR 30373 changed to Black
	endif;
	
	theFrame.showText := false;

	// this draws all the polygons on the background frame, makes it easier to line up what you are drawing
	
	 // PAR 27749. do not do this for container layers as the drawing of selecting takes the container graphic off the container layer and redraws the whole layer each time.
	 //					container positions cannot be moved so do not need to remove from container layer.
	 //					However GC and OOTL can be moved
//	if self.myCurrentLayer &lt;&gt; null and (self.myCurrentLayer.type = ROROLayerType_GC or self.myCurrentLayer.type = ROROLayerType_OOTL or self.myCurrentLayer.type = ROROLayerType_CCLoad) then
	if deckLayer &lt;&gt; null and deckLayer.isPlanningRedrawable() then
//PAR 28318		if self.myCurrentLayer = null then
//PAR 28318			self.myCurrentLayer := deckLayer;
//PAR 28318		endif;
		self.doDrawLayerForLayer(deckLayer); //PAR 28318
		//PAR 28318self.doDrawCurrentLayer();
	endif;
	

epilog
	delete allTIs;
	delete tmpPoints;
	delete lcs;
end;</source>
        <Parameter name="_isMultiSelect" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDrawSelectObjectCCDischarge" id="29be4a3a-52f3-4352-97d5-976a1fa3c12f">
        <updating/>
        <source>doDrawSelectObjectCCDischarge(_isMultiSelect : Boolean) updating; 
/*
Purpose:	This draws the SELECTION		
Date				Who			Reason
APRIL 2011		CNWAB1		Initial creation
*/

vars
	theFrame : CMUI_PointDrawingFrame;
	deckItemLayout : CM_DeckItemLayout;
	locnDefn : CM_ROROLocnDefnVoyage;
	deckItem : CM_DeckItem;
	deckLayer : CM_DeckLayerLayout;
	theSDF : CMUI_ScrollableDrawingFrame;
	allTIs : ObjectArray;
	tmpPoints : PointArray;
	aftLocn : CM_ROROLocnDefn;
	lcs: CM_LCSet;
	aReq : CM_RORORequest;
	objectIRepresent, tmpObj : Object;
	slotDefn : CM_ROROSlotDefn;
	theJob : CM_VoyageJob;
	theJobLC : CM_VoyageROROController;
	is40, altKey : Boolean;
	selectedColour : Integer;
	statusCaption : String;
	getReq, invalidObj : Boolean;
begin
	if  self.modeView &lt;&gt; ShpDisplayMode_ColCodeDisch then
		return;
	endif;

	on Exception do app.handleDeletedObject(exception, deckItemLayout, invalidObj ); // PAR 37204

	theSDF := self.frmDeck;
	theFrame := theSDF.myDrawingFrame.CMUI_PointDrawingFrame;
	deckItemLayout := self.myCurrentItemLayout;
	selectedColour := Gray;
	//cnwmc5 - par 29952 - changed the font of a selected object.
	theFrame.drawFontName := Font_MicrosoftSansSerif;
	altKey := app.isAltKeyDown();
	if altKey then
		selectedColour := DarkGray;
	endif;
	
	if deckItemLayout = null then
		self.doClearTopDrawingFrame(true);

		return;
	endif;

	
//	if self.myROROPlanDrawController.allSelectedObjects.includes(deckItemLayout.getObjectIRepresent()) then
//		self.myROROPlanDrawController.deselectObject(deckItemLayout.getObjectIRepresent(), true);
//	else
		// JOB MODE, select all the slots for the same job
	objectIRepresent := deckItemLayout.getObjectIRepresent();
	if invalidObj then // PAR 37204
		self.myCurrentItemLayout := null; // PAR 37204
		objectIRepresent := null; // PAR 37204
		return; // PAR 37204
	endif;


	if objectIRepresent.isKindOf(CM_RORORequest) then
		aReq := objectIRepresent.CM_RORORequest;
		
		// PAR 32158 select the allocation in the palette
		if self.myCCPaletteLoad &lt;&gt; null then
			self.myCCPaletteLoad.selectVoyageAllocationRow(aReq.getFirstAllocation());
		endif;
		if self.myCCPalette &lt;&gt; null then
			self.myCCPalette.selectVoyageAllocationRow(aReq.getFirstAllocation());
		endif;
		
	//	is40 := (aReq.getAttrIs40() or aReq.getAttrIs30() or aReq.getAttrIs45() or aReq.getAttrIs53()); // PAR 30022 
		is40 := aReq.getAttrIsNOT20(); // PAR 30253
		if is40  // PAR 30022 
	//	if aReq.getAttrIs40 
		and not aReq.isBackEndRequest() then
			aftLocn := aReq.getAftLocnDefn();
		endif;
		
		deckItem := aReq.myROROController.getDefn(); // PAR 28336
		if deckItem.isKindOf(CM_ROROLocnDefnVoyage) then // PAR 31652
			locnDefn := deckItem.CM_ROROLocnDefnVoyage; // PAR 31652
		endif;
		
		if aftLocn = null then																// 26/07/2012 cnwmh5 #30091
			if deckItem.isKindOf(CM_ROROLocnDefnVoyage) then
				aftLocn := deckItem.CM_ROROLocnDefnVoyage.getDefnFor40RemainOnBoard();
			endif;	 
		endif;
		
		if self.modeWork = self.WorkMode_Plan then
			// PAR 28336
			if deckItem &lt;&gt; null then
				aReq := deckItem.getFirstUnplannedRequest(false);
				if aReq = null then
					aReq := objectIRepresent.CM_RORORequest;
				endif;
				
				if aReq &lt;&gt; null then
					app.myDraggedTrackedItem := aReq.getFirstUnplannedTI();
				endif;
			
				if app.myDraggedTrackedItem &lt;&gt; null then
					delete app.myMoveController;
					create app.myMoveController transient;
					app.myMoveController.myVoyageRequest := aReq;
					app.myMoveController.setMyTrackedItem(app.myDraggedTrackedItem);
					app.myMoveController.setMoveMode(PLANNING_MODE);
				endif;
			endif;
		endif;

		
		if locnDefn &lt;&gt; null then // PAR 31652
			self.myROROPlanDrawController.selectObject(locnDefn, false, altKey); // PAR 31652
		endif;
		if aftLocn &lt;&gt; null then
			self.myROROPlanDrawController.selectObject(aftLocn, false, altKey);
		endif;
		// get the request's locn, then get all the requests for this locn
		 if deckItem &lt;&gt; null then
			statusCaption := statusCaption &amp; deckItem.code &amp; " ";
			statusCaption := statusCaption &amp; deckItem.getCargoDetails(ShpDisplayMode_Actual, self.modeView, self.myROROPlanDrawController.modeViewSubSub) &amp; " ";		 // PAR 29298  29398  // 05/09/2012 cnwmh5 #30332    // #31367
			
			if deckItem.isLocnContainer() then
				locnDefn := deckItem.CM_ROROLocnDefnVoyage;
				foreach slotDefn in locnDefn.allROROSlotDefnByOrdinal  reversed, discreteLock do
					if self.myROROPlanDrawController.modeViewSubSub = ShpDisplayModeSub_ExportsHide then // PAR 31366
						aReq := slotDefn.CM_ROROSlotDefnVoyage.mySlotController.myRORORequestDischarge ;
					else
						aReq := slotDefn.CM_ROROSlotDefnVoyage.mySlotController.myRORORequestLoad; // PAR 31366
						if aReq &lt;&gt; null then
							deckItemLayout := aReq.myLayout; // PAR 31366
						endif;
						deckItemLayout := slotDefn.CM_ROROSlotDefnVoyage.myROROLocnDen.myLayout; // PAR 31366
					endif;
					if aReq &lt;&gt; null then
						self.myROROPlanDrawController.selectObject(aReq, false, altKey);
						if theJob = null and aReq.myJob &lt;&gt; null then
							theJob := aReq.myJob.CM_VoyageJob;
							theJobLC := aReq.myROROController;
						endif;
					endif;
				endforeach;
			elseif  deckItem.isLocnGC() then
				if aReq &lt;&gt; null then
					self.myROROPlanDrawController.selectObject(aReq, false, altKey);
					if theJob = null and aReq.myJob &lt;&gt; null then
						theJob := aReq.myJob.CM_VoyageJob;
						theJobLC := aReq.myROROController;
					endif;
				endif;
			elseif  deckItem.isLocnLanePosition() then
				if aReq &lt;&gt; null then
					self.myROROPlanDrawController.selectObject(aReq, false, altKey);
					if theJob = null and aReq.myJob &lt;&gt; null then
						theJob := aReq.myJob.CM_VoyageJob;
						theJobLC := aReq.myROROController;
					endif;
				endif;
			endif;
		endif;
	elseif objectIRepresent.isKindOf(CM_ROROLocnDefnVoyage) then
		self.myROROPlanDrawController.selectObject(objectIRepresent, false, altKey);
		locnDefn := objectIRepresent.CM_ROROLocnDefnVoyage;
		
		statusCaption := statusCaption &amp; locnDefn.code &amp; " ";
		statusCaption := statusCaption &amp; objectIRepresent.CM_ROROLocnDefnVoyage.getCargoDetails(ShpDisplayMode_Actual, self.modeView, 
			self.myROROPlanDrawController.modeViewSubSub) &amp; " ";		 // PAR 29298   // 05/09/2012 cnwmh5 #30332	// #31367
		
		getReq := true; // PAR 31118
		if self.modeView = ShpDisplayMode_ColCodeDisch then // PAR 31118
			if self.myROROPlanDrawController.modeViewSubSub = ShpDisplayModeSub_ExportsShow then // PAR 31118
				if locnDefn.hasTIs40Loaded(REAL_MODE, false, true) then  // PAR 31118 31162 added new parameter
					getReq := false;
				endif;
			endif;
		endif;
	
		if  getReq  then
			if self.myROROPlanDrawController.modeViewSubSub = ShpDisplayModeSub_ExportsHide then // PAR 31366
				aReq := locnDefn.getFirst40Request(false);
			endif;
		endif;
		
		//epr par 31936 18/7/13
		if aReq = null  and self.myROROPlanDrawController.modeViewSubSub = ShpDisplayModeSub_ExportsHide then 
			aReq := locnDefn.getFirstRequest(false);
			aftLocn := locnDefn.getAftLCFor40(REAL_MODE);
			if aReq = null and aftLocn &lt;&gt; null then
				aReq := aftLocn.getFirstRequest(false);
			endif;
		endif;
		
		if aReq &lt;&gt; null then
			//epr par 31936 18/7/13
			if aReq.isKindOf(CM_ROROSlotRequest) then
				deckItemLayout:=aReq.myLayout;
			endif;
			
			if aReq.isBackEndRequest() then
				return;
			endif;
			
			if aftLocn &lt;&gt; null then
				self.myROROPlanDrawController.selectObject(aftLocn, false, altKey);
			endif;
		else // PAR 29005
			tmpObj := objectIRepresent.CM_ROROLocnDefnVoyage.getAftLCFor40(REAL_MODE);
			if tmpObj &lt;&gt; null then
				self.myROROPlanDrawController.selectObject(tmpObj, false, altKey);
			endif;
		endif;
	elseif objectIRepresent.isKindOf(CM_ROROGCDefnVoyage) then
		self.myROROPlanDrawController.selectObject(objectIRepresent, false, altKey);
		statusCaption := statusCaption &amp; objectIRepresent.CM_ROROGCDefnVoyage.code &amp; " ";
		statusCaption := statusCaption &amp; objectIRepresent.CM_ROROGCDefnVoyage.getCargoDetails(ShpDisplayMode_Actual, self.modeView, 
			self.myROROPlanDrawController.modeViewSubSub) &amp; " ";		 // PAR 29298	// 05/09/2012 cnwmh5 #30332     // #31367
	elseif objectIRepresent.isKindOf(CM_ROROLaneDefnVoyage) then
		self.myROROPlanDrawController.selectObject(objectIRepresent, false, altKey);
		statusCaption := statusCaption &amp; objectIRepresent.CM_ROROLaneDefnVoyage.code &amp; " ";
		statusCaption := statusCaption &amp; objectIRepresent.CM_ROROLaneDefnVoyage.getCargoDetails(ShpDisplayMode_Actual, self.modeView, 
			self.myROROPlanDrawController.modeViewSubSub) &amp; " ";		 // PAR 29298	// 05/09/2012 cnwmh5 #30332		// #31367
	elseif objectIRepresent.isKindOf(CM_ROROLanePositionDefn) then
		self.myROROPlanDrawController.selectObject(objectIRepresent, false, altKey);
		statusCaption := statusCaption &amp; objectIRepresent.CM_ROROLanePositionDefn.code &amp; " ";
		statusCaption := statusCaption &amp; objectIRepresent.CM_ROROLanePositionDefn.getCargoDetails(ShpDisplayMode_Actual, self.modeView, 
			self.myROROPlanDrawController.modeViewSubSub) &amp; " ";		 // PAR 29298	// 05/09/2012 cnwmh5 #30332		// #31367

	endif;
	
	if self.modeWork = WorkMode_Plan then
		if aReq &lt;&gt; null then
			self.setUpPlannedToLCs(aReq);

		endif;
	elseif self.modeWork = self.WorkMode_Job then
		if deckItemLayout.isKindOf(CM_RORORequestLayout) then
			if theJob &lt;&gt; null then //aReq.myJob &lt;&gt; null then
				self.doClearTopDrawingFrame(true);
				if theJob &lt;&gt; null then 
					statusCaption := statusCaption &amp;  app.getErrorString(Job) &amp; ": " &amp; theJob.jobNum &amp; " ";
				endif;
				self.myROROPlanDrawController.selectSlotsForJob(theJobLC); //aReq.myROROController);
				if self.mySideViewForm &lt;&gt; null then
					self.mySideViewForm.myROROLocnDrawingController.selectObjectsForJob(theJob, false, true);
				endif;
				self.doSetJobComboForClick(theJob);
				self.frmStatus.myFrameCaption.caption := statusCaption;
				return;
			else
				//epr par 29098
				self.cmbWorkPoint.listIndex := -1;
				self.cmbWPJob.listIndex := -1;
				self.myCurrentJob := null; // PAR 31652
			endif;
		endif;
	else
		if theJob &lt;&gt; null then 
			statusCaption := statusCaption &amp;  app.getErrorString(Job) &amp; ": " &amp; theJob.jobNum &amp; " ";
		endif;

	endif;
	
	
	deckLayer := deckItemLayout.myDeckLayer;
	// ### REGISTER FOR NOTES
	self.beginNotification(deckItemLayout, EVENT_RORO_ITEM_SELECT, Response_Continuous, null);

	self.lblArea.caption:=deckItemLayout.getAreaInSquareMetresDisplay();
	
	// we make these transparent so that the other polygons for this terminal can be seen underneath
	if theFrame.mode &lt;&gt; theFrame.Mode_MultiSelect then
		theFrame.mode := CMUI_PointDrawingFrame.Mode_LineAlter; 
	endif;
	theFrame.transparent := true;
	
	
	if theFrame.mode &lt;&gt; theFrame.Mode_MultiSelect 
	and ((self.myCurrentLayer &lt;&gt; null and self.myCurrentLayer.type &lt;&gt; ROROLayerType_GC) or self.myCurrentLayer = null) then

		self.doClearTopDrawingFrame(true );
	endif;
	theFrame.enabled := true;
	theSDF.transparent := true;
 	
	
	theFrame.doPointArrayAdd(Black,true, Frame.DrawFillStyle_Solid, 1, selectedColour, deckItemLayout);
	
	//cnwmc5 - 26 Nov 2013 - PAR 32697
	if not _isMultiSelect then
		self.myROROPlanDrawController.getAllPolygonsColourCoding(theFrame,null,false, White);
	endif;

	theFrame.showText := false;

	// this draws all the polygons on the background frame, makes it easier to line up what you are drawing
	
	 // PAR 27749. do not do this for container layers as the drawing of selecting takes the container graphic off the container layer and redraws the whole layer each time.
	 //					container positions cannot be moved so do not need to remove from container layer.
	 //					However GC and OOTL can be moved
	if deckLayer &lt;&gt; null and deckLayer.isPlanningRedrawable() then
		if self.myCurrentLayer = null then
			self.myCurrentLayer := deckLayer;
		endif;
		self.doDrawCurrentLayer();
	endif;

	self.frmStatus.myFrameCaption.caption := statusCaption;
	

epilog
	delete allTIs;
	delete tmpPoints;
	delete lcs;
end;</source>
        <Parameter name="_isMultiSelect" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDrawSelectObjectCCLoad" id="8b69d875-99b7-482c-a33a-9408ca7d0c54">
        <updating/>
        <source>doDrawSelectObjectCCLoad(_isMultiSelect : Boolean) updating; 
/*
Purpose:	This draws the SELECTION		
Date				Who			Reason
APRIL 2011		CNWAB1		Initial creation
16 Apr 2012 	cnwer1	 	PAR 29406
*/

vars
	theFrame : CMUI_PointDrawingFrame;
	deckItemLayout : CM_DeckItemLayout;
	locnDefn : CM_ROROLocnDefnVoyage;
	deckItem : CM_DeckItem;
	deckLayer : CM_DeckLayerLayout;
	theSDF : CMUI_ScrollableDrawingFrame;
	allTIs : ObjectArray;
	tmpPoints : PointArray;
	aftLocn : CM_ROROLocnDefn;
	lcs: CM_LCSet;
	aReq,
	nonPlannedReq,
	tmpReq: CM_RORORequest;
	objectIRepresent, tmpObj : Object;
	slotDefn : CM_ROROSlotDefn;
	theJob : CM_VoyageJob;
	theJobLC : CM_VoyageROROController;
	altKey, is40 : Boolean;
	selectedColour : Integer;
	statusCaption : String;
	doRedrawLayer : Boolean;
	invalid : Boolean;
begin

	if  self.modeView &lt;&gt; ShpDisplayMode_ColCodeLoad then
		return;
	endif;

	on Exception do app.handleDeletedObject(exception, deckItemLayout, invalid);
	
	theSDF := self.frmDeck;
	theFrame := theSDF.myDrawingFrame.CMUI_PointDrawingFrame;
	deckItemLayout := self.myCurrentItemLayout;
	selectedColour := Gray;
	//cnwmc5 - par 29952 - changed the font of a selected object.
	theFrame.drawFontName := Font_MicrosoftSansSerif;
	altKey := app.isAltKeyDown();
	if altKey then
		selectedColour := DarkGray;
	endif;
	
	if deckItemLayout = null then
		self.doClearTopDrawingFrame(true);
		return;
	endif;

		// JOB MODE, select all the slots for the same job
	objectIRepresent := deckItemLayout.getObjectIRepresent();
	
	// PAR 29884
	if invalid then
		self.myCurrentItemLayout := null;
		objectIRepresent := null;
		return;
	endif;
	
	if objectIRepresent.isKindOf(CM_RORORequest) then

		aReq := objectIRepresent.CM_RORORequest;
		
		// PAR 32158 select the allocation in the palette
		if self.myCCPaletteLoad &lt;&gt; null then
			self.myCCPaletteLoad.selectVoyageAllocationRow(aReq.getFirstAllocation());
		endif;
		if self.myCCPalette &lt;&gt; null then
			self.myCCPalette.selectVoyageAllocationRow(aReq.getFirstAllocation());
		endif;
		
		is40 := aReq.getAttrIsNOT20(); // PAR 30253
		if is40  // PAR 30022 
		and not aReq.isBackEndRequest() then
			aftLocn := aReq.getAftLocnDefn();
		endif;
		if aftLocn &lt;&gt; null then
			self.myROROPlanDrawController.selectObject(aftLocn, false, altKey);
		endif;
		// get the request's locn, then get all the requests for this locn
		 deckItem := aReq.myROROController.getDefn();
		 if deckItem &lt;&gt; null then
			statusCaption := statusCaption &amp; deckItem.code &amp; " ";
			statusCaption := statusCaption &amp; deckItem.getCargoDetails(ShpDisplayMode_Proposed, self.modeView, self.myROROPlanDrawController.modeViewSubSub) &amp; " ";		 // PAR 29298  29398    // 30332    // #31367
			
			if deckItem.isLocnContainer() then
				locnDefn := deckItem.CM_ROROLocnDefnVoyage;
				
				//cnwrd1 par 31771 for now we disable val/loos for gc so we enable ot for containers
				self.chkOutOfSequence.value := self.myCurrentVoyage.createOutOfSequenceLoadJobs();
				self.chkOutOfSequence.enabled := true;
		
				doRedrawLayer := locnDefn.isOOTL(); // PAR 28746
				
				//epr par 29406 help with the load plan on yard forms select req that has not been planned yet
				nonPlannedReq:=null;
				foreach slotDefn in locnDefn.allROROSlotDefnByOrdinal  discreteLock do
					tmpReq := slotDefn.CM_ROROSlotDefnVoyage.mySlotController.myRORORequestLoad ;
					if tmpReq &lt;&gt; null then
						if tmpReq.isSOB then // PAR 33860 ignore load SOB in jobs.
							self.myROROPlanDrawController.selectObject(locnDefn, false, altKey); // PAR 33971 - ignore the SOB request, but select the location
							continue;
						endif;
						if nonPlannedReq = null and tmpReq.getTrackedItem = null then
							nonPlannedReq:=tmpReq;
						endif;
						self.myROROPlanDrawController.selectObject(tmpReq, false, altKey);
						if theJob = null and tmpReq.myJob &lt;&gt; null then
							theJob := tmpReq.myJob.CM_VoyageJob;
							theJobLC := tmpReq.myROROController;
						endif;
					endif;
				endforeach;
				
				if nonPlannedReq &lt;&gt;  null then
					aReq:= nonPlannedReq;
				endif;
			elseif  deckItem.isLocnGC() then
				//cnwrd1 par 31771 for now we disable val/loos for gc so we enable ot for containers
				self.chkOutOfSequence.value := false;
				self.chkOutOfSequence.enabled := false;
				
				doRedrawLayer := true; // PAR 28746
				
				if aReq &lt;&gt; null then
					self.myROROPlanDrawController.selectObject(aReq, false, altKey);
					if theJob = null and aReq.myJob &lt;&gt; null then
						theJob := aReq.myJob.CM_VoyageJob;
						theJobLC := aReq.myROROController;
					endif;
				endif;
			elseif  deckItem.isLocnLane() then
				
				doRedrawLayer := true; // PAR 28746
				
				if aReq &lt;&gt; null then
					self.myROROPlanDrawController.selectObject(aReq, false, altKey);
					if theJob = null and aReq.myJob &lt;&gt; null then
						theJob := aReq.myJob.CM_VoyageJob;
						theJobLC := aReq.myROROController;
					endif;
				endif;
			endif;
		endif;
	elseif objectIRepresent.isKindOf(CM_ROROLocnDefnVoyage) then
		locnDefn := objectIRepresent.CM_ROROLocnDefnVoyage;
		
		doRedrawLayer := locnDefn.isOOTL(); // PAR 28746
		// PAR 28336
		if not locnDefn.myLayout.isSelectableByMode(ShpDisplayMode_ColCodeLoad) then
			return;
		endif;
		self.myROROPlanDrawController.selectObject(objectIRepresent, false, altKey);
		// PAR 29298statusCaption := statusCaption &amp; locnDefn.getCargoDetails(ShpDisplayMode_Actual) &amp; " "; // PAR 28990
		statusCaption := statusCaption &amp; locnDefn.getCargoDetails(ShpDisplayMode_Proposed, self.modeView, self.myROROPlanDrawController.modeViewSubSub) &amp; " ";		 // PAR 29298   // 30332   // 31367
		// PAR 29006 select the aft if there is no load CC but there are actual 40 cargo
		tmpObj := objectIRepresent.CM_ROROLocnDefnVoyage.getAftLCFor40(REAL_MODE);
		if tmpObj &lt;&gt; null then
			self.myROROPlanDrawController.selectObject(tmpObj, false, altKey);
		endif;
		
		//epr TFS 3594 26/5/17 
		aReq := locnDefn.getFirst40Request(true);
		if aReq = null then
			aReq:=locnDefn.getFirstRequest(true);
			
			if aReq = null then
				aftLocn:=locnDefn.getAftLCFor40(REAL_MODE);
				if aftLocn &lt;&gt; null then
					aReq := aftLocn.getFirstRequest(true);
				endif;
			endif;
		endif;
		
		if aReq &lt;&gt; null then
			//epr par 31936 18/7/13
			if aReq.isKindOf(CM_ROROSlotRequest) then
				deckItemLayout:=aReq.myLayout;
			endif;
			
			if aReq.isBackEndRequest() then
				return;
			endif;
			
			if aftLocn &lt;&gt; null then
				self.myROROPlanDrawController.selectObject(aftLocn, false, altKey);
			endif;
		endif;
	elseif objectIRepresent.isKindOf(CM_ROROGCDefnVoyage) then
		aReq:=objectIRepresent.CM_ROROGCDefnVoyage.getFirstRequest(true);
		if aReq &lt;&gt; null then
			doRedrawLayer := true; // PAR 28746
			self.myROROPlanDrawController.selectObject(aReq, false, altKey);
			//self.myROROPlanDrawController.drawReqInPolygon(aReq.myLayout,0,true);
			if theJob = null and aReq.myJob &lt;&gt; null then
				theJob := aReq.myJob.CM_VoyageJob;
				theJobLC := aReq.myROROController;
			endif;
		endif;
	elseif objectIRepresent.isKindOf(CM_DeckItem) then
		self.myROROPlanDrawController.selectObject(objectIRepresent, false, altKey);
		statusCaption := statusCaption &amp; objectIRepresent.CM_DeckItem.code &amp; " ";
		statusCaption := statusCaption &amp; objectIRepresent.CM_DeckItem.getCargoDetails(ShpDisplayMode_Proposed, self.modeView, self.myROROPlanDrawController.modeViewSubSub) &amp; " ";	// PAR 29298   // 30332   // #31367

	endif;
	
	if self.modeWork = WorkMode_Plan then
		if aReq &lt;&gt; null then
			self.setUpPlannedToLCs(aReq);

		endif;
	elseif self.modeWork = self.WorkMode_Job then
		if deckItemLayout.isKindOf(CM_RORORequestLayout) then
			if theJob &lt;&gt; null then //aReq.myJob &lt;&gt; null then
				self.doClearTopDrawingFrame(true);
				if theJob &lt;&gt; null then 
					statusCaption := statusCaption &amp;  app.getErrorString(Job) &amp; ": " &amp; theJob.jobNum &amp; " ";
				endif;
				self.myROROPlanDrawController.selectSlotsForJob(theJobLC);
				if self.mySideViewForm &lt;&gt; null then
					self.mySideViewForm.myROROLocnDrawingController.selectObjectsForJob(theJob, true, true);
				endif;
				self.doSetJobComboForClick(theJob);
				self.frmStatus.myFrameCaption.caption := statusCaption;
				return;
			else
				//epr par 29098
				self.cmbWorkPoint.listIndex := -1;
				self.cmbWPJob.listIndex := -1;
				self.myCurrentJob := null; // PAR 31652
			endif;
		endif;
	else
		if theJob &lt;&gt; null then 
			statusCaption := statusCaption &amp;  app.getErrorString(Job) &amp; ": " &amp; theJob.jobNum &amp; " ";
		endif;
	endif;
	
	deckLayer := deckItemLayout.myDeckLayer;
	// ### REGISTER FOR NOTES
	self.beginNotification(deckItemLayout, EVENT_RORO_ITEM_SELECT, Response_Continuous, null);
	self.lblArea.caption:=deckItemLayout.getAreaInSquareMetresDisplay();
	
	// we make these transparent so that the other polygons for this terminal can be seen underneath
	if theFrame.mode &lt;&gt; theFrame.Mode_MultiSelect then
		theFrame.mode := CMUI_PointDrawingFrame.Mode_LineAlter; 
	endif;
	theFrame.transparent := true;
	
// PAR 28920	
	if theFrame.mode &lt;&gt; theFrame.Mode_MultiSelect then
//	and ((self.myCurrentLayer &lt;&gt; null and self.myCurrentLayer.type &lt;&gt; ROROLayerType_GC) or self.myCurrentLayer = null) then
		self.doClearTopDrawingFrame(true);
		self.myROROPlanDrawController.selectObject(objectIRepresent, false, null);// PAR 28920	the clear top frame clears all selected, so re select the selected object that we are drawing
	endif;
	
	theFrame.enabled := true;
	theSDF.transparent := true;
 		
	theFrame.doPointArrayAdd(Black,true, Frame.DrawFillStyle_Solid, 1, selectedColour, deckItemLayout);
	
	//cnwmc5 - 26 Nov 2013 - PAR 32697
	if not _isMultiSelect  then
		self.myROROPlanDrawController.getAllPolygonsColourCoding(theFrame,null,true, Black); // PAR 30373 changed to Black
	endif;

	theFrame.showText := false;
	// this draws all the polygons on the background frame, makes it easier to line up what you are drawing
	
	 // PAR 27749. do not do this for container layers as the drawing of selecting takes the container graphic off the container layer and redraws the whole layer each time.
	 //					container positions cannot be moved so do not need to remove from container layer.
	 //					However GC and OOTL can be moved
	if deckLayer &lt;&gt; null and deckLayer.isPlanningRedrawable() and doRedrawLayer then // PAR 28746
		if self.myCurrentLayer = null then
			self.myCurrentLayer := deckLayer;
		endif;
		self.doDrawCurrentLayer();
		self.myCurrentLayer := null; // PAR 28920 noticed that could not move GC or OOTL load CC and it was because myCurrentLayer &lt;&gt; null and was being looked at in doFrameDrawSetCurrentGraphic
	endif;

	self.frmStatus.myFrameCaption.caption := statusCaption;
	

epilog
	delete allTIs;
	delete tmpPoints;
	delete lcs;
end;</source>
        <Parameter name="_isMultiSelect" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDrawSelectObjectDefn" id="4e0dfd85-095d-4790-8028-424ef683973e">
        <updating/>
        <source>doDrawSelectObjectDefn(_isMultiSelect : Boolean) updating; 
/*
Purpose:	This draws the SELECTION		
Date				Who			Reason
APRIL 2011		CNWAB1		Initial creation
*/

vars
	theFrame, layerFrame : CMUI_PointDrawingFrame;
	deckItemLayout, pxyLayout : CM_DeckItemLayout;
	deckLayer : CM_DeckLayerLayout;
	theSDF : CMUI_ScrollableDrawingFrame;
	allTIs : ObjectArray;
	numTier : Integer;
	tmpPoints : PointArray;
	aTI : CM_TrackedItem;
	aftLocn : CM_ROROLocnDefn;
	area : Decimal[12,4];
	lcs: CM_LCSet;
	aReq : CM_RORORequest;
	tmpObj, objectIRepresent : Object;
	slotDefn : CM_ROROSlotDefn;
	theJob : CM_VoyageJob;
	theJobLC : CM_VoyageROROController;
	altKey : Boolean;
	selectedColour : Integer;
begin
	if  self.modeView &lt;&gt; ShpDisplayMode_Defn then
		return;
	endif;


	theSDF := self.frmDeck;
	theFrame := theSDF.myDrawingFrame.CMUI_PointDrawingFrame;
	deckItemLayout := self.myCurrentItemLayout;
	selectedColour := Gray;
	//cnwmc5 - par 29952 - changed the font of a selected object.
	theFrame.drawFontName := Font_MicrosoftSansSerif;
	
	if deckItemLayout = null then
		self.doClearTopDrawingFrame(true);

		return;
	endif;

	
//	if self.myROROPlanDrawController.allSelectedObjects.includes(deckItemLayout.getObjectIRepresent()) then
//		self.myROROPlanDrawController.deselectObject(deckItemLayout.getObjectIRepresent(), true);
//	else
		// JOB MODE, select all the slots for the same job
		objectIRepresent := deckItemLayout.getObjectIRepresent();
		self.myROROPlanDrawController.selectObject(objectIRepresent, false, altKey);
		if objectIRepresent.isKindOf(CM_ROROLocnDefnVoyage) then
			tmpObj := objectIRepresent.CM_ROROLocnDefnVoyage.getAftLCFor40(REAL_MODE);
			if tmpObj &lt;&gt; null then
				self.myROROPlanDrawController.selectObject(tmpObj, false, altKey);
			endif;
			self.frmStatus.myFrameCaption.caption := objectIRepresent.CM_ROROLocnDefnVoyage.code &amp; objectIRepresent.CM_ROROLocnDefnVoyage.getStatusDescription();
		endif;

	
	
	deckLayer := deckItemLayout.myDeckLayer;
	// ### REGISTER FOR NOTES
	self.beginNotification(deckItemLayout, EVENT_RORO_ITEM_SELECT, Response_Continuous, null);

	self.lblArea.caption:=deckItemLayout.getAreaInSquareMetresDisplay();
	
	// we make these transparent so that the other polygons for this terminal can be seen underneath
	if theFrame.mode &lt;&gt; theFrame.Mode_MultiSelect then
		theFrame.mode := CMUI_PointDrawingFrame.Mode_LineAlter; 
	endif;
	theFrame.transparent := true;
	
	
	if theFrame.mode &lt;&gt; theFrame.Mode_MultiSelect 
	and ((self.myCurrentLayer &lt;&gt; null and self.myCurrentLayer.type &lt;&gt; ROROLayerType_GC) or self.myCurrentLayer = null) then

		self.doClearTopDrawingFrame(true);
	endif;
	theFrame.enabled := true;
	theSDF.transparent := true;
 	
	
	theFrame.showText := (self.modeView = ShpDisplayMode_Defn and  self.optText.value);
	theFrame.doPointArrayAdd(Black,true, Frame.DrawFillStyle_Solid, 1, selectedColour, deckItemLayout);
	self.addPillarsToTopFrame();
	
	//cnwmc5 - 26 Nov 2013 - PAR 32697
	if not _isMultiSelect then
		self.myROROPlanDrawController.getAllPolygonsActual(theFrame,deckLayer, Black); // PAR 30373 changed to Black
	endif;
	
	theFrame.showText := false;

	// this draws all the polygons on the background frame, makes it easier to line up what you are drawing
	
	 // PAR 27749. do not do this for container layers as the drawing of selecting takes the container graphic off the container layer and redraws the whole layer each time.
	 //					container positions cannot be moved so do not need to remove from container layer.
	 //					However GC and OOTL can be moved
//	if self.myCurrentLayer &lt;&gt; null and (self.myCurrentLayer.type = ROROLayerType_GC or self.myCurrentLayer.type = ROROLayerType_OOTL or self.myCurrentLayer.type = ROROLayerType_CCLoad) then
	if deckLayer &lt;&gt; null and deckLayer.isPlanningRedrawable() then
		if self.myCurrentLayer = null then
			self.myCurrentLayer := deckLayer;
		endif;
		self.doDrawCurrentLayer();
	endif;
	

epilog
	delete allTIs;
	delete tmpPoints;
	delete lcs;
end;</source>
        <Parameter name="_isMultiSelect" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDrawSelectObjectProposed" id="1644de8c-b58a-4737-b781-94124d7bf09a">
        <updating/>
        <source>doDrawSelectObjectProposed(_isMultiSelect : Boolean) updating; 
/*
Purpose:	28990		
Date				Who			Reason
FEBRUARY 2012		CNWAB1		Initial creation
*/

vars
	theFrame : CMUI_PointDrawingFrame;
	deckItemLayout : CM_DeckItemLayout;
	deckLayer : CM_DeckLayerLayout;
	theSDF : CMUI_ScrollableDrawingFrame;
	allTIs : ObjectArray;
	tmpPoints : PointArray;
	lcs: CM_LCSet;
	tmpObj, objectIRepresent : Object;
	altKey, invalidObj : Boolean;
	selectedColour : Integer;
begin
	if  self.modeView &lt;&gt; ShpDisplayMode_Proposed then
		return;
	endif;


	on Exception do app.handleDeletedObject(exception, deckItemLayout, invalidObj ); // PAR 37204

	theSDF := self.frmDeck;
	theFrame := theSDF.myDrawingFrame.CMUI_PointDrawingFrame;
	deckItemLayout := self.myCurrentItemLayout;
	selectedColour := Gray;
	//cnwmc5 - par 29952 - changed the font of a selected object.
	theFrame.drawFontName := Font_MicrosoftSansSerif;
	
	if deckItemLayout = null then
		self.doClearTopDrawingFrame(true);

		return;
	endif;

	
//	if self.myROROPlanDrawController.allSelectedObjects.includes(deckItemLayout.getObjectIRepresent()) then
//		self.myROROPlanDrawController.deselectObject(deckItemLayout.getObjectIRepresent(), true);
//	else
		// JOB MODE, select all the slots for the same job
	objectIRepresent := deckItemLayout.getObjectIRepresent();
	
	if invalidObj then // PAR 37204
		self.myCurrentItemLayout := null; // PAR 37204
		objectIRepresent := null; // PAR 37204
		return; // PAR 37204
	endif;
	
	self.myROROPlanDrawController.selectObject(objectIRepresent, false, altKey);
	if objectIRepresent.isKindOf(CM_ROROLocnDefnVoyage) then
		tmpObj := objectIRepresent.CM_ROROLocnDefnVoyage.getAftLCFor40Proposed();
		if tmpObj &lt;&gt; null then
			self.myROROPlanDrawController.selectObject(tmpObj, false, altKey);
		endif;
	endif;
	
	if objectIRepresent.isKindOf(CM_DeckItem) then
		self.frmStatus.myFrameCaption.caption := objectIRepresent.CM_DeckItem.getCargoDetails(ShpDisplayMode_Proposed, self.modeView, self.myROROPlanDrawController.modeViewSubSub);     // 30332	// #31367
	endif;
	
	
	deckLayer := deckItemLayout.myDeckLayer;
	// ### REGISTER FOR NOTES
	self.beginNotification(deckItemLayout, EVENT_RORO_ITEM_SELECT, Response_Continuous, null);

	self.lblArea.caption:=deckItemLayout.getAreaInSquareMetresDisplay();
	
	// we make these transparent so that the other polygons for this terminal can be seen underneath
	if theFrame.mode &lt;&gt; theFrame.Mode_MultiSelect then
		theFrame.mode := CMUI_PointDrawingFrame.Mode_LineAlter; 
	endif;
	theFrame.transparent := true;
	
	
	if theFrame.mode &lt;&gt; theFrame.Mode_MultiSelect 
	and ((self.myCurrentLayer &lt;&gt; null and self.myCurrentLayer.type &lt;&gt; ROROLayerType_GC) or self.myCurrentLayer = null) then

		self.doClearTopDrawingFrame(true);
	endif;
	theFrame.enabled := true;
	theSDF.transparent := true;
 	

	
	theFrame.showText := (self.modeView = ShpDisplayMode_Defn and  self.optText.value);
	theFrame.doPointArrayAdd(Black,true, Frame.DrawFillStyle_Solid, 1, selectedColour, deckItemLayout);
	self.addPillarsToTopFrame();
	
	//cnwmc5 - 26 Nov 2013 - PAR 32697
	if not _isMultiSelect then
		self.myROROPlanDrawController.getAllPolygonsProposed(theFrame,deckLayer, Black); // PAR 30373 changed to Black  //epr par 29978 19/7/12 was displaying actual in proposed mode
	endif;
	
	theFrame.showText := false;



	// this draws all the polygons on the background frame, makes it easier to line up what you are drawing
	
	 // PAR 27749. do not do this for container layers as the drawing of selecting takes the container graphic off the container layer and redraws the whole layer each time.
	 //					container positions cannot be moved so do not need to remove from container layer.
	 //					However GC and OOTL can be moved
//	if self.myCurrentLayer &lt;&gt; null and (self.myCurrentLayer.type = ROROLayerType_GC or self.myCurrentLayer.type = ROROLayerType_OOTL or self.myCurrentLayer.type = ROROLayerType_CCLoad) then
	if deckLayer &lt;&gt; null and deckLayer.isPlanningRedrawable() then
//PAR 28318		if self.myCurrentLayer = null then
//PAR 28318			self.myCurrentLayer := deckLayer;
//PAR 28318		endif;
		self.doDrawLayerForLayer(deckLayer); //PAR 28318
		//PAR 28318self.doDrawCurrentLayer();
	endif;
	

epilog
	delete allTIs;
	delete tmpPoints;
	delete lcs;
end;</source>
        <Parameter name="_isMultiSelect" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doDrawSelectObjectsForJob" id="ef29272f-31c8-4393-b698-82aaf477c042">
        <updating/>
        <source>doDrawSelectObjectsForJob(_job : CM_VoyageJob) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
25 June 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	statusCaption : String;
begin

	if _job = null then 
		return;
	endif;
	 //epr par 29608 26/6/12
	//	self.doClearTopDrawingFrame(true);
	
	
	statusCaption := statusCaption &amp;  app.getErrorString(Job) &amp; ": " &amp; _job.jobNum &amp; " ";
	self.myROROPlanDrawController.selectObjectsForJob(_job,self.modeView = ShpDisplayMode_ColCodeLoad,false); 

	if self.mySideViewForm &lt;&gt; null then
		self.mySideViewForm.myROROLocnDrawingController.selectObjectsForJob(_job, true, true);
	endif;
	self.doSetJobComboForClick(_job);
	self.frmStatus.myFrameCaption.caption := statusCaption;
		
		


epilog

end;</source>
        <access>protected</access>
        <Parameter name="_job" type="CM_VoyageJob"/>
    </JadeMethod>
    <JadeMethod name="doDropFromGridAreaForm" id="c24ca629-58de-4e85-9cf2-4aaf651ef6d9">
        <updating/>
        <source>doDropFromGridAreaForm(frame: Frame input; win: Window input; x: Real; y: Real) updating;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
*/

vars
	tmpObj		: Object;
	aSlotController : CM_VoyageROROController;
	tmpMoveController	: CMIF_MoveController;
begin
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	tmpMoveController := app.myMoveController;
	
	if tmpMoveController = null then
		return;
	endif;
	if tmpMoveController.myTrackedItem = null then
		return;
	endif;

	tmpObj := self.myROROPlanDrawController.getLCFromXYNoTI(x,y);
	

	if tmpObj = null or (tmpObj &lt;&gt; null and (not CM_VoyageROROController.hasInstance(tmpObj))) then
		return;
	endif;
	aSlotController := tmpObj.CM_VoyageROROController;
	
	
	self.doMoveFromGridAreaForm(aSlotController, false);// PAR 32149 pass in context of drag drop move

epilog

end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doEditCurrentJobDetails" id="bb83455a-422f-434d-84e7-f8f979827c09">
        <source>doEditCurrentJobDetails();
/*
Date		    Who			Reason
29 Sep 2011		cnwas3	  	Initial creation: CCMS 1035 CargoSideView form
25 Oct 2012		PJS			PAR # 30631
*/

vars
	anObject : Object;
begin
	if self.myCurrentVoyage &lt;&gt; null then
		anObject := self.tblJobsData.accessRow(self.tblJobsData.row).itemObject;
		if anObject &lt;&gt; null then
			//self.myAssistant.SHP_Assistant.showVoyageJobForm(self.myCurrentVoyage, anObject.CM_Job, self.myMasterMenuAction);
			self.myAssistant.SHP_Assistant.showVoyageJobForm(self.myCurrentVoyage, anObject.CM_Job);
		endif;	
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="doEnableJobButtons" id="01162e7a-298e-45c2-a66f-0eb4bb418d54">
        <updating/>
        <source>doEnableJobButtons(_enable : Boolean) updating;
/*
Date		    Who			Reason
27 September 2011	cnwas3	  Initial creation: CCMS 1035 CargoSideView form
*/

vars

begin
	if (self.tblJobsData.rows &gt; 2 and _enable = true) or 
		_enable = false then
		self.btnEditJob.enabled := _enable;
		self.btnPrintJobsCSV.enabled := _enable;
		self.btnPrintJobs.enabled := _enable;
		self.btnRefreshJobs.enabled := _enable;
	endif;
epilog

end;</source>
        <Parameter name="_enable" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFrameDragDropEvent" id="53ca0ba0-d8b1-41c3-8d6f-976efdb5c5a2">
        <updating/>
        <source>doFrameDragDropEvent(frame: Frame input; win: Window input; x: Real; y: Real) updating;
/*
Purpose:			
Date				Who			Reason
SEPTEMBER 2011		CNWAB1		Initial creation
29/05/2019			jlgzm1		TFS 42840 MSL - Direct Delivery Between LOLO RORO Voyages and Rail
*/

vars
begin
	/* tfs42840 Direct Release functionality allows drag drop from Rail or Road Ops form to the Ship Planning
	if CM_DataTable.hasInstance(win) and win. CM_DataTable.form.isKindOf(CMUI_OpsForm) then 
			app.msgBox(app.getErrorString3(Cannot_drag_drop_from_form_2, app.getErrorString(Rail),app.getErrorString(XLAT_Road_operations), app.getErrorString(Ship_roro_planning)),app.getErrorString(Dragging) &amp; " " &amp; app.getErrorString(Error),
							MsgBox_OK_Only + MsgBox_Exclamation_Mark_Icon);
			return;
	endif;
	*/
	
	if CMUI_GridAreaForm.hasInstance(win) or 
	   CMUI_GridAreaFrame.hasInstance(win) or
	   CMUI_PointDrawingFrame.hasInstance(win) or
	   CMUI_GridAreaDrawingFrame.hasInstance(win) or
	   CM_DataTable.hasInstance(win) then 
		self.doDropFromGridAreaForm(frame, win, x,y);
	endif;
	
epilog
//	app.isDragging := false;
	frame.dragMode := DragMode_None;
//	frame.enableEvent("mouseMove",false);
end;</source>
        <Parameter name="frame" type="Frame" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="doFrameDrawAllowDrag" id="5a59c988-aaee-418f-9319-cbb768d09393">
        <updating/>
        <source>doFrameDrawAllowDrag(_frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     July 2010 ANDREW BISHOP
//
// CALLED BY CMUI_PointDrawingFrame, no references
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	frame : CMUI_PointDrawingFrame;
begin

	if self.myCurrentLayer &lt;&gt; null and self.myCurrentLayer.type = ROROLayerType_Cargo then
		return false;
	endif;

	return true;
	//frame := self.getFrameForLayer(self.myCurrentLayer, self.allBackFramesBottom);
//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1.' &amp; myCurrentLayer.String &amp; " " &amp; frame.String);	
end;</source>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFrameDrawContextMenuEvent" id="27da34b5-1d00-467a-9365-ce31dd1130f2">
        <updating/>
        <source>doFrameDrawContextMenuEvent(cntrl: Frame input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer) : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     January 2010 ANDREW BISHOP
//
// CALLED BY CMUI_POINTDRAWINGFRAME, no references
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tmpSect : CM_VesselSection;
	posM, x1, y1 : Decimal[12,2];
	//aPoint : Point;
	locnDefn : CM_ROROLocnDefnVoyage;
	obj : Object;
	defn : CM_DeckItem;
	isOOTL, amLinked : Boolean;
	
	theFrame : CMUI_PointDrawingFrame;
	
	theTI : CM_TrackedItem;
	invalidObject : Boolean;

begin
	theFrame := self.frmDeck.myDrawingFrame.CMUI_PointDrawingFrame;
	
//	PAR 28920 	aPoint := theFrame.getDragPoint2(); // PAR 28920
//	PAR 28920 	overAPoint := (aPoint.x &lt;&gt; 0 and aPoint.y &lt;&gt; 0); // PAR 28920


	// ### MENU
	self.origMouseY := y;
	self.origMouseX := x;
	
	// TFS 2198 TURN OFF MOST EVERYTHING
	self.mnuReturnCargo.visible := false;
	self.mnuCargoCreateCont.visible := false;
	self.mnuLocnSide.userObject := null;
	self.mnuLocnSide.caption := app.getErrorString(Location_side_view);
	self.mnuLocnSide.enabled := true;  //false;	// 12/12/2011 cnwmh5 #28749
	self.mnuCargoEnquiry.userObject := self.myCurrentDeckItem;
	self.mnuCargoEnquiry.caption := app.getErrorString(Enquire) &amp; " " &amp; app.getErrorString(Containers);
	self.mnuRotateMain.visible := false;
	self.mnuUnRotate.visible := false;
	self.mnuUnplanCargo.visible := false;
	self.mnuAssignRelease.visible := false; 
	self.mnuCCLoadAltGCDLR.visible := false;
	self.mnuCCLoadAltGCSOB.visible := false;
	self.mnuCargoErase.visible := false;
	self.mnuCargoCreate.visible := app.isSpecial();
	self.mnuInspectMain.visible := app.isAllowedToInspect();
	self.mnuCargoInspect.visible := app.isAllowedToInspect();
	self.mnuLinkMain.visible := false;
	self.mnuLoadCCQuantity.visible := false; 
	self.mnuLocnDefn.visible := false;
	self.mnuPlanCargo.visible := false;
	self.mnuPointMain.visible := false;
	self.mnuCCLoadMain.visible := false;
	self.mnuCCLoadDelete.visible := false;
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return self.showContextMenu(self.mnuContextMain, cntrl, conwin, mouse, x, y);
	endif;

	self.mnuCargoCreateCont.visible := true;
	self.mnuCargoCreateCont.userObject := null;
	self.mnuCargoCreateCont.caption := app.getErrorString(Create) &amp; " " &amp; app.getErrorString(Containers);
	self.mnuCargoCreateContAll.userObject := null;
	self.mnuCargoCreateContAll.caption := app.getErrorString(Fill) &amp; " " &amp; app.getErrorString(Containers);
	self.mnuLocnDefn.userObject := null;
	self.mnuLocnDefn.caption := app.getErrorString(Location_defn);
	self.mnuLocnDefn.enabled := false;
	self.mnuLocnDefn.visible := true;
	self.mnuCargoCreateGC.caption := app.getErrorString(Create) &amp; " " &amp; app.getErrorString(CMQF_GeneralCargo);
	self.mnuCargoCreateGC.userObject := null;
	self.mnuCargoCreateGCAread.visible := false;
	self.mnuCargoCreateOOTL.caption := app.getErrorString(Create) &amp; " " &amp; app.getErrorString(Ootl).toUpper &amp; " " &amp; app.getErrorString(Container);
	self.mnuCargoCreateOOTL.userObject := null;
	self.mnuCargoErase.caption := app.getErrorString(Erase) &amp; " " &amp; app.getErrorString(Cargo);
	self.mnuCargoErase.userObject := null;
	self.mnuCargoErase.enabled := true;
	self.mnuCargoErase.visible := true;
	self.mnuRotateMain.enabled := false;
	self.mnuRotateMain.visible := true;
	self.mnuRotateMain.userObject := null;
	self.mnuUnRotate.visible := false;
	self.mnuUnRotate.userObject := null;
	self.mnuUnplanCargo.visible := false;
	self.mnuAssignRelease.visible := false; //cnwrd1 ccms 1310 par 30807
	self.mnuUnplanCargo.userObject := null;
	self.mnuPlanCargo.visible := false;
	self.mnuPlanCargo.userObject := null;
	self.mnuCargoCreateTruck.userObject := null;
	
	self.mnuAllocateCargo.visible := false;
	
	self.mnuPointMain.visible := false;
	self.mnuCCLoadMain.visible := (self.modeView = ShpDisplayMode_ColCodeLoad);
	self.mnuCCLoadDelete.visible := (self.modeView = ShpDisplayMode_ColCodeLoad);
	// PAR 31116 self.mnuCCLoadAltGCDLR.visible := (self.modeView = ShpDisplayMode_ColCodeLoad or self.modeView = ShpDisplayMode_ColCodeDisch);	
	// PAR 31116 self.mnuCCLoadAltGCSOB.visible := (self.modeView = ShpDisplayMode_ColCodeLoad or self.modeView = ShpDisplayMode_ColCodeDisch);	
	
	// PAR 31116 only show these for GC locations
	if (self.modeView = ShpDisplayMode_ColCodeLoad or self.modeView = ShpDisplayMode_ColCodeDisch) then
		self.mnuCCLoadAltGCDLR.visible := true;
		self.mnuCCLoadAltGCSOB.visible := true;
	
		if self.myROROPlanDrawController &lt;&gt; null 
		and not self.myROROPlanDrawController.hasOnlyGCSelected() then
			self.mnuCCLoadAltGCDLR.visible := false;
			self.mnuCCLoadAltGCSOB.visible := false;
		endif;
	endif;
	
	self.mnuLinkMain.visible := (self.modeView = ShpDisplayMode_ColCodeLoad or self.modeView = ShpDisplayMode_ColCodeDisch);	
	self.mnuCargoCreate.visible := app.isSpecial();
	self.mnuInspectMain.visible := app.isSpecial();
//	self.mnuInspectMain.visible := true;
	self.mnuCargoInspect.visible := app.isAllowedToInspect();
	self.mnuLoadCCQuantity.visible := false; // PAR 28985
	self.mnuLoadCCQuantity.userObject := null; // PAR 28985
	
	x1 := (((x/self.scaleFactor)/ROROStructurePixelsPerMetre) - (ROROStructureRearLine /ROROStructurePixelsPerMetre));
	y1 := (-1 *  ((ROROStructureCentreLine/ROROStructurePixelsPerMetre) - ((y/self.scaleFactor) /ROROStructurePixelsPerMetre)));
	self.mnuCCLoadMain.caption := app.getErrorString2(Load_colour_coding_at,x1.String,y1.String);
	self.mnuCCLoadAltGCDLR.caption := app.getErrorString2(DLR_Colour_coding_at,x1.String,y1.String);
	self.mnuCCLoadAltGCSOB.caption := app.getErrorString2(SOB_colour_coding_at,x1.String,y1.String);
	
	self.mnuPointRemove.enabled := true;	
	// PAR 28920
	if theFrame.theGraphic &lt;&gt; null and theFrame.theGraphic.pointsPolygon.size &lt;= 4 then
	self.mnuPointRemove.enabled := false;	
	
	endif;

	
	if cntrl = theFrame then
		if self.myCurrentDeckItem &lt;&gt; null then
			self.mnuCargoInspect.userObject := self.myCurrentDeckItem;
				
			self.mnuReturnCargo.visible := (self.modeView = ShpDisplayMode_Actual); //PAR 30373
			if self.mnuReturnCargo.visible then //PAR 30373
				self.mnuReturnCargo.userObject := self.myCurrentDeckItem; //PAR 30373
			endif;
			
			if self.myCurrentDeckItem.isKindOf(CM_ROROLocnDefnVoyage) then
				locnDefn := self.myCurrentDeckItem.CM_ROROLocnDefnVoyage;
				
				//PAR 29306 - cnwmc5 - below if statement
//PAR 30373				self.mnuReturnCargo.visible := (self.modeView = ShpDisplayMode_Actual); //PAR 29306 cnwmc5
//PAR 30373				if self.mnuReturnCargo.visible then
//PAR 30373					self.mnuReturnCargo.userObject := locnDefn;
//PAR 30373				endif;
				
				self.mnuRotateMain.userObject := self.myCurrentDeckItem;
				self.mnuRotateMain.enabled := (self.modeView = ShpDisplayMode_Actual or self.modeView = ShpDisplayMode_ColCodeLoad); // PAR 28990
				self.mnuRotateMain.caption := app.getErrorString1(Rotate_positions_from,self.myCurrentDeckItem.code);
				self.mnuRotate1to1.enabled := locnDefn.isOOTL();
				self.mnuRotate10to10.enabled := not locnDefn.isOOTL();
				self.mnuRotate3to2.enabled := not locnDefn.isOOTL();
				self.mnuRotate5to4.enabled := not locnDefn.isOOTL();
				self.mnuRotate6to5.enabled := not locnDefn.isOOTL();
				if locnDefn.isPlannedRotated then
					self.mnuRotateMain.enabled := false;
					self.mnuUnRotate.visible := (self.modeView = ShpDisplayMode_Actual or self.modeView = ShpDisplayMode_ColCodeLoad); // PAR 28990
					if not locnDefn.allPlannedRotatedLocnDefns.isEmpty() then
						self.mnuUnRotate.userObject := self.myCurrentDeckItem;
						self.mnuUnRotate.enabled := (self.modeView = ShpDisplayMode_Actual or self.modeView = ShpDisplayMode_ColCodeLoad); // PAR 28990
						self.mnuUnRotate.caption := app.getErrorString1(Unrotate_positions_from,self.myCurrentDeckItem.code) &amp; " (" &amp; locnDefn.getRotationStringForJRW() &amp; ")";  // PAR 28990
					else
						self.mnuUnRotate.enabled := false;
						self.mnuUnRotate.caption := app.getErrorString1(Unrotate_positions_from,app.getErrorString(Master));
					endif;
					
				endif;
				
				self.mnuCargoCreateCont.caption := app.getErrorString1(Create_containers_in,self.myCurrentDeckItem.code);
				self.mnuCargoCreateCont.userObject := self.myCurrentDeckItem;
				self.mnuCargoCreateContAll.caption := app.getErrorString1(Fill_containers_in,self.myCurrentDeckItem.code);
				self.mnuCargoCreateContAll.userObject := self.myCurrentDeckItem;
				self.mnuCargoEnquiry.userObject := self.myCurrentDeckItem;
				self.mnuCargoEnquiry.caption := app.getErrorString(Enquiry)&amp; " " &amp; self.myCurrentDeckItem.code;
				self.mnuLocnDefn.userObject := self.myCurrentDeckItem;
				self.mnuLocnDefn.caption := app.getErrorString1(Location_defn_code,self.myCurrentDeckItem.code);
				self.mnuLocnDefn.enabled := true;
				///self.mnuLocnSide.enabled := true;					// 12/12/2011 cnmwh5 #28749
				self.mnuLocnSide.userObject := self.myCurrentDeckItem;
				self.mnuLocnSide.caption := app.getErrorString(Location_side_view);
				self.mnuCargoErase.caption := app.getErrorString(Erase) &amp; " " &amp; self.myCurrentDeckItem.code;
				self.mnuCargoErase.userObject := self.myCurrentDeckItem;
				
				
				/* PAR 31442 WAS
				self.mnuCargoErase.enabled := (self.myCurrentDeckItem.isOOTL or self.myCurrentDeckItem.isLocnGC);
				if locnDefn.isOOTL then
					self.mnuCargoErase.enabled := true;
				else
					self.mnuCargoErase.enabled := (locnDefn.getFirstTI() &lt;&gt; null);
				endif;
				NOW */
				self.mnuCargoErase.enabled := self.myCurrentDeckItem.canIBeErased(); // PAR 31442
				
				
				self.mnuCargoCreateGC.userObject := null;
				self.mnuCargoCreateGC.caption := app.getErrorString2(Create_general_cargo_at,x1.String,y1.String);
				self.mnuCargoCreateOOTL.userObject := null;
				self.mnuCargoCreateOOTL.caption := app.getErrorString2(Create_ootl_container_at,x1.String,y1.String);
				
				
			elseif self.myCurrentDeckItem.isKindOf(CM_ROROGCDefnVoyage) then
				self.mnuPointMain.visible := theFrame.hasCurrentPoint(); // PAR 28920

				self.mnuCargoEnquiry.userObject := self.myCurrentDeckItem;
				self.mnuCargoEnquiry.caption := app.getErrorString(Enquiry) &amp; " " &amp; self.myCurrentDeckItem.code;
				self.mnuCargoCreateGC.userObject := self.myCurrentDeckItem;
				self.mnuCargoCreateGC.caption := app.getErrorString4(Add_general_cargo_at,app.getErrorString(CMQF_GeneralCargo),self.myCurrentDeckItem.code,self.myCurrentDeckItem.CM_ROROGCDefnVoyage.xMetres.String,self.myCurrentDeckItem.CM_ROROGCDefnVoyage.yMetres.String);
				self.mnuCargoCreateOOTL.userObject := self.myCurrentDeckItem;
				self.mnuCargoCreateOOTL.caption := app.getErrorString4(Add_general_cargo_at,app.getErrorString(Ootl).toUpper,self.myCurrentDeckItem.code,self.myCurrentDeckItem.CM_ROROGCDefnVoyage.xMetres.String,self.myCurrentDeckItem.CM_ROROGCDefnVoyage.yMetres.String);
				self.mnuCargoErase.caption := app.getErrorString(Erase) &amp; " " &amp; self.myCurrentDeckItem.code;
				self.mnuCargoErase.userObject := self.myCurrentDeckItem;
				self.mnuCargoErase.enabled := self.myCurrentDeckItem.canIBeErased(); // PAR 31442
 
			elseif self.myCurrentDeckItem.isKindOf(CM_ROROLaneDefnVoyage) then
				self.mnuPointMain.visible := theFrame.hasCurrentPoint(); // PAR 28920


				self.mnuCargoEnquiry.userObject := self.myCurrentDeckItem;
				self.mnuCargoEnquiry.caption := app.getErrorString(Enquiry) &amp; " " &amp; self.myCurrentDeckItem.code;
				self.mnuCargoCreateTruck.userObject := self.myCurrentDeckItem;
				self.mnuCargoCreateTruck.caption := app.getErrorString4(Add_general_cargo_at,app.getErrorString(CMQF_GeneralCargo),self.myCurrentDeckItem.code,"0","0");
				self.mnuCargoErase.caption := app.getErrorString(Erase) &amp; " " &amp; self.myCurrentDeckItem.code;
				self.mnuCargoErase.userObject := self.myCurrentDeckItem;
 				self.mnuCargoErase.enabled := self.myCurrentDeckItem.canIBeErased(); // PAR 31442
 
			elseif self.myCurrentDeckItem.isKindOf(CM_ROROLanePositionDefn) then
				self.mnuPointMain.visible := theFrame.hasCurrentPoint(); // PAR 28920


				self.mnuCargoEnquiry.userObject := self.myCurrentDeckItem;
				self.mnuCargoEnquiry.caption := app.getErrorString(Enquiry) &amp; " " &amp; self.myCurrentDeckItem.code;
				self.mnuCargoCreateTruck.userObject := self.myCurrentDeckItem;
				self.mnuCargoCreateTruck.caption := app.getErrorString4(Add_general_cargo_at,app.getErrorString(CMQF_GeneralCargo),self.myCurrentDeckItem.code,"0","0");
				self.mnuCargoErase.caption := app.getErrorString(Erase) &amp; " " &amp; self.myCurrentDeckItem.code;
				self.mnuCargoErase.userObject := self.myCurrentDeckItem;
 				self.mnuCargoErase.enabled := self.myCurrentDeckItem.canIBeErased(); // PAR 31442
 
			endif;
		else 
			
				self.mnuCargoCreateGC.userObject := null;
				self.mnuCargoCreateGC.caption := app.getErrorString2(Create_general_cargo_at,x1.String,y1.String);
				self.mnuCargoCreateGCAread.visible := true;
				self.mnuCargoCreateGCAread.userObject := null;
				self.mnuCargoCreateGCAread.caption := "AREA: " &amp; app.getErrorString2(Create_general_cargo_at,x1.String,y1.String);
				self.mnuCargoCreateOOTL.userObject := null;
				self.mnuCargoCreateOOTL.caption := app.getErrorString2(Create_ootl_container_at,x1.String,y1.String);
				self.mnuCargoCreateTruck.caption := "Equipment Area at " &amp; x1.String &amp; "m X" &amp; y1.String &amp; "m";
				self.mnuCargoCreateTruck.helpKeyword := "CM_ROROEquipment";
		endif;
		on Exception do app.handleDeletedObject(exception, self.myCurrentItemLayout, invalidObject); // 31053 If this kicks off the next statement is a continue anyway so have not added any extra coding

		if self.myCurrentItemLayout.isKindOf(CM_RORORequestLayout) then
			obj:=self.myCurrentItemLayout.CM_RORORequestLayout.myRequest;
			if invalidObject then// 31053
				self.myCurrentItemLayout := null; // 31053
				self.myCurrentDeckItem := null; // 31053
				return false;// 31053
			endif;
		else
			obj :=  self.myROROPlanDrawController.allSelectedObjects.first;
		endif;
		// PAR 28886
		if  not obj.isKindOf(CM_RORORequest) then
			obj := self.myROROPlanDrawController.allSelectedObjects.last;
		endif;
		if obj &lt;&gt; null then

			self.mnuCargoInspect.userObject := obj;
			self.mnuCargoInspect.caption := app.getErrorString(Inspect) &amp; " " &amp; obj.getName();
			
			//cnwmc5 - 1 August 2013 - PAR 31651
			self.setupLinkContextMenus(self.mnuLinkMain, self.mnuLinkDoLink, self.mnuLinkRelink, self.mnuLinkDelink);	// 10/09/2013 cnwmh5 #31938
			
			// PAR 28339
			if obj.isKindOf(CM_RORORequest) then
				self.mnuUnplanCargo.visible := true;
				self.mnuUnplanCargo.userObject := obj;
				self.mnuUnplanCargo.caption :=  app.getErrorString(Unplan_GC) &amp; " "  &amp; obj.CM_RORORequest.getAllocationName();
				self.mnuPlanCargo.visible:=self.modeView = ShpDisplayMode_ColCodeDisch; //epr par 29007 18/5/12
				///// PAR 28968
				///amLinked := obj.CM_RORORequest.isLinked();  
				///self.mnuLinkRelink.visible := amLinked;
				///self.mnuLinkDelink.visible := amLinked;
				///self.mnuLinkDoLink.visible := not amLinked;
				
				defn := obj.CM_RORORequest.myROROController.getDefn();

				if self.modeWork = WorkMode_Plan then //ccms 1310 
					self.doContextMenuAssignRelease(obj.CM_RORORequest);
				endif;
				
				
				if self.modeWork = WorkMode_Plan  //ccms 1303
					and obj.CM_RORORequest.myJob &lt;&gt; null 
					and obj.CM_RORORequest.myJob.isAllowOutOfOrderLoading 
					and obj.CM_RORORequest.getFirstAllocation &lt;&gt; null then
							self.mnuAllocateCargo.visible := true;
							self.mnuAllocateCargo.userObject := obj.CM_RORORequest.myJob;
							self.mnuAllocateCargo.caption := app.getErrorString1(Manage_allocated_cargo, obj.CM_RORORequest.myJob.CM_VoyageJob.jobNum  );
				endif;
				
				if obj.isA(CM_ROROGCRequest) then
//						self.mnuPointMain.visible := overAPoint; // PAR 28920
					self.mnuPointMain.visible := theFrame.hasCurrentPoint(); // PAR 28920

					if defn &lt;&gt; null then
						self.mnuCargoEnquiry.userObject := defn;
						self.mnuCargoEnquiry.caption := app.getErrorString(Enquiry) &amp; " " &amp; defn.code;
						self.mnuCargoEnquiry.visible := true;
					endif;
					
					// PAR 28985
					self.mnuLoadCCQuantity.visible := true;
					self.mnuLoadCCQuantity.userObject := obj;
				// PAR 28886
				elseif obj.isKindOf(CM_ROROSlotRequest) then
					if defn.isKindOf(CM_ROROLocnDefnVoyage) then
						locnDefn := defn.CM_ROROLocnDefnVoyage;
						
						
						// PAR 28907
						self.mnuLocnDefn.userObject := locnDefn;
						self.mnuLocnDefn.caption := app.getErrorString1(Location_defn_code,locnDefn.code);
						self.mnuLocnDefn.enabled := true;

						
						self.mnuRotateMain.userObject := locnDefn;
						self.mnuRotateMain.caption := app.getErrorString1(Rotate_positions_from,locnDefn.code);
						isOOTL := locnDefn.isOOTL();
// PAR 29990							self.mnuRotateMain.enabled := (isOOTL and not locnDefn.isRotated()) and (self.modeView = ShpDisplayMode_Actual or self.modeView = ShpDisplayMode_ColCodeLoad); // PAR 28886
						self.mnuRotateMain.enabled := (isOOTL and not locnDefn.isPlannedRotated and (self.modeView = ShpDisplayMode_Actual or self.modeView = ShpDisplayMode_ColCodeLoad)); // PAR 28886
						self.mnuRotate1to1.enabled := isOOTL;
						self.mnuRotate10to10.enabled := not isOOTL;
						self.mnuRotate3to2.enabled := not isOOTL;
						self.mnuRotate5to4.enabled := not isOOTL;
						self.mnuRotate6to5.enabled := not isOOTL;
						if locnDefn.isPlannedRotated then
							self.mnuRotateMain.enabled := false;
							self.mnuUnRotate.visible := (self.modeView = ShpDisplayMode_Actual or self.modeView = ShpDisplayMode_ColCodeLoad); // PAR 28990
							if isOOTL or (not locnDefn.allPlannedRotatedLocnDefns.isEmpty()) then
								self.mnuUnRotate.userObject := locnDefn;
								self.mnuUnRotate.enabled := (self.modeView = ShpDisplayMode_Actual or self.modeView = ShpDisplayMode_ColCodeLoad); // PAR 28990
								self.mnuUnRotate.caption := app.getErrorString1(Unrotate_positions_from,locnDefn.code); 
							else
								self.mnuUnRotate.enabled := false;
								self.mnuUnRotate.caption := app.getErrorString1(Unrotate_positions_from,app.getErrorString(Master));
							endif;
							
						endif;

					endif;
				endif;
			// PAR 28887
			elseif obj.isKindOf(CM_ROROLocnDefnVoyage) then
				self.mnuLocnDefn.userObject := obj.CM_ROROLocnDefnVoyage;
				self.mnuLocnDefn.caption := app.getErrorString1(Location_defn_code,obj.CM_ROROLocnDefnVoyage.code);
				self.mnuLocnDefn.enabled := true;
				
				locnDefn := obj.CM_ROROLocnDefnVoyage;
				// PAR 28886
				self.mnuRotateMain.userObject := locnDefn;
				if locnDefn.isOOTL() then
					self.mnuRotateMain.enabled := (self.modeView = ShpDisplayMode_Actual or self.modeView = ShpDisplayMode_ColCodeLoad); // PAR 28990
				else
					// PAR 31347 self.mnuRotateMain.enabled := (not locnDefn.hasTIs(REAL_MODE) and (self.modeView = ShpDisplayMode_Actual or self.modeView = ShpDisplayMode_ColCodeLoad)); // PAR 28990
					// PAR 31347 NOW
					if self.modeView = ShpDisplayMode_Actual then
						self.mnuRotateMain.enabled := not locnDefn.hasTIs(REAL_MODE);
					endif;
					if self.modeView = ShpDisplayMode_ColCodeLoad then
						self.mnuRotateMain.enabled := locnDefn.hasTIsAllColourCoded(REAL_MODE, false,false);
					endif;
				endif;
				self.mnuRotateMain.caption := app.getErrorString1(Rotate_positions_from,locnDefn.code);
				self.mnuRotate1to1.enabled := locnDefn.isOOTL();
				self.mnuRotate10to10.enabled := not locnDefn.isOOTL();
				self.mnuRotate3to2.enabled := not locnDefn.isOOTL();
				self.mnuRotate5to4.enabled := not locnDefn.isOOTL();
				self.mnuRotate6to5.enabled := not locnDefn.isOOTL();
				if locnDefn.isPlannedRotated then
					self.mnuRotateMain.enabled := false;
					self.mnuUnRotate.visible := (self.modeView = ShpDisplayMode_Actual or self.modeView = ShpDisplayMode_ColCodeLoad); // PAR 28990
					if not locnDefn.allPlannedRotatedLocnDefns.isEmpty() then
						self.mnuUnRotate.userObject := self.myCurrentDeckItem;
						self.mnuUnRotate.enabled := (self.modeView = ShpDisplayMode_Actual or self.modeView = ShpDisplayMode_ColCodeLoad); // PAR 28990
						self.mnuUnRotate.caption := app.getErrorString1(Unrotate_positions_from,locnDefn.code); 
					else
						self.mnuUnRotate.enabled := false;
						self.mnuUnRotate.caption := app.getErrorString1(Unrotate_positions_from,app.getErrorString(Master));
					endif;
					
				endif;				
			endif;
		endif;
		return self.showContextMenu(self.mnuContextMain, cntrl, conwin, mouse, x, y);
	endif;
	
end;</source>
        <Parameter name="cntrl" type="Frame" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFrameDrawDetectOtherGraphic" id="449fa40f-88f9-4a09-9606-f5079736693d">
        <updating/>
        <source>doFrameDrawDetectOtherGraphic(_graphic : CM_DeckItemLayout; _isMultiSelect : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     January 2010 ANDREW BISHOP
//
// CALLED BY CMUI_PointDrawingFrame, no references
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aReq, origReq : CM_RORORequest;
	theLayout : CM_DeckItemLayout;
	theItem : CM_DeckItem;
	theLocn,fwdLocn : CM_ROROLocnDefnVoyage;
	is40, has40s : Boolean;
	allTis : CM_TIArray;
begin

	self.myCurrentDeckItem := null;
	self.myCurrentItemLayout := null;


	theLayout := _graphic;
	
	if theLayout &lt;&gt; null then
		self.myCurrentDeckItem := theLayout.myDeckItem;
		// PAR 28787
		if  self.modeView = ShpDisplayMode_ColCodeLoad 
		or  self.modeView = ShpDisplayMode_ColCodeDisch then
				// ### Switch to the req layout for the fwd if this has any back end 40 request
				if self.myCurrentDeckItem.isKindOf(CM_ROROLocnDefnVoyage) then
				
					theLocn := self.myCurrentDeckItem.CM_ROROLocnDefnVoyage;

				// PAR 28883
				elseif theLayout.isKindOf(CM_RORORequestLayout) then
					origReq := theLayout.CM_RORORequestLayout.myRequest;
					if origReq &lt;&gt; null then
						theItem := origReq.myROROController.getDefn();
					endif;
					if theItem.isKindOf(CM_ROROLocnDefnVoyage) then
						theLocn := theItem.CM_ROROLocnDefnVoyage;
					endif;
					// 29744 set myCurrentDeckItem to get context menu correct for cargo
					if self.myCurrentDeckItem = null then
						self.myCurrentDeckItem := theItem;
					endif;
				endif;
				
				if theLocn &lt;&gt; null then
					//cnwmc5 - 29 June 2016 - TFS 2214
					//epr PAR 38138 12/8/16 if it is drawn they can see it they should be able to select it 
					/*if self.modeView = ShpDisplayMode_ColCodeLoad then
						if theLocn.hasBeenRotatedForLoad and theLocn.isOnLayerCargo then
							// Do not draw this slot...
							return;
						endif;
					endif;*/
					
					//epr par 31936 18/7/13
					aReq := theLocn.getFirst40Request((self.modeView = ShpDisplayMode_ColCodeLoad));
					
					//cnwmc5 - 24 March 2014 - PAR 33284
					if self.modeView = ShpDisplayMode_ColCodeDisch 
					and self.myROROPlanDrawController.modeViewSubSub = ShpDisplayModeSub_ExportsShow then
						aReq := theLocn.getFirst40Request(true);
					endif;
					
					if aReq &lt;&gt; null then
				//		is40 := (aReq.getAttrIs40() or aReq.getAttrIs30() or aReq.getAttrIs45() or aReq.getAttrIs53()); // PAR 30022 
						is40 := aReq.getAttrIsNOT20(); // PAR 30253
						if is40  // PAR 30022 
	//					if aReq.getAttrIs40() 
						and aReq.getAttrIsBackend() then
							aReq := aReq.getFwdSlotReq().CM_RORORequest;
						endif;
						if aReq &lt;&gt; null then
							theLayout := aReq.myLayout;
						endif;
					// PAR 29005
					else // PAR 29006 if  self.modeView = ShpDisplayMode_ColCodeDisch then
						if origReq &lt;&gt; null then // PAR 29006 must be  20 foot only request so use the requests layout 
							theLayout := origReq.myLayout;
						
						else
							
							//epr par 31936 18/7/13 					
							has40s := false;
							create allTis transient;
							
							if  theLocn.myAdjacentSlotFwd &lt;&gt; null then
								theLocn.myAdjacentSlotFwd.getAllTIsForDisplayMode(self.modeView,self.myROROPlanDrawController.modeViewSubSub,allTis,true,has40s);
							else
								theLocn.getAllTIsForDisplayMode(self.modeView,self.myROROPlanDrawController.modeViewSubSub,allTis,true,has40s);
							endif;
							if has40s  then
								if  theLocn.myAdjacentSlotFwd &lt;&gt; null then
									theLocn := theLocn.myAdjacentSlotFwd.CM_ROROLocnDefnVoyage;
								endif;
							endif;
				
							theLayout := theLocn.myLayout;
							self.myCurrentDeckItem := theLayout.myDeckItem;
						endif;
					endif;
				endif;
		elseif  self.modeView = ShpDisplayMode_Actual then
		
				// ### Switch to the  fwd if this has any back end 40 tis
				if self.myCurrentDeckItem.isKindOf(CM_ROROLocnDefnVoyage) then
				
					theLocn := self.myCurrentDeckItem.CM_ROROLocnDefnVoyage;
					
					if theLocn.hasTIs40(REAL_MODE, false) then // has aft 40 so switch to forward
						theLocn := theLocn.myAdjacentSlotFwd.CM_ROROLocnDefnVoyage;
					endif;
					theLayout := theLocn.myLayout;
					self.myCurrentDeckItem := theLayout.myDeckItem;
				endif;
		elseif  self.modeView = ShpDisplayMode_Proposed then
			if self.myCurrentDeckItem.isKindOf(CM_ROROLocnDefnVoyage) then
				// get the proposed tis and see if it has a 40ft fwd locn
				theLocn := self.myCurrentDeckItem.CM_ROROLocnDefnVoyage;
				//epr par 29978 19/7/21
				fwdLocn := self.myCurrentDeckItem.CM_ROROLocnDefnVoyage.getFwdDefnFor40Proposed();
				if fwdLocn &lt;&gt; null then
					theLocn:=fwdLocn;
				endif;
				theLayout := theLocn.myLayout;
				self.myCurrentDeckItem := theLayout.myDeckItem;
			endif;
		endif;

		self.myCurrentItemLayout := theLayout;
		
		self.doDrawSelectObject(_isMultiSelect);		//cnwmc5 - 26 Nov 2013 - PAR 32697
		
	endif;
epilog
	delete allTis;
end;</source>
        <Parameter name="_graphic" type="CM_DeckItemLayout"/>
        <Parameter name="_isMultiSelect" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doFrameDrawMouseDownEvent" id="e80b2434-c4de-46f9-a885-8d17e4ee1789">
        <updating/>
        <source>doFrameDrawMouseDownEvent(_frame: Frame input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*
Purpose:			
Date		Who		Reason
19 September 2011	cnwab1	Initial creation
*/

vars

begin
