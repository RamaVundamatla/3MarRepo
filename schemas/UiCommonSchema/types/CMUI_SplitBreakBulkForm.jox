    <JadeMethod name="doResize" id="5a7f1250-a568-4614-bc4c-2a7e40ba3e6f">
        <updating/>
        <source>doResize() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2013	cnwndl1	Initial creation	CCMS 2274 Break Bulk

*/

vars

begin

	self.grpMain.top := 1;
	self.grpMain.left := 1;

