        <source>utlCreateYACriteriaPriority(pProxyObj:CM_YACriteriaPriority;
							pNewObj:CM_YACriteriaPriority output;
							_passport : CM_Passport input);
// --------------------------------------------------------------------------------
// Created:		23 March 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
// 28/08/2008	Simon Ward	SFW1030 - Revised auditing during rework of yard allocations
// --------------------------------------------------------------------------------
begin
	self.initialiseActivity();
	app.setContinueCMExceptions(true);
	app.myValCA.valYACriteriaPriority(pProxyObj);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	create pNewObj as pProxyObj.class persistent;
	pNewObj.setForCreate(pProxyObj);
	
//	if _passport.noErrors then
//		self.myCreateAuditAgent.audCreateGeneric(pNewObj);
//	endif;
end;</source>
