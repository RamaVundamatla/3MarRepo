    <JadeMethod name="autoPlan" id="4922e1d4-ad05-4308-a1d8-dc331d7a3e6c">
        <updating/>
        <source>autoPlan(theAutoMovePlan: CMIF_AutoMovePlan input; theAttributeArea: CM_AttributeArea input) updating; //, serverExecution;
// ---------------------------------------------------------------------------
// Created:		November 2002 By Andrew Bishop cnwab1
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------
vars
	lc								: CM_LocationsController;
	rowOrdinal, colOrdinal,
	columnNumber,columnTotal		: Integer; // 4156
	i								: Integer;
	numInColl						: Integer;
	firstRowLCOrdinal				: Integer;
	firstRowLC						: Boolean;
	autoStackDir					: Integer;
	locnId							: String;
	maxHeight						: Integer;
	prevIndex						: Integer;
	overStowHuntToRow				: Boolean;
	tiLocationParentObject			: CM_Object;
	extraMsg						: String;
	firstEntry						: Boolean;
	refIdx, nextIdx,
	priorIdx, thisRow				: Integer;
	theTI 							: CM_TrackedItem;
begin

	theTI := theAutoMovePlan.myTrackedItem;

	if theAutoMovePlan.isOverstowMove then
			if theTI.myTerminal &lt;&gt; null and theTI.myTerminal.testYAOverstowTI(theTI) then
				self.doOverstowMoveYA(theAutoMovePlan);
			else
				self.doOverStowMove(theAutoMovePlan);
			endif;
		return;
	endif;
	//------------
	//For StraddleStacks, this is repeated if we are stacking ALONG the row
	//We need to traverse to the END of each row.
	//------------
	autoStackDir := self.autoplanStackDirection;
	if autoStackDir = STACK_UP_STACK  then
		//extraMsg := " (Stack pad position to maximum height, then move to previous pad position in Column)";
		theAutoMovePlan.addLogEntry(app.getErrorString1(Testi_termi_area_stack_posit_m, self.id), IsForLogging, Testi_termi_area_stack_posit_m);
	elseif autoStackDir = STACK_ALONG_ROW then
		//extraMsg := " (Stack pad position one layer at a time, then move to next height in Row)";
		theAutoMovePlan.addLogEntry(app.getErrorString1(Testi_termi_area_stack_posit_l, self.id), IsForLogging, Testi_termi_area_stack_posit_l);
	else //STACK_ALL_HEIGHT
		//extraMsg := " (Stack pad position to maximum height, then move to next pad position in Row)";
		theAutoMovePlan.addLogEntry(app.getErrorString1(Testi_termi_area_stack_pos_m, self.id), IsForLogging, Testi_termi_area_stack_pos_m);
	endif;
	//theAutoMovePlan.addLogEntry("Testing Terminal Area " &amp; self.id &amp; extraMsg, IsForLogging); //- cnwmd1, Par 20524
	//theAutoMovePlan.addLogEntry(app.getErrorString(Testing Terminal Area %1", &amp; self.id), IsForLogging);

	// ###########################################
	firstEntry := true;
	if not app.isTerminalAutoPlanningEnabled() then   //SFW1030 04/08/2008
		theAutoMovePlan.updateController(null);
		return;
	endif;

	if theAutoMovePlan.myTrackedItem = null then
		app.raiseCMException1(ERR_NO_OBJECT, "No TI Reference", null, null);
		return;		
	endif;
	//---------------
	//Iterate through all the LC's in this list, test each one
	//---------------
	numInColl := theAttributeArea.allLocationControllers.size;
	if numInColl = 0 then
		theAutoMovePlan.updateController( null);
		//theAutoMovePlan.addLogEntry("No Locations to search in Attribute Area: " &amp; theAttributeArea.restrictedTermAreaId &amp; " , continuing with next Area." , IsForLogging);
		theAutoMovePlan.addLogEntry(app.getErrorString1(Loc_ser_attri_area_conti_w_nxt, theAttributeArea.restrictedTermAreaId) , IsForLogging, Loc_ser_attri_area_conti_w_nxt);
		return;
	endif;
	
	theAutoMovePlan.iteration := 1;

	//------------------
	//Call the terminal area hunt for similar TI to place besides.
	//------------------
	lc := null;
	if self.autoPlanTest.testHuntToFirstSimiliar = false then
		//theAutoMovePlan.addLogEntry("Hunt to first object equal Voyage, CmdtyGroup and Disch Port in area test not selected, Skipping.", IsForLogging);
		theAutoMovePlan.addLogEntry(app.getErrorString(Hunt_first_objec_equal_voyag_c), IsForLogging, Hunt_first_objec_equal_voyag_c);
	else
		//theAutoMovePlan.addLogEntry("Hunt to first object equal Voyage, CmdtyGroup and Disch Port in area test IS selected, Hunting.", IsForLogging);
		theAutoMovePlan.addLogEntry(app.getErrorString(Hnt_first_objec_eql_voyag_cmdy), IsForLogging, Hnt_first_objec_eql_voyag_cmdy);
		lc := self.testFindHuntedTILC(theAutoMovePlan, theAttributeArea);
		//----------------
		//If the hunt finds nothing, simply contine from the start of available LC's.
		//----------------
		if lc = null then
			//theAutoMovePlan.addLogEntry("Hunting to first object equal Voyage, Commodity Group and Discharge Port failed, continuing with normal search.", IsForLogging);
			theAutoMovePlan.addLogEntry(app.getErrorString(Hunti_first_objec_equal_voyag_), IsForLogging, Hunti_first_objec_equal_voyag_);
		else
			//theAutoMovePlan.addLogEntry("Found " &amp; lc.getFullId, IsForLogging);
			theAutoMovePlan.addLogEntry(app.getErrorString1(Found_something, lc.getFullId), IsForLogging, Found_something);
		endif;
	endif;
	if self.autoplanStackDirection = STACK_UP_STACK then
		self.autoPlanColumn01(theAutoMovePlan,theAttributeArea,lc);
	elseif autoStackDir = STACK_ALL_HEIGHT  then
		self.autoPlanRow01(theAutoMovePlan,theAttributeArea,lc);
	else //STACK_ALONG_ROW
		self.autoPlanRow02(theAutoMovePlan,theAttributeArea,lc);
	endif;
end;</source>
        <Parameter name="theAutoMovePlan" type="CMIF_AutoMovePlan" usage="input"/>
        <Parameter name="theAttributeArea" type="CM_AttributeArea" usage="input"/>
    </JadeMethod>
    <JadeMethod name="autoPlanColumn01" id="6aa7fcd8-f8d5-4cd0-932b-cfe30b9e7745">
        <updating/>
        <source>autoPlanColumn01(theAutoMovePlan: CMIF_AutoMovePlan input; theAttributeArea: CM_AttributeArea input;_theLC : CM_LocationsController) updating;
// ---------------------------------------------------------------------------
// Created:		November 2002 By Andrew Bishop cnwab1
//
// Purpose:		STACK_ALONG_COLUMN NOTE: as a fork lift stack we have a special feature.
//				if a location restriction that matches our TI is basically going across the area and not covering whole columns
//				then we scann backwards. This allows 2 machines to work 1 area at the same time, 1 on each side
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lc	:CM_LocationsController;
	rowNumber,rowTotal,columnNumber,columnTotal, theStartColumn, theStartRow : Integer;
	numInColl : Integer;
	locnId	:	String;
	maxHeight	:	Integer;
	directionForward : Boolean;
begin

	directionForward := self.getDirectionForward(theAutoMovePlan);

	// Work out the maximum height, not in feet but in containers. Note the stacks max height is in feet based on the ability to stack 9'6"s
	maxHeight := self.autoPlanGetMaxHeight(theAutoMovePlan);
	columnTotal := self.numberOfColumns;

	if directionForward then // go forward
		// HUNT FIRST SIMILAR
		if _theLC &lt;&gt; null then
			theStartColumn := _theLC.CM_GridController.myGridColumn.column;
			theStartRow :=  _theLC.CM_GridController.myGridRow.row;
		else
			theStartColumn := 1;
			theStartRow := 1;
		endif;
	
		// do not use the order of the restricted locations. Always start at the back left hand corner and work through.
		foreach columnNumber in theStartColumn to columnTotal  do : outerLoop
			foreach rowNumber in theStartRow to rowTotal do
				lc := self.allGridControllersByRowColumn[rowNumber,columnNumber];
				
				if theAttributeArea.allLocationControllers.includes(lc) then
					// only look at this controller if the space at the maximum height for the TI is empty
					if lc.CM_StackController.allTrackedItems.size &lt;= maxHeight then
						theAutoMovePlan.iteration := 1;
						self.autoPlanTestLC(lc,theAutoMovePlan,theAttributeArea);

						if theAutoMovePlan.getController &lt;&gt; null then

							//-------------
							//We have found a suitable location for this TI, we can go home now. The End
							//-------------
							return;
						endif;
					endif;
				endif;
			endforeach; // rowNumber
		endforeach; // columnNumber
	else // go backwards
		// HUNT FIRST SIMILAR
		if _theLC &lt;&gt; null then
			theStartColumn := _theLC.CM_GridController.myGridColumn.column;
			theStartRow :=  _theLC.CM_GridController.myGridRow.row;
		else
			theStartColumn := self.numberOfColumns;
			theStartRow := self.numberOfRows;
		endif;
		foreach columnNumber in 1 to columnTotal reversed do : outerLoop2
			foreach rowNumber in theStartRow to rowTotal reversed do
				lc := self.allGridControllersByRowColumn[rowNumber,columnNumber];
				
				if theAttributeArea.allLocationControllers.includes(lc) then
					// only look at this controller if the space at the maximum height for the TI is empty
					if lc.CM_StackController.allTrackedItems.size &lt;= maxHeight  then
						self.autoPlanTestLC(lc,theAutoMovePlan,theAttributeArea);
						if theAutoMovePlan.getController &lt;&gt; null then
							//-------------
							//We have found a suitable location for this TI, we can go home now. The End
							//-------------
							return;
						endif;
					endif;
				endif;
			endforeach;
		endforeach;
	endif;
end;</source>
        <Parameter name="theAutoMovePlan" type="CMIF_AutoMovePlan" usage="input"/>
        <Parameter name="theAttributeArea" type="CM_AttributeArea" usage="input"/>
        <Parameter name="_theLC" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="autoPlanGetMaxHeight" id="ca3977d8-24ba-4894-a124-9e84e3f17fc8">
        <source>autoPlanGetMaxHeight(theAutoMovePlan: CMIF_AutoMovePlan input) : Integer;
// ---------------------------------------------------------------------------
// Created:		November 2002 By Andrew Bishop cnwab1
//
// Purpose:		Work out the maximum height, not in feet but in containers. 
//				Note the stacks max height is in feet based on the ability to stack 9'6"s
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars	
	maxHeight : Integer;
	theTI : CM_TrackedItem;
begin
	theTI := theAutoMovePlan.myTrackedItem;
	
	if not theTI.isFull then
		if theTI.isAttributeTrue(TI_Attrib_RequiresPower) then
			maxHeight := (self.maxHeightPower / HEIGHT_FULL_HIGH_CUBE).Integer;
		else
			maxHeight := (self.maxHeightFull / HEIGHT_FULL_HIGH_CUBE).Integer;
		endif;
	else
		if theTI.isAttributeTrue(TI_Attrib_RequiresPower) then
			maxHeight := (self.maxHeightPower / HEIGHT_FULL_HIGH_CUBE).Integer;
		else
			maxHeight := (self.maxHeightMT / HEIGHT_FULL_HIGH_CUBE).Integer;
		endif;
	endif;

	return maxHeight;
end;</source>
        <Parameter name="theAutoMovePlan" type="CMIF_AutoMovePlan" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="autoPlanRow01" id="048c6ef2-6cc4-427e-97c6-4b1685c9e6ef">
        <updating/>
        <source>autoPlanRow01(theAutoMovePlan: CMIF_AutoMovePlan input; theAttributeArea: CM_AttributeArea input;_theLC : CM_LocationsController) updating;
// ---------------------------------------------------------------------------
// Created:		November 2002 By Andrew Bishop cnwab1
//
// Purpose:		STACK_ALL_HEIGHT along a row one pad at a time
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lc	:CM_LocationsController;
	numInColl : Integer;
	locnId	:	String;
	maxHeight,rowNumber,rowTotal,columnNumber,columnTotal, theStartColumn, theStartRow : Integer;

	directionForward : Boolean;
begin

	directionForward := self.getDirectionForward(theAutoMovePlan);
	// Work out the maximum height, not in feet but in containers. Note the stacks max height is in feet based on the ability to stack 9'6"s
	maxHeight := self.autoPlanGetMaxHeight(theAutoMovePlan);

	if directionForward then // forward
		// HUNT FIRST SIMILAR
		if _theLC &lt;&gt; null then
			theStartColumn := _theLC.CM_GridController.myGridColumn.column;
			theStartRow :=  _theLC.CM_GridController.myGridRow.row;
		else
			theStartColumn := 0;
			theStartRow := 0;
		endif;
		// do not use the order of the restricted locations. Always start at the back left hand corner and work through.
		foreach rowNumber in theStartRow to rowTotal do
			foreach columnNumber in theStartColumn to columnTotal  do : outerLoop
				lc := self.allGridControllersByRowColumn[rowNumber,columnNumber];
				
				if theAttributeArea.allLocationControllers.includes(lc) then
					// only look at this controller if the space at the maximum height for the TI is empty
					if lc.CM_GridController.allTrackedItems.size &lt; maxHeight  then
						self.autoPlanTestLC(lc,theAutoMovePlan,theAttributeArea);
						if theAutoMovePlan.getController &lt;&gt; null then
							//-------------
							//We have found a suitable location for this TI, we can go home now. The End
							//-------------
							return;
						endif;
					endif;
				endif;
			endforeach;
		endforeach;
	else
		// HUNT FIRST SIMILAR
		if _theLC &lt;&gt; null then
			theStartColumn := _theLC.CM_GridController.myGridColumn.column;
			theStartRow :=  _theLC.CM_GridController.myGridRow.row;
		else
			theStartColumn := self.numberOfColumns;
			theStartRow := self.numberOfRows;
		endif;
		foreach rowNumber in theStartRow to rowTotal reversed do
			foreach columnNumber in 1 to columnTotal reversed do : outerLoop2
				lc := self.allGridControllersByRowColumn[rowNumber,columnNumber];
				
				if theAttributeArea.allLocationControllers.includes(lc) then
					// only look at this controller if the space at the maximum height for the TI is empty
					if lc.CM_GridController.allTrackedItems.size &lt; maxHeight  then
						self.autoPlanTestLC(lc,theAutoMovePlan,theAttributeArea);
						if theAutoMovePlan.getController &lt;&gt; null then
							//-------------
							//We have found a suitable location for this TI, we can go home now. The End
							//-------------
							return;
						endif;
					endif;
				endif;
			endforeach;
		endforeach;
	endif;
end;</source>
        <Parameter name="theAutoMovePlan" type="CMIF_AutoMovePlan" usage="input"/>
        <Parameter name="theAttributeArea" type="CM_AttributeArea" usage="input"/>
        <Parameter name="_theLC" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="autoPlanRow02" id="167fa9b4-9f23-48e7-818e-cd3ae1460e66">
        <updating/>
        <source>autoPlanRow02(theAutoMovePlan: CMIF_AutoMovePlan input; theAttributeArea: CM_AttributeArea input;_theLC : CM_LocationsController) updating;
// ---------------------------------------------------------------------------
// Created:		November 2002 By Andrew Bishop cnwab1
//
// Purpose:		STACK_ALONG_ROW - One level at a time
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	lc	:CM_LocationsController;
	stackController : CM_StackController;
	numInColl,columnNumber,columnTotal : Integer;
	maxHeight,rowNumber,rowTotal, theStartColumn, theStartRow : Integer;
	locnId	:	String;
	levelNumber : Integer;
	directionForward : Boolean;
begin
	directionForward := self.getDirectionForward(theAutoMovePlan);

	// Work out the maximum height, not in feet but in containers. Note the stacks max height is in feet based on the ability to stack 9'6"s
	maxHeight := self.autoPlanGetMaxHeight(theAutoMovePlan);
	
	if directionForward then // go forward
		columnTotal := self.numberOfColumns;
		rowTotal := self.numberOfRows;
		// HUNT FIRST SIMILAR
		if _theLC &lt;&gt; null then
			theStartColumn := _theLC.CM_GridController.myGridColumn.column;
			theStartRow :=  _theLC.CM_GridController.myGridRow.row;
		else
			theStartColumn := 0;
			theStartRow := 1;
		endif;

		// do not use the order of the restricted locations. Always start at the back left hand corner and work through.
		foreach rowNumber in theStartRow to rowTotal do
			foreach columnNumber in theStartColumn to columnTotal  do 
				foreach levelNumber in 1 to maxHeight do
					lc := self.allGridControllersByRowColumn[rowNumber,columnNumber];
				
					theAutoMovePlan.iteration := levelNumber;
				
					if theAttributeArea.allLocationControllers.includes(lc) then
	
						stackController := lc.CM_StackController;
						// this option says to go through the locations filling up each level first for a row before moving onto the next row
						numInColl := stackController.allQueuedFutureMoves.size + stackController.allTrackedItems.size;
						if numInColl  &lt; levelNumber then
							// only look at this controller if the space at the maximum height for the TI is empty
							if numInColl &lt; maxHeight then
								self.autoPlanTestLC(lc,theAutoMovePlan,theAttributeArea);
								if theAutoMovePlan.getController &lt;&gt; null then
									//-------------
									//We have found a suitable location for this TI, we can go home now. The End
									//-------------
									return;
								endif;
							endif;
						endif;
					endif;
				endforeach; // levelNumber
			endforeach; // controller
		endforeach; // rowNumber
	else // backwards
		// HUNT FIRST SIMILAR
		if _theLC &lt;&gt; null then
			theStartColumn := _theLC.CM_GridController.myGridColumn.column;
			theStartRow :=  _theLC.CM_GridController.myGridRow.row;
		else
			theStartColumn := self.numberOfColumns;
			theStartRow := self.numberOfRows;
		endif;
		// do not use the order of the restricted locations. Always start at the back left hand corner and work through.
		foreach rowNumber in theStartRow to rowTotal reversed do
			foreach columnNumber in theStartColumn to columnTotal reversed  do 
				foreach levelNumber in 1 to maxHeight do
					lc := self.allGridControllersByRowColumn[rowNumber,columnNumber];
				
					theAutoMovePlan.iteration := levelNumber;
				
					if theAttributeArea.allLocationControllers.includes(lc) then
	
						stackController := lc.CM_StackController;
						// this option says to go through the locations filling up each level first for a row before moving onto the next row
						numInColl := stackController.allQueuedFutureMoves.size + stackController.allTrackedItems.size;
						if numInColl  &lt; levelNumber then
							// only look at this controller if the space at the maximum height for the TI is empty
							if numInColl &lt; maxHeight then
								self.autoPlanTestLC(lc,theAutoMovePlan,theAttributeArea);
								if theAutoMovePlan.getController &lt;&gt; null then
									//-------------
									//We have found a suitable location for this TI, we can go home now. The End
									//-------------
									return;
								endif;
							endif;
						endif;
					endif;
				endforeach; // levelNumber
			endforeach; // controller
		endforeach; // rowNumber
	endif;	
end;</source>
        <Parameter name="theAutoMovePlan" type="CMIF_AutoMovePlan" usage="input"/>
        <Parameter name="theAttributeArea" type="CM_AttributeArea" usage="input"/>
        <Parameter name="_theLC" type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="autoPlanTestLC" id="de3576ea-fa75-490e-a581-2750ae40deac">
        <updating/>
        <source>autoPlanTestLC(_theLC : CM_LocationsController;theAutoMovePlan: CMIF_AutoMovePlan input; theAttributeArea: CM_AttributeArea input) updating;
// ---------------------------------------------------------------------------
// Created:		November 2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// ---------------------------------------------------------------------------

vars
	locnId	:	String;

begin
	// check that it is in the list for this attribute plan
	if theAttributeArea.allLocationControllers.includes(_theLC) then
		theAutoMovePlan.numLCsTested := theAutoMovePlan.numLCsTested +1;

		locnId := _theLC.getFullId &amp; theAutoMovePlan.iteration.String;
		//theAutoMovePlan.addLogEntry("Testing : " &amp; locnId, IsForLogging ); //- cnwmd1, Par 20524
		theAutoMovePlan.addLogEntry(app.getErrorString1(Testing, locnId), IsForLogging, Testing);
		//-------------
		//Test this LC and see if it meets the criteria in the autoplan
		//-------------
		_theLC.testAutoPlan(theAutoMovePlan);		//Test this lc against the autoplan criteria
	endif;
end;</source>
        <Parameter name="_theLC" type="CM_LocationsController"/>
        <Parameter name="theAutoMovePlan" type="CMIF_AutoMovePlan" usage="input"/>
        <Parameter name="theAttributeArea" type="CM_AttributeArea" usage="input"/>
    </JadeMethod>
    <JadeMethod name="calculateMoveLCs" id="c3db37c0-4a5e-4fa4-98a9-4abcf11caa4d">
        <source>calculateMoveLCs(ti: CM_TrackedItem): Real;
// ---------------------------------------------------------------------------
// Created:		28 November 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
begin
	//return ti.getActualLength() / self.locationLength;
	return ti.getMoveLengthForLCs() / self.locationLength; // PAR 16415 CCMS 1029
	
end;</source>
        <Parameter name="ti" type="CM_TrackedItem"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="canAccessHeight" id="3422ed13-b574-4580-a25d-56bf4aa3b1e1">
