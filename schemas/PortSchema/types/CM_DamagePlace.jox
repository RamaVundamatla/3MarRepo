    <JadeMethod name="shouldAuditProperty" id="a7f52f5c-5e0a-4f86-8353-840edadce55a">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 August 2022	navak20	TFS ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars

begin
	if _property = null then
		return false;
	endif;
	return inheritMethod(_rootClass, _property);

epilog

end;</source>
