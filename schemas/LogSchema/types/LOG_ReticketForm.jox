    <JadeMethod name="doSave" id="5a7e5bf5-1496-4319-9c22-02b8c3d51ba5">
        <updating/>
        <source>doSave() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     21/7/2006  cnwrbb1
//
// Purpose:     			call inheritmethod so form is unloaded
//
// ----------   ----------  --------------------------------------------------
vars
	
begin
	if doSaveRetickets = true then
		myCurrentView := null;
		modalResult := MsgBox_Return_OK;
		unloadForm();
	endif;
	return true;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSaveRetickets" id="19f3d3c0-5466-4325-9019-3500756f026a">
        <updating/>
        <source>doSaveRetickets() : Boolean updating;
// ---------------------------------------------------------------------------
// Created:     18 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	errorReticketSet: CMIF_TIReticketSet;
	reticketTI		: CMIF_TIReticket;
	errorStr		: String;
	cmif			: CMIF_Remote;
	rtnValue		: Boolean;
	manager			: CM_RemoteDataManagerInternal;
	newLocation,
	location		: CM_LogController;
	result			: Integer;
	log				: CM_Log;
	
begin
	if allCMIF_TIRetickets.isEmpty then
		app.msgBox('Please enter old and new log IDs, and add to the re-ticket table', 'Re-tickets', MsgBox_OK_Only+MsgBox_Exclamation_Mark_Icon);
		rtnValue := false;
		return rtnValue;
	endif;
	
	log			:= self.allCMIF_TIRetickets.first.myLog;				// PAR 21218 24/02/2010
	if log &lt;&gt; null then		// PAR 22597 8/03/2010
		location	:= log.getPrimaryLocation(REAL_MODE).CM_LogController;	// PAR 21218 24/02/2010 - I am going to compare an old location with a new location later.
	endif;
	newLocation	:= self.cmbTOLocation.listObject.CM_LogController;
	
	create errorReticketSet transient;
	app.mousePointer := MousePointer_HourGlass;
	
	//if self.chkBackground.value then//par11486
	if self.btnBackground.value then
		create cmif transient;
		create manager transient;
		cmif.transactionType	:= manager.RETICKETRQ;
		cmif.terminal			:= self.myTerminal.code;
		self.getRetickets(cmif.allTis);
		// PAR 21218 24/02/2010. Moving to a new location used to be ignored in BGP mode
		if (newLocation &lt;&gt; null) and (location &lt;&gt; null) and (newLocation &lt;&gt; location) then
			cmif.isMove	:= true;
			cmif.terminalAreaTo		:= newLocation.myTerminalArea.id;
			cmif.location			:= newLocation.id;
		endif;
	endif;
	
	// ccms 1107 / PAR20999 - need to organize warnings to a user
	while true do
	
		if self.btnBackground.value then
			rtnValue := manager.processInternal(cmif, app.myPassport);
		else
			if errorReticketSet.size &gt; 0 then
				errorReticketSet.clear();
			endif;
			app.myTrxUA.trxUpdateReticketTI(self.allCMIF_TIRetickets, 
													errorReticketSet,
													TI_CargoType_Log,
													TA_TYPE_LOGAREA,
													newLocation,
													app.myPassport);
			rtnValue := app.myPassport.trxCompletedOK;
		endif;
	
		if app.myPassport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			
			if errorReticketSet.size &gt; 0 then
				self.tblAll.rows := self.tblAll.fixedRows;
				errorStr := 'The following re-tickets were not processed:';
				errorStr := errorStr &amp; CrLf;
				foreach reticketTI in errorReticketSet do
					errorStr := errorStr &amp; CrLf &amp; reticketTI.errorDescription;
					self.addTblAllRow(reticketTI);
				endforeach;
				errorStr := errorStr &amp; CrLf &amp; CrLf &amp; 'The re-tickets in error are displayed in the table of the Re-ticketing screen.';
				app.msgBox(errorStr, 'Re-tickets in error', MsgBox_OK_Only+MsgBox_Exclamation_Mark_Icon);
			else
				self.allCMIF_TIRetickets.purge;
				self.tblAll.rows := tblAll.fixedRows;
				self.tblItem.setFocus;
				self.tblItem.setValueByName(ETRow_OldLogId, null);
				self.tblItem.setValueByName(ETRow_NewLogId, null);
				self.tblItem.goToRowByName(ETRow_OldLogId);
				self.cmbTOLocation.clear(); // Mohammad 28.6.2007 par#14281
			endif;
			
			self.clearErrorWarnings();
			break;

		else
			result := app.showErrorWarningDialog('Reticket', app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			if app.myPassport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
			return false;
			
		endif;
		break;
		
	endwhile;
	
	
epilog
	rtnValue := rtnValue and errorReticketSet.isEmpty;
	delete errorReticketSet;
	delete cmif;
	delete manager;
	app.mousePointer := MousePointer_Default;
	return rtnValue;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTblAllClick" id="bdc7230c-4cf6-42b9-bca3-57b061c39b51">
        <updating/>
        <source>doTblAllClick(table: Table input) updating;
// ---------------------------------------------------------------------------
// Created:     05 September 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars
	logReticket			: CMIF_TIReticket;	
	
begin
	logReticket := self.tblAll.accessRow(self.tblAll.row).itemObject.CMIF_TIReticket;
	if logReticket &lt;&gt; null then
		tblItem.setValueByName(ETRow_OldLogId, logReticket.oldId);
		tblItem.setValueByName(ETRow_NewLogId, logReticket.newId);
	endif;

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAvailableLocations" id="2e1f0c1a-7a62-4e74-b546-18d0864b0c8d">
        <source>getAvailableLocations() protected;

vars

	location		: CM_LocationsController;
	tmpLCSearch		: CMIF_SearchTypes;
	row				: Integer;
	cell			: JadeTableCell;
	array			: CMIF_DocketLogDefByLocation;
	isFirst			: Boolean;
	prevSelection	: String;
	reticket		: CMIF_TIReticket;
	
begin

	app.mousePointer := MousePointer_HourGlass;	
	self.allLocations.clear;
	prevSelection := self.cmbTOLocation.text;
	create tmpLCSearch transient;
	isFirst := true;
	create array transient;
	foreach reticket in self.allCMIF_TIRetickets do
		if reticket.myLog &lt;&gt; null then
			tmpLCSearch.myOperator := reticket.myLog.myOperator;
			if reticket.myLog.myLogSpecies &lt;&gt; null and not tmpLCSearch.allSpecies.includes(reticket.myLog.myLogSpecies) then
				tmpLCSearch.allSpecies.add(reticket.myLog.myLogSpecies);
			endif;
				
			if reticket.myLog.myLogGrade &lt;&gt; null and not tmpLCSearch.allGrades.includes(reticket.myLog.myLogGrade) then
				tmpLCSearch.allGrades.add(reticket.myLog.myLogGrade);
			endif;
				
			if reticket.myLog.myLogType &lt;&gt; null and not tmpLCSearch.allTypes.includes(reticket.myLog.myLogType) then
				tmpLCSearch.allTypes.add(reticket.myLog.myLogType);
			endif;
				
			if reticket.myLog.myLogTreatment &lt;&gt; null and not tmpLCSearch.allTreatments.includes(reticket.myLog.myLogTreatment) then
				tmpLCSearch.allTreatments.add(reticket.myLog.myLogTreatment);		
			endif;
				
			if reticket.myLog.myLogLength &lt;&gt; null and not tmpLCSearch.allLengths.includes(reticket.myLog.myLogLength) then
				tmpLCSearch.allLengths.add(reticket.myLog.myLogLength);
			endif;
		endif;	
	endforeach;	
	if isFirst then
		self.myTerminal.availableLocationsForType(tmpLCSearch, self.allLocations, TA_TYPE_LOGAREA);
		isFirst := false;
	else
		self.myTerminal.availableLocationsForTypeSub(tmpLCSearch, self.allLocations, TA_TYPE_LOGAREA);
	endif;
	
	// Load up combobox.	
	self.myAssistant.comboBoxAddLocationsWithNull(self.cmbTOLocation, self.allLocations);
	if self.cmbTOLocation.findStringExact(1,prevSelection) &lt;&gt; -1 then
		self.cmbTOLocation.text := prevSelection;
		self.tblActionData.setValueByName(ETRow_ToLocation, prevSelection);	
	else
		self.tblActionData.setValueByName(ETRow_ToLocation, null);	
	endif;

epilog
	
	delete tmpLCSearch;
	delete array;
	app.mousePointer := MousePointer_Default;	

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getRetickets" id="3a6821c2-073a-46e6-b7fa-c9adb7c67676">
        <source>getRetickets(_strArray : StringArray input);

// cnwdvb1 20 November 2002 

vars

	reticket : CMIF_TIReticket;

begin

	_strArray.clear();
	foreach reticket in self.allCMIF_TIRetickets do
		_strArray.add(reticket.oldId &amp; ',' &amp; reticket.newId);
	endforeach;

end;</source>
        <Parameter name="_strArray" type="StringArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initTblActionData" id="facad56f-4a8a-4748-a3af-2d8da93633aa">
        <source>initTblActionData();

// cnwdvb1 13 January 2003 

