    <JadeMethod name="pxyCreateUpdateProxy" id="d9035adc-7313-48c3-81d3-4e7a5e0e5c91">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 April 2018	jlgndl1	Initial creation	TFS 37818

*/

vars

	proxy : CM_InvoiceTypeSurchargeExempt;
	completedOK : Boolean;

begin

	proxy := inheritMethod();
	
	proxy.myInvoiceType := self.myInvoiceType;	//02 Nov 2018	NDL	TFS 41684
	proxy.myMinimumChargeInvoiceLineType := self.myMinimumChargeInvoiceLineType;	//02 Nov 2018	NDL	TFS 41684
	proxy.myCurrencyType := self.myCurrencyType;	//02 Nov 2018	NDL	TFS 41684
	proxy.myInvoiceDescForSeperateTax := self.myInvoiceDescForSeperateTax;	//07 May 2019	NDL	TFS 44651
	
	completedOK := true;
	return proxy;

epilog

	if not completedOK then
		delete proxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
