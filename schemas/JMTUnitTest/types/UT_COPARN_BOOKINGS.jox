<Class name="UT_COPARN_BOOKINGS" id="05e222b3-ca07-419b-b38f-0be753cb72bd">
    <superclass name="UT_EDI"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="unitTest"/>
    <JadeMethod name="iCoparnVGM" id="5fb2849b-4ced-4170-8b55-0e2de5e5933a">
        <source>iCoparnVGM();
/*

Date		Who		Reason
05 February 2016	cnwer1	Initial creation PAR
//06 May 2016	cnwrs1	TFS 1600 COPARN VGM
*/
constants
	ShipName 	= "VGM111";
	VoyageName 	= "VGM111VOY";
	SENDER1		= 'MSKNZ';
	BookingNo1 	= "VGM111a";
	Cargo1  = "VGMC000001";
vars
	text : String;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	ediFile : CM_EDIFile;
	tempStr : String;
	ediData : CM_EDIDataVGM;
	ediVGMTI : CM_EDIVGMTI;
	ediTI : CM_EDITrackedItem;
//	cargoWeightUpdateRequest,
//	cargoUpdateRequest : CM_EventRequestStops;
	iter: Iterator;
	terminal : CM_Terminal;
	obj : CM_Object;
	vvr : CM_VehicleVisitRecord;
	ti : CM_TrackedItem;
begin	

	text:="UNA:+.? '
UNB+UNOA:1+" &amp; SENDER1 &amp; "+NZWLGT01+20130415:0933+003780'
UNH+00000000000002+COPARN:D:95B:UN:SMDG16'
BGM+11+" &amp; BookingNo1 &amp; "+9'
RFF+BN:" &amp; BookingNo1 &amp; "'
TDT+20+"&amp;VoyageName&amp;"+1++MAE:172:20+++OYDM2:103::KIRSTEN MAERSK'
LOC+9+BEANR:139:6+K913:TER:ZZZ'
DTM+133:200510301230:203'
DTM+132:200510291400:203'
NAD+CA+MAE:172:20'
EQD+CN+" &amp; Cargo1 &amp; "+45R1:102:5+2+2+5'
RFF+BN:"&amp;VoyageName&amp;"'
RFF+SQ:32702'
TMD+3++1'
LOC+11+SGSIN:139:6'
LOC+8+IDJKT:139:6'
MEA+AAE+VGM+KGM:18000'
NAD+SPC+++UT_CL_VOY1:172:20'
NAD+AM+++JOHN P. SMITH:C/O A1 LTD+B1 STREET 100:PO BOX 1000+C CITY++9000+DE'
CNT+16:1'
UNT+23+00000000000002'";

	self.deleteVoyage(VoyageName);
	self.deleteVessel(ShipName);
	self.deleteBooking(BookingNo1);
	terminal := self.getTerminal();
	self.deleteCargo(Cargo1, "CONT");

	vessel := self.addVesselCellular(ShipName, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertNotNullMsg(vessel, "Add vessel failed");
	
	voyage := self.addVoyageWithContainerStructur(VoyageName, ShipName, 'PIL', self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg (voyage, "Add voyage failed");
	
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN-1"&amp;method.name);
	
	self.assertNotNull(ediFile);
	self.ediVerify(ediFile);
	
	tempStr	:= 'Verified failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg( ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, tempStr );
	
	self.ediDBLoad(ediFile);
	
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_DBLOADED);
	
	if ediFile.ediData.isKindOf(CM_EDIDataVGM) then
		ediData := ediFile.ediData.CM_EDIDataVGM;
	endif;
	
	self.assertNotNull(ediData);
	self.assertEqual(ediData.allEDITrackedItems.size, 1);//booking header and booking item
	
	foreach ediTI in ediData.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDIVGMTI) then
			ediVGMTI := ediTI.CM_EDIVGMTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNull(ediVGMTI);
	self.assertEqual(ediVGMTI.id , Cargo1);
	self.assertEqual(ediVGMTI.totalWeight, 18000.Decimal);
	self.assertTrue(app.myRoot.canDo(Mod_EDIVGM));
	
	self.deleteVehicle("UT_VGM");
	vvr := self.gateInContainer("UT_VGM", Cargo1, "2200", self.getOperator("ANL"). code,"GENL", null);
	self.assertNotNull(vvr);
	
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_DBLOADED);
	
	ti := vvr.allReceivedTrackedItems.first;
	self.assertNotNull(ti);
	self.assertEqual(ti.totalWeight, 18000.Decimal);
	self.assertTrue(ti.isWeightCertified);
	self.assertEqual(ti.weightCertifiedName, "JOHN P. SMITH");
	self.assertEqual(ti.weightCertifiedReference, "UT_CL_VOY1");
epilog
	delete iter;
end;</source>
    </JadeMethod>
    <JadeMethod name="iCoparnVGMAlert" id="4e9c13ba-b6c6-4668-82f6-3a9d781d7af8">
        <source>iCoparnVGMAlert();
/*

Date		Who		Reason
05 February 2016	cnwer1	Initial creation PAR
//06 May 2016	cnwrs1	TFS 1600 COPARN VGM
*/
constants
	ShipName 	= "VGM111";
	VoyageName 	= "VGM111VOY";
	SENDER1		= 'MSKNZ';
	BookingNo1 	= "VGM111a";
	Cargo1  = "VGMC000001";
vars
	text : String;
	vessel : CM_Vessel;
	voyage : CM_Voyage;
	ediFile : CM_EDIFile;
	tempStr : String;
	ediData : CM_EDIDataVGM;
	ediVGMTI : CM_EDIVGMTI;
	ediTI : CM_EDITrackedItem;
//	cargoWeightUpdateRequest,
//	cargoUpdateRequest : CM_EventRequestStops;
	iter: Iterator;
	terminal : CM_Terminal;
	obj : CM_Object;
	vvr : CM_VehicleVisitRecord;
	ti : CM_TrackedItem;
	alert : CM_SystemAlert;
	alertDetails : HugeStringArray;
begin	

	text:="UNA:+.? '
UNB+UNOA:1+" &amp; SENDER1 &amp; "+NZWLGT01+20130415:0933+003780'
UNH+00000000000002+COPARN:D:95B:UN:SMDG16'
BGM+11+" &amp; BookingNo1 &amp; "+9'
RFF+BN:" &amp; BookingNo1 &amp; "'
TDT+20+"&amp;VoyageName&amp;"+1++MAE:172:20+++OYDM2:103::KIRSTEN MAERSK'
LOC+9+BEANR:139:6+K913:TER:ZZZ'
DTM+133:200510301230:203'
DTM+132:200510291400:203'
NAD+CA+MAE:172:20'
EQD+CN+" &amp; Cargo1 &amp; "+45R1:102:5+2+2+5'
RFF+BN:"&amp;VoyageName&amp;"'
RFF+SQ:32702'
TMD+3++1'
LOC+11+SGSIN:139:6'
LOC+8+IDJKT:139:6'
MEA+AAE+VGM+KGM:18000'
NAD+SPC+++UT_CL_VOY1:172:20'
NAD+AM+++JOHN P. SMITH:C/O A1 LTD+B1 STREET 100:PO BOX 1000+C CITY++9000+DE'
CNT+16:1'
UNT+23+00000000000002'";

	self.deleteVoyage(VoyageName);
	self.deleteVessel(ShipName);
	self.deleteBooking(BookingNo1);
	terminal := self.getTerminal();
	self.deleteCargo(Cargo1, "CONT");

	vessel := self.addVesselCellular(ShipName, self.getOperator(self.getProfileSetting(UT_Profile.P_OPERATOR).asString));
	self.assertNotNullMsg(vessel, "Add vessel failed");
	
	voyage := self.addVoyageWithContainerStructur(VoyageName, ShipName, 'PIL', self.getProfileSetting(UT_Profile.P_SHIPPING_LINE).asString);
	self.assertNotNullMsg (voyage, "Add voyage failed");
	
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN-1"&amp;method.name);
	
	self.assertNotNull(ediFile);
	self.ediVerify(ediFile);
	
	tempStr	:= 'Verified failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertEqualMsg( ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, tempStr );
	
	self.ediDBLoad(ediFile);
	
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_DBLOADED);
	
	if ediFile.ediData.isKindOf(CM_EDIDataVGM) then
		ediData := ediFile.ediData.CM_EDIDataVGM;
	endif;
	
	self.assertNotNull(ediData);
	self.assertEqual(ediData.allEDITrackedItems.size, 1);//booking header and booking item
	
	foreach ediTI in ediData.allEDITrackedItems do
		if ediTI.isKindOf(CM_EDIVGMTI) then
			ediVGMTI := ediTI.CM_EDIVGMTI;
			break;
		endif;
	endforeach;
	
	self.assertNotNull(ediVGMTI);
	self.assertEqual(ediVGMTI.id , Cargo1);
	self.assertEqual(ediVGMTI.totalWeight, 18000.Decimal);
	self.assertTrue(app.myRoot.canDo(Mod_EDIVGM));
	
	self.deleteVehicle("UT_VGM");
	vvr := self.gateInContainer("UT_VGM", Cargo1, "2200", self.getOperator("ANL"). code,"GENL", null);
	self.assertNotNull(vvr);
	
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_DBLOADED);
	
	ti := vvr.allReceivedTrackedItems.first;
	self.assertNotNull(ti);
	self.assertEqual(ti.totalWeight, 18000.Decimal);
	self.assertTrue(ti.isWeightCertified);
	self.assertEqual(ti.weightCertifiedName, "JOHN P. SMITH");
	self.assertEqual(ti.weightCertifiedReference, "UT_CL_VOY1");
	
	
	text:="UNA:+.? '
UNB+UNOA:1+" &amp; SENDER1 &amp; "+NZWLGT01+20130415:0933+003780'
UNH+00000000000002+COPARN:D:95B:UN:SMDG16'
BGM+11+" &amp; BookingNo1 &amp; "+9'
RFF+BN:" &amp; BookingNo1 &amp; "'
TDT+20+"&amp;VoyageName&amp;"+1++MAE:172:20+++OYDM2:103::KIRSTEN MAERSK'
LOC+9+BEANR:139:6+K913:TER:ZZZ'
DTM+133:200510301230:203'
DTM+132:200510291400:203'
NAD+CA+MAE:172:20'
EQD+CN+" &amp; Cargo1 &amp; "+45R1:102:5+2+2+5'
RFF+BN:"&amp;VoyageName&amp;"'
RFF+SQ:32702'
TMD+3++1'
LOC+11+SGSIN:139:6'
LOC+8+IDJKT:139:6'
MEA+AAE+VGM+KGM:18032'
NAD+SPC+++UT_CL_VOY2:172:20'
NAD+AM+++JOHN P.J SMITH:C/O A1 LTD+B1 STREET 100:PO BOX 1000+C CITY++9000+DE'
CNT+16:1'
UNT+23+00000000000002'";
	
	ediFile := self.ediLoadFileName(text, EDIFileType_Unknown, "COPARN", "COPARN-2"&amp;method.name);
	self.assertNotNull(ediFile);
	self.ediVerify(ediFile);
	self.assertEqualMsg( ediFile.fileStatus, CM_EDIFile.EDI_STATUS_VERIFIED_WARNINGS, tempStr );
	
	self.ediDBLoad(ediFile);
	tempStr	:= 'DB Load failed' &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	self.assertIsOneOf(ediFile.fileStatus, tempStr, CM_EDIFile.EDI_STATUS_DBLOADED);
	
	if ediFile.ediData.isKindOf(CM_EDIDataVGM) then
		ediData := ediFile.ediData.CM_EDIDataVGM;
	endif;
	
	self.assertNotNull(ediData);
	self.assertEqual(ediData.allEDITrackedItems.size, 1);//booking header and booking item
	
	self.assertEqual(ti.totalWeight, 18032.Decimal);
	self.assertTrue(ti.isWeightCertified);
	self.assertEqual(ti.weightCertifiedName, "JOHN P.J SMITH");
	self.assertEqual(ti.weightCertifiedReference, "UT_CL_VOY2");
	
	alert :=ti.allAlerts.last;
	self.assertNotNull(alert);
	
	create alertDetails transient;
	alert.details.getTokensForDelimiterHugeNoNul(CrLf,alertDetails);
	self.assertEqual(alertDetails.size,5);
	
	self.assertEqual(alertDetails[2].trimBlanks,app.getErrorString3(Total_weight_changed_from,Cargo1,"39683.240 lbs" ,"39753.788 lbs"));
	self.assertEqual(alertDetails[3],app.getErrorString3(Weight_certifi_changed_from,Cargo1 ,"UT_CL_VOY1" ," UT_CL_VOY2"));
	self.assertEqual(alertDetails[4],app.getErrorString3(Autho_perso_certi_weigh_chang,Cargo1 ,"JOHN P. SMITH" ,"JOHN P.J SMITH"));
epilog
	delete iter;
	delete alertDetails;
end;</source>
        <text>&lt;?xml version="1.0"?&gt;
