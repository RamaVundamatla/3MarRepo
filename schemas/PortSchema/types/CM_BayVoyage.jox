    <JadeMethod name="archive" id="eeacbc41-711d-435a-afe7-4d2a1f9015f0">
        <updating/>
        <source>archive(_controller : CMIF_ArchiveVoyage; _moveControl : CMIF_MoveController input; _passport : CM_Passport input) updating;
/*
------------------------------------------------------------------------
Created:			20 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
13 Mar 2020 cnwma1 Bug 48863: JMT - Voyage Archive, Non Worked Cargo Issue														
------------------------------------------------------------------------
*/
vars
	slotControllerIter : Iterator;
	slotController 	: CM_SlotController;	
	objSet		:	ObjectSet;
	obj			:	Object;
	tiArray		: CM_TIArray;
begin

	exclusiveLock(self);
	if _controller = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'CMIF_ArchiveVoyage controller', null, null);
		return;
	endif;
	if _passport = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'passport', null, null);
		return;
	endif;
	if _moveControl = null then
		app.raiseCMException2(MethodWithNullParam, method.name, '_moveControl', null, null);
		return;
	endif;	

	create tiArray transient;

	slotControllerIter := self.allSlotControllersByOrdinal.createIterator;
	while slotControllerIter.next(slotController) do
		slotController.archive(_controller, _moveControl, tiArray, _passport);
	endwhile;

epilog
	delete tiArray;
	delete slotControllerIter;
end;</source>
        <Parameter name="_controller" type="CMIF_ArchiveVoyage"/>
        <Parameter name="_moveControl" type="CMIF_MoveController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createDefaultDischargeCC" id="fce7effe-d167-4deb-b664-4b743653a210">
        <updating/>
        <source>createDefaultDischargeCC(_passport : CM_Passport input) updating;
/*
------------------------------------------------------------------------
Created:			26 February 2003 by cnwdwq1
Purpose:			Called from the voyage for each bay, sets the slotRequest to Discharge
Parameters:		
Returns:			
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	slotControllerIter : Iterator;
	slotController : CM_SlotController;
begin
	slotControllerIter := self.allSlotControllersByOrdinal.createIterator;
	while slotControllerIter.next(slotController) do
		slotController.createDefaultDischargeCC(DISCHARGE_MOVETYPE, false, _passport); // PAR 28968 isManual
	endwhile;

epilog
	delete slotControllerIter;
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createPlanningStructsCells" id="a6dd61f7-db31-48ee-bde6-d57b21c058fb">
        <updating/>
        <source>createPlanningStructsCells(_bayDefn : CM_BayDefn) updating, protected;
/*
------------------------------------------------------------------------
Created:			04 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	cellDefn : CM_CellDefn;
	newCellDefn : CM_CellDefn;
	iAmTransient : Boolean;
begin
	iAmTransient := self.isTransient;
	
	if _bayDefn = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No bayDefinition ref');
		return;
	endif;
	//-----------------
	//On deck cells
	//-----------------
	foreach cellDefn in _bayDefn.allCellsOnDeckByOrdinal do
		newCellDefn := cellDefn.cloneSelf(iAmTransient);
		newCellDefn.setMyBay(self, true);
	endforeach;
	//-----------------
	//Under deck cells
	//-----------------
	foreach cellDefn in _bayDefn.allCellsUnderDeckByOrdinal do
		newCellDefn := cellDefn.cloneSelf(iAmTransient);
		newCellDefn.setMyBay(self, false);
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_bayDefn" type="CM_BayDefn"/>
    </JadeMethod>
    <JadeMethod name="createPlanningStructsHatchLids" id="e58cd727-d432-45e3-b776-1b5ec90284f2">
        <updating/>
        <source>createPlanningStructsHatchLids(_bayDefn : CM_BayDefn) protected, updating;
/*
------------------------------------------------------------------------
Created:			03 February 2003 by cnwdwq1
Purpose:			Code to encapsulate the creation of hatchlids. These are a little dfficult in that
							they dont necessarily start at a specic bay (i.e, the 1st in the old) like holds do.
Parameters:		The original bayDefn we are cloning from
Returns:			Nothing:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	tmpHatch : CM_HatchLid;
	vessHatch : CM_HatchLidVessel;
	hatch : CM_HatchLidVoyage;
	bay : CM_Bay;
	bayVessel : CM_BayDefn;
	bayVoyage : CM_BayVoyage;
	iAmTransient : Boolean;
begin
	iAmTransient := self.isTransient;

	if _bayDefn = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No bayDefinition ref');
		return;
	endif;
	//---------------------
	//Determine WHICH hatches START in THIS bay
	//---------------------
	foreach tmpHatch in _bayDefn.allHatchLids do
		vessHatch := tmpHatch.CM_HatchLidVessel;

		if vessHatch.ordinalStartBay &lt;&gt; self.ordinalBay then
			//This hatch doesnt start here, so we have to find out where it was constructed
			bay := vessHatch.getHatchPrimaryBay();
			if bay = null then
				//Real problem. NO definition!
				app.raiseUnexpectedProgramError(class.name, method.name, 'Vessels hatch '&amp; vessHatch.String &amp; ' has no primary bay' );
				return;							
			endif;
			//---------------------------
			//Now we have a bay(its actually a bayDefn). Find it's equiv bayVoyage
			//---------------------------
			bayVoyage := self.myCellularVoyageStructure.allBayVoyagesByOrdinal[bay.ordinalBay];
			if bayVoyage = null then
				if bay.ordinalBay &gt; self.ordinalBay then
					//We havent reached this bay yet, when we reach it this code will work.
					continue;
				endif;
				app.raiseUnexpectedProgramError(class.name, method.name, 'Unable to locate corresponding BayVoyage object from supplied BayDefn' );
			endif;
			//------------------
			//ok, add this to the hatch's bays coll
			//------------------
			hatch := bayVoyage.findHatchLid(vessHatch);
			if hatch = null then
				//Hmm, not sure about why this could happen.
				app.raiseUnexpectedProgramError(class.name, method.name, 'Unable to locate corresponding voyage hatch object from supplied vessel hatch' );
				return;
			endif;
		else
			//--------------------
			//Does start in this bay, clone from this hatch..
			//--------------------
			hatch := vessHatch.cloneSelfAs(CM_HatchLidVoyage, iAmTransient).CM_HatchLidVoyage;
		endif;
		//-----------------
		//and link to me/etc!
		//-----------------
		hatch.addBayVoyage(self);
		
		// PAR 15971 add in other bays for thsi hatch
		foreach bay in vessHatch.allBays discreteLock do
			bayVessel := bay.CM_BayDefn;
			
			if bayVessel.ordinalBay = self.ordinalBay then
				continue;
			endif;
			bayVoyage := self.myCellularVoyageStructure.allBayVoyagesByOrdinal[bayVessel.ordinalBay];
			if bayVoyage &lt;&gt; null then
				hatch.addBayVoyage(bayVoyage);
			endif;
			
			
		endforeach;
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_bayDefn" type="CM_BayDefn"/>
    </JadeMethod>
    <JadeMethod name="createPlanningStructsHolds" id="6fa5eed7-d94f-40c3-a608-7df655755263">
        <updating/>
        <source>createPlanningStructsHolds(_bayDefn : CM_BayDefn) updating, protected;
/*
------------------------------------------------------------------------
Created:			04 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	hold : CM_VoyageHold;
	iAmTransient : Boolean;
begin
	iAmTransient := self.isTransient;

	if _bayDefn = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No bayDefinition ref');
		return;
	endif;
	//-----------------
	//Hold &amp; Hatch lids
	//-----------------
	if _bayDefn.isFirstInHold then
		// PAR 7369 - AKB2004JAN if the voyage is converted, but had not structure and now they want structure the  holds are already here.
		// normally the holds are not present.
		hold := self.myCellularVoyageStructure.allHolds[_bayDefn.myHold.ordinalHold].CM_VoyageHold; // PAR 7369  added
		if hold = null then // PAR 7369 added
			create hold;
			hold.setFromVesselHold(_bayDefn.myHold.CM_VesselHold);
		endif;
		
	else
		//Get previous bay's hold
		if _bayDefn.myHold &lt;&gt; null then
			hold := self.myForwardBay.myHold.CM_VoyageHold;
		endif;
	endif;
	if hold &lt;&gt; null then
		self.myHold := hold;
		//This as to be set AFTER the properties are set cos hold is key triggered by ref being set.
		hold.setMyVoyage(self.myCellularVoyageStructure);	
	endif;	
end;</source>
        <access>protected</access>
        <Parameter name="_bayDefn" type="CM_BayDefn"/>
    </JadeMethod>
    <JadeMethod name="createPlanningStructsSlots" id="f738a090-fcb4-45e2-b105-3e56ba647ebe">
        <updating/>
        <source>createPlanningStructsSlots(_bayDefn : CM_BayDefn input) updating, protected;
/*
------------------------------------------------------------------------
Created:			04 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	slotDefn : CM_SlotDefn;
	slotDefnVoyage : CM_SlotDefnVoyage;
	aCell : CM_CellDefn;
	aTier : CM_TierDefn;
	iAmTransient : Boolean;
begin
	iAmTransient := self.isTransient;


	if _bayDefn = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No bayDefinition ref');
		return;
	endif;
	//----------------------
	//Clone the slotDefns as slotDefnVoyages
	//----------------------

	if app.isConverting then
		self.allSlotsByOrdinal.purge;
	endif;	
	
	foreach slotDefn in _bayDefn.allSlotsOnDeck do
		slotDefnVoyage := slotDefn.cloneSelfAs(CM_SlotDefnVoyage, iAmTransient).CM_SlotDefnVoyage;
		slotDefnVoyage.setMyBay(self, true);
		aCell := self.allCellsOnDeckByOrdinal[slotDefnVoyage.ordinalCell];
		aTier := self.allTiersOnDeck[slotDefnVoyage.ordinalTier];
		slotDefnVoyage.setCellAndTierDefn(aCell,aTier);

		//-----------------
		//And the slot controllers...
		//-----------------
		slotDefnVoyage.createSlotController(iAmTransient);
	endforeach;
	
	foreach slotDefn in _bayDefn.allSlotsUnderDeck do
		slotDefnVoyage := slotDefn.cloneSelfAs(CM_SlotDefnVoyage, iAmTransient).CM_SlotDefnVoyage;
		slotDefnVoyage.setMyBay(self, false);
		aCell := self.allCellsUnderDeckByOrdinal[slotDefnVoyage.ordinalCell];
		aTier := self.allTiersUnderDeck[slotDefnVoyage.ordinalTier];
		slotDefnVoyage.setCellAndTierDefn(aCell,aTier);
		//-----------------
		//And the slot controllers...
		//-----------------
		slotDefnVoyage.createSlotController(iAmTransient);
	endforeach;


end;</source>
        <access>protected</access>
        <Parameter name="_bayDefn" type="CM_BayDefn" usage="input"/>
    </JadeMethod>
    <JadeMethod name="createPlanningStructsTiers" id="345e34ff-4000-4e86-be93-06d2ea9da5ec">
        <updating/>
        <source>createPlanningStructsTiers(_bayDefn : CM_BayDefn) updating, protected;
/*
------------------------------------------------------------------------
Created:			04 February 2003 by cnwdwq1
Purpose:			Dave Q's code
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	tierDefn : CM_TierDefn;
	newtierDefn : CM_TierDefn;
	iAmTransient : Boolean;
begin
	iAmTransient := self.isTransient;


	if _bayDefn = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No bayDefinition ref');
		return;
	endif;
	//-----------------
	//On deck tiers
	//-----------------
	foreach tierDefn in _bayDefn.allTiersOnDeck do
		newtierDefn := tierDefn.cloneSelf(iAmTransient);
		newtierDefn.setMyBay(self, true);
	endforeach;
	//-----------------
	//Under deck tiers
	//-----------------
	foreach tierDefn in _bayDefn.allTiersUnderDeck do
		newtierDefn := tierDefn.cloneSelf(iAmTransient);
		newtierDefn.setMyBay(self, false);
	endforeach;

end;</source>
        <access>protected</access>
        <Parameter name="_bayDefn" type="CM_BayDefn"/>
    </JadeMethod>
    <JadeMethod name="createPlanningStructures" id="207f73f6-02d2-4ee2-86e6-f422ca8bdd14">
        <updating/>
        <source>createPlanningStructures(_bayDefn : CM_BayDefn input) updating;
/*
------------------------------------------------------------------------
Created:			17 January 2003 by cnwdwq1
Purpose:			copies the bayDefn's attributes to this new bayVoyage
							NOTE: I assume that I'm only copying NON-PRIMITIVES
							as this is called from a cloneSelfAs method.
Parameters:		As above. Special comment:
Returns:			As above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														 
------------------------------------------------------------------------
*/
begin
	if _bayDefn = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'No bayDefinition ref');
		return;
	endif;
	if not app.isConverting then
		self.createPlanningStructsHolds(_bayDefn);
	endif;
	self.createPlanningStructsHatchLids(_bayDefn);
	self.createPlanningStructsCells(_bayDefn);
	self.createPlanningStructsTiers(_bayDefn); 
	self.createPlanningStructsSlots(_bayDefn);
end;</source>
        <Parameter name="_bayDefn" type="CM_BayDefn" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doObjectVolatilityConversion" id="348ce27a-5588-4b02-addd-77765eae9ea4">
        <updating/>
        <source>doObjectVolatilityConversion(_converter: CM_ObjectVolatilityConverter input; _logIndent: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 May 2010	cnwkpd1	PAR #23525 - System performance enhancements

*/

vars

begin
	inheritMethod(_converter, _logIndent);

	_converter.doChangeVolatilityOfObject(self.allSlotControllersByOrdinal, _logIndent);
	
	
epilog

end;</source>
        <Parameter name="_converter" type="CM_ObjectVolatilityConverter" usage="input"/>
        <Parameter name="_logIndent" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="findHatchLid" id="4e4303be-bffd-418e-9265-bffb9004fc9b">
        <source>findHatchLid(_hatch : CM_HatchLidVessel) : CM_HatchLidVoyage protected;
/*
------------------------------------------------------------------------
Created:			03 February 2003 by cnwdwq1
Purpose:			For a passed in hatchlid, find a match and return it.
Parameters:		See Method signature above. Special comment:
Returns:			See Method signature above. Special comment:
Changed On		Changed By		Reason
------------	------------	-----------------------------------------
														
------------------------------------------------------------------------
*/
vars
	hatch : CM_HatchLid;
begin
	foreach hatch in self.allHatchLids do
		if hatch.isSameHatch(_hatch) then
			return hatch.CM_HatchLidVoyage;	//Trust me, these ARE voyage lids, NOT vessel types
		endif;
	endforeach;
	return null;
end;</source>
        <access>protected</access>
        <Parameter name="_hatch" type="CM_HatchLidVessel"/>
        <ReturnType type="CM_HatchLidVoyage"/>
    </JadeMethod>
    <JadeMethod name="findLocation" id="710bc7f0-541a-45fc-a0c2-5550201aca15">
        <source>findLocation(_strs: StringArray; _noException : Boolean; _foundLC: CM_LocationsController io; _foundHeight: Integer io);
/*
 ------------------------------------------------------------------------
Created:			04 November 2002 by cnwdwq1
Purpose:			
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------		--------------		-----------------------------------------
---------------------------------------------------------------------------
*/
vars
	tStr			: String;
	tierId			: String;
	cellId			: String;
	sc				: CM_SlotController;
	cellLen,
	tierLen,
	cellOrd			: Integer;
	tierOrd			: Integer;
	cell			: CM_CellDefn;
	tier			: CM_TierDefn;
	sdVoyage		: CM_SlotDefnVoyage;
begin
	//OK, we have to process the passed in strs. What we have here MUST be a valid tier/cell
	inheritMethod(_strs, _noException, _foundLC, _foundHeight);
	if _strs.isEmpty then
		return;
	endif;
	tStr := _strs[1].trimBlanks;

	if tStr = null then
		return;
	endif;	
	//What we should have here is either a cellid/tierid combo, or a reverse of tierid/cellid
	//depending on the type of vessel, reverse as required so we end up with a consistent
	//string for the dictionary lookup.

	if tStr.length() &lt;&gt; self.getDefinedLenOfCellTierId() then
		if _noException then
			_foundLC := null;
			_foundHeight := NULLINDEX;
			return;
		else
			// PAR 33441 this method should not raise an error it should just return.
			// PAR 33441 app.raiseCMException1(ERR_INVALID_LABEL, tStr, null, null);
			return;
		endif;
	endif;
	
//	cellLen := CM_SlotDefn.cnEcGetStringPropertyLength('cellId');
	cellLen := 2;
//	tierLen := CM_SlotDefn.cnEcGetStringPropertyLength('tierId');
	tierLen := 2;
	
	if not self.myCellularVoyageStructure.useBayCellTierNumbering then
//		self.reverseCellTierId(tStr, tierId, cellId);
		tierId := tStr[1: tierLen];
		cellId := tStr[(tStr.length - (cellLen -1)):end];
	else
		tierId := tStr[(tStr.length - (tierLen -1)):end];
		cellId := tStr[1: cellLen];
	endif;
	
	sdVoyage := self.getUnderDeckSlotForEDI(cellId, tierId).CM_SlotDefnVoyage;
	if sdVoyage = null then	// try on deck
		sdVoyage := self.getOnDeckSlotForEDI(cellId, tierId).CM_SlotDefnVoyage;
	endif;

	if sdVoyage &lt;&gt; null then
		sc := sdVoyage.mySlotController;
	endif;
	
	//-----------------
	//Find the controller
	//-----------------
	
	_foundLC := sc;
	return;
	
	// The lengths are hardcoded above
	write CM_SlotDefn::cellId.name;
	write CM_SlotDefn::tierId.name;

end;</source>
        <Parameter name="_strs" type="StringArray"/>
        <Parameter name="_noException" type="Boolean"/>
        <Parameter name="_foundLC" type="CM_LocationsController" usage="io"/>
        <Parameter name="_foundHeight" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="getActiveSlotLCsForColourCode" id="cb8e2645-8233-4a2b-8d64-c09ccc699c40">
        <source>getActiveSlotLCsForColourCode(ccType : Integer; scs : CM_SlotControllerArray input);
/*
 ------------------------------------------------------------------------
Created:			20 November 2002 by cnwdwq1
Purpose:			Iterates through, and gets all slotControllers where we have a type requested.
Parameters:		None
Returns:			Nothing
Changed On		Changed By		Reason
--------------	-------------	-----------------------------------------
24/04/2013		cnwcs5			par 30652 - remove resynch/resynchObject method calls
---------------------------------------------------------------------------
*/
vars
	slot : CM_SlotController;
begin
	if scs = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'SlotController Array', null, null);
		return;
	endif;
	scs.clear;
	if ccType &lt;&gt; LOAD_COLOURCODE and ccType &lt;&gt; DISCHARGE_COLOURCODE then
		app.raiseCMException1(ERR_INVALID_COLOURCODE, ccType.String, null, null);
		return;
	endif;
	//------------------
	//Find all slots in the colour code for the passed in type
	//------------------
	foreach slot in self.allSlotControllersByOrdinal do
		//----------------------
		//Test to see if its set
		//----------------------
		if ccType = LOAD_COLOURCODE then
			if slot.mySlotRequestLoad = null then
				continue;
			endif;
		elseif ccType = DISCHARGE_COLOURCODE then
			if slot.mySlotRequestDischarge = null then
				continue;
			endif;
		endif;
		scs.add(slot);
	endforeach;
end;</source>
        <Parameter name="ccType" type="Integer"/>
        <Parameter name="scs" type="CM_SlotControllerArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getActiveSlotReqs4DeckJobType" id="5751f078-69f3-4abf-ad73-b2f2ab2130ca">
        <source>getActiveSlotReqs4DeckJobType(_deck, _jobType : Integer; scs : CM_SlotRequestSet input; _get40 : Boolean);
// ---------------------------------------------------------------------------
// Created:		May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
*/

vars
	slot : CM_SlotController;
	sd : CM_SlotDefn;
	slotReqDisc, slotReqLoad : CM_SlotRequest;
	invalidDisc,
	invalidLoad		: Boolean;
	
begin
	if scs = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'SlotRequest Set', null, null);
		return;
	endif;
//	scs.clear;
	if _deck &lt;&gt; DeckOnDeck and _deck &lt;&gt; DeckUnderDeck then
		app.raiseCMException1(ERR_INVALID_COLOURCODE, _deck.String, null, null);
		return;
	endif;

	//------------------
	//Find all slots in the colour code for the passed in type
	//------------------
	
	on Exception do app.handleDeletedObject(exception, slotReqDisc, invalidDisc);
	on Exception do app.handleDeletedObject(exception, slotReqLoad, invalidLoad);
	
	foreach slot in self.allSlotControllersByOrdinal where slot.ordinalDeck = _deck do
		sd := slot.mySlotDefnVoyage;
		if sd.unavailable then
			continue;
		endif;
		
		// ### DISCHARGES

		if _jobType = JobTypePriority_DischargeDLR20 
		or _jobType = JobTypePriority_DischargeDLR40 
		or _jobType = JobTypePriority_DischargeIMP20
		or _jobType = JobTypePriority_DischargeIMP40 then

			slotReqDisc := slot.mySlotRequestDischarge;

//			if global.isValidObject(slotReqDisc)  
			if slotReqDisc &lt;&gt; null then
				if not slotReqDisc.unavailable 
				and slotReqDisc.myJob = null
				and not slotReqDisc.getAttrIsBackend() // PAR 21746
				 // PAR 21746 and not slotReqDisc.fortyBack
				 // PAR 21746 and not slotReqDisc.isBackend // PAR 19945
				and slotReqDisc.moveType &lt;&gt; NULL_MOVETYPE then
					if slotReqDisc.doIMatchCCType(_jobType,_get40) then
						scs.add(slotReqDisc);
					endif;
				endif;
			endif;
		endif;		

		
		// ### LOADS

		if _jobType = JobTypePriority_LoadDLR20 
		or _jobType = JobTypePriority_LoadDLR40 
		or _jobType = JobTypePriority_LoadExport20
		or _jobType = JobTypePriority_LoadExport40 then

			slotReqLoad := slot.mySlotRequestLoad;

//			if global.isValidObject(slotReqLoad)
			if slotReqLoad &lt;&gt; null then
				if slotReqLoad.myJob = null
				and not slotReqLoad.unavailable 
				and not slotReqLoad.getAttrIsBackend() // PAR 21746
				// PAR 21746 and not slotReqLoad.fortyBack
				// PAR 21746 and not slotReqLoad.isBackend // PAR 19945
				and slotReqLoad.moveType &lt;&gt; NULL_MOVETYPE then
					if slotReqLoad.doIMatchCCType(_jobType,_get40) then
						scs.add(slotReqLoad);
					endif;
				endif;
			endif;
		endif;		


	endforeach;
end;</source>
        <Parameter name="_deck" type="Integer"/>
        <Parameter name="_jobType" type="Integer"/>
        <Parameter name="scs" type="CM_SlotRequestSet" usage="input"/>
        <Parameter name="_get40" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getActiveSlotReqsForCCByDeck" id="2a453f7b-b613-426b-9259-916644b64d0e">
        <source>getActiveSlotReqsForCCByDeck(_deck : Integer; scs : CM_SlotRequestSet input; _get40 : Boolean; _getLoad : Boolean; _getSOB : Boolean);
// ---------------------------------------------------------------------------
// Created:		April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance

*/

vars
	slot : CM_SlotController;
	sd : CM_SlotDefn;
	srDisch, srLoad : CM_SlotRequest;
	invalidDisc,
	invalidLoad		: Boolean;
	
	
begin
	if scs = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'SlotRequest Set', null, null);
		return;
	endif;
	scs.clear;
	if _deck &lt;&gt; DeckOnDeck and _deck &lt;&gt; DeckUnderDeck then
		app.raiseCMException1(ERR_INVALID_COLOURCODE, _deck.String, null, null);
		return;
	endif;
	//------------------
	//Find all slots in the colour code for the passed in type
	//------------------
	on Exception do app.handleDeletedObject(exception, srDisch, invalidDisc);
	on Exception do app.handleDeletedObject(exception, srLoad, invalidLoad);
		
	foreach slot in self.allSlotControllersByOrdinal where slot.ordinalDeck = _deck do
		
		sd := slot.mySlotDefnVoyage;
		if sd.unavailable then
			continue;
		endif;
		
		srDisch := slot.mySlotRequestDischarge; // PAR 17343
		srLoad := slot.mySlotRequestLoad; // PAR 17343
		
		if _getSOB then // PAR 15285
//			if global.isValidObject(srDisch) 
			if srDisch &lt;&gt; null then
				if srDisch.isSOB() 
				and (_get40 = (srDisch.getAttrIs40() or srDisch.getAttrIs30() or srDisch.getAttrIs53() or srDisch.getAttrIs45())) // PAR 17343 PAR 18682		//cnwas3 PAR 24273
				and not srDisch.unavailable
				
				and not srDisch.getAttrIsBackend // PAR 21746
				// PAR 21746 and not srDisch.fortyBack
				// PAR 21746 and not srDisch.isBackend // PAR 19945
				and srDisch.moveType &lt;&gt; NULL_MOVETYPE  then
					scs.add(srDisch);
				endif;
			endif;
		else
			if _getLoad and srLoad &lt;&gt; null then		// global.isValidObject(srLoad) then
				if not srLoad.isSOB()
				and (_get40 = (srLoad.getAttrIs40() or srLoad.getAttrIs30() or srLoad.getAttrIs53() or srLoad.getAttrIs45())) // PAR 17343
				and not srLoad.unavailable
				and not srLoad.getAttrIsBackend // PAR 21746
				// PAR 21746 and not srLoad.fortyBack
				// PAR 21746 and not srLoad.isBackend // PAR 19945
				and srLoad.moveType &lt;&gt; NULL_MOVETYPE  then
					scs.add(srLoad);
				endif;
			elseif not _getLoad and srDisch &lt;&gt; null then 	// global.isValidObject(srDisch)  then
				if not srDisch.isSOB()
				and (_get40 = (srDisch.getAttrIs40() or srDisch.getAttrIs30() or srDisch.getAttrIs53() or srDisch.getAttrIs45())) // PAR 17343		//cnwas3 PAR 24273
				and not srDisch.unavailable
				and not srDisch.getAttrIsBackend() // PAR 21746
				// PAR 21746 and not srDisch.fortyBack
				// PAR 21746 and not srDisch.isBackend // PAR 19945
				and srDisch.moveType &lt;&gt; NULL_MOVETYPE then
					scs.add(srDisch);
				endif;
			endif;
		endif;

	endforeach;
end;</source>
        <Parameter name="_deck" type="Integer"/>
        <Parameter name="scs" type="CM_SlotRequestSet" usage="input"/>
        <Parameter name="_get40" type="Boolean"/>
        <Parameter name="_getLoad" type="Boolean"/>
        <Parameter name="_getSOB" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getActiveSlotReqsForCCByDeckOL" id="20c7834e-da71-4879-8f4d-7233f8648c31">
        <source>getActiveSlotReqsForCCByDeckOL(_deck : Integer; scs : CM_SlotRequestSet input; _get40 : Boolean; _getLoad : Boolean);
// ---------------------------------------------------------------------------
// Created:		April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
19 May 2010	cnwkpd1	PAR #20728 - remove isValidObject calls for performance
24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls

*/

vars
	slot : CM_SlotController;
	sd : CM_SlotDefn;
	srDisch, srLoad : CM_SlotRequest;
	invalidDisc,
	invalidLoad		: Boolean;
	
begin
	if scs = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'SlotRequest Set', null, null);
		return;
	endif;
	scs.clear;
	if _deck &lt;&gt; DeckOnDeck and _deck &lt;&gt; DeckUnderDeck then
		app.raiseCMException1(ERR_INVALID_COLOURCODE, _deck.String, null, null);
		return;
	endif;
	//------------------
	//Find all slots in the colour code for the passed in type
	//------------------
	
	on Exception do app.handleDeletedObject(exception, srDisch, invalidDisc);
	on Exception do app.handleDeletedObject(exception, srLoad, invalidLoad);
	
	foreach slot in self.allSlotControllersByOrdinal where slot.ordinalDeck = _deck do
		sd := slot.mySlotDefnVoyage;
		if sd.unavailable then
			continue;
		endif;
		
		srDisch := slot.mySlotRequestDischarge; 
		srLoad := slot.mySlotRequestLoad; 
		
		if _getLoad and srLoad &lt;&gt; null then 	// global.isValidObject(slot.mySlotRequestLoad) then
			if (_get40 = srLoad.getAttrIs40())
			and not srLoad.unavailable
			and not srLoad.getAttrIsBackend() // PAR 21746
			// PAR 21746and not slot.mySlotRequestLoad.fortyBack
			// PAR 21746and not slot.mySlotRequestLoad.isBackend // PAR 19945
			and srLoad.moveType &lt;&gt; NULL_MOVETYPE  then
				scs.add(srLoad);
			endif;
		endif;

		if not _getLoad and srDisch &lt;&gt; null then		// global.isValidObject(slot.mySlotRequestDischarge)  then
			if (_get40 = srDisch.getAttrIs40())
			and not srDisch.unavailable
			and not srDisch.getAttrIsBackend() // PAR 21746
			// PAR 21746 and not slot.mySlotRequestDischarge.fortyBack
			// PAR 21746 and not slot.mySlotRequestDischarge.isBackend // PAR 19945
			and srDisch.moveType &lt;&gt; NULL_MOVETYPE then
				scs.add(srDisch);
			endif;
		endif;

	endforeach;
end;</source>
        <Parameter name="_deck" type="Integer"/>
        <Parameter name="scs" type="CM_SlotRequestSet" usage="input"/>
        <Parameter name="_get40" type="Boolean"/>
        <Parameter name="_getLoad" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getActiveSlotReqsForColourCode" id="10f37ef1-6802-44e3-8b9c-758b0251568a">
        <source>getActiveSlotReqsForColourCode(ccType : Integer; scs : CM_SlotRequestSet input);
/*
 ------------------------------------------------------------------------
Created:			20 November 2002 by cnwdwq1
Purpose:			Iterates through, and gets all slotControllers where we have a type requested.
Changed On		Changed By		Reason
--------------	--------------	-----------------------------------------
24/04/2013		cnwcs5			par 30652 - remove resynch/resynchObject method calls
---------------------------------------------------------------------------
*/
vars
	slot : CM_SlotController;
begin
	if scs = null then
		app.raiseCMException2(MethodWithNullParam, method.name, 'SlotRequest Set', null, null);
		return;
	endif;
	scs.clear;
	if ccType &lt;&gt; LOAD_COLOURCODE and ccType &lt;&gt; DISCHARGE_COLOURCODE then
		app.raiseCMException1(ERR_INVALID_COLOURCODE, ccType.String, null, null);
		return;
	endif;
	//------------------
	//Find all slots in the colour code for the passed in type
	//------------------
	foreach slot in self.allSlotControllersByOrdinal do
		//----------------------
		//Test to see if its set
		//----------------------
		if ccType = LOAD_COLOURCODE then
			if slot.mySlotRequestLoad = null then
				continue;
			endif;
			if slot.mySlotRequestLoad.moveType = NULL_MOVETYPE then
				continue;
			endif;
			scs.add(slot.mySlotRequestLoad);
		elseif ccType = DISCHARGE_COLOURCODE then
			if slot.mySlotRequestDischarge = null then
				continue;
			endif;
			if slot.mySlotRequestDischarge.moveType = NULL_MOVETYPE then
				continue;
			endif;
			scs.add(slot.mySlotRequestDischarge);
		endif;
	endforeach;
end;</source>
        <Parameter name="ccType" type="Integer"/>
        <Parameter name="scs" type="CM_SlotRequestSet" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllJobs" id="02521c23-4a5d-4352-bf90-99c300d19042">
        <updating/>
        <source>getAllJobs(_jobType : Integer; _jobStatus : Integer; _allJobs : CM_JobArray input) updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		get all the jobs in this bay. Look at all the jobs for the voyage, check their type and status and then their first request to see if it is in us
// ---------------------------------------------------------------------------
vars
	aSlotController : CM_SlotController;
	aJob : CM_Job;
	theVoyage : CM_Voyage;
	aRequest : CM_Request;
begin
	
	theVoyage := self.myCellularVoyageStructure.myVoyage;
	
	foreach aJob in theVoyage.allVoyageJobs do
		if aJob.jobType = _jobType and aJob.status = _jobStatus then
			aRequest := aJob.allRequests.first;
			if aRequest &lt;&gt; null then
				aSlotController := aRequest.CM_SlotRequest.mySlotController;
				if aSlotController &lt;&gt; null then
					if aSlotController.myBayVoyage = self then
						_allJobs.add(aJob);
					endif;
				endif;
			endif;
		endif;
	endforeach;
end;</source>
        <Parameter name="_jobType" type="Integer"/>
        <Parameter name="_jobStatus" type="Integer"/>
        <Parameter name="_allJobs" type="CM_JobArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllProposedCargo" id="898eb3e3-58f1-4e18-88e4-5e9aee0f2611">
        <source>getAllProposedCargo(_theTIs : CM_TIArray input);
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theSlotController : CM_SlotController;
	theTIs : CM_TIArray;
	theTI : CM_TrackedItem;
	numTIs	: Integer;
begin
	if _theTIs = null then
		return;
	endif;
	foreach theSlotController in self.allSlotControllersByOrdinal do
		theSlotController.getProposedCargo(theTI, numTIs);
		if theTI &lt;&gt; null then
			_theTIs.add(theTI);
		endif;
	endforeach;
epilog
end;</source>
        <Parameter name="_theTIs" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllProposedTIs" id="15bedbff-63d4-41fa-a5a4-9963a223e2db">
        <source>getAllProposedTIs(_theTIs : CM_TIArray input);
// ---------------------------------------------------------------------------
// Created:		November 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	theSlotController : CM_SlotController;
	theTIs : CM_TIArray;
	theTI : CM_TrackedItem;
	numTI, labelID : String;
begin
	if _theTIs = null then
		return;
	endif;
	create theTIs transient;
	foreach theSlotController in self.allSlotControllersByOrdinal do
		theSlotController.getProposedTIs(theTIs);
		if not theTIs.isEmpty then
			theTIs.copy(_theTIs);
		endif;
	endforeach;
epilog
	delete theTIs;
end;</source>
        <Parameter name="_theTIs" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getAllTrackedItems" id="c6ec47dd-d182-4148-8d3c-2b557ed7f97b">
        <source>getAllTrackedItems(_theMoveMode : Integer; _theTIs : CM_TIArray input);
// ---------------------------------------------------------------------------
// Created:		October 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	theSlotController : CM_SlotController;
	theTIs : CM_TIArray;
begin
	if _theTIs = null then
		return;
	endif;
	create theTIs transient;
	foreach theSlotController in self.allSlotControllersByOrdinal do
		theTIs.clear;
		if _theMoveMode = QUEUE_MODE then
			theSlotController.getAllQueuedTrackedItems(theTIs, true);
		elseif _theMoveMode = PLANNING_MODE then
			theSlotController.getAllPlannedTrackedItems(theTIs, true, false);
		elseif _theMoveMode = REAL_MODE then
			theSlotController.allTrackedItems.copy(theTIs);
		endif;
		
		theTIs.copy(_theTIs);
	endforeach;
epilog
	delete theTIs;
end;</source>
        <Parameter name="_theMoveMode" type="Integer"/>
        <Parameter name="_theTIs" type="CM_TIArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getBayDefn" id="6155d17f-c394-4019-8818-b53eec4058e3">
        <source>getBayDefn(_vess : CM_Vessel) : CM_BayDefn;
// ---------------------------------------------------------------------------
// Created:		14 September 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	ves : CM_Vessel;
begin
	ves := _vess;
	if ves = null then
		self.myCellularVoyageStructure.myVoyage.getMyVessel();
	endif;
	
	if ves &lt;&gt; null then
		return ves.myCellularVesselStructure.allBaysByOrdinal[self.ordinalBay];
	endif;
	
	return null;
end;</source>
        <Parameter name="_vess" type="CM_Vessel"/>
        <ReturnType type="CM_BayDefn"/>
    </JadeMethod>
    <JadeMethod name="getCellPileColourHeight" id="17ecabfe-5c3e-4367-9cbf-6174a44d35b8">
        <source>getCellPileColourHeight(_ordinalDeck,_ordinalCell:Integer):Real;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 November 2009	cnwas3	Checks out the new colour coding of cells to issue warning in cases of "abusive" usage of high containers

*/

vars
	pileHeight : Real;
	ordinalTier : Integer;
	ti : CM_TrackedItem;
	slotController : CM_SlotController;
begin
	if _ordinalDeck = DeckOnDeck then
		ordinalTier := self.allTiersOnDeck.size;
	else
		ordinalTier := self.allTiersUnderDeck.size;
	endif;	
	
	slotController := self.allSlotControllersByOrdinal[_ordinalDeck,_ordinalCell,ordinalTier];
	while true do
		if slotController = null then
			break;
		endif;
		if slotController.mySlotRequestLoad &lt;&gt; null then
			if slotController.mySlotRequestLoad.getAttrHiCubed() then
				pileHeight := pileHeight + HEIGHT_FULL_HIGH_CUBE;	//we just want the number of existing high-cubes
			else
				//pileHeight := pileHeight + HEIGHT_FULL_NORMAL;
			endif;
		endif;		
		slotController := slotController.myUnderfootSlot;
	endwhile;
	return pileHeight;
end;</source>
        <Parameter name="_ordinalDeck" type="Integer"/>
        <Parameter name="_ordinalCell" type="Integer"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getCellPileHeight" id="859606b0-2f63-48b5-bdc7-8aad9163a980">
        <source>getCellPileHeight(_ordinalDeck,_ordinalCell:Integer; _inMetres : Boolean ):Real;
//-----------------------------------------
//Created: June 2003 By: cnwgd1
//-----------------------------------------
vars
	pileHeight : Real;
	pileHeightMetres : Decimal [6,2];
	ordinalTier : Integer;
	ti : CM_TrackedItem;
	slotController : CM_SlotController;
begin
//	if _ordinalDeck = DeckOnDeck then
//		ordinalTier := self.allTiersOnDeck.size;
//	else
//		ordinalTier := self.allTiersUnderDeck.size;
//	endif;	
	
	slotController := self.allSlotControllersByOrdinal[_ordinalDeck,_ordinalCell,1];
	while true do
		if slotController = null then
			break;
		endif;
		foreach ti in slotController.allTrackedItems do
			
			//total height of all ti's in pile (current cell)
			pileHeight := pileHeight + ti.getActualHeight();	// 03 Aug 2010	NDL	Par 25127
		/*	if ti.isAttributeTrue(TI_Attrib_IsForty) 
			   and slotController.isFortyBack then
				  // do not include the back end of a 40 footer			
			else
				pileHeight := pileHeight + ti.getActualHeight();		
			endif; */
		endforeach;
		slotController := slotController.myOverheadSlot;
	endwhile;
	
	if _inMetres then
		// convert to metres.
		//feet * 12 (inches in a foot) / 39.37 (inches in a metre)
		pileHeightMetres := (( pileHeight * 12 ) / 39.37 );
		pileHeight := pileHeightMetres;
	endif;
	
	return pileHeight;
end;</source>
        <Parameter name="_ordinalDeck" type="Integer"/>
        <Parameter name="_ordinalCell" type="Integer"/>
        <Parameter name="_inMetres" type="Boolean"/>
        <ReturnType type="Real"/>
    </JadeMethod>
    <JadeMethod name="getCellPileWeight" id="696606b9-8e2c-4332-94c5-370c51a00283">
        <source>getCellPileWeight(_ordinalDeck,_ordinalCell:Integer; _mode : Integer):Decimal;
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
vars
	pileWeight	: Decimal[14,4];
	ordinalTier : Integer;
	ti : CM_TrackedItem;
	slotController : CM_SlotController;
	theTIs : CM_TIArray ;
begin
	// PAR 8423. This code wants to start at the bottom of the cell. But the tier ordinals start at the bottom not the top.
	ordinalTier := 1;
	create theTIs transient;
	
	slotController := self.allSlotControllersByOrdinal[_ordinalDeck,_ordinalCell,ordinalTier];
	
	while true do
		if slotController = null then
			break;
		endif;
		theTIs.clear; // PAR 8858
		if _mode = ShpDisplayMode_Actual then // PAR 8667 added
			slotController.allTrackedItems.copy(theTIs); // PAR 8667 added
		elseif _mode = ShpDisplayMode_Proposed then // PAR 8667 added
			slotController.getProposedTIs(theTIs); // PAR 8667 added
		endif;

		foreach ti in theTIs do
			//total weight of all ti's in pile (current cell)
			if ti.isAttributeTrue(TI_Attrib_IsForty) 
			and slotController.isFortyBack then
				  // do not include the back end of a 40 footer	
			else
				pileWeight := pileWeight + ti.totalWeight;		
			endif;
		endforeach;
		slotController := slotController.myOverheadSlot;
	endwhile;
	return pileWeight;
epilog
	delete theTIs;
end;</source>
        <Parameter name="_ordinalDeck" type="Integer"/>
        <Parameter name="_ordinalCell" type="Integer"/>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getCellPileWeightRounded" id="a0a9317e-8f58-4fab-91a1-653b5af8c2d8">
        <source>getCellPileWeightRounded(_mode : Integer; _ordinalDeck, _ordinalCell : Integer; _isOverweight : Boolean output; interTermVoyage: CM_Voyage) : Integer;
// need to round the weight of each slot
vars
	pileWeight,
	maxWeight, 
	splitWeight	: Integer;
	ti : CM_TrackedItem;
	slotController	: CM_SlotController;
	tmpDict			: CM_SlotLCByDeckCellTier;
	tmpSlotDefn		: CM_SlotDefnVoyage;
	cellDefn : CM_CellDefn;
begin

	tmpDict := self.allSlotControllersByOrdinal;

	foreach slotController in tmpDict where
			slotController.ordinalDeck = _ordinalDeck and
			slotController.ordinalCell = _ordinalCell do
		
		pileWeight := pileWeight + slotController.getWeightRounded(_mode, interTermVoyage, splitWeight);
	endforeach;
	
	if slotController &lt;&gt; null and pileWeight &gt; 0 then
	
		// 03 Sep 2010 NDL Par 25256
		cellDefn := slotController.getCellDefn;
		if cellDefn &lt;&gt; null then
			maxWeight := cellDefn.getMaxPileWeight( _mode );
		endif;
		
		
	/*	// we found some slots so check now if overweight
		if _ordinalDeck = DeckUnderDeck then
			maxWeight := self.maxPileWeightUD;
		else
			tmpSlotDefn := slotController.mySlotDefnVoyage;
			if tmpSlotDefn.isOutboard = true then
				maxWeight := self.maxPileWeight20OB;
			else
				maxWeight := self.maxPileWeight20IB;
			endif;
		endif; */
		
		// At this stage use the splitWeight which takes 1/2 the
		// 40ft weight and spreads over the fore and aft piles.
		// This is primarily because we don't know here if we
		// have 40's, 20's or a mixture in the cell
		
		//_isOverweight := (splitWeight &gt; (maxWeight / 1000));
		
		// above change needs further discussion with ports
		_isOverweight := (pileWeight &gt; (maxWeight / 1000));
	endif;

	return pileWeight;
end;</source>
        <Parameter name="_mode" type="Integer"/>
        <Parameter name="_ordinalDeck" type="Integer"/>
        <Parameter name="_ordinalCell" type="Integer"/>
        <Parameter name="_isOverweight" type="Boolean" usage="output"/>
        <Parameter name="interTermVoyage" type="CM_Voyage"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getHatchLidCodeForUDJobs" id="f8f67f98-6245-41ac-a043-7a63ef7a8f01">
        <source>getHatchLidCodeForUDJobs() : String;

vars
	hasP, hasS, hasC : Boolean;
	vJob : CM_VoyageJob;
	aJob : CM_Job;
	aReq : CM_SlotRequest;
	locationStr : String;
	aBay : CM_Bay;
begin

	foreach aBay in self.myHold.allBays do
	foreach aReq in aBay.CM_BayVoyage.allSlotRequestByMoveType discreteLock do
		if aReq.ordinalDeck = DeckOnDeck then
			continue;
		endif;
		
		aJob := aReq.myJob;
		if aJob = null then
			continue;
		endif;
		
		vJob := aJob.CM_VoyageJob;
		
		if vJob.isPort then
			hasP := true;
		endif;
		if vJob.isCentre then
			hasC := true;
		endif;
		if vJob.isStarboard then
			hasS := true;
		endif;
		
	endforeach;
	endforeach;
	
	if hasP then
		locationStr := locationStr &amp; "P";
	endif;
	if hasC then
		locationStr := locationStr &amp; "C";
	endif;
	if hasS then
		locationStr := locationStr &amp; "S";
	endif;

	return locationStr;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getKPIVoyageBayCraneForJS" id="70ff2d6d-160c-4bee-94f2-b722c8e9f880">
        <source>getKPIVoyageBayCraneForJS(_js : CM_VoyageJobSheet) : CM_KPIVoyageBayCrane;
// ---------------------------------------------------------------------------
// Created:		14 September 2007 By Andrew Bishop cnwab1
//
// Purpose:		
// 29/05/2015	cnwma1  PAR #35561 Archive Voyages
// ---------------------------------------------------------------------------
vars
	kpi  : CM_KPI;
begin

	foreach kpi in self.allVoyageKPIBayCranes discreteLock do
		if kpi.CM_KPIVoyageBayCrane.myCrane &lt;&gt; null then			// 29/05/2015 cnwma1 PAR #35561
			if kpi.CM_KPIVoyageBayCrane.myCrane.id = _js.crane then
				return kpi.CM_KPIVoyageBayCrane;
			endif;
		endif;
	endforeach;
	
	return null;
end;</source>
        <Parameter name="_js" type="CM_VoyageJobSheet"/>
        <ReturnType type="CM_KPIVoyageBayCrane"/>
    </JadeMethod>
    <JadeMethod name="getMyTerminal" id="2da4d439-6d59-4a60-a5b8-6550484637ba">
        <source>getMyTerminal(): CM_Terminal;
/*

Date		Who		Reason
02 February 2017	cnwer1	Initial creation TFS 3284

*/

vars

begin
