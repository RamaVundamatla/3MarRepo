    <JadeMethod name="erase" id="737ce344-667c-4c62-84b3-602637979a33">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
//------------------------------------------------
// Created: 18 May 2006 By: cnwgd1
//------------------------------------------------
vars

begin

	if self.myBank &lt;&gt; null and
	   not self.isTransient then		// from 37200 review of 'erase' code
		self.myBank.terminal.causeEvent(self.myBank.terminal.getTerminalEvent(EVENT_TAXCODE_DELETE), false, self);
	endif;	
	inheritMethod(_eraseLevel);

end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDescription" id="268ffcb4-172c-4c6b-94f4-e12c08f5d5ed">
        <source>getDescription(_description:Boolean):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		  Reason
20 October 2022		navmv20	  ChangeRequest 55005: EUP - Invoicing - Invoice Line TAX Maintenance

*/

vars
	taxCode : String;
begin
	 if _description then
		taxCode := self.description;
	else
		taxCode := self.code;
	endif;
	
	return taxCode;
epilog

end;</source>
        <Parameter name="_description" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayDetails" id="388b3319-0c26-4867-8126-0398507bd107">
        <source>getDisplayDetails(_short: Boolean): String;
//------------------------------------------------
// Created: 18 May 2006 By: cnwgd1
//------------------------------------------------
vars

begin
	if _short then
		return self.code;
	elseif self.notAvailableForEntry then
		return self.code &amp; ' - ' &amp; self.description &amp; ' (Not Available For Entry)';	
	else
		return self.code &amp; ' - ' &amp; self.description;
	endif;
end;</source>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTimeRate" id="b4e1c927-c43a-4a0c-9688-6237e0bb8097">
        <source>getTimeRate(_ts : TimeStamp) : CM_TaxRate;
// ---------------------------------------------------------------------------
// Created:		April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	retVal : CM_TaxRate;
begin

	retVal := self.allTaxRates.getAtKeyLeq(_ts);

	return retVal;

end;</source>
        <Parameter name="_ts" type="TimeStamp"/>
        <ReturnType type="CM_TaxRate"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="ccbfa35d-3b87-46b1-9a4f-91d858aa183b">
        <source>pxyCreateUpdateProxy(): SelfType;
//------------------------------------------------
// Created: 18 May 2006 By: cnwgd1
//------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	tmpProxy : SelfType;
	completedOK		: Boolean;
begin
	tmpProxy := inheritMethod();
	tmpProxy.myBank := tmpProxy.myBank;
	tmpProxy.myGLCode := tmpProxy.myGLCode;
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return tmpProxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete tmpProxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="d53fdcc9-577c-4ff2-88dc-c8c112b6ee24">
        <updating/>
        <source>setForCreate(_pxyTaxCode : CM_TaxCode; _passport : CM_Passport input) updating;
//------------------------------------------------
// Created: 18 May 2006 By: cnwgd1
//------------------------------------------------
vars

begin
	self.raiseExceptionIfTransient(method);
	self.setForUpdate(_pxyTaxCode, _passport);
end;</source>
        <Parameter name="_pxyTaxCode" type="CM_TaxCode"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="229143b6-fcd5-46c5-8b3e-517fd581e8d8">
        <updating/>
        <source>setForUpdate(_pxyTaxCode : CM_TaxCode; _passport : CM_Passport input) updating;
//------------------------------------------------
// Created: 18 May 2006 By: cnwgd1
//------------------------------------------------
// 29/3/22  jlier1	TFS 53286
vars

begin
	self.raiseExceptionIfTransient(method);
	self.code := _pxyTaxCode.code;
	self.description := _pxyTaxCode.description;
	self.notAvailableForEntry := _pxyTaxCode.notAvailableForEntry;
	self.myBank := _pxyTaxCode.myBank;
	self.myGLCode := _pxyTaxCode.myGLCode;
	self.externalReference1:=_pxyTaxCode.externalReference1;
end;</source>
        <Parameter name="_pxyTaxCode" type="CM_TaxCode"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="9fd6fdf9-843a-4fe9-9576-4eca0dcabb52">
        <updating/>
        <source>setProxy(_code, _description : String; 
			_bank : CM_Bank;
			_glCode : CM_GLCode;
			_notAvailableForEntry : Boolean;
			_externalRef1 : String) updating;
//------------------------------------------------
// Created: 17 May 2006 By: cnwgd1
//------------------------------------------------
// 29/3/22  jlier1	TFS 53286
vars

begin
	self.raiseExceptionIfNotTransient(method);
	self.code := _code;
	self.description := _description;
	self.myBank := _bank;
	self.myGLCode := _glCode;
	
	self.notAvailableForEntry := _notAvailableForEntry;	
	self.externalReference1:=_externalRef1;
end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_description" type="String"/>
        <Parameter name="_bank" type="CM_Bank"/>
        <Parameter name="_glCode" type="CM_GLCode"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
        <Parameter name="_externalRef1" type="String"/>
    </JadeMethod>
    <JadeMethod name="validateCreate" id="41504404-7eb2-43c0-b187-c4df3742aeae">
        <source>validateCreate(_passport: CM_Passport input);
//------------------------------------------------
// Created: 18 May 2006 By: cnwgd1
//------------------------------------------------
vars

begin
	self.validateUpdate(_passport);

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateDelete" id="91b74bd0-473a-4bbe-8534-204186b9ce3d">
        <source>validateDelete(_passport: CM_Passport input);
//------------------------------------------------
// Created: 18 May 2006 By: cnwgd1
//------------------------------------------------
	// 08/12/2014 cnwdb2 PAR 35364

vars

begin
	if (not self.allServiceObjects.isEmpty) then
		app.raiseCMException2(ObjectStillHasEntries, 'Tax Code ' &amp; self.code, "Service", null, null);
	endif;
	
	if (not self.allTaxRates.isEmpty) then
		app.raiseCMWarning2(HMSConfirmDelete, 'Tax Code (' &amp; self.getDisplayDetails(false) &amp; ')', 'Tax Rate', null, null, self);
	else
	//	app.raiseCMWarning2(CONF_DELETE, 'Tax Code', '(' &amp; self.getDisplayDetails(false) &amp; ')', null, null, self);		
		app.raiseCMWarning1(Sure_want_delete35364e,self.getDisplayDetails(false), null, null, self);	//cnwdb2 PAR 35364	

	endif;

end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="validateUpdate" id="d0cd4e1f-6574-45d3-9bd3-1e69373e782c">
        <source>validateUpdate(_passport: CM_Passport input);
//------------------------------------------------
// Created: 18 May 2006 By: cnwgd1
//14/06/2022 navds20 TFS 53760 DuplicateItem not Translatable
//------------------------------------------------
vars
	realTaxCode,
	tmpTaxCode : SelfType;
begin
	if self.myBank = null then
//		app.raiseCMException1(REQUIRED_FIELD, 'Business Unit', null, null);
		app.raiseCMException(Input_required_field_BusUnit, null, null); // cnwdb2	PAR 35364
	
	elseif self.code = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Code', null, null);
		app.raiseCMException(Input_required_field_code, null, null);// cnwdb2	PAR 35364
	else
		// code and bank set, check for duplicate tax code
		tmpTaxCode := self.myBank.allTaxCodes[self.code];
		if self.isTransient() then
			realTaxCode := self.pxyGetRealObject();
		else
			realTaxCode := self;
		endif;
		if tmpTaxCode &lt;&gt; null
		and realTaxCode &lt;&gt; tmpTaxCode then
			//app.raiseCMException2(DuplicateItem, 'Tax Code', self.code, null, null);	//14.06.2022 navds20 53760
			// Tax Code already exists for %1 : Code_already_exists
			app.raiseCMException1(Code_already_exists, self.code, null, null); //14.06.2022 navds20 53760
		endif;		
	endif;
	
	if self.description = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Description', null, null);
		app.raiseCMException(Input_required_field_Desc, null, null); // cnwdb2	PAR 35364
	endif;
	
end;</source>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
</Class>
