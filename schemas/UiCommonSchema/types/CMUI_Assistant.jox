    <JadeMethod name="displayEntryDischarge" id="10312d41-c91a-494c-8626-f84db69d1a10">
        <source>displayEntryDischarge(pPort : CM_Port) : String;
// ---------------------------------------------------------------------------
// Created:     20 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29/6/2006	RBarr		CM_Port::codeDisplay attribute obsolete
// ---------------------------------------------------------------------------
vars

begin

	if pPort = null then
		return null;
	endif;
	
	if pPort.isNotAvailableForEntry then 
		return null;
	endif;
	if self.isPortCodeDisplayInitialized then
		return pPort.getDisplayFormatted(self.portCmbOrderDescrFirst);
	endif;
end;</source>
        <Parameter name="pPort" type="CM_Port"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="displayEntryDischargeList" id="fb3262fd-40ef-4e27-9d44-f9b9b7d82262">
        <source>displayEntryDischargeList(pPort : CM_Port; pSelected : Boolean) : String;
// ---------------------------------------------------------------------------
// Created:     20 December 2000 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	str : String;
begin

	if pPort &lt;&gt; null and not pPort.isNotAvailableForEntry then
		str := pPort.getDisplayFormatted(self.portCmbOrderDescrFirst);
		if pSelected then
			//return TableCheckBox_Selected &amp; Tab &amp; pPort.code &amp; Tab &amp; pPort.description;
			return TableCheckBox_Selected &amp; Tab &amp; str;
		else
			//return TableCheckBox_NotSelected &amp; Tab &amp; pPort.code &amp; Tab &amp; pPort.description;
			return TableCheckBox_NotSelected &amp; Tab &amp; str;
	//		return TableCheckBox_NotSelected &amp; Tab &amp; pPort.codeDisplay &amp; Tab &amp; pPort.description;
		endif;
	endif;
	
	return null;

end;</source>
        <Parameter name="pPort" type="CM_Port"/>
        <Parameter name="pSelected" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
