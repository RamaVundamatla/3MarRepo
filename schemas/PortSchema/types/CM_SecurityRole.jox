    <JadeMethod name="isParentOf" id="d00c9873-eca8-4f43-882f-f89ce5198d3f">
        <source>isParentOf(_child : CM_SecurityRole) : Boolean;
// ---------------------------------------------------------------------------
// Created:     21 February 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpChild	: CM_SecurityRole;

begin

	if self = _child then
		return true;
	endif;
	
	foreach tmpChild in self.allChildRoles do
		if tmpChild.isParentOf(_child) then
			return true;
		endif;
	endforeach;	
	
	return false;

end;</source>
        <Parameter name="_child" type="CM_SecurityRole"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
