    <JadeMethod name="populateAttributes" id="98033534-89ad-43ea-9308-860c8e263e23">
        <updating/>
        <source>populateAttributes() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	critType : CM_YACriteriaType;
	propString : String;
	critTypeSelectArray : CM_YACriteriaTypeArray;
	bu : CM_Bank;
	headings : String;
	
	iter : Iterator;
	proformaCrit : CM_ProformaTransactionCriteria;
	rowString : String;
	index : Integer;
	
begin
	
	self.mulBUProCirt.setAvailable( self.allAvailTrxTypes, true );
	
	bu := self.cmbBusUnits.listObject.CM_Bank;
	create critTypeSelectArray transient;
	if bu &lt;&gt; null then
		iter := bu.allSelectedProformaQueryProps.createIterator;
		while iter.next( propString ) do
			foreach critType in app.myRoot.allYACriteriaTypes do
				if critType.description = propString then	//09 Oct 2013	NDL	Par 32456
					critTypeSelectArray.add( critType );
					break;
				endif;
			endforeach;
		endwhile;
		delete iter;
	endif;
	
	self.mulBUProCirt.setSelected( critTypeSelectArray );
	
	self.tblCritAlloc.columns := critTypeSelectArray.size + 3;
	self.tblCritAlloc.rows := 1;
	headings := app.getErrorString(Priority) &amp; Tab;
	foreach critType in critTypeSelectArray do
		headings := headings &amp; critType.description &amp; Tab;	//09 Oct 2013	NDL	Par 32456
	endforeach;
	// 34917 show if hook code
	headings := headings &amp; app.getErrorString(Hook_Code) &amp; Tab &amp; app.getErrorString(Transactions);
	self.tblCritAlloc.setCellText(1,1,headings);
	
	// populate Table.
	iter := bu.allProformaCriteria.createIterator;
	while iter.next( proformaCrit ) do
		if proformaCrit.type &lt;&gt; CM_ProformaTransactionCriteria.TypeCargo then // TFS 37453
			continue;
		endif;
			
		rowString := proformaCrit.priority.String &amp; Tab &amp; proformaCrit.getTableDisplay(critTypeSelectArray) &amp; Tab &amp; (proformaCrit.getJadeCode() &lt;&gt; null).getYes
						&amp; Tab &amp; proformaCrit.getTransactionList();
		index := self.tblCritAlloc.addItem(rowString);
		self.tblCritAlloc.accessRow(index).itemObject := proformaCrit;
	endwhile;
	
epilog

	delete critTypeSelectArray;
	delete iter;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="populateCmbDebtAction" id="c9769b3b-5485-486e-a311-e4cbf4d2b447">
        <source>populateCmbDebtAction( _action : Integer );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 May 2018	jlgndl1	Initial creation	TFS 38952

*/

vars

	combo : CMUI_ComboBox;

begin

	combo := self.cmbDebtAction;
	combo.clear;
	combo.itemData[ combo.addItem( " " ) ] := 0;
	combo.itemData[ combo.addItem(app.getErrorString(Cash_debtor_debt_raise_error)) ] := 1;
	combo.itemData[ combo.addItem(app.getErrorString(Cash_debtor_debt_raise_warnin)) ] := 2;
	combo.itemData[ combo.addItem(app.getErrorString(Cash_debtor_debt_no_action)) ] := 3;
	
	if _action &gt;= 1 and _action &lt;= 3 then
		combo.listIndex := combo.findItemData( _action );
		combo.lostFocus( combo );
	endif;

epilog

end;</source>
        <Parameter name="_action" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="populateTblBankConfig" id="eb512ce2-d693-46ac-8962-cd45d8b0de23">
        <source>populateTblBankConfig();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2019	jlgndl1	Initial creation	TFS 40010	 Moved some Term config items to Bank.

*/

vars

	bank : CM_Bank;
	entTableDef : EntTableDef;
	configInvDesc : CM_InvoiceDesc;
	invDesc : CM_InvoiceDesc;
	int : Integer;
	configILD : CM_InvoiceLineDesc;
	invLineDesc : CM_InvoiceLineDesc;
	configRoundTypeStr : String;
	
	myConfigBank : CMIF_ConfigBank;
	
	invLineGrp : CM_InvoiceLineDescGroup;
	configInvLineGrp : CM_InvoiceLineDescGroup;

begin

	bank := self.cmbBusUnitConfig.listObject.CM_Bank; 
	
	if bank &lt;&gt; null then
		myConfigBank:= self.allConfigBanks.getAtKey( bank );
	endif;
	
	//08/01/2025	navkc1 JIRA Bug MTN-33573 - We are now always showing the Pro Forma sheet, populate the table so the details are saved correctly in pro forma mode
	if myConfigBank = null then
	//if myConfigBank = null or self.proformaConfigurationOnly then
		self.tblBankConfig.rows := 0;
		return;
	endif;
	
	// setup the table
	self.tblBankConfig.warningMethod := 'entTableWarning';
	self.tblBankConfig.optimiseRowHeight := true;
	entTableDef := app.myController.getEntTableDef(	ETDef_BankCashOps );
	self.tblBankConfig.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	self.tblBankConfig.changeMode := CM_EntryTable.ChangeMode_FirstOnly;

	//Cash Round Up Amount
	self.tblBankConfig.setValueByName(ETRow_CashRoundUpAmount, myConfigBank.cashRoundUpAmount );			
	
	//Cash Invoice Type
	self.cmbCashInvType.clear;
	self.cmbCashInvType.addItem(" ");		// null entry 
	configInvDesc := myConfigBank.cashInvoiceType;
	foreach invDesc in bank.invoiceTypes where not invDesc.isNotAvailableForEntry do
		// from 33885 filter out types with line types (can have invoices from transaction activity) or the wrong accrual type/separate invoices for values
		if invDesc = configInvDesc or
		   (invDesc.invoiceLineDescriptors.size = 0 and invDesc.accrualType = CM_InvoiceDesc.Accrue_Until_Manually_Closed and
			invDesc.invoiceKey = CM_InvoiceDesc.Key_None) then
			self.cmbCashInvType.itemObject[self.cmbCashInvType.addItem(invDesc.description)] := invDesc;
		endif;
	endforeach;
	if configInvDesc &lt;&gt; null then 
		int := self.cmbCashInvType.findStringExact(1, configInvDesc.description);
		self.cmbCashInvType.listIndex := int;
		self.tblBankConfig.setValueByName(ETRow_CashInvoiceType, configInvDesc.description);
	endif;	
	
	//Cash Tax Inv Line Type
	configILD := myConfigBank.cashTaxInvLineType;
	self.cmbTaxInvLineTyp.clear();
	self.cmbTaxInvLineTyp.addItem(" ");		// add an empty line so can clear the option 
	foreach invLineDesc in bank.invoiceLineDescriptors where not invLineDesc.isNotAvailableForEntry do
		self.cmbTaxInvLineTyp.itemObject[self.cmbTaxInvLineTyp.addItem(invLineDesc.narration)] := invLineDesc;
	endforeach;
	if configILD &lt;&gt; null then 
		int := self.cmbTaxInvLineTyp.findStringExact(1, configILD.narration);
		self.cmbTaxInvLineTyp.listIndex := int;
		self.tblBankConfig.setValueByName(ETRow_CashTaxInvLineType, configILD.narration);
	endif;	
	
	//Cash Round Inv Line Type
	configILD := myConfigBank.cashRoundInvLineType;
	self.cmbRoundInvLineT.clear();
	self.cmbRoundInvLineT.addItem(" ");		// add an empty line so can clear the option
	foreach invLineDesc in bank.invoiceLineDescriptors where not invLineDesc.isNotAvailableForEntry do
		self.cmbRoundInvLineT.itemObject[self.cmbRoundInvLineT.addItem(invLineDesc.narration)] := invLineDesc;
	endforeach;
	
	if configILD &lt;&gt; null then 
		int := self.cmbTaxInvLineTyp.findStringExact(1, configILD.narration);
		self.cmbRoundInvLineT.listIndex := int;
		self.tblBankConfig.setValueByName(ETRow_CashRoundInvLineType, configILD.narration);
	endif;
	
	//Cash Rounding Type
	configRoundTypeStr := app.roundingTypeEnumToString(myConfigBank.cashRoundingType);
	self.cmbRoundingType.clear();
	self.cmbRoundingType.addItem(RoundingType_None_Str);
	self.cmbRoundingType.addItem(RoundingType_Down_Str);
	self.cmbRoundingType.addItem(RoundingType_Up_Str);
	
	int := self.cmbRoundingType.findStringExact(1, configRoundTypeStr);
	self.cmbRoundingType.listIndex := int;
	self.tblBankConfig.setValueByName(ETRow_CashRoundingType, configRoundTypeStr);
	
	//28 Jan 2019	NDL	TFS 42940
	//ProForma Extra Invoice Line 
	self.cmbInvLineGrp.clear;
	self.cmbInvLineGrp.addItem(" ");		// null entry 
	configInvLineGrp := myConfigBank.proXtraInvLineGrp;
	foreach invLineGrp in bank.invLineDescGroups do
		self.cmbInvLineGrp.itemObject[self.cmbInvLineGrp.addItem(invLineGrp.description)] := invLineGrp;
	endforeach;
	if configInvLineGrp &lt;&gt; null then 
		int := self.cmbCashInvType.findStringExact(1, configInvLineGrp.description);
		self.cmbInvLineGrp.listIndex := int;
		self.tblBankConfig.setValueByName(ETRow_ProXtraInvLineGrp, configInvLineGrp.description);
	endif;	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setInitialControlValues" id="eeb163b8-0e51-4836-855d-ffa87dea8655">
        <updating/>
        <source>setInitialControlValues() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/08/2012	cnwndl1	Initial creation	Par 29968
28/07/2017	cnwdap1	TFS 5520 SSL Pro forma settings required for non-cash systems
08/08/2017	jlgdap1	TFS 5740 AAT Changes to Pro Forma Invoices
02/04/2019	jlgdi1	TFS 44087 Added setting the (checkbox) control that holds the value of the attribute validateCashDebtorOnRelease
19/03/2020  cnwma1  Bug 48897: SNO - New cargo enquiry screen
23/06/2022 navsj20  TFS 53759 : MTN - Proforma Cash Configuration Missing Options
27 Jun 2024 navbs1  CR 64834 Task 64847: UI - Terminal and Cash Configurations
*/

vars

	bank                    : CM_Bank;
	defaultBank             : CM_Bank;
	headings                : String;
	entTableDef             : EntTableDef;
	allDebtors              : CM_DebtorByNameDict;
	allCashDebtors          : CM_DebtorByNameDict;
	allTaxCodes	            : CM_TaxCodeByCodeDict;
	sa		                : StringArray;
	root	                : CM_Root;
	codeList	            : String;
	code		            : String;
	int		                : Integer;
	idx                 	: Integer;
	dr                      : CM_Debtor;
	taxCode	                : CM_TaxCode;
	isCashOnly              : Boolean;
	drTerm                  : CM_DebtorTerminal;
	cashReceiptReport       : String;
	cashCreditReport	    : String;
	cashInvReceiptReport    : String;
	cashOnlyReceiptReport	: String;
	agent                   : CM_CashInvoiceProformaAgent;
	debtorType		        : CM_DebtorType;
	dutyDocCarReport        : String;
	dutyDocReport           : String;		
	currType                : CM_CurrencyType;
	selectedCurrType        : CM_CurrencyType;
	bankConfig              : CMIF_ConfigBank;
	term                    : CM_Terminal;
	rowIndex : Integer;
	selectedCurrencyCode	:String;
begin

	self.setNavigatorHeading( self.caption );
	
	self.minimumHeight := 460;
	self.minimumWidth  := 920;
	
	self.allAvailTrxTypes.clear();
	root                     := app.myRoot;
	term                     := self.myTerminal;
	self.frmMain.borderStyle := 0;
	self.frmMain.top         := 0;
	self.frmMain.left        := 0;
	self.frmMain.width       := self.clientWidth;
	self.frmMain.height      := self.clientHeight;
	
	self.frmBUProCrit.borderStyle   := 0;
	self.frmCashDebtors.borderStyle := 0;
	
	if self.proformaConfigurationOnly then
		self.shtCashConfigOpt.visible  := false;
		//08/01/2025	navkc1 JIRA Bug MTN-33573 - Show Vessel Proforma sheet
		//self.shtVesselProforma.visible := false;    // TFS 37453
		self.cmbRoundingType.visible   := false;
		self.cmbRoundInvLineT.visible  := false;
		self.cmbCurrencyType.visible   := false;	//20 Apr 2018	NDL	TFS 37550
		self.cmbInvLineGrp.visible     := false;	// 15 Jun 2022 navsj20 TFS 53759
		self.cmbCurrencyCode.visible   := false; 	//08/01/2025	navkc1 JIRA Bug MTN-33573
	endif;
	
	if term &lt;&gt; null then
	// 34917 can be called from invoicing
		
		defaultBank := term.getDefaultCompanyBank();
		
		//08 Jan 2018	NDL	TFS 40010
		foreach bank in term.companies do
			if not bank.isBusinessUnit then        // TFS 43258
				continue;                          // TFS 43258
			endif;
			create bankConfig transient;
			bankConfig.populateCMIFfromBank( bank );
			self.allConfigBanks.add( bankConfig );
		endforeach;
		
		
		if not self.proformaConfigurationOnly then
		
			create allDebtors transient;
			//13 Dec 2012	NDL	Par 30857
			foreach dr in app.myRoot.myRootCompany.debtors discreteLock do
				if not dr.isKindOf( CM_Debtor )then
					continue;
				endif;
				allDebtors.addNoDuplicates( dr, false );
			endforeach;
			
			
			create allCashDebtors transient;
			foreach dr in allDebtors do
				isCashOnly := false;
				drTerm     := term.allDebtorTerminals.getAtKey( dr );
				if drTerm &lt;&gt; null then
					isCashOnly := drTerm.isCashOnly;
				endif;
				if isCashOnly then
					allCashDebtors.addNoDuplicates( dr, false );
				endif;
			endforeach;
			
			self.mulCashDebtors.top  := 0;
			self.mulCashDebtors.left := 0;
			self.mulCashDebtors.myAvailableListBox.sorted := true;
			self.mulCashDebtors.mySelectedListBox.sorted  := false;
			self.mulCashDebtors.setupControl(app.getErrorString(Cash_only_debtors), allDebtors, INV_CashModuleConfigForm::getDebtorName.name);
			self.mulCashDebtors.availableHeading := app.getErrorString(All_Debtors);
			self.mulCashDebtors.selectedHeading  := app.getErrorString(Cash_only_debtors);
			self.mulCashDebtors.setSelected( allCashDebtors );
			self.mulCashDebtors.setVisibleButtons(true,true,true);
		endif;

		// proforma transaction setup unconditional 
		create agent transient;
		agent.getAvailableCritTypes( self.allAvailTrxTypes );
		
		self.cmbBusUnits.clear();
		self.cmbBusUnitsVess.clear();
		self.cmbBusUnitConfig.clear();
		
		foreach bank in term.companies do
			if not bank.isBusinessUnit then             // TFS 43258
				continue;                               // TFS 43258
			endif;
			self.cmbBusUnits.itemObject     [ self.cmbBusUnits.addItem( bank.getDisplayDetails(false) ) ]      := bank;
			self.cmbBusUnitsVess.itemObject [ self.cmbBusUnitsVess.addItem( bank.getDisplayDetails(false) ) ]  := bank;
			self.cmbBusUnitConfig.itemObject[ self.cmbBusUnitConfig.addItem( bank.getDisplayDetails(false) ) ] := bank;
		endforeach;
		
		
		if defaultBank &lt;&gt; null then
			self.cmbBusUnits.listIndex      := self.cmbBusUnits.findObject( defaultBank );
			self.cmbBusUnitsVess.listIndex  := self.cmbBusUnitsVess.findObject( defaultBank );
			self.cmbBusUnitConfig.listIndex := self.cmbBusUnitConfig.findObject( defaultBank );
		endif;
		
		// TFS 37453
		self.setInitialVoyageEvents();
		
		// TFS 37453
		self.setInitialVoyageResources();
		
		// TFS 37453
		self.doCmbVesselsWithDefaultLoad();
		
		self.mulBUProCirt.caption                    := "";
		self.mulBUProCirt.distanceFromBottom 	     := 10;
		self.mulBUProCirt.distanceFromRight 	     := 25;
		self.mulBUProCirt.lockBottom 			     := false;
		self.mulBUProCirt.lockRight				     := false;
		self.mulBUProCirt.stretchHeight 		     := true;
		self.mulBUProCirt.stretchWidth 			     := true;
		self.mulBUProCirt.multiSelect 	             := ListBox.MultiSelect_Extended;
		self.mulBUProCirt.formDisplayEntryMethodName := INV_CashModuleConfigForm::displayAttributeName.name;
		self.mulBUProCirt.availableHeading           := app.getErrorString(Available_attributes);
		self.mulBUProCirt.selectedHeading            := app.getErrorString(Selected_attributes);
		self.mulBUProCirt.myDownSelectedBtn.visible  := true;
		self.mulBUProCirt.myUpSelectedBtn.visible    := true;
		self.mulBUProCirt.myAddAllBtn.visible        := true;
		self.mulBUProCirt.myRemoveAllBtn.visible     := true;
		self.mulBUProCirt.myBaseForm	             := self;
		self.mulBUProCirt.mySelectedListBox.sorted  := false;
		self.mulBUProCirt.cnEcResizeContents();
		self.mulBUProCirt.readOnly                  := false;
		
		self.tblCritAlloc.fixedRows    := 1;
		self.tblCritAlloc.fixedColumns := 0;
		self.tblCritAlloc.rows         := 1;
		self.tblCritAlloc.columns      := 2;
		self.tblCritAlloc.selectMode   := Table.SelectMode_CurrentRow;
		
		headings := app.getErrorString(Priority) &amp; Tab &amp; app.getErrorString(Transactions);
		self.tblCritAlloc.setCellText(1,1,headings);
		
		self.populateAttributes();
		if self.proformaConfigurationOnly then
			self.cmbDebtorType.visible    := false;
			self.cmbCashInvType.visible   := false;
			self.cmbTaxInvLineTyp.visible := false; 
			self.lstTaxCodes.visible      := false;
		endif;
		
		self.populateTblBankConfig();	//08 Jan 2019	TFS 40010
		
		//08/01/2025	navkc1 JIRA Bug MTN-33573 - We are now always showing the Pro Forma sheet now, populate these so it gets saved correctly
		//if not self.proformaConfigurationOnly then
			
			self.tblConfigOpt.warningMethod     := 'entTableWarning';
			self.tblConfigOpt.optimiseRowHeight := true;
			entTableDef := app.myController.getEntTableDef(	ETDef_TermCashOps );
			self.tblConfigOpt.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
			self.tblConfigOpt.changeMode := CM_EntryTable.ChangeMode_FirstOnly;
			self.populateCmbDebtAction( term.getConfig( CashOnlyInDebtOption ).Integer );	//30 May 2018	NDL	TFS 38952
			self.tblConfigOpt.setValueByName(ETRow_CashACforGL,             term.getConfig(CashACforGL).String);
			self.tblConfigOpt.setValueByName(ETRow_CashCollectUnderpay,     term.getConfig(CashCollectAllowUnderpay).String);
			self.tblConfigOpt.setValueByName(ETRow_CashCollectOverpay,      term.getConfig(CashCollectAllowOverPay).String);
			self.tblConfigOpt.setValueByName(ETRow_InvoiceEveryCashReceipt, term.getConfig(CashInvoiceEveryReceipt).String);
			
			cashReceiptReport := term.getConfig(GateCashReceiptReport).String;
			if cashReceiptReport = null then
				cashReceiptReport := DefRep_CashReceiptReport;
			endif;
			// 33523 add cash-only report
			cashOnlyReceiptReport := term.getConfig(CashOnlyReceiptReport).String;
			if cashOnlyReceiptReport = null then
				cashOnlyReceiptReport := DefRep_CashReceiptReport;
			endif;
			cashInvReceiptReport := term.getConfig(GateCashInvReceiptReport).String;
			if cashInvReceiptReport = null then
				cashInvReceiptReport := DefRep_CashInvReceiptReport;
			endif;
			// 37141
			cashCreditReport := term.getConfig(CashCreditReport).String;
			self.tblConfigOpt.setValueByName(ETRow_CashCreditReport,      cashCreditReport);
			self.tblConfigOpt.setValueByName(ETRow_CashReceiptReport,     cashReceiptReport);
			self.tblConfigOpt.setValueByName(ETRow_CashOnlyReceiptReport, cashOnlyReceiptReport);
			self.tblConfigOpt.setValueByName(ETRow_CashInvReceiptReport,  cashInvReceiptReport);
			// 33885 no pre-payments, no need for over-pay option and cash-only report options
			self.tblConfigOpt.hideRowByName(ETRow_CashCollectOverpay,false);
			self.tblConfigOpt.hideRowByName(ETRow_CashOnlyReceiptReport,false);
			self.tblConfigOpt.hideRowByName(ETRow_CashInvReceiptReport,false);
			
			//self.myAssistant.comboBoxUserQuery( self.cmbQuery, self.myTerminal.getConfig(ProFormaItemQuery).String,null,false );	   //19.03.2020 cnwma1 #48897
			//self.tblConfigOpt.setValueByName(ETRow_ProFormaItemQuery, self.myTerminal.getConfig(ProFormaItemQuery).String);          //19.03.2020 cnwma1 #48897
			// 31602 additional cash entry for Gulftainer
			self.tblConfigOpt.setValueByName(ETRow_CashAllowSecondCurrency, term.getConfig(CashAllowSecondCurrency).Boolean);
			self.tblConfigOpt.setValueByName(ETRow_CashSecondPayCurrency,   term.getConfig(CashSecondPayCurrency).String);
			self.tblConfigOpt.setValueByName(ETRow_NoConsolidateRoadExit,   term.getConfig(NoConsolidateRoadExit).Boolean);	//16 Aug 2019	NDL	TFS 44261
			self.tblConfigOpt.setValueByName(ETRow_CashProformaReport,      term.getConfig(CashProformaReport).String);			// TFS 5740
			self.tblConfigOpt.setValueByName(ETRow_ShowDebtorForPayment,    term.getConfig(ShowDebtorForPayment).Boolean);		// TFS 5740
			self.tblConfigOpt.setValueByName(ETRow_ShowDebtorForProforma,   term.getConfig(ShowDebtorForProforma).Boolean);	// TFS 5740
			self.tblConfigOpt.setValueByName(ETRow_CashRoadExitChkServices,	term.getConfig(CashRoadExitChkServices).Boolean); //25/02/2025	navkc1 JIRA Story MTN-33928
			// 32416... add consignee, consignor, customs agent and freight forwarder
			self.cmbDebtorType.itemObject[self.cmbDebtorType.addItem("")] := null;
			debtorType := app.myRoot.allDebtorTypes["SDT2"];
			self.cmbDebtorType.itemObject[self.cmbDebtorType.addItem(debtorType.description)] := debtorType;
			debtorType := app.myRoot.allDebtorTypes["SDT3"];
			self.cmbDebtorType.itemObject[self.cmbDebtorType.addItem(debtorType.description)] := debtorType;
			debtorType := app.myRoot.allDebtorTypes["SDT6"];
			self.cmbDebtorType.itemObject[self.cmbDebtorType.addItem(debtorType.description)] := debtorType;
			debtorType := app.myRoot.allDebtorTypes["SDT7"];
			self.cmbDebtorType.itemObject[self.cmbDebtorType.addItem(debtorType.description)] := debtorType;
			debtorType := app.myRoot.allDebtorTypes["SDT4"]; // TFS 37454
			self.cmbDebtorType.itemObject[self.cmbDebtorType.addItem(debtorType.description)] := debtorType; // TFS 37454
			
			// ### TFS CR 65810 TASK 65811 27AUG2024 NAVAB1
			debtorType := app.myRoot.allDebtorTypes["SDT1"]; 
			self.cmbDebtorType.itemObject[self.cmbDebtorType.addItem(debtorType.description)] := debtorType;
			
			debtorType := term.getConfig(CashDebtorType).CM_DebtorType;
			if debtorType &lt;&gt; null then 
				int := self.cmbDebtorType.findStringExact(1, debtorType.description);
				self.cmbDebtorType.listIndex := int;
				self.tblConfigOpt.setValueByName(ETRow_CashDebtorType, debtorType.description);
			endif;	
			
			self.tblConfigOpt.setValueByName(ETRow_CashFullCustomsAgentID,   term.getConfig(CashFullCustomsAgentID).Boolean);    	//epr par 35304 2/12/14
			self.tblConfigOpt.setValueByName(ETRow_CheckCashDebtorOnRelease, term.getConfig(CheckCashDebtorOnRelease).Boolean);	// TFS 44087
			
			//18 Dec 2012	NDL	Par 30901 duty doc options
			if term.isDutyDocEnabled then
				self.tblConfigOpt.enableRowByName(ETRow_DutyDocCarReport);
				self.tblConfigOpt.enableRowByName(ETRow_DutyDocumentReport);
				self.tblConfigOpt.enableRowByName(ETRow_ProFormaInclDDTicket);
				self.tblConfigOpt.enableRowByName(ETRow_ProFormaInclDDBill);
				
				dutyDocCarReport := term.getConfig(DutyDocCarReport).String;
				if dutyDocCarReport = null then
					dutyDocCarReport := DefRep_DutyDocumentCarReport;//"CMUI_AjmanCarPrint?DOT?0?-3?10?Courier";
				endif;
				self.tblConfigOpt.setValueByName(ETRow_DutyDocCarReport, dutyDocCarReport);
				
				dutyDocReport := term.getConfig(DutyDocumentReport).String;
				if dutyDocReport = null then
					dutyDocReport := DefRep_DutyDocumentReport;//"CMUI_AjmanCustoms?DOT?0?-5?10?Courier";
				endif;
				self.tblConfigOpt.setValueByName(ETRow_DutyDocumentReport, dutyDocReport);
				
				self.tblConfigOpt.setValueByName(ETRow_ProFormaInclDDTicket, term.getConfig(ProFormaInclDDTicket).Boolean);
				self.tblConfigOpt.setValueByName(ETRow_ProFormaInclDDBill,   term.getConfig(ProFormaInclDDBill).Boolean);
				
			else
				self.tblConfigOpt.hideRowByName(ETRow_DutyDocCarReport,false);
				self.tblConfigOpt.hideRowByName(ETRow_DutyDocumentReport,false);
				self.tblConfigOpt.hideRowByName(ETRow_ProFormaInclDDTicket,false);
				self.tblConfigOpt.hideRowByName(ETRow_ProFormaInclDDBill,false);
			endif;
	
			// 34917 GPHA extra options
			if not term.isDutyDocEnabled then
				self.tblConfigOpt.setValueByName(ETRow_PaymentDetailsMandatory, term.getConfig(PaymentDetailsMandatory).Boolean);
				codeList := term.getConfig(CashAllCashTax).String;
				create allTaxCodes transient;
				create sa transient;
				codeList.asStringArrayByDelimiter(sa, ",");
				self.lstTaxCodes.rows := 0;
				if defaultBank &lt;&gt; null then
					codeList := null;
					// get the actual current tax code from the saved code string
					foreach code in sa do
						taxCode := defaultBank.allTaxCodes[code];
						if taxCode &lt;&gt; null then
							allTaxCodes.add(taxCode);
							if codeList = null then
								codeList := taxCode.description;
							else
								codeList := codeList &amp; ", " &amp; taxCode.description;
							endif;
						endif;
					endforeach;
					self.tblConfigOpt.setValueByName(ETRow_AllCashTax, codeList);
					// add all available tax codes
					foreach taxCode in defaultBank.allTaxCodes where not taxCode.notAvailableForEntry do
						self.lstTaxCodes.addItemObject(taxCode.description, taxCode);
					endforeach;
					if allTaxCodes &lt;&gt; null then
						// add not available tax code if already used
						foreach taxCode in allTaxCodes do
							idx := 1;
							if not self.lstTaxCodes.findObjectInRow(taxCode, idx) then
								self.lstTaxCodes.addItemObject(taxCode.description, taxCode);
							endif;
						endforeach;
						// select the existing tax codes
						foreach taxCode in allTaxCodes do
							self.lstTaxCodes.addSelectedObject(taxCode);
						endforeach;
					endif;
				endif;
			endif;
		//endif; //08/01/2025	navkc1 JIRA Bug MTN-33573
	endif;
	
	if self.shtProForma.visible then																			// TFS 5520
	
		// ### TFS CR 65810 TASK 65812 27AUG2024 NAVAB1
		self.doCmbProformaInvReportBuild();

		self.cmbCashDebtorInv.itemObject[self.cmbCashDebtorInv.addItem("")] := null;							// TFS 5520
		debtorType := app.myRoot.allDebtorTypes["SDT2"];														// TFS 5520
		self.cmbCashDebtorInv.itemObject[self.cmbCashDebtorInv.addItem(debtorType.description)] := debtorType;	// TFS 5520
		debtorType := app.myRoot.allDebtorTypes["SDT3"];														// TFS 5520
		self.cmbCashDebtorInv.itemObject[self.cmbCashDebtorInv.addItem(debtorType.description)] := debtorType;	// TFS 5520
		debtorType := app.myRoot.allDebtorTypes["SDT6"];														// TFS 5520
		self.cmbCashDebtorInv.itemObject[self.cmbCashDebtorInv.addItem(debtorType.description)] := debtorType;	// TFS 5520
		debtorType := app.myRoot.allDebtorTypes["SDT7"];														// TFS 5520
		self.cmbCashDebtorInv.itemObject[self.cmbCashDebtorInv.addItem(debtorType.description)] := debtorType;	// TFS 5520
			
		// ### TFS CR 65810 TASK 65811 27AUG2024 NAVAB1
		debtorType := app.myRoot.allDebtorTypes["SDT1"]; 
		self.cmbCashDebtorInv.itemObject[self.cmbCashDebtorInv.addItem(debtorType.description)] := debtorType;

		debtorType := term.getConfig(CashDebtorType).CM_DebtorType;									            // TFS 5520
		if debtorType &lt;&gt; null then 																				// TFS 5520
			int := self.cmbCashDebtorInv.findStringExact(1, debtorType.description);							// TFS 5520
			self.cmbCashDebtorInv.listIndex := int;																// TFS 5520
		endif;																									// TFS 5520
		cashReceiptReport := term.getConfig(GateCashReceiptReport).String;							            // TFS 5520
		if cashReceiptReport = null then																		// TFS 5520
			cashReceiptReport := DefRep_CashReceiptReport;														// TFS 5520
		endif;																									// TFS 5520
		self.txtCashReport.text := cashReceiptReport;															// TFS 5520
		/* // ### TFS CR 65810 TASK 65811 26SEP2024 NAVAB1 these shoudl be shown, they are saved in the SAVE of proforma
		self.txtCashReport.visible := false;																	// 23 Jun 2022 navsj20  TFS 53759
		self.lblCashReport.visible := false;																	// 23 Jun 2022 navsj20  TFS 53759
		*/
		self.txtCashProformaReport.text :=  term.getConfig(CashProformaReport).String;							// 23 Jun 2022 navsj20  TFS 53759
		self.chkShowDebtorForPaymentInv.value := term.getConfig(ShowDebtorForPayment).Boolean;					// 23 Jun 2022 navsj20  TFS 53759
		
		self.cmbProformaReportProf.visible := true; // ### TFS CR 65810 TASK 65811 26SEP2024 NAVAB1
	endif;																										// TFS 5520
	
	
	//21 Mar 2018	NDL	TFS 37550
	selectedCurrType := term.getCashSecondCurrencyType();
	self.cmbCurrencyType.clear();
	foreach currType in app.myRoot.allCurrencyTypes do
		self.cmbCurrencyType.itemObject[self.cmbCurrencyType.addItem(currType.code)] := currType;
	endforeach;
	if selectedCurrType &lt;&gt; null then
		int := self.cmbCurrencyType.findObject( selectedCurrType );
		self.cmbCurrencyType.listIndex := int;
	endif;
	self.tblConfigOpt.setValueByName( CashSecondPayCurrency, self.cmbCurrencyType.text );
	
	//Start 27.06.2024  navbs1  CR 64834 Task 64847
	//populate currencyCode comboBox and set the table cell text and set currencyCode comboxBox listindex
	selectedCurrencyCode := term.getConfig(CurrencyCodeForAPI).String;
	self.cmbCurrencyCode.clear();
	self.cmbCurrencyCode.itemObject[self.cmbCurrencyCode.addItem("")] := null;
	foreach currType in app.myRoot.allCurrencyTypes do
		self.cmbCurrencyCode.itemObject[self.cmbCurrencyCode.addItem(currType.code)] := currType;
	endforeach;
	if selectedCurrencyCode &lt;&gt; null then
		int := self.cmbCurrencyCode.findStringExact(1, selectedCurrencyCode);
		self.cmbCurrencyCode.listIndex := int;
	endif;
	self.tblConfigOpt.setValueByName( ETRow_CurrencyCodeForAPI, self.cmbCurrencyCode.text);
	//End 27.06.2024  navbs1  CR 64834 Task 64847
	
	
	
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(term, self.permissionMaint) then
		self.btnSave.enabled := false;
		self.btnDelCritAlloc.enabled := false;
		self.btnUpdCritAlloc.enabled := false;
		self.btnAddCritAlloc.enabled := false;
		self.mulBUProCirt.enabled    := false;
		self.cmbBusUnits.enabled     := true;
	endif;	
	
	//26 Mar 2021	NDL	TFS 49840
	if not app.getMyUser.isSuperUser and not app.isSpecial then
		rowIndex := self.tblConfigOpt.getRowByName(ETRow_ShowDebtorForProforma);
		if rowIndex &lt;&gt; 0 then
			self.tblConfigOpt.accessRow( rowIndex ).enabled := false;
		endif;
	endif;
	
epilog

	delete allDebtors;
	delete allCashDebtors;
	delete allTaxCodes;
	delete agent;
	delete sa;

end;</source>
    </JadeMethod>
    <JadeMethod name="setInitialVoyageEvents" id="3f04bf8b-12b8-4acf-9560-4ec772637951">
        <source>setInitialVoyageEvents();
/*

Purpose:			 // TFS 37453

Parameters:			

Return Value:		

Date			Who		Reason
05 March 2018	jlgab1	Initial creation

*/

vars
	eventTypes: ObjectArray;
	firstEventType : CM_EventType;
	eventType : CM_EventType;
	iter : Iterator;
	myOwnerType : Integer;

begin
	self.mulColumns.userInputEnabled 			:= true;
	self.mulColumns.formDisplayEntryMethodName  := INV_CashModuleConfigForm::getEventName.name;
	self.mulColumns.multiSelect					:= ListBox.MultiSelect_Extended;
	self.mulColumns.myAvailableListBox.sorted 	:= true;		
	self.mulColumns.mySelectedListBox.sorted 	:= true;
	self.mulColumns.setTabIndex();
	self.mulColumns.myBaseForm := self;
	
	create	eventTypes transient;
		
	iter := app.myRoot.allEventTypesByCategory.createIterator;
	firstEventType := app.myRoot.allEventTypesByCategory.getAtKeyGeq(CM_EventType.VOYAGE_EVENT,null);

	if firstEventType &lt;&gt; null then
		iter.startAtObject(firstEventType);
		while iter.next( eventType ) do
			if eventType.category &lt;&gt; CM_EventType.VOYAGE_EVENT then
				break;
			endif;
			eventTypes.add(eventType);
		endwhile;
	endif;	
	
	self.mulColumns.setAvailable(eventTypes, true); 

	self.mulColumns.setFocus();
epilog
	delete eventTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="setInitialVoyageResources" id="03b7f4d8-4137-4c58-8c3e-c30bde1b3baa">
        <source>setInitialVoyageResources();
/*

Purpose:			 // TFS 37453

Parameters:			

Return Value:		

Date			Who		Reason
05 March 2018	jlgab1	Initial creation

*/

vars
	eventTypes: ObjectArray;
	firstEventType : CM_EventType;
	eventType : CM_EventType;
	iter : Iterator;
	myOwnerType : Integer;
	tHarbour : HMS_Harbour;
	resource	: HMS_Resource;

begin
	self.mulHMSResources.userInputEnabled 			:= true;
	self.mulHMSResources.formDisplayEntryMethodName  	:= INV_CashModuleConfigForm::getResourceName.name;
	self.mulHMSResources.multiSelect					:= ListBox.MultiSelect_Extended;
	self.mulHMSResources.myAvailableListBox.sorted 	:= true;		
	self.mulHMSResources.mySelectedListBox.sorted 	:= true;
	self.mulHMSResources.setTabIndex();
	self.mulHMSResources.myBaseForm := self;
	
	create	eventTypes transient;
		
	tHarbour := self.myTerminal.myHarbour;
	
	if tHarbour &lt;&gt; null then // TFS 38658
		foreach resource in tHarbour.allResources discreteLock do
				if resource.isNotAvailableForEntry = false then
					eventTypes.add(resource);
		
				endif;
		endforeach;
	endif;
	
	self.mulHMSResources.setAvailable(eventTypes, true); 

	self.mulHMSResources.setFocus();
epilog
	delete eventTypes;
end;</source>
    </JadeMethod>
    <JadeMethod name="setTblConfigOptHeight" id="a497000c-9e3e-484e-b00c-5c0c6bbb153a">
        <updating/>
        <source>setTblConfigOptHeight() updating, protected;
// 34917 for the tax list
vars

begin
	self.tblConfigOpt.adjustHeight(self.height - 30);
end;
</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="cef9aa1e-164b-40a7-b133-9f16cb4a2c7e">
        <updating/>
        <source>setupForm() updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20/08/2012	cnwndl1	Initial creation	Par 29968
28/07/2017	cnwdap1	TFS 5520 SSL Add new sheet with proforma settings
*/
vars

	user : CM_User;				// TFS 5520
	

begin

	// 34917 can be called from invoicing
	if not self.proformaConfigurationOnly then
		if not app.isCashOnlyEnabled then
			self.unloadForm;
			return;
		endif;
	
		if self.myTerminal &lt;&gt; null and not self.myTerminal.isCashOnlyEnabled then
			self.unloadForm;
			return;
		endif;
		
	else
		self.caption := "Invoice Pro Forma Configuration";
		self.lblAttributes.caption := "Please choose the attributes to perform pro forma invoicing with.";
	endif;
	
	self.splConfigOpts.setSplitDirection(true);
	self.splConfigOpts.stretchHeight := true;
	
	inheritMethod();
	
	self.setInitialControlValues();

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		
		self.shtBusUnit.disableAllChildren();
		self.shtCashConfigOpt.disableAllChildren();
		self.shtVesselProforma.disableAllChildren(); // TFS 37453
		self.frmBUProCrit.enabled := true;
		self.cmbBusUnits.enabled := true;
		self.cmbBusUnitsVess.enabled := true; // TFS 37453
		self.cmbBusUnitConfig.enabled := true;	//08 Jan 2019	NDL	TFS 40010
		self.mulColumns.readOnly := true; // TFS 37453
	endif;
	
	/* //08/01/2025	navkc1 JIRA Bug MTN-33573 - Change it to always display Pro Forma Invoice Options sheet in Proforma mode
	user := app.getMyUser;																						// TFS 5520
	
	if not user.canDo(self.myTerminal, Mod_Cash) and user.canDo(self.myTerminal, Mod_Invoicing) then	// TFS 5520
		self.shtProForma.visible := true;																		// TFS 5520
	else																										// TFS 5520
		self.shtProForma.visible := false;																		// TFS 5520
	endif;																										// TFS 5520
	*/
	
	//08/01/2025	navkc1 JIRA Bug MTN-33573 - Change it to always display Pro Forma Invoice Options sheet in Proforma mode
	if self.proformaConfigurationOnly then
		self.shtProForma.visible := true;
	else
		self.shtProForma.visible := false;
	endif;
	
	self.tblConfigOpt.zOrder(0); //	16/09/2025	navkc1	JIRA MTN-35682
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="skipToAttribute" id="e24b28c0-ec15-4cd4-b547-9717f9f2c40b">
        <updating/>
        <source>skipToAttribute(_attributeName: String; _shtName: String) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 August 2012	cnwndl1	Initial creation

*/

vars

	tbl : CM_EntryTable;
	entRow : EntTableRow;
	row : Integer;

begin

	tbl := self.tblConfigOpt;
	if tbl.myEntTableDef &lt;&gt; null then
		entRow := tbl.myEntTableDef.getEntTableRowByHeading(_attributeName);
	endif;
	if entRow &lt;&gt; null then
		row := tbl.myEntTableDef.allEntTableRows.indexOf(entRow);
	endif;
	
	if row &gt; tbl.fixedRows and row &lt;= tbl.rows then
		tbl.accessRow(row).selected := true;
		tbl.topRow := row;
	endif;
	

epilog

end;</source>
        <Parameter name="_attributeName" type="String"/>
        <Parameter name="_shtName" type="String"/>
    </JadeMethod>
    <JadeMethod name="tblBankConfig_lostFocus" id="97d1fd5d-5aeb-4b47-919f-fe4436918d40">
        <controlMethod name="CM_EntryTable::lostFocus"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblBankConfig_lostFocus(table: Table input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2019	jlgndl1	Initial creation	TFS 40010

*/

vars

	row : Integer;
	col : Integer;
	
	bank : CM_Bank;
	myConfigBank : CMIF_ConfigBank;

begin

	row := self.tblBankConfig.row;
	col := self.tblBankConfig.column;

	if col = 2 then
		bank := self.cmbBusUnitConfig.listObject.CM_Bank; 
	
		if bank &lt;&gt; null then
			myConfigBank:= self.allConfigBanks.getAtKey( bank );
		endif;
	
	endif;
	
	if myConfigBank &lt;&gt; null then

		self.updateBankCMIFfromForm();
		
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="tblBankConfig_queryRowColChg" id="713bccf0-444a-4d5d-b5f4-c0914e3db0ca">
        <controlMethod name="CM_EntryTable::queryRowColChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblBankConfig_queryRowColChg(table: Table input; newSheet: Integer; newRow: Integer; newCol: Integer):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2019	jlgndl1	Initial creation	TFS 40010

*/

vars

	row : Integer;
	col : Integer;
	
	bank : CM_Bank;
	myConfigBank : CMIF_ConfigBank;

begin

	

	row := self.tblBankConfig.row;
	col := self.tblBankConfig.column;
	
	if col = 2 then
		bank := self.cmbBusUnitConfig.listObject.CM_Bank; 
	
		if bank &lt;&gt; null then
			myConfigBank:= self.allConfigBanks.getAtKey( bank );
		endif;
	
	endif;
	
	if myConfigBank &lt;&gt; null then
	
		self.updateBankCMIFfromForm();
	
	
	endif;
	
	return true;

epilog


end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="newSheet" type="Integer"/>
        <Parameter name="newRow" type="Integer"/>
        <Parameter name="newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="tblConfigOpt_cellInputReady" id="e3738675-058b-4886-af0c-a4e227c5d1ed">
        <controlMethod name="CM_EntryTable::cellInputReady"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblConfigOpt_cellInputReady(table: Table input; inputControl: Control input; cleft: Real io; ctop: Real io; cwidth: Real io; cheight: Real io) updating;
// 34917 expand the table row/cell for the tax table
vars
	tbl		: CM_BaseTable;
begin
	if CMUI_ListTable.hasInstance(inputControl) then
		tbl := table.CM_BaseTable;
		self.myAssistant.listTableCellInputReady(tbl, cheight, self.saveRowHeight);
		self.setTblConfigOptHeight();
	endif;

end;
</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="inputControl" type="Control" usage="input"/>
        <Parameter name="cleft" type="Real" usage="io"/>
        <Parameter name="ctop" type="Real" usage="io"/>
        <Parameter name="cwidth" type="Real" usage="io"/>
        <Parameter name="cheight" type="Real" usage="io"/>
    </JadeMethod>
    <JadeMethod name="tblConfigOpt_mouseDown" id="2da38f9c-5f42-4ffe-8717-0622fc5f4e46">
        <controlMethod name="CM_EntryTable::mouseDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblConfigOpt_mouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 November 2012	cnwndl1	Initial creation	Par 30682

*/

vars

	str : String;
	rowIndex : Integer;
	heading : String;
	msg : String;

begin

	//26 Mar 2021	NDL	TFS 49840
	rowIndex := self.tblConfigOpt.getRowByName(ETRow_ShowDebtorForProforma);
	if rowIndex = table.row then
		if table.column = 2 then
			heading := 'This option should only be set once, during initial configuration of a new Master Terminal system.';
			msg := 'This configuration option is meant for a client who only wants to Print the Proforma charges and not collect any cash. Checking this box removes the "Save" option on the Cash Collection screen. 

Using the Print option on the Cash collection screen updates the invoice lines as "Paid" status but technically there is no payment received yet as there is no cash receipt. 

Clients have to be extra careful while using this option because when turned on it is used as a database condition that puts the cash receipt into a different collection from normal cash receipts. This means that these proforma cash receipts are not used for road exit financial stop checking and they are not shown in any of the cash transaction screens. 

This option should only be set once, during initial configuration of a new Master Terminal system.';
			app.msgBox( msg, heading, MsgBox_OK_Only + MsgBox_Information_Icon );
		endif;
	endif;
	

	str := table.getCellText( table.row, table.column);
	if str &lt;&gt; null and button = 2 then
		app.printReportDotMatrixLineUp( str );
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
    <JadeMethod name="tblCritAlloc_dblClick" id="af51c33f-b355-4bc1-a476-94f2cd3669cd">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblCritAlloc_dblClick(table: Table input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2012	cnwndl1	Initial creation	Par 29968

*/

vars

	row : Integer;
	proCriteria : CM_ProformaTransactionCriteria;

begin

	row := self.tblCritAlloc.row;
	if row &gt; self.tblCritAlloc.fixedRows and row &lt;= self.tblCritAlloc.rows then
		proCriteria := self.tblCritAlloc.accessRow(row).itemObject.CM_ProformaTransactionCriteria;
	endif;

	if proCriteria = null then
		return;
	endif;

	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		return;
	endif;

	self.doAddUpdateClick( proCriteria );

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="de03fad8-6529-4390-8e12-aeacbb8f9d88">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 26 September 2024 09:53:46.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0018255, locale);
	btnAddCritAlloc.translateCaption(Xlat_0018256, locale);
	btnClose.translateCaption(Xlat_0018257, locale);
	btnDelCritAlloc.translateCaption(Xlat_0018258, locale);
	btnDeleteVessel.translateCaption(Xlat_0022224, locale);
	btnHookVessel.translateCaption(Xlat_0022225, locale);
	btnSave.translateCaption(Xlat_0018259, locale);
	btnSaveVessel.translateCaption(Xlat_0022226, locale);
	btnUpdCritAlloc.translateCaption(Xlat_0018260, locale);
	chkShowDebtorForPaymentInv.translateCaption(Xlat_0024956, locale);
	cmbProformaReportProf.translateBubbleHelp(Xlat_0026983, locale);
	lblAttributes.translateCaption(Xlat_0018261, locale);
	lblBusUnit.translateCaption(Xlat_0018262, locale);
	lblBusUnitConfig.translateCaption(Xlat_0023145, locale);
	lblBusUnitVess.translateCaption(Xlat_0022227, locale);
	lblCashProformaReport.translateCaption(Xlat_0024957, locale);
	lblCashReport.translateCaption(Xlat_0022075, locale);
	lblDefDebtor.translateCaption(Xlat_0022076, locale);
	lblEvents.translateCaption(Xlat_0022228, locale);
	lblProformaReportProf.translateBubbleHelp(Xlat_0026984, locale);
	lblProformaReportProf.translateCaption(Xlat_0026985, locale);
	lblResources.translateCaption(Xlat_0022229, locale);
	lblVessel.translateCaption(Xlat_0022230, locale);
	mulBUProCirt.translateCaption(Xlat_0018263, locale);
	shtBusUnit.translateCaption(Xlat_0018264, locale);
	shtCashConfigOpt.translateCaption(Xlat_0018265, locale);
	shtProForma.translateCaption(Xlat_0022077, locale);
	shtVesselProforma.translateCaption(Xlat_0022231, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="unload" id="f3607364-90c2-4735-a55c-5f31b02d69bf">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2019	jlgndl1	Initial creation	TFS 40010

