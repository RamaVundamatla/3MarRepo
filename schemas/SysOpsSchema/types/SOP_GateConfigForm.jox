    <JadeMethod name="doSave" id="a5661c73-2995-42ec-abf9-9a063efb1fec">
        <updating/>
        <source>doSave() : Boolean updating;

/*
Date			Who		Reason
02 July 2009	cnwar2	Initial creation

*/
vars
	configCMIF : CMIF_ConfigTerminal;
	theResult : Integer;	//14 Jan 2020 NDL	TFS 46815
	msg : String;
	
begin
	create configCMIF transient;
	configCMIF.setFromPersistentData(self.myTerminal);
	self.setCMIFFromForm(configCMIF);
	
	if self.myTerminal.myRoadProcess &lt;&gt; self.cmbRoadProcess.listObject.CM_RoadProcess
	and self.cmbRoadProcess.listObject.CM_RoadProcess.isASPA then
		msg := "The 'ASPA GCI Road Process' does not support 'Road Jobs', 'Road Tasks' or the concept of a current 'Vehicle Visit'." &amp; CrLf &amp; CrLf;
		msg := msg &amp; "As a result, the 'Road Operations' form will not be available with this option selected." &amp; CrLf &amp; CrLf;
		msg := msg &amp; "Similarly, Hand Held and web based 'Road' apps will be not supported. (I.e. Gate Checker, Truck Loader, Release (to Truck), Pack (to Truck) etc.)" &amp; CrLf;
		if app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Cancel + MsgBox_Exclamation_Mark_Icon ) = MsgBox_Return_Cancel then
			return false;
		endif;
	endif;

	// ### TFS 52268 15Dec2021 NAVPW1
	if self.myTerminal.myRoadProcess &lt;&gt; self.cmbRoadProcess.listObject.CM_RoadProcess
	and self.cmbRoadProcess.listObject.CM_RoadProcess.is1STOPVBS and self.myTerminal.myActive1StopVBSWebServiceDef = null then
		msg := "No active 1STOPVBS External Web Services detected.";
		if app.msgBox( msg, app.getErrorString(Warning), MsgBox_OK_Cancel + MsgBox_Exclamation_Mark_Icon ) = MsgBox_Return_Cancel then
			return false;
		endif;
	endif;
	
	//14 Jan 2020 NDL	TFS 46815 - Add while loop for warning acknowledgements
	while true do
	
		app.myTrxUA.trxUpdateConfig(configCMIF, self.myTerminal, self.expectedEdition, app.myPassport);
	
		if app.myPassport.trxCompletedOK then
			return true;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(Gate_configuration), app.myPassport, ErrWarnMode_Update);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		return false;
		
	endwhile;
	
epilog

	delete configCMIF;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getReportNameForCMIF" id="fff5c8a4-4da2-440f-8fc6-7a194a19b08f">
        <source>getReportNameForCMIF(_txtControl : CMUI_TextBox; _defaultValue : String) : String protected;

/*

Purpose:			Get Report Name to save in CMIF.

Parameters:			Control displaying Report Name and default value

Return Value:		Report Name to save in CMIF.  Will be null if default value being used.


Date		Who		Reason
23 Feb 2010	consw1	PAR #21156 - Gate Config Report Names

*/

vars
	reportName	: String;

begin
	reportName := _txtControl.text.trimBlanks();

	//14 Jan 2019	TFS 40479
//	if reportName = _defaultValue then
//		reportName := null;
//	endif;
	
	return reportName;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_txtControl" type="CMUI_TextBox"/>
        <Parameter name="_defaultValue" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getReportNameForForm" id="ee2d0d14-53d9-4e84-9952-85bd150e319c">
        <source>getReportNameForForm(_cmifValue, _defaultValue : String) : String protected;

/*

Purpose:			Get Report Name to display on form

Parameters:			Value from CMIF and default value

Return Value:		Report Name to display


Date		Who		Reason
23 Feb 2010	consw1	PAR #21156 - Gate Config Report Names

*/

vars
	reportName	: String;

begin
	reportName := _cmifValue.trimBlanks();
	
	if reportName = null then
		reportName := _defaultValue;
	endif;
	
	return reportName;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_cmifValue" type="String"/>
        <Parameter name="_defaultValue" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="hasChanged" id="ee090dcf-517c-4b6b-82fa-442cbbd5f981">
        <source>hasChanged(): Boolean protected;

/*
Date			Who		Reason
03 Sep 2009		cnwar2	Initial creation
23 Feb 2010		consw1	PAR #21156 - Gate Config Report Names
16/03/2010		cnwcs5	par 22734 - transit into yard
29/11/2011		cnwdap1	PAR #28733 CCMS SFW 1261 Removed Ticket fields from Printing tab
01/07/2013		cnwdap1	PAR #30344 CCMS GLT 2226 Gate Out Consignee Required check box
16/12/2013		cnwdap1	PAR #32849 CCMS PEN 2321 Security Gate
12/05/2022 		navhl20 TFS 53430  EUP - Sub Carrier registration in MTN
21/09/2023		jlizm1	TFS 59576 Kiosk error advice report - gate config
08 Feb 2024 	navhl20 ChangeRequest 62084:[62376] EUP | Retrospective Operations - [54177.010] - Road Entry
*/
vars
	configCMIF : CMIF_ConfigTerminal;
	
begin
	create configCMIF transient;
	configCMIF.setFromPersistentData(self.myTerminal);
	
	if configCMIF.gateInCheckISOTypes 			&lt;&gt; self.chkRecISO.value
	or configCMIF.gateInForceBATNumber 			&lt;&gt; self.chkRecBAT.value
	or configCMIF.gateInOutHazardousWarning 	&lt;&gt; self.chkRecHazard.value
	or configCMIF.doNotCreateBulkRelease		&lt;&gt; self.chkRecBR.value
	or configCMIF.allowDuplicateReleaseNos		&lt;&gt; self.chkMTDuplicates.value
	or configCMIF.brPackReqDelvRelNum			&lt;&gt; self.chkMTUnqiue.value
	or configCMIF.gateAllowMultipleMTGrades		&lt;&gt; self.chkMTGrades.value
	or configCMIF.allowMultiBookingRef			&lt;&gt; self.chkBRMultiLine.value
	or configCMIF.bookingRefBasicCheck			&lt;&gt; self.chkBRBasicChecks.value
	or configCMIF.useBookingSummView			&lt;&gt; self.chkBRSummaryView.value
	or configCMIF.bookingRefRequired			&lt;&gt; app.bookingRequiredStringToEnum(self.cmbBookingReq.text)			//+cnwml2 PAR23763 MSL PAR1078
	or configCMIF.bookingOversubscribe		    &lt;&gt; self.chkBookOversubs.value										// 08/04/2014 cnwmh5 #33829
	or configCMIF.bookingRefErrors				&lt;&gt; self.chkBRErrors.value
	or configCMIF.noPINforHazardousPreNote		&lt;&gt; self.chkNoPinPrenoteH.value
	or configCMIF.noPINforOverDimenPreNote		&lt;&gt; self.chkNoPinPrenoteO.value
	or configCMIF.noPINforHazardousRelease		&lt;&gt; self.chkNoPinReleaseH.value
	or configCMIF.noPINforOverDimenRelease		&lt;&gt; self.chkNoPinReleaseO.value
	or configCMIF.fleetFileContDetails			&lt;&gt; self.chkFleetFileCont.value
	or configCMIF.fleetFileGenDetails			&lt;&gt; self.chkFleetFileGen.value
	or configCMIF.fleetFileTrailerDetails		&lt;&gt; self.chkFleetFileTrlr.value
	or configCMIF.fleetFileErrors				&lt;&gt; self.chkFleetFileErr.value
	or configCMIF.allowMobileRoadExit			&lt;&gt; self.chkOtherMAQ.value
	or configCMIF.gateAllowDualGate				&lt;&gt; self.chkOtherMMQ.value
	or configCMIF.gateAllowUngatedTrucks		&lt;&gt; self.chkOtherUUT.value
	or configCMIF.twinLiftFromGate				&lt;&gt; self.chkOtherTwin.value
	or configCMIF.gateElapsedTimeExceeded		&lt;&gt; self.txtOtherMinutes.text.Integer
	or configCMIF.defaultCarrierEmail			&lt;&gt; self.lblEmailCarrier.value
	or configCMIF.defaultConsignorEmail			&lt;&gt; self.lblEmailConsign.value
	or configCMIF.gateDefaultEntry				&lt;&gt; self.cmbDefEntryGate.listObject.CM_Gate
	or configCMIF.gateIOHideAutoComplete		&lt;&gt; self.chkEntryAutoComp.value
	or configCMIF.gateReceiptRequired			&lt;&gt; self.chkEntryGateRec.value
	or configCMIF.gateInOutHideBatNumber		&lt;&gt; self.chkEntryHideBAT.value
	or configCMIF.weighBridgeEnabled			&lt;&gt; self.chkEntryWeigh.value
	or configCMIF.gateInVehicleTareWeight		&lt;&gt; self.chkEntryTare.value
	or configCMIF.isSubCarrierEnabled           &lt;&gt; self.chkSubcarrier.value			//12/5/2022 navhl20 TFS 53430
	or configCMIF.isSubCarrierRequired          &lt;&gt; self.chkSubCarrierMand.value		//12/5/2022 navhl20 TFS 53430
	or configCMIF.isRetrospectiveMode          	&lt;&gt; self.chkRetroMode.value			//08.02.2023 navhl20 #62084[62376]
	//10/01/2011 cnwdz2 26613
	or configCMIF.hideRGateDriverCodeName		&lt;&gt; self.chkEntryHideName.value
	or configCMIF.gateDefaultExit				&lt;&gt; self.cmbDefExitGate.listObject.CM_Gate
	or configCMIF.gateExitDefaultSortCol		&lt;&gt; self.cmbExitSort.text
	or configCMIF.gateOutReleaseByISOType		&lt;&gt; self.chkExitISO.value
	or configCMIF.gateRelNoSearchText			&lt;&gt; self.chkRelRecTB.value
	or configCMIF.gateInAllowAutoComplete		&lt;&gt; self.chkAutoComplete.value
	or configCMIF.trailerDetailsVisible			&lt;&gt; self.chkTrailerDet.value//cnwas3
	or configCMIF.gateInAutoBOLNumber			&lt;&gt; self.chkAutoBOL.value
	or configCMIF.gateInAutoComplete			&lt;&gt; self.chkAutoCompDef.value
	or configCMIF.gateInAutoVisitNo			&lt;&gt; self.chkAutoVisitNo.value
	or configCMIF.showVehicleState			&lt;&gt; self.chkShowState.value //cnwrd1 par 21158 18.3.2010
	//or configCMIF.gateInAutoCompleteBkgrnd		&lt;&gt; self.chkAutoCompleteB.value
	or configCMIF.vehicleVisitNumPrefix			&lt;&gt; self.txtVVPrefix.text
	or configCMIF.vehicleVisitNumLength			&lt;&gt; self.txtVVLength.text.Integer
	or configCMIF.vehicleVisitNumStartSeq		&lt;&gt; self.txtVVStartSeqNum.text.Integer
	or configCMIF.vehicleVisitNumRollover		&lt;&gt; self.cmbVVRollover.listIndex
	or configCMIF.vehicleVisitNumMax			&lt;&gt; self.txtVVMax.text.Integer
	or configCMIF.gateCarterNoteReport			&lt;&gt; self.getReportNameForCMIF(self.txtPrintCarter, DefRep_GateCarterNoteReport)
	or configCMIF.gateDriverInstructionsReport	&lt;&gt; self.getReportNameForCMIF(self.txtDriverInstr, DefRep_GateDriverInstructions)
	or configCMIF.gateCheckAllowsIsoChg			&lt;&gt; self.chkAllowIso.value	//27 jan 2010 NDL CCMS MES 1005
	or configCMIF.gateCheckRequiresCargoId		&lt;&gt; self.chkEnterId.value	//27 jan 2010 NDL CCMS MES 1005
	or configCMIF.gateRoadJobReceipt			&lt;&gt; self.getReportNameForCMIF(self.txtPrintRRR, DefRep_GateRoadJobReceipt)
	or configCMIF.gateInterchangeReport			&lt;&gt; self.getReportNameForCMIF(self.txtInterChg, null)	//11 Jan 2019	NDL	TFS 40479
	or configCMIF.gateKioskErrorAdvice			&lt;&gt; self.getReportNameForCMIF(self.txtKioskErrorAdv, null) // TFS 59576
	
	//or configCMIF.gateTicketJRWEquipment_REL	&lt;&gt; self.getReportNameForCMIF(self.txtPrintTickRel, DefRep_GateTicketJRWEquip_REL)	// PAR #28733
	//or configCMIF.gateTicketJRWEquipment_REC	&lt;&gt; self.getReportNameForCMIF(self.txtPrintTickRec, DefRep_GateTicketJRWEquip_REC)	// PAR #28733
	//or configCMIF.gateTicketJRWReefer			&lt;&gt; self.getReportNameForCMIF(self.txtPrintTickRef, DefRep_GateTicketJRWReefer)		// PAR #28733
	//or configCMIF.gateTicketJRWEIR				&lt;&gt; self.getReportNameForCMIF(self.txtPrintTickEIR, DefRep_GateTicketJRWEIR)		// PAR #28733
	//or configCMIF.gateTicketJRWTrouble			&lt;&gt; self.getReportNameForCMIF(self.txtPrintTickTrb, DefRep_GateTicketJRWTrouble)	// PAR #28733
	//or configCMIF.gateTicketJRWHaz				&lt;&gt; self.getReportNameForCMIF(self.txtPrintTickHaz, DefRep_GateTicketJRWHaz)		// PAR #28733
	or configCMIF.gateReceiptCopies				&lt;&gt; self.txtPrintCopies.text.Integer
	or configCMIF.gateTransitIntoYard			&lt;&gt; self.chkYardTransitIN.value	// 16/03/2010 cnwcs5 par 22743
	or configCMIF.printBuckslip					&lt;&gt; self.chkPrintBuckslip.value
	or configCMIF.printPreview					&lt;&gt; self.chkPrintPreview.value 
	or configCMIF.printInterchange				&lt;&gt; self.chkPrintInterchg.value	//11 Jan 2019	NDL	TFS 40479
	or configCMIF.gateOutConsigneeReqd			&lt;&gt; self.chkConsignee.value				// PAR #30344
	or configCMIF.siteHasSecurityGate			&lt;&gt; self.chkSecurityGate.value			// PAR #32849
	or self.cmbTrailDefIMEX.listObject = null or configCMIF.defRecTrailIMEX &lt;&gt; self.cmbTrailDefIMEX.listObject.CM_IMEXStatus.code //26 May 2017	NDL	TFS 4452	
	or self.myTerminal.myRoadProcess &lt;&gt; self.cmbRoadProcess.listObject.CM_RoadProcess	//01 Oct 2020	NDL	TFS 49189
	or configCMIF.defRecTrailOper &lt;&gt; self.cmbTrailDefOper.listObject.CM_Operator	//21 Oct 2020	NDL	TFS 50113
	then
		return true;
	endif;
	
	return false;
epilog
	delete configCMIF;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hideVVRNumFields" id="e8d6b190-12b8-4dd1-8cec-5346483f76e9">
        <source>hideVVRNumFields();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 October 2020	jlgndl1	Initial creation

*/

vars

	roadProcess : CM_RoadProcess;
	show : Boolean;

begin

	roadProcess := self.cmbRoadProcess.listObject.CM_RoadProcess;
	if roadProcess = null or not roadProcess.isASPA then
		show := true;
	else
		//Not valid fields when using ASPA GCI Road Process
		show := false;
	endif;
	
	self.chkAutoVisitNo.visible := show;
	self.lblVVPrefix.visible := show;
	self.txtVVPrefix.visible := show;
	self.lblVVLength.visible := show;
	self.txtVVLength.visible := show;
	self.lblVVStartSeqNum.visible := show;
	self.txtVVStartSeqNum.visible := show;
	self.lblVVRollover.visible := show;
	self.cmbVVRollover.visible := show;
	self.lblVVMax.visible := show;
	self.txtVVMax.visible := show;

epilog

end;</source>
    </JadeMethod>
