    <JadeMethod name="convertInvoiceAmountDetails" id="48577111-96fa-4720-a9d0-f3aa51daf07f">
        <source>convertInvoiceAmountDetails(_controller : CnEcReleaseController);
/*
Purpose - 	
Who - NAVAB1
Date - 08APR2024
ADO -  CR 63369 TASK 63371
*/

vars
	iter01 : Iterator;
	theInvLine : CM_InvoiceLine;
	theInv : CM_Invoice;
	oArray : ObjectArray; 
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	
	app.writeLog(method.qualifiedName &amp; " Convert Invoice Total Amount", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" Convert Invoice Total Amount") ;	
	endif;
	
	create oArray transient;
	
	CM_InvoiceLine.allInstances(oArray,0,false);
	iter01 := oArray.createIterator;
	
	while iter01.next(theInvLine) do
		beginTransaction;
		theInvLine.setTotalAmount();
		commitTransaction;
	endwhile;

	oArray.clear();

	
	CM_Invoice.allInstances(oArray,0,false);
	iter01 := oArray.createIterator;
	
	while iter01.next(theInv) do
		beginTransaction;
		theInv.setTotalAmountFromLines();
		commitTransaction;
	endwhile;

	
	app.writeLog(method.qualifiedName &amp; " all Invoices converted", LogINFO);
	if _controller &lt;&gt; null then
		_controller.logEntry(" all Invoices converted") ;
	endif;
	
	self.addScriptRun(method.name);
epilog
	delete oArray;
end;</source>
