    <JadeMethod name="setTwinLift" id="78e301e8-0c8b-4307-80f9-6c2890bf6a01">
        <updating/>
        <source>setTwinLift(_tl : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		30 September 2005  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

