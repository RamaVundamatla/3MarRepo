    <JadeMethod name="tblMain_queryRowColChg" id="093201a3-3c94-474f-b9f9-136cf3468004">
        <controlMethod name="CM_EntryTable::queryRowColChg"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMain_queryRowColChg(table: CM_EntryTable input; newSheet: Integer; newRow: Integer; newCol: Integer):Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 Jun 2008	cnwkpd1	PAR #17145 - Form translation isssues

*/

vars
	localSaveRowH	: Real;
	
begin
	if self.mode &lt;&gt; self.Mode_View then
		if table.row = table.getRowByName(ETRow_CustomsEntryNumber) then
			localSaveRowH := self.saveRowHeight;
			self.myAssistant.stringsTableQueryRowChange(table, localSaveRowH, self.tblCustEntry);
			self.saveRowHeight := localSaveRowH.Integer;
			self.tblCustEntry.height := 20;
			table.cnEcResizeContents();
		endif;
	endif;
	return true;
	
	
epilog

end;</source>
        <Parameter name="table" type="CM_EntryTable" usage="input"/>
        <Parameter name="newSheet" type="Integer"/>
        <Parameter name="newRow" type="Integer"/>
        <Parameter name="newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
