<Class name="CM_CodeGroupLogSpecs">
    <JadeMethod name="loadTreeViewArray" id="4f8e7bbd-868a-40fc-a245-d0a0ad6506f1">
        <source>loadTreeViewArray(_collection: Collection input; _level: Integer; _form: CMUI_CodesMaintTree);
// -----------------------------------------------------------------------------
// Created:		12 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	code : CM_Code;	
	obj  : SOPVM_LogSpecs;
begin
	create obj transient;
	
	obj.initializeMe(self, _level, null);
	obj.myForm := _form;
	_collection.add(obj);
	obj.loadTreeViewArray(_collection, 	_level, _form, obj);

epilog

end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_level" type="Integer"/>
        <Parameter name="_form" type="CMUI_CodesMaintTree"/>
    </JadeMethod>
</Class>
