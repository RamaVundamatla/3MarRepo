<Class name="WS_ProformaDetailsResponse" id="4369089f-070d-41af-a19d-23d01a8da149">
    <superclass name="WS_Response"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="webservice"/>
    <ImplicitInverseRef name="allProformaHeaders" id="f0e1c38e-76c0-452a-9a7b-e8c8f0ec1b1f">
        <memberTypeInverse/>
        <type name="WS_ProformaHeaderArray"/>
        <access>readonly</access>
    </ImplicitInverseRef>
    <JadeMethod name="delete" id="99952f84-aeed-440d-b39a-845218ff42d1">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 April 2024	navkc1	CR 63402 Task 63403: Jade - REST API getProformaDetailsForDebtor

*/

vars

begin
	self.allProformaHeaders.purge();
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setValuesFromController" id="4aedaae8-a806-433f-bbd3-0dd8089394c0">
        <updating/>
        <source>setValuesFromController(_controller : CMIF_CashReceiptEnqController) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02/05/2024	navkc1 CR63402  Task 63403: Jade - REST API getProformaDetailsForDebtor

*/

vars
	cashReceipt		: CM_CashReceipt;
	wsHeader		: WS_ProformaHeader;
	object 			: Object;
	cashPayment 	: CM_CashPayment;
	cashCredit 		: CM_CashCredit;
	wsDetail		: WS_ProformaDetails;
	number			: Integer;
begin
	
	foreach cashReceipt in _controller.allCashReceiptHeaders as CM_CashReceipt do
		create wsHeader transient;
		
		wsHeader.setValuesFromCMIF(cashReceipt, _controller);
		
		self.allProformaHeaders.add(wsHeader);
	endforeach;
	
	foreach object in _controller.allCashPayments do
		if object.isKindOf(CM_CashPayment) then
			cashPayment := object.CM_CashPayment;
			number := cashPayment.myCashReceipt.sequenceNum;
		/*elseif object.isKindOf(CM_CashCredit) then
			cashCredit := object.CM_CashCredit;
			number := cashCredit.myDerivedFromCashReceipt.sequenceNum;*/
		else
			continue;
		endif;
		
		create wsDetail transient;
		
		//wsDetail.setValuesFromCMIF(cashPayment, cashCredit, _controller);
		wsDetail.setValuesFromCMIF(cashPayment, cashCredit); //11/07/2024	navkc1 CR 64837 Task 64851
		
		foreach wsHeader in self.allProformaHeaders do
			if wsHeader.receiptNumber &lt;&gt; number then
				continue;
			endif;
			wsHeader.allProformaDetails.add(wsDetail);
		endforeach;
		
	endforeach;
	
epilog

end;</source>
        <Parameter name="_controller" type="CMIF_CashReceiptEnqController"/>
    </JadeMethod>
</Class>
