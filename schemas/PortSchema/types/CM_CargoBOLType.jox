    <JadeMethod name="refreshSelectorColumns" id="8e64946a-fc28-4fad-948f-7c8ad131b9af">
        <updating/>
        <source>refreshSelectorColumns() updating;
// ---------------------------------------------------------------------------
// Created:     22 April 2004		cnwth2	
//
// Purpose:     Adds any available properties that might not already be present		 
// ----------   ----------  --------------------------------------------------
vars
	qDef					: CM_QueryDefinition;
	sorter					: CnEcSorter;
	qProp					: CM_QueryProperty;
begin
	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.BOL_Query_Type, self.id];
	if qDef = null then
		return;
	endif;
	
	foreach qProp in qDef.allQueryProperties do
		
	endforeach;
	
	create sorter transient;

	
epilog
	delete sorter;
end;</source>
    </JadeMethod>
    <JadeMethod name="resetSelectorColumns" id="cf1c670f-f8cd-4a76-886f-8dcae6d24fdd">
        <updating/>
        <source>resetSelectorColumns(_setDefaults : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     25 September 2003	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	qDef		: CM_QueryDefinition;
	qProp		: CM_QueryProperty;
	colArray	: StringArray;
	type		: Integer;
begin
	//24 Nov 2009	NDL	CCMS 1028
	if ( self.id &gt;= BOLType_Min and self.id &lt;= BOLType_Max ) then
		type := CM_QueryDefinition.BOL_Query_Type;
	else
		type := CM_QueryDefinition.TrackedItem_Query_Type;
	endif;
		
	qDef := app.myRoot.allQueryDefinitionObjects[type, self.id];
	if qDef = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'A query definition object could not be found for ' &amp; self.description &amp; ' mode');
		return;
	endif;
	
	colArray := self.allSelectorColumns;	
	colArray.clear();

	foreach qProp in qDef.allQueryProperties do
		colArray.add(qProp.propertyName);
	endforeach;
	
	if _setDefaults then
		self.setDefaultSelectorColumns(qDef);
	endif;

end;</source>
        <Parameter name="_setDefaults" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setDefaultSelectorColumns" id="1eade4c6-7275-4d7f-8ef9-df56e90bb1ec">
