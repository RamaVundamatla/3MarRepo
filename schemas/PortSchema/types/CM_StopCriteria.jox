    <JadeMethod name="isAnExcludedTypeForMatching" id="6b87da32-a1e0-4057-aaeb-671a8e942ef3">
        <source>isAnExcludedTypeForMatching(_type: Integer): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 July 2022	navds20	ChangeRequest 53862: EUP - WMS - Damage Recording Extra Details

*/

vars

begin

	if _type = YACriteriaType_AvGrade
	or _type = YACriteriaType_BOL
	or _type = YACriteriaType_BookingRef 
	or _type = YACriteriaType_CargoType
	or _type = YACriteriaType_Clean
	or _type = YACriteriaType_Commodity 
	or _type = YACriteriaType_CommodityGroup 
	or _type = YACriteriaType_Consignee
	or _type = YACriteriaType_FreightForward
	or _type = YACriteriaType_ISO
	or _type = YACriteriaType_ISOGroup
	or _type = YACriteriaType_ImexStatus
	or _type = YACriteriaType_OperatorItem
	or _type = YACriteriaType_Product
	or _type = YACriteriaType_RailReleaseReq 
	or _type = YACriteriaType_RequiresPower 
	or _type = YACriteriaType_TrailerType  
	or _type = YACriteriaType_TransactionType  
	or _type = YACriteriaType_SrcTermArea
	or _type = YACriteriaType_SrcTermAreaType 
	or _type = YACriteriaType_Stops	
	or _type = YACriteriaType_SubTerminal
	or _type = YACriteriaType_ToDoTasks	
	or _type = YACriteriaType_Voyage
	or _type = YACriteriaType_Weight 
	then
		return true;
	endif;
	
	return inheritMethod(_type);

epilog

end;</source>
        <Parameter name="_type" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
