    </ImplicitInverseRef>
    <JadeMethod name="asKey" id="7dc9640e-6226-4591-bdb4-c8d673727eca">
        <source>asKey(): CM_ExportPropertyConfigBuilder;
/*

Purpose:			
	* Marks the current property as the business key
	* @return self for chaining
Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation  MTN 36792 - JADE Core Framework - Property Configuration Builder

*/

begin
	if self.currentProperty = null then
        app.raiseUnexpectedProgramError(class.name, method.name, 
            "asKey() called without property");
        return self;
    endif;
    
     self.currentProperty.myKeyName := self.currentProperty.propertyName;
     self.exportClass.myKeyName := self.currentProperty.propertyName;
    
    return self;
end;</source>
        <ReturnType type="CM_ExportPropertyConfigBuilder"/>
    </JadeMethod>
    <JadeMethod name="asParent" id="2539a34b-0082-4768-bb5b-ff8e1afd521e">
        <source>asParent() : CM_ExportPropertyConfigBuilder;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation  MTN 36792 - JADE Core Framework - Property Configuration Builder

*/

vars
begin
	if self.currentProperty = null then
        app.raiseUnexpectedProgramError(class.name, method.name, 
            "asParent() called without property");
        return self;
    endif;
	 if self.currentProperty.isAttribute then
        app.raiseUnexpectedProgramError(class.name, method.name, 
            "asParent() must be called on object reference");
        return self;
    endif;
	
	 self.currentProperty.includeInExport := false;
	 self.currentProperty.isParentReference := true;
	 return self;
epilog

end;</source>
        <ReturnType type="CM_ExportPropertyConfigBuilder"/>
    </JadeMethod>
    <JadeMethod name="commit" id="509c9311-f75d-4bcf-b367-7dded6ba2059">
        <source>commit();
/*

Purpose:			
	* Applies all queued property configurations to the export class
Parameters:			

Return Value:		

Date		Who		Reason
07 January 2026	naviv1	Initial creation  MTN 36792 - JADE Core Framework - Property Configuration Builder

*/

vars
    prop: CM_ExportImportProperty;
begin   
    foreach prop in self.propertyQueue do
        // Use existing method - it handles property lookup internally
        self.exportClass.setExportImportProperty(
            prop.propertyName,       // Property name as string
            prop.includeInExport,    // Include in export
            prop.expandReference,    // Expand reference
            prop.displayName,        // Display name
            prop.referencedClassName,             // Key name for references/collections
			prop.isAttribute,
			prop.isReference,
			prop.isCollection
        );
    endforeach;
end;</source>
    </JadeMethod>
    <JadeMethod name="excluded" id="3fbd670f-b301-4309-98d0-bff17ef7dc58">
        <updating/>
        <source>excluded(): CM_ExportPropertyConfigBuilder updating;
/*

Purpose:			
	* Marks current property as excluded from export
	 * Useful for documenting properties that are NOT exported
	 * 
	 * Example:
	 *   .property(CM_Commodity::internalId, "Internal ID").excluded()
Parameters:			

Return Value:		

Date		Who		Reason
07 January 2026	naviv1	Initial creation  MTN 36792 - JADE Core Framework - Property Configuration Builder

*/

begin
    if self.currentProperty = null then
        app.raiseUnexpectedProgramError(class.name, method.name, 
            "excluded() called without property");
        return self;
    endif;
    
    self.currentProperty.includeInExport := false;
    
    return self;
end;</source>
        <ReturnType type="CM_ExportPropertyConfigBuilder"/>
    </JadeMethod>
    <JadeMethod name="expanded" id="3a5e700d-5ab8-4129-9c77-d34a19e2402f">
        <updating/>
        <source>expanded(): CM_ExportPropertyConfigBuilder updating;
/*

Purpose:			
	* Marks current collection/reference for full expansion
	 * Must be called after .property() on reference/collection
	 * 
	 * Example:
	 *   .property(CM_TerminalAreaView::allTerminalAreaViewPositions, "Positions").expanded()
Parameters:			

Return Value:		

Date		Who		Reason
07 January 2026	naviv1	Initial creation  MTN 36792 - JADE Core Framework - Property Configuration Builder

*/

begin
    if self.currentProperty = null then
        app.raiseUnexpectedProgramError(class.name, method.name, 
            "expanded() called without property");
        return self;
    endif;
    
    if not self.currentProperty.isReference and not self.currentProperty.isCollection then
        app.raiseUnexpectedProgramError(class.name, method.name, 
            "expanded() called on attribute (only for references/collections)");
        return self;
    endif;
    
    self.currentProperty.expandReference := true;
    
    return self;
end;</source>
        <ReturnType type="CM_ExportPropertyConfigBuilder"/>
    </JadeMethod>
    <JadeMethod name="forClass" id="789c47c1-8f23-4adf-be31-13ade845facc">
        <updating/>
        <source>forClass(_exportClass: CM_ExportImportClass io): CM_ExportPropertyConfigBuilder updating;
/*

Purpose:			
	* Sets the class being configured
	* @return self for chaining	
Parameters:			

Return Value:		

Date		Who		Reason
06 January 2026	naviv1	Initial creation MTN 36792 - JADE Core Framework - Property Configuration Builder

*/

begin
    self.exportClass := _exportClass;
    create self.propertyQueue transient;
    return self;
end;</source>
        <Parameter name="_exportClass" type="CM_ExportImportClass" usage="io"/>
        <ReturnType type="CM_ExportPropertyConfigBuilder"/>
    </JadeMethod>
    <JadeMethod name="parentProperty" id="bb2559a0-69f1-4882-9b6d-d43deec318a2">
        <updating/>
        <source>parentProperty(_property: Property; _displayName: String): CM_ExportPropertyConfigBuilder updating;
/*

Purpose:			
	* Marks property as parent reference (not exported - inferred from context)
	* Use for child objects that reference their parent:
	*   - CM_TerminalAreaViewPosition::myTerminalAreaView
	*   - CM_GridRow::myGridArea
Parameters:			
	* @param _property Property constant
	* @param _displayName Display name (for documentation)
	
Return Value:		
	* @return self for chaining
Date		Who		Reason
06 January 2026	naviv1	Initial creation  MTN 36792 - JADE Core Framework - Property Configuration Builder

*/

vars
    refClassName: String;
begin
    // Validate it's a reference
    if not _property.isKindOf(Reference) or not _property.type.isA(Class) then
        app.raiseUnexpectedProgramError(class.name, method.name, 
            "parentProperty() must be called on object reference");
        return self;
    endif;
    
    refClassName := _property.type.name;
    
    // Create property configuration
    create self.currentProperty transient;
    self.currentProperty.propertyName := _property.name;
    self.currentProperty.displayName := _displayName;
    self.currentProperty.includeInExport := false;  // Parent key not exported
    self.currentProperty.expandReference := false;
    self.currentProperty.isAttribute := false;
    self.currentProperty.isReference := true;
	self.currentProperty.isCollection := false;
    self.currentProperty.isParentReference := true;
    self.currentProperty.referencedClassName := refClassName;
    
    self.propertyQueue.add(self.currentProperty);
    
    return self;
end;</source>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_displayName" type="String"/>
        <ReturnType type="CM_ExportPropertyConfigBuilder"/>
    </JadeMethod>
    <JadeMethod name="property" id="1983c89b-1dee-4bca-9949-43219e2f282d">
        <updating/>
        <source>property(_property: Property; _displayName: String): CM_ExportPropertyConfigBuilder updating;
/*

Purpose:			
	* Auto-detecting property configuration 
	 * 
	 * Automatically determines if property is:
	 * - Attribute (primitive/string/date/etc)
	 * - Reference (single object reference)
	 * - Collection (set/array/dictionary of objects)
Parameters:				
	* @param _property Property constant (e.g., CM_Commodity::code)
	* @param _displayName Display name
Return Value:		
	* @return self for chaining
Date		Who		Reason
06 January 2026	naviv1	Initial creation  MTN 36792 - JADE Core Framework - Property Configuration Builder

*/
vars
    isAttr, isRef, isColl: Boolean;
    refClassName: String;
begin
    // Auto-detect property type
    if _property.isKindOf(Attribute) then
        isAttr := true;
        isRef := false;
        isColl := false;
        refClassName := "";
		elseif _property.isKindOf(Reference) then
        isAttr := false;
        
        if _property.type.isA(Class) then
            // Single object reference
            isRef := true;
            isColl := false;
            refClassName := _property.type.name;
        elseif _property.type.isA(CollClass) then
            // Collection reference
            isRef := false;
            isColl := true;
            refClassName := _property.type.CollClass.memberType.name;
        endif;
    endif;
    
    // Create property configuration
    create self.currentProperty transient;
    self.currentProperty.propertyName := _property.name;
    self.currentProperty.displayName := _displayName;
    self.currentProperty.includeInExport := true;
    self.currentProperty.isAttribute := isAttr;
    self.currentProperty.isReference := isRef;
    self.currentProperty.isCollection := isColl;
    self.currentProperty.referencedClassName := refClassName;
    
    self.propertyQueue.add(self.currentProperty);
    
    return self;
end;</source>
        <Parameter name="_property" type="Property"/>
        <Parameter name="_displayName" type="String"/>
        <ReturnType type="CM_ExportPropertyConfigBuilder"/>
    </JadeMethod>
</Class>
