    <JadeMethod name="doLstDataDragDrop" id="ebbee5cd-10ae-40fd-abd7-becaf73097c0">
        <updating/>
        <source>doLstDataDragDrop(listbox: ListBox input; win: Window input; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     26 January 2005	cnwhjg1
//
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	lObjectTarget : Object;
	dropIndex: Integer;

begin
	
	inheritMethod(listbox, win, x,y);

	
	dropIndex := listbox.dragListIndex;
	
	if dropIndex &lt; 1 then
		lObjectTarget := null;  // if draging off the list set target to null so later on can check. 
	else
		lObjectTarget := listbox.itemObject[dropIndex];  // set target so know what action to take 
	endif;

	if lObjectTarget &lt;&gt; null then 
	
		if not lObjectTarget.isKindOf(CM_ServiceGroup) or not  self.myCurrentServiceObject.isKindOf(CM_Service) then
			app.msgBox("Can only move a service to a service group.","Service Move",MsgBox_OK_Only);
			return;
		else
			if app.msgBox("Are you sure that you want to move  '" &amp;  self.myCurrentServiceObject.name &amp; "' to group '" &amp;  lObjectTarget.CM_ServiceObject.name &amp; "' ?", 
								"Service Move",MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
				return;
			endif;
			self.doUpdateFromDrag(self.myCurrentServiceObject, lObjectTarget.CM_ServiceGroup);
		endif;
	endif;
	
end;</source>
        <Parameter name="listbox" type="ListBox" usage="input"/>
        <Parameter name="win" type="Window" usage="input"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
