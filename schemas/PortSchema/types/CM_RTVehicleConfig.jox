    <JadeMethod name="getDoorDirHookString" id="833b67c7-1783-4ae1-8b83-969ba686a6a4">
        <source>getDoorDirHookString( _task : CM_RTQueueTask;  _isSource : Boolean) : String;
/*

Date		Who		Reason
05 February 2014	cnwer1	Initial creation PAR 33425

*/

vars
	cmifParams		: CMIF_LocationTransParams;
begin
	if _task = null then
		return null;
	endif;
	
	if self.myDoorDirectionHookCode = null then
		return null;
	endif;
	
	create cmifParams transient;
	cmifParams.isSource := _isSource;

	cmifParams.myQueueTask:=_task;
	cmifParams.myTrackedItem := _task.ti;
	if _isSource then
		cmifParams.myLocation :=_task.sourceLocation;
	else
		cmifParams.myLocation :=_task.targetLocation;
	endif;
	
	return app.myHookAgent.runHookLinkPublic( self.myDoorDirectionHookCode.myHookType.hookType,	// _hookType : Integer;
											   self.myTerminal,							// _hookObject : CM_Object;
											   self,							// _receiver : Object;
											   cmifParams).String;
	
epilog
	delete cmifParams;


end;</source>
        <Parameter name="_task" type="CM_RTQueueTask"/>
        <Parameter name="_isSource" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getIsoTypeHookString" id="a1020291-b54e-40a9-966f-ee6c830afd39">
        <source>getIsoTypeHookString(_ti : CM_TrackedItem ) : String;
/*

Date		Who		Reason
05 February 2014	cnwer1	Initial creation PAR 33425

*/

vars
	cmifParams		: CMIF_ContainerAttrParams;
begin
	if _ti = null then
		return null;
	endif;
	
	if self.myIsoTypeHookCode = null then
		if _ti.isKindOf(CM_Container) then
			return _ti.CM_Container.isoType;
		endif;
		
		return null;
	endif;
	
	create cmifParams transient;
	cmifParams.myTrackedItem:=_ti;
	
	return app.myHookAgent.runHookLinkPublic( self.myIsoTypeHookCode.myHookType.hookType,	// _hookType : Integer;
													   self.myTerminal,							// _hookObject : CM_Object;
													   self,							// _receiver : Object;
													   cmifParams).String;
	
epilog
	delete cmifParams;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocationHookString" id="e913fe10-ca04-484b-9e10-ba908c3686a0">
        <source>getLocationHookString( _task : CM_RTQueueTask;  _isSource : Boolean) : String;
/*

Date		Who		Reason
05 February 2014	cnwer1	Initial creation PAR 33425

*/

vars
	cmifParams		: CMIF_LocationTransParams;
begin
	if _task = null then
		return null;
	endif;
	create cmifParams transient;
	cmifParams.isSource := _isSource;

	cmifParams.myQueueTask:=_task;
	cmifParams.myTrackedItem := _task.ti;
	if _isSource then
		cmifParams.myLocation :=_task.sourceLocation;
	else
		cmifParams.myLocation :=_task.targetLocation;
	endif;
	
	
	if self.myLocationHookCode = null then
		return cmifParams.myLocation.getFullId();
		
	endif;
	
	return app.myHookAgent.runHookLinkPublic( self.myLocationHookCode.myHookType.hookType,	// _hookType : Integer;
											   self.myTerminal,							// _hookObject : CM_Object;
											   self,							// _receiver : Object;
											   cmifParams).String;
	
epilog
	delete cmifParams;
end;</source>
