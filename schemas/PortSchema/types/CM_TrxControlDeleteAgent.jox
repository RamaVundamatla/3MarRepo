    <JadeMethod name="trxDeleteRestrictionLabour" id="b7932a38-017b-4dc7-9f7f-9f2dd01882ce">
        <updating/>
        <source>trxDeleteRestrictionLabour(pRestriction : CM_LabourRestriction; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		August 2001 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

	restrictionToDelete : CM_LabourRestriction;
	childRestriction : CM_LabourRestriction;
	children : CM_LabourRestrictionSet;
	
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if pRestriction = null then
		app.raiseCMException1(ERR_DEL_NULLOBJECT, 'Labour Restriction', null, null);
		return;
	endif;
	
	//23 Apr 2014	NDL Par 33995 - Always start from the parent if there is one.
	restrictionToDelete := pRestriction.myMasterLabourRestriction;
	if restrictionToDelete = null then
		restrictionToDelete := pRestriction;
	endif;

	app.setContinueCMExceptions(false);

	// Start the transaction
	beginTransaction;
	
	//23 Apr 2014	NDL Par 33995
	if not restrictionToDelete.allChildLabourRestrictions.isEmpty then
		create children transient;
		restrictionToDelete.allChildLabourRestrictions.copy(children);
		foreach childRestriction in children do
			app.myUtilityDA.utlDeleteRestrictionLabour(childRestriction, true, _passport);
			if _passport.hasErrors then
				return;
			endif;
		endforeach;
	endif; 

	app.myUtilityDA.utlDeleteRestrictionLabour(restrictionToDelete, false, _passport);

epilog
	self.finaliseActivityWithPassport(_passport);
	delete children;
end;</source>
        <Parameter name="pRestriction" type="CM_LabourRestriction"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
