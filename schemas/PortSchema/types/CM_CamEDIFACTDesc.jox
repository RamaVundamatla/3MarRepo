    <JadeMethod name="makeMessageSealsData" id="29dbe9d9-c8b4-46f5-8b2d-ec44501fb786">
        <source>makeMessageSealsData(	_theTI : CM_TrackedItem;
						_camMessage: CM_CamMessage input;
						_group :HugeStringArray input;
						_camProtocol : CM_CamProtocol;
						_contentsStatus : String);
/* Changes

Date		Name	TFS#			Description
============================================================================
15/09/2010	cnwndl1	par 25608 		Initial creation. change to using method 'getSealNum', 
									'getSealNumShipper'	and 'getSealNumCustomsStringArray'
10/02/2011	cnwcs5	CCMS JMT 1977
					PAR 26531 		changed _camMessage parameter usage from io to input
10/05/2011	cnwcs5	CCMS SCT 2058 
					PAR 27460 		user defined special characters
									pass group as parameter, not number
29 Jan 2015	cnwrs1	Par 35544 		Change CamMessage to use HugeStringArray
29 Mar 2019 jlgka1	TFS 44020		Change StringArray to HugeStringArray.
============================================================================*/
vars
	strSeal 	: String;
	custSeals 	: HugeStringArray; // jlgka1 TFS 44020
	plus, 
	singleQuote	: Character;	// 10/05/2011 cnwcs5 par 27460
begin

	//23 Mar 2012	NDL	Par 29144
	if _contentsStatus = '4' then
		//Empty Containers should never include seals data...
		return;
	endif;
	
	plus 		:= _camProtocol.elementSeparator;	// 10/05/2011 cnwcs5 par 27460
	singleQuote	:= _camProtocol.segmentTerminator;	// 10/05/2011 cnwcs5 par 27460
	
	//the SEL for the seal number
	if _theTI.getSealNum.trimRight &lt;&gt; "" then	
		_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(_theTI.getSealNum) &amp; plus &amp; "CA" &amp; singleQuote);	// 10/05/2011 cnwcs5 par 27460
	endif;
	
	
	create custSeals transient;
	_theTI.getSealNumCustomsStringArray( custSeals );
	foreach strSeal in custSeals do
		if strSeal.trimRight &lt;&gt; "" then		// 12/09/2014 cnwar2 #34897
			_group.add("SEL" &amp; plus &amp; _camProtocol.formatSeal(strSeal) &amp; plus &amp; "CU" &amp; singleQuote);	// 10/05/2011 cnwcs5 par 27460
		endif;
	endforeach;
	
	
	if _theTI.getSealNumShipper.trimRight &lt;&gt; "" then
		_group.add("SEL" &amp; plus &amp;  _camProtocol.formatSeal(_theTI.getSealNumShipper) &amp; plus &amp; "SH" &amp; singleQuote);	// 10/05/2011 cnwcs5 par 27460
	endif;
	
epilog

	delete custSeals;

end;</source>
        <Parameter name="_theTI" type="CM_TrackedItem"/>
        <Parameter name="_camMessage" type="CM_CamMessage" usage="input"/>
        <Parameter name="_group" type="HugeStringArray" usage="input"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_contentsStatus" type="String"/>
    </JadeMethod>
