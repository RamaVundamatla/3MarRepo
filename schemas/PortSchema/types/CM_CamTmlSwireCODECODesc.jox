    <JadeMethod name="getMessageType" id="498a9ae6-694b-4809-a0a3-30aef8e4cae7">
        <source>getMessageType(_transaction: CM_TITransaction; _messageTypeArray: IntegerArray input; _camProtocol: CM_CamProtocol; _camAgent: CM_CamControllerAgent input);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 20/07/2021	navdap1		Initial creation TFS 51572 TML Swire Outbound EDI TRFE from Marine to Depot values incorrect
// 25/08/2021	navdap1		TFS 51834 TML 1090 occurs when processing new Swire Codeco message for terminal
//
vars
	ti : CM_TrackedItem;
	subTo, subFrom : CM_SubTerminal;
	subToStr, subFromStr : String;			// TFS 51834

begin
	_messageTypeArray.clear;
	
	// TRFE from Marine to Depot is treated as a Gate Out
	ti := _transaction.myTrackedItem;
	if ti &lt;&gt; null and ti.isContainer and ti.CM_Container.isTMLTRFE(_transaction, null) and _transaction.isKindOf(CM_SubTerminalReceive) then
		subTo	:=	_transaction.CM_SubTerminalReceive.mySubTerminal;
		if subTo &lt;&gt; null then				// TFS 51834
			subToStr := subTo.code;			// TFS 51834
		endif;								// TFS 51834
		subFrom	:=	_transaction.CM_SubTerminalReceive.mySubTerminalFrom;
		if subFrom &lt;&gt; null then				// TFS 51834
			subFromStr := subFrom.code;		// TFS 51834
		endif;								// TFS 51834
		//app.writeLog(method.qualifiedName &amp; Tab &amp; "Transaction is a CM_SubTerminalReceive from " &amp; subFrom.code &amp; " to " &amp; subTo.code, LogINFO);	// TFS 51834
		app.writeLog(method.qualifiedName &amp; Tab &amp; "Transaction is a CM_SubTerminalReceive from " &amp; subFromStr &amp; " to " &amp; subToStr, LogINFO);		// TFS 51834
		_messageTypeArray.add(CODECO_GATEOUT);
	else	
		inheritMethod(_transaction, _messageTypeArray, _camProtocol, _camAgent);
	endif;
	
epilog

end;</source>
        <Parameter name="_transaction" type="CM_TITransaction"/>
        <Parameter name="_messageTypeArray" type="IntegerArray" usage="input"/>
        <Parameter name="_camProtocol" type="CM_CamProtocol"/>
        <Parameter name="_camAgent" type="CM_CamControllerAgent" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getProtocolDepotCode" id="86d07075-0113-4981-98e0-2bffcf27b9c2">
        <source>getProtocolDepotCode(_protocol :CM_CamProtocol) : String;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/08/2020	jlgdap1		Initial creation TFS 49880 TML Swire Shipping Outgoing EDI Depot and Terminal
