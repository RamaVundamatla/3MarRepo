    <JadeMethod name="getStatusDescription" id="b39ccac1-1c54-4ca9-8820-60a283dabb20">
        <source>getStatusDescription(_status : Integer): String;
// ---------------------------------------------------------------------------
// Created:		April 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	str:   String;
begin
	if _status = CM_InvoiceLine.STATUS_NORMAL then
		str := app.getErrorString(Normal);
	elseif _status = CM_InvoiceLine.STATUS_VOIDED then
		str := app.getErrorString(Void);
	endif;

	return str;
end;</source>
