    <JadeMethod name="getStringForIdStyle" id="c892bade-0dac-4627-b147-f851d846c03e">
        <source>getStringForIdStyle(_idStyle : Integer) : String;
/*

Purpose:			
		This method returns the text of the Global Constant based on the value
		i.e Id Style 1 returns P YY SSS
Parameters:			

Return Value:		

Date		Who		Reason
22 December 2022	navkc1	Initial creation TFS CR 55300 TASK 55524

*/

vars
	appScm 		: Schema;
	category 	: ConstantCategory;
	const 		: GlobalConstant;
	dict		: ConstantNDict;
	
begin

	appScm := rootSchema.getSchema(PortSchemaName);
	category := appScm.getCategory("AutoIdStyle");
	
	dict  := category.getConstants();
	
	foreach const in dict as GlobalConstant do
		if _idStyle = const.valueAsInteger() then
			return const.text;
		endif;
	endforeach;
	
	return null;
	
epilog

end;</source>
        <Parameter name="_idStyle" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getStringForResetOption" id="3af1871e-3360-42b1-99de-3e9f18df3e8e">
        <source>getStringForResetOption( _int : Integer ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 January 2019	jlgndl1	Initial creation	TFS 43018

*/

vars

begin

	if _int = self.Reset_On_Date_Chg_Int then
		return self.Reset_On_Date_Chg_String;
	elseif _int = self.Reset_On_Month_Chg_Int then
		return self.Reset_On_Month_Chg_String;
	elseif _int = self.Reset_On_Year_Chg_Int then
		return self.Reset_On_Year_Chg_String;
	elseif _int = self.Reset_On_Overflow_Int then
		return self.Reset_On_Overflow_String;
	elseif _int = self.Reset_Custom_Int then
		return self.Reset_Custom_String;
	else
		return "Unknown";
	endif;

epilog

end;</source>
        <Parameter name="_int" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValidResetOptions" id="18ecabfb-76c9-4472-ada1-9fd6db18e463">
        <source>getValidResetOptions( intArray : IntegerArray input; _styleId : Integer );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 January 2019	jlgndl1	Initial creation	TFS 43018
20 September 2022 navmv20 ChangeRequest 54610: MTN - Auto Cargo Id New Options
*/

vars

begin

	//Generic default behaviour....  re-implemented as required.
	
	if _styleId &gt; 0 then
		if _styleId = AutoIdStyle_P_YY_SSS
		or _styleId = AutoIdStyle_YY_SSS
		or _styleId = AutoIdStyle_P_MM_YY_SSS
		or _styleId = AutoIdStyle_P_YY_MM_SSS
		then
			intArray.add( self.Reset_On_Year_Chg_Int );
		elseif _styleId = AutoIdStyle_P_YY_MM_DD_SSS then //15/09/2022 navmv20 TFS 54610
			intArray.add( self.Reset_On_Date_Chg_Int ); //15/09/2022 navmv20 TFS 54610
		else
			intArray.add( self.Reset_On_Overflow_Int );
		endif;
	else
		intArray.add( self.Reset_On_Overflow_Int );
	endif;

epilog

end;</source>
        <Parameter name="intArray" type="IntegerArray" usage="input"/>
        <Parameter name="_styleId" type="Integer"/>
    </JadeMethod>
