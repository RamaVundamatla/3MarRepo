    <JadeMethod name="tblWLESetRowColour" id="cdf54926-2dff-46c9-a6f2-bd28532c0e03">
        <source>tblWLESetRowColour(pWLE : CM_WorkListEntry; _rowIdx, _rtCol : Integer);
//--------------------------------------------------------------
//Created: 17 March 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	isSelected,
	isReceipt 	: Boolean;
	foreColour,
	backColour 	: Integer;	
begin
	
	foreColour := Black;
	backColour := White;

	if pWLE = null then
		return;
	endif;

	if pWLE.job &lt;&gt; null and pWLE.job.jobType = BOLType_Log then
		foreColour := Black;
		if _rowIdx mod 2 = 0 then
			backColour := self.colorRow1;
		else
			backColour := self.colorRow2;
		endif;
	else
		pWLE.getRowColour(foreColour, backColour);	
	endif;	

	self.tblWorkEntries.accessRow(_rowIdx).backColor := backColour;
	self.tblWorkEntries.accessRow(_rowIdx).foreColor := foreColour;	
	
	if backColour = Red then
		self.tblWorkEntries.accessRow(_rowIdx).fontBold := true;	
	else		
		self.tblWorkEntries.accessRow(_rowIdx).fontBold := false;		
	endif;
	
	if _rtCol &gt; 0 then
		self.displayWLEsShowRT(self.tblWorkEntries, _rowIdx, _rtCol); // TFS 42872 jlgzm1 19/08/2019
	endif;	

end;</source>
        <Parameter name="pWLE" type="CM_WorkListEntry"/>
        <Parameter name="_rowIdx" type="Integer"/>
        <Parameter name="_rtCol" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="tblWLESetSelected" id="fb536c79-7f82-4234-b4a5-dfa1098564b5">
        <updating/>
        <source>tblWLESetSelected() updating;
//--------------------------------------------------------------
//Created: 05 September 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	newRow : Integer;
begin
	
	if (not global.isValidObject(self.selectedTableObject)) then
		self.selectedTableObject := null;
		return;
	endif;
	
	self.tblWorkEntries.findObjectInRow(self.selectedTableObject, newRow);

	if newRow &gt; tblWorkEntries.fixedRows then
		self.tblWorkEntries.selectRow(newRow, false);
		self.tblWorkEntries.row := newRow;
		self.tblWLEChange(newRow);
	endif;

end;</source>
    </JadeMethod>
