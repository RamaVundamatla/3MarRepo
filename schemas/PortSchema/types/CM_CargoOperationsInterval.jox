    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="harbour"/>
    <ExplicitInverseRef name="myHMSMovement" id="afec152e-ed8b-48ca-9e13-528e621575ee">
        <kind>child</kind>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="HMS_Movement"/>
