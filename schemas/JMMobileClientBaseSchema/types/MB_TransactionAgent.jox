<Class name="MB_TransactionAgent" id="351893a7-a4d7-4771-824a-674fdc714bda">
    <superclass name="MB_Transient"/>
    <transient/>
    <sharedTransientAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="mbTransient"/>
    <JadeMethod name="trxCreateTerminalAreas" id="0492c5b4-b9f9-413f-a2de-b2d53e1a1519">
        <source>trxCreateTerminalAreas(_terminalAreas : MB_TerminalAreaByIdDict);
// ---------------------------------------------------------------------------
// Created:     23 August 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	dtoTA	: MB_TerminalArea;
	tmpTA	: MB_TerminalArea;
begin
	beginTransaction;

	foreach dtoTA in _terminalAreas do
		tmpTA := app.myRoot.allTerminalAreasById[dtoTA.id];
		
		if tmpTA = null then
			create tmpTA persistent;
		endif;
		
		tmpTA.setFromDTO();
	endforeach;

	commitTransaction;
end;</source>
        <Parameter name="_terminalAreas" type="MB_TerminalAreaByIdDict"/>
    </JadeMethod>
    <JadeMethod name="trxCreateTerminals" id="aa9b5fe0-8c2b-4838-85b4-bd6e7891917e">
        <source>trxCreateTerminals(_terminals : MB_TerminalAreaByIdDict);
// ---------------------------------------------------------------------------
// Created:     23 August 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	dtoTerminal	: MB_TerminalArea;
	tmpTerminal	: MB_Terminal;
begin
	beginTransaction;
	
	foreach dtoTerminal in _terminals do
		tmpTerminal := app.myRoot.allTerminalsByName[dtoTerminal.id];
		
		if tmpTerminal = null then
			create tmpTerminal persistent;
		endif;
		
		tmpTerminal.setFromDTO();
	endforeach;

	commitTransaction;
end;</source>
        <Parameter name="_terminals" type="MB_TerminalAreaByIdDict"/>
    </JadeMethod>
</Class>
