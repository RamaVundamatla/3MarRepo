<Class name="CM_RORORampExternalVoyage" id="2da5e72d-5a73-4bb1-8c47-cfdf1b93e30e">
    <superclass name="CM_RORORampExternal"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="vesselStructures"/>
    <ExplicitInverseRef name="myVoyageStructuralElement" id="732be25b-07b6-4de3-9a66-c68441810bf6">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <embedded/>
        <type name="CM_VoyageStructuralElements"/>
        <access>readonly</access>
        <Inverse name="CM_VoyageStructuralElements::allRamps"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="myVoyageStructure" id="888ea24d-85e9-4193-b4e8-6add47a46c44">
        <kind>child</kind>
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="CM_ROROVoyageStructure"/>
        <access>readonly</access>
        <Inverse name="CM_ROROVoyageStructure::allRamps"/>
    </ExplicitInverseRef>
    <JadeMethod name="delete" id="dac6b370-d9d5-4f2e-aefe-4bd567dba803">
        <updating/>
        <source>delete() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	if self.isTransient then
		return;
	endif;
	
	if self.myVoyageStructuralElement &lt;&gt; null then
		self.myVoyageStructuralElement.causeEvent(EVENT_DECK_ITEM_DELETE,false,self);
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getAuditParent" id="d0c95639-1766-41d4-8ea3-5170ecdb21bf">
        <source>getAuditParent(): CM_Voyage;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin

	if self.myVoyageStructuralElement = null then
		return null;
	endif;
	
	
	return self.myVoyageStructuralElement.myVoyage;

epilog

end;</source>
        <ReturnType type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="getStructure" id="9edaa1e5-95dc-4aaa-a645-db39aeec39f8">
        <source>getStructure(): CM_VoyageStructuralElements;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	return self.myVoyageStructuralElement;

epilog

end;</source>
        <ReturnType type="CM_VoyageStructuralElements"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="92ca8335-5ca1-4ad2-a335-85e0ad4dfa70">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

	pxySelf: SelfType;
	completedOK		: Boolean;
	
begin
	pxySelf:= inheritMethod();
	
	pxySelf.myVoyageStructuralElement:=self.myVoyageStructuralElement;
	
	completedOK := true;		
	return pxySelf;

epilog
	if not completedOK then			
		delete pxySelf;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="f3c4f5bd-c60a-4f87-8cbb-f9a144926e82">
        <updating/>
        <source>setForUpdate(_proxyRORORamp: SelfType; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars
	voyage : CM_Voyage;
	beforeAuditText,
	afterAuditText	: String;
	realStructure : CM_VoyageStructuralElements;
begin

	realStructure:=_proxyRORORamp.myVoyageStructuralElement;
	
	if  realStructure &lt;&gt; null then
		beforeAuditText:=realStructure.getAuditText;
	endif;
	
	inheritMethod(_proxyRORORamp,_passport);

	self.myVoyageStructuralElement:=realStructure;
	
	
	if self.myVoyageStructuralElement &lt;&gt; null then
		
		voyage:= self.myVoyageStructuralElement.myVoyage;
		afterAuditText:=self.myVoyageStructuralElement.getAuditText;
		app.myAA.auditUpdateTrx(voyage,beforeAuditText, afterAuditText);
			
		if _proxyRORORamp.pxyGetRealObject =null then
			self.myVoyageStructuralElement.causeEvent(EVENT_DECK_ITEM_CREATE,false,self);
		else
			self.myVoyageStructuralElement.causeEvent(EVENT_DECK_ITEM_UPDATE,false,self);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_proxyRORORamp" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setMyVoyageStructure" id="3135992a-7202-46a4-bca2-c1417d242298">
        <updating/>
        <source>setMyVoyageStructure(_voyageStructure : CM_VoyageStructuralElements ) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
07 June 2011	cnwer1	Initial creation CCMS MES 1116

*/

vars

begin
	self.myVoyageStructuralElement:=_voyageStructure;
epilog

end;</source>
        <Parameter name="_voyageStructure" type="CM_VoyageStructuralElements"/>
    </JadeMethod>
    <JadeMethod name="validateUpdate" id="34e73a26-83ec-44ad-82fe-8ab6586c1cc1">
        <source>validateUpdate(_passport: CM_Passport);

/*

Purpose:		Add validation for ramp

Parameters:			

Return Value:		


Date			Who		Reason
18 October 2011	cnwmh5	Initial creation #28440

*/

vars
	realRamp, 
	ramp				: CM_RORORampExternal;
begin
	inheritMethod(_passport);

	if self.myVoyageStructuralElement &lt;&gt; null then
		
		realRamp := self.pxyGetRealObject();
		ramp := self.myVoyageStructuralElement.allRamps[self.code];
		if ramp &lt;&gt; null and ramp &lt;&gt; realRamp then
			app.raiseCMException1(VB_DUPLICATED_ITEM, self.code, null, null);
		endif;
	
	endif;
	
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
</Class>
