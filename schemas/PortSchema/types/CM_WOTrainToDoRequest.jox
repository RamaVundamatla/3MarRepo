<Class name="CM_WOTrainToDoRequest" id="a39d66c7-1223-4b69-a4cd-0fe0a9f7ef72">
    <superclass name="CM_WOToDoRequest"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="workorder"/>
    <ExplicitInverseRef name="allTrains" id="9df6e854-069e-4a8f-b980-c14e2793efe2">
        <transientToPersistentAllowed/>
        <updateMode>manual</updateMode>
        <type name="CM_TrainByCodeDict"/>
        <access>readonly</access>
        <Inverse name="CM_Train::allWorkOrderRequests"/>
    </ExplicitInverseRef>
    <JadeMethod name="createWLEs" id="6369af0f-1729-44f2-afbe-5ba7bc8bd2f4">
        <source>createWLEs();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
23 November 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs

*/

vars
	aWLE			:	CM_WOTrainToDoWLE;
	train			:	CM_Train;
	toDoTask		: 	CM_ToDoTask;
	trainIter,
	toDoTaskIter	: 	Iterator;
begin
	trainIter := self.myJob.CM_WOToDoTrainJob.allTrains.createIterator();
	toDoTaskIter := self.allToDoTasks.createIterator();
	
	while trainIter.next(train) do
		create aWLE persistent;
		aWLE.setForCreate(self.myJob, self); 
		aWLE.setMyTrain(train);
	endwhile;
epilog
	delete trainIter;
	delete toDoTaskIter;
end;</source>
    </JadeMethod>
    <JadeMethod name="setForCreateInternal" id="2f6ac90c-ab8d-4be9-af49-44fd76c6ab21">
        <updating/>
        <source>setForCreateInternal(_myJob: CM_WOToDoTaskJob; _toDoInternalJobParam: CMIF_WorkOrderJobParams) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Jan 2023 navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs (Task 54263)

*/

vars

begin
	inheritMethod(_myJob, _toDoInternalJobParam);
	
	self.myJob.CM_WOToDoTrainJob.allTrains.copy(self.allTrains);
epilog

end;</source>
        <Parameter name="_myJob" type="CM_WOToDoTaskJob"/>
        <Parameter name="_toDoInternalJobParam" type="CMIF_WorkOrderJobParams"/>
    </JadeMethod>
</Class>
