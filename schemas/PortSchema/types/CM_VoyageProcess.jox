    </JadeMethod>
    <JadeMethod name="updateAdditionalReps" id="d6c4f32f-6ba3-400a-ac6c-598bde0ea94e">
        <updating/>
        <source>updateAdditionalReps( _allPxyReps : CM_VoyageProcessReportArray )updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 February 2019	jlgndl1	Initial creation	TFS 43240

*/

vars

	pxyRep : CM_VoyageProcessReport;
	realRep : CM_VoyageProcessReport;

begin

	self.allAdditionalReports.purge();

	foreach pxyRep in _allPxyReps do
		create realRep persistent;
		realRep.setForCreate( pxyRep );
		realRep.setMyVoyageProcess( self );
		realRep.validateForUpdate();
	endforeach;

epilog

end;</source>
        <Parameter name="_allPxyReps" type="CM_VoyageProcessReportArray"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="4461e8c8-2bc0-4803-8666-8207fee750c9">
        <source>validateForCreate(_passport : CM_Passport);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/03/2018	jlgdap1		Initial creation TFS 37427 PEL1 Voyage Status Enhancements
//
vars

begin
	if self.myRoot.allVoyageProcesses[self.code] &lt;&gt; null then
		app.raiseCMException1(Duplicate_code_must_unique, self.code, null, null);
	endif;
	self.validateMe;
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="0d71ff68-9f74-4442-8f7e-1f83ea677f18">
        <source>validateForUpdate(_passport : CM_Passport);
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/03/2018	jlgdap1		Initial creation TFS 37427 PEL1 Voyage Status Enhancements
//
vars
	voyageProcess, realProcess : SelfType;

begin
	if self.isTransient then
		realProcess := self.pxyGetRealObject().CM_VoyageProcess;
	else
		realProcess := self;
	endif;
	voyageProcess := app.myRoot.allVoyageProcesses[self.code];
	if voyageProcess &lt;&gt; null and voyageProcess &lt;&gt; realProcess then
		app.raiseCMException1(Duplicate_code_must_unique, self.code, null, null);
	endif;
	self.validateMe();
epilog

end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="validateMe" id="6dd4f03e-8260-4fe6-8069-db98a834696d">
        <source>validateMe();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 07/03/2018	jlgdap1		Initial creation TFS 37427 PEL1 Voyage Status Enhancements
//
vars

	fileType : CM_EDIFileTypeUser;
	entTableDef : EntTableDef;
	entTableRow : EntTableRow;
	niceName : String;

begin

	if self.code = null then
		app.raiseCMException(Input_required_field_code, "code", null);
	endif;
	if self.description = null then
		app.raiseCMException(Input_required_field_Desc, "description", null);
	endif;
	
	entTableDef := app.myRoot.myEntTableDataRoot.getEntTableDef(ETDef_VoyageProcessThumb);
	if entTableDef &lt;&gt; null then
		//10 May 2018	NDL	TFS 38517
		entTableRow := entTableDef.getEntTableRow( ETRow_ReportInvoiceEstimate );
		if entTableRow &lt;&gt; null then
			niceName := entTableRow.getHeading(null, null, app.myCurrentLocale);
		else
			niceName := "Report Invoice Estimate";
		endif;
		app.validateReportName( self.reportInvoiceEstimate, niceName, "CM_InvoiceView" );
		
		entTableRow := entTableDef.getEntTableRow( ETRow_ReportInvoicePreinvoice );
		if entTableRow &lt;&gt; null then
			niceName := entTableRow.getHeading(null, null, app.myCurrentLocale);
		else
			niceName := "Report Invoice Pre Invoice";
		endif;
		app.validateReportName( self.reportInvoicePreinvoice, niceName, "CM_InvoiceView" );
		
		entTableRow := entTableDef.getEntTableRow( ETRow_ReportInvoiceTaxinvoice );
		if entTableRow &lt;&gt; null then
			niceName := entTableRow.getHeading(null, null, app.myCurrentLocale);
		else
			niceName := "Report Invoice Tax Invoice";
		endif;
		app.validateReportName( self.reportInvoiceTaxinvoice, niceName, "CM_InvoiceView" );
		
		//11 Jun 2018	NDL	TFS 38795
		entTableRow := entTableDef.getEntTableRow( ETRow_WorkOrderReceivalReport );
		if entTableRow &lt;&gt; null then
			niceName := entTableRow.getHeading(null, null, app.myCurrentLocale);
		else
			niceName := "Work Order Receive Report";
		endif;
		app.validateReportName( self.workOrderReceivalReport, niceName, "CM_TransactionView" );
		
		entTableRow := entTableDef.getEntTableRow( ETRow_WorkOrderReleaseReport );
		if entTableRow &lt;&gt; null then
			niceName := entTableRow.getHeading(null, null, app.myCurrentLocale);
		else
			niceName := "Work Order Release Report";
		endif;
		app.validateReportName( self.workOrderReleaseReport, niceName, "CM_TransactionView" );
	endif;
	//18 May 2018	NDL	TFS 38517
	if self.ediPrenoteFormat.trimBlanks &lt;&gt; null then
		fileType := app.myRoot.allEDIFileTypeUsersByName[self.ediPrenoteFormat];
		if fileType = null then
			app.raiseCMWarning1(Not_curren_user_define_format, "'" &amp; self.ediPrenoteFormat &amp; "'", null, null, null);
		elseif fileType.dataType &lt;&gt; EDIDataType_Prenote then
			app.raiseCMException(Format_selecte_not_prenote, null, null);
		endif;
	endif;
	
epilog

end;</source>
    </JadeMethod>
</Class>
