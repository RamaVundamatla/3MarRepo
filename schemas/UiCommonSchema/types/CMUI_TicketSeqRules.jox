<Class name="CMUI_TicketSeqRules" id="b89e0193-b04b-43fa-9dbd-5f69c75db7af">
    <superclass name="CMUI_Transient"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmui"/>
    <ImplicitInverseRef name="allTicketSequences" id="43115f40-ea68-4c52-9085-77a54f46310f">
        <memberTypeInverse/>
        <type name="CM_TicketSequenceSet"/>
    </ImplicitInverseRef>
    <PrimAttribute name="jasScaled" id="765c5bc9-06fe-4c75-8664-674580d05af9">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="numberOfTickets" id="ca77614c-d62e-4d43-a299-7c146849bbf2">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="percentageScaled" id="09b3c234-89cd-4714-9b82-033e2877cba6">
        <embedded/>
        <type name="Integer"/>
    </PrimAttribute>
    <PrimAttribute name="ticketedAll" id="3a96c40b-7b1f-46fd-ad20-08c7b5d7d201">
        <embedded/>
        <type name="Boolean"/>
    </PrimAttribute>
    <PrimAttribute name="totalToScale" id="e0e36801-a3f5-401c-b878-2eef2f777c50">
        <embedded/>
        <virtual/>
        <type name="Integer"/>
    </PrimAttribute>
    <JadeMethod name="calculateExisting" id="92444575-f1c6-415e-9fc9-174b8f8de1ed">
        <source>calculateExisting() : Integer;
//--------------------------------------------------------------
//Created: 14 May 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	allReadyUsed : Integer;
	ts : CM_TicketSequence;
begin
	foreach ts in self.allTicketSequences do
		allReadyUsed := allReadyUsed + ts.quantity;
	endforeach;
	return allReadyUsed;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="calculateRemaining" id="ffc8d950-bab2-4b1c-badd-2cf176ba0bd2">
        <source>calculateRemaining() : Integer;
// -----------------------------------------------------------------------------
// Created:		08 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	allReadyUsed : Integer;
	ts : CM_TicketSequence;
begin
	foreach ts in self.allTicketSequences do
		allReadyUsed := allReadyUsed + ts.quantity;
	endforeach;
	return self.calculateRequired() - allReadyUsed;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="calculateRequired" id="efefc88f-b708-47e7-8f7a-89c1df8ce2bc">
        <source>calculateRequired() : Integer;
// -----------------------------------------------------------------------------
// Created:		08 April 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	required : Integer;
begin
	if self.ticketedAll then
		return self.numberOfTickets;
	endif;
	required := (self.numberOfTickets * ( self.percentageScaled / 100) ).Real.rounded(); 
	return required;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="totalToScale" id="6b9e5046-59d3-40ee-87d5-a329930d25f1">
        <methodInvocation>mapping</methodInvocation>
        <source>totalToScale(set: Boolean; _value: Integer io) mapping;
//--------------------------------------------------------------
//Created: 07 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	endif;
	if self.ticketedAll then
		_value := (self.calculateRequired() * (self.percentageScaled/100)).rounded;
	else
		_value := self.calculateRequired();
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
</Class>
