        <Parameter name="_newVehicleBookingTimeSlot" type="CM_VehicleBookingTimeSlot" usage="output"/>
        <Parameter name="_isCopy" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
