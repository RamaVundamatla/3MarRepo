        <source>selectUnselectAll(_all : Boolean)updating;
//--------------------------------------------------------------
//Created: June 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	row		: Integer;		
begin

	foreach row in 2 to self.tblLocations.rows do
		self.tblLocations.accessCell(row, 1).text := _all.Integer.String;
	endforeach;
	self.loadNNDtlsMatchSpec();
end;</source>
