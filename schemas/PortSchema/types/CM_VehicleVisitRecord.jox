    <JadeMethod name="getInLane" id="7b38da1b-38ee-4bf4-9f30-225f038cb025">
        <source>getInLane():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 November 2017	jlgma1	TFS #7610 PKT - REQUIRED FIELD FOR REPORTING

*/

vars
	laneId : String;
	vVVRD : CM_VehicleVisitRecordDetail ;
	extraInfo : CM_Object;
begin
	foreach vVVRD in self.allVehicleVisitRecordDetails do 
		if vVVRD.recordType= VisitRecord_Arrive_PGate_In then
			break;
		else
			vVVRD := null;
		endif;
	endforeach;
	if vVVRD &lt;&gt; null then
		if vVVRD.getExtraInfoObject&lt;&gt; null then
			extraInfo := vVVRD.getExtraInfoObject;
			if extraInfo.isKindOf(CM_GateAreaLaneController) then
				laneId := extraInfo.CM_LaneController.getLaneNumber.String;
			endif;
		
		endif;
	endif;
	return laneId;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInwardScaleWeight" id="c7cc9579-011b-4dcf-b9a9-d39a072e88cf">
        <source>getInwardScaleWeight():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 December 2016	cnwns1	Initial creation

*/

vars
	vvrd : CM_VehicleVisitRecordDetail;
	arrivalWeight : Decimal[16,4];
	measure : CM_MeasurementType;
begin

	vvrd := self.getBulkGateIn(null);
	if vvrd &lt;&gt; null then
		arrivalWeight := vvrd.getExtraInfo_BulkGateInOrOut;
		measure := app.getDefaultMeasurementForType(Type_Weight);
		return	app.convertMeasurementForDisplay(measure.shortName, arrivalWeight) &amp; Space &amp; measure.shortName;
	endif;
	return null;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getInwardScaleWeights" id="9384e4a9-a58e-475c-b7bc-ca017e77f9e8">
        <source>getInwardScaleWeights():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 February 2017	cnwndl1	Initial creation	TFS 3313

*/

vars

	vvrd : CM_VehicleVisitRecordDetail;
	localDict : CM_VehicleVisitDetailByTime;
	arrivalWeight : Decimal[16,4];
	measure : CM_MeasurementType;
	vvrdString : String;
	
begin

	create localDict transient;
	foreach vvrd in self.allVehicleVisitRecordDetails do
		if vvrd.recordType = VisitRecord_Bulk_In then
			localDict.add( vvrd );
		endif;
	endforeach;
	
	if not localDict.isEmpty then
		measure := app.getDefaultMeasurementForType(Type_Weight);
		
		foreach vvrd in localDict do
			if vvrdString &lt;&gt; null then
				vvrdString := vvrdString &amp; " ==&gt; ";
			endif;
			arrivalWeight := vvrd.getExtraInfo_BulkGateInOrOut;
			vvrdString := vvrdString &amp; app.convertMeasurementForDisplay(measure.shortName, arrivalWeight) &amp; Space &amp; measure.shortName;
			vvrdString := vvrdString &amp; " [" &amp; vvrd.userCode &amp; "] " &amp; vvrd.computerName;
		endforeach;
	endif;
	
	return vvrdString;
	
epilog

	delete localDict;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
