    <JadeMethod name="getNumTIsQueuedOut" id="dbdf68b1-ac82-4bc0-aaac-efee4d95f1bd">
        <source>getNumTIsQueuedOut(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2009	cnwer1	Initial creation

*/

vars

	count : Integer;
	ti : CM_TrackedItem;
begin
	count:=0;
	foreach ti in self.allTrackedItems do
		//use first rather than size because it is an array
		if ti.allQueuedFutureMoves.first &lt;&gt; null then 
			count:=count+1;
		endif;
	endforeach;
	
	return count;

epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getNumUnitsFlexiOffset" id="7d7f38f2-369e-4394-a6cc-aec57efb3b2a">
        <source>getNumUnitsFlexiOffset(_ti : CM_TrackedItem) : Integer;
// ---------------------------------------------------------------------------
// Created:     18 December 2008 by cnwab1
//
//					PAR 18682 CCMS SFW 1055
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	tiLen, primaryPortion, lcLen, numUnits, offset : Integer;
begin
//	if _ti.isForty then
//		return 2;
//	endif;


	tiLen := _ti.getActualLength().Integer;
	if self.myTerminalArea = null then
		lcLen := 10;
	else
		lcLen := self.myTerminalArea.locationLength.Integer;
	endif;
	
	if _ti.isForty and not self.isWagon() then // PAR 22750
		return (tiLen / lcLen).Integer;
	endif;

	offset := self.offsetFlexi;
// PAR 22750	if offset &lt; 20 then
	if offset &lt; lcLen then
		// PAR 19031 check for a strict grid
		if offset = 0 then
			offset := self.getStrictOffsetForTI(_ti);
		endif;
		// PAR 19031 to here
		primaryPortion := (lcLen - offset);
	else
// PAR 22750			primaryPortion := 20;
		primaryPortion := lcLen;
	endif;
	if lcLen = 10 then // PAR 23533
		numUnits := ((tiLen - primaryPortion)/ lcLen).Integer; // PAR 23533
	else
		numUnits := ((tiLen - primaryPortion)/ lcLen).roundedUp();
	endif;
//app.writeStatement( class.name &amp; '::' &amp; method.name &amp; ' 1.' &amp; tiLen.String &amp; " " &amp; primaryPortion.String &amp; " " &amp; lcLen.String &amp; " = " &amp; numUnits.String);	

	return numUnits;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
