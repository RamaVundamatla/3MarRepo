    <JadeMethod name="assignValueSpecial" id="190a2012-f106-4739-997d-7faa4ffd26af">
        <updating/>
        <source>assignValueSpecial(_propName: String; _processedValue: String; _xlationOperator: CM_Operator): Boolean updating;
/*
Date		Who		Reason
01 Aug 2012	cnwcs5	Initial creation - par 29124
18/09/2012	cnwcs5	par 30316 - changed parameter usage for _processedValue
10 May 2013	cnwcs5	par 31626 - make method public so can be used for hook code*/
vars

begin
	if _propName = ETRow_Remarks then
		self.description	:= _processedValue;
		
		return true;
	endif;
	
	return inheritMethod(_propName, _processedValue, _xlationOperator);

epilog

end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_processedValue" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserSet" id="23c828d0-bdd3-4f4f-8df4-f5bbd98bdd50">
        <source>canUserSet(_propName: String): Boolean;

vars

begin
	return inheritMethod(_propName);
end;
</source>
        <Parameter name="_propName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="create" id="f0a22220-6f49-453b-bc86-bb3bcbca1c3a">
        <updating/>
        <source>create() updating;

vars

begin
	self.messageMode := CM_EDITrackedItem.EDI_ACTION_ADD;

end;
</source>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="046b935c-5727-4813-b2b5-b8c7b6c23f62">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*
Date		Who		Reason
02 August 2012	cnwcs5	Initial creation - par 29124
23 April 2014	cnwdap1	PAR #33005 CCMS SFW 1381 Imperial measurements for EDI user defined layouts
*/
vars
	rowName, type : String;								// PAR #33005

begin
	if _attrName = ETRow_Remarks then
		return self.getValueSpecial (_attrName, null);
		
	elseif _attrName.isMeasurementType then									// PAR #33005
		_attrName.getRowNameMeasureType(rowName, type);						// PAR #33005
		return self.getMeasurementStringForAttrib(rowName, type, _short);	// PAR #33005
		
	endif;
	
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getMyTIDisplayDefName" id="20967c70-3d36-4462-b4b5-f9aaf1a42edf">
        <source>getMyTIDisplayDefName(): String;

vars

begin
	return ETDef_EDITILayout;
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getValueSpecial" id="7abc863c-478d-4e3d-917c-388bb0599ca2">
        <source>getValueSpecial(_propName: String; _xlationOperator: CM_Operator): String;
/*
Date		Who		Reason
02 Aug 2012	cnwcs5	Initial creation - par 29124
*/
vars

begin
	if _propName = ETRow_Remarks then
		return self.description;
	endif;
	
	return inheritMethod(_propName, _xlationOperator);

epilog

end;</source>
        <Parameter name="_propName" type="String"/>
        <Parameter name="_xlationOperator" type="CM_Operator"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="c6ad8f7e-524b-4fcb-b866-d82bfbad5ca5">
        <source>pxyCreateUpdateProxy(): SelfType;

// cmwrs1 28 July 2011 CCMS 1009
//Date			Who		Reason

vars
	pxy	: SelfType;
	completedOK		: Boolean;
begin
	pxy := inheritMethod();

	completedOK := true;
	return pxy;
epilog
	if not completedOK then
		delete pxy;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="e14e9d3a-d617-406c-b581-f18509263ff6">
        <updating/>
        <source>setForUpdate(_proxy: SelfType) updating;
//
// cmwrs1 28 July 2011 CCMS 1009
//
// 21 Feb 2012	cnwrs1	Par 29157 error is rotation location is invalid
// 23 Jul 2012	cnwcs5	CCMS MES 2168 / par 29124 - RORO Deck Stowage Advice extensions
vars

begin
	inheritMethod(_proxy);
	
	self.area 				:= _proxy.area;
	self.description		:= _proxy.description;			// remarks - par 29124 July 2012
	self.isRotationMaster 	:= _proxy.isRotationMaster;
	self.layoutId 			:= _proxy.layoutId;
	self.layoutType 		:= _proxy.layoutType;
	self.longPos 			:= _proxy.longPos;
	self.rotation 			:= _proxy.rotation;
	self.transPos 			:= _proxy.transPos;
	self.vertPos 			:= _proxy.vertPos;
	self.weight 			:= _proxy.weight;
end;
</source>
        <Parameter name="_proxy" type="SelfType"/>
    </JadeMethod>
</Class>
