    <JadeMethod name="addLineToTable" id="7fcd5649-4a91-4b0e-bd68-4e673e804116">
        <source>addLineToTable( _finObject : CM_FinancialObject; _drTerm : CM_DebtorTerminal; _tax: Decimal io ):Decimal protected;

/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28/05/2018 	JLGNS1	Bug 38730: Cash Collection - Extra charge lines

*/

vars

	dateStr 	: String;
	typeString 	: String;
	amountString : String;
	termString 	: String;
	drString 	: String;
	tableLine 	: String;
	taxString	: String;
	index 		: Integer;
	amount 		: Decimal [16,4];
	cashPayment	: CM_CashPayment;
	invoiceLine : CM_InvoiceLine;
	
begin
	
	if _finObject.isKindOf(CM_CashPayment) then
		cashPayment := _finObject.CM_CashPayment;
		dateStr :=cashPayment.systemToLocalTime(cashPayment.dateTime).asStringJMT;		
		amount := -cashPayment.cashValue;
		if cashPayment.myCashPaymentForTax &lt;&gt; null then
			_tax := -cashPayment.myCashPaymentForTax.cashValue;
		endif;	
		typeString := cashPayment.getTypeString(_drTerm).replaceString(Tab, " ");	
				
	elseif _finObject.isKindOf(CM_InvoiceLine)  then
		invoiceLine := _finObject.CM_InvoiceLine;
		dateStr := invoiceLine.systemToLocalTime(invoiceLine.chargeTime).asStringJMT;
		typeString := invoiceLine.getConsolidatingNarration();
		amount := invoiceLine.getUnpaidAmount();
	else
		return 0;
	endif;
	
	drString 	 := _drTerm.myDebtor.name;
	termString 	 := _drTerm.myTerminal.name;
	amountString := amount.asCurrencyJMT;
	if self.showServiceTax then
		taxString := _tax.asCurrencyJMT();
	endif;
	
	tableLine := dateStr &amp; Tab
				&amp; drString &amp; Tab
				&amp; termString &amp; Tab
				&amp; typeString &amp; Tab
				&amp; amountString &amp; Tab
				&amp; taxString;

	index := self.tblCash.addItem( tableLine );
	self.tblCash.accessRow(index).itemObject := _finObject;
		
	self.tblCash.accessCell(index,2).itemObject := _drTerm.myDebtor;
	self.tblCash.accessCell(index,3).itemObject := _drTerm.myTerminal;

	if _finObject.isKindOf(CM_CashPayment) then	
		self.tblCash.accessRow(index).backColor := LightGreen;
	endif;
	
	return amount;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_finObject" type="CM_FinancialObject"/>
        <Parameter name="_drTerm" type="CM_DebtorTerminal"/>
        <Parameter name="_tax" type="Decimal" usage="io"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
