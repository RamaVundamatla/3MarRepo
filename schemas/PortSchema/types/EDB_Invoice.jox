    <JadeMethod name="edb_Narration" id="35f8ddef-bb21-46e0-8dd3-8d6ffedb0f8a">
        <methodInvocation>mapping</methodInvocation>
        <updating/>
        <source>edb_Narration(set:Boolean; value:String io) mapping, updating, subschemaHidden;
begin
	if set then
		_setVirtualString( 'narration',27, value );
	else
		value := _getVirtualString( 'narration',27);
	endif;
end;</source>
        <subAccess>hidden</subAccess>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="value" type="String" usage="io"/>
    </JadeMethod>
