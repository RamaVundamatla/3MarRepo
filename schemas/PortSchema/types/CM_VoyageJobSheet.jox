    <JadeMethod name="setKPIVoyageBayCraneMovesTRAN" id="6e36627a-3dbe-40cf-8a6a-5b10f8312133">
        <source>setKPIVoyageBayCraneMovesTRAN(_tran : CM_TITransaction);
// ---------------------------------------------------------------------------
// Created:		August 2010 By Andrew Bishop cnwab1
//
// Purpose:		2010 KPIS!!!! Get the KPI Bay stats from the Ship Receive and Release transactions
// 29/05/2015	cnwma1  PAR #35561 Archive Voyages
// ---------------------------------------------------------------------------
vars
	kpi : CM_KPIVoyageBayCrane;
	vJob : CM_VoyageJob;
	aJob: CM_Job;
	bayOne, bayTwo: CM_Bay;
	vBay1, vBay2 : CM_BayVoyage;
	dBay1, dBay2 : CM_BayDefn;
	vess : CM_Vessel;
	shipRec : CM_ReceiveShip;
	shipRel : CM_ReleaseShip;
	kpiUpdated : Boolean;
begin
	vJob := _tran.getJob().CM_VoyageJob;
	
	if vJob = null then
		return;
	endif;
	if self.getMyCrane = null and self.getMyWorkPoint() = null then   // 29/05/2015 cnwma1 PAR #35561
		return;
	endif;
	
	vess := self.myVoyage.getMyVessel();
	
	vJob.getBays(bayOne, bayTwo);
	
	vBay1 := bayOne.CM_BayVoyage;
	vBay2 := bayTwo.CM_BayVoyage;
	if vBay1 &lt;&gt; null then
		kpi := vBay1.getKPIVoyageBayCraneForJS(self);
		if kpi = null then
			create kpi;
			dBay1 := vBay1.getBayDefn(vess);
			kpi.setKPI(self.getMyCrane(),	self, self.myVoyage,	self.myVoyage.myTerminal,vBay1,dBay1);
		endif;
		kpi.setFromTransaction(_tran);
		kpiUpdated := true;
		if kpi.allTrackedItems.isEmpty then
			kpiUpdated := false;
			delete kpi;
		endif;
	endif;
	if not kpiUpdated and  vBay2 &lt;&gt; null then
		kpi := vBay2.getKPIVoyageBayCraneForJS(self);
		if kpi = null then
			create kpi;
			dBay2 := vBay2.getBayDefn(vess);
			kpi.setKPI(self.getMyCrane(),	self, self.myVoyage,	self.myVoyage.myTerminal,vBay2,dBay2);
		endif;
		kpi.setFromTransaction(_tran);
		if kpi.allTrackedItems.isEmpty then
			delete kpi;
		endif;
	endif;

end;</source>
        <Parameter name="_tran" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="setKPIVoyageJSShiftMovesTRAN" id="3bd500af-72fe-4933-b031-5a044d597128">
        <source>setKPIVoyageJSShiftMovesTRAN(_tran :CM_TITransaction);
/*
Purpose:	KPI shift stats for single transaction		
Parameters:			
Return Value:		

Date		Who		Reason
10 August 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	realShift, shift,
	pxyShift 		: CM_Shift;
	voyage 			: CM_Voyage;
	shiftKpi 		: CM_KPIVoyageJobSheetShift;
	kpi 			: CM_KPI;
	terminal		: CM_Terminal;
	ts			 	: TimeStamp;
	iter			: Iterator;
	realShifts		: CM_ShiftStartDateCodeDict;
begin
	voyage 		:= self.myVoyage;
	terminal 	:= voyage.myTerminal;
	ts		 	:= _tran.dateTime;

	// Start by getting the persistent shifts for the date range
	realShift := terminal.getShiftForTimeStampReal(ts);
	
	if realShift &lt;&gt; null then
		// look for kpi for the receiver/shift
		foreach kpi in realShift.allVoyageKPIJobSheetShifts discreteLock do
			if kpi.CM_KPIVoyageJobSheetShift.myJobSheet = self then
				shiftKpi := kpi.CM_KPIVoyageJobSheetShift;
				break;
			endif;
		endforeach;
		
		shift := realShift;
	else
		// get the shift that this transaction falls into
		pxyShift := terminal.getShiftForTimeStamp(ts);
		
		if pxyShift = null then
			// should never happen
			return;
		endif;
		shift := pxyShift;
	endif;

	if shiftKpi = null then
		if self.isVoyageROROJobSheet then
			create shiftKpi as CM_KPIVoyageWorkPointShift;
		elseif self.isVoyageLOLOJobSheet then
			create shiftKpi as CM_KPIVoyageCraneShift;
		else
			app.raiseUnexpectedProgramError (self.class.name, method.name, 'Job sheet is not RORO/LOLO');
		endif;
		// use transaction date-time as start and end of shift
		shiftKpi.setKPIForCreate(ts, ts, self, shift, voyage, terminal);
	endif;
	
	shiftKpi.setFromTransaction (_tran);
epilog
	delete iter;
	delete pxyShift;
	delete realShifts;
end;</source>
        <Parameter name="_tran" type="CM_TITransaction"/>
    </JadeMethod>
    <JadeMethod name="setKPIVoyageJobSheetShift" id="4708882f-e7aa-466b-bdf0-a086312111c5">
        <source>setKPIVoyageJobSheetShift(_shifts : CM_ShiftStartDateCodeDict);
// ---------------------------------------------------------------------------
// Created:     May 2010 ANDREW BISHOP
//
// Changed On   	Changed By  	Reason
//
// Based on CM_Voyage::getKPIVoyageShiftMoves
// ----------   	----------  	--------------------------------------------------
// 04/08/2011		cnwcs5			CCMS MES 1033 - RORO KPI (RENAMED METHOD)
//11 April 2017		cnwma1	TFS #4027:MSL - Voyage Side Profile - delay not showed
// ---------------------------------------------------------------------------

vars
	kpi 					: CM_KPIVoyageJobSheetShift;
	tmpShift 				: CM_Shift;
	aTran 					: CM_TITransaction;
	ti						: CM_TrackedItem;
	tsStrFrom, tsStrTo, tsWorkFinished	: TimeStamp;
	trans 					: CM_TITransactionByDateDict;
	teus					: Decimal [8,2];
	tis						: Integer;
	firstShift, lastShift ,foundShift	: Boolean;
	tisCol 					: CM_TISet; 
	kpiTrans 				: CM_TITransactionSet;
	firstTxn				: Boolean;						// 26/10/2010 cnwmh5 #26067
	tmpTS					: TimeStamp;					// 26/10/2010 cnwmh5 #26067
	
begin
	if (self.allShipReceivals.isEmpty and self.allShipReleases.isEmpty) then
		return;
	endif;
	
	create trans transient;
	create tisCol transient;
	create kpiTrans transient;
		
	// ### for this jobsheet get all the loads and discharges from the transactions.
	trans.clear;
	self.allShipReceivals.copy(trans);
	self.allShipReleases.copy(trans);
	
	firstShift 	:= true;
	lastShift 	:= false;
	tsStrFrom 	:= null;
	
	// ### go through all the shifts over all the days and split up the transactions for this job sheet.
	foreach tmpShift in _shifts discreteLock do
		tsStrFrom 		:= tmpShift.startDateTime;
		tsStrTo 		:= tmpShift.endDateTime;
		tsWorkFinished	:= self.getWorkFinishedDT;	// par 17592

		// ### if the shift ended before the work started on the receiver job sheet there is
		// ### no point looking for data for this shift
		if self.getStartDateFromReceiveRelease() &gt; tsStrTo then	// par 17592  // cnwrd1 par 22533 6.5.2010		
			continue;						// par 17592
		endif;								// par 17592

		// ### if the shift started after work finished on the receiver job sheet there is
		// ### no point looking for data for this shift
		if tsWorkFinished &lt; tsStrFrom then	// par 17592
			continue;						// par 17592			
		endif;								// par 17592
		
		tisCol.clear;
		kpiTrans.clear;
						
		firstTxn 	:= true;									// 26/10/2010 cnwmh5 #26067
		tmpTS 		:= null;									// 26/10/2010 cnwmh5 #26067
		
		// ### GETS MOVES PER SHIFT
		foreach aTran in trans discreteLock where aTran.dateTime &lt;= tsStrTo do
			tis 		:= tis + 1;
			foundShift 	:= true; //cnwrd1 par 22533 6.5.2010
			ti			:= aTran.myTrackedItem;
			
			tisCol.addNoDuplicates(ti ,false);
			
			// only accumulate TEU for containers
			if ti.isContainer then 
				teus := teus + ti.getNumTEU;	// par 17592
			endif;
			
			kpiTrans.add(aTran);
			trans.remove(aTran);
			
			// ### set the start time (for the purposes of calculating gross hours) to the start time 
			// ### of the first transaction for the shift
			if firstTxn then
				tsStrFrom := aTran.dateTime;
				firstTxn := false;
			endif;
				
			tmpTS := aTran.dateTime;
		endforeach;
		
		if tmpTS &lt;&gt; null and tmpTS &lt;= tsStrTo then							// 26/10/2010 cnwmh5 #26067
			tsStrTo := tmpTS;
		endif;
		
		// ### tmpShift is a shift the overlas the start of the first job and the fonish of the last job for the receiver
		// ### tsStrFrom is either the start of the first job for the first shift of the start of tmpShift
		// ### tsStrTo is the finish time for the shift or for the last shift the finish time of the last job for that shift
		
		// need to check if have just had a delay here
		if foundShift then  //cnwrd1 par 22533 6.5.2010   -- only want to start recording kpi when work has started (found ashift we worked in)
			if self.isVoyageLOLOJobSheet then
				create kpi as CM_KPIVoyageCraneShift;
			elseif self.isVoyageROROJobSheet or self.isVoyageHoldJobSheet then   //11/04/2017 cnwma1 TFS #4017
				create kpi as CM_KPIVoyageWorkPointShift;
			else
				app.raiseUnexpectedProgramError (self.class.name, method.name, 'Invalid voyage job sheet - must be crane or work point');
			endif;
				
			kpi.setKPI(	teus, tis, 			// Integers/Decimals
							tsStrFrom, tsStrTo, // TimeStamps
							self,
							tmpShift, 			// shift
							tisCol,
							kpiTrans);
						
		endif; 
		
		tis 	:= 0;
		teus 	:= 0;
	endforeach;
epilog
	delete trans;
	delete tisCol;
	delete kpiTrans;
end;</source>
        <Parameter name="_shifts" type="CM_ShiftStartDateCodeDict"/>
    </JadeMethod>
    <JadeMethod name="setOOWCraneDetails" id="553e738c-b0eb-4165-9b97-1135801b90a7">
        <updating/>
        <source>setOOWCraneDetails(_start : TimeStamp; _rev : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:		02 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	self.workStarted := _start;
	self.oowReversed := _rev;
end;</source>
        <Parameter name="_start" type="TimeStamp"/>
        <Parameter name="_rev" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sortWLEsForOverstowCheck" id="01a26d81-bc0f-47e0-a3d7-b5845336cc61">
        <source>sortWLEsForOverstowCheck();
// ### This is only used by a CMIF controller that is analysing the overstow state of the workload for LOADING
// ### They are sorted by Job order within the  jobsheet and then the WLE Sequence 
vars
	jsOrder, jobOrder, wleOrder : Integer;
	wle : CM_WorkListEntry;
	reqs : CM_RequestArray;
	request : CM_Request;
	aWLE : CM_WorkListEntry;
	job : CM_Job;
begin
	if not self.isTransient() then
		return;
	endif;

	self.allWLEByOrder.clear;
	create reqs transient;
	
	jsOrder := self.myVoyage.allJobSheetsInOrder.indexOf(self);
	

	foreach job in self.allJobsByOrder where not job.CM_VoyageJob.isDischarge and not job.isJobComplete do
		
		jobOrder := job.jobOrder;
		reqs.clear;
		job.CM_VoyageJob.doSortReqsInToSeqOrder(reqs);
		foreach request in reqs do
			wleOrder := reqs.indexOf(request);
			foreach wle in request.allWorkListEntries do
				self.allWLEByOrder.putAtKey(jsOrder,jobOrder,wleOrder,wle.CM_VoyageWLE);
			endforeach;
		endforeach;
	endforeach;
epilog
	delete reqs;
end;
</source>
    </JadeMethod>
    <JadeMethod name="validateForOOWAuto" id="51e24cad-fd88-40e3-9c0d-d12b1b53af52">
        <source>validateForOOWAuto();
// ---------------------------------------------------------------------------
// Created:		11 May 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	mess : String;
	errorCodes : IntegerArray;
begin
	if self.myVoyage.myCellularVoyageStructure = null then
		return;
	endif;
	
	if  self.allOOWCreations.isEmpty then
		app.raiseCMException1(Crane_bays_alloca_cannot_produ,self.crane, null, null);
	
	endif;

	create errorCodes transient;	//13 Sep 2012	NDL	Par 30366
	if self.myVoyage.myCellularVoyageStructure.hasVoyageStartedPlanning(mess, errorCodes) then
		//app.raiseCMException1(Full_Replacement_Message, mess, null, null); //- cnwmd1, Par 20524
		//app.raiseCMException1(Voyage_Job_Sheet, mess, null, null);
		app.raiseMultiReasonExcOrWarning( errorCodes, mess, false, null,  null );	//13 Sep 2012	NDL	Par 30366
	else
		if not self.allJobsByOrder.isEmpty then
			app.raiseCMWarning1(Crane_jobs_these_will_erase_wa,self.crane, null, null, self.myVoyage);
		endif;
	endif;
epilog
	delete errorCodes;	//13 Sep 2012	NDL	Par 30366
end;</source>
    </JadeMethod>
    <JadeMethod name="validateOOWCPhysicalOrder" id="02fea92d-3f8c-48e6-80d3-d4af7eb65f2d">
        <source>validateOOWCPhysicalOrder();
// ---------------------------------------------------------------------------
// Created:		September 2007 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	firstOOWC, oowc : CM_OOWCreation;
begin	

	if self.allOOWCreations.isEmpty then
		return;
	endif;
	
	foreach oowc in self.allOOWCreations do
		if firstOOWC &lt;&gt; null then
			if not  oowc.CM_OOWCreationDetail.validateOOWCOrder(firstOOWC.CM_OOWCreationDetail) then
				app.raiseCMWarning2(Cannot_after, oowc.getDescription(),firstOOWC.getDescription(),null,null, self);
				
			endif;
		endif;
		firstOOWC := oowc;
	endforeach;
epilog
end;</source>
    </JadeMethod>
</Class>
