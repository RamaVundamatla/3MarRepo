    <JadeMethod name="userNotification" id="ff483444-5673-42f3-b6a8-120c86c3b816">
        <updating/>
        <source>userNotification(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// -------------------------------------------
// Created 24 January 2006 by cnwdvb1
// Updated 15 June 2010 by cnwjo3 - par #22376
// -------------------------------------------
constants
	Event_Factor = 1000;
vars

	sendNote	: Boolean;
	info		: DTO_StateInfo;
	infoStr		: String;
	terminal	: CM_Terminal;
	theEvent	: Integer;
	entryCheck	: Object;
	entry		: CM_RTQueueEntry;
	invalid : Boolean;
	mediator : CM_RadioTelemetryMediator;
	validObject : Object;
begin
	mediator := self.myMediator;
	
	if mediator &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, validObject, invalid);
		validObject := mediator;
		validObject.creationTime();
	endif;
	
	if invalid then
		return;
	endif;
	
	// We need a mediator and don't care if session is logged off.
	if mediator = null or mediator.state = self.LoggedOff then
		return;
	endif;
	
	// What is the generic event type.
	theEvent := eventType;
	
	if theObject.isKindOf(CM_RadioTelemetryQueue) then
		if mediator.machine &lt;&gt; null then
			terminal := app.getMyTerminalDO_NOT_USE();
			theEvent := terminal.getEventFromTerminalEvent(eventType);
			// We have been told about a queue entry that has been added to this terminal.
			if theEvent = Event_New_Queue_Entry then
				entry := userInfo.CM_RTQueueEntry;
				// Check whether the current machine is interested.
				if self.notifyMachineOfNewTask(theObject.CM_RadioTelemetryQueue, mediator.machine, entry) then
					// Add this entry to the notified entry collection.
					if not self.allNotifiedQueueEntries.includes(entry) then
						self.allNotifiedQueueEntries.add(entry);
						// We send note because it is easier than checking previous state.
						sendNote := true;
					endif;
				else
					// Does the entry exist in our notified list and are all the entries still valid... just incase. Sometimes
					// queue entries can be cleaned up 
					foreach entryCheck in self.allNotifiedQueueEntries do
						// Check the oid. Clean up any odd references.
						validObject := entryCheck;
						validObject.creationTime();  //cause exception if invalid object
						if invalid or entryCheck = entry then
							self.allNotifiedQueueEntries.remove(entryCheck);
							invalid := false;
						endif;
					endforeach;
				
					// Nothing left so turn display off.
					if self.allNotifiedQueueEntries.isEmpty() then
						sendNote := true;
						theEvent := Event_Delete_Queue_Entry;
					endif;
				endif;
			elseif theEvent = Event_Delete_Queue_Entry then
				entry := userInfo.CM_RTQueueEntry;
				// Does the entry exist in our notified list and are all the entries still valid... just incase. Sometimes
				// queue entries can be cleaned up 
				foreach entryCheck in self.allNotifiedQueueEntries do
					// Check the oid. Clean up any odd references.
						validObject := entryCheck;
						validObject.creationTime();  //cause exception if invalid object
					if invalid or entryCheck = entry then
						self.allNotifiedQueueEntries.remove(entryCheck);
					endif;
				endforeach;
				
				// Nothing left so turn display off.
				if self.allNotifiedQueueEntries.isEmpty() then
					sendNote := true;
				endif;
			endif;
		endif;
	elseif eventType = EVENT_MACHQUEUE_ALTERED and theObject.isKindOf(CM_Machine) then
		if mediator.machine &lt;&gt; null and theObject = mediator.machine then
			self.reviewQueueEntries();
			sendNote := true;
			infoStr := "Transfer to Queue: " &amp; theObject.CM_Machine.queueId.trimRight();
		endif;
	elseif eventType = EVENT_MACH_BROADCAST_MSG and theObject.isKindOf(CM_Machine) then
		if mediator.machine &lt;&gt; null and theObject = mediator.machine then
			sendNote := true;
			infoStr := userInfo.String;
		endif;
	endif;
	
	
	// Send the appropriate note.
	if sendNote then
		create info transient;
		info.guiState := theEvent + Event_Factor;
		info.errorString := infoStr;
		self.causeEvent(self.Event_Server_Note, true, info);
	endif;
	// Info gets deleted on client side of the package.

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</Class>
