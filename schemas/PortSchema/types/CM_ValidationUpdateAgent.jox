    <JadeMethod name="valGetTargetLocation" id="91719cf3-ee3a-4755-b752-b354ed3372e8">
        <source>valGetTargetLocation(_terminal : CM_Terminal input; _locationStr : String;  _passport : CM_Passport) : CM_LocationsController;
/*

Date		Who		Reason
17 May 2017	cnwer1	Initial creation TFS 995 moved from MobileServerSchema::CM_ValidationRTAgent::valGetTargetLocation

*/

vars
	location	: CM_LocationsController;
	foundHeight	: Integer;
begin
	if _locationStr = null then
		app.raiseCMException(Input_required_field_toLocn ,null, null);
		return null;
	endif;
	
	_terminal.findLocationFromString(_locationStr, false, location, foundHeight);
	
	if location = null then
		app.raiseCMException1(Err_LocationNotFound, _locationStr ,null, null);
		return null;
	endif;
		
	return location;
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal" usage="input"/>
        <Parameter name="_locationStr" type="String"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="CM_LocationsController"/>
    </JadeMethod>
    <JadeMethod name="valHandlingType" id="1a370a9e-cb24-4bf5-a332-8e5d47cb8bc0">
        <source>valHandlingType(_realHandlingType, _pxyHandlingType : CM_HandlingType);
// ---------------------------------------------------------------------------
// Created:     01 October 2002 by cnwth2
//
// Purpose:     
//
// ----------   ----------  --------------------------------------------------
vars

begin
	self.raiseExceptionIfNull(_pxyHandlingType, 'Handling Type Proxy');
	_pxyHandlingType.raiseExceptionIfNotTransient(method);

	if _realHandlingType.id = _pxyHandlingType.id then
		_pxyHandlingType.validateForUpdate;
	else
		_pxyHandlingType.validateForCreate;
	endif;

epilog
	// Always return the error code to the caller (which will be zero if no errors)
	

end;</source>
        <Parameter name="_realHandlingType" type="CM_HandlingType"/>
        <Parameter name="_pxyHandlingType" type="CM_HandlingType"/>
    </JadeMethod>
