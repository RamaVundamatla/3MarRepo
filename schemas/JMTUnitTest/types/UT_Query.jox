	while iter.next(obj) do
		msg := msg &amp; CrLf &amp; obj.String &amp; ":" &amp; obj.CM_TrackedItem.id;
	endwhile;
		
	assertTrueMsg(results.includes(ti), msg &amp; CrLf &amp; CrLf &amp; ti.String&amp;":"&amp;ti.CM_TrackedItem.id);
	assertTrueMsg(results.includes(ti1), msg &amp; CrLf &amp; CrLf &amp; ti.String&amp;":"&amp;ti.CM_TrackedItem.id);
