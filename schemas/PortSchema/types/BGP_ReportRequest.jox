// -------------------------------------------
vars

begin

	// No request limit.
	return 0;


end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTempDirectory" id="950b7e83-11fb-4159-a157-e210eb7841d0">
        <source>getTempDirectory() : String;
//----------------------------------------------------------------------
// Created by 	cnwsh3 - 28 July 2010
//
// Implemented version: JMT 7.8.2
// Date  		User  		Change
// 28/07/2010 	cnwsh3		PAR22336 - Need to log the fact we don't have a JMT temp dir set up on the Report Controller.
//							We want to avoid using the temp dir on the same logical drive as the Windows system drive for
//							managed service admin reasons.  
//							We create an alert if we unsuccessfully check for a valid directory. 
//							We log the fact we are using temp dir just in case.  We aren't responsible for how non managed services.
//							administrate temporary file processing.
//----------------------------------------------------------------------
vars
	tmpDir : String;
begin
	tmpDir := self.myProcessingController.BGP_ReportController.tempFileLocation;
	
	app.checkTempDirFolderPath(tmpDir, method.qualifiedName, BGP_ReportController.name &amp; '::' &amp; BGP_ReportController::tempFileLocation.name);

	return tmpDir;
epilog
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="init" id="ec057395-74d9-4bff-9a2b-48548ee28c20">
        <updating/>
        <source>init(_filter		: CMQF_FilterReports;
	 _reportDef		: CM_QryReport;
	 _profileName	: String;
	 _destination	: Integer;
	 _extraDetail	: CM_ExtraDetail;
	 _printerName	: String;
	 _outputType	: Integer) updating;
// ---------------------------------------------------------------------------
// Created:     18 October 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	// Setup all the appropriate stuff.
	if _extraDetail &lt;&gt; null then
		self.myExtraDetail := _extraDetail.cloneSelf(false);
		self.myExtraDetail.cloneReferences(_extraDetail);
	endif;
	
	self.myFilter := _filter.cloneSelf(false);
	self.myFilter.cloneReferences(_filter, false);

	self.myReportDef		:= _reportDef;
	self.outputDestination	:= _destination;
	self.profileName 		:= _profileName;
	self.printerName		:= _printerName;
	self.outputType			:= _outputType;
	// Request is ready to be picked up.
	self.initRequestEvent(true, false, null);
	
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports"/>
        <Parameter name="_reportDef" type="CM_QryReport"/>
        <Parameter name="_profileName" type="String"/>
        <Parameter name="_destination" type="Integer"/>
        <Parameter name="_extraDetail" type="CM_ExtraDetail"/>
        <Parameter name="_printerName" type="String"/>
        <Parameter name="_outputType" type="Integer"/>
    </JadeMethod>
