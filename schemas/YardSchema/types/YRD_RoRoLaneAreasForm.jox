    <JadeMethod name="getExtraInfoForObject" id="e32c9578-ce78-4e46-9fa5-86dbb68ad517">
        <updating/>
        <source>getExtraInfoForObject(_obj : Object; _dataContainer : CM_DataContainer) updating;
// ---------------------------------------------------------------------------
// Created:     28 January 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 07/11/2012	cnwcs5	par 30475 - remove location restrictions

vars
	block 	: CM_DataContainerBlock;
	aTA 	: CM_TerminalArea;
	aStr 	: String;
begin
	if _obj.isKindOf(CM_TrackedItem) then
		_obj.CM_TrackedItem.getExtraInfo(_dataContainer);
	elseif _obj.isKindOf(CM_GridRow) then
		_obj.CM_GridRow.getExtraInfo(_dataContainer);
	elseif _obj.isKindOf(CM_GridColumn) then
		_obj.CM_GridColumn.getExtraInfo(_dataContainer);
	elseif _obj.isKindOf(CM_LabourRestriction) then
		_obj.CM_LabourRestriction.getExtraInfo(_dataContainer);
	
	elseif _obj.isKindOf(CM_SubBlockStack) then
		_obj.CM_SubBlockStack.getExtraInfo(_dataContainer);
	elseif _obj.isKindOf(CM_YardController) then
		_obj.CM_YardController.getExtraInfo(_dataContainer);
	elseif _obj.isKindOf(CMIF_RoRoLaneLenExceeded) then
		_obj.getExtraInfo(_dataContainer);
	elseif _obj.isKindOf(CM_YardAllocation) then
		foreach aTA in _obj.CM_YardAllocation.allTerminalAreas do
			if aStr = null then
				aStr := aTA.id;
			else
				aStr := aStr &amp; ", " &amp;  aTA.id;
			endif;
		endforeach;
		block := _dataContainer.addNewBlock;
		block.addNewItem("Terminal Areas", DC_Label, 1, null);
		block.addNewItem(aStr, DC_Data, 1, null);


		_obj.CM_YardAllocation.getExtraInfo(_dataContainer);
	endif;

	if app.isSpecial then
		block := _dataContainer.addNewBlock;
		block.addNewItem("Yard Drawing Controller", DC_Label, 1, self.myCurrentDrawingController);
		block.addNewItem(self.myCurrentDrawingController.String, DC_Data, 1, self.myCurrentDrawingController);
	
	endif;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
