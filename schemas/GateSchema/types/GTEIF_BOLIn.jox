<Class name="GTEIF_BOLIn" id="4754182d-26cc-40e0-bde5-e465abb961d8">
    <superclass name="CMIF_BOLIn"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="gate"/>
    <JadeMethod name="setDataFromTable" id="b7634839-579d-4462-b146-f224219bcda2">
        <updating/>
        <source>setDataFromTable(pTblMain: CM_EntryTable input; pTblExtra: CM_EntryTable input; pIntFaceCommon: CMIF_InOutCommon; pAssistant: GTE_Assistant) updating;
// ---------------------------------------------------------------------------
// Created:     25 June 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	consignStr		: String;
	consign			: CM_ConsigneeConsignor;
begin

	self.setUserDetails(app.getMyUser);
	self.setMyInOutCommon(pIntFaceCommon);
	
	pTblMain.setObjectFromTable(self, null, false);
	pTblExtra.setObjectFromTable(self, null, false);
	
	self.operatorCode := pTblMain.getValueByName(ETRow_Supplier).String;
	self.myOperator := app.myRoot.allOperators[self.operatorCode];
	
	//consignStr := pTblMain.getValueByName(ETRow_ConsigneeCode).String;
	//consign := app.myRoot.allConsigneeConsignors[consignStr]
	
end;</source>
        <Parameter name="pTblMain" type="CM_EntryTable" usage="input"/>
        <Parameter name="pTblExtra" type="CM_EntryTable" usage="input"/>
        <Parameter name="pIntFaceCommon" type="CMIF_InOutCommon"/>
        <Parameter name="pAssistant" type="GTE_Assistant"/>
    </JadeMethod>
</Class>
