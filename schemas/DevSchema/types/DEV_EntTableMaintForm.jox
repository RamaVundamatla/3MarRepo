    <JadeMethod name="getMeasurementTypeNames" id="7a9f8e7d-16b2-4e29-b3a0-93d95fcaa5c2">
        <source>getMeasurementTypeNames() : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12/02/2013	cnwdap1	Initial creation PAR #31155 CCMS SFW 1321 Imperial Measurements
*/
vars

begin
	return "" &amp; Tab &amp; Type_Weight &amp; Tab &amp; 
			Type_Volume &amp; Tab &amp; 
			Type_Linear &amp; Tab &amp; 
			Type_Displacement &amp; Tab &amp;
			Type_Density &amp; Tab;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTerminologyTypeNames" id="30109da4-c127-4617-8649-ca3a6468e949">
        <source>getTerminologyTypeNames() : String;
// ---------------------------------------------------------------------------
// Created:     19 August 2004	cnwth2
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	termType 			: CM_TerminologyType;
	termTypeDict		: CM_TerminologyTypeByNameDict;
	str					: String;
begin
	termTypeDict := app.myRoot.allTerminologyTypes;
	foreach termType in termTypeDict do
		str := str &amp; termType.name &amp; Tab;
	endforeach;

	return str;
	
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
