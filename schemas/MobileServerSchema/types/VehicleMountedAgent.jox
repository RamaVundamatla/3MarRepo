    <JadeMethod name="useEntryFirstTaskForAccept" id="9044a97a-3c28-416e-a97f-f94e071d9688">
        <source>useEntryFirstTaskForAccept() : Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
02 July 2010	cnwer1	Initial creation

*/

vars

begin
	return true;
