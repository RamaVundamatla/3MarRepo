    <JadeMethod name="create" id="86b77e9a-34b4-4800-bf0c-c5ba8ac9a0b3">
        <updating/>
        <source>create() updating;
// -----------------------------------------------------------------------------
// Created:		24 December 2001 by cnwdad1
//
// Purpose:		Instantiates the receiver's format references.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	if self.isTransient() then
		create self.myCurrencyFormat transient;
		create self.myDateFormat transient;
		create self.myNumberFormat transient;
		create self.myTimeFormat transient;
	else
		create self.myCurrencyFormat;
		create self.myDateFormat;
		create self.myNumberFormat;
		create self.myTimeFormat;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="delete" id="1c759c1f-3bf1-4fcc-b1fd-583b42e283d5">
        <updating/>
        <source>delete() updating;
// -----------------------------------------------------------------------------
// Created:		24 December 2001 by cnwdad1
//
// Purpose:		Deletes the receiver's format references.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	delete self.myCurrencyFormat;
	delete self.myDateFormat;
	delete self.myNumberFormat;
	delete self.myTimeFormat;
end;</source>
    </JadeMethod>
    <JadeMethod name="getLocaleFullInfo" id="8e9199a3-8711-446d-9edd-560771c63159">
        <source>getLocaleFullInfo(pTheLocaleFullInfo:LocaleFullInfo io);
// -----------------------------------------------------------------------------
// Created:		24 December 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	theCurrencyFormat	: CurrencyFormat;
	theDateFormat		: DateFormat;
	theNumberFormat		: NumberFormat;
	theTimeFormat		: TimeFormat;
	
begin
	create theCurrencyFormat transient;
	create theDateFormat transient;
	create theNumberFormat transient;
	create theTimeFormat transient;
	
	self.myCurrencyFormat.getCurrencyFormat(theCurrencyFormat);
	self.myDateFormat.getDateFormat(theDateFormat);
	self.myNumberFormat.getNumberFormat(theNumberFormat);
	self.myTimeFormat.getTimeFormat(theTimeFormat);
	
	// Set the locale's properties.
	
	pTheLocaleFullInfo.jssUpdateMe(self.abbreviatedCountryName,
									self.abbreviatedLangName,
									self.countryCode,
									self.englishCountryName,
									self.englishLangName,
									self.languageId,
									self.localeId,
									self.localizedCountryName,
									self.localizedLangName,
									self.nativeCountryName,
									self.nativeLangName,
									theCurrencyFormat,
									theDateFormat,
									self.defaultCodePage,
									self.defaultCountryCode,
									self.defaultLanguageId,
									self.listSeparator,
									self.measurementSystem,
									self.nativeDigits,
									theNumberFormat,
									theTimeFormat);
epilog
	delete theCurrencyFormat;
	delete theDateFormat;
	delete theNumberFormat;
	delete theTimeFormat;
end;</source>
        <Parameter name="pTheLocaleFullInfo" type="LocaleFullInfo" usage="io"/>
    </JadeMethod>
    <JadeMethod name="updateMe" id="23fa80bc-f15f-447f-93da-ed61b58ecd2c">
        <updating/>
        <source>updateMe(pTheLocaleFullInfo:LocaleFullInfo) updating;
// -----------------------------------------------------------------------------
// Created:		24 December 2001 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	// Set the locale's properties.
	
	self.abbreviatedCountryName	:=	pTheLocaleFullInfo.abbreviatedCountryName;
	self.abbreviatedLangName	:=	pTheLocaleFullInfo.abbreviatedLangName;
	self.countryCode			:=	pTheLocaleFullInfo.countryCode;
	self.defaultCodePage		:=	pTheLocaleFullInfo.defaultCodePage;
	self.defaultCountryCode		:=	pTheLocaleFullInfo.defaultCountryCode;
	self.defaultLanguageId		:=	pTheLocaleFullInfo.defaultLanguageId;
	self.englishCountryName		:=	pTheLocaleFullInfo.englishCountryName;
	self.englishLangName		:=	pTheLocaleFullInfo.englishLangName;
	self.languageId				:=	pTheLocaleFullInfo.languageId;
	self.listSeparator			:=	pTheLocaleFullInfo.listSeparator;
	self.localeId				:=	pTheLocaleFullInfo.localeId;
	self.localizedCountryName	:=	pTheLocaleFullInfo.localizedCountryName;
	self.localizedLangName		:=	pTheLocaleFullInfo.localizedLangName;
	self.measurementSystem		:=	pTheLocaleFullInfo.measurementSystem;
	self.nativeCountryName		:=	pTheLocaleFullInfo.nativeCountryName;
	self.nativeDigits			:=	pTheLocaleFullInfo.nativeDigits;
	self.nativeLangName			:=	pTheLocaleFullInfo.nativeLangName;
	
	// Set the locale's format information.
	
	self.myCurrencyFormat.updateMe(pTheLocaleFullInfo.currencyInfo);
	self.myDateFormat.updateMe(pTheLocaleFullInfo.dateInfo);
	self.myNumberFormat.updateMe(pTheLocaleFullInfo.numericInfo);
	self.myTimeFormat.updateMe(pTheLocaleFullInfo.timeInfo);
end;</source>
        <Parameter name="pTheLocaleFullInfo" type="LocaleFullInfo"/>
    </JadeMethod>
</Class>
