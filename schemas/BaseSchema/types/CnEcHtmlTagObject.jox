    <JadeMethod name="buildTagBody" id="be1625fd-42e7-4e8a-9fce-b4e5c69dc121">
        <source>buildTagBody():String protected;
// --------------------------------------------------------------------------------
// Created:		02 December 2001 by cnwdad1
//
// Purpose:		Assemble the body of the tag, and return the result.
//
// Parameters:	None
//
// Returns:		The HTML stream.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	htmlString	: String;
	
begin
	if self.htmlName &lt;&gt; null then
		htmlString	:=	' NAME="' &amp; self.htmlName &amp; '"';
	endif;
	
	if self.htmlNonStandard &lt;&gt; null then
		htmlString	:=	htmlString &amp; ' ' &amp; self.htmlNonStandard;
	endif;
	
	return htmlString;
end;</source>
        <access>protected</access>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="clearAllTagValues" id="17bb4681-1321-416e-83a7-047a8167dfc6">
        <updating/>
        <source>clearAllTagValues() updating;
// -----------------------------------------------------------------------------
// Created:		30 November 2001 by cnwdad1
//
// Purpose:		Clears the values of all of the receiver's properties, references
//				and collections.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	propertyObj		: Property;
	allProperties	: PropertyColl;
	
begin
	allProperties	:=	self.class().allProperties();
	
	foreach propertyObj in allProperties do
		if (not propertyObj.isSystemObject()) then
		
			if propertyObj.cnEcIsCollection() then
				self.getPropertyValue(propertyObj.name).Collection.purge();
				
			elseif propertyObj.cnEcIsPrimitive() then
				self.setPropertyValue(propertyObj.name, null);
				
			endif;
			
		endif;
	endforeach;
epilog
	delete allProperties;
end;</source>
    </JadeMethod>
