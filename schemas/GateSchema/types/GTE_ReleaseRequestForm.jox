    <JadeMethod name="setTableDataFromOrganiser" id="2cb11fa3-1dc7-44e6-aa1d-6a112d8e4f37">
        <updating/>
        <source>setTableDataFromOrganiser(_theTable: CM_DataTable input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 February 2015	cnwndl1	Initial creation	Par 35650

*/

vars
	startRow,
	endRow,
	idx2,
	index : Integer;
	obj : Object;
begin
	
	
	
	//epr TFS 1826 15/4/16 the problem was when form is populated from the MT pooling enquiry the column organiser use to redo the search
	// now just reloads from the current table data
	self.zSetXMLStrForTblColumns(_theTable, false, self.xmlStrTblData);		// par 31087 March 2013
	_theTable.refreshRowObjects();
	
	self.zTblDataColorRows();
	
	/*self.numItemsShown	:= endRow -  self.tblData.fixedRows;
	if self.useNumRowsShown then
		self.showNumRowsShown();
	endif;*/
	index := self.getIndexForXmlStrTblDataArray();

	if index = BR_TYPE_ROAD then
		self.xmlRoad := self.xmlStrTblData;
	elseif index = BR_TYPE_RAIL then
		self.xmlRail := self.xmlStrTblData;
	elseif index = BR_TYPE_SHIP then
		self.xmlShip := self.xmlStrTblData;
	elseif index = BR_TYPE_PACKING then
		self.xmlPack := self.xmlStrTblData;
	elseif index = BR_TYPE_UNKNOWN then
		self.xmlUnknown := self.xmlStrTblData;
	elseif index = BR_TYPE_BOL then
		self.xmlAll := self.xmlStrTblData;
	endif;

epilog
	
end;</source>
        <Parameter name="_theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setTblDataXML" id="b691bc66-69c3-4073-8a62-aa297670072d">
        <updating/>
        <source>setTblDataXML(): String updating;
// ---------------------------------------------------------------------------
// Created:		May 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed on	By			Reason
// ----------	----------	--------------------------------------------------
// 11/08/2011	cnwdap1		PAR #27972 Bulk release type no longer translatable, replaced by string constants
//							Also swap Ship and Packing XML string array positions, so they now match the new constant values
//23/11/2011	cnwcs5		CCMS POL 2122 / par 28696 - new type of unknown
// 10 Feb 2015	NDL	Par 35650
vars 
	str, typeTag, typeXML : String;
	table	:CM_DataTable;
begin
	table	:= self.tblData;

	if self.xmlStrTblData &lt;&gt; null then
		str := self.xmlStrTblData;
	else
		str := table.getXmlStrForColumns(true);
	endif;

	typeTag := self.typeMode;
	typeXML := global.formatAsXMLPrefix(typeTag) &amp; str &amp; global.formatAsXMLSuffix(typeTag);
	if self.typeMode &lt;&gt; BR_TYPE_ROAD_STR then
		typeXML := typeXML &amp; global.formatAsXMLPrefix(BR_TYPE_ROAD_STR) &amp; self.xmlRoad &amp; global.formatAsXMLSuffix(BR_TYPE_ROAD_STR); 
	endif;
	if self.typeMode &lt;&gt; BR_TYPE_RAIL_STR then
		typeXML := typeXML &amp; global.formatAsXMLPrefix(BR_TYPE_RAIL_STR) &amp; self.xmlRail &amp; global.formatAsXMLSuffix(BR_TYPE_RAIL_STR); 
	endif;
	if self.typeMode &lt;&gt; BR_TYPE_PACKING_STR then
		typeXML := typeXML &amp; global.formatAsXMLPrefix(BR_TYPE_PACKING_STR) &amp; self.xmlPack &amp; global.formatAsXMLSuffix(BR_TYPE_PACKING_STR); 
	endif;
	if self.typeMode &lt;&gt; BR_TYPE_SHIP_STR then
		typeXML := typeXML &amp; global.formatAsXMLPrefix(BR_TYPE_SHIP_STR) &amp; self.xmlShip &amp; global.formatAsXMLSuffix(BR_TYPE_SHIP_STR); 
	endif;
	if self.typeMode &lt;&gt; BR_TYPE_UNKNOWN_STR then
		typeXML := typeXML &amp; global.formatAsXMLPrefix(BR_TYPE_UNKNOWN_STR) &amp; self.xmlUnknown &amp; global.formatAsXMLSuffix(BR_TYPE_UNKNOWN_STR); 
	endif;
	if self.typeMode &lt;&gt; BR_TYPE_ALL_STR then
		typeXML := typeXML &amp; global.formatAsXMLPrefix(BR_TYPE_ALL_STR) &amp; self.xmlAll &amp; global.formatAsXMLSuffix(BR_TYPE_ALL_STR); 
	endif;
	
	str := str &amp;  typeXML;

	return str;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setThumbnailHeading" id="02207aa9-00ed-4b3a-9dec-cc1ae55d9404">
        <source>setThumbnailHeading(_table :CM_ThumbnailTable input; _rowName, _heading :String; _entTableDef :EntTableDef; _locale :CM_Locale) protected;
/*
Date		Who		Reason
07 February 2012	cnwcs5	Initial creation - par 28756 Refactoring Release requests form
*/
vars
	entRow	:EntTableRow;
begin
	entRow  := _entTableDef.getEntTableRow (_rowName);
			
	if entRow &lt;&gt; null then
		_table.setHeadingByHeading (entRow.getHeading (null, null, _locale), _heading);
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_table" type="CM_ThumbnailTable" usage="input"/>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_heading" type="String"/>
        <Parameter name="_entTableDef" type="EntTableDef"/>
        <Parameter name="_locale" type="CM_Locale"/>
    </JadeMethod>
    <JadeMethod name="setVoyageComboObject" id="b7bb7e2f-6453-4272-bcdb-72ab5539f10f">
        <updating/>
        <source>setVoyageComboObject(_voyage : CM_Voyage) updating;
//
// Purpose:			Set the voyage filter combo to the supplied voyage - no references to this method,
//					but it is called from CMUI_Assistant::showReleaseFormForVoyage via a sendMsgWithParams
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 08/01/2015	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394 Voyage Rationalisation
//
vars
	idx : Integer;

begin
	if _voyage &lt;&gt; null and self.cmbFiltVoyage.listCount &gt; 0 then
		idx := self.cmbFiltVoyage.findObject(_voyage);
		self.cmbFiltVoyage.listIndex := idx;
		self.cmbFiltVoyage_lostFocus(self.cmbFiltVoyage);
	endif;
epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
    </JadeMethod>
    <JadeMethod name="setupContextMenuItems" id="998808f0-01c1-4e24-9157-7a358ed84645">
        <updating/>
        <source>setupContextMenuItems(_conwin: Window input) updating;
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 15/02/2010	cnwcs5	ccms 1925 / par 22295 - Release Summaries
// 28/11/2011	cnwcs5	CCMS POL 2122 / par 28696
// 23/04/2012	cnwcs5	CCMS POL 2172 / par 29480 coparn release updates.  Also fixed up handling of some other menu items
vars
	menu : MenuItem;
begin
	inheritMethod(_conwin);

	self.mnuCargoEnquiry.visible 		:= false;
	self.mnuCreateInternalMove.visible 	:= false;
	self.mnuSummarise.visible			:= false;	// 15/02/2010 cnwcs5 ccms 1925 / par 22295
	self.mnuEditBooking.visible 		:= false;
	self.mnuSetReleaseStatus.visible	:= false;	// par 29480 April 2012
	self.mnuSetReleaseType.visible		:= false;	// par 29480 April 2012
	self.mnuBlockEDI.visible			:= false;	// par 29480 April 2012
	self.mnuViewEDIFile.visible			:= false;	// par 29480 April 2012
	self.mnuQueueMoves.visible			:= false;	// 04 Sep 2014	NDL	Par 34717
	self.mnuTestAutoPlan.visible 		:= false;	//16 Jun 2015	NDL	Par 36338
	self.mnuFindMatching.visible		:= false;	//16 Jun 2015	NDL	Par 36338

	// 04 Sep 2014	NDL	Par 34717
	if self.btnMoveIt.visible then
		// TFS 2198 CNWAB1
		if app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
			self.mnuQueueMoves.visible := true;
			menu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuQueueMoves, false);
	
		endif;
	endif;
	
	if self.currentObjectIsPacking() then
		// TFS 2734 CNWAB1
		if app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
			self.mnuCreateInternalMove.visible := true;
		endif;
	endif;
	
	menu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuCreateInternalMove, false);
	
	if self.currentObjectHasBooking() then  //cwnrd1 par 23922 ccms mes 1091 11.10.2010
		// TFS 2198 CNWAB1
		if app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
			self.mnuEditBooking.visible := true;
	
		endif;
	endif;
	
	menu := self.zCloneMenu( self.mnuTblVCloneDataTbl, self.mnuEditBooking, false );
	
	
	self.doContextForTestAutoPlan();	//16 Jun 2015	NDL	Par 36338
	
	
	if self.canSummarise then																// 15/02/2010 cnwcs5 ccms 1925 / par 22295
		self.mnuSummarise.visible 			:= true;										// 15/02/2010 cnwcs5 ccms 1925 / par 22295
		// the summarise selected is only enabled if something is actually selected.
		self.mnuSummariseSelected.visible	:= not self.tblData.allSelectedObjects.isEmpty;	// 15/02/2010 cnwcs5 ccms 1925 / par 22295
	endif;																					// 15/02/2010 cnwcs5 ccms 1925 / par 22295
	
	menu := self.zCloneMenu( self.mnuTblVCloneDataTbl, self.mnuSummarise, false );			// 15/02/2010 cnwcs5 ccms 1925 / par 22295
	
	self.zCloneMenu( menu, self.mnuSummariseAll, true );									// 15/02/2010 cnwcs5 ccms 1925 / par 22295
	self.zCloneMenu( menu, self.mnuSummariseSelected, true );								// 15/02/2010 cnwcs5 ccms 1925 / par 22295
	
	if self.currentObjectHasTIs() then
		self.mnuCargoEnquiry.visible := true;
	endif;

	menu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuCargoEnquiry, false);
	
	if self.currentObjectHasEDIFile then		// par 28696
		self.mnuViewEDIFile.visible	:= true;	// par 29480 April 2012
	endif;
	
	menu := self.zCloneMenu (self.mnuTblVCloneDataTbl, self.mnuViewEDIFile, false);	// par 28696
	
	if self.canDoEdit then						// par 29480 April 2012			
		self.mnuBlockEDI.visible := true;		// par 29480 April 2012
	endif;										// par 29480 April 2012
	
	menu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuBlockEDI, false);	// par 29480 April 2012
	
	if self.canMaintainAll or self.canMaintainPending then	// par 28696
		self.mnuSetReleaseType.visible := true;				// par 29480 April 2012
	endif;
	
	menu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuSetReleaseType, false); 

	if self.canArchive then 
		self.mnuSetReleaseStatus.visible := true;	// par 29480 April 2012
	endif;
	
	menu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuSetReleaseStatus, false); 
			
	menu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuOutwardRail, false); 
	self.doBuildMenuRailLines(menu);
	
	if self.canDoEdit then	// TFS 2734
		menu := self.zCloneMenu(self.mnuTblVCloneDataTbl, self.mnuCompleteItems, false); 	// cnwrd1 ccms pol 2103 par 27856 18.7.2011
		self.doBuildMnuCompleteItems(menu);
	endif;
		
	
end;</source>
        <Parameter name="_conwin" type="Window" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="e2c2655f-41c8-4eaa-906a-8baed26aaf0b">
        <updating/>
        <source>setupForm() updating;
/*
----------   ----------  --------------------------------------------------
Created:	25 July 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
04 Oct 2022 navtnr20 ChangeRequest 54967: EUP - INB/OUT - Operational Instructions	
----------   ----------  --------------------------------------------------
*/
vars
	userWindow		: CM_UserWindow;
begin
	inheritMethod();
	
	userWindow := self.myUserWindow;
	self.btnSearch2.visible := false;	
	if userWindow = null then
		userWindow := app.getUserWindow(self.name, false);
	endif;
	
	if userWindow = null then
		self.isSearcherFloating := false;
		self.searcherDockUndock(self.isSearcherFloating);
		self.zShowSearcher();
		
		self.isThumbnailVisible := true;//so as to make this false in the following call
		self.hideShowThumbnail();
	endif;
	self.btnInstruction.enabled := false;	//04.10.2022 navtnr20 TFS 54967
	
	self.frmTableFilter.setCallbackMethod(GTE_ReleaseRequestForm::doFilterTable.name); //25/06/2024	navkc1 CR 64823 Task 64824
end;

</source>
    </JadeMethod>
    <JadeMethod name="setupPermissions" id="7cf3d23c-f441-422d-9983-40d7d8433c12">
        <updating/>
        <source>setupPermissions() updating;
// ---------------------------------------------------------------------------
// Created:     16 March 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod();

	self.canMaintainPending := app.myCurrentUserCan(self.myTerminal, PmGteEmptyReleaseMaintPending);
	self.canMaintainAll  	:= app.myCurrentUserCan(self.myTerminal, PmGteEmptyReleaseMaintAll);

	if self.canMaintainPending or self.canMaintainAll then
		self.allowAdd	 := true;
		self.allowDelete := true;
		self.allowUpdate := true;
	else
		self.allowAdd	 := false;
		self.allowDelete := false;
		self.allowUpdate := false;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="showPrintFrame" id="02eda09c-5065-47a2-a876-4eb90439e789">
        <source>showPrintFrame();
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	int :	Integer;
begin

//	05 Aug 2016	NDL	TFS 2496
//	if self.myTerminal.allUserTerminals[app.myPassport.myUser.code].canDoReport("_rpt115") then 
		self.optReport.visible:= true;
//	else
//		self.optPrintList.value := true;
//		self.optReport.visible := false;
//	endif;
	self.frmPrint2.backColor := self.backColor;
	self.grpReportOptions.backColor := self.backColor;
	
	self.frmPrint2.visible := true;
	self.frmPrint2.centreWindow();
	self.frmPrint2.zOrder(1);
	self.optPrintList.setFocus();
end;</source>
    </JadeMethod>
    <JadeMethod name="showThumbnailData" id="c96ed0de-c13f-49af-8cc1-08d17fc1930f">
        <updating/>
        <source>showThumbnailData(obj: Object) updating;
// ---------------------------------------------------------------------------
// Created:     10 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 11/08/2011	cnwdap11	PAR #27972 Bulk release type no loger translatable, replaced by string constants
// 24/11/2011	cnwcs5		CCMS POL 2122 / par 28696
// 07/02/2012	cnwcs5		par 28756 - refactoring
// 20 Oct 2022 	navtnr20 	ChangeRequest 54967: EUP - INB/OUT - Operational Instructions
// 13 Mar 2025	navah1		Bug 34283: EUP | Additional Operational Instructions - further issuesv
// 03 Nov 2025	jlizm1		MTN 36255 Rotabox Assign Release To Vessel
// ---------------------------------------------------------------------------
vars
	br 			: CM_BulkRelease;
	row			: Integer;
	heading 	: String;
	entTableDef	: EntTableDef;
	thumbTable	: CM_ThumbnailTable;
	dataTable	: CM_DataTable;
	locale		: CM_Locale;
	entRow		: EntTableRow;
	objArray	: ObjectArray;
	docObj 		: Object;
	docAction	: CM_DocumentActions;
	rowIndex	: Integer;
	cargoType : CM_CargoType;
begin
	thumbTable	:= self.tblThumb;
	dataTable	:= self.tblData;

	if obj.isKindOf(CM_ReserveDetail) then
		br := obj.CM_ReserveDetail.myReserveHeader;
	elseif obj.isKindOf(CM_TrackedItem) then
		br := obj.CM_TrackedItem.allBulkReleasesAssigned.first;
	else
		br := obj.CM_BulkRelease;
	endif;
	//	th2 added 20/03/2007 - isValidObject call is justified in that the user 
	//	may have multi-selected and clicked delete
	if br = null or (not app.isValidObject(br)) then
		return;
	endif;

	if br.type &lt;&gt; BR_TYPE_RAIL then
		self.mnuSendToBP.visible 		:= false;
		self.mnuOutwardRail.visible 	:= false;
		
		self.mnuOutwardRail.caption 	:= "Assign To Outward Rail...";
		self.mnuOutwardRail.userObject 	:= null;
	else
		self.mnuOutwardRail.visible := br.status &lt;&gt; BR_COMPLETE;
	
		//23 Feb 2017	NDL	TFS 3514
		if obj.isKindOf(CM_ReserveDetail) then
			cargoType := obj.CM_ReserveDetail.getCargoType;
			if cargoType = null then
				self.mnuOutwardRail.visible := false;
			elseif cargoType.isBulkMulti or cargoType.isBreakBulkMulti then
				self.mnuOutwardRail.visible := false;
			endif;
		endif;
		
		// TFS 2734 CNWAB1
		if not app.myCurrentUserCan(self.myTerminal,self.permissionMaint) then
			self.mnuOutwardRail.visible := false;
		endif;
			
	endif;
	
	if br.status &lt;&gt; BR_ACTIVE then
		self.btnGeneratePin.enabled := false;
		self.btnDeletePIN.enabled 	:= false;
		self.btnMoveIt.enabled := false;	//03 Sep 2014	NDL	Par 34717
	else
		self.btnGeneratePin.enabled := self.viewStatusMode = BR_ACTIVE_STRING or 
										self.viewStatusMode = (BR_ACTIVE_STRING &amp; ' &amp; ' &amp; BR_PENDING_STRING) or 
										self.viewStatusMode = BR_TYPE_ALL_STR;
		self.btnDeletePIN.enabled 	:= self.btnGeneratePin.enabled;
		self.btnMoveIt.enabled := self.btnGeneratePin.enabled;	//03 Sep 2014	NDL	Par 34717
	endif;
	/* //13.03.2025 navah1 #34283
	if br.status = BR_COMPLETE then	//20.10.2022 navtnr20 TFS 54967
		self.btnInstruction.enabled := false;	//20.10.2022 navtnr20 TFS 54967
	endif;	//20.10.2022 navtnr20 TFS 54967
	*/
	self.setNavigatorHeading(self.viewStatusMode &amp; ' (' &amp; br.code &amp; ')');
	
	thumbTable.rows := 0;

	//here is the def data
	self.showThumbnailForDef(ETDef_MTReleaseThumb, br);
	
	entTableDef := app.myController.getEntTableDef(ETDef_MTReleaseThumb);
	locale		:= app.myCurrentLocale;
	self.hideThumbnailRow (thumbTable, ETRow_RequestsOutstanding, entTableDef, locale);
	
	//23 Oct 2014	NDL	Par 35008
	if not app.isVehicleBookingEnabled then
		self.tblData.hideColumnByColName(ETRow_VehicleBookingSlots);
	endif;
	
	if br.type = BR_TYPE_RAIL or br.type = BR_TYPE_ROAD or br.type = BR_TYPE_SHIP or br.type = BR_TYPE_UNKNOWN then	// par 28696
		// not packing
		self.hideThumbnailRow (thumbTable, ETRow_PackLocation, entTableDef, locale);
		self.hideThumbnailRow (thumbTable, ETRow_PackProduct, entTableDef, locale);
		self.hideThumbnailRow (thumbTable, ETRow_PackQuantity, entTableDef, locale);
		self.hideThumbnailRow (thumbTable, ETRow_VoyageArrival, entTableDef, locale);
		self.hideThumbnailRow (thumbTable, ETRow_DeliveryReleaseNumber, entTableDef, locale);
		self.hideThumbnailRow (thumbTable, ETRow_TotalPacked, entTableDef, locale);
		self.hideThumbnailRow (thumbTable, ETRow_MySubTerminalTarget, entTableDef, locale);	// 20/08/2010 cnwar2 #25380
		
		if not br.hasRotatableContainer then
			self.hideThumbnailRow (thumbTable, ETRow_CargoTypeCodeForCntnt, entTableDef, locale);
			self.hideThumbnailRow (thumbTable, ETRow_CargoSubTypeCodeForCntnt, entTableDef, locale);
		endif;
		
		if br.type = BR_TYPE_RAIL  then
			self.hideThumbnailRow (thumbTable, ETRow_MyOperatorGroup, entTableDef, locale);
// TFS 2686			self.hideThumbnailRow (thumbTable, ETRow_RemoveStops, entTableDef, locale);
			self.hideThumbnailRow (thumbTable, ETRow_PowerRequirements, entTableDef, locale);
			self.hideThumbnailRow (thumbTable, ETRow_HeavyRated, entTableDef, locale);
			self.hideThumbnailRow (thumbTable, ETRow_DoorsForward, entTableDef, locale);
			
		elseif br.type = BR_TYPE_SHIP then
			self.hideThumbnailRow (thumbTable, ETRow_FreightPayerCode, entTableDef, locale);
			self.hideThumbnailRow (thumbTable, ETRow_MyTransferToTerminal, entTableDef, locale);
			self.hideThumbnailRow (thumbTable, ETRow_CarrierCode, entTableDef, locale);
			self.hideThumbnailRow (thumbTable, ETRow_DoorsForward, entTableDef, locale);
			self.hideThumbnailRow (thumbTable, ETRow_Email, entTableDef, locale);
			self.hideThumbnailRow (thumbTable, ETRow_HiLowCube, entTableDef, locale);

		else	// road or Unknown
			self.hideThumbnailRow (thumbTable, ETRow_RailReference, entTableDef, locale);
			self.hideThumbnailRow (thumbTable, ETRow_LoadPort, entTableDef, locale);
			self.hideThumbnailRow (thumbTable, ETRow_FreightPayerCode, entTableDef, locale);
			self.hideThumbnailRow (thumbTable, ETRow_BookingConfirmation, entTableDef, locale);
		endif;
		
	elseif br.type = BR_TYPE_PACKING then 
		self.hideThumbnailRow (thumbTable, ETRow_RailReference, entTableDef, locale);
		self.hideThumbnailRow (thumbTable, ETRow_MyOperatorGroup, entTableDef, locale);
		self.hideThumbnailRow (thumbTable, ETRow_CarrierCode, entTableDef, locale);
		self.hideThumbnailRow (thumbTable, ETRow_PowerRequirements, entTableDef, locale);
		self.hideThumbnailRow (thumbTable, ETRow_HeavyRated, entTableDef, locale);
		self.hideThumbnailRow (thumbTable, ETRow_DoorsForward, entTableDef, locale);
// TFS 2686		self.hideThumbnailRow (thumbTable, ETRow_RemoveStops, entTableDef, locale);
		self.hideThumbnailRow (thumbTable, ETRow_FreightPayerCode, entTableDef, locale);
		self.hideThumbnailRow (thumbTable, ETRow_CargoTypeCodeForCntnt, entTableDef, locale);
		self.hideThumbnailRow (thumbTable, ETRow_CargoSubTypeCodeForCntnt, entTableDef, locale);
		
		self.setThumbnailHeading (thumbTable, ETRow_DeliveryReleaseNumber, "Delivery number", entTableDef, locale);
		self.setThumbnailHeading (thumbTable, ETRow_EstimatedRequiredDate, "Pack By Date", entTableDef, locale);
		self.setThumbnailHeading (thumbTable, ETRow_EstimatedRequiredTime, "Pack By Time", entTableDef, locale);
	endif;
	
	if app.isSpecial() then
		thumbTable.addItem(obj.String);
	endif;
	
	// CCMS 1412
	if (not self.permissionMaint = PmGteEmptyReleaseMaintAll) then
		entRow := entTableDef.getEntTableRow(ETRow_PinNo);
		
		if entRow &lt;&gt; null then
			heading	:= entRow.getHeading (null, null, locale);
			row 	:= thumbTable.getRowFromHeading(heading);
			
			if row &gt; 0 and row &lt;= thumbTable.rows then
				thumbTable.accessCell(row, 1).text := heading &amp; Tab &amp; '****';
			endif;
		endif;
	endif;
	
	//16/04/2009 cnwdz2 ccms1735
	if not app.isSubTerminalsOn(self.myTerminal) then
		dataTable.hideColumnByColName(ETRow_MySubTerminal);
		dataTable.hideColumnByColName(ETRow_MySubTerminalTarget); //cnwrd1 par 23219 30.3.2010
		
		self.hideThumbnailRow (thumbTable, ETRow_MySubTerminal, entTableDef, locale);
		self.hideThumbnailRow (thumbTable, ETRow_MySubTerminalTarget, entTableDef, locale);	// 20/08/2010 cnwar2 #25380
	endif;
	
	create objArray transient;
	self.tblResDetails.rows := 0;
	if br.hasDocumentActions( objArray ) then
		self.tblResDetails.visible := true;
		self.sptThumbEdit.showRightControl(20, true);
		foreach docObj in objArray do
			docAction := docObj.CM_DocumentActions;
			rowIndex := self.tblResDetails.addItem( docAction.getThumbNailDisp() );
			self.tblResDetails.accessCell(rowIndex,1).wordWrap := true;
		endforeach;
		self.tblResDetails.cnEcResizeContents();
	else
		self.tblResDetails.visible := false;
		self.sptThumbEdit.hideRightControl(true);
	endif;

	if br.isKindOf(CM_InterTerminalBulkRelease) then // ccms 1867 cnwrd1 22.2.2010 disable delete btn for inter terminal br
		self.btnDeleteTV.enabled := false;
	else
		self.btnDeleteTV.enabled := true;
	endif;
	// TFS 2198 CNWAB1
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.btnMoveIt.enabled:= false;
		self.btnEditTV.enabled:= false;
	endif;
	
epilog

	delete objArray;

end;</source>
        <Parameter name="obj" type="Object"/>
    </JadeMethod>
    <JadeMethod name="tblDataDisplayRow" id="0ce65028-5a2a-4ed2-8bfb-7f51e6cf8a07">
        <updating/>
        <source>tblDataDisplayRow(table: Table input; obj: Object): String updating;
// ---------------------------------------------------------------------------
// Created:     10 January 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	23/5/01			AA		Changed to show quantity remaining instead of total requested
// 11/07/2018		jlgrh7 TFS #39309  Release Request Search based on data access group
// ---------------------------------------------------------------------------
vars
	br		: CM_BulkRelease;
	opCode	: String;
	tiId	: String;
	carrier	: CM_Carrier;
	str :String;
	passport : CM_Passport;
	showReserve, showTI : Boolean;
	aReserve : CM_ReserveDetail;
	aTI : CM_TrackedItem;
	aCol,theRow : Integer;
	strArray : HugeStringArray;
	failedDAC  :CM_DataAccessController;
	customAgent : CM_CustomsAgent;							//+TFS39309
begin

	if obj.isKindOf(CM_BulkRelease) then
		br := obj.CM_BulkRelease;
		if self.showFullReq and self.mode = self.Mode_View then
			if br.getDeliveryRequest(false) &lt;&gt; null then
				showTI := true;
				aTI := br.allTrackedItemsAssigned.first;
			else
				return null;// ### PAR 11353
			endif;
		endif;

	else
		if obj.isKindOf(CM_ReserveDetail) then
			showReserve := true;
			aReserve := obj.CM_ReserveDetail;
			br := aReserve.myReserveHeader;
			
			// ### PAR 11353
			if not self.showFullReq then
				if (self.tblData.findObjectInRow(br, theRow)) then
					return null;
				endif;
			endif;

		elseif obj.isKindOf(CM_TrackedItem) then
			showTI := true;
			aTI := obj.CM_TrackedItem;
			br := aTI.allBulkReleasesAssigned.first;
		endif;
	endif;
	
	if br = null then
		return null;
	endif;
		// Display the Bulk Release	
	if br.myOperator &lt;&gt; null then
		opCode := br.myOperator.code;
	endif;
	
	passport := app.myPassport;

	if self.filterFreeText &lt;&gt; null then
	endif;
			
	if br.myOperator &lt;&gt; null then
		if (not br.myOperator.canUserAccessSelf(null, failedDAC,  passport)) then
			return null;
		endif;
	elseif br.myOperatorGroup &lt;&gt; null then
		if (not br.myOperatorGroup.canUserAccessSelf(null, failedDAC, passport)) then
			return null;
		endif;
	endif;

	if br.carrierId &lt;&gt; null then
		carrier := app.myRoot.allCarriers[br.carrierId];
		if carrier &lt;&gt; null then
			if (not carrier.canUserAccessSelf(null, failedDAC, passport)) then
				return null;
			endif;
		endif;
	endif;

	// Check if bulk release has been filtered.
	if   (self.filterCarrierCode &lt;&gt; null and br.carrierId.trimRight &lt;&gt; self.filterCarrierCode) or
	   (self.filterConsignorCode &lt;&gt; null and br.consigneeCode.trimRight &lt;&gt; self.filterConsignorCode) then
	   	return null;
	endif;
	
	if br.customsAgent &lt;&gt; null then																					//+TFS39303
		customAgent := app.myRoot.allCustomsAgents[br.customsAgent];
		if customAgent &lt;&gt; null then
			if (not customAgent.canUserAccessSelf(null, failedDAC, passport)) then
				return null;
			endif;
		endif;
	endif;
	
	if (self.filterFreightForwarder &lt;&gt; null and br.freightForwarderCode &lt;&gt; self.filterFreightForwarder) then		// PAR 20646
	   	return null;
	endif;

	if self.filterDateFrom.isValid and self.filterDateTo.isValid then
//		if (not br.createdTime.date.cnEcIsBetween(self.filterDateFrom, self.filterDateTo)) then
		 // ### PAR 10574 should be using requested date
		if (not br.dateRequested.date.cnEcIsBetween(self.filterDateFrom, self.filterDateTo)) then
			return null;
		endif;
		
	// 25/01/2012 cnwar2 #28109
	elseif self.filterDateTo.isValid then
		if br.dateRequested.date &gt; self.filterDateTo then
			return null;
		endif;
	endif;
	
	if showReserve then
		str := aReserve.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
	elseif showTI then
		str := br.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
		
		aCol := self.tblData.getColumnByRowName(ETRow_EmptyReleaseItemDescr);
		if aCol &gt; 0 and aTI &lt;&gt; null then
			create strArray transient;
// cnwdad1 21/06/2005 - Was getting a "String Too Long" exception.
//			str.getTokensForDelimiter(Tab,strArray);
			str.getTokensForDelimiterHuge(Tab, strArray);
			strArray[aCol] := aTI.id;
			str := strArray.getFirstElementsDelimited(0,Tab);
//			str := str[2:end];
		endif;
//		str := aTI.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
	else
		str := br.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
	endif;

/*	
	if self.filterFreeText &lt;&gt; null then
		if str.pos(self.filterFreeText,1) &gt; 0 then
			return null;
		endif;
	endif;
*/
	return str;	
epilog
	delete strArray;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="obj" type="Object"/>
        <ReturnType type="String"/>
    </JadeMethod>
