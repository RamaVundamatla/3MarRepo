    <JadeMethod name="populateHookTypes" id="2feb45b1-d263-4408-8177-60574dd8a74e">
        <updating/>
        <source>populateHookTypes() protected, updating;
// populate the two hook type collections for the combo
vars
	hookType	: CM_HookType;
begin
	foreach hookType in app.myRoot.allHookTypes do
		if hookType.hookType = HookType_HMS_CheckPoint
		or hookType.hookType = HookType_IsStopRelevant
		or hookType.hookType = HookType_ContainerAttributes
		or hookType.hookType = HookType_ContainerUnique
		or hookType.hookType = HookType_LocationTranslation
		or hookType.hookType = HookType_EDIFileFieldHook
		or hookType.hookType = HookType_EDIFileIncludeLine
		or hookType.hookType = HookType_CashProForma
		or hookType.hookType = HookType_VesselProforma		// jlgab1 MARCH18 TFS 37453
		then
			// These types not maintained from this form
			continue;
		endif;
		
		if not app.isCashOnlyEnabled then
			if hookType.hookType = HookType_ProFormaItemSearch then
				continue;
			endif;
		endif;
	
		self.fullHookTypes.add(hookType);

	// TFS 2010 these types are shown but not maintained in this form, they have no hook links
		if hookType.hookType = HookType_RTConfigDoorDir or
		   hookType.hookType = HookType_InvoiceQuantity or
		   hookType.hookType = HookType_InvoiceRate or
		   hookType.hookType = HookType_HMSInvoiceQuantity or
		   hookType.hookType = HookType_HMSInvoiceRate or
		   hookType.hookType = HookType_RTConfigIsoType or
		   hookType.hookType = HookType_RTConfigLocation or
		   hookType.hookType = HookType_YardAllocationOS then
			continue;
		endif;
		
		self.addHookTypes.add(hookType);

	endforeach;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="fb88b51b-cfda-42d8-8c68-eaf6a72551d5">
