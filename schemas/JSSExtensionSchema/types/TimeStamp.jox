<PrimType name="TimeStamp">
    <Constant name="JSS_ENCRYPTBASEDATE" id="866a5dea-6ea9-4475-a17e-83504a36a42c">
        <source>'26MAY1998'.Date</source>
        <type name="Date"/>
    </Constant>
    <Constant name="JSS_ENCRYPTBASETIME" id="7c524b95-7b64-4d6c-af77-6a303da7db33">
        <source>'00:00:00:00'.Time</source>
        <type name="Time"/>
    </Constant>
    <JadeMethod name="jssAddDays" id="1f6ea954-d88d-4393-bc16-04bf490b1e0e">
        <source>jssAddDays(pDays:Integer):TimeStamp;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of days to the
//				receiver timestamp.
//
// Parameters:	pDays (Integer) - The number of days to add (or subtract).
//
// Returns:		The resulting timestamp.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	currentTimestamp	: TimeStamp;
	
begin
	currentTimestamp	:=	self;
	currentTimestamp.setDate(self.date().jssAddDays(pDays));
	
	return currentTimestamp;
end;</source>
        <Parameter name="pDays" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="jssAddHours" id="0fe90cf9-e642-4321-8a69-f50d5b7b6fb3">
        <source>jssAddHours(pHours:Integer):TimeStamp;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of hours to the
//				receiver timestamp.
//
// Parameters:	pHours (Integer) - The number of hours to add (or subtract).
//
// Returns:		The resulting timestamp.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	adjustTime	: Time;
	
begin
	if pHours &gt; 0 then
		adjustTime.setTime(pHours, 0, 0, 0);
		return self + adjustTime;
	else
		adjustTime.setTime(-pHours, 0, 0, 0);
		return self - adjustTime;
	endif;
end;</source>
        <Parameter name="pHours" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="jssAddMinutes" id="359fbc00-cba3-4621-9bd9-441b805ce8e6">
        <source>jssAddMinutes(pMinutes:Integer):TimeStamp;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of minutes to the
//				receiver timestamp.
//
// Parameters:	pMinutes (Integer) - The number of minutes to add (or subtract).
//
// Returns:		The resulting timestamp.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	adjustTime	: Time;
	
begin
	if pMinutes &gt; 0 then
		adjustTime.setTime(0, pMinutes, 0, 0);
		return self + adjustTime;
	else
		adjustTime.setTime(0, -pMinutes, 0, 0);
		return self - adjustTime;
	endif;
end;</source>
        <Parameter name="pMinutes" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="jssAddMonths" id="af9888bd-48ff-4335-8da2-e0291cba8afb">
        <source>jssAddMonths(pMonths:Integer):TimeStamp;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of months to the
//				receiver timestamp.
//
// Parameters:	pMonth (Integer) - The number of months to add (or subtract).
//
// Returns:		The resulting timestamp.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	currentTimestamp	: TimeStamp;
	
begin
	currentTimestamp	:=	self;
	currentTimestamp.setDate(self.date().jssAddMonths(pMonths));
	
	return currentTimestamp;
end;</source>
        <Parameter name="pMonths" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="jssAddSeconds" id="f0703562-065d-4dbb-9834-38b6918e4ebd">
        <source>jssAddSeconds(pSeconds:Integer):TimeStamp;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of seconds to the
//				receiver timestamp.
//
// Parameters:	pSeconds (Integer) - The number of seconds to add (or subtract).
//
// Returns:		The resulting timestamp.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	adjustTime	: Time;
	
begin
	if pSeconds &gt; 0 then
		adjustTime.setTime(0, 0, pSeconds, 0);
		return self + adjustTime;
	else
		adjustTime.setTime(0, 0, -pSeconds, 0);
		return self - adjustTime;
	endif;
end;</source>
        <Parameter name="pSeconds" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="jssAddYears" id="4bfe8f1d-dd03-476a-80e2-170654b9de65">
        <source>jssAddYears(pYears:Integer):TimeStamp;
// --------------------------------------------------------------------------------
// Created:		24 May 2001 by cnwdad1
//
// Purpose:		Add the specified number (positive or negative) of years to the
//				receiver timestamp.
//
// Parameters:	pYears (Integer) - The number of years to add (or subtract).
//
// Returns:		The resulting timestamp.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	currentTimestamp	: TimeStamp;
	
begin
	currentTimestamp	:=	self;
	currentTimestamp.setDate(self.date().jssAddYears(pYears));
	
	return currentTimestamp;
end;</source>
        <Parameter name="pYears" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="jssAge" id="40e1cb4c-8243-4194-ab8c-092ecdf01c55">
        <source>jssAge():Decimal;
// Determines the age - i.e. the time between the TimeStamp and now.
// Returns the age in milliseconds.
vars
	now	: TimeStamp;
	age	: Decimal[23,1];

begin
	if now &gt;= self then
		age := now.jssDiff(self);
	else
		age := self.jssDiff(now);
	endif;

	return age;
end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="jssAgeInDays" id="77262bde-c5fe-4200-83cd-36aa878e6276">
        <source>jssAgeInDays():Integer;

begin
	return (self.jssAge() div Milliseconds_In_Day).Integer;
end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="jssDiff" id="8085e21b-86b0-4554-9d32-16ec396eb3c2">
        <source>jssDiff(pTimeStamp:TimeStamp):Decimal;
// Calculates the difference between two timestamp values and returns "days" and
// time difference in milliseconds.  The value returned will be positive (always
// taking the smaller value from larger value).
vars
	dateFrom		: Date;
	dateTo			: Date;
	timeFrom		: Time;
	timeTo			: Time;
	daysDifference	: Integer;

begin
	// Make sure we take the smaller value from the larger.

    if self &gt; pTimeStamp then
 		dateFrom	:=	self.Date;
		dateTo		:=	pTimeStamp.Date;

	   	timeFrom	:=	self.Time;
		timeTo		:=	pTimeStamp.Time;
	else
		dateTo		:=	self.Date;
		dateFrom	:=	pTimeStamp.Date;

	   	timeTo		:=	self.Time;
		timeFrom	:=	pTimeStamp.Time;
	endif;

	daysDifference	:=	dateFrom - dateTo;         						// Get the difference in dates.

	// [DvA19990127] added .Decimal to be able to calculate with differences larger than 24 days.....
	// .... also changed the returned datatype from Integer to Decimal.
	// cnwdad1 03/12/2001 - Changed to cast the Milliseconds_In_Day to a decimal.
//	return  (Milliseconds_In_Day * daysDifference).Decimal + 			// days component
//			(timeFrom - timeTo).Decimal;								// and time
	return  (Milliseconds_In_Day.Decimal * daysDifference.Decimal) + 	// days component
			(timeFrom - timeTo).Decimal;								// and time
end;</source>
        <Parameter name="pTimeStamp" type="TimeStamp"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="jssEncrypt" id="7f54ec3b-2784-4218-9eda-5d9a9761372c">
        <source>jssEncrypt():String;
// Encrypts the receiver and returns the value as a string.
//
// NOTE: If the date is less than EncryptBaseDate, then the decryption
// will not match the date supplied here - this is deliberate. The date
// time should be current in which case the decryption will be correct.
vars
	theDate				: Date;
	theTime				: Time;
	dateInteger			: Integer;
	timeInteger			: Integer;
	returnString		: String;
	positionOfRandom	: Integer;
	lengthOfRandom		: Integer;
	randomSubstring		: String;

begin
	// Split the current date and time.
	theDate	:=	self.date();
	theTime	:=	self.time();

	// Get the integer differnces from the base date and time.
	if theDate &lt; JSS_ENCRYPTBASEDATE then
		dateInteger	:=	0;
	else
		dateInteger	:=	theDate - JSS_ENCRYPTBASEDATE;
	endif;

	timeInteger	:=	theTime - JSS_ENCRYPTBASETIME;

	// Build the initial return string.
	returnString	:=	dateInteger.padLeadingWith("0", 6) &amp; timeInteger.String;

	// Generate the position of the random insert string (also random).
	if returnString.length() &lt; 9 then
		positionOfRandom	:=	app.random(returnString.length());
	else
		positionOfRandom	:=	app.random(9);
	endif;

	// Generate the length of the random insert string (also random).
	lengthOfRandom	:=	app.random(6);

	// Generate the random string - if no length then null is also valid.
	if lengthOfRandom &gt; 0 then
		randomSubstring	:=	app.random('999999'[1:lengthOfRandom].Integer).padLeadingWith("0", lengthOfRandom);
	endif;

	// Insert rand at the required position.
	if positionOfRandom &gt; 1 then
		if positionOfRandom &lt; returnString.length() then
			returnString	:=	returnString[1:positionOfRandom - 1] &amp; randomSubstring &amp; returnString[positionOfRandom:end];
		else
			returnString	:=	returnString &amp; randomSubstring;
		endif;
	else
		returnString	:=	randomSubstring &amp; returnString;
	endif;

	// Put the posRand and lenRand at the start of the return string
	// and return the result.

	return positionOfRandom.padLeadingWith("0", 1) &amp; lengthOfRandom.padLeadingWith("0", 1) &amp; returnString;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssIsLessThanOrEqual" id="f6382867-f332-4961-bcd9-c186e01722b2">
        <source>jssIsLessThanOrEqual(pTimeStamp:TimeStamp):Boolean;
// --------------------------------------------------------------------------------
// Created:		13 November 2000 by cnwdad1
//
// Purpose:		Returns a boolean flag to indicate whether the receiver is less-
//				than or equal-to the specified timestamp.
//
// Parameters:	pTimeStamp - The tmestamp to compare the receiver to.
//
// Returns:		True if the receiver is less-than or equal-to the specified timestamp.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.date() &lt; pTimeStamp.date() then
		return true;
	elseif self.date() = pTimeStamp.date() and self.time() &lt;= pTimeStamp.time() then
		return true;
	endif;

	return false;
end;</source>
        <Parameter name="pTimeStamp" type="TimeStamp"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="jssSetDateAndTime" id="ae14efc6-bb91-4cc9-a78c-d76f376c9fba">
        <updating/>
        <source>jssSetDateAndTime(pDate:Date; pTime:Time) updating;
// --------------------------------------------------------------------------------
// Created:		08 November 2000 by cnwdad1
//
// Purpose:		Updates the Date and Time properties of the TimeStamp.
//
// Parameters:	pDate (Date) - The new date value.
//				pTime (Time) - The new time value.
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.date() &lt;&gt; pDate then
		self.setDate(pDate);
	endif;
	
	if self.time() &lt;&gt; pTime then
		self.setTime(pTime);
	endif;
end;</source>
        <Parameter name="pDate" type="Date"/>
        <Parameter name="pTime" type="Time"/>
    </JadeMethod>
    <JadeMethod name="jssShortFullFormat" id="96c98339-5334-4ec7-a365-18056cc377e1">
        <source>jssShortFullFormat():String;
// -----------------------------------------------------------------------------
// Created:		07 January 2002 by cnwdad1
//
// Purpose:		Returns the receiver in a short and full format, i.e. dd/MM/yyyy, hh:mm.
//
// Parameters:	None
//
// Returns:		The short-formated timestamp.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	return	self.date().userFormat($JSS_DATE_SHORT_FULL) &amp; ", " &amp; self.time().userFormat($JSS_TIME_HHMM_24);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="jssShortPartFormat" id="eba38b56-2859-4001-9862-f5e88ffaceb5">
        <source>jssShortPartFormat():String;
// -----------------------------------------------------------------------------
// Created:		07 January 2002 by cnwdad1
//
// Purpose:		Returns the receiver in a short and partial format, i.e. d/M/yy, hh:mm.
//
// Parameters:	None
//
// Returns:		The short-formated timestamp.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
begin
	return	self.date().userFormat($JSS_DATE_SHORT_PART) &amp; ", " &amp; self.time().userFormat($JSS_TIME_HHMM_24);
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
</PrimType>
