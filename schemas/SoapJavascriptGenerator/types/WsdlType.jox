<Class name="WsdlType" id="0c3a8461-4540-4139-a38c-ed1b124b1236">
    <superclass name="Object"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>This class represents a Type defined in the wsdl. ie a data class.
In Jade if you were importing a wsdl, these Types defined would
be automatically generated as new classes in Jade. These classes
are used as parameters to webservice methods (or are referenced
by the classes used as parameters etc)

Each type has a name (wsdlName), potentially a superclass and/or
some subclasses, and potentially some properties which are
represented by a collection of WsdlPropertys.</text>
    <DbClassMap file="richinternettoolset"/>
    <ImplicitInverseRef name="properties" id="65e74df2-ba9e-4bf6-ac46-5339fe247a62">
        <memberTypeInverse/>
        <type name="WPropertyArray"/>
    </ImplicitInverseRef>
    <ExplicitInverseRef name="subclasses" id="7b9f5111-fb02-4d7c-866e-a7cdd1207fb5">
        <updateMode>automatic</updateMode>
        <type name="WTypeArray"/>
        <Inverse name="superclass"/>
    </ExplicitInverseRef>
    <ExplicitInverseRef name="superclass" id="ecddd6d8-1ae9-4686-8dd2-81a8f8474fab">
        <updateMode>manual</updateMode>
        <embedded/>
        <type name="WsdlType"/>
        <Inverse name="subclasses"/>
    </ExplicitInverseRef>
    <PrimAttribute name="wsdlName" id="df794d2c-c2c3-4581-af92-fde4db134e40">
        <type name="String"/>
    </PrimAttribute>
</Class>
