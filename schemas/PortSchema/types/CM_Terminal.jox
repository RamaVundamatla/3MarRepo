    <JadeMethod name="generateNextNumber" id="613ef03f-fc05-4907-9bbe-aa625e9866b0">
        <source>generateNextNumber(_class : Class) : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2018	jlger1	Initial creation 38519
