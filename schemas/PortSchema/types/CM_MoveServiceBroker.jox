    <JadeMethod name="setForCreate" id="3d6ec6d4-bc2e-403f-85e0-434c07b57992">
        <updating/>
        <source>setForCreate(_pxySB : SelfType) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	inheritMethod(_pxySB);
	self.commodityMap := _pxySB.commodityMap;
	self.moveFrom := _pxySB.moveFrom;
	self.moveTo := _pxySB.moveTo;
	self.initialise(self.getBank());
end;</source>
