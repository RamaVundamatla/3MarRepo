    </PrimAttribute>
    <PrimAttribute name="description" id="d594e7c6-4d89-4667-a3de-11aa4190a158">
        <length>51</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="dutyCharged" id="97bf1c7a-7060-41b9-8089-94041c38f729">
        <embedded/>
