    <JadeMethod name="buildComboEWS" id="046509ef-bf76-48be-801f-389f0888e7a8">
        <source>buildComboEWS(_cmb : CMUI_ComboBox io);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 November 2023	navra1	Initial creation for TFS 54090 CR - 61380/Task - 61385 - 30th Nov 2023
27/09/2024	navcs2	ChangeRequest 66181: MTN | External Webservice Monitor - Feedback
*/

vars	
	wsDef : CM_ExternalWebServiceDef;
	
begin	
	
	_cmb.clear();
	_cmb.sorted := true;

	foreach wsDef in app.myRoot.allExternalWebServices where wsDef.isInvoiceAPIDef do		// 27/09/2024	navcs2	ChangeRequest 66181
		_cmb.addItemObject(wsDef.name, wsDef);		
	endforeach;
	
	_cmb.sorted := false;
	
	_cmb.addItemAt("All EWS Interfaces", 1);
	
	_cmb.listIndex := 1;
	
end;</source>
        <Parameter name="_cmb" type="CMUI_ComboBox" usage="io"/>
    </JadeMethod>
