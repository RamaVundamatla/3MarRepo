	endif;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="requiresVentilation" id="3aefc6ed-3d42-4912-86fd-965898bd76b8">
        <source>requiresVentilation() : Boolean;
//
// 02 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
//
vars
	operator : CM_Operator;
	isoType : CM_ISOType;
	commodity : CM_Commodity;
begin
	operator := app.myRoot.allOperators[self.operatorCode];
	if operator = null then
		return false;
	endif;
	if (not operator.requiresVentilation) then
		return false;
	endif;
	isoType := app.myRoot.allISOTypes[self.isoType];
	if isoType = null then
		return false;
	endif;
	commodity := app.myRoot.allCommodities[self.commodity];
	if commodity = null then
		return false;
	endif;
	if (isoType.isReefer or isoType.isIntegral) and 
	   commodity.hasTemp then
		return true;
	endif;
	if isoType.isFantainer and 
	   (commodity.hasTemp or commodity.requiresPower) then
		return true;
	endif;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sealNum" id="89cf8efb-e3d7-4944-acb7-d45c44f46176">
        <methodInvocation>mapping</methodInvocation>
        <source>sealNum(set : Boolean; _value : String io) mapping;
//
// 28 Jun 2017	cnwrs1	TFS 4462 SNO add Terminal Operator, Unknown Seal and support multiple seals
//
vars

begin
	if set then
		self.setSealsAsObjects(_value, SealType_Operator);
	else
		_value := self.getSealsAsString(SealType_Operator);
		if _value = null then
			_value := self.sealNum;
		endif;
	endif;	
end;
</source>
