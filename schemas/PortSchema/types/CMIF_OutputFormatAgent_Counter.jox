    <JadeMethod name="getTotalForAtttribute" id="7a165dda-072d-445f-a57b-1d0e722890ce">
        <source>getTotalForAtttribute(_coll :Collection; _attribute :Attribute):Decimal protected;
/*

Date		Who		Reason
01 September 2011	cnwcs5	Initial creation - CCMS MES 1033 / par 27951 RORO KPI
*/
vars
	value		:Decimal [12, 2];
	isCount, isTEU, isQty, isArea, isLM, isVolume, 
	isWeight	:Boolean;
	ti			:CM_TrackedItem;
begin
	if _coll = null then
		return null;
	endif;
	
	isCount		:= (_attribute = CM_KPIVoyageMoveDtl::numTIs);
	isTEU		:= (_attribute = CM_KPIVoyageMoveDtl_Container::numTEU);
	isQty		:= (_attribute = CM_KPIVoyageMoveDtl_GC::quantity);
	isArea		:= (_attribute = CM_KPIVoyageMoveDtl_GC::area);
	isLM		:= (_attribute = CM_KPIVoyageMoveDtl_GC::linearMetres);
	isVolume	:= (_attribute = CM_KPIVoyageMoveDtl_GC::volume);
	isWeight	:= (_attribute = CM_KPIVoyageMoveDtl_GC::totalWeight);
	
	foreach ti in _coll.CM_TISet do
		if isCount then
			value := value + 1;
		elseif isTEU and ti.isContainer then
			value := value + ti.getNumTEU;
		elseif isQty then
			value := value + ti.totalQuantity;
		elseif isArea then
			if self.isActual then
				value := value + ti.getAreaInSquareMetres (REAL_MODE);
			else
				value := value + ti.getAreaInSquareMetres (PLANNING_MODE);
			endif;
		elseif isVolume then	
			value := value + ti.getMyTotalVolume; // PAR 27868
		elseif isWeight then
			value := value + ti.totalWeight;
		endif;
	endforeach;
	
	return value;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_coll" type="Collection"/>
        <Parameter name="_attribute" type="Attribute"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="init_CapacityTable" id="f3ef9c9d-9e2f-49c1-b619-3bfdcf8877ae">
