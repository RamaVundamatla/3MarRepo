    <JadeMethod name="doConfirmAftContainer" id="dd454492-0cc1-4c20-a542-6c57cd40422d">
        <source>doConfirmAftContainer(_vehicleID, _containerId, _laneID, sealCust, sealOp, sealShip : String; _errorMsgs : MobileHandHeldThin::DTO_HandHeldGateErrorDict input);
