    <JadeMethod name="addCargoToDoTask" id="d0ab6598-d35f-4c6d-a825-4d97d2215fd8">
        <source>addCargoToDoTask();
/*

Purpose:			
if we dont use Yard Jobs we should add todo tasks at the time of [Approving] working order
if we 	   use Yard Jobs we should add todo tasks at the time of [Actioning] and Create Wls and Jobs
Parameters:			

Return Value:		

Date		Who		Reason
24 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
08 Feb 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task

*/

vars
	localTis : CM_TISet;
	ti 		 : CM_TrackedItem;
	wodToDo  : CM_WodToDo;
	toDo 	 : CM_ToDoTaskDesc;
begin
	
	if not self.canAddTodoTaskToCargoWO then
		return;
	endif;
	
	if self.allAvailableTIs.isEmpty then
		return;
	endif;
	
	foreach wodToDo in self.allToDoRequests do
		if not wodToDo.allActionedTIs.isEmpty then
			//if already set before, our collection may have changed since then
			create localTis transient;
			wodToDo.allActionedTIs.copy( localTis );
			foreach ti in localTis do
				wodToDo.setTIUnactioned( ti, false );
			endforeach;
			delete localTis;
		endif;
		if not wodToDo.allAvailableTIs.isEmpty then
			//if already set before, our collection may have changed since then
			create localTis transient;
			wodToDo.allAvailableTIs.copy( localTis );
			foreach ti in localTis do
				wodToDo.removeTIAvailable( ti );
			endforeach;
			delete localTis;
		endif;
		
		foreach ti in self.allAvailableTIs do
			// set the work order to do match our current collection
			wodToDo.addTIAvailable( ti );
			wodToDo.allSelectedTIs.addNoDuplicates(ti,false);   	//06.03.2023 navma1 #56457:[56458]
		endforeach;
		
		//wodToDo.setTotalUnactioned( self.getTotalTasks );			//08.02.2023 navma1 #56457:[56458]
		wodToDo.setTotalUnactioned(self.allSelectedTIs.size);		//08.02.2023 navma1 #56457:[56458]
		
		//actually create all the to do tasks for the tis
		app.myUtilityCA.utlCreateToDosForWO( wodToDo, app.myPassport );
		
		if app.myPassport.hasErrors then
			break;
		endif;
		
	endforeach;

epilog

	delete localTis;
end;</source>
    </JadeMethod>
    <JadeMethod name="addSchedule" id="a6a3690b-f73f-4987-91b3-c0e51efd903c">
        <source>addSchedule( _schedule : CM_WorkOrderSchedule);

