        <source>isVoyageOutbound_Match(_yaData: CM_YADataObjects): Boolean;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01/06/2010	cnwdap1	Initial creation CCMS 1116 Tranship changes
*/
vars

	yaData : CM_YAData;
	yaDataObjs : CM_YADataObjects;
	obj : Object;

begin

	//12 Aug 2016	NDL	TFS 2527
	yaData := self.getExtraCriteriaMatchData( YACriteriaType_VoyageOutbound );

	if yaData &lt;&gt; null and yaData.isKindOf(CM_YADataObjects) then
		yaDataObjs := yaData.CM_YADataObjects;
		if not yaDataObjs.isEmpty then
			obj := yaDataObjs.getFirstObject;
		endif;
		if obj &lt;&gt; null then
			return _yaData.includes(obj);
		endif;
	endif;
		
	return false;
	
epilog

end;</source>
