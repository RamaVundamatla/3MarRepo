    <JadeMethod name="prenotifiedAssignedCount" id="e0d97c48-ce41-4acf-bb81-53f73dcd1c9f">
        <source>prenotifiedAssignedCount():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 February 2016	cnwndl1	Initial creation	Par 37544
10 June 2024 navrv30 Task 64477 CR 64475: Jade - New Cargo Group Details II
24/03/2025	navkc1 JIRA Story MTN-34256: MTN | Cargo Group Details for non Euroports Clients
*/

vars
	totalPrenotifiedQuantity : Integer;
	ti : CM_TrackedItem; 
	cargoGroupDtl : CM_CargoGroupDetail;
begin
	//24/03/2025	navkc1 JIRA Story MTN-34256
	if self.allCargoGroupDetails.isEmpty() then
		foreach ti in self.allAssignedTrackedItems discreteLock do
			if ti.site = TI_SITE_UNDEFINED then
				totalPrenotifiedQuantity += ti.totalQuantity;
			endif;
		endforeach;
	else
		foreach cargoGroupDtl in self.allCargoGroupDetails do
			if cargoGroupDtl.site = TI_SITE_UNDEFINED then
				totalPrenotifiedQuantity := totalPrenotifiedQuantity + cargoGroupDtl.totalQuantity;
			endif;
		endforeach;
	endif;
	
	return totalPrenotifiedQuantity;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="7bc60fa4-cae8-4a1b-9e48-3f83ced8bcdd">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2015	cnwndl1	Initial creation
12 Nov 2019	NDl	TFS 47298
*/

vars

	pxy : CM_CargoGroup;
	ti : CM_TrackedItem;
	pxyTi : CM_TrackedItem;
	string: String;

begin

	pxy := inheritMethod();
	pxy.myCargoGroupTerminal := self.myCargoGroupTerminal;
	
	//01 Oct 2018	NDL	TFS 39186
	pxy.myCargoGroupAssignment := self.getMyCargoGroupAssignment;
	pxy.allPreAssignedCargoIds.clear();
	foreach string in self.allPreAssignedCargoIds do
		pxy.allPreAssignedCargoIds.add( string );
	endforeach;
	
	return pxy;

epilog

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="releasedAssignedCount" id="210f5d61-cdc2-4bbb-a139-0dc11fc28392">
        <source>releasedAssignedCount():Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 February 2016	cnwndl1	Initial creation	Par 37544
10 June 2024 navrv30 Task 64477 CR 64475: Jade - New Cargo Group Details II
24/03/2025	navkc1 JIRA Story MTN-34256: MTN | Cargo Group Details for non Euroports Clients
*/

vars
	totalCount : Integer;
	cargoGroupDtl : CM_CargoGroupDetail;
	ti : CM_TrackedItem;
begin
	
	//24/03/2025	navkc1 JIRA Story MTN-34256
	if self.allCargoGroupDetails.isEmpty() then
		foreach ti in self.allAssignedTrackedItems discreteLock do
			if ti.site = TI_SITE_ONSITE then
				totalCount += ti.totalQuantity;
			endif;
		endforeach;
	else
		foreach cargoGroupDtl in self.allCargoGroupDetails do
			if cargoGroupDtl.site = TI_SITE_ONSITE then
				totalCount := totalCount + cargoGroupDtl.totalQuantity;
			endif;
		endforeach;
	endif;
	
	return totalCount;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="removeAssignedCargo" id="8a5ccfe0-e8d6-402c-8d16-382e6be10389">
        <updating/>
        <source>removeAssignedCargo( _ti : CM_TrackedItem input; _passport : CM_Passport input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03 June 2015	cnwndl1	Initial creation	Par 36338
30 Jan 2025		navah1	Bug 33749: MTN - Cargo Group Unit Test Failure - Incorrect On Site Assigned Count returned
*/

vars
	now : TimeStamp;
	cargoGroupDtl : CM_CargoGroupDetail;								// 30.01.2025 navah1 #33749	
	
begin

	if self.allAssignedTrackedItems.includes( _ti ) then
		_ti.setMyCargoGroup( null, _passport );
		self.updateObjectEdition( self );
		foreach cargoGroupDtl in self.allCargoGroupDetails do			// 30.01.2025 navah1 #33749	
			cargoGroupDtl.removeTIToDetail(_ti); 
		endforeach; 
	endif;
	
	self.setForArchiving( false, true, null );
	
epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
