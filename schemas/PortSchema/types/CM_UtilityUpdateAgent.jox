    <JadeMethod name="utlUpdateROROLocnDefnRotate" id="1e222762-c61a-46da-8110-367a7dbfeceb">
        <updating/>
        <source>utlUpdateROROLocnDefnRotate(_startLocn : CM_ROROLocnDefn; _items, _split : Integer; _clear : Boolean; _passport : CM_Passport input; _isLoad : Boolean) updating;
/*
Purpose:			
Date				Who			Reason
JULY 2011		CNWAB1		Initial creation
02 Apr 2012	cnwrs1		Par 29077 - EDI RORO Stowage Advice errors
*/

vars

	realDeckItem	: CM_DeckItem;
	expectedEdition	: Integer;
	beforeAuditText, 
	afterAuditText: String;
	theDeckItem : CM_ROROLocnDefn;
begin

	self.initialiseActivity();
	app.setContinueCMExceptions(true);	//02 Apr 2012	cnwrs1		Par 29077 - EDI RORO Stowage Advice errors

	theDeckItem := _startLocn.CM_ROROLocnDefn;
	
	if theDeckItem = null then
		return;
	endif;
	
	theDeckItem.validateForRotate(_items, _split, _passport, _isLoad); // PAR 28525
	
	if not _passport.checkValidation() then // PAR 28990
		return;
	endif;
	
	exclusiveLock(theDeckItem.myDeckLayerLayout);
	theDeckItem.setForUpdateRotate(theDeckItem, _items, _split, _clear, _isLoad);
	//theDeckItem.myDeckLayerLayout.setForUpdateRotate(theDeckItem, _items, _split, _clear);
epilog

end;</source>
        <Parameter name="_startLocn" type="CM_ROROLocnDefn"/>
        <Parameter name="_items" type="Integer"/>
        <Parameter name="_split" type="Integer"/>
        <Parameter name="_clear" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_isLoad" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateROROLocnDefnUnRotate" id="3bcf1e41-0506-42e2-8047-004dd9636580">
        <updating/>
        <source>utlUpdateROROLocnDefnUnRotate(_isLoad : Boolean; _duringMove : Boolean; _startLocn : CM_ROROLocnDefn;  _passport : CM_Passport input) updating;
/*
Purpose:			
Date				Who			Reason
JULY 2011		CNWAB1		Initial creation
*/
//22 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
//
vars

	realDeckItem	: CM_DeckItem;
	expectedEdition	: Integer;
	beforeAuditText, 
	afterAuditText: String;
	theDeckItem : CM_ROROLocnDefn;
	isInvalid		: Boolean;
		theDeck : CM_Deck;
begin
	on Exception do app.handleDeletedObject(exception, _startLocn, isInvalid); // PAR 28990


	self.initialiseActivity();

	theDeckItem := _startLocn.CM_ROROLocnDefn;
	
	if theDeckItem = null then
		return;
	endif;
	
	theDeckItem.validateForUnrotate(_isLoad, _duringMove, _passport); // PAR 29080 // PAR 30423

	if not _passport.checkValidation() then // PAR 28990
		return;
	endif;
	
	theDeck := _startLocn.myDeck;
	
	exclusiveLock(theDeckItem.myDeckLayerLayout);
	
	theDeckItem.myDeckLayerLayout.setLocnDefnsToUnRotate(_isLoad, theDeckItem); // PAR 29884
	theDeck.causeEvent(theDeck.CM_DeckVoyage.myVoyageStructure.myVoyage.myTerminal.getTerminalEvent(EVENT_RORORotationUpdate),false,null);  // PAR 28990

	// PAR 28886
	if _startLocn.isOOTL() then
		 if not _startLocn.myLayout.moveAftWithForward(false) then	//22 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
			_startLocn.myLayout.moveForwardWithAft(false);	//22 Jan 2013	cnwrs1	Par30951 include Exports as ROBs for EDI Proposed
		endif;
	endif;
	
epilog

end;</source>
        <Parameter name="_isLoad" type="Boolean"/>
        <Parameter name="_duringMove" type="Boolean"/>
        <Parameter name="_startLocn" type="CM_ROROLocnDefn"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateROROPointInsert" id="ba719331-e4c6-41aa-a3f8-17c0971d8ab6">
