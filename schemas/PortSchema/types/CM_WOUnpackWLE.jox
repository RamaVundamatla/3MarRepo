    <JadeMethod name="getTotalQuant" id="300e01ae-0b47-4f43-82cf-d4324aba2570">
        <source>getTotalQuant(): Integer;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Jul 2024 navhl20	ChangeRequest 64969: EUP | 53856 - New Scanning App - Unpack mode issue
31 Jul 2024 navhl20	Defect 65460: Some columns are missing on the Pack Unpack operation mode and the Quantity is not displaying the correct value
*/

vars
	ti,
	child 	: CM_TrackedItem;
	quant	: Integer;
begin
	ti := self.myTrackedItem;
	if ti &lt;&gt; null and ti.allChildren.isNotEmpty() then
		foreach child in ti.allChildren do													//31.07.2024 navhl20 #65460
			quant := quant + child.totalQuantity;
		endforeach;
		//return self.myTrackedItem.allChildren.size;										//31.07.2024 navhl20 #65460
		return quant;																		//31.07.2024 navhl20 #65460
	endif;
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getTotalWeight" id="ae7d15dd-7e39-452e-a329-3bd7ff206a24">
