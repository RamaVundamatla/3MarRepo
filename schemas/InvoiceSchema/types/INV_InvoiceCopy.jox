    <JadeMethod name="doSaveDLRT" id="876f57ff-6c33-4426-b422-f7097da52091">
        <updating/>
        <source>doSaveDLRT(_cmifInvoiceList : CMIF_InvoiceCopy) : Boolean updating;
/*
Purpose:	

Date		Who		Reason
21 October 2024	navab1	JIRA 19932
//7/3/2025 navsaa30 TFS 14818 MTN | Silent Deadlock Retry Technical Debt
03/11/2025 jlier1 	MTN-34531 - Deadlock retry for everyone	
*/

vars
	theReturn : Integer;
	localCaption : String;
	cmifInvoiceList : CMIF_InvoiceCopy;
begin
	self.mousePointer := Window.MousePointer_HourGlass;
	cmifInvoiceList := _cmifInvoiceList;
	
	/*if not app.myRoot.isAsynchronousMethodEnabled() then // EUP ONLY for FOLLOWING CODE
		while true do
			app.myTrxCA.trxCopyInvoiceList(cmifInvoiceList, app.myPassport);
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				// START //navtnr20 05-06-2023 BUG 58389
				if cmifInvoiceList.myInvoice.isCreditNote() then
					if cmifInvoiceList.myInvoice.externalNumber = null then	//navtnr20 05-06-2023 BUG 58389
						app.msgBox( app.getErrorString1(Credit_note_create_success, cmifInvoiceList.myInvoice.sequenceNum.String), app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
					else
						app.msgBox( app.getErrorString2(Credit_note_ext_create_success, cmifInvoiceList.myInvoice.sequenceNum.String, cmifInvoiceList.myInvoice.externalNumber), app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
					endif;
				else
					if cmifInvoiceList.myInvoice.externalNumber = null then
						app.msgBox( app.getErrorString1(Invoice_created_successful, cmifInvoiceList.myInvoice.sequenceNum.String), app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
					else
						app.msgBox( app.getErrorString2(Invoice_ext_created_successful, cmifInvoiceList.myInvoice.sequenceNum.String, cmifInvoiceList.myInvoice.externalNumber), app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
					endif;
				endif;
				//END navtnr20 05-06-2023 BUG 58389
				self.clearErrorWarnings();
				global.beep;
				break;
				
			else
				theReturn := app.showErrorWarningDialog(app.getErrorString(CM_Manual_Invoice), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				return false;
			endif;
			break;
		endwhile;		
		return true;
	endif;*/

	localCaption := self.caption;
	//set up the silent deadlock handler to attempt to retry
	app.myPassport.setupForDeadlockReplay(220, 3000);
	app.myPassport.silentDeadlockLimit := 10;	
	
	
	while true do
	
		
		//call the code that was originally in this method
		while true do
			app.myTrxCA.trxCopyInvoiceList(cmifInvoiceList, app.myPassport);
			
			if app.myPassport.hadDeadlock then //jlier1 4/11/25 break to deadlock loop
				break;
			endif;
			
			if app.myPassport.trxCompletedOK then
				// Clear errors/warnings from form and err/warnings window
				// START //navtnr20 05-06-2023 BUG 58389
				if cmifInvoiceList.myInvoice.isCreditNote() then
					if cmifInvoiceList.myInvoice.externalNumber = null then	//navtnr20 05-06-2023 BUG 58389
						app.msgBox( app.getErrorString1(Credit_note_create_success, cmifInvoiceList.myInvoice.sequenceNum.String), app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
					else
						app.msgBox( app.getErrorString2(Credit_note_ext_create_success, cmifInvoiceList.myInvoice.sequenceNum.String, cmifInvoiceList.myInvoice.externalNumber), app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
					endif;
				else
					if cmifInvoiceList.myInvoice.externalNumber = null then
						app.msgBox( app.getErrorString1(Invoice_created_successful, cmifInvoiceList.myInvoice.sequenceNum.String), app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
					else
						app.msgBox( app.getErrorString2(Invoice_ext_created_successful, cmifInvoiceList.myInvoice.sequenceNum.String, cmifInvoiceList.myInvoice.externalNumber), app.getErrorString(Information) , MsgBox_OK_Only + MsgBox_Information_Icon);
					endif;
				endif;
				//END navtnr20 05-06-2023 BUG 58389
				self.clearErrorWarnings();
				global.beep;
				break;
				
			else
				theReturn := app.showErrorWarningDialog(app.getErrorString(CM_Manual_Invoice), app.myPassport, ErrWarnMode_AddUpdate + ErrWarnMode_CanAckWarnings);
				if app.myPassport.noErrors and
				   theReturn = IDOK then
					// there must have just been warnings that the user has acknoledged so ..
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
				self.setAllErrorWarnings(app.myPassport);	// copies errors to this form and shows in err/warnings window
				return false;
			endif;
			break;
		endwhile;	
		
		
		//if we did not have a deadlock or reached retry limit break
		if app.myPassport.noTrxReplayAllowed() then	
			if app.myPassport.hadDeadlock then //had a deadlock and reached the limit show the deadlock error
				app.showErrorWarningDialog(app.getErrorString(CM_Manual_Invoice), app.myPassport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			endif;
			break;
		endif;
		
		self.updateCaptionDeadlockRetry(localCaption);
	endwhile;

	return true;
epilog

	//set the silent deadlock handler back to the default values i.e. OFF
	app.myPassport.resetSilentDeadlockHandler;   //7/3/25 navsaa30 #14818
	self.caption := localCaption;
	self.mousePointer := Window.MousePointer_Default;
end;</source>
        <Parameter name="_cmifInvoiceList" type="CMIF_InvoiceCopy"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="invTypeClick" id="b92d4e47-2f50-4b4f-adbf-2dd890a4517d">
        <updating/>
        <source>invTypeClick(combobox: ComboBox input) protected, updating;
/*

Purpose:

Parameters:

Return Value:

Date		  Who		Reason 
24 April 2023 navmk20 	Bug 57663: EUP - Incorrect Statuses Available when copying an invoice
06 June 2023  navmv20   Bug 58388: EUP - Copy Posted Invoices	
*/

vars 
	invoiceProcess	: CM_InvoiceProcess;
	invoiceStatus	: String;
begin
	inheritMethod(combobox); 
	
	invoiceProcess := self.myCurrentInvoice.myInvoiceProcess;
	invoiceStatus  := app.getInvoiceStatusString(invoiceProcess, self.myCurrentInvoice.status);
	
	//06/06/2023 navmv20 Bug 58388 - start
	if self.myCurrentInvoice.status = CM_Invoice.INVOICE_POSTED
	or self.myCurrentInvoice.status = CM_Invoice.INVOICE_POSTED_DRAFT then // ### JIRA 35468 31JUL2025 NAVAB1
		invoiceStatus  := app.getInvoiceStatusString(invoiceProcess, CM_Invoice.INVOICE_OPEN);
	endif;
	//06/06/2023 navmv20 Bug 58388 - end
		
	self.cmbStatusInvProp.listIndex	:= self.cmbStatusInvProp.findStringExact(1, invoiceStatus);
	self.tblInvProperties.setValueByControlName(self.cmbStatusInvProp.name, invoiceStatus);

epilog 

end;</source>
        <access>protected</access>
        <Parameter name="combobox" type="ComboBox" usage="input"/>
    </JadeMethod>
