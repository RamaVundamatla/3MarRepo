    <JadeMethod name="opsViewCreateRequest" id="66ec49a4-75d4-4f93-9cf0-4057cf45b9b8">
        <source>opsViewCreateRequest();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice
*/

vars
	wle 		: CM_WorkListEntry;
