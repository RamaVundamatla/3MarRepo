    <JadeMethod name="setControlsForAddEdit" id="58ad7f94-ce42-49e1-ae29-1bd583e91c97">
        <updating/>
        <source>setControlsForAddEdit() updating;
// ---------------------------------------------------------------------------
// Created:      12 May 2003 by cnwsgp1
// ---------------------------------------------------------------------------
// 19/06/2013	cnwcs5	par 31657 - tidy up while fixing par

vars
	form 		: SOP_TableMaintForm;
	table		: CM_EntryTable;
	trxType		: CM_TransactionType;
	nextType	: Integer;
	transactionType : String;
begin
  	form 	:= self.myForm;
	table	:= form.tblInput1;
	
	if form.mode = form.Mode_Add then
		table.clearValues;
		form.fldInput.initSheetBackColors();	

		trxType := app.myRoot.allTransactionTypes.last;
		
		if trxType &lt;&gt; null then
			nextType := trxType.trxType;
		endif;
		
		nextType := (TransactionTypeJMTMax + 1).max(nextType) + 1;
		
		table.setValueByName(ETRow_TrxType, nextType);
		table.enableRowByName(ETRow_TranTypeGroup);// ### TFS CR 60699 TASK 60700 27SEP2023 NAVAB1
		self.setupComboTranTypeGroup(null);
	else
		trxType := form.myProxyObject.CM_TransactionType; // ### TFS CR 60699 TASK 60700 27SEP2023 NAVAB1
		// refresh the data from the newly created proxy
		self.showThumbnail(form.myProxyObject.CM_TransactionType);
		
		// cannot edit the following fields
		table.disableRowByName(ETRow_TranTypeGroup); // ### TFS CR 60699 TASK 60700 27SEP2023 NAVAB1
		
		// ### TFS CR 60699 TASK 60700 27SEP2023 NAVAB1
		transactionType := app.transactionTypeEnumToString(trxType.trxGroup);
		table.setValueByName(ETRow_TranTypeGroup, transactionType);
		self.setupComboTranTypeClass(transactionType,  trxType.classNameToCreate);
		table.setValueByName(ETRow_TranTypeClass, trxType.classNameToCreate);
	endif;

	
	table.userInputEnabled := true;
	table.cnEcResizeContents();

	table.moveFirst();
	table.setFocus;
end;</source>
    </JadeMethod>
    <JadeMethod name="setCtrlsForView" id="42418fdc-5f93-4266-b337-4edde6659263">
        <updating/>
        <source>setCtrlsForView()updating;
// ---------------------------------------------------------------------------
// Created:      12 May 2003 by cnwsgp1
