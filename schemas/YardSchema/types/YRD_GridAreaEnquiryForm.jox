    <JadeMethod name="mnuGridSelectAreas_click" id="b43e969f-e069-4f96-984b-b3d27e41cea0">
        <controlMethod name="MenuItem::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>mnuGridSelectAreas_click(menuItem: MenuItem input) updating;
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aForm 	: Form;
	menuAction 		: CMUI_MenuAction;
	theLC : CM_LocationsController;
	theTI : CM_TrackedItem;
begin
	menuAction := app.myController.createMenuAction(PmYardAreaView, null, self.myMasterMenuAction, self.myTerminal);
	if menuAction = null then
		return;
	endif;
	aForm := menuAction.goToObject(null, null, false, null); 
	if aForm = null then
		return;
	endif;
	
	if menuItem.userObject.isKindOf(CM_LocationsController) then
		theLC := menuItem.userObject.CM_LocationsController;
	else
		theTI := menuItem.userObject.CM_TrackedItem;
		if self.myCurrentDrawingController.displayMode = DISPLAY_MODE_ACTUAL then
			theLC := theTI.myPrimaryActualLocation;
		elseif self.myCurrentDrawingController.displayMode = DISPLAY_MODE_QUEUE then
			theLC := theTI.myPrimaryQueuedLocation;
		elseif self.myCurrentDrawingController.displayMode = DISPLAY_MODE_PLAN then
			theLC := theTI.myPrimaryPlannedLocation;
		endif;
	endif;

	
	aForm.sendMsgWithParams("doInitializeWithTI",theLC.myTerminalArea,theLC,theTI);
	aForm.show;	
end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="mnuGridSelectorClear_click" id="4f48fb2a-636d-4674-b14f-b62f6cd16bce">
