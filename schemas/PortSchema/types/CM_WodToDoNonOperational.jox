    <JadeMethod name="prepareAuditDetail" id="789d9506-2c5c-4ead-bc5d-1688833d9c1e">
        <source>prepareAuditDetail(_str : String io);
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
06 April 2023	navhl20	ChangeRequest 57301:[57303] EUP - [Framework] - Improve Audits on Work orders
21/04/2023		navcs2	Bug 57691: MTN - WO - Audits are missing for the totalActioned
*/

vars
	tmpStr	 	: String;
	debtor		: CM_Debtor;
begin
	inheritMethod(_str);
	tmpStr := null;
	if self.allDebtors.isNotEmpty then
		foreach debtor in self.allDebtors do
			if tmpStr = null then
				tmpStr := debtor.name;
			else
				tmpStr :=tmpStr &amp; Comma &amp; debtor.name;
			endif;
		endforeach;
		_str := _str &amp; app.getErrorString(Debtors) &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	
	// 21/04/2023 navcs2 Bug 57691 Start
	tmpStr := null;
	if self.allDebtorsActioned.isNotEmpty then
		tmpStr := self.allDebtorsActioned.size.String;
		_str := _str &amp; "Number Actioned" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	else
		tmpStr := 0.String;
		_str := _str &amp; "Number Actioned" &amp; AuditStringSeparator &amp; tmpStr.length.String &amp; AuditStringSeparator &amp;tmpStr &amp; AuditStringSeparator;
	endif;
	// 21/04/2023 navcs2 Bug 57691 End
epilog

end;</source>
        <Parameter name="_str" type="String" usage="io"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="ac5cdbbb-025b-4c48-bede-9109fb850b8a">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
19 December 2022	navcs2	ChangeRequest 56632:[56057] EUP - VAS Non Operational Work Order

*/

vars
	pxy 			: SelfType;
	completedOK		: Boolean;
begin
	pxy := inheritMethod();
	
	self.allDebtors.copy(pxy.allDebtors);
	self.allDebtorsActioned.copy(pxy.allDebtorsActioned);
	self.allDebtorsCompleted.copy(pxy.allDebtorsCompleted);

	completedOK := true;
	return pxy;
	
epilog
	if not completedOK then
		delete pxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="ee2285e0-7de4-4ae0-9c20-c8d4e0e0c68b">
        <updating/>
        <source>setForUpdate(_pxyWoDDtl: CM_WodToDoNonOperational) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
03 October 2022	navcs2	ChangeRequest 54344: EUP - VAS Work Orders - Jobs
20 Mar 2023  	navhl20 Defect 57233: MTN - Editing Vas Tasks is not working correctly
*/

vars

begin
	
	inheritMethod(_pxyWoDDtl);
	self.allDebtors.clear();																	//20.3.2023 navhl20	#57233
	_pxyWoDDtl.CM_WodToDoNonOperational.allDebtors.copyNoDuplicates(self.allDebtors, false);

epilog

end;</source>
        <Parameter name="_pxyWoDDtl" type="CM_WodToDoNonOperational"/>
    </JadeMethod>
    <JadeMethod name="setProxyToDo" id="a62cd455-dab1-4464-aeb3-066583e5229c">
        <updating/>
        <source>setProxyToDo(_allSelectedEntities	: Any) updating;
/*

Purpose:			

Parameters:			

