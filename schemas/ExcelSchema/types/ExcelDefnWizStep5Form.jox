/*****************************************************
	Written by	:	cnwpra1		09 May 2004
	Description	:	

	Change history
	--------------
	Date		By		Reason
******************************************************/

vars

begin
	myDA.setBlnLoadTestData(chkLoadTestData.value);

epilog

end;</source>
    </JadeMethod>
