    <JadeMethod name="setProxyWodUnpack" id="188aa7ac-630f-4fab-9ff3-fdb70f5f3b2d">
        <updating/>
        <source>setProxyWodUnpack(_unpackLocation : CM_TerminalArea) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
17 Aug 2009	cnwmd1	Initial creation
10 Sep 2021 navma1  ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
*/

vars
	unpackLocation  : CM_LocationsController;
begin
	if _unpackLocation &lt;&gt; null then
		unpackLocation 			:= _unpackLocation.getMyLocationsController();
		self.myUnpackToLocation := unpackLocation;
	endif;

epilog

end;</source>
        <Parameter name="_unpackLocation" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="updateStatus" id="cfc281bf-eb4e-457f-b051-ca9fdf0e03d3">
        <updating/>
        <source>updateStatus()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 Jul 2024 navhl20	ChangeRequest 64969: EUP | 53856 - New Scanning App - Unpack mode issue

*/

vars
	job 	: CM_Job;
begin
	if not app.myPassport.isVASEnabled then
		return;
	endif;
	
	job := self.allJobs.first;
	
	if job &lt;&gt; null then
		if (job.getTotalQuantity() - job.getRemainingQuantity().Integer) &gt; 0 then
			self.setStatus(WO_STATUS_PARTCOMPLETE);	
			self.myParent.setTaskStatus(WO_STATUS_PARTCOMPLETE);
		endif;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validate" id="5d9dcb3f-1abb-416f-b146-8d3b0ad9b1f5">
        <source>validate() protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 Aug 2009	cnwmd1	Initial creation
10 Sep 2021 navma1  ChangeRequest 51002: MTN - Web Portal Cargo Work Orders
12 Jan 2023	navma1  ChangeRequest 56141: EUP - Refactor and Remove CM_WorkOrderTISource from CM_WorkOrderTI
08 Feb 2023 navma1  ChangeRequest 56457:[56458] EUP - [Refactor] - Allowing different sets of cargo items per work order task
*/

vars
	ti : CM_TrackedItem;
begin
	inheritMethod();
	
	if self.myUnpackToLocation = null then
		app.raiseCMException1(Input_required_field_Required, app.getErrorString(Unpack_location), null, null); 
	endif;
	
	
	if not self.myParent.hasBeenApproved then												//06.03.2023 navma1 #56457:[56458]
		foreach ti in self.allSelectedTIs do												//08.02.2023 navma1 #56457:[56458]
			if not ti.isKindOf(CM_Container) and ti.hasChildren = false then
				app.raiseCMException(Parent_cargo_must_packab_conta, null, null);
			endif;
		endforeach;

		if self.myUnpackToLocation &lt;&gt; null then												//06.03.2023 navma1 #56457:[56458]
			ti := self.allSelectedTIs.first;
			if ti &lt;&gt; null then
				if ti.myPrimaryActualLocation = self.myUnpackToLocation then
					app.raiseCMException2(ERR_ALREADY_HERE, ti.id, self.myUnpackToLocation.ident,null, null); 
				endif;
			endif;
		endif;
	endif;
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
