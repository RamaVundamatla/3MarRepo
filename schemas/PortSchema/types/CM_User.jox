    <JadeMethod name="setForCreate" id="50b2a235-bacc-49ba-9212-f604443d6ffe">
        <updating/>
        <source>setForCreate(_proxy : CM_User) updating;
// ---------------------------------------------------------------------------
// Created:			09 April 2001 by cnwdwq1
// Purpose:			!     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------	----------		--------------------------------------------------
// 10/09/2008	concms1			par 17903/ccms 1741 Welcome form - interim solution
// 19/12/2018	jlgdap1			TFS 42542 PEl1 Freight Forwarder Access and Visibility
// 05/08/2021	navmd1			TFS 51226 Allow users with permission to force off old sessions
// 04 Feb 2025	navah1			Story 14660: MTN - New option to disable users from changing their own passwords
// 10 Nov 2025	navlw1			JIRA-36369: Add a new status “PENDING” for users and use this status for new imported users
// 05 Dec 2025  navlc30         JIRA 36748 CUX - Enforce SSO Login
// ---------------------------------------------------------------------------
vars
	realUT,
	pxyUT	: CM_UserTerminal;

begin

	// This method should be used only to update persistents
	self.raiseExceptionIfTransient(method);
	if not _proxy.isTransient then
		self.raiseExceptionIfNotTransient(method);
		return;
	endif;
	self.code := _proxy.code.toUpper.trimBlanks;
	self.dateCreated := app.serverTimestampAtTrxStart;	//This is always NOW
	self.isNotAvailableForEntry := _proxy.isNotAvailableForEntry;
	self.isNewEncryptionImplemented := true;
	
	self.mySystemSecurityRole := _proxy.mySystemSecurityRole;
	if self.mySystemSecurityRole = null then
		delete self.myMenuRootForSysEntities;
	else
		self.createMenuRootForSysEntities();
	endif;
	
	self.myOrganisation := _proxy.myOrganisation;
	self.myRoot := _proxy.myRoot;
	
	self.numberOfFailedLogons := 0;
	self.persistentPassword := _proxy.persistentPassword;
	self.radioTelemetryDevice := _proxy.radioTelemetryDevice;
	self.preventPasswordChange := _proxy.preventPasswordChange; //04.02.2025 navah1 #14660
	//self.radioTelemetryOnly := _proxy.radioTelemetryOnly;		//GD removed dummy checkbox OCT01
	//PAR16595 cnwsh3 29/5/2008 - allow users to set the status for new users, not just a NewUser setting.  This is to accommodate mobile
	//app users and CE sign ons as they don't have the facility to be able to change their password at first sign on.
	//self.status := NewUser;
	self.status :=  _proxy.status;
	self.userName := _proxy.userName;
	self.myLocale := _proxy.myLocale;
	self.allowAutomaticDisability := _proxy.allowAutomaticDisability;	// cnwvu1	20/11/2006	ccms1051
	self.setShowWelcomeScreen (_proxy.getShowWelcomeScreen);			// par17903
	self.ssoMatchingId		:= _proxy.ssoMatchingId; // navlw1 10/11/2025 JIRA-36369 
	self.ssoAllowLocalLogin := _proxy.ssoAllowLocalLogin;				//05.12.2025 navlc30 #36748	
	
	//-------------------
	//Update the collections
	//-------------------
	_proxy.allDataAccessControllers.copy(self.allDataAccessControllers);
//	_proxy.allSecurityRoles.copy(self.allSecurityRoles);

	// Update/create user terminals
	foreach pxyUT in _proxy.allUserTerminals do
	 	create realUT persistent;
	 	realUT.setForCreate(pxyUT, self);
	endforeach;

	self.myEmailEntity := _proxy.myEmailEntity;
	
	self.allEmailsICanSee.clear();
	_proxy.allEmailsICanSee.copy(self.allEmailsICanSee);
	
	_proxy.allSystemAlertTypes.copy(self.allSystemAlertTypes);
	_proxy.allEventTypes.copy(self.allEventTypes);	
	
	if self.code &lt;&gt; SUPERUSER_Str then //when createing SUPERUSER in MT db
		self.resetSysEntMenuFromJMTDefault(true);
		self.resetToolbarMenuFromJMTDefault();
	endif;
	//Par 4759
	app.myUtilityUA.utlUpdateUserStateData(self, ConfigGrp_Gate, UserSaveSettingsOnExit, true);

	// default to show the navigator on create
	app.myUtilityUA.utlUpdateUserStateData(self, ConfigGrp_Gate, UserNavigatorWindow, true);

	app.myUtilityUA.utlUpdateUserStateData(self, ConfigGrp_System, UserSingleSignOnOnly, _proxy.getUserSingleSignOnOnly); //+ cnwmd1 Par 22287
	app.myUtilityUA.utlUpdateUserStateData(self, ConfigGrp_System, UserSingleSignOnAllowOverride, _proxy.getUserSingleSignAllowOverride); // TFS 51226
	
	app.myUtilityUA.utlUpdateUserStateData(self, ConfigGrp_ExtraData, UserIsFreightForwarder, _proxy.getUserIsFreightForwarder);	// TFS 42542 
end;</source>
        <Parameter name="_proxy" type="CM_User"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="512002b2-0aeb-4601-975f-d0c569e6e6f6">
        <updating/>
        <source>setForUpdate(_proxy : CM_User) updating;
// ---------------------------------------------------------------------------
// Created:			10 April 2001 by cnwdwq1
// Purpose:			!     
// Parameters:	None
// Returns:			Nothing
// Changed On	Changed By		Reason
// ----------	----------		--------------------------------------------------
// 10/09/2008	concms1			par 17903/ccms 1741
// 19/12/2018	jlgdap1			TFS 42542 PEL1 Freight Forwarder Access and Visibility
// 05/08/2021	navmd1			TFS 51226 Allow users with permission to force off old sessions
// 04 Feb 2025	navah1			Story 14660: MTN - New option to disable users from changing their own passwords
// 05 Dec 2025  navlc30         JIRA 36748 CUX - Enforce SSO Login
// ---------------------------------------------------------------------------
vars
	realUT,
	pxyUT	: CM_UserTerminal;
	deleteSet	: ObjectSet;
	tmpEdition	: Integer;

begin

	// This method should be used only to update persistents
	self.raiseExceptionIfTransient(method);
	if not _proxy.isTransient then
		self.raiseExceptionIfNotTransient(method);
		return;
	endif;
	
	self.persistentPassword := _proxy.persistentPassword;
	self.radioTelemetryDevice := _proxy.radioTelemetryDevice;
	self.isNotAvailableForEntry := _proxy.isNotAvailableForEntry;
	//self.radioTelemetryOnly := _proxy.radioTelemetryOnly;		//GD removed dummy checkbox OCT01
	self.status 			:= _proxy.status;
	self.userName 			:= _proxy.userName;
	self.myLocale           := _proxy.myLocale;
	self.ssoMatchingId		:= _proxy.ssoMatchingId; 	//20.07.2022 navam1 #52824
	self.ssoUniqueId		:= _proxy.ssoUniqueId;		//20.07.2022 navam1 #52824
	self.preventPasswordChange	:= _proxy.preventPasswordChange; //04.02.2025 navah1 #14660
	self.mySystemSecurityRole := _proxy.mySystemSecurityRole;
	if self.mySystemSecurityRole = null then
		delete self.myMenuRootForSysEntities;
	else
		self.createMenuRootForSysEntities();
	endif;
	
	self.myOrganisation 	:= _proxy.myOrganisation;
	self.allowAutomaticDisability:= _proxy.allowAutomaticDisability;	// cnwvu1	20/11/2006	ccms1051
	self.lastLoginTS			 := _proxy.lastLoginTS;					// cnwvu1	20/11/2006	ccms1051

	self.setShowWelcomeScreen (_proxy.getShowWelcomeScreen);			// par17903
	self.ssoAllowLocalLogin := _proxy.ssoAllowLocalLogin;				//05.12.2025 navlc30 #36748	
	
	//-------------------
	//Update the collections
	//-------------------
	self.allDataAccessControllers.clear;
	_proxy.allDataAccessControllers.copy(self.allDataAccessControllers);
	
	foreach realUT in self.allUserTerminals do
		if _proxy.allUserTerminals[realUT.getRealTerminal] = null then
			// This user-terminal has been deleted
			if deleteSet = null then
				create deleteSet transient;
			endif;
			deleteSet.add(realUT);
		endif;
	endforeach;
	
	if deleteSet &lt;&gt; null then
		deleteSet.purge;
	endif;
	
	// Update/create user terminals
	foreach pxyUT in _proxy.allUserTerminals do
		 pxyUT.pxyGetRealObjectAndEdition(realUT, tmpEdition);
		 if realUT = null then
		 	// must be a create
		 	create realUT persistent;
		 	realUT.setForCreate(pxyUT, self);
		 else
		 	realUT.setForUpdate(pxyUT);
		 endif;
	endforeach;
	self.myEmailEntity := _proxy.myEmailEntity;
	
	self.allEmailsICanSee.clear();
	_proxy.allEmailsICanSee.copy(self.allEmailsICanSee);
	
	self.allSystemAlertTypes.clear;
	_proxy.allSystemAlertTypes.copy(self.allSystemAlertTypes);
	
	self.allEventTypes.clear;
	_proxy.allEventTypes.copy(self.allEventTypes);
	
	self.checkReportMenuAgainstSecurity();
	self.checkMenuNavAgainstSecurity();
	self.checkSysMenuAgainstPermissions(false);
	
	app.myUtilityUA.utlUpdateUserStateData(self, ConfigGrp_System, UserSingleSignOnOnly, _proxy.getUserSingleSignOnOnly); //+ cnwmd1 Par 22287
	app.myUtilityUA.utlUpdateUserStateData(self, ConfigGrp_System, UserSingleSignOnAllowOverride, _proxy.getUserSingleSignAllowOverride); // TFS 51226
	app.myUtilityUA.utlUpdateUserStateData(self, ConfigGrp_ExtraData, UserIsFreightForwarder, _proxy.getUserIsFreightForwarder);	// TFS 42542
	app.myUtilityUA.utlUpdateUserStateData(self, ConfigGrp_System, UserSSOMatchingId, _proxy.ssoMatchingId); //20.07.2022 navam1 #52824
	app.myUtilityUA.utlUpdateUserStateData(self, ConfigGrp_System, UserSSOUniqueId, _proxy.ssoUniqueId); //20.07.2022 navam1 #52824

epilog
	delete deleteSet;
end;</source>
        <Parameter name="_proxy" type="CM_User"/>
    </JadeMethod>
