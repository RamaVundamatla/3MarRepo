    <JadeMethod name="keyDown" id="1ad31a56-35a0-431e-a13d-1ed0fc740b60">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
//--------------------------------------------------------------
//Created: 11 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars	

begin

	if self.fldMain.topSheet = self.shtItemDetails then
		self.handleTableTab(keyCode, shift);
	endif;		

	inheritMethod(keyCode, shift);

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="loadOutItemOption" id="c0bda3fd-a4ea-4a35-af21-d4b894e2b172">
        <updating/>
        <source>loadOutItemOption()updating;
//--------------------------------------------------------------
//Created: 10 June 2002 By: cnwgd1
//--------------------------------------------------------------
vars

begin

	self.shtLocationDtls.visible := false;
	self.shtNoNumbers.visible := false;	
	self.shtItemDetails.visible := true;
	self.fldMain.topSheet := self.shtItemDetails;
	self.myAssistant.LOG_Assistant.comboBoxUnitOfMeasure(self.tblHeaderDtls, ETRow_UnitOfMeasure, true);
	self.tblHeaderDtls.setValueByName(ETRow_UnitOfMeasure, BOL_UOM_PIECE_COUNT);
			
	self.resizeShtItemDetail();
	self.tbRequired.text := self.tblHeaderDtls.getValueByName(ETRow_Quantity).String;
	self.calculateItems();	
		
end;</source>
    </JadeMethod>
    <JadeMethod name="loadOutLocnOption" id="e7f3b724-07de-461c-888e-34d976042d52">
