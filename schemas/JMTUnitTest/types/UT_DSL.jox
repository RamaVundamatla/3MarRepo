    <JadeMethod name="machineRejectTask" id="e1cebc99-9dbb-4279-bde4-29caf5082066">
        <source>machineRejectTask(_machine: CM_Machine; _task :CM_RTQueueTask) protected;
//07 January 2009	cnwdw1	
//14 November 2012	cnwcs5	Add task parameter
vars
	mediator : CM_RadioTelemetryMediator;
begin
	create mediator transient;
	
	mediator.machine := _machine;
	
	if _task &lt;&gt; null then
		mediator.task := _task;
	else
		mediator.task := _machine.currentQueueTask;
	endif;
	
	app.myTrxRT.trxRejectTask(mediator, null, app.myPassport);
	
	self.assertNoTrxErrorsOrWarnings();
epilog
	delete mediator;
end;</source>
