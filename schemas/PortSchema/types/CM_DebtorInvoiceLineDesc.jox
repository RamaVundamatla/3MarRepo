    <JadeMethod name="setForUpdate" id="0e3cee70-d0b9-4d0a-9985-153ad9e3851f">
        <updating/>
        <source>setForUpdate(pProxyInvoiceLineDesc : CM_DebtorInvoiceLineDesc) updating;
//_bank : CM_Bank input; _debtors : Collection; _invLineDescs : CM_InvoiceLineDescByNarrDict; _narr : String; _remarks : String) updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//31 Jan 2023 	navvt20  TFS 56132 Task 56134: UI - Invoice Line Type - UOM
// ---------------------------------------------------------------------------

vars
	anILD, aDILDtmp : CM_InvoiceLineDesc;
	anObject, aObject : Object;
	aDebtor : CM_Debtor;
	aDILD : SelfType;
	
begin
	self.myBankDebtor := pProxyInvoiceLineDesc.myBankDebtor;
	self.myUOM	      := pProxyInvoiceLineDesc.myUOM; // 31 Jan 2023 navvt20 TFS 56134
	self.allConsolidatingDebtor.clear;
	
	foreach anObject in self.allConsolidatingInvLineDesc do
		anObject.CM_InvoiceLineDesc.removeMyDebtorInvLineDesc(self);
	endforeach;

	
	foreach anObject in pProxyInvoiceLineDesc.allConsolidatingInvLineDesc do
		anObject.CM_InvoiceLineDesc.setMyDebtorInvLineDesc(self);
	endforeach;
	
	pProxyInvoiceLineDesc.allConsolidatingInvLineDesc.copy(self.allConsolidatingDebtor);

	// The invoice lines (ILD) can be part of many debtor Invoice Lines (DILD), BUT can only be consolidated for  debtors in 1 debtor invoice line (DILD)
	// i.e. ILD 'FRED" can be part of DILD 'RED" and DILD 'BLUE'. RED and BLUE also have a collection of debtors. 
	//		If DILD RED has debtor SQUARE, we cannot have debtor square as part of DILD BLUE.
	//		Basically there is a many to many ILD to DILD, but the ILD has a 1 to many relationship with the debtors used by the DILD.
	//		I tried to change the collection to be an ExtKeyDict but it would not let me so we have this horrible code to remove a debtors from this DILD
	//			if the debtor is used by a DILD that also has this ILD
	foreach aDebtor in self.allConsolidatingDebtor do
		foreach anILD in allConsolidatingInvLineDesc do
			foreach aDILDtmp in anILD.allConsolidatedDebtorInvLineD do
				aDILD := aDILDtmp.CM_DebtorInvoiceLineDesc;
				if aDILD &lt;&gt; self then
					if aDILD.allConsolidatingDebtor.includes(aDebtor) then
						self.allConsolidatingDebtor.removeIfPresent(aDebtor);
					endif;
				endif;
			endforeach;
		endforeach;
	endforeach;
	

	self.narration := null;
	self.narration := pProxyInvoiceLineDesc.narration;
	self.remarks := pProxyInvoiceLineDesc.remarks;
end;</source>
        <Parameter name="pProxyInvoiceLineDesc" type="CM_DebtorInvoiceLineDesc"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateCMS" id="deb31f1d-56fc-4c41-9fe5-de8ebb46af01">
        <updating/>
        <source>setForUpdateCMS(_bank : CM_Bank input; _debtors : Collection; _invLineDescs : CM_InvoiceLineDescByNarrDict; _narr : String; _remarks : String) updating;
// ---------------------------------------------------------------------------
// Created:		March 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	anILD : CM_InvoiceLineDesc;
	anObject : Object;
begin
	self.myBankDebtor := _bank;
	self.allConsolidatingDebtor.clear;
	
	_debtors.copy(self.allConsolidatingDebtor);

	foreach anObject in self.allConsolidatingInvLineDesc do // PAR 8899
		anObject.CM_InvoiceLineDesc.removeMyDebtorInvLineDesc(self);// PAR 8899
	endforeach;
	
	foreach anObject in _invLineDescs do
		anObject.CM_InvoiceLineDesc.setMyDebtorInvLineDesc(self);
	endforeach;
	self.narration := null;
	self.narration := _narr;
	self.remarks := _remarks;
end;</source>
        <Parameter name="_bank" type="CM_Bank" usage="input"/>
        <Parameter name="_debtors" type="Collection"/>
        <Parameter name="_invLineDescs" type="CM_InvoiceLineDescByNarrDict"/>
        <Parameter name="_narr" type="String"/>
        <Parameter name="_remarks" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateController" id="3c4b8739-aca9-40d2-8c0d-0b8391bfcf56">
        <updating/>
        <source>setForUpdateController(_theController : CMIF_InvoiceLineDescDebtor) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
// 28 Oct 2021 navma1 ChangeRequest 52163: SAL - Unicode Arabic Support Business Requirements
// ---------------------------------------------------------------------------

vars

	aLine : CM_InvoiceLineDesc;
begin
	self.narration := _theController.myProxyInvoiceLineDebtor.narration;		//[1:60]; //28.10.2021 navma1 #52163
	self.remarks   := _theController.myProxyInvoiceLineDebtor.remarks[1:601];
	
	foreach aLine in self.allConsolidatingInvLineDesc do
		aLine.removeMyDebtorInvLineDesc(self);// PAR 8899
	endforeach;
	
	foreach aLine in _theController.allInvoiceLineDescriptions do
		aLine.setMyDebtorInvLineDesc(self);
	endforeach;

	self.allConsolidatingDebtor.clear;
	_theController.allConsolidatingDebtor.copy(self.allConsolidatingDebtor);

	self.validateMe();

end;</source>
        <Parameter name="_theController" type="CMIF_InvoiceLineDescDebtor"/>
    </JadeMethod>
    <JadeMethod name="setProxy" id="62e731b6-fd09-43e8-b4ba-9ddf21851dc2">
        <updating/>
        <source>setProxy(_bOneLinePerFinancialPeriod: Boolean; _bPrintTrackedItems: Boolean; _chargeByOpCon: Integer; _chargeDebtorType : CM_DebtorType; _calculationType : CM_CalculationType; 
		_invoiceType: CM_InvoiceDesc; _narration: String; _printingOrder: Integer; _remarks: String; 
		_unitNarration: String; _services: CM_ServiceByNameDict; _notAvailableForEntry : Boolean;
		_minimumCharge : Real; _minimumChargeGroupBy : String; _minimumChargeType : String; _currNot : Boolean;	// PAR #36909
		_taxAlwaysCharged : Boolean;	//07 May 2019	NDL	TFS 44651
		_externalRef1 : String;
		_uom		  : CM_InvoiceUnitOfMeasure // 31 Jan 2023 navvt20 TFS 56134
			) updating;
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// Changed On	By			Reason
// ----------	--------	--------------------------------------------------
// 17/09/2015	cnwdap1		PAR #36909 CCMS ADP 2537 Minimum Charge changes - new signature
// 31 Jan 2023 	navvt20  TFS 56132 Task 56134: UI - Invoice Line Type - UOM
vars

begin
	inheritMethod(_bOneLinePerFinancialPeriod, _bPrintTrackedItems, _chargeByOpCon, _chargeDebtorType, _calculationType,
				  _invoiceType, _narration, _printingOrder, _remarks, _unitNarration, _services, _notAvailableForEntry,
				  _minimumCharge, _minimumChargeGroupBy, _minimumChargeType, _currNot,					// PAR #36909
				  _taxAlwaysCharged,_externalRef1,	//07 May 2019	NDL	TFS 44651
				  _uom); // 31 Jan 2023 navvt20 TFS 56134

end;</source>
        <Parameter name="_bOneLinePerFinancialPeriod" type="Boolean"/>
        <Parameter name="_bPrintTrackedItems" type="Boolean"/>
        <Parameter name="_chargeByOpCon" type="Integer"/>
        <Parameter name="_chargeDebtorType" type="CM_DebtorType"/>
        <Parameter name="_calculationType" type="CM_CalculationType"/>
        <Parameter name="_invoiceType" type="CM_InvoiceDesc"/>
        <Parameter name="_narration" type="String"/>
        <Parameter name="_printingOrder" type="Integer"/>
        <Parameter name="_remarks" type="String"/>
        <Parameter name="_unitNarration" type="String"/>
        <Parameter name="_services" type="CM_ServiceByNameDict"/>
        <Parameter name="_notAvailableForEntry" type="Boolean"/>
        <Parameter name="_minimumCharge" type="Real"/>
        <Parameter name="_minimumChargeGroupBy" type="String"/>
        <Parameter name="_minimumChargeType" type="String"/>
        <Parameter name="_currNot" type="Boolean"/>
        <Parameter name="_taxAlwaysCharged" type="Boolean"/>
        <Parameter name="_externalRef1" type="String"/>
        <Parameter name="_uom" type="CM_InvoiceUnitOfMeasure"/>
    </JadeMethod>
