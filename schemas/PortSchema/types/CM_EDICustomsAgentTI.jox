    <JadeMethod name="createProxy" id="d87c829e-941e-4f27-be95-85966712fb15">
        <source>createProxy() : CM_CustomsAgent;
/*

Date		Who		Reason
28 November 2014	cnwer1	Initial creation PAR 35304

*/

vars
	real,
	proxy 	: CM_CustomsAgent;
begin
	if self.action = self.EDI_ACTION_ADD then
		create proxy transient;
	else
		real:=self.getCustomsAgent();
		if real = null then
			return null;
		endif;
		
		proxy:=real.pxyCreateUpdateProxy.CM_CustomsAgent;

	endif;
	
	proxy.setProxy(self.code,self.name,self.notAvailable.asBooleanJMT,self.getDebtor);
	
	return proxy;
epilog
	

end;</source>
        <ReturnType type="CM_CustomsAgent"/>
    </JadeMethod>
    <JadeMethod name="getCustomsAgent" id="b0b22559-aa7d-4974-a999-897e4f76b30e">
        <source>getCustomsAgent() : CM_CustomsAgent;
/*

Date		Who		Reason
28 November 2014	cnwer1	Initial creation PAR 35304

*/

vars

begin

	return app.myRoot.allCustomsAgents[self.code];
epilog

end;</source>
        <ReturnType type="CM_CustomsAgent"/>
    </JadeMethod>
    <JadeMethod name="getDebtor" id="d8d8fd98-39d6-4c5f-9df5-bc67d4977624">
        <source>getDebtor() : CM_Debtor;
/*

Date		Who		Reason
27 November 2014	cnwer1	Initial creation PAR 35304

*/

vars

begin
	return app.myRoot.myRootCompany.debtors[self.debtorName];
epilog

end;</source>
        <ReturnType type="CM_Debtor"/>
    </JadeMethod>
