    <JadeMethod name="setPxyWoToDo" id="cf956e34-f202-403a-938c-15dd76e7a641">
        <updating/>
        <source>setPxyWoToDo(_noCharge				: Boolean; 
			 _remarks				: String; 
			 _priority				: Integer;
			 _allToDoTasksDescs		: CM_ToDoTaskDescSet) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 March 2023	navhl20 ChangeRequest 56614:[56615] EUP - Allow Multi ToDo Tasks Description on Cargo ToDo Work Order
17/03/2023	navcs2	ChangeRequest 56842:[56843]: EUP - VAS Task Priority

*/

vars

begin
	self.allToDoTasksDescs.clear();
	_allToDoTasksDescs.copy(self.allToDoTasksDescs);
	
	self.noCharge := _noCharge; 	//17.03.2023	navcs2	#56842:[56843]
	self.remarks  := _remarks; 		//17.03.2023	navcs2	#56842:[56843]
	self.priority := _priority; 	//17.03.2023	navcs2	#56842:[56843]
epilog

end;</source>
