end;</source>
    </JadeMethod>
    <JadeMethod name="setCurrentDetails" id="e10c8050-f675-40ec-b710-ed8990e3ec82">
        <updating/>
        <source>setCurrentDetails() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 Feb 2010	cnwkpd1	PAR #21603 - Tidy up screenshot processing

*/

vars

begin
	self.appName := app.niceName;
	self.currentDateTime := app.actualTimeServer;
	self.userName := process.userCode;
	
	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
</Class>
