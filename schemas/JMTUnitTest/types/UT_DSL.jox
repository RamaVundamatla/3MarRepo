    <JadeMethod name="updateVehicleDetails" id="4c35aae8-0405-4699-b55e-3418e7e9193c">
        <source>updateVehicleDetails(_vehicle : Any io);

/*

Purpose:		Update vehicle details

Date			Who		Reason
04/02/2014		cnwmh5	Initial creation

*/

vars

	vehicle				: CM_Vehicle;
	pxyVehicle			: CM_Vehicle;
	
begin

	if _vehicle.isKindOf(String) then
		vehicle := self.getVehicle(_vehicle.String);
	else	
		vehicle := _vehicle.CM_Vehicle;
	endif;
	self.assertNotNull(vehicle);
	
	beginLoad;
	pxyVehicle := vehicle.pxyCreateUpdateProxy();
	endLoad;
	
	if self.opts.includesKey("VehicleTareKilos") then
		pxyVehicle.setPropertyValue('tareKilos', self.opts.real("VehicleTareKilos").Decimal);
	endif;
	
	app.myTrxUA.trxUpdateVehicle(pxyVehicle, app.myPassport);
	self.assertNoTrxErrorsOrWarnings();
	
	if self.opts.includesKey("VehicleRego") then
		app.myTrxUA.trxUpdateVehicleRegNumber(vehicle, self.opts.str("VehicleRego"), vehicle.state, app.myPassport);
		self.assertNoTrxErrorsOrWarnings();
	endif;
	
epilog

	delete pxyVehicle;

end;</source>
        <Parameter name="_vehicle" type="Any" usage="io"/>
    </JadeMethod>
