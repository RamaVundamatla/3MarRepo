    <JadeMethod name="tblMachines_mouseMove" id="97f8bbff-045f-4f06-ae4e-9c541ad535f3">
        <controlMethod name="Table::mouseMove"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblMachines_mouseMove(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:     15 October 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 29 Aug 2011	cnwkpd1		PAR #27747 - New drag icons for machines
// ---------------------------------------------------------------------------
vars
	theRow,
	theCol	: Integer;
	lObj : Object;	
	lastLocnStr		: String;
	machine		: CM_Machine;
	cell : JadeTableCell;
begin
	// TFS 52945 NAVCS2 22/03/2022
	if not self.canMaintainRTQueue then
		return;
	endif;

	if table.row &lt; 1 then
		return;
	endif;

	if not app.dragDetected(x, y, self.origXPos, self.origYPos) then
		return;
	endif;

	// PAR 20738 - show last known position
	if table.getCellFromPosition(x, y, theRow, theCol) then
		machine := table.accessRow(theRow).itemObject.CM_Machine;

		if machine &lt;&gt; null then
			if machine.myLastKnownLocation &lt;&gt; null then
				lastLocnStr := app.getErrorString2(Last_known_location, machine.myLastKnownLocation.getFullId(), 
								machine.lastKnownTimeStamp.asStringJMT);
			endif;
			
			executeWhen JMTDevelopmentEnvironment;
			if machine.myRTDevice = null then
				lastLocnStr := lastLocnStr &amp; CrLf &amp; "NO RTDevice declared - No log in available!";
			endif;
			endExecuteWhen;
			
			table.bubbleHelp := table.accessCell(theRow, 2).text &amp; CrLf &amp; lastLocnStr;
		else
			table.bubbleHelp := null;
		endif;
	else
		table.bubbleHelp := null;
	endif;
	
	if button = Window.MouseButton_Left then
		machine := table.accessRow(table.row).itemObject.CM_Machine;
		if machine &lt;&gt; null  then
			//19/08/2011 cnwdz2	27747
			if machine.machineStatus = STATUS_OFFLINE then
				self.dragCursor := picMoveOff.picture;
			elseif machine.currentQueueTask = null then
				self.dragCursor := picMoveIdle.picture;
			else
				self.dragCursor := picMoveActive.picture;
			endif;
			self.userObject := machine;
			self.dragMode := DragMode_Drag;
		endif;
	else
		dragMode := DragMode_None;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
