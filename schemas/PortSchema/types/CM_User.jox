    <JadeMethod name="resetReportMenuFromJMTDefault" id="0fb1dbcc-0633-4719-b391-d3d95459304e">
        <updating/>
        <source>resetReportMenuFromJMTDefault(_clearFirst : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     22 November 2002		cnwth2	
//
// Purpose:     
//			 
// ----------   ----------  --------------------------------------------------
vars
	userTerm	: CM_UserTerminal;
			
begin
	
	foreach userTerm in self.allUserTerminals do
		userTerm.resetReportMenuFromJMTDefault(_clearFirst);
	endforeach;
	
end;</source>
        <Parameter name="_clearFirst" type="Boolean"/>
