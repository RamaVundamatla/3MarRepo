    <JadeMethod name="createCustomerLicense" id="6cefe2f0-8904-43f9-97eb-8af08e148a8d">
        <source>createCustomerLicense(pTheServiceManager:JSSLKServiceManager input; pCustomerName:String; pProductCode:String; pLicenseKey:String):JSSLKCustomerLicense;
// --------------------------------------------------------------------------------
// Created:		17 January 2003 by cnwdad1
//
// Purpose:		Creates a new Customer License object.
//
// Parameters:	pTheServiceManager - A reference to the Service Manager object.
//				pCustomerName - The name of the Customer.
//				pProductCode - A unique code identifying the product being licensed.
//				pLicenseKey - The Customer's Product license key.
//
// Returns:		A reference to the newly created Customer License object.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	theCustomerLicense	: JSSLKCustomerLicense;
	
begin
	create theCustomerLicense;
	theCustomerLicense.updateMe(pTheServiceManager, pCustomerName, pProductCode, pLicenseKey, self);
	
	return theCustomerLicense;
end;</source>
        <Parameter name="pTheServiceManager" type="JSSLKServiceManager" usage="input"/>
        <Parameter name="pCustomerName" type="String"/>
        <Parameter name="pProductCode" type="String"/>
        <Parameter name="pLicenseKey" type="String"/>
        <ReturnType type="JSSLKCustomerLicense"/>
    </JadeMethod>
</Class>
