	//Customs Entry Num
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Customs Entry Number', CM_CashPayment::getCustomsEntryNumber.name, self.className);
	tmpProp.needToUpperCase := true;
	tmpProp.setPerformanceRating( CM_QueryProperty.Complex );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//Payment Method
	create tmpProp as CM_QRefPaymentMethodMethod persistent;
	tmpProp.set('Payment Method', CM_CashPayment::getMyPaymentMethod.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//debtor type
	create tmpProp as CM_QRefDebtorTypeMethod persistent;
	tmpProp.set('Debtor Type', CM_CashPayment::getDebtorType.name, self.className);
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
	self.allQueryProperties.add(tmpProp);
	
	//debtor account code
	create tmpProp as CM_QStringMethod persistent;
	tmpProp.set('Debtor Account Code', CM_CashPayment::getDebtorAccountCode.name, self.className);
	tmpProp.needToUpperCase := true;
	tmpProp.setPerformanceRating( CM_QueryProperty.Simple );	// Simple	= '1', CollKey	= '2', Complex	= '3'
