    <JadeMethod name="setupTable_Comments" id="45463d9a-10e0-4a94-bc77-caa5caca2631">
        <source>setupTable_Comments(_dd :DynaDictionary)protected;
/*
	Purpose:			
	Parameters:		_dd - used to print delay comments
	Return Value:		

Date		Who		Reason
24 July 2008	concms1	Initial creation
15 Sep  2017    CNWMA1	tfs #6923 QNS - OPERATIONS REPORT - MV TARUS-1715
*/
constants
	ColWidth1	= 30;
	ColWidth2	= 30;
vars
	tbl 			:Table;
	voyage			:CM_Voyage;
	delay			:Object;
	fixedColumns, 
	colWidth, row, count	:Integer;
begin
	if _dd.size = 0 then
		return;
	endif;
	app.printer.print (self.frmNull);	 //15/09/2017 cnwma1 TFS #6923
	
	/* //15/09/2017 cnwma1 TFS #6923
	tbl				:= self.tblReport;
	tbl.clear;
	tbl.rows 		:= 0;
	tbl.columns		:= 3;
	
	fixedColumns	:= ColWidth1 + ColWidth2;
	colWidth		:= (tbl.width -fixedColumns).Integer;
	
	tbl.accessColumn(1).width 	:= ColWidth1;	
	tbl.accessColumn(2).width 	:= ColWidth2;	tbl.accessColumn(2).alignment := Table.Alignment_Left;	
	tbl.accessColumn(3).width 	:= colWidth;	tbl.accessColumn(3).alignment := Table.Alignment_Left; 

	voyage		:= self.getVoyage;

	row := tbl.addItem ("DELAY COMMENTS");
	tbl.accessCell (row, 1).mergeCells	:= Table.MergeCells_Merge; tbl.accessedCell.fontBold := true;
	*/
	app.printer.print (frmDelayComment); //15/09/2017 cnwma1 TFS #6923
	foreach delay in _dd do
		if delay.CM_Delay.remarks = null then
			continue;	// nothing to output
		endif;
		count 	:= count + 1;
		
		/*15/09/2017 cnwma1 TFS #6923
		row 	:= tbl.addItem (Tab &amp; count.String &amp; Tab &amp; delay.CM_Delay.remarks);
		tbl.accessCell (row, 3).fontBold := false;
		*/
		
		lblCount.caption := count.String;
		
		lblRemarks.caption := delay.CM_Delay.remarks;
	
		app.printer.print (frmDelayRemarks);
		if not app.printer.frameFits(frmDelayRemarks) then
			app.printer.newPage();
		endif;
		
	endforeach;

	// set the table height based on the sum of the row heights
	/*15/09/2017 cnwma1 TFS #6923
	self.setTableHeight (tbl);
	
	self.frmTable.height	:= tbl.height;
	
	// now print
	app.printer.print (self.frmNull);
	app.printer.print (frmTable);	
	*/
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_dd" type="DynaDictionary"/>
    </JadeMethod>
    <JadeMethod name="setupTable_Hours" id="c6667a9c-953c-4232-9fa7-aba073ad47ad">
        <source>setupTable_Hours(_cranesArray :ObjectArray; _dd :DynaDictionary)protected;
/*
	Purpose:			
	Parameters:		_cranesArray - the cranes we have
					_movesArray	- total moves for each crane	
					_dd - used to print delay comments
	Return Value:		

Date		Who		Reason
24 July 2008	concms1	Initial creation
*/

vars
	tbl 		:Table;
	voyage		:CM_Voyage;
	row, int, size, index, craneTotMoves	:Integer;
	craneNetHrs, craneGrsHrs : Real;
	dataArray	:ObjectArray;
	hoursArray, 
	delayArray,
	totDelayArray:DecimalArray;
	obj			:Object;
	crane		:CM_Crane;
	kpi			:CM_KPIVoyageCraneShift;
	kpiTotals : CM_KPIVoyageTotals;
	delay		:CM_Delay;
	lastType	:CM_DelayType;
	value 		:Decimal[23,8];
begin
	tbl			:= self.tblReport;
	tbl.rows	:= 0;
	voyage		:= self.getVoyage;
	kpiTotals			:= voyage.getKPIByType(KPI_Type_Voyage).CM_KPIVoyageTotals;
	
	create dataArray transient;	// one entry per crane
	
	// work out gross hours by crane	
	size := _cranesArray.size;
	
	foreach int in 1 to size do
		crane := _cranesArray[int].CM_Crane;
		
		create hoursArray transient;
		
		hoursArray[self.HOURS_VALUES_SIZE]	:= null;	// to save checking index later

		craneTotMoves := 0;		// 22/2/17 MAP TFS3383
		craneNetHrs := 0;
		craneGrsHrs := 0;

		foreach kpi in crane.allVoyageKPICraneShifts discreteLock 
			where kpi.myVoyage = voyage do // PAR 31484 add WHERE statement as this is a collection of KPIs for all voyages that this crane has been used for
			
			craneTotMoves := craneTotMoves + kpi.getTotalMoves;
			//craneNetHrs := craneNetHrs + kpi.hoursNet;
			craneNetHrs := craneNetHrs + kpi.getHoursNetLessDownTime;	//04 Apr 2012	NDL	Par 29369
			craneGrsHrs := craneGrsHrs + kpi.hoursGross;
			
			hoursArray[1] := hoursArray[1] + kpi.CM_KPIVoyageCraneShift.hoursGross; 
		endforeach;
		if craneGrsHrs &lt;&gt; 0 then
			hoursArray[2] := (craneTotMoves/craneGrsHrs).roundedTo (1); 
		endif;
		if craneNetHrs &lt;&gt; 0 then
			hoursArray[3] := (craneTotMoves/craneNetHrs).roundedTo (1); 
		endif;

		dataArray.add(hoursArray);	// add figures for this crane to array of data for all cranes
	endforeach;
	
	// now output hours
	
	if kpiTotals &lt;&gt; null then 
		value := kpiTotals.getGrossHours;
	else 
		value := null;
	endif;
	
	row := self.addRowToHoursTable(tbl, "Gross Crane Hours (HH:MM)" &amp; Tab &amp; Tab &amp; "F", 1, dataArray, value, true, 0); // PAR 22125
		tbl.accessCell (row, 1).mergeCells	:= Table.MergeCells_Merge;
		
	if kpiTotals &lt;&gt; null then 
		value := kpiTotals.getGrossMovesPerHour;
	else 
		value := null;
	endif;
	
	row := self.addRowToHoursTable(tbl, "Moves Per Gross C/Hr", 2, dataArray, value, false, 1);
		tbl.accessCell (row, 1).mergeCells	:= Table.MergeCells_Merge; 
		tbl.accessCell(row, 3).mergeCells 	:= Table.MergeCells_NotAvailable;	
	row := tbl.addItem (null);
	
	if _dd.size &gt; 0 then
		row := tbl.addItem ("DELAYS");	// heading

		create delayArray transient;		delayArray[self.MAX_CRANES] := null;
		create totDelayArray transient;		totDelayArray[self.MAX_CRANES] := null;
		foreach obj in _dd do
			delay := obj.CM_Delay;
			
			if delay.myMachine = null or not delay.myMachine.isKindOf (CM_Crane) then
				continue;	// hopefully does not happen
			endif;
			
			crane := delay.myMachine.CM_Crane;
			index := _cranesArray.indexOf (crane);
			
			if index = null then
				continue;	//must be bad data in test system
			endif;
			
			if lastType &lt;&gt; delay.myDelayType then
				if lastType &lt;&gt; null then
					// output row for this delay type;
					row := self.addRowToDelayTable(tbl, lastType.description, delayArray, 2);
				endif;
				lastType := delay.myDelayType;
				
				delayArray.clear; delayArray[self.MAX_CRANES] := null;
			endif;
			// now update for this delay type
			self.updateArrayEntry(delayArray, index, delay.getDelayDuration);
			self.updateArrayEntry(totDelayArray, index, delay.getDelayDuration); 
		endforeach;
		
		if lastType &lt;&gt; null then
			row := self.addRowToDelayTable(tbl, lastType.description, delayArray, 2);
		endif;
		
		row := self.addRowToDelayTable(tbl, "Total Delays" &amp; Tab &amp; Tab &amp; "G", totDelayArray, 2);
	else	
		row := tbl.addItem ("Total Delays" &amp; Tab &amp; Tab &amp; "G");
	endif;
	
	row := tbl.addItem (null);
	
	if kpiTotals &lt;&gt; null then 
		value := kpiTotals.getNetMovesPerHour;	// 22/2/17 MAP TFS3383
	else 
		value := null;
	endif;
	
	row := self.addRowToHoursTable(tbl, "Moves Per Net C/Hour (E/F-G)", 3, dataArray, value,false, 1); 
		tbl.accessCell (row, 1).mergeCells	:= Table.MergeCells_Merge; 
		tbl.accessCell(row, 3).mergeCells 	:= Table.MergeCells_NotAvailable;	

	// set the table height based on the sum of the row heights
	self.setTableHeight (tbl);
	
	self.frmTable.height	:= tbl.height;

	// now print
	app.printer.print (self.frmNull);
	app.printer.print (frmTable);	
epilog
	dataArray.purge;
	delete dataArray;
	delete delayArray;
	delete totDelayArray;
end;</source>
        <access>protected</access>
        <Parameter name="_cranesArray" type="ObjectArray"/>
        <Parameter name="_dd" type="DynaDictionary"/>
    </JadeMethod>
    <JadeMethod name="setupTable_Moves" id="44ef6322-3c8f-4c35-89d6-ab2ef44b10ad">
        <source>setupTable_Moves(_cranesArray :ObjectArray)protected;
/*
	Purpose:				
	Parameters:		_cranesArray
	Return Value:		

Date			Who		Reason
23 July 2008	concms1	Initial creation
*/
constants
	ColWidth1	= 100;
	ColWidth2	= 100;
	ColWidth3	= 20;
vars
	dataArray				:ObjectArray;
	totalsArray 			:DecimalArray;
	tbl						: Table;
	fixedColumns, colWidth, 
	row, int, size			:Integer;
	str						:String;
begin
	// first get the data to be displayed
	self.getMoveData (_cranesArray, dataArray, totalsArray);
	
	tbl 			:= self.tblReport;
	tbl.clear;
	tbl.fontSize 		:= 8;
	
	tbl.fixedRows 		:= 0;
	tbl.rows 			:= tbl.fixedRows;
	tbl.columns 		:= 10;
	tbl.fixedColumns	:= 0;
	
	fixedColumns	:= ColWidth1 + ColWidth2 + ColWidth3;
	colWidth		:= (tbl.width -fixedColumns) div 7;
	
	tbl.accessColumn(1).width 	:= ColWidth1;	tbl.accessColumn(1).fontSize := 8;
	tbl.accessColumn(2).width 	:= ColWidth2;	tbl.accessColumn(2).alignment := Table.Alignment_Right;	
	tbl.accessColumn(3).width 	:= ColWidth3;	tbl.accessColumn(3).alignment := Table.Alignment_Center; tbl.accessColumn(3).fontSize := 8;
	tbl.accessColumn(4).width 	:= colWidth;	tbl.accessColumn(4).alignment := Table.Alignment_Right;
	tbl.accessColumn(5).width 	:= colWidth;	tbl.accessColumn(5).alignment := Table.Alignment_Right;
	tbl.accessColumn(6).width 	:= colWidth;	tbl.accessColumn(6).alignment := Table.Alignment_Right;
	tbl.accessColumn(7).width 	:= colWidth;	tbl.accessColumn(7).alignment := Table.Alignment_Right;
	tbl.accessColumn(8).width 	:= colWidth;	tbl.accessColumn(8).alignment := Table.Alignment_Right;
	tbl.accessColumn(9).width 	:= colWidth;	tbl.accessColumn(9).alignment := Table.Alignment_Right;
	tbl.accessColumn(10).width 	:= colWidth;	tbl.accessColumn(10).alignment := Table.Alignment_Right;

	// heading lines - cranes
	str 	:= Tab &amp; Tab;	// gets us to column 3
	size	:= _cranesArray.size;
	
	foreach int in 1 to size do
		str := str &amp; Tab &amp; _cranesArray[int].CM_Crane.code;
		
		if int = 6 then
			break;	// report will only display up to 6 cranes
		endif;
	endforeach;
	
	row := tbl.addItem (str);	
	
	tbl.accessCell(row,10).text 	:= 'Totals';
	tbl.accessRow (row).fontBold	:= true;
	
	// values
	int := 0;
	int := int + 1; row := self.addRowToMovesTable (tbl, ('Discharged' &amp; Tab &amp; "20'"), int, dataArray, totalsArray, 0);	
	int := int + 1; row := self.addRowToMovesTable (tbl, ('Containers' &amp; Tab &amp; "30'"), int, dataArray, totalsArray, 0);		
	int := int + 1; row := self.addRowToMovesTable (tbl, (Tab &amp; "40'"), int, dataArray, totalsArray, 0);			
	int := int + 1; row := self.addRowToMovesTable (tbl, (Tab &amp; "45'"), int, dataArray, totalsArray, 0);		
	int := int + 1; row := self.addRowToMovesTable (tbl, (Tab &amp; "53'"), int, dataArray, totalsArray, 0);		
	int := int + 1; row := self.addRowToMovesTable (tbl, ('Loaded' &amp; Tab &amp; "20'"), int, dataArray, totalsArray, 0);
	int := int + 1; row := self.addRowToMovesTable (tbl, ('Containers' &amp; Tab &amp; "30'"), int, dataArray, totalsArray, 0);
	int := int + 1; row := self.addRowToMovesTable (tbl, (Tab &amp; "40'"), int, dataArray, totalsArray, 0);			
	int := int + 1; row := self.addRowToMovesTable (tbl, (Tab &amp; "45'"), int, dataArray, totalsArray, 0);			
	int := int + 1; row := self.addRowToMovesTable (tbl, (Tab &amp; "53'"), int, dataArray, totalsArray, 0);		
	row := tbl.addItem (null);
	int := int + 1; row := self.addRowToMovesTable (tbl, ('Out of Gauge Items'), int, dataArray, totalsArray, 0);			
	
	// it's not easy to get a right justified cell to merge with the cells before it !!!
	// put the text in the first column and then merge with the next
	tbl.accessCell(row, 1).fontBold		:= false; 
	tbl.accessCell (row,1).alignment 	:= Table.Alignment_Right;  
	tbl.accessCell(row, 3).mergeCells 	:= Table.MergeCells_NotAvailable;	
	tbl.accessCell (row, 1).mergeCells	:= Table.MergeCells_Merge;
	
	int := int + 1; row := self.addRowToMovesTable (tbl, ('TOTAL CONTAINERS' &amp; Tab &amp; Tab &amp; "A"), int, dataArray, totalsArray, 0);		
		tbl.accessCell (row, 1).mergeCells	:= Table.MergeCells_Merge;		
//	int := int + 1; row := self.addRowToMovesTable (tbl, (Tab &amp; "* Twin Lift %"), int, dataArray, totalsArray, 2);
//	int := int + 1; row := self.addRowToMovesTable (tbl, ("* TOTAL CONTAINER MOVES" &amp; Tab &amp; Tab &amp; "A"), int, dataArray, totalsArray, 0);	
		tbl.accessCell (row, 1).mergeCells	:= Table.MergeCells_Merge;
		
	row := tbl.addItem (null);
	//TEU Figures
	int := int + 1; row := self.addRowToMovesTable (tbl, (Tab &amp; "Discharged TEU"), int, dataArray, totalsArray, 0);		
	int := int + 1; row := self.addRowToMovesTable (tbl, (Tab &amp; "Loaded TEU"), int, dataArray, totalsArray, 0);
	int := int + 1; row := self.addRowToMovesTable (tbl, ("TOTAL TEU"), int, dataArray, totalsArray, 0);		
		tbl.accessCell(row, 2).fontBold := true;
		
	row := tbl.addItem (null);
	// Restows
	row := tbl.addItem("Restows");	// no data
	int := int + 1; row := self.addRowToMovesTable (tbl, ("SOB" &amp; Tab &amp; "20'"), int, dataArray, totalsArray, 0);	
		tbl.accessCell(row, 1).fontBold := false; 
		tbl.accessedCell.alignment := Table.Alignment_Right; 
	int := int + 1; row := self.addRowToMovesTable (tbl, (Tab &amp; "30'"), int, dataArray, totalsArray, 0);			
	int := int + 1; row := self.addRowToMovesTable (tbl, (Tab &amp; "40'"), int, dataArray, totalsArray, 0);				
	int := int + 1; row := self.addRowToMovesTable (tbl, (Tab &amp; "45'"), int, dataArray, totalsArray, 0);	
	int := int + 1; row := self.addRowToMovesTable (tbl, (Tab &amp; "53'"), int, dataArray, totalsArray, 0);	
	int := int + 1; row := self.addRowToMovesTable (tbl, ("DLR" &amp; Tab &amp; "20'"), int, dataArray, totalsArray, 0);	
		tbl.accessCell(row, 1).fontBold := false; 
		tbl.accessedCell.alignment := Table.Alignment_Right;  
	int := int + 1; row := self.addRowToMovesTable (tbl, (Tab &amp; "30'"), int, dataArray, totalsArray, 0);			
	int := int + 1; row := self.addRowToMovesTable (tbl, (Tab &amp; "40'"), int, dataArray, totalsArray, 0);				
	int := int + 1; row := self.addRowToMovesTable (tbl, (Tab &amp; "45'"), int, dataArray, totalsArray, 0);	
	int := int + 1; row := self.addRowToMovesTable (tbl, (Tab &amp; "53'"), int, dataArray, totalsArray, 0);	
	int := int + 1; row := self.addRowToMovesTable (tbl, ("Total Restows" &amp; Tab &amp; Tab &amp; "B"), int, dataArray, totalsArray, 0);	
		tbl.accessCell (row, 1).mergeCells	:= Table.MergeCells_Merge;
	row := tbl.addItem (null);
	int := int + 1; row := self.addRowToMovesTable (tbl, (Tab &amp; "Twin Lift %"), int, dataArray, totalsArray, 2);
	row := tbl.addItem (null);
	int := int + 1; row := self.addRowToMovesTable (tbl, ("Hatch Lid" &amp; Tab &amp; "Moves" &amp; Tab &amp; "C"), int, dataArray, totalsArray, 0);
	int := int + 1; row := self.addRowToMovesTable (tbl, ("* Lashing Bin" &amp; Tab &amp; "Moves" &amp; Tab &amp; "D"), int, dataArray, totalsArray, 0);
	int := int + 1; row := self.addRowToMovesTable (tbl, (Tab &amp; "* #"), int, dataArray, totalsArray, 0);
	int := int + 1; row := self.addRowToMovesTable (tbl, ("TOTAL MOVES (A-D)" &amp; Tab &amp; Tab &amp; "E"), int, dataArray, totalsArray, 0);
		tbl.accessCell (row, 1).mergeCells	:= Table.MergeCells_Merge;

	// set the table height based on the sum of the row heights
	self.setTableHeight (tbl);
	
	self.frmTable.height	:= tbl.height;

	// now print
	app.printer.print (self.frmNull);
	app.printer.print (frmTable);	
epilog
	dataArray.purge;
	delete dataArray;
	delete totalsArray;
end;</source>
        <access>protected</access>
        <Parameter name="_cranesArray" type="ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="setupTable_Times" id="86d309c8-ab0e-42b0-ae57-230359a7756a">
        <source>setupTable_Times()protected;
/*
	Purpose:			
	Parameters:		
	Return Value:		

Date		Who		Reason
24 July 2008	concms1	Initial creation
*/
constants
	
vars
	tbl 			:Table;
	voyage			:CM_Voyage;
	kpi				:CM_KPIVoyageTotals;
	delay			:Object;
	row				:Integer;
	strHours		:String;
begin
	tbl				:= self.tblReport;
		
	inheritMethod;
	
	voyage		:= self.getVoyage;
	kpi			:= voyage.getKPIByType(KPI_Type_Voyage).CM_KPIVoyageTotals;

	if kpi &lt;&gt; null then
		strHours := kpi.getNetHours.asHoursMinutes;
	endif;
	
	tbl.accessCell (6, 4).text := ('Ship Working Crane Time' &amp; Tab &amp; strHours);
	

	// set the table height based on the sum of the row heights
	self.setTableHeight (tbl);
	
	self.frmTable.height	:= tbl.height;

	// now print
	app.printer.print (self.frmNull);
	app.printer.print (frmTable);	
epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupTable_Voyage" id="25fadfa0-4de7-4884-9514-4e38e9af0ba2">
        <source>setupTable_Voyage()protected;
/*
	Purpose:			
	Parameters:			
	Return Value:		

Date			Who		Reason
22 July 2008	concms1	par 17592 - Initial creation
*/
constants
	ColWidth1	= 60;
	ColWidth3	= 70;
	ColWidth5	= 60;
	ColWidth6	= 70;
vars
	tbl				: Table;
	fixedColumns	:Integer;
begin
	tbl 			:= self.tblReport;
	tbl.rows		:= 0;
	tbl.columns		:= 0;
	tbl.show3D 		:= Table.Show3D_Not3D;
	
	tbl.rows 			:= 2;
	tbl.fixedRows 		:= 0;
	tbl.columns 		:= 6;
	tbl.fixedColumns	:= 0;
	fixedColumns		:= ColWidth1 + ColWidth3 + ColWidth5 + ColWidth6;
	
	tbl.accessColumn(1).width 	:= ColWidth1;
	tbl.accessColumn(2).width 	:= ((tbl.width - fixedColumns)/2).Integer;
	tbl.accessColumn(3).width 	:= ColWidth3;
	tbl.accessColumn(4).width 	:= ((tbl.width - fixedColumns)/2).Integer;
	tbl.accessColumn(5).width 	:= ColWidth5;
	tbl.accessColumn(6).width 	:= ColWidth6;
	
	tbl.accessColumn(1).fontBold	:= true;
	tbl.accessColumn(3).fontBold	:= true;
	tbl.accessCell(2,5).fontBold	:= true;
	
	tbl.accessCell(1,1).text 	:= 'Voyage';
	tbl.accessCell(1,2).text	:= self.getVoyageCode;
	tbl.accessCell(1,3).text	:= 'Shipping Line';
	tbl.accessCell(1,4).text	:= self.getShippingLine;
	tbl.accessCell(2,1).text 	:= 'Vessel';
	tbl.accessCell(2,2).text	:= self.getVesselName;
	tbl.accessCell(2,3).text	:= 'Vessel Operator';
	tbl.accessCell(2,4).text	:= self.getVesselOperator;
	tbl.accessCell(2,5).text	:= 'Arrival';
	tbl.accessCell(2,6).text	:= self.getArrivalDate;
	
	tbl.accessRow(1).height := 35;
	tbl.accessRow(2).height := 35;
	
	tbl.accessRow(1).alignment := Table.Alignment_Left_Bottom;
	tbl.accessRow(2).alignment := Table.Alignment_Left_Bottom;
	
	tbl.accessRow(1).wordWrap:= true;
	tbl.accessRow(2).wordWrap:= true;

	// set the table height based on the sum of the row heights
	self.setTableHeight (tbl);
	
	self.frmTable.height	:= tbl.height;

	// now print
	app.printer.print (frmTable);	
end;</source>
        <access>protected</access>
    </JadeMethod>
</GUIClass>
