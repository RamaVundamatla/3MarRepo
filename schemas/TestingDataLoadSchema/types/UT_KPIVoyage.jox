    <JadeMethod name="getVoyage" id="30d13d42-6300-4f96-8259-fc297213bf96">
        <source>getVoyage(_name: String): CM_Voyage;
// ---------------------------------------------------------------------------
// Created:     04 June 2010 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	voy : CM_Voyage;
begin
	voy := self.getTerminal.allVoyagesByCode.getAtKeyGeq(_name, null);
	if voy &lt;&gt; null and voy.code &lt;&gt; _name then
		return null;
	endif;
	
	return voy;

epilog

end;</source>
