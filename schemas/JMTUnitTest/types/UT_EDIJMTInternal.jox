//						CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL);
	errorMsg := "DB Load Failed" &amp; CrLf &amp; passportObj.getErrorsAsString();
	self.assertEqualMsg(ediFileObj.fileStatus, CM_EDIFile.EDI_STATUS_DBLOADED, errorMsg);
	if ediFileObj.fileStatus = CM_EDIFile.EDI_STATUS_DBLOADED_PARTIAL then
		write "EDI message not fully loaded - needs a re-run.";
	endif;
	self.assertEqualMsg(ediDataObj.allEDITrackedItems.size, 1, "incorrect number of EDI trackedItems");
	customsAgent := self.getCustomsAgent(CUSTOMSAGENT);
	self.assertNotNull(customsAgent);
	self.assertEqualMsg(customsAgent.name, "Stuff", "wrong name");

	ediText :=
'&lt;?xml version="1.0"?&gt;
&lt;JMTInternalCustomsAgent xmlns:xsi="http://www.jademasterterminallogistics.com/JMTInternal" xsi:noNamespaceSchemaLocation="JMTInternalCustomsAgent.xsd"&gt;
	&lt;AllCustomsAgent&gt;
		&lt;CustomsAgent&gt;
			&lt;action&gt;U&lt;/action&gt;
			&lt;cargoTypeDescr&gt;&lt;/cargoTypeDescr&gt;
			&lt;code&gt;'&amp;CUSTOMSAGENT&amp;'&lt;/code&gt;
			&lt;debtorName&gt;&lt;/debtorName&gt;
			&lt;description&gt;&lt;/description&gt;
			&lt;fullOrMT&gt;&lt;/fullOrMT&gt;
