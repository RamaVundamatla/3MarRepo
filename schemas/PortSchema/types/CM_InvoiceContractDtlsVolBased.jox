    <JadeMethod name="getContractAccumulation" id="1a8d03f4-6a56-4753-8bd6-f8c36d695015">
        <updating/>
        <source>getContractAccumulation(_invLine : CM_InvoiceLine) : CM_InvoiceContractAccumulate updating;
/*
Purpose:	Get a valid accumulation object, create if necessary. Perform the accumulation.		

Date		Who		Reason
24 January 2023	navab1	TFS CR 55624 TASK 55700 
*/

vars
	accum : CM_InvoiceContractAccumulate;
	ti : CM_TrackedItem;
	voyage : CM_Voyage;
	accumulate : Boolean;
	titrans : CM_TITransaction;
begin
	if _invLine = null then 
		return null;
	endif;
	
	titrans := _invLine.myTransactionTI;
	
	if titrans = null then
		return null;
	endif;
	
	if titrans.isKindOf(CM_ReceiveShip)
	and self.accumulateForShipReceival then
		accumulate := true;
	elseif titrans.isKindOf(CM_ReceiveRoad)
	and self.accumulateForRoadReceival then
		accumulate := true;
	elseif titrans.isKindOf(CM_ReceiveRail)
	and self.accumulateForRailReceival then
		accumulate := true;
	endif;
	
	if not accumulate then
		return null;
	endif;
	
	voyage := titrans.getVoyage();
	ti := titrans.myTrackedItem;
	
	if self.accumulationType = INV_VOL_BASED_VOYAGE then
		accum := self.allAccumulationsByType[INV_VOL_BASED_VOYAGE,voyage];
	else
		accum := self.allAccumulationsByType[INV_VOL_BASED_PERIOD,null];
	endif;
	
	if accum = null then
		create accum;
		accum.setFromInvoiceLine(_invLine, self.accumulationType, self);
	endif;	

	accum.accumulatFromInvoiceLine(_invLine);
	
	return accum;
epilog

end;</source>
        <Parameter name="_invLine" type="CM_InvoiceLine"/>
        <ReturnType type="CM_InvoiceContractAccumulate"/>
    </JadeMethod>
