    <JadeMethod name="timerEvent" id="d3f350c9-63ae-4455-8285-790bf8c21df5">
        <updating/>
        <source>timerEvent(eventTag: Integer) updating;
// --------------------------------------------------------------------------------
// Created:		26 June 2002 by cnwdad1
//
// Purpose:		Performs local timer event processing, and then passes this event
//				on to the Form Interface class for processing.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if eventTag = self.TIMER_STATUS_TIMESTAMP then
		self.statusSetTimestampFormat();
		self.statusResizeTimestamp();
		self.statusResizeKeys();
	endif;
	
	if self.aMyFormInterface &lt;&gt; null then
		self.aMyFormInterface.sendMsgWithParams("formTimerEvent", eventTag);
	endif;
end;</source>
        <Parameter name="eventTag" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="unload" id="3753eb01-78ed-4b25-b701-800afcf7bdd0">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
// --------------------------------------------------------------------------------
// Created:		30 July 2002 by cnwdad1
//
// Purpose:		Passes this event on to the Form Interface class for processing.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.aMyFormInterface &lt;&gt; null then
		self.aMyFormInterface.sendMsg(method.name);
	endif;
	
	inheritMethod();
end;</source>
    </JadeMethod>
    <JadeMethod name="userNotify" id="ee423faa-7ff7-478a-a369-04ff4c7fd2ab">
        <controlMethod name="Form::userNotify"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>userNotify(eventType: Integer; theObject: Object; eventTag: Integer; userInfo: Any) updating;
// --------------------------------------------------------------------------------
// Created:		30 July 2002 by cnwdad1
//
// Purpose:		Passes this event on to the Form Interface class for processing.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.aMyFormInterface &lt;&gt; null then
		self.aMyFormInterface.sendMsgWithParams(method.name, eventType, theObject, eventTag, userInfo);
	endif;
end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
        <Parameter name="eventTag" type="Integer"/>
        <Parameter name="userInfo" type="Any"/>
    </JadeMethod>
</GUIClass>
