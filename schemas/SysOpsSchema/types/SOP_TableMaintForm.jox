    <JadeMethod name="initTblData" id="5167383c-a071-497c-a455-db5666b5942f">
        <source>initTblData(theTable : CM_DataTable input);
// ---------------------------------------------------------------------------
// Created:     30 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theRow		: Integer;
	
begin

	theTable.rows := 1;
		
	theTable.optimiseRowHeight := true;
	
	theTable.top 	:= 5;
	theTable.left	:= 5;
	theTable.parentTopMargin	:= theTable.top;
	theTable.parentLeftMargin	:= theTable.left;
	theTable.parentRightMargin	:= 15;
	theTable.parentBottomMargin := 10;

	theTable.lockBottom := false;
	theTable.lockRight	:= false;
	theTable.stretchHeight := true;
	theTable.stretchWidth := true;
	
	
end;</source>
        <Parameter name="theTable" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="initTblInput" id="fb553773-4a2e-49f3-a525-f64b4d69a77b">
        <source>initTblInput(pTable : CM_EntryTable; pDef : String);
// ---------------------------------------------------------------------------
// Created:     30 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 13/05/2015	cnwdap1		PAR #36206 TFS 324/334 Graphical Representation of Hazard Class and Special Stow
// ---------------------------------------------------------------------------
vars
	entTableControl	: EntTableDef;
	theRow			: Integer;
	theTable		: CM_EntryTable;
	
begin
	
	theTable := pTable;
	theTable.rows := 0;
		
	theTable.optimiseRowHeight := true;
	
	if pDef &lt;&gt; null then
		entTableControl := app.myController.getEntTableDef(pDef);
		theTable.setEntTableDef(entTableControl, null, 'entTableDefSetupWarning');
	endif;
//	theTable.adjustHeight(200);

	theTable.top 	:= 0;
	theTable.left	:= 0;
	theTable.parentTopMargin	:= theTable.top;
	theTable.parentLeftMargin	:= theTable.left;
	theTable.parentRightMargin	:= 15;
	theTable.parentBottomMargin := 10;

	theTable.lockBottom := false;
	theTable.lockRight	:= false;
	theTable.stretchHeight := true;
	theTable.stretchWidth := true;
	theTable.changeMode := theTable.ChangeMode_FirstOnly;
	
	theTable.pictureViewMethod := 'picViewMethod';
	theTable.pictureLoadMethod := 'picLoadMethod';
	theTable.pictureExtractMethod := 'picExtractMethod';

//	app.myController.comboBoxPowerRequirements(theTable, 'powerRequirements', POWER_NONE);

	theTable.resetSize();
	theTable.optimiseHeadingColumn();
	
	theTable.hideRowByName(ETRow_CharacterNumber, false);			// PAR #36206
		
end;</source>
        <Parameter name="pTable" type="CM_EntryTable"/>
        <Parameter name="pDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="initTblView" id="8c777e2c-b6a5-40a4-acfc-257849190229">
        <source>initTblView(pTable : CM_ViewTable input);
// ---------------------------------------------------------------------------
// Created:     30 March 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	theRow			: Integer;

begin

	pTable.clear;
	pTable.rows := 0;
		
	pTable.optimiseRowHeight := true;
	
	pTable.top 	:= 5;
	pTable.left	:= 5;
	pTable.parentTopMargin	:= pTable.top;
	pTable.parentLeftMargin	:= pTable.left;
	pTable.parentRightMargin	:= 15;
	pTable.parentBottomMargin := 10;

	pTable.lockBottom := false;
	pTable.lockRight	:= false;
	pTable.stretchHeight := true;
	pTable.stretchWidth := true;

end;</source>
        <Parameter name="pTable" type="CM_ViewTable" usage="input"/>
    </JadeMethod>
