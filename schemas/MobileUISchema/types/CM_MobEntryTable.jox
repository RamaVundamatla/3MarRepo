    <JadeMethod name="addAttribute" id="2668451c-2453-4b52-a680-3cc5b0ecfdc8">
        <updating/>
        <source>addAttribute(pAttrName, pAttrHeading : String; pInputType : Integer; pTmpNum : Integer; pVisible : Boolean) : Integer updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2010	cnwndl1	Initial creation

*/

vars
	
begin

	return self.addAttributeAt(pAttrName, pAttrHeading, pInputType, pTmpNum, pVisible, 0);

end;</source>
        <Parameter name="pAttrName" type="String"/>
        <Parameter name="pAttrHeading" type="String"/>
        <Parameter name="pInputType" type="Integer"/>
        <Parameter name="pTmpNum" type="Integer"/>
        <Parameter name="pVisible" type="Boolean"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="addAttributeAt" id="91b8e629-c15c-4846-9d2e-baef0d25a320">
        <updating/>
        <source>addAttributeAt(pAttrName, pAttrHeading : String; pInputType : Integer; pTmpNum : Integer; pVisible : Boolean;
			pRow : Integer) : Integer updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2010	cnwndl1	Initial creation

*/

vars
	newRow				: Integer;
	cell				: JadeTableCell;
	entRowTrans			: EntTableRowTransient;

begin
	if pRow = 0 then
		newRow := self.addItem('');
	else
		self.addItemAt('', pRow);
		newRow := pRow;
	endif;
	
	create entRowTrans transient;
	self.allEntRowTransients.insert(newRow, entRowTrans);
	
	self.accessRow(newRow).itemObject := entRowTrans;
	
	entRowTrans.setBasicDetails(pAttrName, pAttrHeading, pInputType, true, pVisible);

	self.accessCell(newRow, ColumnHeading).text := pAttrHeading;
	
	cell := self.accessCell(newRow, ColumnValue);

	if pInputType = InputType_Picture or pInputType = InputType_PictureViewOnly then
		self.picturesUsed := true;
		
		cell.inputType := InputType_ComboBox;
		if pInputType = InputType_PictureViewOnly then
			cell.comboList := PictureNoneText &amp; Tab &amp; PictureViewText;
		else
			cell.comboList := PictureNoneText &amp; Tab &amp; PictureLoadText &amp; Tab &amp;
							  PictureExtractText &amp; Tab &amp; PictureViewText;
		endif;

	elseif pInputType = InputType_Date then
		self.initCellForDate(cell);

	elseif pInputType = InputType_Time then
		self.initCellForTime(cell);

	elseif pInputType = InputType_ColourSelection then
		cell.inputType := InputType_ComboBox;
		cell.comboList := ColourCurrentText &amp; Tab &amp;
						  ColourSelectText &amp; Tab &amp;
						  ColourNoneText;

	elseif pInputType &gt;= InputType_JMTBase then
		// at this stage we don't handle this input type in
		// the CM_EntryTable so set to readonly
		cell.inputType := Table.InputType_None;
	else
		cell.inputType := pInputType;
	    if pInputType = InputType_SignedNumeric or
	       pInputType = InputType_TextNumeric then
			cell.decimals := pTmpNum;
		elseif pInputType = InputType_TextBox and pTmpNum &lt;&gt; 0 then
			cell.maxLength := pTmpNum;
		endif;
	endif;
	
	if pVisible then
		if topEntryRow = 0 then
			// must be adding the first row
			self.topEntryRow := newRow;
		endif;
		self.bottomEntryRow := newRow;
	else
		// as new row will be visible by default
		self.accessRow(newRow).visible := false;
	endif;
	
	return newRow;
	
end;</source>
        <Parameter name="pAttrName" type="String"/>
        <Parameter name="pAttrHeading" type="String"/>
        <Parameter name="pInputType" type="Integer"/>
        <Parameter name="pTmpNum" type="Integer"/>
        <Parameter name="pVisible" type="Boolean"/>
        <Parameter name="pRow" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="clearEntTableRowTransients" id="a35c819d-2e07-423c-a21b-6b05608de64c">
        <updating/>
        <source>clearEntTableRowTransients() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2010	cnwndl1	Initial creation

*/

vars
	changedColor,
	minRows,
	numRows,
	idx					: Integer;
	entRowTrans			: EntTableRowTransient;
begin
	numRows := self.rows;
	changedColor := self.hasChangedColor;
	
	minRows := self.fixedRows + 1;
	
	foreach idx in minRows to numRows do
		entRowTrans := self.accessRow(idx).itemObject.EntTableRowTransient;
		if entRowTrans = null then
			continue;
		endif;
		entRowTrans.originalValue:= self.accessCell(idx, ColumnValue).text;
		self.accessRow(idx).itemObject:=null;
		if self.changeMode = self.ChangeMode_All then
			if (self.accessCell(idx, self.ColumnValue).backColor = changedColor) then
				self.accessedCell.backColor := White;
			endif;
		endif;
	endforeach;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="clearHasChanged" id="85cb75d6-b2aa-4f35-a800-3c40c9183082">
        <updating/>
        <source>clearHasChanged() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2010	cnwndl1	Initial creation

*/

vars
	changedColor,
	valueColumn,
	minRows,
	numRows,
	idx					: Integer;
	entRowTrans			: EntTableRowTransient;
begin
	numRows := self.rows;
	changedColor := self.hasChangedColor;
	
	minRows := self.fixedRows + 1;
	
	foreach idx in minRows to numRows do
		entRowTrans := self.accessRow(idx).itemObject.EntTableRowTransient;
		if entRowTrans = null then
			continue;
		endif;
		entRowTrans.hasChanged := false;
		entRowTrans.isOriginalValueSet := false;
		entRowTrans.originalValue := null;
		
		if self.changeMode = self.ChangeMode_All then
			if (self.accessCell(idx, self.ColumnValue).backColor = changedColor) then
				self.accessedCell.backColor := White;
			endif;
		endif;
	endforeach;

	self.hasChanged := false;
end;</source>
    </JadeMethod>
    <JadeMethod name="clearValues" id="c3468466-c15e-46af-acda-c954cc34c110">
        <updating/>
        <source>clearValues() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
28 January 2010	cnwndl1	Initial creation

*/

vars
	idx		: Integer;
	maxRows	: Integer;
	obj		: Object;
	cell	: JadeTableCell;
	ctrl	: Control;
begin

	// we are clearing the values	
	maxRows := self.rows;

	foreach idx in topNonHeadingRow to maxRows do
		/* Don't use setValue() as it does more than necessary
		 and has changed to allow the display of '0' for numeric fields when the field value is zero
		//self.setValue(idx, null);
		*/

		//self.setValue(idx, null);

		obj := self.accessRow(idx).itemObject;
		
		if (obj = null) 
		or (not EntTableRowTransient.hasInstance(obj)) then
			continue;
		endif;
		
		cell := self.accessCell(idx, ColumnValue);

		// clear text
		if cell.text &lt;&gt; null then // this needs to be in else cell input types of combobox will crash if no null in combo box list
			cell.text := null;
			cell.alignment := Alignment_Left_Top;
			if self.optimiseRowHeight then
				// PAR 9317 
				self.optimiseHeightForRow(cell.inputType, idx, null);
			endif;			
		endif;
		
		cell.picture := null;//&lt;&lt;--was leaving logo/ship pics so clear picture as well		
		
		// clear our controls
		ctrl := cell.cellControl;
		if ctrl &lt;&gt; null 
		and ctrl.name[1] &lt;&gt; '_' then // This is NOT one of our controls.
		   	// this is one of our controls
		   	if ComboBox.hasInstance(ctrl) then
				ctrl.ComboBox.listObject := null;
	   		elseif TextBox.hasInstance(ctrl) then
		   		ctrl.TextBox.text := null;
		   	endif;
		endif;

	endforeach;
	
	self.clearHasChanged();

end;</source>
    </JadeMethod>
    <JadeMethod name="click" id="026a3a44-a41c-4821-a731-ca5d9ad71bc1">
