    <JadeMethod name="getFirstErrorNonWarning" id="614430df-369a-4f4b-aed4-d3a3b318057f">
        <source>getFirstErrorNonWarning() : CM_Error;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 October 2010	cnwndl1	Initial creation

*/

vars

	error : CM_Error;
	iter : Iterator;
	
begin

	if self.allErrorWarnings.isEmpty then
		return null;
	endif;
	
	iter :=  self.allErrorWarnings.createIterator;
	while iter.next( error ) do
		if error.warningOnly then
			continue;
		endif;
		return error;
	endwhile;
	
	return null;

epilog

	delete iter;

end;</source>
        <ReturnType type="CM_Error"/>
    </JadeMethod>
    <JadeMethod name="getFirstErrorWarning" id="ce9f3d12-2936-456c-8117-188ee2b7b3a7">
        <source>getFirstErrorWarning() : CM_Error;
// ---------------------------------------------------------------------------
// Created:     11 February 2003 by cnwrs2
//
// Purpose:     
//
