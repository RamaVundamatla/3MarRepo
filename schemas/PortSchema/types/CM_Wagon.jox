    <JadeMethod name="getCargoWeight" id="22ba4446-617f-4242-92ab-4e1f1626f8cd">
        <source>getCargoWeight(isReceived : Boolean) : Decimal;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
13 July 2009	cnwmd1	Initial creation

*/

vars
	ti : CM_TrackedItem;
	tis : CM_TIArray;
	weight : Decimal[12,2];
begin
	create tis transient;
	self.getAllTrackedItems(isReceived, tis, true);
	if tis.isEmpty() then
		self.getAllTrackedItems(isReceived, tis, false);
	endif;
	
	foreach ti in tis do
		weight := weight + ti.totalWeight;
	endforeach;
	
	return weight;
epilog
	delete tis;
end;</source>
        <Parameter name="isReceived" type="Boolean"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getCarrierDescription" id="720919e9-c8a1-4225-aba3-b7ffa67ad70c">
        <source>getCarrierDescription() : String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
09 January 2018	jlgns1	Initial creation
9/01/2018 JLGNS1 Bug 36407: Wagon Enquiry Issues
*/

vars

begin
	if self.myCarrier = null then
		return null;
