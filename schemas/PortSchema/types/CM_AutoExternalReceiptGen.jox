    <JadeMethod name="setForCreate" id="107daa34-0b5f-472b-916a-bbdc65ee27cd">
        <updating/>
        <source>setForCreate(_proxy: CM_AutoIdGenerator) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 November 2018	jlgma1	Bug 41688: PEL1 - Estimation ID sequence

*/

vars
	now : Date;
begin
	inheritMethod(_proxy);
	
	if not self.isTransient and self.nextSequenceNumArray.isEmpty then
		now := app.actualTimeAppServer.Date;
		self.setLastAndNextValues(	null,	//_lastIdGenerated: String;
								//	null,	//_lastIdGeneratedYear: String;
									1,	//_nextSeqNum: Real;
									now.format("yy").Integer,	//_seqYear: Integer
									now	//_lastGeneratedDate : Date
									);
	endif;

epilog

end;</source>
        <Parameter name="_proxy" type="CM_AutoIdGenerator"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="34fa7cbd-fc7e-4a6f-ac52-c187831a4951">
        <updating/>
