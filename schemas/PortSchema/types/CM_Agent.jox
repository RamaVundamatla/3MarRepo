    <JadeMethod name="handleJSONException" id="ef9f9e71-9f73-464c-938b-cc8e50943eec">
        <source>handleJSONException(_exc : Exception; _parsingError : Boolean io) :  Integer protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
03 February 2021	jlgmd1	Initial creation TFS 49052 MACS3 Vessel Library API

*/

constants
	JSONErrorRangeStart	: Integer = 11100;
	JSONErrorRangeEnd	: Integer = 11199;

vars
	returnVal		: Integer;
	
begin
	_parsingError := false;

	// Not an exception we care about
	if _exc.errorCode &lt; JSONErrorRangeStart or _exc.errorCode &gt; JSONErrorRangeEnd then
		returnVal := Ex_Pass_Back;
		return returnVal;
	endif;
	
	// Must be a JSON exception to get this far
	_parsingError := true;
	returnVal := Ex_Resume_Next;
	
	app.writeLog(method.qualifiedName &amp; " (" &amp; _exc.errorCode.String &amp; ") " &amp; _exc.text &amp; CrLf &amp; _exc.extendedErrorText, LogERROR);
epilog
	return returnVal;
	
end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="Exception"/>
        <Parameter name="_parsingError" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="lockExHandlerForErrorText" id="8c6f2e40-d55f-4553-8794-31efdc842383">
        <source>lockExHandlerForErrorText(_exc : LockException; _objLocked : Boolean io): Integer protected;

/*
Date			Who		Reason
03 June 2010	cnwar2	#23977

*/
vars
	returnVal : Integer;
	
begin
	returnVal := Ex_Pass_Back;
	
	_objLocked := true;
	if _exc.resumable then
		returnVal := Ex_Resume_Next;
	endif;

epilog
	return returnVal;
end;</source>
        <access>protected</access>
        <Parameter name="_exc" type="LockException"/>
        <Parameter name="_objLocked" type="Boolean" usage="io"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
