    <JadeMethod name="getSptMainTop" id="77c34c35-9cd5-4e8b-a9f8-e8f4b88428dc">
        <source>getSptMainTop() : Integer;
// ---------------------------------------------------------------------------
// Created:     02 April 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpTop : Integer;
	tmpLeft	: Integer;

begin

	if lblTable.visible then
		return (WinTopMargin + cmbTable.height + VerticalSpacing).Integer;
