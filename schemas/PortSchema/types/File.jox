<Class name="File">
    <JadeMethod name="jmtopy" id="96076779-7601-40c3-adce-cf3da56195f0">
        <updating/>
        <source>jmtopy(_target: String; _ignoreErrors, _replace, _copyFolders : Boolean) : Boolean updating;
// -----------------------------------------------------------------------------
// Created:		Nov 2006 cnwrs1
//
// Purpose:		Copies the receiver's file  to the specified file name.
//				The entire contents of the  will also be copied.
//
// Parameters:	pTarget - The name of the to copy the receiver to.
//
// Returns:		True if the copy was successful, otherwise false.
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	folderObj: FileFolder;
	fileNodeObj: FileNode;
	allFiles: FileNodeArray;
	isSuccessful, result: Boolean;
	msg, folderTarget : String;
begin
	result :=	false;
	
	create folderObj transient;
	
	folderObj.fileName := _target;
	folderObj.make();
	
	if folderObj.isAvailable() then
//		allFiles := self.files();
		foreach fileNodeObj in allFiles do
			if fileNodeObj.isKindOf(FileFolder) then
				if _copyFolders then
					folderTarget := _target&amp;'\'&amp;fileNodeObj.cnGetSimpleFileName();
					isSuccessful := fileNodeObj.FileFolder.copy(folderTarget, _ignoreErrors, _replace, _copyFolders);
					if (not _ignoreErrors) and
					   (not isSuccessful) then
						result := isSuccessful;
						app.writeLog("copy of "&amp;_target&amp;global.cnEcGetFileSeparator()&amp;fileNodeObj.name&amp;' failed '&amp;msg, 0);
						return result;
					endif;
				else
					continue;
				endif;
			endif;
			isSuccessful := fileNodeObj.File.cnCopyFile(_target &amp; global.cnEcGetFileSeparator() &amp; fileNodeObj.name, (not _replace), msg);
			if (not _ignoreErrors) and
			   (not isSuccessful) then
				result := isSuccessful;
				app.writeLog("copy of "&amp;_target&amp;global.cnEcGetFileSeparator()&amp;fileNodeObj.name&amp;' failed '&amp;msg, 0);
				return result;
			endif;
		endforeach;
	endif;
	result := true;
epilog
	delete folderObj;
	
	return result;
end;
</source>
        <Parameter name="_target" type="String"/>
        <Parameter name="_ignoreErrors" type="Boolean"/>
        <Parameter name="_replace" type="Boolean"/>
        <Parameter name="_copyFolders" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
