    <JadeMethod name="getAuditText" id="9ab6d0f1-3deb-4359-811c-9f0ae37024b2">
        <source>getAuditText(): String;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
11 May 2015	cnwrd1	Initial creation

*/

vars

	txt, str	:String;
begin
	str := "Action " &amp; self.getFunctionDescription;
	
	txt := txt &amp; self.formatAuditText(str, self.item &amp; '+' &amp; self.value &amp; '+' &amp; self.stopTable);
	
	return txt;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
