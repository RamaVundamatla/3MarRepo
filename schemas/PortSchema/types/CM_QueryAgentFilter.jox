    <JadeMethod name="qryDailyMovements" id="529fa028-63b0-416c-a9d4-9daa57691f0b">
        <updating/>
        <source>qryDailyMovements(_filter : CMQF_FilterReports input; _passport : CM_Passport input) : Integer updating;
// ---------------------------------------------------------------------------
// Created:     13 November 2002		cnwth2	
// Purpose:     
// ----------   ----------  --------------------------------------------------
vars
	numSelected			: Integer;
	jrwTrans			: CM_JRWDailyMovements;
	
	filter				: CMQF_DailyMovements;
	
begin
	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	filter := _filter.CMQF_DailyMovements;
	
	jrwTrans := self.createJRWTransient(CM_JRWDailyMovements).CM_JRWDailyMovements;
	jrwTrans.allCMIFStockLevels.clear();
	
	filter.filterForStockLevels(jrwTrans.allCMIFStockLevels, _passport);
	// Par 15343
	// Road
	filter.filterForReceivals(TRANS_TYPE_REC_ROAD, jrwTrans.allRecievalTransactions, _passport);
	filter.filterForReleases(TRANS_TYPE_REL_ROAD, jrwTrans.allReleaseTransactions, _passport);
	// Rail
	filter.filterForReceivals(TRANS_TYPE_REC_RAIL, jrwTrans.allRecievalTransactions, _passport);
	filter.filterForReleases(TRANS_TYPE_REL_RAIL, jrwTrans.allReleaseTransactions, _passport);
	// Ship
	filter.filterForReceivals(TRANS_TYPE_REC_SHIP, jrwTrans.allRecievalTransactions, _passport);
	filter.filterForReleases(TRANS_TYPE_REL_SHIP, jrwTrans.allReleaseTransactions, _passport);
		
	filter.filterForBookingRefs(jrwTrans.allBookingRefs, _passport);
	filter.filterForReleaseRequests(jrwTrans.allReleaseRequests, _passport);
	
	jrwTrans.setAllTerminals(filter.allTerminals);
	
	jrwTrans.myOperator		:= filter.myOperator;
	jrwTrans.startDateTime	:= filter.startDateTime;
	jrwTrans.endDateTime	:= filter.endDateTime;
	
	//some collections might be empty while other populated. As the numSelected
	//is used to decide whether or not to return any output, the following should suffice.
	numSelected := jrwTrans.allCMIFStockLevels.size + 
					jrwTrans.allRecievalTransactions.size + 
					jrwTrans.allReleaseTransactions.size + 
					jrwTrans.allBookingRefs.size + 
					jrwTrans.allReleaseRequests.size;
epilog
	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryDateSorter" id="02220446-bda8-413b-b54d-ce02ad00005a">
        <source>qryDateSorter(_filter : CMQF_DateSorter input; _passport : CM_Passport) : Integer;
// -----------------------------------------------------------------------------
// Created:		18 November 2009 by cnwjo3
//
// Purpose:		Actually this method doesn't currently do anything!!!!  its for future use
//
vars
	numSelected			: Integer;
	//jrwTrans			: CM_JRWTrain;

begin
/*	on CM_BreakOutException do self.xHandlerBreakOut(exception);
	
	jrwTrans := self.createJRWTransient(CM_JRWTrain).CM_JRWTrain;
	jrwTrans.allTrains.clear();
	_filter.filterObjects(jrwTrans.allTrains, _passport);

	jrwTrans.setAllTerminals(_filter.allTerminals);

	jrwTrans.myTrain := _filter.myTrain;
	
	numSelected := jrwTrans.allTrains.size;
*/
epilog
	return numSelected;
end;</source>
        <Parameter name="_filter" type="CMQF_DateSorter" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="qryDocket" id="5d6a2d19-d8ec-415d-8077-62143717aab8">
        <source>qryDocket(_filter : CM_QFDocket; _collToSearch : Dictionary; _resultColl : Collection input);
// -----------------------------------------------------------------------------
// Created:		07 May 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars 
	iter 	: Iterator;
	docket 	: CM_BOL;
begin
	iter := _collToSearch.createIterator();
	
	while iter.next(docket) do
		if docket.qryFilter(_filter) then
			_resultColl.add(docket);
		endif;
	endwhile;
epilog
	delete iter;
end;</source>
        <Parameter name="_filter" type="CM_QFDocket"/>
        <Parameter name="_collToSearch" type="Dictionary"/>
        <Parameter name="_resultColl" type="Collection" usage="input"/>
    </JadeMethod>
    <JadeMethod name="qryEventTransactions" id="2171fe0c-e943-4a10-936b-11d3db407cf9">
        <updating/>
        <source>qryEventTransactions(_filter : CMQF_FilterReports input; _passport : CM_Passport) : Integer updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 January 2020	jlgndl1	Initial creation	TFS 47780

*/

vars

	numSelected	: Integer;
	jrwTrans : CM_JRWEventTransactions;
	eventFilter : CMQF_Events;

begin

	on CM_BreakOutException do self.xHandlerBreakOut(exception);

	eventFilter := _filter.CMQF_Events;
	jrwTrans := self.createJRWTransient(CM_JRWEventTransactions).CM_JRWEventTransactions;
	
	jrwTrans.allEventTransactions.purge();
	eventFilter.filterObjects(jrwTrans.allEventTransactions, _passport);
	
	eventFilter.allTerminals.copy(jrwTrans.allTerminals);
	
	eventFilter.allEventTypes.copy(jrwTrans.allEventTypes);
	jrwTrans.fromDT.setDate(eventFilter.startDate);
	jrwTrans.fromDT.setTime(eventFilter.startTime);
	jrwTrans.toDT.setDate(eventFilter.endDate);
	jrwTrans.toDT.setTime(eventFilter.endTime);
	
	jrwTrans.includeNoTerminal 	:= eventFilter.includeNoTerminal;
	jrwTrans.includeNoUser		:= eventFilter.includeNoUser;
	jrwTrans.needFilterEventTypes := eventFilter.needFilterEventTypes;
	jrwTrans.needFilterUsers	:= eventFilter.needFilterUsers;
	
	numSelected := jrwTrans.allEventTransactions.size;
	
epilog

	return numSelected;

end;</source>
        <Parameter name="_filter" type="CMQF_FilterReports" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
