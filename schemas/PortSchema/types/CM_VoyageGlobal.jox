    <JadeMethod name="canUserAccess" id="a00e284b-368f-4ade-97b2-fd86dd74bf25">
        <source>canUserAccess(_passport : CM_Passport; _perm : Integer) : Boolean;
// ---------------------------------------------------------------------------
// Created:     10 March 2003 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//	 14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  
// ---------------------------------------------------------------------------
vars
	voy			: CM_Voyage;
	rtnValue	: Boolean;
	iter		: Iterator;
	tmpTerminal	: CM_Terminal;
	theUser		: CM_User;
	arrivalDate	: TimeStamp;
	failedDAC  :CM_DataAccessController;
	
begin
	theUser	:=	_passport.myUser;
	iter	:=	self.allVoyages.createIterator();
	
	while iter.next(voy) do
		iter.getCurrentKeys(arrivalDate,tmpTerminal); //MTN-35226
		
		if theUser.canDo(tmpTerminal, _perm) then
			rtnValue	:=	voy.canUserAccessSelf(null, failedDAC,_passport);
			break;
		endif;
	endwhile;

	return rtnValue;
epilog
	delete iter;
end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_perm" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canUserAccessSelf" id="b3196033-803b-4477-ac80-b90a87c8ca27">
        <source>canUserAccessSelf(_user : CM_User; _failedDAC  :CM_DataAccessController output; _passport: CM_Passport): Boolean;
// ---------------------------------------------------------------------------
// Created:     03 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*

Date		Who		Reason
11 Apr 2008	cnwkpd1	PAR #16378 - remove unnecessary code checking allVoyages, as result
					of check wasn't being used

*/

vars
	dac 	: CM_DataAccessController;
	voyOp	: CM_VoyageOperator;
	tmpOperator,
	lastOperator	: CM_Operator;
	voy		: CM_Voyage;
//	found	: Boolean;
	tmpUser	: CM_User;

begin
	if app.isSpecial() then
		return true;
	endif;

	// PAR-13972
	if _user &lt;&gt; null then
		tmpUser := _user;
	else
		tmpUser := _passport.myUser;
	endif;
	
/*	
	PAR #16378 - unnecessary code removed
	
	foreach voy in self.allVoyages do
		if global.isValidObject(voy) then
			//lorcan 10/9/2007 - we always allow access to scenario objects - is this ok??
			if tmpUser.allUserTerminals.includesKey(voy.myTerminal) or voy.myTerminal.isScenarioObject then
				found := true;
				break;
			endif;
		endif;
	endforeach;
	
	if (not found ) then
		// the user does not have access to any terminals that this
		// global voyage calls at
		
	endif;
*/

	dac := _passport.allDataAccessControllers[CM_Operator.name];

	if dac = null then
		// no Operator Data Access Group so view all
		return true;
	endif;
	
	if self.allVoyOpsByOpTerm.isEmpty then
		return true;
	endif;
	
	// does user have access to any of the operators
	foreach voyOp in self.allVoyOpsByOpTerm do
		tmpOperator := voyOp.myOperator;
		if tmpOperator = lastOperator then
			continue;
		endif;
		lastOperator := tmpOperator;
		if dac.canAccess(tmpOperator) then
			return true;
		endif;
	endforeach;
	
	_failedDAC := dac;
	
	return false;

end;</source>
        <Parameter name="_user" type="CM_User"/>
        <Parameter name="_failedDAC" type="CM_DataAccessController" usage="output"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkAllArchived" id="63b8a86a-f0b7-4e5f-805e-333277c12bfd">
        <source>checkAllArchived() : Boolean;
//--------------------------------------------------------------
//Created: 07 August 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	voyage : CM_Voyage;
begin
	
	foreach	voyage in self.allVoyages do
		if (not voyage.archived) then
			return false;
		endif;
	endforeach;
	
	return true;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="checkCanViewUnArchived" id="a63bffcd-f91f-4984-8489-c428a231ce1d">
        <source>checkCanViewUnArchived(_passport: CM_Passport;_perm : Integer) : Boolean;
// 14/07/2025	naviv1	MTN-35226	MTN - Usage of Iterator.getCurrentKeys  
vars
	voy			: CM_Voyage;
	rtnValue	: Boolean;
	iter		: Iterator;
	tmpTerminal	: CM_Terminal;
	theUser		: CM_User;
	arrivalDate	: TimeStamp;
	failedDAC  :CM_DataAccessController;
	
begin
	theUser	:=	_passport.myUser;
	iter	:=	self.allVoyages.createIterator();
	
	while iter.next(voy) do
		iter.getCurrentKeys(arrivalDate,tmpTerminal); //MTN-35226
		if theUser.canDo(tmpTerminal, _perm) and not voy.archived then
			rtnValue := voy.canUserAccessSelf(null, failedDAC,_passport);
			break;
		endif;
	endwhile;

	return rtnValue;
epilog
	delete iter;
end;</source>
        <Parameter name="_passport" type="CM_Passport"/>
        <Parameter name="_perm" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="delete" id="6b039155-e4a0-4074-ba48-53a5f3aea106">
        <updating/>
        <source>delete() updating;
// --------------------------------------------------------------------------------
// Created:		13 September 2006 by cnwdad1
//
/*
Date		Name	TFS#		Description
============================================================================
19 May 2010	cnwkpd1	PAR #20728 	remove isValidObject calls for performance
24 Sep 2019 jlgka1 	TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
============================================================================*/

vars
	voyagesToDeleteSet	: CM_VoyageSet;
	voyage				: CM_Voyage;
	invalid 			: Boolean;
	
begin
	create voyagesToDeleteSet transient;

	on Exception do app.handleDeletedObject(exception, voyage, invalid);
	
	// we only delete 'our' voyages
	foreach voyage in self.allVoyages do
		// check for valid object is required here as this can
		// be called when deleting the voyage object
//		if global.isValidObject(voyage) then		// cnwdad1 03/10/2006 - PAR #12646.
			if voyage.myVoyageGlobalArrival = null or voyage.myVoyageGlobalArrival = self then
				if voyage.myVoyageGlobalDeparture = null or voyage.myVoyageGlobalDeparture = self then
					if (not voyagesToDeleteSet.includes(voyage)) then
						voyagesToDeleteSet.add(voyage);
					endif;
					voyage.removeFromGlobalVoyage(self);
					//voyage.removeTIsForScenario();						// 30/06/2014 cnwmh5 // jlgka1 TFS 45614
				endif;
			endif;
//		endif;
	endforeach;
	
	voyagesToDeleteSet.purge();
	
	self.resetAuditsDuringDelete();	//25 Jan 2021	NDL	TFS 50152
	
epilog
	delete voyagesToDeleteSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="erase" id="08ffcb2a-8bc4-4809-9e13-da7576550c70">
        <updating/>
        <source>erase(_eraseLevel: Integer) updating;
//--------------------------------------------------------------
//Created: 20 November 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	voy : CM_Voyage;
	
begin
	if (not self.isTransient()) then
		foreach voy in self.allVoyages do
			voy.causeEvent(voy.myTerminal.getTerminalEvent(Voyage_Delete_Event), false, voy);
		endforeach;
	endif;

	inheritMethod(_eraseLevel);
end;</source>
        <Parameter name="_eraseLevel" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="fixArchivedFlag" id="2f8d4c3a-af37-4044-a3c2-dbc81a543f22">
        <updating/>
        <source>fixArchivedFlag() updating;
// ---------------------------------------------------------------------------
// Created:     11 April 2006 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	exclusiveLock(self);

	if self.isArchived and self.hasNonArchivedVoyages() then
		beginTransaction;
		self.isArchived := false;
		self.setMyRoot();
		commitTransaction;
	endif;

epilog
	endLoad;	// to free lock
end;</source>
    </JadeMethod>
