<Class name="Root" id="d338ccb9-1bad-462c-bb25-17b833bbcfac">
    <superclass name="DataObjects"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>Purpose:	Root object for all persistent objects of classes
			that are not LINCOBJECT subclasses. 
			General collections of persistent objects should be 
			added to this class, not to the Global class.

Occurence:	One for JetPlusSchema plus one for each subschema.

Creation:	JadeScript::rootCreate
			Run once in JetPlusSchema.
			Run again from subschema to create subschema instance.
			
Interface:	None.

Collections:None.</text>
    <DbClassMap file="JetPlusMap"/>
