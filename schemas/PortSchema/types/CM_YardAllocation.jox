        <source>cloneCriteriaTransient(_realAllocation: CM_YardAllocation) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
10 December 2012	cnwrd1	Initial creation

*/

vars

	newCriteria,
