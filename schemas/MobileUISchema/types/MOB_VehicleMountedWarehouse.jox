    <JadeMethod name="addInfoDisplay" id="e70b16c9-04a6-4b83-a63b-ed27f336b3a5">
        <source>addInfoDisplay(_message : String) protected;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 April 2010	cnwer1	Initial creation

*/

vars
	option,
	timeRemaining : Integer;
begin
	
	
	//self.lblInfo.foreColor := Black;	//10 Mar 2011	NDL	Par 27174	/ CCMS 2046
	self.lblInfo.caption:=_message;
	if not self.getTimerStatus(InfoTimer,option,timeRemaining) then
		self.beginTimer(5000,Timer_OneShot,InfoTimer);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_message" type="String"/>
    </JadeMethod>
