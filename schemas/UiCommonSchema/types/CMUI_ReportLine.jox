    <JadeMethod name="addRow" id="e865a6a3-1581-4b68-9dae-f56c1142e8de">
        <updating/>
        <source>addRow(pHeading : String; pValue : Any) updating;
// ---------------------------------------------------------------------------
// Created:     May 2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------


vars

begin
	self.myLabels.add(pHeading);
	self.myData.add(pValue.String);
end;</source>
        <Parameter name="pHeading" type="String"/>
        <Parameter name="pValue" type="Any"/>
    </JadeMethod>
    <JadeMethod name="initReport" id="8285a17c-de4e-46a0-be25-44740082961c">
        <updating/>
        <source>initReport() updating;
// ---------------------------------------------------------------------------
// Created:   May  2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.portteclogo.picture := app.getPicLogoProduct();
	self.picLogo.picture := app.getPicLogoPort();

end;</source>
    </JadeMethod>
    <JadeMethod name="initReportForLandscape" id="57445e35-d325-446b-a676-f608698d2801">
        <source>initReportForLandscape();
// ---------------------------------------------------------------------------
// Created:		March 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.picLogo.move(950,self.picLogo.top, self.picLogo.width, self.picLogo.height);
	self.frHeader.width := 1050;

	self.lblTitle01.width := 350;
	self.lblTitle03.left := 510;
	self.lblTitle03.width := 350;
	
	self.lblTitle02.width := 350;
	self.lblTitle04.left := 510;
	self.lblTitle04.width := 350;

	self.lblPrintedBylbl.width := 350;
	self.lblPrintedBy.left := 510;
	self.lblPrintedBy.width := 350;

	self.frDetail.width := 1050;
	self.lblDetail.width := 900;

end;</source>
    </JadeMethod>
    <JadeMethod name="initReportForOrientation" id="11442ff4-55f1-48ec-96c1-db1cca270081">
        <source>initReportForOrientation();
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
21 September 2011	cnwer1	Initial creation CCMS MES 1025

*/

vars

begin
	if app.printer.orientation=Print_Landscape then
		self.initReportForLandscape();
	else
		self.initReportForPortrait();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="initReportForPortrait" id="d962cb3e-be69-4abd-849e-0597b5e92b99">
        <source>initReportForPortrait();
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin
	self.picLogo.move(590,self.picLogo.top, self.picLogo.width, self.picLogo.height);
	self.frHeader.width := 690;

	self.lblTitle01.width := 200;
	self.lblTitle03.left := 350;
	self.lblTitle03.width := 200;
	
	self.lblTitle02.width := 200;
	self.lblTitle04.left := 350;
	self.lblTitle04.width := 200;

	self.lblPrintedBylbl.width := 200;
	self.lblPrintedBy.left := 350;
	self.lblPrintedBy.width := 240;

	self.frDetail.width := 690;
	self.lblDetail.width := 680;

end;</source>
    </JadeMethod>
    <JadeMethod name="printLine" id="110f531d-7d1a-4d4d-877a-2745e9f9aecf">
        <source>printLine(lLabel : String);
// ---------------------------------------------------------------------------
// Created:  May 2001 By Andrew Bishop cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin
	self.lblDetail.caption := lLabel;
	app.printer.print(self.frDetail);

end;</source>
        <Parameter name="lLabel" type="String"/>
    </JadeMethod>
    <JadeMethod name="showSheetExHandler" id="80f8ebc1-d659-4bce-941e-be8a00d44d28">
        <source>showSheetExHandler(exObj : Exception; pMethodName : String) : Integer;
// ---------------------------------------------------------------------------
// Created:  May 2001 By Andrew Bishop cnwab1
//
// Purpose:     
// Copy of showSheetExHandler on CM_ContainerEnqForm
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	if exObj.errorCode = 1010 then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Method (' &amp; pMethodName &amp; ') not defined');
		return Ex_Resume_Next;
	endif;
	
	return Ex_Pass_Back;

end;</source>
        <Parameter name="exObj" type="Exception"/>
        <Parameter name="pMethodName" type="String"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</GUIClass>
