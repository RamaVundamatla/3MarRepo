    <JadeMethod name="getWeighFormObjects" id="ae872172-5d94-475e-91ce-189cd2e53827">
        <source>getWeighFormObjects( _obj : CM_Object; _objArray: ObjectArray input ): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 March 2014	cnwndl1	Initial creation

*/

vars

	vvr : CM_VehicleVisitRecord;
	errStr : String;	//08 Jan 2018	NDL	TFS 36437

begin

	if _obj &lt;&gt; null then
		_objArray.addExclusive(_obj);
	endif;

	vvr := self.myCurrentVehicleVisit;
	if vvr &lt;&gt; null then
		_objArray.addExclusive(vvr);
		//vvr.isWeighBridgeWeighable( _objArray );
		//08 Jan 2018	NDL	TFS 36437
		vvr.isWeighBridgeWeighable( _objArray, errStr );
	else
		//04 Aug 2016	NDL	TFS 2331 - debug message
		errStr := "No current vehicle visit found!";	
	endif;
	
	if errStr &lt;&gt; null then
		app.writeLog(method.qualifiedName &amp; " " &amp; errStr, LogINFO);
		app.msgBox( errStr, "Unable to use weigh bridge interface!", MsgBox_OK_Only );
		return false;
	endif;
	
	return true;

epilog

end;</source>
        <Parameter name="_obj" type="CM_Object"/>
        <Parameter name="_objArray" type="ObjectArray" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
