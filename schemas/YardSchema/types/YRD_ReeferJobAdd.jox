    <JadeMethod name="displaySelectorResults" id="5f6749e0-f530-48f1-a9a3-252ce0f1ae57">
        <updating/>
        <source>displaySelectorResults(_resultCollection: Collection; _mode: Integer) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	objSet : ObjectSet;

begin

	if _resultCollection &lt;&gt; null and _resultCollection.isKindOf( ObjectSet ) then
		self.doProcessSearch( _resultCollection.ObjectSet, _mode );
	elseif _resultCollection &lt;&gt; null and _resultCollection.isKindOf( ObjectArray ) then	//10 Sep 2020	NDL
		create objSet transient;
		_resultCollection.copy( objSet );
		self.doProcessSearch( objSet, _mode );
	else
		self.doProcessSearch( null, _mode );
	endif;
	

epilog

	delete objSet;

end;</source>
        <Parameter name="_resultCollection" type="Collection"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doProcessSearch" id="d33ecfe9-3f0e-4cca-9d40-e7b4b062a3a0">
        <source>doProcessSearch( _resultSet : ObjectSet; _mode: Integer );
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	id : String;
	msg : String;
	objArray : ObjectArray;
	obj : Object;
	ti : CM_TrackedItem;
	isReefer : Boolean;
	needsToAdd : CM_TIArray;
	rowIndex : Integer;
	voyageJob : CM_VoyageJob;
	wleArray: CM_WLEArray;
	wle : CM_WorkListEntry;
	columnIndex : Integer;
	str : String;

begin

	create objArray transient;
	create needsToAdd transient;

	if self.optId.value then
		id := self.txtById.text.trimBlanks;
		if id = null then
			msg := app.getErrorString1( Gate_Error14, app.getErrorString( ReeferId ) );
			return;
		endif;
		
		self.myTerminal.findAllCargoWithId( id, CM_QueryOperator.Operator_Equal, null, TI_STATE_NORMAL, null,null,null,false, objArray );
		
		if objArray.isEmpty then
			msg := app.getErrorString( No_Matchin_cargo_found_onsite );
			return;
		endif;
	
	elseif self.optVoyage.value then
		voyageJob := self.cmbVoyageJob.listObject.CM_VoyageJob;
		if voyageJob = null then
			msg := app.getErrorString( Voyage_job_selected );
			return;
		endif;
		
		create wleArray transient;								
		voyageJob.getAllWLEs(wleArray);
		
		foreach wle in wleArray do
			ti := wle.getMyTrackedITem;
			if ti &lt;&gt; null then
				objArray.add(ti);
			endif;
		endforeach;		
		
	elseif self.optSelector.value then
	
		if _resultSet &lt;&gt; null then
			foreach obj in _resultSet where obj.isKindOf( CM_TrackedItem ) do
				ti := obj.CM_TrackedItem;
				objArray.add(ti);
			endforeach;
		endif;
	
	else
		return;
	endif;

	
	
	if objArray.isEmpty then
		msg := app.getErrorString( NO_Cargo_found );
		return;
	endif;
	
	foreach obj in objArray do
		ti := obj.CM_TrackedItem;
		if ti.isReefer then
			isReefer := true;
		else
			continue;
		endif;
		if not self.allDisplayedReefers.includes( ti ) then
			needsToAdd.addExclusive( ti );
		endif;
	endforeach;
	
	if needsToAdd.isEmpty then
		if not isReefer then
			msg := app.getErrorString(Matching_reefers_found);
			return;
		endif;
		msg := app.getErrorString(Addit_reefe_found_reefe_found_);
		return;
	endif;
	
	columnIndex := self.tblReefers.getColumnByRowName( ETRow_Selected );
	
	foreach ti in needsToAdd do
		self.allDisplayedReefers.add( ti );
		str := ti.getAttributeStringForDefArray(self.tblReefers.allTblDataEntRows);
		rowIndex := self.tblReefers.addItem( str );
		self.tblReefers.accessCell( rowIndex, columnIndex ).text := "1";		// selected by default
		self.tblReefers.accessRow( rowIndex ).itemObject := ti;
		
	endforeach;
	

epilog

	if msg &lt;&gt; null then
		app.msgBox( msg, app.getErrorString(Error), MsgBox_OK_Only );
	endif;
	delete objArray;
	delete needsToAdd;

end;</source>
        <Parameter name="_resultSet" type="ObjectSet"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getXMLSettingsForSave" id="85cfeb9d-a715-461a-8ec7-878e53f77c66">
        <updating/>
        <source>getXMLSettingsForSave(): String updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 July 2020	jlgndl1	Initial creation	TFS 49581

*/

vars

	xmlStr : String;

begin

	xmlStr := inheritMethod();
	
	xmlStr := xmlStr &amp; self.tblReefers.getXmlStrForColumns(true);
	
	return xmlStr;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
