    <JadeMethod name="getDrawingColour" id="409ff2a8-341c-48fe-8065-cab78364e48f">
        <source>getDrawingColour(pColourMode: Integer): Integer;
// ---------------------------------------------------------------------------
// Created:     05 February 2002 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	tmpTempRange	: CM_TempRange;
	ls			: Boolean;

begin

	app.cmsBeginLoad(ls);

	if pColourMode = TI_ColourMode_Temperature then
		tmpTempRange := app.myRoot.allTempRanges[self.getTemperature];
		if tmpTempRange &lt;&gt; null then
			sharedLock(tmpTempRange);
			return tmpTempRange.colour;
		endif;
	endif;

	return inheritMethod(pColourMode);

epilog
	app.cmsEndLoad(ls);

end;</source>
        <Parameter name="pColourMode" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfo" id="7d48b53b-9eed-4e07-a529-b6a2f2b2caff">
        <source>getExtraInfo(_dataContainer : CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 25 June 2003 sgp			Use CM_DataContainer to hold data
// ---------------------------------------------------------------------------

vars
	block : CM_DataContainerBlock;

begin
	inheritMethod(_dataContainer);
		
	if self.requiresTemperature then
	//Things with a weird temperature are getting here somehow
//	if self.temperature &lt;&gt; NULL_TEMPERATURE then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_TemperatureExtra), DC_Label, 1, null);
		block.addNewItem(self.getDisplayTemperature(true, false), DC_Data, 1, null);
	endif;
	if self.isConnected then
		if self.towerId &lt;&gt; null then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(CM_Connected_To_Tower), DC_Label, 1, self.getTower);
			block.addNewItem(self.towerId, DC_Data, 1, self.getTower);
		endif;
	endif;
	if self.hasCOU then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Attached_COU_ID), DC_Label, 1, self.getCou);
		block.addNewItem(self.couId, DC_Data, 1, self.getCou);
	endif;
	if self.hasGeneratorSetAttached() then	//Par17775. ccms1045. September 2008
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Attached_GenSet), DC_Label, 1, self.getGenerator);
		block.addNewItem(self.generatorId, DC_Data, 1, self.getGenerator);
	endif;
	

	if self.getMyGapPower &lt;&gt; null then
		if self.getPrimaryLocation(REAL_MODE).myTerminalArea.isKindOf(CM_ForkLiftStack) then
			block := _dataContainer.addNewBlock;
			block.addNewItem(app.getErrorString(CM_Power_Point), DC_Label, 1, self.getMyGapPower);
			block.addNewItem(self.getMyGapPower.getID, DC_Data, 1, self.getMyGapPower);
		endif;
	endif;
	
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
    <JadeMethod name="getExtraInfoFirst" id="0300015b-22a7-4f46-9e52-3f5ed712600a">
        <source>getExtraInfoFirst(_dataContainer : CM_DataContainer);
// ---------------------------------------------------------------------------
// Created:		December 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	block : CM_DataContainerBlock;

begin

	if self.hasReeferRemarks then
		block := _dataContainer.addNewBlock;
		block.addNewItem("Reefer Remarks", DC_Label, 1, null);
		block.addNewItem(self.getReeferRemarks.trimBlanks, DC_Data, 1, null);
	endif;

	inheritMethod(_dataContainer);
			
	if self.hasCOU then
		block := _dataContainer.addNewBlock;
		block.addNewItem(app.getErrorString(CM_Attached_COU_ID), DC_Label, 1, self.getCou);
		block.addNewItem(self.couId, DC_Data, 1, self.getCou);
	endif;
	
end;</source>
        <Parameter name="_dataContainer" type="CM_DataContainer"/>
    </JadeMethod>
