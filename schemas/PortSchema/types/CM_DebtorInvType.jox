    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="invConfig"/>
    <ExplicitInverseRef name="allPackageInvoices" id="ea1c69ca-531f-4d87-a7ca-e0ef74a0fcbf">
