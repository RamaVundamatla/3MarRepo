    <JadeMethod name="showColourLegend" id="c07274f7-e2cf-4366-adc3-d8a5e802c894">
        <source>showColourLegend();
//----------------------------------------------------------------
//	Created:	23 October 2003	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	colLegend	: CMUI_ColourLegend;
	
begin
	create colLegend;
	self.setNavigatorHeading( colLegend.caption ); 
	colLegend.centreWindow;
	
	colLegend.addLegendItem("Load List Cargo", Black, self.ColourYellowLight, null, false);
	colLegend.addLegendItem("System Cargo", Black, self.ColorGreenLight, null, false);
	colLegend.addLegendItem("System Cargo discrepancy", Red, self.ColorGreenLight, null, true);
	
	colLegend.showModal;
	
epilog
	delete colLegend;
	// cnwrl1 16/04/2009 PAR 19440
	// reset the navigation heading.
	self.setNavigator;
	
end;
</source>
    </JadeMethod>
    <JadeMethod name="showColumnOrganiser" id="4f274d26-2cd3-4272-b2c2-c935258c75ea">
        <source>showColumnOrganiser();
/*
----------   ----------  --------------------------------------------------
Created:	01 March 2007 By cnwmo1

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	startRow,
	rowIndex,
	visibleCount,
	endRow : Integer;
	
begin
	inheritMethod();	
	
	//navra1 - MTN-36126 - 24th Sep 2025 - start
	if self.context = "AUTO" then
		if self.tblData.allowsColumnFilters then
			self.tblData.applyColumnFilter(self.allColumnFilters);
		endif;
		startRow := 1;
		endRow := self.tblData.rows;
		foreach rowIndex in startRow to endRow where self.tblData.rowVisible[rowIndex] do
			visibleCount := visibleCount + 1;			
		endforeach;
		self.staStatusBar.caption := app.getErrorString2(Total_Comparisons,(tblData.rows-1).String,self.cmbView.text.toLower)&amp; ". " &amp; (visibleCount-1).String &amp; " rows displayed";		
	else
		self.staStatusBar.caption := app.getErrorString2(Total_Comparisons,(tblData.rows-1).String,self.cmbView.text.toLower);
	endif;
	//navra1 - MTN-36126 - 24th Sep 2025 - end


end;
</source>
    </JadeMethod>
