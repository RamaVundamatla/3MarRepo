    <JadeMethod name="wsRESTPostBooking" id="1b0c9287-e507-4c36-bb1b-6329a0707e07">
        <source>wsRESTPostBooking(_loginString: String; _json : String; _expectFailure: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 March 2023	navpw1	Initial creation TFS: 57264 (57434)

*/

vars
	request				: WS_RestBookingArray;
	requestLogin		: WS_RESTLoginAuthRequest;
	webService			: MasterTerminalAPIService;
	parser				: JadeJson;
	transientJSONObjs	: ObjectArray;
	response 			: WS_Response;
	login 				: WS_InterfaceObject;
	jsonLogin			: String;
	responseLogin  		: WS_NAuthTokenResponse;
	ref 				: String;
	jsonFormat			: String;
	newJson 			: String;
	
begin
	create webService transient;
	create transientJSONObjs transient;
	create parser transient;
	
	// call POST /login
	requestLogin := parser.parse(_loginString, WS_RESTLoginAuthRequest, transientJSONObjs).WS_RESTLoginAuthRequest;
	webService.setPropertyValue(WS_RestWebServiceProvider::requestPath.name, "/login");
	
	login := webService.postLogin(requestLogin);
	if not login.isKindOf(WS_NAuthTokenResponse) then
		delete login;
		if webService.httpStatusCode = HttpResponseUnauthorized then
			return HttpResponseUnauthorized.String &amp; " Unauthorized - Username / Password not OK";
		endif;
		return "Login failed";
	endif;
	
	responseLogin := login.WS_NAuthTokenResponse;
	webService.unitTestData.addAssoc("HTTP_AUTHORIZATION", "Bearer " &amp; responseLogin.accessToken);
	
	webService.setPropertyValue(WS_RestWebServiceProvider::requestPath.name, "/booking");
	
	request := parser.parse(_json, WS_RestBookingArray, transientJSONObjs).WS_RestBookingArray;
	
	// call the post/customer
	response := webService.postBooking(request);
	
	// If we're expecting to fail, then return early
	if _expectFailure then
		if webService.httpStatusCode = HttpResponseOK then
			return "Failure expected, got 200 OK";
		endif;
		return response.WS_Response.allErrors.first.text;
	endif;
	
	if webService.httpStatusCode &lt;&gt; HttpResponseOK then
		if response.allErrors.size &gt; 0 then
			app.writeLog(response.allErrors.first.text, LogERROR);
		endif;
		return method.qualifiedName &amp; " Bad Response Code, expecting 200 OK, got " &amp; webService.httpStatusCode.String &amp; ". Check UnitTest runner logs for more details" &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	endif;
	
	return null;
	
	// Not used,just here to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsRESTPostBooking.name;
	
epilog
	if webService.objectsToBeDeleted.isNotEmpty then
		webService.objectsToBeDeleted.purge;
	endif;
	delete webService;
	delete parser;
	delete requestLogin;
	delete request;
	transientJSONObjs.purge();
	delete transientJSONObjs;

end;</source>
        <Parameter name="_loginString" type="String"/>
        <Parameter name="_json" type="String"/>
        <Parameter name="_expectFailure" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="wsRESTPostCargo" id="e54ad106-7520-432d-9567-d94abe88742d">
        <source>wsRESTPostCargo(_operator: String; json: String io; expectErrors: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who			Reason
19 February 2024	navsaa30	Initial creation
22 May 2024			navmd1		TFS 64234 Return Pin information when creating prenotes
04 July 2024		navmd1		TFS 65034 Allow logging in as Cuxport to test CUX specific workflow

*/

vars
	request 			: WS_RestCargoParentArray;
	requestLogin		: WS_RESTLoginAuthRequest;
	webService			: MasterTerminalAPIService;
	parser				: JadeJson;
	transientJSONObjs	: ObjectArray;
	response 			: WS_RestResponse;
	ref 				: String;
begin
	create webService transient;
	create transientJSONObjs transient;
	create parser transient;
	
	// Login Request
	self.loginRestWithOperator(webService, _operator);	
	
	// set up the WS_Request object
	webService.setPropertyValue(WS_RestWebServiceProvider::requestPath.name, "/cargo");
	request := parser.parse(json, WS_RestCargoParentArray, transientJSONObjs).WS_RestCargoParentArray;
	
	// call the put/WorkPointJobSheet
	
	
	response := webService.postCargo(request);
	
	// If we're expecting to fail, then return early
	if expectErrors then
		if webService.httpStatusCode = HttpResponseOK then
			return "Failure expected, got 200 OK";
		endif;
		return response.allErrors.first.text;
	endif;
	
	if webService.httpStatusCode &lt;&gt; HttpResponseOK then
		if response.allErrors.size &gt; 0 then
			app.writeLog(response.allErrors.first.text, LogERROR);
		endif;
		return method.qualifiedName &amp; " Bad Response Code, expecting 200 OK, got " &amp; webService.httpStatusCode.String &amp; ". Check UnitTest runner logs for more details" &amp; CrLf &amp; app.myPassport.getErrorsAsString;
	endif;
	
	// Bit of a hack to get the response back ;)
	json := parser.generateJson(response, JadeJson.Format_Json_Microsoft);
	
	return null;
	
	// Not used,just here to provide a reference from the super schema super class method 
	ref := CM_UnitTestAgent::wsRESTPostCargo.name;

epilog
	if webService.objectsToBeDeleted.isNotEmpty then
		webService.objectsToBeDeleted.purge;
	endif;
	delete webService;
	delete parser;
	delete requestLogin;
	delete request;
	transientJSONObjs.purge();
	delete transientJSONObjs;
end;</source>
        <Parameter name="_operator" type="String"/>
        <Parameter name="json" type="String" usage="io"/>
        <Parameter name="expectErrors" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
