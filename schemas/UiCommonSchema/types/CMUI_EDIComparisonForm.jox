    <JadeMethod name="initTableData" id="2f959c79-7cd3-4706-9906-72090a4153b6">
        <source>initTableData(_etDefName :String) protected;
/*
Date		Who		Reason
01 Aug 2013	cnwcs5	CCMS POL 2221 / par 32094(2)
*/
vars
	entTableView	: EntTableView;
	entTableDef		: EntTableDef;
	table			: CM_DataTable;
begin
	table := self.tblData;
	
	table.userInputEnabled 	:= false;
	table.selectMode 		:= CM_EntryTable.SelectMode_Multiple;
	table.multiSelect := CM_BaseTable.MultiSelect_Simple;
	table.selectionType 	:= CM_EntryTable.SelectionType_Row;
	table.rows 				:= table.fixedRows;
	table.readOnly 			:= true;	
	table.fixedColumns 		:= 2;
	table.columns			:= table.fixedColumns;
	// set headings for fixed columns
	table.setCellText (1, 1, '*' &amp; Tab &amp; app.getErrorString (Source));

	table.cnEcResizeContents();
	
	table.disallowColumnSorter := true;
	
	entTableDef := app.myController.getEntTableDef(_etDefName);
	
	if entTableDef &lt;&gt; null then
		table. setTblDataEntRowsFromDefUser(entTableDef, true);
	endif;
	
	self.setEntTableRowsForDBItem (table.allTblDataEntRows, self.allEntTableRowsForDBItem);
end;</source>
        <access>protected</access>
        <Parameter name="_etDefName" type="String"/>
    </JadeMethod>
