    <JadeMethod name="pxyCreateUpdateProxy" id="df7faf3b-cb46-46b7-9706-a3617751bc86">
        <source>pxyCreateUpdateProxy(): SelfType;
// ---------------------------------------------------------------------------
// Created:		December 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// 20/04/2011	cnwmh5		PAR #27401 - Add code to handle prossible exceptions occurring when
//							trying to create the proxy

vars
	proxy:SelfType;
	completedOK		: Boolean;
	
begin

	proxy := inheritMethod();
	
	proxy.fortyFront := self.fortyFront or self.fortyBack; // in the GUI we are only interested in fortyFront. These 2 boolean are set correctly in setForUpdate
	
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxy;
	
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxy;
	endif;	
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setAnAttributeFromController" id="57e855e3-368b-4d3d-aa9f-083f94ce2047">
        <updating/>
        <source>setAnAttributeFromController(_theAttribute: String) updating;
// ---------------------------------------------------------------------------
// Created:		23 May 2008 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
// ---- WHO --- WHEN ----- WHY---------------------------------------------
// ---------------------------------------------------------------------------
//       AKB    23MAY2008     PAR 16415 CCMS 1029 30,45,53s
// ---------------------------------------------------------------------------
vars
	aftSlot : CM_SlotDefnVoyage;
begin
	inheritMethod(_theAttribute);

	if not self.isTransient then // PAR 18682 - Proxy does not have a slotcontroller reference
		// PAR 16415 CCMS 1029
		if _theAttribute = CM_SlotRequest.Attribute_FiftyThree then
			self.mySlotController.setIs53ft(self.is53);
			aftSlot := self.myAftSlot.CM_SlotDefnVoyage;
			if aftSlot &lt;&gt; null then
				aftSlot.mySlotController.setIs53ft(self.is53);
				//22 Jun 2020	NDL	TFS 49408 - Removed
				//aftSlot := aftSlot.myAftSlot.CM_SlotDefnVoyage;
				//if aftSlot &lt;&gt; null then
				//	aftSlot.mySlotController.setIs53ft(self.is53);
				//endif;
			endif;
		endif;
		if _theAttribute = CM_SlotRequest.Attribute_Thirty then
			self.mySlotController.setIs30ft(self.is30);
			//22 Jun 2020	NDL	TFS 49408 - Removed
			//aftSlot := self.myAftSlot.CM_SlotDefnVoyage;
			//if aftSlot &lt;&gt; null then
			//	aftSlot.mySlotController.setIs30ft(self.is30);
			//endif;
		endif;
		
		// PAR 18682 CCMS SFW 1055
		if _theAttribute = CM_SlotRequest.Attribute_FortyFive then
			self.mySlotController.setIs45ft(self.is45);
			aftSlot := self.myAftSlot.CM_SlotDefnVoyage;
			if aftSlot &lt;&gt; null then
				aftSlot.mySlotController.setIs45ft(self.is45);
			endif;
		endif;
	endif;
	
end;</source>
        <Parameter name="_theAttribute" type="String"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="bbf70184-fe5e-42a6-a544-4084deb114ed">
        <updating/>
        <source>setForUpdate(_proxy: SelfType;_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     03 September 2008 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars
	aftSlot : CM_SlotDefnVoyage;

begin
	inheritMethod(_proxy,_passport);
	
	//epr par 34518 24/11/14
	if self.mySlotController &lt;&gt; null then
	
		// PAR 17841
		self.mySlotController.setIs53ft(self.is53);
		aftSlot := self.myAftSlot.CM_SlotDefnVoyage;
		if aftSlot &lt;&gt; null then
			aftSlot.mySlotController.setIs53ft(self.is53);
		//22 Jun 2020	NDL	TFS 49408 - removed
		//	aftSlot := aftSlot.myAftSlot.CM_SlotDefnVoyage;
		//	if aftSlot &lt;&gt; null then
		//		aftSlot.mySlotController.setIs53ft(self.is53);
		//	endif;
		endif;
		self.mySlotController.setIs30ft(self.is30);
		//22 Jun 2020	NDL	TFS 49408 - removed
		//aftSlot := self.myAftSlot.CM_SlotDefnVoyage;
		//if aftSlot &lt;&gt; null then
		//	aftSlot.mySlotController.setIs30ft(self.is30);
		//endif;
		
		// PAR 18682
		self.mySlotController.setIs45ft(self.is45);
		aftSlot := self.myAftSlot.CM_SlotDefnVoyage;
		if aftSlot &lt;&gt; null then
			aftSlot.mySlotController.setIs45ft(self.is45);
		endif;
	endif;

epilog

end;</source>
        <Parameter name="_proxy" type="SelfType"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setForUpdateOrdinals" id="b57400bc-a1ab-44ec-82a0-4e0e0d443537">
        <updating/>
        <source>setForUpdateOrdinals(_deckOrd: Integer; _cellOrd: Integer; _tierOrd: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
