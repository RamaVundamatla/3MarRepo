    <JadeMethod name="hasResDetAlreadyAssigned" id="df8a0fa3-0d99-4d78-9dc7-430863421c22">
        <source>hasResDetAlreadyAssigned( _reserveDetail : CM_ReserveDetail ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 February 2017	cnwndl1	Initial creation	TFS 3514

*/

vars

	iter : Iterator;
	wle : CM_WorkListEntry;
	req : CM_Request;
	invalid: Boolean;

begin

	iter := self.allRailWLELoad.createIterator;
	
	on Exception do app.handleDeletedObject( exception, req, invalid );
	while iter.next( wle ) do
		if wle.status &lt;&gt; WLE_UNACTIONED then
			continue;
		endif;
		req := wle.myRequest;
		invalid := false;
		if req = null or not req.isKindOf( CM_DeliveryRequest ) then
			continue;
		endif;
		if req.myReserveDetail = _reserveDetail then
			return true;
		endif;
	endwhile;
	
	return false;

epilog

	delete iter;

end;</source>
        <Parameter name="_reserveDetail" type="CM_ReserveDetail"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="hasRestrictions" id="2060d99f-8d9d-45d9-b363-00e31e0c37f0">
        <source>hasRestrictions(mode : Integer) : Boolean;
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 30/06/2009	consw1		PAR 19913 - SFW1067 Rail Simplifications
// 19/08/2010   cnwer1		PAR 25501 - removed the sharedLocks -were not being released
vars
	value : Boolean;

begin

	if mode = NULL_RESTRICTION then
		if self.myTerminalArea &lt;&gt; null then
			if self.myTerminalArea.labourRestriction &lt;&gt; null then //location restrictions do not apply here
				value := true;
			endif;
		endif;
	elseif mode = LOCATION_RESTRICTION then
		value := false;
	elseif mode = LABOUR_RESTRICTION then
		if self.myTerminalArea &lt;&gt; null then
			if self.myTerminalArea.labourRestriction &lt;&gt; null then //location restrictions do not apply here
				value := true;
			endif;
		endif;
	else //oops this should never happen
		app.setContinueCMExceptions(false);
	//	app.raiseCMException(ERR_INVALID_MODE, null, null);
		app.raiseCMException1( Invalid_move_mode_passed, method.qualifiedName, null, null );	//13 Apr 2021	NDL	TFS 50906
		return false;	
	endif;

	return value;

end;</source>
        <Parameter name="mode" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isAvailForMultiMove" id="a649eaa4-0f66-4294-a7c5-b27ef1560cf6">
        <source>isAvailForMultiMove(): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 December 2012	cnwndl1	Initial creation	Par 30885

*/
vars

	ti : CM_TrackedItem;

begin

	if self.myWagon = null then
		return false;
	endif;
	
	if not self.allTrackedItems.isEmpty then
		foreach ti in self.allTrackedItems do
			if self.myWagon.isTIOutward(ti) then
				// this one is not coming off.
				return false;
			endif;
		endforeach;
	endif;
	if not self.allQueuedFutureMoves.isEmpty then
		return false;
	endif;
	if not self.allPlannedFutureMoves.isEmpty then
		return false;
	endif;
	if not self.allTrackedItemOSBackEnds.isEmpty then
		foreach ti in self.allTrackedItemOSBackEnds do
			if self.myWagon.isTIOutward(ti) then
				// this one is not coming off.
				return false;
			endif;
		endforeach;
	endif;
	if not self.allTrackedItemOSBackEndsPd.isEmpty then
		return false;
	endif;
	if not self.allTrackedItemOSBackEndsQd.isEmpty then
		return false;
	endif;

	return true;
	
epilog
	
end;
</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
