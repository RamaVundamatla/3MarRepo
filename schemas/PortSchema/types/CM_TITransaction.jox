    <JadeMethod name="getCustomsAgent" id="22822eca-c5e9-48e2-852c-f5febe820fdc">
        <source>getCustomsAgent() : CM_CustomsAgent;
// ---------------------------------------------------------------------------
// Created:		21 February 2006  By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	ca : CM_CustomsAgent;
begin
	if app.myRoot = null 
	or self.customsAgentCode = null then
		return null;
	endif;
	
	ca := app.myRoot.allCustomsAgents[self.customsAgentCode];
	
	return ca;
end;</source>
