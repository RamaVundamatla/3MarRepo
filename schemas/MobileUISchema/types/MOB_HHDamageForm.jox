    <JadeMethod name="doResizeControls" id="39edc27a-a9a0-4178-abe0-9e3ee3b6aea9">
        <updating/>
        <source>doResizeControls(_initialSetup: Boolean) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18/02/2015	cnwndl1	Initial creation	Par 35406
25/05/2015	cnwdap1	PAR #36311 Don't do the cnEc resize stuff, this overwrites what the table itself
						has already decided the column widths should be, based on the text extent of
						the Position and Damage codes (see CM_DamageTable::initCombos). 
						cnAdjustColumnWidths for an empty table just sets all columns to minimum 
						and the last column to maximum.
*/

vars

	cTop : Real;
	stdWidth : Real;
	cWidth : Real;
	stdHeight : Real;
	cHeight : Real;
	tabIndex : Integer;
	
	iter : Iterator;
	remark : CM_PredefinedRemark;

begin

	self.setResizeableMarginAndFontSize();
	stdWidth := self.clientWidth - self.resizedMargin - self.resizedMargin;
	stdHeight := self.getStdControlHeight;
	
	cTop := self.resizedMargin;
	cWidth := stdWidth - (self.getSearchButtonSpace() * 2);
	cHeight := stdHeight;
	tabIndex := 4000;
	
	if _initialSetup then
		self.txtCargoId.setAndIncrementTabIndex( tabIndex );
		self.txtCargoId.visible := true;
	endif;
	self.txtCargoId.move( 	self.resizedMargin,
							cTop,
							cWidth,
							cHeight );
						 
	cWidth := self.getStdControlHeight();
	if _initialSetup then
		self.btnPartCargoId.setAndIncrementTabIndex( tabIndex );
		self.btnPartCargoId.visible := true;
	endif;
	self.btnPartCargoId.move(	self.txtCargoId.left + self.txtCargoId.width + self.resizedMargin,
								cTop,
								cWidth,
								cHeight );
	
	if _initialSetup then
		self.btnPhoto.setAndIncrementTabIndex( tabIndex );
		self.btnPhoto.visible := true;
		self.btnPhoto.enabled := self.canTakePhoto();
	endif;
	self.btnPhoto.move(	self.btnPartCargoId.left + self.btnPartCargoId.width + self.resizedMargin,
						cTop,
						cWidth,
						cHeight );
	
	cTop := cTop + self.txtCargoId.height + self.resizedMargin;
	cHeight:= (self.clientHeight - cTop - self.getCMDButtonsHeight() - self.resizedMargin - self.resizedMargin - stdHeight - self.resizedMargin);
	if _initialSetup then
		self.tblDamages.setAndIncrementTabIndex( tabIndex );
		self.tblDamages.visible := true;
	endif;
	self.tblDamages.move(	self.resizedMargin, 
							cTop, 
							stdWidth, 
							cHeight);
							
	cTop := cTop + self.tblDamages.height + self.resizedMargin;
	cHeight := stdHeight;
	if _initialSetup then
		self.chkToDo.setAndIncrementTabIndex( tabIndex );
		self.chkToDo.visible := false;
	endif;
	self.chkToDo.move(	self.resizedMargin, 
							cTop, 
							stdWidth, 
							cHeight);

	if _initialSetup then
		self.tblDamages.parentAspect:=Control.ParentAspect_StretchBoth;
		self.tblDamages.init;
		
		//epr CCMS 1099 I know this has 1 fixed row colour for vehicle mounted apps 
		if app.myVMAgent &lt;&gt; null then
			self.tblDamages.accessRow(1).backColor:=app.myVMAgent.getMyScreenMode.screenBackColour;
		endif;
	endif;
	
	//self.tblDamages.cnAdjustColumnWidths();			// PAR #36311

	inheritMethod(_initialSetup);

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_initialSetup" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="593df5e0-ca0a-4f70-983c-f88ec1ff1f96">
        <source>doSave() : Boolean protected;
/*
Date		Who		Reason
29/01/2009	cnwcp2	Initial creation
06/10/2016	cnwdap1	TFS 2788 Damage validation - raise as passport warnings, not a message box
*/

vars
	errors : String;
	sessionAgent : CM_MobileAgent;
	damageInterface : IF_DamageDetails;
	toDoTaskDesc	: CM_ToDoTaskDesc;		//cnwas3 par 24175 begin
//	addingToDo		: Boolean;				//cnwas3 par 24175 end
	addCompRemTodo	: Integer;	// 1 = add, 2 = complete, 3 = remove 16 Mar 2016	NDL TFS 1673
	result 			: Integer;				// TFS 2788
begin
	app.mousePointer := self.MousePointer_HourGlass;
	
	sessionAgent:=self.getSessionAgent;
	
	if sessionAgent.getMyProxyObject = null then
		return false;
	else
		damageInterface:=sessionAgent.getMyProxyObject.IF_DamageDetails;
	endif;
	
	if damageInterface = null then
		return false;
	endif;
	
	if not self.validateDamageData() then				// TFS 2788
		app.myPassport.setWarningsIgnored(false);		// TFS 2788
		result := app.showErrorWarningDialog(app.getString(Complete_TDTask), app.myPassport, ErrWarnMode_Add + ErrWarnMode_CanAckWarnings);	// TFS 2788
	endif;												// TFS 2788
	app.myPassport.clearErrorsWarnings();				// TFS 2788
	if result &lt;&gt; IDOK then								// TFS 2788
		return false;									// TFS 2788
	endif;												// TFS 2788
	
	self.tblDamages.setProxyFromTable(damageInterface, errors, null);
	
	//addingToDo := self.chkToDo.value; //cnwas3 par 24175 begin
	if self.chkToDo.value then
		addCompRemTodo := 1;
	else
		addCompRemTodo := 3;
	endif;
	
	if self.myDamageCargoCheckItem &lt;&gt; null then
		toDoTaskDesc := self.myDamageCargoCheckItem.myToDoTaskDesc;
	else
		//16 Mar 2016	NDL TFS 1673
		toDoTaskDesc := self.myToDoTaskDesc;
		addCompRemTodo := 2;
	endif;
	
	if sessionAgent.updateDamages(damageInterface, toDoTaskDesc, addCompRemTodo) then	//cnwas3 par 24175 end
		//if errors &lt;&gt; null then													// TFS 2788
		//	self.msgBox(errors,app.getErrorString(Error),MsgBox_OK_Only, false);	// TFS 2788
		//endif;																	// TFS 2788
		return true;
	else
		return false;
	endif;
epilog
	app.mousePointer := self.MousePointer_Default;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
