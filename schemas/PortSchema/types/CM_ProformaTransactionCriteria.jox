    <JadeMethod name="delete" id="bee37430-5ebf-4feb-a07f-bf618faf47c5">
        <updating/>
        <source>delete() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
24 July 2012	cnwndl1	Initial creation

*/

vars

begin

	if not self.allCriteria.isEmpty then
		self.allCriteria.purge();
	endif;

epilog

end;</source>
