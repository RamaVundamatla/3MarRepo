<Class name="JadeReportWriterManager">
    <JadeMethod name="cnEcGetAllReports" id="eb5de016-8b5a-4f39-8ee6-8c75d796ea65">
        <source>cnEcGetAllReports(pAllReports:CnEcReportWriterReportArray io);
// --------------------------------------------------------------------------------
// Created:		26 March 2001 by cnwdad1
//
// Purpose:		This method will return an array (whose membership is of the
//				JadeReportWriterReport class) of all Report Writer Reports.
//
// Parameters:	pAllReports - The array of Report Writer Reports.
//
// Returns:		The populated array of Report Writer Reports.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	rwManagerObj				: JadeReportWriterManager;
	rwReportObj					: JadeReportWriterReport;
	allReportWriterFolderNames	: HugeStringArray;
	allReportWriterReportNames	: StringArray;
	reportName					: String;

begin
	pAllReports.clear();
	
	create rwManagerObj transient;
	create allReportWriterFolderNames transient;
	create allReportWriterReportNames transient;
	
	rwManagerObj.getAllReportNames(allReportWriterFolderNames, allReportWriterReportNames);
	
	foreach reportName in allReportWriterReportNames do
		rwReportObj	:=	rwManagerObj.getReport(reportName);
		pAllReports.add(rwReportObj);
	endforeach;
epilog
	delete rwManagerObj;
	delete allReportWriterFolderNames;
	delete allReportWriterReportNames;
end;</source>
        <Parameter name="pAllReports" type="CnEcReportWriterReportArray" usage="io"/>
    </JadeMethod>
</Class>
