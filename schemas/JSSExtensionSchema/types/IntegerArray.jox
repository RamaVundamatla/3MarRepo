<CollClass name="IntegerArray">
    <JadeMethod name="jssDoSort" id="1a2afb37-77e8-4381-b956-cac7348539c9">
        <lockReceiver/>
        <updating/>
        <source>jssDoSort(pTheSorter : JSSSorter) lockReceiver, updating, protected;
// --------------------------------------------------------------------------------
// Created:		08 February 2001 by cnwdad1
//
// Purpose:		Refer to method implementation on the Array class.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	arrayPointer	: Integer;
	integerValue	: Integer;
	theSortKey		: Object;
	anyValue		: Any;

begin
	foreach integerValue in self do
		pTheSorter.addValue(integerValue);
	endforeach;
	
	self.purge();
	
	foreach theSortKey in pTheSorter.mySortColl do
		self.add(theSortKey.JSSSortKey.getValue().Integer);
	endforeach;
end;</source>
        <access>protected</access>
        <Parameter name="pTheSorter" type="JSSSorter"/>
    </JadeMethod>
</CollClass>
