<Class name="CMIF_RDTTrackDrawElement" id="2d1f00ed-4495-42d5-8cb8-8e6fae2c9752">
    <superclass name="CMIF_RDTDrawElement"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="cmtrans"/>
    <Constant name="NORMAL" id="05b9d38e-214b-48ea-9c5a-6d51d0047be2">
        <source>1</source>
        <type name="Integer"/>
    </Constant>
    <PrimAttribute name="type" id="03744f92-07f6-40a6-8a9e-c64ed4968415">
        <embedded/>
        <type name="Integer"/>
