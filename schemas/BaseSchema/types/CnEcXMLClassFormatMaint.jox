    <JadeMethod name="btnUpdateProp_click" id="a4a7760e-20ab-46ca-8144-6f4c429ae432">
        <controlMethod name="Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnUpdateProp_click(btn: Button input) updating;

begin
	app.mousePointer	:=	Busy;
	lblStatus.caption := "";

	if lstFormatAttribs.listIndex &lt; 1 then // we have a classFormat
		lblStatus.caption := self.updateFormatClass();
	else	// we have a property	
		lblStatus.caption := self.updatePropertyFormat();
	endif;
epilog
	app.mousePointer	:=	Idle;
end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="checkTagWithForIllegalChars" id="ac70ce2a-a9f5-4559-b807-61b05c467c4e">
        <source>checkTagWithForIllegalChars():Boolean protected;

vars
	string			: String;
	foundIllegal	: Integer;
	
begin
	string			:=	txtTagWith.text;
	foundIllegal	:=	string.pos("&lt;",1);
	foundIllegal	:=	foundIllegal + string.pos("&gt;",1);
	foundIllegal	:=	foundIllegal + string.pos("'",1);
	foundIllegal	:=	foundIllegal + string.pos('"',1);
	foundIllegal	:=	foundIllegal + string.pos("&amp;",1);

	if foundIllegal &gt; 0 then
		app.msgBox ("&lt;  &gt;  '  " &amp; '" ' &amp; " &amp;      are illegal charaacters within an XML Tag", "Error", 0);
		return false;			
	endif;
	
	return true;
end;</source>
        <access>protected</access>
        <ReturnType type="Boolean"/>
    </JadeMethod>
