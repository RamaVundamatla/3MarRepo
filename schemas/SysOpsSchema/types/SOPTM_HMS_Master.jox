vars
	theForm : SOP_HMS_TableMaintForm;
begin
	
	inheritMethod (pObj);
	self.setTblData1Rows(pObj);
	self.setTblShtData4(pObj);
	
	// TFS 2734 CNWAB1
	if not app.myCurrentUserCan(self.myForm.myTerminal, self.myForm.permissionMaint) then
		theForm := self.myForm.SOP_HMS_TableMaintForm;
		theForm.btnDeleteInput4.enabled:= false;
		theForm.btnEditInput4.enabled:= false;
		theForm.btnNewInput4.enabled:= false;
	endif;
end;</source>
        <Parameter name="pObj" type="HMS_Master"/>
    </JadeMethod>
</Class>
