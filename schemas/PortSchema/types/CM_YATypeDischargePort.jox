    <JadeMethod name="getAllCriteriaValues" id="23d1cd61-4456-4e0b-8a46-6be2195b4d01">
        <source>getAllCriteriaValues(_terminalObj:CM_Terminal; _allCriteriaValues: ObjectSet input; _filter : Integer; _allDependentObjs : CM_ObjectArray);
// --------------------------------------------------------------------------------
// Created:		07 March 2005 by cnwdad1
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//17 September 2013	cnwmc5	PAR 31255 - allowing dependent objects the criteria is based on.
// --------------------------------------------------------------------------------
begin	
	//app.myRoot.allActiveDestinations.copy(_allCriteriaValues);
	app.myRoot.allActivePorts.copy(_allCriteriaValues);		// 27/09/2011 cnwar2 #28084
end;</source>
        <Parameter name="_terminalObj" type="CM_Terminal"/>
        <Parameter name="_allCriteriaValues" type="ObjectSet" usage="input"/>
        <Parameter name="_filter" type="Integer"/>
        <Parameter name="_allDependentObjs" type="CM_ObjectArray"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaObjectForTi" id="92351ab8-b2f7-43c2-8c78-9654468ed082">
        <source>getCriteriaObjectForTi(_ti: CM_TrackedItem; _criteriaObject: CM_Object output; _process: Boolean output);

vars

begin
	_criteriaObject := app.myRoot.allPorts[_ti.dischargePort];
end;
</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_criteriaObject" type="CM_Object" usage="output"/>
        <Parameter name="_process" type="Boolean" usage="output"/>
    </JadeMethod>
    <JadeMethod name="getCriteriaValuesForVoyage" id="e2e0bd8a-ab2f-4697-b39a-cbcde955a28b">
        <source>getCriteriaValuesForVoyage(_voyage: CM_Voyage; _criteriaValues: ObjectSet input);

/*

Purpose:			Get Discharge Ports values for given Voyage

Parameters:			

Return Value:		_criteriaValues populated with criteria values appropriate to voyage

Date				Who		Reason
16 December 2008	consw1	Initial creation

*/

vars
	port 			: CM_Port;
	portRotation	: CM_PortRotation;
begin
	_criteriaValues.clear;

	foreach port in	_voyage.allPorts where app.myRoot.allActiveDestinations.includes(port) do
		if not _criteriaValues.includes(port) then									//+cnwml2	PAR21370
			_criteriaValues.add( port );
		endif;		
	endforeach;
	foreach portRotation in _voyage.allPortRotations discreteLock where not portRotation.allTranshipPorts.isEmpty() do		//ccms 1096 add tranship ports to list of available discharge ports, in case they change their minds
		foreach port in portRotation.allTranshipPorts discreteLock do			
			if not _criteriaValues.includes(port) and app.myRoot.allActiveDestinations.includes(port) then									
				_criteriaValues.add( port );
			endif;
		endforeach;
	endforeach;
	

epilog

end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <Parameter name="_criteriaValues" type="ObjectSet" usage="input"/>
    </JadeMethod>
