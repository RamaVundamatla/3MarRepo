    <JadeMethod name="areBulkReleaseWlesComplete" id="544037df-c489-4fee-b5d4-a40df44e6072">
        <source>areBulkReleaseWlesComplete() : Boolean;
/*

Date		Who		Reason
05 November 2015	cnwer1	Initial creation PAR 37075

*/

vars
	wle : CM_WorkListEntry ;
begin

	foreach wle in self.workListEntries discreteLock do
		if wle.isReceipt then
			continue;
		endif;
		if wle.status = WLE_COMPLETED then
			continue;
		endif;
		if wle.myRequest.myReserveDetail &lt;&gt; null then
			return false;
		endif;
	endforeach;
	
	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="areWLEsAllStatus" id="3373a252-f48f-4a98-84a3-5e7769bd8d1f">
        <source>areWLEsAllStatus(wleStat: Integer): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Apr 2024 navhl20 ChangeRequest 63148: EUP* | 53729 - Delivery Dispatch Screen - Should not update job status when trailers got completed.
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	wle : CM_WorkListEntry;
begin
	if wleStat = WLE_UNACTIONED and self.ignoreUpdateJobStatus()  then			//06.03.2025 navma1 #MTN-34179
		foreach wle in self.workListEntries discreteLock do						//06.03.2025 navma1 #MTN-34179
			if wle.myTrackedItem &lt;&gt; null and wle.myTrackedItem.isTILC then		//06.03.2025 navma1 #MTN-34179
				continue;
			endif;
			if wle.status &lt;&gt; wleStat then
				return false;
			endif;
		endforeach;
		return true;
	else
		return inheritMethod(wleStat);
	endif;
epilog

end;</source>
        <Parameter name="wleStat" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="cameThroughTwinStageGate" id="8e0d3a10-fc5f-43d4-b550-387a844e722d">
        <source>cameThroughTwinStageGate():Boolean;
// ---------------------------------------------------------------------------
// Created:     28 August 2009 by cnwcs5
// Purpose:     CCMS 1061 - gate config
// Parameters:  None
// Returns:     True if vehcile associated with job came through dual gateVTA or 
//				gate.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 23/02/2010	cnwcs5		par 18061 - tidying up method post 7.7.3 conversion
// ---------------------------------------------------------------------------
vars
	ta		:CM_TerminalAreaMaster;
	invalid	:Boolean;
	gate: CM_Gate;
begin
	gate := self.getGateIn;
	
	if gate &lt;&gt; null then
		// job created post 7.7.3 conversion of VTAs to gates 
		return gate.hasPGateAreas;
	endif;
	
	// it is possible for there to be no gate if the road job was created using trxCreateRoadJob
	// if that is the case though we definitely did not come through a tin stage gate
	
	return false;	// 23/02/2010 cnwcs5 par 18061
/*	
	on Exception do app.handleDeletedObject (exception, ta, invalid);
	
	// no gate reference on the job - must have been created prior to converio
	// does roadTransAreaId refer to an interchange area
	// 17/02/2010 - it is also possible for there to be no gate if the road job was created
	// using trxCreateRoadJob
	process.isChristinaToDo ('ccms 1071 - need to revisit at some stage in future');
	ta := self.myTerminal.allTerminalAreaMastersById[self.roadTransAreaId];
	
	if ta.isKindOf(CM_YardInterchangeArea) then
		// old road job - has not been through 7.7.3 conversion so gate property has not been updated
		gate := ta.CM_YardInterchangeArea.myDefaultOutGate;
		
		if invalid then
			return false;
		endif;
		
		// we can assume in/out gate area the same in this particular case
		return gate.hasPGateAreas;
		
		// if ta is invalid then we will resume execution here.
	endif;
	
	// no gate/no VTA - it must refer an interchange area which was created
	// during conversion but because there is no gate it must have been a single stage VTA
	return false;*/
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="canBeAutoCompleted" id="811d7256-1de9-4979-b95f-2efdbcdda993">
        <source>canBeAutoCompleted(_ti : CM_TrackedItem; _gteEntity : CMGTE_Entity;_isRelease : Boolean) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
25 Jan 2024 	navra1  TFS 62081 - CUX | Auto-setdown of cargo that doesn't require a machine move
12 Jun 2024	jlier1  TFS 64018  
*/

vars
	criteria : CM_RoadGateAutoComplete;
	terminal : CM_Terminal;
begin
	terminal := self.myTerminal;
	
	if terminal = null then
		return false;
	endif;
	
	if terminal.getConfig(CashProcessingEnabled).Boolean or terminal.getConfig(SiteHasSecurityGate).Boolean then
		return false;
	endif;
	
	if _gteEntity &lt;&gt; null then
		if _gteEntity.autoComplete then
			return true;
		endif;
	endif;
	
	if self.autoComplete then
		return true;
	endif;	

	foreach criteria in terminal.allRoadGateAutoCompleteCrit where  criteria.isRelease = _isRelease do
		if criteria.matches(_ti) then
			return true;
		endif;
	endforeach;

	return false;

epilog

end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_gteEntity" type="CMGTE_Entity"/>
        <Parameter name="_isRelease" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
