    <JadeMethod name="testHazardLoadCC" id="cba4504d-0ba1-47ce-8444-b027dca79718">
        <source>testHazardLoadCC(_voyAlloc : CM_VoyageAllocation);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
14 October 2010	cnwmh5	Initial creation #25632
23 July 2015	NDL	Par 36568	- remove use of LC collection with 'myTerminalArea' as key, replace with LC Set

*/

vars

	lc				: CM_LocationsController;
	slotController2	: CM_SlotController;
	slotRequest2	: CM_SlotRequest;
	allocation		: CM_VoyageAllocation;
	hazClass1		: CM_HazardClass;
	hazClass2		: CM_HazardClass;
	object			: Object;
	segRule			: CM_SegregationRule;
	
	segRuleDict		: CM_SegRuleByTypeEntity1Entity2;
	lcDict			: CM_LCSet;
		
	tmpHazardArray1	: ObjectArray;
	tmpHazardArray2	: ObjectArray;
	
	vert			: Integer;
	horiz			: Integer;
	depth			: Integer;
	ruleType		: Integer;
	
begin

	// get the rule type
	ruleType := self.getHazardSegregationRuleType();
	
	// get the current slot controllers hazard, vert, horiz, depth details
	create tmpHazardArray1 transient;
	_voyAlloc.getAllocationsHazAndProximity(ruleType, tmpHazardArray1, vert, horiz, depth);
	if tmpHazardArray1.isEmpty then
		return;
	endif;
	
	// No vert, horiz, depth proximity found
	if vert = null and horiz = null and depth = null then
		return;
	endif;

	// get all the slotControllers that need to be tested
	create lcDict transient;
	self.getLocationsForSpan(vert, horiz, depth, lcDict);
	
	// create the array for hazards for slots will be testing (lcDict)
	create tmpHazardArray2 transient;
	
	// get segrgation rule dict
	segRuleDict := self.myTerminal.allSegRulesByEntity1Entity2;
	
	// read through lcDict and see who needs to be checked and then check
	foreach lc in lcDict do
		
		// get the slot controller and request.  if null or same as self do next
		slotController2 := lc.CM_SlotController;
		slotRequest2 := slotController2.mySlotRequestLoad;
		if slotRequest2 = null or slotController2 = self then
			continue;
		endif;
			
		// get voyage allocation for slot request
		allocation := slotRequest2.allAllocations.first.CM_VoyageAllocation;
		if allocation = null then
			continue;
		endif;
		
		// get the new slot controllers hazard, vert, horiz, depth and proximity details
		tmpHazardArray2.clear();
		allocation.getAllocationsHazAndProximity(ruleType, tmpHazardArray2, vert, horiz, depth);
		if tmpHazardArray2.isEmpty then
			return;
		endif;
		self.getProximity(slotController2, vert, horiz, depth);
		
		// check each hazard and put up error message if there is a problem
		foreach object in tmpHazardArray1 do
			hazClass1 := object.CM_HazardClass;
			foreach object in tmpHazardArray2 do
				hazClass2 := object.CM_HazardClass;
				segRule := segRuleDict[ruleType, hazClass1, hazClass2];
				if segRule = null or (not segRule.mySegregationCondition.isActive) then
					continue;
				endif;
				if segRule.mySegregationCondition.proximityInViolation(vert, horiz, depth, app.isSpecial) then
					app.raiseCMWarning3(Hazard_seg_locationCC, self.getFullId(), slotController2.getFullId(), segRule.getErrorDescr, null, null, null);
				endif;
			endforeach;
		endforeach;
		
	endforeach;
	
epilog

	delete tmpHazardArray1;
	delete tmpHazardArray2;
	delete lcDict;

end;</source>
        <Parameter name="_voyAlloc" type="CM_VoyageAllocation"/>
    </JadeMethod>
    <JadeMethod name="validateMoveTo" id="ca507045-f848-44e2-8676-23089c4efe7b">
        <source>validateMoveTo(_control: CMIF_MoveController input);
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05/08/2013	cnwndl1	Initial creation	Par 32162
28/09/2016	cnwdap1	TFS 2652 Check if all document actions are complete before moving
					a TI with a booking to a ship location
25/07/2019	jlgzm1	TFS 42872 Direct Release Between HOLD Voyages and Rail
03/10/2019	jlgdap1	TFS 46870 JMT Cargo Request Direct Delivery Gate to Vessel
*/

vars

	fromLC : CM_LocationsController;
	ti : CM_TrackedItem;
	fromVoyage : CM_Voyage;
	docActions : CM_DocumentActions;			// TFS 2652
	reason, dummyString : String;							// TFS 2652
	childTi : CM_TrackedItem;
	moveWle : CM_WorkListEntry; // TFS 42872
	
begin

	inheritMethod(_control);
	
	if _control.moveMode = QUEUE_MODE or  _control.moveMode = PLANNING_MODE then
		//If planing or queuing a ship to ship move, ti must already be marked as a tranship
		ti := _control.myTrackedItem;
		if ti = null then
			return;
		endif;
		
		fromLC := ti.getPrimaryLocation(REAL_MODE);
		if fromLC = null then
			return;
		endif;
		
		//03 Nov 2014	NDL	Par 35017 - migrated down to CM_VoyageROROController and CM_SlotController
		/*	//22 Oct 2013	NDL	Par 31398
		if fromLC.isWagon or fromLC.isVehicle then
			if _control.moveMode = QUEUE_MODE then
				app.raiseCMException(NoQueue_Rail_To_Voyage, null, null);
			endif;
		endif;*/
		
		if fromLC &lt;&gt; null and fromLC.isKindOf( CM_VoyageController ) then
			// Going to a voyage
			fromVoyage := fromLC.CM_VoyageController.myVoyage;
			if fromVoyage = null then
				// Huh?
				return;
			elseif fromVoyage = self.myVoyage then
				// Its a shift on board.
				return;
			endif;
			
			if not ti.isTranshipItem then
				if not (ti.myCargoType.isBreakBulkMulti or ti.myCargoType.isBulkMulti) then
					app.raiseCMException(Ship_To_Ship_Must_Tranship, null, null);
				endif;
			endif; 
		
		endif;
		
	// TFS 2652 start
	elseif _control.moveMode = REAL_MODE then
		ti := _control.myTrackedItem;
		if ti = null then
			return;
		endif;
		
		_control.myTrackedItem.hasUnactionedDocumentActions(false,true,dummyString); // TFS 3972

		//28 Aug 2017	NDL	TFS 6686
		if not _control.myTrackedItem.allChildren.isEmpty then
			foreach childTi in _control.myTrackedItem.allChildren do
				childTi.hasUnactionedDocumentActions( false, true, dummyString );	// raise errors.
			endforeach;
		endif;
		
		// ### TFS CR 60424 TASK 60549 02OCT2023 NAVAB1
		_control.myTrackedItem.validateCustDocTransportMove(_control, app.myPassport);
		
		// TFS 42872 Start
		moveWle := _control.myWorkListEntry;
		if moveWle &lt;&gt; null then //there is a move associated with the controller 
			if moveWle.isReceipt then
				if not moveWle.isDRLinkedByFM and // Not Direct Release
				not moveWle.isDirectDelivery and // Not Direct Delivery
				not moveWle.isDirectToVoyage and // TFS 46870 Not direct to voyage from truck as part of a planned voyage hold move
				not moveWle.isKindOf(CM_VoyageWLE) then // Not being received from a voyage
					// cargo must have been received before it can be loaded to a voyage, unless it has been marked for direct release or direct delivery
					app.raiseCMException2(Uncomplete_receival_wle, ti.id, moveWle.job.getDisplayDetails(false), null, null);
				endif;
			endif;
		endif;
		// TFS 42872 End
		
	endif;
	

epilog

end;</source>
        <Parameter name="_control" type="CMIF_MoveController" usage="input"/>
    </JadeMethod>
</Class>
