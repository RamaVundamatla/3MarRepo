    <JadeMethod name="shouldAuditProperty" id="2c6d7448-2084-46da-aa5e-d0c11e42da3d">
        <source>shouldAuditProperty(_rootClass: Class; _property: Property): Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
28 November 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars
		propName	: String;
begin
	if _property = null then
		return false;
	endif;
	
	propName := _property.name;
	
	if 	propName = CM_HSCodeChapter::allHSCodeHeadings.name or
		propName = CM_HSCodeChapter::myHSSection.name
		then
		return false;
	else
		return inheritMethod(_rootClass, _property);
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_rootClass" type="Class"/>
        <Parameter name="_property" type="Property"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateForCreate" id="b4687383-ae80-4e05-ad69-acdc2a1877a2">
        <source>validateForCreate();
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
28 November 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars

begin
	inheritMethod();
	
	self.validateForUpdate();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="validateForUpdate" id="4da311ba-26a4-4ab4-8c86-092fd0193867">
        <source>validateForUpdate();
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
28 November 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars
	realHS,
	exisitngHS : CM_HSCodeChapter;
	
begin
	inheritMethod();
	
	if self.id = null then
		app.raiseCMException(Input_required_field_Id, null, null);
		return;
	endif;
	
	if self.id.length &lt;&gt; 2 then
		app.raiseCMException2(Field_length_characters_long, self.id &amp; ": " &amp; app.getErrorString(Id), "2", null, null);
	endif;
	
	realHS := self.pxyGetRealObject();
	exisitngHS := app.myRoot.allHSChapters[self.id];
	
	if exisitngHS &lt;&gt; null and (realHS = null or exisitngHS &lt;&gt; realHS) then
		app.raiseCMException3(ERR_DuplicateItemWith, app.getErrorString(Chapter), app.getErrorString(Id), self.id, null, null);
		return;
	endif;

	if self.description = null then
		app.raiseCMException(Input_required_field_Desc, null, null);
	endif;
	
	if self.myHSSection = null then
		app.raiseCMException1(REQUIRED_FIELD, app.getErrorString(Section), null, null);
	endif;


epilog

end;</source>
    </JadeMethod>
</Class>
