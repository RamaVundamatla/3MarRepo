    <JadeMethod name="trxCreateWorkOrder" id="a7154f1b-49d0-484f-a41a-4ff6070dc87b">
        <updating/>
        <source>trxCreateWorkOrder(_proxyWorkOrder : CM_WorkOrder input; _workOrder:CM_WorkOrder output; _passport : CM_Passport input) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
31 July 2009	cnwmd1	Initial creation
15/07/2025	navcs2	MTN-35210 Add Deferred Updates for WO Transaction During Transport Manifest and Call-Off Loading to Reduce Deadlocks
*/

vars

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Set to use deffered updates
	_passport.useTITransactionDeferUpdate := true;							// 15/07/2025	navcs2	MTN-35210
	_passport.useWOTransactionDeferUpdate := true;							// 17/07/2025	navcs2	MTN-35210
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	// Start the transaction
	beginTransaction;

	// Perform the operation
	app.myUtilityCA.utlCreateWorkOrder(_proxyWorkOrder, _workOrder, _passport);
	
epilog
	if _passport.noErrors() then				// 15/07/2025	navcs2	MTN-35210
		_passport.doDeferredUpdates();			// 15/07/2025	navcs2	MTN-35210	
	endif;										// 15/07/2025	navcs2	MTN-35210
	
	self.finaliseActivityWithPassport(_passport);
end;</source>
        <Parameter name="_proxyWorkOrder" type="CM_WorkOrder" usage="input"/>
        <Parameter name="_workOrder" type="CM_WorkOrder" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
