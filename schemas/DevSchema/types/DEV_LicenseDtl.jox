    <JadeMethod name="createEWSLicense" id="b8846ec1-7d9a-4165-8015-fa14c79d8c97">
        <updating/>
        <source>createEWSLicense(_client : DEV_LicenseClient) updating;
/*
Purpose:	

Date		Who		Reason
16 December 2024	navab1	JIRA 33543
*/

vars

begin
	self.myClient := _client;
	self.name := _client.name;
	self.type := DEV_LicenseEntity.LicenseType_EWS;
	
	self.clearArrays();  // ### JIRA 36920 15JAN2026 NAVAB1
	self.setTEMPEWS(_client);  // ### JIRA 36920 15JAN2026 NAVAB1
epilog

end;</source>
        <Parameter name="_client" type="DEV_LicenseClient"/>
    </JadeMethod>
    <JadeMethod name="getLicenseIndex" id="595754a6-de62-4978-82e8-d70dce2f2235">
        <source>getLicenseIndex(_idx : Integer) : Integer protected;
// ---------------------------------------------------------------------------
// Created:     13 September 2004 by cnwrs2
//
// Purpose:     Permission Objects have an offset which we need
//				to apply to get the index in the allDetails array
// ---------------------------------------------------------------------------
vars

begin

	if self.type = LicenseType_EDI then
		return _idx;
	// ### JIRA 33543 12DEC2024 NAVAB1
	elseif self.type = LicenseType_EWS then
		return _idx;
	else
		return _idx - Mod_BaseView;
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_idx" type="Integer"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getLicenseName" id="ac3712b0-9c65-48ad-87e8-91a6dbd80cb9">
        <source>getLicenseName() : String;
/*
Purpose:	

Date		Who		Reason
12 December 2025	navab1	JIRA 35465
*/

vars

begin
	if self.type = DEV_LicenseDtl.LicenseType_EDI then
		return "EDI License";
	elseif self.type = DEV_LicenseDtl.LicenseType_EWS then
		return "EWS License";
	elseif self.type = DEV_LicenseDtl.LicenseType_Subscription then
		return "SUB License";
	elseif self.type = DEV_LicenseDtl.LicenseType_System then
		return "SYS License";
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSubscriptionExpDate" id="a7acfe26-653b-4cb9-85ab-cd25206937c8">
        <source>getSubscriptionExpDate( _permValue : Integer ):Date;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 June 2020	jlgndl1	Initial creation	TFS 49569

*/

vars

	dateIndex : Integer;

begin

	dateIndex := self.getLicenseIndex( _permValue );
	
	if dateIndex &lt;= self.allExpiries.size then
		return self.allExpiries[dateIndex];
	endif;

	return null;

epilog

end;</source>
        <Parameter name="_permValue" type="Integer"/>
        <ReturnType type="Date"/>
    </JadeMethod>
    <JadeMethod name="outputAsXML" id="fe58d4ee-8f3e-47e5-8e34-228914f07312">
        <source>outputAsXML() : String;
// ---------------------------------------------------------------------------
// Created:     05 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*
&lt;terminal&gt;
&lt;name&gt;Terminal One&lt;/name&gt;
&lt;details&gt;1:2:3:4&lt;/details&gt;
&lt;/terminal&gt;
*/
vars
	dtlStr		: String;
	subsExpString	: String;
	tmpValue	: Boolean;
	idx			: Integer;
begin

	foreach tmpValue in self.allDetails do
		idx := idx + 1;
		if tmpValue then
			if dtlStr = null then
				dtlStr := idx.String;
				if allExpiries.size &gt;= idx then	//17 Jun 2020	NDL	TFS 49569
					subsExpString := allExpiries[idx].format("yyyMMdd");
				endif;
			else
				dtlStr := dtlStr &amp; Seperator &amp; idx.String;
				if allExpiries.size &gt;= idx then	//17 Jun 2020	NDL	TFS 49569
					subsExpString := subsExpString &amp; Seperator &amp; allExpiries[idx].format("yyyMMdd");
				endif;
			endif;
		endif;
	endforeach;
	
	if subsExpString = null then
		return self.formatAsXMLPrefix(XMLTag_Terminal) &amp; 
			   self.formatAsXML(XMLTag_LicenseName, self.name) &amp;
			   self.formatAsXML(XMLTag_Type, self.type.String) &amp;
			   self.formatAsXML(XMLTag_ExpiryDate, self.expiryDate.formatAsYYYYMMDD()) &amp;
			   self.formatAsXML(XMLTag_Details, dtlStr) &amp;
			   self.formatAsXMLSuffix(XMLTag_Terminal);
	else	//17 Jun 2020	NDL	TFS 49569
		return self.formatAsXMLPrefix(XMLTag_Terminal) &amp; 
			   self.formatAsXML(XMLTag_LicenseName, self.name) &amp;
			   self.formatAsXML(XMLTag_Type, self.type.String) &amp;
			   self.formatAsXML(XMLTag_ExpiryDate, self.expiryDate.formatAsYYYYMMDD()) &amp;
			   self.formatAsXML(XMLTag_Details, dtlStr) &amp;
			   self.formatAsXML(XMLTag_SubsDates, subsExpString) &amp;
			   self.formatAsXMLSuffix(XMLTag_Terminal);
	
	endif;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="7471a509-c9ba-4768-815b-e35546aeb72e">
        <updating/>
        <source>setForCreate(_name : String; _type : Integer; _client : DEV_LicenseClient) updating;
// ---------------------------------------------------------------------------
// Created:     06 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if _type = LicenseType_System or
		_type = LicenseType_Subscription then	//17 Jun 2020	NDL	TFS 49569
		self.name := _client.name;
	elseif _type = LicenseType_EDI then		// 15/07/21 navmd1 Do the same as UpdateClient!
		self.name := _client.name &amp; ' (EDI)';
	// ### JIRA 33543 12DEC2024 NAVAB1
	elseif _type = LicenseType_EWS then	
		self.name := _client.name &amp; ' (EWS)';
	else
		self.name		:= _name;
	endif;

	self.type		:= _type;
	
	self.myClient	:= _client;

	self.clearArrays();  // ### JIRA 36920 08JAN2026 NAVAB1

end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_type" type="Integer"/>
        <Parameter name="_client" type="DEV_LicenseClient"/>
    </JadeMethod>
    <JadeMethod name="setForUpdate" id="67cc8419-0baa-4e24-ab97-e04aa146663b">
        <updating/>
        <source>setForUpdate(_name : String; _expiryDate : Date) updating;
// ---------------------------------------------------------------------------
// Created:     13 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	if self.type = LicenseType_System or
		self.type = LicenseType_Subscription or	//17 Jun 2020	NDL	TFS 49569
		self.type = LicenseType_EWS or // ### JIRA 33543 12DEC2024 NAVAB1
	   self.type = LicenseType_EDI then
		// do nothing as name comes from client
	else
		self.name		:= _name;
	endif;
	self.expiryDate := _expiryDate;
end;</source>
        <Parameter name="_name" type="String"/>
        <Parameter name="_expiryDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="setFromXML" id="c696e110-e7a3-4a36-8df2-e906124a4cdc">
        <updating/>
        <source>setFromXML(_xml : String; _client : DEV_LicenseClient) updating;
// ---------------------------------------------------------------------------
// Created:     05 November 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
/*
&lt;terminal&gt;
&lt;name&gt;Terminal One&lt;/name&gt;
&lt;type&gt;1&lt;/type&gt;
&lt;expiryDate&gt;20041201&lt;/expiryDate&gt;
&lt;details&gt;1:2:3:4&lt;/details&gt;
&lt;/terminal&gt;
*/
vars
	sa		: StringArray;
	tmpInt	: Integer;
	tmpStr	: String;
	dtlStr	: String;
	sa2 : StringArray;	//17 Jun 2020	NDL	TFS 49569
	subsDatesStr : String;	//17 Jun 2020	NDL	TFS 49569
	saIndex: Integer;

begin

	self.name		:= _xml.cnEcGetTagValueOfName(XMLTag_LicenseName);
	self.type		:= _xml.cnEcGetTagValueOfName(XMLTag_Type).Integer;
	self.expiryDate	:= _xml.cnEcGetTagValueOfName(XMLTag_ExpiryDate).convertYYYYMMDDToDate();

	dtlStr			:= _xml.cnEcGetTagValueOfName(XMLTag_Details);
	subsDatesStr	:= _xml.cnEcGetTagValueOfName(XMLTag_SubsDates);	//17 Jun 2020	NDL	TFS 49569
	
	sa := dtlStr.getTokens();
	if subsDatesStr &lt;&gt; null then	//17 Jun 2020	NDL	TFS 49569
		sa2 := subsDatesStr.getTokens();
	endif;
	
	 // ### JIRA 36920 05JAN2026 NAVAB1 initialise
	self.allDetails.atPut(250, false);
	self.allExpiries.atPut(250, null );
	
	foreach tmpStr in sa do
		saIndex := saIndex + 1;
		tmpInt := tmpStr.Integer;
		if tmpInt &gt; 0 then
			self.allDetails.atPut(tmpInt, true);
			if sa2 &lt;&gt; null and sa2.size &gt;= saIndex then	//17 Jun 2020	NDL	TFS 49569
				self.allExpiries.atPut(tmpInt, sa2[saIndex].convertYYYYMMDDToDate() );
			endif;
		endif;
	endforeach;

	self.myClient	:= _client;

epilog
	delete sa;
end;</source>
        <Parameter name="_xml" type="String"/>
        <Parameter name="_client" type="DEV_LicenseClient"/>
    </JadeMethod>
    <JadeMethod name="setNameFromClient" id="a1a204a2-5ec3-4044-9887-da41bf7ba680">
        <updating/>
        <source>setNameFromClient(_name : String) updating;
// ---------------------------------------------------------------------------
// Created:     13 September 2004 by cnwrs2
//
// Purpose:     Called from the client when that name is updated for
//				the System &amp; EDI license
// ---------------------------------------------------------------------------
vars

begin
	if self.type = LicenseType_System
	or self.type = LicenseType_Subscription	//17 Jun 2020	NDL	TFS 49569
	then
		self.name := _name;
	elseif self.type = LicenseType_EDI then
		self.name := _name &amp; ' (EDI)';
	// ### JIRA 33543 12DEC2024 NAVAB1
	elseif self.type = LicenseType_EWS then
		self.name := _name &amp; ' (EWS)';
	endif;
end;</source>
        <Parameter name="_name" type="String"/>
    </JadeMethod>
    <JadeMethod name="setPermission" id="0715bf9c-18dc-4bcb-8269-bbf961ed3b84">
        <updating/>
        <source>setPermission(_permIdx : Integer; _value : Boolean; _subsExpDate : Date ) updating;
// ---------------------------------------------------------------------------
// Created:     13 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	idx	: Integer;
begin

	idx := self.getLicenseIndex(_permIdx);

	if idx &gt; self.allDetails.size and (not _value) then
		return;
	endif;
	
	self.allDetails.atPut(idx, _value);
	if _subsExpDate &lt;&gt; null then
		self.allExpiries.atPut(idx, _subsExpDate);
	endif;
	
end;</source>
        <Parameter name="_permIdx" type="Integer"/>
        <Parameter name="_value" type="Boolean"/>
        <Parameter name="_subsExpDate" type="Date"/>
    </JadeMethod>
    <JadeMethod name="setTEMPEWS" id="0fe6f2c2-6d63-45a0-ad18-d589582e77f6">
        <updating/>
        <source>setTEMPEWS(_client : DEV_LicenseClient) updating;
/*
Purpose:	

Date		Who		Reason
13 December 2024	navab1	JIRA 33543
*/

vars

	local : DEV_LicenseClient;
begin
	local := _client;
	local.setTEMPEWS(self);
epilog

end;</source>
        <Parameter name="_client" type="DEV_LicenseClient"/>
    </JadeMethod>
    <JadeMethod name="validateEWSExpiryDates" id="046dc3f8-5c38-4a48-bbf0-9c25efceb6d1">
        <source>validateEWSExpiryDates( _ewsTypeAgent : CM_EWSTypeAgent ) : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 June 2020	jlgndl1	Initial creation

*/

vars

	size : Integer;
	checkDate : Date;
	moduleName : String;
	index : Integer;
	permObject : CM_PermissionObject;
	ewsType : CM_ExternalWebServiceType;
	epType : CM_EWSEndpointType;
	obj : Object;
begin

	if self.type = self.LicenseType_EWS then// ### JIRA 33543 12DEC2024 NAVAB1
		size := self.allDetails.size;
		
		foreach ewsType in _ewsTypeAgent.allEWSTypesByType do
			moduleName := ewsType.name;
			index := ewsType.type;
			if index &lt;= size and self.allDetails[index] then
				if self.allExpiries.size &lt; index then
					app.msgBox("You must enter a valid expiry date for '" &amp; moduleName &amp; "'", 'Error', 0);
					return false;
				endif;
				checkDate := self.allExpiries[ index ];
				if checkDate &lt; app.actualTimeServer.Date then
					app.msgBox('Expiry date must be in the future for ' &amp; moduleName, 'Error', 0);
					return false;
				endif;
				if checkDate &lt; app.actualTimeServer.Date + 100 then
					if app.msgBox('Expiry date for ' &amp; moduleName &amp; ' is less than 100 days.  Continue?', 'Warning', MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
						return false;
					endif;
				endif;
			endif;

		endforeach;
	
		foreach epType in _ewsTypeAgent.allEWSEndpointTypeByType do
			moduleName := epType.name;
			index := epType.type;
			if index &lt;= self.allDetails.size and self.allDetails[index] then
				if self.allExpiries.size &lt; index then
					app.msgBox("You must enter a valid expiry date for '" &amp; moduleName &amp; "'", 'Error', 0);
					return false;
				endif;
				checkDate := self.allExpiries[ index ];
				if checkDate &lt; app.actualTimeServer.Date then
					app.msgBox('Expiry date must be in the future for ' &amp; moduleName, 'Error', 0);
					return false;
				endif;
				if checkDate &lt; app.actualTimeServer.Date + 100 then
					if app.msgBox('Expiry date for ' &amp; moduleName &amp; ' is less than 100 days.  Continue?', 'Warning', MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
						return false;
					endif;
				endif;
			endif;

		endforeach;

	endif;

	return true;

epilog

end;</source>
        <Parameter name="_ewsTypeAgent" type="CM_EWSTypeAgent"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateExpiryDate" id="07d5b816-58a2-456b-a64b-ba3966296be8">
        <source>validateExpiryDate(_date : Date) : Boolean;
// ---------------------------------------------------------------------------
// Created:     13 September 2004 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
vars

begin

	if (not _date.isValid()) then
		app.msgBox('You must enter a valid expiry date', 'Error', 0);
		return false;
	endif;

	if _date &lt; app.actualTimeServer.Date then// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
		app.msgBox('Expiry date must be in the future', 'Error', 0);
		return false;
	endif;

	if _date &lt; app.actualTimeServer.Date + 100 then// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
		if app.msgBox('Expiry date is less than 100 days.  Continue?', 'Warning', MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
			return false;
		endif;
	endif;

	return true;

end;</source>
        <Parameter name="_date" type="Date"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="validateSubsExpDates" id="8db7c8f5-e688-4612-8d3f-ff1cb57e69d7">
        <source>validateSubsExpDates( permAgent : CM_PermissionAgent ):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 June 2020	jlgndl1	Initial creation

*/

vars

	size : Integer;
	checkDate : Date;
	subscriptionName : String;
	index : Integer;
	permObject : CM_PermissionObject;

begin

	if self.type = self.LicenseType_EWS // ### JIRA 33543 12DEC2024 NAVAB1
	or self.type = LicenseType_Subscription then
		size := self.allDetails.size;
		if size &gt; 0 then
			foreach index in 1 to size do
				if self.allDetails[index] then
				
					subscriptionName := "&lt;subitem " &amp; index.String &amp;  "&gt;";
					if permAgent &lt;&gt; null then
						permObject :=  permAgent.allPermissionsByConstValue[ Mod_BaseView + index ];
						if permObject &lt;&gt; null then
							subscriptionName := permObject.description;
						endif;
					endif;
				
					
					if self.allExpiries.size &lt; index then
						app.msgBox("You must enter a valid expiry date for '" &amp; subscriptionName &amp; "'", 'Error', 0);
						return false;
					endif;
					checkDate := self.allExpiries[ index ];
					if checkDate &lt; app.actualTimeServer.Date then
						app.msgBox('Expiry date must be in the future for ' &amp; subscriptionName, 'Error', 0);
						return false;
					endif;
					if checkDate &lt; app.actualTimeServer.Date + 100 then
						if app.msgBox('Expiry date for ' &amp; subscriptionName &amp; ' is less than 100 days.  Continue?', 'Warning', MsgBox_Yes_No) &lt;&gt; MsgBox_Return_Yes then
							return false;
						endif;
					endif;
				endif;
			endforeach;
		endif;
	endif;

	return true;

epilog

end;</source>
        <Parameter name="permAgent" type="CM_PermissionAgent"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</Class>
