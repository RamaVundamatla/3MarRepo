    <JadeMethod name="xVGMCargoUpdateRequestDetails" id="c5eb7ea9-6a51-4ece-bdf3-13f955c3650f">
        <source>xVGMCargoUpdateRequestDetails(_format : Integer; _containerId, _voyageId : String; _stopId : Integer) : String;

/*

Purpose:		Various VGM options

Date			Who		Reason
19/05/2016		cnwmh5	Initial creation

*/

vars

	ediText						: String;

begin

	if _format = 1 then
		// set all fields
		ediText := 'ISO Container,' &amp; _containerId &amp;',Y,Ned Kelly,Robin Hood,' &amp; _voyageId &amp; ',,,,';		
	elseif _format = 2 then
		// remove certified name
		ediText := 'ISO Container,' &amp; _containerId &amp;',Y,,Robin Hood,' &amp; _voyageId &amp; ',,A,' &amp; _stopId.String &amp; ',5999.00';
	elseif _format = 2 then
	else 
		ediText := 'ISO Container,' &amp; _containerId &amp;',,,,' &amp; _voyageId &amp; ',,D,' &amp; _stopId.String &amp; ',5999.00';
	endif;

	return ediText;

epilog

end;</source>
