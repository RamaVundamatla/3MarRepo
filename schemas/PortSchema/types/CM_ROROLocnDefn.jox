    <JadeMethod name="setCode" id="d0de3c89-0045-46b3-9805-03bb9829e21d">
        <updating/>
        <source>setCode(_code : String; _syncLayoutCode : Boolean) updating;
/*
Purpose:			
Date		Who		Reason
21 April 2011	cnwab1	Initial creation
*/

vars
	aSlot : CM_ROROSlotDefn;
	idx : Integer;
begin
	inheritMethod(_code, _syncLayoutCode);

	if not self.labelManuallyChanged then // PAR 28990
		foreach aSlot in self.allROROSlotDefnByOrdinal discreteLock do
			idx := idx + 1;
			aSlot.setCode(self.code &amp; idx.String);
		endforeach;
	endif;
	epilog

end;</source>
        <Parameter name="_code" type="String"/>
        <Parameter name="_syncLayoutCode" type="Boolean"/>
    </JadeMethod>
