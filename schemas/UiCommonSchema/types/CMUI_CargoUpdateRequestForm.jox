    <JadeMethod name="btnSaveNext_click" id="f56cda7f-fdca-4d77-bf73-f34a153d7a13">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnSaveNext_click(btn: Button input) updating;
/*

Date		Who		Reason
07 May 2014	cnwer1	Initial creation PAR

*/

vars

begin
	if self.doSave() then
		self.myCurrentEventRequest :=null;
		self.setupStops();
		self.setupToDo();
		self.cmbGrade.listObject:=null;
		self.txtRemarks.text:=null;
		self.setEnableObjects();
	endif;
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
