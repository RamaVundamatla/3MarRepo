    <JadeMethod name="setComboValues" id="171745e3-4557-4802-98fb-a6a4d321fe39">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars
	selectedVess,
	vessel		: CM_Vessel;
	idx			: Integer;
	value		: Any;
	root 		: CM_Root;
	obj			: Object;
	isFound		: Boolean;
begin
	_combo.clear;
	_combo.sorted := false;
	
	if _params = null then
		return;
	endif;
	
	if CM_QStringLookup.hasInstance(_queryOperator) then
		selectedVess := app.myRoot.getVesselByName(_queryOperator.CM_QStringLookup.selectionValue);
	elseif CM_QStringLookupNotEqual.hasInstance(_queryOperator) then
		selectedVess := app.myRoot.getVesselByName(_queryOperator.CM_QStringLookupNotEqual.selectionValue);
	endif;

	foreach vessel in app.myRoot.allVessels do
		idx := _combo.addItem(vessel.code &amp; '   ' &amp; vessel.name);
		_combo.itemObject[idx] := vessel;
		if vessel = selectedVess then
			isFound := true;
		endif;
	endforeach;

	if isFound then
		_combo.listObject := selectedVess;
	endif;
epilog
	
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="5e71ef58-db16-4812-a6a5-2cb2aac1cf2d">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QReferenceIsOneOf; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars
	crit			: CM_SelectorCriteriaLine;
	vessel			: CM_Vessel;
	idx				: Integer;
	root 			: CM_Root;
	voyDescr		: String;
	selectionValue	: Boolean;
	set				: ObjectArray;
begin
	_tbl.rows := 0;
	_tbl.sortColumn[1] := 2; // TFS 7821

	
	if _params = null then
		return;
	endif;

	//doesn't know about CMUI_ListTable - so have to do this:
	set := _tbl.getPropertyValue('allSelectedObjects').ObjectArray;
	set.clear();
	
	foreach vessel in app.myRoot.allVessels do
		selectionValue := false;
		if _operator.allSelectionValues.includes(vessel) then
			selectionValue := true;
			set.add(vessel);
		endif;
		self.addObjectToTable(_tbl, vessel, selectionValue, _passport);
	endforeach;
epilog

end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QReferenceIsOneOf"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="d15e6e2b-303b-4c65-8bab-a9bbbeca1bcf">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars
	str				: String;
	numRows,
	idx				: Integer;
	vessel			: CM_Vessel;
	vesselSet			: CM_VesselSet;
begin
	create vesselSet transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			vessel := _tbl.accessRow(idx).itemObject.CM_Vessel;
			vesselSet.add(vessel);
		endif;
	endforeach;
	
	_op.setSearchValue(vesselSet);
epilog
	delete vesselSet;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="976eda7c-4e05-4c53-b22e-5f9a1159e0cf">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars

begin
	if _value = null then
		return null;
	endif;
	
	if _value.isKindOf( CM_Vessel ) then
		return _value.CM_Vessel.name;
	endif;
	
	return _value.String;
	
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="3e47f915-def2-401f-9f47-ade0271c0004">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 May 2014	cnwndl1	Initial creation	Par 34142

*/

vars
	invalidObj 		: Boolean;
	object			: CM_Vessel;
	returnVal		: String;
	
begin
	if _value &lt;&gt; null then
		if _value.isKindOf(Collection) then		
			return _value;
		endif;

		if _value.isKindOf(CM_Vessel) then
			object := _value.CM_Vessel;
		endif;
	endif;
	
	if object &lt;&gt; null then
		on Exception do app.handleDeletedObject(exception, object, invalidObj);
		
		returnVal := object.name;
	endif;
	
	return returnVal;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValueForWeb" id="ccf906fb-957c-4687-8200-e56ce8e7e552">
        <source>translateToSearchValueForWeb(_value: Any; _sending : Boolean): Any;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 24/09/2019	jlgdap1		Initial creation TFS 45769 JMT Web Portal selector query
//
vars

begin
	if _value.isKindOf(String) then
		return _value.String;
	endif;
	
	return inheritMethod(_value, _sending);

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_sending" type="Boolean"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
