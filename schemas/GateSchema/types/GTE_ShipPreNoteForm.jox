    <JadeMethod name="hideShowVolumeQuantity" id="049deab2-f682-43eb-a233-ee7fe5118b99">
        <source>hideShowVolumeQuantity(_cargoBolType : CM_CargoBOLType);

/*


28 April 2010	cnwas3	par 23833

*/

vars
	
	product : CM_Product;
	
begin
	
	self.tblExtra.hideRowByName(ETRow_Quantity, false);
	self.tblExtra.hideRowByName(ETRow_Volume, false);
	self.tblExtra.hideRowByName(ETRow_MyQuantity, false);
	self.tblExtra.hideRowByName(ETRow_MyVolume, false);
	
	
	if _cargoBolType.isCargoType() and 																					
	   ((_cargoBolType.CM_CargoType.productType = ProductType_BreakBulk and _cargoBolType.id &lt;&gt; TI_CargoType_Container) or 					
	   _cargoBolType.CM_CargoType.productType = ProductType_Vehicle) then	//if we are dealing with break bulk or vehicle system/user defined types then we show the quantity and volume fields   
	   if _cargoBolType.isSystemCargoBOLType then
			self.tblExtra.showRowByName(ETRow_Quantity, false);
			self.tblExtra.showRowByName(ETRow_Volume, false);
	   else
		   product := _cargoBolType.CM_CargoType.mySystemProductType;
		   if product &lt;&gt; null then
				if product.getProdAttrFromName(ETRow_MyQuantity).isViewable then
					self.tblExtra.showRowByName(ETRow_MyQuantity, false);
				endif;
				if product.getProdAttrFromName(ETRow_MyVolume).isViewable then
					self.tblExtra.showRowByName(ETRow_MyVolume, false);
				endif;		   
			endif;
		endif;		
	endif;														
	
epilog

end;</source>
        <Parameter name="_cargoBolType" type="CM_CargoBOLType"/>
    </JadeMethod>
    <JadeMethod name="initComboNonWorked" id="09717c85-23f4-4f34-b9a0-47f1bdca8ff2">
        <source>initComboNonWorked();
//********************************************************************
//
// Created by: cnwsh3
//
// Date: 13 February 2004
//
// initiated here as opposed to assistant as this is the only place it is used.
//
//********************************************************************
vars
	cmb : ComboBox;
begin
	cmb := self.cmbNonWorked;
	
	cmb.addItem(app.getErrorString(NonWorked));
	cmb.addItem(app.getErrorString(PositionOnShip));
	cmb.listIndex := 1;
	self.myAssistant.GTE_Assistant.mainExtraSetValueByControl(tblMain, tblExtra, cmb.name, cmb.text);
end;</source>
    </JadeMethod>
