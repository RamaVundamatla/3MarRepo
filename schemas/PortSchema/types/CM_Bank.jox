    <JadeMethod name="setStateData" id="68f3cbd2-38d5-40a6-a613-58c1910f0965">
        <updating/>
        <source>setStateData( pKey : String; pValue : Any ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 January 2019	jlgndl1	Initial creation	TFS 40010

*/

vars

	stateObj	: CM_StateObject;
	
begin
	
	stateObj := self.myStateObject;
	if stateObj = null then
