    <JadeMethod name="doFormLoad" id="151196ab-c1af-4423-8def-81c8826f6d3c">
        <updating/>
        <source>doFormLoad() updating, protected;

begin
	self.centreWindow();
	self.populateAddressPersonList();
	aMyEmailSendForm.aSelectedPersonAddress := "";	
	btnSelect.enabled := false;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="getAddressfromLdap" id="6ee5762e-8ad3-4a2c-a953-509a16ee2ba2">
        <updating/>
        <source>getAddressfromLdap() updating, protected;

vars
	ldapObj			: CnLdapConnection;
	searchObj		: CnLdapSearch;
	entryObj		: CnLdapEntry;
	allAddresses	: String;
	firstName		: String;
	lastName		: String;
	ldapBase		: String;
	ldapHost		: String;
	emailAddress	: String;
	reply			: Integer;
	
begin
	app.mousePointer := Busy;
		
	lstLdapPerson.clear();
	aAllNamesArray.clear();
		
	ldapBase	:= aMyEmailSendForm.aMyEmailBaseData.ldapBase;	//"dc=aoraki,dc=co,dc=nz";
	ldapHost	:= aMyEmailSendForm.aMyEmailBaseData.ldapHost;	//"ldap.cnw.co.nz";
	firstName	:= txtFirstName.text.trimBlanks();
	lastName	:= txtLastName.text.trimBlanks();
		
	if firstName &lt;&gt; "" and lastName &lt;&gt; ""then
		allAddresses := "(&amp;(givenname&gt;=" &amp; firstName &amp; ")(givenname&lt;=" &amp; firstName &amp; "Z)(sn&gt;=" &amp; lastName &amp; ")(sn&lt;=" &amp; lastName &amp; "Z))"; 
	elseif firstName &lt;&gt; "" then
		allAddresses := "(&amp;(givenname&gt;=" &amp; firstName &amp; ")(givenname&lt;=" &amp; firstName &amp; "Z))";  
	elseif lastName &lt;&gt; "" then
		allAddresses := "(&amp;(sn&gt;=" &amp; lastName &amp; ")(sn&lt;=" &amp; lastName &amp; "Z))";
	else
		app.msgBox("No data entered to search on !!","Error",MsgBox_OK_Only);
		return;	  
	endif; 

	create ldapObj transient;
	ldapObj.cnOpen(ldapHost,null,null);
	
	create searchObj transient;	
	ldapObj.cnSearchAsync(ldapBase, allAddresses, searchObj);
	
	while true do
		reply := ldapObj.cnPollSearchAsync(searchObj);
		
		if reply = ldapObj.ENTRY_AVAILABLE then
			searchObj.cnGetNextEntry(entryObj);
			lastName		:=	entryObj.cnGetAttributeValue('sn').String;
			firstName		:=	entryObj.cnGetAttributeValue('givenname').String;
			emailAddress	:=	entryObj.cnGetAttributeValue('mail').String;
			lstLdapPerson.addItem(emailAddress);
			aAllNamesArray.add(lastName &amp; ", " &amp; firstName);
			
		elseif reply = ldapObj.NO_MORE_ENTRIES then
			break;
			
		endif;
	endwhile;
	
	ldapObj.cnClose();
epilog
	delete searchObj;
	delete ldapObj;
	app.mousePointer := Idle;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="load" id="f0822ca4-eedc-4a0a-b1f4-6e21fdb5e434">
