    <JadeMethod name="getCargoId" id="22bf0f61-25a3-4ce5-b973-6998050d7bcd">
        <source>getCargoId() : String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 June 2024	navra1	Initial creation for //navra1 - TFS 60149/Task 64397 - 12th June 2024

*/

vars

begin
	if self.myParentObject &lt;&gt; null and self.myParentObject.isKindOf(CM_VehicleVisitRecord) then
		return self.myParentObject.CM_VehicleVisitRecord.visitNumber;
	else
		return '';
	endif;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
