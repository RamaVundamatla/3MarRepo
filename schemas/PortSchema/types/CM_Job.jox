    <JadeMethod name="getFirstWle" id="fa442f9e-1c89-449c-9d02-d68f2d76cde7">
        <source>getFirstWle(): CM_WorkListEntry;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Nov 2023 navhl20 Bug 60924: MTN - Unable to sort the jobs using Source and Target Locations on the Work Order Operations app
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
