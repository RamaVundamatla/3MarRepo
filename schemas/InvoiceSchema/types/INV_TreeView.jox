    <JadeMethod name="initPropertyTable" id="eba03a76-8386-466c-8e1e-e0cf75f865ad">
        <source>initPropertyTable(_entDef : String);
// ---------------------------------------------------------------------------
// Created:		May 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

	entTableDef		: EntTableDef;
	theRow			: Integer;
	theTable		: CM_EntryTable;
	
begin

	self.fldProperties.top := self.frmPropToolbar.clientHeight;
	/*self.fldProperties.move(1,self.frmPropToolbar.clientHeight + 4,self.frmProperties.clientWidth - 2,
								self.frmProperties.height - self.frmPropToolbar.clientHeight - 2);*/

	theTable := self.tblProperties;
	theTable.warningMethod := 'entTableWarning';
	
	theTable.stretchToParent := true;
	theTable.optimiseRowHeight := true;
	entTableDef := app.myController.getEntTableDef(_entDef); //
	theTable.setEntTableDef(entTableDef, null, 'entTableDefSetupWarning');
	theTable.changeMode := theTable.ChangeMode_FirstOnly;

end;</source>
        <Parameter name="_entDef" type="String"/>
    </JadeMethod>
    <JadeMethod name="inspectObject" id="b71501d2-4f0f-4240-9a5b-48eb4e5b178f">
        <source>inspectObject();
// ---------------------------------------------------------------------------
// Created:		November 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin
	if self.lstData.listObject &lt;&gt; null then
		self.lstData.listObject.inspect;
	else
		app.msgBox("No Object On Row!","Inspect Error",MsgBox_OK_Only);
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="keyDown" id="076e5b2f-139c-4ee7-bd11-536c67791dda">
        <controlMethod name="Form::keyDown"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>keyDown(keyCode: Integer io; shift: Integer) updating;
// ---------------------------------------------------------------------------
// Created:		August 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars

begin

	if keyCode = CMUI_Key_F3 then
		if self.frmSearch.visible then
			self.frmSearch.visible := false;
			self.lstData.enabled := true;
		else
			self.showSearchFrame();
		endif;

	elseif keyCode = CMUI_Key_F5 then
		self.doQuery();
		return;

	elseif keyCode = J_key_C and shift.isAltKeyPressed and not shift.isControlKeyPressed and not shift.isShiftKeyPressed then
		if self.frmSearch.visible then
			self.btnSearchCancel_click(self.btnSearchCancel);
		elseif self.frmProperties.visible then
			self.btnPropCancel_click(self.btnPropCancel);
		endif;
	endif;
	
	inheritMethod(keyCode, shift);

end;</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
