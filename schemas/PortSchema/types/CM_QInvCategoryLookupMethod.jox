    <JadeMethod name="setComboValues" id="59f90313-69c0-4a47-81f4-a1622137ff48">
        <source>setComboValues(_combo: ComboBox input; _params: CM_QueryCriteriaLineHolder; _queryOperator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/12/22    navmv20 TFS CR 55309   Task 55556: Jade - Add all the new invoice attributes to the selector query


*/

vars

begin

	_combo.clear;
	_combo.addItem(app.getErrorString(Invoice));
	_combo.addItem(app.getErrorString(Credit_note));
	
	if CM_QIntegerLookupEqual.hasInstance(_queryOperator) then
		_combo.text := app.invCategoryIntToString(_queryOperator.CM_QIntegerLookupEqual.searchValue);
	elseif CM_QIntegerLookupNotEqual.hasInstance(_queryOperator) then
		_combo.text := app.invCategoryIntToString(_queryOperator.CM_QIntegerLookupNotEqual.searchValue);
	endif;
	
end;</source>
        <Parameter name="_combo" type="ComboBox" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_queryOperator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setListValues" id="25eb75d3-14b4-4e56-8fca-d35a28d1f999">
        <source>setListValues(_tbl: Table input; _params: CM_QueryCriteriaLineHolder; _operator: CM_QueryOperator; _passport: CM_Passport);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/12/22    navmv20 TFS CR 55309   Task 55556: Jade - Add all the new invoice attributes to the selector query


*/

vars
	intArray	: IntegerArray;
	idx,int	: Integer;
	cmString		: CM_String;
begin

	_tbl.purgeTableObjects();
	_tbl.clear;
	_tbl.rows := _tbl.fixedRows;
	
	create intArray transient;
	
	intArray.add(InvoiceCategory_Invoice);
	intArray.add(InvoiceCategory_CreditNote);
	
	foreach int in intArray do
		create cmString transient;
		cmString.string := self.translateToDisplayValue( int );
		
		if _operator &lt;&gt; null then
			idx := _tbl.addItem(1.String &amp; Tab &amp; cmString.string);
		else
			idx := _tbl.addItem(0.String &amp; Tab &amp; cmString.string);	
		endif;
		_tbl.accessRow(idx).itemObject := cmString;
		_tbl.row := idx;
		_tbl.change(_tbl);	
	endforeach;

epilog
	delete intArray;
end;

</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_params" type="CM_QueryCriteriaLineHolder"/>
        <Parameter name="_operator" type="CM_QueryOperator"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="setValuesFromList" id="ca093699-da99-4924-b405-60690d988c4b">
        <source>setValuesFromList(_tbl: Table input; _op: CM_QueryOperator input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/12/22    navmv20 TFS CR 55309   Task 55556: Jade - Add all the new invoice attributes to the selector query


*/

vars
	str		: String;
	numRows,
	idx		: Integer;
	ia		: IntegerArray;

begin

	create ia transient;
	
	numRows := _tbl.rows;
	foreach idx in (_tbl.fixedRows + 1) to numRows do
		str := _tbl.accessCell(idx, 1).text;
		if str = TableCheckBox_Selected then
			str := _tbl.accessCell(idx, 2).text;
			ia.add(self.translateToSearchValue(str).Integer);
		endif;
	endforeach;
	
	_op.setSearchValue(ia);

epilog
	delete ia;
end;</source>
        <Parameter name="_tbl" type="Table" usage="input"/>
        <Parameter name="_op" type="CM_QueryOperator" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateStringToSearchValue" id="5906bc50-5f33-4f6a-88ea-01b7a26483eb">
        <source>translateStringToSearchValue(_value: Any; _criteriaLine: CM_SelectorCriteriaLine): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/12/22    navmv20 TFS CR 55309   Task 55556: Jade - Add all the new invoice attributes to the selector query


*/

vars
	intCategory	: Integer;
	
begin
	if _value.String.isInteger then
		return _value;
	endif;
	
	intCategory := app.invCategoryStringToInt(_value.String);
	
	return intCategory;
	
end;
</source>
        <Parameter name="_value" type="Any"/>
        <Parameter name="_criteriaLine" type="CM_SelectorCriteriaLine"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="translateToDisplayValue" id="62f1acf1-7087-4652-8e03-b6b02c5c5278">
        <source>translateToDisplayValue(_value: Any): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/12/22    navmv20 TFS CR 55309   Task 55556: Jade - Add all the new invoice attributes to the selector query


*/

vars

begin
	return app.invCategoryIntToString(_value.Integer);
epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="translateToSearchValue" id="026ef74c-8abf-4281-b5c4-1623e15858d9">
        <source>translateToSearchValue(_value: Any): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06/12/22    navmv20 TFS CR 55309   Task 55556: Jade - Add all the new invoice attributes to the selector query

*/

vars
	
begin
	if _value.isKindOf(IntegerArray) then
		return _value;
	elseif _value.isKindOf(Integer) then	
		return _value.String;
	endif;
	
	return translateStringToSearchValue( _value.String, null).Integer;

epilog

end;</source>
        <Parameter name="_value" type="Any"/>
        <ReturnType type="Any"/>
    </JadeMethod>
</Class>
