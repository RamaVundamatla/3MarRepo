    <JadeMethod name="getVoyageJobId" id="6d7a5313-18aa-4a52-a77f-f6f7b992682e">
        <source>getVoyageJobId(_job : CM_Job; _jobSheet : CM_WorkPointJobSheet):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
05 Oct 2023 navhl20 ChangeRequest 60090: EUP | Ship Operations in DD - [54176.020] -[Receive] Allocate Jobs to Gangs and Gangs to Holds
27 Oct 2023 navhl20 ChangeRequest 60037: EUP | Ship Operations in DD - [54176.030] - [Receive] Additional Job Details
29 Nov 2023 navhl20 ChangeRequest 61510: EUP | Ship Operations in DD - [54176.020] - [Release] Allocate Jobs to Gangs and Gangs to Holds
04 Jan 2023 navhl20 Bug 61873: FR | 53891 - Mobile App changes for Delivery Dispatch (EP Tickets)
16 Jan 2023 navhl20 ChangeRequest 62066: EUP | Ship Operations in DD - FR - 01
*/

vars
	str	,
	counter,
	hold,
	crit		: String;
	wod			: CM_WorkOrder;
	grpMethod	: CM_WorkOrderJobGroupMethod; 
	specialStow	: String;
	ti			: CM_TrackedItem;
	int			: Integer;
	voyage		: CM_Voyage;
	location	: CM_LocationsController;
begin
	if _job &lt;&gt; null then
		wod := self.myParent;
		if self.isKindOf(CM_WodReceive) then									//29.11.2023 navhl20 #61510
			voyage := self.CM_WodReceive.myVoyage;								//27.10.2023 navhl20 #60037
		else
			voyage := self.CM_WodRelease.myVoyage;
		endif;
		
		//if voyage.allVoyageJobs.isEmpty then									//27.10.2023 navhl20 #60037	//04.01.2023 navhl20 #61873
		if voyage &lt;&gt; null and voyage.allVoyageJobs.isEmpty then					//04.01.2023 navhl20 #61873
			counter := "00" &amp; 1.String;
		else
			counter := "00" &amp; (voyage.allVoyageJobs.size + 1).String;			//27.10.2023 navhl20 #60037
		endif;
		
		ti := _job.getFirstTrackedItem();
		
		grpMethod := wod.myWorkOrderJobGroupMethod;
		
		if ti &lt;&gt; null then
			location := ti.myPrimaryActualLocation;											//16.01.2023 navhl20 #62066
			if location &lt;&gt; null and location.isKindOf(CM_GeneralCargoController) then		//16.01.2023 navhl20 #62066
				hold := location.CM_GeneralCargoController.name;
			endif;
			specialStow := ti.specialStow;
		
			if grpMethod &lt;&gt; null then
				grpMethod.getJobIdCrit(ti);
			endif;
		endif;
		
		str := counter &amp; CN_UNDERSCORE &amp; _jobSheet.externalName;
		if hold &lt;&gt; null then
			str := str &amp; CN_UNDERSCORE &amp; hold;
		endif;
		if crit &lt;&gt; null then
			str := str &amp; CN_UNDERSCORE &amp; crit;
		endif;
		if specialStow &lt;&gt; null then
			str := str &amp; CN_UNDERSCORE &amp; specialStow;
		endif;
	endif;
	return str[1:30];
epilog

end;</source>
        <Parameter name="_job" type="CM_Job"/>
        <Parameter name="_jobSheet" type="CM_WorkPointJobSheet"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getWOTransactionType" id="d24e5201-eb90-4892-b485-7e187eccf396">
