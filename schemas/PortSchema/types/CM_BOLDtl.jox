    <JadeMethod name="hsCode" id="8aff93b7-320d-4450-83ac-af296a34e4f3">
        <methodInvocation>mapping</methodInvocation>
        <source>hsCode(set: Boolean; _value: String io) mapping;
/*

Purpose:			

Parameters:			

Return Value:		

Date					Who		Reason
25 November 2022		jlizm1	Initial creation TFS 55280 Harmonized System Codes

*/

vars

begin
	if set then
		global.setExtraData(self.allExtraData, self, HSCode, _value);
	else
