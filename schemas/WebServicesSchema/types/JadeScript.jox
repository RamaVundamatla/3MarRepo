    <JadeMethod name="eprTestTruckLoad" id="1cd562e8-d643-4463-90ac-d07e6316ae53">
        <source>eprTestTruckLoad();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 December 2017	jlger1	Initial creation
14 Feb 2023 navhl20 ChangeRequest 62093: EUP | Retrospective Operations - [54177.030] - Road Receive
*/

vars


	wsQueryRequest : WS_RoadJobRequest;
tiArray : CM_TIArray;
	truckUnLoaderController: CMIF_MobileTruckLoaderUnloader;
	webService  : JMTUserInterfaceService;
	ti 	: CM_TrackedItem;
	truck : CM_Vehicle;
	lc : CM_LocationsController;
	foundHeight : Integer;
	anyIdDynaDict : DynaDictionary;
begin
	create anyIdDynaDict transient;
	anyIdDynaDict.setMembership(WS_RoadWLE);
	anyIdDynaDict.addExternalKey(String,30,true,true);
	anyIdDynaDict.endKeys(false);
	
	
	return;
	ti:="4949.1941982".asOid.CM_TrackedItem;
	app.initialize;
	app.myPassport.setMyUserFromCode("CNWER1");
	app.myPassport.setMyTerminal(app.myRoot.allTerminals["T01"]);
	truck :=app.myPassport.myTerminal.findTruck( "AAT",null,null );
	create truckUnLoaderController transient;
	truckUnLoaderController.setMyTerminal(app.myPassport.myTerminal);
	truckUnLoaderController.setTruck(truck);
	//truckUnLoaderController.setMy
	//truckUnLoaderController.setMyWle("2425.1401310".asOid.CM_WorkListEntry);
	truckUnLoaderController.setDoNotShowMsgBox(true);
	truckUnLoaderController.inspectModal;
	//self.setIgnoreWarnings(true)
	//	truckUnLoaderController.clickInYardItem(ti);
	app.myPassport.myTerminal.findLocationFromString(ti.priorLocation ,true,lc,foundHeight);
	truckUnLoaderController.setDoingReversal(true);
	truckUnLoaderController.setChecksState(truckUnLoaderController.TruckUnload);
	truckUnLoaderController.saveChangesUnload(ti,lc,1,0,null);					//14.02.2023 navhl20 #62093
epilog
	delete truckUnLoaderController;
end;</source>
    </JadeMethod>
    <JadeMethod name="eprTestUpdateVoyRequest" id="d175f770-55b3-4738-ba5c-0d42ba526bf1">
        <source>eprTestUpdateVoyRequest();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 September 2021	jlier1	Initial creation

*/

vars
	wsVoyageCargoRequest : WS_CreateVoyageRequest;
	wsVoyageHoldCargo  : WS_VoyageHoldCargo;
	allCargo 			: CMIF_TIObjectArray;
	allJobParams 		: ObjectArray;
	obj: Object;
	uiService : JMTUserInterfaceService;
	voyage : CM_Voyage;
	pxyDtl,
	woDtl : CM_WodVoyageRequest;
	pxyWorkOrder : CM_WorkOrder;
begin
	app.initialize;
	app.myPassport.setMyUserFromCode("JLGER1");
	app.myPassport.setMyTerminal(app.myRoot.allTerminals["JBL"]);
	
	create wsVoyageCargoRequest transient;
	wsVoyageCargoRequest.setPropertyValue("cmObjectId","4480.2067170");
	wsVoyageCargoRequest.arrivalDate:="21/09/2021";
	wsVoyageCargoRequest.arrivalTime:="21:30";
	wsVoyageCargoRequest.departureDate:="30/09/2021";
	wsVoyageCargoRequest.departureTime:="11:30";
//	wsVoyageCargoRequest.generalRemarks:="test remarks";
//	wsVoyageCargoRequest.vesselCategory:="IC51";
//	wsVoyageCargoRequest.visitType:="SSV";
	wsVoyageCargoRequest.vessel:="VICT";
	wsVoyageCargoRequest.operator:="ABC";
	
	
	voyage:=app.myPassport.getObjectOfTypeFromOid(wsVoyageCargoRequest.cmObjectId,CM_Voyage).CM_Voyage;
	
	woDtl := voyage.getWorkOrderForVoyageRequest();	
	if woDtl = null then
		
		return ;
	endif;
	
	
	beginLoad;
		pxyWorkOrder:=woDtl.getMyParent.pxyCreateUpdateProxy.CM_WorkOrder;
		pxyDtl:=woDtl.pxyGetProxyObject.CM_WodVoyageRequest;
	endLoad;
	
	
	wsVoyageCargoRequest.updatePxyVoyageRequest(pxyDtl);

	
	
	app.myPassport.setWarningsIgnored( true);
	app.myPassport.setWarningsAcknowledged( true);
	app.myTrxUA.trxUpdateVoyageRequest(pxyWorkOrder,null,app.myPassport);
	
	app.myPassport.dumpErrorWarnings;
	
epilog
		endLoad;
	delete pxyWorkOrder;
end;</source>
    </JadeMethod>
    <JadeMethod name="eprTestVoyageHoldCargoRequest" id="378e73fc-a896-4bb5-9070-1d353a6b3822">
        <source>eprTestVoyageHoldCargoRequest();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 March 2018	jlger1	Initial creation

*/

vars
	wsVoyageCargoRequest : WS_VoyageHoldCargoRequest;
	wsVoyageHoldCargo  : WS_VoyageHoldCargo;
	allCargo 			: CMIF_TIObjectArray;
	allJobParams 		: ObjectArray;
	voyage 			: CM_Voyage;
	obj: Object;
	uiService : JMTUserInterfaceService;
begin
	app.initialize;
	app.myPassport.setMyUserFromCode("CNWER1");
	app.myPassport.setMyTerminal(app.myRoot.allTerminals["JBL"]);
	voyage:="4480.1148129".asOid.CM_Voyage;
	create wsVoyageCargoRequest transient;
	wsVoyageCargoRequest.voyage:=voyage.getOidString;
	
	//voyage:="4480.1159448".asOid.CM_Voyage;
	
	create wsVoyageHoldCargo transient;
	wsVoyageHoldCargo.holdLocation:=voyage.myGeneralCargoVoyage.allLocationsByOrdinal.first.getOidAsString;
	wsVoyageHoldCargo.workpoint:="11484.312";
	wsVoyageHoldCargo.imexStatus:=TI_IMEX_STATUS_IMPORT;
	wsVoyageHoldCargo.cargoType:="10096";
	wsVoyageHoldCargo.totalQuantity:=50;
	wsVoyageHoldCargo.operator:=voyage.myOperator.getOidString;
	wsVoyageHoldCargo.dischargePort:=voyage.allPortRotations.first.myPort.code;
	wsVoyageHoldCargo.consignee:="BOEIN";
	wsVoyageHoldCargo.gangs :=44;
	//wsVoyageHoldCargo.voyageJobTransferType:=10002;
	wsVoyageCargoRequest.allVoyageHoldCargo.add(wsVoyageHoldCargo);
	create wsVoyageHoldCargo transient;
	wsVoyageHoldCargo.holdLocation:=voyage.myGeneralCargoVoyage.allLocationsByOrdinal.first.getOidAsString;
	wsVoyageHoldCargo.workpoint:="11484.312";
	wsVoyageHoldCargo.imexStatus:=TI_IMEX_STATUS_IMPORT;
	wsVoyageHoldCargo.cargoType:="10096";
	wsVoyageHoldCargo.totalQuantity:=50;
	wsVoyageHoldCargo.operator:=voyage.myOperator.getOidString;
	wsVoyageHoldCargo.dischargePort:=voyage.allPortRotations.first.myPort.code;
	wsVoyageHoldCargo.consignee:="BOEIN";
	wsVoyageHoldCargo.gangs :=44;
	//wsVoyageHoldCargo.voyageJobTransferType:=10002;
	wsVoyageCargoRequest.allVoyageHoldCargo.add(wsVoyageHoldCargo);
	
	create wsVoyageHoldCargo transient;
	wsVoyageHoldCargo.holdLocation:=voyage.myGeneralCargoVoyage.allLocationsByOrdinal.first.getOidAsString;
	wsVoyageHoldCargo.workpoint:="11484.312";
	wsVoyageHoldCargo.imexStatus:=TI_IMEX_STATUS_IMPORT;
	wsVoyageHoldCargo.cargoType:="10096";
	wsVoyageHoldCargo.totalQuantity:=50;
	wsVoyageHoldCargo.operator:=voyage.myOperator.getOidString;
	wsVoyageHoldCargo.dischargePort:=voyage.allPortRotations.first.myPort.code;
	wsVoyageHoldCargo.consignee:="BOEIN";
	wsVoyageHoldCargo.gangs :=44;
	//wsVoyageHoldCargo.voyageJobTransferType:=10002;
	wsVoyageCargoRequest.allVoyageHoldCargo.add(wsVoyageHoldCargo);
	
	
	create allCargo transient;
	create allJobParams transient;
	wsVoyageCargoRequest.setAllProxyObjects(allCargo,allJobParams,null);
	voyage:=app.myPassport.getObjectOfTypeFromOid(wsVoyageCargoRequest.voyage,CM_Voyage).CM_Voyage;
	
	app.myPassport.setWarningsIgnored(true);
	app.myPassport.setWarningsAcknowledged(true);
	
	
	//	on CM_Exception do app.validationExHandler(exception,app.myPassport);
	app.myTrxCA.trxCreateVoyageCargoRequest(voyage,null,null, null,null,null,null, null,false, app.myPassport);
	
	app.myPassport.dumpErrorWarnings;
epilog

	delete wsVoyageCargoRequest;
	if allCargo &lt;&gt; null then
		allCargo.purge;
		delete allCargo;
	endif;
	foreach obj in allJobParams discreteLock do
		delete obj.CMIF_VoyageJobParams.myProxyJob;
	endforeach;
	if allJobParams &lt;&gt; null then
		allJobParams.purge;
	endif;
	
end;</source>
    </JadeMethod>
