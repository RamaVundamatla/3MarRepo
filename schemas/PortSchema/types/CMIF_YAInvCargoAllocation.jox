    <JadeMethod name="isTrailerType_Match" id="41d50a37-32ea-4f4c-acf6-bd00d9c2d3fa">
        <source>isTrailerType_Match(_yaData: CM_YADataObjects): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 October 2020	jlgndl1	Initial creation	TFS 50113

*/

vars

	yaDataObjs : CM_YADataObjects;
	obj : Object;
	
	trailerTypeStr : String;
	trailerType : CM_TILCType;

begin

	if self.myTransaction = null then
		return inheritMethod( _yaData );
	endif;
	if self.myTransaction.isKindOf( CM_ReceiveRoad ) then
		trailerTypeStr := self.myTransaction.CM_ReceiveRoad.trailerTypeCode;
	elseif self.myTransaction.isKindOf( CM_ReleaseRoad ) then
		trailerTypeStr := self.myTransaction.CM_ReleaseRoad.trailerTypeCode;
	//27 Nov 2020	NDL	TFS 50329
	elseif self.myTransaction.isKindOf( CM_TrailerDischarge ) then
		trailerTypeStr := self.myTransaction.CM_TrailerDischarge.trailerTypeCode;
	//27 Nov 2020	NDL	TFS 50329
	elseif self.myTransaction.isKindOf( CM_TrailerLoad ) then
		trailerTypeStr := self.myTransaction.CM_TrailerLoad.trailerTypeCode;

	else
		return inheritMethod( _yaData );
	endif;
	
	if trailerTypeStr &lt;&gt; null then
		trailerType := app.myRoot.allTILCTypes[null, trailerTypeStr];
	endif;
	
	if _yaData.matches( trailerType ) then
		return true;
	endif;
	
	return inheritMethod( _yaData );
	
epilog

end;</source>
        <Parameter name="_yaData" type="CM_YADataObjects"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isTransactionType_Match" id="c474fec9-cff6-447c-bfea-9a35e51962ad">
        <source>isTransactionType_Match(_yaData: CM_YADataObjects): Boolean;
/*
Purpose:			
Date		Who		Reason
25 March 2015	cnwab1	Initial creation
*/

vars
	
begin
	if self.myTransaction = null then
		return false;
	endif;
	
	// Only priorities will be empty.
	if _yaData.isEmpty() then
		return true;
	endif;
	
	return _yaData.matches(self.myTransaction.getTransactionType());

epilog

