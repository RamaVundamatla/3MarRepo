    <JadeMethod name="setChildrenForCreate" id="8d202bbf-c5b7-4011-bde4-2fcaa07f35db">
        <updating/>
        <source>setChildrenForCreate(pChildren: CM_TISet; _passport: CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 22/01/2021	jlgdap1		Initial creation TFS 50553 Handling of Nested Child Cargo in BAPLIE EQA Segment
// 22/02/2023 	navmk20 	Bug 56400: EUP Testing | Container Weights not updated when Making New LCL
// 08/05/2023	navpw1		TFS: 57388 - Backed out code for 56400
//
vars
	parentDown : Boolean;
	child : CM_TrackedItem;
	totWeight : Decimal [14,4];

begin
	inheritMethod(pChildren, _passport);
	
	// TFS 50553 if I'm a flat rack, and my children are all flat racks, set ends down on me and my children
	// Also set my total weight from the child weights
	if self.isFlat then
		foreach child in pChildren where child.isFlat do
			parentDown := true;
			child.CM_Container.setDoorsDirn(TI_DOORSDIRN_ENDDOWN);
			totWeight 	:= totWeight + child.totalWeight;
		endforeach;
		
		if parentDown then
			self.setDoorsDirn(TI_DOORSDIRN_ENDDOWN);
		endif;
		if self.totalWeight &lt; totWeight then
			self.setTotalWeightWithoutTrans(totWeight + self.totalWeight);
		endif;
	endif;
epilog

end;</source>
        <Parameter name="pChildren" type="CM_TISet"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="setCommodity" id="45d95b25-6f9c-4beb-9cb1-8960fa084d7a">
        <updating/>
        <source>setCommodity(_commodityCode: String) updating;
/*
----------   ----------  --------------------------------------------------
Created:	17 July 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
30 Oct 2023	navma1 ChangeRequest 60841: MTN - Improve Performance of Cargo Bulk Edit - First Enhancement
----------   ----------  --------------------------------------------------
*/
vars
	commodity		: CM_Commodity;
begin
	inheritMethod(_commodityCode);
	
	if _commodityCode &lt;&gt; null then												//30.10.2023 navma1 #60841
		commodity := app.myRoot.allCommodities[_commodityCode];
	endif;
	
	//th2 17/07/06 - non reefer boxes cannot have temperature readings now.
	if commodity = null or (not commodity.hasTemp) then
		self.setTemperature(NULL_TEMPERATURE);
	endif;

end;</source>
        <Parameter name="_commodityCode" type="String"/>
    </JadeMethod>
    <JadeMethod name="setContentsStatus" id="8cd6f0c5-6f2b-445f-9eb7-08d0baa27eaa">
        <updating/>
        <source>setContentsStatus(_contentStatus: Integer) updating;
/*
Purpose:		PAr 35308	
Date		Who		Reason
12 December 2014	cnwab1	Initial creation
 7/9/22 	jlier1	TFS 54700 
*/

vars

begin
//	if _contentStatus&lt;&gt; _contentStatus then
	if self.contentsStatus &lt;&gt; _contentStatus then
		self.contentsStatus := _contentStatus;
	endif;
	
epilog

end;</source>
        <Parameter name="_contentStatus" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setCustomsSealNums" id="d9c4f965-ecda-448f-8549-d7a5849ddbf0">
        <updating/>
        <source>setCustomsSealNums(_pxyTI: CM_Container) updating;
//----------------------------------------------------------------
//	Created:	13 September 2004	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars

//	str	: String;
	sealType : CM_SealType;
	pxySealTI : CM_SealTI;
	realSealTI : CM_SealTI;
	previousValue : String;
	
begin

/*	self.allCustomsSealNumbers.clear;
	
	self.sealNumCustoms := _pxyTI.sealNumCustoms;
	if _pxyTI.sealNumCustoms &lt;&gt; null then
		self.allCustomsSealNumbers.add(_pxyTI.sealNumCustoms);
	endif;
	
	foreach str in _pxyTI.allCustomsSealNumbers do
		str := str.trimBlanks;
		if str &lt;&gt; null 
		and not self.allCustomsSealNumbers.includes(str) then
			self.allCustomsSealNumbers.add(str);
		endif;
	endforeach;
	
	if not self.allCustomsSealNumbers.isEmpty 
	and self.sealNumCustoms = null then
		self.sealNumCustoms := self.allCustomsSealNumbers.first[1:35];
	endif; */
	
	//16 Sep 2010	NDL	Par 25608 - Use/update new seals data structure
	sealType := app.myRoot.getSealType( SealType_Customs );
	
	pxySealTI := _pxyTI.getSealTI(sealType);
	realSealTI := self.getSealTI(sealType);
	
	if pxySealTI = null then
		if realSealTI &lt;&gt; null then
			// we had a customs seal once, but apparently have it no longer, update its value to null.
			if not realSealTI.allSealNums.isEmpty then
				previousValue := realSealTI.allSealNums.first;
			endif;
			realSealTI.setPreviousSeal(previousValue);
			realSealTI.allSealNums.clear();
			realSealTI.setSealedDT(app.actualTimeServer);
		else
			// we don't have one, and didn't have one, nothing to do.
		endif;
	else
		// we have a customs seal
		if realSealTI = null then
			// but we didn't before, so create it.
			create realSealTI persistent;
			realSealTI.setForCreate(pxySealTI);
			realSealTI.setMyTrackedItem(self);
			
		else
			// and we did before, so update it.
			realSealTI.setForUpdate(pxySealTI);
			
		endif;
		
	endif;
	
end;</source>
        <Parameter name="_pxyTI" type="CM_Container"/>
    </JadeMethod>
    <JadeMethod name="setDefaultAvailabilityGrade" id="64fb5a7a-9106-4bfd-b9e5-419e0956d784">
        <updating/>
        <source>setDefaultAvailabilityGrade() updating;
//AJA 13/10/99: This detrmines if the TI should have an availability grade.
//If so, the default grade is used, as set in the config object
//Must be in transaction state here (done when receiving TI on site)
vars
	theAvailabilityGrade : Integer;
begin

	if contentsStatus &lt;&gt; TI_CONTENTS_STATUS_EMPTY or
		self.site &lt;&gt; TI_SITE_ONSITE or
		self.priorLocation &lt;&gt; null then
		return;		//must be empty and moved onsite from offsite
	endif;

  //Set the availability grade to default value if not already set
	if self.availabilityGrade = 0 then
	// CCMS 1235
		theAvailabilityGrade := self.myTerminal.getConfig(DefAvailabilityGrade).Integer;
		self.availabilityGrade := theAvailabilityGrade;
	endif;
end;</source>
    </JadeMethod>
    <JadeMethod name="setDefrostTemp" id="67b92ae5-d45b-4d41-83bb-8a031cfef7bb">
        <updating/>
        <source>setDefrostTemp(_dateTime : TimeStamp) updating;
//
// Aug 2007 cnwrs1 CCMS1055
//
// CCMS 1007 This method is not referenced any more, defrost dates are updated
// in CM_TempReading setForCreate and setForUpdate directly on the new CM_ReeferProperties reference
//
// PAR #25754 this should have been moevd to CM_TrackedItem as part of reefer changes - even though
// this method is no longer referenced, it has been cvhanged to align it with other reefer property updates
vars

begin
	inheritMethod(_dateTime);
	
	// what the code was before PAR #25754
	/*if self.getDefrostDate  &lt;&gt; null and
	   _dateTime = null then 
		self.setDefrostDate(null); // unset defrost date
	elseif self.getDefrostDate &lt;&gt; null and
	   _dateTime &lt;&gt; null then	// still on defrost do nothing
	elseif self.getDefrostDate = null then
		self.setDefrostDate(_dateTime);	//set to firstDefost date
	endif;*/
end;
</source>
        <Parameter name="_dateTime" type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="setDoorsDirn" id="e65a827c-9048-454a-8521-04a78b89271e">
        <updating/>
        <source>setDoorsDirn(_value : Integer) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 14/11/2019	jlgdap1		Initial creation TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
//
vars

begin
	if self.doorsDirn &lt;&gt; _value then
		self.doorsDirn := _value;
	endif;
epilog

end;</source>
        <Parameter name="_value" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="setFlatEndDirection" id="0d743633-4292-44d5-a8df-ff89c78b3e86">
        <updating/>
        <source>setFlatEndDirection() updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 04/11/2019	jlgdap1		Initial creation TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
//
vars
	child : CM_TrackedItem;
	up : Boolean;
	childDict : CM_TISet;

begin
	if not self.isFlat then
		return;
	endif;
	
	up := true;
	foreach child in self.allChildren discreteLock do
		if child.isFlat then
			up := false;
			childDict := self.allChildren;
		endif;
	endforeach;
	
	if self.myParent &lt;&gt; null and self.myParent.isFlat and self.isFlat then
		up := false;
		childDict := self.myParent.allChildren;
	endif;
	
	if up then
		self.setDoorsDirn(TI_DOORSDIRN_ENDUP);
	else
		self.setDoorsDirn(TI_DOORSDIRN_ENDDOWN);
		foreach child in childDict where child.isFlat do
			child.CM_Container.setDoorsDirn(TI_DOORSDIRN_ENDDOWN);
		endforeach;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setForConnectDelete" id="dca1e354-ff0e-4645-ae2d-c164b8bc649b">
        <updating/>
        <source>setForConnectDelete(_deletedTrans: CM_ConnectPower) updating;
//----------------------------------------------------------------
//	Created:	25 February 2004	by Jason Chapman  (cnwjc2)
//	
//	Resets first/lastConnectDT after deletion of CM_ConnectPower transaction
//----------------------------------------------------------------
// 10/12/2009	cnwdap1		CCMS MES 1007 Now implemented at CM_TrackedItem level - any TI can now be a reefer
vars
	trans		: CM_TITransaction;
	powerConFirst,
	powerConLast: CM_ConnectPower;
	
begin
	inheritMethod(_deletedTrans);
	
	/*	foreach trans in self.allTransactions do
			if trans.type = TRANS_TYPE_CONNECT_POWER
			and (not trans.deleted) then
				if powerConLast = null then
					powerConFirst	:= trans.CM_ConnectPower;
					powerConLast	:= trans.CM_ConnectPower;
				else
					if powerConLast.dateTime.cnEcIsLessThanOrEqual(trans.dateTime) then
						powerConLast := trans.CM_ConnectPower;
					endif;
				endif;
			endif;
		endforeach;
	
		if powerConLast = null then
			self.setFirstConnectDT(null);
			self.setLastConnectDT(null);
		else
			self.setFirstConnectDT(powerConFirst.dateTime);
			self.setLastConnectDT(powerConLast.dateTime);
		endif;

		self.fixOnPower();	*/
end;</source>
        <Parameter name="_deletedTrans" type="CM_ConnectPower"/>
    </JadeMethod>
    <JadeMethod name="setForCreate" id="75bf08c9-ad79-4c0b-971f-05a746227340">
        <updating/>
        <source>setForCreate(_pxyTI: CM_TrackedItem; _passport: CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Oct 2019	jlgsl4	TFS 46767 - PEN - GenSet Trailer Linking
04 Nov 2019	jlgdap1	TFS 46405 AAT Flat Rack and OOG in LOLO Planning Screen
*/

vars

begin
	inheritMethod(_pxyTI, _passport);
	//self.autoCreateTIMaster(); // 31/10/2019 disable autocreation for 090
	
	self.setFlatEndDirection();			// TFS 46405
epilog

end;</source>
        <Parameter name="_pxyTI" type="CM_TrackedItem"/>
