    <JadeMethod name="setName" id="f36f08f2-d7a3-49f0-a206-376bdd5e4ef3">
        <updating/>
        <source>setName(_name : String) updating;
/*
----------   ----------  --------------------------------------------------
Created:	27 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin

	if self.name &lt;&gt; _name then
		self.name := _name;
	endif;
	

		
end;


</source>
        <Parameter name="_name" type="String"/>
    </JadeMethod>
    <JadeMethod name="setSelf" id="b8cb2baa-d88b-462d-82b9-48fed4ff4b95">
        <updating/>
        <source>setSelf(_entRowEntity : EntTableRowEntity) updating;
// ---------------------------------------------------------------------------
// Created:     19 June 2003		cnwth2	
//
// Purpose:     		 
// ----------   ----------  --------------------------------------------------
vars

begin

// do not set these as they are set by the setBasicDetails method and
// should NOT be overridden. Par 17908
//	self.name							:= _entRowEntity.name;
//	self.heading						:= _entRowEntity.heading;
//	self.inputType						:= _entRowEntity.inputType;



	self.clickMethodName				:= _entRowEntity.clickMethodName;
	self.controlName					:= _entRowEntity.controlName;
	self.myTerminologyType				:= _entRowEntity.myTerminologyType;
	self.gotFocusMethodName				:= _entRowEntity.gotFocusMethodName;
	self.shortHeading					:= _entRowEntity.shortHeading;
	self.sortFieldName					:= _entRowEntity.sortFieldName;
	self.inputTypeForWeb				:= _entRowEntity.inputTypeForWeb;
	self.lostFocusMethodName			:= _entRowEntity.lostFocusMethodName;
	self.sortFieldName					:= _entRowEntity.sortFieldName;
	self.displayNullIfZero			:= _entRowEntity.displayNullIfZero;

end;</source>
        <Parameter name="_entRowEntity" type="EntTableRowEntity"/>
    </JadeMethod>
