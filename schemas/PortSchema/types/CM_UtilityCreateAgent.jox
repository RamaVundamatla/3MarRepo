    <JadeMethod name="utlCreateVoyage" id="89ab5cc9-137c-4fa2-8ac4-fbe16399da01">
        <source>utlCreateVoyage(_proxyVoyage:CM_Voyage; _newVoyage:CM_Voyage output;
			_realVessel : CM_Vessel input; _realVoyGlobal : CM_VoyageGlobal;
			_createSPS : Boolean; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 July 2001 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valVoyage(_proxyVoyage, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	
	self.zUtlCreateVoyage(_proxyVoyage, _newVoyage, _realVessel,
						_realVoyGlobal, _createSPS,
						_passport);
	
	if _passport.hasErrors() then
		return;
	endif;

	// PAR 26885 (ensure movements are linked correctly) RJS 6 Feb 2011
	if _newVoyage &lt;&gt; null then
		_newVoyage.maintainMovementLinkedList();
		
		//navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024 - start
		if _newVoyage.myVoyageProcess &lt;&gt; null and _newVoyage.myVoyageProcess.isAutomaticProcess() then //navpw1 added not null check.
			app.myUtilityCA.utlCreateVoyageProgress(_newVoyage, _passport);
		endif;
		//navra1 - CR-65068/Task-64641 - Auto Comparison - 15th July 2024 - end
	endif;
	
end;</source>
        <Parameter name="_proxyVoyage" type="CM_Voyage"/>
        <Parameter name="_newVoyage" type="CM_Voyage" usage="output"/>
        <Parameter name="_realVessel" type="CM_Vessel" usage="input"/>
        <Parameter name="_realVoyGlobal" type="CM_VoyageGlobal"/>
        <Parameter name="_createSPS" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateVoyageController" id="18d3b2a9-40da-42e1-912b-3a0d6dba86b4">
        <source>utlCreateVoyageController(pProxyVoyageController:CM_VoyageController; pNewVoyageController:CM_VoyageController output;
				_passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     16 January 2002 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars

begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valVoyageController(pProxyVoyageController, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	create pNewVoyageController as pProxyVoyageController.class persistent;
	pNewVoyageController.setForCreate(pProxyVoyageController);

end;</source>
        <Parameter name="pProxyVoyageController" type="CM_VoyageController"/>
        <Parameter name="pNewVoyageController" type="CM_VoyageController" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateVoyageGlobal" id="57d141b3-63db-48f7-9112-7cd91a63caf3">
        <updating/>
        <source>utlCreateVoyageGlobal(_pxyVoyageGlobal : CM_VoyageGlobal; _realVoyageGlobal : CM_VoyageGlobal output; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: 08 January 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	proxyCode,
	realCode	: CM_CurrencyCode;

begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	app.myValCA.valVoyageGlobal(_pxyVoyageGlobal, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	create _realVoyageGlobal persistent;
	_realVoyageGlobal.setForCreate(_pxyVoyageGlobal, _passport);
	// CCMS 1124 save vessel name if IMO is set, in vesselCode
	if _realVoyageGlobal.vesselCode &lt;&gt; null and
	   _realVoyageGlobal.vesselName &lt;&gt; null then
		realCode := app.myRoot.allCurrencyCodes[_realVoyageGlobal.vesselCode];
		if realCode = null then
			create realCode persistent;
			create proxyCode transient;
			proxyCode.setProxy(_realVoyageGlobal.vesselCode, _realVoyageGlobal.vesselName);
			realCode.setForCreate(proxyCode);
		endif;
	endif;
	
	if _passport.noErrors then
		global.causeEvent(LogVoyageOps_Create_Event, false, _realVoyageGlobal);	
		self.myCreateAuditAgent.audCreateGeneric(_realVoyageGlobal);
	endif;
epilog
	delete proxyCode;
end;</source>
        <Parameter name="_pxyVoyageGlobal" type="CM_VoyageGlobal"/>
        <Parameter name="_realVoyageGlobal" type="CM_VoyageGlobal" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateVoyageHoldJob" id="a678c64b-4798-4add-9b47-4c6451b9abe9">
        <updating/>
        <source>utlCreateVoyageHoldJob(	_jobParams  : CMIF_VoyageJobParams input; 
						_newHoldJob : CM_VoyageHoldJob io; 
						_passport   : CM_Passport input;
						_allWLEs    : CM_WLEArray	) updating;				// TFS 3516
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 19/01/2017	cnwdap1		Initial creation TFS 3219 LNX Voyage Operations Enhancements
// 01/03/2017	cnwdap1		TFS 3516 LNX Hold Planning Quantity
// 20/11/2023   navma1		ChangeRequest 58400: EUP | Ship Operations in DD - [54176.050] [Receive] Mobile App changes
//
vars
	voyageHoldJobSheet : CM_VoyageJobSheet;
	shift 			   : CM_Shift;
	realShift 		   : CM_ShiftEntity;
	voyage 			   : CM_Voyage;
	wle 			   : CM_WorkListEntry;
	voyageProcess 	   : CM_VoyageProcess;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);

	app.myValCA.valVoyageHoldJob(_jobParams);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	voyageHoldJobSheet := _jobParams.myJobSheet;
	if voyageHoldJobSheet = null then
		if _jobParams.myWorkPoint &lt;&gt; null then
			voyageHoldJobSheet := _jobParams.myVoyage.allJobSheets[_jobParams.myWorkPoint.code];
		endif;
	endif;

	// auto create the voyage job sheet for this crane, if necesssary
	// they can allocate a job to a crane elsewhere so they do not have to supply a crane
	if voyageHoldJobSheet = null then
		if _jobParams.myWorkPoint &lt;&gt; null then
			create voyageHoldJobSheet as CM_VoyageHoldJobSheet;
			// if the voyage is null or the crane id is null the validation above will have kicked in
			voyageHoldJobSheet.setForCreate(_jobParams.myVoyage, _jobParams.myWorkPoint.code, _jobParams.myWorkPoint);	
		endif;
	endif;
	_jobParams.myJobSheet := voyageHoldJobSheet;
	
	// create a shift for this job as well
	if _jobParams.myProxyJob.myShift &lt;&gt; null then
		shift     := _jobParams.myProxyJob.myShift;
		voyage    := _jobParams.myVoyage;
		realShift := app.myProxyManager.getRealObject(shift).CM_Shift;
		
		if realShift = null then
			realShift := voyage.myTerminal.allShiftsDay[shift.startDateTime, shift.code];
		endif;
		
		if realShift = null then
			self.utlCreateShiftStd(shift, _passport, realShift);
		else
			if realShift.pxyGetProxyObject = shift then
				app.myUtilityUA.utlUpdateShift(shift, _passport);
			endif;
		endif;
	endif;
	
	create _newHoldJob as _jobParams.myProxyJob.class;
	
	_newHoldJob.setForCreateVoyage(_jobParams, _allWLEs, _passport);			// TFS 3516
	if _jobParams.remarks = null then											// TFS 3516
		_newHoldJob.setRemarks(null);											// TFS 3516
	endif;																		// TFS 3516
	
	//epr TFS 39166 13/6/18
	voyageProcess := _jobParams.myVoyage.myVoyageProcess;								//20.11.2023 navma1 #58400
	if voyageProcess &lt;&gt; null and voyageProcess.doCreateWOCargoRequest() then
		app.myUtilityUA.utlUpdateWorkOrderCargoRequest(_newHoldJob,_passport);
	endif;
	
	if _passport.noErrors and not _jobParams.isTransientJob and not _jobParams.holdNote then
		_newHoldJob.causeTerminalEvent(_newHoldJob.Event_Mode_Create);
		
		 // ### TFS 53105 02JUN2022 NAVAB1
		app.myPassport.opsViewCreateRequest(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_JOB,_newHoldJob.myTerminal,_newHoldJob);
		foreach wle in _newHoldJob.workListEntries as CM_VoyageWLE discreteLock do 
			if wle.status &lt;&gt; WLE_UNACTIONED then
				continue;
			endif;
			if not wle.isSOBLoad() then
				app.myPassport.opsViewCreateRequest(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_WLE,wle.getMyTerminal,wle);
			endif;
		endforeach;
		
	endif;
epilog

end;</source>
        <Parameter name="_jobParams" type="CMIF_VoyageJobParams" usage="input"/>
        <Parameter name="_newHoldJob" type="CM_VoyageHoldJob" usage="io"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_allWLEs" type="CM_WLEArray"/>
    </JadeMethod>
    <JadeMethod name="utlCreateVoyageInternalJob" id="f721477d-70ee-4e02-99e2-6e71169acfd5">
        <updating/>
        <source>utlCreateVoyageInternalJob(	_changeVoyageJobParam	: CMIF_WorkOrderJobParams;
							_realChangeVoyageJob	: CM_WOChangeVoyageJob output;
							_terminal 				: CM_Terminal;
							_passport				: CM_Passport input) updating;
/*

/*

Purpose:			

Parameters:			

Return Value:		


Date			Who		Reason
14/06/2022		navcs2	ChangeRequest 53038: MTN - Work Order Maintenance Refactor - PortSchema

*/


vars
	cancelSave : Boolean;
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);

	create _realChangeVoyageJob persistent;
	_realChangeVoyageJob.setForCreateInternal(_changeVoyageJobParam,_terminal); 

end;</source>
        <Parameter name="_changeVoyageJobParam" type="CMIF_WorkOrderJobParams"/>
        <Parameter name="_realChangeVoyageJob" type="CM_WOChangeVoyageJob" usage="output"/>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateVoyageJob" id="359f7de4-6f7e-42d8-bccd-04b4312cce18">
        <updating/>
        <source>utlCreateVoyageJob(_theJobParams:CMIF_VoyageJobParams input; _theNewVoyageJob:CM_VoyageJob output;_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		February 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 07/03/2017	cnwdap1		TFS 3516 LNX Hold Planning Quantity
// 21 Sep 2020  cnwma1 		ChangeRequest 49906: MTN - Ops View External Webservice
// ---------------------------------------------------------------------------

vars
	theVoyageJobSheet :	CM_VoyageJobSheet;
	aReq 			  : CM_RORORequest;
	wle               : CM_WorkListEntry;
	ti	: CM_TrackedItem;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);

	if _theJobParams.useNewMethod  then
		// PAR 32120 if we get a warning and this is a SOB job then the job is changed to be a discharge job 
		//					and the auto link planning does not happen. the trigger if whether allRORORequests is empty
		_theJobParams.allRORORequests.clear(); 
		
		_theJobParams.setRequests();
		if (not _theJobParams.isExportReturn) then // CCMS 1018 Editions already checked
			_theJobParams.validateSlotAndHatchEditions();
		endif;
	endif;

	app.myValCA.valVoyageJob(_theJobParams);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	theVoyageJobSheet := _theJobParams.myJobSheet;
	if theVoyageJobSheet = null then
		theVoyageJobSheet := _theJobParams.myVoyage.allJobSheets[_theJobParams.craneID];
	endif;

	// auto create the voyage job sheet for this crane, if necesssary
	// they can allocate a job to a crane elsewhere so they do not have to supply a crane
	if theVoyageJobSheet = null then
		if _theJobParams.myWorkPoint &lt;&gt; null then
			create theVoyageJobSheet as CM_VoyageDeckJobSheet;
			// if the voyage is null or the crane id is null the validation above will have kicked in
			theVoyageJobSheet.setForCreate(_theJobParams.myVoyage,_theJobParams.myWorkPoint.code,_theJobParams.myWorkPoint);	
		else
			if _theJobParams.craneID &lt;&gt; null then
				create theVoyageJobSheet;
				// if the voyage is null or the crane id is null the validation above will have kicked in
				theVoyageJobSheet.setForCreate(_theJobParams.myVoyage,_theJobParams.craneID,null);
			endif;
		endif;
			
	endif;
	
	create _theNewVoyageJob as _theJobParams.myProxyJob.class;
	//_theNewVoyageJob.setForCreateVoyage(_theJobParams, _passport);			// TFS 3516
	_theNewVoyageJob.setForCreateVoyage(_theJobParams, null, _passport);		// TFS 3516

	
	
	if _passport.noErrors 
	and not _theJobParams.isTransientJob 
	and not _theJobParams.holdNote then
		_theNewVoyageJob.causeTerminalEvent(_theNewVoyageJob.Event_Mode_Create);
		//21/09/2020 cnwma1 TFS #49906
		app.myPassport.opsViewCreateRequest(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_JOB,_theNewVoyageJob.myTerminal,_theNewVoyageJob);
		foreach wle in _theNewVoyageJob.workListEntries discreteLock do 
			if wle.status &lt;&gt; WLE_UNACTIONED then
				continue;
			endif;
			if not wle.isSOBLoad() then // ### TFS 51855 01FEB2022 NAVAB1
				app.myPassport.opsViewCreateRequest(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_WLE,wle.getMyTerminal,wle);
				
				if _theNewVoyageJob.isVoyageJob() then // ### TFS 53105 13JUN2022 NAVAB1
					ti := wle.myTrackedItem; // ### TFS 52925 21FEB2022 NAVAB1
					if ti &lt;&gt; null then // ### TFS 52925 21FEB2022 NAVAB1
						if ti.myPrimaryActualLocation &lt;&gt; null // ### TFS 52925 21FEB2022 NAVAB1
						and ti.myPrimaryActualLocation.isVoyageController() then // ### TFS 52925 21FEB2022 NAVAB1
							app.myPassport.opsViewCreateRequest(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_TRACKEDITEM,ti.getMyTerminal,ti); // ### TFS 52925 21FEB2022 NAVAB1
						endif;
					endif;
				endif;
			endif;
		endforeach;
		//21/09/2020 cnwma1 TFS #49906
	endif;

end;</source>
        <Parameter name="_theJobParams" type="CMIF_VoyageJobParams" usage="input"/>
        <Parameter name="_theNewVoyageJob" type="CM_VoyageJob" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateVoyageJobOOW" id="89c37cd2-7593-4264-8224-685974c114ec">
        <updating/>
        <source>utlCreateVoyageJobOOW(_theJobSheets : CM_VoyageJobSheetByCraneDict;_passport : CM_Passport input; _controller : CMIF_VoyageJobParams input) updating;
// ### passed in CMIF_VoyageJobParams is only used to report back TL changes
// ---------------------------------------------------------------------------
// Created:		April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
// 21 Sep 2020  cnwma1 		ChangeRequest 49906: MTN - Ops View External Webservice
// ---------------------------------------------------------------------------
vars
	cvs : CM_CellularVoyageStructure;
	aJS : CM_VoyageJobSheet;
	ls  : Boolean;
	job : CM_Job;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);

	app.myValCA.valVoyageJobOOW(_theJobSheets);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);
	app.cmsBeginLoad(ls);
	_passport.clearErrorsWarnings();
	
	foreach aJS in _theJobSheets 
		where aJS.isVoyageROROJobSheet() or aJS.isVoyageLOLOJobSheet	do // TFS 3631

		cvs := aJS.myVoyage.myCellularVoyageStructure;

		aJS.createOOWAuto(_controller);
		// Create Boomup and lid jobs
		aJS.createOOWAutoCraneJobs();

		aJS.createOOWAutoSetJobs(); // PAR 15285
		
		aJS.createOOWAutoRenumber();
	endforeach;
	if _passport.noErrors and cvs &lt;&gt; null then
		cvs.causeEvent(cvs.myVoyage.myTerminal.getTerminalEvent(EVENT_OOWCREATION_UPDATE), false, cvs);
		
		//21/09/2020 cnwma1 TFS #49906
		foreach aJS in _theJobSheets discreteLock do
			foreach job in aJS.allJobsByOrder discreteLock do
				if job.isVoyageJob() then
					app.myPassport.opsViewCreateRequest(BGP_OpsViewWSRequest.OPS_ACTION_CREATE,BGP_OpsViewWSRequest.OPS_TYPE_JOB,job.getMyTerminal(),job);
				endif;
			endforeach;
		endforeach;
		//21/09/2020 cnwma1 TFS #49906
	endif;
epilog
	app.cmsEndLoad(ls);

end;</source>
        <Parameter name="_theJobSheets" type="CM_VoyageJobSheetByCraneDict"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
        <Parameter name="_controller" type="CMIF_VoyageJobParams" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateVoyageJobPriority" id="b7a48440-77f6-4490-9d09-66f97ce580fe">
        <updating/>
        <source>utlCreateVoyageJobPriority(_theController:CMIF_JobPriorityController input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars

begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);


	_theController.purgePriorities();
	
	if _theController.isResetToSystem then//added by cnwyl1
		return;
	endif;//add end
	
	
	_theController.setForCreate();

end;</source>
        <Parameter name="_theController" type="CMIF_JobPriorityController" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateVoyageJobSheet" id="d5a8b375-90fe-4a0c-8b06-3d8831a98224">
        <updating/>
        <source>utlCreateVoyageJobSheet(_theCranes : CM_MachineSet;_theVoyage : CM_Voyage;_passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		August 2003 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theVoyageJobSheet :	CM_VoyageJobSheet;
	aCrane : CM_Machine;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	foreach aCrane in _theCranes do
		app.myValCA.valVoyageJobSheet(aCrane,_theVoyage,_passport);
	endforeach;
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	foreach aCrane in _theCranes do
		create theVoyageJobSheet;
		// if the voyage is null or the crane id is null the validation above will have kicked in
		theVoyageJobSheet.setForCreate(_theVoyage,aCrane.id,null);
	endforeach;
	
	if _passport.noErrors then
		_theVoyage.causeEvent(_theVoyage.myTerminal.getTerminalEvent(JobSheet_Update_Event), false, _theVoyage);
	endif;
end;</source>
        <Parameter name="_theCranes" type="CM_MachineSet"/>
        <Parameter name="_theVoyage" type="CM_Voyage"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateVoyageOOWCreation" id="86324293-4e3a-455b-8dad-88caf420cac4">
        <updating/>
        <source>utlCreateVoyageOOWCreation(_cvs:CM_CellularVoyageStructure input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aBay : CM_BayVoyage;
	order : Integer;
	
begin
	
	// self.initialiseActivity(); cnwgb1 30133 14.8.2012

	_cvs.getOOWCreation();

	foreach aBay in _cvs.allBayVoyagesByOrdinal do
		order := order + CM_OOWCreation.OOWCreationIncrement;
		aBay.getOOWCreation(order);
	endforeach;
	
	_cvs.reOrderOOWForCreate();
	
end;</source>
        <Parameter name="_cvs" type="CM_CellularVoyageStructure" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateVoyageOOWCreationRORO" id="46669475-3f78-4826-998c-d510ed292c4d">
        <updating/>
        <source>utlCreateVoyageOOWCreationRORO(_roroVoyageStructure :CM_ROROVoyageStructure input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
06 September 2011	cnwer1	Initial creation CCMS MES 1033
//02 Apr 2012	cnwrs1		Par 29077 - EDI RORO Stowage Advice errors
*/

vars
	deck : CM_DeckVoyage;
	order : Integer;
begin	
	self.initialiseActivity();
	app.setContinueCMExceptions(true);	//02 Apr 2012	cnwrs1		Par 29077 - EDI RORO Stowage Advice errors
	
	_roroVoyageStructure.allOOWCreations.purge;
	
	foreach deck in _roroVoyageStructure.allDecks do
		order := order + CM_OOWCreation.OOWCreationIncrement;
		deck.getOOWCreation(order);
	endforeach;
	
epilog

end;</source>
        <Parameter name="_roroVoyageStructure" type="CM_ROROVoyageStructure" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateVoyageOOWMoveCC" id="669b6b00-03a6-4c29-b8a6-013e40b24bd2">
        <updating/>
        <source>utlCreateVoyageOOWMoveCC(_pxyOOWC, _srcOOWC : CM_OOWCreation input;_attribute : String; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:		April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	realOOWC, twinOOWC, pushOOWC : CM_OOWCreation;
	cvs : CM_CellularVoyageStructure;
begin
	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);


	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	
	_srcOOWC.setPropertyValue(_attribute,0);
	_srcOOWC.setPropertyValue(CM_OOWCreationDetail::orderType.name,2);

	create realOOWC as CM_OOWCreationDetail;
	realOOWC.setForCreate(_pxyOOWC.CM_OOWCreationDetail);
	cvs	:= realOOWC.myVoyageStructure;

	_srcOOWC.setMySplitSelf(realOOWC);
	realOOWC.setMySplitSelf(_srcOOWC);

	if  cvs.isOOWCraneBefore(_srcOOWC.myCraneJobSheet, realOOWC.myCraneJobSheet) then
		pushOOWC := realOOWC.myCraneJobSheet.allOOWCreations.first;
		realOOWC.incrementYourOrder(pushOOWC, true);	
	else
		pushOOWC := realOOWC.myCraneJobSheet.allOOWCreations.last;
		realOOWC.incrementYourOrder(pushOOWC, false);	

	endif;

	cvs.tidyUpOOWCreations();

	if _passport.noErrors then
		cvs.causeEvent(cvs.myVoyage.myTerminal.getTerminalEvent(EVENT_OOWCREATION_UPDATE), false, cvs);
	endif;

end;</source>
        <Parameter name="_pxyOOWC" type="CM_OOWCreation" usage="input"/>
        <Parameter name="_srcOOWC" type="CM_OOWCreation" usage="input"/>
        <Parameter name="_attribute" type="String"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateVoyageOperator" id="3c29fa47-91dc-4414-9e04-55edaf00f6a6">
        <updating/>
        <source>utlCreateVoyageOperator(_pxyVoyageOperator : CM_VoyageOperator; _realVoyageOperator : CM_VoyageOperator output; _passport : CM_Passport input) updating;
//--------------------------------------------------------------
//Created: July 2002 By: cnwgd1
//--------------------------------------------------------------
vars
	cancelSave 	: Boolean;
	realVessel 	: CM_Vessel;
	pxyVoy,
	realVoy 	: CM_Voyage;

begin

	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	
	app.myValCA.valVoyageOperator(_pxyVoyageOperator, _passport);

	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;

	app.setContinueCMExceptions(false);
	
	create _realVoyageOperator persistent;
	_realVoyageOperator.setForCreate(_pxyVoyageOperator);
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(_realVoyageOperator);
		//log voyage ops is multi terminal therefore we need to send this extra note
		//global.causeEvent(LogVoyageOps_Create_Event, false, _realVoyageOperator);
		global.causeEvent(_realVoyageOperator.myVoyage.myTerminal.getTerminalEvent(VoyageOperator_Create_Event), false, _realVoyageOperator);	
	endif;
end;</source>
        <Parameter name="_pxyVoyageOperator" type="CM_VoyageOperator"/>
        <Parameter name="_realVoyageOperator" type="CM_VoyageOperator" usage="output"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateVoyagePlanningCode" id="e6cd3618-f061-4bc8-b789-4fca26630600">
        <source>utlCreateVoyagePlanningCode(pProxyVoyagePlanCodeObj:CM_VoyagePlanningCode;
							pNewVoyagePlanCodeObj:CM_VoyagePlanningCode output;
							pPassport : CM_Passport input);
// --------------------------------------------------------------------------------
// Created:		11 March 2005 by cnwdad1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	app.myValCA.valVoyagePlanningCode(pProxyVoyagePlanCodeObj);

	if not self.checkValidationWithPassport(pPassport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	create pNewVoyagePlanCodeObj persistent;
	pNewVoyagePlanCodeObj.setForCreate(pProxyVoyagePlanCodeObj);
	
	if pPassport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(pNewVoyagePlanCodeObj);
	endif;
end;</source>
        <Parameter name="pProxyVoyagePlanCodeObj" type="CM_VoyagePlanningCode"/>
        <Parameter name="pNewVoyagePlanCodeObj" type="CM_VoyagePlanningCode" usage="output"/>
        <Parameter name="pPassport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlCreateVoyageProcess" id="b2bec6b5-dabc-4af1-88b8-e1a58034b65d">
