    <JadeMethod name="initFromUserWindow" id="d58e2c90-087e-4f94-9ad3-b8be0602339e">
        <updating/>
        <source>initFromUserWindow(_userWindow: CM_UserWindow) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------
// 10/12/2014	cnwdap1		Initial creation PAR #35397 CCMS SFW 1394
// 16/04/2019   cnwma1		Bug 44075: JMT - Voyage Operations - Selector - Voyage Types - Shouldn't refresh until Select button selected
// 08/12/2022	navkc1		ChangeRequest 55409: MTN - Voyage Ops Form - Pagination of tables
vars
	tmpTypeStr	: String;
	test : Boolean;
	str : String;
	count : Integer;
	layout : Integer;
begin
	if _userWindow = null then
		return;
	endif;
	
	tmpTypeStr := _userWindow.xmlInfo.cnEcGetTagValueOfName( 'listTablelstCargoTypes' );
	/* example
	&lt;selectedValue&gt;1&lt;/selectedValue&gt;
&lt;selectedValue&gt;6&lt;/selectedValue&gt;
&lt;selectedValue&gt;9&lt;/selectedValue&gt;
&lt;selectedValue&gt;10001&lt;/selectedValue&gt;
*/
	test := true;
	count := 1;
	while test do
		str := null;
		str := tmpTypeStr.cnEcGetNextTagValueOfName('selectedValue', count);
		if str = null then
			test := false;
		else
			self.filterCargoTypes.add(str);
		endif;		
		count := count +1;		
	endwhile;

	inheritMethod(_userWindow);

	self.xmlColourPlanned := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_TagColourPlanned).Integer;
	self.xmlColourNonPlanned := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_TagColourNonPlanned).Integer;
	self.xmlColourOnShip := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_TagColourOnShip).Integer;
	
	self.chkRemember.value := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_TagRememberSettings).Boolean;
	if self.chkRemember.value then
		self.chkLOLOBays.value := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_TagVoyageLOLO).Boolean;
		self.chkRORODecks.value := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_TagVoyageRORO).Boolean;
		self.chkHolds.value := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_TagVoyageHold).Boolean;
		self.chkBlockStack.value := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_TagVoyageBlockStack).Boolean;
		
		self.chkShowOffsite.value := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_TagShowOffSite).Boolean;
		self.chkPreNote.value := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_TagShowPrenotes).Boolean;
		self.chkConfirmAllMoves.value := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_TagConfirmAllMoves).Boolean;		// 28/6/17 MAP TFS4719
		
		self.chkDirDel.value := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_TagIncludeDD).Boolean;
		self.chkColourCells.value := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_TagColourTableCells).Boolean;
		self.chkCurrentVoyages.value := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_TagVoyageCurrent).Boolean; // TFS 50012
		
	endif;
	
	self.chkTableCount.value := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.chkTableCount.name).Boolean;
	self.chkAllowFilter.value := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.chkAllowFilter.name).Boolean;
	self.chkAllowMore20.value := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.chkAllowMore20.name).Boolean;
	self.chkNumOfRowPerTable.value := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.chkNumOfRowPerTable.name).Boolean;	// 08/12/2022	navkc1	#55409
	self.txtNumOfRow.text := _userWindow.xmlInfo.cnEcGetTagValueOfName(self.txtNumOfRow.name).String; 					// 08/12/2022	navkc1	#55409
	
	self.doFirstRunAfterUpgrade(_userWindow);  // navkc1	22/08/2025	JIRA MTN 35788
	
	// Update these so we have correct settings // navkc1	20/08/2025	JIRA MTN 35788
	self.performTableCount := self.chkTableCount.value;
	self.performAllowFilter := self.chkAllowFilter.value;
	self.performAllowMore20 := self.chkAllowMore20.value;
	
	layout := _userWindow.xmlInfo.cnEcGetTagValueOfName(XML_TagLayout).Integer;
	if layout = 1 then
		self.btnNormal_click(self.btnNormal);
		self.btnNormal.value := true;
	elseif layout = 2 then
		self.btnVertical_click(self.btnVertical);
		self.btnVertical.value := true;
	elseif layout = 3 then
		self.btnHorizontal_click(self.btnHorizontal);
		self.btnHorizontal.value := true;
	endif;
	
epilog
	
end;</source>
        <Parameter name="_userWindow" type="CM_UserWindow"/>
    </JadeMethod>
    <JadeMethod name="initTable" id="04e91a9c-6086-4ecc-b97f-532056fd8420">
        <updating/>
        <source>initTable(_table : CM_DataTable input)updating;
//--------------------------------------------------
// Created:	17 October 2003 By: cnwgd1
// 02 March 2018	jlgrh7		TFS 36564 AAT - Missing Stevedore field from Column Organiser in Voyage Operations
//--------------------------------------------------
vars

	bottomOffSet : Integer;

begin
	if _table = null then
		return;
	endif;
	
	//14 Jan 2014	NDL
	if _table.isKindOf(CM_FilterTable) then
		bottomOffSet := 31;		// This is to allow space for the status bar under each table.
		_table.height := _table.parent.height - _table.top - bottomOffSet;
		_table.CM_FilterTable.columnFilterSetup( true );	
		_table.parentBottomOffset := bottomOffSet;
	else
		_table.stretchHeight	:= true;
		_table.stretchWidth		:= true;
		_table.setDistanceFromBottom(31);
	endif;
	
	self.setTableHeadings(_table);
	
	_table.userInputEnabled := false;
	_table.multiSelect := CM_DataTable.MultiSelect_Simple;
	_table.selectMode := Table.SelectMode_CurrentRow;
	_table.selectionType := CM_DataTable.SelectionType_Row;
	self.setColorsForTable(_table);
	//+TFS36564 begins for 4 tables on the form so it needs 4 collections for ent tables
	self.allTblDataTransientRows.copy(_table.allTblDataEntRows);
	if _table = self.tblOffsite then
		self.allOffSiteTblDataTransRows.copy(_table.allTblDataEntRows);
	endif;
	if _table = self.tblOnsite then
		self.allOnSiteTblDataTransRows.copy(_table.allTblDataEntRows);
	endif;
	if _table = self.tblOnship then
		self.allOnShipTblDataTransRows.copy(_table.allTblDataEntRows);
	endif;
	if _table = self.tblPreNote then
		self.allPreNoteTblDataTransRows.copy(_table.allTblDataEntRows);
	endif;
	_table.toSetColumnsFromDefault(self.allTblDataTransientRows);
	_table.setTblDataEntRowsArray(_table.myEntTableDef, self.allTblDataTransientRows, null);	
	//+TFS36564 ends
end;</source>
        <Parameter name="_table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
