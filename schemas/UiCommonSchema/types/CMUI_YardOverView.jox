    <JadeMethod name="unload" id="7d26c529-047d-400f-8b85-edfd5e33e9c1">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;
// ---------------------------------------------------------------------------
// Created:		May 2003 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	theReturn : Integer;
begin
	if self.mySDF.myDrawingFrame.CMUI_PointDrawingFrame.dataChanged then
		theReturn := app.msgBox("You have changed the yard positions, do you want to save the changes?", "Save Changes",MsgBox_Yes_No + MsgBox_Question_Mark_Icon);
		if theReturn = MsgBox_Return_Yes then
			self.doSave(false);
		endif;		
	endif;
	inheritMethod();
	
end;</source>
    </JadeMethod>
</GUIClass>
