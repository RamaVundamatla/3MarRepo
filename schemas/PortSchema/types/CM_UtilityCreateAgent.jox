/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 August 2012	cnwndl1	Initial creation	Par 29968
17 August 2022	navpw1	TFS: 54564 (54374) - EUP - Inv Config - DB Changes
1st May 2023	navra1 TFS 57086 - EUP - Customer Update - New Fields incl Debtor Details incl Financial ID

*/

vars

begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(true);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	//_dr.createDebtorTerminal( _term, _isCashOnly, _paymentType);
	//_dr.createDebtorTerminal( _term, _isCashOnly, _paymentType, _currencyType, _locale, _defaultInvoiceJRW); // ### TFS 54564 (54374) 17Aug2022 NAVPW1
	_dr.createDebtorTerminal( _term, _isCashOnly, _paymentType, _currencyType, _locale, _defaultInvoiceJRW, _orgCode, _interTerminalCode); // navra1 - TFS 57086 - 23Apr 2023
	

epilog

end;</source>
