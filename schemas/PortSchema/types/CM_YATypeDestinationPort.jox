    <JadeMethod name="getObjects" id="2aa4726e-2826-4669-82c5-8cc822de99a9">
        <source>getObjects(objects: ObjectLongNameDict input);
//05 August 2008	cnwdw1	
// Return a dict of objects for this criteria type
vars
	port: CM_Port;
begin
	foreach port in app.myRoot.allActiveDestinations do //epr 7/4/16 the getAllCriteriaValues only includes allActiveDestinations this needs to do the same
		objects[port.getYAIdentifier] := port;
	endforeach;
	/* 23057 11/03/2010 cnwjre1 following 21778 fix in getAllCriteriaValues, getObjects really needs to 
		do the same, either root.allActivePorts or the code below.  However the context is lost at this point -
		it really needs something like the CM_YardAllocation of clineCriteria passed on through the criteria
		processing to here, so you can tell this is rail-related (CM_RailAllocation) or not.  This means 
		changing to many methods to be safe at this particular time.
		Note: CM_YACarrier has the same issue.
	*/
	foreach port in app.myRoot.allPorts where port.isActive and port.bIsRail do
		if objects[port.getYAIdentifier] = null then
			objects[port.getYAIdentifier] := port;
		endif;
	endforeach;
end;</source>
        <Parameter name="objects" type="ObjectLongNameDict" usage="input"/>
    </JadeMethod>
