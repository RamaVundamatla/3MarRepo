    <JadeMethod name="setupForm" id="2c702ab9-b60f-4132-a467-5600104ed6a1">
        <updating/>
        <source>setupForm() updating;
/*
Purpose - 	
Who - NAVAB1
Date - 15AUG2023
ADO - CR 59615 TASK 59620 	
//20.07.2024 navrv30 Bug 64858: MTN - Ownership Change Maint - Select All issues
*/

vars
	cargoType 		: CM_CargoType;
	ti : CM_TrackedItem;
begin
	inheritMethod();
	
	self.setTotalValues(); 
	self.doMeasurementVolume();
	self.doMeasurementWeight();
	
	self.initTblData(ETDef_CustDocDetailMaint);
	//25/06/2024	navkc1 CR 64823 Task 64824
	//self.btnClear.enabled	:= false;
	//self.txtFilterTblData.enabled	:= false;
	
	self.displayCustDocDetail();

	ti := self.myCustDocDetail.myTrackedItem;
	if ti.isCargoGroupItem then
	
	else
		self.chkHide.value := true;
		self.chkHide.visible := false;
		self.showHideDetail();
	endif;
	self.chkIncludeDetail.value := self.myProxyDetail.included;
	
	if not app.myCurrentUserCan(self.myTerminal, self.permissionMaint) then
		self.tblData.userInputEnabled := false;
		self.btnCargoUpdate.enabled := false;
		self.btnSave.enabled := false;
		self.chkIncludeDetail.enabled := false;
		self.chkSelectAll.enabled := false;
		self.txtClearedCargoQuantity.enabled := false;
		self.txtClearedCargoVolume.enabled := false;
		self.txtClearedCargoWeight.enabled := false;
		self.txtClearedQuantity.enabled := false;
		self.txtClearedVolume.enabled := false;
		self.txtClearedWeight.enabled := false;
		
	endif;
	
	self.frmTableFilter.setupControl(self.tblData, null); //05/06/2024	navkc1 CR 63736 Task 63770
	self.doSetSelectAll();			//20.07.2024 navrv30 Bug 64858
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="showHideDetail" id="05320826-507d-4d3f-a06f-4e81b7683c16">
        <updating/>
        <source>showHideDetail() updating;
/*
Purpose - 	
Who - NAVAB1
Date - 15AUG2023
ADO - CR 59615 TASK 59620 	
*/

vars

begin
	if self.chkHide.value then
		self.grpDetails.visible := false;
		self.minimumHeight := (self.grpDetails.top + 90).Integer;
		self.height := self.minimumHeight;
		
	else
		self.grpDetails.visible := true;
		self.minimumHeight := 585;
	endif;
epilog

end;</source>
    </JadeMethod>
