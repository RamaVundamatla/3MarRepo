    <JadeMethod name="checkForNewDeveloper" id="6413612f-9be5-4a21-bb3b-af801cafb090">
        <updating/>
        <source>checkForNewDeveloper() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date			Who		Reason
11 October 2012	cnwmc5	Initial creation.
03 June 2025	navpw1	JIRA: MTN-35018 - Fixed 1310 exception by not changing the username when searching for the user

*/

vars

	root 				: UM_Root;
	userEmail			: UM_UserEmailAddress;
	testController		: JMTTestController;

	klass				: Class;
	meth				: Method;
	
	classes				: ClassColl;
	methodsDict			: MethodNDict;
	
	tokens				: StringArray512;
	ownerArray			: StringArray;
	
	altUser				: String;
	userName			: String;
	methodSource		: String;
	line				: String;
	token				: String;
	linePos 			: Integer;
	found				: Boolean;
	isAdmin				: Boolean;
	cnwPos				: Integer;
	
begin
	root := UM_Root.firstInstance();
	if root = null then
		return;
	endif;
	
	create tokens transient;
	create ownerArray transient;
	
	// get UT_DSL class
	klass := currentSchema.getClass("UT_DSL");
	if klass = null then
		return;
	endif;
	
	// create classes
	create classes transient;
	classes.add(klass);
	klass.allLocalSubclasses(classes);
	
	foreach klass in classes do
	
		methodsDict := klass.cnGetMethods();
		
		foreach meth in methodsDict where meth.isRunnableUnitTestMethod() do
		
		//foreach meth in methodsDict where meth.name = "tCoparn_ReleaseUpdates" do
		
			found := false;
			linePos := 1;
			meth.getSource.cnEcGetNextLine(linePos);
			while linePos &gt; 0 do
				line :=  meth.getSource.cnEcGetNextLine(linePos);
				if (line[1:9] = 'constants' and line.trimBlanks().length = 9) or 		
						(line[1:4] = "vars" and line.trimBlanks().length = 4) then
					break;
				endif;
				line.replaceChar(Tab, ' ');
				tokens.clear;
				line.getTokensForDelimiter(" ", tokens);
				// 04/07/2017 cnwmh5 - new jlg code
				if self.populateOwnerArray("CNW", tokens, ownerArray) or 
						self.populateOwnerArray("JLG", tokens, ownerArray) then
					break;
				endif;
				/*
				foreach token in tokens do
					if token.toUpper().cnContains("CNW") then
						cnwPos := token.toUpper.pos("CNW", 1);
						if cnwPos = 0 then
							continue;
						endif;
						userName := token[cnwPos:end];
						if not ownerArray.includes(userName.toUpper) then
							ownerArray.add(userName.toUpper);
							linePos := -1;
							break;
						endif;
						if token.toUpper().cnContains("CNW") then
							linePos := -1;
							break;
						endif;
					endif;
				endforeach;
				*/
			endwhile;
			
		endforeach;
		
	endforeach;
	
	//NEED TO GET JMTTestController - getEmailToUser method to get the alt emails....
	if not app.isRunningOnNavisServer() then
		beginTransaction;
			foreach	userName in ownerArray do
				//userEmail := root.allUserEmailAddresses[app.returnCorrectUserName(userName.toUpper, true)];
				userEmail := root.allUserEmailAddresses[userName.toUpper];	// ### JIRA: MTN-35018 03Jun2025 NAVPW1
				if userEmail &lt;&gt; null then
					continue;
				endif;
				create userEmail persistent;
				userEmail.setNewUserDetails(userName.toUpper, null, null, null, null, null, null, null, null);
			endforeach;
		commitTransaction;
	endif;
	
epilog

	delete classes;
	delete tokens;
	delete ownerArray;
	delete testController;

end;</source>
    </JadeMethod>
    <JadeMethod name="checkForProcessDebugInCode" id="41696330-e0ce-469b-a4ee-9bbad9f388f7">
        <source>checkForProcessDebugInCode() protected;

/*

Purpose:			writes a list of methods with process.debug in the code

Parameters:			

Return Value:		


Date			Who		Reason
27 April 2011	cnwmh5	Initial creation

*/

vars

	meth					: Method;
	type					: Type;
		
	meths					: MethodSet;

	foundInPortSchemaLevel	: Boolean;
	found					: Boolean;
	str						: String;
	
begin
	
	app.writeLog("Checking for process.debug in code", LogINFO);
	
	meth := rootSchema.getClass("Process").getMethod("debug");
	
	create meths transient;	
	meth.getMethodRefs(meths);
		
	foreach meth in meths do
	
		foundInPortSchemaLevel := false;

		type := meth.getSchemaType();
				
		if meth.getSchema() &lt;&gt; null and meth.getSchema().getName() = PortSchema.name then
			if type.getName() &lt;&gt; Process.name and type.getName() &lt;&gt; JadeScript.name and
					not meth.name.cnContains("ebug") then
				foundInPortSchemaLevel := true;
			endif;
		endif;
		
		if foundInPortSchemaLevel then
			if type &lt;&gt; null then
				str := meth.name &amp; Tab &amp; meth.getSchema().getName() &amp; Tab &amp; type.getName();
			else
				str := meth.name &amp; Tab &amp; meth.getSchema().getName();
			endif;
			app.writeLog(str, LogINFO);
			found := true;
		endif;
		
	endforeach;

	if not found then
		app.writeLog("No process.debug found in code", LogINFO);
	endif;	
	
	app.writeLog("Finished checking for process.debug in code", LogINFO);
	
epilog

	delete meths;
	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="create" id="d6dfa3fc-046a-4752-a2d5-39948b3ab5a2">
