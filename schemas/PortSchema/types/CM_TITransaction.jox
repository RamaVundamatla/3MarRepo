    <JadeMethod name="getStartDateTime" id="7f1371f8-3d61-4a15-8c54-c88c28aa6cb7">
        <source>getStartDateTime(_calcType : Integer) : TimeStamp;
// parameter added for par 26109 ccms 2020 invoice storage by first/last cargo date
// 23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
vars
	voyage	: CM_Voyage;
	startTime	: TimeStamp;
begin
	startTime := self.dateTime;
	if _calcType = INV_CALC_TYPE_DAYSINCE_SHIP_ST then
		// if the export item is still on-site don't get the voyage date, use the transaction date instead
		if self.myTrackedItem &lt;&gt; null and
		   self.myTrackedItem.isExport and
		   self.myTrackedItem.site = TI_SITE_ONSITE then
			// do nothing
		else
			voyage := self.getVoyage();
			if voyage &lt;&gt; null then
				startTime := voyage.shipExchangeDate;
				if startTime = null then		// old voyage
					startTime := self.dateTime;
				endif;
			endif;
		endif;
	endif;
	
	app.invLog(method.qualifiedName &amp; " _calcType=" &amp; _calcType.String &amp; " returning " &amp; startTime.String, LogINFO.String);
	return startTime;
end;</source>
        <Parameter name="_calcType" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getStartDateTimeFSD" id="c249a9f9-751a-4d98-8025-0b6a40a80aeb">
        <source>getStartDateTimeFSD(_calcType : Integer; _storageConfig : CM_StorageConfig) : TimeStamp;
// Oct 2012 storageConfig added to use the storage config includeFirstDay option
// explicit calculation type processing takes precedence over config options
// PAR 31615 - re wrote , based on 811 version and extended to not use storage config.
// 29/08/2022	jlika1	TFS 54420 - PRP - Enstructure - Financial Requirements
// 23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
vars
	voyage	: CM_Voyage;
	startTime	: TimeStamp;
begin
	startTime := self.dateTime;

	if _calcType = INV_CALC_TYPE_DAYSINCE_SHIP_ST then
		// if the export item is still on-site don't get the voyage date, use the transaction date instead
		if self.myTrackedItem &lt;&gt; null and
		   self.myTrackedItem.isExport and
		   self.myTrackedItem.site = TI_SITE_ONSITE then
			// do nothing
		else
			voyage := self.getVoyage();
			if voyage &lt;&gt; null then
				startTime := voyage.shipExchangeDate;
				if startTime = null then		// old voyage
					startTime := self.dateTime;
				endif;
			endif;
		endif;
	elseif _calcType = INV_CALC_TYPE_DAYSINCE_VOY_IN then
		// if the export item is still on-site don't get the voyage date, use the transaction date instead
		if self.myTrackedItem &lt;&gt; null and
		   self.myTrackedItem.isExport and
		   self.myTrackedItem.site = TI_SITE_ONSITE then
			// do nothing
		else
			voyage := self.getVoyage();
			if voyage &lt;&gt; null then
				startTime := voyage.arrivedDT;
				if startTime = null then		// old voyage
					startTime := self.dateTime;
				endif;
			endif;
		endif;
	elseif _calcType = INV_CALC_TYPE_DAYS_SINCE_RECVL 
	or  _calcType = INV_CALC_TYPE_DAYSINCE_SUBTERM	//29 Jun 2018	NDL	TFS 39338
	or  _calcType = INV_CALC_TYPE_DAYSINCE_REC_TEU
	or 	_calcType = INV_CALC_TYPE_DAYSINCE_REC_RT	//08 May 2018	NDL	TFS 38525
	or  _calcType = INV_CALC_TYPE_DAYS_WEIGHT
	or  _calcType = INV_CALC_TYPE_DAYS_VOLUME 
	or  _calcType = INV_CALC_TYPE_BOARDFEET_DAYS then
		if self.myTrackedItem &lt;&gt; null then
			startTime := self.myTrackedItem.receivedDT;
			if not startTime.isValid() then
				startTime := self.myTrackedItem.createdTime;
			endif;
		
			if not startTime.isValid() then
				startTime := self.dateTime;
			endif;
		else
			startTime := self.dateTime;
		endif;
	endif;
	
	app.invLog(method.qualifiedName &amp; " _calcType=" &amp; _calcType.String &amp; " self.dateTime=" &amp; self.dateTime.String &amp; " startTime=" &amp; startTime.String, LogINFO.String);
	return startTime;

end;</source>
        <Parameter name="_calcType" type="Integer"/>
        <Parameter name="_storageConfig" type="CM_StorageConfig"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
    <JadeMethod name="getStartDateTimeLocalTZ" id="6a264d37-0f04-4d8c-b27d-8d1405a3b3a8">
        <source>getStartDateTimeLocalTZ(_calcType : Integer) : TimeStamp;
// parameter added for par 26109 ccms 2020 invoice storage by first/last cargo date
// 03 June 2016	cnwns1	TFS 488 - Multi Timezone Support
// 23 Oct 2024	navlw1	JIRA-33107: Invoice Logging Use Levels
vars
	voyage	: CM_Voyage;
	startTime	: TimeStamp;
begin
	startTime := self.dateTime;
	if _calcType = INV_CALC_TYPE_DAYSINCE_SHIP_ST then
		// if the export item is still on-site don't get the voyage date, use the transaction date instead
		if self.myTrackedItem &lt;&gt; null and
		   self.myTrackedItem.isExport and
		   self.myTrackedItem.site = TI_SITE_ONSITE then
			// do nothing
		else
			voyage := self.getVoyage();
			if voyage &lt;&gt; null then
				startTime := voyage.shipExchangeDate;
				if startTime = null then		// old voyage
					startTime := self.dateTime;
				endif;
			endif;
		endif;
	endif;
	
	app.invLog(method.qualifiedName &amp; " _calcType=" &amp; _calcType.String &amp; " returning " &amp; startTime.String, LogINFO.String);
	return self.systemToLocalTime(startTime);
end;</source>
        <Parameter name="_calcType" type="Integer"/>
        <ReturnType type="TimeStamp"/>
    </JadeMethod>
