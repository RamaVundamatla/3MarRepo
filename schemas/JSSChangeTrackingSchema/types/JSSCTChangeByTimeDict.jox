    <JadeMethod name="addClassObject" id="81f34d4a-a9c7-494c-9d97-b3f2b5957bc6">
        <lockReceiver/>
        <updating/>
        <source>addClassObject(pClassObject: JSSCTChangeTrackingObject) lockReceiver, updating;
/*
		Add the object to this collection AND the collection by oid
*/
begin
//	on Exception do handleException(exception, pClassObject);

	self.add(pClassObject);
//	if not self.isDelete then
	if not self.allChangesByOidDict.includes(pClassObject) then
		self.allChangesByOidDict.add(pClassObject);
	endif;
end;</source>
        <Parameter name="pClassObject" type="JSSCTChangeTrackingObject"/>
    </JadeMethod>
    <JadeMethod name="delete" id="89cc9f5a-9101-4d11-8938-e929a96236a1">
        <lockReceiver/>
        <updating/>
        <source>delete() updating, protected, lockReceiver;
/*
*/
begin
	self.purge;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="findClassObject" id="2924e23b-ba98-4645-ab2d-d20babcf9e4f">
        <source>findClassObject(pObjectID: String): JSSCTChangeTrackingObject;
/*
*/
begin
	return (self.allChangesByOidDict[pObjectID]);
end;</source>
        <Parameter name="pObjectID" type="String"/>
        <ReturnType type="JSSCTChangeTrackingObject"/>
    </JadeMethod>
    <JadeMethod name="handleException" id="66cffec5-13fd-4ec0-9f1f-0b4e0bad1cd4">
        <source>handleException(pException: Exception; pClassObject: JSSCTChangeTrackingObject): Integer;

vars
	classObject: JSSCTChangeTrackingObject;
begin
	if self.isDelete then
		write "Delete Dict [" &amp; self.String &amp; "]";
	else
		write "Change Dict [" &amp; self.String &amp; "]";
	endif;
	write "Class " &amp; self.className &amp; " [" &amp; pClassObject.String &amp; "]";
	write "Oid " &amp; pClassObject.changeObjectID;
	write "Action " &amp; pClassObject.changeAction.String;
	write "TimeStamp " &amp; pClassObject.changeTimestamp.String;
	write "TransID " &amp; pClassObject.changeTransactionID.String;
	write "Sequence " &amp; pClassObject.changeSequence.String;

	classObject := self.allChangesByOidDict[pClassObject.changeObjectID];
	if classObject &lt;&gt; null then
		write " Oid " &amp; classObject.changeObjectID;
		write " Action " &amp; classObject.changeAction.String;
		write " TimeStamp " &amp; classObject.changeTimestamp.String;
		write " TransID " &amp; classObject.changeTransactionID.String;
		write " Sequence " &amp; classObject.changeSequence.String;
	endif;
	return(Ex_Pass_Back);
end;</source>
        <Parameter name="pException" type="Exception"/>
        <Parameter name="pClassObject" type="JSSCTChangeTrackingObject"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="removeClassObject" id="6f182c5a-af50-42fd-9c3d-1041a584190a">
        <lockReceiver/>
        <updating/>
        <source>removeClassObject(pClassObject: JSSCTChangeTrackingObject) lockReceiver, updating;
/*
		Remove the object from this collection AND the collection by oid
*/
begin

//	if pClassObject.String = 'JSSCTChangeTrackingObject/5350.4069123' then
//		pClassObject.writeLogProcessStack();
//	endif;
	if self.includes(pClassObject) then
		self.remove(pClassObject);
	endif;
//	if not self.isDelete then
	if self.allChangesByOidDict.includes(pClassObject) then
		self.allChangesByOidDict.remove(pClassObject);
	endif;
//	endif;
end;</source>
        <Parameter name="pClassObject" type="JSSCTChangeTrackingObject"/>
    </JadeMethod>
