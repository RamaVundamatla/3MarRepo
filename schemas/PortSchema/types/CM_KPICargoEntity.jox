    <JadeMethod name="getTEUGC" id="6d5eeefb-f3ff-4a72-a87d-c190676291ac">
        <source>getTEUGC() : Decimal;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 December 2025	navhn30	 MTN-36753: MTN | KPI REST API - Cargo

*/

vars
	ct : CM_CargoType;
	teu : Decimal[8,2];
begin
	ct:=self.myCargoType;
	if ct.isContainer then
		return null;
	endif;
	teu := ct.getTEUConversionValue(TEUConversionIndexGC);
	if ct.teuMultiplier = TEUMultiplierIndexQ then
		return teu * self.totalQty;
	elseif ct.teuMultiplier =  TEUMultiplierIndexW then
		return teu * self.totalWeight;
	endif;
	
	return teu;
epilog

end;</source>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="setKeys" id="0f2fe21f-6934-4b8c-84cf-12519be1c0a7">
        <updating/>
        <source>setKeys(_terminal : CM_Terminal; _cargoType : CM_CargoType; _date : Date) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08/09/2010	cnwdap1	Initial creation PAR #25173 CCMS SFW 1108
*/
vars

begin
	self.myTerminal		:= _terminal;
	self.myCargoType	:= _cargoType;
	self.dateTime.setDate(_date);
epilog

end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
        <Parameter name="_cargoType" type="CM_CargoType"/>
        <Parameter name="_date" type="Date"/>
    </JadeMethod>
</Class>
