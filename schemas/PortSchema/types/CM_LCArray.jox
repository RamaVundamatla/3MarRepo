<CollClass name="CM_LCArray" id="f42bfa41-039d-45ba-a179-90bbefc91b95">
    <memberType name="CM_LocationsController"/>
    <superclass name="CM_ObjectArray"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="location"/>
    <JadeMethod name="auditIdDisplay" id="0dd47d6c-2e24-4fdd-9ffc-001accf5a9ba">
        <source>auditIdDisplay(): String;
// ---------------------------------------------------------------------------
// Created:     June 2007 by cnwvu1
//
// Purpose:     
// ---------------------------------------------------------------------------

vars
	locationC	: CM_LocationsController;
	rtnStr		: String;
	
begin
	
	foreach locationC in self do
		if rtnStr = null then
			rtnStr := locationC.auditId();
		else
			rtnStr := rtnStr &amp; ', ' &amp; locationC.auditId();
		endif;
	endforeach;

	return rtnStr;
	
end;
</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="includesTerminalArea" id="5c643a2e-8263-4433-9383-511cad52ae3d">
        <source>includesTerminalArea(_ta : CM_TerminalArea) : Boolean;

// Created by cnwdvb1 on 10 October 2007

vars

	lc	: CM_LocationsController;

begin

	foreach lc in self do
		if lc.myTerminalArea = _ta then
			return true;
		endif;
	endforeach;
	
	return false;

end;</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="includesVoyageROROController" id="e5dce5a4-6b5e-45ba-9da5-808ca5e214f2">
        <source>includesVoyageROROController() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 August 2014	cnwmc5	Initial creation	PAR 34361

*/

vars
	lc	: CM_LocationsController;

begin

	foreach lc in self do
		if lc.isVoyageROROController() then
			return true;
		endif;
	endforeach;
	
	return false;

epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="sortLCsInToSeqOrder" id="cf0c5d78-a980-4a39-9c16-cd79b3c99581">
        <lockReceiver/>
        <updating/>
        <source>sortLCsInToSeqOrder() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 May 2012	cnwer1	Initial creation CCMS MES 1035

*/

vars
	theSC : CM_VoyageController;
	theSReq : CM_Request;
	anLC : CM_LocationsController;
	aWLE : CM_WorkListEntry;
	wleSorter :	CM_VoyageWLEDynaDict;
	iter : Iterator;
begin
	if self.isEmpty then
		return;
	endif;
	
	anLC := self.first;
	if not anLC.isKindOf(CM_VoyageController) then
		return;
	endif;

	theSC := self.first.CM_VoyageController;
	
	theSReq := theSC.getRequest(true);
	if theSReq = null
	or theSReq.myJob = null then
		return;
	endif;
	// PAR 28365 - No need to sort GC WLEs. RORO GC Request may have many WLEs all for the same LC.
	if theSReq.allWorkListEntries.size &gt; 1 then
		return;
	endif;
		
	create  wleSorter transient;	
	wleSorter.init(theSC.myVoyage,theSReq.myJob.CM_VoyageJob);
	
	foreach anLC in self do
		theSC := anLC.CM_VoyageController;
		theSReq := theSC.getColourCoding(true);
		if theSReq &lt;&gt; null then
			//theSReq.allWorkListEntries.copy(wleSorter);
			//25 June 2012	NDL	Par 29796
			foreach aWLE in theSReq.allWorkListEntries discreteLock do
				wleSorter.addNoDuplicates(aWLE,false);
			endforeach;
		endif;
	endforeach;

	self.clear;
	iter := wleSorter.createIterator();
	while iter.next(aWLE) do
		theSReq := aWLE.CM_VoyageWLE.myRequest;
		theSC := theSReq.getVoyageController().CM_VoyageController;

		if not self.includes(theSC) then
			self.add(theSC);
		endif;
	endwhile;
//app.cnwdad1_write(method.name);
epilog
	delete iter;
	delete wleSorter;
end;</source>
    </JadeMethod>
</CollClass>
