    <JadeMethod name="getCargoType" id="033a9ee5-b96c-4f7b-b808-55659010a6f5">
        <source>getCargoType() : CM_CargoType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 June 2018	jlger1	Initial creation

*/

vars
	cargoTypeObj : CM_CargoType;
begin
	cargoTypeObj:=app.myPassport.getObjectOfTypeFromOid(self.cargoType,CM_CargoType).CM_CargoType;
	if cargoTypeObj = null then
		cargoTypeObj := app.myRoot.allCargoTypesById[self.cargoType.Integer];
	endif;
	
	return cargoTypeObj;
epilog

end;</source>
        <ReturnType type="CM_CargoType"/>
    </JadeMethod>
