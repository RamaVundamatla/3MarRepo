	tmpStruct		: CnEcXmlStructureInstance;
	userId			: String;
	terminalCode	: String;
	xmlVersion		: String;
	fellingDate		: Date;
	fellDate		: String;
begin



//test xml from c3	xmlStr			:= XML_BolMntRq;
	/*

xmlStr			:= '&lt;msg&gt;&lt;hdr&gt;&lt;msgtype&gt;BolMntRq&lt;/msgtype&gt;
&lt;msgid&gt;10004&lt;/msgid&gt;&lt;deviceid&gt;XMLTestTool&lt;/deviceid&gt;
&lt;userid&gt;jason&lt;/userid&gt;&lt;pswd&gt;jackie7&lt;/pswd&gt;
