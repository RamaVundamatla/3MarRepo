//	self.colorRow2			:= tmpColorControl.getColorValue(self, tmpColorControl.rowColor2);
//	self.colorValueColumn	:= tmpColorControl.getColorValue(self, tmpColorControl.valueColumnColor);

	// setup modal display window
	infoColor := self.backColor;	//self.getSystemColor(Window.Color_InfoBk);
	
//	self.lblModalInfo.backColor		:= infoColor;
//	self.lblModalMessage.backColor	:= infoColor;
//	self.frmModalDialog.backColor	:= infoColor;
//	self.frmProgressCtr.backColor	:= infoColor;
	// ==========================
*/
end;</source>
    </JadeMethod>
    <JadeMethod name="setInitialLocation" id="d9d2a3a8-7c7b-4e02-9fb0-4706edd2765b">
        <updating/>
        <source>setInitialLocation(_initialLocation : CM_LocationsController; _showOnlyEmptyLocations : Boolean) updating;
// -------------------------------------------
// Created 07 November 2003 by cnwdvb1
// -------------------------------------------
vars

begin

	self.mySelectedLocation := _initialLocation;
	self.showOnlyEmptyLocations := _showOnlyEmptyLocations;
	self.loadTACombos();

end;</source>
        <Parameter name="_initialLocation" type="CM_LocationsController"/>
        <Parameter name="_showOnlyEmptyLocations" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setTargetLocation" id="0d4e145b-83e8-4953-97fe-77fc0b968a29">
        <updating/>
        <source>setTargetLocation()updating, protected;
//--------------------------------------------------
// Created:	25 August 2003 By: cnwgd1
//--------------------------------------------------
vars
	tmpStr : String;
begin

	if self.mySelectedLocation &lt;&gt; null then
		tmpStr := self.mySelectedLocation.getFullId();
	endif;
	self.tblMove.setValueByName(ETRow_NewLocn, tmpStr);
	self.selectedLocationString := tmpStr;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="windowCreated" id="1d820715-416b-4548-842c-dfa803478af4">
        <updating/>
        <source>windowCreated(cntrl: Control input; persistCntrl: Control) updating;
// -------------------------------------------
// Created 07 November 2003 by cnwdvb1
// -------------------------------------------
vars

begin
	
	inheritMethod(cntrl, persistCntrl);
	self.createMyControls();
	if not self.isInPainter then
		create self.myAssistant transient;
		self.loadTable();
		self.resetTerminal();
	endif;
end;</source>
        <Parameter name="cntrl" type="Control" usage="input"/>
        <Parameter name="persistCntrl" type="Control"/>
    </JadeMethod>
