    <JadeMethod name="isChilled" id="3bf155c2-ad79-4e9d-a151-6344335cb293">
        <methodInvocation>mapping</methodInvocation>
        <source>isChilled(set: Boolean; _value: Boolean io) mapping;
/*
Purpose:			CCMS 1007 Allow for reefer details on booking and CM_TrackedItem, not just CM_Container

Parameters:			

Return Value:		

Date		Who		Reason
25/11/2009	cnwdap1	Initial creation
*/
vars
	minTemp, maxTemp	: Real;
	terminal			: CM_Terminal;

begin
	/* 
	isChilled is tested against the configuration object. This is setup by sysops.
	This method is used by reports to define the tracked Item set for Chilled Reefer Report.
	STG 24/3/98 
	*/

	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;

	//epr par 32291 8/1/14
	if self.myParent = null then
		_value :=  false;
		return;
	endif;
	
	terminal	:= self.myParent.CM_TrackedItem.myTerminal;
	minTemp 	:= terminal.getConfig(MinChilledTemp).Real;
	maxTemp 	:= terminal.getConfig(MaxChilledTemp).Real;

	if temperature &gt;= minTemp and temperature &lt;= maxTemp then
		_value := true;
	else
		_value := false;
	endif;
	
epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isConnected" id="80779243-491c-4839-98df-ee380d34c84f">
        <methodInvocation>mapping</methodInvocation>
        <source>isConnected(set: Boolean; _value: Boolean io) mapping;
/*
Purpose:			CCMS 1007 Allow for reefer details on booking and CM_TrackedItem, not just CM_Container
					Virtual instance variable to indicate if the tracked item
                    is "connected".  For a porthole with an attached cou, the
                    porthole is connected if the cou is connected. For a porthole
										without a cou, the porthole is connected if it is connected to
                    a tower.  For any other tracked item, the item is connected if
                    it is onPower.
Parameters:			

Return Value:		

Date		Who		Reason
25/11/2009	cnwdap1	Initial creation
*/
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
		return;
	endif;
	
	//epr par 32291 8/1/14
	if self.myParent = null then
		_value :=  false;
		return;
	endif;
	
	if self.myParent.CM_TrackedItem.isPortHole() then
		// Check to see if the porthole has an attached cou...
		if self.cou = null then
			//No it hasn't. ChecK to see if it is connected to a tower...
			if self.tower &lt;&gt; null then
				_value := true;
			endif;
		else
			sharedLock(self.cou);
			// Check to see if the cou is connected...
			_value := self.cou.onPower;
			//PAR 2621 AA 27/6/01: Unlock the object afterwards...			
			unlock(self.cou);
		endif;
	else
		// Not a porthole, see if it is on-power...
		_value := self.onPower;
	endif;

epilog
	if self.cou &lt;&gt; null then
		unlock(self.cou);
	endif;
end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Boolean" usage="io"/>
    </JadeMethod>
    <JadeMethod name="isPlannedUDWithCOU" id="e3583371-b92a-4f81-89e2-dbd2f7259fd1">
        <source>isPlannedUDWithCOU() : Boolean;
/*
Purpose:			CCMS 1007 Allow for reefer details on booking and CM_TrackedItem, not just CM_Container

Parameters:			

Return Value:		

Date		Who		Reason
25/11/2009	cnwdap1	Initial creation
*/
vars
	tmpLC	: CM_LocationsController;

begin
	tmpLC := self.myParent.CM_TrackedItem.getPrimaryLocation(PLANNING_MODE);
	if tmpLC = null then
		return false;
	endif;
	//-------------
	//If not planned to a ship location, ignore.
	//-------------
	if not tmpLC.isKindOf(CM_SlotController) then
		return false;
	endif;
	
	if tmpLC.CM_SlotController.ordinalDeck = DeckUnderDeck then
		if self.hasCOU then
			//-------------
			//Attempting to load a TI with a COU to the underdeck area. A NO-NO!
			//-------------
			return true;
		endif;
	endif;
	
	return false;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="monitorConnection" id="48995083-b2ad-42f7-affb-52c230436ee2">
