    <JadeMethod name="doTableHandlePassword" id="a861f826-7ca8-4677-9082-fb68f2c524de">
        <updating/>
        <source>doTableHandlePassword( _table : CM_EntryTable input; _newRow: Integer; _newCol: Integer ):Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 August 2021	navndl1	Initial creation	TFS 51632

*/

vars

	rowIndex : Integer;
	encryptedPassword : String;
	isPasswordField : Boolean;
	updated : Boolean;
	config : CMIF_Config;
	configField : String;
	maxPwLength : Integer;  // The max length of the actual password, not the encrypted version

begin

	if not _table.userInputEnabled then
		return false;
	endif;
	
	rowIndex := _table.row;
	if _newRow &gt; 0 then
		rowIndex := _newRow;
	endif;
	
	config := self.myIntFaceConfig;
	if config &lt;&gt; null then
		if rowIndex = _table.getRowByName( ETRow_AutoOutwardPassword ) then
			maxPwLength := 64;  // previous form restriction for actual password
			configField := ETRow_AutoOutwardPassword;
			isPasswordField := true;
		endif;
	endif;
	
	if isPasswordField then
		encryptedPassword := self.myAssistant.showSetPassword( CM_TableViewForm.Mode_Update, null, config, configField, updated, maxPwLength );
		if updated then
			if configField = ETRow_AutoOutwardPassword then
				enteredPassword2 := encryptedPassword;
			endif;
			if encryptedPassword &lt;&gt; null then
				_table.setValueByName(configField, '******');
			else
				_table.setValueByName(configField, ' ');
			endif;
		endif;
		return true;
	else
		return false;
	endif;

epilog

end;</source>
        <Parameter name="_table" type="CM_EntryTable" usage="input"/>
        <Parameter name="_newRow" type="Integer"/>
        <Parameter name="_newCol" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
