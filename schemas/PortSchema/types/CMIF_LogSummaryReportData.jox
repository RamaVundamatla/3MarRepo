    <JadeMethod name="numberOfLoads" id="c5c9543b-fa02-4f28-b491-902b7818fd63">
        <methodInvocation>mapping</methodInvocation>
        <source>numberOfLoads(set: Boolean; _value: Integer io) mapping;
//----------------------------------------------------------------------
// Created by 	cnwsh3
// Date 		16 November 2010
//
// Implemented version: JMT 7.8.1
// Date  		User  		Change
// 16/11/2010				cnwsh3		CCMS1115 PAR26245
//----------------------------------------------------------------------
vars

begin
	if set then
		app.raiseSetVirtualError(self.class.name, method.qualifiedName);
	else
		_value := self.allBOLs.size;
	endif;


epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Integer" usage="io"/>
    </JadeMethod>
    <JadeMethod name="sedMean" id="77212a71-3e0e-490a-8fb3-b6eb8b0f9b17">
        <methodInvocation>mapping</methodInvocation>
        <source>sedMean(set: Boolean; _value: Decimal io) mapping;
/* ---------------------------------------------------------------------------
Created:     01 February 2010 by cnwrs2

Purpose:     	 CCMS 1108 par22177 

        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin
	if set then
		app.raiseSetVirtualError(class.name, method.name);
	else
		//_value := (self.sedMeanTotal / self.numberOfLogs).roundedTo(2);
		if self.myProduct &lt;&gt; null then
			_value := global.calcAverageSEDMean(self.myProduct.CM_ProductLog.logLength, self.totalVolume, self.numberOfLogs);
		else
			_value := 0;
		endif;
	endif;

epilog

end;</source>
        <Parameter name="set" type="Boolean"/>
        <Parameter name="_value" type="Decimal" usage="io"/>
    </JadeMethod>
    <JadeMethod name="setFromTI" id="32c7b69d-8ca2-449c-a073-350978cb1e60">
        <updating/>
        <source>setFromTI(_ti: CM_TrackedItem) updating;
//----------------------------------------------------------------
//	Created:	cnwdz2	 CCMS 1108 par22177 

//----------------------------------------------------------------
vars
	ti	: CM_Log;
	bolIn : CM_BOLIn;
	
begin
	ti := _ti.CM_Log;

	if ti = null then
		return;
	endif;
	
	self.allLogs.add(ti);
	
	self.numberOfLogs 	:= self.numberOfLogs + 1;
	self.totalVolume 	:= self.totalVolume + ti.getMyTotalVolume;
	self.totalWeightTonnes := self.totalWeightTonnes + ti.weightTonnes;
	self.sedMax := self.sedMax.max(ti.sedMax);
	self.sedMin := self.sedMin.min(ti.sedMin);
	
	self.sedMeanTotal := self.sedMeanTotal + ti.sedMean;
	
	bolIn := ti.myReceivalBOL;
	
	if bolIn &lt;&gt; null then
		if not self.allBOLs.includes(bolIn) then
			self.allBOLs.add(bolIn);
		endif;
	endif;
	
	//Store the oldest (ie. the lowest) fell date in the log collection.
	if ti.fellDate.isValid and ti.fellDate &lt; self.oldestFellDate then
		self.oldestFellDate := ti.fellDate;
	endif;
end;</source>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="setKeys" id="f38b7bf1-66b0-4abf-8d4c-a37f22efa69c">
        <updating/>
        <source>setKeys(_operator : CM_Operator; 
	    _consignor : CM_ConsigneeConsignor; 
		_logOrg : String;
		_sourceLocn	: String; 
		_product : CM_Product; 
		_sohLocation : CM_SOHLocation) updating;
/* ---------------------------------------------------------------------------
Created:     01 February 2010 by cnwrs2

Purpose:     	 CCMS 1108 par22177 
        
Change Date	Who		Reason

------------------------------------------------------------------------------*/
vars

begin
	self.forest				:= _sourceLocn;
	self.loggingOrganisation:= _logOrg;
	self.myConsignor		:= _consignor;
	self.myOperator			:= _operator;
	self.myProduct 			:= _product; // 16/11/2010 CCMS JML 1115 PAR26245 cnwsh3
	self.mySOHLocation		:= _sohLocation; // 16/11/2010 CCMS JML 1115 PAR26245 cnwsh3
	
	//While not a key, this would be a good time to initialise the oldest fell date for comparison with the logs we pass in.
	self.oldestFellDate := app.actualTimeServer.date; // 16/11/2010 CCMS JML 1115 PAR26245 cnwsh3
epilog

end;</source>
        <Parameter name="_operator" type="CM_Operator"/>
        <Parameter name="_consignor" type="CM_ConsigneeConsignor"/>
        <Parameter name="_logOrg" type="String"/>
        <Parameter name="_sourceLocn" type="String"/>
        <Parameter name="_product" type="CM_Product"/>
        <Parameter name="_sohLocation" type="CM_SOHLocation"/>
    </JadeMethod>
</Class>
