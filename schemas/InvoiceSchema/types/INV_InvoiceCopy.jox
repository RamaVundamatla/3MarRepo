        <source>doCmbDebtorBuild(_combo: CMUI_ComboBox input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Apr 2023 navtnr20	TFS CR 55303	Task 55531: UI - Invoice NEW UI Changes Invoice Copy

*/

vars
	realContractDebtor		: CM_Debtor;
	debtor : CM_Debtor;
	
begin
	
	inheritMethod(_combo);
