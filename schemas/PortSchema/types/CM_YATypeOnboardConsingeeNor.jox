    <JadeMethod name="getDisplay" id="c49290d5-cf27-4bb2-a4cd-b7afa44cd90a">
        <source>getDisplay(dataObj: Object): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
09 May 2024	jlier1	Initial creation 63834

*/

vars

begin
	return dataObj.CM_ConsigneeConsignor.code;

epilog

end;</source>
        <Parameter name="dataObj" type="Object"/>
