    <JadeMethod name="addTask" id="09354e4e-6b8f-49af-9667-a627641baa52">
        <source>addTask() protected;
// -----------------------------------------------------------------------------
// Created:		15 December 2001 by cnwdad1
//
// Purpose:		Show a form to enter details of a task to add to the schedule queue.
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	----------------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	taskFormObj	: CnEcTaskDetailsForm;
	
begin
	create taskFormObj;
	taskFormObj.setTask(null);
	
	taskFormObj.showModal();
end;</source>
        <access>protected</access>
    </JadeMethod>
