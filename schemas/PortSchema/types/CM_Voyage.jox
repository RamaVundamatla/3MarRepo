    <JadeMethod name="getTugDescUsedDeparture" id="6d45bf79-8b08-4868-8b6c-7d707693c398">
        <source>getTugDescUsedDeparture() : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/02/2012	cnwdap1	Initial creation PAR #29042 Rio Tinto Short Term Port Movement report
*/
vars
	movement	: HMS_VoyageMovement;
	tug			: HMS_Tug;
	
begin
	if self.myHMSVoyageData = null then
		return null;
	endif;

	movement := self.myHMSVoyageData.getMovementForMoveType(HMSMovementTypeDeparture);
	if movement = null then
		return null;
	endif;
	
	if movement.allTugsUsed.isEmpty then
		return null;
	endif;
	
	tug := movement.allTugsUsed.first;
	return tug.description;
	
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getTugDescUsedFirstBerth" id="df8de2de-38c9-4cdc-a1d6-f8c993d0108e">
        <source>getTugDescUsedFirstBerth() : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
03/02/2012	cnwdap1	Initial creation PAR #29043 For use in Rio Tinto's Short Term Port Movements report
*/
vars
	movement	: HMS_VoyageMovement;
	tug			: HMS_Tug;
	
begin
	if self.myHMSVoyageData = null then
		return null;
	endif;

	movement := self.myHMSVoyageData.getMovementFirstRealBerth;
	if movement = null then
		return null;
	endif;
	
	if movement.allTugsUsed.isEmpty then
		return null;
	endif;
	
	tug := movement.allTugsUsed.first;
	return tug.description;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getUnassignedVoyageJobs" id="93eb41ee-0dc2-49fa-ae29-0bf7f59f6d10">
        <source>getUnassignedVoyageJobs(jobArray : CM_JobArray input);
//--------------------------------------------------------------
//Created: 15 April 2003 By: cnwgd1
//--------------------------------------------------------------
vars
	job : CM_Job;
begin
	if jobArray = null then
		app.raiseUnexpectedProgramError(class.name, method.name, 'Null _jobSet passed to method. Contact Developer.');
		return;
	endif;
	
	foreach job in self.allVoyageJobs discreteLock do
		if job.isVoyageROROJob then
			continue;
		endif;
		if job.myJobSheet = null and job.CM_VoyageJob.isLoadedToOperations then
			jobArray.add(job);
		endif;
	endforeach;
	
end;</source>
        <Parameter name="jobArray" type="CM_JobArray" usage="input"/>
    </JadeMethod>
    <JadeMethod name="getVesselCategory" id="1c56b6b1-fb2b-4aed-817b-5154dfff31e6">
        <source>getVesselCategory() : HMS_VesselCategory;
/*
Purpose:			

Date		Who		Reason
12 October 2021	navab1	TFS 52132
*/

vars

begin
	if self.myHMSVoyageData = null then
		return null;
	endif;
	
	if self.myHMSVoyageData.myVesselCategoryIn &lt;&gt; null then
		return self.myHMSVoyageData.myVesselCategoryIn;
	endif;
	
	return self.myHMSVoyageData.myVesselCategoryOut;
epilog

end;</source>
        <ReturnType type="HMS_VesselCategory"/>
    </JadeMethod>
    <JadeMethod name="getVesselDefaultTugsForMovemnt" id="80958637-0e09-48d4-b3f6-c1ba4ca096c4">
        <updating/>
        <source>getVesselDefaultTugsForMovemnt(_movement : HMS_VoyageMovement) : Integer updating;
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		For each movement the number of tugs that are part of the contract, is stored on the vessel
//
// ---------------------------------------------------------------------------

vars
	numTugs : Integer;
begin
	
	numTugs := _movement.numContractTugs;
	
	// PAR 15693
	if numTugs = 0 then
		// go get the numTugs from the vessel default.
		// the value of the movement's 'numContractTugs' attribute is set when the voyage is created 
		// and it is set from the following value on the vessel by movement.
		numTugs := _movement.getNumTugsOnContractFromVessel();
	endif;
	
	return numTugs;
end;</source>
        <Parameter name="_movement" type="HMS_VoyageMovement"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
