    <JadeMethod name="addToolbarControls" id="7ecd4d1c-15c8-48ba-bfcd-f51e6ef442e1">
        <updating/>
        <source>addToolbarControls() updating, protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
12 July 2012	cnwndl1	Initial creation
28/09/2022 	navds20 ChangeRequest 54617: MTN - Configure Options Locator

*/

vars
	toolbar	: CMUI_Toolbar;
	
begin
	inheritMethod();
	
	// ### TFS 55322 08NOV2022 NAVAB1 - the cmbTerminal and txtFilter were reparented corretly to the corresponding frame and had their top and left set to zero in the painter
	toolbar := self.frmToolbar;
	toolbar.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);	
	toolbar.addButton(self.btnShowOption, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnSearchMsg, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmTerminal,CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmFilter,CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnResetSearchMs, CMUI_Toolbar.Control_Alignment_Left);
	
	self.btnRefresh.enabled := false;
	
	
	
	/*// ### TFS 55322 08NOV2022 NAVAB1
	

	toolbar := self.frmToolbar;
	//toolbar.addButton(self.btnShowSearchTV, CMUI_Toolbar.Control_Alignment_Left);			//start 25/08/2022 navds20 TFS 54617
	//toolbar.addButton(self.btnResetSearchMs, CMUI_Toolbar.Control_Alignment_Left);		//start 25/08/2022 navds20 TFS 54617
	//toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);							//start 25/08/2022 navds20 TFS 54617
	//toolbar.addButton(self.btnRefresh, CMUI_Toolbar.Control_Alignment_Left);				//start 25/08/2022 navds20 TFS 54617
	//toolbar.addButton(self.btnCancelBase, CMUI_Toolbar.Control_Alignment_Right);			//start 25/08/2022 navds20 TFS 54617
	
	//start 25/08/2022 navds20 TFS 54617
	toolbar.addButton(self.btnSearchMsg, CMUI_Toolbar.Control_Alignment_Left);
	toolbar := self.frmSearchMsgTB;
	toolbar.visible := true;
	
	toolbar := self.frmToolbar;
	self.frmToolbar.addFrame(self.frmFilter,CMUI_Toolbar.Control_Alignment_Left);
	self.txtFilterBox.parent 	:= self.frmFilter;
	self.txtFilterBox.visible 	:= true;
	self.txtFilterBox.left 		:= 4;
	self.txtFilterBox.top 		:= 2;
	
	toolbar.addButton(self.btnResetSearchMs, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	
	toolbar := self.frmToolbar;
	self.frmToolbar.addFrame(self.frmTerminal,CMUI_Toolbar.Control_Alignment_Left);
	self.cmbTerminal.parent 	:= self.frmTerminal;
	self.cmbTerminal.visible 	:= true;
	self.cmbTerminal.left 		:= 1;
	self.txtFilterBox.top 		:= 2;
	self.cmbTerminal.top 		:= self.txtFilterBox.top;
	
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnShowOption, CMUI_Toolbar.Control_Alignment_Left);
	*/
	self.btnRefresh2.visible :=false;
	//self.cmbTerminal.visible :=false;
	self.btnJumpTo.visible :=false;
	//end 25/08/2022 navds20 TFS 54617
	
	//start 25/08/2022 navds20 TFS 54617
	/*toolbar := self.frmSearchMsgTB;
	toolbar.addButton(self.btnSearchMsg, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addButton(self.btnHideSearchMsg, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.positionToolbarControls();
	toolbar.visible := true;*/
	//end 25/08/2022 navds20 TFS 54617
	
	toolbar := self.frmCompareTool;
	toolbar.addFrame(self.frmCurrTerm, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmExpTerm, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmCompTerm, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addSeperator(CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmCompFile, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmCompHeading, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	
	toolbar := self.frmUserTool;
	toolbar.addFrame(self.frmExportUser, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmCompUser, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmUserSel, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmUserHeading, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.positionToolbarControls();
	toolbar.visible := true;
	
	toolbar := self.frmRoleTool;
	toolbar.addFrame(self.frmExportRole, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmCompRole, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmRoleSel, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.addFrame(self.frmRoleHeading, CMUI_Toolbar.Control_Alignment_Left);
	toolbar.positionToolbarControls();
	toolbar.visible := true;
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="allowsTableFilters" id="5a9ddd81-c742-4c80-8d28-e25310119445">
        <source>allowsTableFilters(_table: Table): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 August 2014	cnwndl1	Initial creation

