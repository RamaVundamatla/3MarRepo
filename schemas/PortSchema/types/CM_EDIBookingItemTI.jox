    <JadeMethod name="setMeasurementTypeValue" id="5112bc3b-2ca0-45ca-aab0-79c0cf181a16">
        <updating/>
        <source>setMeasurementTypeValue(_columnName: String; _value: String) : Boolean updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04/09/2014	cnwmc5	Initial creation	PAR 34533
12/12/2014  cnwma1  PAR #35355 Invalid parameter error when trying to save edits in EDI operations window
11/05/2015	cnwdap1	PAR #35924 Another Invalid parameter error when trying to save edits in EDI operations window
*/
vars
	rowName,
	measureType		: String;
	
begin

	if not inheritMethod(_columnName, _value) then
		return false;
	endif;
	
	_columnName.getRowNameMeasureType(rowName, measureType);
	
	if rowName = ETRow_TotalWeight then
		self.weight := app.convertMeasurementForStorage(measureType, _value.asDecimalJMT());
		return true;
	elseif rowName = ETRow_ProductVolume then												//12/12/2014 cnwma1 PAR #35355
		self.productVolume := app.convertMeasurementForStorage(measureType, _value.asRealJMT);
		return true;
	elseif rowName = ETRow_Density then																	// PAR #35924
		self.density := app.convertMeasurementForStorage(measureType, _value.asDecimalJMT).Integer;		// PAR #35924
		return true;																					// PAR #35924
	endif;
	
	if self.class.getPropertyInHTree(rowName) &lt;&gt; null then
		self.setPropertyValue(rowName, app.convertMeasurementForStorage(measureType, _value.asDecimalJMT()));
	endif;
	
	return true;
	
epilog

end;</source>
        <Parameter name="_columnName" type="String"/>
        <Parameter name="_value" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
