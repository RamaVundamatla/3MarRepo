    <JadeMethod name="binaryImageTest" id="565fae0d-909a-4f3c-942f-2a7a495e3766">
        <source>binaryImageTest();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 September 2025	navsp1	Initial creation

*/
constants
    IMAGE_PATH : String = "C:\Users\Shanu.Paul\OneDrive - Kaleris Corporation\Desktop\binaryImage.png";
vars
	offset,
	fileLength	: Integer;
	dataLength	: Integer;
	fileData	: Binary;
	detail		: CM_FileDataStorageDetail;
	fileName : String; description:String; heading:String;
	file : File;
	base64String : String;
	binaryData : Binary;
	
	outputFile : File;
	
begin
	create file transient;
	
	file.fileName := IMAGE_PATH;
	file.createdTime:=app.actualTimeServer;// 13 June 2016	cnwns1	TFS 488 - Multi Timezone Support
	file.mode := File.Mode_Input;
	file.kind	:= File.Kind_Binary;
	if (not file.isAvailable) then
		app.raiseCMException(File_available, null, null);
	endif;
	
	fileLength	:=	file.fileLength();

	dataLength	:=	CM_FileDataStorageDetail.COPY_CHUNK_SIZE;

	while offset &lt;= fileLength do
		if (fileLength - offset) &lt; dataLength then
			dataLength	:=	fileLength - offset;
		endif;
		
		if offset &lt;&gt; 0 then
			file.seek(offset);
		endif;
		
		fileData	:=	file.readBinary(dataLength);
		offset		:=	offset + fileData.length;
		
		//need this to send an empty file for CAMS.  See above JC	21/06/2004
		if fileData.length() &lt; 1 then
			fileData := CrLf.Binary;
		endif;
			
		// cnwdad1 25/02/2009 - PAR #18366.
		//		fileData	:=	fileData.compress();
		fileData	:=	fileData.compressToBinary(Binary.Compression_ZLib);
		
	
		if offset &gt;= fileLength then
			break;
		endif;
	endwhile;
	
	base64String := fileData.base64Encode();
	
	write base64String;
	
	binaryData := base64String.base64Decode().Binary;
	/*
	create outputFile transient;
	outputFile.maxRecordSize := 100000;
	outputFile.usePresentationFileSystem := true;
	outputFile.openOutput("C:\Users\navpw1\Desktop\mypdfData.txt");
	outputFile.writeString(base64String);
	outputFile.close();
	
	delete outputFile;*/
	
	//write binaryData;
	
	create outputFile transient;
	outputFile.kind := File.Kind_Binary;
	outputFile.maxRecordSize := 100000;
	outputFile.usePresentationFileSystem := true;
	outputFile.openOutput(IMAGE_PATH);
	outputFile.writeBinary(binaryData.uncompressToBinary());
	outputFile.close();
	
epilog
	delete file;
	delete outputFile;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="bolFieldReference_19553" id="44dce3d9-3a8b-4e8e-bfe8-761e6f81468e">
        <source>bolFieldReference_19553();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 December 2024	navsp1	Initial creation MTN-19553

*/

constants
	PatternStr 	= "bol"; 
	PatternStr2 = "num";
vars
	cls       			: Class;
	propertyCollObj  	: PropertyColl;
	prop      			: Property;
	cnt       			: Integer;
  	sc 					: SchemaColl;
	indirectRefs,
	visited 			: FeatureSet;
	inv					: InverseSet;
	reference			: ExplicitInverseRef;
	obj 				: Object;
	set 				: MemberKeySet;
	coll 				: ClassColl;
	cls1, cls2 			: Class;
	portSchema 			: Schema;
	refColList 			: String;
	classNameSpace 		: String;
	totLength 			: Integer;
	propName, className : String;
	propertyMatch,
	classMatch			: Boolean;
	constantCategory	: ConstantCategory;
	constant			: Constant;
	tmpConstantDict		: ConstantNDict;
	entTableHeader 		: EntTableRowHeader;
	root 				: CM_EntTableDataRoot;
	row 				: EntTableRow;
	heading				: String;
	propLen 			: Integer;
begin
	app.clearWriteWindow();
	portSchema := rootSchema.getSchema("PortSchema");
	
	/*Find EntTable Rows*/
	root := CM_EntTableDataRoot.firstInstance;
	cnt :=0;
	write "*********Enttable Rows for the BOL*****************";
	write "No.      Row Name           Heading             Length";
	write "------------------------------------------------------";
	foreach row in root.allEntTableRowsByNumber do		
		
		heading := row.getHeading(null, null, null);
		if (JadeRegex@contains(row.name, "bol", true) and JadeRegex@contains(row.name, "num", true)) or JadeRegex@contains(row.name, "billoflad", true) or JadeRegex@contains(heading, "bol", true) then
			if row.myEntTableCellControl &lt;&gt; null then
				cnt := cnt + 1;
				write cnt.String &amp; ". " &amp; Tab &amp; row.name &amp; Tab &amp; heading &amp; Tab &amp; row.myEntTableCellControl.getPropertyValue(EntTableTextBox::maxLength.name).String;
			endif;
		endif;
	endforeach;
	
	/*
	constantCategory := portSchema.getCategory(EntTableRows);
	tmpConstantDict := constantCategory.getConstants();
	cnt := 0;
	foreach constant in tmpConstantDict do
		entTableHeader := app.myRoot.myEntTableDataRoot.allEntTableRowHeadersByName[constant.getSource()];
		
		if entTableHeader &lt;&gt; null then
			write entTableHeader;
		endif;
		cnt := cnt +1;
		if cnt &gt; 50 then
			break;
		endif;
		//write constant.getSource().trimBlanks();
	endforeach;
	*/
	
	/*Find all the bol properties from the classes*/
	
	//create sc transient;
	//sc.add(currentSchema);
	//currentSchema.allSubschemas(sc);
	cnt :=0;
	write "*********Class properties for the BOL*****************";
	write "No.      Class Name           Property Name             Length       Collection Class";
	write "---------------------------------------------------------------------------------------";
	foreach cls in portSchema.allClasses do
		//cnt := cnt + 1;
		propertyCollObj := cls.allProperties;
		foreach prop in cls.getPropertiesProperty do
			//if JadeRegex@contains(prop.name, PatternStr, false) or JadeRegex@contains(cls.name, PatternStr, false) then
			propName := prop.name.toLower(); className := cls.name.toLower();
			propertyMatch 	:= propName.startsWith("bol") or propName.startsWith("billof");
			classMatch		:= className.startsWith("cm_bol") and JadeRegex@contains(propName, PatternStr2, false);
			if (propertyMatch or classMatch) and  prop.getLength &gt; 29 then
				create coll transient;
				coll := prop.usedAsKeyInClasses();//find the property used in collection classes
				refColList := "";
				foreach cls2 in coll do
					if refColList &lt;&gt; "" then
						refColList := refColList &amp; ", ";
					endif;
					refColList := refColList &amp; cls2.name;
				endforeach;
				if refColList &lt;&gt; null then
					refColList :="(" &amp; refColList &amp; ")";
				endif;
				totLength := cls.name.length;
				classNameSpace := null;
				while totLength &lt; 61 do
					classNameSpace := classNameSpace &amp; "  ";
					totLength := totLength +1;
				endwhile;
				cnt := cnt + 1;
				propLen := prop.getLength - 1;
				write cnt.String &amp; ". " &amp; Tab &amp; cls.name &amp; Tab &amp; prop.name &amp; Tab &amp; propLen.String &amp;Tab&amp; refColList;
				//prop.refer
				//if cls.name = "CM_BOL" and prop.name = "number" then
				//	write "Bol";
				//endif;
				//create indirectRefs transient;
				//create visited transient;
				//prop.getRefs(sc.first, sc, indirectRefs, visited);
				//reference	:=	prop.getinv;
				//inv := reference.cnEcGetInverses();
				//write cls.name &amp;" : "&amp; prop.name &amp;" : "&amp; prop.getLength.String &amp;Tab&amp; indirectRefs.size.String &amp; Tab &amp; visited.size.String &amp;Tab&amp;inv.String;
				//delete indirectRefs;
				//delete visited;
			endif;
		endforeach;
	endforeach;	
epilog
	delete sc;
	delete indirectRefs;
	delete visited;
end;
</source>
    </JadeMethod>
    <JadeMethod name="camsRunAdhoc" id="1e37d027-8718-4a19-85eb-6fee25995ffd">
        <source>camsRunAdhoc();
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 13 March 2023	navdap1		Initial creation TFS 
//
constants
	CAMProtocol : String = "Goods Receipt A";//"EUP Damage Repair Activity";
	StartDate	: Date = '13/01/2025'.Date;// setup start and end dates/time and protocol to use
	EndDate1	: Date = '13/01/2025'.Date;
	StartTime	: Time = '11:40:00:000'.Time;
	EndTime		: Time = '11:45:00:000'.Time;
	Terminal1	: String = 'SPT';
vars
	camProtocol		: CM_CamProtocol;
	runDateTime		: TimeStamp;
	startDateTime	: TimeStamp;
	endDateTime		: TimeStamp;
	valDate			: Date;
	valTime			: Time;
	terminal		: CM_Terminal;
	camsController : CM_CamControllerAgent;
begin
	app.initialize();
	app.changeLogLevel(LogDEBUG);
	// setup start and end dates/time and protocol to use
	valDate := StartDate;
	valTime := StartTime;
	startDateTime.setDate(valDate);
	startDateTime.setTime(valTime);
	if not startDateTime.isValid() then
		write 'startDateTime is not valid';
		return;
	endif;
	
	valDate := EndDate1;
	valTime := EndTime;
	endDateTime.setDate(valDate);
	endDateTime.setTime(valTime);
	if not endDateTime.isValid() then
		write 'endDateTime is not valid';
		return;
	endif;
	
	runDateTime := app.actualTimeServer;
	app.hideDebug	:= false;			// false implies do not hide debugging - helps with display messages
	terminal		:= app.myRoot.allTerminals[Terminal1];
	if terminal = null then
		app.writeStatement('Can not find required terminal ' &amp; Terminal1);
		return;
	endif;
	app.myPassport.setMyTerminal(terminal);
	
	camProtocol := terminal.camProtocols[CAMProtocol];
	if camProtocol = null then
		app.writeStatement("Cannot find required cam protocol description");
		return;
	endif;
	
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);
	
	on Exception do null global;
	
	app.setPassBackExceptions(true, true);
	create camsController transient;
	camsController.setMyTerminal(terminal);
	camsController.adhocTask(camProtocol, startDateTime, endDateTime, runDateTime, true, true);	//this does runs the adhoc cams
epilog
	delete camsController;
end;</source>
    </JadeMethod>
    <JadeMethod name="camsRunNonAdhoc" id="e8c7ed5e-ef80-4cb8-9382-7630e9ec1b54">
        <source>camsRunNonAdhoc();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 October 2023	navsp1	Initial creation

*/

constants
	Terminal1 : String = 'SPT';
vars
	terminal : CM_Terminal;
	bgpRequest : BGP_CamsRequest;
begin
	app.initialize;
	terminal := app.myRoot.allTerminals[Terminal1];
	if terminal = null then
		app.writeStatement('Can not find required terminal ' &amp; Terminal1);
		return;
	endif;
	app.myPassport.setMyTerminal(terminal);
	app.myPassport.setMyUserFromCode(SUPERUSER_Str);
	app.changeLogLevel(LogDEBUG);
	create bgpRequest transient;
	bgpRequest.setPropertyValue(BGP_CamsRequest::myTerminal.name, terminal);
	bgpRequest.setPropertyValue(BGP_CamsRequest::myUser.name, app.myPassport.myUser);
	bgpRequest.action();
epilog
	delete bgpRequest;
end;</source>
    </JadeMethod>
    <JadeMethod name="clientRefFieldReference_19553" id="ca283a81-2463-4293-9e12-70ba406c8f8b">
        <source>clientRefFieldReference_19553();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
15 Jan 2024	navsp1	Initial creation MTN-19553

*/

constants
	//PatternStr 	= "bol"; 
	//PatternStr2 = "num";
vars
	cls       			: Class;
	propertyCollObj  	: PropertyColl;
	prop      			: Property;
	cnt       			: Integer;
  	sc 					: SchemaColl;
	indirectRefs,
	visited 			: FeatureSet;
	inv					: InverseSet;
	reference			: ExplicitInverseRef;
	obj 				: Object;
	set 				: MemberKeySet;
	coll 				: ClassColl;
	cls1, cls2 			: Class;
	portSchema 			: Schema;
	refColList 			: String;
	classNameSpace 		: String;
	totLength 			: Integer;
	propName, className : String;
	propertyMatch,
	classMatch			: Boolean;
	constantCategory	: ConstantCategory;
	constant			: Constant;
	tmpConstantDict		: ConstantNDict;
	entTableHeader 		: EntTableRowHeader;
	root 				: CM_EntTableDataRoot;
	row 				: EntTableRow;
	heading				: String;
	propLen 			: Integer;
begin
	app.clearWriteWindow();
	portSchema := rootSchema.getSchema("PortSchema");
	
	/*Find EntTable Rows*/
	root := CM_EntTableDataRoot.firstInstance;
	cnt :=0;
	write "*********Enttable Rows for the BOL*****************";
	write "No.      Row Name           Heading             Length";
	write "------------------------------------------------------";
	foreach row in root.allEntTableRowsByNumber do		
		
		heading := row.getHeading(null, null, null);
		if JadeRegex@contains(row.name, "clientref", true) then
			if row.myEntTableCellControl &lt;&gt; null then
				cnt := cnt + 1;
				write cnt.String &amp; ". " &amp; Tab &amp; row.name &amp; Tab &amp; heading &amp; Tab &amp; row.myEntTableCellControl.getPropertyValue(EntTableTextBox::maxLength.name).String;
			endif;
		endif;
	endforeach;
	
	/*
	constantCategory := portSchema.getCategory(EntTableRows);
	tmpConstantDict := constantCategory.getConstants();
	cnt := 0;
	foreach constant in tmpConstantDict do
		entTableHeader := app.myRoot.myEntTableDataRoot.allEntTableRowHeadersByName[constant.getSource()];
		
		if entTableHeader &lt;&gt; null then
			write entTableHeader;
		endif;
		cnt := cnt +1;
		if cnt &gt; 50 then
			break;
		endif;
		//write constant.getSource().trimBlanks();
	endforeach;
	*/
	
	/*Find all the bol properties from the classes*/
	
	//create sc transient;
	//sc.add(currentSchema);
	//currentSchema.allSubschemas(sc);
	cnt :=0;
	write "*********Class properties for the BOL*****************";
	write "No.      Class Name           Property Name             Length       Collection Class";
	write "---------------------------------------------------------------------------------------";
	foreach cls in portSchema.allClasses do
		//cnt := cnt + 1;
		propertyCollObj := cls.allProperties;
		foreach prop in cls.getPropertiesProperty do
			//if JadeRegex@contains(prop.name, PatternStr, false) or JadeRegex@contains(cls.name, PatternStr, false) then
			propName := prop.name.toLower(); className := cls.name.toLower();
			propertyMatch 	:= propName.startsWith("clientref");
			classMatch		:= className.startsWith("clientref");
			if (propertyMatch or classMatch) and  prop.getLength &gt; 29 then
				create coll transient;
				coll := prop.usedAsKeyInClasses();//find the property used in collection classes
				refColList := "";
				foreach cls2 in coll do
					if refColList &lt;&gt; "" then
						refColList := refColList &amp; ", ";
					endif;
					refColList := refColList &amp; cls2.name;
				endforeach;
				if refColList &lt;&gt; null then
					refColList :="(" &amp; refColList &amp; ")";
				endif;
				totLength := cls.name.length;
				classNameSpace := null;
				while totLength &lt; 61 do
					classNameSpace := classNameSpace &amp; "  ";
					totLength := totLength +1;
				endwhile;
				cnt := cnt + 1;
				propLen := prop.getLength - 1;
				write cnt.String &amp; ". " &amp; Tab &amp; cls.name &amp; Tab &amp; prop.name &amp; Tab &amp; propLen.String &amp;Tab&amp; refColList;
				//prop.refer
				//if cls.name = "CM_BOL" and prop.name = "number" then
				//	write "Bol";
				//endif;
				//create indirectRefs transient;
				//create visited transient;
				//prop.getRefs(sc.first, sc, indirectRefs, visited);
				//reference	:=	prop.getinv;
				//inv := reference.cnEcGetInverses();
				//write cls.name &amp;" : "&amp; prop.name &amp;" : "&amp; prop.getLength.String &amp;Tab&amp; indirectRefs.size.String &amp; Tab &amp; visited.size.String &amp;Tab&amp;inv.String;
				//delete indirectRefs;
				//delete visited;
			endif;
		endforeach;
	endforeach;	
epilog
	delete sc;
	delete indirectRefs;
	delete visited;
end;
</source>
    </JadeMethod>
