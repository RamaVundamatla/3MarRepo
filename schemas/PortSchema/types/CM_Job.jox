    <JadeMethod name="isMatchingCommodity" id="6fcd785e-5352-49b5-a6fe-c6faea32d6f0">
        <source>isMatchingCommodity(_commodity : String): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 Apr 2024 navhl20 ChangeRequest 63251: FR | 53729 - Delivery Dispatch screen - Further issues and Remedial work - 1
06 Mar 2025 navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	wle 			: CM_WorkListEntry;
	invalid			: Boolean;
	ti				: CM_TrackedItem;
	commodity		: String;
	job				: CM_Job;
begin
	if _commodity &lt;&gt; null then
		if not self.isKindOf(CM_VoyageWorkPointJob) then
			job := self;
		else
			job := self.CM_VoyageWorkPointJob.getMyWOJob();
			if job = null then
				return false;
			endif;
		endif;
		foreach wle in job.workListEntries discreteLock do	//06.03.2025 navma1 #MTN-34179
			invalid := false;
			ti := wle.myTrackedItem;
		
			if ti &lt;&gt; null then
				ti.edition;
				if invalid then
					continue;
				endif;
				
				commodity := ti.commodity;
				if _commodity = commodity then
					return true;
				endif;
			endif;
		endforeach;
	endif;
	return false;
epilog

end;</source>
        <Parameter name="_commodity" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
