//--------------------------------------------------
vars
	tmpTI : CM_TrackedItem;
begin

	foreach tmpTI in self.allTrackedItems do
		if tmpTI.myPrimaryPlannedLocation &lt;&gt; null
		or tmpTI.myPrimaryQueuedLocation &lt;&gt; null then
			return true;
		endif;
	endforeach;

	return false;
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
