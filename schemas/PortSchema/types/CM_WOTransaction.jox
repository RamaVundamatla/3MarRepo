    <JadeMethod name="isTypeOfJobActivity" id="a9c51525-1aed-4a11-9aae-0c417c012755">
        <source>isTypeOfJobActivity() : Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28/03/2024	navkc1 CR63258  Task 63259: Jade - Start Stop API call TRX

*/

vars

begin
	if 	self.type = TRANS_TYPE_WOJOBSTART or
		self.type = TRANS_TYPE_WOJOBSTOP or
		self.type = TRANS_TYPE_WOJOBRESUME or
		self.type = TRANS_TYPE_WOJOBCOMPLETE then
			return true;
	endif;
	
	return false;
epilog

end;</source>
