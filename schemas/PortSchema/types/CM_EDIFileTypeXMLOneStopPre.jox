    <JadeMethod name="getIdStringFromFile" id="72ed3af1-f35d-48a4-a323-883d09994b78">
        <source>getIdStringFromFile( _ediFile: CM_EDIFile input ):String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 September 2016	cnwndl1	Initial creation

*/

vars

	ediData : CM_EDIDataPrenote;
	ediPrenote : CM_EDITrackedItem;
	extraString : String;

begin

	if _ediFile.ediData &lt;&gt; null and _ediFile.ediData.isKindOf( CM_EDIDataPrenote ) then
		ediData := _ediFile.ediData.CM_EDIDataPrenote;
		ediPrenote := ediData.allEDITrackedItems.first;
		if ediPrenote &lt;&gt; null then
			extraString := ediPrenote.id.trimBlanks;
			if extraString &lt;&gt; null then
				extraString := " [id = " &amp; extraString &amp; "]";
				return extraString;
			endif;
		endif;
	endif;
	
	return null;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="processArriveCarrier" id="b9385d2e-ef0f-4003-b0d8-97524034d858">
        <source>processArriveCarrier(	_xmlElementACarr : JadeXMLElement;
						_ediFile: CM_EDIFile input;
						_ediTIErrors : HugeStringArray input;
						_ediPreNote : CM_EDIPrenoteTI input
						) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 August 2016	cnwndl1	Initial creation	TFS 2276 / 2565

*/

vars

	xmlElementArrTruck : JadeXMLElement;
	xmlSubElement : JadeXMLElement;
	str : String;
	carrierObj : CM_Carrier;
	

begin


	xmlElementArrTruck := _xmlElementACarr.getElementByTagName(self.TagArrivalCarrierTruck);
	if xmlElementArrTruck &lt;&gt; null then

		xmlSubElement := null;
		xmlSubElement := xmlElementArrTruck.getElementByTagName(self.TagCarrierCode);
		if xmlSubElement &lt;&gt; null then
			str := xmlSubElement.textData.trimBlanks;
			if str &lt;&gt; null and str &lt;&gt; "ROADCARRIER" then
				carrierObj := app.myRoot.allCarriers.getAtKey(str);
				if carrierObj = null then
					self.addErrorMessNoMatchingObj( "Carrier", self.TagArrivalCarrierTruck, self.TagCarrierCode, str, _ediFile, _ediTIErrors );
				else
					_ediPreNote.carrierCode := carrierObj.code;
				endif;
			endif;
			
		endif;
		
		
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_xmlElementACarr" type="JadeXMLElement"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_ediTIErrors" type="HugeStringArray" usage="input"/>
        <Parameter name="_ediPreNote" type="CM_EDIPrenoteTI" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processCommodity" id="fb8eb722-71f3-4f53-9cc9-164fa724a24a">
        <source>processCommodity(	_xmlElementComm : JadeXMLElement;
					_ediFile: CM_EDIFile input;
					_ediTIErrors : HugeStringArray input;
					_ediPreNote : CM_EDIPrenoteTI input
					) protected;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31/08/2016	cnwndl1	Initial creation	TFS 2276 / 2565
01/05/2017	cnwdap1	TFS 4267 AAT OneStop prenote not translating commodity
05/11/2019	jlgzm1	TFS 47309 AAT - Default Customs Entry Number on MT Exports
*/

vars

	xmlSubElement : JadeXMLElement;
	str : String;
	commodityObj : CM_Commodity;
	operator : CM_Operator;						// TFS 4267
	translatedCode : String;					// TFS 4267
	foundMatch : Boolean;						// TFS 4267

begin

	xmlSubElement := null;
	xmlSubElement := _xmlElementComm.getElementByTagName(self.TagCode);
	if xmlSubElement = null then
		self.addErrorMessTagSetMissing( self.TagCommodity, self.TagCode, _ediFile, _ediTIErrors );
	else
		str := xmlSubElement.textData.trimBlanks;
		if str = null then
			self.addErrorMessEmptyTag( self.TagCommodity, self.TagCode, _ediFile, _ediTIErrors );
		else
			commodityObj := app.myRoot.allCommodities.getAtKey(str);
			if commodityObj = null then
				operator := app.myRoot.allOperators[_ediPreNote.operatorCode];											// TFS 4267
				if operator &lt;&gt; null then																				// TFS 4267
					translatedCode := operator.getXlationSystemCode_Commodity(str, foundMatch, null);					// TFS 4267
					if foundMatch then																					// TFS 4267
						commodityObj := app.myRoot.allCommodities.getAtKey(translatedCode);								// TFS 4267
					endif;																								// TFS 4267
				endif;																									// TFS 4267
			endif;																										// TFS 4267
			if commodityObj = null then																					// TFS 4267
				self.addErrorMessNoMatchingObj( "Commodity", self.TagCommodity, self.TagCode, str, _ediFile, _ediTIErrors );
			else
				_ediPreNote.commodity := commodityObj.code;
				_ediPreNote.commodityDescription := commodityObj.description;
				if commodityObj.isEmpty then		// TFS 47309
					// Empty containers may not have an Export Clearence Number. Set it to 'EXDC' here.
					// if file does include an Export Clearence Number it will be overriden with the 
					// correct one during processRefNumbers method
					_ediPreNote.customExportEntryNumber := DefaultCAN;	// TFS 47309
				endif;
			endif;
		endif;
		
	endif;
	
	xmlSubElement := null;
	xmlSubElement := _xmlElementComm.getElementByTagName(self.TagPackages);
	if xmlSubElement &lt;&gt; null then
		str := xmlSubElement.textData.trimBlanks;
		if str &lt;&gt; null and str.isInteger then
			if _ediPreNote.cargoType &lt;&gt; 1 then	// Not a container
				_ediPreNote.totalQuantity := str.Integer;
			endif;
		endif;
		
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_xmlElementComm" type="JadeXMLElement"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_ediTIErrors" type="HugeStringArray" usage="input"/>
        <Parameter name="_ediPreNote" type="CM_EDIPrenoteTI" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processConsignee" id="236fac31-baf3-4b36-8110-a5982587562d">
        <source>processConsignee(	_xmlElementCnee : JadeXMLElement;
					_ediFile: CM_EDIFile input;
					_ediTIErrors : HugeStringArray input;
					_ediPreNote : CM_EDIPrenoteTI input
					) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 August 2016	cnwndl1	Initial creation	TFS 2276 / 2565

*/

vars

	xmlSubElement : JadeXMLElement;
	str : String;
	consigneeObj : CM_ConsigneeConsignor;
	

begin

	xmlSubElement := null;
	xmlSubElement := _xmlElementCnee.getElementByTagName(self.TagConsigneeCode);
	if xmlSubElement &lt;&gt; null then
		str := xmlSubElement.textData.trimBlanks;
		if str &lt;&gt; null then
			consigneeObj := app.myRoot.allConsigneeConsignors.getAtKey(str);
			if consigneeObj = null then
				self.addErrorMessNoMatchingObj( "Consignee", self.TagConsignee, self.TagConsigneeCode, str, _ediFile, _ediTIErrors );
			else
				_ediPreNote.consignee := consigneeObj.code;
			endif;
		endif;
		
	endif;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_xmlElementCnee" type="JadeXMLElement"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_ediTIErrors" type="HugeStringArray" usage="input"/>
        <Parameter name="_ediPreNote" type="CM_EDIPrenoteTI" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processConsignor" id="c3e19f50-8968-476c-b454-6799abf7068a">
        <source>processConsignor(	_xmlElementCnor : JadeXMLElement;
					_ediFile: CM_EDIFile input;
					_ediTIErrors : HugeStringArray input;
					_ediPreNote : CM_EDIPrenoteTI input
					) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 August 2016	cnwndl1	Initial creation	TFS 2276 / 2565

*/

vars

	xmlSubElement : JadeXMLElement;
	str : String;
	consignorObj : CM_ConsigneeConsignor;
	

begin

	xmlSubElement := null;
	xmlSubElement := _xmlElementCnor.getElementByTagName(self.TagConsignorCode);
	if xmlSubElement &lt;&gt; null then
		str := xmlSubElement.textData.trimBlanks;
		if str &lt;&gt; null then
			consignorObj := app.myRoot.allConsigneeConsignors.getAtKey(str);
			if consignorObj = null then
				self.addErrorMessNoMatchingObj( "Consignor", self.TagConsignor, self.TagConsignorCode, str, _ediFile, _ediTIErrors );
			else
				_ediPreNote.consignor := consignorObj.code;
			endif;
		endif;
		
	endif;
	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_xmlElementCnor" type="JadeXMLElement"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_ediTIErrors" type="HugeStringArray" usage="input"/>
        <Parameter name="_ediPreNote" type="CM_EDIPrenoteTI" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processContainer" id="9363e4c6-f07f-424e-8a3e-4adb8cc8f1de">
        <source>processContainer(	_xmlElementCont : JadeXMLElement;
					_ediFile: CM_EDIFile input;
					_ediTIErrors : HugeStringArray input;
					_ediPreNote : CM_EDIPrenoteTI input
					):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 August 2016	cnwndl1	Initial creation
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 09 July 2018		jlgrh7 TFS #39221 AAT - PRA Error
*/

vars

	xmlSubElement : JadeXMLElement;
	str : String;
	isoTypeObj : CM_ISOType;
	cargoTypeObj : CM_CargoType;
	operatorObj : CM_Operator;
	portObj : CM_Port;
	translatedCode : String;
	found : Boolean;

begin

	xmlSubElement := null;
	xmlSubElement := _xmlElementCont.getElementByTagName(self.TagNumber);
	if xmlSubElement = null then
		self.addErrorMessTagSetMissing( self.TagContainer, self.TagNumber, _ediFile, null );
		return false;
	else
		str := xmlSubElement.textData.trimBlanks;
		if str = null then
			self.addErrorMessEmptyTag( self.TagContainer, self.TagNumber, _ediFile, null );
			return false;
		endif;
		_ediPreNote.setId(str);
	endif;
	
	xmlSubElement := null;
	xmlSubElement := _xmlElementCont.getElementByTagName(self.TagISOCode);
	if xmlSubElement &lt;&gt; null then
		str := xmlSubElement.textData.trimBlanks;
		if str &lt;&gt; null then
			isoTypeObj := app.myRoot.allISOTypes.getAtKey(str);
			if isoTypeObj &lt;&gt; null then
				_ediPreNote.isoType := str;
			else
				self.addErrorMessNoMatchingObj( "ISO Type", self.TagContainer, self.TagISOCode, str, _ediFile, _ediTIErrors );
			endif;
		endif;
	endif;
	
	xmlSubElement := null;
	xmlSubElement := _xmlElementCont.getElementByTagName(self.TagType);
	if xmlSubElement = null
	and _ediPreNote.isoType = null // cos if we have an isotype its a container...
	then
		self.addErrorMessTagSetMissing( self.TagContainer, self.TagType, _ediFile, _ediTIErrors );
	else
		if _ediPreNote.isoType &lt;&gt; null then
			// cos if we have an isotype its a container...
			str := "1";
		elseif xmlSubElement &lt;&gt; null then
			str := xmlSubElement.textData.trimBlanks;
		endif;
		
		if str = null then 
			self.addErrorMessEmptyTag( self.TagContainer, self.TagType, _ediFile, _ediTIErrors );
		else
			if str.toUpper = "CON" then
				str := "1";	
			endif;
			if str.isInteger then
				cargoTypeObj := app.myRoot.allCargoTypesById.getAtKey(str.Integer);
			else
				cargoTypeObj := app.myRoot.getCargoTypeFromAbbrevOrDescr(str);
			endif;
			if cargoTypeObj = null then
				self.addErrorMessNoMatchingObj( "Cargo Type", self.TagContainer, self.TagType, str, _ediFile, _ediTIErrors );
			else
				_ediPreNote.setCargoType( cargoTypeObj.id );
			endif;
		endif;
		
	endif;
	
	//20 Apr 2017	NDL	TFS 4099 - Just check for either, One Stop suggest they will only ever give us one.
	xmlSubElement := null;
	xmlSubElement := _xmlElementCont.getElementByTagName(self.TagVerifiedGrossWeight);
	if xmlSubElement &lt;&gt; null then
		str := xmlSubElement.textData.trimBlanks;
		//if str &lt;&gt; null and str.isInteger and str.Integer &gt; 0 then								//-TFS39221
		if str &lt;&gt; null and str.cnEcIsNumeric and str.Real &gt; 0 then							//+TFS39221
			_ediPreNote.weight := str.Integer;
		endif;
	endif;
	
	if _ediPreNote.weight = 0 then
		xmlSubElement := null;
		xmlSubElement := _xmlElementCont.getElementByTagName(self.TagGrossWeight);
		if xmlSubElement &lt;&gt; null then
			str := xmlSubElement.textData.trimBlanks;
			//if str &lt;&gt; null and str.isInteger and str.Integer &gt; 0 then								//-TFS39221
			if str &lt;&gt; null and str.cnEcIsNumeric and str.Real &gt; 0 then							//+TFS39221
				_ediPreNote.weight := str.Integer;
			endif;
		endif;
	endif;
	
	xmlSubElement := null;
	xmlSubElement := _xmlElementCont.getElementByTagName(self.TagCategory);
	if xmlSubElement &lt;&gt; null then
		str := xmlSubElement.textData.trimBlanks;
		if str = 'E' then	//Export
			_ediPreNote.statusString := "Export";
			_ediPreNote.imexStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_EXPORT].description;
		elseif str = 'H' then	//Storage
			_ediPreNote.statusString := "Storage";
			_ediPreNote.imexStatus := app.myRoot.allImexStatuses[TI_IMEX_STATUS_STORAGE].description;
		endif;
	endif;
	
	xmlSubElement := null;
	xmlSubElement := _xmlElementCont.getElementByTagName(self.TagLineOperator);
	if xmlSubElement = null then
		self.addErrorMessTagSetMissing( self.TagContainer, self.TagLineOperator, _ediFile, _ediTIErrors );
	else
		str := xmlSubElement.textData.trimBlanks;
		if str = null then
			self.addErrorMessEmptyTag( self.TagContainer, self.TagLineOperator, _ediFile, _ediTIErrors );
		else
			operatorObj := app.myRoot.allOperators.getAtKey(str);
			//27 Apr 2017	NDL	TFS 4234
			if operatorObj = null then
				translatedCode := app.myRoot.getXlationSystemCode(str, XLATION_TYPE_OPERATOR, found);
				operatorObj := app.myRoot.allOperators.getAtKey(translatedCode);
			endif;
			
			if operatorObj = null then
				self.addErrorMessNoMatchingObj( "Operator", self.TagContainer, self.TagLineOperator, str, _ediFile, _ediTIErrors );
			else
				_ediPreNote.setOperator( operatorObj );
			endif;
		endif;
		
	endif;
	
	xmlSubElement := null;
	xmlSubElement := _xmlElementCont.getElementByTagName(self.TagArrivalCarrierMode);
	if xmlSubElement &lt;&gt; null then
		str := xmlSubElement.textData.trimBlanks;
		if str = 'R' then
			_ediPreNote.transportMode := TI_TRANSMODE_ROAD_STR;
		elseif str = 'T' then
			_ediPreNote.transportMode := TI_TRANSMODE_RAIL_STR;
		endif;
	endif;
	
	xmlSubElement := null;
	xmlSubElement := _xmlElementCont.getElementByTagName(self.TagUNLoadPortCode);
	if xmlSubElement &lt;&gt; null then
		str := xmlSubElement.textData.trimBlanks;
		if str = null then
			self.addErrorMessEmptyTag( self.TagContainerMessage, self.TagUNLoadPortCode, _ediFile, _ediTIErrors );
		else
			portObj := app.myRoot.allActivePorts.getAtKey(str);
			if portObj = null then
				self.addErrorMessNoMatchingObj( "Port", self.TagContainer, self.TagUNLoadPortCode, str, _ediFile, _ediTIErrors );
			else
				_ediPreNote.loadPort := portObj.code;
			endif;
		endif;
		
	endif;
	
	xmlSubElement := null;
	xmlSubElement := _xmlElementCont.getElementByTagName(self.TagUNDischargePortCode);
	if xmlSubElement &lt;&gt; null then
		str := xmlSubElement.textData.trimBlanks;
		if str = null then
			self.addErrorMessEmptyTag( self.TagContainerMessage, self.TagUNDischargePortCode, _ediFile, _ediTIErrors );
		else
			portObj := app.myRoot.allActivePorts.getAtKey(str);
			if portObj = null then
				self.addErrorMessNoMatchingObj( "Port", self.TagContainer, self.TagUNDischargePortCode, str, _ediFile, _ediTIErrors );
			else
				_ediPreNote.dischargePort := portObj.code;
			endif;
		endif;
		
	endif;
	
	xmlSubElement := null;
	xmlSubElement := _xmlElementCont.getElementByTagName(self.TagUNFinalDischargePortCode);
	if xmlSubElement &lt;&gt; null then
		str := xmlSubElement.textData.trimBlanks;
		if str = null then
			self.addErrorMessEmptyTag( self.TagContainerMessage, self.TagUNFinalDischargePortCode, _ediFile, _ediTIErrors );
		else
			portObj := app.myRoot.allActivePorts.getAtKey(str);
			if portObj = null then
				self.addErrorMessNoMatchingObj( "Port", self.TagContainer, self.TagUNFinalDischargePortCode, str, _ediFile, _ediTIErrors );
			else
				_ediPreNote.destinationPort := portObj.code;
			endif;
		endif;
		
	endif;
	
	xmlSubElement := null;
	xmlSubElement := _xmlElementCont.getElementByTagName(self.TagVGMCertificateStatement);
	self.processVGM( xmlSubElement, _ediFile, _ediPreNote );

	
	return true;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_xmlElementCont" type="JadeXMLElement"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_ediTIErrors" type="HugeStringArray" usage="input"/>
        <Parameter name="_ediPreNote" type="CM_EDIPrenoteTI" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processDeclarant" id="f39ae4cc-b61b-4669-96ee-2e1adcae5dc4">
        <source>processDeclarant(	_xmlElementDecl : JadeXMLElement;
					_ediFile: CM_EDIFile input;
					_ediPreNote : CM_EDIPrenoteTI input
					):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31/08/2016	cnwndl1	Initial creation	TFS 2276 / 2565
05/07/2017	cnwdap1	TFS 4492 SNO VERMAS Changes
*/
vars
	xmlSubElement : JadeXMLElement;
	str : String;

begin
	// Declarant segment is structured as follows;
	//	&lt;Declarant&gt;
	//		&lt;NameOfDeclarant&gt;JOE BLOGGS&lt;/NameOfDeclarant&gt;
	//		&lt;CompanyOfDeclarant&gt;J EXPORTER&lt;/CompanyOfDeclarant&gt;
	//		&lt;DeclarantPhone&gt;0424222333&lt;/DeclarantPhone&gt;
	//		&lt;DeclarantEmail&gt;JBLOKE@EMAIL.COM&lt;/DeclarantEmail&gt;
	//	&lt;/Declarant&gt;
	
	// Name of declarant
	xmlSubElement := null;
	xmlSubElement := _xmlElementDecl.getElementByTagName(self.TagNameOfDeclarant);
	if xmlSubElement &lt;&gt; null then
		str := xmlSubElement.textData.trimBlanks;
		if str &lt;&gt; null then
			_ediPreNote.weightCertifiedName := str;
		endif;
	endif;
	
	// Company of Declarant
	xmlSubElement := null;
	xmlSubElement := _xmlElementDecl.getElementByTagName(self.TagCompanyOfDeclarant);
	if xmlSubElement &lt;&gt; null then
		str := xmlSubElement.textData.trimBlanks;
		if str &lt;&gt; null then
			_ediPreNote.weightCertifiedReference := str;
		endif;
	endif;

	// Declarant Phone
	xmlSubElement := null;
	xmlSubElement := _xmlElementDecl.getElementByTagName(self.TagDeclarantPhone);
	if xmlSubElement &lt;&gt; null then
		str := xmlSubElement.textData.trimBlanks;
		if str &lt;&gt; null then
			_ediPreNote.vgmTelephone := str;
		endif;
	endif;

	// Declarant Email
	xmlSubElement := null;
	xmlSubElement := _xmlElementDecl.getElementByTagName(self.TagDeclarantEmail);
	if xmlSubElement &lt;&gt; null then
		str := xmlSubElement.textData.trimBlanks;
		if str &lt;&gt; null then
			_ediPreNote.vgmElectronicMail := str;
		endif;
	endif;

	return true;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_xmlElementDecl" type="JadeXMLElement"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_ediPreNote" type="CM_EDIPrenoteTI" usage="input"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="processDepartCarrier" id="1332e58f-7472-4c72-978e-21822ce38920">
        <source>processDepartCarrier(	_xmlElementDCarr : JadeXMLElement;
						_ediFile: CM_EDIFile input;
						_ediTIErrors : HugeStringArray input;
						_ediPreNote : CM_EDIPrenoteTI input
						) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 August 2016	cnwndl1	Initial creation	TFS 2276 / 2565

*/

vars

	xmlElementDepVessel : JadeXMLElement;
	xmlSubElement : JadeXMLElement;
	str : String;
	voyageObj : CM_Voyage;
	operator : CM_Operator;
	lloydsNumber : String;
	foundMatch: Boolean;
	xlVoyageCode : String;
	vessel : CM_Vessel;

begin

	xmlElementDepVessel := _xmlElementDCarr.getElementByTagName(self.TagDepartCarrierVessel);
	if xmlElementDepVessel &lt;&gt; null then
	
		//13 Mar 2017	NDL	TFS 3710
		xmlSubElement := null;
		xmlSubElement := xmlElementDepVessel.getElementByTagName(self.TagLloydsNumber);
		if xmlSubElement &lt;&gt; null then
			lloydsNumber := xmlSubElement.textData.trimBlanks;
			//21 Mar 2017	NDL	TFS 3710 - get the vessel operator for potential transalation
			if lloydsNumber &lt;&gt; null then
				vessel := app.myRoot.allVesselsByLloydsNumber.getAtKey( lloydsNumber );
				if vessel &lt;&gt; null then
					operator := vessel.myOperator;
				endif;
			endif;
		endif;

		xmlSubElement := null;
		xmlSubElement := xmlElementDepVessel.getElementByTagName(self.TagCTOVoyageOutBound);
		if xmlSubElement &lt;&gt; null then
			str := xmlSubElement.textData.trimBlanks;
			if str &lt;&gt; null then
				voyageObj := _ediPreNote.getMyTerminal.lookupVoyage( str, null, false );
				//13 Mar 2017	NDL	TFS 3710 - Try and find transalated voyage code.
				if voyageObj = null then
					if operator &lt;&gt; null then
						xlVoyageCode := operator.getXlationSystemCode_Voyage(str, null, lloydsNumber, null, foundMatch);
						if xlVoyageCode &lt;&gt; null then
							voyageObj := _ediPreNote.getMyTerminal.lookupVoyage( xlVoyageCode, null, false );
						endif;
					endif;
				endif;
				
				if voyageObj = null then
					self.addErrorMessNoMatchingObj( "Voyage", self.TagDepartCarrierVessel, self.TagCTOVoyageOutBound, str, _ediFile, _ediTIErrors );
				else
					_ediPreNote.setVoyageCode( voyageObj.code );
				endif;
			endif;
			
		endif;
			
	endif;
	
epilog

end;
</source>
        <access>protected</access>
        <Parameter name="_xmlElementDCarr" type="JadeXMLElement"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_ediTIErrors" type="HugeStringArray" usage="input"/>
        <Parameter name="_ediPreNote" type="CM_EDIPrenoteTI" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processFile" id="7a4dbe97-4242-47d3-9189-33d91b4035f5">
        <updating/>
        <source>processFile(_ediFile: CM_EDIFile input) updating, protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 August 2016	cnwndl1	Initial creation
// 18 Jan 2019	jlgrs1	TFS 41659 42276 STWR Make EDI MultiThreaded Stage 8
// 08 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/
vars
	message : String;
	xmlDoc : CM_XMLDocument;
	rootElement : JadeXMLElement;
	xmlSubElement : JadeXMLElement;
	xmlElements : JadeXMLElementArray;

	xmlElementMH : JadeXMLElement;
	xmlElementCont : JadeXMLElement;
	xmlElementComm : JadeXMLElement;
	xmlElementCnor : JadeXMLElement;
	xmlElementCnee : JadeXMLElement;
	xmlElementRefNum : JadeXMLElement;
	xmlElementACarr : JadeXMLElement;
	xmlElementDCarr : JadeXMLElement;
	xmlElementSeal : JadeXMLElement;
	xmlElementOD : JadeXMLElement;
	xmlElementReefer : JadeXMLElement;
	xmlElementHaz : JadeXMLElement;

	str : String;
	
	theXMLStr : String;
	senderId : String;
	loadPort : String;
	action : String;
	
	ediPreNote : CM_EDIPrenoteTI;
	term : CM_Terminal;
	newEvent : CMEVT_EDIFileReceived;
	docRef : String;
	sentTs : TimeStamp;
	
	ediTIErrors : HugeStringArray;	//
	
	cmifEventCtrl : CMIF_EDIFileReceiveEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
begin

	create xmlDoc transient;
	create ediTIErrors transient;
	
	message := _ediFile.getRawDataString();
	
	if app.myPassport.myCMIFMonitor &lt;&gt; null then
		app.myPassport.myCMIFMonitor.updateProgressWithCaption("Processing File Data", 4, 3, "Loading EDI file Step 3 of 3.");
	endif;
	
	theXMLStr := message.extractXML();
	if theXMLStr = null then	//05 Apr 2017	NDL	TFS 3971 - The raw message didn't have an XML header record on it.
		theXMLStr := message;
	endif;
	
	if theXMLStr &lt;&gt; null then
	
		xmlDoc.parseString(theXMLStr);
		if xmlDoc.rootElement.tagName = self.TagContainerMessage then
			rootElement := xmlDoc.rootElement;
		else
			rootElement := xmlDoc.rootElement.getElementByTagName(self.TagContainerMessage);
		endif;
		
		if rootElement &lt;&gt; null then
		
			xmlElementMH := rootElement.getElementByTagName(self.TagMessageHeader);
			xmlElementCont := rootElement.getElementByTagName(self.TagContainer);
			xmlElementComm := rootElement.getElementByTagName(self.TagCommodity);
			
			if xmlElementMH = null then
				self.addErrorMessTagSetMissing( self.TagContainerMessage, self.TagMessageHeader, _ediFile, null );
				return;
			endif;
			if xmlElementCont = null then
				self.addErrorMessTagSetMissing( self.TagContainerMessage, self.TagContainer, _ediFile, null );
				return; 
			endif;
			if xmlElementComm = null then
				self.addErrorMessTagSetMissing( self.TagContainerMessage, self.TagCommodity, _ediFile, ediTIErrors );
				return;
			endif;
			
			if not self.processMessageHeader( xmlElementMH, _ediFile, ediTIErrors, senderId, loadPort, action, docRef, sentTs ) then
				return;
			endif;
			
			create ediPreNote;
			ediPreNote.setMyEDIData( _ediFile.ediData );
			ediPreNote.messageMode := action;
			ediPreNote.loadPort := loadPort;
			
			ediPreNote.setOneStopAperakValues( _ediFile, docRef, sentTs );
			
			if not self.processContainer( xmlElementCont, _ediFile, ediTIErrors, ediPreNote ) then
				return;
			endif;
				
			if action = 'D' then
				// no point in doing anymore, we have enough to identify the existing pre-note 
				// and are just going to delete the sucker.
			else
			
				self.processCommodity( xmlElementComm, _ediFile, ediTIErrors, ediPreNote );
				
				xmlElementCnor := rootElement.getElementByTagName(self.TagConsignor);
				if xmlElementCnor &lt;&gt; null then
					self.processConsignor( xmlElementCnor, _ediFile, ediTIErrors, ediPreNote );
				endif;
				
				xmlElementCnee := rootElement.getElementByTagName(self.TagConsignee);
				if xmlElementCnee &lt;&gt; null then
					self.processConsignee( xmlElementCnee, _ediFile, ediTIErrors, ediPreNote );
				endif;
				
				xmlElementRefNum := rootElement.getElementByTagName(self.TagReferenceNumbers);
				if xmlElementRefNum &lt;&gt; null then
					self.processRefNumbers( xmlElementRefNum, _ediFile, ediPreNote );
				endif;
				
				xmlElementACarr := rootElement.getElementByTagName(self.TagArrivalCarrier);
				if xmlElementACarr &lt;&gt; null then
					self.processArriveCarrier( xmlElementACarr, _ediFile, ediTIErrors, ediPreNote );
				endif;
				
				xmlElementDCarr := rootElement.getElementByTagName(self.TagDepartCarrier);
				if xmlElementDCarr &lt;&gt; null then
					self.processDepartCarrier( xmlElementDCarr, _ediFile, ediTIErrors, ediPreNote );
				endif;
				
				xmlElementSeal := rootElement.getElementByTagName(self.TagSeal);
				if xmlElementSeal &lt;&gt; null then
					self.processSeals( xmlElementSeal, _ediFile, ediPreNote );
				endif;
				
				xmlElementOD := rootElement.getElementByTagName(self.TagOverDimension);
				if xmlElementOD &lt;&gt; null then
					self.processOverDims( xmlElementOD, _ediFile, ediPreNote );
				endif;
				
				xmlElementReefer := rootElement.getElementByTagName(self.TagReeferInfo);
				if xmlElementReefer &lt;&gt; null then
					self.processReeferInfo( xmlElementReefer, _ediFile, ediPreNote );
				endif;
				
				create xmlElements transient;
				rootElement.getAllElementsByTagName(self.TagHazardousInfo, xmlElements);
				foreach xmlElementHaz in xmlElements do
					self.processHazInfo(xmlElementHaz, _ediFile, ediTIErrors, ediPreNote);
				endforeach;
				
				if ediPreNote.weight &gt; 0
				and ediPreNote.weightCertifiedName &lt;&gt; null
				and ediPreNote.weightCertifiedReference &lt;&gt; null
				then
					ediPreNote.setPropertyValue("isWeightCertified",true);
					ediPreNote.assignValueSpecial( ETRow_IsCertifiedWeight, "true", null );
				endif;
			
			endif;
			
			ediPreNote.setParserWarnings( ediTIErrors );
			
		endif;
		
	endif;

epilog

	// Create Event for the Ack to be sent
	if ediPreNote &lt;&gt; null and _ediFile.ediData &lt;&gt; null and _ediFile.ediData.ediConfig &lt;&gt; null then
		term := _ediFile.ediData.ediConfig.myTerminal;
		if term &lt;&gt; null then
			if not self.findEDIFileReceivedEvent(ediPreNote.id, _ediFile, term) then
				/*//17/02/2025	navkc1 JIRA Bug MTN-33582
				newEvent := app.createEvent(EVT_EDIFileReceived, app.actualTimeServer, term, app.myPassport.userCode, false, false, 0).CMEVT_EDIFileReceived;
				if newEvent &lt;&gt; null then
					newEvent.set(app.actualTimeServer, ediPreNote.getOidString(), self.type);
				endif;
				*/
				
				//17/02/2025	navkc1 JIRA Bug MTN-33582 - Starts
				create cmifEventCtrl transient;
				cmifEventCtrl.type := EVT_EDIFileReceived;
				cmifEventCtrl.dateTime := app.actualTimeServer();
				cmifEventCtrl.myTerminal := term;
				cmifEventCtrl.userCode := app.myPassport.userCode;
				cmifEventCtrl.dateTimeReceived := app.actualTimeServer();
				cmifEventCtrl.fileNumber := ediPreNote.getOidString();
				cmifEventCtrl.fileType := self.type;
				
				newEvent := app.createEventUsingCMIF(cmifEventCtrl).CMEVT_EDIFileReceived;
				//17/02/2025	navkc1 JIRA Bug MTN-33582 - Ends
				
			endif;
		endif;
	endif;

	delete xmlDoc;
	delete xmlElements;
	delete ediTIErrors;
	delete cmifEventCtrl; //17/02/2025	navkc1 JIRA Bug MTN-33582
end;</source>
        <access>protected</access>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processHazInfo" id="bff65091-a749-49ef-bcbe-dafeb58548ea">
        <source>processHazInfo(	_xmlElementHaz : JadeXMLElement;
				_ediFile: CM_EDIFile input;
				_ediTIErrors : HugeStringArray input;
				_ediPreNote : CM_EDIPrenoteTI input) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 August 2016	cnwndl1	Initial creation	TFS 2276 / 2565
// 08 May 2018	jlgrs1	TFS 36425 SingleLine Booking partial processing not working
// 08 Apr 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
*/
vars
	xmlSubElement : JadeXMLElement;
	str : String;
	dangerousGoods : CM_UNDangerousGoods;
	hazardObj : CM_HazardClass;
	ediHazDets : CM_EDIHazDetailsTI;	//31 Jan 2018	NDL	TFS 36824
	packingGroup : String;
begin
	//31 Jan 2018	NDL	TFS 36824 / TFS 36932
	xmlSubElement := null;
	xmlSubElement := _xmlElementHaz.getElementByTagName(self.TagPackingGroup);
	if xmlSubElement &lt;&gt; null then
		str := xmlSubElement.textData.trimBlanks;
		if str = null then
			self.addErrorMessEmptyTag( self.TagHazardousInfo, self.TagPackingGroup, _ediFile, _ediTIErrors );
		else
			packingGroup := str;
		endif;
	endif;

	xmlSubElement := null;
	xmlSubElement := _xmlElementHaz.getElementByTagName(self.TagUNDGNumber);
	if xmlSubElement = null then
		
		self.addErrorMessTagSetMissing( self.TagHazardousInfo, self.TagUNDGNumber, _ediFile, _ediTIErrors );
		
		//02 Feb 2018	NDL	TFS 36932 - to force an error during validation if UNDGNumber tag is completely missing and but other data is there
		xmlSubElement := _xmlElementHaz.getElementByTagName("IMDG_Class");
		if xmlSubElement &lt;&gt; null or packingGroup &lt;&gt; null then
			create ediHazDets;
			ediHazDets.setId(_ediPreNote.id);
			ediHazDets.setMyParent(_ediPreNote);
			ediHazDets.setMyEDIData(_ediPreNote.myEDIData);
			ediHazDets.packingGroup := str;
		endif;
		
	else
	
		//31 Jan 2018	NDL	TFS 36824
		create ediHazDets;
		ediHazDets.setId(_ediPreNote.id);
		ediHazDets.setMyParent( _ediPreNote );
		ediHazDets.setMyEDIData( _ediPreNote.myEDIData );
		ediHazDets.packingGroup := str;
					
		str := xmlSubElement.textData.trimBlanks;
		if str = null then
			self.addErrorMessEmptyTag( self.TagHazardousInfo, self.TagUNDGNumber, _ediFile, _ediTIErrors );
		else
			dangerousGoods := app.myRoot.allUNDangerousGoodsCodes[str].CM_UNDangerousGoods;
			if dangerousGoods = null then
				self.addErrorMessNoMatchingObj( "Dangerous Goods", self.TagHazardousInfo, self.TagUNDGNumber, str, _ediFile, _ediTIErrors );
			else
				ediHazDets.undgCodes := str;	//31 Jan 2018	NDL	TFS 36824
				hazardObj := dangerousGoods.myHazardClass;
				if hazardObj = null then
					_ediTIErrors.add ("No matching Hazard found for Dangerous Goods of '" &amp; str &amp; "' in JMT, &lt;" &amp; self.TagUNDGNumber &amp; "&gt;. " &amp; self.getIdStringFromFile(_ediFile));
				else
				//	_ediPreNote.setImCodes( hazardObj.code );
					ediHazDets.code := hazardObj.code;	//31 Jan 2018	NDL	TFS 36824	
				endif;
			endif;
		endif;
	endif;	
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_xmlElementHaz" type="JadeXMLElement"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_ediTIErrors" type="HugeStringArray" usage="input"/>
        <Parameter name="_ediPreNote" type="CM_EDIPrenoteTI" usage="input"/>
    </JadeMethod>
    <JadeMethod name="processMessageHeader" id="0b28dc14-cb00-40eb-ae5f-6a239e6ef686">
        <source>processMessageHeader(	_xmlElementMH : JadeXMLElement;
						_ediFile: CM_EDIFile input;
						_ediTIErrors : HugeStringArray input;
						_senderId : String output;
						_loadPort : String output;
						_action : String output;
						_docRef : String output;
						_sentTs : TimeStamp output
						):Boolean protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 August 2016	cnwndl1	Initial creation	TFS 2276 / 2565

*/

vars

	xmlSubElement : JadeXMLElement;
	str : String;
	sentDate : Date;
	sentTime : Time;

begin

	xmlSubElement := null;
	xmlSubElement := _xmlElementMH.getElementByTagName(self.TagEventType);
	if xmlSubElement = null then
		self.addErrorMessTagSetMissing( self.TagMessageHeader, self.TagEventType, _ediFile, null );
		return false;
	else
		if xmlSubElement.textData.trimBlanks &lt;&gt; "CONTAINERPREADVICE" then
			self.addFileErrors("&lt;" &amp;self.TagEventType&amp; "&gt; within the &lt;" &amp; self.TagMessageHeader &amp; "&gt; does not contain the value CONTAINERPREADVICE.", 1, _ediFile);
			return false;
		endif;
	endif;
	
	xmlSubElement := null;
	xmlSubElement := _xmlElementMH.getElementByTagName(self.TagDocumentRefNum);
	if xmlSubElement = null then
		self.addErrorMessTagSetMissing( self.TagMessageHeader, self.TagDocumentRefNum, _ediFile, _ediTIErrors );
	else
		_docRef := xmlSubElement.textData.trimBlanks;
	endif;
	
	_sentTs := app.actualTimeServer;
	xmlSubElement := null;
	xmlSubElement := _xmlElementMH.getElementByTagName(self.TagLocalDateTimeSent);
	if xmlSubElement = null then
		self.addErrorMessTagSetMissing( self.TagMessageHeader, self.TagLocalDateTimeSent, _ediFile, _ediTIErrors );
	else
		str := xmlSubElement.textData.trimBlanks;
		if str.length = 14 then
			sentDate.setDate( str[7:2].Integer, str[5:2].Integer, str[1:4].Integer);
			sentTime.setTime( str[9:2].Integer, str[11:2].Integer, str[13:2].Integer, 0);
			_sentTs.setDate(sentDate);
			_sentTs.setTime(sentTime);
		else
			_sentTs := app.actualTimeAppServer();
			_ediTIErrors.add("&lt;" &amp;self.TagLocalDateTimeSent&amp; "&gt; within the &lt;" &amp; self.TagMessageHeader &amp; "&gt; invalid format.");
		endif;
	endif;
	
	xmlSubElement := null;
	xmlSubElement := _xmlElementMH.getElementByTagName(self.TagSenderID);
	if xmlSubElement = null then
		self.addErrorMessTagSetMissing( self.TagMessageHeader, self.TagSenderID, _ediFile, _ediTIErrors );
	else
		_senderId := xmlSubElement.textData.trimBlanks;
		if _senderId = null then
			self.addErrorMessEmptyTag( self.TagMessageHeader, self.TagSenderID, _ediFile, _ediTIErrors );
		endif;
	endif;
	
	xmlSubElement := null;
	xmlSubElement := _xmlElementMH.getElementByTagName(self.TagRecipientID);
	if xmlSubElement = null then
		self.addErrorMessTagSetMissing( self.TagMessageHeader, self.TagRecipientID, _ediFile, _ediTIErrors );
	else
		_loadPort := xmlSubElement.textData.trimBlanks;
		if _loadPort = null then
			self.addErrorMessEmptyTag( self.TagMessageHeader, self.TagRecipientID, _ediFile, _ediTIErrors );
		endif;
	endif;
	
	xmlSubElement := null;
	xmlSubElement := _xmlElementMH.getElementByTagName(self.TagDocumentFunction);
	if xmlSubElement = null then
		self.addErrorMessTagSetMissing( self.TagMessageHeader, self.TagDocumentFunction, _ediFile, _ediTIErrors );
		_action := "A";
	else
		str := xmlSubElement.textData.trimBlanks;
		if str = null then
			self.addErrorMessEmptyTag( self.TagMessageHeader, self.TagDocumentFunction, _ediFile, _ediTIErrors );
			_action := "A";
		elseif str = "ORIGINAL" then	//Add, its a new one
			_action := "A";
		elseif str = "REPLACEMENT" then	//Update, its an update
			_action := "U";
		elseif str = "CANCELLATION" then	//Delete
			_action := "D";
		else
			_ediTIErrors.add("&lt;" &amp; self.TagDocumentFunction&amp; "&gt; tag value of '" &amp; str &amp; "' ( within the &lt;" &amp; self.TagMessageHeader &amp; "&gt;) is a not recognised value. ");
			_action := "A";
		endif;
	endif;
	
	return true;

epilog

end;</source>
        <access>protected</access>
        <Parameter name="_xmlElementMH" type="JadeXMLElement"/>
        <Parameter name="_ediFile" type="CM_EDIFile" usage="input"/>
        <Parameter name="_ediTIErrors" type="HugeStringArray" usage="input"/>
        <Parameter name="_senderId" type="String" usage="output"/>
        <Parameter name="_loadPort" type="String" usage="output"/>
        <Parameter name="_action" type="String" usage="output"/>
        <Parameter name="_docRef" type="String" usage="output"/>
        <Parameter name="_sentTs" type="TimeStamp" usage="output"/>
        <ReturnType type="Boolean"/>
