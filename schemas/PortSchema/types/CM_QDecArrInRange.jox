<Class name="CM_QDecArrInRange" id="50c2e6f1-fda4-487b-b90c-96dd08c691bd">
    <superclass name="CM_QueryDecimalOperator"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="query"/>
    <PrimAttribute name="lowerValue" id="364dfe65-fd66-40db-9d67-e0a0297d472d">
        <precision>14</precision>
        <scaleFactor>4</scaleFactor>
        <embedded/>
        <type name="Decimal"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="create" id="21ef9658-5d7d-4404-82e5-036bda0d27c9">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields

*/
vars

begin
	self.description := "in the range of";
end;</source>
    </JadeMethod>
    <JadeMethod name="doMatch" id="2d01f737-af9a-4498-9a9d-d6c0d16c4347">
        <source>doMatch(_value: DecimalArray): Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields

*/

vars
	decimalVal : Decimal[23,4];
begin
	foreach decimalVal in _value do
		if ((decimalVal.Decimal &gt;= self.lowerValue) and (decimalVal.Decimal &lt;= self.searchValue)) then
			return true;
		endif;
	endforeach;
	return false;

epilog

end;</source>
        <Parameter name="_value" type="DecimalArray"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getLowerValue" id="39ba68c4-ada7-4bea-a835-22f5c1315eca">
        <source>getLowerValue(_prop: CM_QueryProperty): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields

*/
vars

begin
	return _prop.translateToDisplayValue(self.lowerValue);
end;</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSearchValueRange" id="862baf21-5ae2-42b3-9bdd-d52dba242a3d">
        <source>getSearchValueRange(_prop : CM_QueryProperty): Any;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields

*/

vars
	weightRange : CM_WeightRange;
	measure : CM_MeasurementType;
	measureStr 	: String;
	pos : Integer;
begin
	pos := _prop.propertyName.pos(CN_UNDERSCORE, 1);
	if pos = null then
		return null;
	endif;
	
	measureStr := _prop.propertyName[1:pos-1];
	measure:=app.myRoot.allMeasurementTypesByShortName[measureStr];
	if measure &lt;&gt; null then
		weightRange:=app.myRoot.allWeightRanges[measure,self.searchValue.Integer];
	endif;
	
	return weightRange;
	

epilog

end;</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <ReturnType type="Any"/>
    </JadeMethod>
    <JadeMethod name="getSearchValueStr" id="7279d0c2-d90e-4e10-bd0d-4c840dcd0f42">
        <source>getSearchValueStr(_prop: CM_QueryProperty): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields

*/
vars
	measure	: String;																						

begin
	if CM_QDecimalProperty.hasInstance(_prop) and _prop.CM_QDecimalProperty.myMeasurementType &lt;&gt; null then
		measure := _prop.CM_QDecimalProperty.myMeasurementType.shortName;									
	endif;																									
	if measure &lt;&gt; null then																					
		return lowerValue.Integer.String &amp; "-" &amp; searchValue.Integer.String &amp; Space &amp; measure;				
	else																									
		return lowerValue.Integer.String &amp; "-" &amp; searchValue.Integer.String;
	endif;																								
end;</source>
        <Parameter name="_prop" type="CM_QueryProperty"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setLowerValue" id="d4a84879-0562-4714-aae4-719ab7dfb8c2">
        <updating/>
        <source>setLowerValue(_value: Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields

*/
vars
	stringValue		: String;
	decimalValue	: Decimal[14,4];
begin
	if _value &lt;&gt; null then 
		stringValue := _value.String;
		if stringValue.isDecimal then
			decimalValue := stringValue.Decimal;
		else
			app.raiseCMException1(VB_INVALID_NUM, stringValue, null, null);
		endif;		
	endif;
	
	self.lowerValue := decimalValue;
end;</source>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="setSearchValue" id="932a734f-f582-486e-90e2-b7a36ef3ec0d">
        <updating/>
        <source>setSearchValue(_value: Any) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 November 2023 navmv20 Bug 61113: FR | 54089 - EUP - Invoice contracts - Selector query - Missing fields

*/
vars
	stringValue		: String;
	decimalValue	: Decimal[14,4];
begin
	if _value &lt;&gt; null then
		stringValue := _value.CM_WeightRange.value.String;
		if stringValue.isDecimal then
			decimalValue := stringValue.Decimal;
			self.lowerValue := _value.CM_WeightRange.lower; //epr TFS 47132 - avoid 1086 exception
		else
			app.raiseCMException1(VB_INVALID_NUM, stringValue, null, null);
		endif;		
	endif;
	
	self.searchValue := decimalValue;
	
end;</source>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
</Class>
