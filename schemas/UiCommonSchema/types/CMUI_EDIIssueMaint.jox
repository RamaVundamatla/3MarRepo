        <source>getEDIFileTypeDisplay(_type : CM_EDIFileType) : String;
/*
Purpose:	

Date		Who		Reason
09 July 2024	navab1	CR 64617 TASK 64638
*/

vars
	gotException	: Boolean;
begin
	on Exception do app.handleDeletedObject (exception, _type, gotException);
	
	return _type.name;
epilog

end;</source>
        <Parameter name="_type" type="CM_EDIFileType"/>
        <ReturnType type="String"/>
