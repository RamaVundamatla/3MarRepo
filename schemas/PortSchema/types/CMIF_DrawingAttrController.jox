	_codesStr	:= _codesStr &amp; theCode &amp; GridData_SubDelimiter;
	_colourStr	:= _colourStr &amp; theColour.String &amp; GridData_SubDelimiter;
	_objStr		:= _objStr &amp; self.getOidStringForObject(theObject) &amp; GridData_SubDelimiter;
end;</source>
