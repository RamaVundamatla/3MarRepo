// -------------------------------------------
// Created 12 January 2006 by cnwdvb1
// -------------------------------------------
vars
	errorStr	: String;
	tandemTIid	: String;
	
begin
	if aMachineLiftType = TANDEM_LIFT then
		tandemTIid := self.txtContainerID2.text;
	endif;
	self.aWarnings := false;
	
	while true do
		if not app.myRTGuiAgent.setdownWithTask(self, tandemTIid, self.txtNewLocation.text.trimRight(), errorStr, self.aState, self.aWarnings) then
			if self.showMessage(errorStr, true) then
				continue;
