        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="locksPrintDeveloper" id="5459c8b5-b4af-4eba-a2dd-c5996a6bac49">
        <source>locksPrintDeveloper(_selectedOnly : Boolean) protected;
// ---------------------------------------------------------------------------
// Created:     15 October 2003 by cnwrs2
//
// Purpose:     Prints the selected data for developer
// ---------------------------------------------------------------------------
vars
	theReport 	: CMUI_LockTransactionReport;
	now			: TimeStamp;
	tmpReport 	: JadeReport;
	transArray	: CM_LockTransactionArray;
	numRows,
	idx			: Integer;
	jadeRow		: JadeTableRow;	
begin
	app.mousePointer := MousePointer_HourGlass;
	now := self.systemToLocalTime(app.actualTimeServer());	// 13/6/16 cnwmp6 TFS 488 - Multi timezone support
	
	create transArray transient;
	numRows := tblLocks.rows;
	
	// to this way so that we print out in the
	// same order as the data is currently displayed
	
	foreach idx in tblLocks.fixedRows + 1 to numRows do
		jadeRow := tblLocks.accessRow(idx);
		if _selectedOnly then
			if jadeRow.selected then
				transArray.add(jadeRow.itemObject.CM_LockTransaction);
			endif;
		else
			transArray.add(jadeRow.itemObject.CM_LockTransaction);
		endif;
	endforeach;
	
	create tmpReport transient;
	app.printer.printPreview := false;
	app.printer.setMargins(Print_Portrait,5,5,10,10);
	app.printer.topOfPage := 1;
	app.printer.bottomOfPage := 1;
	app.printer.setReport(tmpReport);

	create theReport transient;
	// setup header information
	theReport.picLogo.picture := app.getPicLogoPort; // The bitmap called rptlogo.bmp in reports/formats
	theReport.lblMainHeading.caption := 'Current Locks';
	theReport.lblPrintedBy.caption := app.getMyUserCode &amp; " - " &amp; now.date.String &amp; ", " &amp; now.time.format("H:mm").String;
	// set header
	app.printer.setHeader(theReport.frmHeader);
	app.printer.setFooter(null);
	theReport.printReport(transArray);

	app.printPreview(tmpReport, true);

epilog
	app.printer.close;
	app.mousePointer := MousePointer_Default;
	delete theReport;
	delete transArray;
end;</source>
        <access>protected</access>
        <Parameter name="_selectedOnly" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="locksTableInit" id="90f9ecc3-1824-4ff8-a1b4-4c5f0c9a456e">
        <source>locksTableInit() protected;
// ---------------------------------------------------------------------------
// Created:		June  2002 By Andrew Bishop cnwab1
//
// Purpose:		
// ---------------------------------------------------------------------------
vars
	tmpTbl	: CM_DataTable;
begin

	tmpTbl := self.tblLocks;

	//tmpTbl.selectionType := CM_BaseTable.SelectionType_Row;
	//tmpTbl.selectMode := Table.SelectMode_WholeRows;
	tmpTbl.selectMode	:= Table.SelectMode_WholeRows;
	
	tmpTbl.autoSize	:= Table.AutoSize_Column;
	
	if self.isDeveloper then
		tmpTbl.multiSelect := CM_DataTable.MultiSelect_Simple;
	endif;
	
	tmpTbl.left := 0;
	tmpTbl.stretchWidth := true;
	tmpTbl.stretchHeight	:= true;
	tmpTbl.setColumnHeadingsFromDef(ETDef_Locks, false);
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setColorsFromController" id="2ec33774-fb95-4cb2-9624-de9d44c2c713">
        <updating/>
        <source>setColorsFromController(_colorControl: CM_ColorController) updating;
// ---------------------------------------------------------------------------
// Created:     11 August 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin
	inheritMethod(_colorControl);
	
	self.tblLocks.backColor := self.colorControlBack;
	self.tblLocks.accessRow(1).backColor := self.colorHeadingColumn;
	
	self.graphColor1	:= Blue;
	self.graphColor2	:= LightGreen;

end;</source>
        <Parameter name="_colorControl" type="CM_ColorController"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="37526e78-28b3-4597-916d-f3a5ea99fd06">
        <updating/>
        <source>setupForm() updating;

begin
	self.setNavigatorHeading(self.caption); 
	self.lblPrint.visible := false;
	self.frmPrint.visible := false;

	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.showToolbar := true;
	self.frmToolbar.priorityRight := true;
	
	self.fldMain.useSheetBackColors := true;
	self.fldMain.setDefaultSheetBackColors();
	self.fldMain.initSheetBackColors();
	
	self.locksTableInit();
	
	self.doResize();
end;</source>
    </JadeMethod>
    <JadeMethod name="tblLocks_dblClick" id="fb9b662f-6c90-40a5-80eb-27b12fcd2579">
        <controlMethod name="CM_DataTable::dblClick"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>tblLocks_dblClick(table: CM_DataTable input) updating;
// ---------------------------------------------------------------------------
// Created:     15 October 2003 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars
	theRow	: Integer;
	
begin

	theRow := table.row;
	if theRow = 1 then
		table.resortTableByColumn(table.column);
	endif;

end;</source>
        <Parameter name="table" type="CM_DataTable" usage="input"/>
    </JadeMethod>
    <JadeMethod name="translateForm" id="40438b2b-1bef-4074-8d00-7273cbea3df0">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0008189, locale);
	btnPerfOpts.translateBubbleHelp(Xlat_0001007, locale);
	btnPerfOpts.translateCaption(Xlat_0001008, locale);
	btnPrint.translateBubbleHelp(Xlat_0001013, locale);
	btnPrint.translateCaption(Xlat_0001014, locale);
	btnRefresh.translateBubbleHelp(Xlat_0001009, locale);
	btnRefresh.translateCaption(Xlat_0001010, locale);
	btnSample.translateBubbleHelp(Xlat_0001011, locale);
	btnSample.translateCaption(Xlat_0001012, locale);
	frmPrint.translateCaption(Xlat_0001015, locale);
	lblPrint.translateCaption(Xlat_0001016, locale);
	shtLocks.translateCaption(Xlat_0001017, locale);
	shtPerf.translateCaption(Xlat_0001018, locale);
end;</source>
    </JadeMethod>
