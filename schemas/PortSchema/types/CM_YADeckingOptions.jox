    <JadeMethod name="applyDeckingRulesToCellOrder" id="e5f672ba-a28f-4e96-989d-1f4bf24f97aa">
        <source>applyDeckingRulesToCellOrder();
//----------------------------------------------------------------
//	Created:	26 April 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
begin

	
	if self.inOptionType = DeckingRule_Custom then
		if self.allYALocationCellsIn.isEmpty then
			//something has gone wrong since validation
			app.raiseUnexpectedProgramError(class.name, method.name, 'invalid custom In decking setup');	
		endif;
	endif;
	
	if self.outOptionType = DeckingRule_Custom then
		if self.allYALocationCellsOut.isEmpty then
			//something has gone wrong since validation
			app.raiseUnexpectedProgramError(class.name, method.name, 'invalid custom Out decking setup');	
		endif;
	endif;

end;</source>
    </JadeMethod>
    <JadeMethod name="copyInRules" id="579bec50-1812-408a-a387-f686bfe196b2">
        <updating/>
        <source>copyInRules(_copyFrom: CM_YADeckingOptions) updating;
//----------------------------------------------------------------
//	Created:	07 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tmpRule,
	pxyRule		: CM_YADeckingRule;
	locnCell	: CM_YALocationCell;
	tmpCellArray: CM_YALocationCellArray;
	int			: Integer;
begin

	self.showHeightsForCustom := _copyFrom.showHeightsForCustom;
	self.useReverseOfIn := _copyFrom.useReverseOfIn;

	create tmpCellArray transient;
	//IN
	foreach tmpRule in _copyFrom.allDeckingRulesIn do
		create pxyRule transient;
		self.allDeckingRulesIn.add(pxyRule);
		pxyRule.setProxyFromOtherRule(tmpRule);
	endforeach;

	//IN CELL ORDER
	foreach locnCell in _copyFrom.allYALocationCellsIn do
		if self.allYALocationCellsIn.includes(locnCell) then
			tmpCellArray.add(locnCell);
		endif;	
	endforeach;
	self.allYALocationCellsIn.clear;
	tmpCellArray.copy(self.allYALocationCellsIn);

epilog
	delete tmpCellArray;
end;</source>
        <Parameter name="_copyFrom" type="CM_YADeckingOptions"/>
    </JadeMethod>
    <JadeMethod name="copyOutRules" id="bd515ef8-a355-47d8-bbb7-6281e8000b25">
        <source>copyOutRules(_copyFrom: CM_YADeckingOptions);
//----------------------------------------------------------------
//	Created:	07 June 2005	by Jason Chapman  (cnwjc2)
//----------------------------------------------------------------
vars
	tmpRule,
	pxyRule		: CM_YADeckingRule;
	locnCell	: CM_YALocationCell;
	tmpCellArray: CM_YALocationCellArray;
begin

	create tmpCellArray transient;

	//OUT
	foreach tmpRule in _copyFrom.allDeckingRulesOut do
		create pxyRule transient;
		self.allDeckingRulesOut.add(pxyRule);
		pxyRule.setProxyFromOtherRule(tmpRule);
	endforeach;

	//OUT CELL ORDER
	foreach locnCell in _copyFrom.allYALocationCellsOut do
		if self.allYALocationCellsOut.includes(locnCell) then
			tmpCellArray.add(locnCell);
		endif;	
	endforeach;
	self.allYALocationCellsOut.clear;
	tmpCellArray.copy(self.allYALocationCellsOut);

epilog
	delete tmpCellArray;
end;</source>
        <Parameter name="_copyFrom" type="CM_YADeckingOptions"/>
    </JadeMethod>
    <JadeMethod name="getAdvancedRule" id="b4adb99f-d898-4f8b-988d-4e9f77753f37">
        <source>getAdvancedRule(_direction: Integer): CM_YADeckingRule;
//12 January 2009	cnwdw1	
//
vars

begin

	if _direction = DeckingDirectionIn then
		if self.inOptionType &lt;&gt; DeckingRule_Advanced then
			return null;
		endif;
		return self.allDeckingRulesIn.first;
	endif;
	if _direction = DeckingDirectionOut then
		if self.outOptionType &lt;&gt; DeckingRule_Advanced then
			return null;
		endif;
		return self.allDeckingRulesOut.first;	
	endif;	

	return null;
end;</source>
        <Parameter name="_direction" type="Integer"/>
        <ReturnType type="CM_YADeckingRule"/>
    </JadeMethod>
