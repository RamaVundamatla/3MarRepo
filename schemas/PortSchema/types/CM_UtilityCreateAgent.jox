/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
27 April 2012	cnwndl1	Initial creation	Par 29496

*/

vars
	newPilotExempt	:HMS_PilotExemptionCertificate;
begin
	self.initialiseActivity();

	app.setContinueCMExceptions(true);
	
	app.myValCA.valCM_Object(_proxy, _passport);
	
	if not self.checkValidationWithPassport(_passport) then
		return null;
	endif;
	
	app.setContinueCMExceptions(false);
	
	create newPilotExempt persistent;
	
	newPilotExempt.setForCreate (_proxy, _passport);
	
	if _passport.noErrors then
		self.myCreateAuditAgent.audCreateGeneric(newPilotExempt);
	endif;	

	return newPilotExempt;
epilog

end;</source>
