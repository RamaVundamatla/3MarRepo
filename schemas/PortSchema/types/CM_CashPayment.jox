    <JadeMethod name="getPaidProformaDesc" id="f3963e04-673b-4ff2-8f90-a080a127ea0b">
        <source>getPaidProformaDesc() : String;
// 34990
vars

	proformaDescArray : StringArray512;	//14 July 2015	NDL	Par 36482
	proformaLine : String;
	paidDesc	: String;
	startIndex : Integer;
	desc	 : String;

begin

	if not self.isProformaPayment then
		return null;
	endif;
	
	//get an array of the various lines..
	create proformaDescArray transient;
	self.getTokensForDelimiter( self.proformaDesc, self.ProformaLineSep, proformaDescArray );
	
	foreach proformaLine in proformaDescArray do
		if proformaLine &lt;&gt; null then
			startIndex := 1;
			desc := proformaLine.scanUntil(self.ProformaDescAndValueSep, startIndex);
			if paidDesc = null then
				paidDesc := desc;
			else
				paidDesc := paidDesc &amp; ", " &amp; desc;
			endif;
		endif;
	endforeach;
	
	return paidDesc;
	
epilog

	delete proformaDescArray;

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPaymentCheckBox" id="e9f4ed3e-244c-4ab0-8f07-e11921bdd35b">
        <source>getPaymentCheckBox(_queryCashReceipt : CM_CashReceipt ; _isInvoiceProforma : Boolean):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Feb 2020 cnwma1  Bug 48511: JMT - Duplicate Narration for Manual Cash Payment on Cash Collection Screen

*/

vars
	checkboxvalue : String;
begin
	// ### EXTRA EXTRA
	if self.manual then
		if _queryCashReceipt &lt;&gt; null then
			checkboxvalue := "";
		else
			checkboxvalue := (self.status = 0).Integer.String;
		endif;
					
		
	// ### INVOICED INVOICED
	elseif self.myInvoiceLine &lt;&gt; null then
		if self.pxyIsProxy() then // this is a pxy for a real cash payment
			checkboxvalue := "0";
		elseif _queryCashReceipt &lt;&gt; null or _isInvoiceProforma then
			checkboxvalue := "";
		else
			checkboxvalue := (self.status = 0).Integer.String;  //self.StatusSelected=0
		endif;
		
	
	// ### ESTIMATE
	else

		
		if _queryCashReceipt &lt;&gt; null or _isInvoiceProforma then
			checkboxvalue := "";
		else
			checkboxvalue := (self.status = 0).Integer.String;
		endif;
	endif;
	
	return checkboxvalue;
epilog

end;</source>
        <Parameter name="_queryCashReceipt" type="CM_CashReceipt"/>
        <Parameter name="_isInvoiceProforma" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getPaymentNarration" id="92c94e1b-780d-426b-be3f-8968faeb1688">
        <source>getPaymentNarration(_includeCredit      : Boolean;
					_includePrevReceipt : Boolean):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 Feb 2020 cnwma1  Bug 48511: JMT - Duplicate Narration for Manual Cash Payment on Cash Collection Screen

*/

vars
	creditOnPayment,
	creditOnPaymentTax : Decimal[23,6];
	str,
	creditStr,
	remarks,
	qty,         
	narration   	   : String;
	realCashPayment    : CM_CashPayment;
	invLineDesc 	   : CM_InvoiceLineDesc;

begin
	
	//Check if credit exist on payment and Tax
	creditOnPayment := self.getCreditOnPayment();
	if creditOnPayment &lt;&gt; 0 then
		creditOnPaymentTax := self.getCreditOnPaymentTax();
		creditStr := " (" &amp; app.getErrorString(Credit) &amp; ' ' &amp; (creditOnPayment+creditOnPaymentTax).asStringJMTWithPrecision(2,true) &amp;  ")";
	endif;
	
	if self.myInvoiceLine &lt;&gt; null then 
		invLineDesc := self.myInvoiceLine.invoiceLineDesc;
		qty         := self.myInvoiceLine.quantity.asStringJMTWithPrecision(2,true).asStringJMT;
		remarks     := self.myInvoiceLine.remarks;
		narration   := invLineDesc.narration;
		
	elseif self.myProformaDetail &lt;&gt; null then 
		invLineDesc :=	self.myProformaDetail.myInvoiceLineType;
		qty         :=  self.myProformaDetail.quantity.asStringJMTWithPrecision(2,true).asStringJMT;
		narration   :=  invLineDesc.narration;
	
	endif;
	
	if self.manual then
		if remarks &lt;&gt; null then
			if self.proformaDesc &lt;&gt; remarks then
				str := narration &amp; " x " &amp; qty &amp; " (" &amp; remarks.replace(self.proformaDesc,"") &amp;")";	
				if str[str.length-2]= "-" then
					str := str.truncatedAt(str.length-4) &amp;")";
				endif;
			else
				str := narration &amp; " x " &amp; qty;
			endif;
		else
			str := narration &amp; " x " &amp; qty;
		endif;
	else 	
		str := narration &amp; " x " &amp; qty.asStringJMT();
	
	endif;
	
	if _includePrevReceipt then
		if self.pxyIsProxy then  
				realCashPayment := self.pxyGetRealObject().CM_CashPayment;
				if realCashPayment &lt;&gt; null then
					str := str &amp; " (" &amp; realCashPayment.myCashReceipt.getExternalInvoiceNumber() &amp;")";
				endif;
			endif;
	endif;
	
	if _includeCredit then
		if creditStr &lt;&gt; null then
			str := str &amp; creditStr;
		endif;
	endif;
	
	return str;
epilog

end;</source>
        <Parameter name="_includeCredit" type="Boolean"/>
        <Parameter name="_includePrevReceipt" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
