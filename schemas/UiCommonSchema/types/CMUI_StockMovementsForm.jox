    <JadeMethod name="doPrint" id="6096c4dd-c78e-4401-afad-02cb071e4769">
        <source>doPrint();
// ---------------------------------------------------------------------------
// Created:     31 July 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//// 20 May 2016	cnwns1	TFS 488 - Multi Timezone Support
// ---------------------------------------------------------------------------
vars
	blnIsData	: Boolean;
	genPrint	: CM_GenericTablePrint;
	pd			: CMS_Progress;
	heading1,
	heading2	: String;
	now			: TimeStamp;
	tmpSheet	: JadeTableSheet;
	intTopSheet	: Integer;
	jadeReport	: JadeReport;
begin

// 	Par 9771 error being caused when print button clicked and no info in table. Diff tables are used depending on what options have been chosen. 
	intTopSheet := self.tblData.topSheet;

	now := self.systemToLocalTime(app.actualTimeServer);// 20 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	if intTopSheet = TblDataSheet_ItemDetail or intTopSheet = TblDataSheet_SOHFixups or intTopSheet = TblDataSheet_ValidateTotals then
		tmpSheet := tblData.accessSheet(intTopSheet);		
		if tmpSheet.rows &gt; 1 then 
			blnIsData := true;
		endif;
	else 
		if self.tblData.rows &gt; 2 then
			blnIsData := true;
		endif;
	endif;

	if not blnIsData then
//	if self.tblData.rows &lt;= 1 then   /// old code ****
		app.msgBox('There is no data to view','No data',0);
		return;
	endif;

	app.mousePointer := MP_HOURGLASS;
	app.printer.printPreview := false;
	
	app.printer.suppressDialog := true;
	
	create jadeReport transient;
	create genPrint;
	create pd;
	
	app.printer.setReport(jadeReport);
	
	pd.show;
	pd.raiseExceptionOnAbort := false;
	
	
	pd.setAction("Printing stock movements query");
	//app.printer.setMargins(Print_Portrait,10,10,0,0);
	pd.progress.partsInJob := tblData.rows - 1;
	
	// set header
	genPrint.frHeader.width := app.printer.pageWidth;
	self.assignQueryHeadings(heading1, heading2);
	
	genPrint.setHeaders(heading1, heading2);
	
	app.printer.setHeader(genPrint.frHeader);

	// set footer
	genPrint.frFooter.width := app.printer.pageWidth;
	genPrint.lblTheUser.caption := app.getMyUserCode;
	genPrint.lblTheDatePrinted.caption := now.String;
	app.printer.setFooter(genPrint.frFooter);
	
	genPrint.printTable(tblData, false, pd);
	
	if pd.aborted then
		app.printer.abort;
		return;
	endif;
	pd.unloadForm;

	app.printPreview(jadeReport, true);

epilog
	app.printer.close;
	delete pd;
	delete genPrint;
	app.mousePointer := MP_DEFAULT;

end;</source>
    </JadeMethod>
