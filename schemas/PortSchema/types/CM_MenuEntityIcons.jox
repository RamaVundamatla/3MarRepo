    <JadeMethod name="saveJust1Picture" id="d24bf3e9-7bb5-4e63-8e3c-40f4f4c259aa">
        <source>saveJust1Picture();
/*
Purpose:			

Date		Who		Reason
22 October 2021	navab1	TFS 51853
*/

vars
	root : CM_Root;
	navPicture : CM_MenuEntityPicture;
	hasIssue : Boolean;
begin
	root := CM_Root.firstInstance;

	navPicture := self.picEDIIssues;
	
	if navPicture.tag = "" then
		global.beep;
		app.msgBox(navPicture.name &amp; "(" &amp; navPicture.description &amp; ") does not  have a value in the 'tag' attribute", "ISSUE", MsgBox_OK_Only);
		hasIssue := true;
	elseif navPicture.hyperlink = "" then
		global.beep;
		app.msgBox(navPicture.name &amp; "(" &amp; navPicture.description &amp; ") does not  have a value in the 'hyperlink' attribute", "ISSUE", MsgBox_OK_Only);
		hasIssue := true;
	elseif navPicture.helpKeyword = "" then
		global.beep;
		app.msgBox(navPicture.name &amp; "(" &amp; navPicture.description &amp; ") does not  have a value in the 'helpKeyword' attribute", "ISSUE", MsgBox_OK_Only);
		hasIssue := true;
	endif;	

	// ### UPDATE	
	if not hasIssue then
		beginTransaction;
		navPicture.savePictureToDatabase(root);
		commitTransaction;
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="savePicturesToDatabase" id="afbd1cbb-0724-43be-9df1-98efd06ded99">
        <source>savePicturesToDatabase(_check : Boolean);
/*
Purpose:			

Date		Who		Reason
11 October 2021	navab1	TFS 51853
*/

vars
	root : CM_Root;
	navPicture : CM_MenuEntityPicture;
	idx : Integer;
	iter01 : Iterator;
	oArray : ObjectArray; 
	schemaName, uniqueName : String;
	hasIssue : Boolean;
begin
	root := CM_Root.firstInstance;

	create oArray transient;
	CM_MenuEntityPicture.allInstances(oArray,0,false);
	iter01 := oArray.createIterator;
	
	// ### VALIDATE
	
	if _check then
		while iter01.next(navPicture) do
			if navPicture.enabled = false then
				continue; // ignore. 
			endif;
			if navPicture.tag = "" then
				global.beep;
				app.msgBox(navPicture.name &amp; "(" &amp; navPicture.description &amp; ") does not  have a value in the 'tag' attribute", "ISSUE", MsgBox_OK_Only);
				hasIssue := true;
				break;
			elseif navPicture.hyperlink = "" then
				global.beep;
				app.msgBox(navPicture.name &amp; "(" &amp; navPicture.description &amp; ") does not  have a value in the 'hyperlink' attribute", "ISSUE", MsgBox_OK_Only);
				hasIssue := true;
				break;
			elseif navPicture.helpKeyword = "" then
				global.beep;
				app.msgBox(navPicture.name &amp; "(" &amp; navPicture.description &amp; ") does not  have a value in the 'helpKeyword' attribute", "ISSUE", MsgBox_OK_Only);
				hasIssue := true;
				break;
			elseif navPicture.bubbleHelp = "" then
				global.beep;
				app.msgBox(navPicture.name &amp; "(" &amp; navPicture.description &amp; ") does not  have a value in the 'bubbleHelp' attribute", "ISSUE", MsgBox_OK_Only);
				hasIssue := true;
				break;
			elseif navPicture.description = "" then
				global.beep;
				app.msgBox(navPicture.name &amp; "(" &amp; navPicture.description &amp; ") does not  have a value in the 'description' attribute", "ISSUE", MsgBox_OK_Only);
				hasIssue := true;
				break;
			endif;	
		endwhile;
	endif;
	
	iter01.startAtIndex(1);
	
	// ### UPDATE	
	if not hasIssue then
		beginTransaction;
		while iter01.next(navPicture) do
			if navPicture.enabled = false then
				continue; // ignore. 
			endif;
			navPicture.savePictureToDatabase(root);
		endwhile;
		commitTransaction;
	endif;
epilog

end;</source>
        <Parameter name="_check" type="Boolean"/>
    </JadeMethod>
</GUIClass>
