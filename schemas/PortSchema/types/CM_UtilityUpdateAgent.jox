    <JadeMethod name="utlUpdateBackup" id="fa5ee152-4ace-450a-8fe0-861958638568">
        <source>utlUpdateBackup(_proxyBackup:CM_Backup; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:     Aug 2004 by cnwrs1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------
vars
	cancelSave:Boolean;
	realBackup:CM_Backup;
	expectedEdition:Integer;
	
begin

	self.initialiseActivity();

	_proxyBackup.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_proxyBackup.pxyGetRealObjectAndEdition(realBackup, expectedEdition);
	
	if realBackup = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Backup.name, null, null);
		return;
	endif;

	app.myValUA.valBackup(realBackup, _proxyBackup);
	
	if (not self.checkValidationWithPassport(_passport)) then
		return;		// note that this gets "ignored" in the eplog
	endif;


	app.setContinueCMExceptions(false);

	exclusiveLock(realBackup);

	if _passport.noErrors and realBackup.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Backup', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realBackup, true);
	endif;
	
	if _passport.noErrors then
		realBackup.setForUpdate(_proxyBackup);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realBackup, false);
	endif;

epilog
	
	
end;</source>
        <Parameter name="_proxyBackup" type="CM_Backup"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateBank" id="bb537046-3bc7-4a9f-8d0e-164587381814">
        <source>utlUpdateBank(_theController : CMIF_BankDetails; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	proxyBank, realBank	: CM_Bank;
	expectedEdition	: Integer;
	
begin

	self.initialiseActivity();
	proxyBank := _theController.myProxyBank;
	proxyBank.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	proxyBank.pxyGetRealObjectAndEdition(realBank, expectedEdition);
	
	if realBank = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Bank.name, null, null);
		return;
	endif;

	app.myValUA.valBank(realBank, proxyBank);
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realBank);

	if _passport.noErrors and realBank.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'Bank', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realBank, true);
	endif;
	
	if _passport.noErrors then
		realBank.setForUpdate(_theController);
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realBank, false);
	endif;
	if _passport.noErrors then
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_COMPANY_UPDATE),false,realBank);
	endif;

end;</source>
        <Parameter name="_theController" type="CMIF_BankDetails"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateBankProforma" id="b2b8c259-c1ff-42e3-912d-a84d4ca31120">
        <source>utlUpdateBankProforma(_realBank : CM_Bank io; _critTypes : StringArray input; _hasDifferentCritAttr : Boolean; _passport : CM_Passport input);

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
23 July 2012	cnwndl1	Initial creation

*/

vars

begin

	self.initialiseActivity();
	
	app.setContinueCMExceptions(false);

	exclusiveLock(_realBank);
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_realBank, true);
	endif;
	
	if _passport.noErrors then
		_realBank.setSelectedProformaCriteria( _critTypes );
	endif;
	
	//22/01/2025	navkc1 JIRA Bug MTN-33836
	if _passport.noErrors() and _hasDifferentCritAttr then
		self.utlUpdateProformaCriteriaAttr(_realBank.allProformaCriteria, _critTypes, _passport);
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(_realBank, false);
	endif;

epilog

end;</source>
        <Parameter name="_realBank" type="CM_Bank" usage="io"/>
        <Parameter name="_critTypes" type="StringArray" usage="input"/>
        <Parameter name="_hasDifferentCritAttr" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateBankSuspenders" id="c53ccdd0-fdad-46b9-9540-e912e1540c55">
        <source>utlUpdateBankSuspenders(_pxyBank : CM_Bank; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	realBankNode:CM_Bank;
	expectedEdition:Integer;
	codeChanged:Boolean;
	eventStr : String;
	theTerminal : CM_Terminal;
	
begin

	self.initialiseActivity();
	_pxyBank.raiseExceptionIfNotProxy(method);

	app.setContinueCMExceptions(true);

	_pxyBank.pxyGetRealObjectAndEdition(realBankNode, expectedEdition);
	
	if realBankNode = null then	
		app.raiseCMException1(ProxyMgrCannotLocateReal, CM_Bank.name, null, null);
		return;
	endif;

	//app.myValUA.valBankNode(realBankNode, _pxyBank);
	app.myValUA.valBank(realBankNode, _pxyBank);	//24 Apr 2012	NDL	Par 29393
	
	
	if not self.checkValidationWithPassport(_passport) then
		return;
	endif;
	
	app.setContinueCMExceptions(false);

	exclusiveLock(realBankNode);

	if _passport.noErrors and realBankNode.edition &lt;&gt; expectedEdition then
		app.raiseCMException1(ObjectUpdatedByAnotherUserSave, 'BankNode', null, null);
		return;
	endif;
	
	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realBankNode, true);
	endif;
	
	if _passport.noErrors then
		if _pxyBank.isSuspended then
			realBankNode.suspend(_passport.myTerminal);
		else
			realBankNode.reinstate(_passport.myTerminal,false);
		endif;
	endif;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realBankNode, false);
	endif;
	if _passport.noErrors then
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_COMPANY_UPDATE),false,realBankNode);
	endif;

end;</source>
        <Parameter name="_pxyBank" type="CM_Bank"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="utlUpdateBankTMActive" id="dab1fa3e-68fd-48a6-b3c9-26a4b7803b68">
        <source>utlUpdateBankTMActive(_theTM : CM_TranMap; _passport : CM_Passport input);
// ---------------------------------------------------------------------------
// Created:		February 2005 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	realBankNode:CM_Bank;
	expectedEdition:Integer;
	codeChanged:Boolean;
	eventStr : String;
	theTerminal : CM_Terminal;
	theInactive : CM_TranMap;
begin

	self.initialiseActivity();
	
	realBankNode := _theTM.bank;
	theInactive := realBankNode.currentTransactionMap;
	_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_UPDATE),false,_theTM);
	
	exclusiveLock(realBankNode);

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realBankNode, true);
	endif;
	realBankNode.currentTransactionMap := _theTM;

	if _passport.noErrors then
		self.myUpdateAuditAgent.audUpdateGeneric(realBankNode, false);
	endif;
	if _passport.noErrors then
		_passport.myTerminal.causeEvent(_passport.myTerminal.getTerminalEvent(EVENT_TRANSACTIONMAP_UPDATE),false,theInactive);
	endif;

end;</source>
        <Parameter name="_theTM" type="CM_TranMap"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
