    <JadeMethod name="updateMSKCodecoPackUnpack" id="ed876c0f-d198-47f1-9ec3-60f590c837a0">
        <source>updateMSKCodecoPackUnpack(_controller: CnEcReleaseController);
//
//26 July 2017	jlgrs1	TFS 4465 SNO standard Codeco
//
vars
	camProtocol : CM_CamProtocol;
begin
	if self.hasScriptBeenRunAtAll(method.name, _controller) then
		return;
	endif;
	app.writeLog(method.qualifiedName &amp; " update MSK Cams Codeco Pack Unpack", LogINFO);
	foreach camProtocol in CM_CamProtocol.instances do
		if camProtocol.protocolDesc.isKindOf(CM_CamMskCODECODesc) and
		   (camProtocol.registeredTransactions.includes(TRANS_TYPE_PACK.asStringJMT()) or 
			camProtocol.registeredTransactions.includes(TRANS_TYPE_PackComplete.asStringJMT()) or 
			camProtocol.registeredTransactions.includes(TRANS_TYPE_UNPACK.asStringJMT()) or 
			camProtocol.registeredTransactions.includes(TRANS_TYPE_UnpackComplete.asStringJMT())) then
			app.writeLog(method.qualifiedName&amp;' camProtocol='&amp;camProtocol.String&amp;' description='&amp;camProtocol.description&amp;' protocolDesc='&amp;camProtocol.protocolDesc.String, LogINFO);
			beginTransaction;
			camProtocol.setPackUnpackStatusChange(true);
			commitTransaction;
		endif;
	endforeach;
	app.writeLog(method.qualifiedName &amp; " update MSK Cams Codeco Pack Unpack - Completed", LogINFO);
	self.addScriptRun(method.name);
epilog

end;</source>
