    <JadeMethod name="getGateAndChanel" id="d1930e1f-fb2f-44c8-8196-a32b82e81ba7">
        <source>getGateAndChanel(_gate : Integer io; _chanel : Integer io; _btn : Button input);

vars

begin
	// ### IN
	if self.optIn1.value then
		_gate := 1;
		_chanel := self.getChanel(_btn, true);
	elseif self.optIn2.value then
		_gate := 2;
		_chanel := self.getChanel(_btn, false);
	elseif self.optIn3.value then
		_gate := 3;
		_chanel := self.getChanel(_btn, true);
	elseif self.optIn4.value then
		_gate := 4;
		_chanel := self.getChanel(_btn, true);
	elseif self.optIn5.value then
		_gate := 5;
		_chanel := self.getChanel(_btn, true);
	elseif self.optIn6.value then
		_gate := 6;
		_chanel := self.getChanel(_btn, true);
	elseif self.optIn7.value then
		_gate := 7;
		_chanel := self.getChanel(_btn, true);
	elseif self.optIn8.value then
		_gate := 8;
		_chanel := self.getChanel(_btn, true);
		
	// ### OUT
	elseif self.optOut3.value then
		_gate := 3;
		_chanel := self.getChanel(_btn, false);
	elseif self.optOut4.value then
		_gate := 4;
		_chanel := self.getChanel(_btn, false);
	elseif self.optOut5.value then
		_gate := 5;
		_chanel := self.getChanel(_btn, false);
	elseif self.optOut6.value then
		_gate := 6;
		_chanel := self.getChanel(_btn, false);
	elseif self.optOut7.value then
		_gate := 7;
		//epr 6/9/07 updated after email from micheal peirce gate lanes 7 &amp; 8 share an adam device so lane 7 has 3 for open
		_chanel := self.getChanel(_btn, true);
	elseif self.optOut8.value then
		_gate := 8;
		_chanel := self.getChanel(_btn, false);
	endif;
end;
</source>
        <Parameter name="_gate" type="Integer" usage="io"/>
        <Parameter name="_chanel" type="Integer" usage="io"/>
        <Parameter name="_btn" type="Button" usage="input"/>
    </JadeMethod>
