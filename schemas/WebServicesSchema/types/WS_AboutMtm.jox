    <JadeMethod name="convertTimezone" id="82cfe8aa-3074-4c37-9fde-9662e0bd05cf">
        <updating/>
        <source>convertTimezone() updating;
/*

Purpose:			Sets the JMT Build time based on the servers timezone

Parameters:			

Return Value:		

Date				Who		Reason
29 November 2019	jlgmd1	Initial creation TFS 47471

*/

vars

begin
	self.jmtBuild := self.getJMTBuildTime(true);
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getJMTBuildTime" id="2a1b09ec-0daf-4956-acbf-723e86105f6a">
        <source>getJMTBuildTime(_convert : Boolean) : String protected;
/*

Purpose:			Moved from WS_AboutMtm::setDetails

Parameters:			

Return Value:		

Date				Who		Reason
29 November 2019	jlgmd1	Initial creation TFS 47471

*/

constants
	NZST : String = "New Zealand Standard Time";
vars

begin
	if not _convert then
		// For the non-react .net apps and REST web services
		return app.getJMTReleaseExtractTime.asStringForWebInterface();		// TFS 38923 jlger1 30/05/2018
	else
		// For the react .net apps (Webportal and Tallyman at this stage)
		return app.getJMTReleaseExtractTime.localToSystemTime(NZST).asStringForWebInterface();
	endif;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_convert" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setDetails" id="8c9bc22e-1721-4050-9eb9-368cbb6eddf8">
        <updating/>
        <source>setDetails() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
30 November 2016	cnwsc8	Initial creation
29 November 2019	jlgmd1	TFS 47471 - Moved setting jmtBuild to its own method

*/

vars
begin
	
	
	self.appName 		:= app.niceName;
	if self.appName = null then
		self.appName:=app.name;
	endif;
	
	self.copyright 		:= app.getCopyrightNotice();
	self.userName 		:= app.getMyUserName();
	self.systemMode 	:= app.myRoot.getSystemModeDesc;
	
	self.jmtBuild		:= self.getJMTBuildTime(false);
	self.jmtVersion 	:= app.myRoot.getVersionAndPatchLevelDisplay();

epilog

end;</source>
    </JadeMethod>
</Class>
