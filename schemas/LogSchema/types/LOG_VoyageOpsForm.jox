    <JadeMethod name="currentView" id="ac81493a-e89f-4504-9419-14fac3f22864">
        <updating/>
        <source>currentView() updating;

vars

begin
	self.modeView := self.viewMode;
	self.setMode(self.viewMode);
	
	// CCMS 1124
	self.tblArchiveSearch.visible := false; 
	self.btnArchiveSearch.visible := false;
	
	self.setEnableObjects();	
	self.listsTreeViewLoadAll();
	if self.fldTreeView.topSheet = self.shtListSuppliers then		
		self.listTreeViewChange(lstSuppliers);
	else
