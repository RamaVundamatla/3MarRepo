    <JadeMethod name="canTwinLift" id="82c25ab9-bc19-4270-a728-e73bfd1ff238">
        <source>canTwinLift(slotController : CM_SlotController) : Boolean;
//30 June 2008	cnwdw1	
// Return true if this slot is part of twin lift
// If either end of the win lift is complete, then cannot be handled as a twin lift
begin
	return (slotController.mySlotRequestLoad.isTwinLift(true) or slotController.mySlotRequestLoad.isTwinLift(false)) and
			(not self.isCompletedSlot(slotController) and not self.isCompletedSlot(self.getTwinSlotController(slotController)));
end;</source>
        <Parameter name="slotController" type="CM_SlotController"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="displaySlot" id="3976a457-849f-4e10-9576-9de996c2a676">
        <source>displaySlot(cell : JadeTableCell io);
vars
	slot : CM_SlotController;
	wle : CM_VoyageWLE;
begin
	slot := cell.itemObject.CM_SlotController;
	cell.enabled := false;
	if slot = null then
		cell.backColor := Grey;
	else
		if slot.mySlotRequestLoad &lt;&gt; null then
			if self.isCurrentJobSlot(slot) then
				cell.backColor := Yellow;
			else
				cell.backColor := PaleGreen;
			endif;
			
			if self.isCompletedSlot(slot) then
				cell.text := "C";
			else		
				if slot.isBulkRelease then
					//cell.text := "BR";
					// 22 Nov 2010	NDL	Par 25074
					wle := slot.mySlotRequestLoad.allWorkListEntries.first.CM_VoyageWLE;
					if wle = null then
						cell.text := "BR";
					else
						cell.text := wle.seqNumAsString;
					endif;
				endif;
			endif;

			//cnwrd1 par 30222 change in rules here, now dont allow selection of completed slot and allow selection of slots without ti's assigned 
			if self.isCurrentJobSlot(slot) and slot.isBulkRelease and not self.isCompletedSlot(slot) then
				cell.enabled := true;
			endif;
			
		endif;
	endif;

end;
</source>
        <Parameter name="cell" type="JadeTableCell" usage="io"/>
    </JadeMethod>
    <JadeMethod name="doBack" id="bfefe1fd-bdb3-4946-af1c-b142e7df17f7">
