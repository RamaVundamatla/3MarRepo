    <JadeMethod name="doDelete" id="dc95e81a-c533-4820-889d-c36cdcb8d7d8">
        <updating/>
        <source>doDelete() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Sep 2022 navma1	ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen
25 April 2023	navhl20	ChangeRequest 57716:[57718] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 01]
*/

vars
	selObj 		: Object;
	vbsTimeSlot : CM_VehicleBookingTimeSlot;
	theResult	: Integer;
begin
	selObj := self.tblData.allSelectedObjects.first;

	if selObj = null then
		//app.msgBox(app.getErrorString(Please_select_work_order), app.getErrorString(No_Work_order_selected), MsgBox_Exclamation_Mark_Icon);
		app.msgBox(app.getErrorString(Please_select_vehicle_booking), app.getErrorString(No_vehicle_booking_selected), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	
	if selObj.isKindOf(CM_VehicleBookingTimeSlot) then
		vbsTimeSlot := selObj.CM_VehicleBookingTimeSlot;
	endif;
	
	if vbsTimeSlot &lt;&gt; null then
		if not app.msgBox(app.getErrorString(Delete_selected_slots), app.getErrorString(Alert), MsgBox_OK_Cancel) = MsgBox_OK_Cancel then
			return;
		endif;
	endif;
	
	while true do
		foreach vbsTimeSlot in self.tblData.allSelectedObjects as CM_VehicleBookingTimeSlot do							//24.4.2023 navhl20 #57716[57718]
			app.myTrxDA.trxDeleteVehicleBooking(vbsTimeSlot, app.myPassport);
		endforeach;																										//24.4.2023 navhl20 #57716[57718]
		if app.myPassport.trxCompletedOK then
			self.doRefresh();
			break;
		else
			theResult := app.showErrorWarningDialog(app.getErrorString(Vehicle_booking_updated) &amp; " " &amp; app.getErrorString(Delete), app.myPassport, ErrWarnMode_Delete);
			if app.myPassport.noErrors and theResult = IDOK then
				app.myPassport.warningsAcknowledged	:= true;
				continue;
			endif;
		endif;
		
		break;
		
	endwhile;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doEditItem" id="d892ba7d-fefc-4049-8aa6-997a149b1d8d">
        <source>doEditItem();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
18 Aug 2022	navcs2	ChangeRequest 53899: EUP - VBS MTN - [3] - Maintaining VBS Slot
23 Sep 2022 navhl20 ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen
13/12/2022	navcs2 	ChangeRequest 53899: EUP - VBS MTN - [3] - Maintaining VBS Slot
23 Dec 2022	navak20 Task 55979: EUP - VBS MTN - [3] - Maintaining VBS Slot - Review Changes
*/

vars
	slotMaintForm : CMUI_VehicleBookingAdvMaint;
	//selObj		: Object;	// 23.12.2022 navak20 TFS 55979
	selObj		: CM_VehicleBookingTimeSlot;	// 23.12.2022 navak20 TFS 55979
	row		    : Integer;
	vbsItems	  : CM_VehicleBookingByTs;
	canBeBulkEdit : Boolean;
	vehicleBookingSlotType : CM_VehicleBookingTimeSlotType;
	selectedObjects : ObjectArray;		// 23.12.2022 navak20 TFS 55979
begin
	
	/**
	13/12/2022	navcs2 	ChangeRequest 53899
	*/
	selectedObjects := self.tblData.allSelectedObjects;		// 23.12.2022 navak20 TFS 55979
	if selectedObjects.size &gt; 1 then
		canBeBulkEdit := true;
		vehicleBookingSlotType := selectedObjects.first.CM_VehicleBookingTimeSlot.myVBTimeSlotType;
		//foreach selObj in self.tblData.allSelectedObjects do	// 23.12.2022 navak20 TFS 55979
		foreach selObj in selectedObjects as CM_VehicleBookingTimeSlot do	// 23.12.2022 navak20 TFS 55979
			//Start 23.12.2022 navak20 TFS 55979
			if selObj.myVBTimeSlotType = vehicleBookingSlotType then
				continue;
			endif;
			/*if selObj.CM_VehicleBookingTimeSlot.myVBTimeSlotType &lt;&gt; vehicleBookingSlotType then
				canBeBulkEdit := false;
				app.raiseCMException(Vbs_diff_type_bulk_ed, null, selObj.CM_VehicleBookingTimeSlot);
			endif;*/
			canBeBulkEdit := false;
			app.raiseCMException(Vbs_diff_type_bulk_ed, null, selObj);
			//End 23.12.2022 navak20 TFS 55979
		endforeach;
		create vbsItems transient;
		
		selectedObjects.copy(vbsItems);
		
		if vbsItems &lt;&gt; null and canBeBulkEdit then
			slotMaintForm := app.loadForm(CMUI_VehicleBookingAdvMaint, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_VehicleBookingAdvMaint;
			if slotMaintForm &lt;&gt; null then
				slotMaintForm.setAllVbsItems(vbsItems);
				slotMaintForm.setVbsItem(vbsItems.last);
				slotMaintForm.initialise(vbsItems.last, slotMaintForm.MODE_UPDATE_BULK);
				slotMaintForm.height := 410;
				slotMaintForm.show;
			endif;
		endif;
		return;
	endif;
	/**
	13/12/2022	navcs2 	ChangeRequest 53899
	*/

	row 	:= self.tblData.row;
	//selObj  := self.tblData.accessRow(row).itemObject;	// 23.12.2022 navak20 TFS 55979
	selObj  := self.tblData.accessRow(row).itemObject.CM_VehicleBookingTimeSlot;	// 23.12.2022 navak20 TFS 55979
	
	//Start 23.09.2022 navhl20 TFS 53900
	if selObj = null then
		app.msgBox(app.getErrorString(Please_select_vehicle_booking), app.getErrorString(No_vehicle_booking_selected), MsgBox_Exclamation_Mark_Icon);
		return;
	endif;
	//End 23.09.2022 navhl20 TFS 53900
	
	if selObj &lt;&gt; null then
		slotMaintForm := app.loadForm(CMUI_VehicleBookingAdvMaint, CMUI_Assistant, false, false, false, self.myTerminal, null).CMUI_VehicleBookingAdvMaint;
		if slotMaintForm &lt;&gt; null then
			if selObj.isKindOf(CM_VehicleBookingTimeSlot) then
				slotMaintForm.initialise(selObj.CM_VehicleBookingTimeSlot, slotMaintForm.MODE_UPDATE);
			endif;
			slotMaintForm.show;
		endif;
	endif;
	

epilog
	delete vbsItems;
end;</source>
    </JadeMethod>
    <JadeMethod name="doFilterTable" id="c495bfa2-8127-44fc-a514-2c10501882dc">
        <updating/>
        <source>doFilterTable() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 December 2022	navhl20	CR 53900: Task 55833: EUP - VBS MTN - [4] - Search Screen - Add Text Filtering
24 Apr 2023 		navhl20	ChangeRequest 57716:[57718] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 01]
*/

vars
	filterText 	: String;
	rowIdx,
	colIdx,
	start,
	rows		: Integer;
	cell 		: JadeTableCell;
	cellText 	: String;
	tbl			: CM_DataTable;
	
begin
   /* //25/06/2024	navkc1 CR 64823 Task 64824
   rows		:= 0;
	filterText  := self.txtFilterBox.text.toUpper();
	tbl			:= self.tblData;
	
	if filterText = "" then
		self.clearFilter();
		return;
	else
		self.btnClearFilter.enabled := true;
	endif;

	start := tbl.fixedRows + 1;
	
	foreach rowIdx in start to tbl.rows do : rowLoop
		tbl.accessRow(rowIdx);
		
		foreach colIdx in 1 to tbl.columns do
			cell 	 := tbl.accessCell(rowIdx, colIdx);
			cellText := cell.text.toUpper;
			
			if cellText.length &gt; 0 and cellText.pos(filterText, 1) &gt; 0 then
				self.tblInfo.rows := 0;      
				tbl.accessedRow.visible := true;
				rows := rows+1;
				continue rowLoop;
			endif;
		endforeach;
		
		tbl.accessedRow.visible := false;
	endforeach;
	*/
	//25/06/2024	navkc1 CR 64823 Task 64824
	if self.frmTblFilter &lt;&gt; null then
		rows := self.frmTblFilter.numOfRowVisible;
	endif;
	self.numRows := rows;											//24.4.2023 navhl20 #57716[57718]
	self.staStatusBar.caption := rows.String &amp; " rows found.";		//24.4.2023 navhl20 #57716[57718]
	
	if rows = 0 then 
		self.tblInfo.rows := 0;          
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doHandleNotification" id="ade7db92-49e6-4b05-9d17-008aad0a457d">
        <updating/>
        <source>doHandleNotification( eventType: Integer; theObject: Object ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
23 Sep 2022	navhl20	ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen
24 Apr 2023 navhl20	ChangeRequest 57716:[57718] EUP - VBS changes MTN - Bulk Edit and Linking of slots [Refinement - 01]
19 Jul 2023 navhl20 Bug 59181: EUP | VBS changes MTN - VBS Enquiry refresh issue
*/

vars
	dataLine	: String;
	idx 		: Integer;
	timeSlotObj : CM_VehicleBookingTimeSlot;
begin
	if theObject = null then
		return;
	endif;
	
	timeSlotObj := theObject.CM_VehicleBookingTimeSlot;
	
	if eventType = Object_Create_Event then
		if self.includeObject(timeSlotObj) then
			dataLine := timeSlotObj.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
			self.tblData.accessRow(self.tblData.addItem(dataLine)).itemObject := timeSlotObj;
			self.doNotableAdd(timeSlotObj);
		endif;
	elseif eventType = Object_Update_Event  then
		if self.tblData.findObjectInRow(timeSlotObj,idx) then			//19.7.2023 navhl20 #59181
			self.tblData.removeItemObject(timeSlotObj);
		endif;
		if self.includeObject(timeSlotObj) then
			dataLine := timeSlotObj.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);
			self.tblData.accessRow(self.tblData.addItem(dataLine)).itemObject := timeSlotObj;
		endif;
	elseif eventType = Object_Delete_Event then
		self.tblData.removeItemObject(timeSlotObj);
		self.doNotableRemove(timeSlotObj);
	endif;
	self.numRows := tblData.rows-tblData.fixedRows;
	self.staStatusBar.caption := (tblData.rows-tblData.fixedRows).String &amp; " rows found.";		//24.4.2023 navhl20 #57716[57718]
epilog

end;</source>
        <Parameter name="eventType" type="Integer"/>
        <Parameter name="theObject" type="Object"/>
    </JadeMethod>
    <JadeMethod name="doMnuAuditsForObjectClick" id="6a4b1882-6e11-43b1-bc95-7a048cfabe18">
        <source>doMnuAuditsForObjectClick(menuItem: MenuItem input);
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
10 Aug 2023	navlw1	ChangeRequest 59132:[59133] EUP | VBS Audits

*/

vars
	vehicleBooking : CM_VehicleBookingTimeSlot;
begin
	vehicleBooking := self.tblData.accessRow(self.tblData.row).itemObject.CM_VehicleBookingTimeSlot;
	
	if vehicleBooking &lt;&gt; null then
		app.viewAuditFormModal(vehicleBooking, self.myAssistant.class, self.myTerminal);
	endif;
epilog

end;</source>
        <Parameter name="menuItem" type="MenuItem" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doMnuSendEmail" id="159a3bfd-eb77-4db8-83e7-93e17a0f36da">
        <source>doMnuSendEmail();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Oct 2022	navak20 ChangeRequest 54046: EUP - VBS MTN - [7] - Email configuration and notifications

*/

vars
	form : CMUI_VBSEmailSend;
	vbsDetails : String;
	selectedObjects : ObjectArray;
begin
	selectedObjects := self.tblData.allSelectedObjects;
	if selectedObjects.isNotEmpty() then
		vbsDetails := self.createVbsDetailsCSV(selectedObjects);
		if form = null then
			form := app.loadForm(CMUI_VBSEmailSend, CMUI_Assistant, false, false, true , self.myTerminal, null).CMUI_VBSEmailSend; 
		endif;
		form.setMyCarrier(selectedObjects);
		form.myParentForm := self;
		form.setVbsDetails(vbsDetails);
		form.show();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuVbsCopySlots" id="41d21248-0595-4b9b-9496-9cd875ccae0a">
        <source>doMnuVbsCopySlots();
/*

Purpose:			

Create new copies of an existing vehicle booking time slot

Parameters:			

Return Value:		

Date				Who		Reason
01 November 2022	navcs2	ChangeRequest 53899: EUP - VBS MTN - [3] - Maintaining VBS Slot
23 Dec 2022			navak20 Task 55979: EUP - VBS MTN - [3] - Maintaining VBS Slot - Review Changes
17 May 2023 		navhl20	Defect 58041:[58042] MTN - Unable to copy the slots with the status "Booked - Current"
20 Nov 2023 		navlc30 ChangeRequest 61207: EUP | FR | 54329 | VBS - Pending issues - Issue 13
08 Aug 2024 navcs2	ChangeRequest 63928: EUP | Trailer Type in a VBS Slot
*/

vars
	inputBox 						: CMUI_InputBox;
	numCopies,
	count							: Integer;
	selObj							: Object;
	row,theResult		    		: Integer;
	vbsSlot,
	newVehicleBookingTimeSlot,
	proxyVehicleBookingTimeSlot		: CM_VehicleBookingTimeSlot;
	vehicleBookingSlots				: CM_VehicleBookingTSItemSet;
	vbTimeSlot						: CM_VehicleBookingTimeSlot;	// 23.12.2022 navak20 TFS 55979
begin
	// Create the modal to get the users input for number of copies to be made
	create inputBox transient;

	inputBox.init(	"amount of copies", null,
					"0", 20, TextBox.DataType_Numeric, TextBox.Case_None, false, false);
					
	inputBox.showModal;
	
	if inputBox.modalResult &lt;&gt; IDOK then
		return;
	endif;

	numCopies := inputBox.txtInput.text.Integer;
	
	// Get the object to be copied and create a proxy for it
	row 	:= self.tblData.row;
	selObj  := self.tblData.accessRow(row).itemObject;
	
	if selObj.isKindOf(CM_VehicleBookingTimeSlot) then
		vbTimeSlot := selObj.CM_VehicleBookingTimeSlot;		// 23.12.2022 navak20 TFS 55979
	endif;
	
	// Create the new copies
	foreach count in 1 to numCopies do
		if vbTimeSlot &lt;&gt; null and vbTimeSlot.canBeCopied() then														//20.11.2023 navlc30 #61207
			create vehicleBookingSlots transient;
			
			//myProxyVehicleBookingTimeSlot := (selObj.CM_VehicleBookingTimeSlot).pxyCreateUpdateProxy;		// 23.12.2022 navak20 TFS 55979
			proxyVehicleBookingTimeSlot := app.createUpdateProxy(vbTimeSlot).CM_VehicleBookingTimeSlot;		// 23.12.2022 navak20 TFS 55979
			//selObj.CM_VehicleBookingTimeSlot.allVehicleBookingItems.copy(vehicleBookingSlots);	// 23.12.2022 navak20 TFS 55979
			vbTimeSlot.allVehicleBookingItems.copy(vehicleBookingSlots);	// 23.12.2022 navak20 TFS 55979
			
			create vbsSlot transient;
					
			vbsSlot.setProxy(proxyVehicleBookingTimeSlot.bookingTSstart,											//20.11.2023 navlc30 #61207
								proxyVehicleBookingTimeSlot.bookingTSend,
								proxyVehicleBookingTimeSlot.myVehicleBookingTerminal,
								proxyVehicleBookingTimeSlot.myCarrier,
								proxyVehicleBookingTimeSlot.mySubCarrier,
								proxyVehicleBookingTimeSlot.myDriver,
								proxyVehicleBookingTimeSlot.myVehicle,
								proxyVehicleBookingTimeSlot.remarks,
								proxyVehicleBookingTimeSlot.includesDelivery,
								proxyVehicleBookingTimeSlot.includesPickUp,
								null,
								null,
								proxyVehicleBookingTimeSlot.myVBTimeSlotType,
								null,
								proxyVehicleBookingTimeSlot.allBookingRefs,
								proxyVehicleBookingTimeSlot.allBulkReleases,
								vehicleBookingSlots,
								proxyVehicleBookingTimeSlot.preGateInCheck,
								proxyVehicleBookingTimeSlot.preGateOutCheck,
								proxyVehicleBookingTimeSlot.kioskCheck,
								null,
								null);																				// 08 Aug 2024 navcs2	ChangeRequest 63928	
			while true do																							//23.5.2023 navhl20	#58041
				app.myTrxCA.trxCreateVehicleBookingAdv(vbsSlot, newVehicleBookingTimeSlot,true, app.myPassport);	//24.5.2023 navhl20 #58041
				if app.myPassport.trxCompletedOK then
					delete proxyVehicleBookingTimeSlot;
					break;
				else
					theResult := app.showErrorWarningDialog("Copy Slots", app.myPassport, ErrWarnMode_Delete);
					if app.myPassport.noErrors and theResult = IDOK then
						app.myPassport.warningsAcknowledged	:= true;
						continue;
					endif;
					if theResult = IDCANCEL then
						delete proxyVehicleBookingTimeSlot;
						delete vbsSlot;
						delete vehicleBookingSlots;
						return;
					endif;
				endif;
				break;
			endwhile;
			delete proxyVehicleBookingTimeSlot;
		else
			app.raiseCMException(Slot_vbs_cannot_copie, null, null);
		endif;
	endforeach;
epilog
	delete proxyVehicleBookingTimeSlot;
	delete vbsSlot;
	delete vehicleBookingSlots;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuVbsDeleteSlot" id="2161abf8-8c77-4f65-b9bb-d3c6d3fbcfcb">
        <updating/>
        <source>doMnuVbsDeleteSlot() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Sep 2022	navak20	ChangeRequest 54048: EUP - VBS MTN - [8] - Transfer Slots

*/

vars
	vbsTimeSlots	: ObjectArray;
	theResult   : Integer;
begin
	if app.msgBox(app.getErrorString(Delete_selected_slots), app.getErrorString(Alert), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;
	
	vbsTimeSlots := self.tblData.allSelectedObjects;
	if vbsTimeSlots.isNotEmpty then
		while true do
			app.myTrxDA.trxDeleteMultiVehicleBookSlots(vbsTimeSlots, app.myPassport);
			if app.myPassport.trxCompletedOK then
				self.doRefresh();
				break;
			else
				theResult := app.showErrorWarningDialog(app.getErrorString(Transfer_slots) &amp; " " &amp; app.getErrorString(Delete), app.myPassport, ErrWarnMode_Delete);
				if app.myPassport.noErrors and theResult = IDOK then
					app.myPassport.warningsAcknowledged	:= true;
					continue;
				endif;
			endif;
			break;
		endwhile;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuVbsSendLoadNA" id="5c5d8bee-45a6-4864-8d83-2011b008174e">
        <source>doMnuVbsSendLoadNA();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
30 June 2023	jlier1	Initial creation 58839
28 Apr  2025    navsp1  JIRA-34630 EUP FR | 54026 - LOADCO and LOADNA Message - Unable to send LOADNA via VBS Selector Query
*/

vars
	allVBS : CM_VehicleBookingTimeSlotById;
	result : Integer;
begin
	if self.tblData.allSelectedObjects.isEmpty then
		return;
	endif;
	
	create allVBS transient;
	self.tblData.allSelectedObjects.copy(allVBS);
	
	while true do
		app.myTrxCA.trxCreateBGPAPIRequestForVBS(allVBS,  app.myPassport);
		if app.myPassport.trxCompletedOK then														//JIRA-34630
			break;																					//JIRA-34630
		else																						//JIRA-34630
			result :=  app.showErrorWarningDialog('Send LOADNA', app.myPassport, ErrWarnMode_Add);	//JIRA-34630
			if app.myPassport.noErrors and result = IDOK then										//JIRA-34630
				app.myPassport.warningsAcknowledged	:= true;										//JIRA-34630
				continue;																			//JIRA-34630
			endif;																					//JIRA-34630
		endif;
		break;
	endwhile;
	
	if app.myPassport.trxCompletedOK then
		app.msgBox(app.getErrorString(Success_back_load_note),app.getErrorString(Information),MsgBox_OK_Only);
	endif;
	
epilog
	delete allVBS;
end;</source>
    </JadeMethod>
    <JadeMethod name="doMnuVbsTransferSlot" id="527710dc-3392-4369-8c97-36e4bfb4d62b">
        <source>doMnuVbsTransferSlot();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
27 Sep 2022	navak20	ChangeRequest 54048: EUP - VBS MTN - [8] - Transfer Slots

*/

vars
	allSelectedObjects : ObjectArray;
	
begin
	if app.msgBox(app.getErrorString(Transfer_selected_slots), app.getErrorString(Alert), MsgBox_Yes_No + MsgBox_Question_Mark_Icon) = MsgBox_Return_No then
		return;
	endif;
	
	allSelectedObjects := self.tblData.allSelectedObjects;
	
	if allSelectedObjects.isNotEmpty then
		self.myAssistant.showVBSTransferSlotForm(allSelectedObjects);
	endif;
	
end;</source>
    </JadeMethod>
    <JadeMethod name="doQuery" id="1e9e45d7-e296-4acb-90dc-09304f9732e8">
        <updating/>
        <source>doQuery() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
20 Sep 2022 navma1	ChangeRequest 53900: EUP - VBS MTN - [4] - Search Screen
19 May 2023	navlw1	Initial creation CR 53902 EUP - VBS MTN - [6] - Selector Query and JRW

*/

vars
	vbTerminal	: CM_VehicleBookingTerminal;
begin
	inheritMethod();
	
	self.tblData.clearAllData();
	
	vbTerminal := self.myTerminal.myVehicleBookingTerminal;
	self.populateVbsSlots(vbTerminal.allVBTimeslotsById , false);
