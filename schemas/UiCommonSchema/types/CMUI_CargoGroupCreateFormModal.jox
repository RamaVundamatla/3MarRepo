<GUIClass name="CMUI_CargoGroupCreateFormModal" id="5df7f1ad-b7bd-49ed-b927-098728b54f1c">
    <superclass name="CMUI_CargoGroupCreateForm"/>
    <transient/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <PrimAttribute name="passedID" id="eb4a7647-f4d5-4e31-8d8c-3e8383211c58">
        <length>21</length>
        <embedded/>
        <type name="String"/>
        <access>readonly</access>
    </PrimAttribute>
