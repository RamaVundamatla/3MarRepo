    <JadeMethod name="getDisplayModeForFrame" id="6b732428-f3bc-4bf7-9fd8-b03c6d84bfc2">
        <source>getDisplayModeForFrame( _dispFrame : Frame ):Integer;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 November 2009	cnwndl1	Initial creation	CCMS 1031

*/

vars

begin

	if _dispFrame = self.frmDispOffsite then
		return self.displayModeOffSite;
	elseif _dispFrame = frmDispOnship then
		return self.displayModeOnShip;
	elseif _dispFrame = frmDispOnsite then
		return self.displayModeOnSite;
	elseif _dispFrame = self.frmDispPreNote then
		return self.displayModePreNote;
	else
		return DISPLAY_MODE_ACTUAL;
	endif;

epilog

end;</source>
        <Parameter name="_dispFrame" type="Frame"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
