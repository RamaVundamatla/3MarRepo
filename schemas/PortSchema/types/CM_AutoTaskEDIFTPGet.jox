    <JadeMethod name="setValueForRow" id="17261fb0-7035-4ae1-a0ab-7724d7aef305">
        <updating/>
        <source>setValueForRow(_rowName: String; _value: Any) updating;
//
// 03 Mar 2014	cmwrs1 par 33631 SFW 1373
//
vars

begin
	if _rowName = ETRow_BgpAutoEDIFTP then
		self.myFTPEntity := _value.CM_FTPEntity;
	else
		inheritMethod(_rowName, _value);
	endif;

end;</source>
        <Parameter name="_rowName" type="String"/>
        <Parameter name="_value" type="Any"/>
    </JadeMethod>
    <JadeMethod name="validate" id="f98a5440-78ac-44e5-bb2b-aeb468c011e3">
        <source>validate();
//
// 03 Mar 2014	cmwrs1 par 33631 SFW 1373
//
vars

begin
	inheritMethod();
	if self.myTerminal = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'Terminal', ETRow_BgpAutoTerminals, null);
		app.raiseCMException(Input_required_field_terminal, ETRow_BgpAutoTerminals, null);	
		
	endif;
	if self.myFTPEntity = null then
	//	app.raiseCMException1(REQUIRED_FIELD, 'FTP Entity', ETRow_BgpAutoEDIFTP, null);
		app.raiseCMException(Input_required_field_ftpEntity, ETRow_BgpAutoEDIFTP, null); // cnwdb2	PAR 35364

	endif;
end;
</source>
    </JadeMethod>
