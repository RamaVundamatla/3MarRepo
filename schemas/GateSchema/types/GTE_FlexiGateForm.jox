/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 September 2011	cnwndl1	Initial creation	Par 24455
31 Aug 2023 navhl20 Bug 60183: FR | 53429 - VBS changes - Quantity assigned in the VBS is not remembered during Road Gate announcement
*/

vars

	row : Integer;
	resDtl : CM_ReserveDetail;
	bulkRelease : CM_BulkRelease;

begin

	row := self.tblBulkRelease.row;
	if row &gt; self.tblBulkRelease.fixedRows and row &lt;= self.tblBulkRelease.rows then
		if self.tblBulkRelease.accessRow(row).selected then
			resDtl := self.tblBulkRelease.accessRow(row).itemObject.CM_ReserveDetail;	
			if resDtl &lt;&gt; null then
				bulkRelease	:= resDtl.myReserveHeader;
				if bulkRelease &lt;&gt; null then
					self.openSubScreenFromBulkRelease(bulkRelease.code, bulkRelease, resDtl, null, null);		//31.8.2023 navhl20 #60183
