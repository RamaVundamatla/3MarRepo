<Class name="CMIF_RefEquipment" id="e852305b-f831-4442-acec-de2e83859e69">
    <superclass name="CMIF_OpsViewTables"/>
    <transient/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <text>

DATASET - Yard

Mapping 
MTN : 
N4  : ref_equipment

[gkey]							bigint						NOT NULL,
[eqtyp_gkey]					bigint						NOT NULL,
[id]							character varying(30)			NOT NULL,
[class]							character varying(30)			NOT NULL,	//This field is defined as 'class_namechange' in JADE since 'class' is already defined, this hack is taken care in the producer
[life_cycle_state]				character varying(3)		NOT NULL,</text>
    <DbClassMap file="backgroundprocess"/>
    <PrimAttribute name="classStr" id="0bfad577-0ddd-4153-912c-26d6a5a5251a">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="class_namechange" id="8332980c-5abb-482c-8d54-62e813b58b4b">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="eqtyp_gkey" id="8baee6ce-ca0c-4020-b71a-22a2a5f35ca1">
        <embedded/>
        <type name="Integer64"/>
    </PrimAttribute>
    <PrimAttribute name="id" id="733858e1-30c1-4aaa-ab06-56a92c2a80f3">
        <type name="String"/>
    </PrimAttribute>
    <PrimAttribute name="life_cycle_state" id="7e12a62a-ba87-4d9e-bcef-549809b4d9b5">
