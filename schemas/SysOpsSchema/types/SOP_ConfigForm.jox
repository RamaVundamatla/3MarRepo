    <JadeMethod name="translateForm" id="310c6240-80af-4a9e-9a65-c6310245ee8d">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 24 December 2024 09:42:31.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0006974, locale);
	btnEditNew.translateCaption(Xlat_0003799, locale);
	btnFixup.translateCaption(Xlat_0015819, locale);
	btnHideSearchMsg.translateCaption(Xlat_0015820, locale);
	btnJobPriority.translateBubbleHelp(Xlat_0015821, locale);
	btnJobPriority.translateCaption(Xlat_0015822, locale);
	btnLicenseNew.translateCaption(Xlat_0003800, locale);
	btnOutputConfig.translateBubbleHelp(Xlat_0010828, locale);
	btnOutputConfig.translateCaption(Xlat_0010829, locale);
