</source>
        <Parameter name="_startTS" type="TimeStamp"/>
        <Parameter name="_endTS" type="TimeStamp"/>
        <Parameter name="_numberDone" type="Integer"/>
        <Parameter name="_taskDescription" type="String"/>
        <Parameter name="_startingSize" type="Decimal"/>
        <Parameter name="_endingSize" type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="getIncBetweenRuns" id="c520ed11-a81b-47e7-9ba6-7d1d2661c48e">
        <source>getIncBetweenRuns(_cleanUpDetails : UM_CleanUpResultsDetails; _cleanUpResultsDict : DynaDictionary; _reversed : Boolean) : Decimal;

/*

Purpose:		Get the increase details between passed in run and the previous run	

Date			Who		Reason
19/11/2013		cnwmh5	Initial creation

*/

vars
	
	cleanUp								: UM_CleanUpResultsDetails;
	
	iter								: Iterator;

	incBetweenRuns						: Decimal[12,0];
	
begin
	
	iter := _cleanUpResultsDict.createIterator;
	
	if _reversed then
		_cleanUpResultsDict.startKeyGeq(_cleanUpDetails.startTS, _cleanUpDetails.endTS, iter);
		
		while iter.next(cleanUp) do 
			if cleanUp.taskDescription &lt;&gt; _cleanUpDetails.taskDescription then
				continue;
			endif;
			
			if cleanUp.startTS.date &lt;&gt; _cleanUpDetails.startTS.date then
				incBetweenRuns := cleanUp.endingSize - _cleanUpDetails.startingSize;
				break;
			endif;	
		endwhile;
	else
		_cleanUpResultsDict.startKeyLeq(_cleanUpDetails.startTS, _cleanUpDetails.endTS, iter);
		
		while iter.back(cleanUp) do 
			if cleanUp.taskDescription &lt;&gt; _cleanUpDetails.taskDescription then
				continue;
			endif;
			
			if cleanUp.startTS.date &lt;&gt;_cleanUpDetails.startTS.date then
				incBetweenRuns := _cleanUpDetails.startingSize - cleanUp.endingSize;
				break;
			endif;	
		endwhile;
	endif;

	return incBetweenRuns;
	
epilog

	delete iter;

end;</source>
        <Parameter name="_cleanUpDetails" type="UM_CleanUpResultsDetails"/>
        <Parameter name="_cleanUpResultsDict" type="DynaDictionary"/>
        <Parameter name="_reversed" type="Boolean"/>
        <ReturnType type="Decimal"/>
    </JadeMethod>
    <JadeMethod name="outputFormatted" id="2ffef27c-1b8c-4eb1-9017-8ce1d5e535c4">
        <source>outputFormatted(_formatObject : Any; _dontFormat : Boolean) : String;

/*

Purpose:		

Date			Who		Reason
19 November 2013	cnwmh5	Initial creation

*/

vars

	rtnValue				: String;
	
begin

	rtnValue := null;
	if _formatObject.isKindOf(Integer) then
		if _formatObject.Integer &lt;&gt; 0 then
			rtnValue := _formatObject.Integer.asStringJMTWithOptionalCommas(true, true);
		endif;
	elseif _formatObject.isKindOf(Decimal) then
		if _formatObject.Decimal &lt;&gt; 0.00 then
			rtnValue := _formatObject.Decimal.asStringJMTWithPrecision(0, true);
		endif;
	endif;
	if _dontFormat then
		rtnValue := rtnValue.replaceString(",", "");
	endif;
	return rtnValue;

epilog

end;</source>
        <Parameter name="_formatObject" type="Any"/>
        <Parameter name="_dontFormat" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
</Class>
