    <JadeMethod name="validateSubBlock" id="c0f3c163-8a16-4859-aeed-a9a2f3a48330">
        <updating/>
        <source>validateSubBlock(_theGridTARegion : CMIF_GridTARegion input) updating;
// ---------------------------------------------------------------------------
// Created:		August  2002 By Andrew Bishop cnwab1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

	lControllerArray	: CM_LCArray;
	lController	: CM_LocationsController;

begin
	
	create lControllerArray transient;
	
	foreach lController in _theGridTARegion.allLocationControllers do
		lControllerArray.add(lController);
	endforeach;
	
	self.myParent.validateConvertToSubBlock(lControllerArray);

epilog
	delete lControllerArray;



end;</source>
        <Parameter name="_theGridTARegion" type="CMIF_GridTARegion" usage="input"/>
    </JadeMethod>
    <JadeMethod name="yaFindLCs" id="17996861-7383-4d77-9ccd-912757c5602e">
        <source>yaFindLCs(pFromId: String; pToId: String; pAllControllersObj: CM_LCArray input);
// --------------------------------------------------------------------------------
// Created:		14 April 2005 by cnwdad1:2
//
// Purpose:		Refer to superclass implementation.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
begin
	if self.myParent = null then
		inheritMethod(pFromId, pToId, pAllControllersObj);
	endif;
end;</source>
        <Parameter name="pFromId" type="String"/>
        <Parameter name="pToId" type="String"/>
