    <JadeMethod name="canHaveGeneratorAttached" id="04e7dfa8-0ad7-4275-bee2-453dbae18fdb">
        <source>canHaveGeneratorAttached(): Boolean;
/* ---------------------------------------------------------------------------
Created:	21 January 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	theISOType	: CM_ISOType;
	
begin
	
	theISOType := self.getISOTypeObject();
	
	if theISOType &lt;&gt; null and theISOType.isReefer() then
		return true;
	endif;
	
	return false;

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
