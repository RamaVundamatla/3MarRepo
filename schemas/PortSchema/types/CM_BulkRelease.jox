    <JadeMethod name="isComplete" id="3ee00e77-d691-49d9-94e9-6a01f067d24c">
        <source>isComplete() :Boolean;
/*
----------   ----------  --------------------------------------------------
Created:	13 June 2007 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars
	reserveDetail		: CM_ReserveDetail;
begin
	if not self.releaseByType then
		return false;
	endif;
	
	foreach reserveDetail in self.allReserveDetails do
		if not reserveDetail.CM_ReserveSelection.isComplete() then
			return false;
		endif;
	endforeach;
	//	begin -	27/05/08 Anca Par 16830
	foreach reserveDetail in self.allReservePackingChildren do
		if not reserveDetail.CM_ReserveSelection.isComplete() then
			return false;
		endif;
	endforeach;
	//	end
	return true;
end;


</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="isForBookingRef" id="096b11fb-7103-4751-9b22-efd176f05c94">
        <source>isForBookingRef() : Boolean;
/* ---------------------------------------------------------------------------
Created:	08 September 2009	by cnwvu1

Purpose:	
   
Change Date		Who		Reason

------------------------------------------------------------------------------*/
vars
	br		: CM_BookingRef;
	
begin

	br := self.myBookingRefStock;
	
	if br = null then
		return false;
	endif;
	
	if br.isStockBookingRef = true then
		return false;
	endif;
	
	//cnwrd1 par 23922 ccms mes 1091 11.10.2010
	if not br.isManagedEmptyRelease then
		return false;
	endif;

	return true;
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
