    <JadeMethod name="setForUpdate" id="fc5f71a8-84ab-4392-bd4f-dec82f5d8952">
        <updating/>
        <source>setForUpdate(_pxyTrain: CM_Train; _trainArrivalEvent, _trainDepartEvent : CMEVT_TrainTransaction output) updating;
// ---------------------------------------------------------------------------
// Created:     21 August 2009 by cnwab1
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//16 Dec 2013	cnwrs1	Par 33035 - add CamsDateTime to CM_EventTransaction
// ---------------------------------------------------------------------------

vars

begin
	// NO NOTHING
	self.colour 		:= _pxyTrain.colour;

epilog

end;</source>
        <Parameter name="_pxyTrain" type="CM_Train"/>
        <Parameter name="_trainArrivalEvent" type="CMEVT_TrainTransaction" usage="output"/>
        <Parameter name="_trainDepartEvent" type="CMEVT_TrainTransaction" usage="output"/>
