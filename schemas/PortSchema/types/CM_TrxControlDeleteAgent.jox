    <JadeMethod name="trxDeleteROROVesselDecks" id="0cdd40ed-7fd0-4867-bae4-2912721b2119">
        <updating/>
        <source>trxDeleteROROVesselDecks(_vesselDecks : ObjectArray input; _passport : CM_Passport input) updating;
/*
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
05 May 2011	cnwer1	Initial creation CCMS 1031

*/

vars
	obj : Object;
	deck : CM_Deck;
begin

	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);
	
	// Start the transaction
	beginTransaction;

	foreach obj in _vesselDecks discreteLock do
		deck:=obj.CM_Deck;
		app.myUtilityDA.utlDeleteRORODeck(deck, _passport);
		if _passport.hasErrors then
			return;
		endif;
	endforeach;
epilog		
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_vesselDecks" type="ObjectArray" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxDeleteRPPTrackedItems" id="860c8312-df41-48b5-90ec-26e9772364fc">
        <updating/>
        <source>trxDeleteRPPTrackedItems(_tiSet : CM_TISet input; _forVoyage : CM_Voyage input; _tisWithWarnSet : CM_TISet input; _confirmEachDelete: Boolean; _passport : CM_Passport input ) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 January 2026	jlier1	Initial creation  JIRA-36877

*/

vars
	wle : CM_WorkListEntry;
	job : CM_Job;
	deleteJob,invalidTi : Boolean;
	tmpTI : CM_TrackedItem;
	terminal : CM_Terminal;
	errorSet : CM_ErrorSet;
	alertCreated : Boolean;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if _tiSet = null then
		app.raiseCMException1(ERR_DEL_NULLOBJECT, 'ti set', null, null);
		return;
	endif;
	
	app.myEventManager.setMultiTransactionTrx();
	app.setContinueCMExceptions(false);
	create errorSet transient;
	
	on Exception do app.handleDeletedObject(exception, tmpTI, invalidTi );	//30 May 2013	NDL	Par 31548
	terminal := app.myPassport.myTerminal;
	foreach tmpTI in _tiSet do
		invalidTi := false;
		// Start the transaction
		exclusiveLock(tmpTI);
		if invalidTi then	//30 May 2013	NDL	Par 31548
			continue;
		endif;
		
		wle:=null;
		deleteJob:=false;
		if tmpTI.isRRPforVoyage then
			wle := tmpTI.allWorklistEntries.getFirstUnactionedWLE();
			if wle &lt;&gt; null and wle.isKindOf(CM_VoyageWLE) and wle.CM_VoyageWLE.getMyVoyageObject = _forVoyage then
				if wle.job &lt;&gt; null and wle.job.isKindOf(CM_VoyageHoldJob) then
					job:= wle.job.CM_VoyageHoldJob;
					if job.workListEntries.size = 1 and job.workListEntries.includes(wle) then
						//can just delete the job this will then delete all wles and rrps etc and can continue
						deleteJob:=true;
					endif;
				endif;		
			endif;
		endif;
	
		beginTransaction;
		
		//Lock all the TI collections exactly as they appear in the passport(PortSchema::CM_Passport::updateTIsForDeferUpd)		//JIRA-34262
		//This ensures that there are no deadlocks while processing the deferred update on the other side.						//JIRA-34262
		self.exclusiveLock(terminal.allOnsiteTIsByCargoTypeId);																	//JIRA-34262			
		self.exclusiveLock(terminal.allOnsiteTIsByCargoTypeIdRev);																//JIRA-34262					
		self.exclusiveLock(terminal.allOnsiteTIsByIdCargoType);																	//JIRA-34262				
		self.exclusiveLock(terminal.allOnsiteTIsByIdCargoTypeRev);																//JIRA-34262					
		self.exclusiveLock(terminal.allOnsiteTIsByBookingRef);																	//JIRA-34262				
		self.exclusiveLock(terminal.allOnsiteTIsByAlternativeId);																//JIRA-34262	
		self.exclusiveLock(terminal.allNotifiedTIsByCargoTypeId);																//JIRA-34262		
		
		
		if deleteJob then
			app.myUtilityDA.utlDeleteJob(job, _passport);
			continue;
		else
			// otherwise delete the wle then unqueue &amp; unplan RRP ti so the delete will not get errors for being planned
			if wle &lt;&gt; null then
				wle.erase(NORMAL_ERASE);
				//if the rrp ti is planned or queued - unplan/queue first
				tmpTI.doForcedUnplan(app.myPassport);
				tmpTI.doForcedUnqueue(app.myPassport);
			endif;
		endif;
	
		app.myUtilityDA.utlDeleteTI(tmpTI, _confirmEachDelete, _passport);
		
		if _passport.isOkToCommit(false)  then
			app.cmsCommitTransaction(_passport);
		else
			app.cmsAbortTransaction();
			if invalidTi then	//30 May 2013	NDL	Par 31548
				_passport.initialiseTransaction();
				continue;
				
			elseif _passport.hasErrors then
				app.convertErrorsWarningsToAlert('TrackedItem ' &amp; tmpTI.id &amp; ' could not be deleted', _passport.allErrorWarnings);				
				alertCreated := true;
				
			elseif _passport.hasWarnings then
				_tisWithWarnSet.add(tmpTI);
				
			endif;
			_passport.moveErrorsToSet(errorSet);
			_passport.initialiseTransaction();				
		endif;
	endforeach;

	if _passport.noErrors and (not process.isInTransactionState) then
		// Done so that finaliseActivityWithPassport will commit correctly
		beginTransaction;
	endif;
	_passport.addErrorsFromSet(errorSet);
	if alertCreated then
		app.raiseCMException1(SystemAlertCreated, 'Tracked Items for delete', null, self);
	endif;	
	
epilog
	self.finaliseActivityWithPassport(_passport);
	delete errorSet;
	
end;</source>
        <Parameter name="_tiSet" type="CM_TISet" usage="input"/>
        <Parameter name="_forVoyage" type="CM_Voyage" usage="input"/>
        <Parameter name="_tisWithWarnSet" type="CM_TISet" usage="input"/>
        <Parameter name="_confirmEachDelete" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
