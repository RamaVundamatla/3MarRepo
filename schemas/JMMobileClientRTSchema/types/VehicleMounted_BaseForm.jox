    <JadeMethod name="doChangeQueue" id="c1c418c4-4206-4dad-8bbb-363d2d148f0e">
        <updating/>
        <source>doChangeQueue() updating, protected;
/*

Purpose:			


Return Value:		


Date		Who		Reason
24 October 2006	cnwer1	Initial creation - PAR#xxxx

*/
vars

	queueId : String;
	errorMsg : MobileHandHeldThin::DTO_HandHeldGateError;
	queue : CM_RadioTelemetryQueue;
begin

	if self.cmbQueue.listIndex = -1 then
		app.msgBox('Please select a queue.','Invalid Queue', MsgBox_OK_Only);
		return;
	endif;
	
	queue :=self.cmbQueue.itemObject[self.cmbQueue.listIndex].CM_RadioTelemetryQueue;
	queueId:=queue.id;//  self.cmbQueue.itemText[self.cmbQueue.listIndex];
	
	self.clearErrors;
	
	app.myHandHeldGuiAgent.VehicleMountedGuiAgent.doChangeQueue( queue,allErrorMsgs);
	self.setMode();
	self.checkErrors();
	
	self.doCancelQueue;


epilog

end;</source>
        <access>protected</access>
    </JadeMethod>
