    <JadeMethod name="delete" id="0592ac2f-a0dd-4dae-986e-4537b88e8232">
        <updating/>
        <source>delete() updating;
// ---------------------------------------------------------------------------
// Created:		11 April 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
	aTerm : CM_Terminal;
	theMachines : CM_MachineSet;
	aMach : CM_Machine;
	
begin
	aTerm := app.getMyTerminalDO_NOT_USE();
	if aTerm = null then
		return;	
	endif;
	create theMachines transient;
	
	aTerm.getAllMachines(theMachines,true); // cranes only
	
	foreach aMach in theMachines do
		if aMach.CM_Crane.allHatchJobTypes.includes(self) then
			aMach.CM_Crane.allHatchJobTypes.remove(self);
		endif;
	endforeach;
// cnwrs1 june 2006 was missing
	self.resetAuditsDuringDelete();	//21 Jan 2021	NDL	TFS 50152 
epilog
	delete theMachines;
end;</source>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="3a0b0f21-7bd1-425b-9fcb-aefd30c93473">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------
// Created:	25 November 2003 By: cnwgd1
//--------------------------------------------------
vars

begin
	if _attrName = ETRow_Code then
		return self.name;
	elseif _attrName = ETRow_TimeToComplete then
		return self.estimatedTimeToCompleteMins.String;
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
