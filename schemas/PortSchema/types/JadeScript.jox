	array.add ("ETDef_TerminalDefaultsConfig");
	array.add ("ETDef_TermCashOps");
	etAgent.trxUpdateFromConstant(array);
	delete array;	
	
	// set up the new translatable error messages
	create transAgent transient;
	create tmpArray transient;
	
	tmpArray.add("Validated");
	tmpArray.add("Approved");
	tmpArray.add("Rejected");
	tmpArray.add("Unable_charge_no_debtor");
	tmpArray.add("Freigh_forwar_no_Debtor");
