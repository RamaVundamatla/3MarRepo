begin

	self.constText := self.outputAsXML();

end;</source>
    </JadeMethod>
    <JadeMethod name="setFromXML" id="c908218e-db08-403b-bc19-ee34ce91d0f8">
        <updating/>
        <source>setFromXML(_const : Constant) updating;
// ---------------------------------------------------------------------------
// Created:     17 May 2002 by cnwth2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  TFS			Reason
// ----------   ----------  --------------------------------------------------
// 03 Sep 2019	jlgdi1		45802		Added formType attribute
// 23 Sep 2019 	jlgka1 		TFS 45614 	JMT - Refactoring remove Voyage Commodity Scenario mode
// ---------------------------------------------------------------------------
vars
	
	str,
	tmpChildrenStr,	
	tmpTag,
	tmpStringValue 	: String;
	tmpValue,
	pos				: Integer;
begin
	self.constName	:= _const.name;
	self.constValue	:= _const.valueAsInteger;

	str				:= _const.text;
	self.constText	:= str;

	tmpChildrenStr := str.cnEcGetTagValueOfName(XMLTag_Children);
	if tmpChildrenStr &lt;&gt; null then
		pos := 1;
		while true do
			tmpValue := str.cnEcGetNextTagValueOfName(XMLTag_Child, pos).Integer;
			if pos &lt;= 0 then
				break;
			endif;
			if tmpValue = 0 then
				continue;
			endif;
			self.allChildValues.add(tmpValue + Mod_BaseView);
		endwhile;
	endif;
	//epr TFs 36402 31/1/18
	tmpTag := str.cnEcGetTagValueOfName(XMLTag_Webservices);
	if tmpTag &lt;&gt; null then
		pos := 1;
		while true do
			tmpStringValue := str.cnEcGetNextTagValueOfName(XMLTag_Webservice, pos);
			if pos &lt;= 0 then
				break;
			endif;
			if tmpStringValue = null then
				continue;
			endif;
			self.allWebservices.add(tmpStringValue) ;
		endwhile;
	endif;
	//epr TFs 36402 31/1/18
	tmpTag := str.cnEcGetTagValueOfName(XMLTag_HandHelds);
	if tmpTag &lt;&gt; null then
		pos := 1;
		while true do
			tmpStringValue := str.cnEcGetNextTagValueOfName(XMLTag_HandHeld, pos);
			if pos &lt;= 0 then
				break;
			endif;
			if tmpStringValue = null then
				continue;
			endif;
			self.allHandheldApps.add(tmpStringValue) ;
		endwhile;
	endif;
	//epr TFs 36402 31/1/18
	tmpTag := str.cnEcGetTagValueOfName(XMLTag_MobileApps);
	if tmpTag &lt;&gt; null then
		pos := 1;
		while true do
			tmpStringValue := str.cnEcGetNextTagValueOfName(XMLTag_MobileApp, pos);
			if pos &lt;= 0 then
				break;
			endif;
			if tmpStringValue = null then
				continue;
			endif;
			self.allMobileApps.add(tmpStringValue);
		endwhile;
	endif;
	
	
	// tmp for converting across
//	if (not self.allChildValues.includes(self.childValue)) then
//		self.allChildValues.add(self.childValue);
//	endif;

	self.explanation 		:= str.cnEcGetTagValueOfName(XMLTag_Explanation);
	self.description 		:= str.cnEcGetTagValueOfName(XMLTag_Description);
	self.category 			:= str.cnEcGetTagValueOfName(XMLTag_Category);
	self.isInternal 		:= (str.cnEcGetTagValueOfName(XMLTag_Internal).toUpper = "TRUE");
	self.permType	 		:= str.cnEcGetTagValueOfName(XMLTag_PermType).Integer;
	self.formType := str.cnEcGetTagValueOfName(XMLTag_FormType).Integer;		// 45802

	// menu related attributes
	self.heading 		:= str.cnEcGetTagValueOfName(CM_MenuEntity.XMLTag_Heading);
	self.actionClass	:= str.cnEcGetTagValueOfName(CM_MenuEntity.XMLTag_ActionClass);
	self.attr1			:= str.cnEcGetTagValueOfName(CM_MenuEntity.XMLTag_Attr1);
	self.id				:= str.cnEcGetTagValueOfName(CM_MenuEntity.XMLTag_Id);
	self.extraTableDef	:= str.cnEcGetTagValueOfName(CM_MenuEntity.XMLTag_ExtraTableDef);
	self.mainTableDef	:= str.cnEcGetTagValueOfName(CM_MenuEntity.XMLTag_MainTableDef);
	self.param1			:= str.cnEcGetTagValueOfName(CM_MenuEntity.XMLTag_Param1);
	self.pictureStringButton		:= str.cnEcGetTagValueOfName(CM_MenuEntity.XMLTag_PictureButton);
	self.pictureStringButtonDown	:= str.cnEcGetTagValueOfName(CM_MenuEntity.XMLTag_PictureButtonDown);
	self.pictureStringIcon			:= str.cnEcGetTagValueOfName(CM_MenuEntity.XMLTag_PictureIcon);
	self.schemaName		:= str.cnEcGetTagValueOfName(CM_MenuEntity.XMLTag_SchemaName);
	self.toolTip		:= str.cnEcGetTagValueOfName(CM_MenuEntity.XMLTag_ToolTip);
	self.windowClass	:= str.cnEcGetTagValueOfName(CM_MenuEntity.XMLTag_WindowClass);
	
	self.myConstant := _const.GlobalConstant;//&lt;&lt;this is not actually required at the moment -23/05/2002
																						//but left in anyway
end;</source>
        <Parameter name="_const" type="Constant"/>
    </JadeMethod>
    <JadeMethod name="showInLicenseApp" id="a7106d17-7692-4f0a-9591-9c3bf9911088">
        <source>showInLicenseApp(_clientName : String) : Boolean;
/*
Purpose:	

Date		Who		Reason
20 December 2024	navab1	JIRA 33502
*/

vars

begin
	if self.constValue = Mod_CargoShip
	or self.constValue = PmHMSResource 
	or self.constValue = Mod_YardPlanning 
	or self.constValue = Mod_CargoHandling 
	or self.constValue = Mod_Weighing 
	or self.constValue = Mod_EventStream // this is now a subscription 
	or self.constValue = Mod_Webservice 
	or self.constValue = Mod_CargoGroup then
		return false;
	endif;

	return true;
epilog

end;</source>
        <Parameter name="_clientName" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
