    <JadeMethod name="setupForm" id="bb38a06a-e90c-4bcc-b73f-72d40fa12331">
        <updating/>
        <source>setupForm() updating;
// ---------------------------------------------------------------------------
// Created:     10 May 2001 by cnwrs2
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 
// ---------------------------------------------------------------------------
vars
	theMdiFrame	: Form;

begin
	self.frmDetailsTop.borderStyle := Frame.BorderStyle_None;
	
	inheritMethod();
	
	if self.amInitialisingWithObject
	and self.myCurrentObject = null
	then
		// This means that you have not called the setInitialiseWithObject method correctly
		app.raiseUnexpectedProgramError(class.name, method.name, 'Initialising form with null object');
		return;
	endif;

	self.toolbarStyle := self.ToolbarStyle_ShowNoHide;
	self.frmToolbar.priorityRight := true;
	self.showToolbar := true;
	
	self.setupPermissions();
	self.initForm();

	self.setMyDataClass();
	
	self.zInitControls();
	
	/* Now done at the end of self.loadDataForFirstTime()
	// as loadDataForFirstTime clears the values set by add/edit			
	if self.initialMode &lt;&gt; 0 then
		if self.initialMode = Mode_Add then
			self.zDoAdd();
		elseif self.initialMode = Mode_Update then
			self.zDoEdit();
		endif;
	endif;*/

	self.frmTableFilter.setupControl(self.tblData, null); //05/06/2024	navkc1 CR 63736 Task 63770
end;</source>
    </JadeMethod>
    <JadeMethod name="setupPermissions" id="9baaa4e1-6b1c-43ef-a43d-38c4f9c81777">
        <updating/>
        <source>setupPermissions() updating;
// ---------------------------------------------------------------------------
// Created:     16 March 2005 by cnwrs2
//
// Purpose:     
// ---------------------------------------------------------------------------
vars

begin

	if app.getMyUser.canDo(self.myTerminal, self.permissionMaint) then
		self.allowAdd	 := true;
		self.allowDelete := true;
		self.allowUpdate := true;
	else
		self.allowAdd	 := false;
		self.allowDelete := false;
		self.allowUpdate := false;
	endif;

end;</source>
    </JadeMethod>
