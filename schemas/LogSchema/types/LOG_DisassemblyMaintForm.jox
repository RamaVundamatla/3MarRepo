    <JadeMethod name="doAddNewLog" id="709a035a-7249-4f76-8165-580df7ad252b">
        <updating/>
        <source>doAddNewLog() protected, updating;

vars

	newLog 	: CMIF_LogRegrade;
	newId, newGrade, newLength, newMin, newMax, newLoc, newType, newTreatment : String;
	display	: String;
begin

	if getNewLogDetail(newId, newGrade, newLength, newType, newTreatment, newMin, newMax, newLoc) then
		if checkForUniqueId(newId, true) then
			create newLog transient;
			newLog.initForDisassembly(newId, newGrade, newLength, newType, newTreatment, newMin, newMax, newLoc, self.cmbNewLocation.listObject.CM_LocationsController);
			self.allNewLogs.add(newLog);
			doDisplay(Add);
		endif;
	endif;

/*	if (not app.noErrors) then
		app.showErrorWarnings();
		return;
	endif;*/
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doDisplay" id="53e87949-e47e-4455-a626-055c918d96cf">
        <updating/>
        <source>doDisplay(_type : Integer) protected, updating;

vars

	cmif				: CMIF_LogRegrade;
	display				: String;
	pos					: Integer;
	logId, nextLogId	: String;
	trailingNum, lastNum: String;

begin

	initDisplayTable();
	foreach cmif in self.allNewLogs do
		display := cmif.getDisplay();		
		self.tblDisplayDetail.addItem(display);
	endforeach;
	displayResidual();
	if self.mySelectedNewLog &lt;&gt; null and _type = Update then
		pos := self.allNewLogs.indexOf(self.mySelectedNewLog) + 1;
	else
		pos := self.tblDisplayDetail.rows;
	endif;
	self.selectNewLog(pos);
	self.tblNewLogDetail.moveFirst();
	logId := self.tblNewLogDetail.getValueByName(ETRow_NewLogId).String;
	if logId &lt;&gt; null then
		nextLogId := logId.incrementID(1);
		self.tblNewLogDetail.setValueByName(ETRow_NewLogId, nextLogId);	
	endif;

end;</source>
        <access>protected</access>
        <Parameter name="_type" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="doOptLocationClick" id="c9756dab-8595-41e9-8129-961f046fb409">
        <updating/>
        <source>doOptLocationClick() updating, protected;

vars

begin

	self.selection := LOGLOCATION;
	self.tblSelection.visible := true;
	self.txtDetails.visible := true;
	self.txtDetails.text := null;
	self.tblSelection.showHideRowsByViewName("ViewDisassemblyLoc", CM_EntryTable.ShowHideRows, false); 
	self.tblSelection.optimiseHeadingColumn();
	self.tblSelection.adjustHeight(1000);
//	resize();
	self.resetTopPositions();
//	setDistances();
//	self.resize();
	tblSelection.goToRowByName(ETRow_Location);
	tblSelection.setFocus;
	self.myLog := null;
	self.setButtons(false);

	self.setNavigatorHeading('By Location');

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doOptTicketClick" id="f941a626-7559-42cc-b862-abc15e28cbfb">
        <updating/>
        <source>doOptTicketClick() updating, protected;

vars

begin

	self.selection := LOGID;
	self.tblSelection.visible 	:= true;
	self.txtDetails.visible 	:= true;
	self.txtDetails.text := null;
	clearSelectionDataTable();
	
	self.tblSelection.showHideRowsByViewName("ViewDisassemblyId", CM_EntryTable.ShowHideRows, false); 
	self.tblSelection.optimiseHeadingColumn();
	self.tblSelection.adjustHeight(1000);
//	resize();
//	setDistances();
	self.resetTopPositions();
//	resize();
	self.tblSelection.goToRowByName(ETRow_LogId);
	self.tblSelection.setFocus;
	self.setButtons(false);
	self.myLog := null;
	self.setNavigatorHeading('By ID');

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRefresh" id="8dfb64e7-bddc-46ab-a954-483c9b61f75e">
        <updating/>
        <source>doRefresh() updating, protected;

vars

begin
	
	self.tblNewLogDetail.userInputEnabled := false;
	self.tblActionData.userInputEnabled := false;
	self.setButtons(false);
	clearDisplay();
	self.txtDetails.text := null;
	self.tblSelection.clearValues;
	self.myLog := null;
	self.loadCombos();
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doRemoveNewLog" id="5bd5856a-b1fc-4efb-bf2f-dcbe4d47683e">
        <updating/>
        <source>doRemoveNewLog() protected, updating;

vars

begin

	if self.mySelectedNewLog &lt;&gt; null then
		self.allNewLogs.remove(self.mySelectedNewLog);
		delete self.mySelectedNewLog;
		clearDisplay();
		doDisplay(Remove);
	endif;

end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="doResize" id="aaea28bd-21ff-4917-9678-bf877dabe8fa">
        <updating/>
        <source>doResize() updating;

vars

begin
	if self.frmToolbar.visible then
		self.frmToolbar.repositionAfterResize;
	endif;
	self.optLocation.left := 87;
	self.splitContainer.cnEcResizeContents();

end;</source>
    </JadeMethod>
    <JadeMethod name="doSave" id="4b1d3f97-f05e-428b-9198-d9f69fb87501">
        <updating/>
        <source>doSave(_exiting : Boolean): Boolean updating, protected;
// 10/12/2014  cnwdb2	PAR 35364

vars
	passport		: CM_Passport;
	newPieces		: Integer;
	comment			: String;
	reason			: String;
	recovery		: String;
	action			: Integer;
	rtnValue		: Boolean;
	cmif			: CMIF_Remote;
	manager			: CM_RemoteDataManagerInternal;
	tempLogArray	: CMIF_LogRegradeArray;
	isBackground	: Boolean;
	result			: Integer;
	
begin

	app.mousePointer := MousePointer_HourGlass;	
	
	if not validateForSave() then	// when ID enetered and no tabbing done (or log not found). PAR 21688 Dec 2009
		return false;
	endif;
	
	isBackground := self.btnBackground.value;
	newPieces := self.tblSelection.getValueByName(ETRow_NewPieces).Integer;
	comment := self.tblSelection.getValueByName(ETRow_Comment).String;
	reason := self.tblActionData.getValueByName(ETRow_ReasonCode).String;
	recovery := self.tblActionData.getValueByName(ETRow_RecoveryCode).String;
	rtnValue := true;
	
	
	self.clearErrorWarnings();
	passport := app.myPassport;
	passport.clearErrorsWarnings();	//also, need to clear passport errors - pasport can have errors from another screen and it is cleared usualy in trx method.
		
	if isBackground then
		//want to warn early of these as they will prevent the logs processing in the background
		//non-background handled normally trx
		if reason = null then
			rtnValue := false;
		//	app.addWarningFullPassport(REQUIRED_FIELD,app.getErrorString1(REQUIRED_FIELD, 'reason code'), null, null, passport);
			app.addWarningFullPassport(Input_required_field_reasonCde,app.getErrorString(Input_required_field_reasonCde), null, null, passport); // cnwdb2	PAR 35364
		endif;
		if recovery = null then
			rtnValue := false;
	//		app.addWarningFullPassport(REQUIRED_FIELD,app.getErrorString1(REQUIRED_FIELD, 'recovery code'), null, null, passport);
			app.addWarningFullPassport(Input_required_field_recvryFld,app.getErrorString(Input_required_field_recvryFld), null, null, passport); // cnwdb2	PAR 35364
		endif;
		if self.residualLength &lt; 0 then
			rtnValue := false;
			app.addWarningFullPassport(LengthOfNewExceedsOld,app.getErrorString(LengthOfNewExceedsOld), null, null, passport);
		endif;
	endif;

	if newPieces &lt;&gt; self.allNewLogs.size then
		rtnValue := false;
		app.addWarningFullPassport(InvalidPieceCount,app.getErrorString(InvalidPieceCount), null, null, passport);
	endif;
		
	if self.myLog &lt;&gt; null and self.myLog.isAverageScaled then	// Average scaled not editable. PAR 21688 Dec 2009
		rtnValue := false;	// if isBackGround, then it will stop processing at this point as well.
		app.addWarningFullPassport(AverageScaledLogNotEditable, app.getErrorString1(AverageScaledLogNotEditable, self.myLog.id), null, null, passport);		
	endif;

	if self.myLog = null or self.allNewLogs.size = 0 then
		if rtnValue then	// populate this wqrning if all other requirements are fulfilled. As previous functinlaity from 2005
			rtnValue := false;
			app.addWarningFullPassport(Err_DisassemblyIncomplete,app.getErrorString(Err_DisassemblyIncomplete), null, null,	passport);
		endif;
	endif;
	
	if not rtnValue then
		app.showErrorWarningDialog('Disassembly', passport, ErrWarnMode_Add);
		self.setAllErrorWarnings(passport);	// copies errors to this form and shows in err/warnings window
		return rtnValue;
	endif;
	
	
	
	self.setWeightNewLogs();

	if isBackground then
		create cmif transient;
		create manager transient;
		create tempLogArray transient;
		cmif.transactionType	:= manager.DISASSEMBLYRQ;
		cmif.terminal			:= self.myTerminal.code;
		cmif.originalLog := self.myLog.id;
		cmif.residualLength := self.residualLength;
		cmif.residualVolume := self.residualVolume;
		cmif.reason 		:= reason;
		cmif.recovery		:= recovery;
		cmif.comment		:= comment;
		self.allNewLogs.copy(tempLogArray);
		cmif.allDisassemblyLogs := tempLogArray;
	endif;
	
	// ccms 1107 / PAR20999 - need to organize warnings to a user
	while true do

		if isBackground then
			rtnValue := manager.processInternal(cmif, passport);
		else
			app.myTrxUA.trxDisassembleLogs(self.myLog, self.allNewLogs, self.residualLength, self.residualVolume, reason, recovery, comment, passport);
			rtnValue := passport.trxCompletedOK;
		endif;

		if passport.trxCompletedOK then
			// Clear errors/warnings from form and err/warnings window
			self.clearErrorWarnings();
			break;

		else
			//result := app.showErrorWarningDialog('Regrade', passport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			result := app.showErrorWarningDialog('Reinstate Rejects', passport, ErrWarnMode_Update + ErrWarnMode_CanAckWarnings);
			if passport.noErrors and result = IDOK then
				// there must have just been warnings that the user has acknoledged so ..
				passport.warningsAcknowledged	:= true;
				continue;
			endif;
			self.setAllErrorWarnings(passport);	// copies errors to this form and shows in err/warnings window
			return false;
			
		endif;
		break;

	endwhile;
	
epilog
	// removed from epilog, par 20999. Oct 20999
	/*if not rtnValue then
		app.showErrorWarningDialog('Disassembly', passport, ErrWarnMode_Add);
		self.setAllErrorWarnings(passport);	// copies errors to this form and shows in err/warnings window
	else*/
	if rtnValue then
		self.clearErrorWarnings();
		if (not _exiting) then
			doRefresh();
		endif;
	endif;
	delete manager;
	delete cmif;
	app.mousePointer := MousePointer_Default;	
	return rtnValue;
	
end;</source>
        <access>protected</access>
        <Parameter name="_exiting" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSearch" id="0560f713-7a66-4468-a55b-55e0b7203c71">
        <updating/>
        <source>doSearch(_isLostFocus: Boolean): Boolean updating, protected;

vars
	logId : String;
begin
	if self.selection = LOGID then
		logId := self.tblSelection.getValueByName(ETRow_LogId).String;
	else
		logId := self.tblSelection.getValueByName(ETRow_LogIdMulti).String;
	endif;
	
	if self.myLog &lt;&gt; null and self.myLog.id = logId then 
		// do nothing as logid hasn't changed.
		return false;
	else		
		self.myLog := null;
		self.myLocation := null;
		self.mySelectedDocketDef := null;
		self.doSearchNew(true);
		if self.myLog &lt;&gt; null then
			return true;
		endif;
		return false;
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_isLostFocus" type="Boolean"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
