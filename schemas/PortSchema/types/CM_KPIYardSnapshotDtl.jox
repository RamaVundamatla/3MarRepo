<Class name="CM_KPIYardSnapshotDtl" id="f9850b50-93f7-4fab-870e-31cc9c2c6ac5">
    <superclass name="CM_KPISnapshotDtl"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="kpiPeriod"/>
    <PrimAttribute name="freeTEU" id="becc34b8-37c5-4964-aede-dd5cb0f7e60b">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <PrimAttribute name="usedTEU" id="0b416b0f-21d5-42be-b8a8-d2c184207fb0">
        <embedded/>
        <type name="Integer"/>
        <access>readonly</access>
    </PrimAttribute>
    <JadeMethod name="displayString" id="ed0dc7bd-fc08-4faf-aa83-34fc1e99e3e2">
        <source>displayString() : String;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 July 2012	cnwdw1	Initial creation
*/
vars

begin
	return "Id: " &amp; self.id &amp; " Type: " &amp; self.type &amp; " FreeTEU: " &amp; self.freeTEU.String &amp;
		" UsedTEU: " &amp; self.usedTEU.String &amp; " Cargo Count: " &amp; self.allCargo.size.String;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="setFrom" id="6ff6f50b-f281-4d5f-adbd-6d583f5e8122">
        <updating/>
        <source>setFrom(_object: CM_Object; _at: TimeStamp; _movements: CM_KPIMovementDtlArray) updating;
/*
Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
26 July 2012	cnwdw1	Initial creation
*/
vars
	ta: CM_TerminalArea;
	lc: CM_LocationsController;
	ti: CM_TrackedItem;
	cargoLocation: CM_KPICargoLocationDtl;

	tas : CM_TerminalAreaSet;
	yas: CM_YABlockSet;
	oa: ObjectArray;
	total: Integer;
	
	movement: CM_KPIMovementDtl;

begin
	if _object.isKindOf(CM_TerminalArea) then
		ta := _object.CM_TerminalArea;

		self.id := ta.id;
		self.type := "YARD";

		create tas transient;
		tas.add(ta);
		create yas transient;
		if not ta.isBlockStack then
			app.myTrxUA.trxCalcLocationStats(tas, yas, oa, app.myPassport);
			if ta.myLocationStatistics &lt;&gt; null then
				if ta.myLocationStatistics.c20Used &lt;&gt; 0 or
				   ta.myLocationStatistics.c20Free &lt;&gt; 0 then
				   // Assume 20ft store
					self.usedTEU := ta.myLocationStatistics.used;
					self.freeTEU := ta.myLocationStatistics.free;
				else
					// Assume 40ft store
					self.usedTEU := ta.myLocationStatistics.used * 2;
					self.freeTEU := ta.myLocationStatistics.free * 2;
				endif;
			endif;	
		else
			foreach lc in ta.allLocationsControllers do
				foreach ti in lc.allTrackedItems do
					self.usedTEU := self.usedTEU + ti.getNumTEU.Integer.max(1);
				endforeach;
			endforeach;
			self.freeTEU := ta.getMaxCapacity - self.usedTEU;
		endif;
		
		//write "Current usedTEU: " &amp; self.usedTEU.String &amp; " freeTEU: " &amp; self.freeTEU.String;
		/*
		foreach lc in ta.allLocationsControllers do
			foreach ti in lc.allTrackedItems do
				create cargoLocation transient;
				cargoLocation.setFromTrackedItem(ti);
				self.allCargo.add(cargoLocation);
			endforeach;
		endforeach;
		*/
		
		foreach movement in _movements reversed do
			if movement.isYardSource and movement.getPrimeSource = ta.id then
				//write movement.displayString;
				self.freeTEU := self.freeTEU - movement.teu;
				self.usedTEU := self.usedTEU + movement.teu;
			endif;
			if movement.isYardTarget and movement.getPrimeTarget = ta.id then
				//write movement.displayString;
				self.freeTEU := self.freeTEU + movement.teu;
				self.usedTEU := self.usedTEU - movement.teu;
			endif;
		endforeach;
		if self.freeTEU &lt; 0 then
			self.freeTEU := -1;		// Do not know the capacity of the area
		endif;
		self.dateTime := _at;
	endif;
	
epilog
	delete tas;
	delete yas;
end;</source>
        <Parameter name="_object" type="CM_Object"/>
        <Parameter name="_at" type="TimeStamp"/>
        <Parameter name="_movements" type="CM_KPIMovementDtlArray"/>
    </JadeMethod>
</Class>
