    <JadeMethod name="zStartSearch" id="d0838ecf-2067-426b-b37c-cbab16707e05">
        <updating/>
        <source>zStartSearch() protected, updating;

vars

begin

	mousePointer := MousePointer_HourGlass;
	if zDoSearch(true) then
		self.tblActionData.userInputEnabled := true;
	endif;
epilog

	mousePointer       := MousePointer_Default;

end;</source>
        <access>protected</access>
    </JadeMethod>
