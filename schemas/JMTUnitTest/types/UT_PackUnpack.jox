&lt;ediDataType&gt;61&lt;/ediDataType&gt;
&lt;/CM_EDIFieldMappingTypeAttributes&gt;
&lt;CM_EDIFieldMappingTypeReferences&gt;
&lt;/CM_EDIFieldMappingTypeReferences&gt;
&lt;CM_EDIFieldMappingTypeCollections&gt;
