    <JadeMethod name="doDragDropFromListBox" id="cd218b12-bc62-486c-8eaf-621f81fed73c">
        <updating/>
        <source>doDragDropFromListBox(_listBox : ListBox input; win: Window input; x: Real; y: Real) updating;
// ---------------------------------------------------------------------------
// Created:		January 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
