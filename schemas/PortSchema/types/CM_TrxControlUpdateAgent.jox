    </JadeMethod>
    <JadeMethod name="trxProcessEDIData" id="1b6d5eca-5a94-4e7a-91fe-d42ed85432d6">
        <updating/>
        <source>trxProcessEDIData(_ediData :CM_EDIData input; _validateOnly, _useDeferredUpdate : Boolean; _passport : CM_Passport input) updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
			epr par 35304 2/12/14 
16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
12 Nov 2018	jlgrs1	TFS 41659 STWR Make EDI MultiThreaded Stage 6
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
29 Oct 2019	cnwrs1	TFS 47281
20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
============================================================================*/

vars
	partsDone 		 : Integer;
	partsInJob 		 : Integer;
	progressStr 	 : String;
	progressTS 		 : TimeStamp;
	ediTI 			 : CM_EDITrackedItem;
	status 			 : Integer;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if _validateOnly then
		app.setContinueCMExceptions(true);
	else
		app.setContinueCMExceptions(false);
	endif;

	beginTransaction;
	
	_passport.useTITransactionDeferUpdate := _useDeferredUpdate; 
	_passport.useTIDictDeferUpdate := _useDeferredUpdate;
	_passport.useEventDeferUpdate := _useDeferredUpdate; //30/05/2025	navkc1 JIRA MTN 34639
	
	partsInJob	:= _ediData.allEDITrackedItems.size();
	partsDone	:= null;
	
	progressStr	:= app.getString(Loading_EDI_Data_Total, partsInJob.display);
	progressTS	:= app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	_ediData.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, _passport);
	
	foreach ediTI in _ediData.allEDITrackedItems do
		partsDone := partsDone + 1;
		_ediData.updateProgress(progressTS, progressStr, partsInJob, partsDone, false, _passport);
		
		ediTI.loadDB(_validateOnly,_passport);
	endforeach;
	
	_ediData.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, _passport);
	
	if _validateOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		return;
	else
		if _passport.noErrors() then
			// sucessful DB Load so update status in same transaction
			_passport.doDeferredUpdates();
			if _passport.noErrors() then
				// use passport to get new status for EDI Data
				status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
				app.myUtilityUA.utlSetEDIDataStatusAfterVerify(_ediData, status);
			endif;
		endif;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);

	if _validateOnly or _passport.hasErrors then
		// use passport to get new status for EDI Data
		status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(_ediData, status);	// par 27392 cnwrs1 14 Apr 2011
	endif;

end;</source>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_useDeferredUpdate" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxProcessEDIDebtor" id="c6531ec4-525b-46fd-82db-238c2e86243d">
        <updating/>
        <source>trxProcessEDIDebtor(_ediData :CM_EDIData input;_passport: CM_Passport input) updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
03 Jun 2015	cnwer1	Initial creation PAR 36370 TFS 188 EDI Debtor maintenance
16 May 2016	cnwns1	TFS 488 	Multi Timezone Support
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
29 Oct 2019	cnwrs1	TFS 47281
20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
12 Nov 2025 navlc30 JIRA 36357 - LINX - Enable importing debtor addresses via EDI
============================================================================*/

vars
	partsDone 		 : Integer;
	partsInJob 		 : Integer;
	progressStr 	 : String;
	progressTS 		 : TimeStamp;
	ediTI 			 : CM_EDITrackedItem;
	status 			 : Integer;
	dynaDict 		 : DynaDictionary;
	iter 			 : Iterator;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);
	
	beginTransaction;
	
	_passport.useTITransactionDeferUpdate := false; 
	_passport.useTIDictDeferUpdate := false;

	partsInJob	:= _ediData.allEDITrackedItems.size();
	partsDone	:= null;
	
	progressStr	:= app.getString(Loading_EDI_Data_Total, partsInJob.display);
	progressTS	:= app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	
	_ediData.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, _passport);
	
	//Commenting the below use dynaDict as we now have both CM_EDIDebtorTI and EM_EDIAddressTI objects in allEDITrackedItems
	/*create dynaDict transient;																				//12.11.2025 navlc30 #36357
	dynaDict.setMembership(CM_EDIDebtorTI);
	dynaDict.addMemberKey(CM_EDIDebtorTI::action.name ,false,true);
	dynaDict.addMemberKey(CM_EDIDebtorTI::myParentDebtorNode.name,false,true);
	dynaDict.endKeys(true);
	_ediData.allEDITrackedItems.copy(dynaDict);
	
	iter :=dynaDict.createIterator;
	while iter.next(ediTI) do
		partsDone := partsDone + 1;
		_ediData.updateProgress(progressTS, progressStr, partsInJob, partsDone, false, _passport);
		
		ediTI.loadDB(false,_passport);
	endwhile;*/
	
	//Using common foreach mechanism instead of dyna dict as we now have both CM_EDIDebtorTI and EM_EDIAddressTI objects in allEDITrackedItems
	foreach ediTI in _ediData.allEDITrackedItems do															//12.11.2025 navlc30 #36357
		partsDone := partsDone + 1;
		_ediData.updateProgress(progressTS, progressStr, partsInJob, partsDone, false, _passport);
		
		ediTI.loadDB(false,_passport);
	endforeach;	
	
	if _passport.noErrors() then
		// sucessful DB Load so update status in same transaction
		_passport.doDeferredUpdates();
		if _passport.noErrors() then
			// use passport to get new status for EDI Data
			status := _ediData.getStatusAfterVerifyOrDBLoad (false, _passport);
			app.myUtilityUA.utlSetEDIDataStatusAfterVerify(_ediData, status);
		endif;
	endif;
	
	_ediData.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, _passport);
	
epilog
	self.finaliseActivityWithPassport(_passport);

	if  _passport.hasErrors then
		// use passport to get new status for EDI Data
		status := _ediData.getStatusAfterVerifyOrDBLoad (false, _passport);
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(_ediData, status);	// par 27392 cnwrs1 14 Apr 2011
	endif;
	delete dynaDict;
	delete iter;
end;</source>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxProcessEDIFleet" id="f67fd153-f0ae-4bfe-b979-df0394e44684">
        <updating/>
        <source>trxProcessEDIFleet(_ediData :CM_EDIDataFleet input; _validateOnly : Boolean; _passport : CM_Passport input) updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
14 Feb 2013	cnwrs1	Par 31143 	EDI TRX not handling dbLoadErrors after no verify errors take 4
04 Aug 2014	cnwrs1	Par 34668	EDI Status can be wrong if doDeferredUpdate fails
08 Oct 2015	cnwrs1	Par 36863  	make EDI consistant times when refreshing progress bar
16 May 2016	cnwns1	TFS 488 	Multi Timezone Support
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
29 Oct 2019	cnwrs1	TFS 47281
20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
============================================================================*/

vars
	ediTI 			: CM_EDITrackedItem ;
	ediTiFleet 		: CM_EDIFleetTI;
	done 			: Integer; 
	todo 			: Integer;
	tmpTiMaster  	: CM_TIMaster;
	realTiMCont  	: CM_TIMaster;
	foundTiMCont  	: CM_TIMaster;
	operator 		: CM_Operator;
	status 			: Integer;
	progressTS 		: TimeStamp;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if _validateOnly then
		app.setContinueCMExceptions(true);
	else
		app.setContinueCMExceptions(false);
	endif;

	beginTransaction;
	
	_passport.useTITransactionDeferUpdate := false; 
	_passport.useTIDictDeferUpdate := false;

	//utl
	progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	todo := _ediData.allEDITrackedItems.size;
	done := null;
	_ediData.updateProgress(progressTS, "Loading into JMT...", todo, done, true, _passport);
	
	foreach ediTI in _ediData.allEDITrackedItems do
		done := done + 1;
		_ediData.updateProgress(progressTS, "Loading into JMT...", todo, done, false, _passport);
		
		ediTiFleet := ediTI.CM_EDIFleetTI;
		
		operator := ediTiFleet.getOperator();
		if operator = null then
			operator := _ediData.myOperator;
		endif;
		
		if ediTiFleet.cargoType = TI_CargoType_Container then
		
			//create master ti container
			foundTiMCont := app.myRoot.allTiMasters.getAtKey(TI_CargoType_Container, ediTiFleet.id);
			
			if ediTiFleet.isForDelete  then
				if foundTiMCont &lt;&gt; null then
					app.myUtilityDA.utlDeleteTIMaster(foundTiMCont, app.myPassport);
				endif;
				continue;
			endif;	
			
			if foundTiMCont = null  then
				create tmpTiMaster as CM_TIMasterContainer transient;				
				tmpTiMaster.CM_TIMasterContainer.convertFromEDIFleetTi( ediTiFleet , operator);
				app.myUtilityCA.utlCreateTiMasterContainer(tmpTiMaster.CM_TIMasterContainer, realTiMCont, false, app.myPassport);
			else
				tmpTiMaster := app.createUpdateProxy(foundTiMCont).CM_TIMaster;
				tmpTiMaster.CM_TIMasterContainer.convertFromEDIFleetTi( ediTiFleet, operator);
				app.myUtilityUA.utlUpdateTiMasterContainer(tmpTiMaster.CM_TIMasterContainer, app.myPassport);
			endif;
			
		elseif ediTI.cargoType =TI_CargoType_Generator then
			//create master ti gen
			foundTiMCont := app.myRoot.allTiMasters.getAtKey(TI_CargoType_Generator, ediTiFleet.id);
			
			if ediTiFleet.isForDelete  then
				if foundTiMCont &lt;&gt; null then
					app.myUtilityDA.utlDeleteTIMaster(foundTiMCont, app.myPassport);
				endif;
				continue;
			endif;	
			
			if foundTiMCont = null  then
				create tmpTiMaster as CM_TIMasterGenerator transient;				
				tmpTiMaster.CM_TIMasterGenerator.convertFromEDIFleetTi(ediTiFleet, operator);
				app.myUtilityCA.utlCreateTiMasterGenerator(tmpTiMaster.CM_TIMasterGenerator, realTiMCont, false, app.myPassport);
			else
				tmpTiMaster := app.createUpdateProxy(foundTiMCont).CM_TIMaster;
				tmpTiMaster.CM_TIMasterGenerator.convertFromEDIFleetTi(ediTiFleet, operator);
				app.myUtilityUA.utlUpdateTiMasterGenerator(tmpTiMaster.CM_TIMasterGenerator, app.myPassport);
			endif;
		else
			//trailer
			foundTiMCont := app.myRoot.allTiMasters.getAtKey(ediTiFleet.cargoType, ediTiFleet.id) ;
			
			if ediTiFleet.isForDelete  then
				if foundTiMCont &lt;&gt; null then
					app.myUtilityDA.utlDeleteTIMaster(foundTiMCont, app.myPassport) ;
				endif;
				continue;
			endif;	
			
			if foundTiMCont = null  then
				create tmpTiMaster as CM_TIMasterTILC transient;				
				tmpTiMaster.CM_TIMasterTILC.convertFromEDIFleetTi(ediTiFleet , operator);
				//app.myTrxCA.trxCreateTIMasterTILC(tmpTiMaster.CM_TIMasterTILC, realTiMCont, app.myPassport);
				app.myUtilityCA.utlCreateTiMasterTILC(tmpTiMaster.CM_TIMasterTILC, realTiMCont, app.myPassport);
			else
				tmpTiMaster := app.createUpdateProxy(foundTiMCont).CM_TIMaster;
				tmpTiMaster.CM_TIMasterTILC.convertFromEDIFleetTi(ediTiFleet, operator);
				//app.myTrxUA.trxUpdateTIMasterTILC(tmpTiMaster.CM_TIMasterTILC, app.myPassport);
				app.myUtilityUA.utlUpdateTIMasterTILC(tmpTiMaster.CM_TIMasterTILC, app.myPassport);
			endif;
		endif;
		delete tmpTiMaster;
	endforeach;
	
	_ediData.updateProgress(progressTS, "Loading into JMT...", todo, done, true, _passport);
	
	if _validateOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		return;
	else
		if _passport.noErrors() then
			// sucessful DB Load so update status in same transaction
			_passport.doDeferredUpdates();
			if _passport.noErrors() then
				// use passport to get new status for EDI Data
				status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
				app.myUtilityUA.utlSetEDIDataStatusAfterVerify(_ediData, status);
			endif;
		endif;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);

	if _validateOnly or _passport.hasErrors then
		// use passport to get new status for EDI Data
		status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(_ediData, status);	// par 27392 cnwrs1 14 Apr 2011
	endif;
end;</source>
        <Parameter name="_ediData" type="CM_EDIDataFleet" usage="input"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxProcessEDIFleetWagon" id="56b585d2-3c17-4e76-9cbc-86149f36e107">
        <updating/>
        <source>trxProcessEDIFleetWagon(_ediData :CM_EDIDataFleetWagon input; _validateOnly : Boolean; _passport : CM_Passport input) updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
14 Feb 2013	cnwrs1	Par 31143 	EDI TRX not handling dbLoadErrors after no verify errors take 4
04 Aug 2014	cnwrs1	Par 34668	EDI Status can be wrong if doDeferredUpdate fails
08 Oct 2015	cnwrs1	Par 36863 	make EDI consistant times when refreshing progress bar
16 May 2016	cnwns1	TFS 488  	Multi Timezone Support
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
29 Oct 2019	cnwrs1	TFS 47281
20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
============================================================================*/

vars
	ediTI 			: CM_EDITrackedItem ;
	ediWagon 		: CM_EDIFleetWagonMasterTI;
	done 			: Integer;
	todo 			: Integer;
	tmpWagon 		: CM_WagonMaster;
	realWagon		: CM_WagonMaster;
	foundWagon 		: CM_WagonMaster;
	operator 		: CM_Operator;
	status 			: Integer;
	progressTS 		: TimeStamp;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if _validateOnly then
		app.setContinueCMExceptions(true);
	else
		app.setContinueCMExceptions(false);
	endif;

	progressTS := app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	beginTransaction;
	
	_passport.useTITransactionDeferUpdate := false; 
	_passport.useTIDictDeferUpdate := false;
	
	todo := _ediData.allEDITrackedItems.size;
	_ediData.updateProgress(progressTS, "Loading into JMT...", todo, done, true, _passport);
	
	foreach ediTI in _ediData.allEDITrackedItems do
		ediWagon := ediTI.CM_EDIFleetWagonMasterTI;
		
		done := done + 1;
		_ediData.updateProgress(progressTS, "Loading into JMT...", todo, done, false, _passport);
		
		//create master ti container
		foundWagon := app.myRoot.allWagonMasters.getAtKey(ediWagon.id.toUpper ) ;		// PAR21262
		
		if foundWagon = null  then
			create tmpWagon as CM_WagonMaster transient;				
			tmpWagon.convertFromEDIFleet( ediWagon );
			app.myUtilityCA.utlCreateWagonMaster(tmpWagon, realWagon, app.myPassport);
		else
			tmpWagon := app.createUpdateProxy(foundWagon).CM_WagonMaster;
			tmpWagon.convertFromEDIFleet( ediWagon );
			app.myUtilityUA.utlUpdateWagonMaster(tmpWagon.CM_WagonMaster,app.myPassport);
		endif;

		delete tmpWagon;
	endforeach;
	
	_ediData.updateProgress(progressTS, "Loading into JMT...", todo, done, true, _passport);
	
	if _validateOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		return;
	else
		if _passport.noErrors() then
			// sucessful DB Load so update status in same transaction
			_passport.doDeferredUpdates();
			if _passport.noErrors() then
				// use passport to get new status for EDI Data
				status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
				app.myUtilityUA.utlSetEDIDataStatusAfterVerify(_ediData, status);
			endif;
		endif;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);

	if _validateOnly or _passport.hasErrors then
		// use passport to get new status for EDI Data
		status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(_ediData, status);	// par 27392 cnwrs1 14 Apr 2011
	endif;
end;</source>
        <Parameter name="_ediData" type="CM_EDIDataFleetWagon" usage="input"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxProcessEDIMoveDataPartial" id="37d37162-19c0-4f6f-bf1f-2b4b6057b5d8">
        <updating/>
        <source>trxProcessEDIMoveDataPartial(_ediData :CM_EDIDataMove input; _useDeferredUpdate : Boolean; _passport : CM_Passport input) updating;
//
// Purpose:			
//
// Parameters:			
//
// Return Value:		
//
// Changed On	By			Reason
// ----------	--------	-----------------------------------------------------------------------
// 05/06/2024	navdap1		Initial creation TFS 64459 EUP - Lock when loading Move EDI file
//
vars
	partsDone : Integer;
	partsInJob : Integer;
	progressStr : String;
	progressTS : TimeStamp;
	ediTI : CM_EDITrackedItem;
	status : Integer;
	lastUpdated : Decimal [20];

begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	app.setContinueCMExceptions(false);

	beginTransaction;
	
	_passport.useTITransactionDeferUpdate := _useDeferredUpdate; 
	_passport.useTIDictDeferUpdate := _useDeferredUpdate;
	_passport.useEventDeferUpdate := _useDeferredUpdate;
	
	partsInJob	:= _ediData.allEDITrackedItems.size();
	partsDone	:= null;
	
	progressStr	:= app.getString(Loading_EDI_Data_Total, partsInJob.display);
	progressTS	:= app.actualTimeServer();
	
	_ediData.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, _passport);
	lastUpdated := app.relativeMachineTime;
	
	foreach ediTI in _ediData.allEDITrackedItems do
		// ignore ones that are already DB Loaded
		if ediTI.status = CM_EDIFile.EDI_STATUS_DBLOADED then
			continue;
		endif;
		
		partsDone := partsDone + 1;
		_ediData.updateProgress(progressTS, progressStr, partsInJob, partsDone, false, _passport);
		
		ediTI.loadDB(false, _passport);
		
		// if everything's ok, update status to DB Loaded. Otherwise leave status as it is
		if _passport.noErrors then
			app.myUtilityUA.utlSetEDIDataStatusAfterVerify(_ediData, CM_EDIFile.EDI_STATUS_DBLOADED);
		else
			app.writeLog(method.qualifiedName &amp; Tab &amp; "Got errors for EDI TI " &amp; ediTI.getOidString &amp; ": " &amp; _passport.getErrorsAsString &amp; " - leave status as is " &amp; ediTI.status.String, LogDEBUG);
		endif;
		
		if (app.relativeMachineTime - lastUpdated) &gt; CMIF_Monitor.Monitor_TimeBetweenUpdates then
			lastUpdated := app.relativeMachineTime;
			_passport.doDeferredUpdates();
			process.sleep(100);
			
			app.writeLog(method.qualifiedName &amp; Tab &amp; "Updating - committing transaction", LogDEBUG);
			app.cmsCommitTransaction(_passport);
			
			beginTransaction;
			_passport.useTITransactionDeferUpdate := _useDeferredUpdate; 
			_passport.useTIDictDeferUpdate := _useDeferredUpdate;
			_passport.useEventDeferUpdate := _useDeferredUpdate;
			app.writeLog(method.qualifiedName &amp; Tab &amp; "starting new transaction and setting deferred everything", LogDEBUG);
		endif;
		
	endforeach;
	
	_ediData.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, _passport);
	
	if _passport.noErrors() then
		// sucessful DB Load
		_passport.doDeferredUpdates();
	endif;
	
epilog
	self.finaliseActivityWithPassport(_passport);
	
	// Get new status for EDI Data
	status := _ediData.getStatusAfterVerifyOrDBLoad (false, _passport);
	app.writeLog(method.qualifiedName &amp; Tab &amp; "Updating EDI Data status to " &amp; status.String, LogDEBUG);
	app.myTrxUA.trxSetEDIDataStatusAfterVerify(_ediData, status);
end;</source>
        <Parameter name="_ediData" type="CM_EDIDataMove" usage="input"/>
        <Parameter name="_useDeferredUpdate" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxProcessEDIPreNote" id="c007ef65-7ed5-451b-b3c4-8642f88e6184">
        <updating/>
        <source>trxProcessEDIPreNote(_interFace : CMIF_PreNote; _validateOnly: Boolean; _ediData : CM_EDIData input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     Jan 2010 cmwrs1 par 21329
//
// Purpose:     Takes an array of CM_InterfaceObjects (all members should be CM_IntFaceReceival)
//				and creates/update/delete pre-notified tracked items from these.
//
// Parameters:  The array of interface objects.
//
// Returns:     True if successful.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26/05/2010	cnwdad1		Near the emd of this method, the status of the EDI Data
//							is changed, however, if there are any errors on the Passport,
//							the "finaliseActivityWithPassport" method would abort the
//							transaction, hence the status update was lost.  Changed this
//							method to clear the errors after determining the EDI Data status.
//
// 27/07/2010	cnwdad1		PAR #25120. Changed to call a single utility method to process the EDI Prenotes.
// 06/08/2012	cnwcs5		par 30136 - EDI BGP split
// 18/09/2012	cnwcs5		par 30316 - link errors to EDI TI so Jump to Line works in EDI Ops Form
//									  - also re-work trx/utl/val so all transaction control etc is in trx not utl and val seperated out
//14 Feb 2013	cnwrs1	Par 31143 EDI TRX not handling dbLoadErrors after no verify errors
//04 Aug 2014	cnwrs1	Par 34668	EDI Status can be wrong if doDeferredUpdate fails
//18 Nov 2015	cnwrs1	Par 36852 - when skip processing the staus should reflect that
// 13 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 03 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 02 Feb 2018	jlgrs1	TFS 36951 JMT Prenote Partial for GateDoc
//12 Sep 2023	jlirs1	TFS 60392 EUP | FR 53824 - Transport Manifest - Cargo Group Details
//15 Apr 2025	navsaa30 MTN-12349 - Transport Manifest load after locking does not add all cargo to work order
// ---------------------------------------------------------------------------
vars
	hadLock : Boolean;
	terminal : CM_Terminal;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	_passport.setWarningsIgnored(true);
	
	terminal := _ediData.getMyTerminal();

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	on DeadlockException do agtPassportSilDLckExHandlerFlg(exception, hadLock, app.myPassport);			//navsaa30 16/4/25 #12349

	// Set up the deadlock reply values
	app.myPassport.setupForDeadlockReplay(-200, 300 + app.random(300));
	app.myPassport.silentDeadlockLimit := 5;	
	//
	// Improve performance on EDI loads by only getting voyages once
	// PAR 22396
	//
	_passport.allCurrentCellularVoyages.clear();
	_passport.myTerminal.getAllCurrentCellularVoyagesNC(_passport.allCurrentCellularVoyages, false, false);
	
	app.myValUA.valEDIPrenote(_interFace, _ediData, _passport);					// par 30316 Sept 2012
		
	_ediData.assesInvalidConsignor(_passport);	// 45733
	
	if _passport.noErrors then
		
		while true do
			// Start the transaction
			beginTransaction;
			
			_passport.clearErrorsWarnings();
			_passport.useTIDictDeferUpdate := true;
			_passport.useTITransactionDeferUpdate := true;
			
			// MTN-12349 Lock the terminal prenote dictionaries
			self.exclusiveLock(terminal.allNotifiedTIsByIdCargoType);
			self.exclusiveLock(terminal.allNotifiedTIsByIdCargoTypeRev);
			self.exclusiveLock(terminal.allNotifiedTIsByCargoTypeId);
			self.exclusiveLock(terminal.allNotifiedTIsByCargoTypeIdRev);
			self.exclusiveLock(terminal.allNotifiedTIsByAlternativeId);
			
			app.myUtilityUA.utlProcessEDIPrenote(_interFace, _validateOnly, _ediData, _passport);	// par 30316 Sept 2012
			
			// If we had a deadlock, then try, try and try again &gt;.&gt;
			if hadLock then
				if _passport.silentDeadlockRetryCount &gt; _passport.silentDeadlockLimit then
					// Too many errors!
					break;
				else
					hadLock := false;				
					_passport.silentDeadlockRetryCount := _passport.silentDeadlockRetryCount + 1;
					process.sleep(_passport.silentDeadlockSleepTime);
					continue;
				endif;
			endif;
			
			// All good, job done
			break;
		endwhile;
	endif;
		
	if _validateOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		return;
	else
		if _passport.noErrors() then
			// sucessful DB Load so update status in same transaction
			_passport.doDeferredUpdates();
		endif;
	endif;
epilog
	app.myPassport.resetSilentDeadlockHandler;			//15/4/25 navsaa30 #12349
	self.finaliseActivityWithPassport(_passport);
	if app.myPassport.trxCompletedOK() then	//12 Sep 2023	jlirs1	TFS 60392 EUP | FR 53824 - Transport Manifest - Cargo Group Details
		app.myPassport.doTrxPostActions();		
	endif;
end;</source>
        <Parameter name="_interFace" type="CMIF_PreNote"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxProcessEDIPreNotes" id="69136798-bec6-4b26-a0d4-8b02edb57da5">
        <updating/>
        <source>trxProcessEDIPreNotes(_intFaceArray : CMIF_PrenoteSet; _validateOnly: Boolean; _ediData : CM_EDIData input; _passport : CM_Passport input) updating;
// ---------------------------------------------------------------------------
// Created:     Jan 2010 cmwrs1 par 21329
//
// Purpose:     Takes an array of CM_InterfaceObjects (all members should be CM_IntFaceReceival)
//				and creates/update/delete pre-notified tracked items from these.
//
// Parameters:  The array of interface objects.
//
// Returns:     True if successful.
//
// Changed On   Changed By  Reason
// ----------   ----------  --------------------------------------------------
// 26/05/2010	cnwdad1		Near the emd of this method, the status of the EDI Data
//							is changed, however, if there are any errors on the Passport,
//							the "finaliseActivityWithPassport" method would abort the
//							transaction, hence the status update was lost.  Changed this
//							method to clear the errors after determining the EDI Data status.
//
// 27/07/2010	cnwdad1		PAR #25120. Changed to call a single utility method to process the EDI Prenotes.
// 06/08/2012	cnwcs5		par 30136 - EDI BGP split
// 18/09/2012	cnwcs5		par 30316 - link errors to EDI TI so Jump to Line works in EDI Ops Form
//									  - also re-work trx/utl/val so all transaction control etc is in trx not utl and val seperated out
// 14 Feb 2013	cnwrs1	Par 31143 EDI TRX not handling dbLoadErrors after no verify errors
// 04 Aug 2014	cnwrs1	Par 34668	EDI Status can be wrong if doDeferredUpdate fails
// 18 Nov 2015	cnwrs1	Par 36852 - when skip processing the staus should reflect that
// 13 Oct 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 03 Nov 2017	jlgrs1	TFS 5705 - SNO - EDIDataBooking Prenote release Req
// 19 Sep 2018	jlgrh7 	TFS 39839	POL - [Fwd: ##RE-8414## : Error in prenoting PONU2919363]	
// 22 Jan 2019	jlgzm1	TFS 41915 Deadlocks in doDeferredUpdates not being reflected in EDI Status
// 10 Jul 2020	jlgmd1	TFS 49690 Ignore deferred updates, and grab an early lock on allNotifiedTIsByCargoTypeId
// 12 Sep 2023	jlirs1	TFS 60392 EUP | FR 53824 - Transport Manifest - Cargo Group Details
// ---------------------------------------------------------------------------
vars
//	status		: Integer;
	
	error 	: CM_Error;
	itemObj : CMIF_TIObject;
	obj		: Object;
	ediTI 	: CM_EDITrackedItem;
	gotLockException : Boolean;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);	
	_passport.setWarningsIgnored(true);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	//on LockException do agtPassportLockExHandler(exception, _passport);				//-TFS39839 arm Lock Exception in utlProcessEDIPrenotes
	on DeadlockException do agtPassportSilDLckExHandlerFlg(exception, gotLockException, _passport); //tfs41915
	//
	// Improve performance on EDI loads by only getting voyages once
	// PAR 22396
	//
	_passport.allCurrentCellularVoyages.clear();
	_passport.myTerminal.getAllCurrentCellularVoyagesNC(_passport.allCurrentCellularVoyages, false, false);
	
	app.myValUA.valEDIPrenotes(_intFaceArray, _ediData, _passport);					// par 30316 Sept 2012

	if _passport.noErrors then
		// Start the transaction
		beginTransaction;
		
		_passport.useTIDictDeferUpdate 			:= true;
		_passport.useTITransactionDeferUpdate 	:= true;
		
		// TFS49690 Prevent other users from changing Prenote data while we're in the middle of doing stuff
		self.exclusiveLock(_ediData.getMyTerminal.allNotifiedTIsByCargoTypeId);
		
		app.myUtilityUA.utlProcessEDIPrenotes(_intFaceArray, _validateOnly, _ediData, _passport);	// par 30316 Sept 2012
	endif;
	
	if _validateOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		return;
	else
		if _passport.noErrors() then
			// sucessful DB Load so update status in same transaction
			_passport.doDeferredUpdates();
			if _passport.hasErrors() and gotLockException then
				foreach itemObj in _intFaceArray do
					obj := itemObj.myUserObject;												
					if obj &lt;&gt; null and obj.isKindOf (CM_EDIPrenoteTI) then						
						ediTI := obj.CM_EDIPrenoteTI;											
						if ediTI.status = CM_EDITrackedItem.EDI_STATUS_DBLOADING then
							beginTransaction;
								ediTI.setStatus(CM_EDITrackedItem.EDI_STATUS_LOCKERROR);
							commitTransaction;
						endif;
					endif;
				endforeach;
			endif;
		endif;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);

//	if _validateOnly or _passport.hasErrors then
//		// use passport to get new status for EDI Data
//		status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
//		app.myTrxUA.trxSetEDIDataStatusAfterVerify(_ediData, status);	// par 27392 cnwrs1 14 Apr 2011
//	endif;
	if app.myPassport.trxCompletedOK() then	//12 Sep 2023	jlirs1	TFS 60392 EUP | FR 53824 - Transport Manifest - Cargo Group Details
		app.myPassport.doTrxPostActions();		
	endif;
end;</source>
        <Parameter name="_intFaceArray" type="CMIF_PrenoteSet"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_ediData" type="CM_EDIData" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxProcessEDIShipManifest" id="bad457c2-a541-4cde-bf6d-655081e80a8d">
        <updating/>
        <source>trxProcessEDIShipManifest(_ediData :CM_EDIDataShipManifest input; _validateOnly : Boolean; _passport : CM_Passport input) updating;
//
// cnwrs1 Jan 2010 CCMS 1008 1006 Messina Ship Mainfest
//
// 20/06/0212	cnwcs5	par 29747 - refactor utlr
// 26/06/2012	cnwcs5	par 29747:1 - fix problem with errors
// 26/06/2012	cnwcs5	par 29747:2 - make setting status simpler
//14 Feb 2013	cnwrs1	Par 31143 EDI TRX not handling dbLoadErrors after no verify errors
//04 Aug 2014	cnwrs1	Par 34668	EDI Status can be wrong if doDeferredUpdate fails
//07 Dec 2022 	navma1 	ChangeRequest 52499: MTN - Improve the performance of the Edi file verification process.
//25 Jul 2023	jlirs1	NFS 59324 (58026) Sea Manifest for non partial	EUP
vars
	status 				: Integer;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);
	
	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if _validateOnly then
		app.setContinueCMExceptions(true);
	else
		app.setContinueCMExceptions(false);
	endif;
	
	beginTransaction;
	
	_passport.useTIDictDeferUpdate 			:= true;
	_passport.useTITransactionDeferUpdate 	:= true;
	
	//12.12.2022 navma1 #52499
	if _validateOnly then
		app.myPassport.setPassportEdiMode(CM_Passport.EDI_MODE_VERIFY);		
	endif;
		
	// par 29747 - the whole process has been moved to a single utl method
	app.myUtilityUA.utlProcessEDIShipManifest (_ediData, _validateOnly, _passport);

	if _validateOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		return;
	else
		if _passport.noErrors() then
			// sucessful DB Load so update status in same transaction
			_passport.doDeferredUpdates();
			if _passport.noErrors() then
				// use passport to get new status for EDI Data
				status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
				app.myUtilityUA.utlSetEDIDataStatusAfterVerify(_ediData, status);
			endif;
		endif;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);

	if _validateOnly or _passport.hasErrors then
		// use passport to get new status for EDI Data
		status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
		app.myTrxUA.trxSetEDIShipMfStatusAftrVerfy(_ediData, status);	//Bug 45797
	endif;
	if app.myPassport.trxCompletedOK() then	//25 Jul 2023	jlirs1	NFS 59324 (58026) Sea Manifest for non partial	EUP
		app.myPassport.doTrxPostActions();		
	endif;
end;</source>
        <Parameter name="_ediData" type="CM_EDIDataShipManifest" usage="input"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxProcessEDIStops" id="87cd87da-8d1c-4d56-ac24-a6b73f104c26">
        <updating/>
        <source>trxProcessEDIStops(_ediData :CM_EDIDataStop input; _validateOnly : Boolean; _passport : CM_Passport input) updating;
/* Changes

Date		Name	TFS#		Description
============================================================================
14 Feb 2013	cnwrs1	Par 31143 	EDI TRX not handling dbLoadErrors after no verify errors take 4
04 Aug 2014	cnwrs1	Par 34668	EDI Status can be wrong if doDeferredUpdate fails
16 May 2016	cnwns1	TFS 488 	Multi Timezone Support
03 Sep 2019 jlgka1 	TFS 45332 	STWR - Better Forms and Interfaces for EDI Module
29 Oct 2019	cnwrs1	TFS 47281
20 Oct 2020	jlgmd1	TFS 50204	Refactor progress updates to superclass method
============================================================================*/

vars
	partsDone 		 : Integer;
	partsInJob 		 : Integer;
	progressStr 	 : String;
	progressTS 		 : TimeStamp;
	ediTI			 : CM_EDITrackedItem;
	status 			 : Integer;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);

	if _validateOnly then
		app.setContinueCMExceptions(true);
	else
		app.setContinueCMExceptions(false);
	endif;

	beginTransaction;
	
	_passport.useTITransactionDeferUpdate := false; 
	_passport.useTIDictDeferUpdate := false;
//utl
	
	partsInJob	:= _ediData.allEDITrackedItems.size();
	partsDone	:= null;
	
	progressStr	:= app.getString(Loading_EDI_Data_Total, partsInJob.display);
	progressTS	:= app.actualTimeServer();// 16 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	_ediData.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, _passport);
	
	foreach ediTI in _ediData.allEDITrackedItems do
		partsDone := partsDone + 1;
		_ediData.updateProgress(progressTS, progressStr, partsInJob, partsDone, false, _passport);
		
		_ediData.zLoadDB(ediTI.CM_EDIStopTI, _ediData.getMyTerminal(), _passport);
	endforeach;
	
	_ediData.updateProgress(progressTS, progressStr, partsInJob, partsDone, true, _passport);

	if _validateOnly and _passport.noErrors then
		// sucessful validate - abort then update status in new transaction
		// we need to abort here as it won't get done for us in self.finaliseActivityWithPassport
		app.cmsAbortTransaction();
		return;
	else
		if _passport.noErrors() then
			// sucessful DB Load so update status in same transaction
			_passport.doDeferredUpdates();
			if _passport.noErrors() then
				// use passport to get new status for EDI Data
				status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
				app.myUtilityUA.utlSetEDIDataStatusAfterVerify(_ediData, status);
			endif;
		endif;
	endif;
epilog
	self.finaliseActivityWithPassport(_passport);

	if _validateOnly or _passport.hasErrors then
		// use passport to get new status for EDI Data
		status := _ediData.getStatusAfterVerifyOrDBLoad (_validateOnly, _passport);
		app.myTrxUA.trxSetEDIDataStatusAfterVerify(_ediData, status);	// par 27392 cnwrs1 14 Apr 2011
	endif;
end;</source>
        <Parameter name="_ediData" type="CM_EDIDataStop" usage="input"/>
        <Parameter name="_validateOnly" type="Boolean"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
