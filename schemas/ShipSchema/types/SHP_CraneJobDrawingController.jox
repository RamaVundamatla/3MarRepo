    <JadeMethod name="setZforJobsAtXY" id="0a3452f2-3c08-4037-bf54-1d6934577358">
        <source>setZforJobsAtXY(_obj : Object ; _x1,_y1,_x2,_y2 : Real );
/*

Purpose:			


Return Value:		


Date		Who		Reason
25 June 2007	cnwer1	Initial creation - PAR#xxxx

*/
vars
	objs : ObjectArray;
	obj : Object;
	indx: Integer;
	x1,y1,x2,y2  : Real;
	z, z1 : Integer;
	iter : Iterator;
begin

	create objs transient;
	objs.add(_obj);
	iter:=self.allJobObjects.createIterator;
	indx:=2;
	while iter.next(obj) do
		self.allJobObjects.getIteratorKeys(x1, y1, x2, y2,z, iter);
		
		if _x1 &gt;= x1 and
		   _x1 &lt;= x2 and
		   _y1 &gt;= y1 and
		   _y1 &lt;= y2 then
		   
		   // z  can be + 1 this object
		   if x1  &gt; _x1 then 				
				if not objs.includes(obj) then
					objs.atPut(indx,obj);
					indx:=indx+1;
				endif;
		   elseif x1 = _x1 then
			 // check which ends first 
			if x2 &lt; _x2 then
				if not objs.includes(obj) then
					objs.atPut(indx,obj);
					indx:=indx+1;
				endif;
			else
				if not objs.includes(obj) then
					objs.insert(indx-1,obj);
					indx:=indx+1;
				endif;
			
			endif;
		   
		   elseif x1 &lt; _x1 then
		   // z is less than current object
				if not objs.includes(obj) then
					objs.insert(indx-1,obj);
					indx:=indx+1;
				endif;
			endif;
		   
		   
			
		endif;
	endwhile;
	
	
	foreach obj in objs discreteLock do
		if self.allJobObjects.findObjectInDictGetXY(obj,x1,y1,x2,y2,z) then
			indx:=(objs.last =obj).Integer;
			
			if z &lt;&gt; indx then
				self.allJobObjects.removeKeyEntry(x1,y1,x2,y2,z,obj);
				if self.allJobObjects.getAtKey(x1,y1,x2,y2,indx) = null then
					self.allJobObjects.putAtKey(x1,y1,x2,y2,indx,obj);
				endif;
			endif;		
		endif;
	
	endforeach;
	
	

epilog
	delete objs;
	delete iter;
end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
    </JadeMethod>
</Class>
