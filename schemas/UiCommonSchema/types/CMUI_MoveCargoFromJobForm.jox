    <JadeMethod name="doTableContextMenu" id="a45bca80-1933-4efe-a37b-3a4a68cf7554">
        <updating/>
        <source>doTableContextMenu(table: Table input; conwin: Window input; mouse: Boolean; x: Integer; y: Integer):Boolean updating;
// --------------------------------------------------------------------------------
// Created:		20 September 2010 by cnwjo3
//
// Purpose:		
//
vars
	x1,y1 : Real;
begin
	x1 := x;
	y1 := y;
	
	conwin.windowToScreen(x1, y1);
	self.screenToWindow(x1, y1);   // convert x, y relative to form	

	self.mnuInspectObject.visible :=  app.isAllowedToInspect;
	
	self.popupMenu(self.mnuContextMenu, x1.Integer, y1.Integer);	

	return false;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="conwin" type="Window" usage="input"/>
        <Parameter name="mouse" type="Boolean"/>
        <Parameter name="x" type="Integer"/>
        <Parameter name="y" type="Integer"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doTableDblClick" id="b23d3e4c-f8a5-4c73-8cbb-ed30bcf48b8f">
        <updating/>
        <source>doTableDblClick(table: Table input) updating;
// --------------------------------------------------------------------------------
// Created:		20 September 2010 by cnwjo3
//
// Purpose:		open up cargo enquiry screen
//
vars
	ti : CM_TrackedItem;
	voyageWLE : CM_VoyageWLE;
begin

	if table.accessRow(table.row).itemObject &lt;&gt; null then
		voyageWLE := table.accessRow(table.row).itemObject.CM_VoyageWLE;
		ti := voyageWLE.myTrackedItem;
	endif;
	
	if ti &lt;&gt; null then
		self.myAssistant.showCargoEnquiry(ti);
	endif;

epilog

end;</source>
        <Parameter name="table" type="Table" usage="input"/>
    </JadeMethod>
    <JadeMethod name="doTableMouseDown" id="a1dbd3ac-4668-4dfd-b43e-b91507d8de63">
        <updating/>
        <source>doTableMouseDown(table: Table input; button: Integer; shift: Integer; x: Real; y: Real) updating;
// --------------------------------------------------------------------------------
// Created:		20 September 2010 by cnwjo3
//
// Purpose:		do automatic selection if necessary
//
vars
	rowIdx : Integer;
begin
	if table.row &lt;= table.fixedRows then
	else
		//we only go into SELECT TO END mode when we enter the screen with only 1 selected
		//and the ctrl key (shift = 2) has not been pressed
		if self.wleSelectMode = self.WLE_SELECTTOEND and shift &lt; 2 then
			foreach rowIdx in table.row to table.rows do
				table.accessRow(rowIdx).selected := true;
			endforeach;
		endif;
	endif;
end;</source>
        <Parameter name="table" type="Table" usage="input"/>
        <Parameter name="button" type="Integer"/>
        <Parameter name="shift" type="Integer"/>
        <Parameter name="x" type="Real"/>
        <Parameter name="y" type="Real"/>
    </JadeMethod>
