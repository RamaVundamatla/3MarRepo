<Class name="CM_YABlockRTG" id="6c8f63f8-6a32-4b01-ae66-ac19d1250a49">
    <superclass name="CM_YABlockGridArea"/>
    <persistentAllowed/>
    <sharedTransientAllowed/>
    <subclassPersistentAllowed/>
    <subclassSharedTransientAllowed/>
    <subclassTransientAllowed/>
    <transientAllowed/>
    <DbClassMap file="yardAllocations"/>
    <JadeMethod name="applyDeckingRulesToCellOrder" id="be0681d3-e406-4070-a9ae-63b7149a7255">
        <source>applyDeckingRulesToCellOrder();

vars
	
	tmpObject		: Object;
	cell 			: CM_YALocationCell;
	dyna			: DynaDictionary;
	yardController	: CM_YardController;
	
begin
	//the rules have just been updated - we need to rearrange the YALocnCells based on new rules
	if self.myDeckingOptions.allDeckingRulesIn.first.isAdvancedRule then
		inheritMethod();
		return;
	endif;
	
	create dyna transient;
	dyna.setMembership(CM_YALocationCell);
	dyna.addMemberKey(CM_YALocationCell::column.name, false, false);
	dyna.addMemberKey(CM_YALocationCell::height.name, false, false);
	dyna.addMemberKey(CM_YALocationCell::row.name, false, false);
	
	dyna.endKeys(false);
	
	foreach yardController in self.allYardControllers do
		yardController.allYAYardLocationCells.copy(dyna);
	endforeach;
	
	self.myDeckingOptions.allYALocationCellsIn.clear();
	
	dyna.copy(self.myDeckingOptions.allYALocationCellsIn);
	
	self.myDeckingOptions.allYALocationCellsOut.clear();
	
	foreach tmpObject in dyna reversed do
		self.myDeckingOptions.allYALocationCellsOut.add(tmpObject.CM_YALocationCell);
	endforeach;

	
epilog	

	delete dyna;
end;

	
</source>
    </JadeMethod>
    <JadeMethod name="getOverstowDeckingSequence" id="6b0402ac-cbaa-49b9-9e71-f38804f42c3b">
        <source>getOverstowDeckingSequence(_sideAccess: Boolean; _overstowedLC: CM_GridController; _lcCell: CM_YALocationCell): Integer protected;

/*

Purpose:		FOR RTGS - SEARCHS STACKWISE MIDDLING OUT IN CURRENT O/S CARGO BAY FIRST 
					THEN WILL TRY ALTERNATING CLOSEST BAYS MIDDLING OUT FROM THE CURRENT O/S CARGO LC

Parameters:			

Return Value:		


Date		Who		Reason
20 Jan 2010	cnwer1	Initial creation
27 Jun 2013 cnwer1	Par 31576
*/

vars
	rows,
	stacks,
	tiers,
	startRow,
	startStack,
	offset,
	rowOffset,
	colOffset,
	tier,
	sequence: Integer;
	deckingRule 	: CM_YADeckingRule;
	seq : CMIF_DeckingSequenceService;	
	lcToCheck : CM_GridController;
	gridArea  : CM_GridArea;
	gridRows : CM_GridRowDict;
	gridCols : CM_GridColumnDict;
begin
	//side access do the side access overstow planning
	if _sideAccess then
		return inheritMethod(_sideAccess, _overstowedLC, _lcCell);
	endif;
	
	if not _lcCell.myYardController.isKindOf(CM_GridController) then
		return null;
	endif;
	
	lcToCheck:=_lcCell.myYardController.CM_GridController;
	gridArea:=lcToCheck.getMyGridArea;
	create seq transient;	
	//epr par 31576 27/6/13
	if self.allGridRows.size = 0 then
		gridRows:=gridArea.allGridRows;
	else
		gridRows:=self.allGridRows;
	endif;
	
	if self.allGridColumns.size = 0 then
		gridCols:=gridArea.allGridColumns;
	else
		gridCols:=self.allGridColumns;
	endif;
	stacks:=gridCols.size;
	rows:=gridRows.size;
	
	deckingRule := self.myDeckingOptions.allDeckingRulesIn.first;
	tiers:=(self.getMaxHeight-self.getMinHeight) +1;
	
	seq.onCreate(DeckingRule_ByStack); //set area rule for RTGs this is by stack
	startRow:=0;
	startStack:=0;
	offset:=0;
	rowOffset:=(gridRows.first.row - gridArea.allGridRows.first.row);
	colOffset:=(gridCols.first.column -  gridArea.allGridColumns.first.column);

	//stack rule , row rule , pattern rule
	seq.setRules(DeckingRule_MiddleOut,DeckingRule_MiddleOut,  DeckingRule_Columnwise );
	startStack:=(_overstowedLC.column - colOffset) ;	
	startRow:=(_overstowedLC.row - rowOffset) ;

	seq.setExtent(stacks, rows, tiers);
	seq.setStartRowStack( startStack,startRow) ;

	tier:=(_lcCell.height - self.getMinHeight) +1;
	
	sequence:=seq.getStackingSequence( lcToCheck.column -colOffset ,
								 lcToCheck.row-rowOffset ,
								 tier);
	sequence:=sequence +offset; 
	//write lcToCheck.getFullId &amp; Tab &amp; sequence.String &amp; Tab &amp; rowOffset.String &amp; Tab &amp; offset.String &amp; Tab &amp; startRow.String &amp; Tab &amp; startStack.String;
	
	return sequence;
	

epilog
	delete seq;

end;</source>
        <access>protected</access>
        <Parameter name="_sideAccess" type="Boolean"/>
        <Parameter name="_overstowedLC" type="CM_GridController"/>
        <Parameter name="_lcCell" type="CM_YALocationCell"/>
        <ReturnType type="Integer"/>
    </JadeMethod>
</Class>
