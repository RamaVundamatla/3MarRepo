    <JadeMethod name="cloneReferences" id="0d1c4e4c-26e8-4610-9a73-c67efe0c9cd2">
        <updating/>
        <source>cloneReferences(_obj: CMQF_Audit; _transient: Boolean) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 June 2018	jlgmp6	Initial creation	TFS37718

*/

vars

begin
	inheritMethod(_obj, _transient);
	
	self.allUsers.clear();
	_obj.allUsers.copy(self.allUsers);
	self.setMyCMObject(_obj.getMyCMObject);
epilog

end;</source>
        <Parameter name="_obj" type="CMQF_Audit"/>
        <Parameter name="_transient" type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="filterObjects" id="7b503c80-0710-4e06-9896-6d8d7245d366">
        <updating/>
        <source>filterObjects(_collection: Collection input; _passport: CM_Passport) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Jun 2018	jlgmp6	Initial creation	TFS37718
06 Apr 2020 cnwma1	Bug 49065: PIBT - Audit Cash Receipt issue
*/

vars
	iter		: Iterator;
	mi			: MergeIterator;
	breakOut	: Boolean;
	user		: CM_User;
	audit		: CM_AuditObject;
	auditConfig : CM_AuditConfig;

begin

	// Audits selector reports                                //06.04.2020 cnwma1 #49065
	if (not self.allQueryCriteriaHolders.isEmpty) then
		self.filterSelectorQuery(_collection, _passport);
		return;
	endif;
	
	if not self.allUsers.isEmpty() then
		foreach user in self.allUsers do
			iter := user.allAuditObjectChangesByMe.createIterator();
			while iter.next(audit) do
				if self.checkStatusIncludesObject(audit, _passport, breakOut) then
					_collection.add(audit);
				endif;
				if breakOut then
					break;
				endif;
			endwhile;
		endforeach;
	else
		create mi transient;
	
		foreach auditConfig in app.myRoot.allAuditConfigs discreteLock do
			mi.addCollection(auditConfig.allAuditObjects);
		endforeach;
	
		if self.startDate.isValid() then
			mi.startKeyGeq(self.startDate);
		endif;
		
		while mi.next(audit) do
		
			if audit.timestamp.Date &gt; self.endDate then
				break;
			endif;
			
			if self.checkStatusIncludesObject(audit, _passport, breakOut) then
				_collection.add(audit);
			endif;
			if breakOut then
				break;
			endif;
		endwhile;
	endif;

epilog
	delete iter;
	delete mi;
end;</source>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="filterSelectorQuery" id="114dc7ff-2a89-4d4c-9f10-9e2384834a9a">
        <source>filterSelectorQuery(_collection  : Collection input;
					_passport 	 : CM_Passport) protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
06 Apr 2020 cnwma1	Bug 49065: PIBT - Audit Cash Receipt issue

*/

vars
	criteriaHolder 		: CM_QueryCriteriaLineHolder;
	qDef				: CM_QueryDefinition;
	enqController		: CM_EnquiryController;
	queryAgent			: CM_QueryAgentFilter;

begin

	// Special one because we need the copy
	on CM_BreakOutException do app.myQAFilter.xHandlerBreakOut(exception);
	
	queryAgent := app.myQAFilter;
	if queryAgent = null then
		return;
	endif;
	
	qDef := app.myRoot.allQueryDefinitionObjects[CM_QueryDefinition.Audit_Query_Type, self.selectorMode];
	queryAgent.createEnqControllerForMode(self.selectorMode, CM_QueryDefinition.Audit_Query_Type, enqController);
	
	delete enqController.allObjects;
	create enqController.allObjects as _collection.class transient;
	
	foreach criteriaHolder in self.allQueryCriteriaHolders discreteLock do
		enqController.myCriteriaLineHolder := criteriaHolder;
		enqController.doQuery(qDef);
	endforeach;

	enqController.allObjects.copy(_collection);
	
epilog
	if enqController &lt;&gt; null then
		delete enqController.allObjects;
	endif;
	delete enqController;
end;</source>
        <access>protected</access>
        <Parameter name="_collection" type="Collection" usage="input"/>
        <Parameter name="_passport" type="CM_Passport"/>
    </JadeMethod>
    <JadeMethod name="getMyCMObject" id="5a4124b0-6547-4d6b-a22c-9cb705c36ce4">
        <source>getMyCMObject(): CM_Object;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 June 2018	jlgmp6	Initial creation	TFS37718

*/

vars

	object : CM_Object;
	edition : Integer;
	invalidObj : Boolean;

begin

	object := self.myCMObject;

	if object = null then
		return null;
	endif;
	
	on Exception do app.handleDeletedObject( exception, object, invalidObj );
	edition := object.edition;
	
	if invalidObj then
		return null;
	endif;
	
	return object;

epilog

end;</source>
        <ReturnType type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="setMyCMObject" id="9541f680-3e85-478a-8a07-cfd0fcb5053d">
        <updating/>
        <source>setMyCMObject(_object: CM_Object) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 June 2018	jlgmp6	Initial creation	TFS37718

*/

vars

begin

	self.myCMObject := _object;

epilog

end;</source>
        <Parameter name="_object" type="CM_Object"/>
    </JadeMethod>
</Class>
