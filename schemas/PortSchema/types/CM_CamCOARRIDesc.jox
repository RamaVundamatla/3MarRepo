    <JadeMethod name="makeMessageRFF_BN" id="2468ade1-62a4-4679-a716-0cdcc84a7bf5">
        <source>makeMessageRFF_BN(_protocol :CM_CamProtocol; _group :HugeStringArray input; _ti :CM_TrackedItem):String protected;
/*
Purpose:			
Parameters:			
Return Value:		

Date		Who		Reason
22 May 2011	cnwcs5	Initial creation - CCMS SCT 2058/par 27460
*/
//29 Jan 2015	cnwrs1	Par 35544 - Change CamMessage to use HugeStringArray
vars
	msg, booking	:String;
begin
	if _protocol.isUseCarrierRefForBooking then
		booking := _ti.getCarrierReference;
	else
		booking := _ti.bookingReference.trimRight;
		//09 Jun 2020	NDL	TFS 49402
		if booking = null and _ti.myTranshipDetail &lt;&gt; null then
			booking := _ti.myTranshipDetail.importBookingReference.trimBlanks;
		endif;
	endif;
	
	if booking &lt;&gt; null then
		msg := self.makeRFFSegment (_protocol, _group, "BN", booking);
	endif;
	
	return msg;
epilog

end;</source>
        <access>protected</access>
