    <JadeMethod name="getDisplayStringForAttribute" id="f0dd7f33-4770-48cf-86bb-bf8f27335f1b">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
17 November 2016	cnwndl1	Initial creation
27 Aug 2024 navsaa30 Bug 65356: MTN - UNDG Code cannot be edited in EDI Operations (Transport Manifest)
*/

vars

begin

	if _attrName = ETRow_CargoID then //epr TFS 4139 27/4/17 changed from parent Cargo id	
		return self.id;
	elseif _attrName = ETRow_AllUNDGCodes then
		return self.undgCodes;
	elseif _attrName = ETRow_UndgCodes then			//27/8/24 navsaa30  #65356
		return self.undgCodes;
	elseif _attrName = ETRow_FlashpointTemperature then		//07 Mar 2017	NDL	TFS 3486
		if self.flashpointTemperature = NULL_TEMPERATURE then
			return null;
		endif;
	endif;
	return inheritMethod(_attrName, _short);

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
