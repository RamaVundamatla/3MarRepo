    <JadeMethod name="getActivityDisplayString" id="a3d5f6d8-6d4d-4289-b898-f8800f0323fb">
        <source>getActivityDisplayString() : String;
//--------------------------------------------------
// Created:	31 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.eventType &lt;&gt; null then
		return app.eventReqFormatActivityString(self.eventType, self.eventName);
	else
		return app.myRoot.eventReqFormatActivityString(self.eventName);
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="40498b5f-dae5-4f6c-97ae-a380cff2c681">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
//--------------------------------------------------
// Created:	05 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if _attrName = ETRow_Event then
		return self.getActivityDisplayString();
	else
		return inheritMethod(_attrName, _short);
	endif;

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSendMessage" id="fb51bfd1-af2a-4242-808e-2883e43803b7">
        <source>getSendMessage(): String;
//--------------------------------------------------
// Created:	17 May 2005 By: cnwgd1
//--------------------------------------------------
vars

begin
	if self.status = EventRequestActioned then
		return 'Event type ' &amp; self.getActivityDisplayString() &amp; ' has occurred at terminal ' &amp; self.myTrackedItem.myTerminal.name &amp;
		 ' for cargo item ' &amp; self.myTrackedItem.id  &amp; ' at ' &amp; self.statusDT.shortCurrentLocaleFormat() &amp; '. ' &amp; self.remarks;
	else
		if self.myTrackedItem &lt;&gt; null then //par 15000 cnwrs1 sept 2007
			return 'Notification request for cargo item ' &amp; self.myTrackedItem.id &amp; ' (' &amp; self.actionFailedReason &amp; ')';
		else
			return 'Notification request ' &amp; ' (' &amp; self.actionFailedReason &amp; ')';
		endif;
	endif;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getSendSubject" id="9f17b4c1-6da0-4ef1-8bfc-e3e3cfea6753">
