    <JadeMethod name="setCriteriaResizeScrollBar" id="b09eff66-b426-4657-8bfc-8ad13518aecf">
        <updating/>
        <source>setCriteriaResizeScrollBar() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
28/11/2023	navkc1 Bug 60782: FR | 54089 EUP -Invoice Contracts - Criteria screen width issues

*/

vars
	max			: Integer;
	numOfCrit	: Integer;
	imex			: CM_IMEXStatus;
	yaIMEXConfig	: CM_YAIMEXConfig;
begin

	imex := self.cmbIMEX.getCurrentItemObject().CM_IMEXStatus;
	
	if imex &lt;&gt; null then
		if self.myTerminal &lt;&gt; null then
			if self.myTerminal.myYAConfig &lt;&gt; null then
				if self.myTerminal.myYAConfig.allYAIMEXConfigs.size &gt; 0 then
					yaIMEXConfig := self.myTerminal.myYAConfig.allYAIMEXConfigs[imex.code];
					
					if yaIMEXConfig &lt;&gt; null	then
						numOfCrit := yaIMEXConfig.allOpCriteria.size;
					endif;
				endif;
			endif;
		endif;
	endif;
	
	if numOfCrit = null then
		numOfCrit := self.getNumCriteriaToDisplay();
	endif;
	max := (numOfCrit * (self.frmCriteria.height)).Integer;
	
	if self.picCriteria.height &lt; max then
		self.picCriteria.scrollBars := Picture.ScrollBar_Vertical;
		self.picCriteria.setScrollRange(ScrollBar_Vertical, 0, max, 20, 100);
	else
		self.picCriteria.scrollBars := 0;
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="5759e527-5796-4c35-8d33-f15711e06ff4">
