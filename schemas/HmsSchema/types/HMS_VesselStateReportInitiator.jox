    <JadeMethod name="runReport" id="f2151aaa-8950-457b-9aad-37bbb286af3b">
        <updating/>
        <source>runReport() protected, updating;
// -------------------------------------------
// Created 10 May 2004 by cnwdvb1
// -------------------------------------------
// 24/04/2013	cnwcs5		par 30652 - remove resynch/resynchObject method calls
// 10/12/2014  cnwdb2	PAR 35364

vars

	report 			: HMS_ShippingReport;
	now				: TimeStamp;
	date			: Date;
	offset			:	Time;
	sendEmail 		: Boolean;
	emailGroup		: CM_EmailGroup;	
	tempTs			: TimeStamp;
	tmpReportOutput	: JadeReport;	// PAR13089

begin
	if self.myHarbour = null then
		app.raiseCMException1(HMSNoHarbourForTerminal, self.myTerminal.name, null, null);
		return;
	endif;
	
	create report transient;
	report.myHarbour := self.myHarbour;
	if self.chkInPort.value then
//		tempTs.setDate(self.tblEntry.getValueByName(ETRow_InPortDateFrom).Date);
		tempTs.setDate(self.tblEntry.getValueAsDate(ETRow_InPortDateFrom));
		tempTs.setTime(self.tblEntry.getValueByName(ETRow_InPortTimeFrom).Time);
		if tempTs.isValid then
			report.portDate_From := tempTs;
		endif;
//		tempTs.setDate(self.tblEntry.getValueByName(ETRow_InPortDateTo).Date);
		tempTs.setDate(self.tblEntry.getValueAsDate(ETRow_InPortDateTo));
		tempTs.setTime(self.tblEntry.getValueByName(ETRow_InPortTimeTo).Time);
		if tempTs.isValid then
			report.portDate_To := tempTs;
		else
			report.portDate_To := report.portDate_From;					
		endif;
	else
		report.portDate_From 	:= null;
		report.portDate_To		:= null;
	endif;
	
	if self.chkDeparted.value then
//		tempTs.setDate(self.tblEntry.getValueByName(ETRow_DepartedDateFrom).Date);
		tempTs.setDate(self.tblEntry.getValueAsDate(ETRow_DepartedDateFrom));
		tempTs.setTime(self.tblEntry.getValueByName(ETRow_DepartedTimeFrom).Time);
		if tempTs.isValid then
			report.departDate_From := tempTs;
		endif;		
//		tempTs.setDate(self.tblEntry.getValueByName(ETRow_DepartedDateTo).Date);
		tempTs.setDate(self.tblEntry.getValueAsDate(ETRow_DepartedDateTo));
		tempTs.setTime(self.tblEntry.getValueByName(ETRow_DepartedTimeTo).Time);
		if tempTs.isValid then
			report.departDate_To := tempTs;
		endif;				
	else
		report.departDate_From	:= null;
		report.departDate_To	:= null;
	endif;
	
	if self.chkArrivals.value then
//		tempTs.setDate(self.tblEntry.getValueByName(ETRow_ArrivalsDateFrom).Date);
		tempTs.setDate(self.tblEntry.getValueAsDate(ETRow_ArrivalsDateFrom));
		tempTs.setTime(self.tblEntry.getValueByName(ETRow_ArrivalsTimeFrom).Time);
		if tempTs.isValid then
			report.arriveDate_From := tempTs;
		endif;						
//		tempTs.setDate(self.tblEntry.getValueByName(ETRow_ArrivalsDateTo).Date);
		tempTs.setDate(self.tblEntry.getValueAsDate(ETRow_ArrivalsDateTo));
		tempTs.setTime(self.tblEntry.getValueByName(ETRow_ArrivalsTimeTo).Time);
		if tempTs.isValid then
			report.arriveDate_To := tempTs;
		endif;						
	else
		report.arriveDate_From	:= null;
		report.arriveDate_To	:= null;
	endif;

		//AJA 9/11/00: Can also send report file by email
	if self.chkReportToFile.value then
		// Send report to file
		sendEmail := self.chkReportEmail.value;
		emailGroup := self.myHarbour.myEmailGroup;
		if sendEmail
		and emailGroup = null then
		//	app.raiseCMException1(REQUIRED_FIELD, 'Harbour Email Group', null,  null);
			app.raiseCMException(Input_required_field_hrbEmlGrp, null,  null); // cnwdb2	PAR 35364		
			return;
		endif;
		if self.cmbFileFormat.text = "HTML" then
			//AA 9/7/01: Enhancement to send report as HTML file
			report.writeHTMLReportToFile(sendEmail, emailGroup);
		else
			//Ordinary csv file
			report.writeReportToFile(sendEmail, emailGroup);
		endif;
	else
			
		create tmpReportOutput transient;				// PAR13089
		tmpReportOutput.description := report.caption;	// PAR13089
		app.printer.setReport(tmpReportOutput);			// PAR13089
		// Send report to printer
		app.printer.setMargins(Print_Landscape,5,0,5,0);
		app.printer.printPreview := false;				// PAR13089
		app.mousePointer := MousePointer_HourGlass;
		report.processReport();

		app.printPreview(tmpReportOutput, true);		// PAR13089
		
	endif;
	
epilog	
	delete report;
	app.mousePointer := MousePointer_Default;	
end;</source>
        <access>protected</access>
    </JadeMethod>
    <JadeMethod name="setupForm" id="d7228e97-8921-42f9-9fc6-c0c1b78a42b6">
        <updating/>
        <source>setupForm() updating;
// -------------------------------------------
// Created 10 May 2004 by cnwdvb1
// -------------------------------------------
vars

begin

	self.caption := HMS_VesselReportInitiator.SHIPPING_REPORT_NAME &amp; ' Initiation'; //16988 cnwdz2
	self.lblDescription.caption := 'This report can show any or all of the following : Vessels currently in the port, vessels that have departed and expected arrivals. Select the date range(s) from the calendars below.';
	self.minimumHeight := 550;
	self.minimumWidth := 470;	
	inheritMethod();
	self.chkArrivals.value := true;
	self.chkDeparted.value := true;
	self.chkInPort.value := true;
	

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="df897b7e-5796-4436-94a1-b36d66856175">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 15 August 2018 16:40:56.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022930, locale);
	chkArrivals.translateCaption(Xlat_0001712, locale);
	chkDeparted.translateCaption(Xlat_0001713, locale);
	chkInPort.translateCaption(Xlat_0001714, locale);
end;</source>
    </JadeMethod>
</GUIClass>
