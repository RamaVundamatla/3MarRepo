    <JadeMethod name="btnStart_click" id="de5e572a-9711-44e4-a64e-891ecbacf943">
        <controlMethod name="CMUI_Button::click"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>btnStart_click(btn: Button input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2021	navra1	Initial creation tfs-50529- Singnal to the producer to start using the Start Producer button

*/

vars

begin
	self.signalProducerToStart();		//navra1 - 50529- Create a trigger on click of the button to send a REST ProducerStart to the producer
epilog

end;</source>
        <Parameter name="btn" type="Button" usage="input"/>
    </JadeMethod>
    <JadeMethod name="displayMultiSelectTerminal" id="cae8550d-83bf-4dbe-bcf7-0b115360c9db">
        <source>displayMultiSelectTerminal( _term : CM_Terminal ) : String protected;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Aug 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice Definition
*/

vars

begin

	return _term.name;

end;</source>
        <access>protected</access>
        <Parameter name="_term" type="CM_Terminal"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="doOK" id="26cd4ac9-5670-4479-a20c-e3f972424a5a">
        <updating/>
        <source>doOK() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
21 Sep 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice

*/

vars
	terminals : ObjectArray;
begin
	if self.myExtWebService &lt;&gt; null then
		self.myExtWebService.allTerminals.clear();
		create terminals transient;
		self.lstTerminal.getSelected(terminals);
		terminals.copy(self.myExtWebService.allTerminals);
	endif;
	
	inheritMethod();

epilog
	delete terminals;
end;</source>
    </JadeMethod>
    <JadeMethod name="initMultiSelect" id="b2d3cb92-a3e0-4b8a-8bac-baf9662f912b">
        <source>initMultiSelect();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Aug 2020 cnwma1  ChangeRequest 49906: MTN - Ops View External Webservice Definition

*/
vars
	tmpMulSel : CMUI_MultiSelectGroupBox;

begin

	tmpMulSel 				              	  := self.lstTerminal;
	tmpMulSel.availableHeading           	  := app.getErrorString(Available_terminals);
	tmpMulSel.selectedHeading            	  := app.getErrorString(Selected_terminals);
	tmpMulSel.formDisplayEntryMethodName 	  := SOP_ExtWSTerminal::displayMultiSelectTerminal.name; 
	tmpMulSel.myBaseForm 				 	  := self;
	tmpMulSel.myAvailableListBox.sorted    	  := true;		
	tmpMulSel.mySelectedListBox.sorted 	      := true;
	tmpMulSel.mySelectedListBox.allowDragDrop := true;
	tmpMulSel.multiSelect 					  := ListBox.MultiSelect_Extended;


end;</source>
    </JadeMethod>
    <JadeMethod name="setExtWebService" id="470a9328-ed87-4ad2-beb4-2af3a2ccb911">
        <updating/>
        <source>setExtWebService(_service: CM_ExternalWebServiceDef) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Aug 2020 cnwma1 ChangeRequest 49906: MTN - Ops View External Webservice Definition

*/

vars

begin
	self.myExtWebService := _service;
epilog

end;</source>
        <Parameter name="_service" type="CM_ExternalWebServiceDef"/>
    </JadeMethod>
    <JadeMethod name="setMultiSelectTerminal" id="65b14a7e-83b4-4727-b373-cebfe58883d2">
        <source>setMultiSelectTerminal();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
19 August 2020	jlgma1	Initial creation

*/

vars
	allUserTerminals		: CM_TerminalByCodeDict;
	terminalSet				: CM_TerminalSet;
begin
	create allUserTerminals transient;
	create terminalSet transient;
	
	app.getMyUser.getTerminals(allUserTerminals);
	self.lstTerminal.setAvailable(allUserTerminals, true);
	
	if self.myExtWebService &lt;&gt; null then	
		self.myExtWebService.getExtWebServiceTerminals(terminalSet);
		self.lstTerminal.setSelected(terminalSet);	
	endif;

epilog
	delete allUserTerminals;
	delete terminalSet;
end;</source>
    </JadeMethod>
    <JadeMethod name="setupForm" id="69c23dd0-2fb1-48eb-b048-05ca745df72f">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
13 Aug 2020 cnwma1  ChangeRequest 49906: MTN - Ops View External Webservice Definition

*/

vars

begin
	inheritMethod();

	if self.myAssistant = null then
		create self.myAssistant transient;
	endif;
	
	if self.myExtWebService = null then
		return;
	endif;
	
	self.lblExtTypeData.caption := self.myExtWebService.getExternalWebServiceType();
	self.lblExtNameData.caption := self.myExtWebService.name;
	
	if self.mode = self.ModeUpdate then
		self.btnOk.enabled 		 := true;
		self.lstTerminal.enabled := true;
	else
		self.btnOk.enabled := false;
	endif;
	
	self.initMultiSelect();	
	self.setMultiSelectTerminal();
	
	self.btnStart.enabled := self.myExtWebService.status = EWS_STATUS_IDLE; // ### TFS 50669 25AUG2021 NAVAB1
end;
</source>
    </JadeMethod>
    <JadeMethod name="signalProducerToStart" id="d06ad63a-797b-4682-9621-58a681db8b8d">
        <source>signalProducerToStart();
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
08 September 2021	navra1	Initial creation - 50529 - Make the button(Start Producer) to trigger  ProducerStart API on the producer

*/

vars

	httpConn			: JadeHTTPConnection;
	returnBod			: String;
	sendSuccess			: Boolean;	
	resultCode 			: Integer;
	timeoutMS			: Integer;
	apiUri				: String;
	
begin
	
	create httpConn transient;
	
	// Set timeouts
	timeoutMS := 5000;
	
	// 50529 - navra1 - 18th Sep 2021 - Changed to use the API endpoint	
	apiUri := self.myExtWebService.baseEndpointAPI &amp; ProducerAPI_ProducerStart;		//navra1 - 50529 - 22nd Sep 2021 - Introduced baseEndpointAPI field and Added ProducerStart as a Global Constant
	httpConn.url := apiUri;
	httpConn.connectTimeout := timeoutMS;
	httpConn.sendTimeout := timeoutMS;
	httpConn.receiveTimeout := timeoutMS;			
	
	returnBod := httpConn.responseBody.StringUtf8.String;

	write httpConn.state;
	
	sendSuccess := httpConn.sendRequest(JadeHTTPConnection.Verb_GET, null, null);
	
	write httpConn.queryStatusCode();
	
	if sendSuccess then
		httpConn.readBody(0);
		returnBod := httpConn.responseBody.StringUtf8.String;
		app.writeLog("signalProducerToStart succeeded:" &amp; Space &amp; returnBod, LogDEBUG);
		self.btnStart.enabled := false;
		write returnBod;
	else
		app.writeLog("signalProducerToStart: Failed", LogDEBUG);
		write "signalProducerToStart: failed";
	endif;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="8ad8c624-1981-4618-9b15-f0518fe03e63">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 26 August 2021 09:20:20.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0024042, locale);
	btnStart.translateBubbleHelp(Xlat_0024443, locale);
	btnStart.translateCaption(Xlat_0024444, locale);
	lblExtName.translateCaption(Xlat_0024043, locale);
	lblExtType.translateCaption(Xlat_0024044, locale);
end;</source>
    </JadeMethod>
</GUIClass>
