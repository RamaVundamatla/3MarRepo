    <JadeMethod name="trxRepairDamage" id="d19982a4-daa6-45b3-9fab-dbd54fcb6468">
        <updating/>
        <source>trxRepairDamage( _allDamageToRepair : CM_DamageInstanceSet input; _passport : CM_Passport input) updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
02 May 2022	jlier1	Initial creation TFS 53313

*/

vars
	damageInstance : CM_DamageInstance;
	allCargoRepaired : CM_TISet;
	cargo : CM_TrackedItem;
	terminal : CM_Terminal;
	trxDateTime : TimeStamp;
	clearDamage : Boolean;
begin
	// Always initialize the activity first
	self.initialiseActivityWithPassport(_passport, method);

	// Arm our base exception handlers
	on Exception do agtPassportExHandler(exception, _passport);
	on LockException do agtPassportLockExHandler(exception, _passport);


	app.setContinueCMExceptions(false);

	self.raiseExceptionIfNull(_allDamageToRepair, 'All repaired damage');
	
	if _passport.hasErrors then
		return;
	endif;
	
	//nothing to repair then return
	if _allDamageToRepair.first = null then
		return;
	endif;

	beginTransaction;
	
	create allCargoRepaired transient;
	trxDateTime := app.actualTimeServer();
	foreach damageInstance in _allDamageToRepair discreteLock do
		//set to repaired;
		//first if already repaired then don't update again 
		if not damageInstance.repaired then
			damageInstance.setRepaired();
		endif;
		if damageInstance.myTrackedItem &lt;&gt; null and not allCargoRepaired.includes(damageInstance.myTrackedItem) then
			allCargoRepaired.add(damageInstance.myTrackedItem);
		endif;
	
		if _passport.hasErrors then
			return;
		endif;
	endforeach;
	
	cargo:=allCargoRepaired.first;
	if cargo &lt;&gt; null then
		terminal:=cargo.myTerminal;
		clearDamage:=terminal.getConfig(ClearDamageAfterRepair).Boolean;
	endif;
	trxDateTime := app.actualTimeServer();
	foreach cargo in allCargoRepaired discreteLock do
		if cargo.isAllDamagesRepaired() then
			//create the repair transaction
			cargo.createRepairTransaction(trxDateTime);
			
			//delete if need to clear;
			if clearDamage and not cargo.damaged then
				foreach damageInstance in cargo.allDamageInstances discreteLock do
					damageInstance.updateDamageLocationToDeleted(cargo); 
				endforeach;
				cargo.allDamageInstances.purge;
			endif;
		endif;	
		
		if _passport.hasErrors then
			return;
		endif;
	endforeach;
	
epilog

	delete allCargoRepaired;
	self.finaliseActivityWithPassport(_passport);

end;</source>
        <Parameter name="_allDamageToRepair" type="CM_DamageInstanceSet" usage="input"/>
        <Parameter name="_passport" type="CM_Passport" usage="input"/>
    </JadeMethod>
    <JadeMethod name="trxReplaceTMInvoiceLineType" id="3fa96167-464b-477f-8c43-30ade285f652">
