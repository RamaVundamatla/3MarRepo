        <Parameter name="_maxNumberOverstowForDriver" type="Integer"/>
        <Parameter name="_maxNumberQueryResults" type="Integer"/>
        <Parameter name="_maxNumberQueueEntries" type="Integer"/>
        <Parameter name="_maxNumberSearchResults" type="Integer"/>
        <Parameter name="_allAvailableGraphicViews" type="IntegerArray"/>
        <Parameter name="_defaultGraphicView" type="Integer"/>
        <Parameter name="_columnLabelsPlacement" type="Integer"/>
        <Parameter name="_rowLabelsPlacement" type="Integer"/>
        <Parameter name="_myQueriesForDrivers" type="CM_SelectorQueryAccess"/>
        <Parameter name="_myNightScreenConfig" type="CM_RTScreenConfig"/>
        <Parameter name="_myDayScreenConfig" type="CM_RTScreenConfig"/>
        <Parameter name="_fontSize" type="Integer"/>
        <Parameter name="_selectedFontSize" type="Integer"/>
        <Parameter name="_myVisibleCargoFields" type="EntTableView" usage="input"/>
        <Parameter name="_myVisibleDirectorFields" type="EntTableView" usage="input"/>
        <Parameter name="_myVisibleTaskFields" type="EntTableView" usage="input"/>
        <Parameter name="_showSecondaryQueues" type="Boolean"/>
        <Parameter name="_useDetailsViewForPickup" type="Boolean"/>
        <Parameter name="_useDetailsViewForSetdown" type="Boolean"/>
        <Parameter name="_displayAcceptOnLeft" type="Boolean"/>
        <Parameter name="_removeSplitScreen" type="Boolean"/>
        <Parameter name="_locationHookCode" type="String"/>
        <Parameter name="_isoHookCode" type="String"/>
        <Parameter name="_doorDirHookCode" type="String"/>
