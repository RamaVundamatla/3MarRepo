    <JadeMethod name="buildOneAreaSystemCount" id="aecc9423-2062-4b95-ac56-689f49c1537f">
        <updating/>
        <source>buildOneAreaSystemCount(_ta : CM_TerminalArea) updating;
vars

	lc                : CM_LocationsController;
	total20Containers : Integer;
	total30Containers : Integer;
	total45Containers : Integer;
	total40Containers : Integer;
	total53Containers : Integer;
	oaTotal             : ObjectArray;
	oaFree              : ObjectArray;
	gcDict              : CM_GridControllersByRowColumn;

	
begin
	create oaTotal transient;
	create oaFree  transient;

	create gcDict transient;
	_ta.allLocationsControllers.copy(gcDict);

	clearSystemCounts;
	foreach lc in gcDict discreteLock do
		if lc.isKindOf(CM_GapController) = true then
			//
			// ignore, but take note ??
			//
			continue;
		endif;
		
		if not lc.status = LC_Status_Open then
			continue;
		endif;
		if lc.isKindOf(CM_GridController) = true then

			lc.CM_GridController.calculateAllContaineSizeTotals(total20Containers, total30Containers, total40Containers, 
										   total45Containers, total53Containers, 1, lc.CM_GridController.getMaxHeight(), gcDict, oaTotal);
	
			self.processALocationController(lc, 1, lc.CM_GridController.getMaxHeight());
			self.c20Free := self.c20Free + lc.CM_GridController.getFreeSpaceFor20;
			self.c30Free := self.c30Free + lc.CM_GridController.getFreeSpaceFor30(gcDict);
			self.c40Free := self.c40Free + lc.CM_GridController.getFreeSpaceFor40(gcDict, oaFree);
			self.c45Free := self.c45Free + lc.CM_GridController.getFreeSpaceFor45(gcDict);
			self.c53Free := self.c53Free + lc.CM_GridController.getFreeSpaceFor53(gcDict);

		endif;
		
	endforeach;

	if _ta.isKindOf(CM_BlockStack) = true then
		c20Total := _ta.CM_BlockStack.maxCapacity;
		c40Total := c20Total div 2;
	else
		c20Total := total20Containers;
		c30Total := total30Containers;
		c40Total := total40Containers;
		c45Total := total45Containers;
		c53Total := total53Containers;
	endif;

	self.setUpdateTimestamp;
epilog
	delete oaTotal;
	delete oaFree;	
	delete gcDict;
end;</source>
        <Parameter name="_ta" type="CM_TerminalArea"/>
    </JadeMethod>
    <JadeMethod name="clearSystemCounts" id="2a039de5-4c5d-4eac-9bf9-b59de391a63f">
        <updating/>
        <source>clearSystemCounts() updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 August 2008	conkc1	Initial creation

*/

vars

begin
		c20Free         := 0;
		c20PlannedIn    := 0;
		c20PlannedOut   := 0;
		c20QueuedIn     := 0;
		c20QueuedOut    := 0;
		c20Total        := 0;
		c20Used         := 0;

		c30Free         := 0;
		c30PlannedIn    := 0;
		c30PlannedOut   := 0;
		c30QueuedIn     := 0;
		c30QueuedOut    := 0;
		c30Total        := 0;
		c30Used         := 0;

		c40Free         := 0;
		c40PlannedIn    := 0;
		c40PlannedOut   := 0;
		c40QueuedIn     := 0;
		c40QueuedOut    := 0;
		c40Total        := 0;
		c40Used         := 0;

		c45Free         := 0;
		c45PlannedIn    := 0;
		c45PlannedOut   := 0;
		c45QueuedIn     := 0;
		c45QueuedOut    := 0;
		c45Total        := 0;
		c45Used         := 0;

		c53Free         := 0;
		c53PlannedIn    := 0;
		c53PlannedOut   := 0;
		c53QueuedIn     := 0;
		c53QueuedOut    := 0;
		c53Total        := 0;
		c53Used         := 0;

		//cnwjo3 par 21189
		self.free		:= 0;
		self.plannedIn	:= 0;
		self.plannedOut	:= 0;
		self.queuedIn	:= 0;
		self.queuedOut	:= 0;
		self.total		:= 0;
		self.used		:= 0;
		self.projected	:= 0;

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="getDelimitedStats" id="3f57bfb1-9a3c-452a-a407-c6fb7b3aaafb">
        <source>getDelimitedStats(_delimiter:String):String;
// --------------------------------------------------------------------------------
// Created:		18 November 2008 by cnwdad1
//
// Purpose:		Returns a string of the receiver's statistics, with each statistic
//				delimited by the specified character.
//
// Parameters:	_delimiter - The character used to delimit each statistic.
//
// Returns:		The delimited string of statistics.
//
// Changed On	Changed By	Reason
// ----------	----------	-------------------------------------------------------
//
// --------------------------------------------------------------------------------
vars
	returnValue	: String;
	
begin
	returnValue	:=	self.c20Total.String &amp;
					_delimiter &amp; self.c40Total.String &amp;
					_delimiter &amp; self.c20Used.String &amp;
					_delimiter &amp; self.c40Used.String &amp;
					_delimiter &amp; self.c20QueuedIn.String &amp;
					_delimiter &amp; self.c40QueuedIn.String &amp;
					_delimiter &amp; self.c20QueuedOut.String &amp;
					_delimiter &amp; self.c40QueuedOut.String &amp;
					_delimiter &amp; self.c20Free.String &amp;
					_delimiter &amp; self.c40Free.String &amp;
					_delimiter &amp; self.c20Projected.String &amp;
					_delimiter &amp; self.c40Projected.String &amp;
					_delimiter &amp; self.c20PlannedIn.String &amp;
					_delimiter &amp; self.c40PlannedIn.String &amp;
					_delimiter &amp; self.c20PlannedOut.String &amp;
					_delimiter &amp; self.c40PlannedOut.String;
	
	return returnValue;
end;</source>
        <Parameter name="_delimiter" type="String"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getDisplayStringForAttribute" id="98db23b3-e72c-4799-a5ff-36f4ca578a99">
        <source>getDisplayStringForAttribute(_attrName :String; _short:Boolean) :String;
vars

begin
	if _attrName = ETRow_HideShow then
		return null;
	elseif _attrName = ETRow_Code then
		if self.myParent = null then	//28 Mar 2012	NDL	Par 29350
			return null;
		endif;
		return self.myParent.getDisplayStringForAttribute(_attrName, _short);
	elseif _attrName = ETRow_Free20 then
		return self.c20Free.zeroNotAllowed();
	elseif _attrName = ETRow_Free30 then
		return self.c30Free.zeroNotAllowed();
	elseif _attrName = ETRow_Free40 then
		return self.c40Free.zeroNotAllowed();
	elseif _attrName = ETRow_Free45 then
		return self.c45Free.zeroNotAllowed();
	elseif _attrName = ETRow_Free53 then
		return self.c53Free.zeroNotAllowed();
	elseif _attrName = ETRow_ColTotalFree then 	//cnwjo3 par 21189
		return self.free.zeroNotAllowed();
		
	elseif _attrName = ETRow_PlannedIn20 then
		return self.c20PlannedIn.zeroNotAllowed();
	elseif _attrName = ETRow_PlannedIn30 then
		return self.c30PlannedIn.zeroNotAllowed();
	elseif _attrName = ETRow_PlannedIn40 then
		return self.c40PlannedIn.zeroNotAllowed();
	elseif _attrName = ETRow_PlannedIn45 then
		return self.c45PlannedIn.zeroNotAllowed();
	elseif _attrName = ETRow_PlannedIn53 then
		return self.c53PlannedIn.zeroNotAllowed();
	elseif _attrName = ETRow_ColTotalPlanIn then 	//cnwjo3 par 21189
		return self.plannedIn.zeroNotAllowed();
		
	elseif _attrName = ETRow_PlannedOut20 then
		return self.c20PlannedOut.zeroNotAllowed();
	elseif _attrName = ETRow_PlannedOut30 then
		return self.c30PlannedOut.zeroNotAllowed();
	elseif _attrName = ETRow_PlannedOut40 then
		return self.c40PlannedOut.zeroNotAllowed();
	elseif _attrName = ETRow_PlannedOut45 then
		return self.c45PlannedOut.zeroNotAllowed();
	elseif _attrName = ETRow_PlannedOut53 then
		return self.c53PlannedOut.zeroNotAllowed();
	elseif _attrName = ETRow_ColTotalPlanOut then 	//cnwjo3 par 21189
		return self.plannedOut.zeroNotAllowed();
		
	elseif _attrName = ETRow_Projected20 then
		return self.c20Projected.zeroNotAllowed();
	elseif _attrName = ETRow_Projected30 then
		return self.c30Projected.zeroNotAllowed();
	elseif _attrName = ETRow_Projected40 then
		return self.c40Projected.zeroNotAllowed();
	elseif _attrName = ETRow_Projected45 then
		return self.c45Projected.zeroNotAllowed();
	elseif _attrName = ETRow_Projected53 then
		return self.c53Projected.zeroNotAllowed();
	elseif _attrName = ETRow_ColTotalProjected then 	//cnwjo3 par 21189
		return self.projected.zeroNotAllowed();
		
	elseif _attrName = ETRow_QueuedIn20 then
		return self.c20QueuedIn.zeroNotAllowed();
	elseif _attrName = ETRow_QueuedIn30 then
		return self.c30QueuedIn.zeroNotAllowed();
	elseif _attrName = ETRow_QueuedIn40 then
		return self.c40QueuedIn.zeroNotAllowed();
	elseif _attrName = ETRow_QueuedIn45 then
		return self.c45QueuedIn.zeroNotAllowed();
	elseif _attrName = ETRow_QueuedIn53 then
		return self.c53QueuedIn.zeroNotAllowed();
	elseif _attrName = ETRow_ColTotalQIn then 	//cnwjo3 par 21189
		return self.queuedIn.zeroNotAllowed();
		
	elseif _attrName = ETRow_QueuedOut20 then
		return self.c20QueuedOut.zeroNotAllowed();
	elseif _attrName = ETRow_QueuedOut30 then
		return self.c30QueuedOut.zeroNotAllowed();
	elseif _attrName = ETRow_QueuedOut40 then
		return self.c40QueuedOut.zeroNotAllowed();
	elseif _attrName = ETRow_QueuedOut45 then
		return self.c45QueuedOut.zeroNotAllowed();
	elseif _attrName = ETRow_QueuedOut53 then
		return self.c53QueuedOut.zeroNotAllowed();
	elseif _attrName = ETRow_ColTotalQOut then 	//cnwjo3 par 21189
		return self.queuedOut.zeroNotAllowed();
		
	elseif _attrName = ETRow_Total20 then
		return self.c20Total.zeroNotAllowed();
	elseif _attrName = ETRow_Total30 then
		return self.c30Total.zeroNotAllowed();
	elseif _attrName = ETRow_Total40 then
		return self.c40Total.zeroNotAllowed();
	elseif _attrName = ETRow_Total45 then
		return self.c45Total.zeroNotAllowed();
	elseif _attrName = ETRow_Total53 then
		return self.c53Total.zeroNotAllowed();
	elseif _attrName = ETRow_ColTotalTotal then 	//cnwjo3 par 21189
		return self.total.zeroNotAllowed();
		
	elseif _attrName = ETRow_Used20 then
		return self.c20Used.zeroNotAllowed();
	elseif _attrName = ETRow_Used30 then
		return self.c30Used.zeroNotAllowed();
	elseif _attrName = ETRow_Used40 then
		return self.c40Used.zeroNotAllowed();
	elseif _attrName = ETRow_Used45 then
		return self.c45Used.zeroNotAllowed();
	elseif _attrName = ETRow_Used53 then
		return self.c53Used.zeroNotAllowed();
	elseif _attrName = ETRow_ColTotalUsed then 	//cnwjo3 par 21189
		return self.used.zeroNotAllowed();
		
		
	elseif _attrName = ETRow_Stacking then
		return Tab;
	elseif _attrName = ETRow_DeckingSequence then
		return Tab;
	elseif _attrName = ETRow_PriorityValue then
		return Tab;
	elseif _attrName = ETRow_AllowOthers then //cnwjo3 par 20135
		return Tab;
	elseif _attrName = ETRow_IfNoLocationFound then //cnwjo3 par 20135
		return Tab;
	elseif _attrName = ETRow_OverstowRule then //cnwjo3 par 20135
		return Tab;
	//04 Jan 2012	NDL	Par 28889
	elseif (	_attrName = ETRow_HasRemarks 
				or _attrName = ETRow_Remarks
				or _attrName = ETRow_AvailabilityGrade
				or _attrName = ETRow_BOL
				or _attrName = ETRow_Booking
				or _attrName = ETRow_CargoHeight
				or _attrName = ETRow_CargoLength
				or _attrName = ETRow_CargoSubtype
				or _attrName = ETRow_CargoType
				or _attrName = ETRow_CargoWidth
				or _attrName = ETRow_Carrier
				or _attrName = ETRow_Clean
				or _attrName = ETRow_Commodity
				or _attrName = ETRow_CommodityGroup
				or _attrName = ETRow_Communicating
				or _attrName = ETRow_Consignee
				or _attrName = ETRow_Consignor
				or _attrName = ETRow_ContainerLength
				or _attrName = ETRow_ContentsStatus
				or _attrName = ETRow_CurtainsIn
				or _attrName = ETRow_DestinationPort
				or _attrName = ETRow_DestinationTerminal
				or _attrName = ETRow_DischargePort
				or _attrName = ETRow_FreightForwarder
				or _attrName = ETRow_Hazardous
				or _attrName = ETRow_HeavyDuty
				or _attrName = ETRow_Id
				or _attrName = ETRow_ImexStatus
				or _attrName = ETRow_IntendedReleaseMode
				or _attrName = ETRow_IsAvailable
				or _attrName = ETRow_IsCoastal
				or _attrName = ETRow_IsControlled
				or _attrName = ETRow_IsFiftyThree
				or _attrName = ETRow_IsForty
				or _attrName = ETRow_IsFortyFive
				or _attrName = ETRow_IsHazardLtdQty
				or _attrName = ETRow_IsHazardOrLtdQty
				or _attrName = ETRow_IsHazardous
				or _attrName = ETRow_IsHazardousNotLtd
				or _attrName = ETRow_IsOverDimensional
				or _attrName = ETRow_IsThirty
				or _attrName = ETRow_IsTransShip
				or _attrName = ETRow_IsTwenty
				or _attrName = ETRow_ISO
				or _attrName = ETRow_ISOGroup
				or _attrName = ETRow_LoadPort
				or _attrName = ETRow_OperatorItem
				or _attrName = ETRow_OperatorVoyage
				or _attrName = ETRow_ReceiveTransMode
				or _attrName = ETRow_Rehandles
				or _attrName = ETRow_ReleaseRequest
				or _attrName = ETRow_ReleaseTransMode
				or _attrName = ETRow_RequiresPower
				or _attrName = ETRow_SourceTermArea
				or _attrName = ETRow_SourceTermAreaType
				or _attrName = ETRow_SpecialLift
				or _attrName = ETRow_SpecialStow
				or _attrName = ETRow_Stops
				or _attrName = ETRow_SubTerminal
				or _attrName = ETRow_TodoTasks
				or _attrName = ETRow_TrailerType
				or _attrName = ETRow_Train
				or _attrName = ETRow_TranshipDischPort
				or _attrName = ETRow_TranshiptoPort
				or _attrName = ETRow_Voyage
				or _attrName = ETRow_VoyageBerth
				or _attrName = ETRow_VoyageInbound
				or _attrName = ETRow_VoyageOutbound
				or _attrName = ETRow_VoyagePlanningCode
				or _attrName = ETRow_VoyageTrade
				or _attrName = ETRow_WaterCooled
				or _attrName = ETRow_Weight
				or _attrName = ETRow_WeightFlexi 
				or _attrName = ETRow_Mark
				or _attrName = ETRow_Colour
		)
		then
			return Tab;
	else
		return inheritMethod(_attrName , _short);
	endif;
end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getFreeTEU" id="421b7b42-652c-4e6e-870f-5cb463925180">
        <source>getFreeTEU() : Integer;

vars

begin
	return self.c20Free + ((self.c30Free + self.c40Free + self.c45Free + self.c53Free) * 2);
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getUsedTEU" id="1a9e8558-74ba-4d86-9be4-f5ac0a24e16c">
        <source>getUsedTEU() : Integer;

vars

begin
	return self.c20Used + ((self.c30Used + self.c40Used + self.c45Used + self.c53Used) * 2);
end;
</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
    <JadeMethod name="processALocationController" id="cf089b70-51b7-4730-bb23-9b656d5ad1b0">
        <updating/>
        <source>processALocationController(lc : CM_LocationsController; minHeight, maxHeight: Integer) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
20 Aug 2008	conkc1	Initial creation
08 Sep 2009	cnwkpd1	PAR #20586 - Improve performance of BGP Location Statistics

*/

vars
	yc                : CM_YardController;
	container         : CM_Container;
	trackedItem       : CM_TrackedItem;
	fmp               : CM_FutureMovePlanned;
	fmq               : CM_FutureMoveQueued;
	unknownUsed       : Integer;
	unknownPlannedOut : Integer;
	unknownQueuedOut  : Integer;
	unknownPlannedIn  : Integer;
	unknownQueuedIn   : Integer;
	height			  : Integer;
	iter			  : Iterator;
	invalidContainer  : Boolean;
begin
	yc := lc.CM_YardController;
	height := 0;
	
	on Exception do app.handleDeletedObject(exception, container, invalidContainer); //+ cnwmd1 Par 26125
	
	foreach trackedItem in lc.allTrackedItems do
		if trackedItem.isKindOf(CM_Container) then
			container := trackedItem.CM_Container;
			height := height + 1;
			
			if container.allPlannedFutureMoves.size &gt; 0 then
				if container.is20 then
					self.c20PlannedOut := self.c20PlannedOut + 1;
				elseif container.is30 then
					if container.isFrontEndOfTi(yc) = true then
						self.c30PlannedOut := self.c30PlannedOut + 1;
					endif;
				elseif container.is45 then
					if container.isFrontEndOfTi(yc) = true then
						self.c45PlannedOut := self.c45PlannedOut + 1;
					endif;
				elseif container.is40 then
					if container.isFrontEndOfTi(yc) = true then
						self.c40PlannedOut := self.c40PlannedOut + 1;
					endif;
				elseif container.is53 then
					if container.isFrontEndOfTi(yc) = true then
						self.c53PlannedOut := self.c53PlannedOut + 1;
					endif;
				else
					unknownPlannedOut := unknownPlannedOut + 1;
				endif;
			endif;
	
			if container.allQueuedFutureMoves.size &gt; 0 then
				if container.is20 then
					self.c20QueuedOut := self.c20QueuedOut + 1;
				elseif container.is30 then
					if container.isFrontEndOfTi(yc) = true then
						self.c30QueuedOut := self.c30QueuedOut + 1;
					endif;
				elseif container.is45 then
					if container.isFrontEndOfTi(yc) = true then
						self.c45QueuedOut := self.c45QueuedOut + 1;
					endif;
				elseif container.is40 then
					if container.isFrontEndOfTi(yc) = true then
						self.c40QueuedOut := self.c40QueuedOut + 1;
					endif;
				elseif container.is53 then
					if container.isFrontEndOfTi(yc) = true then
						self.c53QueuedOut := self.c53QueuedOut + 1;
					endif;
				else
					unknownQueuedOut := unknownQueuedOut + 1;
				endif;
			endif;
			
		else
		//
		// Code needs to be added for all TrackedItems other than a CM_Container
		//
		//	self.c20Used := self.c20Used + 1;	//15 Apr 2015	NDL	Par 35969 - Bulk is NOT a 20
		endif;
	endforeach;
	
	// May not have a container so must be outside
	iter := lc.allPlannedFutureMoves.createIterator();				// PAR #20586 - reworked to us iterator and local
	while iter.next(fmp) do											// trackedItem variable for performance
		trackedItem := fmp.myTrackedItem;
		if trackedItem.isKindOf(CM_Container) then
			container := trackedItem.CM_Container;
			if container.is20 then
				self.c20PlannedIn := self.c20PlannedIn + 1;
			elseif container.is30 then
				if container.myPrimaryPlannedLocation = lc then
					self.c30PlannedIn := self.c30PlannedIn + 1;
				endif;
			elseif container.is45 then
				if container.myPrimaryPlannedLocation = lc then
					self.c45PlannedIn := self.c45PlannedIn + 1;
				endif;
			elseif container.is40 then
				if container.myPrimaryPlannedLocation = lc then
					self.c40PlannedIn := self.c40PlannedIn + 1;
				endif;
			elseif container.is53 then
				if container.myPrimaryPlannedLocation = lc then
					self.c53PlannedIn  := self.c53PlannedIn  + 1;
				endif;
			else
				unknownPlannedIn := unknownPlannedIn + 1;
			endif;
		else
		//
		// Code needs to be added for all TrackedItems other than a CM_Container
		//
		//	self.c20QueuedIn := self.c20QueuedIn + 1;	//15 Apr 2015	NDL	Par 35969 - Bulk is NOT a 20
		endif;	
	endwhile;
	
	delete iter;
	iter := lc.allQueuedFutureMoves.createIterator();
	while iter.next(fmq) do
		trackedItem := fmq.myTrackedItem;
		if trackedItem.isKindOf(CM_Container) then
			container := trackedItem.CM_Container;
			if container.is20 then
				self.c20QueuedIn := self.c20QueuedIn + 1;
			elseif container.is30 then
				if container.myPrimaryQueuedLocation = lc then
					self.c30QueuedIn := self.c30QueuedIn + 1;
				endif;
			elseif container.is45 then
				if container.myPrimaryQueuedLocation = lc then
					self.c45QueuedIn := self.c45QueuedIn + 1;
				endif;
			elseif container.is40 then
				if container.myPrimaryQueuedLocation = lc then
					self.c40QueuedIn := self.c40QueuedIn + 1;
				endif;
			elseif container.is53 then
				if container.myPrimaryQueuedLocation = lc then
					self.c53QueuedIn  := self.c53QueuedIn  + 1;
				endif;
			else
				unknownQueuedIn := unknownQueuedIn + 1;
			endif;
		else
		//
		// Code needs to be added for all TrackedItems other than a CM_Container
		//
		//	self.c20QueuedIn := self.c20QueuedIn + 1;	//15 Apr 2015	NDL	Par 35969 - Bulk is NOT a 20
		endif;

	endwhile;

	//cnwjo3 par 21189
	//'used' does not get calculated here!
	self.plannedIn	:= self.c20PlannedIn + self.c30PlannedIn + self.c40PlannedIn + self.c45PlannedIn + self.c53PlannedIn + unknownPlannedIn;
	self.plannedOut	:= self.c20PlannedOut + self.c30PlannedOut + self.c40PlannedOut + self.c45PlannedOut + self.c53PlannedOut + unknownPlannedOut;
	self.queuedIn	:= self.c20QueuedIn + self.c30QueuedIn + self.c40QueuedIn + self.c45QueuedIn + self.c53QueuedIn + unknownQueuedIn;
	self.queuedOut	:= self.c20QueuedOut + self.c30QueuedOut + self.c40QueuedOut + self.c45QueuedOut + self.c53QueuedOut + unknownQueuedOut;

	
//  debugging - remove when happy
	if unknownUsed + unknownPlannedOut + unknownQueuedOut + unknownPlannedIn + unknownQueuedIn &gt; 0 then
		app.writeLog(class.name &amp; '::' &amp; method.name &amp; ' unknown container length - LC ' &amp; lc.String, LogINFO);
	endif;

epilog
	delete iter;
	
end;</source>
        <Parameter name="lc" type="CM_LocationsController"/>
        <Parameter name="minHeight" type="Integer"/>
        <Parameter name="maxHeight" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="d72a0412-e055-409d-a1bc-ce4965e1ae5d">
        <source>pxyCreateUpdateProxy(): SelfType;

/*

Purpose:			

Date			Who		Reason
18 August 2008	conkc1	Initial creation
20/04/2011		cnwmh5	PAR #27401 - Add code to handle prossible exceptions occurring when
						trying to create the proxy
*/

vars
	proxyYAObj			: SelfType;
	completedOK		: Boolean;
begin
	if self.isTransient() then
		completedOK := true;			// 20/04/2011 cnwmh5 #27401
		return null;
	endif;
	
	proxyYAObj	 :=	inheritMethod();
	completedOK := true;			// 20/04/2011 cnwmh5 #27401
	return proxyYAObj;
epilog
	if not completedOK then			// 20/04/2011 cnwmh5 #27401
		delete proxyYAObj;
	endif;

end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="rebuildAllSystemCounts" id="ef71b930-652d-4638-8271-06a0b66ace0c">
        <updating/>
        <source>rebuildAllSystemCounts(_terminal : CM_Terminal) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
15 August 2008	conkc1	Initial creation

*/


vars

	childLS         : CM_LocationStatistics;
	proxyLocationStatistic : CM_LocationStatistics;
	ta				: CM_TerminalArea;

	t20Total,
	t20Used,
	t20QueuedIn,
	t20QueuedOut,
	t20PlannedIn,
	t20PlannedOut,
	t20Free        : Integer;

	t30Total,
	t30Used,
	t30QueuedIn,
	t30QueuedOut,
	t30PlannedIn,
	t30PlannedOut,
	t30Free        : Integer;

	t45Total,
	t45Used,
	t45QueuedIn,
	t45QueuedOut,
	t45PlannedIn,
	t45PlannedOut,
	t45Free        : Integer;

	t40Total,
	t40Used,
	t40QueuedIn,
	t40QueuedOut,
	t40PlannedIn,
	t40PlannedOut,
	t40Free        : Integer;

	t53Total,
	t53Used,
	t53QueuedIn,
	t53QueuedOut,
	t53PlannedIn,
	t53PlannedOut,
	t53Free        : Integer;
	
begin

	foreach ta in _terminal.allTerminalAreas discreteLock do

		if (ta.isKindOf(CM_GridArea) or ta.isKindOf(CM_BlockStack)) = false then
			continue;
		endif;
		if ta.myLocationStatistics = null then

			create proxyLocationStatistic transient;
			proxyLocationStatistic.setParent(ta);
			create childLS persistent;
			childLS.setupForCreate(proxyLocationStatistic);
			delete proxyLocationStatistic;
		endif;
		ta.myLocationStatistics.buildOneAreaSystemCount(ta);
		childLS    := ta.myLocationStatistics;
		//
		//  Accumulate each TA's counts for the terminal totals
		//
		t20Used    := t20Used + childLS.c20Used;
		t30Used    := t30Used + childLS.c30Used;
		t40Used    := t40Used + childLS.c40Used;
		t45Used    := t45Used + childLS.c45Used;
		t53Used    := t53Used + childLS.c53Used;

		t20PlannedOut := t20PlannedOut + childLS.c20PlannedOut;
		t30PlannedOut := t30PlannedOut + childLS.c30PlannedOut;
		t40PlannedOut := t40PlannedOut + childLS.c40PlannedOut;
		t45PlannedOut := t45PlannedOut + childLS.c45PlannedOut;
		t53PlannedOut := t53PlannedOut + childLS.c53PlannedOut;

		t20QueuedOut  := t20QueuedOut + childLS.c20QueuedOut;
		t30QueuedOut  := t30QueuedOut + childLS.c30QueuedOut;
		t40QueuedOut  := t40QueuedOut + childLS.c40QueuedOut;
		t45QueuedOut  := t45QueuedOut + childLS.c45QueuedOut;
		t53QueuedOut  := t53QueuedOut + childLS.c53QueuedOut;

		t20PlannedIn  := t20PlannedIn + childLS.c20PlannedIn;
		t30PlannedIn  := t30PlannedIn + childLS.c30PlannedIn;
		t40PlannedIn  := t40PlannedIn + childLS.c40PlannedIn;
		t45PlannedIn  := t45PlannedIn + childLS.c45PlannedIn;
		t53PlannedIn  := t53PlannedIn + childLS.c53PlannedIn;

		t20QueuedIn   := t20QueuedIn + childLS.c20QueuedIn;
		t30QueuedIn   := t30QueuedIn + childLS.c30QueuedIn;
		t40QueuedIn   := t40QueuedIn + childLS.c40QueuedIn;
		t45QueuedIn   := t45QueuedIn + childLS.c45QueuedIn;
		t53QueuedIn   := t53QueuedIn + childLS.c53QueuedIn;
		
		t20Total      := t20Total + childLS.c20Total;
		t30Total      := t30Total + childLS.c30Total;
		t40Total      := t40Total + childLS.c40Total;
		t45Total      := t45Total + childLS.c45Total;
		t53Total      := t53Total + childLS.c53Total;

		t20Free       := t20Free + childLS.c20Free;
		t30Free       := t30Free + childLS.c30Free;
		t40Free       := t40Free + childLS.c40Free;
		t45Free       := t45Free + childLS.c45Free;
		t53Free       := t53Free + childLS.c53Free;

	endforeach;
	
	self.c20Used    := t20Used;
	self.c30Used    := t30Used;
	self.c40Used    := t40Used;
	self.c45Used    := t45Used;
	self.c53Used    := t53Used;

	self.c20PlannedOut := t20PlannedOut;
	self.c30PlannedOut := t30PlannedOut;
	self.c40PlannedOut := t40PlannedOut;
	self.c45PlannedOut := t45PlannedOut;
	self.c53PlannedOut := t53PlannedOut;

	self.c20QueuedOut  := t20QueuedOut;
	self.c30QueuedOut  := t30QueuedOut;
	self.c40QueuedOut  := t40QueuedOut;
	self.c45QueuedOut  := t45QueuedOut;
	self.c53QueuedOut  := t53QueuedOut;

	self.c20PlannedIn  := t20PlannedIn;
	self.c30PlannedIn  := t30PlannedIn;
	self.c40PlannedIn  := t40PlannedIn;
	self.c45PlannedIn  := t45PlannedIn;
	self.c53PlannedIn  := t53PlannedIn;

	self.c20QueuedIn   := t20QueuedIn;
	self.c30QueuedIn   := t30QueuedIn;
	self.c40QueuedIn   := t40QueuedIn;
	self.c45QueuedIn   := t45QueuedIn;
	self.c53QueuedIn   := t53QueuedIn;
	
	self.c20Total      := t20Total;
	self.c30Total      := t30Total;
	self.c40Total      := t40Total;
	self.c45Total      := t45Total;
	self.c53Total      := t53Total;

	self.c20Free       := t20Free;
	self.c30Free       := t30Free;
	self.c40Free       := t40Free;
	self.c45Free       := t45Free;
	self.c53Free       := t53Free;
	
	self.setUpdateTimestamp;
epilog
	delete proxyLocationStatistic;
end;</source>
        <Parameter name="_terminal" type="CM_Terminal"/>
    </JadeMethod>
    <JadeMethod name="recalculateValues" id="4ac96dab-ce6e-40af-929f-d3a0f593764e">
        <updating/>
        <source>recalculateValues(pProxyLocationStatistics : CM_LocationStatistics) updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 August 2008	conkc1	Initial creation

*/

vars
	terminal : CM_Terminal;
begin
	terminal := self.myParent.CM_Terminal;
	rebuildAllSystemCounts(terminal);
epilog

end;</source>
        <Parameter name="pProxyLocationStatistics" type="CM_LocationStatistics"/>
    </JadeMethod>
