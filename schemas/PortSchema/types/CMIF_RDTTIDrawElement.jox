    <JadeMethod name="drawTIBox" id="a307290c-4103-44d7-874b-015bf2991aa1">
        <source>drawTIBox(_frame : Frame; _colour1 : Integer; _colour2 : Integer; _x1,_y1,_x2,_y2 : Integer; _scaleFactor : Real) protected;
// ---------------------------------------------------------------------------
// Created:		31 July 2006 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------
vars
begin
	//lFactor := self.scaleFactor.Integer;

	_frame.drawLine(_x1, _y1, _x2 + 1, _y1 ,  _colour1);
	_frame.drawLine(_x1, _y1, _x1, _y2,  _colour1);
	_frame.drawLine(_x2, _y1 , _x2, _y2 + 1,  _colour2);
	_frame.drawLine(_x1, _y2, _x2, _y2,  _colour2);

	if _scaleFactor &gt; .75 then

		_frame.drawLine(_x1, _y1 + 1, _x2, _y1 + 1 ,  _colour1);
		_frame.drawLine(_x1 + 1, _y1, _x1 + 1, _y2,  _colour1);
		_frame.drawLine(_x2 - 1, _y1 + 1, _x2 - 1, _y2 + 1,  _colour2);
		_frame.drawLine(_x1 + 1, _y2 - 1, _x2, _y2 - 1,  _colour2);
	endif;

	if _scaleFactor &gt; 1.5 then

		_frame.drawLine(_x1, _y1 + 2, _x2 - 1, _y1 + 2 ,  _colour1);
		_frame.drawLine(_x1 + 2, _y1, _x1 + 2, _y2 - 2,  _colour1);
		_frame.drawLine(_x2 - 2, _y1 + 2, _x2 - 2, _y2 + 1,  _colour2);
		_frame.drawLine(_x1 + 2, _y2 - 2, _x2, _y2 - 2,  _colour2);
	endif;
end;</source>
        <access>protected</access>
        <Parameter name="_frame" type="Frame"/>
        <Parameter name="_colour1" type="Integer"/>
        <Parameter name="_colour2" type="Integer"/>
        <Parameter name="_x1" type="Integer"/>
        <Parameter name="_y1" type="Integer"/>
        <Parameter name="_x2" type="Integer"/>
        <Parameter name="_y2" type="Integer"/>
        <Parameter name="_scaleFactor" type="Real"/>
    </JadeMethod>
    <JadeMethod name="drawTopDown" id="4a410f3f-1d9f-42c6-873a-8a0d214765b4">
        <source>drawTopDown(_x1: Real; _y1: Real; _x2: Real; _y2: Real; _frame: Frame input; _scaleFactor: Real; _isLandscape: Boolean; _flipH: Boolean; _flipV: Boolean; _mode : Integer) protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
26 May 2010	cnwjk3	Initial creation
12 Jul 2010 cnwer1	PAR 24901 - display id at smaller scale factor 
23 May 2011 cnwer1	PAR 27558 - highlight from height should be &gt; or = to
*/

vars
	operator 		: CM_Operator;
	oldDrawWidth    : Integer;
	oldFontSize		: Real;
	highlightColour,
	tiColour,
	fontColour	 	: Integer;
	x1, y1,
	x2, y2 			: Real;
	text			: String;
	lc : CM_LocationsController;

begin
	
	x1 := _x1;
	y1 := _y1;
	x2 := _x2;
	y2 := _y2;
	self.gridPointsToElementPoints(x1, y1, x2, y2, _scaleFactor, _isLandscape, _flipH, _flipV);
		
	operator := app.myRoot.allOperators[self.myTI.operatorCode];
	if operator &lt;&gt; null then
		tiColour := operator.colour;
		fontColour := tiColour.getInverseColour();
	else
		tiColour := White;
		fontColour := Black;
	endif;
		
	highlightColour := tiColour;
	
	oldFontSize := _frame.drawFontSize;
	oldDrawWidth := _frame.drawWidth;

	_frame.drawFontBold := true; 
	
	//epr par 24901 12/7/10
	if _scaleFactor  &lt;= 1.5 then
		_frame.drawFontSize :=6;
	elseif  _scaleFactor &gt; 1.5 and _scaleFactor &lt;= 3.5 then
		_frame.drawFontSize := 4 * _scaleFactor;
	elseif  _scaleFactor &gt;= 1 then
		_frame.drawFontSize := 3 * _scaleFactor;	
	endif;
	
	_frame.drawFillColor := tiColour;
	_frame.drawFilledRectangle(x1, y1, x2, y2, highlightColour);
	
	// 80's 3D look...
	self.drawTIBox(_frame, Grey, Black, x1.Integer, y1.Integer, x2.Integer, y2.Integer, _scaleFactor);
	
	//02 March 2011	#cnwdz2	 ccms 2005 par25644 start
	lc := self.myTI.myPrimaryActualLocation;
	if lc &lt;&gt; null and lc.isKindOf(CM_GridController) then
		//epr par 27558 23/5/11 should higllight from specified highlight height and above
		if self.highlightHeight &gt; 0  and lc.CM_GridController.getActualStackPositionOfTI(self.myTI) &gt;= self.highlightHeight  then
			self.highlightGridHeight(_frame, x1.Integer, y1.Integer, x2.Integer, y2.Integer, _scaleFactor);
		endif;
	endif;
	//02 March 2011	#cnwdz2	 ccms 2005 par25644 start
	
	if (_scaleFactor &gt;= 0.5 and _mode &lt;&gt; CMIF_RDTDrawElement.MODE_END) or (_scaleFactor &gt;= 2 and _mode = CMIF_RDTDrawElement.MODE_END) then
		text := self.getDisplayTextForTI(self.myTI, _scaleFactor, _isLandscape, _mode);		
		text := self.convertStringForWidth((x2-x1-8).Integer, _frame, text);
		if self.myTI.myPrimaryActualLocation &lt;&gt; null and self.myTI.myPrimaryActualLocation.isKindOf(CM_WagonController) then
			if _isLandscape and (not _flipV ) then
				_frame.drawTextIn(text, x1+ 4, y2  - _frame.drawFontSize  - 8, x2, y2, fontColour);// 8 is the size of the selection border	
			else
				if _flipV then
					_frame.drawTextIn(text, x1+ 4, y1 + _frame.drawFontSize, x2, y2, fontColour);
				else
					_frame.drawTextIn(text, x1+ 4, y1 + (_frame.drawFontSize*2), x2, y2, fontColour);
				endif;
			endif;
		
		else	
			_frame.drawTextIn(text, x1+ 4, y1 + 8, x2, y2, fontColour);
		endif;
	
	
	endif;
	
	
	
	
	_frame.drawFontSize := oldFontSize;
	_frame.drawWidth := oldDrawWidth;
	_frame.drawFontBold := false; 
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_x1" type="Real"/>
        <Parameter name="_y1" type="Real"/>
        <Parameter name="_x2" type="Real"/>
        <Parameter name="_y2" type="Real"/>
        <Parameter name="_frame" type="Frame" usage="input"/>
        <Parameter name="_scaleFactor" type="Real"/>
        <Parameter name="_isLandscape" type="Boolean"/>
        <Parameter name="_flipH" type="Boolean"/>
        <Parameter name="_flipV" type="Boolean"/>
        <Parameter name="_mode" type="Integer"/>
    </JadeMethod>
    <JadeMethod name="getDisplayTextForTI" id="53b28f06-1016-4363-9ac0-f28227ca2f3b">
        <source>getDisplayTextForTI(_ti : CM_TrackedItem; _scaleFactor : Real; _isLandscape : Boolean; _mode : Integer) : String protected;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
30 April 2010	cnwjk3	Initial creation
12 Jul 2010 cnwer1	PAR 24901 - display id at smaller scale factor 
*/
constants 
	Factor : Real = 0.001;
vars
	maxDisplay : Boolean;
	lc : CM_LocationsController;
	id,
	isoType,
	weight,
	text	: String;
begin
	lc := _ti.myPrimaryActualLocation;//.CM_GridController;
	if lc = null then
		return '';
	endif;
	
	maxDisplay := (_isLandscape and _scaleFactor &gt;= 0.5) or
				  (not _isLandscape and _scaleFactor &gt; 1);
	
	
	// Id
	if maxDisplay then
		if not _isLandscape then
			text := _ti.getSplitIdText();
		else
			if _scaleFactor &lt; 1 and _ti.id.length &gt; 4 then
				text:=_ti.id[_ti.id.length - 3 : _ti.id.length];
			else
				text := _ti.id;
			endif;
		endif;
	endif;

	if maxDisplay then
		// ISO Type
		if _isLandscape and _scaleFactor &gt;= 1.5 or
		   not _isLandscape and _scaleFactor &gt;= 1.75 then
			if _ti.isKindOf(CM_Container) then
				if _isLandscape and _scaleFactor &lt; 2.5  then
					text := text &amp; " ";
				else
					if (_ti.is20 or _ti.is30) then
						text := text &amp; Cr &amp; Cr;
					else
						text := text &amp; " ";
					endif;
				endif;
				text := text &amp; _ti.CM_Container.isoType;
			endif;
		endif;
		
		
		// Weight
		if _isLandscape and _scaleFactor &gt;= 1.5 or
		   not _isLandscape and _scaleFactor &gt;= 1.75 then
			if _isLandscape and _scaleFactor &lt; 4.75 then
				text := text &amp; " ";
			else
				text := text &amp; Cr &amp; Cr;
			endif;
			text := text &amp; (_ti.totalWeight * Factor).roundedTo(1).String &amp; "T";
		endif;
	endif;
	
	// Height
	if _mode = CMIF_RDTDrawElement.MODE_TOPDOWN and _scaleFactor &gt; 0.5 then
		if _isLandscape then
			text := text &amp; " ";
		else
			text := text &amp; Cr &amp; Cr;
		endif;
		
		if lc.isKindOf(CM_GridController) then
			text := text &amp; "H:" &amp; lc.CM_GridController.getActualStackPositionOfTI(_ti).String;
		else
			text := text &amp; "H:" &amp; lc.allTrackedItems.size().String;
		endif;
	endif;
	
	
	return text;
epilog

end;</source>
        <access>protected</access>
        <Parameter name="_ti" type="CM_TrackedItem"/>
        <Parameter name="_scaleFactor" type="Real"/>
        <Parameter name="_isLandscape" type="Boolean"/>
        <Parameter name="_mode" type="Integer"/>
        <ReturnType type="String"/>
    </JadeMethod>
