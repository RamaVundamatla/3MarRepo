    <JadeMethod name="setupForm" id="1c6e69db-cb22-47b7-9b21-e04d032243df">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 June 2018	jlgndl1	Initial creation	TFS 39140
12 Feb  2019	cnwma1	ChangeRequest 43244: PEL1 - Container Services - Segregation in WP for Depot and Terminal
*/

vars

begin
	
	self.frmMain.left := 1;
	self.frmMain.top := 1;
	self.frmMain.borderStyle := 0;
	self.clientWidth := ( self.frmMain.width + 2 ).Integer;
	self.clientHeight := ( self.frmMain.height + 2 ).Integer;
	self.frmMain.parentAspect := 3;
	self.cmbDepotVoyage.enabled := false;  //12.02.2019 cnwma1 TFS #43244
	
	allowUpdate := app.getMyUser.canDo( null, self.permissionMaint );

	inheritMethod();
	
	if self.myAssistant = null then
		create self.myAssistant transient;
	endif;
	
	self.centreOverParent(1);
	
	self.populateCmbTerminals();

epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="50ad63e2-9433-4788-bf40-eeb66b44cadb">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 10 February 2022 10:11:14.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0022594, locale);
	btnClose.translateCaption(Xlat_0022595, locale);
	btnDelete.translateCaption(Xlat_0022596, locale);
	btnUpdate.translateCaption(Xlat_0022597, locale);
	chkWPUpdateBerth.translateCaption(Xlat_0023044, locale);
	lblDepotVoyage.translateCaption(Xlat_0023212, locale);
	lblTerminal.translateCaption(Xlat_0022598, locale);
end;</source>
    </JadeMethod>
    <JadeMethod name="vesselDisplayName" id="09380044-d0fa-4143-84f2-3b469afba865">
        <source>vesselDisplayName( _vessel : CM_Vessel ):String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
11 June 2018	jlgndl1	Initial creation

*/

vars

begin

	if _vessel &lt;&gt; null then
		return _vessel.name;
	endif;
	
	return null;

epilog

end;</source>
        <Parameter name="_vessel" type="CM_Vessel"/>
        <ReturnType type="String"/>
    </JadeMethod>
</GUIClass>
