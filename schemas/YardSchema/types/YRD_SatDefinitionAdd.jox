    <JadeMethod name="setMyTAViewInterface" id="6db42d7a-9517-4738-bbde-14f9dda4b38f">
        <updating/>
        <source>setMyTAViewInterface(_taViewInterface : IF_CM_TerminalAreaViews) updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
18 November 2010	cnwer1	Initial creation

*/

vars

begin
	self.myTAViewInterface:=_taViewInterface;
	self.myTerminal:=_taViewInterface.getTerminal;
epilog

end;</source>
        <Parameter name="_taViewInterface" type="IF_CM_TerminalAreaViews"/>
    </JadeMethod>
    <JadeMethod name="setupForm" id="60ff2e55-d24d-40ae-a678-e910f710e24f">
        <updating/>
        <source>setupForm() updating;
/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
22 November 2010	cnwer1	Initial creation
19 September 2011	cnwdap1	PAR #27814 Set focus to "Name" field
*/

vars
	allowPrivate : Boolean;
begin
	inheritMethod();
	self.optSystem.value:=true;
	allowPrivate:=app.myPassport.myUser.canDo(self.myTerminal,PmAdmSatellitePrivateView);
	if not allowPrivate then
		self.enablePrivate(false);	
	endif;
	self.txtName.setFocus();		// PAR #27814
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="translateForm" id="3c4525f4-1b76-4b00-8bd8-94eae4190bfe">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 13 April 2013.
	//3/11/2019	jlgns1	TFS 3827 XLAT_FormCaptions need to be sorted out
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0016364, locale);
	lblName.translateCaption(Xlat_0016365, locale);
	optPrivate.translateCaption(Xlat_0016366, locale);
	optSystem.translateCaption(Xlat_0016367, locale);
end;</source>
    </JadeMethod>
</GUIClass>
