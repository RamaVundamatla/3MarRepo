    <JadeMethod name="create" id="358166ef-7dc6-4b9e-8769-c92e48b92e8e">
        <updating/>
        <source>create() updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 September 2021	jlizm1	Initial creation TFS 51963 SAL Voyage Request Changes
14 Mar 2022			navma1	ChangeRequest 52821: EUP - Documents Linked to Cargo Types
*/

vars

begin
	
	/*
	14.03.2022 navma1 #52821
	Permissions have been disabled here to be able to set the permission based on the object type the same form will be used 
	at system and terminal level
	self.permissionView  := PmFileAttachView;
	self.permissionMaint := PmFileAttachMaint;
	*/
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayFileSelected" id="e825a161-3b6f-4cdd-86f8-03afc067a97c">
        <source>displayFileSelected();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 September 2021	jlizm1	Initial creation TFS 51963 SAL Voyage Request Changes
05 Dec 2022			navvt20 TFS CR 55299 Task 55520: UI - File Load and File Attachment UI changes
09 Dec 2022 		navvt20 TFS CR 55302 Defect 55795: MTN - Cannot attach files in state = posted
12 Jan 2022			navvt20	TFS CR 55302 Defect 56161: MTN - cannot edit documents on posted invoices.
22 May 2023			navmk20	Bug 58087: FR | EUP 54086 - Invoicing - Maintenance Enhancements 090.h
21 Aug 2024			navnk30 Bug 65602: FR - 54089 - Invoice Contract - permissions
*/

vars

begin
	/*				21.08.2024	navnk30	#65602	START
	// disable everything
	self.btnDelete.enabled := false;
	self.btnLoad.enabled := false;//9 Dec 2022 navvt20 TFS ,55795 navtnr20 07-02-2022 
	//self.btnLoad.enabled := true;	// 9 Dec 2022 navvt20 TFS 55795	
	self.btnView.enabled := false;
	self.btnEdit.enabled := false; // 5 Dec 2022 navvt20 TFS 55520
	self.btnAudits.enabled := false; // 22.5.2020 navmk20 TFS 58087
		
	if allowUpdate then
		self.btnLoad.enabled := true;
		if self.tblFiles.row &lt;= self.tblFiles.fixedRows then
			// nothing in table to view or delete
			return;
		endif;
		self.btnDelete.enabled := true; 
		self.btnEdit.enabled := true; // 5 Dec 2022 navvt20 TFS 55520
	endif;
		
	self.btnView.enabled := true;
	// Start 12 Jan 2022 navvt20 TFS 56161
	if(tblFiles.selected) then
		self.btnDelete.enabled := true; 
		self.btnEdit.enabled := true; 
		self.btnAudits.enabled := true; // 22.5.2020 navmk20 TFS 58087
	else
		self.btnDelete.enabled := false; 
		self.btnEdit.enabled := false; 
		self.btnAudits.enabled := false; // 22.5.2020 navmk20 TFS 58087
	endif;
	// End 12 Jan 2022 navvt20 TFS 56161
	*/
	
	self.btnAudits.enabled	:= self.tblFiles.selected;
	self.btnView.enabled 	:= self.tblFiles.selected;
	
	self.btnLoad.enabled	:= self.allowUpdate;
	self.btnEdit.enabled	:= self.allowUpdate and self.tblFiles.selected;
	self.btnDelete.enabled	:= self.allowUpdate and self.tblFiles.selected;
	//				21.08.2024	navnk30	#65602	END
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="displayFiles" id="c40c03f5-e09b-46ad-a36a-876757c70620">
        <source>displayFiles();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 September 2021	jlizm1	Initial creation TFS 51963 SAL Voyage Request Changes
04 March 2022		navhl20	TFS 52821 EUP - Documents Linked to Cargo Types
09 March 2022		jlizm1	TFS 52834 SAL file attachments filter by work order
26 Nov 2022  		navvt20	Task 55527: Invoice List Attachments
*/

vars

	tblDocument : CM_DataTable;
	rowArray : EntTableRowArray;
	file : CM_FileData;
	wo : CM_WorkOrder;	// TFS 52834
	files : CM_FileDataSet;
begin

	tblDocument := self.tblFiles;
	tblDocument.clearAllData();
	if self.myParent = null then
		return;
	endif;
	
	rowArray := tblDocument.allTblDataEntRows;
	
	// ### TFS CR 55645 TASK 55662 13DEC2022 NAVAB1 - refactored
	files := self.myParent.getFileAttachments();
	foreach file in files do
		//Add each file to the table by using the tblDocument.addObjectToTable.
		tblDocument.addItemObject(file, file.getAttributeStringForDefArray(rowArray));
	endforeach;

	if files.isTransient then // CM_Invoice sends back a transient set
		delete files;
	endif;
	/*  // ### TFS CR 55645 TASK 55662 13DEC2022 NAVAB1
	if self.myParent.isKindOf(CM_Voyage) then
		foreach file in self.myParent.CM_Voyage.allFiles do
			//Add each file to the table by using the tblDocument.addObjectToTable.
			tblDocument.addItemObject(file, file.getAttributeStringForDefArray(rowArray));
		endforeach;

		foreach wo in self.myParent.CM_Voyage.allWorkOrders do // TFS 52834
			foreach file in wo.allFiles do
				tblDocument.addItemObject(file, file.getAttributeStringForDefArray(rowArray));
			endforeach;
		endforeach;
	
	elseif self.myParent.isKindOf(CM_WorkOrder) then // TFS 52834
		foreach file in self.myParent.CM_WorkOrder.allFiles do
			tblDocument.addItemObject(file, file.getAttributeStringForDefArray(rowArray));
		endforeach;
		
	elseif self.myParent.isKindOf(CM_CargoType) then 											//04.03.2022 navhl20 TFS #52821
		foreach file in self.myParent.CM_CargoType.allFiles do									//04.03.2022 navhl20 TFS #52821
			//Add each file to the table by using the tblDocument.addObjectToTable.
			tblDocument.addItemObject(file, file.getAttributeStringForDefArray(rowArray));		//04.03.2022 navhl20 TFS #52821
		endforeach;																				//04.03.2022 navhl20 TFS #52821
	//Start 25 Nov 2022 navvt20 TFS 55527
	elseif	self.myParent.isKindOf(CM_Invoice) then
		foreach file in self.myParent.CM_Invoice.allFiles do
			tblDocument.addItemObject(file, file.getAttributeStringForDefArray(rowArray));
		endforeach;
	// End 25.11.2022 navvt20 TFS 55527
	elseif	self.myParent.isKindOf(CM_InvoiceContract) then // ### TFS CR 55645 TASK 55662 13DEC2022 NAVAB1
		foreach file in self.myParent.CM_InvoiceContract.allFiles do // ### TFS CR 55645 TASK 55662 13DEC2022 NAVAB1
			tblDocument.addItemObject(file, file.getAttributeStringForDefArray(rowArray)); // ### TFS CR 55645 TASK 55662 13DEC2022 NAVAB1
		endforeach; // ### TFS CR 55645 TASK 55662 13DEC2022 NAVAB1
	endif;
	
	*/
	
	tblDocument.colourRows(self.colorRow1, self.colorRow2);
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnDeleteClick" id="77f5807e-56ca-4c35-85e6-a5011ec8d6ec">
        <source>doBtnDeleteClick();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 September 2021	jlizm1	Initial creation TFS 51963 SAL Voyage Request Changes
09 March 2022		jlizm1	TFS 52834 SAL file attachments filter by work order
14 Mar 2022			navma1	ChangeRequest 52821: EUP - Documents Linked to Cargo Types
31 Mar 2022			navhl20  TFS 53185 Screen validation issue for File Attachment
05 Dec 2022 		navvt20  TFS CR 55299 Task 55520: UI - File Load and File Attachment UI changes 
22 May 2023	navmk20	Bug 58087: FR | EUP 54086 - Invoicing - Maintenance Enhancements 090.h
*/

vars

	fileData: CM_FileData;
	
begin
	
	/*14.03.2022 navma1 52821
	if not app.myCurrentUserCan(self.myTerminal, PmFileAttachMaint) then
		app.msgBox(app.getErrorString(NoPermission2), "File Attachments Delete", MsgBox_OK_Only);
		return;
	endif;
	*/
	
	fileData:=self.tblFiles.accessRow(self.tblFiles.row).itemObject.CM_FileData;
	
	if fileData = null then
		return;
	endif;
	
	if app.msgBox(app.getErrorString(ConfirmDeleteItems), app.getErrorString(Confirm_Delete), MsgBox_Yes_No) = MsgBox_Return_Yes then // TFS 52834
		app.myTrxDA.trxDeleteFile(self.myParent, fileData, app.myPassport);
		self.btnDelete.enabled := false;                //TFS 53185
		self.btnView.enabled := false;                  //TFS 53185
		self.btnEdit.enabled := false;					// 5 Dec 2022 navvt20 TFS 55520
		self.btnAudits.enabled := false; 				// 22.5.2020 navmk20 TFS 58087
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnEditClick" id="45c5849b-328f-4dc1-8984-b66090659c48">
        <source>doBtnEditClick();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
06 December 2022	navhl20	TFS CR 55299 Task 55520: UI - File Load and File Attachment UI changes

*/

vars
	fileData : CM_FileData;
	loadForm: CMUI_EditFileAttachment;
begin
	fileData := self.tblFiles.accessRow(self.tblFiles.row).itemObject.CM_FileData;
	
	if fileData = null then
		return;
	endif;
		
	if self.myParent =  null then
		btnEdit.enabled := false;
		return;
	endif;
	
	loadForm := app.loadForm(CMUI_EditFileAttachment, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_EditFileAttachment;
	if loadForm = null then
		return;
	else
	  loadForm.init(self.myParent, self.myParent.getDisplayDetails(true));
		if  self.myParent.isKindOf(CM_CargoBOLType)then						//16.03.2022 navma1 #52821
			loadForm.myParentForm := self;
		endif;
			loadForm.myFileData := fileData;
		loadForm.showModal();
	endif;
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnLoadClick" id="8673447c-d85e-4195-9ab3-264a61fe3583">
        <source>doBtnLoadClick();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 September 2021	jlizm1	Initial creation TFS 51963 SAL Voyage Request Changes
14 Mar 2022			navma1	ChangeRequest 52821: EUP - Documents Linked to Cargo Types
*/

vars

	loadForm: CMUI_FileLoad;
	
begin

	if self.myParent =  null then
		return;
	endif;
	
	/*
	14.03.2022 navma1 52821
	if not app.myCurrentUserCan(self.myTerminal, PmFileAttachMaint) then
		app.msgBox(app.getErrorString(NoPermission2), "File Attachments Add", MsgBox_OK_Only);
		return ;
	endif;
	*/
	
	loadForm := app.loadForm(CMUI_FileLoad, CMUI_Assistant, false, false, true, self.myTerminal, null).CMUI_FileLoad;
	if loadForm = null then
		return;
	else
		loadForm.init(self.myParent, self.myParent.getDisplayDetails(true));
		if  self.myParent.isKindOf(CM_CargoBOLType)then						//16.03.2022 navma1 #52821
			loadForm.myParentForm := self;
		endif;
		loadForm.showModal();
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doBtnViewClick" id="b706ac03-6bbd-4504-a666-8a90c956c22f">
        <source>doBtnViewClick();
/*

Purpose:			

Parameters:			

Return Value:		

Date				Who		Reason
24 September 2021	jlizm1	Initial creation TFS 51963 SAL Voyage Request Changes
14 Mar 2022         navma1  14 Mar 2022		navma1	ChangeRequest 52821: EUP - Documents Linked to Cargo Types
*/

vars

	fileData :CM_FileData;
	
begin
	
	/* 
	14.03.2022 navma1 52821
	if not app.myCurrentUserCan(self.myTerminal, PmFileAttachView) then
		app.msgBox(app.getErrorString(NoPermission2), "File Attachments View", MsgBox_OK_Only);
		return ;
	endif;
	*/
	
	fileData := self.tblFiles.accessRow(self.tblFiles.row).itemObject.CM_FileData;
	
	if fileData&lt;&gt; null then
		fileData.viewFile(fileData.fileName);
	endif;
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doPermissionCheck" id="17e05227-c3c7-42f6-b01d-d39cc909c31f">
        <updating/>
        <source>doPermissionCheck()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
14 Mar 2022		navma1	ChangeRequest 52821: EUP - Documents Linked to Cargo Types
02-02-2023 		navtnr20 TFS CR 55646	Task 55664: UI - Contracts Maint
07-02-2023		navvt20 Defect 56451: Jade - Invoice File Attachment Permissions
22 June 2023 navtnr20	TFS CR 58224	Task 58228: UI - COO Attachments
*/

vars
	viewPerm  : Integer;
	maintPerm : Integer;
begin
	self.allowUpdate := false;
	
	self.myParent.getFileCategoryPermissions(viewPerm,maintPerm); // ### TFS CR 56094 TASK 59618 08AUG2023 NAVAB1
	
	// End 7 Feb 2023 navvt20 Defect 56451
	//view Permission 
	if not app.myCurrentUserCan(self.myTerminal, viewPerm) then
		app.msgBox(app.getErrorString(NoPermission2), "File Attachments View", MsgBox_OK_Only);
		unloadForm();
	endif;
	
	
	//Maint Permission 
	if  app.myCurrentUserCan(self.myTerminal, maintPerm) then
		self.allowUpdate := true;
	endif;
	
	
epilog

end;</source>
    </JadeMethod>
    <JadeMethod name="doViewAudits" id="c2b87e95-baa1-430f-80c1-dd1d2ba8b1bc">
        <updating/>
        <source>doViewAudits()updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
22 May 2023	navmk20	Bug 58087: FR | EUP 54086 - Invoicing - Maintenance Enhancements 090.h

*/

vars
	
	fileData: CM_FileData;
begin

	fileData := self.tblFiles.accessRow(self.tblFiles.row).itemObject.CM_FileData; 
	
	if fileData = null then
		return;
	endif;

	if self.myAssistant = null then
		create self.myAssistant as CMUI_Assistant transient;
		self.myAssistant.setMyTerminal(self.myTerminal);		
	endif;
	
	app.viewAuditForm(fileData.CM_FileData, self.myAssistant.class, self.myTerminal);
epilog

end;</source>
    </JadeMethod>
