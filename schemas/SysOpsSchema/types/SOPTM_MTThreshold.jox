    <JadeMethod name="includeObject" id="6c485bd5-de74-4596-ab6a-dc27add571d8">
        <updating/>
        <source>includeObject(_obj: Object; _passport: CM_Passport): Boolean updating;

/*

Purpose:			

Parameters:			

Return Value:		


Date		Who		Reason
16 June 2011	cnwndl1	Initial creation	Par 27731

*/

vars

begin
	if self.includeNotAvailableEntries then
		return true;
	else
		return _obj.CM_MTThreshold.isActive;
	endif;

epilog

end;</source>
        <Parameter name="_obj" type="Object"/>
        <Parameter name="_passport" type="CM_Passport"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
