    <JadeMethod name="unload" id="8b00584c-9219-4a01-a291-83c9519ee47f">
        <controlMethod name="Form::unload"/>
        <methodInvocation>event</methodInvocation>
        <updating/>
        <source>unload() updating;

vars
	invalidObject	: Boolean;
begin
	// Mar 2012 from general testing - if the rate table is closed first, the reference here is invalid
	on Exception do app.handleDeletedObject(exception, self.myRateTableForm, invalidObject);

	// July 2010 cnwjre1 24052 save last entered date for subsequent adds in parent form
	if self.lastEnteredDate &lt;&gt; null and
	   self.myRateTableForm &lt;&gt; null then
		self.myRateTableForm.lastEnteredDate := self.lastEnteredDate;
	endif;
	inheritMethod;
end;
</source>
    </JadeMethod>
    <JadeMethod name="userNotificationUpdate" id="b401e536-7837-490e-945e-67f6824b6f9f">
        <updating/>
        <source>userNotificationUpdate(_event: Integer; _noteobj : CM_Object; _obj: CM_Object) updating;
// ---------------------------------------------------------------------------
// Created:		September 2004 By Andrew Bishop cnwab1
//
// Purpose:		
//
// ---------------------------------------------------------------------------

vars
	theRateEntry : CM_RateEntry;
	theDataLine : String;
	idx : Integer;
	savedChargedEffTS : TimeStamp;
begin
	// 
	//19 Sep 2012	NDL	Par 30375
	savedChargedEffTS := app.getChargeRateEffectiveDate();
	app.setChargeRateEffectiveDate( self.effectiveDate.TimeStamp );
	
	// PAR 31657
	if _event = EVENT_SERVICE_DELETE then
		if _obj = self.myCurrentService then
			self.myCurrentService := null;
			self.myCurrentRate := null;
			self.myCurrentRateEntry := null;
			self.doComboServicesBuild();
			self.doQuery();
		endif;
	
	endif;

	
	if _event = EVENT_RATEENTRY_DELETE then
		self.tblData.findObjectInRow(_obj,idx);
		if idx &gt; 0 then
			self.tblData.removeItem(idx);
		endif;
		if self.myCurrentRateEntry = _obj then // PAR 18586
			self.setMyCurrentRateEntry(null);	//17 Sep 2012	NDL	Par 30375
		endif;
		return;
	endif;

	if _obj &lt;&gt; null and _event = EVENT_RATEENTRY_UPDATE then
		theRateEntry := _obj.CM_RateEntry;
		// 35872 ignore if for a different business unit
		if theRateEntry.rate.service.bank &lt;&gt; self.myCurrentBank then
			return;
		endif;
		theDataLine := theRateEntry.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);	// 23582

		self.tblData.findObjectInRow(theRateEntry,idx);
		if idx &gt; 0 then
			self.tblData.accessCell(idx,1).text := theDataLine;
		endif;
		self.displayExtraInfo();	//19 Sep 2012	NDL	Par 30375
		
	elseif _obj &lt;&gt; null and _event = EVENT_RATEENTRY_CREATE then
		theRateEntry := _obj.CM_RateEntry;
		// 35872 ignore if for a different business unit
		if theRateEntry.rate.service.bank &lt;&gt; self.myCurrentBank then
			return;
		endif;
		// ## insert the new Bank by finding the group then insert under that.
		idx := self.tblData.rows;
		if idx &gt; 0 then
			idx := idx + 1;
			theDataLine := theRateEntry.getAttributeStringForDefArray(self.tblData.allTblDataEntRows);	// 23582
			self.tblData.addItemAt(theDataLine, idx);
			self.tblData.accessRow(idx).itemObject := theRateEntry;
		endif;
	endif;
epilog
	app.setChargeRateEffectiveDate( savedChargedEffTS );	//19 Sep 2012	NDL	Par 30375
end;</source>
        <Parameter name="_event" type="Integer"/>
        <Parameter name="_noteobj" type="CM_Object"/>
        <Parameter name="_obj" type="CM_Object"/>
    </JadeMethod>
    <JadeMethod name="validateNewValue" id="a1f4fc11-291f-461d-b0ba-f4484a6ba74b">
        <updating/>
        <source>validateNewValue() : Boolean updating;
/*

Purpose:			validate percentage or adjustment to base entry

Parameters:			

Return Value:		false if entered values fail the validation

Date		Who		Reason
17/09/2012	cnwndl1	Initial creation	Par 30375, modified 30456
24/05/2016	cnwns1	TFS 488 - Multi Timezone Support
28/03/2018	jlgdap1	TFS 37794 PEL1 Vessel Rates
// 07 Jun 2018  cnwma1		ChangeRequest 38953: PEL1 - Berth Rates, Vessel Type Rates, Visit Types
*/

vars

	default : CM_RateEntry;
	bank : CM_Bank;
	ts,tsLocal : TimeStamp;
//	percent : Decimal [9,4];
	// 32672 handle maximum of 6 decimals in the rate
//	value : Decimal [16,6];
//	baseRate : Decimal [16,6]; 
	percent : Decimal [13,4];	//10 May 2018	NDL	TFS 38528
	value : Decimal [23,6];//10 May 2018	NDL	TFS 38528
	baseRate : Decimal [23,6]; //10 May 2018	NDL	TFS 38528

begin
	
	ts := app.actualTimeServer;
	
	if self.optRatePercent.value or
	   self.optRateAdjust.value then
		value := self.txtCostAdjust.text.asDecimalJMT;
		default := self.myBaseRateEntry;
		if default = null then
			tsLocal.cnEcSetDateAndTime(self.txtRateDate.getDate, self.txtRateTime.getTime);		// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
			ts.cnEcSetDateAndTime(self.effectiveDate, self.localToSystemTime(tsLocal).time());	// 24 May 2016	cnwns1	TFS 488 - Multi Timezone Support
				
			//if self.myCurrentLineGroupDebtor = null then		// TFS 37794
			if self.modeDisplay = self.Mode_Debtor  
				or self.modeDisplay = self.Mode_Vessel
				or self.modeDisplay = self.Mode_VesselType
				or self.modeDisplay = self.Mode_VisitType
				or self.modeDisplay = self.Mode_Berth then
					bank := self.myCurrentDebtor.bank;
			else
				if self.myCurrentLineGroupDebtor &lt;&gt; null and self.myCurrentLineGroupDebtor.debtor &lt;&gt; null then
					bank := self.myCurrentLineGroupDebtor.debtor.bank;
				endif;
			endif;
			if bank &lt;&gt; null then
				default := bank.getRootDebtorGroup.getServiceTimeRate(self.myCurrentService, ts);
			endif;
		endif;
		
		if default = null then
			app.msgBox(app.getErrorString(Base_rate_found_adjust), app.getErrorString(Error), MsgBox_OK_Only );
			return false;
		endif;
		if self.optRatePercent.value then
			percent := self.txtCostPercent.text.asDecimalJMT;
			if percent &lt; -100 then	// 31732
				app.msgBox(app.getErrorString(Percent_more_neg_100_not_poss), app.getErrorString(Error), MsgBox_OK_Only );
				return false;
			endif;
			if percent &gt; 9999 then // PAR 31662
				app.msgBox(app.getErrorString(Perce_great_than_9999_not_poss), app.getErrorString(Error), MsgBox_OK_Only );
				return false;
			endif;
		else
			baseRate := default.getDerivedCostPerUnit( ts );
			if(  baseRate + value ) &lt; 0 then
				app.msgBox(app.getErrorString(Adjust_plus_base_LessThan_zero), app.getErrorString(Error), MsgBox_OK_Only );
				return false;
			endif;
		endif;
	else
		value := self.txtCostPerUnit.text.asDecimalJMT;
	endif;

	return true;
epilog

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
</GUIClass>
