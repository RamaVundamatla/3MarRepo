    <JadeMethod name="setForUpdate" id="7b1e49c5-b4c1-4ffb-9a81-7854fb62f6d5">
        <updating/>
        <source>setForUpdate(_proxyEDITI: SelfType) updating;
//
//19 Sep 2012	cnwrs1		CCMS SFW 1290 Transaction file
//
vars
	prop : Property;
	propDict : PropertyNDict;
begin
	inheritMethod(_proxyEDITI);
	
	propDict := self.class.getProperties;
	foreach prop in propDict do
		if self.canUserSet(prop.name) then
			// bypass all type integrity checking in the name of convenience!!!
			self.setPropertyValue(prop.name, _proxyEDITI.getPropertyValue(prop.name));
		endif;
	endforeach;
end;
</source>
        <Parameter name="_proxyEDITI" type="SelfType"/>
    </JadeMethod>
    <JadeMethod name="setMeasurementTypeValue" id="a27f305b-4875-4e23-acec-cffd79e4a065">
        <updating/>
        <source>setMeasurementTypeValue(_columnName: String; _value: String) : Boolean updating;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
04 September 2014	cnwmc5	Initial creation	PAR 34533

*/

vars
	rowName,
	measureType		: String;
	
begin

	if not inheritMethod(_columnName, _value) then
		return false;
	endif;
	
	_columnName.getRowNameMeasureType(rowName, measureType);
	
	if rowName = ETRow_TotalWeight then
		self.weight := app.convertMeasurementForStorage(measureType, _value.asDecimalJMT());
		return true;
	endif;
	
	if self.class.getPropertyInHTree(rowName) &lt;&gt; null then
		self.setPropertyValue(rowName, app.convertMeasurementForStorage(measureType, _value.asDecimalJMT()));
	endif;
	
	return true;
	
epilog

end;</source>
        <Parameter name="_columnName" type="String"/>
        <Parameter name="_value" type="String"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="setupCMIF" id="69f95bca-5873-460b-964b-6585af7f04e7">
        <source>setupCMIF(_cmif : CMIF_TITransactionController input; _ti : CM_TrackedItem);
//
//19 Sep 2012	cnwrs1		CCMS SFW 1290 Transaction file
// 04 Mar 2019	jlgrs1	TFS 41913 STWR - Reconfiguration of the EDI Operation form to better handle EDI collection locks while loading 
//
vars

begin
	_cmif.dateTime := self.transactionTime;
	_cmif.type := self.transactionType;
	_cmif.operatorCode := self.operatorCode;
	_cmif.myTerminal := self.getMyTerminal();
	_cmif.myTrackedItem := _ti;
	_cmif.noCharge := not self.chargeable;
end;
</source>
        <Parameter name="_cmif" type="CMIF_TITransactionController" usage="input"/>
        <Parameter name="_ti" type="CM_TrackedItem"/>
    </JadeMethod>
    <JadeMethod name="verifyContractId" id="d70cb5a5-fd6e-4e7d-ae21-3abf49577cce">
        <source>verifyContractId();
/*

Purpose:			
		This method validatest the Contract Id entered in the Transaction.
		
		If Operator code is entered, use that to get the Debtor, then look up the Contract from the collection in either Terminal or Bank (depending on which one is available)
		by the Contract Id and Debtor
		
		If Operator code is not entered, look up the Contract ID from the collection in either Terminal or Bank (depending on which one is available) 
		by the Contract Id and current timestamp
		
Parameters:			

Return Value:		

Date		Who		Reason
16 January 2023	navkc1	Initial creation TFS CR 55625 TASK 55660 Task 55660: Jade - Contract Id EDI TRX
24 Nov 2023 navrv30 #61154: FR | 54089 - EUP - Invoice Contracts - EDI upload for Contract ID
*/

vars
	terminal			: CM_Terminal;
	operator			: CM_Operator;
	debtor				: CM_Debtor;
	bank				: CM_Bank;
	allContractsById 	: CM_InvoiceContractByIdDebtor;
	allContractsByTs	: CM_InvoiceContractByToTS;
	contract			: CM_InvoiceContract;
	root				: CM_Root;
	contractIdString,
	operatorCodeString,
	bankCodeString		: String;
	
begin
	contractIdString := self.contractIdForTIstring;
	if contractIdString = null then
		return;
	endif;
	
	terminal := self.getMyTerminal();
	if terminal = null then
		return;
	endif;
	
	allContractsById := terminal.allInvoiceContractsById;
	if allContractsById.isEmpty() then
		return;
	endif;
	
	root := app.myRoot;
	if root = null then
		return;
	endif;
	
	operatorCodeString := self.operatorCode;
	operator := root.allOperators[operatorCodeString];
	if operator &lt;&gt; null then
		debtor := operator.debtor;
	endif;

	bankCodeString := self.companyCode;
	if bankCodeString &lt;&gt; null then
		bank := terminal.companies[bankCodeString];		
	endif;
	
	// We have a debtor, look up the Contract using the Debtor
	if debtor &lt;&gt; null then
		if bank &lt;&gt; null then
			allContractsById := bank.allInvoiceContractsById;
		else
			allContractsById := terminal.allInvoiceContractsById;
		endif;
		
		contract := allContractsById.getAtKey(contractIdString, debtor);
	// We dont have a debtor, look up the Contract using the current timestamp
	else
		if bank &lt;&gt; null then
			allContractsByTs := bank.allInvoiceContractsByToTS;
		else
			allContractsByTs := terminal.allInvoiceContractsByToTS;
		endif;
		
		contract := allContractsByTs.getAtKey(app.actualTime());
	endif;
	
	if contract = null then
		if debtor &lt;&gt; null then
			app.raiseCMException2(Contract_not_found_for_debtor, contractIdString, debtor.name, null, self);               //24 Nov 2023 navrv30 #61154
		else
			app.raiseCMException2(Contract_not_found_for_debtor, contractIdString, "Operator/Debtor not defined", null, self);   //24 Nov 2023 navrv30 #61154
		endif;
		return;
	endif;
	
epilog

end;</source>
    </JadeMethod>
</Class>
