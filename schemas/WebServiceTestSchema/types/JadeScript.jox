    <JadeMethod name="rol201" id="f1284da4-0411-4241-9fac-f10b3186530a">
        <source>rol201();

// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support

vars
	tempStr				: String;
	stringValue			: String;
	binaryMsg			: Binary;
	startTS				: TimeStamp;
	endTS				: TimeStamp;
	interval			: TimeStampInterval;
	
begin
	startTS		:= app.actualTimeServer;// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	tempStr		:= CrLf &amp; 'Starting ' &amp; method.qualifiedName &amp; Tab &amp; startTS.display;
	write tempStr;
	
	app.initialize;
	
	// take the string
	tempStr	:=
"BOL, Booking, cargo subtype, cargo desc, carrier, commodity, commodity desc, company, consignee, consignor, cust seal, dest, discharge, hazardous, height, humidity, Id, IMEX status, ISO type, Length, Load, location, Op, Op Seal, Qty, Received Date, Remarks, Shipper seal, ignored, Temp, UNDG Code, Ventilation, Volume, Voyage, Total Weight, Width, Availability grade
BOL, Booking, , , CROWN, WOOL, , , AGGR, ADST, cust seal, AUSYD, AUSYD, , height, humidity, Web1001, Export, 2200, Length, NZLYT, location, C3, Op Seal, Qty, Received Date, Remarks, Shipper seal, ignored, -273, , Ventilation, Volume, QPA, 2000, Width, Availability grade";
	
	write tempStr.display;
	
	// make it binary
	binaryMsg	:= tempStr.Binary;
	write binaryMsg.display;
	
//	// and encode this binary - this is what gets passed via the web message
	tempStr		:= CrLf &amp; binaryMsg.base64Encode();
	write tempStr;
	
epilog
	endTS		:= app.actualTimeServer;// 17 May 2016	cnwns1	TFS 488 - Multi Timezone Support
	interval	:= endTS - startTS;
	tempStr		:=	CrLf &amp; 'Approximate time taken' &amp; Tab &amp; interval.display &amp;
					CrLf &amp; 'Finished ' &amp; method.qualifiedName &amp; Tab &amp; endTS.display;
	write tempStr;
	
end;
