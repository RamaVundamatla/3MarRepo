			  "code": "ZMMR",
              "name": "Zimmer"
            },
            "iD": "1",
            "keyMarks": "'&amp;_cargoGroupID&amp;'",
            "reference": "HB 450 6000x2500x12.00",
            "grade": "HB 450",
            "remarks": "117404/ZI643361D",
            "width": 2500,
            "length": 6000,
            "thickness": 12,
            "piecesPerPack": 1,
            "type": "Breakbulk",
            "cargoType": "CANNONBALL",
            "packageType": "12POUNDER-6",
            "quantityExpected": 2,
            "grossWeightExpected": 1826,
            "nettWeightExpected": 1826,
            "weightUOM": "Kg",
			"storageLocation": "' &amp; _location &amp; '",
            "buyer": {
              "name": "Zimmer"
            },
            "customs": true,
			"instruction": {
			  "code": "Clean",
