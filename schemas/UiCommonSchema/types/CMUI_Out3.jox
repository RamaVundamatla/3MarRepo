    <JadeMethod name="clearAll" id="a88f7080-ac8c-474d-9151-305e45ae7a96">
        <updating/>
        <source>clearAll(_all : Boolean) updating;
// ---------------------------------------------------------------------------
// Created:     19 June 2008 by cnwab1
//
// Purpose:     
//
// Parameters:  None
//
// Returns:     Nothing
//
// Changed On   	Changed By  	Reason
// ----------   	----------  	--------------------------------------------------
//
// ---------------------------------------------------------------------------

vars

begin

	if _all then
		self.frmPosTL.clearGraphics();
		self.frmPosTM.clearGraphics();
		self.frmPosTR.clearGraphics();
		self.frmPosML.clearGraphics();
		self.frmPosMM.clearGraphics();
		self.frmPosMR.clearGraphics();
		self.frmPosBL.clearGraphics();
		self.frmPosBM.clearGraphics();
		self.frmPosBR.clearGraphics();
		self.init();
	endif;
	
	self.clearGraphics();
epilog

end;</source>
        <Parameter name="_all" type="Boolean"/>
    </JadeMethod>
