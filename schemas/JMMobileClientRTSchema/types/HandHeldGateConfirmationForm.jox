    <JadeMethod name="doKeyDown" id="ec508e41-2998-480b-961b-4da0f9f1a7ae">
        <updating/>
        <source>doKeyDown(keyCode: Integer io; shift: Integer) updating;
/*
----------   ----------  --------------------------------------------------
Created:	13 September 2006 By cnwth2

Purpose:	

Changed On   Changed By  Reason
	
----------   ----------  --------------------------------------------------
*/
vars

begin
	if keyCode = J_key_F2 then
		if self.fldMain.topSheet = self.shtError then
			self.fldMain.topSheet := self.shtJobs;
			return;
		endif;
		//loop forward through pages
		if self.showingContainerNum &gt;= self.numButtons then
			return;//at the last page
		else
			self.showingContainerNum := self.showingContainerNum + 1;
			self.doShowFrmInfo(self.showingContainerNum);
		endif;
	elseif keyCode = J_key_F3 then
		if self.fldMain.topSheet = self.shtError then
			self.fldMain.topSheet := self.shtJobs;
			return;
		endif;
		
		//loop backward through pages
		if self.frmMain.visible then
			return;
		elseif self.showingContainerNum &lt;= 1 then
			self.doShowFrmMain();
		else
			self.showingContainerNum := self.showingContainerNum - 1;
			self.doShowFrmInfo(self.showingContainerNum);
		endif;
		
	elseif keyCode = J_key_F4 then		
		if self.frmContInfo.visible and self.btnDamage.enabled then
			self.doShowFrmDamage();
		elseif self.frmDamage.visible then
			self.doShowFrmInfo(self.showingContainerNum);
		endif;
	elseif keyCode = J_key_F5 then
		//do nothing - nothing to refresh
		
	elseif keyCode = J_key_Delete then
		if self.frmMain.visible then
			self.btnReject.click(self.btnReject);
		endif;
		
	else
		inheritMethod(keyCode, shift);
	endif;
	

end;


</source>
        <Parameter name="keyCode" type="Integer" usage="io"/>
        <Parameter name="shift" type="Integer"/>
    </JadeMethod>
