    <JadeMethod name="doDelete" id="caa8977f-2964-4cdb-92d2-914d4518b362">
        <updating/>
        <source>doDelete(): Boolean updating;
// -----------------------------------------------------------------------------
// Created:		14 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	invalidObj : Boolean;
begin

 on Exception do app.handleDeletedObject(exception, self.myObject.CM_CodeGroup, invalidObj); // cnwrd1 3.11.08 par 18090
 
	app.myTrxDA.trxDeleteCodeGroup(self.myObject.CM_CodeGroup,app.myPassport);
	return app.myPassport.trxCompletedOK();

end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="doSave" id="1bd4a216-361e-4950-80b8-8030835374bc">
        <updating/>
        <source>doSave(): Boolean updating;
// -----------------------------------------------------------------------------
// Created:		13 March 2002 by cnwka1
//
// Purpose:		
//
// Parameters:	None
//
// Returns:		Nothing
//
// Changed On	Changed By	Reason
// ----------	----------	---------------------------------------------
//
// -----------------------------------------------------------------------------
vars
	proxyLogSpecs	: CM_CodeGroupLogSpecs;
	newLogSpecs		: CM_CodeGroup;
begin
	if self.myForm.mode = self.myForm.Mode_Add then
		if self.myForm.myProxyObject &lt;&gt; null then
			self.myForm.myProxyObject.erase(NORMAL_ERASE);
		endif;
		
		create self.myForm.myProxyObject as CM_CodeGroupLogSpecs transient;
	endif;
	
	proxyLogSpecs := self.myForm.myProxyObject.CM_CodeGroupLogSpecs;
	
	proxyLogSpecs.setProxy(	self.myForm.currentGroupType, 
								self.myForm.tblInput1.getValueByName('name').String.removeTabCrLfs(),	// 18/04/2013 cnwar2 #27130
								app.myRoot);
								
	if self.myForm.mode = self.myForm.Mode_Add then
		app.myTrxCA.trxCreateCodeGroup(proxyLogSpecs, newLogSpecs,app.myPassport);
		if app.myPassport.trxCompletedOK then
			self.myObject := newLogSpecs;
		endif;
	elseif self.myForm.mode = self.myForm.Mode_Update then
		app.myTrxUA.trxUpdateCodeGroup(proxyLogSpecs, app.myPassport);
	else
		app.raiseUnexpectedProgramError(class.name, method.name, '  Invalid mode (' &amp; self.myForm.mode.String &amp; ')');
	endif;
	
	self.myForm.myProxyObject 	:= proxyLogSpecs;
	return app.myPassport.trxCompletedOK();
	
end;</source>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="getPeerClass" id="6dae89ee-77b6-4c23-a9db-1ad3adecff41">
