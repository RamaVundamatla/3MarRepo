    <JadeMethod name="translateForm" id="9bd49862-9682-4bc8-9395-b494c287cb5f">
        <updating/>
        <source>translateForm() updating;
	// This method implements user-defined locale-based text translation for forms.
	// Created on 11 July 2024 10:35:44.
vars
	locale : CM_Locale;
begin
	// Determine the locale for translations.
	locale := app.myCurrentLocale;
	if locale = null then
		locale := app.myRoot.getLocale(StandardTextLocale.padLeadingWith("0", 4), false);
		// if no locale the bail out at this point
		if locale = null then
			return;
		endif;
	endif;
	// The inheritMethod call invokes text translation for controls defined on superforms.
	inheritMethod;
	
	// The following code invokes text translation for controls defined on this form.
	self.translateCaption(Xlat_0025560, locale);
	btnClose.translateCaption(Xlat_0025561, locale);
	btnFindCargo.translateCaption(Xlat_0025562, locale);
	btnFindCargoMultiple.translateCaption(Xlat_0026511, locale);
	btnNext.translateCaption(Xlat_0025563, locale);
	btnOk.translateCaption(Xlat_0025564, locale);
	chkAddAllItems.translateCaption(Xlat_0026828, locale);
	chkMultipleItems.translateCaption(Xlat_0026512, locale);
	grpItems.translateCaption(Xlat_0025997, locale);
	grpVbsSlotItems.translateCaption(Xlat_0025569, locale);
	lblBooking.translateCaption(Xlat_0025998, locale);
	lblBookingItem.translateCaption(Xlat_0025999, locale);
	lblCargo.translateCaption(Xlat_0026000, locale);
	lblCargoId.translateCaption(Xlat_0026001, locale);
	lblDirection.translateCaption(Xlat_0025567, locale);
	lblMaxWeight.translateCaption(Xlat_0026898, locale);
	lblQuantity.translateCaption(Xlat_0025565, locale);
	lblReleaseReq.translateCaption(Xlat_0026002, locale);
	lblReserveDetails.translateCaption(Xlat_0026003, locale);
	lblSource.translateCaption(Xlat_0025568, locale);
	lblVolume.translateCaption(Xlat_0026092, locale);
	lblWeight.translateCaption(Xlat_0026004, locale);
	mnuColumnOrganiser.translateCaption(Xlat_0026005, locale);
	mnuVBSItem.translateCaption(Xlat_0026006, locale);
	optBtnBooking.translateCaption(Xlat_0026007, locale);
	optBtnCargo.translateCaption(Xlat_0026008, locale);
	optBtnDelivery.translateCaption(Xlat_0026009, locale);
	optBtnPickUp.translateCaption(Xlat_0026010, locale);
	optBtnRR.translateCaption(Xlat_0026011, locale);
end;</source>
    </JadeMethod>
