    <JadeMethod name="getDisplayStringForAttribute" id="e86e3fb2-d4c3-4787-bbb4-27b6eb7de40d">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2023 navma1  ChangeRequest 57766: EUP - Delivery Dispatch – Define Job Sheet
22 May 2023 navhl20 ChangeRequest 57714:[57764] EUP - Delivery Dispatch – Gate
23 May 2023 navhl20	Defect 58115: MTN - 1090 exception when editing the work point job sheet
30 May 2023 navhl20 ChangeRequest 57747:[57748] EUP - Delivery Dispatch – Allocate Jobs to Gangs
07 Jun 2023 navhl20 ChangeRequest 58543: EUP - Delivery Dispatch – Allocation List - VAS
12 Jun 2023 navhl20 ChangeRequest 56777: EUP | LMS Gang API - Additional Attribute
*/

vars
	workPoint : CM_WorkPoint;
begin
	if _attrName = ETRow_Type then
		workPoint := self.myWorkPoint;
		if workPoint &lt;&gt; null and workPoint.myWorkPointType &lt;&gt; null then			//23.5.2023 navhl20 #58115
			return app.getWorkPointTypeString(workPoint.myWorkPointType.type);
		endif;
		return null;
	elseif _attrName = ETRow_Name then
		return self.externalName;												//22.5.2023 navhl20 #57714:[57764]
	elseif _attrName = ETRow_Jobs then
		return self.getJobs();													//30.5.2023 navhl20 #57747:[57748]
	elseif _attrName = ETRow_Locations then
		return self.getLocations();
	elseif _attrName = ETRow_Shift then											//07.6.2023 navhl20 #58543
		return self.getShift();
	elseif _attrName = ETRow_ExternalRef1 then									//12.6.2023 navhl20 #56777
		return self.externalReference1;
	elseif _attrName = ETRow_ExternalRef2 then									//12.6.2023 navhl20 #56777
		return self.externalReference2;
	elseif _attrName = ETRow_ExternalRef3 then									//12.6.2023 navhl20 #56777
		return self.externalReference3;
	else
		return inheritMethod(_attrName, _short);
	endif;

epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getJobs" id="fdb99aa8-b102-4a9c-a110-eb41ab26e2ff">
        <source>getJobs():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
31 May 2023	navhl20	ChangeRequest 57747:[57748] EUP - Delivery Dispatch – Allocate Jobs to Gangs
25 Feb 2025 navma1  MTN-34075 MTN | Dead Lock (1081) on CM_JobsByPriorityRequiredDT
*/

vars
	job 	: CM_Job;
	count	: Integer;
begin

	count := self.allJobsByPriorityRequiredDT.size;
	return count.asStringJMT;
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getLocations" id="53e62a18-4cde-4f2c-8def-e19b5b5cbaf0">
        <source>getLocations():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
07 Jun 2023	navhl20	ChangeRequest 57747:[57748] EUP - Delivery Dispatch – Allocate Jobs to Gangs
25 Feb 2025 navma1  MTN-34075 MTN | Dead Lock (1081) on CM_JobsByPriorityRequiredDT
*/

vars
	job 	 : CM_Job;
	str		 : String;
	location : String;
	jobDict  : CM_JobsByPriorityRequiredDT;
begin
	
	create jobDict transient;
	self.allJobsByPriorityRequiredDT.copy(jobDict);
	
	foreach job in jobDict discreteLock do				//25.02.2025 navma1 #MTN-34075

		location := job.plannedLocation;				//26/08/2024	navkc1 CR 63588 Task 63589
		if location &lt;&gt; null then
			if str = null then
				str := str &amp; location;
			elseif not str.cnContains(location) then
				str := str &amp; Comma &amp; location;
			endif;
		endif;
	endforeach;
	
	return str;
epilog
	delete jobDict;
end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getNiceName" id="66f1c774-2f1d-4bb0-a6d0-b6a809608007">
        <source>getNiceName(): String;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes

*/

vars

begin
	return app.getErrorString(Work_point) &amp; " " &amp; self.externalName;

epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="getShift" id="8d3e11ae-953e-4692-bcb7-285ed4a5504c">
        <source>getShift():String;
/*

Purpose:			

Parameters:			

Return Value:		

Date   Who		Reason
07 Jun 2023		navhl20	ChangeRequest 58543: EUP - Delivery Dispatch – Allocation List - VAS
13 Jun 2023		Defect 58616: MTN - 1090 Exception when clicking on Work Order Operations form
06 Mar 2025 	navma1  MTN-34179 MTN | Dead Lock (1081) on CM_WLEArray
*/

vars
	shift : CM_Shift;
begin
	
	shift := self.myShift;
	
	if shift = null then	//13.06.2023 navma1 #58616
		return null;
	endif;
	
	return shift.getShiftDay() &amp; Space &amp; shift.code &amp; Space &amp; shift.startDateTime.date.asStringJMT();
epilog

end;</source>
        <ReturnType type="String"/>
    </JadeMethod>
    <JadeMethod name="isMatchingForVoyage" id="5369176a-cac1-444b-b313-d1e035a91cf2">
        <source>isMatchingForVoyage(_voyage : CM_Voyage):Boolean;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
01 Dec 2023 navhl20 ChangeRequest 58400:[61617] EUP | Ship Operations in DD - [54176.050] Mobile App changes
25 Feb 2025 navma1  MTN-34075 MTN | Dead Lock (1081) on CM_JobsByPriorityRequiredDT
*/

vars
	job		: CM_Job;
	voyage	: CM_Voyage;
	jobDict : CM_JobsByPriorityRequiredDT;
begin
	
	create jobDict transient;
	self.allJobsByPriorityRequiredDT.copy(jobDict);
	
	foreach job in jobDict  discreteLock where job.isVoyageWorkpointJob do		//25.02.2025 navma1 #MTN-34075
		voyage := job.CM_VoyageWorkPointJob.myVoyage;
		if voyage &lt;&gt; null and voyage = _voyage then
			return true;
		endif;
	endforeach;
	return false;
epilog
	delete jobDict;
end;</source>
        <Parameter name="_voyage" type="CM_Voyage"/>
        <ReturnType type="Boolean"/>
    </JadeMethod>
    <JadeMethod name="pxyCreateUpdateProxy" id="d7718173-ed30-465a-b277-f2a1a53b293e">
        <source>pxyCreateUpdateProxy(): SelfType;
/*

Purpose:			

Parameters:			

Return Value:		

Date		Who		Reason
12 May 2023 navma1  ChangeRequest 57766: EUP - Delivery Dispatch – Define Job Sheet

*/

vars
	proxy			: SelfType;
	completedOK		: Boolean;
begin
	

	proxy := inheritMethod();

	proxy.myShift 	  := self.myShift;
	proxy.myTerminal  := self.myTerminal;
	proxy.myWorkPoint := self.myWorkPoint;
	
	
	completedOK := true;			
	return proxy;
	
epilog
	if not completedOK then			
		delete proxy;
	endif;
end;</source>
        <ReturnType type="SelfType"/>
    </JadeMethod>
