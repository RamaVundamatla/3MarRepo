    <JadeMethod name="getDisplayStringForAttribute" id="9ac1cb7e-7d8c-4bdc-9f87-c6e0ee9039a0">
        <source>getDisplayStringForAttribute(_attrName: String; _short: Boolean): String;
/*

Purpose:			


Return Value:		


Date		Who		Reason
17 Sep 2007	cnwer1	Initial creation - PAR#xxxx
13 Apr 2016	cnwkpd1	TFS 488 - Multi Timezone Support
07 Jul 2020 cnwma1  Bug 49710: SNO -- Error 1090 when searching under the Fault Enquiry screen
*/

vars

begin
	if _attrName = ETRow_WhenReported then
		return self.systemToLocalTime(self.reportedTS).asStringJMT;
	elseif _attrName = ETRow_Machine then
		if self.myMachine &lt;&gt; null then
			return self.myMachine.getDisplayDetails(false);
		endif;
		return null;
	elseif _attrName = ETRow_EnteredBy then
		if self.myEnteredByUser &lt;&gt; null then
			return self.myEnteredByUser.code;
		endif;
	elseif _attrName = ETRow_ReportedBy then
		if self.myReportedByUser &lt;&gt; null then
			return self.myReportedByUser.code;
		endif;
	elseif _attrName = ETRow_Status then
		// 34387 can have null status, possibly from no default status defined
		if self.myFaultStatus &lt;&gt; null then
			return self.myFaultStatus.description;
		endif;
		return null;
	elseif _attrName  = ETRow_FaultType then
		if self.myFaultType &lt;&gt; null then 
			return self.myFaultType.description; 
		endif;
		return null;
	elseif _attrName = ETRow_FaultResponse then
		if self.myFaultResponse &lt;&gt; null then
			return self.myFaultResponse.response;
		endif;
		return null;
	elseif _attrName = ETRow_MachineType then
		if self.myMachine &lt;&gt; null then
			return self.myMachine.machineTypeString;
		endif;
		return null;
	elseif _attrName = ETRow_AdditionalDetails then
		return self.additionalDetails.removeTabCrLfs;
	elseif _attrName = ETRow_ResolutionDetails then
		return self.resolutionDetails.removeTabCrLfs;
	elseif _attrName = ETRow_FaultStatusCode then
		if self.myFaultStatus &lt;&gt; null then
			return self.myFaultStatus.code;
		endif;
		return null;
	else	

		return inheritMethod(_attrName, _short);
	endif;
epilog

end;</source>
        <Parameter name="_attrName" type="String"/>
        <Parameter name="_short" type="Boolean"/>
        <ReturnType type="String"/>
    </JadeMethod>
