    <JadeMethod name="getMachinePrecidence" id="7d70f6ed-a31c-48dc-b3e3-93b343933f57">
        <source>getMachinePrecidence(): Integer;

vars

begin
	if self.machineType = MACHINE_CRANE then
		return 1;
	endif;
	
	if self.machineType = MACHINE_MOVER then
		return 2;
	endif;
	
	return 3;
	
epilog

end;</source>
        <ReturnType type="Integer"/>
    </JadeMethod>
